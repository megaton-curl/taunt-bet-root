{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QLpUycn7JfvjayvwhwpBoJ","type":"tool_result","content":"1\t/**\n2\t * Fee accounting ledger — durable allocation/debit trail used by the audit\n3\t * snapshot, checkpoint generator, and the referral claim hot path.\n4\t *\n5\t * Spec: docs/specs/306-fee-accounting-audit/spec.md\n6\t *\n7\t * Tables:\n8\t *   - fee_allocation_events   (immutable per-fee allocation rows)\n9\t *   - fee_bucket_debits       (bucket spend lifecycle, e.g. referral claims)\n10\t *   - fee_audit_checkpoints   (acceleration snapshots; written by a separate\n11\t *                              generator in a later iteration)\n12\t */\n13\t\n14\timport type postgres from \"postgres\";\n15\t\n16\t// ---------------------------------------------------------------------------\n17\t// Types\n18\t// ---------------------------------------------------------------------------\n19\t\n20\texport type FeeBucket = \"referral\" | \"promotions\" | \"profit\";\n21\t\n22\texport type FeeBucketDebitStatus =\n23\t  | \"pending\"\n24\t  | \"processing\"\n25\t  | \"error\"\n26\t  | \"completed\"\n27\t  | \"failed\";\n28\t\n29\texport interface FeeAllocation {\n30\t  /** Floor split of `feeLamports * referralRateBps / 10000`. */\n31\t  referralLamports: number;\n32\t  /** Floor split of the post-referral remainder × 20%. */\n33\t  promotionsLamports: number;\n34\t  /** Profit absorbs all rounding dust so the three components sum to the fee. */\n35\t  profitLamports: number;\n36\t}\n37\t\n38\texport interface InsertFeeAllocationParams {\n39\t  sourceType: string;\n40\t  sourceId: string;\n41\t  gameType: string;\n42\t  wallet: string;\n43\t  userId?: string | null;\n44\t  wagerLamports: number;\n45\t  feeLamports: number;\n46\t  referrerUserId?: string | null;\n47\t  referralRateBps: number;\n48\t  referralLamports: number;\n49\t  promotionsLamports: number;\n50\t  profitLamports: number;\n51\t}\n52\t\n53\texport interface InsertFeeBucketDebitParams {\n54\t  bucket: FeeBucket;\n55\t  debitType: string;\n56\t  sourceId: string;\n57\t  userId?: string | null;\n58\t  wallet?: string | null;\n59\t  amountLamports: number | string;\n60\t  status?: FeeBucketDebitStatus;\n61\t}\n62\t\n63\texport interface FeeAllocationEventRow {\n64\t  id: number;\n65\t  source_type: string;\n66\t  source_id: string;\n67\t  game_type: string;\n68\t  wallet: string;\n69\t  user_id: string | null;\n70\t  wager_lamports: number;\n71\t  fee_lamports: number;\n72\t  referrer_user_id: string | null;\n73\t  referral_rate_bps: number;\n74\t  referral_lamports: number;\n75\t  promotions_lamports: number;\n76\t  profit_lamports: number;\n77\t  created_at: Date;\n78\t}\n79\t\n80\texport interface FeeBucketDebitRow {\n81\t  id: number;\n82\t  bucket: FeeBucket;\n83\t  debit_type: string;\n84\t  source_id: string;\n85\t  user_id: string | null;\n86\t  wallet: string | null;\n87\t  amount_lamports: number;\n88\t  status: FeeBucketDebitStatus;\n89\t  created_at: Date;\n90\t  updated_at: Date;\n91\t}\n92\t\n93\texport interface FeeAuditBucketSummary {\n94\t  /** Sum of `*_lamports` from `fee_allocation_events`. */\n95\t  allocated: string;\n96\t  /** Debits with status pending|processing|error. */\n97\t  activeDebits: string;\n98\t  /** Debits with status completed. */\n99\t  completedDebits: string;\n100\t  /** Pending/processing/error debits where `debit_type='claim'`. */\n101\t  pendingClaimReserves: string;\n102\t  /** Debits with status failed (excluded from the available calculation). */\n103\t  failedDebits: string;\n104\t  /** allocated − activeDebits − completedDebits. */\n105\t  available: string;\n106\t}\n107\t\n108\texport interface FeeAuditSnapshot {\n109\t  totals: {\n110\t    feeLamports: string;\n111\t    allocationCount: number;\n112\t    debitCount: number;\n113\t  };\n114\t  buckets: {\n115\t    referral: FeeAuditBucketSummary;\n116\t    promotions: FeeAuditBucketSummary;\n117\t    profit: FeeAuditBucketSummary;\n118\t  };\n119\t  /** Rows where allocation components do not sum to `fee_lamports`. */\n120\t  invariantViolations: Array<{\n121\t    sourceType: string;\n122\t    sourceId: string;\n123\t    wallet: string;\n124\t    feeLamports: string;\n125\t    componentsSum: string;\n126\t  }>;\n127\t  /** Buckets where active+completed debits exceed allocated balance. */\n128\t  overdrawnBuckets: FeeBucket[];\n129\t  /** Earliest `created_at` in the allocation ledger; null when empty. */\n130\t  auditFrom: Date | null;\n131\t}\n132\t\n133\t// ---------------------------------------------------------------------------\n134\t// Pure helper\n135\t// ---------------------------------------------------------------------------\n136\t\n137\t/**\n138\t * Deterministic, integer-safe split of a settled fee into the three virtual\n139\t * buckets. Profit absorbs all rounding dust so the components always sum to\n140\t * `feeLamports`. Mirrors the DB CHECK on `fee_allocation_events`.\n141\t */\n142\texport function calculateFeeAllocation(\n143\t  feeLamports: number,\n144\t  referrerRateBps: number,\n145\t): FeeAllocation {\n146\t  if (!Number.isFinite(feeLamports) || !Number.isInteger(feeLamports) || feeLamports < 0) {\n147\t    throw new Error(`calculateFeeAllocation: feeLamports must be a non-negative integer (got ${feeLamports})`);\n148\t  }\n149\t  if (\n150\t    !Number.isFinite(referrerRateBps) ||\n151\t    !Number.isInteger(referrerRateBps) ||\n152\t    referrerRateBps < 0 ||\n153\t    referrerRateBps > 10000\n154\t  ) {\n155\t    throw new Error(\n156\t      `calculateFeeAllocation: referrerRateBps must be an integer in [0, 10000] (got ${referrerRateBps})`,\n157\t    );\n158\t  }\n159\t\n160\t  const referralLamports = Math.floor((feeLamports * referrerRateBps) / 10000);\n161\t  const postReferral = feeLamports - referralLamports;\n162\t  const promotionsLamports = Math.floor((postReferral * 2000) / 10000);\n163\t  const profitLamports = feeLamports - referralLamports - promotionsLamports;\n164\t\n165\t  return { referralLamports, promotionsLamports, profitLamports };\n166\t}\n167\t\n168\t// ---------------------------------------------------------------------------\n169\t// Interface\n170\t// ---------------------------------------------------------------------------\n171\t\n172\tconst ACTIVE_DEBIT_STATUSES = [\"pending\", \"processing\", \"error\"] as const;\n173\tconst RESERVED_OR_SPENT_STATUSES = [\n174\t  \"pending\",\n175\t  \"processing\",\n176\t  \"error\",\n177\t  \"completed\",\n178\t] as const;\n179\t\n180\texport interface FeeAccountingDb {\n181\t  /**\n182\t   * Insert one allocation row. Idempotent on\n183\t   * `(source_type, source_id, wallet)` — duplicate calls are no-ops.\n184\t   * Returns the row, whether newly inserted or pre-existing.\n185\t   */\n186\t  insertFeeAllocation(params: InsertFeeAllocationParams): Promise<FeeAllocationEventRow>;\n187\t\n188\t  /**\n189\t   * Insert one bucket debit row. Idempotent on\n190\t   * `(bucket, debit_type, source_id)` — duplicate calls are no-ops.\n191\t   * Returns the row, whether newly inserted or pre-existing.\n192\t   */\n193\t  insertFeeBucketDebit(params: InsertFeeBucketDebitParams): Promise<FeeBucketDebitRow>;\n194\t\n195\t  /**\n196\t   * Update a debit's status (and bumps `updated_at`). Returns the updated row,\n197\t   * or `undefined` when the `(bucket, debit_type, source_id)` triple does not\n198\t   * exist.\n199\t   */\n200\t  updateFeeBucketDebitStatus(\n201\t    bucket: FeeBucket,\n202\t    debitType: string,\n203\t    sourceId: string,\n204\t    status: FeeBucketDebitStatus,\n205\t  ): Promise<FeeBucketDebitRow | undefined>;\n206\t\n207\t  /**\n208\t   * Lamports available across the global `referral` bucket.\n209\t   *\n210\t   * `sum(referral_lamports across all allocations)` minus\n211\t   * `sum(amount_lamports across referral debits with status pending|processing|error|completed)`.\n212\t   *\n213\t   * Returned as a lamport string, matching the `getPendingBalanceByUserId` shape\n214\t   * the claim hot path already consumes.\n215\t   */\n216\t  getReferralBucketAvailable(): Promise<string>;\n217\t\n218\t  /**\n219\t   * Lamports available to a specific referrer user.\n220\t   *\n221\t   * `sum(referral_lamports for allocations where referrer_user_id = userId)`\n222\t   * minus `sum(amount_lamports for referral debits with user_id = userId\n223\t   * and status pending|processing|error|completed)`.\n224\t   */\n225\t  getUserReferralAvailable(userId: string): Promise<string>;\n226\t\n227\t  /**\n228\t   * Reconciliation snapshot of the ledger. Treats\n229\t   * `pending|processing|error|completed` debits as reserved/spent and excludes\n230\t   * `failed` debits. Used by `GET /admin/fee-audit/snapshot`.\n231\t   */\n232\t  getFeeAuditSnapshot(): Promise<FeeAuditSnapshot>;\n233\t}\n234\t\n235\t// ---------------------------------------------------------------------------\n236\t// Factory\n237\t// ---------------------------------------------------------------------------\n238\t\n239\tfunction normalizeAllocationRow(row: FeeAllocationEventRow): FeeAllocationEventRow {\n240\t  return {\n241\t    ...row,\n242\t    wager_lamports: Number(row.wager_lamports),\n243\t    fee_lamports: Number(row.fee_lamports),\n244\t    referral_rate_bps: Number(row.referral_rate_bps),\n245\t    referral_lamports: Number(row.referral_lamports),\n246\t    promotions_lamports: Number(row.promotions_lamports),\n247\t    profit_lamports: Number(row.profit_lamports),\n248\t  };\n249\t}\n250\t\n251\tfunction normalizeDebitRow(row: FeeBucketDebitRow): FeeBucketDebitRow {\n252\t  return {\n253\t    ...row,\n254\t    amount_lamports: Number(row.amount_lamports),\n255\t  };\n256\t}\n257\t\n258\tfunction emptyBucketSummary(): FeeAuditBucketSummary {\n259\t  return {\n260\t    allocated: \"0\",\n261\t    activeDebits: \"0\",\n262\t    completedDebits: \"0\",\n263\t    pendingClaimReserves: \"0\",\n264\t    failedDebits: \"0\",\n265\t    available: \"0\",\n266\t  };\n267\t}\n268\t\n269\t\n270\texport function createFeeAccountingDb(sql: ReturnType<typeof postgres>): FeeAccountingDb {\n271\t  return {\n272\t    async insertFeeAllocation(params) {\n273\t      const rows = await sql<FeeAllocationEventRow[]>`\n274\t        INSERT INTO fee_allocation_events (\n275\t          source_type, source_id, game_type, wallet, user_id,\n276\t          wager_lamports, fee_lamports,\n277\t          referrer_user_id, referral_rate_bps,\n278\t          referral_lamports, promotions_lamports, profit_lamports\n279\t        ) VALUES (\n280\t          ${params.sourceType},\n281\t          ${params.sourceId},\n282\t          ${params.gameType},\n283\t          ${params.wallet},\n284\t          ${params.userId ?? null},\n285\t          ${params.wagerLamports},\n286\t          ${params.feeLamports},\n287\t          ${params.referrerUserId ?? null},\n288\t          ${params.referralRateBps},\n289\t          ${params.referralLamports},\n290\t          ${params.promotionsLamports},\n291\t          ${params.profitLamports}\n292\t        )\n293\t        ON CONFLICT (source_type, source_id, wallet) DO NOTHING\n294\t        RETURNING *\n295\t      `;\n296\t      if (rows[0]) return normalizeAllocationRow(rows[0]);\n297\t\n298\t      // Conflict — return the existing row so callers can rely on the\n299\t      // method's return type.\n300\t      const existing = await sql<FeeAllocationEventRow[]>`\n301\t        SELECT * FROM fee_allocation_events\n302\t        WHERE source_type = ${params.sourceType}\n303\t          AND source_id = ${params.sourceId}\n304\t          AND wallet = ${params.wallet}\n305\t      `;\n306\t      return normalizeAllocationRow(existing[0]!);\n307\t    },\n308\t\n309\t    async insertFeeBucketDebit(params) {\n310\t      const rows = await sql<FeeBucketDebitRow[]>`\n311\t        INSERT INTO fee_bucket_debits (\n312\t          bucket, debit_type, source_id, user_id, wallet, amount_lamports, status\n313\t        ) VALUES (\n314\t          ${params.bucket},\n315\t          ${params.debitType},\n316\t          ${params.sourceId},\n317\t          ${params.userId ?? null},\n318\t          ${params.wallet ?? null},\n319\t          ${params.amountLamports},\n320\t          ${params.status ?? \"pending\"}\n321\t        )\n322\t        ON CONFLICT (bucket, debit_type, source_id) DO NOTHING\n323\t        RETURNING *\n324\t      `;\n325\t      if (rows[0]) return normalizeDebitRow(rows[0]);\n326\t\n327\t      const existing = await sql<FeeBucketDebitRow[]>`\n328\t        SELECT * FROM fee_bucket_debits\n329\t        WHERE bucket = ${params.bucket}\n330\t          AND debit_type = ${params.debitType}\n331\t          AND source_id = ${params.sourceId}\n332\t      `;\n333\t      return normalizeDebitRow(existing[0]!);\n334\t    },\n335\t\n336\t    async updateFeeBucketDebitStatus(bucket, debitType, sourceId, status) {\n337\t      const rows = await sql<FeeBucketDebitRow[]>`\n338\t        UPDATE fee_bucket_debits\n339\t        SET status = ${status}, updated_at = now()\n340\t        WHERE bucket = ${bucket}\n341\t          AND debit_type = ${debitType}\n342\t          AND source_id = ${sourceId}\n343\t        RETURNING *\n344\t      `;\n345\t      return rows[0] ? normalizeDebitRow(rows[0]) : undefined;\n346\t    },\n347\t\n348\t    async getReferralBucketAvailable() {\n349\t      const rows = await sql<{ available: string }[]>`\n350\t        SELECT (\n351\t          COALESCE(\n352\t            (SELECT SUM(referral_lamports) FROM fee_allocation_events),\n353\t            0\n354\t          )\n355\t          - COALESCE(\n356\t              (\n357\t                SELECT SUM(amount_lamports)\n358\t                FROM fee_bucket_debits\n359\t                WHERE bucket = 'referral'\n360\t                  AND status IN ${sql(RESERVED_OR_SPENT_STATUSES)}\n361\t              ),\n362\t              0\n363\t            )\n364\t        )::TEXT AS available\n365\t      `;\n366\t      return rows[0]!.available;\n367\t    },\n368\t\n369\t    async getUserReferralAvailable(userId) {\n370\t      const rows = await sql<{ available: string }[]>`\n371\t        SELECT (\n372\t          COALESCE(\n373\t            (\n374\t              SELECT SUM(referral_lamports)\n375\t              FROM fee_allocation_events\n376\t              WHERE referrer_user_id = ${userId}\n377\t            ),\n378\t            0\n379\t          )\n380\t          - COALESCE(\n381\t              (\n382\t                SELECT SUM(amount_lamports)\n383\t                FROM fee_bucket_debits\n384\t                WHERE bucket = 'referral'\n385\t                  AND user_id = ${userId}\n386\t                  AND status IN ${sql(RESERVED_OR_SPENT_STATUSES)}\n387\t              ),\n388\t              0\n389\t            )\n390\t        )::TEXT AS available\n391\t      `;\n392\t      return rows[0]!.available;\n393\t    },\n394\t\n395\t    async getFeeAuditSnapshot() {\n396\t      const totalsRowsPromise = sql<\n397\t        {\n398\t          fee_total: string;\n399\t          referral_total: string;\n400\t          promotions_total: string;\n401\t          profit_total: string;\n402\t          allocation_count: string;\n403\t          audit_from: Date | null;\n404\t        }[]\n405\t      >`\n406\t        SELECT\n407\t          COALESCE(SUM(fee_lamports), 0)::TEXT          AS fee_total,\n408\t          COALESCE(SUM(referral_lamports), 0)::TEXT     AS referral_total,\n409\t          COALESCE(SUM(promotions_lamports), 0)::TEXT   AS promotions_total,\n410\t          COALESCE(SUM(profit_lamports), 0)::TEXT       AS profit_total,\n411\t          COUNT(*)::TEXT                                AS allocation_count,\n412\t          MIN(created_at)                               AS audit_from\n413\t        FROM fee_allocation_events\n414\t      `;\n415\t\n416\t      const debitRowsPromise = sql<\n417\t        {\n418\t          bucket: FeeBucket;\n419\t          status: FeeBucketDebitStatus;\n420\t          debit_type: string;\n421\t          sum_lamports: string;\n422\t          row_count: string;\n423\t        }[]\n424\t      >`\n425\t        SELECT\n426\t          bucket,\n427\t          status,\n428\t          debit_type,\n429\t          COALESCE(SUM(amount_lamports), 0)::TEXT AS sum_lamports,\n430\t          COUNT(*)::TEXT                          AS row_count\n431\t        FROM fee_bucket_debits\n432\t        GROUP BY bucket, status, debit_type\n433\t      `;\n434\t\n435\t      const violationsRowsPromise = sql<\n436\t        {\n437\t          source_type: string;\n438\t          source_id: string;\n439\t          wallet: string;\n440\t          fee_lamports: string;\n441\t          components_sum: string;\n442\t        }[]\n443\t      >`\n444\t        SELECT\n445\t          source_type,\n446\t          source_id,\n447\t          wallet,\n448\t          fee_lamports::TEXT  AS fee_lamports,\n449\t          (referral_lamports + promotions_lamports + profit_lamports)::TEXT\n450\t                              AS components_sum\n451\t        FROM fee_allocation_events\n452\t        WHERE referral_lamports + promotions_lamports + profit_lamports <> fee_lamports\n453\t      `;\n454\t\n455\t      const [totalsRows, debitRows, violationsRows] = await Promise.all([\n456\t        totalsRowsPromise,\n457\t        debitRowsPromise,\n458\t        violationsRowsPromise,\n459\t      ]);\n460\t\n461\t      const totalsRow = totalsRows[0]!;\n462\t\n463\t      const buckets = {\n464\t        referral: emptyBucketSummary(),\n465\t        promotions: emptyBucketSummary(),\n466\t        profit: emptyBucketSummary(),\n467\t      };\n468\t\n469\t      buckets.referral.allocated = totalsRow.referral_total;\n470\t      buckets.promotions.allocated = totalsRow.promotions_total;\n471\t      buckets.profit.allocated = totalsRow.profit_total;\n472\t\n473\t      let debitCount = 0;\n474\t      const accum: Record<FeeBucket, { active: bigint; completed: bigint; failed: bigint; pendingClaim: bigint }> = {\n475\t        referral: { active: 0n, completed: 0n, failed: 0n, pendingClaim: 0n },\n476\t        promotions: { active: 0n, completed: 0n, failed: 0n, pendingClaim: 0n },\n477\t        profit: { active: 0n, completed: 0n, failed: 0n, pendingClaim: 0n },\n478\t      };\n479\t\n480\t      for (const row of debitRows) {\n481\t        const amount = BigInt(row.sum_lamports);\n482\t        const count = Number(row.row_count);\n483\t        debitCount += count;\n484\t\n485\t        const target = accum[row.bucket];\n486\t        if (!target) continue;\n487\t\n488\t        if ((ACTIVE_DEBIT_STATUSES as readonly string[]).includes(row.status)) {\n489\t          target.active += amount;\n490\t          if (row.debit_type === \"claim\") target.pendingClaim += amount;\n491\t        } else if (row.status === \"completed\") {\n492\t          target.completed += amount;\n493\t        } else if (row.status === \"failed\") {\n494\t          target.failed += amount;\n495\t        }\n496\t      }\n497\t\n498\t      const overdrawnBuckets: FeeBucket[] = [];\n499\t      for (const bucket of [\"referral\", \"promotions\", \"profit\"] as const) {\n500\t        const allocated = BigInt(buckets[bucket].allocated);\n501\t        const { active, completed, failed, pendingClaim } = accum[bucket];\n502\t        const reservedOrSpent = active + completed;\n503\t        const available = allocated - reservedOrSpent;\n504\t\n505\t        buckets[bucket].activeDebits = active.toString();\n506\t        buckets[bucket].completedDebits = completed.toString();\n507\t        buckets[bucket].failedDebits = failed.toString();\n508\t        buckets[bucket].pendingClaimReserves = pendingClaim.toString();\n509\t        buckets[bucket].available = available.toString();\n510\t\n511\t        if (reservedOrSpent > allocated) overdrawnBuckets.push(bucket);\n512\t      }\n513\t\n514\t      const invariantViolations = violationsRows.map((row) => ({\n515\t        sourceType: row.source_type,\n516\t        sourceId: row.source_id,\n517\t        wallet: row.wallet,\n518\t        feeLamports: row.fee_lamports,\n519\t        componentsSum: row.components_sum,\n520\t      }));\n521\t\n522\t      return {\n523\t        totals: {\n524\t          feeLamports: totalsRow.fee_total,\n525\t          allocationCount: Number(totalsRow.allocation_count),\n526\t          debitCount,\n527\t        },\n528\t        buckets,\n529\t        invariantViolations,\n530\t        overdrawnBuckets,\n531\t        auditFrom: totalsRow.audit_from,\n532\t      };\n533\t    },\n534\t  };\n535\t}\n536\t"}]},"parent_tool_use_id":null,"session_id":"e8f1bae6-15c6-4afe-be7a-a60683b8f5b8","uuid":"af8b1f08-785b-477b-bda0-58834aa197eb","timestamp":"2026-05-01T20:23:27.274Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/db/fee-accounting.ts","content":"/**\n * Fee accounting ledger — durable allocation/debit trail used by the audit\n * snapshot, checkpoint generator, and the referral claim hot path.\n *\n * Spec: docs/specs/306-fee-accounting-audit/spec.md\n *\n * Tables:\n *   - fee_allocation_events   (immutable per-fee allocation rows)\n *   - fee_bucket_debits       (bucket spend lifecycle, e.g. referral claims)\n *   - fee_audit_checkpoints   (acceleration snapshots; written by a separate\n *                              generator in a later iteration)\n */\n\nimport type postgres from \"postgres\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type FeeBucket = \"referral\" | \"promotions\" | \"profit\";\n\nexport type FeeBucketDebitStatus =\n  | \"pending\"\n  | \"processing\"\n  | \"error\"\n  | \"completed\"\n  | \"failed\";\n\nexport interface FeeAllocation {\n  /** Floor split of `feeLamports * referralRateBps / 10000`. */\n  referralLamports: number;\n  /** Floor split of the post-referral remainder × 20%. */\n  promotionsLamports: number;\n  /** Profit absorbs all rounding dust so the three components sum to the fee. */\n  profitLamports: number;\n}\n\nexport interface InsertFeeAllocationParams {\n  sourceType: string;\n  sourceId: string;\n  gameType: string;\n  wallet: string;\n  userId?: string | null;\n  wagerLamports: number;\n  feeLamports: number;\n  referrerUserId?: string | null;\n  referralRateBps: number;\n  referralLamports: number;\n  promotionsLamports: number;\n  profitLamports: number;\n}\n\nexport interface InsertFeeBucketDebitParams {\n  bucket: FeeBucket;\n  debitType: string;\n  sourceId: string;\n  userId?: string | null;\n  wallet?: string | null;\n  amountLamports: number | string;\n  status?: FeeBucketDebitStatus;\n}\n\nexport interface FeeAllocationEventRow {\n  id: number;\n  source_type: string;\n  source_id: string;\n  game_type: string;\n  wallet: string;\n  user_id: string | null;\n  wager_lamports: number;\n  fee_lamports: number;\n  referrer_user_id: string | null;\n  referral_rate_bps: number;\n  referral_lamports: number;\n  promotions_lamports: number;\n  profit_lamports: number;\n  created_at: Date;\n}\n\nexport interface FeeBucketDebitRow {\n  id: number;\n  bucket: FeeBucket;\n  debit_type: string;\n  source_id: string;\n  user_id: string | null;\n  wallet: string | null;\n  amount_lamports: number;\n  status: FeeBucketDebitStatus;\n  created_at: Date;\n  updated_at: Date;\n}\n\nexport interface FeeAuditBucketSummary {\n  /** Sum of `*_lamports` from `fee_allocation_events`. */\n  allocated: string;\n  /** Debits with status pending|processing|error. */\n  activeDebits: string;\n  /** Debits with status completed. */\n  completedDebits: string;\n  /** Pending/processing/error debits where `debit_type='claim'`. */\n  pendingClaimReserves: string;\n  /** Debits with status failed (excluded from the available calculation). */\n  failedDebits: string;\n  /** allocated − activeDebits − completedDebits. */\n  available: string;\n}\n\nexport interface FeeAuditSnapshot {\n  totals: {\n    feeLamports: string;\n    allocationCount: number;\n    debitCount: number;\n  };\n  buckets: {\n    referral: FeeAuditBucketSummary;\n    promotions: FeeAuditBucketSummary;\n    profit: FeeAuditBucketSummary;\n  };\n  /** Rows where allocation components do not sum to `fee_lamports`. */\n  invariantViolations: Array<{\n    sourceType: string;\n    sourceId: string;\n    wallet: string;\n    feeLamports: string;\n    componentsSum: string;\n  }>;\n  /** Buckets where active+completed debits exceed allocated balance. */\n  overdrawnBuckets: FeeBucket[];\n  /** Earliest `created_at` in the allocation ledger; null when empty. */\n  auditFrom: Date | null;\n}\n\n// ---------------------------------------------------------------------------\n// Pure helper\n// ---------------------------------------------------------------------------\n\n/**\n * Deterministic, integer-safe split of a settled fee into the three virtual\n * buckets. Profit absorbs all rounding dust so the components always sum to\n * `feeLamports`. Mirrors the DB CHECK on `fee_allocation_events`.\n */\nexport function calculateFeeAllocation(\n  feeLamports: number,\n  referrerRateBps: number,\n): FeeAllocation {\n  if (!Number.isFinite(feeLamports) || !Number.isInteger(feeLamports) || feeLamports < 0) {\n    throw new Error(`calculateFeeAllocation: feeLamports must be a non-negative integer (got ${feeLamports})`);\n  }\n  if (\n    !Number.isFinite(referrerRateBps) ||\n    !Number.isInteger(referrerRateBps) ||\n    referrerRateBps < 0 ||\n    referrerRateBps > 10000\n  ) {\n    throw new Error(\n      `calculateFeeAllocation: referrerRateBps must be an integer in [0, 10000] (got ${referrerRateBps})`,\n    );\n  }\n\n  const referralLamports = Math.floor((feeLamports * referrerRateBps) / 10000);\n  const postReferral = feeLamports - referralLamports;\n  const promotionsLamports = Math.floor((postReferral * 2000) / 10000);\n  const profitLamports = feeLamports - referralLamports - promotionsLamports;\n\n  return { referralLamports, promotionsLamports, profitLamports };\n}\n\n// ---------------------------------------------------------------------------\n// Interface\n// ---------------------------------------------------------------------------\n\nconst ACTIVE_DEBIT_STATUSES = [\"pending\", \"processing\", \"error\"] as const;\nconst RESERVED_OR_SPENT_STATUSES = [\n  \"pending\",\n  \"processing\",\n  \"error\",\n  \"completed\",\n] as const;\n\nexport interface FeeAccountingDb {\n  /**\n   * Insert one allocation row. Idempotent on\n   * `(source_type, source_id, wallet)` — duplicate calls are no-ops.\n   * Returns the row, whether newly inserted or pre-existing.\n   */\n  insertFeeAllocation(params: InsertFeeAllocationParams): Promise<FeeAllocationEventRow>;\n\n  /**\n   * Insert one bucket debit row. Idempotent on\n   * `(bucket, debit_type, source_id)` — duplicate calls are no-ops.\n   * Returns the row, whether newly inserted or pre-existing.\n   */\n  insertFeeBucketDebit(params: InsertFeeBucketDebitParams): Promise<FeeBucketDebitRow>;\n\n  /**\n   * Update a debit's status (and bumps `updated_at`). Returns the updated row,\n   * or `undefined` when the `(bucket, debit_type, source_id)` triple does not\n   * exist.\n   */\n  updateFeeBucketDebitStatus(\n    bucket: FeeBucket,\n    debitType: string,\n    sourceId: string,\n    status: FeeBucketDebitStatus,\n  ): Promise<FeeBucketDebitRow | undefined>;\n\n  /**\n   * Lamports available across the global `referral` bucket.\n   *\n   * `sum(referral_lamports across all allocations)` minus\n   * `sum(amount_lamports across referral debits with status pending|processing|error|completed)`.\n   *\n   * Returned as a lamport string, matching the `getPendingBalanceByUserId` shape\n   * the claim hot path already consumes.\n   */\n  getReferralBucketAvailable(): Promise<string>;\n\n  /**\n   * Lamports available to a specific referrer user.\n   *\n   * `sum(referral_lamports for allocations where referrer_user_id = userId)`\n   * minus `sum(amount_lamports for referral debits with user_id = userId\n   * and status pending|processing|error|completed)`.\n   */\n  getUserReferralAvailable(userId: string): Promise<string>;\n\n  /**\n   * Reconciliation snapshot of the ledger. Treats\n   * `pending|processing|error|completed` debits as reserved/spent and excludes\n   * `failed` debits. Used by `GET /admin/fee-audit/snapshot`.\n   */\n  getFeeAuditSnapshot(): Promise<FeeAuditSnapshot>;\n}\n\n// ---------------------------------------------------------------------------\n// Factory\n// ---------------------------------------------------------------------------\n\nfunction normalizeAllocationRow(row: FeeAllocationEventRow): FeeAllocationEventRow {\n  return {\n    ...row,\n    wager_lamports: Number(row.wager_lamports),\n    fee_lamports: Number(row.fee_lamports),\n    referral_rate_bps: Number(row.referral_rate_bps),\n    referral_lamports: Number(row.referral_lamports),\n    promotions_lamports: Number(row.promotions_lamports),\n    profit_lamports: Number(row.profit_lamports),\n  };\n}\n\nfunction normalizeDebitRow(row: FeeBucketDebitRow): FeeBucketDebitRow {\n  return {\n    ...row,\n    amount_lamports: Number(row.amount_lamports),\n  };\n}\n\nfunction emptyBucketSummary(): FeeAuditBucketSummary {\n  return {\n    allocated: \"0\",\n    activeDebits: \"0\",\n    completedDebits: \"0\",\n    pendingClaimReserves: \"0\",\n    failedDebits: \"0\",\n    available: \"0\",\n  };\n}\n\n\nexport function createFeeAccountingDb(sql: ReturnType<typeof postgres>): FeeAccountingDb {\n  return {\n    async insertFeeAllocation(params) {\n      const rows = await sql<FeeAllocationEventRow[]>`\n        INSERT INTO fee_allocation_events (\n          source_type, source_id, game_type, wallet, user_id,\n          wager_lamports, fee_lamports,\n          referrer_user_id, referral_rate_bps,\n          referral_lamports, promotions_lamports, profit_lamports\n        ) VALUES (\n          ${params.sourceType},\n          ${params.sourceId},\n          ${params.gameType},\n          ${params.wallet},\n          ${params.userId ?? null},\n          ${params.wagerLamports},\n          ${params.feeLamports},\n          ${params.referrerUserId ?? null},\n          ${params.referralRateBps},\n          ${params.referralLamports},\n          ${params.promotionsLamports},\n          ${params.profitLamports}\n        )\n        ON CONFLICT (source_type, source_id, wallet) DO NOTHING\n        RETURNING *\n      `;\n      if (rows[0]) return normalizeAllocationRow(rows[0]);\n\n      // Conflict — return the existing row so callers can rely on the\n      // method's return type.\n      const existing = await sql<FeeAllocationEventRow[]>`\n        SELECT * FROM fee_allocation_events\n        WHERE source_type = ${params.sourceType}\n          AND source_id = ${params.sourceId}\n          AND wallet = ${params.wallet}\n      `;\n      return normalizeAllocationRow(existing[0]!);\n    },\n\n    async insertFeeBucketDebit(params) {\n      const rows = await sql<FeeBucketDebitRow[]>`\n        INSERT INTO fee_bucket_debits (\n          bucket, debit_type, source_id, user_id, wallet, amount_lamports, status\n        ) VALUES (\n          ${params.bucket},\n          ${params.debitType},\n          ${params.sourceId},\n          ${params.userId ?? null},\n          ${params.wallet ?? null},\n          ${params.amountLamports},\n          ${params.status ?? \"pending\"}\n        )\n        ON CONFLICT (bucket, debit_type, source_id) DO NOTHING\n        RETURNING *\n      `;\n      if (rows[0]) return normalizeDebitRow(rows[0]);\n\n      const existing = await sql<FeeBucketDebitRow[]>`\n        SELECT * FROM fee_bucket_debits\n        WHERE bucket = ${params.bucket}\n          AND debit_type = ${params.debitType}\n          AND source_id = ${params.sourceId}\n      `;\n      return normalizeDebitRow(existing[0]!);\n    },\n\n    async updateFeeBucketDebitStatus(bucket, debitType, sourceId, status) {\n      const rows = await sql<FeeBucketDebitRow[]>`\n        UPDATE fee_bucket_debits\n        SET status = ${status}, updated_at = now()\n        WHERE bucket = ${bucket}\n          AND debit_type = ${debitType}\n          AND source_id = ${sourceId}\n        RETURNING *\n      `;\n      return rows[0] ? normalizeDebitRow(rows[0]) : undefined;\n    },\n\n    async getReferralBucketAvailable() {\n      const rows = await sql<{ available: string }[]>`\n        SELECT (\n          COALESCE(\n            (SELECT SUM(referral_lamports) FROM fee_allocation_events),\n            0\n          )\n          - COALESCE(\n              (\n                SELECT SUM(amount_lamports)\n                FROM fee_bucket_debits\n                WHERE bucket = 'referral'\n                  AND status IN ${sql(RESERVED_OR_SPENT_STATUSES)}\n              ),\n              0\n            )\n        )::TEXT AS available\n      `;\n      return rows[0]!.available;\n    },\n\n    async getUserReferralAvailable(userId) {\n      const rows = await sql<{ available: string }[]>`\n        SELECT (\n          COALESCE(\n            (\n              SELECT SUM(referral_lamports)\n              FROM fee_allocation_events\n              WHERE referrer_user_id = ${userId}\n            ),\n            0\n          )\n          - COALESCE(\n              (\n                SELECT SUM(amount_lamports)\n                FROM fee_bucket_debits\n                WHERE bucket = 'referral'\n                  AND user_id = ${userId}\n                  AND status IN ${sql(RESERVED_OR_SPENT_STATUSES)}\n              ),\n              0\n            )\n        )::TEXT AS available\n      `;\n      return rows[0]!.available;\n    },\n\n    async getFeeAuditSnapshot() {\n      const totalsRowsPromise = sql<\n        {\n          fee_total: string;\n          referral_total: string;\n          promotions_total: string;\n          profit_total: string;\n          allocation_count: string;\n          audit_from: Date | null;\n        }[]\n      >`\n        SELECT\n          COALESCE(SUM(fee_lamports), 0)::TEXT          AS fee_total,\n          COALESCE(SUM(referral_lamports), 0)::TEXT     AS referral_total,\n          COALESCE(SUM(promotions_lamports), 0)::TEXT   AS promotions_total,\n          COALESCE(SUM(profit_lamports), 0)::TEXT       AS profit_total,\n          COUNT(*)::TEXT                                AS allocation_count,\n          MIN(created_at)                               AS audit_from\n        FROM fee_allocation_events\n      `;\n\n      const debitRowsPromise = sql<\n        {\n          bucket: FeeBucket;\n          status: FeeBucketDebitStatus;\n          debit_type: string;\n          sum_lamports: string;\n          row_count: string;\n        }[]\n      >`\n        SELECT\n          bucket,\n          status,\n          debit_type,\n          COALESCE(SUM(amount_lamports), 0)::TEXT AS sum_lamports,\n          COUNT(*)::TEXT                          AS row_count\n        FROM fee_bucket_debits\n        GROUP BY bucket, status, debit_type\n      `;\n\n      const violationsRowsPromise = sql<\n        {\n          source_type: string;\n          source_id: string;\n          wallet: string;\n          fee_lamports: string;\n          components_sum: string;\n        }[]\n      >`\n        SELECT\n          source_type,\n          source_id,\n          wallet,\n          fee_lamports::TEXT  AS fee_lamports,\n          (referral_lamports + promotions_lamports + profit_lamports)::TEXT\n                              AS components_sum\n        FROM fee_allocation_events\n        WHERE referral_lamports + promotions_lamports + profit_lamports <> fee_lamports\n      `;\n\n      const [totalsRows, debitRows, violationsRows] = await Promise.all([\n        totalsRowsPromise,\n        debitRowsPromise,\n        violationsRowsPromise,\n      ]);\n\n      const totalsRow = totalsRows[0]!;\n\n      const buckets = {\n        referral: emptyBucketSummary(),\n        promotions: emptyBucketSummary(),\n        profit: emptyBucketSummary(),\n      };\n\n      buckets.referral.allocated = totalsRow.referral_total;\n      buckets.promotions.allocated = totalsRow.promotions_total;\n      buckets.profit.allocated = totalsRow.profit_total;\n\n      let debitCount = 0;\n      const accum: Record<FeeBucket, { active: bigint; completed: bigint; failed: bigint; pendingClaim: bigint }> = {\n        referral: { active: 0n, completed: 0n, failed: 0n, pendingClaim: 0n },\n        promotions: { active: 0n, completed: 0n, failed: 0n, pendingClaim: 0n },\n        profit: { active: 0n, completed: 0n, failed: 0n, pendingClaim: 0n },\n      };\n\n      for (const row of debitRows) {\n        const amount = BigInt(row.sum_lamports);\n        const count = Number(row.row_count);\n        debitCount += count;\n\n        const target = accum[row.bucket];\n        if (!target) continue;\n\n        if ((ACTIVE_DEBIT_STATUSES as readonly string[]).includes(row.status)) {\n          target.active += amount;\n          if (row.debit_type === \"claim\") target.pendingClaim += amount;\n        } else if (row.status === \"completed\") {\n          target.completed += amount;\n        } else if (row.status === \"failed\") {\n          target.failed += amount;\n        }\n      }\n\n      const overdrawnBuckets: FeeBucket[] = [];\n      for (const bucket of [\"referral\", \"promotions\", \"profit\"] as const) {\n        const allocated = BigInt(buckets[bucket].allocated);\n        const { active, completed, failed, pendingClaim } = accum[bucket];\n        const reservedOrSpent = active + completed;\n        const available = allocated - reservedOrSpent;\n\n        buckets[bucket].activeDebits = active.toString();\n        buckets[bucket].completedDebits = completed.toString();\n        buckets[bucket].failedDebits = failed.toString();\n        buckets[bucket].pendingClaimReserves = pendingClaim.toString();\n        buckets[bucket].available = available.toString();\n\n        if (reservedOrSpent > allocated) overdrawnBuckets.push(bucket);\n      }\n\n      const invariantViolations = violationsRows.map((row) => ({\n        sourceType: row.source_type,\n        sourceId: row.source_id,\n        wallet: row.wallet,\n        feeLamports: row.fee_lamports,\n        componentsSum: row.components_sum,\n      }));\n\n      return {\n        totals: {\n          feeLamports: totalsRow.fee_total,\n          allocationCount: Number(totalsRow.allocation_count),\n          debitCount,\n        },\n        buckets,\n        invariantViolations,\n        overdrawnBuckets,\n        auditFrom: totalsRow.audit_from,\n      };\n    },\n  };\n}\n","numLines":536,"startLine":1,"totalLines":536}}}
