{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01QCr8C5hd3jE5LioLNyECBe","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FSY6pTZa2MSb5YjhCK6RGB","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/src/__tests__/referral-claim-ledger.test.ts","content":"/**\n * Referral claim — ledger-derived caps + bucket debit lifecycle.\n *\n * Spec: docs/specs/306-fee-accounting-audit/spec.md (FR-3, FR-6)\n *\n * Coverage:\n *   - POST /referral/claim ledger cap enforcement\n *       - per-user cap (no allocations → ZERO_BALANCE)\n *       - global cap (user's allocations exceed global bucket capacity → PRECONDITION_FAILED)\n *   - successful claim writes a `fee_bucket_debits` row with status='pending'\n *   - queue handler success / transient error / permanent fail each move the\n *     debit's status in lockstep with the claim\n */\n\nimport { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport { SignJWT } from \"jose\";\nimport type { Db } from \"../db.js\";\nimport { createReferralRoutes } from \"../routes/referral.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport type { Config } from \"../config.js\";\nimport { createClaimHandler } from \"../queue/handlers/referral-claim.js\";\nimport {\n  closeIntegrationDb,\n  type IntegrationDbContext,\n  MockConnection,\n  openIntegrationDb,\n  resetIntegrationState,\n  type TestSql,\n  userIdFromWallet,\n} from \"./integration-test-helpers.js\";\n\nconst JWT_SECRET = new TextEncoder().encode(\n  \"test-secret-for-referral-claim-ledger\",\n);\nconst TEST_CONFIG = {\n  referralDefaultRateBps: 1000,\n  referralMinClaimLamports: 10_000_000, // 0.01 SOL\n} as Config;\n\nasync function makeJwt(userId: string): Promise<string> {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({})\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userId)\n    .setIssuedAt(now)\n    .setExpirationTime(now + 3600)\n    .sign(JWT_SECRET);\n}\n\nfunction jsonHeaders(token: string) {\n  return {\n    \"Content-Type\": \"application/json\",\n    Authorization: `Bearer ${token}`,\n  };\n}\n\ndescribe(\"Referral claim — ledger caps + debit lifecycle\", () => {\n  let ctx: IntegrationDbContext;\n  let rawSql: TestSql;\n  let db: Db;\n  let app: Hono;\n\n  // Two distinct referrers: userA is the claimant under test, userB exists so\n  // the global referral bucket can be diverged from userA's per-user balance.\n  const referrerAKp = Keypair.generate();\n  const referrerBKp = Keypair.generate();\n  const refereeKp = Keypair.generate();\n  const referrerA = referrerAKp.publicKey.toBase58();\n  const referrerB = referrerBKp.publicKey.toBase58();\n  const referee = refereeKp.publicKey.toBase58();\n  const referrerAUserId = userIdFromWallet(referrerA);\n  const referrerBUserId = userIdFromWallet(referrerB);\n  const refereeUserId = userIdFromWallet(referee);\n\n  /**\n   * Insert one allocation row that contributes `referralLamports` to the\n   * global bucket and (when `referrerUserId` is set) to that user's per-user\n   * balance. Promotions/profit are filled with zero so the row passes the\n   * `components_sum = fee_lamports` CHECK without affecting bucket math under\n   * test.\n   */\n  async function seedAllocation(params: {\n    sourceId: string;\n    referrerUserId: string | null;\n    referralLamports: number;\n  }): Promise<void> {\n    await db.insertFeeAllocation({\n      sourceType: \"flipyou\",\n      sourceId: params.sourceId,\n      gameType: \"flipyou\",\n      wallet: referee,\n      userId: refereeUserId,\n      wagerLamports: 1_000_000_000,\n      feeLamports: params.referralLamports,\n      referrerUserId: params.referrerUserId,\n      referralRateBps: params.referrerUserId ? 10_000 : 0,\n      referralLamports: params.referralLamports,\n      promotionsLamports: 0,\n      profitLamports: 0,\n    });\n  }\n\n  beforeAll(async () => {\n    ctx = await openIntegrationDb();\n    rawSql = ctx.rawSql;\n    db = ctx.db;\n  });\n\n  afterAll(async () => {\n    await closeIntegrationDb(ctx);\n  });\n\n  beforeEach(async () => {\n    await resetIntegrationState(rawSql);\n\n    await rawSql`DELETE FROM player_profiles WHERE user_id IN (${referrerAUserId}, ${referrerBUserId}, ${refereeUserId})`;\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES\n        (${referrerAUserId}, ${referrerA}, ${\"a-\" + Date.now()}),\n        (${referrerBUserId}, ${referrerB}, ${\"b-\" + Date.now()}),\n        (${refereeUserId}, ${referee}, ${\"r-\" + Date.now()})\n    `;\n\n    app = new Hono();\n    app.use(\n      \"/referral/*\",\n      createJwtAuthMiddleware({\n        jwtSecret: JWT_SECRET,\n        requireAllMethods: true,\n      }),\n    );\n    app.route(\n      \"/referral\",\n      createReferralRoutes({ db, sql: rawSql, config: TEST_CONFIG }),\n    );\n  });\n\n  // -----------------------------------------------------------------------\n  // POST /referral/claim — ledger caps\n  // -----------------------------------------------------------------------\n\n  describe(\"POST /referral/claim ledger caps\", () => {\n    it(\"returns 422 ZERO_BALANCE when user has no referral allocations\", async () => {\n      const token = await makeJwt(referrerAUserId);\n      const res = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: jsonHeaders(token),\n      });\n\n      expect(res.status).toBe(422);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"ZERO_BALANCE\");\n    });\n\n    it(\"returns 422 PRECONDITION_FAILED when user > global available\", async () => {\n      // userA: 50M referral allocation (per-user available = 50M).\n      await seedAllocation({\n        sourceId: \"round-a\",\n        referrerUserId: referrerAUserId,\n        referralLamports: 50_000_000,\n      });\n      // userB: 50M referral allocation + 60M completed referral debit (bucket\n      // overdrawn from userB's side; global available = 100M - 60M = 40M).\n      await seedAllocation({\n        sourceId: \"round-b\",\n        referrerUserId: referrerBUserId,\n        referralLamports: 50_000_000,\n      });\n      await db.insertFeeBucketDebit({\n        bucket: \"referral\",\n        debitType: \"claim\",\n        sourceId: \"external-claim-b\",\n        userId: referrerBUserId,\n        wallet: referrerB,\n        amountLamports: 60_000_000,\n        status: \"completed\",\n      });\n\n      // Sanity: per-user (50M) > global (40M).\n      expect(BigInt(await db.getUserReferralAvailable(referrerAUserId))).toBe(\n        50_000_000n,\n      );\n      expect(BigInt(await db.getReferralBucketAvailable())).toBe(40_000_000n);\n\n      const token = await makeJwt(referrerAUserId);\n      const res = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: jsonHeaders(token),\n      });\n\n      expect(res.status).toBe(422);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string; message: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"PRECONDITION_FAILED\");\n\n      // No claim row created when the global cap rejects.\n      const claims =\n        await rawSql`SELECT id FROM referral_claims WHERE user_id = ${referrerAUserId}`;\n      expect(claims.length).toBe(0);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // POST /referral/claim — debit insertion alongside claim\n  // -----------------------------------------------------------------------\n\n  describe(\"POST /referral/claim debit insertion\", () => {\n    it(\"inserts a fee_bucket_debits row with status=pending in the same tx\", async () => {\n      await seedAllocation({\n        sourceId: \"round-pending-debit\",\n        referrerUserId: referrerAUserId,\n        referralLamports: 50_000_000, // ≥ 10M minClaim\n      });\n\n      const token = await makeJwt(referrerAUserId);\n      const res = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: jsonHeaders(token),\n      });\n\n      expect(res.status).toBe(202);\n      const body = (await res.json()) as {\n        ok: true;\n        data: { claimId: string; amountLamports: string; status: string };\n      };\n      expect(body.ok).toBe(true);\n      expect(body.data.amountLamports).toBe(\"50000000\");\n      expect(body.data.status).toBe(\"pending\");\n\n      const debits = await rawSql<\n        {\n          bucket: string;\n          debit_type: string;\n          source_id: string;\n          status: string;\n          amount_lamports: string;\n          user_id: string | null;\n          wallet: string | null;\n        }[]\n      >`\n        SELECT bucket, debit_type, source_id, status, amount_lamports, user_id, wallet\n        FROM fee_bucket_debits\n        WHERE source_id = ${body.data.claimId}\n      `;\n      expect(debits).toHaveLength(1);\n      expect(debits[0]!.bucket).toBe(\"referral\");\n      expect(debits[0]!.debit_type).toBe(\"claim\");\n      expect(debits[0]!.status).toBe(\"pending\");\n      expect(String(debits[0]!.amount_lamports)).toBe(\"50000000\");\n      expect(debits[0]!.user_id).toBe(referrerAUserId);\n      expect(debits[0]!.wallet).toBe(referrerA);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // Queue handler — debit transitions in lockstep with the claim\n  // -----------------------------------------------------------------------\n\n  describe(\"Queue handler debit lifecycle\", () => {\n    /**\n     * Seed a referral_earnings row so the handler's\n     * `getPendingBalanceByUserId` check passes, then insert a pending claim\n     * row + matching pending debit row. Returns the claim id.\n     */\n    async function seedClaimAndDebit(opts: {\n      amountLamports: number;\n      retryCount?: number;\n      seedEarning?: boolean;\n    }): Promise<string> {\n      if (opts.seedEarning ?? true) {\n        await db.insertReferralEarning({\n          referrerUserId: referrerAUserId,\n          refereeUserId,\n          referrerWallet: referrerA,\n          refereeWallet: referee,\n          roundId: `earn-${Date.now()}-${Math.random()}`,\n          gameType: \"flipyou\",\n          wagerLamports: 10_000_000_000,\n          feeLamports: 500_000_000,\n          referrerEarnedLamports: opts.amountLamports,\n          referrerRateBps: 1000,\n        });\n      }\n\n      const claim = await db.insertReferralClaim(\n        referrerAUserId,\n        referrerA,\n        String(opts.amountLamports),\n      );\n      if (opts.retryCount && opts.retryCount > 0) {\n        await rawSql`\n          UPDATE referral_claims\n          SET retry_count = ${opts.retryCount}\n          WHERE id = ${claim.id}\n        `;\n      }\n\n      await db.insertFeeBucketDebit({\n        bucket: \"referral\",\n        debitType: \"claim\",\n        sourceId: claim.id,\n        userId: referrerAUserId,\n        wallet: referrerA,\n        amountLamports: opts.amountLamports,\n        status: \"pending\",\n      });\n\n      return claim.id;\n    }\n\n    async function readDebitStatus(claimId: string): Promise<string | null> {\n      const rows = await rawSql<{ status: string }[]>`\n        SELECT status FROM fee_bucket_debits\n        WHERE bucket = 'referral'\n          AND debit_type = 'claim'\n          AND source_id = ${claimId}\n      `;\n      return rows[0]?.status ?? null;\n    }\n\n    async function readClaimStatus(claimId: string): Promise<string | null> {\n      const rows = await rawSql<{ status: string }[]>`\n        SELECT status FROM referral_claims WHERE id = ${claimId}\n      `;\n      return rows[0]?.status ?? null;\n    }\n\n    it(\"debit → completed when transfer succeeds (mirrors claim)\", async () => {\n      const claimId = await seedClaimAndDebit({ amountLamports: 50_000_000 });\n\n      const conn = new MockConnection();\n      const handler = createClaimHandler({\n        db,\n        connection: conn as unknown as Connection,\n        serverKeypair: Keypair.generate(),\n      });\n\n      await handler({\n        claimId,\n        userId: referrerAUserId,\n        wallet: referrerA,\n        amountLamports: \"50000000\",\n      });\n\n      expect(await readClaimStatus(claimId)).toBe(\"completed\");\n      expect(await readDebitStatus(claimId)).toBe(\"completed\");\n    });\n\n    it(\"debit → error on transient failure when retries remain (mirrors claim)\", async () => {\n      const claimId = await seedClaimAndDebit({\n        amountLamports: 50_000_000,\n        retryCount: 0,\n      });\n\n      const conn = new MockConnection();\n      conn.sendRawTransaction = async () => {\n        throw new Error(\"Simulated transient RPC failure\");\n      };\n      const handler = createClaimHandler({\n        db,\n        connection: conn as unknown as Connection,\n        serverKeypair: Keypair.generate(),\n      });\n\n      await expect(\n        handler({\n          claimId,\n          userId: referrerAUserId,\n          wallet: referrerA,\n          amountLamports: \"50000000\",\n        }),\n      ).rejects.toThrow(/Simulated transient RPC failure/);\n\n      expect(await readClaimStatus(claimId)).toBe(\"error\");\n      expect(await readDebitStatus(claimId)).toBe(\"error\");\n    });\n\n    it(\"debit → failed on permanent insufficient-balance (mirrors claim)\", async () => {\n      // No referral_earnings row → getPendingBalanceByUserId = 0, but the\n      // claim/debit we insert claim 50M → handler permanently fails.\n      const claimId = await seedClaimAndDebit({\n        amountLamports: 50_000_000,\n        seedEarning: false,\n      });\n\n      const conn = new MockConnection();\n      const handler = createClaimHandler({\n        db,\n        connection: conn as unknown as Connection,\n        serverKeypair: Keypair.generate(),\n      });\n\n      await handler({\n        claimId,\n        userId: referrerAUserId,\n        wallet: referrerA,\n        amountLamports: \"50000000\",\n      });\n\n      expect(await readClaimStatus(claimId)).toBe(\"failed\");\n      expect(await readDebitStatus(claimId)).toBe(\"failed\");\n    });\n\n    it(\"debit → failed when retry budget exhausted (mirrors claim)\", async () => {\n      // Start with retry_count = MAX_CLAIM_RETRIES − 1; the next failure tips\n      // it into permanent failure inside the catch branch.\n      const claimId = await seedClaimAndDebit({\n        amountLamports: 50_000_000,\n        retryCount: 4,\n      });\n\n      const conn = new MockConnection();\n      conn.sendRawTransaction = async () => {\n        throw new Error(\"Simulated final RPC failure\");\n      };\n      const handler = createClaimHandler({\n        db,\n        connection: conn as unknown as Connection,\n        serverKeypair: Keypair.generate(),\n      });\n\n      await handler({\n        claimId,\n        userId: referrerAUserId,\n        wallet: referrerA,\n        amountLamports: \"50000000\",\n      });\n\n      expect(await readClaimStatus(claimId)).toBe(\"failed\");\n      expect(await readDebitStatus(claimId)).toBe(\"failed\");\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":239,"cache_read_input_tokens":142131,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":239},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"896d4934-c43e-44ca-831c-60139b475f70","uuid":"780d361b-3037-4c87-a80f-f0f63ea3c09d"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FSY6pTZa2MSb5YjhCK6RGB","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/backend/src/__tests__/referral-claim-ledger.test.ts"}]},"parent_tool_use_id":null,"session_id":"896d4934-c43e-44ca-831c-60139b475f70","uuid":"0265274b-dc99-4c60-a159-deed69b287af","timestamp":"2026-05-01T20:30:31.932Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/backend/src/__tests__/referral-claim-ledger.test.ts","content":"/**\n * Referral claim — ledger-derived caps + bucket debit lifecycle.\n *\n * Spec: docs/specs/306-fee-accounting-audit/spec.md (FR-3, FR-6)\n *\n * Coverage:\n *   - POST /referral/claim ledger cap enforcement\n *       - per-user cap (no allocations → ZERO_BALANCE)\n *       - global cap (user's allocations exceed global bucket capacity → PRECONDITION_FAILED)\n *   - successful claim writes a `fee_bucket_debits` row with status='pending'\n *   - queue handler success / transient error / permanent fail each move the\n *     debit's status in lockstep with the claim\n */\n\nimport { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport { SignJWT } from \"jose\";\nimport type { Db } from \"../db.js\";\nimport { createReferralRoutes } from \"../routes/referral.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport type { Config } from \"../config.js\";\nimport { createClaimHandler } from \"../queue/handlers/referral-claim.js\";\nimport {\n  closeIntegrationDb,\n  type IntegrationDbContext,\n  MockConnection,\n  openIntegrationDb,\n  resetIntegrationState,\n  type TestSql,\n  userIdFromWallet,\n} from \"./integration-test-helpers.js\";\n\nconst JWT_SECRET = new TextEncoder().encode(\n  \"test-secret-for-referral-claim-ledger\",\n);\nconst TEST_CONFIG = {\n  referralDefaultRateBps: 1000,\n  referralMinClaimLamports: 10_000_000, // 0.01 SOL\n} as Config;\n\nasync function makeJwt(userId: string): Promise<string> {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({})\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userId)\n    .setIssuedAt(now)\n    .setExpirationTime(now + 3600)\n    .sign(JWT_SECRET);\n}\n\nfunction jsonHeaders(token: string) {\n  return {\n    \"Content-Type\": \"application/json\",\n    Authorization: `Bearer ${token}`,\n  };\n}\n\ndescribe(\"Referral claim — ledger caps + debit lifecycle\", () => {\n  let ctx: IntegrationDbContext;\n  let rawSql: TestSql;\n  let db: Db;\n  let app: Hono;\n\n  // Two distinct referrers: userA is the claimant under test, userB exists so\n  // the global referral bucket can be diverged from userA's per-user balance.\n  const referrerAKp = Keypair.generate();\n  const referrerBKp = Keypair.generate();\n  const refereeKp = Keypair.generate();\n  const referrerA = referrerAKp.publicKey.toBase58();\n  const referrerB = referrerBKp.publicKey.toBase58();\n  const referee = refereeKp.publicKey.toBase58();\n  const referrerAUserId = userIdFromWallet(referrerA);\n  const referrerBUserId = userIdFromWallet(referrerB);\n  const refereeUserId = userIdFromWallet(referee);\n\n  /**\n   * Insert one allocation row that contributes `referralLamports` to the\n   * global bucket and (when `referrerUserId` is set) to that user's per-user\n   * balance. Promotions/profit are filled with zero so the row passes the\n   * `components_sum = fee_lamports` CHECK without affecting bucket math under\n   * test.\n   */\n  async function seedAllocation(params: {\n    sourceId: string;\n    referrerUserId: string | null;\n    referralLamports: number;\n  }): Promise<void> {\n    await db.insertFeeAllocation({\n      sourceType: \"flipyou\",\n      sourceId: params.sourceId,\n      gameType: \"flipyou\",\n      wallet: referee,\n      userId: refereeUserId,\n      wagerLamports: 1_000_000_000,\n      feeLamports: params.referralLamports,\n      referrerUserId: params.referrerUserId,\n      referralRateBps: params.referrerUserId ? 10_000 : 0,\n      referralLamports: params.referralLamports,\n      promotionsLamports: 0,\n      profitLamports: 0,\n    });\n  }\n\n  beforeAll(async () => {\n    ctx = await openIntegrationDb();\n    rawSql = ctx.rawSql;\n    db = ctx.db;\n  });\n\n  afterAll(async () => {\n    await closeIntegrationDb(ctx);\n  });\n\n  beforeEach(async () => {\n    await resetIntegrationState(rawSql);\n\n    await rawSql`DELETE FROM player_profiles WHERE user_id IN (${referrerAUserId}, ${referrerBUserId}, ${refereeUserId})`;\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES\n        (${referrerAUserId}, ${referrerA}, ${\"a-\" + Date.now()}),\n        (${referrerBUserId}, ${referrerB}, ${\"b-\" + Date.now()}),\n        (${refereeUserId}, ${referee}, ${\"r-\" + Date.now()})\n    `;\n\n    app = new Hono();\n    app.use(\n      \"/referral/*\",\n      createJwtAuthMiddleware({\n        jwtSecret: JWT_SECRET,\n        requireAllMethods: true,\n      }),\n    );\n    app.route(\n      \"/referral\",\n      createReferralRoutes({ db, sql: rawSql, config: TEST_CONFIG }),\n    );\n  });\n\n  // -----------------------------------------------------------------------\n  // POST /referral/claim — ledger caps\n  // -----------------------------------------------------------------------\n\n  describe(\"POST /referral/claim ledger caps\", () => {\n    it(\"returns 422 ZERO_BALANCE when user has no referral allocations\", async () => {\n      const token = await makeJwt(referrerAUserId);\n      const res = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: jsonHeaders(token),\n      });\n\n      expect(res.status).toBe(422);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"ZERO_BALANCE\");\n    });\n\n    it(\"returns 422 PRECONDITION_FAILED when user > global available\", async () => {\n      // userA: 50M referral allocation (per-user available = 50M).\n      await seedAllocation({\n        sourceId: \"round-a\",\n        referrerUserId: referrerAUserId,\n        referralLamports: 50_000_000,\n      });\n      // userB: 50M referral allocation + 60M completed referral debit (bucket\n      // overdrawn from userB's side; global available = 100M - 60M = 40M).\n      await seedAllocation({\n        sourceId: \"round-b\",\n        referrerUserId: referrerBUserId,\n        referralLamports: 50_000_000,\n      });\n      await db.insertFeeBucketDebit({\n        bucket: \"referral\",\n        debitType: \"claim\",\n        sourceId: \"external-claim-b\",\n        userId: referrerBUserId,\n        wallet: referrerB,\n        amountLamports: 60_000_000,\n        status: \"completed\",\n      });\n\n      // Sanity: per-user (50M) > global (40M).\n      expect(BigInt(await db.getUserReferralAvailable(referrerAUserId))).toBe(\n        50_000_000n,\n      );\n      expect(BigInt(await db.getReferralBucketAvailable())).toBe(40_000_000n);\n\n      const token = await makeJwt(referrerAUserId);\n      const res = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: jsonHeaders(token),\n      });\n\n      expect(res.status).toBe(422);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string; message: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"PRECONDITION_FAILED\");\n\n      // No claim row created when the global cap rejects.\n      const claims =\n        await rawSql`SELECT id FROM referral_claims WHERE user_id = ${referrerAUserId}`;\n      expect(claims.length).toBe(0);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // POST /referral/claim — debit insertion alongside claim\n  // -----------------------------------------------------------------------\n\n  describe(\"POST /referral/claim debit insertion\", () => {\n    it(\"inserts a fee_bucket_debits row with status=pending in the same tx\", async () => {\n      await seedAllocation({\n        sourceId: \"round-pending-debit\",\n        referrerUserId: referrerAUserId,\n        referralLamports: 50_000_000, // ≥ 10M minClaim\n      });\n\n      const token = await makeJwt(referrerAUserId);\n      const res = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: jsonHeaders(token),\n      });\n\n      expect(res.status).toBe(202);\n      const body = (await res.json()) as {\n        ok: true;\n        data: { claimId: string; amountLamports: string; status: string };\n      };\n      expect(body.ok).toBe(true);\n      expect(body.data.amountLamports).toBe(\"50000000\");\n      expect(body.data.status).toBe(\"pending\");\n\n      const debits = await rawSql<\n        {\n          bucket: string;\n          debit_type: string;\n          source_id: string;\n          status: string;\n          amount_lamports: string;\n          user_id: string | null;\n          wallet: string | null;\n        }[]\n      >`\n        SELECT bucket, debit_type, source_id, status, amount_lamports, user_id, wallet\n        FROM fee_bucket_debits\n        WHERE source_id = ${body.data.claimId}\n      `;\n      expect(debits).toHaveLength(1);\n      expect(debits[0]!.bucket).toBe(\"referral\");\n      expect(debits[0]!.debit_type).toBe(\"claim\");\n      expect(debits[0]!.status).toBe(\"pending\");\n      expect(String(debits[0]!.amount_lamports)).toBe(\"50000000\");\n      expect(debits[0]!.user_id).toBe(referrerAUserId);\n      expect(debits[0]!.wallet).toBe(referrerA);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // Queue handler — debit transitions in lockstep with the claim\n  // -----------------------------------------------------------------------\n\n  describe(\"Queue handler debit lifecycle\", () => {\n    /**\n     * Seed a referral_earnings row so the handler's\n     * `getPendingBalanceByUserId` check passes, then insert a pending claim\n     * row + matching pending debit row. Returns the claim id.\n     */\n    async function seedClaimAndDebit(opts: {\n      amountLamports: number;\n      retryCount?: number;\n      seedEarning?: boolean;\n    }): Promise<string> {\n      if (opts.seedEarning ?? true) {\n        await db.insertReferralEarning({\n          referrerUserId: referrerAUserId,\n          refereeUserId,\n          referrerWallet: referrerA,\n          refereeWallet: referee,\n          roundId: `earn-${Date.now()}-${Math.random()}`,\n          gameType: \"flipyou\",\n          wagerLamports: 10_000_000_000,\n          feeLamports: 500_000_000,\n          referrerEarnedLamports: opts.amountLamports,\n          referrerRateBps: 1000,\n        });\n      }\n\n      const claim = await db.insertReferralClaim(\n        referrerAUserId,\n        referrerA,\n        String(opts.amountLamports),\n      );\n      if (opts.retryCount && opts.retryCount > 0) {\n        await rawSql`\n          UPDATE referral_claims\n          SET retry_count = ${opts.retryCount}\n          WHERE id = ${claim.id}\n        `;\n      }\n\n      await db.insertFeeBucketDebit({\n        bucket: \"referral\",\n        debitType: \"claim\",\n        sourceId: claim.id,\n        userId: referrerAUserId,\n        wallet: referrerA,\n        amountLamports: opts.amountLamports,\n        status: \"pending\",\n      });\n\n      return claim.id;\n    }\n\n    async function readDebitStatus(claimId: string): Promise<string | null> {\n      const rows = await rawSql<{ status: string }[]>`\n        SELECT status FROM fee_bucket_debits\n        WHERE bucket = 'referral'\n          AND debit_type = 'claim'\n          AND source_id = ${claimId}\n      `;\n      return rows[0]?.status ?? null;\n    }\n\n    async function readClaimStatus(claimId: string): Promise<string | null> {\n      const rows = await rawSql<{ status: string }[]>`\n        SELECT status FROM referral_claims WHERE id = ${claimId}\n      `;\n      return rows[0]?.status ?? null;\n    }\n\n    it(\"debit → completed when transfer succeeds (mirrors claim)\", async () => {\n      const claimId = await seedClaimAndDebit({ amountLamports: 50_000_000 });\n\n      const conn = new MockConnection();\n      const handler = createClaimHandler({\n        db,\n        connection: conn as unknown as Connection,\n        serverKeypair: Keypair.generate(),\n      });\n\n      await handler({\n        claimId,\n        userId: referrerAUserId,\n        wallet: referrerA,\n        amountLamports: \"50000000\",\n      });\n\n      expect(await readClaimStatus(claimId)).toBe(\"completed\");\n      expect(await readDebitStatus(claimId)).toBe(\"completed\");\n    });\n\n    it(\"debit → error on transient failure when retries remain (mirrors claim)\", async () => {\n      const claimId = await seedClaimAndDebit({\n        amountLamports: 50_000_000,\n        retryCount: 0,\n      });\n\n      const conn = new MockConnection();\n      conn.sendRawTransaction = async () => {\n        throw new Error(\"Simulated transient RPC failure\");\n      };\n      const handler = createClaimHandler({\n        db,\n        connection: conn as unknown as Connection,\n        serverKeypair: Keypair.generate(),\n      });\n\n      await expect(\n        handler({\n          claimId,\n          userId: referrerAUserId,\n          wallet: referrerA,\n          amountLamports: \"50000000\",\n        }),\n      ).rejects.toThrow(/Simulated transient RPC failure/);\n\n      expect(await readClaimStatus(claimId)).toBe(\"error\");\n      expect(await readDebitStatus(claimId)).toBe(\"error\");\n    });\n\n    it(\"debit → failed on permanent insufficient-balance (mirrors claim)\", async () => {\n      // No referral_earnings row → getPendingBalanceByUserId = 0, but the\n      // claim/debit we insert claim 50M → handler permanently fails.\n      const claimId = await seedClaimAndDebit({\n        amountLamports: 50_000_000,\n        seedEarning: false,\n      });\n\n      const conn = new MockConnection();\n      const handler = createClaimHandler({\n        db,\n        connection: conn as unknown as Connection,\n        serverKeypair: Keypair.generate(),\n      });\n\n      await handler({\n        claimId,\n        userId: referrerAUserId,\n        wallet: referrerA,\n        amountLamports: \"50000000\",\n      });\n\n      expect(await readClaimStatus(claimId)).toBe(\"failed\");\n      expect(await readDebitStatus(claimId)).toBe(\"failed\");\n    });\n\n    it(\"debit → failed when retry budget exhausted (mirrors claim)\", async () => {\n      // Start with retry_count = MAX_CLAIM_RETRIES − 1; the next failure tips\n      // it into permanent failure inside the catch branch.\n      const claimId = await seedClaimAndDebit({\n        amountLamports: 50_000_000,\n        retryCount: 4,\n      });\n\n      const conn = new MockConnection();\n      conn.sendRawTransaction = async () => {\n        throw new Error(\"Simulated final RPC failure\");\n      };\n      const handler = createClaimHandler({\n        db,\n        connection: conn as unknown as Connection,\n        serverKeypair: Keypair.generate(),\n      });\n\n      await handler({\n        claimId,\n        userId: referrerAUserId,\n        wallet: referrerA,\n        amountLamports: \"50000000\",\n      });\n\n      expect(await readClaimStatus(claimId)).toBe(\"failed\");\n      expect(await readDebitStatus(claimId)).toBe(\"failed\");\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
