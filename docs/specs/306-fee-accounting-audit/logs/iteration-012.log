{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01X4xotQtrHUvYW7JcfhD5wV","type":"tool_result","content":"1\timport { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";\n2\timport { Keypair } from \"@solana/web3.js\";\n3\timport type { Connection } from \"@solana/web3.js\";\n4\timport type { Db } from \"../db.js\";\n5\timport { createCrateSolPayoutHandler } from \"../queue/handlers/crate-sol-payout.js\";\n6\timport {\n7\t  closeIntegrationDb,\n8\t  type IntegrationDbContext,\n9\t  MockConnection,\n10\t  openIntegrationDb,\n11\t  resetIntegrationState,\n12\t  type TestSql,\n13\t  userIdFromWallet,\n14\t} from \"./integration-test-helpers.js\";\n15\t\n16\tdescribe(\"CRATE_SOL_PAYOUT handler\", () => {\n17\t  let ctx: IntegrationDbContext;\n18\t  let rawSql: TestSql;\n19\t  let db: Db;\n20\t  let mockConn: MockConnection;\n21\t  let serverKeypair: Keypair;\n22\t\n23\t  const testWallet = Keypair.generate().publicKey.toBase58();\n24\t  const testUserId = userIdFromWallet(testWallet);\n25\t\n26\t  beforeAll(async () => {\n27\t    ctx = await openIntegrationDb();\n28\t    rawSql = ctx.rawSql;\n29\t    db = ctx.db;\n30\t  });\n31\t\n32\t  afterAll(async () => {\n33\t    await closeIntegrationDb(ctx);\n34\t  });\n35\t\n36\t  beforeEach(async () => {\n37\t    await resetIntegrationState(rawSql);\n38\t    mockConn = new MockConnection();\n39\t    serverKeypair = Keypair.generate();\n40\t  });\n41\t\n42\t  it(\"sends SOL and marks crates as granted\", async () => {\n43\t    const crateRows = await rawSql<{ id: string }[]>`\n44\t      INSERT INTO crate_drops (\n45\t        user_id,\n46\t        trigger_type,\n47\t        trigger_id,\n48\t        crate_type,\n49\t        contents_amount,\n50\t        status\n51\t      )\n52\t      VALUES (${testUserId}, 'game_settled', 'round-sol-payout-1', 'sol', '20000000', 'pending')\n53\t      RETURNING id\n54\t    `;\n55\t    const handler = createCrateSolPayoutHandler({\n56\t      db,\n57\t      connection: mockConn as unknown as Connection,\n58\t      serverKeypair,\n59\t    });\n60\t\n61\t    await handler({\n62\t      crateDropId: crateRows[0]!.id,\n63\t      userId: testUserId,\n64\t      wallet: testWallet,\n65\t      payoutLamports: \"20000000\",\n66\t    });\n67\t\n68\t    const crate = await rawSql<{ status: string; granted_at: string | null }[]>`\n69\t      SELECT status, granted_at FROM crate_drops WHERE id = ${crateRows[0]!.id}\n70\t    `;\n71\t    expect(crate[0]!.status).toBe(\"granted\");\n72\t    expect(crate[0]!.granted_at).not.toBeNull();\n73\t    expect(mockConn.lastRawTx).not.toBeNull();\n74\t  });\n75\t\n76\t  it(\"marks crates as failed when transfers error\", async () => {\n77\t    const crateRows = await rawSql<{ id: string }[]>`\n78\t      INSERT INTO crate_drops (\n79\t        user_id,\n80\t        trigger_type,"}]},"parent_tool_use_id":null,"session_id":"896d4934-c43e-44ca-831c-60139b475f70","uuid":"334b40d6-6b02-4939-8cf8-2027f75ca7b7","timestamp":"2026-05-01T20:27:45.551Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/crate-sol-payout.test.ts","content":"import { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";\nimport { Keypair } from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport { createCrateSolPayoutHandler } from \"../queue/handlers/crate-sol-payout.js\";\nimport {\n  closeIntegrationDb,\n  type IntegrationDbContext,\n  MockConnection,\n  openIntegrationDb,\n  resetIntegrationState,\n  type TestSql,\n  userIdFromWallet,\n} from \"./integration-test-helpers.js\";\n\ndescribe(\"CRATE_SOL_PAYOUT handler\", () => {\n  let ctx: IntegrationDbContext;\n  let rawSql: TestSql;\n  let db: Db;\n  let mockConn: MockConnection;\n  let serverKeypair: Keypair;\n\n  const testWallet = Keypair.generate().publicKey.toBase58();\n  const testUserId = userIdFromWallet(testWallet);\n\n  beforeAll(async () => {\n    ctx = await openIntegrationDb();\n    rawSql = ctx.rawSql;\n    db = ctx.db;\n  });\n\n  afterAll(async () => {\n    await closeIntegrationDb(ctx);\n  });\n\n  beforeEach(async () => {\n    await resetIntegrationState(rawSql);\n    mockConn = new MockConnection();\n    serverKeypair = Keypair.generate();\n  });\n\n  it(\"sends SOL and marks crates as granted\", async () => {\n    const crateRows = await rawSql<{ id: string }[]>`\n      INSERT INTO crate_drops (\n        user_id,\n        trigger_type,\n        trigger_id,\n        crate_type,\n        contents_amount,\n        status\n      )\n      VALUES (${testUserId}, 'game_settled', 'round-sol-payout-1', 'sol', '20000000', 'pending')\n      RETURNING id\n    `;\n    const handler = createCrateSolPayoutHandler({\n      db,\n      connection: mockConn as unknown as Connection,\n      serverKeypair,\n    });\n\n    await handler({\n      crateDropId: crateRows[0]!.id,\n      userId: testUserId,\n      wallet: testWallet,\n      payoutLamports: \"20000000\",\n    });\n\n    const crate = await rawSql<{ status: string; granted_at: string | null }[]>`\n      SELECT status, granted_at FROM crate_drops WHERE id = ${crateRows[0]!.id}\n    `;\n    expect(crate[0]!.status).toBe(\"granted\");\n    expect(crate[0]!.granted_at).not.toBeNull();\n    expect(mockConn.lastRawTx).not.toBeNull();\n  });\n\n  it(\"marks crates as failed when transfers error\", async () => {\n    const crateRows = await rawSql<{ id: string }[]>`\n      INSERT INTO crate_drops (\n        user_id,\n        trigger_type,","numLines":80,"startLine":1,"totalLines":149}}}
