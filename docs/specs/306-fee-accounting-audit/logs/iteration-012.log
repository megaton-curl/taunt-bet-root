{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018jEyJ9XswPBGvpJp3FY6kV","type":"tool_result","content":"80\texport function createDb(databaseUrl: string, _txSql?: any): Db {\n81\t  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n82\t  const sql: any = _txSql ?? postgres(databaseUrl);\n83\t  const _isOwner = !_txSql;\n84\t\n85\t  return {\n86\t    rawSql: sql,\n87\t\n88\t    ...createRoundsDb(sql),\n89\t\n90\t    ...createCloseCallDb(sql),\n91\t\n92\t    ...createGameEntriesDb(sql),\n93\t\n94\t    ...createCloseCallCandlesDb(sql),\n95\t\n96\t    ...createTransactionsDb(sql),\n97\t\n98\t    ...createReferralsDb(sql),\n99\t\n100\t    ...createProfilesDb(sql),\n101\t\n102\t    ...createStatsDb(sql),\n103\t\n104\t    ...createTelegramLinksDb(sql),\n105\t\n106\t    ...createLinkedAccountsDb(sql),\n107\t\n108\t    ...createFeeAccountingDb(sql),\n109\t\n110\t    async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {\n111\t      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n112\t      return sql.begin(async (txSql: any) => fn(createDb(databaseUrl, txSql)));\n113\t    },\n114\t\n115\t    async close() {\n116\t      if (_isOwner) await sql.end();\n117\t    },\n118\t  };\n119\t}\n120\t"}]},"parent_tool_use_id":null,"session_id":"896d4934-c43e-44ca-831c-60139b475f70","uuid":"c79803d0-83e1-404d-98ea-03912df24904","timestamp":"2026-05-01T20:29:01.942Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/db.ts","content":"export function createDb(databaseUrl: string, _txSql?: any): Db {\n  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n  const sql: any = _txSql ?? postgres(databaseUrl);\n  const _isOwner = !_txSql;\n\n  return {\n    rawSql: sql,\n\n    ...createRoundsDb(sql),\n\n    ...createCloseCallDb(sql),\n\n    ...createGameEntriesDb(sql),\n\n    ...createCloseCallCandlesDb(sql),\n\n    ...createTransactionsDb(sql),\n\n    ...createReferralsDb(sql),\n\n    ...createProfilesDb(sql),\n\n    ...createStatsDb(sql),\n\n    ...createTelegramLinksDb(sql),\n\n    ...createLinkedAccountsDb(sql),\n\n    ...createFeeAccountingDb(sql),\n\n    async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      return sql.begin(async (txSql: any) => fn(createDb(databaseUrl, txSql)));\n    },\n\n    async close() {\n      if (_isOwner) await sql.end();\n    },\n  };\n}\n","numLines":41,"startLine":80,"totalLines":120}}}
