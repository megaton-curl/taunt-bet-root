{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LDfmQjcy3cuL43NeZGj1RL","type":"tool_result","content":"1\t/* eslint-disable @typescript-eslint/no-explicit-any */\n2\t/**\n3\t * Referral route tests — set code, apply, stats, earnings, claim flows.\n4\t *\n5\t * Uses real Postgres (same pattern as auth-routes.test.ts) with TRUNCATE\n6\t * between tests for isolation.\n7\t */\n8\t\n9\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n10\timport { Hono } from \"hono\";\n11\timport { Keypair } from \"@solana/web3.js\";\n12\timport { SignJWT } from \"jose\";\n13\timport postgres from \"postgres\";\n14\timport { createDb, type Db } from \"../db.js\";\n15\timport { createReferralRoutes } from \"../routes/referral.js\";\n16\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n17\timport type { Config } from \"../config.js\";\n18\t\n19\t// ---------------------------------------------------------------------------\n20\t// Constants\n21\t// ---------------------------------------------------------------------------\n22\t\n23\tconst DATABASE_URL =\n24\t  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n25\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-referral-tests\");\n26\t\n27\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n28\tfunction makeSql() {\n29\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n30\t  // Dev container: postgres listens on Unix socket only\n31\t  return postgres({\n32\t    host: \"/var/run/postgresql\",\n33\t    user: \"vscode\",\n34\t    database: \"taunt_bet_dev\",\n35\t  });\n36\t}\n37\t\n38\t// ---------------------------------------------------------------------------\n39\t// Helpers\n40\t// ---------------------------------------------------------------------------\n41\t\n42\tasync function makeJwt(wallet: string): Promise<string> {\n43\t  const now = Math.floor(Date.now() / 1000);\n44\t  return new SignJWT({})\n45\t    .setProtectedHeader({ alg: \"HS256\" })\n46\t    .setSubject(userIdFromWallet(wallet))\n47\t    .setIssuedAt(now)\n48\t    .setExpirationTime(now + 3600)\n49\t    .sign(JWT_SECRET);\n50\t}\n51\t\n52\tfunction json(body: Record<string, any>) {\n53\t  return {\n54\t    headers: { \"Content-Type\": \"application/json\" },\n55\t    body: JSON.stringify(body),\n56\t  };\n57\t}\n58\t\n59\tfunction userIdFromWallet(wallet: string) {\n60\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n61\t}\n62\t\n63\t// ---------------------------------------------------------------------------\n64\t// Test suite\n65\t// ---------------------------------------------------------------------------\n66\t\n67\tdescribe(\"Referral routes\", () => {\n68\t  let rawSql: ReturnType<typeof postgres>;\n69\t  let db: Db;\n70\t  let app: Hono;\n71\t\n72\t  const referrerKp = Keypair.generate();\n73\t  const refereeKp = Keypair.generate();\n74\t  const referrer = referrerKp.publicKey.toBase58();\n75\t  const referee = refereeKp.publicKey.toBase58();\n76\t  const referrerUserId = userIdFromWallet(referrer);\n77\t  const refereeUserId = userIdFromWallet(referee);\n78\t\n79\t  const testConfig = {\n80\t    referralDefaultRateBps: 1000,\n81\t    referralMinClaimLamports: 10_000_000, // 0.01 SOL\n82\t  } as Config;\n83\t\n84\t  // Mirror an `insertReferralEarning` fixture into the fee accounting ledger\n85\t  // so the claim route's ledger-derived caps see the same balance.\n86\t  async function seedFeeAllocation(params: {\n87\t    sourceId: string;\n88\t    feeLamports: number;\n89\t    referrerEarnedLamports: number;\n90\t    referrerRateBps: number;\n91\t    wagerLamports: number;\n92\t  }) {\n93\t    const postReferral = params.feeLamports - params.referrerEarnedLamports;\n94\t    const promotionsLamports = Math.floor((postReferral * 2000) / 10000);\n95\t    const profitLamports = postReferral - promotionsLamports;\n96\t    await db.insertFeeAllocation({\n97\t      sourceType: \"flipyou\",\n98\t      sourceId: params.sourceId,\n99\t      gameType: \"flipyou\",\n100\t      wallet: referee,\n101\t      userId: refereeUserId,\n102\t      wagerLamports: params.wagerLamports,\n103\t      feeLamports: params.feeLamports,\n104\t      referrerUserId,\n105\t      referralRateBps: params.referrerRateBps,\n106\t      referralLamports: params.referrerEarnedLamports,\n107\t      promotionsLamports,\n108\t      profitLamports,\n109\t    });\n110\t  }\n111\t\n112\t  beforeAll(async () => {\n113\t    rawSql = makeSql();\n114\t    await rawSql`\n115\t      DROP TABLE IF EXISTS referral_claims, referral_earnings, referral_links, referral_codes, referral_kol_rates CASCADE\n116\t    `;\n117\t    await rawSql`\n118\t      CREATE TABLE referral_codes (\n119\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n120\t        user_id TEXT NOT NULL UNIQUE,\n121\t        wallet TEXT NOT NULL UNIQUE,\n122\t        code TEXT NOT NULL UNIQUE,\n123\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n124\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n125\t      )\n126\t    `;\n127\t    await rawSql`\n128\t      CREATE TABLE referral_links (\n129\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n130\t        referrer_user_id TEXT NOT NULL,\n131\t        referee_user_id TEXT NOT NULL UNIQUE,\n132\t        referrer_wallet TEXT NOT NULL,\n133\t        referee_wallet TEXT NOT NULL,\n134\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n135\t      )\n136\t    `;\n137\t    await rawSql`\n138\t      CREATE INDEX idx_referral_links_referrer ON referral_links (referrer_user_id)\n139\t    `;\n140\t    await rawSql`\n141\t      CREATE TABLE referral_earnings (\n142\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n143\t        referrer_user_id TEXT NOT NULL,\n144\t        referee_user_id TEXT NOT NULL,\n145\t        referrer_wallet TEXT NOT NULL,\n146\t        referee_wallet TEXT NOT NULL,\n147\t        round_id TEXT NOT NULL,\n148\t        game_type TEXT NOT NULL,\n149\t        wager_lamports BIGINT NOT NULL,\n150\t        fee_lamports BIGINT NOT NULL,\n151\t        referrer_earned_lamports BIGINT NOT NULL,\n152\t        referrer_rate_bps INTEGER NOT NULL,\n153\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n154\t        CONSTRAINT uq_referral_earnings_referee_round UNIQUE (referee_user_id, round_id)\n155\t      )\n156\t    `;\n157\t    await rawSql`\n158\t      CREATE INDEX idx_referral_earnings_referrer ON referral_earnings (referrer_user_id, created_at)\n159\t    `;\n160\t    await rawSql`\n161\t      CREATE INDEX idx_referral_earnings_referee ON referral_earnings (referee_user_id, created_at)\n162\t    `;\n163\t    await rawSql`\n164\t      CREATE INDEX idx_referral_earnings_round_id ON referral_earnings (round_id)\n165\t    `;\n166\t    await rawSql`\n167\t      CREATE TABLE referral_claims (\n168\t        id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n169\t        user_id TEXT NOT NULL,\n170\t        wallet TEXT NOT NULL,\n171\t        amount_lamports BIGINT NOT NULL,\n172\t        status TEXT NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'error', 'completed', 'failed')),\n173\t        retry_count INTEGER NOT NULL DEFAULT 0,\n174\t        tx_signature TEXT,\n175\t        error TEXT,\n176\t        requested_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n177\t        processed_at TIMESTAMPTZ\n178\t      )\n179\t    `;\n180\t    await rawSql`\n181\t      CREATE INDEX idx_referral_claims_user_id ON referral_claims (user_id, requested_at)\n182\t    `;\n183\t    await rawSql`\n184\t      CREATE INDEX idx_referral_claims_status ON referral_claims (status) WHERE status IN ('pending', 'processing')\n185\t    `;\n186\t    await rawSql`\n187\t      CREATE UNIQUE INDEX idx_referral_claims_user_active ON referral_claims (user_id) WHERE status IN ('pending', 'processing', 'error')\n188\t    `;\n189\t    await rawSql`\n190\t      CREATE TABLE referral_kol_rates (\n191\t        user_id TEXT PRIMARY KEY,\n192\t        wallet TEXT NOT NULL UNIQUE,\n193\t        rate_bps INTEGER NOT NULL,\n194\t        set_by TEXT NOT NULL,\n195\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n196\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n197\t      )\n198\t    `;\n199\t  });\n200\t\n201\t  afterAll(async () => {\n202\t    if (db) await db.close();\n203\t    await rawSql.end();\n204\t  });\n205\t\n206\t  beforeEach(async () => {\n207\t    await rawSql`TRUNCATE referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, event_queue, fee_allocation_events, fee_bucket_debits RESTART IDENTITY CASCADE`;\n208\t    // Clean + recreate profiles for test wallets — routes resolve wallet\n209\t    // from profile via db.getProfileByUserId(userId).\n210\t    await rawSql`DELETE FROM player_profiles WHERE user_id IN (${referrerUserId}, ${refereeUserId})`;\n211\t    await rawSql`\n212\t      INSERT INTO player_profiles (user_id, wallet, username)\n213\t      VALUES (${referrerUserId}, ${referrer}, ${\"ref-er-\" + Date.now()}),\n214\t             (${refereeUserId}, ${referee}, ${\"ref-ee-\" + Date.now()})\n215\t    `;\n216\t\n217\t    db = createDb(DATABASE_URL, rawSql);\n218\t\n219\t    app = new Hono();\n220\t    app.use(\n221\t      \"/referral/*\",\n222\t      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n223\t    );\n224\t    app.route(\n225\t      \"/referral\",\n226\t      createReferralRoutes({ db, sql: rawSql, config: testConfig }),\n227\t    );\n228\t  });\n229\t\n230\t  // -----------------------------------------------------------------------\n231\t  // POST /referral/code — set custom code\n232\t  // -----------------------------------------------------------------------\n233\t\n234\t  describe(\"POST /referral/code\", () => {\n235\t    it(\"sets a valid custom code and returns code + url\", async () => {\n236\t      const token = await makeJwt(referrer);\n237\t      const res = await app.request(\"/referral/code\", {\n238\t        method: \"POST\",\n239\t        ...json({ code: \"my-code-123\" }),\n240\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n241\t      });\n242\t\n243\t      expect(res.status).toBe(200);\n244\t      const body = (await res.json()) as { ok: true; data: { code: string } };\n245\t      expect(body.ok).toBe(true);\n246\t      expect(body.data.code).toBe(\"my-code-123\");\n247\t    });\n248\t\n249\t    it(\"rejects code shorter than 3 chars\", async () => {\n250\t      const token = await makeJwt(referrer);\n251\t      const res = await app.request(\"/referral/code\", {\n252\t        method: \"POST\",\n253\t        ...json({ code: \"ab\" }),\n254\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n255\t      });\n256\t\n257\t      expect(res.status).toBe(422);\n258\t      const body = (await res.json()) as {\n259\t        ok: false;\n260\t        error: { code: string };\n261\t      };\n262\t      expect(body.ok).toBe(false);\n263\t      expect(body.error.code).toBe(\"INVALID_CODE\");\n264\t    });\n265\t\n266\t    it(\"rejects code longer than 16 chars\", async () => {\n267\t      const token = await makeJwt(referrer);\n268\t      const res = await app.request(\"/referral/code\", {\n269\t        method: \"POST\",\n270\t        ...json({ code: \"abcdefghijklmnopq\" }), // 17 chars\n271\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n272\t      });\n273\t\n274\t      expect(res.status).toBe(422);\n275\t    });\n276\t\n277\t    it(\"rejects code with uppercase or special chars\", async () => {\n278\t      const token = await makeJwt(referrer);\n279\t      const res = await app.request(\"/referral/code\", {\n280\t        method: \"POST\",\n281\t        ...json({ code: \"My_Code!\" }),\n282\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n283\t      });\n284\t\n285\t      expect(res.status).toBe(422);\n286\t    });\n287\t\n288\t    it(\"returns 409 when code is taken by another wallet\", async () => {\n289\t      // First wallet takes the code\n290\t      const token1 = await makeJwt(referrer);\n291\t      await app.request(\"/referral/code\", {\n292\t        method: \"POST\",\n293\t        ...json({ code: \"taken-code\" }),\n294\t        headers: { ...json({}).headers, Authorization: `Bearer ${token1}` },\n295\t      });\n296\t\n297\t      // Second wallet tries the same code\n298\t      const token2 = await makeJwt(referee);\n299\t      const res = await app.request(\"/referral/code\", {\n300\t        method: \"POST\",\n301\t        ...json({ code: \"taken-code\" }),\n302\t        headers: { ...json({}).headers, Authorization: `Bearer ${token2}` },\n303\t      });\n304\t\n305\t      expect(res.status).toBe(409);\n306\t      const body = (await res.json()) as {\n307\t        ok: false;\n308\t        error: { code: string };\n309\t      };\n310\t      expect(body.ok).toBe(false);\n311\t      expect(body.error.code).toBe(\"CODE_TAKEN\");\n312\t    });\n313\t\n314\t    it(\"rejects changing an already-set code (codes are permanent)\", async () => {\n315\t      const token = await makeJwt(referrer);\n316\t\n317\t      // Set initial code\n318\t      await app.request(\"/referral/code\", {\n319\t        method: \"POST\",\n320\t        ...json({ code: \"first-code\" }),\n321\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n322\t      });\n323\t\n324\t      // Attempt to change — must be rejected\n325\t      const res = await app.request(\"/referral/code\", {\n326\t        method: \"POST\",\n327\t        ...json({ code: \"second-code\" }),\n328\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n329\t      });\n330\t\n331\t      expect(res.status).toBe(409);\n332\t      const body = (await res.json()) as {\n333\t        ok: false;\n334\t        error: { code: string };\n335\t      };\n336\t      expect(body.ok).toBe(false);\n337\t      expect(body.error.code).toBe(\"CODE_ALREADY_SET\");\n338\t    });\n339\t\n340\t    it(\"rejects missing body\", async () => {\n341\t      const token = await makeJwt(referrer);\n342\t      const res = await app.request(\"/referral/code\", {\n343\t        method: \"POST\",\n344\t        headers: { Authorization: `Bearer ${token}` },\n345\t      });\n346\t\n347\t      expect(res.status).toBe(422);\n348\t      const body = (await res.json()) as {\n349\t        ok: false;\n350\t        error: { code: string };\n351\t      };\n352\t      expect(body.ok).toBe(false);\n353\t      expect(body.error.code).toBe(\"INVALID_CODE\");\n354\t    });\n355\t  });\n356\t\n357\t  // -----------------------------------------------------------------------\n358\t  // GET /referral/code — retrieve current code\n359\t  // -----------------------------------------------------------------------\n360\t\n361\t  describe(\"GET /referral/code\", () => {\n362\t    it(\"returns existing code for wallet\", async () => {\n363\t      const token = await makeJwt(referrer);\n364\t\n365\t      // Set code first\n366\t      await app.request(\"/referral/code\", {\n367\t        method: \"POST\",\n368\t        ...json({ code: \"get-test\" }),\n369\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n370\t      });\n371\t\n372\t      const res = await app.request(\"/referral/code\", {\n373\t        method: \"GET\",\n374\t        headers: { Authorization: `Bearer ${token}` },\n375\t      });\n376\t\n377\t      expect(res.status).toBe(200);\n378\t      const body = (await res.json()) as { ok: true; data: { code: string } };\n379\t      expect(body.ok).toBe(true);\n380\t      expect(body.data.code).toBe(\"get-test\");\n381\t    });\n382\t\n383\t    it(\"returns 200 with null code when not set\", async () => {\n384\t      const token = await makeJwt(referrer);\n385\t      const res = await app.request(\"/referral/code\", {\n386\t        method: \"GET\",\n387\t        headers: { Authorization: `Bearer ${token}` },\n388\t      });\n389\t\n390\t      expect(res.status).toBe(200);\n391\t      const body = (await res.json()) as {\n392\t        ok: true;\n393\t        data: { code: string | null };\n394\t      };\n395\t      expect(body.ok).toBe(true);\n396\t      expect(body.data.code).toBeNull();\n397\t    });\n398\t  });\n399\t\n400\t  // -----------------------------------------------------------------------\n401\t  // POST /referral/apply — link referee to referrer\n402\t  // -----------------------------------------------------------------------\n403\t\n404\t  describe(\"POST /referral/apply\", () => {\n405\t    beforeEach(async () => {\n406\t      // Set up a referral code for the referrer\n407\t      const token = await makeJwt(referrer);\n408\t      await app.request(\"/referral/code\", {\n409\t        method: \"POST\",\n410\t        ...json({ code: \"apply-test\" }),\n411\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n412\t      });\n413\t    });\n414\t\n415\t    it(\"links referee to referrer via code\", async () => {\n416\t      const token = await makeJwt(referee);\n417\t      const res = await app.request(\"/referral/apply\", {\n418\t        method: \"POST\",\n419\t        ...json({ code: \"apply-test\" }),\n420\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n421\t      });\n422\t\n423\t      expect(res.status).toBe(200);\n424\t      const body = (await res.json()) as {\n425\t        ok: true;\n426\t        data: { referrerUserId: string; benefit: string };\n427\t      };\n428\t      expect(body.ok).toBe(true);\n429\t      expect(body.data.referrerUserId).toBe(referrerUserId);\n430\t      expect(body.data.benefit).toBe(\"Referral linked\");\n431\t    });\n432\t\n433\t    it(\"rejects self-referral with 409\", async () => {\n434\t      const token = await makeJwt(referrer); // referrer applying their own code\n435\t      const res = await app.request(\"/referral/apply\", {\n436\t        method: \"POST\",\n437\t        ...json({ code: \"apply-test\" }),\n438\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n439\t      });\n440\t\n441\t      expect(res.status).toBe(409);\n442\t      const body = (await res.json()) as {\n443\t        ok: false;\n444\t        error: { code: string };\n445\t      };\n446\t      expect(body.ok).toBe(false);\n447\t      expect(body.error.code).toBe(\"SELF_REFERRAL\");\n448\t    });\n449\t\n450\t    it(\"returns 409 when already linked to a referrer\", async () => {\n451\t      const token = await makeJwt(referee);\n452\t\n453\t      // First apply succeeds\n454\t      await app.request(\"/referral/apply\", {\n455\t        method: \"POST\",\n456\t        ...json({ code: \"apply-test\" }),\n457\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n458\t      });\n459\t\n460\t      // Set up a second referrer code (needs a profile first)\n461\t      const other = Keypair.generate().publicKey.toBase58();\n462\t      const otherUserId = userIdFromWallet(other);\n463\t      await rawSql`\n464\t        INSERT INTO player_profiles (user_id, wallet, username)\n465\t        VALUES (${otherUserId}, ${other}, ${\"test-other-\" + Date.now()})\n466\t        ON CONFLICT (user_id) DO NOTHING\n467\t      `;\n468\t      const otherToken = await makeJwt(other);\n469\t      await app.request(\"/referral/code\", {\n470\t        method: \"POST\",\n471\t        ...json({ code: \"other-code\" }),\n472\t        headers: { ...json({}).headers, Authorization: `Bearer ${otherToken}` },\n473\t      });\n474\t\n475\t      // Second apply fails\n476\t      const res = await app.request(\"/referral/apply\", {\n477\t        method: \"POST\",\n478\t        ...json({ code: \"other-code\" }),\n479\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n480\t      });\n481\t\n482\t      expect(res.status).toBe(409);\n483\t      const body = (await res.json()) as {\n484\t        ok: false;\n485\t        error: { code: string };\n486\t      };\n487\t      expect(body.ok).toBe(false);\n488\t      expect(body.error.code).toBe(\"ALREADY_LINKED\");\n489\t    });\n490\t\n491\t    it(\"returns 404 for non-existent code\", async () => {\n492\t      const token = await makeJwt(referee);\n493\t      const res = await app.request(\"/referral/apply\", {\n494\t        method: \"POST\",\n495\t        ...json({ code: \"nonexistent\" }),\n496\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n497\t      });\n498\t\n499\t      expect(res.status).toBe(404);\n500\t      const body = (await res.json()) as {\n501\t        ok: false;\n502\t        error: { code: string };\n503\t      };\n504\t      expect(body.ok).toBe(false);\n505\t      expect(body.error.code).toBe(\"CODE_NOT_FOUND\");\n506\t    });\n507\t\n508\t    it(\"rejects empty code with 422\", async () => {\n509\t      const token = await makeJwt(referee);\n510\t      const res = await app.request(\"/referral/apply\", {\n511\t        method: \"POST\",\n512\t        ...json({ code: \"\" }),\n513\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n514\t      });\n515\t\n516\t      expect(res.status).toBe(422);\n517\t    });\n518\t  });\n519\t\n520\t  // -----------------------------------------------------------------------\n521\t  // GET /referral/stats — summary stats\n522\t  // -----------------------------------------------------------------------\n523\t\n524\t  describe(\"GET /referral/stats\", () => {\n525\t    it(\"returns zeroed stats for wallet with no referrals\", async () => {\n526\t      const token = await makeJwt(referrer);\n527\t      const res = await app.request(\"/referral/stats\", {\n528\t        method: \"GET\",\n529\t        headers: { Authorization: `Bearer ${token}` },\n530\t      });\n531\t\n532\t      expect(res.status).toBe(200);\n533\t      const body = (await res.json()) as {\n534\t        ok: true;\n535\t        data: Record<string, any>;\n536\t      };\n537\t      expect(body.ok).toBe(true);\n538\t      expect(body.data.referredCount).toBe(0);\n539\t      expect(body.data.activeCount).toBe(0);\n540\t      expect(body.data.totalVolumeLamports).toBe(\"0\");\n541\t      expect(body.data.totalEarnedLamports).toBe(\"0\");\n542\t      expect(body.data.pendingLamports).toBe(\"0\");\n543\t    });\n544\t\n545\t    it(\"reflects referred count after linking\", async () => {\n546\t      // Set up referrer code + link a referee\n547\t      const referrerToken = await makeJwt(referrer);\n548\t      await app.request(\"/referral/code\", {\n549\t        method: \"POST\",\n550\t        ...json({ code: \"stats-test\" }),\n551\t        headers: { ...json({}).headers, Authorization: `Bearer ${referrerToken}` },\n552\t      });\n553\t\n554\t      const refereeToken = await makeJwt(referee);\n555\t      await app.request(\"/referral/apply\", {\n556\t        method: \"POST\",\n557\t        ...json({ code: \"stats-test\" }),\n558\t        headers: { ...json({}).headers, Authorization: `Bearer ${refereeToken}` },\n559\t      });\n560\t\n561\t      const res = await app.request(\"/referral/stats\", {\n562\t        method: \"GET\",\n563\t        headers: { Authorization: `Bearer ${referrerToken}` },\n564\t      });\n565\t\n566\t      expect(res.status).toBe(200);\n567\t      const body = (await res.json()) as {\n568\t        ok: true;\n569\t        data: { referredCount: number };\n570\t      };\n571\t      expect(body.ok).toBe(true);\n572\t      expect(body.data.referredCount).toBe(1);\n573\t    });\n574\t  });\n575\t\n576\t  // -----------------------------------------------------------------------\n577\t  // GET /referral/earnings — paginated earnings\n578\t  // -----------------------------------------------------------------------\n579\t\n580\t  describe(\"GET /referral/earnings\", () => {\n581\t    it(\"returns empty items when no earnings exist\", async () => {\n582\t      const token = await makeJwt(referrer);\n583\t      const res = await app.request(\"/referral/earnings\", {\n584\t        method: \"GET\",\n585\t        headers: { Authorization: `Bearer ${token}` },\n586\t      });\n587\t\n588\t      expect(res.status).toBe(200);\n589\t      const body = (await res.json()) as {\n590\t        ok: true;\n591\t        data: {\n592\t          items: unknown[];\n593\t          pagination: { page: number; totalPages: number };\n594\t        };\n595\t      };\n596\t      expect(body.ok).toBe(true);\n597\t      expect(body.data.items).toHaveLength(0);\n598\t      expect(body.data.pagination.page).toBe(1);\n599\t      expect(body.data.pagination.totalPages).toBe(1); // min 1 page even when empty\n600\t    });\n601\t\n602\t    it(\"returns earnings after inserting one\", async () => {\n603\t      // Insert an earning directly via DB\n604\t      await db.insertReferralEarning({\n605\t        referrerUserId,\n606\t        refereeUserId,\n607\t        referrerWallet: referrer,\n608\t        refereeWallet: referee,\n609\t        roundId: \"test-round-001\",\n610\t        gameType: \"flipyou\",\n611\t        wagerLamports: 1_000_000_000,\n612\t        feeLamports: 50_000_000,\n613\t        referrerEarnedLamports: 5_000_000,\n614\t        referrerRateBps: 1000,\n615\t      });\n616\t\n617\t      const token = await makeJwt(referrer);\n618\t      const res = await app.request(\"/referral/earnings\", {\n619\t        method: \"GET\",\n620\t        headers: { Authorization: `Bearer ${token}` },\n621\t      });\n622\t\n623\t      expect(res.status).toBe(200);\n624\t      const body = (await res.json()) as {\n625\t        ok: true;\n626\t        data: {\n627\t          items: Array<{\n628\t            roundId: string;\n629\t            gameType: string;\n630\t            refereeUserId: string;\n631\t            wagerLamports: string;\n632\t            earnedLamports: string;\n633\t            createdAt: string;\n634\t          }>;\n635\t          pagination: { page: number; totalPages: number };\n636\t        };\n637\t      };\n638\t      expect(body.ok).toBe(true);\n639\t      expect(body.data.items).toHaveLength(1);\n640\t      expect(body.data.items[0]!.roundId).toBe(\"test-round-001\");\n641\t      expect(body.data.items[0]!.gameType).toBe(\"flipyou\");\n642\t      expect(body.data.items[0]!.refereeUserId).toBe(refereeUserId);\n643\t      expect(body.data.items[0]!.wagerLamports).toBe(\"1000000000\");\n644\t      expect(body.data.items[0]!.earnedLamports).toBe(\"5000000\");\n645\t      expect(body.data.pagination.totalPages).toBe(1);\n646\t    });\n647\t\n648\t    it(\"respects page and limit query params\", async () => {\n649\t      // Insert 3 earnings\n650\t      for (let i = 1; i <= 3; i++) {\n651\t        await db.insertReferralEarning({\n652\t          referrerUserId,\n653\t          refereeUserId,\n654\t          referrerWallet: referrer,\n655\t          refereeWallet: referee,\n656\t          roundId: `round-${i}`,\n657\t          gameType: \"flipyou\",\n658\t          wagerLamports: 1_000_000_000,\n659\t          feeLamports: 50_000_000,\n660\t          referrerEarnedLamports: 5_000_000,\n661\t          referrerRateBps: 1000,\n662\t        });\n663\t      }\n664\t\n665\t      const token = await makeJwt(referrer);\n666\t      const res = await app.request(\"/referral/earnings?page=1&limit=2\", {\n667\t        method: \"GET\",\n668\t        headers: { Authorization: `Bearer ${token}` },\n669\t      });\n670\t\n671\t      expect(res.status).toBe(200);\n672\t      const body = (await res.json()) as {\n673\t        ok: true;\n674\t        data: {\n675\t          items: unknown[];\n676\t          pagination: { page: number; totalPages: number };\n677\t        };\n678\t      };\n679\t      expect(body.ok).toBe(true);\n680\t      expect(body.data.items).toHaveLength(2);\n681\t      expect(body.data.pagination.totalPages).toBe(2);\n682\t    });\n683\t  });\n684\t\n685\t  // -----------------------------------------------------------------------\n686\t  // POST /referral/claim — claim flow\n687\t  // -----------------------------------------------------------------------\n688\t\n689\t  describe(\"POST /referral/claim\", () => {\n690\t    it(\"rejects claim with zero balance\", async () => {\n691\t      const token = await makeJwt(referrer);\n692\t      const res = await app.request(\"/referral/claim\", {\n693\t        method: \"POST\",\n694\t        headers: {\n695\t          \"Content-Type\": \"application/json\",\n696\t          Authorization: `Bearer ${token}`,\n697\t        },\n698\t      });\n699\t\n700\t      expect(res.status).toBe(422);\n701\t      const body = (await res.json()) as {\n702\t        ok: false;\n703\t        error: { code: string };\n704\t      };\n705\t      expect(body.ok).toBe(false);\n706\t      expect(body.error.code).toBe(\"ZERO_BALANCE\");\n707\t    });\n708\t\n709\t    it(\"rejects claim below minimum threshold\", async () => {\n710\t      // Insert a small earning (below 0.01 SOL threshold)\n711\t      await db.insertReferralEarning({\n712\t        referrerUserId,\n713\t        refereeUserId,\n714\t        referrerWallet: referrer,\n715\t        refereeWallet: referee,\n716\t        roundId: \"small-round\",\n717\t        gameType: \"flipyou\",\n718\t        wagerLamports: 100_000_000, // 0.1 SOL\n719\t        feeLamports: 5_000_000, // 0.005 SOL\n720\t        referrerEarnedLamports: 500_000, // 0.0005 SOL — below 0.01 threshold\n721\t        referrerRateBps: 1000,\n722\t      });\n723\t      await seedFeeAllocation({\n724\t        sourceId: \"small-round\",\n725\t        feeLamports: 5_000_000,\n726\t        referrerEarnedLamports: 500_000,\n727\t        referrerRateBps: 1000,\n728\t        wagerLamports: 100_000_000,\n729\t      });\n730\t\n731\t      const token = await makeJwt(referrer);\n732\t      const res = await app.request(\"/referral/claim\", {\n733\t        method: \"POST\",\n734\t        headers: {\n735\t          \"Content-Type\": \"application/json\",\n736\t          Authorization: `Bearer ${token}`,\n737\t        },\n738\t      });\n739\t\n740\t      expect(res.status).toBe(422);\n741\t      const body = (await res.json()) as {\n742\t        ok: false;\n743\t        error: { code: string };\n744\t      };\n745\t      expect(body.ok).toBe(false);\n746\t      expect(body.error.code).toBe(\"BELOW_THRESHOLD\");\n747\t    });\n748\t\n749\t    it(\"creates a pending claim for valid balance\", async () => {\n750\t      // Insert a large enough earning\n751\t      await db.insertReferralEarning({\n752\t        referrerUserId,\n753\t        refereeUserId,\n754\t        referrerWallet: referrer,\n755\t        refereeWallet: referee,\n756\t        roundId: \"big-round\",\n757\t        gameType: \"flipyou\",\n758\t        wagerLamports: 10_000_000_000, // 10 SOL\n759\t        feeLamports: 500_000_000, // 0.5 SOL\n760\t        referrerEarnedLamports: 50_000_000, // 0.05 SOL — above threshold\n761\t        referrerRateBps: 1000,\n762\t      });\n763\t      await seedFeeAllocation({\n764\t        sourceId: \"big-round\",\n765\t        feeLamports: 500_000_000,\n766\t        referrerEarnedLamports: 50_000_000,\n767\t        referrerRateBps: 1000,\n768\t        wagerLamports: 10_000_000_000,\n769\t      });\n770\t\n771\t      const token = await makeJwt(referrer);\n772\t      const res = await app.request(\"/referral/claim\", {\n773\t        method: \"POST\",\n774\t        headers: {\n775\t          \"Content-Type\": \"application/json\",\n776\t          Authorization: `Bearer ${token}`,\n777\t        },\n778\t      });\n779\t\n780\t      expect(res.status).toBe(202);\n781\t      const body = (await res.json()) as {\n782\t        ok: true;\n783\t        data: {\n784\t          claimId: string;\n785\t          amountLamports: string;\n786\t          status: string;\n787\t        };\n788\t      };\n789\t      expect(body.ok).toBe(true);\n790\t      expect(body.data.claimId).toBeDefined();\n791\t      expect(body.data.amountLamports).toBe(\"50000000\");\n792\t      expect(body.data.status).toBe(\"pending\");\n793\t\n794\t      // Verify event was emitted\n795\t      const events =\n796\t        await rawSql`SELECT * FROM event_queue WHERE event_type = 'referral.claim_requested'`;\n797\t      expect(events.length).toBe(1);\n798\t    });\n799\t\n800\t    it(\"prevents double-claim by deducting pending balance\", async () => {\n801\t      // Insert earning\n802\t      await db.insertReferralEarning({\n803\t        referrerUserId,\n804\t        refereeUserId,\n805\t        referrerWallet: referrer,\n806\t        refereeWallet: referee,\n807\t        roundId: \"double-round\",\n808\t        gameType: \"flipyou\",\n809\t        wagerLamports: 10_000_000_000,\n810\t        feeLamports: 500_000_000,\n811\t        referrerEarnedLamports: 50_000_000,\n812\t        referrerRateBps: 1000,\n813\t      });\n814\t      await seedFeeAllocation({\n815\t        sourceId: \"double-round\",\n816\t        feeLamports: 500_000_000,\n817\t        referrerEarnedLamports: 50_000_000,\n818\t        referrerRateBps: 1000,\n819\t        wagerLamports: 10_000_000_000,\n820\t      });\n821\t\n822\t      const token = await makeJwt(referrer);\n823\t\n824\t      // First claim succeeds\n825\t      const res1 = await app.request(\"/referral/claim\", {\n826\t        method: \"POST\",\n827\t        headers: {\n828\t          \"Content-Type\": \"application/json\",\n829\t          Authorization: `Bearer ${token}`,\n830\t        },\n831\t      });\n832\t      expect(res1.status).toBe(202);\n833\t\n834\t      // Second claim fails — balance consumed by pending claim\n835\t      const res2 = await app.request(\"/referral/claim\", {\n836\t        method: \"POST\",\n837\t        headers: {\n838\t          \"Content-Type\": \"application/json\",\n839\t          Authorization: `Bearer ${token}`,\n840\t        },\n841\t      });\n842\t      expect(res2.status).toBe(422);\n843\t      const body = (await res2.json()) as {\n844\t        ok: false;\n845\t        error: { code: string };\n846\t      };\n847\t      expect(body.ok).toBe(false);\n848\t      expect(body.error.code).toBe(\"ZERO_BALANCE\");\n849\t    });\n850\t  });\n851\t\n852\t  // -----------------------------------------------------------------------\n853\t  // GET /referral/claim/:claimId — poll claim status\n854\t  // -----------------------------------------------------------------------\n855\t\n856\t  describe(\"GET /referral/claim/:claimId\", () => {\n857\t    it(\"returns claim status for the owner\", async () => {\n858\t      // Insert earning + create claim\n859\t      await db.insertReferralEarning({\n860\t        referrerUserId,\n861\t        refereeUserId,\n862\t        referrerWallet: referrer,\n863\t        refereeWallet: referee,\n864\t        roundId: \"poll-round\",\n865\t        gameType: \"flipyou\",\n866\t        wagerLamports: 10_000_000_000,\n867\t        feeLamports: 500_000_000,\n868\t        referrerEarnedLamports: 50_000_000,\n869\t        referrerRateBps: 1000,\n870\t      });\n871\t      await seedFeeAllocation({\n872\t        sourceId: \"poll-round\",\n873\t        feeLamports: 500_000_000,\n874\t        referrerEarnedLamports: 50_000_000,\n875\t        referrerRateBps: 1000,\n876\t        wagerLamports: 10_000_000_000,\n877\t      });\n878\t\n879\t      const token = await makeJwt(referrer);\n880\t      const claimRes = await app.request(\"/referral/claim\", {\n881\t        method: \"POST\",\n882\t        headers: {\n883\t          \"Content-Type\": \"application/json\",\n884\t          Authorization: `Bearer ${token}`,\n885\t        },\n886\t      });\n887\t      const claimBody = (await claimRes.json()) as {\n888\t        ok: true;\n889\t        data: { claimId: string };\n890\t      };\n891\t      const claim = claimBody.data;\n892\t\n893\t      // Poll status\n894\t      const res = await app.request(`/referral/claim/${claim.claimId}`, {\n895\t        method: \"GET\",\n896\t        headers: { Authorization: `Bearer ${token}` },\n897\t      });\n898\t\n899\t      expect(res.status).toBe(200);\n900\t      const body = (await res.json()) as {\n901\t        ok: true;\n902\t        data: {\n903\t          claimId: string;\n904\t          amountLamports: string;\n905\t          status: string;\n906\t        };\n907\t      };\n908\t      expect(body.ok).toBe(true);\n909\t      expect(body.data.claimId).toBe(claim.claimId);\n910\t      expect(body.data.status).toBe(\"pending\");\n911\t    });\n912\t\n913\t    it(\"returns 404 for non-existent claim\", async () => {\n914\t      const token = await makeJwt(referrer);\n915\t      const res = await app.request(\n916\t        \"/referral/claim/00000000-0000-0000-0000-000000000000\",\n917\t        {\n918\t          method: \"GET\",\n919\t          headers: { Authorization: `Bearer ${token}` },\n920\t        },\n921\t      );\n922\t\n923\t      expect(res.status).toBe(404);\n924\t      const body = (await res.json()) as {\n925\t        ok: false;\n926\t        error: { code: string };\n927\t      };\n928\t      expect(body.ok).toBe(false);\n929\t      expect(body.error.code).toBe(\"CLAIM_NOT_FOUND\");\n930\t    });\n931\t\n932\t    it(\"returns 404 when another wallet tries to view a claim\", async () => {\n933\t      // Create earning + claim as referrer\n934\t      await db.insertReferralEarning({\n935\t        referrerUserId,\n936\t        refereeUserId,\n937\t        referrerWallet: referrer,\n938\t        refereeWallet: referee,\n939\t        roundId: \"auth-round\",\n940\t        gameType: \"flipyou\",\n941\t        wagerLamports: 10_000_000_000,\n942\t        feeLamports: 500_000_000,\n943\t        referrerEarnedLamports: 50_000_000,\n944\t        referrerRateBps: 1000,\n945\t      });\n946\t      await seedFeeAllocation({\n947\t        sourceId: \"auth-round\",\n948\t        feeLamports: 500_000_000,\n949\t        referrerEarnedLamports: 50_000_000,\n950\t        referrerRateBps: 1000,\n951\t        wagerLamports: 10_000_000_000,\n952\t      });\n953\t\n954\t      const referrerToken = await makeJwt(referrer);\n955\t      const claimRes = await app.request(\"/referral/claim\", {\n956\t        method: \"POST\",\n957\t        headers: {\n958\t          \"Content-Type\": \"application/json\",\n959\t          Authorization: `Bearer ${referrerToken}`,\n960\t        },\n961\t      });\n962\t      const claimBody = (await claimRes.json()) as {\n963\t        ok: true;\n964\t        data: { claimId: string };\n965\t      };\n966\t      const claim = claimBody.data;\n967\t\n968\t      // Try to view as referee (different wallet)\n969\t      const refereeToken = await makeJwt(referee);\n970\t      const res = await app.request(`/referral/claim/${claim.claimId}`, {\n971\t        method: \"GET\",\n972\t        headers: { Authorization: `Bearer ${refereeToken}` },\n973\t      });\n974\t\n975\t      expect(res.status).toBe(404);\n976\t      const body = (await res.json()) as {\n977\t        ok: false;\n978\t        error: { code: string };\n979\t      };\n980\t      expect(body.ok).toBe(false);\n981\t      expect(body.error.code).toBe(\"CLAIM_NOT_FOUND\");\n982\t    });\n983\t  });\n984\t\n985\t  // -----------------------------------------------------------------------\n986\t  // GET /referral/referrer — check referrer status\n987\t  // -----------------------------------------------------------------------\n988\t\n989\t  describe(\"GET /referral/referrer\", () => {\n990\t    it(\"returns 200 with null fields when not referred\", async () => {\n991\t      const token = await makeJwt(referee);\n992\t      const res = await app.request(\"/referral/referrer\", {\n993\t        method: \"GET\",\n994\t        headers: { Authorization: `Bearer ${token}` },\n995\t      });\n996\t\n997\t      expect(res.status).toBe(200);\n998\t      const body = (await res.json()) as {\n999\t        ok: true;\n1000\t        data: {\n1001\t          referrerUserId: string | null;\n1002\t          referrerUsername: string | null;\n1003\t          referrerCode: string | null;\n1004\t          linkedAt: string | null;\n1005\t        };\n1006\t      };\n1007\t      expect(body.ok).toBe(true);\n1008\t      expect(body.data.referrerUserId).toBeNull();\n1009\t      expect(body.data.referrerUsername).toBeNull();\n1010\t      expect(body.data.referrerCode).toBeNull();\n1011\t      expect(body.data.linkedAt).toBeNull();\n1012\t    });\n1013\t\n1014\t    it(\"returns referrer wallet after linking\", async () => {\n1015\t      // Set up code + apply\n1016\t      const referrerToken = await makeJwt(referrer);\n1017\t      await app.request(\"/referral/code\", {\n1018\t        method: \"POST\",\n1019\t        ...json({ code: \"referrer-test\" }),\n1020\t        headers: { ...json({}).headers, Authorization: `Bearer ${referrerToken}` },\n1021\t      });\n1022\t\n1023\t      const refereeToken = await makeJwt(referee);\n1024\t      await app.request(\"/referral/apply\", {\n1025\t        method: \"POST\",\n1026\t        ...json({ code: \"referrer-test\" }),\n1027\t        headers: { ...json({}).headers, Authorization: `Bearer ${refereeToken}` },\n1028\t      });\n1029\t\n1030\t      const res = await app.request(\"/referral/referrer\", {\n1031\t        method: \"GET\",\n1032\t        headers: { Authorization: `Bearer ${refereeToken}` },\n1033\t      });\n1034\t\n1035\t      expect(res.status).toBe(200);\n1036\t      const body = (await res.json()) as {\n1037\t        ok: true;\n1038\t        data: {\n1039\t          referrerUserId: string;\n1040\t          linkedAt: string;\n1041\t        };\n1042\t      };\n1043\t      expect(body.ok).toBe(true);\n1044\t      expect(body.data.referrerUserId).toBe(referrerUserId);\n1045\t      expect(body.data.linkedAt).toBeDefined();\n1046\t    });\n1047\t  });\n1048\t\n1049\t  // -----------------------------------------------------------------------\n1050\t  // Auth — missing JWT\n1051\t  // -----------------------------------------------------------------------\n1052\t\n1053\t  describe(\"Authentication\", () => {\n1054\t    it(\"returns 401 for requests without JWT\", async () => {\n1055\t      const res = await app.request(\"/referral/stats\", { method: \"GET\" });\n1056\t      expect(res.status).toBe(401);\n1057\t    });\n1058\t  });\n1059\t});\n1060\t"}]},"parent_tool_use_id":null,"session_id":"896d4934-c43e-44ca-831c-60139b475f70","uuid":"49f1d3f7-bfac-44e5-84d6-307a0bb9861b","timestamp":"2026-05-01T20:26:31.935Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/referral-routes.test.ts","content":"/* eslint-disable @typescript-eslint/no-explicit-any */\n/**\n * Referral route tests — set code, apply, stats, earnings, claim flows.\n *\n * Uses real Postgres (same pattern as auth-routes.test.ts) with TRUNCATE\n * between tests for isolation.\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport { SignJWT } from \"jose\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createReferralRoutes } from \"../routes/referral.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport type { Config } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-referral-tests\");\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  // Dev container: postgres listens on Unix socket only\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"taunt_bet_dev\",\n  });\n}\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\nasync function makeJwt(wallet: string): Promise<string> {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({})\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userIdFromWallet(wallet))\n    .setIssuedAt(now)\n    .setExpirationTime(now + 3600)\n    .sign(JWT_SECRET);\n}\n\nfunction json(body: Record<string, any>) {\n  return {\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify(body),\n  };\n}\n\nfunction userIdFromWallet(wallet: string) {\n  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n}\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"Referral routes\", () => {\n  let rawSql: ReturnType<typeof postgres>;\n  let db: Db;\n  let app: Hono;\n\n  const referrerKp = Keypair.generate();\n  const refereeKp = Keypair.generate();\n  const referrer = referrerKp.publicKey.toBase58();\n  const referee = refereeKp.publicKey.toBase58();\n  const referrerUserId = userIdFromWallet(referrer);\n  const refereeUserId = userIdFromWallet(referee);\n\n  const testConfig = {\n    referralDefaultRateBps: 1000,\n    referralMinClaimLamports: 10_000_000, // 0.01 SOL\n  } as Config;\n\n  // Mirror an `insertReferralEarning` fixture into the fee accounting ledger\n  // so the claim route's ledger-derived caps see the same balance.\n  async function seedFeeAllocation(params: {\n    sourceId: string;\n    feeLamports: number;\n    referrerEarnedLamports: number;\n    referrerRateBps: number;\n    wagerLamports: number;\n  }) {\n    const postReferral = params.feeLamports - params.referrerEarnedLamports;\n    const promotionsLamports = Math.floor((postReferral * 2000) / 10000);\n    const profitLamports = postReferral - promotionsLamports;\n    await db.insertFeeAllocation({\n      sourceType: \"flipyou\",\n      sourceId: params.sourceId,\n      gameType: \"flipyou\",\n      wallet: referee,\n      userId: refereeUserId,\n      wagerLamports: params.wagerLamports,\n      feeLamports: params.feeLamports,\n      referrerUserId,\n      referralRateBps: params.referrerRateBps,\n      referralLamports: params.referrerEarnedLamports,\n      promotionsLamports,\n      profitLamports,\n    });\n  }\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n    await rawSql`\n      DROP TABLE IF EXISTS referral_claims, referral_earnings, referral_links, referral_codes, referral_kol_rates CASCADE\n    `;\n    await rawSql`\n      CREATE TABLE referral_codes (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        user_id TEXT NOT NULL UNIQUE,\n        wallet TEXT NOT NULL UNIQUE,\n        code TEXT NOT NULL UNIQUE,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE referral_links (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        referrer_user_id TEXT NOT NULL,\n        referee_user_id TEXT NOT NULL UNIQUE,\n        referrer_wallet TEXT NOT NULL,\n        referee_wallet TEXT NOT NULL,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_links_referrer ON referral_links (referrer_user_id)\n    `;\n    await rawSql`\n      CREATE TABLE referral_earnings (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        referrer_user_id TEXT NOT NULL,\n        referee_user_id TEXT NOT NULL,\n        referrer_wallet TEXT NOT NULL,\n        referee_wallet TEXT NOT NULL,\n        round_id TEXT NOT NULL,\n        game_type TEXT NOT NULL,\n        wager_lamports BIGINT NOT NULL,\n        fee_lamports BIGINT NOT NULL,\n        referrer_earned_lamports BIGINT NOT NULL,\n        referrer_rate_bps INTEGER NOT NULL,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        CONSTRAINT uq_referral_earnings_referee_round UNIQUE (referee_user_id, round_id)\n      )\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_earnings_referrer ON referral_earnings (referrer_user_id, created_at)\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_earnings_referee ON referral_earnings (referee_user_id, created_at)\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_earnings_round_id ON referral_earnings (round_id)\n    `;\n    await rawSql`\n      CREATE TABLE referral_claims (\n        id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n        user_id TEXT NOT NULL,\n        wallet TEXT NOT NULL,\n        amount_lamports BIGINT NOT NULL,\n        status TEXT NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'error', 'completed', 'failed')),\n        retry_count INTEGER NOT NULL DEFAULT 0,\n        tx_signature TEXT,\n        error TEXT,\n        requested_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        processed_at TIMESTAMPTZ\n      )\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_claims_user_id ON referral_claims (user_id, requested_at)\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_claims_status ON referral_claims (status) WHERE status IN ('pending', 'processing')\n    `;\n    await rawSql`\n      CREATE UNIQUE INDEX idx_referral_claims_user_active ON referral_claims (user_id) WHERE status IN ('pending', 'processing', 'error')\n    `;\n    await rawSql`\n      CREATE TABLE referral_kol_rates (\n        user_id TEXT PRIMARY KEY,\n        wallet TEXT NOT NULL UNIQUE,\n        rate_bps INTEGER NOT NULL,\n        set_by TEXT NOT NULL,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n  });\n\n  afterAll(async () => {\n    if (db) await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, event_queue, fee_allocation_events, fee_bucket_debits RESTART IDENTITY CASCADE`;\n    // Clean + recreate profiles for test wallets — routes resolve wallet\n    // from profile via db.getProfileByUserId(userId).\n    await rawSql`DELETE FROM player_profiles WHERE user_id IN (${referrerUserId}, ${refereeUserId})`;\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${referrerUserId}, ${referrer}, ${\"ref-er-\" + Date.now()}),\n             (${refereeUserId}, ${referee}, ${\"ref-ee-\" + Date.now()})\n    `;\n\n    db = createDb(DATABASE_URL, rawSql);\n\n    app = new Hono();\n    app.use(\n      \"/referral/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n    );\n    app.route(\n      \"/referral\",\n      createReferralRoutes({ db, sql: rawSql, config: testConfig }),\n    );\n  });\n\n  // -----------------------------------------------------------------------\n  // POST /referral/code — set custom code\n  // -----------------------------------------------------------------------\n\n  describe(\"POST /referral/code\", () => {\n    it(\"sets a valid custom code and returns code + url\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"my-code-123\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as { ok: true; data: { code: string } };\n      expect(body.ok).toBe(true);\n      expect(body.data.code).toBe(\"my-code-123\");\n    });\n\n    it(\"rejects code shorter than 3 chars\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"ab\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(422);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"INVALID_CODE\");\n    });\n\n    it(\"rejects code longer than 16 chars\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"abcdefghijklmnopq\" }), // 17 chars\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(422);\n    });\n\n    it(\"rejects code with uppercase or special chars\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"My_Code!\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(422);\n    });\n\n    it(\"returns 409 when code is taken by another wallet\", async () => {\n      // First wallet takes the code\n      const token1 = await makeJwt(referrer);\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"taken-code\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token1}` },\n      });\n\n      // Second wallet tries the same code\n      const token2 = await makeJwt(referee);\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"taken-code\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token2}` },\n      });\n\n      expect(res.status).toBe(409);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"CODE_TAKEN\");\n    });\n\n    it(\"rejects changing an already-set code (codes are permanent)\", async () => {\n      const token = await makeJwt(referrer);\n\n      // Set initial code\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"first-code\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      // Attempt to change — must be rejected\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"second-code\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(409);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"CODE_ALREADY_SET\");\n    });\n\n    it(\"rejects missing body\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(422);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"INVALID_CODE\");\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /referral/code — retrieve current code\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /referral/code\", () => {\n    it(\"returns existing code for wallet\", async () => {\n      const token = await makeJwt(referrer);\n\n      // Set code first\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"get-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      const res = await app.request(\"/referral/code\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as { ok: true; data: { code: string } };\n      expect(body.ok).toBe(true);\n      expect(body.data.code).toBe(\"get-test\");\n    });\n\n    it(\"returns 200 with null code when not set\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/code\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        ok: true;\n        data: { code: string | null };\n      };\n      expect(body.ok).toBe(true);\n      expect(body.data.code).toBeNull();\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // POST /referral/apply — link referee to referrer\n  // -----------------------------------------------------------------------\n\n  describe(\"POST /referral/apply\", () => {\n    beforeEach(async () => {\n      // Set up a referral code for the referrer\n      const token = await makeJwt(referrer);\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"apply-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n    });\n\n    it(\"links referee to referrer via code\", async () => {\n      const token = await makeJwt(referee);\n      const res = await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"apply-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        ok: true;\n        data: { referrerUserId: string; benefit: string };\n      };\n      expect(body.ok).toBe(true);\n      expect(body.data.referrerUserId).toBe(referrerUserId);\n      expect(body.data.benefit).toBe(\"Referral linked\");\n    });\n\n    it(\"rejects self-referral with 409\", async () => {\n      const token = await makeJwt(referrer); // referrer applying their own code\n      const res = await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"apply-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(409);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"SELF_REFERRAL\");\n    });\n\n    it(\"returns 409 when already linked to a referrer\", async () => {\n      const token = await makeJwt(referee);\n\n      // First apply succeeds\n      await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"apply-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      // Set up a second referrer code (needs a profile first)\n      const other = Keypair.generate().publicKey.toBase58();\n      const otherUserId = userIdFromWallet(other);\n      await rawSql`\n        INSERT INTO player_profiles (user_id, wallet, username)\n        VALUES (${otherUserId}, ${other}, ${\"test-other-\" + Date.now()})\n        ON CONFLICT (user_id) DO NOTHING\n      `;\n      const otherToken = await makeJwt(other);\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"other-code\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${otherToken}` },\n      });\n\n      // Second apply fails\n      const res = await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"other-code\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(409);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"ALREADY_LINKED\");\n    });\n\n    it(\"returns 404 for non-existent code\", async () => {\n      const token = await makeJwt(referee);\n      const res = await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"nonexistent\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(404);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"CODE_NOT_FOUND\");\n    });\n\n    it(\"rejects empty code with 422\", async () => {\n      const token = await makeJwt(referee);\n      const res = await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(422);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /referral/stats — summary stats\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /referral/stats\", () => {\n    it(\"returns zeroed stats for wallet with no referrals\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/stats\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        ok: true;\n        data: Record<string, any>;\n      };\n      expect(body.ok).toBe(true);\n      expect(body.data.referredCount).toBe(0);\n      expect(body.data.activeCount).toBe(0);\n      expect(body.data.totalVolumeLamports).toBe(\"0\");\n      expect(body.data.totalEarnedLamports).toBe(\"0\");\n      expect(body.data.pendingLamports).toBe(\"0\");\n    });\n\n    it(\"reflects referred count after linking\", async () => {\n      // Set up referrer code + link a referee\n      const referrerToken = await makeJwt(referrer);\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"stats-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${referrerToken}` },\n      });\n\n      const refereeToken = await makeJwt(referee);\n      await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"stats-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${refereeToken}` },\n      });\n\n      const res = await app.request(\"/referral/stats\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${referrerToken}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        ok: true;\n        data: { referredCount: number };\n      };\n      expect(body.ok).toBe(true);\n      expect(body.data.referredCount).toBe(1);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /referral/earnings — paginated earnings\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /referral/earnings\", () => {\n    it(\"returns empty items when no earnings exist\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/earnings\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        ok: true;\n        data: {\n          items: unknown[];\n          pagination: { page: number; totalPages: number };\n        };\n      };\n      expect(body.ok).toBe(true);\n      expect(body.data.items).toHaveLength(0);\n      expect(body.data.pagination.page).toBe(1);\n      expect(body.data.pagination.totalPages).toBe(1); // min 1 page even when empty\n    });\n\n    it(\"returns earnings after inserting one\", async () => {\n      // Insert an earning directly via DB\n      await db.insertReferralEarning({\n        referrerUserId,\n        refereeUserId,\n        referrerWallet: referrer,\n        refereeWallet: referee,\n        roundId: \"test-round-001\",\n        gameType: \"flipyou\",\n        wagerLamports: 1_000_000_000,\n        feeLamports: 50_000_000,\n        referrerEarnedLamports: 5_000_000,\n        referrerRateBps: 1000,\n      });\n\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/earnings\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        ok: true;\n        data: {\n          items: Array<{\n            roundId: string;\n            gameType: string;\n            refereeUserId: string;\n            wagerLamports: string;\n            earnedLamports: string;\n            createdAt: string;\n          }>;\n          pagination: { page: number; totalPages: number };\n        };\n      };\n      expect(body.ok).toBe(true);\n      expect(body.data.items).toHaveLength(1);\n      expect(body.data.items[0]!.roundId).toBe(\"test-round-001\");\n      expect(body.data.items[0]!.gameType).toBe(\"flipyou\");\n      expect(body.data.items[0]!.refereeUserId).toBe(refereeUserId);\n      expect(body.data.items[0]!.wagerLamports).toBe(\"1000000000\");\n      expect(body.data.items[0]!.earnedLamports).toBe(\"5000000\");\n      expect(body.data.pagination.totalPages).toBe(1);\n    });\n\n    it(\"respects page and limit query params\", async () => {\n      // Insert 3 earnings\n      for (let i = 1; i <= 3; i++) {\n        await db.insertReferralEarning({\n          referrerUserId,\n          refereeUserId,\n          referrerWallet: referrer,\n          refereeWallet: referee,\n          roundId: `round-${i}`,\n          gameType: \"flipyou\",\n          wagerLamports: 1_000_000_000,\n          feeLamports: 50_000_000,\n          referrerEarnedLamports: 5_000_000,\n          referrerRateBps: 1000,\n        });\n      }\n\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/earnings?page=1&limit=2\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        ok: true;\n        data: {\n          items: unknown[];\n          pagination: { page: number; totalPages: number };\n        };\n      };\n      expect(body.ok).toBe(true);\n      expect(body.data.items).toHaveLength(2);\n      expect(body.data.pagination.totalPages).toBe(2);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // POST /referral/claim — claim flow\n  // -----------------------------------------------------------------------\n\n  describe(\"POST /referral/claim\", () => {\n    it(\"rejects claim with zero balance\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n\n      expect(res.status).toBe(422);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"ZERO_BALANCE\");\n    });\n\n    it(\"rejects claim below minimum threshold\", async () => {\n      // Insert a small earning (below 0.01 SOL threshold)\n      await db.insertReferralEarning({\n        referrerUserId,\n        refereeUserId,\n        referrerWallet: referrer,\n        refereeWallet: referee,\n        roundId: \"small-round\",\n        gameType: \"flipyou\",\n        wagerLamports: 100_000_000, // 0.1 SOL\n        feeLamports: 5_000_000, // 0.005 SOL\n        referrerEarnedLamports: 500_000, // 0.0005 SOL — below 0.01 threshold\n        referrerRateBps: 1000,\n      });\n      await seedFeeAllocation({\n        sourceId: \"small-round\",\n        feeLamports: 5_000_000,\n        referrerEarnedLamports: 500_000,\n        referrerRateBps: 1000,\n        wagerLamports: 100_000_000,\n      });\n\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n\n      expect(res.status).toBe(422);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"BELOW_THRESHOLD\");\n    });\n\n    it(\"creates a pending claim for valid balance\", async () => {\n      // Insert a large enough earning\n      await db.insertReferralEarning({\n        referrerUserId,\n        refereeUserId,\n        referrerWallet: referrer,\n        refereeWallet: referee,\n        roundId: \"big-round\",\n        gameType: \"flipyou\",\n        wagerLamports: 10_000_000_000, // 10 SOL\n        feeLamports: 500_000_000, // 0.5 SOL\n        referrerEarnedLamports: 50_000_000, // 0.05 SOL — above threshold\n        referrerRateBps: 1000,\n      });\n      await seedFeeAllocation({\n        sourceId: \"big-round\",\n        feeLamports: 500_000_000,\n        referrerEarnedLamports: 50_000_000,\n        referrerRateBps: 1000,\n        wagerLamports: 10_000_000_000,\n      });\n\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n\n      expect(res.status).toBe(202);\n      const body = (await res.json()) as {\n        ok: true;\n        data: {\n          claimId: string;\n          amountLamports: string;\n          status: string;\n        };\n      };\n      expect(body.ok).toBe(true);\n      expect(body.data.claimId).toBeDefined();\n      expect(body.data.amountLamports).toBe(\"50000000\");\n      expect(body.data.status).toBe(\"pending\");\n\n      // Verify event was emitted\n      const events =\n        await rawSql`SELECT * FROM event_queue WHERE event_type = 'referral.claim_requested'`;\n      expect(events.length).toBe(1);\n    });\n\n    it(\"prevents double-claim by deducting pending balance\", async () => {\n      // Insert earning\n      await db.insertReferralEarning({\n        referrerUserId,\n        refereeUserId,\n        referrerWallet: referrer,\n        refereeWallet: referee,\n        roundId: \"double-round\",\n        gameType: \"flipyou\",\n        wagerLamports: 10_000_000_000,\n        feeLamports: 500_000_000,\n        referrerEarnedLamports: 50_000_000,\n        referrerRateBps: 1000,\n      });\n      await seedFeeAllocation({\n        sourceId: \"double-round\",\n        feeLamports: 500_000_000,\n        referrerEarnedLamports: 50_000_000,\n        referrerRateBps: 1000,\n        wagerLamports: 10_000_000_000,\n      });\n\n      const token = await makeJwt(referrer);\n\n      // First claim succeeds\n      const res1 = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n      expect(res1.status).toBe(202);\n\n      // Second claim fails — balance consumed by pending claim\n      const res2 = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n      expect(res2.status).toBe(422);\n      const body = (await res2.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"ZERO_BALANCE\");\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /referral/claim/:claimId — poll claim status\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /referral/claim/:claimId\", () => {\n    it(\"returns claim status for the owner\", async () => {\n      // Insert earning + create claim\n      await db.insertReferralEarning({\n        referrerUserId,\n        refereeUserId,\n        referrerWallet: referrer,\n        refereeWallet: referee,\n        roundId: \"poll-round\",\n        gameType: \"flipyou\",\n        wagerLamports: 10_000_000_000,\n        feeLamports: 500_000_000,\n        referrerEarnedLamports: 50_000_000,\n        referrerRateBps: 1000,\n      });\n      await seedFeeAllocation({\n        sourceId: \"poll-round\",\n        feeLamports: 500_000_000,\n        referrerEarnedLamports: 50_000_000,\n        referrerRateBps: 1000,\n        wagerLamports: 10_000_000_000,\n      });\n\n      const token = await makeJwt(referrer);\n      const claimRes = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n      const claimBody = (await claimRes.json()) as {\n        ok: true;\n        data: { claimId: string };\n      };\n      const claim = claimBody.data;\n\n      // Poll status\n      const res = await app.request(`/referral/claim/${claim.claimId}`, {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        ok: true;\n        data: {\n          claimId: string;\n          amountLamports: string;\n          status: string;\n        };\n      };\n      expect(body.ok).toBe(true);\n      expect(body.data.claimId).toBe(claim.claimId);\n      expect(body.data.status).toBe(\"pending\");\n    });\n\n    it(\"returns 404 for non-existent claim\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\n        \"/referral/claim/00000000-0000-0000-0000-000000000000\",\n        {\n          method: \"GET\",\n          headers: { Authorization: `Bearer ${token}` },\n        },\n      );\n\n      expect(res.status).toBe(404);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"CLAIM_NOT_FOUND\");\n    });\n\n    it(\"returns 404 when another wallet tries to view a claim\", async () => {\n      // Create earning + claim as referrer\n      await db.insertReferralEarning({\n        referrerUserId,\n        refereeUserId,\n        referrerWallet: referrer,\n        refereeWallet: referee,\n        roundId: \"auth-round\",\n        gameType: \"flipyou\",\n        wagerLamports: 10_000_000_000,\n        feeLamports: 500_000_000,\n        referrerEarnedLamports: 50_000_000,\n        referrerRateBps: 1000,\n      });\n      await seedFeeAllocation({\n        sourceId: \"auth-round\",\n        feeLamports: 500_000_000,\n        referrerEarnedLamports: 50_000_000,\n        referrerRateBps: 1000,\n        wagerLamports: 10_000_000_000,\n      });\n\n      const referrerToken = await makeJwt(referrer);\n      const claimRes = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${referrerToken}`,\n        },\n      });\n      const claimBody = (await claimRes.json()) as {\n        ok: true;\n        data: { claimId: string };\n      };\n      const claim = claimBody.data;\n\n      // Try to view as referee (different wallet)\n      const refereeToken = await makeJwt(referee);\n      const res = await app.request(`/referral/claim/${claim.claimId}`, {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${refereeToken}` },\n      });\n\n      expect(res.status).toBe(404);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"CLAIM_NOT_FOUND\");\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /referral/referrer — check referrer status\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /referral/referrer\", () => {\n    it(\"returns 200 with null fields when not referred\", async () => {\n      const token = await makeJwt(referee);\n      const res = await app.request(\"/referral/referrer\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        ok: true;\n        data: {\n          referrerUserId: string | null;\n          referrerUsername: string | null;\n          referrerCode: string | null;\n          linkedAt: string | null;\n        };\n      };\n      expect(body.ok).toBe(true);\n      expect(body.data.referrerUserId).toBeNull();\n      expect(body.data.referrerUsername).toBeNull();\n      expect(body.data.referrerCode).toBeNull();\n      expect(body.data.linkedAt).toBeNull();\n    });\n\n    it(\"returns referrer wallet after linking\", async () => {\n      // Set up code + apply\n      const referrerToken = await makeJwt(referrer);\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"referrer-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${referrerToken}` },\n      });\n\n      const refereeToken = await makeJwt(referee);\n      await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"referrer-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${refereeToken}` },\n      });\n\n      const res = await app.request(\"/referral/referrer\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${refereeToken}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        ok: true;\n        data: {\n          referrerUserId: string;\n          linkedAt: string;\n        };\n      };\n      expect(body.ok).toBe(true);\n      expect(body.data.referrerUserId).toBe(referrerUserId);\n      expect(body.data.linkedAt).toBeDefined();\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // Auth — missing JWT\n  // -----------------------------------------------------------------------\n\n  describe(\"Authentication\", () => {\n    it(\"returns 401 for requests without JWT\", async () => {\n      const res = await app.request(\"/referral/stats\", { method: \"GET\" });\n      expect(res.status).toBe(401);\n    });\n  });\n});\n","numLines":1060,"startLine":1,"totalLines":1060}}}
