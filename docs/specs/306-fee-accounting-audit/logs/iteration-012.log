{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VDpddsKLE1T39NbzRfXxCz","type":"tool_result","content":"1\t/**\n2\t * Handler for `referral.claim_requested` events.\n3\t *\n4\t * Flow: load claim → verify pending → update to processing → re-verify balance\n5\t * → SOL transfer from server keypair → record tx_signature → completed.\n6\t *\n7\t * Idempotent: skips if claim is already completed or permanently failed.\n8\t * Transient errors set status to 'error' (retryable); only marks 'failed'\n9\t * after MAX_CLAIM_RETRIES attempts.\n10\t */\n11\t\n12\timport {\n13\t  Connection,\n14\t  Keypair,\n15\t  PublicKey,\n16\t  SystemProgram,\n17\t  Transaction,\n18\t} from \"@solana/web3.js\";\n19\timport type { Db } from \"../../db.js\";\n20\timport { logger } from \"../../logger.js\";\n21\t\n22\t/** Max retry attempts before a claim is permanently marked failed. */\n23\tconst MAX_CLAIM_RETRIES = 5;\n24\t\n25\texport interface ClaimHandlerDeps {\n26\t  db: Db;\n27\t  connection: Connection;\n28\t  serverKeypair: Keypair;\n29\t}\n30\t\n31\texport function createClaimHandler(deps: ClaimHandlerDeps) {\n32\t  const { db, connection, serverKeypair } = deps;\n33\t\n34\t  return async (payload: Record<string, unknown>): Promise<void> => {\n35\t    const claimId = payload.claimId as string;\n36\t    const userId = payload.userId as string;\n37\t    const wallet = payload.wallet as string;\n38\t    const amountLamports = payload.amountLamports as string;\n39\t\n40\t    if (!claimId || !userId || !wallet || !amountLamports) {\n41\t      throw new Error(\n42\t        `referral.claim_requested: malformed payload — missing claimId, userId, wallet, or amountLamports`,\n43\t      );\n44\t    }\n45\t\n46\t    // 1. Load claim and check idempotency\n47\t    const claim = await db.getReferralClaim(claimId);\n48\t    if (!claim) {\n49\t      logger.warn(\"referral claim handler: claim not found\", { claimId });\n50\t      return; // no-op — event may reference a deleted/invalid claim\n51\t    }\n52\t\n53\t    if (claim.status === \"completed\") {\n54\t      logger.info(\"referral claim handler: already completed, skipping\", {\n55\t        claimId,\n56\t      });\n57\t      return;\n58\t    }\n59\t\n60\t    if (claim.status === \"failed\") {\n61\t      logger.info(\"referral claim handler: permanently failed, skipping\", {\n62\t        claimId,\n63\t      });\n64\t      return;\n65\t    }\n66\t\n67\t    // 2. Update status to processing (from pending or error). Keep the\n68\t    //    fee_bucket_debits row's status in lockstep so the audit snapshot's\n69\t    //    reserved/spent classification matches the claim lifecycle.\n70\t    await db.updateClaimStatus(claimId, \"processing\");\n71\t    await db.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, \"processing\");\n72\t\n73\t    try {\n74\t      // 3. Re-verify available balance >= claim amount (prevents overpay on concurrent claims)\n75\t      const pendingStr = await db.getPendingBalanceByUserId(userId);\n76\t      const pending = BigInt(pendingStr);\n77\t      const amount = BigInt(amountLamports);\n78\t\n79\t      if (pending < amount) {\n80\t        // Insufficient balance is a permanent failure — no retry will help\n81\t        await db.updateClaimStatus(claimId, \"failed\", {\n82\t          error: `Insufficient balance: pending=${pendingStr}, claim=${amountLamports}`,\n83\t        });\n84\t        await db.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, \"failed\");\n85\t        logger.warn(\"referral claim handler: insufficient balance\", {\n86\t          claimId,\n87\t          userId,\n88\t          wallet,\n89\t          pending: pendingStr,\n90\t          amount: amountLamports,\n91\t        });\n92\t        return;\n93\t      }\n94\t\n95\t      // 4. Execute SOL transfer from server keypair to player wallet\n96\t      const recipient = new PublicKey(wallet);\n97\t      const lamports = Number(amount);\n98\t\n99\t      const { blockhash, lastValidBlockHeight } =\n100\t        await connection.getLatestBlockhash(\"confirmed\");\n101\t\n102\t      const tx = new Transaction({\n103\t        feePayer: serverKeypair.publicKey,\n104\t        blockhash,\n105\t        lastValidBlockHeight,\n106\t      });\n107\t\n108\t      tx.add(\n109\t        SystemProgram.transfer({\n110\t          fromPubkey: serverKeypair.publicKey,\n111\t          toPubkey: recipient,\n112\t          lamports,\n113\t        }),\n114\t      );\n115\t\n116\t      tx.sign(serverKeypair);\n117\t\n118\t      const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n119\t        skipPreflight: false,\n120\t      });\n121\t\n122\t      // Wait for confirmation\n123\t      const confirmation = await connection.confirmTransaction(\n124\t        { signature: txSignature, blockhash, lastValidBlockHeight },\n125\t        \"confirmed\",\n126\t      );\n127\t\n128\t      if (confirmation.value.err) {\n129\t        throw new Error(\n130\t          `Transaction confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n131\t        );\n132\t      }\n133\t\n134\t      // 5. Record success\n135\t      await db.updateClaimStatus(claimId, \"completed\", { txSignature });\n136\t      await db.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, \"completed\");\n137\t      logger.info(\"referral claim handler: transfer completed\", {\n138\t        claimId,\n139\t        userId,\n140\t        wallet,\n141\t        amountLamports,\n142\t        txSignature,\n143\t      });\n144\t    } catch (err) {\n145\t      // 6. Transient failure — increment retry count, mark as 'error' (retryable)\n146\t      //    or 'failed' (permanent) if max retries exceeded.\n147\t      const errorMsg =\n148\t        err instanceof Error ? err.message : \"Unknown transfer error\";\n149\t      const nextRetry = claim.retry_count + 1;\n150\t      const isFinal = nextRetry >= MAX_CLAIM_RETRIES;\n151\t      const nextStatus = isFinal ? \"failed\" : \"error\";\n152\t\n153\t      await db.updateClaimStatus(claimId, nextStatus, {\n154\t        error: errorMsg,\n155\t        incrementRetry: true,\n156\t      });\n157\t      await db.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, nextStatus);\n158\t\n159\t      if (isFinal) {\n160\t        logger.error(\n161\t          \"referral claim handler: max retries exceeded, permanently failed\",\n162\t          {\n163\t            claimId,\n164\t            userId,\n165\t            wallet,\n166\t            amountLamports,\n167\t            retries: nextRetry,\n168\t            error: errorMsg,\n169\t          },\n170\t        );\n171\t        return; // Don't rethrow — claim is permanently dead\n172\t      }\n173\t\n174\t      logger.warn(\n175\t        \"referral claim handler: transient error, will retry\",\n176\t        {\n177\t          claimId,\n178\t          userId,\n179\t          wallet,\n180\t          amountLamports,\n181\t          retry: nextRetry,\n182\t          error: errorMsg,\n183\t        },\n184\t      );\n185\t      // Re-throw so the queue worker retries with exponential backoff\n186\t      throw err;\n187\t    }\n188\t  };\n189\t}\n190\t"}]},"parent_tool_use_id":null,"session_id":"896d4934-c43e-44ca-831c-60139b475f70","uuid":"4049aabf-ddbd-4c10-af23-6a45fff79228","timestamp":"2026-05-01T20:26:37.104Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/queue/handlers/referral-claim.ts","content":"/**\n * Handler for `referral.claim_requested` events.\n *\n * Flow: load claim → verify pending → update to processing → re-verify balance\n * → SOL transfer from server keypair → record tx_signature → completed.\n *\n * Idempotent: skips if claim is already completed or permanently failed.\n * Transient errors set status to 'error' (retryable); only marks 'failed'\n * after MAX_CLAIM_RETRIES attempts.\n */\n\nimport {\n  Connection,\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n} from \"@solana/web3.js\";\nimport type { Db } from \"../../db.js\";\nimport { logger } from \"../../logger.js\";\n\n/** Max retry attempts before a claim is permanently marked failed. */\nconst MAX_CLAIM_RETRIES = 5;\n\nexport interface ClaimHandlerDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n}\n\nexport function createClaimHandler(deps: ClaimHandlerDeps) {\n  const { db, connection, serverKeypair } = deps;\n\n  return async (payload: Record<string, unknown>): Promise<void> => {\n    const claimId = payload.claimId as string;\n    const userId = payload.userId as string;\n    const wallet = payload.wallet as string;\n    const amountLamports = payload.amountLamports as string;\n\n    if (!claimId || !userId || !wallet || !amountLamports) {\n      throw new Error(\n        `referral.claim_requested: malformed payload — missing claimId, userId, wallet, or amountLamports`,\n      );\n    }\n\n    // 1. Load claim and check idempotency\n    const claim = await db.getReferralClaim(claimId);\n    if (!claim) {\n      logger.warn(\"referral claim handler: claim not found\", { claimId });\n      return; // no-op — event may reference a deleted/invalid claim\n    }\n\n    if (claim.status === \"completed\") {\n      logger.info(\"referral claim handler: already completed, skipping\", {\n        claimId,\n      });\n      return;\n    }\n\n    if (claim.status === \"failed\") {\n      logger.info(\"referral claim handler: permanently failed, skipping\", {\n        claimId,\n      });\n      return;\n    }\n\n    // 2. Update status to processing (from pending or error). Keep the\n    //    fee_bucket_debits row's status in lockstep so the audit snapshot's\n    //    reserved/spent classification matches the claim lifecycle.\n    await db.updateClaimStatus(claimId, \"processing\");\n    await db.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, \"processing\");\n\n    try {\n      // 3. Re-verify available balance >= claim amount (prevents overpay on concurrent claims)\n      const pendingStr = await db.getPendingBalanceByUserId(userId);\n      const pending = BigInt(pendingStr);\n      const amount = BigInt(amountLamports);\n\n      if (pending < amount) {\n        // Insufficient balance is a permanent failure — no retry will help\n        await db.updateClaimStatus(claimId, \"failed\", {\n          error: `Insufficient balance: pending=${pendingStr}, claim=${amountLamports}`,\n        });\n        await db.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, \"failed\");\n        logger.warn(\"referral claim handler: insufficient balance\", {\n          claimId,\n          userId,\n          wallet,\n          pending: pendingStr,\n          amount: amountLamports,\n        });\n        return;\n      }\n\n      // 4. Execute SOL transfer from server keypair to player wallet\n      const recipient = new PublicKey(wallet);\n      const lamports = Number(amount);\n\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash(\"confirmed\");\n\n      const tx = new Transaction({\n        feePayer: serverKeypair.publicKey,\n        blockhash,\n        lastValidBlockHeight,\n      });\n\n      tx.add(\n        SystemProgram.transfer({\n          fromPubkey: serverKeypair.publicKey,\n          toPubkey: recipient,\n          lamports,\n        }),\n      );\n\n      tx.sign(serverKeypair);\n\n      const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n        skipPreflight: false,\n      });\n\n      // Wait for confirmation\n      const confirmation = await connection.confirmTransaction(\n        { signature: txSignature, blockhash, lastValidBlockHeight },\n        \"confirmed\",\n      );\n\n      if (confirmation.value.err) {\n        throw new Error(\n          `Transaction confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n        );\n      }\n\n      // 5. Record success\n      await db.updateClaimStatus(claimId, \"completed\", { txSignature });\n      await db.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, \"completed\");\n      logger.info(\"referral claim handler: transfer completed\", {\n        claimId,\n        userId,\n        wallet,\n        amountLamports,\n        txSignature,\n      });\n    } catch (err) {\n      // 6. Transient failure — increment retry count, mark as 'error' (retryable)\n      //    or 'failed' (permanent) if max retries exceeded.\n      const errorMsg =\n        err instanceof Error ? err.message : \"Unknown transfer error\";\n      const nextRetry = claim.retry_count + 1;\n      const isFinal = nextRetry >= MAX_CLAIM_RETRIES;\n      const nextStatus = isFinal ? \"failed\" : \"error\";\n\n      await db.updateClaimStatus(claimId, nextStatus, {\n        error: errorMsg,\n        incrementRetry: true,\n      });\n      await db.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, nextStatus);\n\n      if (isFinal) {\n        logger.error(\n          \"referral claim handler: max retries exceeded, permanently failed\",\n          {\n            claimId,\n            userId,\n            wallet,\n            amountLamports,\n            retries: nextRetry,\n            error: errorMsg,\n          },\n        );\n        return; // Don't rethrow — claim is permanently dead\n      }\n\n      logger.warn(\n        \"referral claim handler: transient error, will retry\",\n        {\n          claimId,\n          userId,\n          wallet,\n          amountLamports,\n          retry: nextRetry,\n          error: errorMsg,\n        },\n      );\n      // Re-throw so the queue worker retries with exponential backoff\n      throw err;\n    }\n  };\n}\n","numLines":190,"startLine":1,"totalLines":190}}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01WNGGAQxuZFRUQLqt8zBj8j","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01PhnRLzGYXW18jqvsmsJ6yM","name":"Read","input":{"file_path":"/workspaces/rng-utopia/backend/src/routes/referral.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":22501,"cache_read_input_tokens":66067,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":22501},"output_tokens":44,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"896d4934-c43e-44ca-831c-60139b475f70","uuid":"99d8c4b8-81fb-4126-8059-9dc2f9db7859"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PhnRLzGYXW18jqvsmsJ6yM","type":"tool_result","content":"1\t/**\n2\t * Referral routes — code management, linking, stats, earnings, and claims.\n3\t *\n4\t * WAITLIST-CONTRACT: the waitlist calls POST/GET /code, POST /apply,\n5\t * GET /referrer, GET /stats, GET /referrals. /earnings and /claim are NOT\n6\t * consumed by waitlist. Request/response shape for the consumed set is\n7\t * pinned in `__tests__/waitlist-contract.test.ts`; keep\n8\t * `waitlist/src/lib/referral-api.ts` in lockstep.\n9\t */\n10\t\n11\timport { createRoute, z } from \"@hono/zod-openapi\";\n12\timport type postgres from \"postgres\";\n13\timport type { AppEnv } from \"../hono-env.js\";\n14\timport type { Db } from \"../db.js\";\n15\timport type { Config } from \"../config.js\";\n16\timport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n17\timport {\n18\t  envelope,\n19\t  ErrorEnvelopeSchema,\n20\t  ok,\n21\t  err,\n22\t} from \"../contracts/api-envelope.js\";\n23\timport {\n24\t  ApplyReferralCodeBodySchema,\n25\t  ClaimResponseSchema,\n26\t  CodeResponseSchema,\n27\t  MaybeCodeResponseSchema,\n28\t  ReferralApplyResponseSchema,\n29\t  ReferralCodeBodySchema,\n30\t  ReferralListResponseSchema,\n31\t  ReferralReferrerResponseSchema,\n32\t  ReferralStatsSchema,\n33\t} from \"../contracts/validators.js\";\n34\timport { logger } from \"../logger.js\";\n35\timport { emitEvent } from \"../queue/emit-event.js\";\n36\timport { EventTypes } from \"../queue/event-types.js\";\n37\timport { createOpenApiApp } from \"../openapi/hono.js\";\n38\t\n39\texport interface ReferralRoutesDeps {\n40\t  db: Db;\n41\t  sql: postgres.Sql;\n42\t  config: Config;\n43\t}\n44\t\n45\tconst EarningsResponseSchema = z.object({\n46\t  items: z.array(\n47\t    z.object({\n48\t      roundId: z.string(),\n49\t      gameType: z.string(),\n50\t      refereeUserId: z.string(),\n51\t      refereeUsername: z.string(),\n52\t      wagerLamports: z.string(),\n53\t      earnedLamports: z.string(),\n54\t      createdAt: z.string().datetime(),\n55\t    }),\n56\t  ),\n57\t  pagination: z.object({\n58\t    page: z.number().int(),\n59\t    totalPages: z.number().int(),\n60\t  }),\n61\t});\n62\t\n63\texport function createReferralRoutes(deps: ReferralRoutesDeps) {\n64\t  const { db, config } = deps;\n65\t  const app = createOpenApiApp<AppEnv>();\n66\t\n67\t  // ── POST /code — set the player's referral code (permanent) ────────────\n68\t\n69\t  const setCodeRoute = createRoute({\n70\t    method: \"post\",\n71\t    path: \"/code\",\n72\t    tags: [\"Referral\"],\n73\t    summary: \"Set referral code (permanent)\",\n74\t    security: [{ bearerAuth: [] }],\n75\t    request: {\n76\t      body: {\n77\t        required: true,\n78\t        content: { \"application/json\": { schema: ReferralCodeBodySchema } },\n79\t      },\n80\t    },\n81\t    responses: {\n82\t      200: {\n83\t        content: { \"application/json\": { schema: envelope(CodeResponseSchema) } },\n84\t        description: \"Code set\",\n85\t      },\n86\t      401: {\n87\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n88\t        description: \"Authentication required\",\n89\t      },\n90\t      404: {\n91\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n92\t        description: \"Profile not found\",\n93\t      },\n94\t      409: {\n95\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n96\t        description: \"Code already set or taken\",\n97\t      },\n98\t      422: {\n99\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n100\t        description: \"Invalid request body or code format\",\n101\t      },\n102\t      500: {\n103\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n104\t        description: \"Failed to set referral code\",\n105\t      },\n106\t    },\n107\t  });\n108\t\n109\t  app.openapi(setCodeRoute, async (c) => {\n110\t    const userId = c.get(\"userId\");\n111\t    if (!userId) {\n112\t      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n113\t    }\n114\t    const profile = await db.getProfileByUserId(userId);\n115\t    if (!profile) {\n116\t      return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");\n117\t    }\n118\t    const wallet = profile.wallet;\n119\t\n120\t    const { code } = c.req.valid(\"json\");\n121\t\n122\t    // Check if the user already has a code — codes are permanent\n123\t    const ownCode = await db.getReferralCodeByUserId(userId);\n124\t    if (ownCode) {\n125\t      return err(\n126\t        c,\n127\t        409,\n128\t        API_ERROR_CODES.CODE_ALREADY_SET,\n129\t        \"You already have a referral code. Codes cannot be changed.\",\n130\t        { retryable: false },\n131\t      );\n132\t    }\n133\t\n134\t    // Check if this code is already taken by another user\n135\t    const existing = await db.getReferralCodeByCode(code);\n136\t    if (existing && existing.user_id !== userId) {\n137\t      return err(\n138\t        c,\n139\t        409,\n140\t        API_ERROR_CODES.CODE_TAKEN,\n141\t        \"This referral code is already in use\",\n142\t        { retryable: false },\n143\t      );\n144\t    }\n145\t\n146\t    try {\n147\t      const result = await db.insertReferralCode(userId, wallet, code);\n148\t      logger.info(\"Referral code set\", { userId, wallet, code: result.code });\n149\t      return ok(c, { code: result.code });\n150\t    } catch (insertError) {\n151\t      // Handle race condition: another wallet grabbed the code between check and insert\n152\t      const msg =\n153\t        insertError instanceof Error ? insertError.message : String(insertError);\n154\t      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n155\t        return err(\n156\t          c,\n157\t          409,\n158\t          API_ERROR_CODES.CODE_TAKEN,\n159\t          \"This referral code is already in use\",\n160\t          { retryable: false },\n161\t        );\n162\t      }\n163\t      logger.error(\"Failed to set referral code\", {\n164\t        err: String(insertError),\n165\t        userId,\n166\t        wallet,\n167\t      });\n168\t      return err(\n169\t        c,\n170\t        500,\n171\t        API_ERROR_CODES.PRECONDITION_FAILED,\n172\t        \"Failed to set referral code\",\n173\t      );\n174\t    }\n175\t  }, (result, c) => {\n176\t    if (result.success) return;\n177\t    return err(\n178\t      c,\n179\t      422,\n180\t      API_ERROR_CODES.INVALID_CODE,\n181\t      \"Referral code must be 3-16 lowercase letters, numbers, or hyphens.\",\n182\t      { retryable: false, details: result.error.issues },\n183\t    );\n184\t  });\n185\t\n186\t  // ── POST /apply — link the authenticated player to a referrer ──────────\n187\t\n188\t  const applyRoute = createRoute({\n189\t    method: \"post\",\n190\t    path: \"/apply\",\n191\t    tags: [\"Referral\"],\n192\t    summary: \"Apply a referral code (link to referrer)\",\n193\t    security: [{ bearerAuth: [] }],\n194\t    request: {\n195\t      body: {\n196\t        required: true,\n197\t        content: { \"application/json\": { schema: ApplyReferralCodeBodySchema } },\n198\t      },\n199\t    },\n200\t    responses: {\n201\t      200: {\n202\t        content: {\n203\t          \"application/json\": { schema: envelope(ReferralApplyResponseSchema) },\n204\t        },\n205\t        description: \"Linked to referrer\",\n206\t      },\n207\t      401: {\n208\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n209\t        description: \"Authentication required\",\n210\t      },\n211\t      404: {\n212\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n213\t        description: \"Profile or code not found\",\n214\t      },\n215\t      409: {\n216\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n217\t        description: \"Self-referral or already linked to a referrer\",\n218\t      },\n219\t      422: {\n220\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n221\t        description: \"Invalid request body or code format\",\n222\t      },\n223\t      500: {\n224\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n225\t        description: \"Failed to apply referral code\",\n226\t      },\n227\t    },\n228\t  });\n229\t\n230\t  app.openapi(applyRoute, async (c) => {\n231\t    const userId = c.get(\"userId\");\n232\t    if (!userId) {\n233\t      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n234\t    }\n235\t    const profile = await db.getProfileByUserId(userId);\n236\t    if (!profile) {\n237\t      return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");\n238\t    }\n239\t    const wallet = profile.wallet;\n240\t\n241\t    const { code } = c.req.valid(\"json\");\n242\t\n243\t    // Look up the referral code to find the referrer\n244\t    const codeRow = await db.getReferralCodeByCode(code);\n245\t    if (!codeRow) {\n246\t      return err(\n247\t        c,\n248\t        404,\n249\t        API_ERROR_CODES.CODE_NOT_FOUND,\n250\t        \"Referral code does not exist\",\n251\t        { retryable: false },\n252\t      );\n253\t    }\n254\t\n255\t    // Self-referral check\n256\t    if (codeRow.user_id === userId) {\n257\t      return err(\n258\t        c,\n259\t        409,\n260\t        API_ERROR_CODES.SELF_REFERRAL,\n261\t        \"You cannot use your own referral code\",\n262\t        { retryable: false },\n263\t      );\n264\t    }\n265\t\n266\t    // Check if the player already has a referrer\n267\t    const existingLink = await db.getReferralLinkByRefereeUserId(userId);\n268\t    if (existingLink) {\n269\t      return err(\n270\t        c,\n271\t        409,\n272\t        API_ERROR_CODES.ALREADY_LINKED,\n273\t        \"You are already linked to a referrer\",\n274\t        { retryable: false },\n275\t      );\n276\t    }\n277\t\n278\t    try {\n279\t      await db.insertReferralLink({\n280\t        referrerUserId: codeRow.user_id,\n281\t        refereeUserId: userId,\n282\t        referrerWallet: codeRow.wallet,\n283\t        refereeWallet: wallet,\n284\t      });\n285\t      logger.info(\"Referral link created\", {\n286\t        referrerUserId: codeRow.user_id,\n287\t        refereeUserId: userId,\n288\t        code,\n289\t      });\n290\t      return ok(c, {\n291\t        referrerUserId: codeRow.user_id,\n292\t        benefit: \"Referral linked\",\n293\t      });\n294\t    } catch (insertError) {\n295\t      // Handle race condition: another request linked this referee between check and insert\n296\t      const msg =\n297\t        insertError instanceof Error ? insertError.message : String(insertError);\n298\t      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n299\t        return err(\n300\t          c,\n301\t          409,\n302\t          API_ERROR_CODES.ALREADY_LINKED,\n303\t          \"You are already linked to a referrer\",\n304\t          { retryable: false },\n305\t        );\n306\t      }\n307\t      logger.error(\"Failed to create referral link\", {\n308\t        err: String(insertError),\n309\t        userId,\n310\t        wallet,\n311\t        code,\n312\t      });\n313\t      return err(\n314\t        c,\n315\t        500,\n316\t        API_ERROR_CODES.PRECONDITION_FAILED,\n317\t        \"Failed to apply referral code\",\n318\t      );\n319\t    }\n320\t  }, (result, c) => {\n321\t    if (result.success) return;\n322\t    return err(\n323\t      c,\n324\t      422,\n325\t      API_ERROR_CODES.INVALID_CODE,\n326\t      \"Referral code must be 3-16 lowercase letters, numbers, or hyphens.\",\n327\t      { retryable: false, details: result.error.issues },\n328\t    );\n329\t  });\n330\t\n331\t  // ── GET /code — return the authenticated player's current referral code ─\n332\t\n333\t  const getCodeRoute = createRoute({\n334\t    method: \"get\",\n335\t    path: \"/code\",\n336\t    tags: [\"Referral\"],\n337\t    summary: \"Get own referral code\",\n338\t    security: [{ bearerAuth: [] }],\n339\t    responses: {\n340\t      200: {\n341\t        content: {\n342\t          \"application/json\": { schema: envelope(MaybeCodeResponseSchema) },\n343\t        },\n344\t        description: \"Code (null if not set)\",\n345\t      },\n346\t      401: {\n347\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n348\t        description: \"Authentication required\",\n349\t      },\n350\t    },\n351\t  });\n352\t\n353\t  app.openapi(getCodeRoute, async (c) => {\n354\t    const userId = c.get(\"userId\");\n355\t    if (!userId) {\n356\t      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n357\t    }\n358\t\n359\t    const row = await db.getReferralCodeByUserId(userId);\n360\t    return ok(c, { code: row?.code ?? null });\n361\t  });\n362\t\n363\t  // ── GET /referrer — check if the authenticated player has a referrer ────\n364\t\n365\t  const referrerRoute = createRoute({\n366\t    method: \"get\",\n367\t    path: \"/referrer\",\n368\t    tags: [\"Referral\"],\n369\t    summary: \"Get own referrer info\",\n370\t    security: [{ bearerAuth: [] }],\n371\t    responses: {\n372\t      200: {\n373\t        content: {\n374\t          \"application/json\": { schema: envelope(ReferralReferrerResponseSchema) },\n375\t        },\n376\t        description: \"Referrer info (all fields null if not linked)\",\n377\t      },\n378\t      401: {\n379\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n380\t        description: \"Authentication required\",\n381\t      },\n382\t      500: {\n383\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n384\t        description: \"Failed to fetch referrer\",\n385\t      },\n386\t    },\n387\t  });\n388\t\n389\t  app.openapi(referrerRoute, async (c) => {\n390\t    const userId = c.get(\"userId\");\n391\t    if (!userId) {\n392\t      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n393\t    }\n394\t\n395\t    try {\n396\t      const link = await db.getReferralLinkByRefereeUserId(userId);\n397\t      if (!link) {\n398\t        return ok(c, {\n399\t          referrerUserId: null,\n400\t          referrerUsername: null,\n401\t          referrerCode: null,\n402\t          linkedAt: null,\n403\t        });\n404\t      }\n405\t\n406\t      // Look up referrer's username and code for display\n407\t      const [referrerProfile, referrerCode] = await Promise.all([\n408\t        db.getProfileByUserId(link.referrer_user_id),\n409\t        db.getReferralCodeByUserId(link.referrer_user_id),\n410\t      ]);\n411\t\n412\t      return ok(c, {\n413\t        referrerUserId: link.referrer_user_id,\n414\t        referrerUsername: referrerProfile?.username ?? link.referrer_user_id,\n415\t        referrerCode: referrerCode?.code ?? null,\n416\t        linkedAt: link.created_at.toISOString(),\n417\t      });\n418\t    } catch (fetchError) {\n419\t      logger.error(\"Failed to fetch referrer\", {\n420\t        err: String(fetchError),\n421\t        userId,\n422\t      });\n423\t      return err(\n424\t        c,\n425\t        500,\n426\t        API_ERROR_CODES.PRECONDITION_FAILED,\n427\t        \"Failed to fetch referrer\",\n428\t      );\n429\t    }\n430\t  });\n431\t\n432\t  // ── GET /stats — referral summary stats for authenticated user ──────────\n433\t\n434\t  const statsRoute = createRoute({\n435\t    method: \"get\",\n436\t    path: \"/stats\",\n437\t    tags: [\"Referral\"],\n438\t    summary: \"Get referral stats\",\n439\t    security: [{ bearerAuth: [] }],\n440\t    responses: {\n441\t      200: {\n442\t        content: {\n443\t          \"application/json\": { schema: envelope(ReferralStatsSchema) },\n444\t        },\n445\t        description: \"Referral statistics\",\n446\t      },\n447\t      401: {\n448\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n449\t        description: \"Authentication required\",\n450\t      },\n451\t      500: {\n452\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n453\t        description: \"Failed to fetch referral stats\",\n454\t      },\n455\t    },\n456\t  });\n457\t\n458\t  app.openapi(statsRoute, async (c) => {\n459\t    const userId = c.get(\"userId\");\n460\t    if (!userId) {\n461\t      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n462\t    }\n463\t\n464\t    try {\n465\t      const stats = await db.getReferralStatsByUserId(userId);\n466\t      return ok(c, {\n467\t        referredCount: stats.referred_count,\n468\t        activeCount: stats.active_count,\n469\t        totalVolumeLamports: stats.total_volume_lamports,\n470\t        totalEarnedLamports: stats.total_earned_lamports,\n471\t        pendingLamports: stats.pending_lamports,\n472\t      });\n473\t    } catch (fetchError) {\n474\t      logger.error(\"Failed to fetch referral stats\", {\n475\t        err: String(fetchError),\n476\t        userId,\n477\t      });\n478\t      return err(\n479\t        c,\n480\t        500,\n481\t        API_ERROR_CODES.PRECONDITION_FAILED,\n482\t        \"Failed to fetch referral stats\",\n483\t      );\n484\t    }\n485\t  });\n486\t\n487\t  // ── GET /referrals — unique referred users (last 10) ────────────────────\n488\t\n489\t  const referralsRoute = createRoute({\n490\t    method: \"get\",\n491\t    path: \"/referrals\",\n492\t    tags: [\"Referral\"],\n493\t    summary: \"List referred users (last 10)\",\n494\t    security: [{ bearerAuth: [] }],\n495\t    responses: {\n496\t      200: {\n497\t        content: {\n498\t          \"application/json\": { schema: envelope(ReferralListResponseSchema) },\n499\t        },\n500\t        description: \"Referred users\",\n501\t      },\n502\t      401: {\n503\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n504\t        description: \"Authentication required\",\n505\t      },\n506\t      500: {\n507\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n508\t        description: \"Failed to fetch referrals\",\n509\t      },\n510\t    },\n511\t  });\n512\t\n513\t  app.openapi(referralsRoute, async (c) => {\n514\t    const userId = c.get(\"userId\");\n515\t    if (!userId) {\n516\t      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n517\t    }\n518\t\n519\t    try {\n520\t      const links = await db.getReferralLinksByReferrerUserId(userId);\n521\t      // Return last 10 unique referees with usernames, sorted by most recent first\n522\t      const recent = links.slice(0, 10);\n523\t      const profiles = await Promise.all(\n524\t        recent.map((l) => db.getProfileByUserId(l.referee_user_id)),\n525\t      );\n526\t      const items = recent.map((l, i) => ({\n527\t        refereeUserId: l.referee_user_id,\n528\t        refereeUsername: profiles[i]?.username ?? l.referee_user_id,\n529\t        createdAt: l.created_at.toISOString(),\n530\t      }));\n531\t      return ok(c, { items });\n532\t    } catch (fetchError) {\n533\t      logger.error(\"Failed to fetch referrals\", {\n534\t        err: String(fetchError),\n535\t        userId,\n536\t      });\n537\t      return err(\n538\t        c,\n539\t        500,\n540\t        API_ERROR_CODES.PRECONDITION_FAILED,\n541\t        \"Failed to fetch referrals\",\n542\t      );\n543\t    }\n544\t  });\n545\t\n546\t  // ── GET /earnings — paginated per-game earnings log ─────────────────────\n547\t\n548\t  const earningsRoute = createRoute({\n549\t    method: \"get\",\n550\t    path: \"/earnings\",\n551\t    tags: [\"Referral\"],\n552\t    summary: \"Get paginated referral earnings\",\n553\t    security: [{ bearerAuth: [] }],\n554\t    request: {\n555\t      query: z.object({\n556\t        page: z.coerce.number().int().min(1).default(1).optional(),\n557\t        limit: z.coerce.number().int().min(1).max(100).default(20).optional(),\n558\t      }),\n559\t    },\n560\t    responses: {\n561\t      200: {\n562\t        content: {\n563\t          \"application/json\": { schema: envelope(EarningsResponseSchema) },\n564\t        },\n565\t        description: \"Earnings list\",\n566\t      },\n567\t      401: {\n568\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n569\t        description: \"Authentication required\",\n570\t      },\n571\t      422: {\n572\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n573\t        description: \"Invalid parameters\",\n574\t      },\n575\t      500: {\n576\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n577\t        description: \"Failed to fetch referral earnings\",\n578\t      },\n579\t    },\n580\t  });\n581\t\n582\t  app.openapi(earningsRoute, async (c) => {\n583\t    const userId = c.get(\"userId\");\n584\t    if (!userId) {\n585\t      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n586\t    }\n587\t\n588\t    const query = c.req.valid(\"query\");\n589\t    const page = query.page ?? 1;\n590\t    const limit = query.limit ?? 20;\n591\t\n592\t    try {\n593\t      const result = await db.getReferralEarningsByUserId(userId, page, limit);\n594\t      // Resolve usernames for referees (batch-dedup by userId)\n595\t      const uniqueRefereeIds = [...new Set(result.items.map((e) => e.referee_user_id))];\n596\t      const refereeProfiles = await Promise.all(\n597\t        uniqueRefereeIds.map((id) => db.getProfileByUserId(id)),\n598\t      );\n599\t      const usernameMap = new Map(\n600\t        uniqueRefereeIds.map((id, i) => [id, refereeProfiles[i]?.username ?? id]),\n601\t      );\n602\t      return ok(c, {\n603\t        items: result.items.map((e) => ({\n604\t          roundId: e.round_id,\n605\t          gameType: e.game_type,\n606\t          refereeUserId: e.referee_user_id,\n607\t          refereeUsername: usernameMap.get(e.referee_user_id) ?? e.referee_user_id,\n608\t          wagerLamports: String(e.wager_lamports),\n609\t          earnedLamports: String(e.referrer_earned_lamports),\n610\t          createdAt: e.created_at.toISOString(),\n611\t        })),\n612\t        pagination: {\n613\t          page,\n614\t          totalPages: result.totalPages,\n615\t        },\n616\t      });\n617\t    } catch (fetchError) {\n618\t      logger.error(\"Failed to fetch referral earnings\", {\n619\t        err: String(fetchError),\n620\t        userId,\n621\t      });\n622\t      return err(\n623\t        c,\n624\t        500,\n625\t        API_ERROR_CODES.PRECONDITION_FAILED,\n626\t        \"Failed to fetch referral earnings\",\n627\t      );\n628\t    }\n629\t  });\n630\t\n631\t  // ── POST /claim — request payout of pending referral earnings ───────────\n632\t\n633\t  const claimRoute = createRoute({\n634\t    method: \"post\",\n635\t    path: \"/claim\",\n636\t    tags: [\"Referral\"],\n637\t    summary: \"Request payout of pending referral earnings\",\n638\t    security: [{ bearerAuth: [] }],\n639\t    responses: {\n640\t      202: {\n641\t        content: {\n642\t          \"application/json\": { schema: envelope(ClaimResponseSchema) },\n643\t        },\n644\t        description: \"Claim queued\",\n645\t      },\n646\t      401: {\n647\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n648\t        description: \"Authentication required\",\n649\t      },\n650\t      404: {\n651\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n652\t        description: \"Profile not found\",\n653\t      },\n654\t      422: {\n655\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n656\t        description: \"Zero balance or below threshold\",\n657\t      },\n658\t      500: {\n659\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n660\t        description: \"Failed to create referral claim\",\n661\t      },\n662\t    },\n663\t  });\n664\t\n665\t  app.openapi(claimRoute, async (c) => {\n666\t    const userId = c.get(\"userId\");\n667\t    if (!userId) {\n668\t      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n669\t    }\n670\t    const profile = await db.getProfileByUserId(userId);\n671\t    if (!profile) {\n672\t      return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");\n673\t    }\n674\t    const wallet = profile.wallet;\n675\t\n676\t    try {\n677\t      // Ledger-derived claim cap: claim ≤ user's referral allocations minus\n678\t      // their active+completed referral debits. Source of truth per FR-6.\n679\t      const userAvailableStr = await db.getUserReferralAvailable(userId);\n680\t      const userAvailable = BigInt(userAvailableStr);\n681\t\n682\t      if (userAvailable <= 0n) {\n683\t        return err(\n684\t          c,\n685\t          422,\n686\t          API_ERROR_CODES.ZERO_BALANCE,\n687\t          \"No pending earnings to claim\",\n688\t          { retryable: false },\n689\t        );\n690\t      }\n691\t\n692\t      if (userAvailable < BigInt(config.referralMinClaimLamports)) {\n693\t        return err(\n694\t          c,\n695\t          422,\n696\t          API_ERROR_CODES.BELOW_THRESHOLD,\n697\t          `Minimum claim amount is ${config.referralMinClaimLamports} lamports (${(config.referralMinClaimLamports / 1e9).toFixed(2)} SOL)`,\n698\t          { retryable: false },\n699\t        );\n700\t      }\n701\t\n702\t      // Global referral bucket cap — defends against ledger drift / a per-user\n703\t      // balance that the bucket as a whole cannot fund.\n704\t      const globalAvailable = BigInt(await db.getReferralBucketAvailable());\n705\t      if (userAvailable > globalAvailable) {\n706\t        return err(\n707\t          c,\n708\t          422,\n709\t          API_ERROR_CODES.PRECONDITION_FAILED,\n710\t          \"Referral bucket has insufficient capacity for this claim\",\n711\t          { retryable: false },\n712\t        );\n713\t      }\n714\t\n715\t      // Atomically insert claim row + bucket debit + emit queue event\n716\t      const claim = await db.withTransaction(async (txDb) => {\n717\t        const claimRow = await txDb.insertReferralClaim(\n718\t          userId,\n719\t          wallet,\n720\t          userAvailableStr,\n721\t        );\n722\t\n723\t        await txDb.insertFeeBucketDebit({\n724\t          bucket: \"referral\",\n725\t          debitType: \"claim\",\n726\t          sourceId: claimRow.id,\n727\t          userId,\n728\t          wallet,\n729\t          amountLamports: userAvailableStr,\n730\t          status: \"pending\",\n731\t        });\n732\t\n733\t        await emitEvent(\n734\t          txDb.rawSql as postgres.Sql,\n735\t          EventTypes.REFERRAL_CLAIM_REQUESTED,\n736\t          {\n737\t            claimId: claimRow.id,\n738\t            userId: claimRow.user_id,\n739\t            wallet: claimRow.wallet,\n740\t            amountLamports: claimRow.amount_lamports,\n741\t            requestedAt: new Date().toISOString(),\n742\t          },\n743\t        );\n744\t\n745\t        return claimRow;\n746\t      });\n747\t\n748\t      logger.info(\"Referral claim requested\", {\n749\t        userId,\n750\t        wallet,\n751\t        claimId: claim.id,\n752\t        amountLamports: claim.amount_lamports,\n753\t      });\n754\t\n755\t      return ok(\n756\t        c,\n757\t        {\n758\t          claimId: claim.id,\n759\t          amountLamports: claim.amount_lamports,\n760\t          status: \"pending\",\n761\t        },\n762\t        202,\n763\t      );\n764\t    } catch (claimError) {\n765\t      logger.error(\"Failed to create referral claim\", {\n766\t        err: String(claimError),\n767\t        userId,\n768\t        wallet,\n769\t      });\n770\t      return err(\n771\t        c,\n772\t        500,\n773\t        API_ERROR_CODES.PRECONDITION_FAILED,\n774\t        \"Failed to create referral claim\",\n775\t      );\n776\t    }\n777\t  });\n778\t\n779\t  // ── GET /claim/:claimId — poll claim status ─────────────────────────────\n780\t\n781\t  const getClaimRoute = createRoute({\n782\t    method: \"get\",\n783\t    path: \"/claim/{claimId}\",\n784\t    tags: [\"Referral\"],\n785\t    summary: \"Poll claim status\",\n786\t    security: [{ bearerAuth: [] }],\n787\t    request: {\n788\t      params: z.object({\n789\t        claimId: z.string().openapi({ description: \"Claim ID\" }),\n790\t      }),\n791\t    },\n792\t    responses: {\n793\t      200: {\n794\t        content: {\n795\t          \"application/json\": { schema: envelope(ClaimResponseSchema) },\n796\t        },\n797\t        description: \"Claim status\",\n798\t      },\n799\t      401: {\n800\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n801\t        description: \"Authentication required\",\n802\t      },\n803\t      404: {\n804\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n805\t        description: \"Claim not found\",\n806\t      },\n807\t      500: {\n808\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n809\t        description: \"Failed to fetch referral claim\",\n810\t      },\n811\t    },\n812\t  });\n813\t\n814\t  app.openapi(getClaimRoute, async (c) => {\n815\t    const userId = c.get(\"userId\");\n816\t    if (!userId) {\n817\t      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n818\t    }\n819\t\n820\t    const { claimId } = c.req.valid(\"param\");\n821\t\n822\t    try {\n823\t      const claim = await db.getReferralClaim(claimId);\n824\t      if (!claim) {\n825\t        return err(\n826\t          c,\n827\t          404,\n828\t          API_ERROR_CODES.CLAIM_NOT_FOUND,\n829\t          \"Claim not found\",\n830\t        );\n831\t      }\n832\t\n833\t      // Only allow the claim owner to view their claim\n834\t      if (claim.user_id !== userId) {\n835\t        return err(\n836\t          c,\n837\t          404,\n838\t          API_ERROR_CODES.CLAIM_NOT_FOUND,\n839\t          \"Claim not found\",\n840\t        );\n841\t      }\n842\t\n843\t      return ok(c, {\n844\t        claimId: claim.id,\n845\t        amountLamports: String(claim.amount_lamports),\n846\t        status: claim.status,\n847\t        ...(claim.tx_signature ? { txSignature: claim.tx_signature } : {}),\n848\t      });\n849\t    } catch (fetchError) {\n850\t      logger.error(\"Failed to fetch referral claim\", {\n851\t        err: String(fetchError),\n852\t        userId,\n853\t        claimId,\n854\t      });\n855\t      return err(\n856\t        c,\n857\t        500,\n858\t        API_ERROR_CODES.PRECONDITION_FAILED,\n859\t        \"Failed to fetch referral claim\",\n860\t      );\n861\t    }\n862\t  });\n863\t\n864\t  return app;\n865\t}\n866\t"}]},"parent_tool_use_id":null,"session_id":"896d4934-c43e-44ca-831c-60139b475f70","uuid":"be86ee17-a138-4f68-9d69-c84c3e8a4fb4","timestamp":"2026-05-01T20:26:39.779Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/referral.ts","content":"/**\n * Referral routes — code management, linking, stats, earnings, and claims.\n *\n * WAITLIST-CONTRACT: the waitlist calls POST/GET /code, POST /apply,\n * GET /referrer, GET /stats, GET /referrals. /earnings and /claim are NOT\n * consumed by waitlist. Request/response shape for the consumed set is\n * pinned in `__tests__/waitlist-contract.test.ts`; keep\n * `waitlist/src/lib/referral-api.ts` in lockstep.\n */\n\nimport { createRoute, z } from \"@hono/zod-openapi\";\nimport type postgres from \"postgres\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport type { Config } from \"../config.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport {\n  ApplyReferralCodeBodySchema,\n  ClaimResponseSchema,\n  CodeResponseSchema,\n  MaybeCodeResponseSchema,\n  ReferralApplyResponseSchema,\n  ReferralCodeBodySchema,\n  ReferralListResponseSchema,\n  ReferralReferrerResponseSchema,\n  ReferralStatsSchema,\n} from \"../contracts/validators.js\";\nimport { logger } from \"../logger.js\";\nimport { emitEvent } from \"../queue/emit-event.js\";\nimport { EventTypes } from \"../queue/event-types.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface ReferralRoutesDeps {\n  db: Db;\n  sql: postgres.Sql;\n  config: Config;\n}\n\nconst EarningsResponseSchema = z.object({\n  items: z.array(\n    z.object({\n      roundId: z.string(),\n      gameType: z.string(),\n      refereeUserId: z.string(),\n      refereeUsername: z.string(),\n      wagerLamports: z.string(),\n      earnedLamports: z.string(),\n      createdAt: z.string().datetime(),\n    }),\n  ),\n  pagination: z.object({\n    page: z.number().int(),\n    totalPages: z.number().int(),\n  }),\n});\n\nexport function createReferralRoutes(deps: ReferralRoutesDeps) {\n  const { db, config } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // ── POST /code — set the player's referral code (permanent) ────────────\n\n  const setCodeRoute = createRoute({\n    method: \"post\",\n    path: \"/code\",\n    tags: [\"Referral\"],\n    summary: \"Set referral code (permanent)\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      body: {\n        required: true,\n        content: { \"application/json\": { schema: ReferralCodeBodySchema } },\n      },\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: envelope(CodeResponseSchema) } },\n        description: \"Code set\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Profile not found\",\n      },\n      409: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Code already set or taken\",\n      },\n      422: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Invalid request body or code format\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to set referral code\",\n      },\n    },\n  });\n\n  app.openapi(setCodeRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");\n    }\n    const wallet = profile.wallet;\n\n    const { code } = c.req.valid(\"json\");\n\n    // Check if the user already has a code — codes are permanent\n    const ownCode = await db.getReferralCodeByUserId(userId);\n    if (ownCode) {\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.CODE_ALREADY_SET,\n        \"You already have a referral code. Codes cannot be changed.\",\n        { retryable: false },\n      );\n    }\n\n    // Check if this code is already taken by another user\n    const existing = await db.getReferralCodeByCode(code);\n    if (existing && existing.user_id !== userId) {\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.CODE_TAKEN,\n        \"This referral code is already in use\",\n        { retryable: false },\n      );\n    }\n\n    try {\n      const result = await db.insertReferralCode(userId, wallet, code);\n      logger.info(\"Referral code set\", { userId, wallet, code: result.code });\n      return ok(c, { code: result.code });\n    } catch (insertError) {\n      // Handle race condition: another wallet grabbed the code between check and insert\n      const msg =\n        insertError instanceof Error ? insertError.message : String(insertError);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return err(\n          c,\n          409,\n          API_ERROR_CODES.CODE_TAKEN,\n          \"This referral code is already in use\",\n          { retryable: false },\n        );\n      }\n      logger.error(\"Failed to set referral code\", {\n        err: String(insertError),\n        userId,\n        wallet,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to set referral code\",\n      );\n    }\n  }, (result, c) => {\n    if (result.success) return;\n    return err(\n      c,\n      422,\n      API_ERROR_CODES.INVALID_CODE,\n      \"Referral code must be 3-16 lowercase letters, numbers, or hyphens.\",\n      { retryable: false, details: result.error.issues },\n    );\n  });\n\n  // ── POST /apply — link the authenticated player to a referrer ──────────\n\n  const applyRoute = createRoute({\n    method: \"post\",\n    path: \"/apply\",\n    tags: [\"Referral\"],\n    summary: \"Apply a referral code (link to referrer)\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      body: {\n        required: true,\n        content: { \"application/json\": { schema: ApplyReferralCodeBodySchema } },\n      },\n    },\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(ReferralApplyResponseSchema) },\n        },\n        description: \"Linked to referrer\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Profile or code not found\",\n      },\n      409: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Self-referral or already linked to a referrer\",\n      },\n      422: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Invalid request body or code format\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to apply referral code\",\n      },\n    },\n  });\n\n  app.openapi(applyRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");\n    }\n    const wallet = profile.wallet;\n\n    const { code } = c.req.valid(\"json\");\n\n    // Look up the referral code to find the referrer\n    const codeRow = await db.getReferralCodeByCode(code);\n    if (!codeRow) {\n      return err(\n        c,\n        404,\n        API_ERROR_CODES.CODE_NOT_FOUND,\n        \"Referral code does not exist\",\n        { retryable: false },\n      );\n    }\n\n    // Self-referral check\n    if (codeRow.user_id === userId) {\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.SELF_REFERRAL,\n        \"You cannot use your own referral code\",\n        { retryable: false },\n      );\n    }\n\n    // Check if the player already has a referrer\n    const existingLink = await db.getReferralLinkByRefereeUserId(userId);\n    if (existingLink) {\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.ALREADY_LINKED,\n        \"You are already linked to a referrer\",\n        { retryable: false },\n      );\n    }\n\n    try {\n      await db.insertReferralLink({\n        referrerUserId: codeRow.user_id,\n        refereeUserId: userId,\n        referrerWallet: codeRow.wallet,\n        refereeWallet: wallet,\n      });\n      logger.info(\"Referral link created\", {\n        referrerUserId: codeRow.user_id,\n        refereeUserId: userId,\n        code,\n      });\n      return ok(c, {\n        referrerUserId: codeRow.user_id,\n        benefit: \"Referral linked\",\n      });\n    } catch (insertError) {\n      // Handle race condition: another request linked this referee between check and insert\n      const msg =\n        insertError instanceof Error ? insertError.message : String(insertError);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return err(\n          c,\n          409,\n          API_ERROR_CODES.ALREADY_LINKED,\n          \"You are already linked to a referrer\",\n          { retryable: false },\n        );\n      }\n      logger.error(\"Failed to create referral link\", {\n        err: String(insertError),\n        userId,\n        wallet,\n        code,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to apply referral code\",\n      );\n    }\n  }, (result, c) => {\n    if (result.success) return;\n    return err(\n      c,\n      422,\n      API_ERROR_CODES.INVALID_CODE,\n      \"Referral code must be 3-16 lowercase letters, numbers, or hyphens.\",\n      { retryable: false, details: result.error.issues },\n    );\n  });\n\n  // ── GET /code — return the authenticated player's current referral code ─\n\n  const getCodeRoute = createRoute({\n    method: \"get\",\n    path: \"/code\",\n    tags: [\"Referral\"],\n    summary: \"Get own referral code\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(MaybeCodeResponseSchema) },\n        },\n        description: \"Code (null if not set)\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n    },\n  });\n\n  app.openapi(getCodeRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    const row = await db.getReferralCodeByUserId(userId);\n    return ok(c, { code: row?.code ?? null });\n  });\n\n  // ── GET /referrer — check if the authenticated player has a referrer ────\n\n  const referrerRoute = createRoute({\n    method: \"get\",\n    path: \"/referrer\",\n    tags: [\"Referral\"],\n    summary: \"Get own referrer info\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(ReferralReferrerResponseSchema) },\n        },\n        description: \"Referrer info (all fields null if not linked)\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch referrer\",\n      },\n    },\n  });\n\n  app.openapi(referrerRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    try {\n      const link = await db.getReferralLinkByRefereeUserId(userId);\n      if (!link) {\n        return ok(c, {\n          referrerUserId: null,\n          referrerUsername: null,\n          referrerCode: null,\n          linkedAt: null,\n        });\n      }\n\n      // Look up referrer's username and code for display\n      const [referrerProfile, referrerCode] = await Promise.all([\n        db.getProfileByUserId(link.referrer_user_id),\n        db.getReferralCodeByUserId(link.referrer_user_id),\n      ]);\n\n      return ok(c, {\n        referrerUserId: link.referrer_user_id,\n        referrerUsername: referrerProfile?.username ?? link.referrer_user_id,\n        referrerCode: referrerCode?.code ?? null,\n        linkedAt: link.created_at.toISOString(),\n      });\n    } catch (fetchError) {\n      logger.error(\"Failed to fetch referrer\", {\n        err: String(fetchError),\n        userId,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch referrer\",\n      );\n    }\n  });\n\n  // ── GET /stats — referral summary stats for authenticated user ──────────\n\n  const statsRoute = createRoute({\n    method: \"get\",\n    path: \"/stats\",\n    tags: [\"Referral\"],\n    summary: \"Get referral stats\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(ReferralStatsSchema) },\n        },\n        description: \"Referral statistics\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch referral stats\",\n      },\n    },\n  });\n\n  app.openapi(statsRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    try {\n      const stats = await db.getReferralStatsByUserId(userId);\n      return ok(c, {\n        referredCount: stats.referred_count,\n        activeCount: stats.active_count,\n        totalVolumeLamports: stats.total_volume_lamports,\n        totalEarnedLamports: stats.total_earned_lamports,\n        pendingLamports: stats.pending_lamports,\n      });\n    } catch (fetchError) {\n      logger.error(\"Failed to fetch referral stats\", {\n        err: String(fetchError),\n        userId,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch referral stats\",\n      );\n    }\n  });\n\n  // ── GET /referrals — unique referred users (last 10) ────────────────────\n\n  const referralsRoute = createRoute({\n    method: \"get\",\n    path: \"/referrals\",\n    tags: [\"Referral\"],\n    summary: \"List referred users (last 10)\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(ReferralListResponseSchema) },\n        },\n        description: \"Referred users\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch referrals\",\n      },\n    },\n  });\n\n  app.openapi(referralsRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    try {\n      const links = await db.getReferralLinksByReferrerUserId(userId);\n      // Return last 10 unique referees with usernames, sorted by most recent first\n      const recent = links.slice(0, 10);\n      const profiles = await Promise.all(\n        recent.map((l) => db.getProfileByUserId(l.referee_user_id)),\n      );\n      const items = recent.map((l, i) => ({\n        refereeUserId: l.referee_user_id,\n        refereeUsername: profiles[i]?.username ?? l.referee_user_id,\n        createdAt: l.created_at.toISOString(),\n      }));\n      return ok(c, { items });\n    } catch (fetchError) {\n      logger.error(\"Failed to fetch referrals\", {\n        err: String(fetchError),\n        userId,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch referrals\",\n      );\n    }\n  });\n\n  // ── GET /earnings — paginated per-game earnings log ─────────────────────\n\n  const earningsRoute = createRoute({\n    method: \"get\",\n    path: \"/earnings\",\n    tags: [\"Referral\"],\n    summary: \"Get paginated referral earnings\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      query: z.object({\n        page: z.coerce.number().int().min(1).default(1).optional(),\n        limit: z.coerce.number().int().min(1).max(100).default(20).optional(),\n      }),\n    },\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(EarningsResponseSchema) },\n        },\n        description: \"Earnings list\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      422: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Invalid parameters\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch referral earnings\",\n      },\n    },\n  });\n\n  app.openapi(earningsRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    const query = c.req.valid(\"query\");\n    const page = query.page ?? 1;\n    const limit = query.limit ?? 20;\n\n    try {\n      const result = await db.getReferralEarningsByUserId(userId, page, limit);\n      // Resolve usernames for referees (batch-dedup by userId)\n      const uniqueRefereeIds = [...new Set(result.items.map((e) => e.referee_user_id))];\n      const refereeProfiles = await Promise.all(\n        uniqueRefereeIds.map((id) => db.getProfileByUserId(id)),\n      );\n      const usernameMap = new Map(\n        uniqueRefereeIds.map((id, i) => [id, refereeProfiles[i]?.username ?? id]),\n      );\n      return ok(c, {\n        items: result.items.map((e) => ({\n          roundId: e.round_id,\n          gameType: e.game_type,\n          refereeUserId: e.referee_user_id,\n          refereeUsername: usernameMap.get(e.referee_user_id) ?? e.referee_user_id,\n          wagerLamports: String(e.wager_lamports),\n          earnedLamports: String(e.referrer_earned_lamports),\n          createdAt: e.created_at.toISOString(),\n        })),\n        pagination: {\n          page,\n          totalPages: result.totalPages,\n        },\n      });\n    } catch (fetchError) {\n      logger.error(\"Failed to fetch referral earnings\", {\n        err: String(fetchError),\n        userId,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch referral earnings\",\n      );\n    }\n  });\n\n  // ── POST /claim — request payout of pending referral earnings ───────────\n\n  const claimRoute = createRoute({\n    method: \"post\",\n    path: \"/claim\",\n    tags: [\"Referral\"],\n    summary: \"Request payout of pending referral earnings\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      202: {\n        content: {\n          \"application/json\": { schema: envelope(ClaimResponseSchema) },\n        },\n        description: \"Claim queued\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Profile not found\",\n      },\n      422: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Zero balance or below threshold\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to create referral claim\",\n      },\n    },\n  });\n\n  app.openapi(claimRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");\n    }\n    const wallet = profile.wallet;\n\n    try {\n      // Ledger-derived claim cap: claim ≤ user's referral allocations minus\n      // their active+completed referral debits. Source of truth per FR-6.\n      const userAvailableStr = await db.getUserReferralAvailable(userId);\n      const userAvailable = BigInt(userAvailableStr);\n\n      if (userAvailable <= 0n) {\n        return err(\n          c,\n          422,\n          API_ERROR_CODES.ZERO_BALANCE,\n          \"No pending earnings to claim\",\n          { retryable: false },\n        );\n      }\n\n      if (userAvailable < BigInt(config.referralMinClaimLamports)) {\n        return err(\n          c,\n          422,\n          API_ERROR_CODES.BELOW_THRESHOLD,\n          `Minimum claim amount is ${config.referralMinClaimLamports} lamports (${(config.referralMinClaimLamports / 1e9).toFixed(2)} SOL)`,\n          { retryable: false },\n        );\n      }\n\n      // Global referral bucket cap — defends against ledger drift / a per-user\n      // balance that the bucket as a whole cannot fund.\n      const globalAvailable = BigInt(await db.getReferralBucketAvailable());\n      if (userAvailable > globalAvailable) {\n        return err(\n          c,\n          422,\n          API_ERROR_CODES.PRECONDITION_FAILED,\n          \"Referral bucket has insufficient capacity for this claim\",\n          { retryable: false },\n        );\n      }\n\n      // Atomically insert claim row + bucket debit + emit queue event\n      const claim = await db.withTransaction(async (txDb) => {\n        const claimRow = await txDb.insertReferralClaim(\n          userId,\n          wallet,\n          userAvailableStr,\n        );\n\n        await txDb.insertFeeBucketDebit({\n          bucket: \"referral\",\n          debitType: \"claim\",\n          sourceId: claimRow.id,\n          userId,\n          wallet,\n          amountLamports: userAvailableStr,\n          status: \"pending\",\n        });\n\n        await emitEvent(\n          txDb.rawSql as postgres.Sql,\n          EventTypes.REFERRAL_CLAIM_REQUESTED,\n          {\n            claimId: claimRow.id,\n            userId: claimRow.user_id,\n            wallet: claimRow.wallet,\n            amountLamports: claimRow.amount_lamports,\n            requestedAt: new Date().toISOString(),\n          },\n        );\n\n        return claimRow;\n      });\n\n      logger.info(\"Referral claim requested\", {\n        userId,\n        wallet,\n        claimId: claim.id,\n        amountLamports: claim.amount_lamports,\n      });\n\n      return ok(\n        c,\n        {\n          claimId: claim.id,\n          amountLamports: claim.amount_lamports,\n          status: \"pending\",\n        },\n        202,\n      );\n    } catch (claimError) {\n      logger.error(\"Failed to create referral claim\", {\n        err: String(claimError),\n        userId,\n        wallet,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to create referral claim\",\n      );\n    }\n  });\n\n  // ── GET /claim/:claimId — poll claim status ─────────────────────────────\n\n  const getClaimRoute = createRoute({\n    method: \"get\",\n    path: \"/claim/{claimId}\",\n    tags: [\"Referral\"],\n    summary: \"Poll claim status\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      params: z.object({\n        claimId: z.string().openapi({ description: \"Claim ID\" }),\n      }),\n    },\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(ClaimResponseSchema) },\n        },\n        description: \"Claim status\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Claim not found\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch referral claim\",\n      },\n    },\n  });\n\n  app.openapi(getClaimRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    const { claimId } = c.req.valid(\"param\");\n\n    try {\n      const claim = await db.getReferralClaim(claimId);\n      if (!claim) {\n        return err(\n          c,\n          404,\n          API_ERROR_CODES.CLAIM_NOT_FOUND,\n          \"Claim not found\",\n        );\n      }\n\n      // Only allow the claim owner to view their claim\n      if (claim.user_id !== userId) {\n        return err(\n          c,\n          404,\n          API_ERROR_CODES.CLAIM_NOT_FOUND,\n          \"Claim not found\",\n        );\n      }\n\n      return ok(c, {\n        claimId: claim.id,\n        amountLamports: String(claim.amount_lamports),\n        status: claim.status,\n        ...(claim.tx_signature ? { txSignature: claim.tx_signature } : {}),\n      });\n    } catch (fetchError) {\n      logger.error(\"Failed to fetch referral claim\", {\n        err: String(fetchError),\n        userId,\n        claimId,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch referral claim\",\n      );\n    }\n  });\n\n  return app;\n}\n","numLines":866,"startLine":1,"totalLines":866}}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01BrR35XGfBSmDh4JnaFFYzh","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01DaEjPHFqg2wYW4mdzbgXbM","name":"Read","input":{"file_path":"/workspaces/rng-utopia/backend/src/db/fee-accounting.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":11638,"cache_read_input_tokens":88568,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":11638},"output_tokens":44,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"896d4934-c43e-44ca-831c-60139b475f70","uuid":"6b7775ef-38ea-4089-a3b6-52ab695c55eb"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DaEjPHFqg2wYW4mdzbgXbM","type":"tool_result","content":"1\t/**\n2\t * Fee accounting ledger — durable allocation/debit trail used by the audit\n3\t * snapshot, checkpoint generator, and the referral claim hot path.\n4\t *\n5\t * Spec: docs/specs/306-fee-accounting-audit/spec.md\n6\t *\n7\t * Tables:\n8\t *   - fee_allocation_events   (immutable per-fee allocation rows)\n9\t *   - fee_bucket_debits       (bucket spend lifecycle, e.g. referral claims)\n10\t *   - fee_audit_checkpoints   (acceleration snapshots; written by a separate\n11\t *                              generator in a later iteration)\n12\t */\n13\t\n14\timport type postgres from \"postgres\";\n15\t\n16\t// ---------------------------------------------------------------------------\n17\t// Types\n18\t// ---------------------------------------------------------------------------\n19\t\n20\texport type FeeBucket = \"referral\" | \"promotions\" | \"profit\";\n21\t\n22\texport type FeeBucketDebitStatus =\n23\t  | \"pending\"\n24\t  | \"processing\"\n25\t  | \"error\"\n26\t  | \"completed\"\n27\t  | \"failed\";\n28\t\n29\texport interface FeeAllocation {\n30\t  /** Floor split of `feeLamports * referralRateBps / 10000`. */\n31\t  referralLamports: number;\n32\t  /** Floor split of the post-referral remainder × 20%. */\n33\t  promotionsLamports: number;\n34\t  /** Profit absorbs all rounding dust so the three components sum to the fee. */\n35\t  profitLamports: number;\n36\t}\n37\t\n38\texport interface InsertFeeAllocationParams {\n39\t  sourceType: string;\n40\t  sourceId: string;\n41\t  gameType: string;\n42\t  wallet: string;\n43\t  userId?: string | null;\n44\t  wagerLamports: number;\n45\t  feeLamports: number;\n46\t  referrerUserId?: string | null;\n47\t  referralRateBps: number;\n48\t  referralLamports: number;\n49\t  promotionsLamports: number;\n50\t  profitLamports: number;\n51\t}\n52\t\n53\texport interface InsertFeeBucketDebitParams {\n54\t  bucket: FeeBucket;\n55\t  debitType: string;\n56\t  sourceId: string;\n57\t  userId?: string | null;\n58\t  wallet?: string | null;\n59\t  amountLamports: number | string;\n60\t  status?: FeeBucketDebitStatus;\n61\t}\n62\t\n63\texport interface FeeAllocationEventRow {\n64\t  id: number;\n65\t  source_type: string;\n66\t  source_id: string;\n67\t  game_type: string;\n68\t  wallet: string;\n69\t  user_id: string | null;\n70\t  wager_lamports: number;\n71\t  fee_lamports: number;\n72\t  referrer_user_id: string | null;\n73\t  referral_rate_bps: number;\n74\t  referral_lamports: number;\n75\t  promotions_lamports: number;\n76\t  profit_lamports: number;\n77\t  created_at: Date;\n78\t}\n79\t\n80\texport interface FeeBucketDebitRow {\n81\t  id: number;\n82\t  bucket: FeeBucket;\n83\t  debit_type: string;\n84\t  source_id: string;\n85\t  user_id: string | null;\n86\t  wallet: string | null;\n87\t  amount_lamports: number;\n88\t  status: FeeBucketDebitStatus;\n89\t  created_at: Date;\n90\t  updated_at: Date;\n91\t}\n92\t\n93\texport interface FeeAuditBucketSummary {\n94\t  /** Sum of `*_lamports` from `fee_allocation_events`. */\n95\t  allocated: string;\n96\t  /** Debits with status pending|processing|error. */\n97\t  activeDebits: string;\n98\t  /** Debits with status completed. */\n99\t  completedDebits: string;\n100\t  /** Pending/processing/error debits where `debit_type='claim'`. */\n101\t  pendingClaimReserves: string;\n102\t  /** Debits with status failed (excluded from the available calculation). */\n103\t  failedDebits: string;\n104\t  /** allocated − activeDebits − completedDebits. */\n105\t  available: string;\n106\t}\n107\t\n108\texport interface FeeAuditSnapshot {\n109\t  totals: {\n110\t    feeLamports: string;\n111\t    allocationCount: number;\n112\t    debitCount: number;\n113\t  };\n114\t  buckets: {\n115\t    referral: FeeAuditBucketSummary;\n116\t    promotions: FeeAuditBucketSummary;\n117\t    profit: FeeAuditBucketSummary;\n118\t  };\n119\t  /** Rows where allocation components do not sum to `fee_lamports`. */\n120\t  invariantViolations: Array<{\n121\t    sourceType: string;\n122\t    sourceId: string;\n123\t    wallet: string;\n124\t    feeLamports: string;\n125\t    componentsSum: string;\n126\t  }>;\n127\t  /** Buckets where active+completed debits exceed allocated balance. */\n128\t  overdrawnBuckets: FeeBucket[];\n129\t  /** Earliest `created_at` in the allocation ledger; null when empty. */\n130\t  auditFrom: Date | null;\n131\t}\n132\t\n133\t// ---------------------------------------------------------------------------\n134\t// Pure helper\n135\t// ---------------------------------------------------------------------------\n136\t\n137\t/**\n138\t * Deterministic, integer-safe split of a settled fee into the three virtual\n139\t * buckets. Profit absorbs all rounding dust so the components always sum to\n140\t * `feeLamports`. Mirrors the DB CHECK on `fee_allocation_events`.\n141\t */\n142\texport function calculateFeeAllocation(\n143\t  feeLamports: number,\n144\t  referrerRateBps: number,\n145\t): FeeAllocation {\n146\t  if (!Number.isFinite(feeLamports) || !Number.isInteger(feeLamports) || feeLamports < 0) {\n147\t    throw new Error(`calculateFeeAllocation: feeLamports must be a non-negative integer (got ${feeLamports})`);\n148\t  }\n149\t  if (\n150\t    !Number.isFinite(referrerRateBps) ||\n151\t    !Number.isInteger(referrerRateBps) ||\n152\t    referrerRateBps < 0 ||\n153\t    referrerRateBps > 10000\n154\t  ) {\n155\t    throw new Error(\n156\t      `calculateFeeAllocation: referrerRateBps must be an integer in [0, 10000] (got ${referrerRateBps})`,\n157\t    );\n158\t  }\n159\t\n160\t  const referralLamports = Math.floor((feeLamports * referrerRateBps) / 10000);\n161\t  const postReferral = feeLamports - referralLamports;\n162\t  const promotionsLamports = Math.floor((postReferral * 2000) / 10000);\n163\t  const profitLamports = feeLamports - referralLamports - promotionsLamports;\n164\t\n165\t  return { referralLamports, promotionsLamports, profitLamports };\n166\t}\n167\t\n168\t// ---------------------------------------------------------------------------\n169\t// Interface\n170\t// ---------------------------------------------------------------------------\n171\t\n172\tconst ACTIVE_DEBIT_STATUSES = [\"pending\", \"processing\", \"error\"] as const;\n173\tconst RESERVED_OR_SPENT_STATUSES = [\n174\t  \"pending\",\n175\t  \"processing\",\n176\t  \"error\",\n177\t  \"completed\",\n178\t] as const;\n179\t\n180\texport interface FeeAccountingDb {\n181\t  /**\n182\t   * Insert one allocation row. Idempotent on\n183\t   * `(source_type, source_id, wallet)` — duplicate calls are no-ops.\n184\t   * Returns the row, whether newly inserted or pre-existing.\n185\t   */\n186\t  insertFeeAllocation(params: InsertFeeAllocationParams): Promise<FeeAllocationEventRow>;\n187\t\n188\t  /**\n189\t   * Insert one bucket debit row. Idempotent on\n190\t   * `(bucket, debit_type, source_id)` — duplicate calls are no-ops.\n191\t   * Returns the row, whether newly inserted or pre-existing.\n192\t   */\n193\t  insertFeeBucketDebit(params: InsertFeeBucketDebitParams): Promise<FeeBucketDebitRow>;\n194\t\n195\t  /**\n196\t   * Update a debit's status (and bumps `updated_at`). Returns the updated row,\n197\t   * or `undefined` when the `(bucket, debit_type, source_id)` triple does not\n198\t   * exist.\n199\t   */\n200\t  updateFeeBucketDebitStatus(\n201\t    bucket: FeeBucket,\n202\t    debitType: string,\n203\t    sourceId: string,\n204\t    status: FeeBucketDebitStatus,\n205\t  ): Promise<FeeBucketDebitRow | undefined>;\n206\t\n207\t  /**\n208\t   * Lamports available across the global `referral` bucket.\n209\t   *\n210\t   * `sum(referral_lamports across all allocations)` minus\n211\t   * `sum(amount_lamports across referral debits with status pending|processing|error|completed)`.\n212\t   *\n213\t   * Returned as a lamport string, matching the `getPendingBalanceByUserId` shape\n214\t   * the claim hot path already consumes.\n215\t   */\n216\t  getReferralBucketAvailable(): Promise<string>;\n217\t\n218\t  /**\n219\t   * Lamports available to a specific referrer user.\n220\t   *\n221\t   * `sum(referral_lamports for allocations where referrer_user_id = userId)`\n222\t   * minus `sum(amount_lamports for referral debits with user_id = userId\n223\t   * and status pending|processing|error|completed)`.\n224\t   */\n225\t  getUserReferralAvailable(userId: string): Promise<string>;\n226\t\n227\t  /**\n228\t   * Reconciliation snapshot of the ledger. Treats\n229\t   * `pending|processing|error|completed` debits as reserved/spent and excludes\n230\t   * `failed` debits. Used by `GET /admin/fee-audit/snapshot`.\n231\t   */\n232\t  getFeeAuditSnapshot(): Promise<FeeAuditSnapshot>;\n233\t}\n234\t\n235\t// ---------------------------------------------------------------------------\n236\t// Factory\n237\t// ---------------------------------------------------------------------------\n238\t\n239\tfunction normalizeAllocationRow(row: FeeAllocationEventRow): FeeAllocationEventRow {\n240\t  return {\n241\t    ...row,\n242\t    wager_lamports: Number(row.wager_lamports),\n243\t    fee_lamports: Number(row.fee_lamports),\n244\t    referral_rate_bps: Number(row.referral_rate_bps),\n245\t    referral_lamports: Number(row.referral_lamports),\n246\t    promotions_lamports: Number(row.promotions_lamports),\n247\t    profit_lamports: Number(row.profit_lamports),\n248\t  };\n249\t}\n250\t\n251\tfunction normalizeDebitRow(row: FeeBucketDebitRow): FeeBucketDebitRow {\n252\t  return {\n253\t    ...row,\n254\t    amount_lamports: Number(row.amount_lamports),\n255\t  };\n256\t}\n257\t\n258\tfunction emptyBucketSummary(): FeeAuditBucketSummary {\n259\t  return {\n260\t    allocated: \"0\",\n261\t    activeDebits: \"0\",\n262\t    completedDebits: \"0\",\n263\t    pendingClaimReserves: \"0\",\n264\t    failedDebits: \"0\",\n265\t    available: \"0\",\n266\t  };\n267\t}\n268\t\n269\t\n270\texport function createFeeAccountingDb(sql: ReturnType<typeof postgres>): FeeAccountingDb {\n271\t  return {\n272\t    async insertFeeAllocation(params) {\n273\t      const rows = await sql<FeeAllocationEventRow[]>`\n274\t        INSERT INTO fee_allocation_events (\n275\t          source_type, source_id, game_type, wallet, user_id,\n276\t          wager_lamports, fee_lamports,\n277\t          referrer_user_id, referral_rate_bps,\n278\t          referral_lamports, promotions_lamports, profit_lamports\n279\t        ) VALUES (\n280\t          ${params.sourceType},\n281\t          ${params.sourceId},\n282\t          ${params.gameType},\n283\t          ${params.wallet},\n284\t          ${params.userId ?? null},\n285\t          ${params.wagerLamports},\n286\t          ${params.feeLamports},\n287\t          ${params.referrerUserId ?? null},\n288\t          ${params.referralRateBps},\n289\t          ${params.referralLamports},\n290\t          ${params.promotionsLamports},\n291\t          ${params.profitLamports}\n292\t        )\n293\t        ON CONFLICT (source_type, source_id, wallet) DO NOTHING\n294\t        RETURNING *\n295\t      `;\n296\t      if (rows[0]) return normalizeAllocationRow(rows[0]);\n297\t\n298\t      // Conflict — return the existing row so callers can rely on the\n299\t      // method's return type.\n300\t      const existing = await sql<FeeAllocationEventRow[]>`\n301\t        SELECT * FROM fee_allocation_events\n302\t        WHERE source_type = ${params.sourceType}\n303\t          AND source_id = ${params.sourceId}\n304\t          AND wallet = ${params.wallet}\n305\t      `;\n306\t      return normalizeAllocationRow(existing[0]!);\n307\t    },\n308\t\n309\t    async insertFeeBucketDebit(params) {\n310\t      const rows = await sql<FeeBucketDebitRow[]>`\n311\t        INSERT INTO fee_bucket_debits (\n312\t          bucket, debit_type, source_id, user_id, wallet, amount_lamports, status\n313\t        ) VALUES (\n314\t          ${params.bucket},\n315\t          ${params.debitType},\n316\t          ${params.sourceId},\n317\t          ${params.userId ?? null},\n318\t          ${params.wallet ?? null},\n319\t          ${params.amountLamports},\n320\t          ${params.status ?? \"pending\"}\n321\t        )\n322\t        ON CONFLICT (bucket, debit_type, source_id) DO NOTHING\n323\t        RETURNING *\n324\t      `;\n325\t      if (rows[0]) return normalizeDebitRow(rows[0]);\n326\t\n327\t      const existing = await sql<FeeBucketDebitRow[]>`\n328\t        SELECT * FROM fee_bucket_debits\n329\t        WHERE bucket = ${params.bucket}\n330\t          AND debit_type = ${params.debitType}\n331\t          AND source_id = ${params.sourceId}\n332\t      `;\n333\t      return normalizeDebitRow(existing[0]!);\n334\t    },\n335\t\n336\t    async updateFeeBucketDebitStatus(bucket, debitType, sourceId, status) {\n337\t      const rows = await sql<FeeBucketDebitRow[]>`\n338\t        UPDATE fee_bucket_debits\n339\t        SET status = ${status}, updated_at = now()\n340\t        WHERE bucket = ${bucket}\n341\t          AND debit_type = ${debitType}\n342\t          AND source_id = ${sourceId}\n343\t        RETURNING *\n344\t      `;\n345\t      return rows[0] ? normalizeDebitRow(rows[0]) : undefined;\n346\t    },\n347\t\n348\t    async getReferralBucketAvailable() {\n349\t      const rows = await sql<{ available: string }[]>`\n350\t        SELECT (\n351\t          COALESCE(\n352\t            (SELECT SUM(referral_lamports) FROM fee_allocation_events),\n353\t            0\n354\t          )\n355\t          - COALESCE(\n356\t              (\n357\t                SELECT SUM(amount_lamports)\n358\t                FROM fee_bucket_debits\n359\t                WHERE bucket = 'referral'\n360\t                  AND status IN ${sql(RESERVED_OR_SPENT_STATUSES)}\n361\t              ),\n362\t              0\n363\t            )\n364\t        )::TEXT AS available\n365\t      `;\n366\t      return rows[0]!.available;\n367\t    },\n368\t\n369\t    async getUserReferralAvailable(userId) {\n370\t      const rows = await sql<{ available: string }[]>`\n371\t        SELECT (\n372\t          COALESCE(\n373\t            (\n374\t              SELECT SUM(referral_lamports)\n375\t              FROM fee_allocation_events\n376\t              WHERE referrer_user_id = ${userId}\n377\t            ),\n378\t            0\n379\t          )\n380\t          - COALESCE(\n381\t              (\n382\t                SELECT SUM(amount_lamports)\n383\t                FROM fee_bucket_debits\n384\t                WHERE bucket = 'referral'\n385\t                  AND user_id = ${userId}\n386\t                  AND status IN ${sql(RESERVED_OR_SPENT_STATUSES)}\n387\t              ),\n388\t              0\n389\t            )\n390\t        )::TEXT AS available\n391\t      `;\n392\t      return rows[0]!.available;\n393\t    },\n394\t\n395\t    async getFeeAuditSnapshot() {\n396\t      const totalsRowsPromise = sql<\n397\t        {\n398\t          fee_total: string;\n399\t          referral_total: string;\n400\t          promotions_total: string;\n401\t          profit_total: string;\n402\t          allocation_count: string;\n403\t          audit_from: Date | null;\n404\t        }[]\n405\t      >`\n406\t        SELECT\n407\t          COALESCE(SUM(fee_lamports), 0)::TEXT          AS fee_total,\n408\t          COALESCE(SUM(referral_lamports), 0)::TEXT     AS referral_total,\n409\t          COALESCE(SUM(promotions_lamports), 0)::TEXT   AS promotions_total,\n410\t          COALESCE(SUM(profit_lamports), 0)::TEXT       AS profit_total,\n411\t          COUNT(*)::TEXT                                AS allocation_count,\n412\t          MIN(created_at)                               AS audit_from\n413\t        FROM fee_allocation_events\n414\t      `;\n415\t\n416\t      const debitRowsPromise = sql<\n417\t        {\n418\t          bucket: FeeBucket;\n419\t          status: FeeBucketDebitStatus;\n420\t          debit_type: string;\n421\t          sum_lamports: string;\n422\t          row_count: string;\n423\t        }[]\n424\t      >`\n425\t        SELECT\n426\t          bucket,\n427\t          status,\n428\t          debit_type,\n429\t          COALESCE(SUM(amount_lamports), 0)::TEXT AS sum_lamports,\n430\t          COUNT(*)::TEXT                          AS row_count\n431\t        FROM fee_bucket_debits\n432\t        GROUP BY bucket, status, debit_type\n433\t      `;\n434\t\n435\t      const violationsRowsPromise = sql<\n436\t        {\n437\t          source_type: string;\n438\t          source_id: string;\n439\t          wallet: string;\n440\t          fee_lamports: string;\n441\t          components_sum: string;\n442\t        }[]\n443\t      >`\n444\t        SELECT\n445\t          source_type,\n446\t          source_id,\n447\t          wallet,\n448\t          fee_lamports::TEXT  AS fee_lamports,\n449\t          (referral_lamports + promotions_lamports + profit_lamports)::TEXT\n450\t                              AS components_sum\n451\t        FROM fee_allocation_events\n452\t        WHERE referral_lamports + promotions_lamports + profit_lamports <> fee_lamports\n453\t      `;\n454\t\n455\t      const [totalsRows, debitRows, violationsRows] = await Promise.all([\n456\t        totalsRowsPromise,\n457\t        debitRowsPromise,\n458\t        violationsRowsPromise,\n459\t      ]);\n460\t\n461\t      const totalsRow = totalsRows[0]!;\n462\t\n463\t      const buckets = {\n464\t        referral: emptyBucketSummary(),\n465\t        promotions: emptyBucketSummary(),\n466\t        profit: emptyBucketSummary(),\n467\t      };\n468\t\n469\t      buckets.referral.allocated = totalsRow.referral_total;\n470\t      buckets.promotions.allocated = totalsRow.promotions_total;\n471\t      buckets.profit.allocated = totalsRow.profit_total;\n472\t\n473\t      let debitCount = 0;\n474\t      const accum: Record<FeeBucket, { active: bigint; completed: bigint; failed: bigint; pendingClaim: bigint }> = {\n475\t        referral: { active: 0n, completed: 0n, failed: 0n, pendingClaim: 0n },\n476\t        promotions: { active: 0n, completed: 0n, failed: 0n, pendingClaim: 0n },\n477\t        profit: { active: 0n, completed: 0n, failed: 0n, pendingClaim: 0n },\n478\t      };\n479\t\n480\t      for (const row of debitRows) {\n481\t        const amount = BigInt(row.sum_lamports);\n482\t        const count = Number(row.row_count);\n483\t        debitCount += count;\n484\t\n485\t        const target = accum[row.bucket];\n486\t        if (!target) continue;\n487\t\n488\t        if ((ACTIVE_DEBIT_STATUSES as readonly string[]).includes(row.status)) {\n489\t          target.active += amount;\n490\t          if (row.debit_type === \"claim\") target.pendingClaim += amount;\n491\t        } else if (row.status === \"completed\") {\n492\t          target.completed += amount;\n493\t        } else if (row.status === \"failed\") {\n494\t          target.failed += amount;\n495\t        }\n496\t      }\n497\t\n498\t      const overdrawnBuckets: FeeBucket[] = [];\n499\t      for (const bucket of [\"referral\", \"promotions\", \"profit\"] as const) {\n500\t        const allocated = BigInt(buckets[bucket].allocated);\n501\t        const { active, completed, failed, pendingClaim } = accum[bucket];\n502\t        const reservedOrSpent = active + completed;\n503\t        const available = allocated - reservedOrSpent;\n504\t\n505\t        buckets[bucket].activeDebits = active.toString();\n506\t        buckets[bucket].completedDebits = completed.toString();\n507\t        buckets[bucket].failedDebits = failed.toString();\n508\t        buckets[bucket].pendingClaimReserves = pendingClaim.toString();\n509\t        buckets[bucket].available = available.toString();\n510\t\n511\t        if (reservedOrSpent > allocated) overdrawnBuckets.push(bucket);\n512\t      }\n513\t\n514\t      const invariantViolations = violationsRows.map((row) => ({\n515\t        sourceType: row.source_type,\n516\t        sourceId: row.source_id,\n517\t        wallet: row.wallet,\n518\t        feeLamports: row.fee_lamports,\n519\t        componentsSum: row.components_sum,\n520\t      }));\n521\t\n522\t      return {\n523\t        totals: {\n524\t          feeLamports: totalsRow.fee_total,\n525\t          allocationCount: Number(totalsRow.allocation_count),\n526\t          debitCount,\n527\t        },\n528\t        buckets,\n529\t        invariantViolations,\n530\t        overdrawnBuckets,\n531\t        auditFrom: totalsRow.audit_from,\n532\t      };\n533\t    },\n534\t  };\n535\t}\n536\t"}]},"parent_tool_use_id":null,"session_id":"896d4934-c43e-44ca-831c-60139b475f70","uuid":"d465e3ac-1e56-4c2f-87e0-1a440ba79fd7","timestamp":"2026-05-01T20:26:42.123Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/db/fee-accounting.ts","content":"/**\n * Fee accounting ledger — durable allocation/debit trail used by the audit\n * snapshot, checkpoint generator, and the referral claim hot path.\n *\n * Spec: docs/specs/306-fee-accounting-audit/spec.md\n *\n * Tables:\n *   - fee_allocation_events   (immutable per-fee allocation rows)\n *   - fee_bucket_debits       (bucket spend lifecycle, e.g. referral claims)\n *   - fee_audit_checkpoints   (acceleration snapshots; written by a separate\n *                              generator in a later iteration)\n */\n\nimport type postgres from \"postgres\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type FeeBucket = \"referral\" | \"promotions\" | \"profit\";\n\nexport type FeeBucketDebitStatus =\n  | \"pending\"\n  | \"processing\"\n  | \"error\"\n  | \"completed\"\n  | \"failed\";\n\nexport interface FeeAllocation {\n  /** Floor split of `feeLamports * referralRateBps / 10000`. */\n  referralLamports: number;\n  /** Floor split of the post-referral remainder × 20%. */\n  promotionsLamports: number;\n  /** Profit absorbs all rounding dust so the three components sum to the fee. */\n  profitLamports: number;\n}\n\nexport interface InsertFeeAllocationParams {\n  sourceType: string;\n  sourceId: string;\n  gameType: string;\n  wallet: string;\n  userId?: string | null;\n  wagerLamports: number;\n  feeLamports: number;\n  referrerUserId?: string | null;\n  referralRateBps: number;\n  referralLamports: number;\n  promotionsLamports: number;\n  profitLamports: number;\n}\n\nexport interface InsertFeeBucketDebitParams {\n  bucket: FeeBucket;\n  debitType: string;\n  sourceId: string;\n  userId?: string | null;\n  wallet?: string | null;\n  amountLamports: number | string;\n  status?: FeeBucketDebitStatus;\n}\n\nexport interface FeeAllocationEventRow {\n  id: number;\n  source_type: string;\n  source_id: string;\n  game_type: string;\n  wallet: string;\n  user_id: string | null;\n  wager_lamports: number;\n  fee_lamports: number;\n  referrer_user_id: string | null;\n  referral_rate_bps: number;\n  referral_lamports: number;\n  promotions_lamports: number;\n  profit_lamports: number;\n  created_at: Date;\n}\n\nexport interface FeeBucketDebitRow {\n  id: number;\n  bucket: FeeBucket;\n  debit_type: string;\n  source_id: string;\n  user_id: string | null;\n  wallet: string | null;\n  amount_lamports: number;\n  status: FeeBucketDebitStatus;\n  created_at: Date;\n  updated_at: Date;\n}\n\nexport interface FeeAuditBucketSummary {\n  /** Sum of `*_lamports` from `fee_allocation_events`. */\n  allocated: string;\n  /** Debits with status pending|processing|error. */\n  activeDebits: string;\n  /** Debits with status completed. */\n  completedDebits: string;\n  /** Pending/processing/error debits where `debit_type='claim'`. */\n  pendingClaimReserves: string;\n  /** Debits with status failed (excluded from the available calculation). */\n  failedDebits: string;\n  /** allocated − activeDebits − completedDebits. */\n  available: string;\n}\n\nexport interface FeeAuditSnapshot {\n  totals: {\n    feeLamports: string;\n    allocationCount: number;\n    debitCount: number;\n  };\n  buckets: {\n    referral: FeeAuditBucketSummary;\n    promotions: FeeAuditBucketSummary;\n    profit: FeeAuditBucketSummary;\n  };\n  /** Rows where allocation components do not sum to `fee_lamports`. */\n  invariantViolations: Array<{\n    sourceType: string;\n    sourceId: string;\n    wallet: string;\n    feeLamports: string;\n    componentsSum: string;\n  }>;\n  /** Buckets where active+completed debits exceed allocated balance. */\n  overdrawnBuckets: FeeBucket[];\n  /** Earliest `created_at` in the allocation ledger; null when empty. */\n  auditFrom: Date | null;\n}\n\n// ---------------------------------------------------------------------------\n// Pure helper\n// ---------------------------------------------------------------------------\n\n/**\n * Deterministic, integer-safe split of a settled fee into the three virtual\n * buckets. Profit absorbs all rounding dust so the components always sum to\n * `feeLamports`. Mirrors the DB CHECK on `fee_allocation_events`.\n */\nexport function calculateFeeAllocation(\n  feeLamports: number,\n  referrerRateBps: number,\n): FeeAllocation {\n  if (!Number.isFinite(feeLamports) || !Number.isInteger(feeLamports) || feeLamports < 0) {\n    throw new Error(`calculateFeeAllocation: feeLamports must be a non-negative integer (got ${feeLamports})`);\n  }\n  if (\n    !Number.isFinite(referrerRateBps) ||\n    !Number.isInteger(referrerRateBps) ||\n    referrerRateBps < 0 ||\n    referrerRateBps > 10000\n  ) {\n    throw new Error(\n      `calculateFeeAllocation: referrerRateBps must be an integer in [0, 10000] (got ${referrerRateBps})`,\n    );\n  }\n\n  const referralLamports = Math.floor((feeLamports * referrerRateBps) / 10000);\n  const postReferral = feeLamports - referralLamports;\n  const promotionsLamports = Math.floor((postReferral * 2000) / 10000);\n  const profitLamports = feeLamports - referralLamports - promotionsLamports;\n\n  return { referralLamports, promotionsLamports, profitLamports };\n}\n\n// ---------------------------------------------------------------------------\n// Interface\n// ---------------------------------------------------------------------------\n\nconst ACTIVE_DEBIT_STATUSES = [\"pending\", \"processing\", \"error\"] as const;\nconst RESERVED_OR_SPENT_STATUSES = [\n  \"pending\",\n  \"processing\",\n  \"error\",\n  \"completed\",\n] as const;\n\nexport interface FeeAccountingDb {\n  /**\n   * Insert one allocation row. Idempotent on\n   * `(source_type, source_id, wallet)` — duplicate calls are no-ops.\n   * Returns the row, whether newly inserted or pre-existing.\n   */\n  insertFeeAllocation(params: InsertFeeAllocationParams): Promise<FeeAllocationEventRow>;\n\n  /**\n   * Insert one bucket debit row. Idempotent on\n   * `(bucket, debit_type, source_id)` — duplicate calls are no-ops.\n   * Returns the row, whether newly inserted or pre-existing.\n   */\n  insertFeeBucketDebit(params: InsertFeeBucketDebitParams): Promise<FeeBucketDebitRow>;\n\n  /**\n   * Update a debit's status (and bumps `updated_at`). Returns the updated row,\n   * or `undefined` when the `(bucket, debit_type, source_id)` triple does not\n   * exist.\n   */\n  updateFeeBucketDebitStatus(\n    bucket: FeeBucket,\n    debitType: string,\n    sourceId: string,\n    status: FeeBucketDebitStatus,\n  ): Promise<FeeBucketDebitRow | undefined>;\n\n  /**\n   * Lamports available across the global `referral` bucket.\n   *\n   * `sum(referral_lamports across all allocations)` minus\n   * `sum(amount_lamports across referral debits with status pending|processing|error|completed)`.\n   *\n   * Returned as a lamport string, matching the `getPendingBalanceByUserId` shape\n   * the claim hot path already consumes.\n   */\n  getReferralBucketAvailable(): Promise<string>;\n\n  /**\n   * Lamports available to a specific referrer user.\n   *\n   * `sum(referral_lamports for allocations where referrer_user_id = userId)`\n   * minus `sum(amount_lamports for referral debits with user_id = userId\n   * and status pending|processing|error|completed)`.\n   */\n  getUserReferralAvailable(userId: string): Promise<string>;\n\n  /**\n   * Reconciliation snapshot of the ledger. Treats\n   * `pending|processing|error|completed` debits as reserved/spent and excludes\n   * `failed` debits. Used by `GET /admin/fee-audit/snapshot`.\n   */\n  getFeeAuditSnapshot(): Promise<FeeAuditSnapshot>;\n}\n\n// ---------------------------------------------------------------------------\n// Factory\n// ---------------------------------------------------------------------------\n\nfunction normalizeAllocationRow(row: FeeAllocationEventRow): FeeAllocationEventRow {\n  return {\n    ...row,\n    wager_lamports: Number(row.wager_lamports),\n    fee_lamports: Number(row.fee_lamports),\n    referral_rate_bps: Number(row.referral_rate_bps),\n    referral_lamports: Number(row.referral_lamports),\n    promotions_lamports: Number(row.promotions_lamports),\n    profit_lamports: Number(row.profit_lamports),\n  };\n}\n\nfunction normalizeDebitRow(row: FeeBucketDebitRow): FeeBucketDebitRow {\n  return {\n    ...row,\n    amount_lamports: Number(row.amount_lamports),\n  };\n}\n\nfunction emptyBucketSummary(): FeeAuditBucketSummary {\n  return {\n    allocated: \"0\",\n    activeDebits: \"0\",\n    completedDebits: \"0\",\n    pendingClaimReserves: \"0\",\n    failedDebits: \"0\",\n    available: \"0\",\n  };\n}\n\n\nexport function createFeeAccountingDb(sql: ReturnType<typeof postgres>): FeeAccountingDb {\n  return {\n    async insertFeeAllocation(params) {\n      const rows = await sql<FeeAllocationEventRow[]>`\n        INSERT INTO fee_allocation_events (\n          source_type, source_id, game_type, wallet, user_id,\n          wager_lamports, fee_lamports,\n          referrer_user_id, referral_rate_bps,\n          referral_lamports, promotions_lamports, profit_lamports\n        ) VALUES (\n          ${params.sourceType},\n          ${params.sourceId},\n          ${params.gameType},\n          ${params.wallet},\n          ${params.userId ?? null},\n          ${params.wagerLamports},\n          ${params.feeLamports},\n          ${params.referrerUserId ?? null},\n          ${params.referralRateBps},\n          ${params.referralLamports},\n          ${params.promotionsLamports},\n          ${params.profitLamports}\n        )\n        ON CONFLICT (source_type, source_id, wallet) DO NOTHING\n        RETURNING *\n      `;\n      if (rows[0]) return normalizeAllocationRow(rows[0]);\n\n      // Conflict — return the existing row so callers can rely on the\n      // method's return type.\n      const existing = await sql<FeeAllocationEventRow[]>`\n        SELECT * FROM fee_allocation_events\n        WHERE source_type = ${params.sourceType}\n          AND source_id = ${params.sourceId}\n          AND wallet = ${params.wallet}\n      `;\n      return normalizeAllocationRow(existing[0]!);\n    },\n\n    async insertFeeBucketDebit(params) {\n      const rows = await sql<FeeBucketDebitRow[]>`\n        INSERT INTO fee_bucket_debits (\n          bucket, debit_type, source_id, user_id, wallet, amount_lamports, status\n        ) VALUES (\n          ${params.bucket},\n          ${params.debitType},\n          ${params.sourceId},\n          ${params.userId ?? null},\n          ${params.wallet ?? null},\n          ${params.amountLamports},\n          ${params.status ?? \"pending\"}\n        )\n        ON CONFLICT (bucket, debit_type, source_id) DO NOTHING\n        RETURNING *\n      `;\n      if (rows[0]) return normalizeDebitRow(rows[0]);\n\n      const existing = await sql<FeeBucketDebitRow[]>`\n        SELECT * FROM fee_bucket_debits\n        WHERE bucket = ${params.bucket}\n          AND debit_type = ${params.debitType}\n          AND source_id = ${params.sourceId}\n      `;\n      return normalizeDebitRow(existing[0]!);\n    },\n\n    async updateFeeBucketDebitStatus(bucket, debitType, sourceId, status) {\n      const rows = await sql<FeeBucketDebitRow[]>`\n        UPDATE fee_bucket_debits\n        SET status = ${status}, updated_at = now()\n        WHERE bucket = ${bucket}\n          AND debit_type = ${debitType}\n          AND source_id = ${sourceId}\n        RETURNING *\n      `;\n      return rows[0] ? normalizeDebitRow(rows[0]) : undefined;\n    },\n\n    async getReferralBucketAvailable() {\n      const rows = await sql<{ available: string }[]>`\n        SELECT (\n          COALESCE(\n            (SELECT SUM(referral_lamports) FROM fee_allocation_events),\n            0\n          )\n          - COALESCE(\n              (\n                SELECT SUM(amount_lamports)\n                FROM fee_bucket_debits\n                WHERE bucket = 'referral'\n                  AND status IN ${sql(RESERVED_OR_SPENT_STATUSES)}\n              ),\n              0\n            )\n        )::TEXT AS available\n      `;\n      return rows[0]!.available;\n    },\n\n    async getUserReferralAvailable(userId) {\n      const rows = await sql<{ available: string }[]>`\n        SELECT (\n          COALESCE(\n            (\n              SELECT SUM(referral_lamports)\n              FROM fee_allocation_events\n              WHERE referrer_user_id = ${userId}\n            ),\n            0\n          )\n          - COALESCE(\n              (\n                SELECT SUM(amount_lamports)\n                FROM fee_bucket_debits\n                WHERE bucket = 'referral'\n                  AND user_id = ${userId}\n                  AND status IN ${sql(RESERVED_OR_SPENT_STATUSES)}\n              ),\n              0\n            )\n        )::TEXT AS available\n      `;\n      return rows[0]!.available;\n    },\n\n    async getFeeAuditSnapshot() {\n      const totalsRowsPromise = sql<\n        {\n          fee_total: string;\n          referral_total: string;\n          promotions_total: string;\n          profit_total: string;\n          allocation_count: string;\n          audit_from: Date | null;\n        }[]\n      >`\n        SELECT\n          COALESCE(SUM(fee_lamports), 0)::TEXT          AS fee_total,\n          COALESCE(SUM(referral_lamports), 0)::TEXT     AS referral_total,\n          COALESCE(SUM(promotions_lamports), 0)::TEXT   AS promotions_total,\n          COALESCE(SUM(profit_lamports), 0)::TEXT       AS profit_total,\n          COUNT(*)::TEXT                                AS allocation_count,\n          MIN(created_at)                               AS audit_from\n        FROM fee_allocation_events\n      `;\n\n      const debitRowsPromise = sql<\n        {\n          bucket: FeeBucket;\n          status: FeeBucketDebitStatus;\n          debit_type: string;\n          sum_lamports: string;\n          row_count: string;\n        }[]\n      >`\n        SELECT\n          bucket,\n          status,\n          debit_type,\n          COALESCE(SUM(amount_lamports), 0)::TEXT AS sum_lamports,\n          COUNT(*)::TEXT                          AS row_count\n        FROM fee_bucket_debits\n        GROUP BY bucket, status, debit_type\n      `;\n\n      const violationsRowsPromise = sql<\n        {\n          source_type: string;\n          source_id: string;\n          wallet: string;\n          fee_lamports: string;\n          components_sum: string;\n        }[]\n      >`\n        SELECT\n          source_type,\n          source_id,\n          wallet,\n          fee_lamports::TEXT  AS fee_lamports,\n          (referral_lamports + promotions_lamports + profit_lamports)::TEXT\n                              AS components_sum\n        FROM fee_allocation_events\n        WHERE referral_lamports + promotions_lamports + profit_lamports <> fee_lamports\n      `;\n\n      const [totalsRows, debitRows, violationsRows] = await Promise.all([\n        totalsRowsPromise,\n        debitRowsPromise,\n        violationsRowsPromise,\n      ]);\n\n      const totalsRow = totalsRows[0]!;\n\n      const buckets = {\n        referral: emptyBucketSummary(),\n        promotions: emptyBucketSummary(),\n        profit: emptyBucketSummary(),\n      };\n\n      buckets.referral.allocated = totalsRow.referral_total;\n      buckets.promotions.allocated = totalsRow.promotions_total;\n      buckets.profit.allocated = totalsRow.profit_total;\n\n      let debitCount = 0;\n      const accum: Record<FeeBucket, { active: bigint; completed: bigint; failed: bigint; pendingClaim: bigint }> = {\n        referral: { active: 0n, completed: 0n, failed: 0n, pendingClaim: 0n },\n        promotions: { active: 0n, completed: 0n, failed: 0n, pendingClaim: 0n },\n        profit: { active: 0n, completed: 0n, failed: 0n, pendingClaim: 0n },\n      };\n\n      for (const row of debitRows) {\n        const amount = BigInt(row.sum_lamports);\n        const count = Number(row.row_count);\n        debitCount += count;\n\n        const target = accum[row.bucket];\n        if (!target) continue;\n\n        if ((ACTIVE_DEBIT_STATUSES as readonly string[]).includes(row.status)) {\n          target.active += amount;\n          if (row.debit_type === \"claim\") target.pendingClaim += amount;\n        } else if (row.status === \"completed\") {\n          target.completed += amount;\n        } else if (row.status === \"failed\") {\n          target.failed += amount;\n        }\n      }\n\n      const overdrawnBuckets: FeeBucket[] = [];\n      for (const bucket of [\"referral\", \"promotions\", \"profit\"] as const) {\n        const allocated = BigInt(buckets[bucket].allocated);\n        const { active, completed, failed, pendingClaim } = accum[bucket];\n        const reservedOrSpent = active + completed;\n        const available = allocated - reservedOrSpent;\n\n        buckets[bucket].activeDebits = active.toString();\n        buckets[bucket].completedDebits = completed.toString();\n        buckets[bucket].failedDebits = failed.toString();\n        buckets[bucket].pendingClaimReserves = pendingClaim.toString();\n        buckets[bucket].available = available.toString();\n\n        if (reservedOrSpent > allocated) overdrawnBuckets.push(bucket);\n      }\n\n      const invariantViolations = violationsRows.map((row) => ({\n        sourceType: row.source_type,\n        sourceId: row.source_id,\n        wallet: row.wallet,\n        feeLamports: row.fee_lamports,\n        componentsSum: row.components_sum,\n      }));\n\n      return {\n        totals: {\n          feeLamports: totalsRow.fee_total,\n          allocationCount: Number(totalsRow.allocation_count),\n          debitCount,\n        },\n        buckets,\n        invariantViolations,\n        overdrawnBuckets,\n        auditFrom: totalsRow.audit_from,\n      };\n    },\n  };\n}\n","numLines":536,"startLine":1,"totalLines":536}}}
