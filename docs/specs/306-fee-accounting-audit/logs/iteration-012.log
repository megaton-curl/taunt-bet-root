{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TNyY7Xq7wfTQcrRZtzyUED","type":"tool_result","content":"1\timport { SignJWT } from \"jose\";\n2\timport bs58 from \"bs58\";\n3\timport postgres from \"postgres\";\n4\timport {\n5\t  LAMPORTS_PER_SOL,\n6\t  PublicKey,\n7\t  SystemProgram,\n8\t} from \"@solana/web3.js\";\n9\timport { createDb, type Db } from \"../db.js\";\n10\timport { FLIPYOU_PROGRAM_ID } from \"../fairness.js\";\n11\timport {\n12\t  PLATFORM_PROGRAM_ID,\n13\t  derivePlatformConfigPda,\n14\t} from \"../platform-config.js\";\n15\timport {\n16\t  encodeFlipYouConfig,\n17\t  encodeFlipYouMatch,\n18\t} from \"../worker/account-decoder.js\";\n19\t\n20\texport const DATABASE_URL =\n21\t  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n22\texport const AMOUNT_LAMPORTS = 5_000_000;\n23\texport const AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\n24\texport const SIDE_HEADS = 0;\n25\texport const PHASE_LOCKED = 1;\n26\texport const JWT_SECRET = new TextEncoder().encode(\n27\t  \"test-secret-for-integration-tests\",\n28\t);\n29\t\n30\tconst RESET_TABLES = [\n31\t  \"rounds\",\n32\t  \"closecall_rounds\",\n33\t  \"closecall_candles\",\n34\t  \"operator_events\",\n35\t  \"event_queue\",\n36\t  \"game_entries\",\n37\t  \"transactions\",\n38\t  \"player_profiles\",\n39\t  \"referral_codes\",\n40\t  \"referral_links\",\n41\t  \"referral_earnings\",\n42\t  \"referral_claims\",\n43\t  \"referral_kol_rates\",\n44\t  \"reward_pool_fundings\",\n45\t  \"point_grants\",\n46\t  \"point_balances\",\n47\t  \"point_rate_versions\",\n48\t  \"multiplier_modifiers\",\n49\t  \"multiplier_ladder_steps\",\n50\t  \"multiplier_ladders\",\n51\t  \"events\",\n52\t  \"seasons\",\n53\t  \"crate_drops\",\n54\t  \"progress_events\",\n55\t  \"challenge_assignments\",\n56\t  \"bonus_completions\",\n57\t  \"fee_allocation_events\",\n58\t  \"fee_bucket_debits\",\n59\t  \"fee_audit_checkpoints\",\n60\t].join(\", \");\n61\t\n62\texport type TestSql = ReturnType<typeof postgres>;\n63\t\n64\texport interface IntegrationDbContext {\n65\t  db: Db;\n66\t  rawSql: TestSql;\n67\t}\n68\t\n69\tlet referralTablesEnsured = false;\n70\tlet rewardEconomyTablesEnsured = false;\n71\t\n72\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n73\texport function makeSql() {\n74\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n75\t  return postgres({\n76\t    host: \"/var/run/postgresql\",\n77\t    user: \"vscode\",\n78\t    database: \"taunt_bet_dev\",\n79\t  });\n80\t}\n81\t\n82\texport async function openIntegrationDb(): Promise<IntegrationDbContext> {\n83\t  const rawSql = makeSql();\n84\t  await ensureReferralTables(rawSql);\n85\t  await ensureRewardEconomyTables(rawSql);\n86\t  return {\n87\t    rawSql,\n88\t    db: createDb(DATABASE_URL, rawSql),\n89\t  };\n90\t}\n91\t\n92\texport async function closeIntegrationDb(ctx: IntegrationDbContext) {\n93\t  await ctx.db.close();\n94\t  await ctx.rawSql.end();\n95\t}\n96\t\n97\t/**\n98\t * Seed a player_profile row for a test. Production creates profiles via the\n99\t * auth flow before any wager fires; tests that bypass auth and call the\n100\t * points-grant handler directly need to pre-create the row, since the\n101\t * handler now updates the profile in-place for materialized economy state.\n102\t */\n103\texport async function seedPlayerProfile(\n104\t  rawSql: TestSql,\n105\t  userId: string,\n106\t  wallet: string,\n107\t  username: string = `tester-${userId}`,\n108\t): Promise<void> {\n109\t  await rawSql`\n110\t    INSERT INTO player_profiles (user_id, wallet, username)\n111\t    VALUES (${userId}, ${wallet}, ${username})\n112\t    ON CONFLICT (user_id) DO NOTHING\n113\t  `;\n114\t}\n115\t\n116\texport async function resetIntegrationState(rawSql: TestSql) {\n117\t  await ensureReferralTables(rawSql);\n118\t  await ensureRewardEconomyTables(rawSql);\n119\t  await rawSql.begin(async (tx) => {\n120\t    const sql = tx as unknown as TestSql;\n121\t    await sql`SELECT pg_advisory_xact_lock(401402)`;\n122\t    await sql.unsafe(`TRUNCATE ${RESET_TABLES} RESTART IDENTITY CASCADE`);\n123\t    await sql`\n124\t    INSERT INTO reward_pool (\n125\t      id,\n126\t      balance_lamports,\n127\t      lifetime_funded,\n128\t      lifetime_paid,\n129\t      updated_at\n130\t    )\n131\t    VALUES (1, 0, 0, 0, now())\n132\t    ON CONFLICT (id) DO UPDATE\n133\t    SET\n134\t      balance_lamports = EXCLUDED.balance_lamports,\n135\t      lifetime_funded = EXCLUDED.lifetime_funded,\n136\t      lifetime_paid = EXCLUDED.lifetime_paid,\n137\t      updated_at = EXCLUDED.updated_at\n138\t  `;\n139\t    await sql`\n140\t    INSERT INTO seasons (slug, name, starts_at, status)\n141\t    VALUES ('season-1', 'Season 1', '2026-01-01T00:00:00Z', 'active')\n142\t  `;\n143\t    await sql`\n144\t    INSERT INTO point_rate_versions (rate_per_usd, effective_from, label)\n145\t    VALUES (100, '2026-01-01T00:00:00Z', 'Launch default')\n146\t  `;\n147\t    await sql`\n148\t      DELETE FROM reward_config\n149\t      WHERE key IN ('points_per_dollar', 'dogpile_default_multiplier')\n150\t    `;\n151\t    await sql`\n152\t      INSERT INTO reward_config (key, value)\n153\t      VALUES\n154\t        ('reward_pool_fee_share', '0.20'),\n155\t        ('points_crate_drop_rate', '0.05'),\n156\t        ('sol_crate_drop_rate', '0.01'),\n157\t        ('sol_crate_pool_pct', '0.10'),\n158\t        ('sol_crate_min_value', '10000000'),\n159\t        ('points_crate_min', '500'),\n160\t        ('points_crate_max', '5000'),\n161\t        ('daily_challenge_count', '3'),\n162\t        ('weekly_challenge_count', '2')\n163\t      ON CONFLICT (key) DO UPDATE\n164\t      SET value = EXCLUDED.value, updated_at = now()\n165\t    `;\n166\t    await sql`\n167\t    WITH lifetime_ladder AS (\n168\t      INSERT INTO multiplier_ladders (scope, metric, effective_from, label)\n169\t      VALUES ('lifetime', 'wagered_usd', '2026-01-01T00:00:00Z', 'Launch lifetime ladder')\n170\t      RETURNING id\n171\t    )\n172\t    INSERT INTO multiplier_ladder_steps (ladder_id, level, threshold_usd, multiplier, sort_order)\n173\t    SELECT id, level, threshold_usd, multiplier, level\n174\t    FROM lifetime_ladder\n175\t    CROSS JOIN (VALUES\n176\t      (1, 1000, 1.10),\n177\t      (2, 10000, 1.20),\n178\t      (3, 50000, 1.30),\n179\t      (4, 100000, 1.40),\n180\t      (5, 250000, 1.50),\n181\t      (6, 500000, 1.60),\n182\t      (7, 1000000, 1.70),\n183\t      (8, 2500000, 1.80),\n184\t      (9, 5000000, 1.90),\n185\t      (10, 10000000, 2.00)\n186\t    ) AS steps(level, threshold_usd, multiplier)\n187\t  `;\n188\t    await sql`\n189\t    WITH active_season AS (\n190\t      SELECT id FROM seasons WHERE status = 'active' LIMIT 1\n191\t    ),\n192\t    season_ladder AS (\n193\t      INSERT INTO multiplier_ladders (scope, metric, season_id, effective_from, label)\n194\t      SELECT 'season', 'wagered_usd', id, '2026-01-01T00:00:00Z', 'Launch season ladder'\n195\t      FROM active_season\n196\t      RETURNING id\n197\t    )\n198\t    INSERT INTO multiplier_ladder_steps (ladder_id, level, threshold_usd, multiplier, sort_order)\n199\t    SELECT id, level, threshold_usd, multiplier, level\n200\t    FROM season_ladder\n201\t    CROSS JOIN (VALUES\n202\t      (1, 500, 1.20),\n203\t      (2, 5000, 1.50),\n204\t      (3, 25000, 2.00),\n205\t      (4, 100000, 2.50),\n206\t      (5, 250000, 3.00)\n207\t    ) AS steps(level, threshold_usd, multiplier)\n208\t  `;\n209\t  });\n210\t}\n211\t\n212\texport async function makeJwt(\n213\t  wallet: string,\n214\t  userId = userIdFromWallet(wallet),\n215\t) {\n216\t  const now = Math.floor(Date.now() / 1000);\n217\t  return new SignJWT({ wallet })\n218\t    .setProtectedHeader({ alg: \"HS256\" })\n219\t    .setSubject(userId)\n220\t    .setIssuedAt(now)\n221\t    .setExpirationTime(now + 3600)\n222\t    .sign(JWT_SECRET);\n223\t}\n224\t\n225\texport function userIdFromWallet(wallet: string) {\n226\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n227\t}\n228\t\n229\t/**\n230\t * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n231\t * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n232\t * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n233\t */\n234\texport class MockConnection {\n235\t  private _slot = 200;\n236\t  private _accounts = new Map<\n237\t    string,\n238\t    {\n239\t      data: Buffer;\n240\t      lamports: number;\n241\t      owner: PublicKey;\n242\t      executable: boolean;\n243\t    }\n244\t  >();\n245\t  lastRawTx: Buffer | null = null;\n246\t\n247\t  set slot(s: number) {\n248\t    this._slot = s;\n249\t  }\n250\t\n251\t  get slot() {\n252\t    return this._slot;\n253\t  }\n254\t\n255\t  setAccount(\n256\t    pubkey: PublicKey,\n257\t    data: Buffer,\n258\t    opts?: { lamports?: number; owner?: PublicKey },\n259\t  ) {\n260\t    this._accounts.set(pubkey.toBase58(), {\n261\t      data,\n262\t      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n263\t      owner: opts?.owner ?? SystemProgram.programId,\n264\t      executable: false,\n265\t    });\n266\t  }\n267\t\n268\t  removeAccount(pubkey: PublicKey) {\n269\t    this._accounts.delete(pubkey.toBase58());\n270\t  }\n271\t\n272\t  async getLatestBlockhash() {\n273\t    return {\n274\t      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n275\t      lastValidBlockHeight: 999_999,\n276\t    };\n277\t  }\n278\t\n279\t  async getSlot() {\n280\t    return this._slot;\n281\t  }\n282\t\n283\t  async getAccountInfo(pubkey: PublicKey) {\n284\t    const acc = this._accounts.get(pubkey.toBase58());\n285\t    if (!acc) return null;\n286\t    return { ...acc, rentEpoch: 0 };\n287\t  }\n288\t\n289\t  async getProgramAccounts(\n290\t    programId: PublicKey,\n291\t    config?: {\n292\t      filters?: Array<\n293\t        | { dataSize: number }\n294\t        | { memcmp: { offset: number; bytes: string } }\n295\t      >;\n296\t    },\n297\t  ) {\n298\t    const results: Array<{\n299\t      pubkey: PublicKey;\n300\t      account: {\n301\t        data: Buffer;\n302\t        lamports: number;\n303\t        owner: PublicKey;\n304\t        executable: boolean;\n305\t        rentEpoch: number;\n306\t      };\n307\t    }> = [];\n308\t\n309\t    for (const [key, acc] of this._accounts) {\n310\t      if (!acc.owner.equals(programId)) continue;\n311\t\n312\t      let matches = true;\n313\t      if (config?.filters) {\n314\t        for (const filter of config.filters) {\n315\t          if (\"dataSize\" in filter && acc.data.length !== filter.dataSize) {\n316\t            matches = false;\n317\t            break;\n318\t          }\n319\t\n320\t          if (\"memcmp\" in filter) {\n321\t            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n322\t            const actual = acc.data.subarray(\n323\t              filter.memcmp.offset,\n324\t              filter.memcmp.offset + expected.length,\n325\t            );\n326\t            if (Buffer.compare(actual, expected) !== 0) {\n327\t              matches = false;\n328\t              break;\n329\t            }\n330\t          }\n331\t        }\n332\t      }\n333\t\n334\t      if (matches) {\n335\t        results.push({\n336\t          pubkey: new PublicKey(key),\n337\t          account: { ...acc, rentEpoch: 0 },\n338\t        });\n339\t      }\n340\t    }\n341\t\n342\t    return results;\n343\t  }\n344\t\n345\t  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n346\t    this.lastRawTx = Buffer.from(rawTx);\n347\t    return bs58.encode(Buffer.alloc(64, 0x01));\n348\t  }\n349\t\n350\t  async confirmTransaction() {\n351\t    return { value: { err: null }, context: { slot: this._slot } };\n352\t  }\n353\t\n354\t  async getBlockTime(_slot: number) {\n355\t    return Math.floor(Date.now() / 1000);\n356\t  }\n357\t\n358\t  async getBalance() {\n359\t    return 2 * LAMPORTS_PER_SOL;\n360\t  }\n361\t}\n362\t\n363\texport async function buildMatchAccountData(params: {\n364\t  creator: PublicKey;\n365\t  opponent: PublicKey;\n366\t  server: PublicKey;\n367\t  entryAmount: bigint;\n368\t  creatorSide: number;\n369\t  phase: number;\n370\t  commitment: Buffer;\n371\t  algorithmVer: number;\n372\t  targetSlot: bigint;\n373\t  resolveDeadline: bigint;\n374\t  matchId: Buffer;\n375\t}): Promise<Buffer> {\n376\t  return encodeFlipYouMatch({\n377\t    creator: params.creator,\n378\t    opponent: params.opponent,\n379\t    server: params.server,\n380\t    entryAmount: params.entryAmount,\n381\t    creatorSide: params.creatorSide,\n382\t    phase: params.phase,\n383\t    commitment: [...params.commitment],\n384\t    algorithmVer: params.algorithmVer,\n385\t    targetSlot: params.targetSlot,\n386\t    resolveDeadline: params.resolveDeadline,\n387\t    resultHash: new Array(32).fill(0),\n388\t    result: 0,\n389\t    winner: PublicKey.default,\n390\t    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n391\t    matchId: [...params.matchId],\n392\t    bump: 0,\n393\t  });\n394\t}\n395\t\n396\texport async function seedSettlementProgramAccounts(\n397\t  mockConn: MockConnection,\n398\t  params: {\n399\t    entropyAccount: PublicKey;\n400\t    entropyData: Buffer;\n401\t    treasury: PublicKey;\n402\t  },\n403\t) {\n404\t  mockConn.setAccount(params.entropyAccount, params.entropyData);\n405\t\n406\t  const [configPda] = PublicKey.findProgramAddressSync(\n407\t    [Buffer.from(\"flipyou_config\")],\n408\t    FLIPYOU_PROGRAM_ID,\n409\t  );\n410\t  mockConn.setAccount(\n411\t    configPda,\n412\t    await buildConfigAccountData(params.treasury),\n413\t    { owner: FLIPYOU_PROGRAM_ID },\n414\t  );\n415\t\n416\t  const [platformConfigPda] = derivePlatformConfigPda();\n417\t  mockConn.setAccount(\n418\t    platformConfigPda,\n419\t    buildPlatformConfigData(params.treasury, 500),\n420\t    { owner: PLATFORM_PROGRAM_ID },\n421\t  );\n422\t}\n423\t\n424\tasync function ensureReferralTables(rawSql: TestSql) {\n425\t  if (referralTablesEnsured) {\n426\t    return;\n427\t  }\n428\t\n429\t  await rawSql`\n430\t    CREATE TABLE IF NOT EXISTS referral_codes (\n431\t      id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n432\t      user_id TEXT NOT NULL UNIQUE,\n433\t      wallet TEXT NOT NULL UNIQUE,\n434\t      code TEXT NOT NULL UNIQUE,\n435\t      created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n436\t      updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n437\t    )\n438\t  `;\n439\t  await rawSql`\n440\t    CREATE TABLE IF NOT EXISTS referral_links (\n441\t      id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n442\t      referrer_user_id TEXT NOT NULL,\n443\t      referee_user_id TEXT NOT NULL UNIQUE,\n444\t      referrer_wallet TEXT NOT NULL,\n445\t      referee_wallet TEXT NOT NULL,\n446\t      created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n447\t    )\n448\t  `;\n449\t  await rawSql`\n450\t    CREATE INDEX IF NOT EXISTS idx_referral_links_referrer\n451\t    ON referral_links (referrer_user_id)\n452\t  `;\n453\t  await rawSql`\n454\t    CREATE TABLE IF NOT EXISTS referral_earnings (\n455\t      id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n456\t      referrer_user_id TEXT NOT NULL,\n457\t      referee_user_id TEXT NOT NULL,\n458\t      referrer_wallet TEXT NOT NULL,\n459\t      referee_wallet TEXT NOT NULL,\n460\t      round_id TEXT NOT NULL,\n461\t      game_type TEXT NOT NULL,\n462\t      wager_lamports BIGINT NOT NULL,\n463\t      fee_lamports BIGINT NOT NULL,\n464\t      referrer_earned_lamports BIGINT NOT NULL,\n465\t      referrer_rate_bps INTEGER NOT NULL,\n466\t      created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n467\t      CONSTRAINT uq_referral_earnings_referee_round\n468\t        UNIQUE (referee_user_id, round_id)\n469\t    )\n470\t  `;\n471\t  await rawSql`\n472\t    CREATE INDEX IF NOT EXISTS idx_referral_earnings_referrer\n473\t    ON referral_earnings (referrer_user_id, created_at)\n474\t  `;\n475\t  await rawSql`\n476\t    CREATE INDEX IF NOT EXISTS idx_referral_earnings_referee\n477\t    ON referral_earnings (referee_user_id, created_at)\n478\t  `;\n479\t  await rawSql`\n480\t    CREATE INDEX IF NOT EXISTS idx_referral_earnings_round_id\n481\t    ON referral_earnings (round_id)\n482\t  `;\n483\t  await rawSql`\n484\t    CREATE TABLE IF NOT EXISTS referral_claims (\n485\t      id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n486\t      user_id TEXT NOT NULL,\n487\t      wallet TEXT NOT NULL,\n488\t      amount_lamports BIGINT NOT NULL,\n489\t      status TEXT NOT NULL DEFAULT 'pending'\n490\t        CHECK (\n491\t          status IN ('pending', 'processing', 'error', 'completed', 'failed')\n492\t        ),\n493\t      retry_count INTEGER NOT NULL DEFAULT 0,\n494\t      tx_signature TEXT,\n495\t      error TEXT,\n496\t      requested_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n497\t      processed_at TIMESTAMPTZ\n498\t    )\n499\t  `;\n500\t  await rawSql`\n501\t    CREATE INDEX IF NOT EXISTS idx_referral_claims_user_id\n502\t    ON referral_claims (user_id, requested_at)\n503\t  `;\n504\t  await rawSql`\n505\t    CREATE INDEX IF NOT EXISTS idx_referral_claims_status\n506\t    ON referral_claims (status)\n507\t    WHERE status IN ('pending', 'processing')\n508\t  `;\n509\t  await rawSql`\n510\t    CREATE UNIQUE INDEX IF NOT EXISTS idx_referral_claims_user_active\n511\t    ON referral_claims (user_id)\n512\t    WHERE status IN ('pending', 'processing', 'error')\n513\t  `;\n514\t  await rawSql`\n515\t    CREATE TABLE IF NOT EXISTS referral_kol_rates (\n516\t      user_id TEXT PRIMARY KEY,\n517\t      wallet TEXT NOT NULL UNIQUE,\n518\t      rate_bps INTEGER NOT NULL,\n519\t      set_by TEXT NOT NULL,\n520\t      created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n521\t      updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n522\t    )\n523\t  `;\n524\t\n525\t  referralTablesEnsured = true;\n526\t}\n527\t\n528\tasync function ensureRewardEconomyTables(rawSql: TestSql) {\n529\t  if (rewardEconomyTablesEnsured) {\n530\t    return;\n531\t  }\n532\t\n533\t  await rawSql`SELECT pg_advisory_lock(401401)`;\n534\t  try {\n535\t    await rawSql`\n536\t      CREATE TABLE IF NOT EXISTS seasons (\n537\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n538\t        slug TEXT NOT NULL UNIQUE,\n539\t        name TEXT NOT NULL,\n540\t        starts_at TIMESTAMPTZ NOT NULL,\n541\t        ends_at TIMESTAMPTZ,\n542\t        status TEXT NOT NULL CHECK (status IN ('scheduled', 'active', 'ended', 'cancelled')),\n543\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n544\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n545\t      )\n546\t    `;\n547\t    await rawSql`\n548\t      CREATE UNIQUE INDEX IF NOT EXISTS idx_seasons_one_active\n549\t      ON seasons ((status))\n550\t      WHERE status = 'active'\n551\t    `;\n552\t    await rawSql`\n553\t      CREATE TABLE IF NOT EXISTS point_rate_versions (\n554\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n555\t        rate_per_usd NUMERIC(18,6) NOT NULL,\n556\t        effective_from TIMESTAMPTZ NOT NULL,\n557\t        label TEXT,\n558\t        created_by TEXT,\n559\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n560\t      )\n561\t    `;\n562\t    await rawSql`\n563\t      CREATE TABLE IF NOT EXISTS point_balances (\n564\t        user_id TEXT NOT NULL,\n565\t        season_id BIGINT NOT NULL REFERENCES seasons(id),\n566\t        wallet TEXT NOT NULL,\n567\t        balance BIGINT NOT NULL DEFAULT 0,\n568\t        season_earned BIGINT NOT NULL DEFAULT 0,\n569\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n570\t        PRIMARY KEY (user_id, season_id)\n571\t      )\n572\t    `;\n573\t    await rawSql`\n574\t      ALTER TABLE player_profiles\n575\t      ADD COLUMN IF NOT EXISTS lifetime_usd NUMERIC(20,6) NOT NULL DEFAULT 0\n576\t    `;\n577\t    await rawSql`\n578\t      ALTER TABLE player_profiles\n579\t      ADD COLUMN IF NOT EXISTS current_season_id BIGINT REFERENCES seasons(id)\n580\t    `;\n581\t    await rawSql`\n582\t      ALTER TABLE player_profiles\n583\t      ADD COLUMN IF NOT EXISTS current_season_usd NUMERIC(20,6) NOT NULL DEFAULT 0\n584\t    `;\n585\t    await rawSql`\n586\t      ALTER TABLE player_profiles\n587\t      ADD COLUMN IF NOT EXISTS cached_lifetime_multiplier NUMERIC(12,6) NOT NULL DEFAULT 1.0\n588\t    `;\n589\t    await rawSql`\n590\t      ALTER TABLE player_profiles\n591\t      ADD COLUMN IF NOT EXISTS cached_season_multiplier NUMERIC(12,6) NOT NULL DEFAULT 1.0\n592\t    `;\n593\t    await rawSql`\n594\t      CREATE TABLE IF NOT EXISTS multiplier_ladders (\n595\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n596\t        scope TEXT NOT NULL CHECK (scope IN ('lifetime', 'season')),\n597\t        metric TEXT NOT NULL CHECK (metric IN ('wagered_usd')),\n598\t        season_id BIGINT REFERENCES seasons(id),\n599\t        effective_from TIMESTAMPTZ NOT NULL,\n600\t        label TEXT,\n601\t        created_by TEXT,\n602\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n603\t      )\n604\t    `;\n605\t    await rawSql`\n606\t      CREATE TABLE IF NOT EXISTS multiplier_ladder_steps (\n607\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n608\t        ladder_id BIGINT NOT NULL REFERENCES multiplier_ladders(id) ON DELETE CASCADE,\n609\t        level INT NOT NULL,\n610\t        threshold_usd NUMERIC(20,6) NOT NULL,\n611\t        multiplier NUMERIC(12,6) NOT NULL CHECK (multiplier >= 0 AND multiplier <= 10),\n612\t        sort_order INT NOT NULL DEFAULT 0,\n613\t        UNIQUE (ladder_id, threshold_usd),\n614\t        UNIQUE (ladder_id, level)\n615\t      )\n616\t    `;\n617\t    await rawSql`\n618\t      CREATE TABLE IF NOT EXISTS events (\n619\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n620\t        season_id BIGINT REFERENCES seasons(id),\n621\t        event_type TEXT NOT NULL DEFAULT 'generic',\n622\t        display_name TEXT NOT NULL,\n623\t        starts_at TIMESTAMPTZ NOT NULL,\n624\t        ends_at TIMESTAMPTZ NOT NULL,\n625\t        status TEXT NOT NULL DEFAULT 'scheduled'\n626\t          CHECK (status IN ('scheduled', 'active', 'ended', 'cancelled')),\n627\t        config JSONB NOT NULL DEFAULT '{}',\n628\t        created_by TEXT,\n629\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n630\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n631\t      )\n632\t    `;\n633\t    await rawSql`\n634\t      CREATE TABLE IF NOT EXISTS multiplier_modifiers (\n635\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n636\t        user_id TEXT,\n637\t        season_id BIGINT NOT NULL REFERENCES seasons(id),\n638\t        source_type TEXT NOT NULL CHECK (source_type IN ('event', 'admin', 'reward')),\n639\t        source_id TEXT NOT NULL,\n640\t        mode TEXT NOT NULL DEFAULT 'set_value'\n641\t          CHECK (mode IN ('multiply', 'set_min', 'set_value')),\n642\t        value NUMERIC(12,6) NOT NULL CHECK (value >= 0 AND value <= 10),\n643\t        priority INT NOT NULL DEFAULT 0,\n644\t        starts_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n645\t        ends_at TIMESTAMPTZ,\n646\t        created_by TEXT,\n647\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n648\t      )\n649\t    `;\n650\t    // Tighten season_id on dev DBs that already have the table from an\n651\t    // earlier run when season_id was nullable.\n652\t    await rawSql`\n653\t      UPDATE multiplier_modifiers\n654\t      SET season_id = (SELECT id FROM seasons WHERE status = 'active' LIMIT 1)\n655\t      WHERE season_id IS NULL\n656\t    `;\n657\t    await rawSql`\n658\t      ALTER TABLE multiplier_modifiers\n659\t      ALTER COLUMN season_id SET NOT NULL\n660\t    `;\n661\t    await rawSql`\n662\t      ALTER TABLE point_grants\n663\t      ADD COLUMN IF NOT EXISTS season_id BIGINT REFERENCES seasons(id)\n664\t    `;\n665\t    await rawSql`\n666\t      ALTER TABLE point_grants\n667\t      ADD COLUMN IF NOT EXISTS effective_multiplier NUMERIC(12,6) NOT NULL DEFAULT 1.0\n668\t    `;\n669\t    await rawSql`\n670\t      ALTER TABLE point_grants\n671\t      ADD COLUMN IF NOT EXISTS point_rate_version_id BIGINT REFERENCES point_rate_versions(id)\n672\t    `;\n673\t    await rawSql`\n674\t      ALTER TABLE point_grants\n675\t      DROP CONSTRAINT IF EXISTS point_grants_source_type_check\n676\t    `;\n677\t    await rawSql`\n678\t      ALTER TABLE point_grants\n679\t      ADD CONSTRAINT point_grants_source_type_check\n680\t      CHECK (source_type IN (\n681\t        'wager',\n682\t        'challenge_completed',\n683\t        'bonus_completed',\n684\t        'crate_points',\n685\t        'admin_adjustment',\n686\t        'reward',\n687\t        'migration_adjustment'\n688\t      ))\n689\t    `;\n690\t\n691\t    rewardEconomyTablesEnsured = true;\n692\t  } finally {\n693\t    await rawSql`SELECT pg_advisory_unlock(401401)`;\n694\t  }\n695\t}\n696\t\n697\tasync function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n698\t  return encodeFlipYouConfig({\n699\t    authority: PublicKey.default,\n700\t    treasury,\n701\t    paused: false,\n702\t    bump: 0,\n703\t  });\n704\t}\n705\t\n706\tfunction buildPlatformConfigData(treasury: PublicKey, feeBps: number): Buffer {\n707\t  const buf = Buffer.alloc(74);\n708\t  PublicKey.default.toBuffer().copy(buf, 8);\n709\t  treasury.toBuffer().copy(buf, 40);\n710\t  buf.writeUInt16LE(feeBps, 72);\n711\t  return buf;\n712\t}\n713\t"}]},"parent_tool_use_id":null,"session_id":"896d4934-c43e-44ca-831c-60139b475f70","uuid":"84fde224-6378-4fe4-8663-050a7ae61664","timestamp":"2026-05-01T20:27:47.837Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/integration-test-helpers.ts","content":"import { SignJWT } from \"jose\";\nimport bs58 from \"bs58\";\nimport postgres from \"postgres\";\nimport {\n  LAMPORTS_PER_SOL,\n  PublicKey,\n  SystemProgram,\n} from \"@solana/web3.js\";\nimport { createDb, type Db } from \"../db.js\";\nimport { FLIPYOU_PROGRAM_ID } from \"../fairness.js\";\nimport {\n  PLATFORM_PROGRAM_ID,\n  derivePlatformConfigPda,\n} from \"../platform-config.js\";\nimport {\n  encodeFlipYouConfig,\n  encodeFlipYouMatch,\n} from \"../worker/account-decoder.js\";\n\nexport const DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\nexport const AMOUNT_LAMPORTS = 5_000_000;\nexport const AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\nexport const SIDE_HEADS = 0;\nexport const PHASE_LOCKED = 1;\nexport const JWT_SECRET = new TextEncoder().encode(\n  \"test-secret-for-integration-tests\",\n);\n\nconst RESET_TABLES = [\n  \"rounds\",\n  \"closecall_rounds\",\n  \"closecall_candles\",\n  \"operator_events\",\n  \"event_queue\",\n  \"game_entries\",\n  \"transactions\",\n  \"player_profiles\",\n  \"referral_codes\",\n  \"referral_links\",\n  \"referral_earnings\",\n  \"referral_claims\",\n  \"referral_kol_rates\",\n  \"reward_pool_fundings\",\n  \"point_grants\",\n  \"point_balances\",\n  \"point_rate_versions\",\n  \"multiplier_modifiers\",\n  \"multiplier_ladder_steps\",\n  \"multiplier_ladders\",\n  \"events\",\n  \"seasons\",\n  \"crate_drops\",\n  \"progress_events\",\n  \"challenge_assignments\",\n  \"bonus_completions\",\n  \"fee_allocation_events\",\n  \"fee_bucket_debits\",\n  \"fee_audit_checkpoints\",\n].join(\", \");\n\nexport type TestSql = ReturnType<typeof postgres>;\n\nexport interface IntegrationDbContext {\n  db: Db;\n  rawSql: TestSql;\n}\n\nlet referralTablesEnsured = false;\nlet rewardEconomyTablesEnsured = false;\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nexport function makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"taunt_bet_dev\",\n  });\n}\n\nexport async function openIntegrationDb(): Promise<IntegrationDbContext> {\n  const rawSql = makeSql();\n  await ensureReferralTables(rawSql);\n  await ensureRewardEconomyTables(rawSql);\n  return {\n    rawSql,\n    db: createDb(DATABASE_URL, rawSql),\n  };\n}\n\nexport async function closeIntegrationDb(ctx: IntegrationDbContext) {\n  await ctx.db.close();\n  await ctx.rawSql.end();\n}\n\n/**\n * Seed a player_profile row for a test. Production creates profiles via the\n * auth flow before any wager fires; tests that bypass auth and call the\n * points-grant handler directly need to pre-create the row, since the\n * handler now updates the profile in-place for materialized economy state.\n */\nexport async function seedPlayerProfile(\n  rawSql: TestSql,\n  userId: string,\n  wallet: string,\n  username: string = `tester-${userId}`,\n): Promise<void> {\n  await rawSql`\n    INSERT INTO player_profiles (user_id, wallet, username)\n    VALUES (${userId}, ${wallet}, ${username})\n    ON CONFLICT (user_id) DO NOTHING\n  `;\n}\n\nexport async function resetIntegrationState(rawSql: TestSql) {\n  await ensureReferralTables(rawSql);\n  await ensureRewardEconomyTables(rawSql);\n  await rawSql.begin(async (tx) => {\n    const sql = tx as unknown as TestSql;\n    await sql`SELECT pg_advisory_xact_lock(401402)`;\n    await sql.unsafe(`TRUNCATE ${RESET_TABLES} RESTART IDENTITY CASCADE`);\n    await sql`\n    INSERT INTO reward_pool (\n      id,\n      balance_lamports,\n      lifetime_funded,\n      lifetime_paid,\n      updated_at\n    )\n    VALUES (1, 0, 0, 0, now())\n    ON CONFLICT (id) DO UPDATE\n    SET\n      balance_lamports = EXCLUDED.balance_lamports,\n      lifetime_funded = EXCLUDED.lifetime_funded,\n      lifetime_paid = EXCLUDED.lifetime_paid,\n      updated_at = EXCLUDED.updated_at\n  `;\n    await sql`\n    INSERT INTO seasons (slug, name, starts_at, status)\n    VALUES ('season-1', 'Season 1', '2026-01-01T00:00:00Z', 'active')\n  `;\n    await sql`\n    INSERT INTO point_rate_versions (rate_per_usd, effective_from, label)\n    VALUES (100, '2026-01-01T00:00:00Z', 'Launch default')\n  `;\n    await sql`\n      DELETE FROM reward_config\n      WHERE key IN ('points_per_dollar', 'dogpile_default_multiplier')\n    `;\n    await sql`\n      INSERT INTO reward_config (key, value)\n      VALUES\n        ('reward_pool_fee_share', '0.20'),\n        ('points_crate_drop_rate', '0.05'),\n        ('sol_crate_drop_rate', '0.01'),\n        ('sol_crate_pool_pct', '0.10'),\n        ('sol_crate_min_value', '10000000'),\n        ('points_crate_min', '500'),\n        ('points_crate_max', '5000'),\n        ('daily_challenge_count', '3'),\n        ('weekly_challenge_count', '2')\n      ON CONFLICT (key) DO UPDATE\n      SET value = EXCLUDED.value, updated_at = now()\n    `;\n    await sql`\n    WITH lifetime_ladder AS (\n      INSERT INTO multiplier_ladders (scope, metric, effective_from, label)\n      VALUES ('lifetime', 'wagered_usd', '2026-01-01T00:00:00Z', 'Launch lifetime ladder')\n      RETURNING id\n    )\n    INSERT INTO multiplier_ladder_steps (ladder_id, level, threshold_usd, multiplier, sort_order)\n    SELECT id, level, threshold_usd, multiplier, level\n    FROM lifetime_ladder\n    CROSS JOIN (VALUES\n      (1, 1000, 1.10),\n      (2, 10000, 1.20),\n      (3, 50000, 1.30),\n      (4, 100000, 1.40),\n      (5, 250000, 1.50),\n      (6, 500000, 1.60),\n      (7, 1000000, 1.70),\n      (8, 2500000, 1.80),\n      (9, 5000000, 1.90),\n      (10, 10000000, 2.00)\n    ) AS steps(level, threshold_usd, multiplier)\n  `;\n    await sql`\n    WITH active_season AS (\n      SELECT id FROM seasons WHERE status = 'active' LIMIT 1\n    ),\n    season_ladder AS (\n      INSERT INTO multiplier_ladders (scope, metric, season_id, effective_from, label)\n      SELECT 'season', 'wagered_usd', id, '2026-01-01T00:00:00Z', 'Launch season ladder'\n      FROM active_season\n      RETURNING id\n    )\n    INSERT INTO multiplier_ladder_steps (ladder_id, level, threshold_usd, multiplier, sort_order)\n    SELECT id, level, threshold_usd, multiplier, level\n    FROM season_ladder\n    CROSS JOIN (VALUES\n      (1, 500, 1.20),\n      (2, 5000, 1.50),\n      (3, 25000, 2.00),\n      (4, 100000, 2.50),\n      (5, 250000, 3.00)\n    ) AS steps(level, threshold_usd, multiplier)\n  `;\n  });\n}\n\nexport async function makeJwt(\n  wallet: string,\n  userId = userIdFromWallet(wallet),\n) {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({ wallet })\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userId)\n    .setIssuedAt(now)\n    .setExpirationTime(now + 3600)\n    .sign(JWT_SECRET);\n}\n\nexport function userIdFromWallet(wallet: string) {\n  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n}\n\n/**\n * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n */\nexport class MockConnection {\n  private _slot = 200;\n  private _accounts = new Map<\n    string,\n    {\n      data: Buffer;\n      lamports: number;\n      owner: PublicKey;\n      executable: boolean;\n    }\n  >();\n  lastRawTx: Buffer | null = null;\n\n  set slot(s: number) {\n    this._slot = s;\n  }\n\n  get slot() {\n    return this._slot;\n  }\n\n  setAccount(\n    pubkey: PublicKey,\n    data: Buffer,\n    opts?: { lamports?: number; owner?: PublicKey },\n  ) {\n    this._accounts.set(pubkey.toBase58(), {\n      data,\n      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n      owner: opts?.owner ?? SystemProgram.programId,\n      executable: false,\n    });\n  }\n\n  removeAccount(pubkey: PublicKey) {\n    this._accounts.delete(pubkey.toBase58());\n  }\n\n  async getLatestBlockhash() {\n    return {\n      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n      lastValidBlockHeight: 999_999,\n    };\n  }\n\n  async getSlot() {\n    return this._slot;\n  }\n\n  async getAccountInfo(pubkey: PublicKey) {\n    const acc = this._accounts.get(pubkey.toBase58());\n    if (!acc) return null;\n    return { ...acc, rentEpoch: 0 };\n  }\n\n  async getProgramAccounts(\n    programId: PublicKey,\n    config?: {\n      filters?: Array<\n        | { dataSize: number }\n        | { memcmp: { offset: number; bytes: string } }\n      >;\n    },\n  ) {\n    const results: Array<{\n      pubkey: PublicKey;\n      account: {\n        data: Buffer;\n        lamports: number;\n        owner: PublicKey;\n        executable: boolean;\n        rentEpoch: number;\n      };\n    }> = [];\n\n    for (const [key, acc] of this._accounts) {\n      if (!acc.owner.equals(programId)) continue;\n\n      let matches = true;\n      if (config?.filters) {\n        for (const filter of config.filters) {\n          if (\"dataSize\" in filter && acc.data.length !== filter.dataSize) {\n            matches = false;\n            break;\n          }\n\n          if (\"memcmp\" in filter) {\n            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n            const actual = acc.data.subarray(\n              filter.memcmp.offset,\n              filter.memcmp.offset + expected.length,\n            );\n            if (Buffer.compare(actual, expected) !== 0) {\n              matches = false;\n              break;\n            }\n          }\n        }\n      }\n\n      if (matches) {\n        results.push({\n          pubkey: new PublicKey(key),\n          account: { ...acc, rentEpoch: 0 },\n        });\n      }\n    }\n\n    return results;\n  }\n\n  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n    this.lastRawTx = Buffer.from(rawTx);\n    return bs58.encode(Buffer.alloc(64, 0x01));\n  }\n\n  async confirmTransaction() {\n    return { value: { err: null }, context: { slot: this._slot } };\n  }\n\n  async getBlockTime(_slot: number) {\n    return Math.floor(Date.now() / 1000);\n  }\n\n  async getBalance() {\n    return 2 * LAMPORTS_PER_SOL;\n  }\n}\n\nexport async function buildMatchAccountData(params: {\n  creator: PublicKey;\n  opponent: PublicKey;\n  server: PublicKey;\n  entryAmount: bigint;\n  creatorSide: number;\n  phase: number;\n  commitment: Buffer;\n  algorithmVer: number;\n  targetSlot: bigint;\n  resolveDeadline: bigint;\n  matchId: Buffer;\n}): Promise<Buffer> {\n  return encodeFlipYouMatch({\n    creator: params.creator,\n    opponent: params.opponent,\n    server: params.server,\n    entryAmount: params.entryAmount,\n    creatorSide: params.creatorSide,\n    phase: params.phase,\n    commitment: [...params.commitment],\n    algorithmVer: params.algorithmVer,\n    targetSlot: params.targetSlot,\n    resolveDeadline: params.resolveDeadline,\n    resultHash: new Array(32).fill(0),\n    result: 0,\n    winner: PublicKey.default,\n    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n    matchId: [...params.matchId],\n    bump: 0,\n  });\n}\n\nexport async function seedSettlementProgramAccounts(\n  mockConn: MockConnection,\n  params: {\n    entropyAccount: PublicKey;\n    entropyData: Buffer;\n    treasury: PublicKey;\n  },\n) {\n  mockConn.setAccount(params.entropyAccount, params.entropyData);\n\n  const [configPda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"flipyou_config\")],\n    FLIPYOU_PROGRAM_ID,\n  );\n  mockConn.setAccount(\n    configPda,\n    await buildConfigAccountData(params.treasury),\n    { owner: FLIPYOU_PROGRAM_ID },\n  );\n\n  const [platformConfigPda] = derivePlatformConfigPda();\n  mockConn.setAccount(\n    platformConfigPda,\n    buildPlatformConfigData(params.treasury, 500),\n    { owner: PLATFORM_PROGRAM_ID },\n  );\n}\n\nasync function ensureReferralTables(rawSql: TestSql) {\n  if (referralTablesEnsured) {\n    return;\n  }\n\n  await rawSql`\n    CREATE TABLE IF NOT EXISTS referral_codes (\n      id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n      user_id TEXT NOT NULL UNIQUE,\n      wallet TEXT NOT NULL UNIQUE,\n      code TEXT NOT NULL UNIQUE,\n      created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n      updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n    )\n  `;\n  await rawSql`\n    CREATE TABLE IF NOT EXISTS referral_links (\n      id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n      referrer_user_id TEXT NOT NULL,\n      referee_user_id TEXT NOT NULL UNIQUE,\n      referrer_wallet TEXT NOT NULL,\n      referee_wallet TEXT NOT NULL,\n      created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n    )\n  `;\n  await rawSql`\n    CREATE INDEX IF NOT EXISTS idx_referral_links_referrer\n    ON referral_links (referrer_user_id)\n  `;\n  await rawSql`\n    CREATE TABLE IF NOT EXISTS referral_earnings (\n      id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n      referrer_user_id TEXT NOT NULL,\n      referee_user_id TEXT NOT NULL,\n      referrer_wallet TEXT NOT NULL,\n      referee_wallet TEXT NOT NULL,\n      round_id TEXT NOT NULL,\n      game_type TEXT NOT NULL,\n      wager_lamports BIGINT NOT NULL,\n      fee_lamports BIGINT NOT NULL,\n      referrer_earned_lamports BIGINT NOT NULL,\n      referrer_rate_bps INTEGER NOT NULL,\n      created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n      CONSTRAINT uq_referral_earnings_referee_round\n        UNIQUE (referee_user_id, round_id)\n    )\n  `;\n  await rawSql`\n    CREATE INDEX IF NOT EXISTS idx_referral_earnings_referrer\n    ON referral_earnings (referrer_user_id, created_at)\n  `;\n  await rawSql`\n    CREATE INDEX IF NOT EXISTS idx_referral_earnings_referee\n    ON referral_earnings (referee_user_id, created_at)\n  `;\n  await rawSql`\n    CREATE INDEX IF NOT EXISTS idx_referral_earnings_round_id\n    ON referral_earnings (round_id)\n  `;\n  await rawSql`\n    CREATE TABLE IF NOT EXISTS referral_claims (\n      id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n      user_id TEXT NOT NULL,\n      wallet TEXT NOT NULL,\n      amount_lamports BIGINT NOT NULL,\n      status TEXT NOT NULL DEFAULT 'pending'\n        CHECK (\n          status IN ('pending', 'processing', 'error', 'completed', 'failed')\n        ),\n      retry_count INTEGER NOT NULL DEFAULT 0,\n      tx_signature TEXT,\n      error TEXT,\n      requested_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n      processed_at TIMESTAMPTZ\n    )\n  `;\n  await rawSql`\n    CREATE INDEX IF NOT EXISTS idx_referral_claims_user_id\n    ON referral_claims (user_id, requested_at)\n  `;\n  await rawSql`\n    CREATE INDEX IF NOT EXISTS idx_referral_claims_status\n    ON referral_claims (status)\n    WHERE status IN ('pending', 'processing')\n  `;\n  await rawSql`\n    CREATE UNIQUE INDEX IF NOT EXISTS idx_referral_claims_user_active\n    ON referral_claims (user_id)\n    WHERE status IN ('pending', 'processing', 'error')\n  `;\n  await rawSql`\n    CREATE TABLE IF NOT EXISTS referral_kol_rates (\n      user_id TEXT PRIMARY KEY,\n      wallet TEXT NOT NULL UNIQUE,\n      rate_bps INTEGER NOT NULL,\n      set_by TEXT NOT NULL,\n      created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n      updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n    )\n  `;\n\n  referralTablesEnsured = true;\n}\n\nasync function ensureRewardEconomyTables(rawSql: TestSql) {\n  if (rewardEconomyTablesEnsured) {\n    return;\n  }\n\n  await rawSql`SELECT pg_advisory_lock(401401)`;\n  try {\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS seasons (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        slug TEXT NOT NULL UNIQUE,\n        name TEXT NOT NULL,\n        starts_at TIMESTAMPTZ NOT NULL,\n        ends_at TIMESTAMPTZ,\n        status TEXT NOT NULL CHECK (status IN ('scheduled', 'active', 'ended', 'cancelled')),\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE UNIQUE INDEX IF NOT EXISTS idx_seasons_one_active\n      ON seasons ((status))\n      WHERE status = 'active'\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS point_rate_versions (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        rate_per_usd NUMERIC(18,6) NOT NULL,\n        effective_from TIMESTAMPTZ NOT NULL,\n        label TEXT,\n        created_by TEXT,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS point_balances (\n        user_id TEXT NOT NULL,\n        season_id BIGINT NOT NULL REFERENCES seasons(id),\n        wallet TEXT NOT NULL,\n        balance BIGINT NOT NULL DEFAULT 0,\n        season_earned BIGINT NOT NULL DEFAULT 0,\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        PRIMARY KEY (user_id, season_id)\n      )\n    `;\n    await rawSql`\n      ALTER TABLE player_profiles\n      ADD COLUMN IF NOT EXISTS lifetime_usd NUMERIC(20,6) NOT NULL DEFAULT 0\n    `;\n    await rawSql`\n      ALTER TABLE player_profiles\n      ADD COLUMN IF NOT EXISTS current_season_id BIGINT REFERENCES seasons(id)\n    `;\n    await rawSql`\n      ALTER TABLE player_profiles\n      ADD COLUMN IF NOT EXISTS current_season_usd NUMERIC(20,6) NOT NULL DEFAULT 0\n    `;\n    await rawSql`\n      ALTER TABLE player_profiles\n      ADD COLUMN IF NOT EXISTS cached_lifetime_multiplier NUMERIC(12,6) NOT NULL DEFAULT 1.0\n    `;\n    await rawSql`\n      ALTER TABLE player_profiles\n      ADD COLUMN IF NOT EXISTS cached_season_multiplier NUMERIC(12,6) NOT NULL DEFAULT 1.0\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS multiplier_ladders (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        scope TEXT NOT NULL CHECK (scope IN ('lifetime', 'season')),\n        metric TEXT NOT NULL CHECK (metric IN ('wagered_usd')),\n        season_id BIGINT REFERENCES seasons(id),\n        effective_from TIMESTAMPTZ NOT NULL,\n        label TEXT,\n        created_by TEXT,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS multiplier_ladder_steps (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        ladder_id BIGINT NOT NULL REFERENCES multiplier_ladders(id) ON DELETE CASCADE,\n        level INT NOT NULL,\n        threshold_usd NUMERIC(20,6) NOT NULL,\n        multiplier NUMERIC(12,6) NOT NULL CHECK (multiplier >= 0 AND multiplier <= 10),\n        sort_order INT NOT NULL DEFAULT 0,\n        UNIQUE (ladder_id, threshold_usd),\n        UNIQUE (ladder_id, level)\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS events (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        season_id BIGINT REFERENCES seasons(id),\n        event_type TEXT NOT NULL DEFAULT 'generic',\n        display_name TEXT NOT NULL,\n        starts_at TIMESTAMPTZ NOT NULL,\n        ends_at TIMESTAMPTZ NOT NULL,\n        status TEXT NOT NULL DEFAULT 'scheduled'\n          CHECK (status IN ('scheduled', 'active', 'ended', 'cancelled')),\n        config JSONB NOT NULL DEFAULT '{}',\n        created_by TEXT,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS multiplier_modifiers (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        user_id TEXT,\n        season_id BIGINT NOT NULL REFERENCES seasons(id),\n        source_type TEXT NOT NULL CHECK (source_type IN ('event', 'admin', 'reward')),\n        source_id TEXT NOT NULL,\n        mode TEXT NOT NULL DEFAULT 'set_value'\n          CHECK (mode IN ('multiply', 'set_min', 'set_value')),\n        value NUMERIC(12,6) NOT NULL CHECK (value >= 0 AND value <= 10),\n        priority INT NOT NULL DEFAULT 0,\n        starts_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        ends_at TIMESTAMPTZ,\n        created_by TEXT,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    // Tighten season_id on dev DBs that already have the table from an\n    // earlier run when season_id was nullable.\n    await rawSql`\n      UPDATE multiplier_modifiers\n      SET season_id = (SELECT id FROM seasons WHERE status = 'active' LIMIT 1)\n      WHERE season_id IS NULL\n    `;\n    await rawSql`\n      ALTER TABLE multiplier_modifiers\n      ALTER COLUMN season_id SET NOT NULL\n    `;\n    await rawSql`\n      ALTER TABLE point_grants\n      ADD COLUMN IF NOT EXISTS season_id BIGINT REFERENCES seasons(id)\n    `;\n    await rawSql`\n      ALTER TABLE point_grants\n      ADD COLUMN IF NOT EXISTS effective_multiplier NUMERIC(12,6) NOT NULL DEFAULT 1.0\n    `;\n    await rawSql`\n      ALTER TABLE point_grants\n      ADD COLUMN IF NOT EXISTS point_rate_version_id BIGINT REFERENCES point_rate_versions(id)\n    `;\n    await rawSql`\n      ALTER TABLE point_grants\n      DROP CONSTRAINT IF EXISTS point_grants_source_type_check\n    `;\n    await rawSql`\n      ALTER TABLE point_grants\n      ADD CONSTRAINT point_grants_source_type_check\n      CHECK (source_type IN (\n        'wager',\n        'challenge_completed',\n        'bonus_completed',\n        'crate_points',\n        'admin_adjustment',\n        'reward',\n        'migration_adjustment'\n      ))\n    `;\n\n    rewardEconomyTablesEnsured = true;\n  } finally {\n    await rawSql`SELECT pg_advisory_unlock(401401)`;\n  }\n}\n\nasync function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n  return encodeFlipYouConfig({\n    authority: PublicKey.default,\n    treasury,\n    paused: false,\n    bump: 0,\n  });\n}\n\nfunction buildPlatformConfigData(treasury: PublicKey, feeBps: number): Buffer {\n  const buf = Buffer.alloc(74);\n  PublicKey.default.toBuffer().copy(buf, 8);\n  treasury.toBuffer().copy(buf, 40);\n  buf.writeUInt16LE(feeBps, 72);\n  return buf;\n}\n","numLines":713,"startLine":1,"totalLines":713}}}
