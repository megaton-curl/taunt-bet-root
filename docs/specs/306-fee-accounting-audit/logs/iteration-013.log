{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VVanjncpQP7qfyjkv8pt2x","type":"tool_result","content":"1\t/**\n2\t * Handler for `referral.claim_requested` events.\n3\t *\n4\t * Flow: load claim → verify pending → update to processing → re-verify balance\n5\t * → SOL transfer from server keypair → record tx_signature → completed.\n6\t *\n7\t * Idempotent: skips if claim is already completed or permanently failed.\n8\t * Transient errors set status to 'error' (retryable); only marks 'failed'\n9\t * after MAX_CLAIM_RETRIES attempts.\n10\t */\n11\t\n12\timport {\n13\t  Connection,\n14\t  Keypair,\n15\t  PublicKey,\n16\t  SystemProgram,\n17\t  Transaction,\n18\t} from \"@solana/web3.js\";\n19\timport type { Db } from \"../../db.js\";\n20\timport { logger } from \"../../logger.js\";\n21\t\n22\t/** Max retry attempts before a claim is permanently marked failed. */\n23\tconst MAX_CLAIM_RETRIES = 5;\n24\t\n25\texport interface ClaimHandlerDeps {\n26\t  db: Db;\n27\t  connection: Connection;\n28\t  serverKeypair: Keypair;\n29\t}\n30\t\n31\texport function createClaimHandler(deps: ClaimHandlerDeps) {\n32\t  const { db, connection, serverKeypair } = deps;\n33\t\n34\t  return async (payload: Record<string, unknown>): Promise<void> => {\n35\t    const claimId = payload.claimId as string;\n36\t    const userId = payload.userId as string;\n37\t    const wallet = payload.wallet as string;\n38\t    const amountLamports = payload.amountLamports as string;\n39\t\n40\t    if (!claimId || !userId || !wallet || !amountLamports) {\n41\t      throw new Error(\n42\t        `referral.claim_requested: malformed payload — missing claimId, userId, wallet, or amountLamports`,\n43\t      );\n44\t    }\n45\t\n46\t    // 1. Load claim and check idempotency\n47\t    const claim = await db.getReferralClaim(claimId);\n48\t    if (!claim) {\n49\t      logger.warn(\"referral claim handler: claim not found\", { claimId });\n50\t      return; // no-op — event may reference a deleted/invalid claim\n51\t    }\n52\t\n53\t    if (claim.status === \"completed\") {\n54\t      logger.info(\"referral claim handler: already completed, skipping\", {\n55\t        claimId,\n56\t      });\n57\t      return;\n58\t    }\n59\t\n60\t    if (claim.status === \"failed\") {\n61\t      logger.info(\"referral claim handler: permanently failed, skipping\", {\n62\t        claimId,\n63\t      });\n64\t      return;\n65\t    }\n66\t\n67\t    // 2. Update status to processing (from pending or error). Keep the\n68\t    //    fee_bucket_debits row's status in lockstep so the audit snapshot's\n69\t    //    reserved/spent classification matches the claim lifecycle.\n70\t    await db.updateClaimStatus(claimId, \"processing\");\n71\t    await db.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, \"processing\");\n72\t\n73\t    try {\n74\t      // 3. Re-verify available balance >= claim amount (prevents overpay on concurrent claims)\n75\t      const pendingStr = await db.getPendingBalanceByUserId(userId);\n76\t      const pending = BigInt(pendingStr);\n77\t      const amount = BigInt(amountLamports);\n78\t\n79\t      if (pending < amount) {\n80\t        // Insufficient balance is a permanent failure — no retry will help\n81\t        await db.updateClaimStatus(claimId, \"failed\", {\n82\t          error: `Insufficient balance: pending=${pendingStr}, claim=${amountLamports}`,\n83\t        });\n84\t        await db.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, \"failed\");\n85\t        logger.warn(\"referral claim handler: insufficient balance\", {\n86\t          claimId,\n87\t          userId,\n88\t          wallet,\n89\t          pending: pendingStr,\n90\t          amount: amountLamports,\n91\t        });\n92\t        return;\n93\t      }\n94\t\n95\t      // 4. Execute SOL transfer from server keypair to player wallet\n96\t      const recipient = new PublicKey(wallet);\n97\t      const lamports = Number(amount);\n98\t\n99\t      const { blockhash, lastValidBlockHeight } =\n100\t        await connection.getLatestBlockhash(\"confirmed\");\n101\t\n102\t      const tx = new Transaction({\n103\t        feePayer: serverKeypair.publicKey,\n104\t        blockhash,\n105\t        lastValidBlockHeight,\n106\t      });\n107\t\n108\t      tx.add(\n109\t        SystemProgram.transfer({\n110\t          fromPubkey: serverKeypair.publicKey,\n111\t          toPubkey: recipient,\n112\t          lamports,\n113\t        }),\n114\t      );\n115\t\n116\t      tx.sign(serverKeypair);\n117\t\n118\t      const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n119\t        skipPreflight: false,\n120\t      });\n121\t\n122\t      // Wait for confirmation\n123\t      const confirmation = await connection.confirmTransaction(\n124\t        { signature: txSignature, blockhash, lastValidBlockHeight },\n125\t        \"confirmed\",\n126\t      );\n127\t\n128\t      if (confirmation.value.err) {\n129\t        throw new Error(\n130\t          `Transaction confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n131\t        );\n132\t      }\n133\t\n134\t      // 5. Record success\n135\t      await db.updateClaimStatus(claimId, \"completed\", { txSignature });\n136\t      await db.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, \"completed\");\n137\t      logger.info(\"referral claim handler: transfer completed\", {\n138\t        claimId,\n139\t        userId,\n140\t        wallet,\n141\t        amountLamports,\n142\t        txSignature,\n143\t      });\n144\t    } catch (err) {\n145\t      // 6. Transient failure — increment retry count, mark as 'error' (retryable)\n146\t      //    or 'failed' (permanent) if max retries exceeded.\n147\t      const errorMsg =\n148\t        err instanceof Error ? err.message : \"Unknown transfer error\";\n149\t      const nextRetry = claim.retry_count + 1;\n150\t      const isFinal = nextRetry >= MAX_CLAIM_RETRIES;\n151\t      const nextStatus = isFinal ? \"failed\" : \"error\";\n152\t\n153\t      await db.updateClaimStatus(claimId, nextStatus, {\n154\t        error: errorMsg,\n155\t        incrementRetry: true,\n156\t      });\n157\t      await db.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, nextStatus);\n158\t\n159\t      if (isFinal) {\n160\t        logger.error(\n161\t          \"referral claim handler: max retries exceeded, permanently failed\",\n162\t          {\n163\t            claimId,\n164\t            userId,\n165\t            wallet,\n166\t            amountLamports,\n167\t            retries: nextRetry,\n168\t            error: errorMsg,\n169\t          },\n170\t        );\n171\t        return; // Don't rethrow — claim is permanently dead\n172\t      }\n173\t\n174\t      logger.warn(\n175\t        \"referral claim handler: transient error, will retry\",\n176\t        {\n177\t          claimId,\n178\t          userId,\n179\t          wallet,\n180\t          amountLamports,\n181\t          retry: nextRetry,\n182\t          error: errorMsg,\n183\t        },\n184\t      );\n185\t      // Re-throw so the queue worker retries with exponential backoff\n186\t      throw err;\n187\t    }\n188\t  };\n189\t}\n190\t"}]},"parent_tool_use_id":null,"session_id":"7596eeac-1b71-465b-9302-dc7f7617a7f4","uuid":"69c9bdd1-2f66-4f58-a5bd-68b7a60410d3","timestamp":"2026-05-01T20:35:13.502Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/queue/handlers/referral-claim.ts","content":"/**\n * Handler for `referral.claim_requested` events.\n *\n * Flow: load claim → verify pending → update to processing → re-verify balance\n * → SOL transfer from server keypair → record tx_signature → completed.\n *\n * Idempotent: skips if claim is already completed or permanently failed.\n * Transient errors set status to 'error' (retryable); only marks 'failed'\n * after MAX_CLAIM_RETRIES attempts.\n */\n\nimport {\n  Connection,\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n} from \"@solana/web3.js\";\nimport type { Db } from \"../../db.js\";\nimport { logger } from \"../../logger.js\";\n\n/** Max retry attempts before a claim is permanently marked failed. */\nconst MAX_CLAIM_RETRIES = 5;\n\nexport interface ClaimHandlerDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n}\n\nexport function createClaimHandler(deps: ClaimHandlerDeps) {\n  const { db, connection, serverKeypair } = deps;\n\n  return async (payload: Record<string, unknown>): Promise<void> => {\n    const claimId = payload.claimId as string;\n    const userId = payload.userId as string;\n    const wallet = payload.wallet as string;\n    const amountLamports = payload.amountLamports as string;\n\n    if (!claimId || !userId || !wallet || !amountLamports) {\n      throw new Error(\n        `referral.claim_requested: malformed payload — missing claimId, userId, wallet, or amountLamports`,\n      );\n    }\n\n    // 1. Load claim and check idempotency\n    const claim = await db.getReferralClaim(claimId);\n    if (!claim) {\n      logger.warn(\"referral claim handler: claim not found\", { claimId });\n      return; // no-op — event may reference a deleted/invalid claim\n    }\n\n    if (claim.status === \"completed\") {\n      logger.info(\"referral claim handler: already completed, skipping\", {\n        claimId,\n      });\n      return;\n    }\n\n    if (claim.status === \"failed\") {\n      logger.info(\"referral claim handler: permanently failed, skipping\", {\n        claimId,\n      });\n      return;\n    }\n\n    // 2. Update status to processing (from pending or error). Keep the\n    //    fee_bucket_debits row's status in lockstep so the audit snapshot's\n    //    reserved/spent classification matches the claim lifecycle.\n    await db.updateClaimStatus(claimId, \"processing\");\n    await db.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, \"processing\");\n\n    try {\n      // 3. Re-verify available balance >= claim amount (prevents overpay on concurrent claims)\n      const pendingStr = await db.getPendingBalanceByUserId(userId);\n      const pending = BigInt(pendingStr);\n      const amount = BigInt(amountLamports);\n\n      if (pending < amount) {\n        // Insufficient balance is a permanent failure — no retry will help\n        await db.updateClaimStatus(claimId, \"failed\", {\n          error: `Insufficient balance: pending=${pendingStr}, claim=${amountLamports}`,\n        });\n        await db.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, \"failed\");\n        logger.warn(\"referral claim handler: insufficient balance\", {\n          claimId,\n          userId,\n          wallet,\n          pending: pendingStr,\n          amount: amountLamports,\n        });\n        return;\n      }\n\n      // 4. Execute SOL transfer from server keypair to player wallet\n      const recipient = new PublicKey(wallet);\n      const lamports = Number(amount);\n\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash(\"confirmed\");\n\n      const tx = new Transaction({\n        feePayer: serverKeypair.publicKey,\n        blockhash,\n        lastValidBlockHeight,\n      });\n\n      tx.add(\n        SystemProgram.transfer({\n          fromPubkey: serverKeypair.publicKey,\n          toPubkey: recipient,\n          lamports,\n        }),\n      );\n\n      tx.sign(serverKeypair);\n\n      const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n        skipPreflight: false,\n      });\n\n      // Wait for confirmation\n      const confirmation = await connection.confirmTransaction(\n        { signature: txSignature, blockhash, lastValidBlockHeight },\n        \"confirmed\",\n      );\n\n      if (confirmation.value.err) {\n        throw new Error(\n          `Transaction confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n        );\n      }\n\n      // 5. Record success\n      await db.updateClaimStatus(claimId, \"completed\", { txSignature });\n      await db.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, \"completed\");\n      logger.info(\"referral claim handler: transfer completed\", {\n        claimId,\n        userId,\n        wallet,\n        amountLamports,\n        txSignature,\n      });\n    } catch (err) {\n      // 6. Transient failure — increment retry count, mark as 'error' (retryable)\n      //    or 'failed' (permanent) if max retries exceeded.\n      const errorMsg =\n        err instanceof Error ? err.message : \"Unknown transfer error\";\n      const nextRetry = claim.retry_count + 1;\n      const isFinal = nextRetry >= MAX_CLAIM_RETRIES;\n      const nextStatus = isFinal ? \"failed\" : \"error\";\n\n      await db.updateClaimStatus(claimId, nextStatus, {\n        error: errorMsg,\n        incrementRetry: true,\n      });\n      await db.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, nextStatus);\n\n      if (isFinal) {\n        logger.error(\n          \"referral claim handler: max retries exceeded, permanently failed\",\n          {\n            claimId,\n            userId,\n            wallet,\n            amountLamports,\n            retries: nextRetry,\n            error: errorMsg,\n          },\n        );\n        return; // Don't rethrow — claim is permanently dead\n      }\n\n      logger.warn(\n        \"referral claim handler: transient error, will retry\",\n        {\n          claimId,\n          userId,\n          wallet,\n          amountLamports,\n          retry: nextRetry,\n          error: errorMsg,\n        },\n      );\n      // Re-throw so the queue worker retries with exponential backoff\n      throw err;\n    }\n  };\n}\n","numLines":190,"startLine":1,"totalLines":190}}}
