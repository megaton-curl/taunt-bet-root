{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JxpWffYCRZ7W2bWLKBQMhu","type":"tool_result","content":"1\t/**\n2\t * Admin API routes — reward config, reward pool, campaign/challenge CRUD,\n3\t * and admin-level management.\n4\t *\n5\t * All routes require X-Admin-Key header matching ADMIN_API_KEY env var.\n6\t */\n7\t\n8\timport { Hono } from \"hono\";\n9\timport type { Db } from \"../db.js\";\n10\timport { getActiveSeason, invalidateRewardEconomyCache } from \"../reward-economy.js\";\n11\t\n12\t// ---------------------------------------------------------------------------\n13\t// Known config keys — reject unknown keys with 400\n14\t// ---------------------------------------------------------------------------\n15\t\n16\tconst VALID_CONFIG_KEYS = new Set([\n17\t  \"reward_pool_fee_share\",\n18\t  \"points_crate_drop_rate\",\n19\t  \"sol_crate_drop_rate\",\n20\t  \"sol_crate_pool_pct\",\n21\t  \"sol_crate_min_value\",\n22\t  \"points_crate_min\",\n23\t  \"points_crate_max\",\n24\t  \"daily_challenge_count\",\n25\t  \"weekly_challenge_count\",\n26\t]);\n27\t\n28\t// ---------------------------------------------------------------------------\n29\t// Route factory\n30\t// ---------------------------------------------------------------------------\n31\t\n32\texport interface AdminRoutesDeps {\n33\t  db: Db;\n34\t  adminApiKey: string;\n35\t}\n36\t\n37\texport function createAdminRoutes(deps: AdminRoutesDeps) {\n38\t  const { db, adminApiKey } = deps;\n39\t  const app = new Hono();\n40\t\n41\t  // Admin auth middleware — all routes in this sub-router require X-Admin-Key\n42\t  app.use(\"*\", async (c, next) => {\n43\t    const key = c.req.header(\"X-Admin-Key\");\n44\t    if (!key || key !== adminApiKey) {\n45\t      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n46\t    }\n47\t    await next();\n48\t  });\n49\t\n50\t  // GET /reward-config — all config key-value pairs\n51\t  app.get(\"/reward-config\", async (c) => {\n52\t    const rows = await db.rawSql<{ key: string; value: string; updated_at: string }[]>`\n53\t      SELECT key, value, updated_at FROM reward_config ORDER BY key ASC\n54\t    `;\n55\t    const config: Record<string, { value: string; updatedAt: string }> = {};\n56\t    for (const row of rows) {\n57\t      config[row.key] = { value: row.value, updatedAt: row.updated_at };\n58\t    }\n59\t    return c.json(config);\n60\t  });\n61\t\n62\t  // PUT /reward-config/:key — update a single config value\n63\t  app.put(\"/reward-config/:key\", async (c) => {\n64\t    const key = c.req.param(\"key\");\n65\t\n66\t    if (!VALID_CONFIG_KEYS.has(key)) {\n67\t      return c.json({ error: \"INVALID_KEY\", message: `Unknown config key: ${key}` }, 400);\n68\t    }\n69\t\n70\t    const body = await c.req.json<{ value?: string }>();\n71\t    if (body.value === undefined || body.value === null) {\n72\t      return c.json({ error: \"MISSING_VALUE\", message: \"Request body must include 'value'\" }, 400);\n73\t    }\n74\t\n75\t    await db.rawSql`\n76\t      UPDATE reward_config\n77\t      SET value = ${String(body.value)}, updated_at = now()\n78\t      WHERE key = ${key}\n79\t    `;\n80\t\n81\t    return c.json({ key, value: String(body.value) });\n82\t  });\n83\t\n84\t  // GET /reward-pool — current pool state\n85\t  app.get(\"/reward-pool\", async (c) => {\n86\t    const rows = await db.rawSql<{\n87\t      balance_lamports: string;\n88\t      lifetime_funded: string;\n89\t      lifetime_paid: string;\n90\t      updated_at: string;\n91\t    }[]>`\n92\t      SELECT balance_lamports, lifetime_funded, lifetime_paid, updated_at\n93\t      FROM reward_pool WHERE id = 1\n94\t    `;\n95\t    if (rows.length === 0) {\n96\t      return c.json({ error: \"NOT_FOUND\", message: \"Reward pool not initialized\" }, 500);\n97\t    }\n98\t    const pool = rows[0]!;\n99\t    return c.json({\n100\t      balanceLamports: pool.balance_lamports,"}]},"parent_tool_use_id":null,"session_id":"14342bb0-1390-4a1f-96f8-b2235d0b347d","uuid":"5716b982-c659-4bbf-b4db-d7041e67a7d7","timestamp":"2026-05-01T20:44:53.390Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/admin.ts","content":"/**\n * Admin API routes — reward config, reward pool, campaign/challenge CRUD,\n * and admin-level management.\n *\n * All routes require X-Admin-Key header matching ADMIN_API_KEY env var.\n */\n\nimport { Hono } from \"hono\";\nimport type { Db } from \"../db.js\";\nimport { getActiveSeason, invalidateRewardEconomyCache } from \"../reward-economy.js\";\n\n// ---------------------------------------------------------------------------\n// Known config keys — reject unknown keys with 400\n// ---------------------------------------------------------------------------\n\nconst VALID_CONFIG_KEYS = new Set([\n  \"reward_pool_fee_share\",\n  \"points_crate_drop_rate\",\n  \"sol_crate_drop_rate\",\n  \"sol_crate_pool_pct\",\n  \"sol_crate_min_value\",\n  \"points_crate_min\",\n  \"points_crate_max\",\n  \"daily_challenge_count\",\n  \"weekly_challenge_count\",\n]);\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport interface AdminRoutesDeps {\n  db: Db;\n  adminApiKey: string;\n}\n\nexport function createAdminRoutes(deps: AdminRoutesDeps) {\n  const { db, adminApiKey } = deps;\n  const app = new Hono();\n\n  // Admin auth middleware — all routes in this sub-router require X-Admin-Key\n  app.use(\"*\", async (c, next) => {\n    const key = c.req.header(\"X-Admin-Key\");\n    if (!key || key !== adminApiKey) {\n      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n    }\n    await next();\n  });\n\n  // GET /reward-config — all config key-value pairs\n  app.get(\"/reward-config\", async (c) => {\n    const rows = await db.rawSql<{ key: string; value: string; updated_at: string }[]>`\n      SELECT key, value, updated_at FROM reward_config ORDER BY key ASC\n    `;\n    const config: Record<string, { value: string; updatedAt: string }> = {};\n    for (const row of rows) {\n      config[row.key] = { value: row.value, updatedAt: row.updated_at };\n    }\n    return c.json(config);\n  });\n\n  // PUT /reward-config/:key — update a single config value\n  app.put(\"/reward-config/:key\", async (c) => {\n    const key = c.req.param(\"key\");\n\n    if (!VALID_CONFIG_KEYS.has(key)) {\n      return c.json({ error: \"INVALID_KEY\", message: `Unknown config key: ${key}` }, 400);\n    }\n\n    const body = await c.req.json<{ value?: string }>();\n    if (body.value === undefined || body.value === null) {\n      return c.json({ error: \"MISSING_VALUE\", message: \"Request body must include 'value'\" }, 400);\n    }\n\n    await db.rawSql`\n      UPDATE reward_config\n      SET value = ${String(body.value)}, updated_at = now()\n      WHERE key = ${key}\n    `;\n\n    return c.json({ key, value: String(body.value) });\n  });\n\n  // GET /reward-pool — current pool state\n  app.get(\"/reward-pool\", async (c) => {\n    const rows = await db.rawSql<{\n      balance_lamports: string;\n      lifetime_funded: string;\n      lifetime_paid: string;\n      updated_at: string;\n    }[]>`\n      SELECT balance_lamports, lifetime_funded, lifetime_paid, updated_at\n      FROM reward_pool WHERE id = 1\n    `;\n    if (rows.length === 0) {\n      return c.json({ error: \"NOT_FOUND\", message: \"Reward pool not initialized\" }, 500);\n    }\n    const pool = rows[0]!;\n    return c.json({\n      balanceLamports: pool.balance_lamports,","numLines":100,"startLine":1,"totalLines":690}}}
