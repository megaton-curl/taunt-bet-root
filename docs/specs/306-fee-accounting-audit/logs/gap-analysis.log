{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R9rfNSj1fm8WYbQ3qfdBh3","type":"tool_result","content":"1\t/**\n2\t * Fee accounting unit + DB constraint coverage.\n3\t *\n4\t * - `calculateFeeAllocation`: pure FR-2 split (referral floor → promotions\n5\t *   floor on remainder × 20% → profit absorbs dust).\n6\t * - `fee_allocation_events` CHECK constraint: the DB rejects rows whose\n7\t *   referral + promotions + profit components do not sum to `fee_lamports`.\n8\t *\n9\t * The DB-backed test mirrors the safety net the audit snapshot relies on —\n10\t * if a future refactor of `insertFeeAllocation` or migration weakens the\n11\t * constraint, this test fails before the snapshot ever sees a bad row.\n12\t */\n13\t\n14\timport { describe, it, expect, afterAll } from \"vitest\";\n15\timport postgres from \"postgres\";\n16\timport { calculateFeeAllocation } from \"../db/fee-accounting.js\";\n17\t\n18\tconst DATABASE_URL =\n19\t  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n20\t\n21\tfunction makeSql() {\n22\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n23\t  return postgres({\n24\t    host: \"/var/run/postgresql\",\n25\t    user: \"vscode\",\n26\t    database: \"taunt_bet_dev\",\n27\t  });\n28\t}\n29\t\n30\t// ---------------------------------------------------------------------------\n31\t// calculateFeeAllocation — pure FR-2 split\n32\t// ---------------------------------------------------------------------------\n33\t\n34\tdescribe(\"calculateFeeAllocation\", () => {\n35\t  it(\"0 bps referral: referral=0, promotions=20% floor, profit=remainder\", () => {\n36\t    const split = calculateFeeAllocation(1000, 0);\n37\t    expect(split.referralLamports).toBe(0);\n38\t    expect(split.promotionsLamports).toBe(200);\n39\t    expect(split.profitLamports).toBe(800);\n40\t  });\n41\t\n42\t  it(\"10000 bps (100%) referral: referral=fee, promotions=0, profit=0\", () => {\n43\t    const split = calculateFeeAllocation(1000, 10000);\n44\t    expect(split.referralLamports).toBe(1000);\n45\t    expect(split.promotionsLamports).toBe(0);\n46\t    expect(split.profitLamports).toBe(0);\n47\t  });\n48\t\n49\t  it(\"mid-range bps splits cleanly when math is integer\", () => {\n50\t    // 500 referral, 100 promotions (20% of 500 remaining), 400 profit.\n51\t    const split = calculateFeeAllocation(1000, 5000);\n52\t    expect(split.referralLamports).toBe(500);\n53\t    expect(split.promotionsLamports).toBe(100);\n54\t    expect(split.profitLamports).toBe(400);\n55\t  });\n56\t\n57\t  it(\"dust from referral floor lands in profit, never in promotions\", () => {\n58\t    // fee=7, bps=5000 → referral=floor(3.5)=3, post=4, promo=floor(0.8)=0, profit=4.\n59\t    const split = calculateFeeAllocation(7, 5000);\n60\t    expect(split.referralLamports).toBe(3);"}]},"parent_tool_use_id":null,"session_id":"14342bb0-1390-4a1f-96f8-b2235d0b347d","uuid":"3fbf8187-8815-4d96-9a29-2d7771f7d1d9","timestamp":"2026-05-01T20:45:00.359Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/fee-accounting.test.ts","content":"/**\n * Fee accounting unit + DB constraint coverage.\n *\n * - `calculateFeeAllocation`: pure FR-2 split (referral floor → promotions\n *   floor on remainder × 20% → profit absorbs dust).\n * - `fee_allocation_events` CHECK constraint: the DB rejects rows whose\n *   referral + promotions + profit components do not sum to `fee_lamports`.\n *\n * The DB-backed test mirrors the safety net the audit snapshot relies on —\n * if a future refactor of `insertFeeAllocation` or migration weakens the\n * constraint, this test fails before the snapshot ever sees a bad row.\n */\n\nimport { describe, it, expect, afterAll } from \"vitest\";\nimport postgres from \"postgres\";\nimport { calculateFeeAllocation } from \"../db/fee-accounting.js\";\n\nconst DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"taunt_bet_dev\",\n  });\n}\n\n// ---------------------------------------------------------------------------\n// calculateFeeAllocation — pure FR-2 split\n// ---------------------------------------------------------------------------\n\ndescribe(\"calculateFeeAllocation\", () => {\n  it(\"0 bps referral: referral=0, promotions=20% floor, profit=remainder\", () => {\n    const split = calculateFeeAllocation(1000, 0);\n    expect(split.referralLamports).toBe(0);\n    expect(split.promotionsLamports).toBe(200);\n    expect(split.profitLamports).toBe(800);\n  });\n\n  it(\"10000 bps (100%) referral: referral=fee, promotions=0, profit=0\", () => {\n    const split = calculateFeeAllocation(1000, 10000);\n    expect(split.referralLamports).toBe(1000);\n    expect(split.promotionsLamports).toBe(0);\n    expect(split.profitLamports).toBe(0);\n  });\n\n  it(\"mid-range bps splits cleanly when math is integer\", () => {\n    // 500 referral, 100 promotions (20% of 500 remaining), 400 profit.\n    const split = calculateFeeAllocation(1000, 5000);\n    expect(split.referralLamports).toBe(500);\n    expect(split.promotionsLamports).toBe(100);\n    expect(split.profitLamports).toBe(400);\n  });\n\n  it(\"dust from referral floor lands in profit, never in promotions\", () => {\n    // fee=7, bps=5000 → referral=floor(3.5)=3, post=4, promo=floor(0.8)=0, profit=4.\n    const split = calculateFeeAllocation(7, 5000);\n    expect(split.referralLamports).toBe(3);","numLines":60,"startLine":1,"totalLines":203}}}
