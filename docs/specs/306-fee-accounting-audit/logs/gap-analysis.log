inClaimLamports} lamports (${(config.referralMinClaimLamports / 1e9).toFixed(2)} SOL)`,\n698\t          { retryable: false },\n699\t        );\n700\t      }\n701\t\n702\t      // Global referral bucket cap — defends against ledger drift / a per-user\n703\t      // balance that the bucket as a whole cannot fund.\n704\t      const globalAvailable = BigInt(await db.getReferralBucketAvailable());\n705\t      if (userAvailable > globalAvailable) {\n706\t        return err(\n707\t          c,\n708\t          422,\n709\t          API_ERROR_CODES.PRECONDITION_FAILED,\n710\t          \"Referral bucket has insufficient capacity for this claim\",\n711\t          { retryable: false },\n712\t        );\n713\t      }\n714\t\n715\t      // Atomically insert claim row + bucket debit + emit queue event\n716\t      const claim = await db.withTransaction(async (txDb) => {\n717\t        const claimRow = await txDb.insertReferralClaim(\n718\t          userId,\n719\t          wallet,\n720\t          userAvailableStr,\n721\t        );\n722\t\n723\t        await txDb.insertFeeBucketDebit({\n724\t          bucket: \"referral\",\n725\t          debitType: \"claim\",\n726\t          sourceId: claimRow.id,\n727\t          userId,\n728\t          wallet,\n729\t          amountLamports: userAvailableStr,\n730\t          status: \"pending\",\n731\t        });\n732\t\n733\t        await emitEvent(\n734\t          txDb.rawSql as postgres.Sql,\n735\t          EventTypes.REFERRAL_CLAIM_REQUESTED,\n736\t          {\n737\t            claimId: claimRow.id,\n738\t            userId: claimRow.user_id,\n739\t            wallet: claimRow.wallet,\n740\t            amountLamports: claimRow.amount_lamports,\n741\t            requestedAt: new Date().toISOString(),\n742\t          },\n743\t        );\n744\t\n745\t        return claimRow;\n746\t      });\n747\t\n748\t      logger.info(\"Referral claim requested\", {\n749\t        userId,"}]},"parent_tool_use_id":null,"session_id":"14342bb0-1390-4a1f-96f8-b2235d0b