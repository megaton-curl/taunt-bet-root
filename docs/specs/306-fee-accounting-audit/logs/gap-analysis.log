{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014obxzSaQBoyL7SLNE62MKm","type":"tool_result","content":"1\t/**\n2\t * Handler for `referral.claim_requested` events.\n3\t *\n4\t * Flow: load claim → verify pending → update to processing → re-verify balance\n5\t * → SOL transfer from server keypair → record tx_signature → completed.\n6\t *\n7\t * Idempotent: skips if claim is already completed or permanently failed.\n8\t * Transient errors set status to 'error' (retryable); only marks 'failed'\n9\t * after MAX_CLAIM_RETRIES attempts.\n10\t */\n11\t\n12\timport {\n13\t  Connection,\n14\t  Keypair,\n15\t  PublicKey,\n16\t  SystemProgram,\n17\t  Transaction,\n18\t} from \"@solana/web3.js\";\n19\timport type { Db } from \"../../db.js\";\n20\timport { logger } from \"../../logger.js\";\n21\t\n22\t/** Max retry attempts before a claim is permanently marked failed. */\n23\tconst MAX_CLAIM_RETRIES = 5;\n24\t\n25\texport interface ClaimHandlerDeps {\n26\t  db: Db;\n27\t  connection: Connection;\n28\t  serverKeypair: Keypair;\n29\t}\n30\t\n31\texport function createClaimHandler(deps: ClaimHandlerDeps) {\n32\t  const { db, connection, serverKeypair } = deps;\n33\t\n34\t  return async (payload: Record<string, unknown>): Promise<void> => {\n35\t    const claimId = payload.claimId as string;\n36\t    const userId = payload.userId as string;\n37\t    const wallet = payload.wallet as string;\n38\t    const amountLamports = payload.amountLamports as string;\n39\t\n40\t    if (!claimId || !userId || !wallet || !amountLamports) {\n41\t      throw new Error(\n42\t        `referral.claim_requested: malformed payload — missing claimId, userId, wallet, or amountLamports`,\n43\t      );\n44\t    }\n45\t\n46\t    // 1. Load claim and check idempotency\n47\t    const claim = await db.getReferralClaim(claimId);\n48\t    if (!claim) {\n49\t      logger.warn(\"referral claim handler: claim not found\", { claimId });\n50\t      return; // no-op — event may reference a deleted/invalid claim\n51\t    }\n52\t\n53\t    if (claim.status === \"completed\") {\n54\t      logger.info(\"referral claim handler: already completed, skipping\", {\n55\t        claimId,\n56\t      });\n57\t      return;\n58\t    }\n59\t\n60\t    if (claim.status === \"failed\") {\n61\t      logger.info(\"referral claim handler: permanently failed, skipping\", {\n62\t        claimId,\n63\t      });\n64\t      return;\n65\t    }\n66\t\n67\t    // 2. Update status to processing (from pending or error). Keep the\n68\t    //    fee_bucket_debits row's status in lockstep so the audit snapshot's\n69\t    //    reserved/spent classification matches the claim lifecycle. Atomic so\n70\t    //    a crash between writes can't drift the two records.\n71\t    await db.withTransaction(async (txDb) => {\n72\t      await txDb.updateClaimStatus(claimId, \"processing\");\n73\t      await txDb.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, \"processing\");\n74\t    });\n75\t\n76\t    try {\n77\t      // 3. Re-verify available balance >= claim amount (prevents overpay on concurrent claims)\n78\t      const pendingStr = await db.getPendingBalanceByUserId(userId);\n79\t      const pending = BigInt(pendingStr);\n80\t      const amount = BigInt(amountLamports);\n81\t\n82\t      if (pending < amount) {\n83\t        // Insufficient balance is a permanent failure — no retry will help.\n84\t        // Wrap the dual update so the audit snapshot can never see a `failed`\n85\t        // claim alongside a `processing` debit (which would phantom-debit the\n86\t        // referral bucket).\n87\t        await db.withTransaction(async (txDb) => {\n88\t          await txDb.updateClaimStatus(claimId, \"failed\", {\n89\t            error: `Insufficient balance: pending=${pendingStr}, claim=${amountLamports}`,\n90\t          });\n91\t          await txDb.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, \"failed\");\n92\t        });\n93\t        logger.warn(\"referral claim handler: insufficient balance\", {\n94\t          claimId,\n95\t          userId,\n96\t          wallet,\n97\t          pending: pendingStr,\n98\t          amount: amountLamports,\n99\t        });\n100\t        return;\n101\t      }\n102\t\n103\t      // 4. Execute SOL transfer from server keypair to player wallet\n104\t      const recipient = new PublicKey(wallet);\n105\t      const lamports = Number(amount);\n106\t\n107\t      const { blockhash, lastValidBlockHeight } =\n108\t        await connection.getLatestBlockhash(\"confirmed\");\n109\t\n110\t      const tx = new Transaction({\n111\t        feePayer: serverKeypair.publicKey,\n112\t        blockhash,\n113\t        lastValidBlockHeight,\n114\t      });\n115\t\n116\t      tx.add(\n117\t        SystemProgram.transfer({\n118\t          fromPubkey: serverKeypair.publicKey,\n119\t          toPubkey: recipient,\n120\t          lamports,\n121\t        }),\n122\t      );\n123\t\n124\t      tx.sign(serverKeypair);\n125\t\n126\t      const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n127\t        skipPreflight: false,\n128\t      });\n129\t\n130\t      // Wait for confirmation\n131\t      const confirmation = await connection.confirmTransaction(\n132\t        { signature: txSignature, blockhash, lastValidBlockHeight },\n133\t        \"confirmed\",\n134\t      );\n135\t\n136\t      if (confirmation.value.err) {\n137\t        throw new Error(\n138\t          `Transaction confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n139\t        );\n140\t      }\n141\t\n142\t      // 5. Record success — atomic so the debit can't be left at `processing`\n143\t      //    after the claim moves to `completed`.\n144\t      await db.withTransaction(async (txDb) => {\n145\t        await txDb.updateClaimStatus(claimId, \"completed\", { txSignature });\n146\t        await txDb.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, \"completed\");\n147\t      });\n148\t      logger.info(\"referral claim handler: transfer completed\", {\n149\t        claimId,\n150\t        userId,\n151\t        wallet,\n152\t        amountLamports,\n153\t        txSignature,\n154\t      });\n155\t    } catch (err) {\n156\t      // 6. Transient failure — increment retry count, mark as 'error' (retryable)\n157\t      //    or 'failed' (permanent) if max retries exceeded.\n158\t      const errorMsg =\n159\t        err instanceof Error ? err.message : \"Unknown transfer error\";\n160\t      const nextRetry = claim.retry_count + 1;\n161\t      const isFinal = nextRetry >= MAX_CLAIM_RETRIES;\n162\t      const nextStatus = isFinal ? \"failed\" : \"error\";\n163\t\n164\t      await db.withTransaction(async (txDb) => {\n165\t        await txDb.updateClaimStatus(claimId, nextStatus, {\n166\t          error: errorMsg,\n167\t          incrementRetry: true,\n168\t        });\n169\t        await txDb.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, nextStatus);\n170\t      });\n171\t\n172\t      if (isFinal) {\n173\t        logger.error(\n174\t          \"referral claim handler: max retries exceeded, permanently failed\",\n175\t          {\n176\t            claimId,\n177\t            userId,\n178\t            wallet,\n179\t            amountLamports,\n180\t            retries: nextRetry,\n181\t            error: errorMsg,\n182\t          },\n183\t        );\n184\t        return; // Don't rethrow — claim is permanently dead\n185\t      }\n186\t\n187\t      logger.warn(\n188\t        \"referral claim handler: transient error, will retry\",\n189\t        {\n190\t          claimId,\n191\t          userId,\n192\t          wallet,\n193\t          amountLamports,\n194\t          retry: nextRetry,\n195\t          error: errorMsg,\n196\t        },\n197\t      );\n198\t      // Re-throw so the queue worker retries with exponential backoff\n199\t      throw err;\n200\t    }\n201\t  };\n202\t}\n203\t"}]},"parent_tool_use_id":null,"session_id":"14342bb0-1390-4a1f-96f8-b2235d0b347d","uuid":"64b69862-af6d-4299-8587-06bea19d09ad","timestamp":"2026-05-01T20:45:24.545Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/queue/handlers/referral-claim.ts","content":"/**\n * Handler for `referral.claim_requested` events.\n *\n * Flow: load claim → verify pending → update to processing → re-verify balance\n * → SOL transfer from server keypair → record tx_signature → completed.\n *\n * Idempotent: skips if claim is already completed or permanently failed.\n * Transient errors set status to 'error' (retryable); only marks 'failed'\n * after MAX_CLAIM_RETRIES attempts.\n */\n\nimport {\n  Connection,\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n} from \"@solana/web3.js\";\nimport type { Db } from \"../../db.js\";\nimport { logger } from \"../../logger.js\";\n\n/** Max retry attempts before a claim is permanently marked failed. */\nconst MAX_CLAIM_RETRIES = 5;\n\nexport interface ClaimHandlerDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n}\n\nexport function createClaimHandler(deps: ClaimHandlerDeps) {\n  const { db, connection, serverKeypair } = deps;\n\n  return async (payload: Record<string, unknown>): Promise<void> => {\n    const claimId = payload.claimId as string;\n    const userId = payload.userId as string;\n    const wallet = payload.wallet as string;\n    const amountLamports = payload.amountLamports as string;\n\n    if (!claimId || !userId || !wallet || !amountLamports) {\n      throw new Error(\n        `referral.claim_requested: malformed payload — missing claimId, userId, wallet, or amountLamports`,\n      );\n    }\n\n    // 1. Load claim and check idempotency\n    const claim = await db.getReferralClaim(claimId);\n    if (!claim) {\n      logger.warn(\"referral claim handler: claim not found\", { claimId });\n      return; // no-op — event may reference a deleted/invalid claim\n    }\n\n    if (claim.status === \"completed\") {\n      logger.info(\"referral claim handler: already completed, skipping\", {\n        claimId,\n      });\n      return;\n    }\n\n    if (claim.status === \"failed\") {\n      logger.info(\"referral claim handler: permanently failed, skipping\", {\n        claimId,\n      });\n      return;\n    }\n\n    // 2. Update status to processing (from pending or error). Keep the\n    //    fee_bucket_debits row's status in lockstep so the audit snapshot's\n    //    reserved/spent classification matches the claim lifecycle. Atomic so\n    //    a crash between writes can't drift the two records.\n    await db.withTransaction(async (txDb) => {\n      await txDb.updateClaimStatus(claimId, \"processing\");\n      await txDb.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, \"processing\");\n    });\n\n    try {\n      // 3. Re-verify available balance >= claim amount (prevents overpay on concurrent claims)\n      const pendingStr = await db.getPendingBalanceByUserId(userId);\n      const pending = BigInt(pendingStr);\n      const amount = BigInt(amountLamports);\n\n      if (pending < amount) {\n        // Insufficient balance is a permanent failure — no retry will help.\n        // Wrap the dual update so the audit snapshot can never see a `failed`\n        // claim alongside a `processing` debit (which would phantom-debit the\n        // referral bucket).\n        await db.withTransaction(async (txDb) => {\n          await txDb.updateClaimStatus(claimId, \"failed\", {\n            error: `Insufficient balance: pending=${pendingStr}, claim=${amountLamports}`,\n          });\n          await txDb.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, \"failed\");\n        });\n        logger.warn(\"referral claim handler: insufficient balance\", {\n          claimId,\n          userId,\n          wallet,\n          pending: pendingStr,\n          amount: amountLamports,\n        });\n        return;\n      }\n\n      // 4. Execute SOL transfer from server keypair to player wallet\n      const recipient = new PublicKey(wallet);\n      const lamports = Number(amount);\n\n      const { blockhash, lastValidBlockHeight } =\n        await connection.getLatestBlockhash(\"confirmed\");\n\n      const tx = new Transaction({\n        feePayer: serverKeypair.publicKey,\n        blockhash,\n        lastValidBlockHeight,\n      });\n\n      tx.add(\n        SystemProgram.transfer({\n          fromPubkey: serverKeypair.publicKey,\n          toPubkey: recipient,\n          lamports,\n        }),\n      );\n\n      tx.sign(serverKeypair);\n\n      const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n        skipPreflight: false,\n      });\n\n      // Wait for confirmation\n      const confirmation = await connection.confirmTransaction(\n        { signature: txSignature, blockhash, lastValidBlockHeight },\n        \"confirmed\",\n      );\n\n      if (confirmation.value.err) {\n        throw new Error(\n          `Transaction confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n        );\n      }\n\n      // 5. Record success — atomic so the debit can't be left at `processing`\n      //    after the claim moves to `completed`.\n      await db.withTransaction(async (txDb) => {\n        await txDb.updateClaimStatus(claimId, \"completed\", { txSignature });\n        await txDb.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, \"completed\");\n      });\n      logger.info(\"referral claim handler: transfer completed\", {\n        claimId,\n        userId,\n        wallet,\n        amountLamports,\n        txSignature,\n      });\n    } catch (err) {\n      // 6. Transient failure — increment retry count, mark as 'error' (retryable)\n      //    or 'failed' (permanent) if max retries exceeded.\n      const errorMsg =\n        err instanceof Error ? err.message : \"Unknown transfer error\";\n      const nextRetry = claim.retry_count + 1;\n      const isFinal = nextRetry >= MAX_CLAIM_RETRIES;\n      const nextStatus = isFinal ? \"failed\" : \"error\";\n\n      await db.withTransaction(async (txDb) => {\n        await txDb.updateClaimStatus(claimId, nextStatus, {\n          error: errorMsg,\n          incrementRetry: true,\n        });\n        await txDb.updateFeeBucketDebitStatus(\"referral\", \"claim\", claimId, nextStatus);\n      });\n\n      if (isFinal) {\n        logger.error(\n          \"referral claim handler: max retries exceeded, permanently failed\",\n          {\n            claimId,\n            userId,\n            wallet,\n            amountLamports,\n            retries: nextRetry,\n            error: errorMsg,\n          },\n        );\n        return; // Don't rethrow — claim is permanently dead\n      }\n\n      logger.warn(\n        \"referral claim handler: transient error, will retry\",\n        {\n          claimId,\n          userId,\n          wallet,\n          amountLamports,\n          retry: nextRetry,\n          error: errorMsg,\n        },\n      );\n      // Re-throw so the queue worker retries with exponential backoff\n      throw err;\n    }\n  };\n}\n","numLines":203,"startLine":1,"totalLines":203}}}
