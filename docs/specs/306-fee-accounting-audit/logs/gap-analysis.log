{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TyEHUTwHk1zzfcioYAXX4N","type":"tool_result","content":"1\timport { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";\n2\timport { Hono } from \"hono\";\n3\timport { Keypair, PublicKey } from \"@solana/web3.js\";\n4\timport type { Connection } from \"@solana/web3.js\";\n5\timport type { Db } from \"../db.js\";\n6\timport { createFlipYouRoutes } from \"../routes/create.js\";\n7\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n8\timport { createSettlementWorker } from \"../worker/settlement.js\";\n9\timport { settleMatch, recordReferralEarnings } from \"../worker/settle-tx.js\";\n10\timport { createRetrySettler } from \"../worker/retry.js\";\n11\timport { FLIPYOU_PROGRAM_ID } from \"../fairness.js\";\n12\timport { resetPlatformConfigCache } from \"../platform-config.js\";\n13\timport { encodeCloseCallRound } from \"../worker/account-decoder.js\";\n14\timport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n15\timport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\n16\timport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\n17\timport {\n18\t  AMOUNT_LAMPORTS,\n19\t  AMOUNT_LAMPORTS_BIGINT,\n20\t  JWT_SECRET,\n21\t  PHASE_LOCKED,\n22\t  SIDE_HEADS,\n23\t  type IntegrationDbContext,\n24\t  type TestSql,\n25\t  buildMatchAccountData,\n26\t  closeIntegrationDb,\n27\t  makeJwt,\n28\t  MockConnection,\n29\t  openIntegrationDb,\n30\t  resetIntegrationState,\n31\t  seedSettlementProgramAccounts,\n32\t} from \"./integration-test-helpers.js\";\n33\t\n34\t// Platform config seeded by `seedSettlementProgramAccounts` is fee_bps = 500.\n35\tconst SETTLED_FEE_BPS = 500;\n36\t// recordReferralEarnings/settle deps default to 1000 bps for referrers.\n37\tconst REFERRER_RATE_BPS = 1000;\n38\t\n39\tinterface FeeAllocationRow {\n40\t  source_type: string;\n41\t  source_id: string;\n42\t  game_type: string;\n43\t  wallet: string;\n44\t  user_id: string | null;\n45\t  wager_lamports: string;\n46\t  fee_lamports: string;\n47\t  referrer_user_id: string | null;\n48\t  referral_rate_bps: number;\n49\t  referral_lamports: string;\n50\t  promotions_lamports: string;\n51\t  profit_lamports: string;\n52\t}\n53\t\n54\tfunction expectComponentsSumToFee(row: FeeAllocationRow) {\n55\t  const sum =\n56\t    BigInt(row.referral_lamports) +\n57\t    BigInt(row.promotions_lamports) +\n58\t    BigInt(row.profit_lamports);\n59\t  expect(sum.toString()).toBe(String(row.fee_lamports));\n60\t}\n61\t\n62\tdescribe(\"Fee allocation integration: settlement writes ledger rows for all three games\", () => {\n63\t  let ctx: IntegrationDbContext;\n64\t  let rawSql: TestSql;\n65\t  let db: Db;\n66\t  let mockConn: MockConnection;\n67\t  let app: Hono;\n68\t\n69\t  const serverKeypair = Keypair.generate();\n70\t  const creatorKeypair = Keypair.generate();\n71\t  const opponentKeypair = Keypair.generate();\n72\t  const treasuryKeypair = Keypair.generate();\n73\t  const entropyKeypair = Keypair.generate();\n74\t  const entropyAccount = entropyKeypair.publicKey;\n75\t\n76\t  const entropyData = Buffer.alloc(32);\n77\t  entropyData[0] = 0xab;\n78\t  entropyData[1] = 0xcd;\n79\t  entropyData[15] = 0x42;\n80\t\n81\t  beforeAll(async () => {\n82\t    ctx = await openIntegrationDb();\n83\t    rawSql = ctx.rawSql;\n84\t    db = ctx.db;\n85\t  });\n86\t\n87\t  afterAll(async () => {\n88\t    await closeIntegrationDb(ctx);\n89\t  });\n90\t\n91\t  beforeEach(async () => {\n92\t    await resetIntegrationState(rawSql);\n93\t    resetPlatformConfigCache();\n94\t\n95\t    mockConn = new MockConnection();\n96\t    await seedSettlementProgramAccounts(mockConn, {\n97\t      entropyAccount,\n98\t      entropyData,\n99\t      treasury: treasuryKeypair.publicKey,\n100\t    });\n101\t\n102\t    app = new Hono();\n103\t    app.use(\"/flipyou/*\", createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }));\n104\t    app.route(\n105\t      \"/flipyou\",\n106\t      createFlipYouRoutes({\n107\t        db,\n108\t        connection: mockConn as unknown as Connection,\n109\t        serverKeypair,\n110\t      }),\n111\t    );\n112\t  });\n113\t\n114\t  it(\"FlipYou settle writes one allocation row per player — referred + non-referred — with components summing to fee\", async () => {\n115\t    const creatorWallet = creatorKeypair.publicKey.toBase58();\n116\t    const opponentWallet = opponentKeypair.publicKey.toBase58();\n117\t    const referrerKeypair = Keypair.generate();\n118\t    const referrerWallet = referrerKeypair.publicKey.toBase58();\n119\t\n120\t    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n121\t    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n122\t    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n123\t\n124\t    await db.insertReferralCode(\n125\t      referrerProfile.user_id,\n126\t      referrerWallet,\n127\t      \"alloc-test-ref\",\n128\t    );\n129\t    await db.insertReferralLink({\n130\t      referrerUserId: referrerProfile.user_id,\n131\t      refereeUserId: opponentProfile.user_id,\n132\t      referrerWallet,\n133\t      refereeWallet: opponentWallet,\n134\t    });\n135\t    // Note: creator has no referral link → non-referred allocation row expected.\n136\t\n137\t    const token = await makeJwt(creatorWallet, creatorProfile.user_id);\n138\t    const createRes = await app.request(\"/flipyou/create\", {\n139\t      method: \"POST\",\n140\t      headers: {\n141\t        \"Content-Type\": \"application/json\",\n142\t        Authorization: `Bearer ${token}`,\n143\t      },\n144\t      body: JSON.stringify({\n145\t        wallet: creatorWallet,\n146\t        amountLamports: AMOUNT_LAMPORTS,\n147\t        side: SIDE_HEADS,\n148\t      }),\n149\t    });\n150\t    expect(createRes.status).toBe(200);\n151\t    const createBody = (await createRes.json()) as {\n152\t      ok: true;\n153\t      data: { matchPda: string; matchId: string; commitment: string };\n154\t    };\n155\t    const createJson = createBody.data;\n156\t\n157\t    const matchAccountData = await buildMatchAccountData({\n158\t      creator: creatorKeypair.publicKey,\n159\t      opponent: opponentKeypair.publicKey,\n160\t      server: serverKeypair.publicKey,\n161\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n162\t      creatorSide: SIDE_HEADS,\n163\t      phase: PHASE_LOCKED,\n164\t      commitment: Buffer.from(createJson.commitment, \"hex\"),\n165\t      algorithmVer: 1,\n166\t      targetSlot: 150n,\n167\t      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n168\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n169\t    });\n170\t    mockConn.setAccount(new PublicKey(createJson.matchPda), matchAccountData, {\n171\t      owner: FLIPYOU_PROGRAM_ID,\n172\t    });\n173\t    mockConn.slot = 200;\n174\t\n175\t    let settlePromise: Promise<void> | null = null;\n176\t    const retrySettler = createRetrySettler({\n177\t      db,\n178\t      connection: mockConn as unknown as Connection,\n179\t      settleRound: (pda) =>\n180\t        settleMatch(\n181\t          {\n182\t            db,\n183\t            connection: mockConn as unknown as Connection,\n184\t            serverKeypair,\n185\t            entropyAccount,\n186\t            referralDefaultRateBps: REFERRER_RATE_BPS,\n187\t          },\n188\t          pda,\n189\t        ),\n190\t    });\n191\t    const worker = createSettlementWorker({\n192\t      db,\n193\t      connection: mockConn as unknown as Connection,\n194\t      serverKey: serverKeypair.publicKey,\n195\t      pollIntervalMs: 60_000,\n196\t      onSettleReady: (pda) => {\n197\t        settlePromise = retrySettler.attemptSettle(pda);\n198\t        return settlePromise;\n199\t      },\n200\t    });\n201\t\n202\t    await worker.poll();\n203\t    if (settlePromise) await settlePromise;\n204\t\n205\t    const rows = await rawSql<FeeAllocationRow[]>`\n206\t      SELECT * FROM fee_allocation_events\n207\t      WHERE source_type = 'flipyou' AND source_id = ${createJson.matchId}\n208\t      ORDER BY wallet\n209\t    `;\n210\t    expect(rows.length).toBe(2);\n211\t\n212\t    const creatorRow = rows.find((r) => r.wallet === creatorWallet)!;\n213\t    const opponentRow = rows.find((r) => r.wallet === opponentWallet)!;\n214\t    expect(creatorRow).toBeDefined();\n215\t    expect(opponentRow).toBeDefined();\n216\t\n217\t    // Non-referred creator: no referrer, 0 rate, components sum to fee.\n218\t    expect(creatorRow.referrer_user_id).toBeNull();\n219\t    expect(creatorRow.referral_rate_bps).toBe(0);\n220\t    expect(creatorRow.referral_lamports).toBe(\"0\");\n221\t    expect(Number(creatorRow.fee_lamports)).toBe(\n222\t      Math.floor((AMOUNT_LAMPORTS * SETTLED_FEE_BPS) / 10_000),\n223\t    );\n224\t    expect(creatorRow.user_id).toBe(creatorProfile.user_id);\n225\t    expectComponentsSumToFee(creatorRow);\n226\t\n227\t    // Referred opponent: referrer set, default rate, components sum to fee.\n228\t    expect(opponentRow.referrer_user_id).toBe(referrerProfile.user_id);\n229\t    expect(opponentRow.referral_rate_bps).toBe(REFERRER_RATE_BPS);\n230\t    expect(Number(opponentRow.referral_lamports)).toBe(\n231\t      Math.floor(\n232\t        (Number(opponentRow.fee_lamports) * REFERRER_RATE_BPS) / 10_000,\n233\t      ),\n234\t    );\n235\t    expect(opponentRow.user_id).toBe(opponentProfile.user_id);\n236\t    expectComponentsSumToFee(opponentRow);\n237\t\n238\t    // Idempotent retry: replay the helper directly with the same inputs.\n239\t    // Production retry hits the same UNIQUE / ON CONFLICT path, so a second\n240\t    // call must not duplicate rows.\n241\t    await recordReferralEarnings(db, {\n242\t      roundId: createJson.matchId,\n243\t      gameType: \"flipyou\",\n244\t      feeBps: SETTLED_FEE_BPS,\n245\t      referralDefaultRateBps: REFERRER_RATE_BPS,\n246\t      players: [\n247\t        { wallet: creatorWallet, wagerLamports: AMOUNT_LAMPORTS },\n248\t        { wallet: opponentWallet, wagerLamports: AMOUNT_LAMPORTS },\n249\t      ],\n250\t    });\n251\t\n252\t    const rowsAfterRetry = await rawSql<FeeAllocationRow[]>`\n253\t      SELECT id FROM fee_allocation_events\n254\t      WHERE source_type = 'flipyou' AND source_id = ${createJson.matchId}\n255\t    `;\n256\t    expect(rowsAfterRetry.length).toBe(2);\n257\t  }, 20_000);\n258\t\n259\t  it(\"Pot Shot helper collapses multiple wallet entries into one allocation row per (round, wallet)\", async () => {\n260\t    // Pot Shot can have multiple entries from the same wallet inside one round.\n261\t    // The shared `recordReferralEarnings` helper dedupes them to a single\n262\t    // allocation keyed on (source_type, source_id, wallet). Asserted directly\n263\t    // because Pot Shot lacks the test infrastructure (account decoder + on-chain\n264\t    // settle path) that FlipYou and Close Call have.\n265\t    const playerAKeypair = Keypair.generate();\n266\t    const playerBKeypair = Keypair.generate();\n267\t    const playerAWallet = playerAKeypair.publicKey.toBase58();\n268\t    const playerBWallet = playerBKeypair.publicKey.toBase58();\n269\t\n270\t    const referrerKeypair = Keypair.generate();\n271\t    const referrerWallet = referrerKeypair.publicKey.toBase58();\n272\t    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n273\t    const playerAProfile = await db.getOrCreateProfile(playerAWallet);\n274\t    await db.getOrCreateProfile(playerBWallet);\n275\t\n276\t    await db.insertReferralCode(\n277\t      referrerProfile.user_id,\n278\t      referrerWallet,\n279\t      \"potshot-ref\",\n280\t    );\n281\t    await db.insertReferralLink({\n282\t      referrerUserId: referrerProfile.user_id,\n283\t      refereeUserId: playerAProfile.user_id,\n284\t      referrerWallet,\n285\t      refereeWallet: playerAWallet,\n286\t    });\n287\t    // playerB intentionally non-referred.\n288\t\n289\t    const roundId = \"potshot-round-001\";\n290\t    await recordReferralEarnings(db, {\n291\t      roundId,\n292\t      gameType: \"potshot\",\n293\t      feeBps: SETTLED_FEE_BPS,\n294\t      referralDefaultRateBps: REFERRER_RATE_BPS,\n295\t      // playerA contributes two entries; total wager is summed by the helper.\n296\t      players: [\n297\t        { wallet: playerAWallet, wagerLamports: 3_000_000 },\n298\t        { wallet: playerAWallet, wagerLamports: 2_000_000 },\n299\t        { wallet: playerBWallet, wagerLamports: 4_000_000 },\n300\t      ],\n301\t    });\n302\t\n303\t    const rows = await rawSql<FeeAllocationRow[]>`\n304\t      SELECT * FROM fee_allocation_events\n305\t      WHERE source_type = 'potshot' AND source_id = ${roundId}\n306\t      ORDER BY wallet\n307\t    `;\n308\t    expect(rows.length).toBe(2);\n309\t\n310\t    const rowA = rows.find((r) => r.wallet === playerAWallet)!;\n311\t    const rowB = rows.find((r) => r.wallet === playerBWallet)!;\n312\t\n313\t    // playerA: collapsed to a single row with summed wager 5_000_000.\n314\t    expect(Number(rowA.wager_lamports)).toBe(5_000_000);\n315\t    expect(Number(rowA.fee_lamports)).toBe(\n316\t      Math.floor((5_000_000 * SETTLED_FEE_BPS) / 10_000),\n317\t    );\n318\t    expect(rowA.referrer_user_id).toBe(referrerProfile.user_id);\n319\t    expect(rowA.referral_rate_bps).toBe(REFERRER_RATE_BPS);\n320\t    expectComponentsSumToFee(rowA);\n321\t\n322\t    // playerB: non-referred, components still sum to fee.\n323\t    expect(Number(rowB.wager_lamports)).toBe(4_000_000);\n324\t    expect(rowB.referrer_user_id).toBeNull();\n325\t    expect(rowB.referral_rate_bps).toBe(0);\n326\t    expect(rowB.referral_lamports).toBe(\"0\");\n327\t    expectComponentsSumToFee(rowB);\n328\t\n329\t    // Replay the same settlement: UNIQUE on (source_type, source_id, wallet)\n330\t    // makes this a no-op.\n331\t    await recordReferralEarnings(db, {\n332\t      roundId,\n333\t      gameType: \"potshot\",\n334\t      feeBps: SETTLED_FEE_BPS,\n335\t      referralDefaultRateBps: REFERRER_RATE_BPS,\n336\t      players: [\n337\t        { wallet: playerAWallet, wagerLamports: 3_000_000 },\n338\t        { wallet: playerAWallet, wagerLamports: 2_000_000 },\n339\t        { wallet: playerBWallet, wagerLamports: 4_000_000 },\n340\t      ],\n341\t    });\n342\t    const rowsAfterRetry = await rawSql<FeeAllocationRow[]>`\n343\t      SELECT id FROM fee_allocation_events\n344\t      WHERE source_type = 'potshot' AND source_id = ${roundId}\n345\t    `;\n346\t    expect(rowsAfterRetry.length).toBe(2);\n347\t  });\n348\t\n349\t  it(\"Close Call clock tick writes allocation rows for both green and red players\", async () => {\n350\t    const greenPlayer = Keypair.generate();\n351\t    const redPlayer = Keypair.generate();\n352\t    const greenWallet = greenPlayer.publicKey.toBase58();\n353\t    const redWallet = redPlayer.publicKey.toBase58();\n354\t\n355\t    const referrerKeypair = Keypair.generate();\n356\t    const referrerWallet = referrerKeypair.publicKey.toBase58();\n357\t    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n358\t    const greenProfile = await db.getOrCreateProfile(greenWallet);\n359\t    await db.getOrCreateProfile(redWallet);\n360\t\n361\t    await db.insertReferralCode(\n362\t      referrerProfile.user_id,\n363\t      referrerWallet,\n364\t      \"closecall-ref\",\n365\t    );\n366\t    await db.insertReferralLink({\n367\t      referrerUserId: referrerProfile.user_id,\n368\t      refereeUserId: greenProfile.user_id,\n369\t      referrerWallet,\n370\t      refereeWallet: greenWallet,\n371\t    });\n372\t    // Red player intentionally non-referred.\n373\t\n374\t    const nowSec = Math.floor(Date.now() / 1000);\n375\t    const minuteTs = BigInt(Math.floor((nowSec - 120) / 60) * 60);\n376\t    const openPrice = 69500_00n;\n377\t\n378\t    const minuteTsBuf = Buffer.alloc(8);\n379\t    minuteTsBuf.writeBigInt64LE(minuteTs);\n380\t    const [roundPda] = PublicKey.findProgramAddressSync(\n381\t      [Buffer.from(\"round\"), minuteTsBuf, serverKeypair.publicKey.toBuffer()],\n382\t      CLOSECALL_PROGRAM_ID,\n383\t    );\n384\t\n385\t    const roundAccountData = await encodeCloseCallRound({\n386\t      minuteTs,\n387\t      server: serverKeypair.publicKey,\n388\t      phase: 0,\n389\t      greenEntries: [\n390\t        { player: greenPlayer.publicKey, amountLamports: 5_000_000n },\n391\t      ],\n392\t      redEntries: [\n393\t        { player: redPlayer.publicKey, amountLamports: 5_000_000n },\n394\t      ],\n395\t      greenPool: 5_000_000n,\n396\t      redPool: 5_000_000n,\n397\t      openPrice,\n398\t      openPriceExpo: -2,\n399\t      closePrice: 0n,\n400\t      createdAt: minuteTs,\n401\t      bettingEndsAt: minuteTs + 45n,\n402\t      resolveDeadline: minuteTs + 300n,\n403\t      outcome: 0,\n404\t      totalFee: 0n,\n405\t      bump: 0,\n406\t    });\n407\t    mockConn.setAccount(roundPda, roundAccountData, {\n408\t      owner: CLOSECALL_PROGRAM_ID,\n409\t    });\n410\t\n411\t    const closePrice = 69600_00n;\n412\t    const mockHermes: HermesFetcher = {\n413\t      fetchLatestBtcPrice: async (): Promise<HermesPrice> => ({\n414\t        price: closePrice,\n415\t        expo: -2,\n416\t        publishTime: Math.floor(Date.now() / 1000),\n417\t        priceHuman: 69600.0,\n418\t        vaaBase64: null,\n419\t      }),\n420\t    };\n421\t\n422\t    const clock = createCloseCallClockWorker({\n423\t      connection: mockConn as unknown as Connection,\n424\t      serverKeypair,\n425\t      db,\n426\t      hermesFetcher: mockHermes,\n427\t      referralDefaultRateBps: REFERRER_RATE_BPS,\n428\t    });\n429\t\n430\t    await clock.tick();\n431\t\n432\t    const roundId = String(Number(minuteTs));\n433\t    const rows = await rawSql<FeeAllocationRow[]>`\n434\t      SELECT * FROM fee_allocation_events\n435\t      WHERE source_type = 'closecall' AND source_id = ${roundId}\n436\t      ORDER BY wallet\n437\t    `;\n438\t    expect(rows.length).toBe(2);\n439\t\n440\t    const greenRow = rows.find((r) => r.wallet === greenWallet)!;\n441\t    const redRow = rows.find((r) => r.wallet === redWallet)!;\n442\t\n443\t    // Green: referred — non-zero referral split.\n444\t    expect(greenRow.referrer_user_id).toBe(referrerProfile.user_id);\n445\t    expect(greenRow.referral_rate_bps).toBe(REFERRER_RATE_BPS);\n446\t    expect(Number(greenRow.fee_lamports)).toBe(\n447\t      Math.floor((5_000_000 * SETTLED_FEE_BPS) / 10_000),\n448\t    );\n449\t    expect(Number(greenRow.referral_lamports)).toBeGreaterThan(0);\n450\t    expectComponentsSumToFee(greenRow);\n451\t\n452\t    // Red: non-referred — referral_lamports = 0 but row still written.\n453\t    expect(redRow.referrer_user_id).toBeNull();\n454\t    expect(redRow.referral_rate_bps).toBe(0);\n455\t    expect(redRow.referral_lamports).toBe(\"0\");\n456\t    expect(Number(redRow.fee_lamports)).toBe(\n457\t      Math.floor((5_000_000 * SETTLED_FEE_BPS) / 10_000),\n458\t    );\n459\t    expectComponentsSumToFee(redRow);\n460\t  }, 20_000);\n461\t});\n462\t"}]},"parent_tool_use_id":null,"session_id":"14342bb0-1390-4a1f-96f8-b2235d0b347d","uuid":"45e57019-6ec5-4a54-a025-9d907a99fa19","timestamp":"2026-05-01T20:45:03.298Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/integration-fee-allocation.test.ts","content":"import { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair, PublicKey } from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport { createFlipYouRoutes } from \"../routes/create.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport { createSettlementWorker } from \"../worker/settlement.js\";\nimport { settleMatch, recordReferralEarnings } from \"../worker/settle-tx.js\";\nimport { createRetrySettler } from \"../worker/retry.js\";\nimport { FLIPYOU_PROGRAM_ID } from \"../fairness.js\";\nimport { resetPlatformConfigCache } from \"../platform-config.js\";\nimport { encodeCloseCallRound } from \"../worker/account-decoder.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\nimport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\nimport {\n  AMOUNT_LAMPORTS,\n  AMOUNT_LAMPORTS_BIGINT,\n  JWT_SECRET,\n  PHASE_LOCKED,\n  SIDE_HEADS,\n  type IntegrationDbContext,\n  type TestSql,\n  buildMatchAccountData,\n  closeIntegrationDb,\n  makeJwt,\n  MockConnection,\n  openIntegrationDb,\n  resetIntegrationState,\n  seedSettlementProgramAccounts,\n} from \"./integration-test-helpers.js\";\n\n// Platform config seeded by `seedSettlementProgramAccounts` is fee_bps = 500.\nconst SETTLED_FEE_BPS = 500;\n// recordReferralEarnings/settle deps default to 1000 bps for referrers.\nconst REFERRER_RATE_BPS = 1000;\n\ninterface FeeAllocationRow {\n  source_type: string;\n  source_id: string;\n  game_type: string;\n  wallet: string;\n  user_id: string | null;\n  wager_lamports: string;\n  fee_lamports: string;\n  referrer_user_id: string | null;\n  referral_rate_bps: number;\n  referral_lamports: string;\n  promotions_lamports: string;\n  profit_lamports: string;\n}\n\nfunction expectComponentsSumToFee(row: FeeAllocationRow) {\n  const sum =\n    BigInt(row.referral_lamports) +\n    BigInt(row.promotions_lamports) +\n    BigInt(row.profit_lamports);\n  expect(sum.toString()).toBe(String(row.fee_lamports));\n}\n\ndescribe(\"Fee allocation integration: settlement writes ledger rows for all three games\", () => {\n  let ctx: IntegrationDbContext;\n  let rawSql: TestSql;\n  let db: Db;\n  let mockConn: MockConnection;\n  let app: Hono;\n\n  const serverKeypair = Keypair.generate();\n  const creatorKeypair = Keypair.generate();\n  const opponentKeypair = Keypair.generate();\n  const treasuryKeypair = Keypair.generate();\n  const entropyKeypair = Keypair.generate();\n  const entropyAccount = entropyKeypair.publicKey;\n\n  const entropyData = Buffer.alloc(32);\n  entropyData[0] = 0xab;\n  entropyData[1] = 0xcd;\n  entropyData[15] = 0x42;\n\n  beforeAll(async () => {\n    ctx = await openIntegrationDb();\n    rawSql = ctx.rawSql;\n    db = ctx.db;\n  });\n\n  afterAll(async () => {\n    await closeIntegrationDb(ctx);\n  });\n\n  beforeEach(async () => {\n    await resetIntegrationState(rawSql);\n    resetPlatformConfigCache();\n\n    mockConn = new MockConnection();\n    await seedSettlementProgramAccounts(mockConn, {\n      entropyAccount,\n      entropyData,\n      treasury: treasuryKeypair.publicKey,\n    });\n\n    app = new Hono();\n    app.use(\"/flipyou/*\", createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }));\n    app.route(\n      \"/flipyou\",\n      createFlipYouRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n  });\n\n  it(\"FlipYou settle writes one allocation row per player — referred + non-referred — with components summing to fee\", async () => {\n    const creatorWallet = creatorKeypair.publicKey.toBase58();\n    const opponentWallet = opponentKeypair.publicKey.toBase58();\n    const referrerKeypair = Keypair.generate();\n    const referrerWallet = referrerKeypair.publicKey.toBase58();\n\n    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n\n    await db.insertReferralCode(\n      referrerProfile.user_id,\n      referrerWallet,\n      \"alloc-test-ref\",\n    );\n    await db.insertReferralLink({\n      referrerUserId: referrerProfile.user_id,\n      refereeUserId: opponentProfile.user_id,\n      referrerWallet,\n      refereeWallet: opponentWallet,\n    });\n    // Note: creator has no referral link → non-referred allocation row expected.\n\n    const token = await makeJwt(creatorWallet, creatorProfile.user_id);\n    const createRes = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet: creatorWallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(createRes.status).toBe(200);\n    const createBody = (await createRes.json()) as {\n      ok: true;\n      data: { matchPda: string; matchId: string; commitment: string };\n    };\n    const createJson = createBody.data;\n\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: Buffer.from(createJson.commitment, \"hex\"),\n      algorithmVer: 1,\n      targetSlot: 150n,\n      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n    mockConn.setAccount(new PublicKey(createJson.matchPda), matchAccountData, {\n      owner: FLIPYOU_PROGRAM_ID,\n    });\n    mockConn.slot = 200;\n\n    let settlePromise: Promise<void> | null = null;\n    const retrySettler = createRetrySettler({\n      db,\n      connection: mockConn as unknown as Connection,\n      settleRound: (pda) =>\n        settleMatch(\n          {\n            db,\n            connection: mockConn as unknown as Connection,\n            serverKeypair,\n            entropyAccount,\n            referralDefaultRateBps: REFERRER_RATE_BPS,\n          },\n          pda,\n        ),\n    });\n    const worker = createSettlementWorker({\n      db,\n      connection: mockConn as unknown as Connection,\n      serverKey: serverKeypair.publicKey,\n      pollIntervalMs: 60_000,\n      onSettleReady: (pda) => {\n        settlePromise = retrySettler.attemptSettle(pda);\n        return settlePromise;\n      },\n    });\n\n    await worker.poll();\n    if (settlePromise) await settlePromise;\n\n    const rows = await rawSql<FeeAllocationRow[]>`\n      SELECT * FROM fee_allocation_events\n      WHERE source_type = 'flipyou' AND source_id = ${createJson.matchId}\n      ORDER BY wallet\n    `;\n    expect(rows.length).toBe(2);\n\n    const creatorRow = rows.find((r) => r.wallet === creatorWallet)!;\n    const opponentRow = rows.find((r) => r.wallet === opponentWallet)!;\n    expect(creatorRow).toBeDefined();\n    expect(opponentRow).toBeDefined();\n\n    // Non-referred creator: no referrer, 0 rate, components sum to fee.\n    expect(creatorRow.referrer_user_id).toBeNull();\n    expect(creatorRow.referral_rate_bps).toBe(0);\n    expect(creatorRow.referral_lamports).toBe(\"0\");\n    expect(Number(creatorRow.fee_lamports)).toBe(\n      Math.floor((AMOUNT_LAMPORTS * SETTLED_FEE_BPS) / 10_000),\n    );\n    expect(creatorRow.user_id).toBe(creatorProfile.user_id);\n    expectComponentsSumToFee(creatorRow);\n\n    // Referred opponent: referrer set, default rate, components sum to fee.\n    expect(opponentRow.referrer_user_id).toBe(referrerProfile.user_id);\n    expect(opponentRow.referral_rate_bps).toBe(REFERRER_RATE_BPS);\n    expect(Number(opponentRow.referral_lamports)).toBe(\n      Math.floor(\n        (Number(opponentRow.fee_lamports) * REFERRER_RATE_BPS) / 10_000,\n      ),\n    );\n    expect(opponentRow.user_id).toBe(opponentProfile.user_id);\n    expectComponentsSumToFee(opponentRow);\n\n    // Idempotent retry: replay the helper directly with the same inputs.\n    // Production retry hits the same UNIQUE / ON CONFLICT path, so a second\n    // call must not duplicate rows.\n    await recordReferralEarnings(db, {\n      roundId: createJson.matchId,\n      gameType: \"flipyou\",\n      feeBps: SETTLED_FEE_BPS,\n      referralDefaultRateBps: REFERRER_RATE_BPS,\n      players: [\n        { wallet: creatorWallet, wagerLamports: AMOUNT_LAMPORTS },\n        { wallet: opponentWallet, wagerLamports: AMOUNT_LAMPORTS },\n      ],\n    });\n\n    const rowsAfterRetry = await rawSql<FeeAllocationRow[]>`\n      SELECT id FROM fee_allocation_events\n      WHERE source_type = 'flipyou' AND source_id = ${createJson.matchId}\n    `;\n    expect(rowsAfterRetry.length).toBe(2);\n  }, 20_000);\n\n  it(\"Pot Shot helper collapses multiple wallet entries into one allocation row per (round, wallet)\", async () => {\n    // Pot Shot can have multiple entries from the same wallet inside one round.\n    // The shared `recordReferralEarnings` helper dedupes them to a single\n    // allocation keyed on (source_type, source_id, wallet). Asserted directly\n    // because Pot Shot lacks the test infrastructure (account decoder + on-chain\n    // settle path) that FlipYou and Close Call have.\n    const playerAKeypair = Keypair.generate();\n    const playerBKeypair = Keypair.generate();\n    const playerAWallet = playerAKeypair.publicKey.toBase58();\n    const playerBWallet = playerBKeypair.publicKey.toBase58();\n\n    const referrerKeypair = Keypair.generate();\n    const referrerWallet = referrerKeypair.publicKey.toBase58();\n    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n    const playerAProfile = await db.getOrCreateProfile(playerAWallet);\n    await db.getOrCreateProfile(playerBWallet);\n\n    await db.insertReferralCode(\n      referrerProfile.user_id,\n      referrerWallet,\n      \"potshot-ref\",\n    );\n    await db.insertReferralLink({\n      referrerUserId: referrerProfile.user_id,\n      refereeUserId: playerAProfile.user_id,\n      referrerWallet,\n      refereeWallet: playerAWallet,\n    });\n    // playerB intentionally non-referred.\n\n    const roundId = \"potshot-round-001\";\n    await recordReferralEarnings(db, {\n      roundId,\n      gameType: \"potshot\",\n      feeBps: SETTLED_FEE_BPS,\n      referralDefaultRateBps: REFERRER_RATE_BPS,\n      // playerA contributes two entries; total wager is summed by the helper.\n      players: [\n        { wallet: playerAWallet, wagerLamports: 3_000_000 },\n        { wallet: playerAWallet, wagerLamports: 2_000_000 },\n        { wallet: playerBWallet, wagerLamports: 4_000_000 },\n      ],\n    });\n\n    const rows = await rawSql<FeeAllocationRow[]>`\n      SELECT * FROM fee_allocation_events\n      WHERE source_type = 'potshot' AND source_id = ${roundId}\n      ORDER BY wallet\n    `;\n    expect(rows.length).toBe(2);\n\n    const rowA = rows.find((r) => r.wallet === playerAWallet)!;\n    const rowB = rows.find((r) => r.wallet === playerBWallet)!;\n\n    // playerA: collapsed to a single row with summed wager 5_000_000.\n    expect(Number(rowA.wager_lamports)).toBe(5_000_000);\n    expect(Number(rowA.fee_lamports)).toBe(\n      Math.floor((5_000_000 * SETTLED_FEE_BPS) / 10_000),\n    );\n    expect(rowA.referrer_user_id).toBe(referrerProfile.user_id);\n    expect(rowA.referral_rate_bps).toBe(REFERRER_RATE_BPS);\n    expectComponentsSumToFee(rowA);\n\n    // playerB: non-referred, components still sum to fee.\n    expect(Number(rowB.wager_lamports)).toBe(4_000_000);\n    expect(rowB.referrer_user_id).toBeNull();\n    expect(rowB.referral_rate_bps).toBe(0);\n    expect(rowB.referral_lamports).toBe(\"0\");\n    expectComponentsSumToFee(rowB);\n\n    // Replay the same settlement: UNIQUE on (source_type, source_id, wallet)\n    // makes this a no-op.\n    await recordReferralEarnings(db, {\n      roundId,\n      gameType: \"potshot\",\n      feeBps: SETTLED_FEE_BPS,\n      referralDefaultRateBps: REFERRER_RATE_BPS,\n      players: [\n        { wallet: playerAWallet, wagerLamports: 3_000_000 },\n        { wallet: playerAWallet, wagerLamports: 2_000_000 },\n        { wallet: playerBWallet, wagerLamports: 4_000_000 },\n      ],\n    });\n    const rowsAfterRetry = await rawSql<FeeAllocationRow[]>`\n      SELECT id FROM fee_allocation_events\n      WHERE source_type = 'potshot' AND source_id = ${roundId}\n    `;\n    expect(rowsAfterRetry.length).toBe(2);\n  });\n\n  it(\"Close Call clock tick writes allocation rows for both green and red players\", async () => {\n    const greenPlayer = Keypair.generate();\n    const redPlayer = Keypair.generate();\n    const greenWallet = greenPlayer.publicKey.toBase58();\n    const redWallet = redPlayer.publicKey.toBase58();\n\n    const referrerKeypair = Keypair.generate();\n    const referrerWallet = referrerKeypair.publicKey.toBase58();\n    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n    const greenProfile = await db.getOrCreateProfile(greenWallet);\n    await db.getOrCreateProfile(redWallet);\n\n    await db.insertReferralCode(\n      referrerProfile.user_id,\n      referrerWallet,\n      \"closecall-ref\",\n    );\n    await db.insertReferralLink({\n      referrerUserId: referrerProfile.user_id,\n      refereeUserId: greenProfile.user_id,\n      referrerWallet,\n      refereeWallet: greenWallet,\n    });\n    // Red player intentionally non-referred.\n\n    const nowSec = Math.floor(Date.now() / 1000);\n    const minuteTs = BigInt(Math.floor((nowSec - 120) / 60) * 60);\n    const openPrice = 69500_00n;\n\n    const minuteTsBuf = Buffer.alloc(8);\n    minuteTsBuf.writeBigInt64LE(minuteTs);\n    const [roundPda] = PublicKey.findProgramAddressSync(\n      [Buffer.from(\"round\"), minuteTsBuf, serverKeypair.publicKey.toBuffer()],\n      CLOSECALL_PROGRAM_ID,\n    );\n\n    const roundAccountData = await encodeCloseCallRound({\n      minuteTs,\n      server: serverKeypair.publicKey,\n      phase: 0,\n      greenEntries: [\n        { player: greenPlayer.publicKey, amountLamports: 5_000_000n },\n      ],\n      redEntries: [\n        { player: redPlayer.publicKey, amountLamports: 5_000_000n },\n      ],\n      greenPool: 5_000_000n,\n      redPool: 5_000_000n,\n      openPrice,\n      openPriceExpo: -2,\n      closePrice: 0n,\n      createdAt: minuteTs,\n      bettingEndsAt: minuteTs + 45n,\n      resolveDeadline: minuteTs + 300n,\n      outcome: 0,\n      totalFee: 0n,\n      bump: 0,\n    });\n    mockConn.setAccount(roundPda, roundAccountData, {\n      owner: CLOSECALL_PROGRAM_ID,\n    });\n\n    const closePrice = 69600_00n;\n    const mockHermes: HermesFetcher = {\n      fetchLatestBtcPrice: async (): Promise<HermesPrice> => ({\n        price: closePrice,\n        expo: -2,\n        publishTime: Math.floor(Date.now() / 1000),\n        priceHuman: 69600.0,\n        vaaBase64: null,\n      }),\n    };\n\n    const clock = createCloseCallClockWorker({\n      connection: mockConn as unknown as Connection,\n      serverKeypair,\n      db,\n      hermesFetcher: mockHermes,\n      referralDefaultRateBps: REFERRER_RATE_BPS,\n    });\n\n    await clock.tick();\n\n    const roundId = String(Number(minuteTs));\n    const rows = await rawSql<FeeAllocationRow[]>`\n      SELECT * FROM fee_allocation_events\n      WHERE source_type = 'closecall' AND source_id = ${roundId}\n      ORDER BY wallet\n    `;\n    expect(rows.length).toBe(2);\n\n    const greenRow = rows.find((r) => r.wallet === greenWallet)!;\n    const redRow = rows.find((r) => r.wallet === redWallet)!;\n\n    // Green: referred — non-zero referral split.\n    expect(greenRow.referrer_user_id).toBe(referrerProfile.user_id);\n    expect(greenRow.referral_rate_bps).toBe(REFERRER_RATE_BPS);\n    expect(Number(greenRow.fee_lamports)).toBe(\n      Math.floor((5_000_000 * SETTLED_FEE_BPS) / 10_000),\n    );\n    expect(Number(greenRow.referral_lamports)).toBeGreaterThan(0);\n    expectComponentsSumToFee(greenRow);\n\n    // Red: non-referred — referral_lamports = 0 but row still written.\n    expect(redRow.referrer_user_id).toBeNull();\n    expect(redRow.referral_rate_bps).toBe(0);\n    expect(redRow.referral_lamports).toBe(\"0\");\n    expect(Number(redRow.fee_lamports)).toBe(\n      Math.floor((5_000_000 * SETTLED_FEE_BPS) / 10_000),\n    );\n    expectComponentsSumToFee(redRow);\n  }, 20_000);\n});\n","numLines":462,"startLine":1,"totalLines":462}}}
