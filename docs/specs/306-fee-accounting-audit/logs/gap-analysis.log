6\t    .setProtectedHeader({ alg: \"HS256\" })\n47\t    .setSubject(userId)\n48\t    .setIssuedAt(now)\n49\t    .setExpirationTime(now + 3600)\n50\t    .sign(JWT_SECRET);"}]},"parent_tool_use_id":null,"session_id":"14342bb0-1390-4a1f-96f8-b2235d0b347d","uuid":"8f295bd4-e400-4fcd-a6d6-971cb7370bd4","timestamp":"2026-05-01T20:45:27.363Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/referral-claim-ledger.test.ts","content":"/**\n * Referral claim — ledger-derived caps + bucket debit lifecycle.\n *\n * Spec: docs/specs/306-fee-accounting-audit/spec.md (FR-3, FR-6)\n *\n * Coverage:\n *   - POST /referral/claim ledger cap enforcement\n *       - per-user cap (no allocations → ZERO_BALANCE)\n *       - global cap (user's allocations exceed global bucket capacity → PRECONDITION_FAILED)\n *   - successful claim writes a `fee_bucket_debits` row with status='pending'\n *   - queue handler success / transient error / permanent fail each move the\n *     debit's status in lockstep with the claim\n */\n\nimport { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport { SignJWT } from \"jose\";\nimport type { Db } from \"../db.js\";\nimport { createReferralRoutes } from \"../routes/referral.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport type { Config } from \"../config.js\";\nimport { createClaimHandler } from \"../queue/handlers/referral-claim.js\";\nimport {\n  closeIntegrationDb,\n  type IntegrationDbContext,\n  MockConnection,\n  openIntegrationDb,\n  resetIntegrationState,\n  type TestSql,\n  userIdFromWallet,\n} from \"./integration-test-helpers.js\";\n\nconst JWT_SECRET = new TextEncoder().encode(\n  \"test-secret-for-referral-claim-ledger\",\n);\nconst TEST_CONFIG = {\n  referralDefaultRateBps: 1000,\n  referralMinClaimLamports: 10_000_000, // 0.01 SOL\n} as Config;\n\nasync function makeJwt(userId: string): Promise<string> {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({})\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userId)\n    .setIssuedAt(now)\n    .setExpirationTime(now + 3600)\n    .sign(JWT_SECRET);","numLines":50,"startLine":1,"totalLines":450}}}
