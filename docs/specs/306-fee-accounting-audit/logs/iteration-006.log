{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01S7F9jNBgQVE6j8njoaGiCQ","type":"tool_result","content":"1\t/**\n2\t * Settle transaction builder + submission.\n3\t *\n4\t * Retrieves the stored secret, reads on-chain match + config data to resolve\n5\t * all accounts, builds the `settle` instruction, submits it, and updates the\n6\t * DB on confirmation.\n7\t */\n8\t\n9\timport { createHash } from \"node:crypto\";\n10\timport { performance } from \"node:perf_hooks\";\n11\timport {\n12\t  Connection,\n13\t  Keypair,\n14\t  PublicKey,\n15\t  SystemProgram,\n16\t  Transaction,\n17\t  TransactionInstruction,\n18\t} from \"@solana/web3.js\";\n19\timport type { Db } from \"../db.js\";\n20\timport { calculateFeeAllocation } from \"../db/fee-accounting.js\";\n21\timport { logger } from \"../logger.js\";\n22\timport { emitEvent } from \"../queue/emit-event.js\";\n23\timport { EventTypes } from \"../queue/event-types.js\";\n24\timport { FLIPYOU_PROGRAM_ID, POTSHOT_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n25\timport { derivePlatformConfigPda, getPlatformConfig } from \"../platform-config.js\";\n26\timport { FlipYouIDL as flipyouIdl, PotShotIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@taunt-bet/anchor-client\";\n27\timport {\n28\t  decodeFlipYouMatch,\n29\t  decodeLordRound,\n30\t  type DecodedPotShotRound,\n31\t} from \"./account-decoder.js\";\n32\t\n33\t// ---------------------------------------------------------------------------\n34\t// Instruction discriminators (from IDL — no hardcoded byte arrays)\n35\t// ---------------------------------------------------------------------------\n36\t\n37\tfunction getInstructionDiscriminator(\n38\t  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n39\t  instructionName: string,\n40\t): Buffer {\n41\t  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n42\t  if (!instruction) {\n43\t    throw new Error(`Instruction ${instructionName} not found in IDL`);\n44\t  }\n45\t  return Buffer.from(instruction.discriminator);\n46\t}\n47\t\n48\tconst SETTLE_DISCRIMINATOR = getInstructionDiscriminator(flipyouIdl, \"settle\");\n49\tconst CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n50\t  lordIdl,\n51\t  \"claim_payout\",\n52\t);\n53\tconst CC_BET_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"bet\");\n54\tconst CC_SETTLE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"settle_round\");\n55\tconst CC_TIMEOUT_REFUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"timeout_refund\");\n56\tconst SLOT_HASHES_WINDOW_SLOTS = 512n;\n57\t\n58\t// ---------------------------------------------------------------------------\n59\t// Types\n60\t// ---------------------------------------------------------------------------\n61\t\n62\texport interface SettleTxDeps {\n63\t  db: Db;\n64\t  connection: Connection;\n65\t  serverKeypair: Keypair;\n66\t  entropyAccount: PublicKey;\n67\t  referralDefaultRateBps: number;\n68\t}\n69\t\n70\texport interface SettleResult {\n71\t  txSignature: string;\n72\t  resultHash: Buffer;\n73\t  resultSide?: number;\n74\t  winningEntryIndex?: number;\n75\t  winner: string;\n76\t}\n77\t\n78\t// ---------------------------------------------------------------------------\n79\t// Instruction encoding\n80\t// ---------------------------------------------------------------------------\n81\t\n82\t/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\n83\tfunction encodeSettleData(secret: Buffer): Buffer {\n84\t  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n85\t}\n86\t\n87\tfunction encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n88\t  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n89\t}\n90\t\n91\t// ---------------------------------------------------------------------------\n92\t// Result derivation (mirrors on-chain derive_result)\n93\t// ---------------------------------------------------------------------------\n94\t\n95\t/**\n96\t * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n97\t * Must match shared/src/fairness.rs `derive_result()`.\n98\t */\n99\tfunction deriveResult(\n100\t  secret: Buffer,\n101\t  entropy: Buffer,\n102\t  matchPdaBytes: Buffer,\n103\t  algoVer: number,\n104\t): Buffer {\n105\t  return createHash(\"sha256\")\n106\t    .update(secret)\n107\t    .update(entropy)\n108\t    .update(matchPdaBytes)\n109\t    .update(Buffer.from([algoVer]))\n110\t    .digest();\n111\t}\n112\t\n113\t// ---------------------------------------------------------------------------\n114\t// Fee allocation + referral earnings hook\n115\t// ---------------------------------------------------------------------------\n116\t\n117\t/**\n118\t * After a game settles, write one `fee_allocation_events` row per unique\n119\t * player (referred or not), and an additional `referral_earnings` row for\n120\t * referred players.\n121\t *\n122\t * For each unique player: look up profile + referral link → compute the\n123\t * deterministic fee split via `calculateFeeAllocation` → write the\n124\t * allocation row. If a referrer is present, also write the legacy\n125\t * `referral_earnings` row.\n126\t *\n127\t * Errors are logged but never bubble — accounting must not fail settlement.\n128\t * Idempotency: `fee_allocation_events` UNIQUE on (source_type, source_id,\n129\t * wallet) plus `ON CONFLICT DO NOTHING` in `insertFeeAllocation`;\n130\t * `referral_earnings` UNIQUE on (referee_user_id, round_id).\n131\t */\n132\tasync function recordReferralEarnings(\n133\t  db: Db,\n134\t  params: {\n135\t    roundId: string;\n136\t    gameType: string;\n137\t    feeBps: number;\n138\t    referralDefaultRateBps: number;\n139\t    players: Array<{ wallet: string; wagerLamports: number }>;\n140\t  },\n141\t): Promise<void> {\n142\t  const { roundId, gameType, feeBps, referralDefaultRateBps, players } = params;\n143\t\n144\t  // Deduplicate players (Pot Shot can have multiple entries per player)\n145\t  const playerWagers = new Map<string, number>();\n146\t  for (const p of players) {\n147\t    playerWagers.set(p.wallet, (playerWagers.get(p.wallet) ?? 0) + p.wagerLamports);\n148\t  }\n149\t\n150\t  for (const [wallet, wagerLamports] of playerWagers) {\n151\t    try {\n152\t      const refereeProfile = await db.getProfileByWallet(wallet);\n153\t      const link = refereeProfile\n154\t        ? await db.getReferralLinkByRefereeUserId(refereeProfile.user_id)\n155\t        : undefined;\n156\t\n157\t      const referrerRateBps = link\n158\t        ? await db.getReferrerRate(link.referrer_user_id, referralDefaultRateBps)\n159\t        : 0;\n160\t\n161\t      const feeLamports = Math.floor((wagerLamports * feeBps) / 10_000);\n162\t      const allocation = calculateFeeAllocation(feeLamports, referrerRateBps);\n163\t\n164\t      await db.insertFeeAllocation({\n165\t        sourceType: gameType,\n166\t        sourceId: roundId,\n167\t        gameType,\n168\t        wallet,\n169\t        userId: refereeProfile?.user_id ?? null,\n170\t        wagerLamports,\n171\t        feeLamports,\n172\t        referrerUserId: link?.referrer_user_id ?? null,\n173\t        referralRateBps: referrerRateBps,\n174\t        referralLamports: allocation.referralLamports,\n175\t        promotionsLamports: allocation.promotionsLamports,\n176\t        profitLamports: allocation.profitLamports,\n177\t      });\n178\t\n179\t      if (link && refereeProfile) {\n180\t        await db.insertReferralEarning({\n181\t          referrerUserId: link.referrer_user_id,\n182\t          refereeUserId: refereeProfile.user_id,\n183\t          referrerWallet: link.referrer_wallet,\n184\t          refereeWallet: wallet,\n185\t          roundId,\n186\t          gameType,\n187\t          wagerLamports,\n188\t          feeLamports,\n189\t          referrerEarnedLamports: allocation.referralLamports,\n190\t          referrerRateBps,\n191\t        });\n192\t\n193\t        logger.info(\"referral earning recorded\", {\n194\t          roundId,\n195\t          gameType,\n196\t          referrerUserId: link.referrer_user_id,\n197\t          refereeUserId: refereeProfile.user_id,\n198\t          referrerEarnedLamports: allocation.referralLamports,\n199\t        });\n200\t      }\n201\t    } catch (err: unknown) {\n202\t      const msg = err instanceof Error ? err.message : String(err);\n203\t      if (msg.includes(\"duplicate key\") || msg.includes(\"unique constraint\")) {\n204\t        logger.info(\"fee accounting row already recorded (idempotent skip)\", {\n205\t          roundId,\n206\t          wallet,\n207\t        });\n208\t      } else {\n209\t        logger.error(\"failed to record fee accounting row\", {\n210\t          roundId,\n211\t          wallet,\n212\t          error: msg,\n213\t        });\n214\t      }\n215\t    }\n216\t  }\n217\t}\n218\t\n219\t// ---------------------------------------------------------------------------\n220\t// Core settle function\n221\t// ---------------------------------------------------------------------------\n222\t\n223\t/**\n224\t * Build, submit, and confirm a settle transaction for a locked match.\n225\t *\n226\t * Steps:\n227\t * 1. Retrieve secret from DB\n228\t * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n229\t * 3. Fetch config account data (treasury)\n230\t * 4. Read entropy from the entropy account\n231\t * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n232\t * 6. Build + submit settle tx\n233\t * 7. Update DB on confirmation\n234\t */\n235\texport async function settleMatch(\n236\t  deps: SettleTxDeps,\n237\t  pda: string,\n238\t): Promise<SettleResult> {\n239\t  const t0 = performance.now();\n240\t  const { db, connection, serverKeypair, entropyAccount } = deps;\n241\t  const matchPubkey = new PublicKey(pda);\n242\t\n243\t  // 1. Retrieve secret from DB\n244\t  const round = await db.getRoundByPda(pda);\n245\t  const tDb = performance.now();\n246\t  if (!round) {\n247\t    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n248\t  }\n249\t  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n250\t    throw new PermanentSettleError(\n251\t      `Round ${pda} in unexpected phase: ${round.phase}`,\n252\t    );\n253\t  }\n254\t\n255\t  const secret = Buffer.from(round.secret);\n256\t\n257\t  // Transition to settling (locked → settling)\n258\t  if (round.phase === \"locked\") {\n259\t    await db.updateRoundPhase(pda, \"settling\");\n260\t  }\n261\t\n262\t  // Log settle_submitted\n263\t  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n264\t    attempt: round.settle_attempts + 1,\n265\t  });\n266\t\n267\t  // 2-4. Fetch match, platform config, entropy, and blockhash in parallel\n268\t  const [platformConfigPda] = derivePlatformConfigPda();\n269\t  const [matchAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n270\t    await Promise.all([\n271\t      connection.getAccountInfo(matchPubkey),\n272\t      getPlatformConfig(connection),\n273\t      connection.getAccountInfo(entropyAccount),\n274\t      connection.getLatestBlockhash(),\n275\t    ]);\n276\t  const tFetch = performance.now();\n277\t\n278\t  if (!matchAccountInfo) {\n279\t    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n280\t  }\n281\t  if (!entropyInfo) {\n282\t    throw new TransientSettleError(\"Entropy account not available yet\");\n283\t  }\n284\t\n285\t  // IDL-driven decode — no manual byte offsets\n286\t  const match = decodeFlipYouMatch(Buffer.from(matchAccountInfo.data));\n287\t  const { feeBps, treasury } = platformConfig;\n288\t\n289\t  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer, targetSlot } = match;\n290\t\n291\t  const currentSlot = BigInt(await connection.getSlot(\"confirmed\"));\n292\t  if (\n293\t    targetSlot > 0n &&\n294\t    currentSlot > targetSlot &&\n295\t    currentSlot - targetSlot > SLOT_HASHES_WINDOW_SLOTS\n296\t  ) {\n297\t    throw new EntropyExpiredSettleError(\n298\t      `FlipYou entropy expired for target slot ${targetSlot.toString()} (current slot ${currentSlot.toString()}); waiting for timeout refund`,\n299\t    );\n300\t  }\n301\t\n302\t  const pool = entryAmount * 2n;\n303\t  const feeAmount = Number((pool * BigInt(feeBps)) / 10_000n);\n304\t  const payoutAmount = Number(pool) - feeAmount;\n305\t\n306\t  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n307\t\n308\t  // 5. Pre-compute result\n309\t  const matchPdaBytes = matchPubkey.toBuffer();\n310\t  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n311\t  const resultSide = resultHash[0]! % 2;\n312\t  const winner = resultSide === creatorSide ? creator : opponent;\n313\t\n314\t  // 6. Build settle instruction (8 accounts, no profile CPI)\n315\t  const data = encodeSettleData(secret);\n316\t\n317\t  const instruction = new TransactionInstruction({\n318\t    keys: [\n319\t      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n320\t      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // flipyou_match\n321\t      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n322\t      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n323\t      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n324\t      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n325\t      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n326\t      {\n327\t        pubkey: SystemProgram.programId,\n328\t        isSigner: false,\n329\t        isWritable: false,\n330\t      }, // system_program\n331\t    ],\n332\t    programId: FLIPYOU_PROGRAM_ID,\n333\t    data,\n334\t  });\n335\t\n336\t  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n337\t\n338\t  const tx = new Transaction({\n339\t    feePayer: serverKeypair.publicKey,\n340\t    blockhash,\n341\t    lastValidBlockHeight,\n342\t  });\n343\t  tx.add(instruction);\n344\t  tx.sign(serverKeypair);\n345\t\n346\t  // 7. Submit and confirm\n347\t  const rawTx = tx.serialize();\n348\t  const tBuild = performance.now();\n349\t  const txSignature = await connection.sendRawTransaction(rawTx, {\n350\t    skipPreflight: false,\n351\t  });\n352\t  const tSend = performance.now();\n353\t\n354\t  logger.info(\"settlement transaction submitted\", {\n355\t    pda,\n356\t    txSignature,\n357\t    attempt: round.settle_attempts + 1,\n358\t    dbMs: Math.round(tDb - t0),\n359\t    fetchMs: Math.round(tFetch - tDb),\n360\t    buildMs: Math.round(tBuild - tFetch),\n361\t    sendMs: Math.round(tSend - tBuild),\n362\t  });\n363\t\n364\t  const confirmation = await connection.confirmTransaction(\n365\t    { signature: txSignature, blockhash, lastValidBlockHeight },\n366\t    \"confirmed\",\n367\t  );\n368\t  const tConfirm = performance.now();\n369\t  if (confirmation.value.err) {\n370\t    throw new TransientSettleError(\n371\t      `FlipYou settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n372\t    );\n373\t  }\n374\t\n375\t  // 8. Update DB — phase settling → settled (atomic transaction)\n376\t  const flipyouEntries = [\n377\t    { player: creator.toBase58(), amountLamports: Number(entryAmount) },\n378\t    { player: opponent.toBase58(), amountLamports: Number(entryAmount) },\n379\t  ];\n380\t\n381\t  await db.withTransaction(async (txDb) => {\n382\t    await txDb.updateRoundPhase(pda, \"settled\", {\n383\t      settle_tx: txSignature,\n384\t      result_hash: resultHash,\n385\t      result_side: resultSide,\n386\t      winner: winner.toBase58(),\n387\t      settle_attempts: round.settle_attempts + 1,\n388\t    });\n389\t\n390\t    // Game entries for leaderboard/stats — UPSERT updates existing (creator) and inserts new (joiner)\n391\t    const loser = winner.equals(creator) ? opponent : creator;\n392\t    const [winnerProfile, loserProfile] = await Promise.all([\n393\t      txDb.getProfileByWallet(winner.toBase58()),\n394\t      txDb.getProfileByWallet(loser.toBase58()),\n395\t    ]);\n396\t    if (!winnerProfile || !loserProfile) {\n397\t      logger.warn(\"flipyou settle: missing profile for participant — skipping game entries\", {\n398\t        pda,\n399\t        winnerWallet: winner.toBase58(),\n400\t        loserWallet: loser.toBase58(),\n401\t        winnerProfileExists: !!winnerProfile,\n402\t        loserProfileExists: !!loserProfile,\n403\t      });\n404\t    } else {\n405\t      await txDb.upsertGameEntries([\n406\t        {\n407\t          userId: winnerProfile.user_id,\n408\t          wallet: winner.toBase58(),\n409\t          game: \"flipyou\",\n410\t          roundPda: pda,\n411\t          matchId: round.match_id,\n412\t          amountLamports: Number(entryAmount),\n413\t          isWinner: true,\n414\t          payoutLamports: payoutAmount,\n415\t          settledAt: new Date(),\n416\t        },\n417\t        {\n418\t          userId: loserProfile.user_id,\n419\t          wallet: loser.toBase58(),\n420\t          game: \"flipyou\",\n421\t          roundPda: pda,\n422\t          matchId: round.match_id,\n423\t          amountLamports: Number(entryAmount),\n424\t          isWinner: false,\n425\t          payoutLamports: 0,\n426\t          settledAt: new Date(),\n427\t        },\n428\t      ]);\n429\t    }\n430\t\n431\t    // Log settle_confirmed\n432\t    await txDb.insertOperatorEvent(pda, \"settle_confirmed\", {\n433\t      txSignature,\n434\t      resultSide,\n435\t      winner: winner.toBase58(),\n436\t      entropy: entropy.toString(\"hex\"),\n437\t      payoutAmount,\n438\t      feeAmount,\n439\t      entries: flipyouEntries,\n440\t    });\n441\t\n442\t    // Write payout transaction for the winner\n443\t    await txDb.insertTransaction({\n444\t      userId: winnerProfile?.user_id,\n445\t      wallet: winner.toBase58(),\n446\t      game: \"flipyou\",\n447\t      matchId: round.match_id,\n448\t      txType: \"payout\",\n449\t      amountLamports: payoutAmount,\n450\t      txSig: txSignature,\n451\t    });\n452\t\n453\t    // Referral earnings hook — in same transaction for atomicity (System Invariant 4)\n454\t    await recordReferralEarnings(txDb, {\n455\t      roundId: round.match_id,\n456\t      gameType: \"flipyou\",\n457\t      feeBps,\n458\t      referralDefaultRateBps: deps.referralDefaultRateBps,\n459\t      players: [\n460\t        { wallet: creator.toBase58(), wagerLamports: Number(entryAmount) },\n461\t        { wallet: opponent.toBase58(), wagerLamports: Number(entryAmount) },\n462\t      ],\n463\t    });\n464\t\n465\t    // Emit game.settled event for challenge engine (async, downstream handlers dedupe)\n466\t    const settledAt = new Date().toISOString();\n467\t    const creatorUserId = winner.equals(creator) ? winnerProfile?.user_id : loserProfile?.user_id;\n468\t    const opponentUserId = winner.equals(creator) ? loserProfile?.user_id : winnerProfile?.user_id;\n469\t    await emitEvent(txDb.rawSql, EventTypes.GAME_SETTLED, {\n470\t      roundId: round.match_id,\n471\t      roundPda: pda,\n472\t      game: \"flipyou\",\n473\t      players: [\n474\t        {\n475\t          userId: creatorUserId ?? creator.toBase58(),\n476\t          wallet: creator.toBase58(),\n477\t          amountLamports: String(entryAmount),\n478\t          isWinner: winner.equals(creator),\n479\t          payoutLamports: winner.equals(creator) ? String(payoutAmount) : \"0\",\n480\t          isCreator: true,\n481\t        },\n482\t        {\n483\t          userId: opponentUserId ?? opponent.toBase58(),\n484\t          wallet: opponent.toBase58(),\n485\t          amountLamports: String(entryAmount),\n486\t          isWinner: winner.equals(opponent),\n487\t          payoutLamports: winner.equals(opponent) ? String(payoutAmount) : \"0\",\n488\t          isCreator: false,\n489\t        },\n490\t      ],\n491\t      feeLamports: String(feeAmount),\n492\t      settledAt,\n493\t    });\n494\t\n495\t    // Emit ticker publish for the on-site news ticker\n496\t    await emitEvent(txDb.rawSql, EventTypes.TICKER_PUBLISH, {\n497\t      kind: \"flipyou.match_settled\",\n498\t      winnerName: winnerProfile?.username,\n499\t      side: resultSide === 0 ? \"heads\" : \"tails\",\n500\t      amountLamports: String(payoutAmount),\n501\t    });\n502\t  });\n503\t\n504\t  const tDone = performance.now();\n505\t  logger.info(\"settlement transaction confirmed\", {\n506\t    pda,\n507\t    txSignature,\n508\t    resultSide,\n509\t    winner: winner.toBase58(),\n510\t    timing: {\n511\t      dbMs: Math.round(tDb - t0),\n512\t      fetchMs: Math.round(tFetch - tDb),\n513\t      buildMs: Math.round(tBuild - tFetch),\n514\t      sendMs: Math.round(tSend - tBuild),\n515\t      confirmMs: Math.round(tConfirm - tSend),\n516\t      dbWriteMs: Math.round(tDone - tConfirm),\n517\t      totalMs: Math.round(tDone - t0),\n518\t    },\n519\t  });\n520\t\n521\t  return {\n522\t    txSignature,\n523\t    resultHash,\n524\t    resultSide,\n525\t    winner: winner.toBase58(),\n526\t  };\n527\t}\n528\t\n529\texport async function settleLordRound(\n530\t  deps: SettleTxDeps,\n531\t  pda: string,\n532\t): Promise<SettleResult> {\n533\t  const t0 = performance.now();\n534\t  const { db, connection, serverKeypair, entropyAccount } = deps;\n535\t  const roundPubkey = new PublicKey(pda);\n536\t\n537\t  const round = await db.getRoundByPda(pda);\n538\t  const tDb = performance.now();\n539\t  if (!round) {\n540\t    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n541\t  }\n542\t  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n543\t    throw new PermanentSettleError(\n544\t      `Round ${pda} in unexpected phase: ${round.phase}`,\n545\t    );\n546\t  }\n547\t\n548\t  const secret = Buffer.from(round.secret);\n549\t\n550\t  if (round.phase === \"locked\") {\n551\t    await db.updateRoundPhase(pda, \"settling\");\n552\t  }\n553\t\n554\t  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n555\t    attempt: round.settle_attempts + 1,\n556\t    game: \"potshot\",\n557\t  });\n558\t\n559\t  const [platformConfigPda] = derivePlatformConfigPda();\n560\t  const [roundAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n561\t    await Promise.all([\n562\t      connection.getAccountInfo(roundPubkey),\n563\t      getPlatformConfig(connection),\n564\t      connection.getAccountInfo(entropyAccount),\n565\t      connection.getLatestBlockhash(),\n566\t    ]);\n567\t\n568\t  const tFetch = performance.now();\n569\t\n570\t  if (!roundAccountInfo) {\n571\t    throw new PermanentSettleError(`Lord round account not found on-chain: ${pda}`);\n572\t  }\n573\t  if (!entropyInfo) {\n574\t    throw new TransientSettleError(\"Entropy account not available yet\");\n575\t  }\n576\t\n577\t  // IDL-driven decode — no manual byte offsets or parseLordRound()\n578\t  const roundData: DecodedPotShotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n579\t  const { feeBps, treasury } = platformConfig;\n580\t\n581\t  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n582\t  const resultHash = deriveResult(\n583\t    secret,\n584\t    entropy,\n585\t    roundPubkey.toBuffer(),\n586\t    roundData.algorithmVer,\n587\t  );\n588\t  const feeAmount = Number((roundData.totalAmountLamports * BigInt(feeBps)) / 10_000n);\n589\t  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n590\t  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n591\t\n592\t  const raw = resultHash.readBigUInt64LE(0);\n593\t  const winningOffset = raw % roundData.totalAmountLamports;\n594\t\n595\t  let cumulative = 0n;\n596\t  let winnerEntryIndex = -1;\n597\t  let winner = roundData.entries[0]?.player;\n598\t  for (const [index, entry] of roundData.entries.entries()) {\n599\t    cumulative += entry.amountLamports;\n600\t    if (winningOffset < cumulative) {\n601\t      winnerEntryIndex = index;\n602\t      winner = entry.player;\n603\t      break;\n604\t    }\n605\t  }\n606\t\n607\t  if (!winner || winnerEntryIndex < 0) {\n608\t    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n609\t  }\n610\t\n611\t  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n612\t  const instruction = new TransactionInstruction({\n613\t    keys: [\n614\t      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n615\t      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n616\t      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n617\t      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n618\t      { pubkey: treasury, isSigner: false, isWritable: true },\n619\t      { pubkey: winner, isSigner: false, isWritable: true },\n620\t      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n621\t    ],\n622\t    programId: POTSHOT_PROGRAM_ID,\n623\t    data: encodeClaimPayoutData(matchIdBuf, secret),\n624\t  });\n625\t\n626\t  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n627\t  const tx = new Transaction({\n628\t    feePayer: serverKeypair.publicKey,\n629\t    blockhash,\n630\t    lastValidBlockHeight,\n631\t  });\n632\t  tx.add(instruction);\n633\t  tx.sign(serverKeypair);\n634\t\n635\t  const tBuild = performance.now();\n636\t  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n637\t    skipPreflight: false,\n638\t  });\n639\t  const tSend = performance.now();\n640\t\n641\t  logger.info(\"lord settlement transaction submitted\", {\n642\t    pda,\n643\t    txSignature,\n644\t    attempt: round.settle_attempts + 1,\n645\t    winningEntryIndex: winnerEntryIndex,\n646\t    dbMs: Math.round(tDb - t0),\n647\t    fetchMs: Math.round(tFetch - tDb),\n648\t    buildMs: Math.round(tBuild - tFetch),\n649\t    sendMs: Math.round(tSend - tBuild),\n650\t  });\n651\t\n652\t  const confirmation = await connection.confirmTransaction(\n653\t    { signature: txSignature, blockhash, lastValidBlockHeight },\n654\t    \"confirmed\",\n655\t  );\n656\t  const tConfirm = performance.now();\n657\t  if (confirmation.value.err) {\n658\t    throw new TransientSettleError(\n659\t      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n660\t    );\n661\t  }\n662\t\n663\t  const serializedEntries = roundData.entries.map((e) => ({\n664\t    player: e.player.toBase58(),\n665\t    amountLamports: Number(e.amountLamports),\n666\t  }));\n667\t\n668\t  await db.withTransaction(async (txDb) => {\n669\t    await txDb.updateRoundPhase(pda, \"settled\", {\n670\t      settle_tx: txSignature,\n671\t      result_hash: resultHash,\n672\t      result_side: winnerEntryIndex,\n673\t      winner: winner.toBase58(),\n674\t      settle_attempts: round.settle_attempts + 1,\n675\t    });\n676\t\n677\t    // Game entries — aggregate per player, resolve profiles for user_id\n678\t    const playerTotals = new Map<string, number>();\n679\t    for (const e of serializedEntries) {\n680\t      playerTotals.set(e.player, (playerTotals.get(e.player) ?? 0) + e.amountLamports);\n681\t    }\n682\t    const winnerKey = winner.toBase58();\n683\t    const profileResults = await Promise.all(\n684\t      [...playerTotals.keys()].map(async (wallet) => {\n685\t        const profile = await txDb.getProfileByWallet(wallet);\n686\t        return [wallet, profile] as const;\n687\t      }),\n688\t    );\n689\t    const missingWallets = profileResults.filter(([, p]) => !p).map(([w]) => w);\n690\t    if (missingWallets.length > 0) {\n691\t      logger.warn(\"lord settle: missing profiles for participants — skipping their game entries\", {\n692\t        pda,\n693\t        missingWallets,\n694\t      });\n695\t    }\n696\t    const profileMap = new Map(\n697\t      profileResults.filter((r): r is [string, NonNullable<(typeof r)[1]>] => !!r[1]),\n698\t    );\n699\t    const entriesToUpsert = [...playerTotals.entries()]\n700\t      .filter(([wallet]) => profileMap.has(wallet))\n701\t      .map(([wallet, amount]) => ({\n702\t        userId: profileMap.get(wallet)!.user_id,\n703\t        wallet,\n704\t        game: \"potshot\",\n705\t        roundPda: pda,\n706\t        matchId: round.match_id,\n707\t        amountLamports: amount,\n708\t        isWinner: wallet === winnerKey,\n709\t        payoutLamports: wallet === winnerKey ? payoutAmount : 0,\n710\t        settledAt: new Date(),\n711\t      }));\n712\t    if (entriesToUpsert.length > 0) {\n713\t      await txDb.upsertGameEntries(entriesToUpsert);\n714\t    }\n715\t\n716\t    await txDb.insertOperatorEvent(pda, \"settle_confirmed\", {\n717\t      txSignature,\n718\t      winner: winner.toBase58(),\n719\t      winningEntryIndex: winnerEntryIndex,\n720\t      game: \"potshot\",\n721\t      entropy: entropy.toString(\"hex\"),\n722\t      winningOffset: winningOffset.toString(),\n723\t      totalAmountLamports: Number(roundData.totalAmountLamports),\n724\t      payoutAmount,\n725\t      feeAmount,\n726\t      rentRefund,\n727\t      entries: serializedEntries,\n728\t    });\n729\t\n730\t    // Write payout transaction for the winner\n731\t    await txDb.insertTransaction({\n732\t      userId: profileMap.get(winnerKey)?.user_id,\n733\t      wallet: winner.toBase58(),\n734\t      game: \"potshot\",\n735\t      matchId: round.match_id,\n736\t      txType: \"payout\",\n737\t      amountLamports: payoutAmount,\n738\t      txSig: txSignature,\n739\t    });\n740\t\n741\t    // Referral earnings hook — in same transaction for atomicity (System Invariant 4)\n742\t    await recordReferralEarnings(txDb, {\n743\t      roundId: round.match_id,\n744\t      gameType: \"potshot\",\n745\t      feeBps,\n746\t      referralDefaultRateBps: deps.referralDefaultRateBps,\n747\t      players: serializedEntries.map((e) => ({\n748\t        wallet: e.player,\n749\t        wagerLamports: e.amountLamports,\n750\t      })),\n751\t    });\n752\t\n753\t    // Emit game.settled event for challenge engine (async, downstream handlers dedupe)\n754\t    const settledAt = new Date().toISOString();\n755\t    // Aggregate per-player totals for lord (a player may have multiple entries)\n756\t    const playerAgg = new Map<string, { total: bigint; isWinner: boolean }>();\n757\t    for (const e of serializedEntries) {\n758\t      const existing = playerAgg.get(e.player);\n759\t      playerAgg.set(e.player, {\n760\t        total: (existing?.total ?? 0n) + BigInt(e.amountLamports),\n761\t        isWinner: existing?.isWinner || e.player === winnerKey,\n762\t      });\n763\t    }\n764\t    await emitEvent(txDb.rawSql, EventTypes.GAME_SETTLED, {\n765\t      roundId: round.match_id,\n766\t      roundPda: pda,\n767\t      game: \"potshot\",\n768\t      players: [...playerAgg.entries()].map(([wallet, agg]) => ({\n769\t        userId: profileMap.get(wallet)?.user_id ?? wallet,\n770\t        wallet,\n771\t        amountLamports: String(agg.total),\n772\t        isWinner: agg.isWinner,\n773\t        payoutLamports: agg.isWinner ? String(payoutAmount) : \"0\",\n774\t        isCreator: serializedEntries[0]?.player === wallet, // first entry is creator\n775\t      })),\n776\t      feeLamports: String(feeAmount),\n777\t      settledAt,\n778\t    });\n779\t\n780\t    // Emit ticker publish for the on-site news ticker\n781\t    await emitEvent(txDb.rawSql, EventTypes.TICKER_PUBLISH, {\n782\t      kind: \"potshot.round_settled\",\n783\t      winnerName: profileMap.get(winnerKey)?.username,\n784\t      prizeLamports: String(payoutAmount),\n785\t      totalEntries: serializedEntries.length,\n786\t    });\n787\t  });\n788\t\n789\t  const tDone = performance.now();\n790\t  logger.info(\"lord settlement transaction confirmed\", {\n791\t    pda,\n792\t    txSignature,\n793\t    winner: winner.toBase58(),\n794\t    winningEntryIndex: winnerEntryIndex,\n795\t    timing: {\n796\t      dbMs: Math.round(tDb - t0),\n797\t      fetchMs: Math.round(tFetch - tDb),\n798\t      buildMs: Math.round(tBuild - tFetch),\n799\t      sendMs: Math.round(tSend - tBuild),\n800\t      confirmMs: Math.round(tConfirm - tSend),\n801\t      dbWriteMs: Math.round(tDone - tConfirm),\n802\t      totalMs: Math.round(tDone - t0),\n803\t    },\n804\t  });\n805\t\n806\t  return {\n807\t    txSignature,\n808\t    resultHash,\n809\t    winningEntryIndex: winnerEntryIndex,\n810\t    winner: winner.toBase58(),\n811\t  };\n812\t}\n813\t\n814\texport async function settleRound(\n815\t  deps: SettleTxDeps,\n816\t  pda: string,\n817\t): Promise<SettleResult> {\n818\t  const round = await deps.db.getRoundByPda(pda);\n819\t  if (!round) {\n820\t    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n821\t  }\n822\t\n823\t  if (round.game === \"potshot\") {\n824\t    return settleLordRound(deps, pda);\n825\t  }\n826\t\n827\t  return settleMatch(deps, pda);\n828\t}\n829\t\n830\t// ---------------------------------------------------------------------------\n831\t// Close Call — transaction builders\n832\t// ---------------------------------------------------------------------------\n833\t\n834\tfunction deriveCloseCallConfigPda(): [PublicKey, number] {\n835\t  return PublicKey.findProgramAddressSync(\n836\t    [Buffer.from(\"closecall_config\")],\n837\t    CLOSECALL_PROGRAM_ID,\n838\t  );\n839\t}\n840\t\n841\t\n842\tfunction minuteTsToBuffer(ts: bigint): Buffer {\n843\t  const buf = Buffer.alloc(8);\n844\t  buf.writeBigInt64LE(ts);\n845\t  return buf;\n846\t}\n847\t\n848\tfunction deriveCloseCallRoundPda(minuteTs: bigint): [PublicKey, number] {\n849\t  return PublicKey.findProgramAddressSync(\n850\t    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n851\t    CLOSECALL_PROGRAM_ID,\n852\t  );\n853\t}\n854\t\n855\t/** Encode closecall instruction data: discriminator(8) + minute_ts(i64 LE, 8) = 16 bytes */\n856\tfunction encodeCcMinuteTsData(discriminator: Buffer, minuteTs: bigint): Buffer {\n857\t  const buf = Buffer.alloc(16);\n858\t  discriminator.copy(buf, 0);\n859\t  buf.writeBigInt64LE(minuteTs, 8);\n860\t  return buf;\n861\t}\n862\t\n863\t/** Encode closecall settle_round data: disc(8) + minute_ts(i64 LE, 8) + close_price(i64 LE, 8) + close_price_expo(i32 LE, 4) = 28 bytes */\n864\tfunction encodeCcSettleData(discriminator: Buffer, minuteTs: bigint, price: bigint, expo: number): Buffer {\n865\t  const buf = Buffer.alloc(28);\n866\t  discriminator.copy(buf, 0);\n867\t  buf.writeBigInt64LE(minuteTs, 8);\n868\t  buf.writeBigInt64LE(price, 16);\n869\t  buf.writeInt32LE(expo, 24);\n870\t  return buf;\n871\t}\n872\t\n873\t/**\n874\t * Encode closecall bet data:\n875\t * disc(8) + minute_ts(i64 LE, 8) + side(1) + amount(u64 LE, 8) + open_price(i64 LE, 8) + open_price_expo(i32 LE, 4) = 37 bytes\n876\t */\n877\tfunction encodeCcBetData(\n878\t  discriminator: Buffer,\n879\t  minuteTs: bigint,\n880\t  side: number,\n881\t  amount: bigint,\n882\t  openPrice: bigint,\n883\t  openPriceExpo: number,\n884\t): Buffer {\n885\t  const buf = Buffer.alloc(37);\n886\t  discriminator.copy(buf, 0);\n887\t  buf.writeBigInt64LE(minuteTs, 8);\n888\t  buf.writeUInt8(side, 16);\n889\t  buf.writeBigUInt64LE(amount, 17);\n890\t  buf.writeBigInt64LE(openPrice, 25);\n891\t  buf.writeInt32LE(openPriceExpo, 33);\n892\t  return buf;\n893\t}\n894\t\n895\texport interface CloseCallTxDeps {\n896\t  connection: Connection;\n897\t  serverKeypair: Keypair;\n898\t}\n899\t\n900\t/**\n901\t * Build a `bet` instruction (no transaction wrapping).\n902\t *\n903\t * Two signers: player (pays bet) + server (pays rent on first call).\n904\t * Price + bet info passed as instruction args.\n905\t * Uses init_if_needed — works for both round creation and joining.\n906\t */\n907\texport function buildCloseCallBetIx(\n908\t  serverPubkey: PublicKey,\n909\t  playerPubkey: PublicKey,\n910\t  minuteTs: bigint,\n911\t  side: number,\n912\t  amountLamports: bigint,\n913\t  openPrice: bigint,\n914\t  openPriceExpo: number,\n915\t): TransactionInstruction {\n916\t  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n917\t  const [configPda] = deriveCloseCallConfigPda();\n918\t  const data = encodeCcBetData(\n919\t    CC_BET_DISCRIMINATOR,\n920\t    minuteTs,\n921\t    side,\n922\t    amountLamports,\n923\t    openPrice,\n924\t    openPriceExpo,\n925\t  );\n926\t\n927\t  return new TransactionInstruction({\n928\t    keys: [\n929\t      { pubkey: playerPubkey, isSigner: true, isWritable: true },  // player (pays bet)\n930\t      { pubkey: serverPubkey, isSigner: true, isWritable: true },  // server (pays rent on first call)\n931\t      { pubkey: configPda, isSigner: false, isWritable: false },   // config\n932\t      { pubkey: roundPda, isSigner: false, isWritable: true },     // round\n933\t      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n934\t    ],\n935\t    programId: CLOSECALL_PROGRAM_ID,\n936\t    data,\n937\t  });\n938\t}\n939\t\n940\t/**\n941\t * Build a `settle_round` instruction (no transaction wrapping).\n942\t * Price is passed as instruction args (no on-chain Pyth account).\n943\t */\n944\texport function buildCloseCallSettleRoundIx(\n945\t  serverPubkey: PublicKey,\n946\t  minuteTs: bigint,\n947\t  closePrice: bigint,\n948\t  closePriceExpo: number,\n949\t  treasury: PublicKey,\n950\t  winnerAccounts: PublicKey[],\n951\t): TransactionInstruction {\n952\t  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n953\t  const [platformConfigPda] = derivePlatformConfigPda();\n954\t  const data = encodeCcSettleData(CC_SETTLE_ROUND_DISCRIMINATOR, minuteTs, closePrice, closePriceExpo);\n955\t\n956\t  return new TransactionInstruction({\n957\t    keys: [\n958\t      { pubkey: serverPubkey, isSigner: true, isWritable: true },\n959\t      { pubkey: roundPda, isSigner: false, isWritable: true },\n960\t      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n961\t      { pubkey: treasury, isSigner: false, isWritable: true },\n962\t      { pubkey: serverPubkey, isSigner: false, isWritable: true },\n963\t      ...winnerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n964\t    ],\n965\t    programId: CLOSECALL_PROGRAM_ID,\n966\t    data,\n967\t  });\n968\t}\n969\t\n970\t/**\n971\t * Build a partially-signed `bet` transaction for the Close Call program.\n972\t *\n973\t * Two signers: player (pays bet) + server (pays rent on first call via init_if_needed).\n974\t * Server signs immediately; the frontend must add the player signature before submitting.\n975\t * Works for both round creation (first bet) and joining (subsequent bets).\n976\t */\n977\texport async function buildCloseCallBetTx(\n978\t  deps: CloseCallTxDeps,\n979\t  playerPubkey: PublicKey,\n980\t  minuteTs: bigint,\n981\t  side: number,\n982\t  amountLamports: bigint,\n983\t  openPrice: bigint,\n984\t  openPriceExpo: number,\n985\t): Promise<{ tx: Transaction; roundPda: PublicKey }> {\n986\t  const { connection, serverKeypair } = deps;\n987\t\n988\t  const instruction = buildCloseCallBetIx(\n989\t    serverKeypair.publicKey,\n990\t    playerPubkey,\n991\t    minuteTs,\n992\t    side,\n993\t    amountLamports,\n994\t    openPrice,\n995\t    openPriceExpo,\n996\t  );\n997\t\n998\t  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n999\t\n1000\t  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n1001\t  const tx = new Transaction({ feePayer: playerPubkey, blockhash, lastValidBlockHeight });\n1002\t  tx.add(instruction);\n1003\t  tx.partialSign(serverKeypair);\n1004\t\n1005\t  return { tx, roundPda };\n1006\t}\n1007\t\n1008\t/**\n1009\t * Build a signed `settle_round` transaction for the Close Call program.\n1010\t *\n1011\t * Price is passed as instruction args. Winners (or all players for refund)\n1012\t * are passed as remaining accounts for auto-payout.\n1013\t */\n1014\texport async function buildCloseCallSettleRoundTx(\n1015\t  deps: CloseCallTxDeps,\n1016\t  minuteTs: bigint,\n1017\t  closePrice: bigint,\n1018\t  closePriceExpo: number,\n1019\t  treasury: PublicKey,\n1020\t  winnerAccounts: PublicKey[],\n1021\t): Promise<Transaction> {\n1022\t  const { connection, serverKeypair } = deps;\n1023\t\n1024\t  const instruction = buildCloseCallSettleRoundIx(\n1025\t    serverKeypair.publicKey,\n1026\t    minuteTs,\n1027\t    closePrice,\n1028\t    closePriceExpo,\n1029\t    treasury,\n1030\t    winnerAccounts,\n1031\t  );\n1032\t\n1033\t  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n1034\t  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n1035\t  tx.add(instruction);\n1036\t  tx.sign(serverKeypair);\n1037\t\n1038\t  return tx;\n1039\t}\n1040\t\n1041\t/**\n1042\t * Build a signed `timeout_refund` transaction for the Close Call program.\n1043\t *\n1044\t * Permissionless after the resolve deadline. Refunds all players their exact\n1045\t * deposit via remaining accounts.\n1046\t */\n1047\texport async function buildCloseCallTimeoutRefundTx(\n1048\t  deps: CloseCallTxDeps,\n1049\t  minuteTs: bigint,\n1050\t  playerAccounts: PublicKey[],\n1051\t): Promise<Transaction> {\n1052\t  const { connection, serverKeypair } = deps;\n1053\t\n1054\t  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n1055\t  const [configPda] = deriveCloseCallConfigPda();\n1056\t  const data = encodeCcMinuteTsData(CC_TIMEOUT_REFUND_DISCRIMINATOR, minuteTs);\n1057\t\n1058\t  const keys = [\n1059\t    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller\n1060\t    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round\n1061\t    { pubkey: configPda, isSigner: false, isWritable: false },               // closecall_config\n1062\t    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)\n1063\t    ...playerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n1064\t  ];\n1065\t\n1066\t  const instruction = new TransactionInstruction({\n1067\t    keys,\n1068\t    programId: CLOSECALL_PROGRAM_ID,\n1069\t    data,\n1070\t  });\n1071\t\n1072\t  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n1073\t  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n1074\t  tx.add(instruction);\n1075\t  tx.sign(serverKeypair);\n1076\t\n1077\t  return tx;\n1078\t}\n1079\t\n1080\t// ---------------------------------------------------------------------------\n1081\t// Error types\n1082\t// ---------------------------------------------------------------------------\n1083\t\n1084\t/** Permanent failure — should not be retried. */\n1085\texport class PermanentSettleError extends Error {\n1086\t  readonly permanent = true;\n1087\t  constructor(message: string) {\n1088\t    super(message);\n1089\t    this.name = \"PermanentSettleError\";\n1090\t  }\n1091\t}\n1092\t\n1093\t/** Transient failure — safe to retry. */\n1094\texport class TransientSettleError extends Error {\n1095\t  readonly permanent = false;\n1096\t  constructor(message: string) {\n1097\t    super(message);\n1098\t    this.name = \"TransientSettleError\";\n1099\t  }\n1100\t}\n1101\t\n1102\t/** Entropy expired from SlotHashes — settlement is impossible until timeout refund. */\n1103\texport class EntropyExpiredSettleError extends Error {\n1104\t  readonly entropyExpired = true;\n1105\t  constructor(message: string) {\n1106\t    super(message);\n1107\t    this.name = \"EntropyExpiredSettleError\";\n1108\t  }\n1109\t}\n1110\t"}]},"parent_tool_use_id":null,"session_id":"79c40dda-28eb-4d1c-9c15-a70e69774dd2","uuid":"c79c872a-cf89-477a-91af-902c8b9e3fed","timestamp":"2026-05-01T19:56:58.306Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/worker/settle-tx.ts","content":"/**\n * Settle transaction builder + submission.\n *\n * Retrieves the stored secret, reads on-chain match + config data to resolve\n * all accounts, builds the `settle` instruction, submits it, and updates the\n * DB on confirmation.\n */\n\nimport { createHash } from \"node:crypto\";\nimport { performance } from \"node:perf_hooks\";\nimport {\n  Connection,\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n  TransactionInstruction,\n} from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport { calculateFeeAllocation } from \"../db/fee-accounting.js\";\nimport { logger } from \"../logger.js\";\nimport { emitEvent } from \"../queue/emit-event.js\";\nimport { EventTypes } from \"../queue/event-types.js\";\nimport { FLIPYOU_PROGRAM_ID, POTSHOT_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { derivePlatformConfigPda, getPlatformConfig } from \"../platform-config.js\";\nimport { FlipYouIDL as flipyouIdl, PotShotIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@taunt-bet/anchor-client\";\nimport {\n  decodeFlipYouMatch,\n  decodeLordRound,\n  type DecodedPotShotRound,\n} from \"./account-decoder.js\";\n\n// ---------------------------------------------------------------------------\n// Instruction discriminators (from IDL — no hardcoded byte arrays)\n// ---------------------------------------------------------------------------\n\nfunction getInstructionDiscriminator(\n  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n  instructionName: string,\n): Buffer {\n  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n  if (!instruction) {\n    throw new Error(`Instruction ${instructionName} not found in IDL`);\n  }\n  return Buffer.from(instruction.discriminator);\n}\n\nconst SETTLE_DISCRIMINATOR = getInstructionDiscriminator(flipyouIdl, \"settle\");\nconst CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n  lordIdl,\n  \"claim_payout\",\n);\nconst CC_BET_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"bet\");\nconst CC_SETTLE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"settle_round\");\nconst CC_TIMEOUT_REFUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"timeout_refund\");\nconst SLOT_HASHES_WINDOW_SLOTS = 512n;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface SettleTxDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  entropyAccount: PublicKey;\n  referralDefaultRateBps: number;\n}\n\nexport interface SettleResult {\n  txSignature: string;\n  resultHash: Buffer;\n  resultSide?: number;\n  winningEntryIndex?: number;\n  winner: string;\n}\n\n// ---------------------------------------------------------------------------\n// Instruction encoding\n// ---------------------------------------------------------------------------\n\n/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\nfunction encodeSettleData(secret: Buffer): Buffer {\n  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n}\n\nfunction encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n}\n\n// ---------------------------------------------------------------------------\n// Result derivation (mirrors on-chain derive_result)\n// ---------------------------------------------------------------------------\n\n/**\n * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n * Must match shared/src/fairness.rs `derive_result()`.\n */\nfunction deriveResult(\n  secret: Buffer,\n  entropy: Buffer,\n  matchPdaBytes: Buffer,\n  algoVer: number,\n): Buffer {\n  return createHash(\"sha256\")\n    .update(secret)\n    .update(entropy)\n    .update(matchPdaBytes)\n    .update(Buffer.from([algoVer]))\n    .digest();\n}\n\n// ---------------------------------------------------------------------------\n// Fee allocation + referral earnings hook\n// ---------------------------------------------------------------------------\n\n/**\n * After a game settles, write one `fee_allocation_events` row per unique\n * player (referred or not), and an additional `referral_earnings` row for\n * referred players.\n *\n * For each unique player: look up profile + referral link → compute the\n * deterministic fee split via `calculateFeeAllocation` → write the\n * allocation row. If a referrer is present, also write the legacy\n * `referral_earnings` row.\n *\n * Errors are logged but never bubble — accounting must not fail settlement.\n * Idempotency: `fee_allocation_events` UNIQUE on (source_type, source_id,\n * wallet) plus `ON CONFLICT DO NOTHING` in `insertFeeAllocation`;\n * `referral_earnings` UNIQUE on (referee_user_id, round_id).\n */\nasync function recordReferralEarnings(\n  db: Db,\n  params: {\n    roundId: string;\n    gameType: string;\n    feeBps: number;\n    referralDefaultRateBps: number;\n    players: Array<{ wallet: string; wagerLamports: number }>;\n  },\n): Promise<void> {\n  const { roundId, gameType, feeBps, referralDefaultRateBps, players } = params;\n\n  // Deduplicate players (Pot Shot can have multiple entries per player)\n  const playerWagers = new Map<string, number>();\n  for (const p of players) {\n    playerWagers.set(p.wallet, (playerWagers.get(p.wallet) ?? 0) + p.wagerLamports);\n  }\n\n  for (const [wallet, wagerLamports] of playerWagers) {\n    try {\n      const refereeProfile = await db.getProfileByWallet(wallet);\n      const link = refereeProfile\n        ? await db.getReferralLinkByRefereeUserId(refereeProfile.user_id)\n        : undefined;\n\n      const referrerRateBps = link\n        ? await db.getReferrerRate(link.referrer_user_id, referralDefaultRateBps)\n        : 0;\n\n      const feeLamports = Math.floor((wagerLamports * feeBps) / 10_000);\n      const allocation = calculateFeeAllocation(feeLamports, referrerRateBps);\n\n      await db.insertFeeAllocation({\n        sourceType: gameType,\n        sourceId: roundId,\n        gameType,\n        wallet,\n        userId: refereeProfile?.user_id ?? null,\n        wagerLamports,\n        feeLamports,\n        referrerUserId: link?.referrer_user_id ?? null,\n        referralRateBps: referrerRateBps,\n        referralLamports: allocation.referralLamports,\n        promotionsLamports: allocation.promotionsLamports,\n        profitLamports: allocation.profitLamports,\n      });\n\n      if (link && refereeProfile) {\n        await db.insertReferralEarning({\n          referrerUserId: link.referrer_user_id,\n          refereeUserId: refereeProfile.user_id,\n          referrerWallet: link.referrer_wallet,\n          refereeWallet: wallet,\n          roundId,\n          gameType,\n          wagerLamports,\n          feeLamports,\n          referrerEarnedLamports: allocation.referralLamports,\n          referrerRateBps,\n        });\n\n        logger.info(\"referral earning recorded\", {\n          roundId,\n          gameType,\n          referrerUserId: link.referrer_user_id,\n          refereeUserId: refereeProfile.user_id,\n          referrerEarnedLamports: allocation.referralLamports,\n        });\n      }\n    } catch (err: unknown) {\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"duplicate key\") || msg.includes(\"unique constraint\")) {\n        logger.info(\"fee accounting row already recorded (idempotent skip)\", {\n          roundId,\n          wallet,\n        });\n      } else {\n        logger.error(\"failed to record fee accounting row\", {\n          roundId,\n          wallet,\n          error: msg,\n        });\n      }\n    }\n  }\n}\n\n// ---------------------------------------------------------------------------\n// Core settle function\n// ---------------------------------------------------------------------------\n\n/**\n * Build, submit, and confirm a settle transaction for a locked match.\n *\n * Steps:\n * 1. Retrieve secret from DB\n * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n * 3. Fetch config account data (treasury)\n * 4. Read entropy from the entropy account\n * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n * 6. Build + submit settle tx\n * 7. Update DB on confirmation\n */\nexport async function settleMatch(\n  deps: SettleTxDeps,\n  pda: string,\n): Promise<SettleResult> {\n  const t0 = performance.now();\n  const { db, connection, serverKeypair, entropyAccount } = deps;\n  const matchPubkey = new PublicKey(pda);\n\n  // 1. Retrieve secret from DB\n  const round = await db.getRoundByPda(pda);\n  const tDb = performance.now();\n  if (!round) {\n    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n  }\n  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n    throw new PermanentSettleError(\n      `Round ${pda} in unexpected phase: ${round.phase}`,\n    );\n  }\n\n  const secret = Buffer.from(round.secret);\n\n  // Transition to settling (locked → settling)\n  if (round.phase === \"locked\") {\n    await db.updateRoundPhase(pda, \"settling\");\n  }\n\n  // Log settle_submitted\n  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n    attempt: round.settle_attempts + 1,\n  });\n\n  // 2-4. Fetch match, platform config, entropy, and blockhash in parallel\n  const [platformConfigPda] = derivePlatformConfigPda();\n  const [matchAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n    await Promise.all([\n      connection.getAccountInfo(matchPubkey),\n      getPlatformConfig(connection),\n      connection.getAccountInfo(entropyAccount),\n      connection.getLatestBlockhash(),\n    ]);\n  const tFetch = performance.now();\n\n  if (!matchAccountInfo) {\n    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n  }\n  if (!entropyInfo) {\n    throw new TransientSettleError(\"Entropy account not available yet\");\n  }\n\n  // IDL-driven decode — no manual byte offsets\n  const match = decodeFlipYouMatch(Buffer.from(matchAccountInfo.data));\n  const { feeBps, treasury } = platformConfig;\n\n  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer, targetSlot } = match;\n\n  const currentSlot = BigInt(await connection.getSlot(\"confirmed\"));\n  if (\n    targetSlot > 0n &&\n    currentSlot > targetSlot &&\n    currentSlot - targetSlot > SLOT_HASHES_WINDOW_SLOTS\n  ) {\n    throw new EntropyExpiredSettleError(\n      `FlipYou entropy expired for target slot ${targetSlot.toString()} (current slot ${currentSlot.toString()}); waiting for timeout refund`,\n    );\n  }\n\n  const pool = entryAmount * 2n;\n  const feeAmount = Number((pool * BigInt(feeBps)) / 10_000n);\n  const payoutAmount = Number(pool) - feeAmount;\n\n  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n\n  // 5. Pre-compute result\n  const matchPdaBytes = matchPubkey.toBuffer();\n  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n  const resultSide = resultHash[0]! % 2;\n  const winner = resultSide === creatorSide ? creator : opponent;\n\n  // 6. Build settle instruction (8 accounts, no profile CPI)\n  const data = encodeSettleData(secret);\n\n  const instruction = new TransactionInstruction({\n    keys: [\n      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // flipyou_match\n      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n      {\n        pubkey: SystemProgram.programId,\n        isSigner: false,\n        isWritable: false,\n      }, // system_program\n    ],\n    programId: FLIPYOU_PROGRAM_ID,\n    data,\n  });\n\n  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n\n  const tx = new Transaction({\n    feePayer: serverKeypair.publicKey,\n    blockhash,\n    lastValidBlockHeight,\n  });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  // 7. Submit and confirm\n  const rawTx = tx.serialize();\n  const tBuild = performance.now();\n  const txSignature = await connection.sendRawTransaction(rawTx, {\n    skipPreflight: false,\n  });\n  const tSend = performance.now();\n\n  logger.info(\"settlement transaction submitted\", {\n    pda,\n    txSignature,\n    attempt: round.settle_attempts + 1,\n    dbMs: Math.round(tDb - t0),\n    fetchMs: Math.round(tFetch - tDb),\n    buildMs: Math.round(tBuild - tFetch),\n    sendMs: Math.round(tSend - tBuild),\n  });\n\n  const confirmation = await connection.confirmTransaction(\n    { signature: txSignature, blockhash, lastValidBlockHeight },\n    \"confirmed\",\n  );\n  const tConfirm = performance.now();\n  if (confirmation.value.err) {\n    throw new TransientSettleError(\n      `FlipYou settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n    );\n  }\n\n  // 8. Update DB — phase settling → settled (atomic transaction)\n  const flipyouEntries = [\n    { player: creator.toBase58(), amountLamports: Number(entryAmount) },\n    { player: opponent.toBase58(), amountLamports: Number(entryAmount) },\n  ];\n\n  await db.withTransaction(async (txDb) => {\n    await txDb.updateRoundPhase(pda, \"settled\", {\n      settle_tx: txSignature,\n      result_hash: resultHash,\n      result_side: resultSide,\n      winner: winner.toBase58(),\n      settle_attempts: round.settle_attempts + 1,\n    });\n\n    // Game entries for leaderboard/stats — UPSERT updates existing (creator) and inserts new (joiner)\n    const loser = winner.equals(creator) ? opponent : creator;\n    const [winnerProfile, loserProfile] = await Promise.all([\n      txDb.getProfileByWallet(winner.toBase58()),\n      txDb.getProfileByWallet(loser.toBase58()),\n    ]);\n    if (!winnerProfile || !loserProfile) {\n      logger.warn(\"flipyou settle: missing profile for participant — skipping game entries\", {\n        pda,\n        winnerWallet: winner.toBase58(),\n        loserWallet: loser.toBase58(),\n        winnerProfileExists: !!winnerProfile,\n        loserProfileExists: !!loserProfile,\n      });\n    } else {\n      await txDb.upsertGameEntries([\n        {\n          userId: winnerProfile.user_id,\n          wallet: winner.toBase58(),\n          game: \"flipyou\",\n          roundPda: pda,\n          matchId: round.match_id,\n          amountLamports: Number(entryAmount),\n          isWinner: true,\n          payoutLamports: payoutAmount,\n          settledAt: new Date(),\n        },\n        {\n          userId: loserProfile.user_id,\n          wallet: loser.toBase58(),\n          game: \"flipyou\",\n          roundPda: pda,\n          matchId: round.match_id,\n          amountLamports: Number(entryAmount),\n          isWinner: false,\n          payoutLamports: 0,\n          settledAt: new Date(),\n        },\n      ]);\n    }\n\n    // Log settle_confirmed\n    await txDb.insertOperatorEvent(pda, \"settle_confirmed\", {\n      txSignature,\n      resultSide,\n      winner: winner.toBase58(),\n      entropy: entropy.toString(\"hex\"),\n      payoutAmount,\n      feeAmount,\n      entries: flipyouEntries,\n    });\n\n    // Write payout transaction for the winner\n    await txDb.insertTransaction({\n      userId: winnerProfile?.user_id,\n      wallet: winner.toBase58(),\n      game: \"flipyou\",\n      matchId: round.match_id,\n      txType: \"payout\",\n      amountLamports: payoutAmount,\n      txSig: txSignature,\n    });\n\n    // Referral earnings hook — in same transaction for atomicity (System Invariant 4)\n    await recordReferralEarnings(txDb, {\n      roundId: round.match_id,\n      gameType: \"flipyou\",\n      feeBps,\n      referralDefaultRateBps: deps.referralDefaultRateBps,\n      players: [\n        { wallet: creator.toBase58(), wagerLamports: Number(entryAmount) },\n        { wallet: opponent.toBase58(), wagerLamports: Number(entryAmount) },\n      ],\n    });\n\n    // Emit game.settled event for challenge engine (async, downstream handlers dedupe)\n    const settledAt = new Date().toISOString();\n    const creatorUserId = winner.equals(creator) ? winnerProfile?.user_id : loserProfile?.user_id;\n    const opponentUserId = winner.equals(creator) ? loserProfile?.user_id : winnerProfile?.user_id;\n    await emitEvent(txDb.rawSql, EventTypes.GAME_SETTLED, {\n      roundId: round.match_id,\n      roundPda: pda,\n      game: \"flipyou\",\n      players: [\n        {\n          userId: creatorUserId ?? creator.toBase58(),\n          wallet: creator.toBase58(),\n          amountLamports: String(entryAmount),\n          isWinner: winner.equals(creator),\n          payoutLamports: winner.equals(creator) ? String(payoutAmount) : \"0\",\n          isCreator: true,\n        },\n        {\n          userId: opponentUserId ?? opponent.toBase58(),\n          wallet: opponent.toBase58(),\n          amountLamports: String(entryAmount),\n          isWinner: winner.equals(opponent),\n          payoutLamports: winner.equals(opponent) ? String(payoutAmount) : \"0\",\n          isCreator: false,\n        },\n      ],\n      feeLamports: String(feeAmount),\n      settledAt,\n    });\n\n    // Emit ticker publish for the on-site news ticker\n    await emitEvent(txDb.rawSql, EventTypes.TICKER_PUBLISH, {\n      kind: \"flipyou.match_settled\",\n      winnerName: winnerProfile?.username,\n      side: resultSide === 0 ? \"heads\" : \"tails\",\n      amountLamports: String(payoutAmount),\n    });\n  });\n\n  const tDone = performance.now();\n  logger.info(\"settlement transaction confirmed\", {\n    pda,\n    txSignature,\n    resultSide,\n    winner: winner.toBase58(),\n    timing: {\n      dbMs: Math.round(tDb - t0),\n      fetchMs: Math.round(tFetch - tDb),\n      buildMs: Math.round(tBuild - tFetch),\n      sendMs: Math.round(tSend - tBuild),\n      confirmMs: Math.round(tConfirm - tSend),\n      dbWriteMs: Math.round(tDone - tConfirm),\n      totalMs: Math.round(tDone - t0),\n    },\n  });\n\n  return {\n    txSignature,\n    resultHash,\n    resultSide,\n    winner: winner.toBase58(),\n  };\n}\n\nexport async function settleLordRound(\n  deps: SettleTxDeps,\n  pda: string,\n): Promise<SettleResult> {\n  const t0 = performance.now();\n  const { db, connection, serverKeypair, entropyAccount } = deps;\n  const roundPubkey = new PublicKey(pda);\n\n  const round = await db.getRoundByPda(pda);\n  const tDb = performance.now();\n  if (!round) {\n    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n  }\n  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n    throw new PermanentSettleError(\n      `Round ${pda} in unexpected phase: ${round.phase}`,\n    );\n  }\n\n  const secret = Buffer.from(round.secret);\n\n  if (round.phase === \"locked\") {\n    await db.updateRoundPhase(pda, \"settling\");\n  }\n\n  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n    attempt: round.settle_attempts + 1,\n    game: \"potshot\",\n  });\n\n  const [platformConfigPda] = derivePlatformConfigPda();\n  const [roundAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n    await Promise.all([\n      connection.getAccountInfo(roundPubkey),\n      getPlatformConfig(connection),\n      connection.getAccountInfo(entropyAccount),\n      connection.getLatestBlockhash(),\n    ]);\n\n  const tFetch = performance.now();\n\n  if (!roundAccountInfo) {\n    throw new PermanentSettleError(`Lord round account not found on-chain: ${pda}`);\n  }\n  if (!entropyInfo) {\n    throw new TransientSettleError(\"Entropy account not available yet\");\n  }\n\n  // IDL-driven decode — no manual byte offsets or parseLordRound()\n  const roundData: DecodedPotShotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n  const { feeBps, treasury } = platformConfig;\n\n  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n  const resultHash = deriveResult(\n    secret,\n    entropy,\n    roundPubkey.toBuffer(),\n    roundData.algorithmVer,\n  );\n  const feeAmount = Number((roundData.totalAmountLamports * BigInt(feeBps)) / 10_000n);\n  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n\n  const raw = resultHash.readBigUInt64LE(0);\n  const winningOffset = raw % roundData.totalAmountLamports;\n\n  let cumulative = 0n;\n  let winnerEntryIndex = -1;\n  let winner = roundData.entries[0]?.player;\n  for (const [index, entry] of roundData.entries.entries()) {\n    cumulative += entry.amountLamports;\n    if (winningOffset < cumulative) {\n      winnerEntryIndex = index;\n      winner = entry.player;\n      break;\n    }\n  }\n\n  if (!winner || winnerEntryIndex < 0) {\n    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n  }\n\n  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n  const instruction = new TransactionInstruction({\n    keys: [\n      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n      { pubkey: treasury, isSigner: false, isWritable: true },\n      { pubkey: winner, isSigner: false, isWritable: true },\n      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n    ],\n    programId: POTSHOT_PROGRAM_ID,\n    data: encodeClaimPayoutData(matchIdBuf, secret),\n  });\n\n  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n  const tx = new Transaction({\n    feePayer: serverKeypair.publicKey,\n    blockhash,\n    lastValidBlockHeight,\n  });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  const tBuild = performance.now();\n  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n    skipPreflight: false,\n  });\n  const tSend = performance.now();\n\n  logger.info(\"lord settlement transaction submitted\", {\n    pda,\n    txSignature,\n    attempt: round.settle_attempts + 1,\n    winningEntryIndex: winnerEntryIndex,\n    dbMs: Math.round(tDb - t0),\n    fetchMs: Math.round(tFetch - tDb),\n    buildMs: Math.round(tBuild - tFetch),\n    sendMs: Math.round(tSend - tBuild),\n  });\n\n  const confirmation = await connection.confirmTransaction(\n    { signature: txSignature, blockhash, lastValidBlockHeight },\n    \"confirmed\",\n  );\n  const tConfirm = performance.now();\n  if (confirmation.value.err) {\n    throw new TransientSettleError(\n      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n    );\n  }\n\n  const serializedEntries = roundData.entries.map((e) => ({\n    player: e.player.toBase58(),\n    amountLamports: Number(e.amountLamports),\n  }));\n\n  await db.withTransaction(async (txDb) => {\n    await txDb.updateRoundPhase(pda, \"settled\", {\n      settle_tx: txSignature,\n      result_hash: resultHash,\n      result_side: winnerEntryIndex,\n      winner: winner.toBase58(),\n      settle_attempts: round.settle_attempts + 1,\n    });\n\n    // Game entries — aggregate per player, resolve profiles for user_id\n    const playerTotals = new Map<string, number>();\n    for (const e of serializedEntries) {\n      playerTotals.set(e.player, (playerTotals.get(e.player) ?? 0) + e.amountLamports);\n    }\n    const winnerKey = winner.toBase58();\n    const profileResults = await Promise.all(\n      [...playerTotals.keys()].map(async (wallet) => {\n        const profile = await txDb.getProfileByWallet(wallet);\n        return [wallet, profile] as const;\n      }),\n    );\n    const missingWallets = profileResults.filter(([, p]) => !p).map(([w]) => w);\n    if (missingWallets.length > 0) {\n      logger.warn(\"lord settle: missing profiles for participants — skipping their game entries\", {\n        pda,\n        missingWallets,\n      });\n    }\n    const profileMap = new Map(\n      profileResults.filter((r): r is [string, NonNullable<(typeof r)[1]>] => !!r[1]),\n    );\n    const entriesToUpsert = [...playerTotals.entries()]\n      .filter(([wallet]) => profileMap.has(wallet))\n      .map(([wallet, amount]) => ({\n        userId: profileMap.get(wallet)!.user_id,\n        wallet,\n        game: \"potshot\",\n        roundPda: pda,\n        matchId: round.match_id,\n        amountLamports: amount,\n        isWinner: wallet === winnerKey,\n        payoutLamports: wallet === winnerKey ? payoutAmount : 0,\n        settledAt: new Date(),\n      }));\n    if (entriesToUpsert.length > 0) {\n      await txDb.upsertGameEntries(entriesToUpsert);\n    }\n\n    await txDb.insertOperatorEvent(pda, \"settle_confirmed\", {\n      txSignature,\n      winner: winner.toBase58(),\n      winningEntryIndex: winnerEntryIndex,\n      game: \"potshot\",\n      entropy: entropy.toString(\"hex\"),\n      winningOffset: winningOffset.toString(),\n      totalAmountLamports: Number(roundData.totalAmountLamports),\n      payoutAmount,\n      feeAmount,\n      rentRefund,\n      entries: serializedEntries,\n    });\n\n    // Write payout transaction for the winner\n    await txDb.insertTransaction({\n      userId: profileMap.get(winnerKey)?.user_id,\n      wallet: winner.toBase58(),\n      game: \"potshot\",\n      matchId: round.match_id,\n      txType: \"payout\",\n      amountLamports: payoutAmount,\n      txSig: txSignature,\n    });\n\n    // Referral earnings hook — in same transaction for atomicity (System Invariant 4)\n    await recordReferralEarnings(txDb, {\n      roundId: round.match_id,\n      gameType: \"potshot\",\n      feeBps,\n      referralDefaultRateBps: deps.referralDefaultRateBps,\n      players: serializedEntries.map((e) => ({\n        wallet: e.player,\n        wagerLamports: e.amountLamports,\n      })),\n    });\n\n    // Emit game.settled event for challenge engine (async, downstream handlers dedupe)\n    const settledAt = new Date().toISOString();\n    // Aggregate per-player totals for lord (a player may have multiple entries)\n    const playerAgg = new Map<string, { total: bigint; isWinner: boolean }>();\n    for (const e of serializedEntries) {\n      const existing = playerAgg.get(e.player);\n      playerAgg.set(e.player, {\n        total: (existing?.total ?? 0n) + BigInt(e.amountLamports),\n        isWinner: existing?.isWinner || e.player === winnerKey,\n      });\n    }\n    await emitEvent(txDb.rawSql, EventTypes.GAME_SETTLED, {\n      roundId: round.match_id,\n      roundPda: pda,\n      game: \"potshot\",\n      players: [...playerAgg.entries()].map(([wallet, agg]) => ({\n        userId: profileMap.get(wallet)?.user_id ?? wallet,\n        wallet,\n        amountLamports: String(agg.total),\n        isWinner: agg.isWinner,\n        payoutLamports: agg.isWinner ? String(payoutAmount) : \"0\",\n        isCreator: serializedEntries[0]?.player === wallet, // first entry is creator\n      })),\n      feeLamports: String(feeAmount),\n      settledAt,\n    });\n\n    // Emit ticker publish for the on-site news ticker\n    await emitEvent(txDb.rawSql, EventTypes.TICKER_PUBLISH, {\n      kind: \"potshot.round_settled\",\n      winnerName: profileMap.get(winnerKey)?.username,\n      prizeLamports: String(payoutAmount),\n      totalEntries: serializedEntries.length,\n    });\n  });\n\n  const tDone = performance.now();\n  logger.info(\"lord settlement transaction confirmed\", {\n    pda,\n    txSignature,\n    winner: winner.toBase58(),\n    winningEntryIndex: winnerEntryIndex,\n    timing: {\n      dbMs: Math.round(tDb - t0),\n      fetchMs: Math.round(tFetch - tDb),\n      buildMs: Math.round(tBuild - tFetch),\n      sendMs: Math.round(tSend - tBuild),\n      confirmMs: Math.round(tConfirm - tSend),\n      dbWriteMs: Math.round(tDone - tConfirm),\n      totalMs: Math.round(tDone - t0),\n    },\n  });\n\n  return {\n    txSignature,\n    resultHash,\n    winningEntryIndex: winnerEntryIndex,\n    winner: winner.toBase58(),\n  };\n}\n\nexport async function settleRound(\n  deps: SettleTxDeps,\n  pda: string,\n): Promise<SettleResult> {\n  const round = await deps.db.getRoundByPda(pda);\n  if (!round) {\n    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n  }\n\n  if (round.game === \"potshot\") {\n    return settleLordRound(deps, pda);\n  }\n\n  return settleMatch(deps, pda);\n}\n\n// ---------------------------------------------------------------------------\n// Close Call — transaction builders\n// ---------------------------------------------------------------------------\n\nfunction deriveCloseCallConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"closecall_config\")],\n    CLOSECALL_PROGRAM_ID,\n  );\n}\n\n\nfunction minuteTsToBuffer(ts: bigint): Buffer {\n  const buf = Buffer.alloc(8);\n  buf.writeBigInt64LE(ts);\n  return buf;\n}\n\nfunction deriveCloseCallRoundPda(minuteTs: bigint): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n    CLOSECALL_PROGRAM_ID,\n  );\n}\n\n/** Encode closecall instruction data: discriminator(8) + minute_ts(i64 LE, 8) = 16 bytes */\nfunction encodeCcMinuteTsData(discriminator: Buffer, minuteTs: bigint): Buffer {\n  const buf = Buffer.alloc(16);\n  discriminator.copy(buf, 0);\n  buf.writeBigInt64LE(minuteTs, 8);\n  return buf;\n}\n\n/** Encode closecall settle_round data: disc(8) + minute_ts(i64 LE, 8) + close_price(i64 LE, 8) + close_price_expo(i32 LE, 4) = 28 bytes */\nfunction encodeCcSettleData(discriminator: Buffer, minuteTs: bigint, price: bigint, expo: number): Buffer {\n  const buf = Buffer.alloc(28);\n  discriminator.copy(buf, 0);\n  buf.writeBigInt64LE(minuteTs, 8);\n  buf.writeBigInt64LE(price, 16);\n  buf.writeInt32LE(expo, 24);\n  return buf;\n}\n\n/**\n * Encode closecall bet data:\n * disc(8) + minute_ts(i64 LE, 8) + side(1) + amount(u64 LE, 8) + open_price(i64 LE, 8) + open_price_expo(i32 LE, 4) = 37 bytes\n */\nfunction encodeCcBetData(\n  discriminator: Buffer,\n  minuteTs: bigint,\n  side: number,\n  amount: bigint,\n  openPrice: bigint,\n  openPriceExpo: number,\n): Buffer {\n  const buf = Buffer.alloc(37);\n  discriminator.copy(buf, 0);\n  buf.writeBigInt64LE(minuteTs, 8);\n  buf.writeUInt8(side, 16);\n  buf.writeBigUInt64LE(amount, 17);\n  buf.writeBigInt64LE(openPrice, 25);\n  buf.writeInt32LE(openPriceExpo, 33);\n  return buf;\n}\n\nexport interface CloseCallTxDeps {\n  connection: Connection;\n  serverKeypair: Keypair;\n}\n\n/**\n * Build a `bet` instruction (no transaction wrapping).\n *\n * Two signers: player (pays bet) + server (pays rent on first call).\n * Price + bet info passed as instruction args.\n * Uses init_if_needed — works for both round creation and joining.\n */\nexport function buildCloseCallBetIx(\n  serverPubkey: PublicKey,\n  playerPubkey: PublicKey,\n  minuteTs: bigint,\n  side: number,\n  amountLamports: bigint,\n  openPrice: bigint,\n  openPriceExpo: number,\n): TransactionInstruction {\n  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n  const [configPda] = deriveCloseCallConfigPda();\n  const data = encodeCcBetData(\n    CC_BET_DISCRIMINATOR,\n    minuteTs,\n    side,\n    amountLamports,\n    openPrice,\n    openPriceExpo,\n  );\n\n  return new TransactionInstruction({\n    keys: [\n      { pubkey: playerPubkey, isSigner: true, isWritable: true },  // player (pays bet)\n      { pubkey: serverPubkey, isSigner: true, isWritable: true },  // server (pays rent on first call)\n      { pubkey: configPda, isSigner: false, isWritable: false },   // config\n      { pubkey: roundPda, isSigner: false, isWritable: true },     // round\n      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n    ],\n    programId: CLOSECALL_PROGRAM_ID,\n    data,\n  });\n}\n\n/**\n * Build a `settle_round` instruction (no transaction wrapping).\n * Price is passed as instruction args (no on-chain Pyth account).\n */\nexport function buildCloseCallSettleRoundIx(\n  serverPubkey: PublicKey,\n  minuteTs: bigint,\n  closePrice: bigint,\n  closePriceExpo: number,\n  treasury: PublicKey,\n  winnerAccounts: PublicKey[],\n): TransactionInstruction {\n  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n  const [platformConfigPda] = derivePlatformConfigPda();\n  const data = encodeCcSettleData(CC_SETTLE_ROUND_DISCRIMINATOR, minuteTs, closePrice, closePriceExpo);\n\n  return new TransactionInstruction({\n    keys: [\n      { pubkey: serverPubkey, isSigner: true, isWritable: true },\n      { pubkey: roundPda, isSigner: false, isWritable: true },\n      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n      { pubkey: treasury, isSigner: false, isWritable: true },\n      { pubkey: serverPubkey, isSigner: false, isWritable: true },\n      ...winnerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n    ],\n    programId: CLOSECALL_PROGRAM_ID,\n    data,\n  });\n}\n\n/**\n * Build a partially-signed `bet` transaction for the Close Call program.\n *\n * Two signers: player (pays bet) + server (pays rent on first call via init_if_needed).\n * Server signs immediately; the frontend must add the player signature before submitting.\n * Works for both round creation (first bet) and joining (subsequent bets).\n */\nexport async function buildCloseCallBetTx(\n  deps: CloseCallTxDeps,\n  playerPubkey: PublicKey,\n  minuteTs: bigint,\n  side: number,\n  amountLamports: bigint,\n  openPrice: bigint,\n  openPriceExpo: number,\n): Promise<{ tx: Transaction; roundPda: PublicKey }> {\n  const { connection, serverKeypair } = deps;\n\n  const instruction = buildCloseCallBetIx(\n    serverKeypair.publicKey,\n    playerPubkey,\n    minuteTs,\n    side,\n    amountLamports,\n    openPrice,\n    openPriceExpo,\n  );\n\n  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n\n  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n  const tx = new Transaction({ feePayer: playerPubkey, blockhash, lastValidBlockHeight });\n  tx.add(instruction);\n  tx.partialSign(serverKeypair);\n\n  return { tx, roundPda };\n}\n\n/**\n * Build a signed `settle_round` transaction for the Close Call program.\n *\n * Price is passed as instruction args. Winners (or all players for refund)\n * are passed as remaining accounts for auto-payout.\n */\nexport async function buildCloseCallSettleRoundTx(\n  deps: CloseCallTxDeps,\n  minuteTs: bigint,\n  closePrice: bigint,\n  closePriceExpo: number,\n  treasury: PublicKey,\n  winnerAccounts: PublicKey[],\n): Promise<Transaction> {\n  const { connection, serverKeypair } = deps;\n\n  const instruction = buildCloseCallSettleRoundIx(\n    serverKeypair.publicKey,\n    minuteTs,\n    closePrice,\n    closePriceExpo,\n    treasury,\n    winnerAccounts,\n  );\n\n  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  return tx;\n}\n\n/**\n * Build a signed `timeout_refund` transaction for the Close Call program.\n *\n * Permissionless after the resolve deadline. Refunds all players their exact\n * deposit via remaining accounts.\n */\nexport async function buildCloseCallTimeoutRefundTx(\n  deps: CloseCallTxDeps,\n  minuteTs: bigint,\n  playerAccounts: PublicKey[],\n): Promise<Transaction> {\n  const { connection, serverKeypair } = deps;\n\n  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n  const [configPda] = deriveCloseCallConfigPda();\n  const data = encodeCcMinuteTsData(CC_TIMEOUT_REFUND_DISCRIMINATOR, minuteTs);\n\n  const keys = [\n    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller\n    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round\n    { pubkey: configPda, isSigner: false, isWritable: false },               // closecall_config\n    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)\n    ...playerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n  ];\n\n  const instruction = new TransactionInstruction({\n    keys,\n    programId: CLOSECALL_PROGRAM_ID,\n    data,\n  });\n\n  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n  tx.add(instruction);\n  tx.sign(serverKeypair);\n\n  return tx;\n}\n\n// ---------------------------------------------------------------------------\n// Error types\n// ---------------------------------------------------------------------------\n\n/** Permanent failure — should not be retried. */\nexport class PermanentSettleError extends Error {\n  readonly permanent = true;\n  constructor(message: string) {\n    super(message);\n    this.name = \"PermanentSettleError\";\n  }\n}\n\n/** Transient failure — safe to retry. */\nexport class TransientSettleError extends Error {\n  readonly permanent = false;\n  constructor(message: string) {\n    super(message);\n    this.name = \"TransientSettleError\";\n  }\n}\n\n/** Entropy expired from SlotHashes — settlement is impossible until timeout refund. */\nexport class EntropyExpiredSettleError extends Error {\n  readonly entropyExpired = true;\n  constructor(message: string) {\n    super(message);\n    this.name = \"EntropyExpiredSettleError\";\n  }\n}\n","numLines":1110,"startLine":1,"totalLines":1110}}}
