{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014LurpEZpfzRedz9VhHV9xn","type":"tool_result","content":"     1→/**\n     2→ * Auth-specific database operations for challenge/response and refresh tokens.\n     3→ * Shares the postgres connection pool via the sql instance passed in.\n     4→ */\n     5→\n     6→import type postgres from \"postgres\";\n     7→\n     8→export interface AuthChallenge {\n     9→  nonce: string;\n    10→  wallet: string;\n    11→  cluster: string;\n    12→  message: string;\n    13→  expires_at: Date;\n    14→  used: boolean;\n    15→  created_at: Date;\n    16→}\n    17→\n    18→export interface RefreshToken {\n    19→  id: string;\n    20→  wallet: string;\n    21→  token_hash: Buffer;\n    22→  family_id: string;\n    23→  expires_at: Date;\n    24→  revoked: boolean;\n    25→  created_at: Date;\n    26→}\n    27→\n    28→export interface AuthDb {\n    29→  insertChallenge(\n    30→    nonce: string,\n    31→    wallet: string,\n    32→    cluster: string,\n    33→    message: string,\n    34→    expiresAt: Date,\n    35→  ): Promise<AuthChallenge>;\n    36→\n    37→  /** Atomically consume a challenge (set used=TRUE). Returns null if already used or not found. */\n    38→  consumeChallenge(nonce: string): Promise<AuthChallenge | null>;\n    39→\n    40→  insertRefreshToken(\n    41→    wallet: string,\n    42→    tokenHash: Buffer,\n    43→    familyId: string,\n    44→    expiresAt: Date,\n    45→  ): Promise<RefreshToken>;\n    46→\n    47→  getRefreshTokenByHash(tokenHash: Buffer): Promise<RefreshToken | null>;\n    48→\n    49→  revokeRefreshToken(id: string): Promise<void>;\n    50→\n    51→  /** Revoke all tokens in a family (stolen-token detection). */\n    52→  revokeTokenFamily(familyId: string): Promise<void>;\n    53→\n    54→  /** Delete expired challenges and revoked/expired refresh tokens. */\n    55→  cleanupExpired(): Promise<void>;\n    56→}\n    57→\n    58→export function createAuthDb(sql: postgres.Sql): AuthDb {\n    59→  return {\n    60→    async insertChallenge(nonce, wallet, cluster, message, expiresAt) {\n    61→      const rows = await sql<AuthChallenge[]>`\n    62→        INSERT INTO auth_challenges (nonce, wallet, cluster, message, expires_at)\n    63→        VALUES (${nonce}, ${wallet}, ${cluster}, ${message}, ${expiresAt.toISOString()})\n    64→        RETURNING *\n    65→      `;\n    66→      return rows[0]!;\n    67→    },\n    68→\n    69→    async consumeChallenge(nonce) {\n    70→      const rows = await sql<AuthChallenge[]>`\n    71→        UPDATE auth_challenges\n    72→        SET used = TRUE\n    73→        WHERE nonce = ${nonce}\n    74→          AND used = FALSE\n    75→          AND expires_at > now()\n    76→        RETURNING *\n    77→      `;\n    78→      return rows[0] ?? null;\n    79→    },\n    80→\n    81→    async insertRefreshToken(wallet, tokenHash, familyId, expiresAt) {\n    82→      const rows = await sql<RefreshToken[]>`\n    83→        INSERT INTO refresh_tokens (wallet, token_hash, family_id, expires_at)\n    84→        VALUES (${wallet}, ${tokenHash}, ${familyId}, ${expiresAt.toISOString()})\n    85→        RETURNING *\n    86→      `;\n    87→      return rows[0]!;\n    88→    },\n    89→\n    90→    async getRefreshTokenByHash(tokenHash) {\n    91→      const rows = await sql<RefreshToken[]>`\n    92→        SELECT * FROM refresh_tokens WHERE token_hash = ${tokenHash}\n    93→      `;\n    94→      return rows[0] ?? null;\n    95→    },\n    96→\n    97→    async revokeRefreshToken(id) {\n    98→      await sql`UPDATE refresh_tokens SET revoked = TRUE WHERE id = ${id}`;\n    99→    },\n   100→\n   101→    async revokeTokenFamily(familyId) {\n   102→      await sql`UPDATE refresh_tokens SET revoked = TRUE WHERE family_id = ${familyId}`;\n   103→    },\n   104→\n   105→    async cleanupExpired() {\n   106→      await sql`DELETE FROM auth_challenges WHERE expires_at < now() OR used = TRUE`;\n   107→      await sql`DELETE FROM refresh_tokens WHERE expires_at < now() OR revoked = TRUE`;\n   108→    },\n   109→  };\n   110→}\n   111→"}]},"parent_tool_use_id":"toolu_015guebxcpHhYbWYzaWhzX43","session_id":"04709d28-c77b-4687-bdb5-b2ffc1a1c744","uuid":"c740c1b6-8a11-4117-abee-66c945f51533","timestamp":"2026-03-21T13:03:05.623Z"}
