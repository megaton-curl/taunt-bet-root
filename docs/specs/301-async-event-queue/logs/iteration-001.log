{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SnfZZhqawdGkrQ68a9HmFX","type":"tool_result","content":"     1→-- 009_transactions.sql — Replace user_transactions with transactions.\n     2→--\n     3→-- Schema change: event-based (join/win/loss/refund) → transaction-based\n     4→-- (deposit/payout/refund). Every row is a real on-chain SOL movement with\n     5→-- a non-null tx_sig.\n     6→--\n     7→-- Dev phase — drop and recreate, no migration.\n     8→\n     9→DROP TABLE IF EXISTS user_transactions;\n    10→\n    11→CREATE TABLE IF NOT EXISTS transactions (\n    12→  id              BIGSERIAL    PRIMARY KEY,\n    13→  wallet          TEXT         NOT NULL,\n    14→  game            TEXT         NOT NULL,\n    15→  match_id        TEXT         NOT NULL,\n    16→  tx_type         TEXT         NOT NULL,\n    17→  amount_lamports BIGINT       NOT NULL,\n    18→  tx_sig          TEXT         NOT NULL,\n    19→  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n    20→);\n    21→\n    22→-- Paginated history by wallet (newest first)\n    23→CREATE INDEX IF NOT EXISTS idx_tx_wallet_created\n    24→  ON transactions (wallet, created_at DESC);\n    25→\n    26→-- Lookup by match_id\n    27→CREATE INDEX IF NOT EXISTS idx_tx_match_id\n    28→  ON transactions (match_id);\n    29→\n    30→-- Idempotency guard — same wallet + match + type + sig = duplicate\n    31→CREATE UNIQUE INDEX IF NOT EXISTS uq_tx_wallet_match_type_sig\n    32→  ON transactions (wallet, match_id, tx_type, tx_sig);\n    33→"}]},"parent_tool_use_id":null,"session_id":"04709d28-c77b-4687-bdb5-b2ffc1a1c744","uuid":"c6bfc4f3-924f-4c26-a6c7-59dc350a304a","timestamp":"2026-03-21T13:04:02.727Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/migrations/009_transactions.sql","content":"-- 009_transactions.sql — Replace user_transactions with transactions.\n--\n-- Schema change: event-based (join/win/loss/refund) → transaction-based\n-- (deposit/payout/refund). Every row is a real on-chain SOL movement with\n-- a non-null tx_sig.\n--\n-- Dev phase — drop and recreate, no migration.\n\nDROP TABLE IF EXISTS user_transactions;\n\nCREATE TABLE IF NOT EXISTS transactions (\n  id              BIGSERIAL    PRIMARY KEY,\n  wallet          TEXT         NOT NULL,\n  game            TEXT         NOT NULL,\n  match_id        TEXT         NOT NULL,\n  tx_type         TEXT         NOT NULL,\n  amount_lamports BIGINT       NOT NULL,\n  tx_sig          TEXT         NOT NULL,\n  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n);\n\n-- Paginated history by wallet (newest first)\nCREATE INDEX IF NOT EXISTS idx_tx_wallet_created\n  ON transactions (wallet, created_at DESC);\n\n-- Lookup by match_id\nCREATE INDEX IF NOT EXISTS idx_tx_match_id\n  ON transactions (match_id);\n\n-- Idempotency guard — same wallet + match + type + sig = duplicate\nCREATE UNIQUE INDEX IF NOT EXISTS uq_tx_wallet_match_type_sig\n  ON transactions (wallet, match_id, tx_type, tx_sig);\n","numLines":33,"startLine":1,"totalLines":33}}}
