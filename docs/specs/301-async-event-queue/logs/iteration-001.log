{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018PdADjWKKXWEaNP88jrU3u","type":"tool_result","content":"     1→{\n     2→  \"name\": \"@rng-utopia/backend\",\n     3→  \"version\": \"0.1.0\",\n     4→  \"private\": true,\n     5→  \"type\": \"module\",\n     6→  \"main\": \"./src/index.ts\",\n     7→  \"types\": \"./src/index.ts\",\n     8→  \"exports\": {\n     9→    \".\": \"./src/index.ts\"\n    10→  },\n    11→  \"scripts\": {\n    12→    \"dev\": \"tsx watch --env-file=.env src/index.ts\",\n    13→    \"start\": \"tsx src/migrate.ts && tsx src/index.ts\",\n    14→    \"build\": \"tsc --noEmit\",\n    15→    \"lint\": \"eslint .\",\n    16→    \"lint:fix\": \"eslint . --fix\",\n    17→    \"typecheck\": \"tsc --noEmit\",\n    18→    \"migrate\": \"tsx --env-file=.env src/migrate.ts\",\n    19→    \"migrate:status\": \"tsx --env-file=.env src/migrate.ts status\",\n    20→    \"test\": \"vitest --passWithNoTests\"\n    21→  },\n    22→  \"dependencies\": {\n    23→    \"@coral-xyz/anchor\": \"^0.32.1\",\n    24→    \"@hono/node-server\": \"^1.19.11\",\n    25→    \"@pythnetwork/hermes-client\": \"^3.1.0\",\n    26→    \"@rng-utopia/anchor-client\": \"workspace:*\",\n    27→    \"@solana/web3.js\": \"^1.98.0\",\n    28→    \"bs58\": \"^6.0.0\",\n    29→    \"hono\": \"^4.6.0\",\n    30→    \"jose\": \"^6.0.0\",\n    31→    \"postgres\": \"^3.4.0\",\n    32→    \"tweetnacl\": \"^1.0.3\"\n    33→  },\n    34→  \"devDependencies\": {\n    35→    \"@rng-utopia/config\": \"workspace:*\",\n    36→    \"@types/node\": \"^22.10.0\",\n    37→    \"tsx\": \"^4.7.0\",\n    38→    \"typescript\": \"^5.7.0\",\n    39→    \"vitest\": \"^2.1.0\"\n    40→  }\n    41→}\n    42→"}]},"parent_tool_use_id":"toolu_015guebxcpHhYbWYzaWhzX43","session_id":"04709d28-c77b-4687-bdb5-b2ffc1a1c744","uuid":"e0f0defe-4717-44ed-8a71-a49e9c24ea9e","timestamp":"2026-03-21T13:02:53.617Z"}
