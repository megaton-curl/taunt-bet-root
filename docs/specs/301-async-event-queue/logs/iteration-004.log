{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011VTH7W8JGkkbPEAkmgFrSA","type":"tool_result","content":"     1→/**\n     2→ * Handler registry — maps event type strings to handler functions.\n     3→ *\n     4→ * One handler per event type (no pub/sub fan-out for v1).\n     5→ * Handlers must be idempotent — re-processing is a safe no-op.\n     6→ */\n     7→\n     8→import type { EventType } from \"./event-types.js\";\n     9→\n    10→export type EventHandler = (\n    11→  payload: Record<string, unknown>,\n    12→) => Promise<void>;\n    13→\n    14→const handlers = new Map<string, EventHandler>();\n    15→\n    16→export function registerHandler(\n    17→  eventType: EventType,\n    18→  handler: EventHandler,\n    19→): void {\n    20→  handlers.set(eventType, handler);\n    21→}\n    22→\n    23→export function getHandler(eventType: string): EventHandler | undefined {\n    24→  return handlers.get(eventType);\n    25→}\n    26→"}]},"parent_tool_use_id":null,"session_id":"6b18a434-7c8e-4399-a029-7bf26c3d1a41","uuid":"c86f3353-9a89-4955-a2ce-70dda86f334c","timestamp":"2026-03-21T13:21:39.750Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/queue/handler-registry.ts","content":"/**\n * Handler registry — maps event type strings to handler functions.\n *\n * One handler per event type (no pub/sub fan-out for v1).\n * Handlers must be idempotent — re-processing is a safe no-op.\n */\n\nimport type { EventType } from \"./event-types.js\";\n\nexport type EventHandler = (\n  payload: Record<string, unknown>,\n) => Promise<void>;\n\nconst handlers = new Map<string, EventHandler>();\n\nexport function registerHandler(\n  eventType: EventType,\n  handler: EventHandler,\n): void {\n  handlers.set(eventType, handler);\n}\n\nexport function getHandler(eventType: string): EventHandler | undefined {\n  return handlers.get(eventType);\n}\n","numLines":26,"startLine":1,"totalLines":26}}}
