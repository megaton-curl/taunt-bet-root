{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RfydhiEYwKRSg9fTvFaDRT","type":"tool_result","content":"     1→import { Keypair } from \"@solana/web3.js\";\n     2→import { applyDbSchemaToUrl, loadDbSchemaFromEnv } from \"./db-config.js\";\n     3→\n     4→export interface Config {\n     5→  port: number;\n     6→  databaseUrl: string;\n     7→  dbSchema: string;\n     8→  rpcUrl: string;\n     9→  wsRpcUrl: string | undefined;\n    10→  serverKeypair: Keypair;\n    11→  jwtSecret: Uint8Array;\n    12→  cluster: string;\n    13→  challengeTtlSeconds: number;\n    14→  accessTokenTtlSeconds: number;\n    15→  refreshTokenTtlDays: number;\n    16→  rateLimitPerWallet: number;\n    17→  rateLimitGlobal: number;\n    18→  workerPollIntervalMs: number;\n    19→  entropyAccount: string;\n    20→  pythBtcUsdAccount: string;\n    21→  minSolBalance: number;\n    22→  eventQueuePollMs: number;\n    23→}\n    24→\n    25→function requireEnv(name: string): string {\n    26→  const value = process.env[name];\n    27→  if (!value) {\n    28→    throw new Error(`Missing required environment variable: ${name}`);\n    29→  }\n    30→  return value;\n    31→}\n    32→\n    33→function parseKeypair(raw: string): Keypair {\n    34→  try {\n    35→    const bytes = JSON.parse(raw) as number[];\n    36→    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n    37→  } catch {\n    38→    throw new Error(\n    39→      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    40→    );\n    41→  }\n    42→}\n    43→\n    44→export function loadConfig(): Config {\n    45→  const dbSchema = loadDbSchemaFromEnv();\n    46→\n    47→  return {\n    48→    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    49→    databaseUrl: applyDbSchemaToUrl(requireEnv(\"DATABASE_URL\"), dbSchema),\n    50→    dbSchema,\n    51→    rpcUrl: requireEnv(\"RPC_URL\"),\n    52→    wsRpcUrl: process.env.WS_RPC_URL || undefined,\n    53→    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    54→    jwtSecret: (() => {\n    55→      const explicit = process.env.JWT_SECRET;\n    56→      if (explicit) return new TextEncoder().encode(explicit);\n    57→      // Derive from first 32 bytes of server keypair secret key\n    58→      const kp = parseKeypair(requireEnv(\"SERVER_KEYPAIR\"));\n    59→      return kp.secretKey.slice(0, 32);\n    60→    })(),\n    61→    cluster: process.env.SOLANA_CLUSTER ?? \"devnet\",\n    62→    challengeTtlSeconds: parseInt(\n    63→      process.env.CHALLENGE_TTL_SECONDS ?? \"300\",\n    64→      10,\n    65→    ),\n    66→    accessTokenTtlSeconds: parseInt(\n    67→      process.env.ACCESS_TOKEN_TTL_SECONDS ?? \"86400\",\n    68→      10,\n    69→    ),\n    70→    refreshTokenTtlDays: parseInt(\n    71→      process.env.REFRESH_TOKEN_TTL_DAYS ?? \"14\",\n    72→      10,\n    73→    ),\n    74→    rateLimitPerWallet: parseInt(\n    75→      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n    76→      10,\n    77→    ),\n    78→    rateLimitGlobal: parseInt(\n    79→      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n    80→      10,\n    81→    ),\n    82→    workerPollIntervalMs: parseInt(\n    83→      process.env.WORKER_POLL_INTERVAL_MS ?? \"1000\",\n    84→      10,\n    85→    ),\n    86→    entropyAccount: process.env.ENTROPY_ACCOUNT ?? \"SysvarS1otHashes111111111111111111111111111\",\n    87→    pythBtcUsdAccount: process.env.PYTH_BTC_USD_ACCOUNT ?? \"4cSM2e6rvbGQUFiJbqytoVMi5GgghSMr8LwVrT9VPSPo\",\n    88→    minSolBalance: parseFloat(process.env.MIN_SOL_BALANCE ?? \"0.1\"),\n    89→    eventQueuePollMs: parseInt(\n    90→      process.env.EVENT_QUEUE_POLL_MS ?? \"1500\",\n    91→      10,\n    92→    ),\n    93→  };\n    94→}\n    95→"}]},"parent_tool_use_id":null,"session_id":"8ac06484-cda2-401d-ad93-d5c7e79f4479","uuid":"469d2d58-8fb0-472a-af89-12e6398dae43","timestamp":"2026-03-21T21:31:25.155Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/config.ts","content":"import { Keypair } from \"@solana/web3.js\";\nimport { applyDbSchemaToUrl, loadDbSchemaFromEnv } from \"./db-config.js\";\n\nexport interface Config {\n  port: number;\n  databaseUrl: string;\n  dbSchema: string;\n  rpcUrl: string;\n  wsRpcUrl: string | undefined;\n  serverKeypair: Keypair;\n  jwtSecret: Uint8Array;\n  cluster: string;\n  challengeTtlSeconds: number;\n  accessTokenTtlSeconds: number;\n  refreshTokenTtlDays: number;\n  rateLimitPerWallet: number;\n  rateLimitGlobal: number;\n  workerPollIntervalMs: number;\n  entropyAccount: string;\n  pythBtcUsdAccount: string;\n  minSolBalance: number;\n  eventQueuePollMs: number;\n}\n\nfunction requireEnv(name: string): string {\n  const value = process.env[name];\n  if (!value) {\n    throw new Error(`Missing required environment variable: ${name}`);\n  }\n  return value;\n}\n\nfunction parseKeypair(raw: string): Keypair {\n  try {\n    const bytes = JSON.parse(raw) as number[];\n    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n  } catch {\n    throw new Error(\n      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    );\n  }\n}\n\nexport function loadConfig(): Config {\n  const dbSchema = loadDbSchemaFromEnv();\n\n  return {\n    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    databaseUrl: applyDbSchemaToUrl(requireEnv(\"DATABASE_URL\"), dbSchema),\n    dbSchema,\n    rpcUrl: requireEnv(\"RPC_URL\"),\n    wsRpcUrl: process.env.WS_RPC_URL || undefined,\n    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    jwtSecret: (() => {\n      const explicit = process.env.JWT_SECRET;\n      if (explicit) return new TextEncoder().encode(explicit);\n      // Derive from first 32 bytes of server keypair secret key\n      const kp = parseKeypair(requireEnv(\"SERVER_KEYPAIR\"));\n      return kp.secretKey.slice(0, 32);\n    })(),\n    cluster: process.env.SOLANA_CLUSTER ?? \"devnet\",\n    challengeTtlSeconds: parseInt(\n      process.env.CHALLENGE_TTL_SECONDS ?? \"300\",\n      10,\n    ),\n    accessTokenTtlSeconds: parseInt(\n      process.env.ACCESS_TOKEN_TTL_SECONDS ?? \"86400\",\n      10,\n    ),\n    refreshTokenTtlDays: parseInt(\n      process.env.REFRESH_TOKEN_TTL_DAYS ?? \"14\",\n      10,\n    ),\n    rateLimitPerWallet: parseInt(\n      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n      10,\n    ),\n    rateLimitGlobal: parseInt(\n      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n      10,\n    ),\n    workerPollIntervalMs: parseInt(\n      process.env.WORKER_POLL_INTERVAL_MS ?? \"1000\",\n      10,\n    ),\n    entropyAccount: process.env.ENTROPY_ACCOUNT ?? \"SysvarS1otHashes111111111111111111111111111\",\n    pythBtcUsdAccount: process.env.PYTH_BTC_USD_ACCOUNT ?? \"4cSM2e6rvbGQUFiJbqytoVMi5GgghSMr8LwVrT9VPSPo\",\n    minSolBalance: parseFloat(process.env.MIN_SOL_BALANCE ?? \"0.1\"),\n    eventQueuePollMs: parseInt(\n      process.env.EVENT_QUEUE_POLL_MS ?? \"1500\",\n      10,\n    ),\n  };\n}\n","numLines":95,"startLine":1,"totalLines":95}}}
