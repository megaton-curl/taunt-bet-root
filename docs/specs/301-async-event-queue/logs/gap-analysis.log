{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016mhzWb4ssXnKfuyKefamHv","type":"tool_result","content":"     1→/**\n     2→ * Event queue worker — polls the event_queue table and dispatches events\n     3→ * to registered handlers.\n     4→ *\n     5→ * Uses the same setTimeout(loop, interval) pattern as the settlement worker.\n     6→ * Claims events with FOR UPDATE SKIP LOCKED for safe concurrency.\n     7→ */\n     8→\n     9→import type postgres from \"postgres\";\n    10→import { logger } from \"../logger.js\";\n    11→import { getHandler } from \"./handler-registry.js\";\n    12→\n    13→export interface EventWorkerOptions {\n    14→  pollIntervalMs?: number; // default: 1500\n    15→  batchSize?: number; // default: 10\n    16→}\n    17→\n    18→export interface EventWorker {\n    19→  start(): void;\n    20→  stop(): void;\n    21→  readonly isRunning: boolean;\n    22→  /** Exposed for testing — runs one poll cycle. */\n    23→  poll(): Promise<void>;\n    24→}\n    25→\n    26→interface EventRow {\n    27→  id: string;\n    28→  event_type: string;\n    29→  payload: Record<string, unknown>;\n    30→  status: string;\n    31→  attempts: number;\n    32→  max_attempts: number;\n    33→  scheduled_at: Date;\n    34→  started_at: Date | null;\n    35→  completed_at: Date | null;\n    36→  error: string | null;\n    37→  created_at: Date;\n    38→}\n    39→\n    40→export function createEventWorker(\n    41→  sql: postgres.Sql,\n    42→  options?: EventWorkerOptions,\n    43→): EventWorker {\n    44→  const pollIntervalMs = options?.pollIntervalMs ?? 1500;\n    45→  const batchSize = options?.batchSize ?? 10;\n    46→\n    47→  let running = false;\n    48→  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n    49→\n    50→  async function poll(): Promise<void> {\n    51→    // Claim a batch of pending events atomically\n    52→    const events = await sql<EventRow[]>`\n    53→      UPDATE event_queue\n    54→      SET status = 'processing', started_at = now()\n    55→      WHERE id IN (\n    56→        SELECT id FROM event_queue\n    57→        WHERE status = 'pending' AND scheduled_at <= now()\n    58→        ORDER BY scheduled_at\n    59→        LIMIT ${batchSize}\n    60→        FOR UPDATE SKIP LOCKED\n    61→      )\n    62→      RETURNING *\n    63→    `;\n    64→\n    65→    for (const event of events) {\n    66→      const handler = getHandler(event.event_type);\n    67→\n    68→      if (!handler) {\n    69→        // No handler registered — mark dead immediately\n    70→        await sql`\n    71→          UPDATE event_queue\n    72→          SET status = 'dead',\n    73→              error = ${\"no handler registered for: \" + event.event_type},\n    74→              completed_at = now()\n    75→          WHERE id = ${event.id}\n    76→        `;\n    77→        logger.warn(\"MANUAL REVIEW NEEDED: unhandled event type\", {\n    78→          eventId: event.id,\n    79→          eventType: event.event_type,\n    80→          transition: \"processing → dead\",\n    81→        });\n    82→        continue;\n    83→      }\n    84→\n    85→      try {\n    86→        await handler(event.payload);\n    87→\n    88→        // Success — mark completed\n    89→        await sql`\n    90→          UPDATE event_queue\n    91→          SET status = 'completed', completed_at = now()\n    92→          WHERE id = ${event.id}\n    93→        `;\n    94→        logger.info(\"event processed\", {\n    95→          eventId: event.id,\n    96→          eventType: event.event_type,\n    97→          transition: \"processing → completed\",\n    98→        });\n    99→      } catch (err) {\n   100→        // Failure handling — increment attempts and decide retry vs dead\n   101→        const attempts = event.attempts + 1;\n   102→        const errorMessage = err instanceof Error ? err.message : String(err);\n   103→\n   104→        if (attempts >= event.max_attempts) {\n   105→          // Exceeded max attempts — mark dead\n   106→          await sql`\n   107→            UPDATE event_queue\n   108→            SET status = 'dead',\n   109→                attempts = ${attempts},\n   110→                error = ${errorMessage},\n   111→                completed_at = now()\n   112→            WHERE id = ${event.id}\n   113→          `;\n   114→          logger.warn(\"MANUAL REVIEW NEEDED: event exhausted retries\", {\n   115→            eventId: event.id,\n   116→            eventType: event.event_type,\n   117→            attempts,\n   118→            maxAttempts: event.max_attempts,\n   119→            error: errorMessage,\n   120→            transition: \"processing → dead\",\n   121→          });\n   122→        } else {\n   123→          // Retry with exponential backoff\n   124→          const backoffSeconds = getBackoffSeconds(attempts);\n   125→          await sql`\n   126→            UPDATE event_queue\n   127→            SET status = 'pending',\n   128→                attempts = ${attempts},\n   129→                error = ${errorMessage},\n   130→                scheduled_at = now() + ${backoffSeconds + \" seconds\"}::interval\n   131→            WHERE id = ${event.id}\n   132→          `;\n   133→          logger.error(\"event handler failed, scheduling retry\", {\n   134→            eventId: event.id,\n   135→            eventType: event.event_type,\n   136→            attempts,\n   137→            maxAttempts: event.max_attempts,\n   138→            retryInSeconds: backoffSeconds,\n   139→            error: errorMessage,\n   140→            transition: \"processing → pending\",\n   141→          });\n   142→        }\n   143→      }\n   144→    }\n   145→  }\n   146→\n   147→  async function loop(): Promise<void> {\n   148→    if (!running) return;\n   149→    try {\n   150→      await poll();\n   151→    } catch (err) {\n   152→      logger.error(\"event queue worker poll error\", {\n   153→        error: err instanceof Error ? err.message : String(err),\n   154→      });\n   155→    }\n   156→    if (running) {\n   157→      timeoutId = setTimeout(loop, pollIntervalMs);\n   158→    }\n   159→  }\n   160→\n   161→  return {\n   162→    start() {\n   163→      if (running) return;\n   164→      running = true;\n   165→      logger.info(\"event queue worker started\", { pollIntervalMs, batchSize });\n   166→      loop();\n   167→    },\n   168→    stop() {\n   169→      running = false;\n   170→      if (timeoutId) {\n   171→        clearTimeout(timeoutId);\n   172→        timeoutId = null;\n   173→      }\n   174→      logger.info(\"event queue worker stopped\");\n   175→    },\n   176→    get isRunning() {\n   177→      return running;\n   178→    },\n   179→    poll,\n   180→  };\n   181→}\n   182→\n   183→/** Exponential backoff: attempt 1 → 5s, attempt 2 → 30s, attempt 3+ → 300s */\n   184→export function getBackoffSeconds(attempt: number): number {\n   185→  switch (attempt) {\n   186→    case 1:\n   187→      return 5;\n   188→    case 2:\n   189→      return 30;\n   190→    default:\n   191→      return 300;\n   192→  }\n   193→}\n   194→"}]},"parent_tool_use_id":null,"session_id":"8ac06484-cda2-401d-ad93-d5c7e79f4479","uuid":"5b3a7582-ff27-44f4-b9c0-0f533e2ece0e","timestamp":"2026-03-21T21:31:22.319Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/queue/worker.ts","content":"/**\n * Event queue worker — polls the event_queue table and dispatches events\n * to registered handlers.\n *\n * Uses the same setTimeout(loop, interval) pattern as the settlement worker.\n * Claims events with FOR UPDATE SKIP LOCKED for safe concurrency.\n */\n\nimport type postgres from \"postgres\";\nimport { logger } from \"../logger.js\";\nimport { getHandler } from \"./handler-registry.js\";\n\nexport interface EventWorkerOptions {\n  pollIntervalMs?: number; // default: 1500\n  batchSize?: number; // default: 10\n}\n\nexport interface EventWorker {\n  start(): void;\n  stop(): void;\n  readonly isRunning: boolean;\n  /** Exposed for testing — runs one poll cycle. */\n  poll(): Promise<void>;\n}\n\ninterface EventRow {\n  id: string;\n  event_type: string;\n  payload: Record<string, unknown>;\n  status: string;\n  attempts: number;\n  max_attempts: number;\n  scheduled_at: Date;\n  started_at: Date | null;\n  completed_at: Date | null;\n  error: string | null;\n  created_at: Date;\n}\n\nexport function createEventWorker(\n  sql: postgres.Sql,\n  options?: EventWorkerOptions,\n): EventWorker {\n  const pollIntervalMs = options?.pollIntervalMs ?? 1500;\n  const batchSize = options?.batchSize ?? 10;\n\n  let running = false;\n  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n\n  async function poll(): Promise<void> {\n    // Claim a batch of pending events atomically\n    const events = await sql<EventRow[]>`\n      UPDATE event_queue\n      SET status = 'processing', started_at = now()\n      WHERE id IN (\n        SELECT id FROM event_queue\n        WHERE status = 'pending' AND scheduled_at <= now()\n        ORDER BY scheduled_at\n        LIMIT ${batchSize}\n        FOR UPDATE SKIP LOCKED\n      )\n      RETURNING *\n    `;\n\n    for (const event of events) {\n      const handler = getHandler(event.event_type);\n\n      if (!handler) {\n        // No handler registered — mark dead immediately\n        await sql`\n          UPDATE event_queue\n          SET status = 'dead',\n              error = ${\"no handler registered for: \" + event.event_type},\n              completed_at = now()\n          WHERE id = ${event.id}\n        `;\n        logger.warn(\"MANUAL REVIEW NEEDED: unhandled event type\", {\n          eventId: event.id,\n          eventType: event.event_type,\n          transition: \"processing → dead\",\n        });\n        continue;\n      }\n\n      try {\n        await handler(event.payload);\n\n        // Success — mark completed\n        await sql`\n          UPDATE event_queue\n          SET status = 'completed', completed_at = now()\n          WHERE id = ${event.id}\n        `;\n        logger.info(\"event processed\", {\n          eventId: event.id,\n          eventType: event.event_type,\n          transition: \"processing → completed\",\n        });\n      } catch (err) {\n        // Failure handling — increment attempts and decide retry vs dead\n        const attempts = event.attempts + 1;\n        const errorMessage = err instanceof Error ? err.message : String(err);\n\n        if (attempts >= event.max_attempts) {\n          // Exceeded max attempts — mark dead\n          await sql`\n            UPDATE event_queue\n            SET status = 'dead',\n                attempts = ${attempts},\n                error = ${errorMessage},\n                completed_at = now()\n            WHERE id = ${event.id}\n          `;\n          logger.warn(\"MANUAL REVIEW NEEDED: event exhausted retries\", {\n            eventId: event.id,\n            eventType: event.event_type,\n            attempts,\n            maxAttempts: event.max_attempts,\n            error: errorMessage,\n            transition: \"processing → dead\",\n          });\n        } else {\n          // Retry with exponential backoff\n          const backoffSeconds = getBackoffSeconds(attempts);\n          await sql`\n            UPDATE event_queue\n            SET status = 'pending',\n                attempts = ${attempts},\n                error = ${errorMessage},\n                scheduled_at = now() + ${backoffSeconds + \" seconds\"}::interval\n            WHERE id = ${event.id}\n          `;\n          logger.error(\"event handler failed, scheduling retry\", {\n            eventId: event.id,\n            eventType: event.event_type,\n            attempts,\n            maxAttempts: event.max_attempts,\n            retryInSeconds: backoffSeconds,\n            error: errorMessage,\n            transition: \"processing → pending\",\n          });\n        }\n      }\n    }\n  }\n\n  async function loop(): Promise<void> {\n    if (!running) return;\n    try {\n      await poll();\n    } catch (err) {\n      logger.error(\"event queue worker poll error\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n    if (running) {\n      timeoutId = setTimeout(loop, pollIntervalMs);\n    }\n  }\n\n  return {\n    start() {\n      if (running) return;\n      running = true;\n      logger.info(\"event queue worker started\", { pollIntervalMs, batchSize });\n      loop();\n    },\n    stop() {\n      running = false;\n      if (timeoutId) {\n        clearTimeout(timeoutId);\n        timeoutId = null;\n      }\n      logger.info(\"event queue worker stopped\");\n    },\n    get isRunning() {\n      return running;\n    },\n    poll,\n  };\n}\n\n/** Exponential backoff: attempt 1 → 5s, attempt 2 → 30s, attempt 3+ → 300s */\nexport function getBackoffSeconds(attempt: number): number {\n  switch (attempt) {\n    case 1:\n      return 5;\n    case 2:\n      return 30;\n    default:\n      return 300;\n  }\n}\n","numLines":194,"startLine":1,"totalLines":194}}}
