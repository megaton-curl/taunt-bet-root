{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NZdeZzaxCuaHF683EJ43MH","type":"tool_result","content":"     1→/**\n     2→ * Queue health — provides event counts by status for observability.\n     3→ */\n     4→\n     5→import type postgres from \"postgres\";\n     6→\n     7→export interface QueueDepth {\n     8→  pending: number;\n     9→  processing: number;\n    10→  dead: number;\n    11→  completed: number;\n    12→}\n    13→\n    14→export async function getQueueDepth(sql: postgres.Sql): Promise<QueueDepth> {\n    15→  const rows = await sql<{ status: string; count: string }[]>`\n    16→    SELECT status, count(*)::text AS count\n    17→    FROM event_queue\n    18→    WHERE status IN ('pending', 'processing', 'dead', 'completed')\n    19→    GROUP BY status\n    20→  `;\n    21→\n    22→  const counts: QueueDepth = { pending: 0, processing: 0, dead: 0, completed: 0 };\n    23→  for (const row of rows) {\n    24→    if (row.status in counts) {\n    25→      counts[row.status as keyof QueueDepth] = parseInt(row.count, 10);\n    26→    }\n    27→  }\n    28→  return counts;\n    29→}\n    30→"}]},"parent_tool_use_id":null,"session_id":"8ac06484-cda2-401d-ad93-d5c7e79f4479","uuid":"b328dd3d-1767-4b6c-8559-f47e312840e5","timestamp":"2026-03-21T21:31:24.089Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/queue/health.ts","content":"/**\n * Queue health — provides event counts by status for observability.\n */\n\nimport type postgres from \"postgres\";\n\nexport interface QueueDepth {\n  pending: number;\n  processing: number;\n  dead: number;\n  completed: number;\n}\n\nexport async function getQueueDepth(sql: postgres.Sql): Promise<QueueDepth> {\n  const rows = await sql<{ status: string; count: string }[]>`\n    SELECT status, count(*)::text AS count\n    FROM event_queue\n    WHERE status IN ('pending', 'processing', 'dead', 'completed')\n    GROUP BY status\n  `;\n\n  const counts: QueueDepth = { pending: 0, processing: 0, dead: 0, completed: 0 };\n  for (const row of rows) {\n    if (row.status in counts) {\n      counts[row.status as keyof QueueDepth] = parseInt(row.count, 10);\n    }\n  }\n  return counts;\n}\n","numLines":30,"startLine":1,"totalLines":30}}}
