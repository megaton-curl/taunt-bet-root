{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P8JXfoHvHCw337tHRnBnDm","type":"tool_result","content":"     1→/**\n     2→ * Unit tests for the async event queue module.\n     3→ *\n     4→ * Covers:\n     5→ * 1. emitEvent — inserts with correct fields, returns eventId\n     6→ * 2. emitEvent — rolled-back transaction does NOT persist\n     7→ * 3. Handler registry — register/get, unknown returns undefined\n     8→ * 4. Backoff calculation — attempt 1 → 5s, attempt 2 → 30s, attempt 3+ → 300s\n     9→ *\n    10→ * Requires a running Postgres database (same as backend).\n    11→ */\n    12→\n    13→import { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n    14→import postgres from \"postgres\";\n    15→import { emitEvent } from \"../emit-event.js\";\n    16→import { registerHandler, getHandler } from \"../handler-registry.js\";\n    17→import { EventTypes } from \"../event-types.js\";\n    18→import { getBackoffSeconds } from \"../worker.js\";\n    19→\n    20→describe(\"event queue unit tests\", () => {\n    21→  let sql: ReturnType<typeof postgres>;\n    22→\n    23→  beforeAll(async () => {\n    24→    sql = process.env.DATABASE_URL\n    25→      ? postgres(process.env.DATABASE_URL)\n    26→      : postgres({\n    27→          host: \"/var/run/postgresql\",\n    28→          database: \"rng_utopia_dev\",\n    29→          username: \"vscode\",\n    30→        });\n    31→  });\n    32→\n    33→  afterAll(async () => {\n    34→    await sql.end();\n    35→  });\n    36→\n    37→  beforeEach(async () => {\n    38→    await sql`TRUNCATE event_queue RESTART IDENTITY`;\n    39→  });\n    40→\n    41→  // -------------------------------------------------------------------------\n    42→  // emitEvent\n    43→  // -------------------------------------------------------------------------\n    44→\n    45→  describe(\"emitEvent\", () => {\n    46→    it(\"inserts a row with correct fields and returns eventId\", async () => {\n    47→      const payload = { referrerWallet: \"abc\", roundId: \"123\" };\n    48→\n    49→      const result = await sql.begin(async (tx) => {\n    50→        return emitEvent(\n    51→          tx as unknown as postgres.Sql,\n    52→          EventTypes.REFERRAL_GAME_SETTLED,\n    53→          payload,\n    54→        );\n    55→      });\n    56→\n    57→      expect(result.eventId).toBeTypeOf(\"bigint\");\n    58→      expect(result.eventId).toBeGreaterThan(0n);\n    59→\n    60→      // Verify the persisted row\n    61→      const rows = await sql`\n    62→        SELECT * FROM event_queue WHERE id = ${result.eventId.toString()}\n    63→      `;\n    64→      expect(rows).toHaveLength(1);\n    65→\n    66→      const row = rows[0]!;\n    67→      expect(row.event_type).toBe(\"referral.game_settled\");\n    68→      expect(row.payload).toEqual(payload);\n    69→      expect(row.status).toBe(\"pending\");\n    70→      expect(row.attempts).toBe(0);\n    71→      expect(row.max_attempts).toBe(3);\n    72→      expect(row.scheduled_at).toBeInstanceOf(Date);\n    73→      expect(row.created_at).toBeInstanceOf(Date);\n    74→    });\n    75→\n    76→    it(\"does NOT persist when transaction is rolled back\", async () => {\n    77→      let capturedId: bigint | undefined;\n    78→\n    79→      try {\n    80→        await sql.begin(async (tx) => {\n    81→          const result = await emitEvent(\n    82→            tx as unknown as postgres.Sql,\n    83→            EventTypes.REFERRAL_CODE_APPLIED,\n    84→            { test: true },\n    85→          );\n    86→          capturedId = result.eventId;\n    87→          throw new Error(\"intentional rollback\");\n    88→        });\n    89→      } catch {\n    90→        // Expected — begin() re-throws after rollback\n    91→      }\n    92→\n    93→      expect(capturedId).toBeDefined();\n    94→      const rows = await sql`\n    95→        SELECT * FROM event_queue WHERE id = ${capturedId!.toString()}\n    96→      `;\n    97→      expect(rows).toHaveLength(0);\n    98→    });\n    99→\n   100→    it(\"respects custom maxAttempts and scheduledAt\", async () => {\n   101→      const future = new Date(Date.now() + 60_000);\n   102→\n   103→      const result = await sql.begin(async (tx) => {\n   104→        return emitEvent(\n   105→          tx as unknown as postgres.Sql,\n   106→          EventTypes.REFERRAL_CLAIM_REQUESTED,\n   107→          { foo: \"bar\" },\n   108→          { maxAttempts: 5, scheduledAt: future },\n   109→        );\n   110→      });\n   111→\n   112→      const rows = await sql`\n   113→        SELECT * FROM event_queue WHERE id = ${result.eventId.toString()}\n   114→      `;\n   115→      expect(rows[0]!.max_attempts).toBe(5);\n   116→      // scheduled_at should be close to the future date (within 1s tolerance)\n   117→      const diff = Math.abs(rows[0]!.scheduled_at.getTime() - future.getTime());\n   118→      expect(diff).toBeLessThan(1000);\n   119→    });\n   120→  });\n   121→\n   122→  // -------------------------------------------------------------------------\n   123→  // Handler registry\n   124→  // -------------------------------------------------------------------------\n   125→\n   126→  describe(\"handler registry\", () => {\n   127→    it(\"register → get returns the handler\", () => {\n   128→      const handler = async () => {};\n   129→      registerHandler(EventTypes.REFERRAL_GAME_SETTLED, handler);\n   130→      expect(getHandler(\"referral.game_settled\")).toBe(handler);\n   131→    });\n   132→\n   133→    it(\"get for unknown type returns undefined\", () => {\n   134→      expect(getHandler(\"unknown.event.type\")).toBeUndefined();\n   135→    });\n   136→  });\n   137→\n   138→  // -------------------------------------------------------------------------\n   139→  // Backoff calculation\n   140→  // -------------------------------------------------------------------------\n   141→\n   142→  describe(\"getBackoffSeconds\", () => {\n   143→    it(\"attempt 1 → 5 seconds\", () => {\n   144→      expect(getBackoffSeconds(1)).toBe(5);\n   145→    });\n   146→\n   147→    it(\"attempt 2 → 30 seconds\", () => {\n   148→      expect(getBackoffSeconds(2)).toBe(30);\n   149→    });\n   150→\n   151→    it(\"attempt 3+ → 300 seconds\", () => {\n   152→      expect(getBackoffSeconds(3)).toBe(300);\n   153→      expect(getBackoffSeconds(4)).toBe(300);\n   154→    });\n   155→  });\n   156→});\n   157→"}]},"parent_tool_use_id":null,"session_id":"8ac06484-cda2-401d-ad93-d5c7e79f4479","uuid":"42e19887-2a47-4e17-9afb-079cdd59bded","timestamp":"2026-03-21T21:31:29.548Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/queue/__tests__/queue.test.ts","content":"/**\n * Unit tests for the async event queue module.\n *\n * Covers:\n * 1. emitEvent — inserts with correct fields, returns eventId\n * 2. emitEvent — rolled-back transaction does NOT persist\n * 3. Handler registry — register/get, unknown returns undefined\n * 4. Backoff calculation — attempt 1 → 5s, attempt 2 → 30s, attempt 3+ → 300s\n *\n * Requires a running Postgres database (same as backend).\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport postgres from \"postgres\";\nimport { emitEvent } from \"../emit-event.js\";\nimport { registerHandler, getHandler } from \"../handler-registry.js\";\nimport { EventTypes } from \"../event-types.js\";\nimport { getBackoffSeconds } from \"../worker.js\";\n\ndescribe(\"event queue unit tests\", () => {\n  let sql: ReturnType<typeof postgres>;\n\n  beforeAll(async () => {\n    sql = process.env.DATABASE_URL\n      ? postgres(process.env.DATABASE_URL)\n      : postgres({\n          host: \"/var/run/postgresql\",\n          database: \"rng_utopia_dev\",\n          username: \"vscode\",\n        });\n  });\n\n  afterAll(async () => {\n    await sql.end();\n  });\n\n  beforeEach(async () => {\n    await sql`TRUNCATE event_queue RESTART IDENTITY`;\n  });\n\n  // -------------------------------------------------------------------------\n  // emitEvent\n  // -------------------------------------------------------------------------\n\n  describe(\"emitEvent\", () => {\n    it(\"inserts a row with correct fields and returns eventId\", async () => {\n      const payload = { referrerWallet: \"abc\", roundId: \"123\" };\n\n      const result = await sql.begin(async (tx) => {\n        return emitEvent(\n          tx as unknown as postgres.Sql,\n          EventTypes.REFERRAL_GAME_SETTLED,\n          payload,\n        );\n      });\n\n      expect(result.eventId).toBeTypeOf(\"bigint\");\n      expect(result.eventId).toBeGreaterThan(0n);\n\n      // Verify the persisted row\n      const rows = await sql`\n        SELECT * FROM event_queue WHERE id = ${result.eventId.toString()}\n      `;\n      expect(rows).toHaveLength(1);\n\n      const row = rows[0]!;\n      expect(row.event_type).toBe(\"referral.game_settled\");\n      expect(row.payload).toEqual(payload);\n      expect(row.status).toBe(\"pending\");\n      expect(row.attempts).toBe(0);\n      expect(row.max_attempts).toBe(3);\n      expect(row.scheduled_at).toBeInstanceOf(Date);\n      expect(row.created_at).toBeInstanceOf(Date);\n    });\n\n    it(\"does NOT persist when transaction is rolled back\", async () => {\n      let capturedId: bigint | undefined;\n\n      try {\n        await sql.begin(async (tx) => {\n          const result = await emitEvent(\n            tx as unknown as postgres.Sql,\n            EventTypes.REFERRAL_CODE_APPLIED,\n            { test: true },\n          );\n          capturedId = result.eventId;\n          throw new Error(\"intentional rollback\");\n        });\n      } catch {\n        // Expected — begin() re-throws after rollback\n      }\n\n      expect(capturedId).toBeDefined();\n      const rows = await sql`\n        SELECT * FROM event_queue WHERE id = ${capturedId!.toString()}\n      `;\n      expect(rows).toHaveLength(0);\n    });\n\n    it(\"respects custom maxAttempts and scheduledAt\", async () => {\n      const future = new Date(Date.now() + 60_000);\n\n      const result = await sql.begin(async (tx) => {\n        return emitEvent(\n          tx as unknown as postgres.Sql,\n          EventTypes.REFERRAL_CLAIM_REQUESTED,\n          { foo: \"bar\" },\n          { maxAttempts: 5, scheduledAt: future },\n        );\n      });\n\n      const rows = await sql`\n        SELECT * FROM event_queue WHERE id = ${result.eventId.toString()}\n      `;\n      expect(rows[0]!.max_attempts).toBe(5);\n      // scheduled_at should be close to the future date (within 1s tolerance)\n      const diff = Math.abs(rows[0]!.scheduled_at.getTime() - future.getTime());\n      expect(diff).toBeLessThan(1000);\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // Handler registry\n  // -------------------------------------------------------------------------\n\n  describe(\"handler registry\", () => {\n    it(\"register → get returns the handler\", () => {\n      const handler = async () => {};\n      registerHandler(EventTypes.REFERRAL_GAME_SETTLED, handler);\n      expect(getHandler(\"referral.game_settled\")).toBe(handler);\n    });\n\n    it(\"get for unknown type returns undefined\", () => {\n      expect(getHandler(\"unknown.event.type\")).toBeUndefined();\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // Backoff calculation\n  // -------------------------------------------------------------------------\n\n  describe(\"getBackoffSeconds\", () => {\n    it(\"attempt 1 → 5 seconds\", () => {\n      expect(getBackoffSeconds(1)).toBe(5);\n    });\n\n    it(\"attempt 2 → 30 seconds\", () => {\n      expect(getBackoffSeconds(2)).toBe(30);\n    });\n\n    it(\"attempt 3+ → 300 seconds\", () => {\n      expect(getBackoffSeconds(3)).toBe(300);\n      expect(getBackoffSeconds(4)).toBe(300);\n    });\n  });\n});\n","numLines":157,"startLine":1,"totalLines":157}}}
