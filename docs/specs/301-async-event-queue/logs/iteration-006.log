{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TaUdZJdap6XYyG8Wd81Npy","type":"tool_result","content":"     1→-- 010_event_queue.sql — Postgres-backed async event queue.\n     2→--\n     3→-- Decouples settlement hot path from secondary side-effects (reward delivery,\n     4→-- notifications, analytics). Events are committed atomically with their\n     5→-- triggering operation. Worker polls with SKIP LOCKED for safe concurrency.\n     6→\n     7→CREATE TABLE IF NOT EXISTS event_queue (\n     8→  id              BIGSERIAL    PRIMARY KEY,\n     9→  event_type      TEXT         NOT NULL,\n    10→  payload         JSONB        NOT NULL,\n    11→  status          TEXT         NOT NULL DEFAULT 'pending',\n    12→  attempts        INTEGER      NOT NULL DEFAULT 0,\n    13→  max_attempts    INTEGER      NOT NULL DEFAULT 3,\n    14→  scheduled_at    TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    15→  started_at      TIMESTAMPTZ,\n    16→  completed_at    TIMESTAMPTZ,\n    17→  error           TEXT,\n    18→  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    19→\n    20→  CONSTRAINT chk_event_queue_status\n    21→    CHECK (status IN ('pending', 'processing', 'completed', 'failed', 'dead'))\n    22→);\n    23→\n    24→-- Partial index for worker polling — only scans pending events\n    25→CREATE INDEX IF NOT EXISTS idx_event_queue_poll\n    26→  ON event_queue (scheduled_at)\n    27→  WHERE status = 'pending';\n    28→\n    29→-- Index for observability queries (dead events, recent failures)\n    30→CREATE INDEX IF NOT EXISTS idx_event_queue_status\n    31→  ON event_queue (status, created_at);\n    32→"}]},"parent_tool_use_id":null,"session_id":"5a06e2aa-bee3-40eb-a97d-65518436146f","uuid":"0927e5cb-8c1a-4484-bbf0-188cab5ebfb0","timestamp":"2026-03-21T13:27:59.030Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/migrations/010_event_queue.sql","content":"-- 010_event_queue.sql — Postgres-backed async event queue.\n--\n-- Decouples settlement hot path from secondary side-effects (reward delivery,\n-- notifications, analytics). Events are committed atomically with their\n-- triggering operation. Worker polls with SKIP LOCKED for safe concurrency.\n\nCREATE TABLE IF NOT EXISTS event_queue (\n  id              BIGSERIAL    PRIMARY KEY,\n  event_type      TEXT         NOT NULL,\n  payload         JSONB        NOT NULL,\n  status          TEXT         NOT NULL DEFAULT 'pending',\n  attempts        INTEGER      NOT NULL DEFAULT 0,\n  max_attempts    INTEGER      NOT NULL DEFAULT 3,\n  scheduled_at    TIMESTAMPTZ  NOT NULL DEFAULT now(),\n  started_at      TIMESTAMPTZ,\n  completed_at    TIMESTAMPTZ,\n  error           TEXT,\n  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n\n  CONSTRAINT chk_event_queue_status\n    CHECK (status IN ('pending', 'processing', 'completed', 'failed', 'dead'))\n);\n\n-- Partial index for worker polling — only scans pending events\nCREATE INDEX IF NOT EXISTS idx_event_queue_poll\n  ON event_queue (scheduled_at)\n  WHERE status = 'pending';\n\n-- Index for observability queries (dead events, recent failures)\nCREATE INDEX IF NOT EXISTS idx_event_queue_status\n  ON event_queue (status, created_at);\n","numLines":32,"startLine":1,"totalLines":32}}}
