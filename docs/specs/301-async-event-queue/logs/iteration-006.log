{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01PGbTb7S76L1Jw2xaim6nAP","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_016XjCDQDQfDSwwo53zygeXC","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/rate-limit.test.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":467,"cache_creation_input_tokens":10801,"cache_read_input_tokens":31358,"cache_creation":{"ephemeral_5m_input_tokens":10801,"ephemeral_1h_input_tokens":0},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01JFkRRo6fd7WCE7xZR8iApU","session_id":"5a06e2aa-bee3-40eb-a97d-65518436146f","uuid":"79276a73-d587-4959-8417-e0bda492713c"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016XjCDQDQfDSwwo53zygeXC","type":"tool_result","content":"     1→import { describe, it, expect } from \"vitest\";\n     2→import { Hono } from \"hono\";\n     3→import { createRateLimitMiddleware } from \"../middleware/rate-limit.js\";\n     4→\n     5→function createTestApp(\n     6→  config = { perWallet: 3, global: 10, windowMs: 60_000 },\n     7→) {\n     8→  const app = new Hono();\n     9→  app.use(\"/*\", createRateLimitMiddleware(config));\n    10→  app.post(\"/test\", (c) => c.json({ ok: true }));\n    11→  app.get(\"/test\", (c) => c.json({ ok: true }));\n    12→  return app;\n    13→}\n    14→\n    15→function post(wallet: string) {\n    16→  return {\n    17→    method: \"POST\" as const,\n    18→    headers: { \"Content-Type\": \"application/json\" },\n    19→    body: JSON.stringify({ wallet }),\n    20→  };\n    21→}\n    22→\n    23→describe(\"rate-limit middleware\", () => {\n    24→  it(\"allows requests within per-wallet limit\", async () => {\n    25→    const app = createTestApp({ perWallet: 3, global: 100, windowMs: 60_000 });\n    26→    for (let i = 0; i < 3; i++) {\n    27→      const res = await app.request(\"/test\", post(\"wallet1\"));\n    28→      expect(res.status).toBe(200);\n    29→    }\n    30→  });\n    31→\n    32→  it(\"blocks requests exceeding per-wallet limit\", async () => {\n    33→    const app = createTestApp({ perWallet: 2, global: 100, windowMs: 60_000 });\n    34→    await app.request(\"/test\", post(\"wallet1\"));\n    35→    await app.request(\"/test\", post(\"wallet1\"));\n    36→    const res = await app.request(\"/test\", post(\"wallet1\"));\n    37→    expect(res.status).toBe(429);\n    38→  });\n    39→\n    40→  it(\"returns Retry-After header on per-wallet 429\", async () => {\n    41→    const app = createTestApp({ perWallet: 1, global: 100, windowMs: 60_000 });\n    42→    await app.request(\"/test\", post(\"wallet1\"));\n    43→    const res = await app.request(\"/test\", post(\"wallet1\"));\n    44→    expect(res.status).toBe(429);\n    45→    expect(res.headers.get(\"Retry-After\")).toBe(\"60\");\n    46→  });\n    47→\n    48→  it(\"tracks wallets independently\", async () => {\n    49→    const app = createTestApp({ perWallet: 1, global: 100, windowMs: 60_000 });\n    50→    const r1 = await app.request(\"/test\", post(\"wallet1\"));\n    51→    const r2 = await app.request(\"/test\", post(\"wallet2\"));\n    52→    expect(r1.status).toBe(200);\n    53→    expect(r2.status).toBe(200);\n    54→    // wallet1 is now exhausted\n    55→    const r3 = await app.request(\"/test\", post(\"wallet1\"));\n    56→    expect(r3.status).toBe(429);\n    57→    // wallet2 is also exhausted\n    58→    const r4 = await app.request(\"/test\", post(\"wallet2\"));\n    59→    expect(r4.status).toBe(429);\n    60→  });\n    61→\n    62→  it(\"enforces global limit across all wallets\", async () => {\n    63→    const app = createTestApp({ perWallet: 10, global: 3, windowMs: 60_000 });\n    64→    await app.request(\"/test\", post(\"w1\"));\n    65→    await app.request(\"/test\", post(\"w2\"));\n    66→    await app.request(\"/test\", post(\"w3\"));\n    67→    const res = await app.request(\"/test\", post(\"w4\"));\n    68→    expect(res.status).toBe(429);\n    69→  });\n    70→\n    71→  it(\"returns correct Retry-After seconds based on window\", async () => {\n    72→    const app = createTestApp({ perWallet: 10, global: 1, windowMs: 30_000 });\n    73→    await app.request(\"/test\", post(\"w1\"));\n    74→    const res = await app.request(\"/test\", post(\"w2\"));\n    75→    expect(res.status).toBe(429);\n    76→    expect(res.headers.get(\"Retry-After\")).toBe(\"30\");\n    77→  });\n    78→\n    79→  it(\"does not rate-limit GET requests\", async () => {\n    80→    const app = createTestApp({ perWallet: 1, global: 1, windowMs: 60_000 });\n    81→    // Exhaust POST limits\n    82→    await app.request(\"/test\", post(\"w1\"));\n    83→    // GET should still work\n    84→    const res = await app.request(\"/test\", { method: \"GET\" });\n    85→    expect(res.status).toBe(200);\n    86→  });\n    87→});\n    88→"}]},"parent_tool_use_id":"toolu_01JFkRRo6fd7WCE7xZR8iApU","session_id":"5a06e2aa-bee3-40eb-a97d-65518436146f","uuid":"69dedbe4-38c9-488e-9cb0-e296a2800dbc","timestamp":"2026-03-21T13:27:10.082Z"}
{"type":"system","subtype":"task_progress","task_id":"af04eba9eb80ceb21","tool_use_id":"toolu_01JFkRRo6fd7WCE7xZR8iApU","description":"Reading sources/rng-utopia/services/backend/src/__tests__/endpoints.test.ts","usage":{"total_tokens":42649,"tool_uses":12,"duration_ms":26959},"last_tool_name":"Read","uuid":"554c39a5-35de-4e75-9795-cfeaa09c82cc","session_id":"5a06e2aa-bee3-40eb-a97d-65518436146f"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01PGbTb7S76L1Jw2xaim6nAP","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01G7HJ4W7La5k93x11UYs7Ms","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/endpoints.test.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":467,"cache_creation_input_tokens":10801,"cache_read_input_tokens":31358,"cache_creation":{"ephemeral_5m_input_tokens":10801,"ephemeral_1h_input_tokens":0},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01JFkRRo6fd7WCE7xZR8iApU","session_id":"5a06e2aa-bee3-40eb-a97d-65518436146f","uuid":"b431aae4-2578-4703-bf7b-0e4aaff8a0df"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G7HJ4W7La5k93x11UYs7Ms","type":"tool_result","content":"     1→/**\n     2→ * HTTP endpoint tests — exercises the full middleware stack (rate limit + JWT auth)\n     3→ * and route handlers for all endpoints:\n     4→ *\n     5→ * POST /fairness/coinflip/create:\n     6→ *   - 200 with valid JWT\n     7→ *   - 401 with missing JWT\n     8→ *   - 401 with expired JWT\n     9→ *   - 409 with duplicate PDA (same wallet + match ID collision)\n    10→ *   - 429 when rate limit exceeded\n    11→ *\n    12→ * GET /fairness/rounds/:pda:\n    13→ *   - 200 for known PDA\n    14→ *   - 404 for unknown PDA\n    15→ *\n    16→ * GET /health:\n    17→ *   - 200 with expected fields\n    18→ */\n    19→\n    20→import { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n    21→import { Hono } from \"hono\";\n    22→import { Keypair, LAMPORTS_PER_SOL } from \"@solana/web3.js\";\n    23→import type { Connection } from \"@solana/web3.js\";\n    24→import { SignJWT } from \"jose\";\n    25→import postgres from \"postgres\";\n    26→import { createDb, type Db } from \"../db.js\";\n    27→import { createCoinflipRoutes } from \"../routes/create.js\";\n    28→import { createLordRoutes } from \"../routes/lord-create.js\";\n    29→import { createRoundsRoutes } from \"../routes/rounds.js\";\n    30→import { createHealthRoutes } from \"../routes/health.js\";\n    31→import { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n    32→import { createRateLimitMiddleware } from \"../middleware/rate-limit.js\";\n    33→\n    34→// ---------------------------------------------------------------------------\n    35→// Constants\n    36→// ---------------------------------------------------------------------------\n    37→\n    38→const DATABASE_URL = \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n    39→const AMOUNT_LAMPORTS = 5_000_000; // 0.005 SOL\n    40→const SIDE_HEADS = 0;\n    41→const JWT_SECRET = new TextEncoder().encode(\"test-secret-for-endpoint-tests\");\n    42→\n    43→// ---------------------------------------------------------------------------\n    44→// Minimal mock Connection (only what routes + health need)\n    45→// ---------------------------------------------------------------------------\n    46→\n    47→class MockConnection {\n    48→  async getLatestBlockhash() {\n    49→    return {\n    50→      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n    51→      lastValidBlockHeight: 999_999,\n    52→    };\n    53→  }\n    54→\n    55→  async getAccountInfo() {\n    56→    return null;\n    57→  }\n    58→\n    59→  async getBalance() {\n    60→    return 1.5 * LAMPORTS_PER_SOL;\n    61→  }\n    62→}\n    63→\n    64→// ---------------------------------------------------------------------------\n    65→// JWT helper\n    66→// ---------------------------------------------------------------------------\n    67→\n    68→async function makeJwt(wallet: string, opts?: { expiresIn?: number }) {\n    69→  const now = Math.floor(Date.now() / 1000);\n    70→  return new SignJWT({ sub: wallet })\n    71→    .setProtectedHeader({ alg: \"HS256\" })\n    72→    .setIssuedAt(now)\n    73→    .setExpirationTime(now + (opts?.expiresIn ?? 3600))\n    74→    .sign(JWT_SECRET);\n    75→}\n    76→\n    77→function makeBody(wallet: string, overrides?: Partial<{ amountLamports: number; side: number }>) {\n    78→  return {\n    79→    wallet,\n    80→    amountLamports: overrides?.amountLamports ?? AMOUNT_LAMPORTS,\n    81→    side: overrides?.side ?? SIDE_HEADS,\n    82→  };\n    83→}\n    84→\n    85→function makeLordBody(wallet: string, overrides?: Partial<{ amountLamports: number }>) {\n    86→  return {\n    87→    wallet,\n    88→    amountLamports: overrides?.amountLamports ?? AMOUNT_LAMPORTS,\n    89→  };\n    90→}\n    91→\n    92→// ---------------------------------------------------------------------------\n    93→// Test suite\n    94→// ---------------------------------------------------------------------------\n    95→\n    96→describe(\"HTTP endpoint tests\", () => {\n    97→  let db: Db;\n    98→  let rawSql: ReturnType<typeof postgres>;\n    99→  let mockConn: MockConnection;\n   100→\n   101→  const serverKeypair = Keypair.generate();\n   102→  const creatorKeypair = Keypair.generate();\n   103→\n   104→  beforeAll(async () => {\n   105→    db = createDb(DATABASE_URL);\n   106→    rawSql = postgres(DATABASE_URL);\n   107→  });\n   108→\n   109→  afterAll(async () => {\n   110→    await db.close();\n   111→    await rawSql.end();\n   112→  });\n   113→\n   114→  beforeEach(async () => {\n   115→    await rawSql`TRUNCATE rounds, operator_events RESTART IDENTITY`;\n   116→    mockConn = new MockConnection();\n   117→  });\n   118→\n   119→  // -----------------------------------------------------------------------\n   120→  // Helper: build a fresh Hono app with full middleware stack\n   121→  // -----------------------------------------------------------------------\n   122→\n   123→  function buildApp(opts?: { perWallet?: number; global?: number }) {\n   124→    const app = new Hono();\n   125→\n   126→    app.use(\n   127→      \"/fairness/*\",\n   128→      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n   129→    );\n   130→\n   131→    app.use(\n   132→      \"/fairness/*\",\n   133→      createRateLimitMiddleware({\n   134→        perWallet: opts?.perWallet ?? 10,\n   135→        global: opts?.global ?? 100,\n   136→        windowMs: 60_000,\n   137→      }),\n   138→    );\n   139→\n   140→    app.route(\n   141→      \"/fairness/coinflip\",\n   142→      createCoinflipRoutes({\n   143→        db,\n   144→        connection: mockConn as unknown as Connection,\n   145→        serverKeypair,\n   146→      }),\n   147→    );\n   148→    app.route(\n   149→      \"/fairness/lord\",\n   150→      createLordRoutes({\n   151→        db,\n   152→        connection: mockConn as unknown as Connection,\n   153→        serverKeypair,\n   154→      }),\n   155→    );\n   156→\n   157→    app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n   158→\n   159→    app.route(\n   160→      \"/health\",\n   161→      createHealthRoutes({\n   162→        db,\n   163→        connection: mockConn as unknown as Connection,\n   164→        serverKey: serverKeypair.publicKey,\n   165→        isWorkerRunning: () => true,\n   166→        minSolBalance: 0.1,\n   167→      }),\n   168→    );\n   169→\n   170→    return app;\n   171→  }\n   172→\n   173→  // -----------------------------------------------------------------------\n   174→  // POST /fairness/coinflip/create\n   175→  // -----------------------------------------------------------------------\n   176→\n   177→  describe(\"POST /fairness/coinflip/create\", () => {\n   178→    it(\"returns 200 with valid JWT\", async () => {\n   179→      const app = buildApp();\n   180→      const wallet = creatorKeypair.publicKey.toBase58();\n   181→      const token = await makeJwt(wallet);\n   182→      const body = makeBody(wallet);\n   183→\n   184→      const res = await app.request(\"/fairness/coinflip/create\", {\n   185→        method: \"POST\",\n   186→        headers: {\n   187→          \"Content-Type\": \"application/json\",\n   188→          \"Authorization\": `Bearer ${token}`,\n   189→        },\n   190→        body: JSON.stringify(body),\n   191→      });\n   192→\n   193→      expect(res.status).toBe(200);\n   194→      const json = (await res.json()) as Record<string, unknown>;\n   195→      expect(json.transaction).toBeDefined();\n   196→      expect(typeof json.transaction).toBe(\"string\");\n   197→      expect(json.matchPda).toBeDefined();\n   198→      expect(typeof json.matchPda).toBe(\"string\");\n   199→      expect(json.commitment).toBeDefined();\n   200→      expect(typeof json.commitment).toBe(\"string\");\n   201→      expect(json.lastValidBlockHeight).toBeDefined();\n   202→      expect(typeof json.lastValidBlockHeight).toBe(\"number\");\n   203→      // Commitment should be 64 hex chars (32 bytes)\n   204→      expect((json.commitment as string).length).toBe(64);\n   205→    });\n   206→\n   207→    it(\"returns 401 with missing JWT\", async () => {\n   208→      const app = buildApp();\n   209→      const wallet = creatorKeypair.publicKey.toBase58();\n   210→      const body = makeBody(wallet);\n   211→\n   212→      const res = await app.request(\"/fairness/coinflip/create\", {\n   213→        method: \"POST\",\n   214→        headers: { \"Content-Type\": \"application/json\" },\n   215→        body: JSON.stringify(body),\n   216→      });\n   217→\n   218→      expect(res.status).toBe(401);\n   219→      const json = (await res.json()) as Record<string, unknown>;\n   220→      expect(json.error).toBeDefined();\n   221→    });\n   222→\n   223→    it(\"returns 401 with expired JWT\", async () => {\n   224→      const app = buildApp();\n   225→      const wallet = creatorKeypair.publicKey.toBase58();\n   226→      const token = await makeJwt(wallet, { expiresIn: -10 });\n   227→      const body = makeBody(wallet);\n   228→\n   229→      const res = await app.request(\"/fairness/coinflip/create\", {\n   230→        method: \"POST\",\n   231→        headers: {\n   232→          \"Content-Type\": \"application/json\",\n   233→          \"Authorization\": `Bearer ${token}`,\n   234→        },\n   235→        body: JSON.stringify(body),\n   236→      });\n   237→\n   238→      expect(res.status).toBe(401);\n   239→      const json = (await res.json()) as Record<string, unknown>;\n   240→      expect(json.error).toBeDefined();\n   241→    });\n   242→\n   243→    it(\"returns 403 when body wallet mismatches JWT wallet\", async () => {\n   244→      const app = buildApp();\n   245→      const wallet = creatorKeypair.publicKey.toBase58();\n   246→      const otherWallet = Keypair.generate().publicKey.toBase58();\n   247→      const token = await makeJwt(wallet);\n   248→      const body = makeBody(otherWallet); // Different wallet in body\n   249→\n   250→      const res = await app.request(\"/fairness/coinflip/create\", {\n   251→        method: \"POST\",\n   252→        headers: {\n   253→          \"Content-Type\": \"application/json\",\n   254→          \"Authorization\": `Bearer ${token}`,\n   255→        },\n   256→        body: JSON.stringify(body),\n   257→      });\n   258→\n   259→      expect(res.status).toBe(403);\n   260→    });\n   261→\n   262→    it(\"returns 409 with duplicate PDA (match ID collision)\", async () => {\n   263→      const app = buildApp();\n   264→      const wallet = creatorKeypair.publicKey.toBase58();\n   265→\n   266→      // First request — should succeed\n   267→      const token1 = await makeJwt(wallet);\n   268→      const body1 = makeBody(wallet);\n   269→      const res1 = await app.request(\"/fairness/coinflip/create\", {\n   270→        method: \"POST\",\n   271→        headers: {\n   272→          \"Content-Type\": \"application/json\",\n   273→          \"Authorization\": `Bearer ${token1}`,\n   274→        },\n   275→        body: JSON.stringify(body1),\n   276→      });\n   277→      expect(res1.status).toBe(200);\n   278→      const json1 = (await res1.json()) as { matchPda: string };\n   279→\n   280→      // Manually insert a second round with a similar PDA to force the collision\n   281→      const fakeSecret = Buffer.alloc(32, 0x01);\n   282→      const fakeCommitment = Buffer.alloc(32, 0x02);\n   283→      await rawSql`\n   284→        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase)\n   285→        VALUES (${json1.matchPda + \"X\"}, 'coinflip', ${wallet}, ${creatorKeypair.publicKey.toBase58()},\n   286→                ${fakeSecret}, ${fakeCommitment}, ${AMOUNT_LAMPORTS}, ${SIDE_HEADS}, ${\"deadbeefcafebabe\"}, 'created')\n   287→      `;\n   288→    });\n   289→\n   290→    it(\"returns 429 when rate limit exceeded\", async () => {\n   291→      // Create app with very low per-wallet limit\n   292→      const app = buildApp({ perWallet: 2, global: 100 });\n   293→      const wallet = creatorKeypair.publicKey.toBase58();\n   294→\n   295→      // Send 2 requests (within limit)\n   296→      for (let i = 0; i < 2; i++) {\n   297→        const token = await makeJwt(wallet);\n   298→        const body = makeBody(wallet);\n   299→        const res = await app.request(\"/fairness/coinflip/create\", {\n   300→          method: \"POST\",\n   301→          headers: {\n   302→            \"Content-Type\": \"application/json\",\n   303→            \"Authorization\": `Bearer ${token}`,\n   304→          },\n   305→          body: JSON.stringify(body),\n   306→        });\n   307→        expect(res.status).toBe(200);\n   308→      }\n   309→\n   310→      // Third request should be rate-limited\n   311→      const token3 = await makeJwt(wallet);\n   312→      const body3 = makeBody(wallet);\n   313→      const res3 = await app.request(\"/fairness/coinflip/create\", {\n   314→        method: \"POST\",\n   315→        headers: {\n   316→          \"Content-Type\": \"application/json\",\n   317→          \"Authorization\": `Bearer ${token3}`,\n   318→        },\n   319→        body: JSON.stringify(body3),\n   320→      });\n   321→      expect(res3.status).toBe(429);\n   322→      expect(res3.headers.get(\"Retry-After\")).toBeDefined();\n   323→      const json = (await res3.json()) as Record<string, unknown>;\n   324→      expect(json.error).toContain(\"Too many\");\n   325→    });\n   326→  });\n   327→\n   328→  describe(\"POST /fairness/lord/create\", () => {\n   329→    it(\"returns 200 with valid JWT\", async () => {\n   330→      const app = buildApp();\n   331→      const wallet = creatorKeypair.publicKey.toBase58();\n   332→      const token = await makeJwt(wallet);\n   333→\n   334→      const res = await app.request(\"/fairness/lord/create\", {\n   335→        method: \"POST\",\n   336→        headers: {\n   337→          \"Content-Type\": \"application/json\",\n   338→          Authorization: `Bearer ${token}`,\n   339→        },\n   340→        body: JSON.stringify(makeLordBody(wallet)),\n   341→      });\n   342→\n   343→      expect(res.status).toBe(200);\n   344→      const json = (await res.json()) as Record<string, unknown>;\n   345→      expect(typeof json.transaction).toBe(\"string\");\n   346→      expect(typeof json.roundPda).toBe(\"string\");\n   347→      expect(typeof json.matchId).toBe(\"string\");\n   348→      expect(typeof json.commitment).toBe(\"string\");\n   349→      expect(typeof json.lastValidBlockHeight).toBe(\"number\");\n   350→    });\n   351→  });\n   352→\n   353→  // -----------------------------------------------------------------------\n   354→  // GET /fairness/rounds/:pda\n   355→  // -----------------------------------------------------------------------\n   356→\n   357→  describe(\"GET /fairness/rounds/:pda\", () => {\n   358→    it(\"returns 200 for known PDA\", async () => {\n   359→      const app = buildApp();\n   360→      const wallet = creatorKeypair.publicKey.toBase58();\n   361→      const token = await makeJwt(wallet);\n   362→      const body = makeBody(wallet);\n   363→\n   364→      // Create a round first\n   365→      const createRes = await app.request(\"/fairness/coinflip/create\", {\n   366→        method: \"POST\",\n   367→        headers: {\n   368→          \"Content-Type\": \"application/json\",\n   369→          \"Authorization\": `Bearer ${token}`,\n   370→        },\n   371→        body: JSON.stringify(body),\n   372→      });\n   373→      expect(createRes.status).toBe(200);\n   374→      const createJson = (await createRes.json()) as { matchPda: string; commitment: string };\n   375→\n   376→      // Fetch the round (GET — no auth needed)\n   377→      const roundRes = await app.request(`/fairness/rounds/${createJson.matchPda}`);\n   378→      expect(roundRes.status).toBe(200);\n   379→\n   380→      const roundJson = (await roundRes.json()) as Record<string, unknown>;\n   381→      expect(roundJson.pda).toBe(createJson.matchPda);\n   382→      expect(roundJson.game).toBe(\"coinflip\");\n   383→      expect(roundJson.phase).toBe(\"created\");\n   384→      expect(roundJson.creator).toBe(wallet);\n   385→      expect(roundJson.commitment).toBe(createJson.commitment);\n   386→      expect(roundJson.amountLamports).toBe(AMOUNT_LAMPORTS);\n   387→      expect(roundJson.side).toBe(SIDE_HEADS);\n   388→      expect(roundJson.createdAt).toBeDefined();\n   389→      expect(roundJson.updatedAt).toBeDefined();\n   390→      // Unsettled: secret and verification should NOT be present\n   391→      expect(roundJson.secret).toBeUndefined();\n   392→      expect(roundJson.verification).toBeUndefined();\n   393→    });\n   394→\n   395→    it(\"returns 404 for unknown PDA\", async () => {\n   396→      const app = buildApp();\n   397→      const unknownPda = Keypair.generate().publicKey.toBase58();\n   398→      const res = await app.request(`/fairness/rounds/${unknownPda}`);\n   399→      expect(res.status).toBe(404);\n   400→      const json = (await res.json()) as Record<string, unknown>;\n   401→      expect(json.error).toContain(\"not found\");\n   402→    });\n   403→  });\n   404→\n   405→  // -----------------------------------------------------------------------\n   406→  // GET /health\n   407→  // -----------------------------------------------------------------------\n   408→\n   409→  describe(\"GET /health\", () => {\n   410→    it(\"returns 200 with expected fields\", async () => {\n   411→      const app = buildApp();\n   412→      const res = await app.request(\"/health\");\n   413→      expect(res.status).toBe(200);\n   414→\n   415→      const json = (await res.json()) as Record<string, unknown>;\n   416→      expect(json.status).toBe(\"ok\");\n   417→      expect(json.version).toBe(\"0.1.0\");\n   418→      expect(json.serverKey).toBe(serverKeypair.publicKey.toBase58());\n   419→      expect(typeof json.solBalance).toBe(\"number\");\n   420→      expect(json.solBalance).toBe(1.5);\n   421→      expect(json.dbConnected).toBe(true);\n   422→      expect(json.workerRunning).toBe(true);\n   423→      expect(typeof json.unsettledCount).toBe(\"number\");\n   424→      expect(typeof json.oldestUnsettledAge).toBe(\"number\");\n   425→    });\n   426→\n   427→    it(\"reflects unsettled round count\", async () => {\n   428→      const app = buildApp();\n   429→\n   430→      // Create a round so there's an unsettled one\n   431→      const wallet = creatorKeypair.publicKey.toBase58();\n   432→      const token = await makeJwt(wallet);\n   433→      const body = makeBody(wallet);\n   434→      const createRes = await app.request(\"/fairness/coinflip/create\", {\n   435→        method: \"POST\",\n   436→        headers: {\n   437→          \"Content-Type\": \"application/json\",\n   438→          \"Authorization\": `Bearer ${token}`,\n   439→        },\n   440→        body: JSON.stringify(body),\n   441→      });\n   442→      expect(createRes.status).toBe(200);\n   443→\n   444→      const healthRes = await app.request(\"/health\");\n   445→      expect(healthRes.status).toBe(200);\n   446→      const json = (await healthRes.json()) as Record<string, unknown>;\n   447→      expect(json.unsettledCount).toBe(1);\n   448→    });\n   449→  });\n   450→});\n   451→"}]},"parent_tool_use_id":"toolu_01JFkRRo6fd7WCE7xZR8iApU","session_id":"5a06e2aa-bee3-40eb-a97d-65518436146f","uuid":"4b0cdfdb-0671-4778-88d7-240b074d6b16","timestamp":"2026-03-21T13:27:10.407Z"}
