{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EQrgephs4nF88qkrkwUsgo","type":"tool_result","content":"     1→/**\n     2→ * HTTP endpoint tests — exercises the full middleware stack (rate limit + JWT auth)\n     3→ * and route handlers for all endpoints:\n     4→ *\n     5→ * POST /fairness/coinflip/create:\n     6→ *   - 200 with valid JWT\n     7→ *   - 401 with missing JWT\n     8→ *   - 401 with expired JWT\n     9→ *   - 409 with duplicate PDA (same wallet + match ID collision)\n    10→ *   - 429 when rate limit exceeded\n    11→ *\n    12→ * GET /fairness/rounds/:pda:\n    13→ *   - 200 for known PDA\n    14→ *   - 404 for unknown PDA\n    15→ *\n    16→ * GET /health:\n    17→ *   - 200 with expected fields\n    18→ */\n    19→\n    20→import { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n    21→import { Hono } from \"hono\";\n    22→import { Keypair, LAMPORTS_PER_SOL } from \"@solana/web3.js\";\n    23→import type { Connection } from \"@solana/web3.js\";\n    24→import { SignJWT } from \"jose\";\n    25→import postgres from \"postgres\";\n    26→import { createDb, type Db } from \"../db.js\";\n    27→import { createCoinflipRoutes } from \"../routes/create.js\";\n    28→import { createLordRoutes } from \"../routes/lord-create.js\";\n    29→import { createRoundsRoutes } from \"../routes/rounds.js\";\n    30→import { createHealthRoutes } from \"../routes/health.js\";\n    31→import { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n    32→import { createRateLimitMiddleware } from \"../middleware/rate-limit.js\";\n    33→\n    34→// ---------------------------------------------------------------------------\n    35→// Constants\n    36→// ---------------------------------------------------------------------------\n    37→\n    38→const DATABASE_URL = \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n    39→const AMOUNT_LAMPORTS = 5_000_000; // 0.005 SOL\n    40→const SIDE_HEADS = 0;\n    41→const JWT_SECRET = new TextEncoder().encode(\"test-secret-for-endpoint-tests\");\n    42→\n    43→// ---------------------------------------------------------------------------\n    44→// Minimal mock Connection (only what routes + health need)\n    45→// ---------------------------------------------------------------------------\n    46→\n    47→class MockConnection {\n    48→  async getLatestBlockhash() {\n    49→    return {\n    50→      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n    51→      lastValidBlockHeight: 999_999,\n    52→    };\n    53→  }\n    54→\n    55→  async getAccountInfo() {\n    56→    return null;\n    57→  }\n    58→\n    59→  async getBalance() {\n    60→    return 1.5 * LAMPORTS_PER_SOL;"}]},"parent_tool_use_id":null,"session_id":"5a06e2aa-bee3-40eb-a97d-65518436146f","uuid":"cd634707-fd3a-4faf-95ac-248d32939ebf","timestamp":"2026-03-21T13:28:02.904Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/endpoints.test.ts","content":"/**\n * HTTP endpoint tests — exercises the full middleware stack (rate limit + JWT auth)\n * and route handlers for all endpoints:\n *\n * POST /fairness/coinflip/create:\n *   - 200 with valid JWT\n *   - 401 with missing JWT\n *   - 401 with expired JWT\n *   - 409 with duplicate PDA (same wallet + match ID collision)\n *   - 429 when rate limit exceeded\n *\n * GET /fairness/rounds/:pda:\n *   - 200 for known PDA\n *   - 404 for unknown PDA\n *\n * GET /health:\n *   - 200 with expected fields\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair, LAMPORTS_PER_SOL } from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport { SignJWT } from \"jose\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createCoinflipRoutes } from \"../routes/create.js\";\nimport { createLordRoutes } from \"../routes/lord-create.js\";\nimport { createRoundsRoutes } from \"../routes/rounds.js\";\nimport { createHealthRoutes } from \"../routes/health.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport { createRateLimitMiddleware } from \"../middleware/rate-limit.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL = \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\nconst AMOUNT_LAMPORTS = 5_000_000; // 0.005 SOL\nconst SIDE_HEADS = 0;\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-endpoint-tests\");\n\n// ---------------------------------------------------------------------------\n// Minimal mock Connection (only what routes + health need)\n// ---------------------------------------------------------------------------\n\nclass MockConnection {\n  async getLatestBlockhash() {\n    return {\n      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n      lastValidBlockHeight: 999_999,\n    };\n  }\n\n  async getAccountInfo() {\n    return null;\n  }\n\n  async getBalance() {\n    return 1.5 * LAMPORTS_PER_SOL;","numLines":60,"startLine":1,"totalLines":451}}}
