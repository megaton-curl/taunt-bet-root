{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01S5eao6dosQ6sxNNTDEfYS9","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/services/backend/src/queue/__tests__/queue.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"5a06e2aa-bee3-40eb-a97d-65518436146f","uuid":"7cfdfda2-1817-470d-91b3-07a6e5f1d821","timestamp":"2026-03-21T13:30:15.634Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/queue/__tests__/queue.test.ts","oldString":"const DATABASE_URL = \"postgresql://vscode@localhost:5432/rng_utopia_dev\";","newString":"const DATABASE_URL =\n  process.env.DATABASE_URL ??\n  \"postgresql://vscode@/rng_utopia_dev?host=/var/run/postgresql\";","originalFile":"/**\n * Unit tests for the async event queue module.\n *\n * Covers:\n * 1. emitEvent — inserts with correct fields, returns eventId\n * 2. emitEvent — rolled-back transaction does NOT persist\n * 3. Handler registry — register/get, unknown returns undefined\n * 4. Backoff calculation — attempt 1 → 5s, attempt 2 → 30s, attempt 3+ → 300s\n *\n * Requires a running Postgres database (same as backend).\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport postgres from \"postgres\";\nimport { emitEvent } from \"../emit-event.js\";\nimport { registerHandler, getHandler } from \"../handler-registry.js\";\nimport { EventTypes } from \"../event-types.js\";\nimport { getBackoffSeconds } from \"../worker.js\";\n\nconst DATABASE_URL = \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n\ndescribe(\"event queue unit tests\", () => {\n  let sql: ReturnType<typeof postgres>;\n\n  beforeAll(async () => {\n    sql = postgres(DATABASE_URL);\n  });\n\n  afterAll(async () => {\n    await sql.end();\n  });\n\n  beforeEach(async () => {\n    await sql`TRUNCATE event_queue RESTART IDENTITY`;\n  });\n\n  // -------------------------------------------------------------------------\n  // emitEvent\n  // -------------------------------------------------------------------------\n\n  describe(\"emitEvent\", () => {\n    it(\"inserts a row with correct fields and returns eventId\", async () => {\n      const payload = { referrerWallet: \"abc\", roundId: \"123\" };\n\n      const result = await sql.begin(async (tx) => {\n        return emitEvent(\n          tx as unknown as postgres.Sql,\n          EventTypes.REFERRAL_GAME_SETTLED,\n          payload,\n        );\n      });\n\n      expect(result.eventId).toBeTypeOf(\"bigint\");\n      expect(result.eventId).toBeGreaterThan(0n);\n\n      // Verify the persisted row\n      const rows = await sql`\n        SELECT * FROM event_queue WHERE id = ${result.eventId.toString()}\n      `;\n      expect(rows).toHaveLength(1);\n\n      const row = rows[0]!;\n      expect(row.event_type).toBe(\"referral.game_settled\");\n      expect(row.payload).toEqual(payload);\n      expect(row.status).toBe(\"pending\");\n      expect(row.attempts).toBe(0);\n      expect(row.max_attempts).toBe(3);\n      expect(row.scheduled_at).toBeInstanceOf(Date);\n      expect(row.created_at).toBeInstanceOf(Date);\n    });\n\n    it(\"does NOT persist when transaction is rolled back\", async () => {\n      let capturedId: bigint | undefined;\n\n      try {\n        await sql.begin(async (tx) => {\n          const result = await emitEvent(\n            tx as unknown as postgres.Sql,\n            EventTypes.REFERRAL_CODE_APPLIED,\n            { test: true },\n          );\n          capturedId = result.eventId;\n          throw new Error(\"intentional rollback\");\n        });\n      } catch {\n        // Expected — begin() re-throws after rollback\n      }\n\n      expect(capturedId).toBeDefined();\n      const rows = await sql`\n        SELECT * FROM event_queue WHERE id = ${capturedId!.toString()}\n      `;\n      expect(rows).toHaveLength(0);\n    });\n\n    it(\"respects custom maxAttempts and scheduledAt\", async () => {\n      const future = new Date(Date.now() + 60_000);\n\n      const result = await sql.begin(async (tx) => {\n        return emitEvent(\n          tx as unknown as postgres.Sql,\n          EventTypes.REFERRAL_CLAIM_REQUESTED,\n          { foo: \"bar\" },\n          { maxAttempts: 5, scheduledAt: future },\n        );\n      });\n\n      const rows = await sql`\n        SELECT * FROM event_queue WHERE id = ${result.eventId.toString()}\n      `;\n      expect(rows[0]!.max_attempts).toBe(5);\n      // scheduled_at should be close to the future date (within 1s tolerance)\n      const diff = Math.abs(rows[0]!.scheduled_at.getTime() - future.getTime());\n      expect(diff).toBeLessThan(1000);\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // Handler registry\n  // -------------------------------------------------------------------------\n\n  describe(\"handler registry\", () => {\n    it(\"register → get returns the handler\", () => {\n      const handler = async () => {};\n      registerHandler(EventTypes.REFERRAL_GAME_SETTLED, handler);\n      expect(getHandler(\"referral.game_settled\")).toBe(handler);\n    });\n\n    it(\"get for unknown type returns undefined\", () => {\n      expect(getHandler(\"unknown.event.type\")).toBeUndefined();\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // Backoff calculation\n  // -------------------------------------------------------------------------\n\n  describe(\"getBackoffSeconds\", () => {\n    it(\"attempt 1 → 5 seconds\", () => {\n      expect(getBackoffSeconds(1)).toBe(5);\n    });\n\n    it(\"attempt 2 → 30 seconds\", () => {\n      expect(getBackoffSeconds(2)).toBe(30);\n    });\n\n    it(\"attempt 3+ → 300 seconds\", () => {\n      expect(getBackoffSeconds(3)).toBe(300);\n      expect(getBackoffSeconds(4)).toBe(300);\n    });\n  });\n});\n","structuredPatch":[{"oldStart":17,"oldLines":7,"newStart":17,"newLines":9,"lines":[" import { EventTypes } from \"../event-types.js\";"," import { getBackoffSeconds } from \"../worker.js\";"," ","-const DATABASE_URL = \"postgresql://vscode@localhost:5432/rng_utopia_dev\";","+const DATABASE_URL =","+  process.env.DATABASE_URL ??","+  \"postgresql://vscode@/rng_utopia_dev?host=/var/run/postgresql\";"," "," describe(\"event queue unit tests\", () => {","   let sql: ReturnType<typeof postgres>;"]}],"userModified":false,"replaceAll":false}}
