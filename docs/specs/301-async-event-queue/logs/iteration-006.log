{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TAtTgtHysCz1cfZqddesQq","type":"tool_result","content":"     1→import { describe, it, expect } from \"vitest\";\n     2→import { Hono } from \"hono\";\n     3→import { SignJWT } from \"jose\";\n     4→import { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n     5→import type { AppEnv } from \"../hono-env.js\";\n     6→\n     7→const JWT_SECRET = new TextEncoder().encode(\"test-secret-key-for-jwt-auth-tests\");\n     8→\n     9→function createTestApp() {\n    10→  const app = new Hono<AppEnv>();\n    11→  app.use(\"/*\", createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }));\n    12→  app.post(\"/test\", (c) => c.json({ ok: true, wallet: c.get(\"wallet\") }));\n    13→  app.get(\"/test\", (c) => c.json({ ok: true }));\n    14→  return app;\n    15→}\n    16→\n    17→async function makeJwt(\n    18→  sub: string,\n    19→  opts?: { expiresIn?: number; secret?: Uint8Array },\n    20→) {\n    21→  const secret = opts?.secret ?? JWT_SECRET;\n    22→  const now = Math.floor(Date.now() / 1000);\n    23→  return new SignJWT({ sub })\n    24→    .setProtectedHeader({ alg: \"HS256\" })\n    25→    .setIssuedAt(now)\n    26→    .setExpirationTime(now + (opts?.expiresIn ?? 3600))\n    27→    .sign(secret);\n    28→}\n    29→\n    30→function post(token?: string) {\n    31→  const headers: Record<string, string> = { \"Content-Type\": \"application/json\" };\n    32→  if (token) {\n    33→    headers[\"Authorization\"] = `Bearer ${token}`;\n    34→  }\n    35→  return {\n    36→    method: \"POST\" as const,\n    37→    headers,\n    38→    body: JSON.stringify({ data: \"test\" }),\n    39→  };\n    40→}\n    41→\n    42→describe(\"JWT auth middleware\", () => {\n    43→  it(\"accepts a valid JWT\", async () => {\n    44→    const app = createTestApp();\n    45→    const token = await makeJwt(\"WalletPubkeyHere\");\n    46→    const res = await app.request(\"/test\", post(token));\n    47→    expect(res.status).toBe(200);\n    48→    const json = (await res.json()) as { ok: boolean; wallet: string };\n    49→    expect(json.ok).toBe(true);\n    50→    expect(json.wallet).toBe(\"WalletPubkeyHere\");\n    51→  });\n    52→\n    53→  it(\"rejects missing Authorization header\", async () => {\n    54→    const app = createTestApp();\n    55→    const res = await app.request(\"/test\", post());\n    56→    expect(res.status).toBe(401);\n    57→  });\n    58→\n    59→  it(\"rejects malformed Authorization header\", async () => {\n    60→    const app = createTestApp();\n    61→    const res = await app.request(\"/test\", {\n    62→      method: \"POST\",\n    63→      headers: {\n    64→        \"Content-Type\": \"application/json\",\n    65→        \"Authorization\": \"Basic abc123\",\n    66→      },\n    67→      body: JSON.stringify({}),\n    68→    });\n    69→    expect(res.status).toBe(401);\n    70→  });\n    71→\n    72→  it(\"rejects an expired JWT\", async () => {\n    73→    const app = createTestApp();\n    74→    const token = await makeJwt(\"WalletPubkeyHere\", { expiresIn: -10 });\n    75→    const res = await app.request(\"/test\", post(token));\n    76→    expect(res.status).toBe(401);\n    77→  });\n    78→\n    79→  it(\"rejects a JWT signed with wrong secret\", async () => {\n    80→    const app = createTestApp();\n    81→    const wrongSecret = new TextEncoder().encode(\"wrong-secret-key\");\n    82→    const token = await makeJwt(\"WalletPubkeyHere\", { secret: wrongSecret });\n    83→    const res = await app.request(\"/test\", post(token));\n    84→    expect(res.status).toBe(401);\n    85→  });\n    86→\n    87→  it(\"passes GET requests without authentication\", async () => {\n    88→    const app = createTestApp();\n    89→    const res = await app.request(\"/test\", { method: \"GET\" });\n    90→    expect(res.status).toBe(200);\n    91→  });\n    92→\n    93→  it(\"sets wallet in context from JWT sub claim\", async () => {\n    94→    const app = createTestApp();\n    95→    const wallet = \"7xKXtg2CW87d97TXJSDpbD5jBkheTqA83TZRuJosgAsU\";\n    96→    const token = await makeJwt(wallet);\n    97→    const res = await app.request(\"/test\", post(token));\n    98→    expect(res.status).toBe(200);\n    99→    const json = (await res.json()) as { wallet: string };\n   100→    expect(json.wallet).toBe(wallet);\n   101→  });\n   102→});\n   103→"}]},"parent_tool_use_id":"toolu_01JFkRRo6fd7WCE7xZR8iApU","session_id":"5a06e2aa-bee3-40eb-a97d-65518436146f","uuid":"31495eb1-604e-409f-ab35-8da4a53f2b30","timestamp":"2026-03-21T13:27:09.501Z"}
