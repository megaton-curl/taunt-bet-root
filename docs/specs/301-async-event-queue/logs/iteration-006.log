{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017rVw7Mqtioeu7Uo6oidkzu","type":"tool_result","content":"     1→/**\n     2→ * Integration test: full create → join → settle lifecycle.\n     3→ *\n     4→ * Uses a mock Solana Connection to simulate on-chain state while exercising\n     5→ * the real HTTP endpoints, database, settlement worker, and retry logic\n     6→ * end-to-end. Auth uses JWT Bearer tokens (HS256).\n     7→ */\n     8→\n     9→import { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n    10→import { Hono } from \"hono\";\n    11→import {\n    12→  Keypair,\n    13→  PublicKey,\n    14→  SystemProgram,\n    15→  LAMPORTS_PER_SOL,\n    16→} from \"@solana/web3.js\";\n    17→import type { Connection } from \"@solana/web3.js\";\n    18→import bs58 from \"bs58\";\n    19→import { SignJWT } from \"jose\";\n    20→import postgres from \"postgres\";\n    21→import { createDb, type Db } from \"../db.js\";\n    22→import { createCoinflipRoutes } from \"../routes/create.js\";\n    23→import { createRoundsRoutes } from \"../routes/rounds.js\";\n    24→import { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n    25→import { createSettlementWorker } from \"../worker/settlement.js\";\n    26→import { settleMatch } from \"../worker/settle-tx.js\";\n    27→import { createRetrySettler } from \"../worker/retry.js\";\n    28→import { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n    29→import { encodeCoinflipMatch, encodeCoinflipConfig } from \"../worker/account-decoder.js\";\n    30→\n    31→// ---------------------------------------------------------------------------\n    32→// Constants\n    33→// ---------------------------------------------------------------------------\n    34→\n    35→const DATABASE_URL = \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n    36→const AMOUNT_LAMPORTS = 5_000_000;\n    37→const AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\n    38→const SIDE_HEADS = 0;\n    39→const PHASE_LOCKED = 1;\n    40→const JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n    41→\n    42→// ---------------------------------------------------------------------------\n    43→// JWT helper\n    44→// ---------------------------------------------------------------------------\n    45→\n    46→async function makeJwt(wallet: string) {\n    47→  const now = Math.floor(Date.now() / 1000);\n    48→  return new SignJWT({ sub: wallet })\n    49→    .setProtectedHeader({ alg: \"HS256\" })\n    50→    .setIssuedAt(now)\n    51→    .setExpirationTime(now + 3600)\n    52→    .sign(JWT_SECRET);\n    53→}\n    54→\n    55→// ---------------------------------------------------------------------------\n    56→// Mock Connection\n    57→// ---------------------------------------------------------------------------\n    58→\n    59→/**\n    60→ * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n    61→ * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n    62→ * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n    63→ */\n    64→class MockConnection {\n    65→  private _slot = 200;\n    66→  private _accounts = new Map<\n    67→    string,\n    68→    {\n    69→      data: Buffer;\n    70→      lamports: number;\n    71→      owner: PublicKey;\n    72→      executable: boolean;\n    73→    }\n    74→  >();\n    75→  lastRawTx: Buffer | null = null;\n    76→\n    77→  set slot(s: number) {\n    78→    this._slot = s;\n    79→  }\n    80→  get slot() {\n    81→    return this._slot;\n    82→  }\n    83→\n    84→  setAccount(\n    85→    pubkey: PublicKey,\n    86→    data: Buffer,\n    87→    opts?: { lamports?: number; owner?: PublicKey },\n    88→  ) {\n    89→    this._accounts.set(pubkey.toBase58(), {\n    90→      data,\n    91→      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n    92→      owner: opts?.owner ?? SystemProgram.programId,\n    93→      executable: false,\n    94→    });\n    95→  }\n    96→\n    97→  removeAccount(pubkey: PublicKey) {\n    98→    this._accounts.delete(pubkey.toBase58());\n    99→  }\n   100→\n   101→  async getLatestBlockhash() {\n   102→    return {\n   103→      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n   104→      lastValidBlockHeight: 999_999,\n   105→    };\n   106→  }\n   107→\n   108→  async getSlot() {\n   109→    return this._slot;\n   110→  }\n   111→\n   112→  async getAccountInfo(pubkey: PublicKey) {\n   113→    const acc = this._accounts.get(pubkey.toBase58());\n   114→    if (!acc) return null;\n   115→    return { ...acc, rentEpoch: 0 };\n   116→  }\n   117→\n   118→  async getProgramAccounts(\n   119→    programId: PublicKey,\n   120→    config?: {\n   121→      filters?: Array<\n   122→        | { dataSize: number }\n   123→        | { memcmp: { offset: number; bytes: string } }\n   124→      >;\n   125→    },\n   126→  ) {\n   127→    const results: Array<{\n   128→      pubkey: PublicKey;\n   129→      account: {\n   130→        data: Buffer;\n   131→        lamports: number;\n   132→        owner: PublicKey;\n   133→        executable: boolean;\n   134→        rentEpoch: number;\n   135→      };\n   136→    }> = [];\n   137→\n   138→    for (const [key, acc] of this._accounts) {\n   139→      if (!acc.owner.equals(programId)) continue;\n   140→\n   141→      let matches = true;\n   142→      if (config?.filters) {\n   143→        for (const filter of config.filters) {\n   144→          if (\"dataSize\" in filter) {\n   145→            if (acc.data.length !== filter.dataSize) {\n   146→              matches = false;\n   147→              break;\n   148→            }\n   149→          }\n   150→          if (\"memcmp\" in filter) {\n   151→            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n   152→            const actual = acc.data.subarray(\n   153→              filter.memcmp.offset,\n   154→              filter.memcmp.offset + expected.length,\n   155→            );\n   156→            if (Buffer.compare(actual, expected) !== 0) {\n   157→              matches = false;\n   158→              break;\n   159→            }\n   160→          }\n   161→        }\n   162→      }\n   163→\n   164→      if (matches) {\n   165→        results.push({\n   166→          pubkey: new PublicKey(key),\n   167→          account: { ...acc, rentEpoch: 0 },\n   168→        });\n   169→      }\n   170→    }\n   171→    return results;\n   172→  }\n   173→\n   174→  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n   175→    this.lastRawTx = Buffer.from(rawTx);\n   176→    // Return a deterministic fake signature\n   177→    return bs58.encode(Buffer.alloc(64, 0x01));\n   178→  }\n   179→\n   180→  async confirmTransaction() {\n   181→    return { value: { err: null }, context: { slot: this._slot } };\n   182→  }\n   183→\n   184→  async getBlockTime(_slot: number) {\n   185→    return Math.floor(Date.now() / 1000);\n   186→  }\n   187→\n   188→  async getBalance() {\n   189→    return 2 * LAMPORTS_PER_SOL;\n   190→  }\n   191→}\n   192→\n   193→// ---------------------------------------------------------------------------\n   194→// Account data builders\n   195→// ---------------------------------------------------------------------------\n   196→\n   197→async function buildMatchAccountData(params: {\n   198→  creator: PublicKey;\n   199→  opponent: PublicKey;\n   200→  server: PublicKey;\n   201→  entryAmount: bigint;\n   202→  creatorSide: number;\n   203→  phase: number;\n   204→  commitment: Buffer;\n   205→  algorithmVer: number;\n   206→  targetSlot: bigint;\n   207→  resolveDeadline: bigint;\n   208→  matchId: Buffer;\n   209→}): Promise<Buffer> {\n   210→  return encodeCoinflipMatch({\n   211→    creator: params.creator,\n   212→    opponent: params.opponent,\n   213→    server: params.server,\n   214→    entryAmount: params.entryAmount,\n   215→    creatorSide: params.creatorSide,\n   216→    phase: params.phase,\n   217→    commitment: [...params.commitment],\n   218→    algorithmVer: params.algorithmVer,\n   219→    targetSlot: params.targetSlot,\n   220→    resolveDeadline: params.resolveDeadline,\n   221→    resultHash: new Array(32).fill(0),\n   222→    result: 0,\n   223→    winner: PublicKey.default,\n   224→    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n   225→    matchId: [...params.matchId],\n   226→    bump: 0,\n   227→  });\n   228→}\n   229→\n   230→async function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n   231→  return encodeCoinflipConfig({\n   232→    authority: PublicKey.default,\n   233→    treasury,\n   234→    paused: false,\n   235→    bump: 0,\n   236→  });\n   237→}\n   238→\n   239→// ---------------------------------------------------------------------------\n   240→// Test suite\n   241→// ---------------------------------------------------------------------------\n   242→\n   243→describe(\"Integration: create → join → settle lifecycle\", () => {\n   244→  let db: Db;\n   245→  let rawSql: ReturnType<typeof postgres>;\n   246→  let mockConn: MockConnection;\n   247→  let app: Hono;\n   248→\n   249→  const serverKeypair = Keypair.generate();\n   250→  const creatorKeypair = Keypair.generate();\n   251→  const opponentKeypair = Keypair.generate();\n   252→  const treasuryKeypair = Keypair.generate();\n   253→  const entropyKeypair = Keypair.generate();\n   254→  const entropyAccount = entropyKeypair.publicKey;\n   255→\n   256→  const entropyData = Buffer.alloc(32);\n   257→  entropyData[0] = 0xab;\n   258→  entropyData[1] = 0xcd;\n   259→  entropyData[15] = 0x42;\n   260→\n   261→  beforeAll(async () => {\n   262→    db = createDb(DATABASE_URL);\n   263→    rawSql = postgres(DATABASE_URL);\n   264→  });\n   265→\n   266→  afterAll(async () => {\n   267→    await db.close();\n   268→    await rawSql.end();\n   269→  });\n   270→\n   271→  beforeEach(async () => {\n   272→    // Clean tables for isolation\n   273→    await rawSql`TRUNCATE rounds, operator_events RESTART IDENTITY`;\n   274→\n   275→    // Fresh mock Connection\n   276→    mockConn = new MockConnection();\n   277→\n   278→    // Pre-populate mock with entropy and config accounts\n   279→    mockConn.setAccount(entropyAccount, entropyData);\n   280→\n   281→    const [configPda] = PublicKey.findProgramAddressSync(\n   282→      [Buffer.from(\"coinflip_config\")],\n   283→      COINFLIP_PROGRAM_ID,\n   284→    );\n   285→    mockConn.setAccount(\n   286→      configPda,\n   287→      await buildConfigAccountData(treasuryKeypair.publicKey),\n   288→      { owner: COINFLIP_PROGRAM_ID },\n   289→    );\n   290→\n   291→    // Build the Hono app (no rate limiting for tests)\n   292→    app = new Hono();\n   293→\n   294→    app.use(\n   295→      \"/fairness/*\",\n   296→      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n   297→    );\n   298→\n   299→    app.route(\n   300→      \"/fairness/coinflip\",\n   301→      createCoinflipRoutes({\n   302→        db,\n   303→        connection: mockConn as unknown as Connection,\n   304→        serverKeypair,\n   305→      }),\n   306→    );\n   307→\n   308→    app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n   309→  });\n   310→\n   311→  it(\"full lifecycle: create → join (mock) → settle → verify\", async () => {\n   312→    const wallet = creatorKeypair.publicKey.toBase58();\n   313→    const token = await makeJwt(wallet);\n   314→\n   315→    // ------------------------------------------------------------------\n   316→    // 1. POST /fairness/coinflip/create\n   317→    // ------------------------------------------------------------------\n   318→    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n   319→\n   320→    const createRes = await app.request(\"/fairness/coinflip/create\", {\n   321→      method: \"POST\",\n   322→      headers: {\n   323→        \"Content-Type\": \"application/json\",\n   324→        \"Authorization\": `Bearer ${token}`,\n   325→      },\n   326→      body: JSON.stringify(body),\n   327→    });\n   328→\n   329→    expect(createRes.status).toBe(200);\n   330→    const createJson = (await createRes.json()) as {\n   331→      transaction: string;\n   332→      matchPda: string;\n   333→      matchId: string;\n   334→      commitment: string;\n   335→      lastValidBlockHeight: number;\n   336→    };\n   337→    expect(createJson.transaction).toBeDefined();\n   338→    expect(createJson.matchPda).toBeDefined();\n   339→    expect(createJson.commitment).toBeDefined();\n   340→    expect(createJson.lastValidBlockHeight).toBeDefined();\n   341→\n   342→    const matchPda = createJson.matchPda;\n   343→    const commitmentHex = createJson.commitment;\n   344→    const commitmentBuf = Buffer.from(commitmentHex, \"hex\");\n   345→\n   346→    // ------------------------------------------------------------------\n   347→    // 2. Verify DB state — round in \"created\" phase\n   348→    // ------------------------------------------------------------------\n   349→    const round = await db.getRoundByPda(matchPda);\n   350→    expect(round).toBeDefined();\n   351→    expect(round!.phase).toBe(\"created\");\n   352→    expect(round!.game).toBe(\"coinflip\");\n   353→    expect(round!.creator).toBe(wallet);\n   354→    expect(round!.amount_lamports).toBe(AMOUNT_LAMPORTS);\n   355→    expect(round!.side).toBe(SIDE_HEADS);\n   356→    expect(round!.commitment.toString(\"hex\")).toBe(commitmentHex);\n   357→    expect(round!.secret).toBeDefined();\n   358→    expect(round!.secret.length).toBe(32);\n   359→\n   360→    // Verify operator event was logged\n   361→    const events =\n   362→      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n   363→    expect(events.length).toBe(1);\n   364→    expect(events[0]!.event_type).toBe(\"secret_generated\");\n   365→\n   366→    // ------------------------------------------------------------------\n   367→    // 3. Simulate on-chain join — add LOCKED match to mock Connection\n   368→    // ------------------------------------------------------------------\n   369→    const matchPubkey = new PublicKey(matchPda);\n   370→    const targetSlot = 150n;\n   371→    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n   372→\n   373→    const matchAccountData = await buildMatchAccountData({\n   374→      creator: creatorKeypair.publicKey,\n   375→      opponent: opponentKeypair.publicKey,\n   376→      server: serverKeypair.publicKey,\n   377→      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n   378→      creatorSide: SIDE_HEADS,\n   379→      phase: PHASE_LOCKED,\n   380→      commitment: commitmentBuf,\n   381→      algorithmVer: 1,\n   382→      targetSlot,\n   383→      resolveDeadline,\n   384→      matchId: Buffer.from(createJson.matchId, \"hex\"),\n   385→    });\n   386→\n   387→    mockConn.setAccount(matchPubkey, matchAccountData, {\n   388→      owner: COINFLIP_PROGRAM_ID,\n   389→    });\n   390→\n   391→    // Set current slot past target_slot so settlement triggers immediately\n   392→    mockConn.slot = 200;\n   393→\n   394→    // ------------------------------------------------------------------\n   395→    // 4. Create worker + retry settler, trigger poll\n   396→    // ------------------------------------------------------------------\n   397→    let settlePromise: Promise<void> | null = null;\n   398→\n   399→    const retrySettler = createRetrySettler({\n   400→      db,\n   401→      connection: mockConn as unknown as Connection,\n   402→      settleRound: (pda) =>\n   403→        settleMatch(\n   404→          {\n   405→            db,\n   406→            connection: mockConn as unknown as Connection,\n   407→            serverKeypair,\n   408→            entropyAccount,\n   409→          },\n   410→          pda,\n   411→        ),\n   412→    });\n   413→\n   414→    const worker = createSettlementWorker({\n   415→      db,\n   416→      connection: mockConn as unknown as Connection,\n   417→      serverKey: serverKeypair.publicKey,\n   418→      pollIntervalMs: 60_000, // won't auto-poll\n   419→      onSettleReady: (pda) => {\n   420→        settlePromise = retrySettler.attemptSettle(pda);\n   421→        return settlePromise;\n   422→      },\n   423→    });\n   424→\n   425→    // Single poll cycle — should discover locked match and settle it\n   426→    await worker.poll();\n   427→    if (settlePromise) await settlePromise;\n   428→\n   429→    // ------------------------------------------------------------------\n   430→    // 5. Verify DB updated to \"settled\" with result data\n   431→    // ------------------------------------------------------------------\n   432→    const settled = await db.getRoundByPda(matchPda);\n   433→    expect(settled).toBeDefined();\n   434→    expect(settled!.phase).toBe(\"settled\");\n   435→    expect(settled!.settle_tx).toBeDefined();\n   436→    expect(settled!.result_hash).toBeDefined();\n   437→    expect(settled!.result_hash!.length).toBe(32);\n   438→    expect(settled!.result_side).toBeDefined();\n   439→    expect([0, 1]).toContain(settled!.result_side);\n   440→    expect(settled!.winner).toBeDefined();\n   441→\n   442→    // Winner should be one of the two players\n   443→    expect([\n   444→      creatorKeypair.publicKey.toBase58(),\n   445→      opponentKeypair.publicKey.toBase58(),\n   446→    ]).toContain(settled!.winner);\n   447→\n   448→    // Verify operator events trail\n   449→    const allEvents =\n   450→      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n   451→    const eventTypes = allEvents.map(\n   452→      (e) => (e as Record<string, unknown>).event_type,\n   453→    );\n   454→    expect(eventTypes).toContain(\"secret_generated\");\n   455→    expect(eventTypes).toContain(\"match_detected\");\n   456→    expect(eventTypes).toContain(\"settle_submitted\");\n   457→    expect(eventTypes).toContain(\"settle_confirmed\");\n   458→\n   459→    // ------------------------------------------------------------------\n   460→    // 6. GET /fairness/rounds/:pda — verify response includes secret\n   461→    // ------------------------------------------------------------------\n   462→    const roundsRes = await app.request(`/fairness/rounds/${matchPda}`);\n   463→    expect(roundsRes.status).toBe(200);\n   464→\n   465→    const roundsJson = (await roundsRes.json()) as Record<string, unknown>;\n   466→    expect(roundsJson.pda).toBe(matchPda);\n   467→    expect(roundsJson.phase).toBe(\"settled\");\n   468→    expect(roundsJson.game).toBe(\"coinflip\");\n   469→    expect(roundsJson.creator).toBe(wallet);\n   470→    expect(roundsJson.commitment).toBe(commitmentHex);\n   471→\n   472→    // Settled round should include secret + verification payload\n   473→    expect(roundsJson.secret).toBeDefined();\n   474→    expect(typeof roundsJson.secret).toBe(\"string\");\n   475→    expect((roundsJson.secret as string).length).toBe(64); // 32 bytes hex\n   476→    expect(roundsJson.resultHash).toBeDefined();\n   477→    expect(roundsJson.resultSide).toBeDefined();\n   478→    expect(roundsJson.winner).toBeDefined();\n   479→    expect(roundsJson.settleTx).toBeDefined();\n   480→\n   481→    // Verification object\n   482→    const verification = roundsJson.verification as Record<string, string>;\n   483→    expect(verification).toBeDefined();\n   484→    expect(verification.commitmentCheck).toBe(\"sha256(secret) == commitment\");\n   485→    expect(verification.resultFormula).toContain(\"sha256(secret\");\n   486→    expect(verification.entropySource).toContain(\"SlotHashes\");\n   487→  });\n   488→\n   489→  it(\"GET /rounds/:pda returns 404 for unknown PDA\", async () => {\n   490→    const unknownPda = Keypair.generate().publicKey.toBase58();\n   491→    const res = await app.request(`/fairness/rounds/${unknownPda}`);\n   492→    expect(res.status).toBe(404);\n   493→  });\n   494→\n   495→  it(\"unsettled round does not expose secret\", async () => {\n   496→    const wallet = creatorKeypair.publicKey.toBase58();\n   497→    const token = await makeJwt(wallet);\n   498→\n   499→    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n   500→\n   501→    const res = await app.request(\"/fairness/coinflip/create\", {\n   502→      method: \"POST\",\n   503→      headers: {\n   504→        \"Content-Type\": \"application/json\",\n   505→        \"Authorization\": `Bearer ${token}`,\n   506→      },\n   507→      body: JSON.stringify(body),\n   508→    });\n   509→    expect(res.status).toBe(200);\n   510→    const json = (await res.json()) as { matchPda: string };\n   511→\n   512→    // GET the unsettled round\n   513→    const roundRes = await app.request(`/fairness/rounds/${json.matchPda}`);\n   514→    expect(roundRes.status).toBe(200);\n   515→    const roundJson = (await roundRes.json()) as Record<string, unknown>;\n   516→    expect(roundJson.phase).toBe(\"created\");\n   517→    expect(roundJson.secret).toBeUndefined();\n   518→    expect(roundJson.resultHash).toBeUndefined();\n   519→    expect(roundJson.verification).toBeUndefined();\n   520→  });\n   521→\n   522→  it(\"two creates from same wallet succeed (different match IDs)\", async () => {\n   523→    const wallet = creatorKeypair.publicKey.toBase58();\n   524→    const token = await makeJwt(wallet);\n   525→\n   526→    const body1 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n   527→    const res1 = await app.request(\"/fairness/coinflip/create\", {\n   528→      method: \"POST\",\n   529→      headers: {\n   530→        \"Content-Type\": \"application/json\",\n   531→        \"Authorization\": `Bearer ${token}`,\n   532→      },\n   533→      body: JSON.stringify(body1),\n   534→    });\n   535→    expect(res1.status).toBe(200);\n   536→\n   537→    // Second request — different random matchId generated server-side\n   538→    const body2 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n   539→    const res2 = await app.request(\"/fairness/coinflip/create\", {\n   540→      method: \"POST\",\n   541→      headers: {\n   542→        \"Content-Type\": \"application/json\",\n   543→        \"Authorization\": `Bearer ${token}`,\n   544→      },\n   545→      body: JSON.stringify(body2),\n   546→    });\n   547→    expect(res2.status).toBe(200);\n   548→\n   549→    // Both should have different matchIds and PDAs\n   550→    const json1 = (await res1.json()) as { matchPda: string; matchId: string };\n   551→    const json2 = (await res2.json()) as { matchPda: string; matchId: string };\n   552→    expect(json1.matchPda).not.toBe(json2.matchPda);\n   553→    expect(json1.matchId).not.toBe(json2.matchId);\n   554→  });\n   555→});\n   556→"}]},"parent_tool_use_id":"toolu_01JFkRRo6fd7WCE7xZR8iApU","session_id":"5a06e2aa-bee3-40eb-a97d-65518436146f","uuid":"56b87d13-286e-45d0-ba2c-a6779009250c","timestamp":"2026-03-21T13:27:12.882Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013oEJxQY5a495hUct7DBJn9","type":"tool_result","content":"     1→/**\n     2→ * Auth routes tests: challenge → verify → refresh → logout flows.\n     3→ */\n     4→\n     5→import { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n     6→import { Hono } from \"hono\";\n     7→import { Keypair } from \"@solana/web3.js\";\n     8→import nacl from \"tweetnacl\";\n     9→import bs58 from \"bs58\";\n    10→import { jwtVerify } from \"jose\";\n    11→import postgres from \"postgres\";\n    12→import { createAuthDb, type AuthDb } from \"../auth-db.js\";\n    13→import { createAuthRoutes } from \"../routes/auth.js\";\n    14→\n    15→// ---------------------------------------------------------------------------\n    16→// Constants\n    17→// ---------------------------------------------------------------------------\n    18→\n    19→const DATABASE_URL = \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n    20→const JWT_SECRET = new TextEncoder().encode(\"test-secret-for-auth-route-tests\");\n    21→\n    22→// ---------------------------------------------------------------------------\n    23→// Test suite\n    24→// ---------------------------------------------------------------------------\n    25→\n    26→describe(\"Auth routes: challenge → verify → refresh → logout\", () => {\n    27→  let rawSql: ReturnType<typeof postgres>;\n    28→  let authDb: AuthDb;\n    29→  let app: Hono;\n    30→\n    31→  const creatorKeypair = Keypair.generate();\n    32→\n    33→  beforeAll(async () => {\n    34→    rawSql = postgres(DATABASE_URL);\n    35→    // Ensure auth tables exist\n    36→    await rawSql`\n    37→      CREATE TABLE IF NOT EXISTS auth_challenges (\n    38→        nonce TEXT PRIMARY KEY,\n    39→        wallet TEXT NOT NULL,\n    40→        cluster TEXT NOT NULL DEFAULT 'devnet',\n    41→        message TEXT NOT NULL,\n    42→        expires_at TIMESTAMPTZ NOT NULL,\n    43→        used BOOLEAN DEFAULT FALSE,\n    44→        created_at TIMESTAMPTZ DEFAULT now()\n    45→      )\n    46→    `;\n    47→    await rawSql`\n    48→      CREATE TABLE IF NOT EXISTS refresh_tokens (\n    49→        id BIGSERIAL PRIMARY KEY,\n    50→        wallet TEXT NOT NULL,\n    51→        token_hash BYTEA NOT NULL UNIQUE,\n    52→        family_id TEXT NOT NULL,\n    53→        expires_at TIMESTAMPTZ NOT NULL,\n    54→        revoked BOOLEAN DEFAULT FALSE,\n    55→        created_at TIMESTAMPTZ DEFAULT now()\n    56→      )\n    57→    `;\n    58→  });\n    59→\n    60→  afterAll(async () => {\n    61→    await rawSql.end();\n    62→  });\n    63→\n    64→  beforeEach(async () => {\n    65→    await rawSql`TRUNCATE auth_challenges, refresh_tokens RESTART IDENTITY`;\n    66→    authDb = createAuthDb(rawSql);\n    67→    app = new Hono();\n    68→    app.route(\n    69→      \"/auth\",\n    70→      createAuthRoutes({\n    71→        authDb,\n    72→        jwtSecret: JWT_SECRET,\n    73→        cluster: \"devnet\",\n    74→        challengeTtlSeconds: 300,\n    75→        accessTokenTtlSeconds: 3600,\n    76→        refreshTokenTtlDays: 14,\n    77→      }),\n    78→    );\n    79→  });\n    80→\n    81→  // -----------------------------------------------------------------------\n    82→  // POST /auth/challenge\n    83→  // -----------------------------------------------------------------------\n    84→\n    85→  it(\"returns a challenge with nonce and message\", async () => {\n    86→    const wallet = creatorKeypair.publicKey.toBase58();\n    87→    const res = await app.request(\"/auth/challenge\", {\n    88→      method: \"POST\",\n    89→      headers: { \"Content-Type\": \"application/json\" },\n    90→      body: JSON.stringify({ wallet }),\n    91→    });\n    92→\n    93→    expect(res.status).toBe(200);\n    94→    const json = (await res.json()) as { nonce: string; message: string; expiresAt: string };\n    95→    expect(json.nonce).toBeDefined();\n    96→    expect(json.nonce.length).toBe(64); // 32 bytes hex\n    97→    expect(json.message).toContain(\"Sign in to RNG Utopia\");\n    98→    expect(json.message).toContain(wallet);\n    99→    expect(json.message).toContain(\"devnet\");\n   100→    expect(json.expiresAt).toBeDefined();\n   101→  });\n   102→\n   103→  it(\"rejects challenge with missing wallet\", async () => {\n   104→    const res = await app.request(\"/auth/challenge\", {\n   105→      method: \"POST\",\n   106→      headers: { \"Content-Type\": \"application/json\" },\n   107→      body: JSON.stringify({}),\n   108→    });\n   109→    expect(res.status).toBe(400);\n   110→  });\n   111→\n   112→  // -----------------------------------------------------------------------\n   113→  // Full flow: challenge → verify → refresh → logout\n   114→  // -----------------------------------------------------------------------\n   115→\n   116→  it(\"full auth flow: challenge → verify → refresh → logout\", async () => {\n   117→    const wallet = creatorKeypair.publicKey.toBase58();\n   118→\n   119→    // 1. Request challenge\n   120→    const challengeRes = await app.request(\"/auth/challenge\", {\n   121→      method: \"POST\",\n   122→      headers: { \"Content-Type\": \"application/json\" },\n   123→      body: JSON.stringify({ wallet }),\n   124→    });\n   125→    expect(challengeRes.status).toBe(200);\n   126→    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n   127→\n   128→    // 2. Sign the message\n   129→    const messageBytes = new TextEncoder().encode(challenge.message);\n   130→    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n   131→    const signature = bs58.encode(signatureBytes);\n   132→\n   133→    // 3. Verify\n   134→    const verifyRes = await app.request(\"/auth/verify\", {\n   135→      method: \"POST\",\n   136→      headers: { \"Content-Type\": \"application/json\" },\n   137→      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n   138→    });\n   139→    expect(verifyRes.status).toBe(200);\n   140→    const tokens = (await verifyRes.json()) as {\n   141→      accessToken: string;\n   142→      accessExpiresAt: string;\n   143→      refreshToken: string;\n   144→      refreshExpiresAt: string;\n   145→    };\n   146→    expect(tokens.accessToken).toBeDefined();\n   147→    expect(tokens.refreshToken).toBeDefined();\n   148→    expect(tokens.accessExpiresAt).toBeDefined();\n   149→    expect(tokens.refreshExpiresAt).toBeDefined();\n   150→\n   151→    // Verify JWT is valid and contains the correct wallet\n   152→    const { payload } = await jwtVerify(tokens.accessToken, JWT_SECRET, {\n   153→      algorithms: [\"HS256\"],\n   154→    });\n   155→    expect(payload.sub).toBe(wallet);\n   156→\n   157→    // 4. Refresh\n   158→    const refreshRes = await app.request(\"/auth/refresh\", {\n   159→      method: \"POST\",\n   160→      headers: { \"Content-Type\": \"application/json\" },\n   161→      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n   162→    });\n   163→    expect(refreshRes.status).toBe(200);\n   164→    const newTokens = (await refreshRes.json()) as {\n   165→      accessToken: string;\n   166→      refreshToken: string;\n   167→    };\n   168→    expect(newTokens.accessToken).toBeDefined();\n   169→    expect(newTokens.refreshToken).toBeDefined();\n   170→    // New refresh token should be different from the old one\n   171→    expect(newTokens.refreshToken).not.toBe(tokens.refreshToken);\n   172→\n   173→    // 5. Old refresh token should no longer work (it was rotated)\n   174→    const replayRes = await app.request(\"/auth/refresh\", {\n   175→      method: \"POST\",\n   176→      headers: { \"Content-Type\": \"application/json\" },\n   177→      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n   178→    });\n   179→    expect(replayRes.status).toBe(401);\n   180→    const replayJson = (await replayRes.json()) as { error: string };\n   181→    expect(replayJson.error).toContain(\"reuse\");\n   182→\n   183→    // 6. Logout with new token\n   184→    const logoutRes = await app.request(\"/auth/logout\", {\n   185→      method: \"POST\",\n   186→      headers: { \"Content-Type\": \"application/json\" },\n   187→      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n   188→    });\n   189→    expect(logoutRes.status).toBe(204);\n   190→\n   191→    // 7. Refresh after logout should fail\n   192→    const postLogoutRefresh = await app.request(\"/auth/refresh\", {\n   193→      method: \"POST\",\n   194→      headers: { \"Content-Type\": \"application/json\" },\n   195→      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n   196→    });\n   197→    expect(postLogoutRefresh.status).toBe(401);\n   198→  });\n   199→\n   200→  // -----------------------------------------------------------------------\n   201→  // Edge cases\n   202→  // -----------------------------------------------------------------------\n   203→\n   204→  it(\"rejects verify with wrong wallet\", async () => {\n   205→    const wallet = creatorKeypair.publicKey.toBase58();\n   206→    const otherKeypair = Keypair.generate();\n   207→\n   208→    // Get challenge for the correct wallet\n   209→    const challengeRes = await app.request(\"/auth/challenge\", {\n   210→      method: \"POST\",\n   211→      headers: { \"Content-Type\": \"application/json\" },\n   212→      body: JSON.stringify({ wallet }),\n   213→    });\n   214→    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n   215→\n   216→    // Sign with the correct keypair\n   217→    const messageBytes = new TextEncoder().encode(challenge.message);\n   218→    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n   219→    const signature = bs58.encode(signatureBytes);\n   220→\n   221→    // But claim to be a different wallet\n   222→    const verifyRes = await app.request(\"/auth/verify\", {\n   223→      method: \"POST\",\n   224→      headers: { \"Content-Type\": \"application/json\" },\n   225→      body: JSON.stringify({\n   226→        nonce: challenge.nonce,\n   227→        wallet: otherKeypair.publicKey.toBase58(),\n   228→        signature,\n   229→      }),\n   230→    });\n   231→    expect(verifyRes.status).toBe(401);\n   232→  });\n   233→\n   234→  it(\"rejects verify with wrong signature\", async () => {\n   235→    const wallet = creatorKeypair.publicKey.toBase58();\n   236→    const otherKeypair = Keypair.generate();\n   237→\n   238→    const challengeRes = await app.request(\"/auth/challenge\", {\n   239→      method: \"POST\",\n   240→      headers: { \"Content-Type\": \"application/json\" },\n   241→      body: JSON.stringify({ wallet }),\n   242→    });\n   243→    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n   244→\n   245→    // Sign with wrong keypair\n   246→    const messageBytes = new TextEncoder().encode(challenge.message);\n   247→    const signatureBytes = nacl.sign.detached(messageBytes, otherKeypair.secretKey);\n   248→    const signature = bs58.encode(signatureBytes);\n   249→\n   250→    const verifyRes = await app.request(\"/auth/verify\", {\n   251→      method: \"POST\",\n   252→      headers: { \"Content-Type\": \"application/json\" },\n   253→      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n   254→    });\n   255→    expect(verifyRes.status).toBe(401);\n   256→  });\n   257→\n   258→  it(\"rejects verify with already-used nonce\", async () => {\n   259→    const wallet = creatorKeypair.publicKey.toBase58();\n   260→\n   261→    // Get and consume a challenge\n   262→    const challengeRes = await app.request(\"/auth/challenge\", {\n   263→      method: \"POST\",\n   264→      headers: { \"Content-Type\": \"application/json\" },\n   265→      body: JSON.stringify({ wallet }),\n   266→    });\n   267→    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n   268→    const messageBytes = new TextEncoder().encode(challenge.message);\n   269→    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n   270→    const signature = bs58.encode(signatureBytes);\n   271→\n   272→    // First verify — should succeed\n   273→    const res1 = await app.request(\"/auth/verify\", {\n   274→      method: \"POST\",\n   275→      headers: { \"Content-Type\": \"application/json\" },\n   276→      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n   277→    });\n   278→    expect(res1.status).toBe(200);\n   279→\n   280→    // Second verify with same nonce — should fail\n   281→    const res2 = await app.request(\"/auth/verify\", {\n   282→      method: \"POST\",\n   283→      headers: { \"Content-Type\": \"application/json\" },\n   284→      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n   285→    });\n   286→    expect(res2.status).toBe(401);\n   287→  });\n   288→\n   289→  it(\"rejects refresh with invalid token\", async () => {\n   290→    const res = await app.request(\"/auth/refresh\", {\n   291→      method: \"POST\",\n   292→      headers: { \"Content-Type\": \"application/json\" },\n   293→      body: JSON.stringify({ refreshToken: \"not-a-real-token\" }),\n   294→    });\n   295→    expect(res.status).toBe(401);\n   296→  });\n   297→});\n   298→"}]},"parent_tool_use_id":"toolu_01JFkRRo6fd7WCE7xZR8iApU","session_id":"5a06e2aa-bee3-40eb-a97d-65518436146f","uuid":"f7c50cb0-60eb-4951-aefb-eb9f56765c67","timestamp":"2026-03-21T13:27:13.263Z"}
