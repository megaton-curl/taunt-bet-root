/web3.js\";\nimport { generateSecret, computeCommitment, deriveMatchPda, generateMatchId } from \"../fairness.js\";\n\ndescribe(\"generateSecret\", () => {\n  it(\"returns a 32-byte buffer\", () => {\n    const secret = generateSecret();\n    expect(Buffer.isBuffer(secret)).toBe(true);\n    expect(secret.length).toBe(32);\n  });\n\n  it(\"produces unique secrets on successive calls\", () => {\n    const a = generateSecret();\n    const b = generateSecret();\n    expect(a.equals(b)).toBe(false);\n  });\n});\n\ndescribe(\"computeCommitment\", () => {\n  it(\"returns sha256 of the secret bytes\", () => {\n    // sha256 of the zero byte (0x00) — well-known constant\n    const zeroByte = Buffer.from([0x00]);\n    const expected =\n      \"6e340b9cffb37a989ca544e6bb780a2c78901d3fb33738768511a30617afa01d\";\n    expect(computeCommitment(zeroByte).toString(\"hex\")).toBe(expected);\n  });\n\n  it(\"matches the packages/fairness commitment algorithm\", () => {\n    // The fairness package computes sha256(hexToBytes(hexSeed)).","numLines":30,"startLine":1,"totalLines":121}}}
