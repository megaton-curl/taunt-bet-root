{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011auc6fZjsDydtox8nAh8ab","type":"tool_result","content":"     1→/**\n     2→ * Queue health — provides event counts by status for observability.\n     3→ */\n     4→\n     5→import type postgres from \"postgres\";\n     6→\n     7→export interface QueueDepth {\n     8→  pending: number;\n     9→  processing: number;\n    10→  dead: number;\n    11→  completed: number;\n    12→}\n    13→\n    14→export async function getQueueDepth(sql: postgres.Sql): Promise<QueueDepth> {\n    15→  const rows = await sql<{ status: string; count: string }[]>`\n    16→    SELECT status, count(*)::text AS count\n    17→    FROM event_queue\n    18→    WHERE status IN ('pending', 'processing', 'dead', 'completed')\n    19→    GROUP BY status\n    20→  `;\n    21→\n    22→  const counts: QueueDepth = { pending: 0, processing: 0, dead: 0, completed: 0 };\n    23→  for (const row of rows) {\n    24→    if (row.status in counts) {\n    25→      counts[row.status as keyof QueueDepth] = parseInt(row.count, 10);\n    26→    }\n    27→  }\n    28→  return counts;\n    29→}\n    30→"}]},"parent_tool_use_id":"toolu_01HRTKbKAjNZnFtrM3rF6ea8","session_id":"5a06e2aa-bee3-40eb-a97d-65518436146f","uuid":"d197a4f7-0cdf-4aeb-a50f-5038bde23bf9","timestamp":"2026-03-21T13:27:15.820Z"}
