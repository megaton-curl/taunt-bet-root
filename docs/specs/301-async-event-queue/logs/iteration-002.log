{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M1tvb6dunoKCKQVjmnN2eu","type":"tool_result","content":"     1→/**\n     2→ * Event producer — inserts an event into the queue within an existing\n     3→ * database transaction so the event is committed atomically with the\n     4→ * triggering operation.\n     5→ */\n     6→\n     7→import type postgres from \"postgres\";\n     8→import type { EventType } from \"./event-types.js\";\n     9→\n    10→export interface EmitEventOptions {\n    11→  maxAttempts?: number; // default: 3\n    12→  scheduledAt?: Date; // default: now\n    13→}\n    14→\n    15→export async function emitEvent(\n    16→  tx: postgres.TransactionSql,\n    17→  eventType: EventType,\n    18→  payload: Record<string, unknown>,\n    19→  options?: EmitEventOptions,\n    20→): Promise<{ eventId: bigint }> {\n    21→  const maxAttempts = options?.maxAttempts ?? 3;\n    22→  const scheduledAt = options?.scheduledAt ?? new Date();\n    23→\n    24→  const rows = await tx<{ id: string }[]>`\n    25→    INSERT INTO event_queue (event_type, payload, max_attempts, scheduled_at)\n    26→    VALUES (${eventType}, ${tx.json(payload)}, ${maxAttempts}, ${scheduledAt})\n    27→    RETURNING id\n    28→  `;\n    29→\n    30→  return { eventId: BigInt(rows[0]!.id) };\n    31→}\n    32→"}]},"parent_tool_use_id":null,"session_id":"f29ae509-f643-4ea1-906d-d19d18bc6bbf","uuid":"ca51f129-4173-47bd-8be5-65753c498314","timestamp":"2026-03-21T13:14:29.005Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/queue/emit-event.ts","content":"/**\n * Event producer — inserts an event into the queue within an existing\n * database transaction so the event is committed atomically with the\n * triggering operation.\n */\n\nimport type postgres from \"postgres\";\nimport type { EventType } from \"./event-types.js\";\n\nexport interface EmitEventOptions {\n  maxAttempts?: number; // default: 3\n  scheduledAt?: Date; // default: now\n}\n\nexport async function emitEvent(\n  tx: postgres.TransactionSql,\n  eventType: EventType,\n  payload: Record<string, unknown>,\n  options?: EmitEventOptions,\n): Promise<{ eventId: bigint }> {\n  const maxAttempts = options?.maxAttempts ?? 3;\n  const scheduledAt = options?.scheduledAt ?? new Date();\n\n  const rows = await tx<{ id: string }[]>`\n    INSERT INTO event_queue (event_type, payload, max_attempts, scheduled_at)\n    VALUES (${eventType}, ${tx.json(payload)}, ${maxAttempts}, ${scheduledAt})\n    RETURNING id\n  `;\n\n  return { eventId: BigInt(rows[0]!.id) };\n}\n","numLines":32,"startLine":1,"totalLines":32}}}
