RVER_KEYPAIR\")),\n    53→    jwtSecret: (() => {\n    54→      const explicit = process.env.JWT_SECRET;\n    55→      if (explicit) return new TextEncoder().encode(explicit);\n    56→      // Derive from first 32 bytes of server keypair secret key\n    57→      const kp = parseKeypair(requireEnv(\"SERVER_KEYPAIR\"));\n    58→      return kp.secretKey.slice(0, 32);\n    59→    })(),\n    60→    cluster: process.env.SOLANA_CLUSTER ?? \"devnet\",\n    61→    challengeTtlSeconds: parseInt(\n    62→      process.env.CHALLENGE_TTL_SECONDS ?? \"300\",\n    63→      10,\n    64→    ),\n    65→    accessTokenTtlSeconds: parseInt(\n    66→      process.env.ACCESS_TOKEN_TTL_SECONDS ?? \"86400\",\n    67→      10,\n    68→    ),\n    69→    refreshTokenTtlDays: parseInt(\n    70→      process.env.REFRESH_TOKEN_TTL_DAYS ?? \"14\",\n    71→      10,\n    72→    ),\n    73→    rateLimitPerWallet: parseInt(\n    74→      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n    75→      10,\n    76→    ),\n    77→    rateLimitGlobal: parseInt(\n    78→      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n    79→      10,\n    80→    ),\n    81→    workerPollIntervalMs: parseInt(\n    82→      process.env.WORKER_POLL_INTERVAL_MS ?? \"1000\",\n    83→      10,\n    84→    ),\n    85→    entropyAccount: process.env.ENTROPY_ACCOUNT ?? \"SysvarS1otHashes111111111111111111111111111\",\n    86→    pythBtcUsdAccount: process.env.PYTH_BTC_USD_ACCOUNT ?? \"4cSM2e6rvbGQUFiJbqytoVMi5GgghSMr8LwVrT9VPSPo\",\n    87→    minSolBalance: parseFloat(process.env.MIN_SOL_BALANCE ?? \"0.1\"),\n    88→  };\n    89→}\n    90→"}]},"parent_tool_use_id":null,"session_id":"f29ae509-f643-4ea1-906d-d19d18bc6bbf","uuid":"912c1a70-4263-4a29-8b2d-10bafd50e6b0","timestamp":"2026-03-21T13:09:11.703Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/config.ts","content":"import { Keypair } from \"@solana/web3.js\";\nimport { applyDbSchemaToUrl, loadDbSchemaFromEnv } from \"./db-config.js\";\n\nexport interface Config {\n  port: number;\n  databaseUrl: string;\n  dbSchema: string;\n  rpcUrl: string;\n  wsRpcUrl: string | undefined;\n  serverKeypair: Keypair;\n  jwtSecret: Uint8Array;\n  cluster: string;\n  challengeTtlSeconds: number;\n  accessTokenTtlSeconds: number;\n  refreshTokenTtlDays: number;\n  rateLimitPerWallet: number;\n  rateLimitGlobal: number;\n  workerPollIntervalMs: number;\n  entropyAccount: string;\n  pythBtcUsdAccount: string;\n  minSolBalance: number;\n}\n\nfunction requireEnv(name: string): string {\n  const value = process.env[name];\n  if (!value) {\n    throw new Error(`Missing required environment variable: ${name}`);\n  }\n  return value;\n}\n\nfunction parseKeypair(raw: string): Keypair {\n  try {\n    const bytes = JSON.parse(raw) as number[];\n    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n  } catch {\n    throw new Error(\n      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    );\n  }\n}\n\nexport function loadConfig(): Config {\n  const dbSchema = loadDbSchemaFromEnv();\n\n  return {\n    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    databaseUrl: applyDbSchemaToUrl(requireEnv(\"DATABASE_URL\"), dbSchema),\n    dbSchema,\n    rpcUrl: requireEnv(\"RPC_URL\"),\n    wsRpcUrl: process.env.WS_RPC_URL || undefined,\n    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    jwtSecret: (() => {\n      const explicit = process.env.JWT_SECRET;\n      if (explicit) return new TextEncoder().encode(explicit);\n      // Derive from first 32 bytes of server keypair secret key\n      const kp = parseKeypair(requireEnv(\"SERVER_KEYPAIR\"));\n      return kp.secretKey.slice(0, 32);\n    })(),\n    cluster: process.env.SOLANA_CLUSTER ?? \"devnet\",\n    challengeTtlSeconds: parseInt(\n      process.env.CHALLENGE_TTL_SECONDS ?? \"300\",\n      10,\n    ),\n    accessTokenTtlSeconds: parseInt(\n      process.env.ACCESS_TOKEN_TTL_SECONDS ?? \"86400\",\n      10,\n    ),\n    refreshTokenTtlDays: parseInt(\n      process.env.REFRESH_TOKEN_TTL_DAYS ?? \"14\",\n      10,\n    ),\n    rateLimitPerWallet: parseInt(\n      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n      10,\n    ),\n    rateLimitGlobal: parseInt(\n      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n      10,\n    ),\n    workerPollIntervalMs: parseInt(\n      process.env.WORKER_POLL_INTERVAL_MS ?? \"1000\",\n      10,\n    ),\n    entropyAccount: process.env.ENTROPY_ACCOUNT ?? \"SysvarS1otHashes111111111111111111111111111\",\n    pythBtcUsdAccount: process.env.PYTH_BTC_USD_ACCOUNT ?? \"4cSM2e6rvbGQUFiJbqytoVMi5GgghSMr8LwVrT9VPSPo\",\n    minSolBalance: parseFloat(process.env.MIN_SOL_BALANCE ?? \"0.1\"),\n  };\n}\n","numLines":90,"startLine":1,"totalLines":90}}}
