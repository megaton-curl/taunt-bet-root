{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ExChytMCKvTqx5fxE7NDhU","type":"tool_result","content":"     1→/**\n     2→ * Simple SQL migration runner with version tracking.\n     3→ *\n     4→ * Reads numbered `.sql` files from `../migrations/`, applies them in order,\n     5→ * and tracks which have been applied in a `_migrations` table. Each migration\n     6→ * runs inside a transaction so partial application is impossible.\n     7→ *\n     8→ * Migrations are idempotent: re-running skips already-applied files.\n     9→ *\n    10→ * Usage:  tsx src/migrate.ts          (uses DATABASE_URL from env)\n    11→ *         tsx src/migrate.ts status   (shows applied migrations)\n    12→ */\n    13→\n    14→import { readdir, readFile } from \"node:fs/promises\";\n    15→import { join, dirname } from \"node:path\";\n    16→import { fileURLToPath } from \"node:url\";\n    17→import postgres from \"postgres\";\n    18→import { applyDbSchemaToUrl, loadDbSchemaFromEnv } from \"./db-config.js\";\n    19→\n    20→const __dirname = dirname(fileURLToPath(import.meta.url));\n    21→const MIGRATIONS_DIR = join(__dirname, \"..\", \"migrations\");\n    22→\n    23→interface MigrationFile {\n    24→  version: number;\n    25→  name: string;\n    26→  path: string;\n    27→}\n    28→\n    29→function quoteIdentifier(identifier: string): string {\n    30→  if (!/^[A-Za-z_][A-Za-z0-9_]*$/.test(identifier)) {\n    31→    throw new Error(`Invalid schema name: ${identifier}`);\n    32→  }\n    33→  return `\"${identifier}\"`;\n    34→}\n    35→\n    36→async function loadMigrationFiles(): Promise<MigrationFile[]> {\n    37→  const entries = await readdir(MIGRATIONS_DIR);\n    38→  const sqlFiles = entries\n    39→    .filter((f) => f.endsWith(\".sql\"))\n    40→    .sort();\n    41→\n    42→  return sqlFiles.map((name) => {\n    43→    const version = parseInt(name.split(\"_\")[0]!, 10);\n    44→    if (Number.isNaN(version)) {\n    45→      throw new Error(`Migration file ${name} does not start with a numeric version`);\n    46→    }\n    47→    return { version, name, path: join(MIGRATIONS_DIR, name) };\n    48→  });\n    49→}\n    50→\n    51→async function ensureMigrationsTable(sql: postgres.Sql): Promise<void> {\n    52→  await sql`\n    53→    CREATE TABLE IF NOT EXISTS _migrations (\n    54→      version   INT PRIMARY KEY,\n    55→      name      TEXT NOT NULL,\n    56→      applied_at TIMESTAMPTZ DEFAULT now()\n    57→    )\n    58→  `;\n    59→}\n    60→\n    61→async function ensureSchema(sql: postgres.Sql, schema: string): Promise<void> {\n    62→  if (schema === \"public\") {\n    63→    return;\n    64→  }\n    65→\n    66→  await sql.unsafe(`CREATE SCHEMA IF NOT EXISTS ${quoteIdentifier(schema)}`);\n    67→}\n    68→\n    69→async function getAppliedVersions(sql: postgres.Sql): Promise<Set<number>> {\n    70→  const rows = await sql<{ version: number }[]>`\n    71→    SELECT version FROM _migrations ORDER BY version\n    72→  `;\n    73→  return new Set(rows.map((r) => r.version));\n    74→}\n    75→\n    76→async function applyMigration(\n    77→  sql: postgres.Sql,\n    78→  migration: MigrationFile,\n    79→): Promise<void> {\n    80→  const content = await readFile(migration.path, \"utf-8\");\n    81→\n    82→  // Run migration SQL (idempotent via IF NOT EXISTS), then record it.\n    83→  // Using sql.begin with unsafe for both statements to stay in one transaction.\n    84→  await sql.begin(async (tx) => {\n    85→    await tx.unsafe(content);\n    86→    await tx.unsafe(\n    87→      \"INSERT INTO _migrations (version, name) VALUES ($1, $2)\",\n    88→      [migration.version, migration.name],\n    89→    );\n    90→  });\n    91→}\n    92→\n    93→export async function runMigrations(databaseUrl: string): Promise<void> {\n    94→  const sql = postgres(databaseUrl);\n    95→\n    96→  try {\n    97→    await ensureSchema(sql, dbSchema);\n    98→    await ensureMigrationsTable(sql);\n    99→\n   100→    const applied = await getAppliedVersions(sql);\n   101→    const files = await loadMigrationFiles();\n   102→    const pending = files.filter((f) => !applied.has(f.version));\n   103→\n   104→    if (pending.length === 0) {\n   105→      console.log(\"All migrations are up to date.\");\n   106→      return;\n   107→    }\n   108→\n   109→    for (const migration of pending) {\n   110→      console.log(`Applying migration ${migration.name}...`);\n   111→      await applyMigration(sql, migration);\n   112→      console.log(`  ✓ ${migration.name} applied.`);\n   113→    }\n   114→\n   115→    console.log(`${pending.length} migration(s) applied successfully.`);\n   116→  } finally {\n   117→    await sql.end();\n   118→  }\n   119→}\n   120→\n   121→async function showStatus(databaseUrl: string): Promise<void> {\n   122→  const sql = postgres(databaseUrl);\n   123→\n   124→  try {\n   125→    await ensureSchema(sql, dbSchema);\n   126→    await ensureMigrationsTable(sql);\n   127→\n   128→    const applied = await getAppliedVersions(sql);\n   129→    const files = await loadMigrationFiles();\n   130→\n   131→    console.log(\"Migration status:\");\n   132→    for (const file of files) {\n   133→      const status = applied.has(file.version) ? \"[applied]\" : \"[pending]\";\n   134→      console.log(`  ${status} ${file.name}`);\n   135→    }\n   136→  } finally {\n   137→    await sql.end();\n   138→  }\n   139→}\n   140→\n   141→// CLI entry point\n   142→const command = process.argv[2];\n   143→const rawDatabaseUrl = process.env.DATABASE_URL;\n   144→const dbSchema = loadDbSchemaFromEnv();\n   145→\n   146→if (!rawDatabaseUrl) {\n   147→  console.error(\"DATABASE_URL environment variable is required\");\n   148→  process.exit(1);\n   149→}\n   150→\n   151→const databaseUrl = applyDbSchemaToUrl(rawDatabaseUrl, dbSchema);\n   152→\n   153→if (command === \"status\") {\n   154→  await showStatus(databaseUrl);\n   155→} else {\n   156→  await runMigrations(databaseUrl);\n   157→}\n   158→"}]},"parent_tool_use_id":"toolu_01YGGLnzuK9bkj58LDnB8Fxo","session_id":"f29ae509-f643-4ea1-906d-d19d18bc6bbf","uuid":"c41ec5a9-fb8e-45bb-9ec7-1aa4af3621b0","timestamp":"2026-03-21T13:08:23.294Z"}
