{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01Y5bduzStK4U8jHD2R5tFRr","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0138b2zdX3bKJBNr8x39Y7i4","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/queue/emit-event.ts","content":"/**\n * Event producer — inserts an event into the queue within an existing\n * database transaction so the event is committed atomically with the\n * triggering operation.\n */\n\nimport type postgres from \"postgres\";\nimport type { EventType } from \"./event-types.js\";\n\nexport interface EmitEventOptions {\n  maxAttempts?: number; // default: 3\n  scheduledAt?: Date; // default: now\n}\n\nexport async function emitEvent(\n  tx: postgres.TransactionSql,\n  eventType: EventType,\n  payload: Record<string, unknown>,\n  options?: EmitEventOptions,\n): Promise<{ eventId: bigint }> {\n  const maxAttempts = options?.maxAttempts ?? 3;\n  const scheduledAt = options?.scheduledAt ?? new Date();\n\n  const rows = await tx<{ id: string }[]>`\n    INSERT INTO event_queue (event_type, payload, max_attempts, scheduled_at)\n    VALUES (${eventType}, ${tx.json(payload)}, ${maxAttempts}, ${scheduledAt})\n    RETURNING id\n  `;\n\n  return { eventId: BigInt(rows[0]!.id) };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":144,"cache_read_input_tokens":44457,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":144},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f29ae509-f643-4ea1-906d-d19d18bc6bbf","uuid":"b2480871-1071-4d4a-af55-95f6d745118b"}
