{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01Y5bduzStK4U8jHD2R5tFRr","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01LDYQdoax2A1Q54G7Sy7RJV","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/queue/handler-registry.ts","content":"/**\n * Handler registry — maps event type strings to handler functions.\n *\n * One handler per event type (no pub/sub fan-out for v1).\n * Handlers must be idempotent — re-processing is a safe no-op.\n */\n\nimport type { EventType } from \"./event-types.js\";\n\nexport type EventHandler = (\n  payload: Record<string, unknown>,\n) => Promise<void>;\n\nconst handlers = new Map<string, EventHandler>();\n\nexport function registerHandler(\n  eventType: EventType,\n  handler: EventHandler,\n): void {\n  handlers.set(eventType, handler);\n}\n\nexport function getHandler(eventType: string): EventHandler | undefined {\n  return handlers.get(eventType);\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":144,"cache_read_input_tokens":44457,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":144},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f29ae509-f643-4ea1-906d-d19d18bc6bbf","uuid":"7291c2c0-d758-4fe4-b978-a064f110dcb0"}
