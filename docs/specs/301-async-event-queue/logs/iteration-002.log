{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y6V11vqGe4pokSqoG6zLJg","type":"tool_result","content":"     1→/**\n     2→ * Settlement worker — polls the chain for server-owned rounds that are ready\n     3→ * for backend settlement across supported games.\n     4→ */\n     5→\n     6→import { performance } from \"node:perf_hooks\";\n     7→import { Connection, PublicKey } from \"@solana/web3.js\";\n     8→import { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID } from \"../tx-builder.js\";\n     9→import type { Db } from \"../db.js\";\n    10→import { logger } from \"../logger.js\";\n    11→import {\n    12→  coinflipMatchSize,\n    13→  decodeCoinflipMatch,\n    14→  decodeLordRound,\n    15→  lordRoundDiscriminatorFilter,\n    16→} from \"./account-decoder.js\";\n    17→\n    18→const PHASE_LOCKED_VALUE = 1;\n    19→const LORD_PHASE_ACTIVE_VALUE = 1;\n    20→\n    21→export interface SettlementWorkerDeps {\n    22→  db: Db;\n    23→  connection: Connection;\n    24→  serverKey: PublicKey;\n    25→  pollIntervalMs: number;\n    26→  /** Called when a match is detected as ready for settlement (target_slot reached). */\n    27→  onSettleReady?: (pda: string) => Promise<void>;\n    28→  /** Called to check if a PDA is finalized (settled or permanently failed). */\n    29→  isFinalized?: (pda: string) => boolean;\n    30→}\n    31→\n    32→export interface SettlementWorker {\n    33→  start(): void;\n    34→  stop(): void;\n    35→  readonly isRunning: boolean;\n    36→  /** Run a single poll cycle (exposed for testing). */\n    37→  poll(): Promise<void>;\n    38→}\n    39→\n    40→export function createSettlementWorker(\n    41→  deps: SettlementWorkerDeps,\n    42→): SettlementWorker {\n    43→  const { db, connection, serverKey, pollIntervalMs } = deps;\n    44→  const discoveredPdas = new Set<string>();\n    45→  const readyPdas = new Set<string>();\n    46→  /** PDAs that failed decode — stale accounts from previous deploys. Logged once, then skipped. */\n    47→  const undecodeablePdas = new Set<string>();\n    48→  let running = false;\n    49→  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n    50→\n    51→  async function handleDiscoveredRound(\n    52→    pda: string,\n    53→    targetSlot: bigint,\n    54→    currentSlot: number,\n    55→    slotTime: string | null,\n    56→  ): Promise<void> {\n    57→    const round = await db.getRoundByPda(pda);\n    58→    if (!round) {\n    59→      return;\n    60→    }"}]},"parent_tool_use_id":null,"session_id":"f29ae509-f643-4ea1-906d-d19d18bc6bbf","uuid":"aeb85078-cf19-42e8-b3e2-bac358539d54","timestamp":"2026-03-21T13:09:10.788Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/settlement.ts","content":"/**\n * Settlement worker — polls the chain for server-owned rounds that are ready\n * for backend settlement across supported games.\n */\n\nimport { performance } from \"node:perf_hooks\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID } from \"../tx-builder.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport {\n  coinflipMatchSize,\n  decodeCoinflipMatch,\n  decodeLordRound,\n  lordRoundDiscriminatorFilter,\n} from \"./account-decoder.js\";\n\nconst PHASE_LOCKED_VALUE = 1;\nconst LORD_PHASE_ACTIVE_VALUE = 1;\n\nexport interface SettlementWorkerDeps {\n  db: Db;\n  connection: Connection;\n  serverKey: PublicKey;\n  pollIntervalMs: number;\n  /** Called when a match is detected as ready for settlement (target_slot reached). */\n  onSettleReady?: (pda: string) => Promise<void>;\n  /** Called to check if a PDA is finalized (settled or permanently failed). */\n  isFinalized?: (pda: string) => boolean;\n}\n\nexport interface SettlementWorker {\n  start(): void;\n  stop(): void;\n  readonly isRunning: boolean;\n  /** Run a single poll cycle (exposed for testing). */\n  poll(): Promise<void>;\n}\n\nexport function createSettlementWorker(\n  deps: SettlementWorkerDeps,\n): SettlementWorker {\n  const { db, connection, serverKey, pollIntervalMs } = deps;\n  const discoveredPdas = new Set<string>();\n  const readyPdas = new Set<string>();\n  /** PDAs that failed decode — stale accounts from previous deploys. Logged once, then skipped. */\n  const undecodeablePdas = new Set<string>();\n  let running = false;\n  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n\n  async function handleDiscoveredRound(\n    pda: string,\n    targetSlot: bigint,\n    currentSlot: number,\n    slotTime: string | null,\n  ): Promise<void> {\n    const round = await db.getRoundByPda(pda);\n    if (!round) {\n      return;\n    }","numLines":60,"startLine":1,"totalLines":224}}}
