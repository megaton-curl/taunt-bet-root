{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013TvVg9Hvq2YHQWnjzmdXad","type":"tool_result","content":"     1→import { Keypair } from \"@solana/web3.js\";\n     2→import { applyDbSchemaToUrl, loadDbSchemaFromEnv } from \"./db-config.js\";\n     3→\n     4→export interface Config {\n     5→  port: number;\n     6→  databaseUrl: string;\n     7→  dbSchema: string;\n     8→  rpcUrl: string;\n     9→  wsRpcUrl: string | undefined;\n    10→  serverKeypair: Keypair;\n    11→  jwtSecret: Uint8Array;\n    12→  cluster: string;\n    13→  challengeTtlSeconds: number;\n    14→  accessTokenTtlSeconds: number;\n    15→  refreshTokenTtlDays: number;\n    16→  rateLimitPerWallet: number;\n    17→  rateLimitGlobal: number;\n    18→  workerPollIntervalMs: number;\n    19→  entropyAccount: string;\n    20→  pythBtcUsdAccount: string;\n    21→  minSolBalance: number;\n    22→}\n    23→\n    24→function requireEnv(name: string): string {\n    25→  const value = process.env[name];\n    26→  if (!value) {\n    27→    throw new Error(`Missing required environment variable: ${name}`);\n    28→  }\n    29→  return value;\n    30→}\n    31→\n    32→function parseKeypair(raw: string): Keypair {\n    33→  try {\n    34→    const bytes = JSON.parse(raw) as number[];\n    35→    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n    36→  } catch {\n    37→    throw new Error(\n    38→      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    39→    );\n    40→  }\n    41→}\n    42→\n    43→export function loadConfig(): Config {\n    44→  const dbSchema = loadDbSchemaFromEnv();\n    45→\n    46→  return {\n    47→    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    48→    databaseUrl: applyDbSchemaToUrl(requireEnv(\"DATABASE_URL\"), dbSchema),\n    49→    dbSchema,\n    50→    rpcUrl: requireEnv(\"RPC_URL\"),\n    51→    wsRpcUrl: process.env.WS_RPC_URL || undefined,\n    52→    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    53→    jwtSecret: (() => {\n    54→      const explicit = process.env.JWT_SECRET;\n    55→      if (explicit) return new TextEncoder().encode(explicit);\n    56→      // Derive from first 32 bytes of server keypair secret key\n    57→      const kp = parseKeypair(requireEnv(\"SERVER_KEYPAIR\"));\n    58→      return kp.secretKey.slice(0, 32);\n    59→    })(),\n    60→    cluster: process.env.SOLANA_CLUSTER ?? \"devnet\",\n    61→    challengeTtlSeconds: parseInt(\n    62→      process.env.CHALLENGE_TTL_SECONDS ?? \"300\",\n    63→      10,\n    64→    ),\n    65→    accessTokenTtlSeconds: parseInt(\n    66→      process.env.ACCESS_TOKEN_TTL_SECONDS ?? \"86400\",\n    67→      10,\n    68→    ),\n    69→    refreshTokenTtlDays: parseInt(\n    70→      process.env.REFRESH_TOKEN_TTL_DAYS ?? \"14\",\n    71→      10,\n    72→    ),\n    73→    rateLimitPerWallet: parseInt(\n    74→      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n    75→      10,\n    76→    ),\n    77→    rateLimitGlobal: parseInt(\n    78→      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n    79→      10,\n    80→    ),\n    81→    workerPollIntervalMs: parseInt(\n    82→      process.env.WORKER_POLL_INTERVAL_MS ?? \"1000\",\n    83→      10,\n    84→    ),\n    85→    entropyAccount: process.env.ENTROPY_ACCOUNT ?? \"SysvarS1otHashes111111111111111111111111111\",\n    86→    pythBtcUsdAccount: process.env.PYTH_BTC_USD_ACCOUNT ?? \"4cSM2e6rvbGQUFiJbqytoVMi5GgghSMr8LwVrT9VPSPo\",\n    87→    minSolBalance: parseFloat(process.env.MIN_SOL_BALANCE ?? \"0.1\"),\n    88→  };\n    89→}\n    90→"}]},"parent_tool_use_id":"toolu_01YGGLnzuK9bkj58LDnB8Fxo","session_id":"f29ae509-f643-4ea1-906d-d19d18bc6bbf","uuid":"99d60ef2-9872-4cd0-90dd-d877d7a1e52e","timestamp":"2026-03-21T13:08:12.495Z"}
