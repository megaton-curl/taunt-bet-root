{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SqFrZeCDwCL428rTEUvAA2","type":"tool_result","content":"     1→/**\n     2→ * Structured JSON logger — all output is JSON with timestamp, level, message,\n     3→ * and optional context fields (e.g. PDA). No secrets or private keys in logs.\n     4→ */\n     5→\n     6→export type LogLevel = \"debug\" | \"info\" | \"warn\" | \"error\";\n     7→\n     8→export interface LogEntry {\n     9→  timestamp: string;\n    10→  level: LogLevel;\n    11→  message: string;\n    12→  [key: string]: unknown;\n    13→}\n    14→\n    15→function write(level: LogLevel, message: string, fields?: Record<string, unknown>): void {\n    16→  const entry: LogEntry = {\n    17→    timestamp: new Date().toISOString(),\n    18→    level,\n    19→    message,\n    20→    ...fields,\n    21→  };\n    22→  const line = JSON.stringify(entry);\n    23→  if (level === \"error\") {\n    24→    process.stderr.write(line + \"\\n\");\n    25→  } else {\n    26→    process.stdout.write(line + \"\\n\");\n    27→  }\n    28→}\n    29→\n    30→export const logger = {\n    31→  debug(message: string, fields?: Record<string, unknown>): void {\n    32→    write(\"debug\", message, fields);\n    33→  },\n    34→  info(message: string, fields?: Record<string, unknown>): void {\n    35→    write(\"info\", message, fields);\n    36→  },\n    37→  warn(message: string, fields?: Record<string, unknown>): void {\n    38→    write(\"warn\", message, fields);\n    39→  },\n    40→  error(message: string, fields?: Record<string, unknown>): void {\n    41→    write(\"error\", message, fields);\n    42→  },\n    43→};\n    44→"}]},"parent_tool_use_id":"toolu_01YGGLnzuK9bkj58LDnB8Fxo","session_id":"f29ae509-f643-4ea1-906d-d19d18bc6bbf","uuid":"39f008ed-9279-4da3-b225-ca928a398a6d","timestamp":"2026-03-21T13:08:12.729Z"}
