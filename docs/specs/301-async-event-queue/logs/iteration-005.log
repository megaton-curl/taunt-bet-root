{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014APcVoMrAJbfMFfXhbaH2o","type":"tool_result","content":"     1→import { Hono } from \"hono\";\n     2→import { cors } from \"hono/cors\";\n     3→import { serve } from \"@hono/node-server\";\n     4→import { Connection, PublicKey } from \"@solana/web3.js\";\n     5→import postgres from \"postgres\";\n     6→import { loadConfig } from \"./config.js\";\n     7→import { createDb } from \"./db.js\";\n     8→import { createAuthDb } from \"./auth-db.js\";\n     9→import { createCoinflipRoutes } from \"./routes/create.js\";\n    10→import { createLordRoutes } from \"./routes/lord-create.js\";\n    11→import { createRoundsRoutes } from \"./routes/rounds.js\";\n    12→import { createCloseCallRoutes } from \"./routes/closecall.js\";\n    13→import { createHealthRoutes } from \"./routes/health.js\";\n    14→import { createProfileRoutes } from \"./routes/profile.js\";\n    15→import { createPriceRoutes } from \"./routes/price.js\";\n    16→import { createAuthRoutes } from \"./routes/auth.js\";\n    17→import { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n    18→import { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n    19→import { createSettlementWorker } from \"./worker/settlement.js\";\n    20→import { settleRound } from \"./worker/settle-tx.js\";\n    21→import { createRetrySettler } from \"./worker/retry.js\";\n    22→import { createPdaWatcher } from \"./worker/pda-watcher.js\";\n    23→import { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n    24→import { logger } from \"./logger.js\";\n    25→\n    26→const config = loadConfig();\n    27→\n    28→// Shared postgres connection for both game DB and auth DB\n    29→const sql = postgres(config.databaseUrl);\n    30→const db = createDb(config.databaseUrl);\n    31→const authDb = createAuthDb(sql);\n    32→\n    33→const connection = new Connection(config.rpcUrl, {\n    34→  commitment: \"confirmed\",\n    35→  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n    36→});\n    37→\n    38→const app = new Hono();\n    39→\n    40→app.use(\n    41→  \"*\",\n    42→  cors({\n    43→    origin: \"*\",\n    44→    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n    45→    allowHeaders: [\"Content-Type\", \"Authorization\"],\n    46→  }),\n    47→);\n    48→\n    49→// Request logging — correlate frontend fetch timing with server-side processing\n    50→app.use(\"*\", async (c, next) => {\n    51→  const start = Date.now();\n    52→  await next();\n    53→  const ms = Date.now() - start;\n    54→  const method = c.req.method;\n    55→  const path = c.req.path;\n    56→  // Skip noisy health checks and OPTIONS preflight\n    57→  if (path === \"/health\" || method === \"OPTIONS\") return;\n    58→  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n    59→});\n    60→\n    61→// Auth routes — no JWT middleware (these are the login endpoints)\n    62→// Lighter rate limiting by IP for auth endpoints\n    63→app.use(\n    64→  \"/auth/*\",\n    65→  createRateLimitMiddleware({\n    66→    perWallet: 20,\n    67→    global: config.rateLimitGlobal,\n    68→    windowMs: 60_000,\n    69→  }),\n    70→);\n    71→\n    72→app.route(\n    73→  \"/auth\",\n    74→  createAuthRoutes({\n    75→    authDb,\n    76→    jwtSecret: config.jwtSecret,\n    77→    cluster: config.cluster,\n    78→    challengeTtlSeconds: config.challengeTtlSeconds,\n    79→    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    80→    refreshTokenTtlDays: config.refreshTokenTtlDays,\n    81→  }),\n    82→);\n    83→\n    84→// Profile routes — authenticated GET endpoints (require JWT on all methods)\n    85→app.use(\n    86→  \"/profile/*\",\n    87→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n    88→);\n    89→app.route(\"/profile\", createProfileRoutes({ db }));\n    90→\n    91→// JWT auth middleware for fairness endpoints\n    92→app.use(\n    93→  \"/fairness/*\",\n    94→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n    95→);\n    96→\n    97→// Rate limiting — per-wallet and global limits on POST requests\n    98→app.use(\n    99→  \"/fairness/*\",\n   100→  createRateLimitMiddleware({\n   101→    perWallet: config.rateLimitPerWallet,\n   102→    global: config.rateLimitGlobal,\n   103→    windowMs: 60_000,\n   104→  }),\n   105→);\n   106→\n   107→// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n   108→const entropyAccount = new PublicKey(config.entropyAccount);\n   109→const retrySettler = createRetrySettler({\n   110→  db,\n   111→  connection,\n   112→  settleRound: (pda) =>\n   113→    settleRound(\n   114→      { db, connection, serverKeypair: config.serverKeypair, entropyAccount },\n   115→      pda,\n   116→    ),\n   117→});\n   118→\n   119→// PDA watcher — WebSocket-based instant join detection\n   120→const pdaWatcher = createPdaWatcher({\n   121→  connection,\n   122→  serverKey: config.serverKeypair.publicKey,\n   123→  db,\n   124→  onJoinDetected: async (pda, targetSlot) => {\n   125→    // Update DB phase if still in 'created'\n   126→    const round = await db.getRoundByPda(pda);\n   127→    if (round && round.phase === \"created\") {\n   128→      await db.updateRoundPhase(pda, \"locked\", {\n   129→        target_slot: targetSlot.toString(),\n   130→      });\n   131→      await db.insertOperatorEvent(pda, \"match_detected\", {\n   132→        targetSlot: targetSlot.toString(),\n   133→        source: \"pda-watcher\",\n   134→        game: round.game,\n   135→      });\n   136→    }\n   137→\n   138→    // Check if target slot already passed — settle immediately if so\n   139→    const currentSlot = await connection.getSlot();\n   140→    if (BigInt(currentSlot) >= targetSlot) {\n   141→      await retrySettler.attemptSettle(pda);\n   142→      pdaWatcher.unwatch(pda);\n   143→    }\n   144→    // If target slot not reached yet, poll worker will pick it up next cycle\n   145→  },\n   146→});\n   147→\n   148→const worker = createSettlementWorker({\n   149→  db,\n   150→  connection,\n   151→  serverKey: config.serverKeypair.publicKey,\n   152→  pollIntervalMs: config.workerPollIntervalMs,\n   153→  onSettleReady: async (pda) => {\n   154→    await retrySettler.attemptSettle(pda);\n   155→    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n   156→  },\n   157→  isFinalized: (pda) => retrySettler.isFinalized(pda),\n   158→});\n   159→worker.start();\n   160→\n   161→// Close Call clock worker — fetches boundary prices + settles open rounds\n   162→// Rounds are created on-demand by players via /closecall/bet\n   163→const closeCallClock = createCloseCallClockWorker({\n   164→  connection,\n   165→  serverKeypair: config.serverKeypair,\n   166→  db: sql,\n   167→});\n   168→closeCallClock.start();\n   169→\n   170→// Coinflip fairness routes\n   171→app.route(\n   172→  \"/fairness/coinflip\",\n   173→  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n   174→);\n   175→app.route(\n   176→  \"/fairness/lord\",\n   177→  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n   178→);\n   179→\n   180→// Close Call routes (create-round co-signing + candle history + read queries)\n   181→app.route(\"/closecall\", createCloseCallRoutes({\n   182→  db,\n   183→  connection,\n   184→  serverKeypair: config.serverKeypair,\n   185→  clockWorker: closeCallClock,\n   186→  sql,\n   187→}));\n   188→\n   189→// Price routes — public, no auth\n   190→app.route(\"/price\", createPriceRoutes());\n   191→\n   192→// Round verification routes\n   193→app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n   194→\n   195→// Health endpoint — wired after worker exists so we can query its status\n   196→app.route(\n   197→  \"/health\",\n   198→  createHealthRoutes({\n   199→    db,\n   200→    connection,\n   201→    serverKey: config.serverKeypair.publicKey,\n   202→    isWorkerRunning: () => worker.isRunning,\n   203→    minSolBalance: config.minSolBalance,\n   204→  }),\n   205→);\n   206→\n   207→const port = config.port;\n   208→logger.info(\"fairness-backend started\", { port });\n   209→\n   210→serve({\n   211→  fetch: app.fetch,\n   212→  port,\n   213→});\n   214→\n   215→export default {\n   216→  port,\n   217→  fetch: app.fetch,\n   218→};\n   219→"}]},"parent_tool_use_id":null,"session_id":"65e92302-5cfe-46cf-9b29-9f2a90a53e10","uuid":"47a02d8b-35f8-4b8d-a970-370c4bdaa940","timestamp":"2026-03-21T13:24:26.422Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/index.ts","content":"import { Hono } from \"hono\";\nimport { cors } from \"hono/cors\";\nimport { serve } from \"@hono/node-server\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport postgres from \"postgres\";\nimport { loadConfig } from \"./config.js\";\nimport { createDb } from \"./db.js\";\nimport { createAuthDb } from \"./auth-db.js\";\nimport { createCoinflipRoutes } from \"./routes/create.js\";\nimport { createLordRoutes } from \"./routes/lord-create.js\";\nimport { createRoundsRoutes } from \"./routes/rounds.js\";\nimport { createCloseCallRoutes } from \"./routes/closecall.js\";\nimport { createHealthRoutes } from \"./routes/health.js\";\nimport { createProfileRoutes } from \"./routes/profile.js\";\nimport { createPriceRoutes } from \"./routes/price.js\";\nimport { createAuthRoutes } from \"./routes/auth.js\";\nimport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\nimport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\nimport { createSettlementWorker } from \"./worker/settlement.js\";\nimport { settleRound } from \"./worker/settle-tx.js\";\nimport { createRetrySettler } from \"./worker/retry.js\";\nimport { createPdaWatcher } from \"./worker/pda-watcher.js\";\nimport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\nimport { logger } from \"./logger.js\";\n\nconst config = loadConfig();\n\n// Shared postgres connection for both game DB and auth DB\nconst sql = postgres(config.databaseUrl);\nconst db = createDb(config.databaseUrl);\nconst authDb = createAuthDb(sql);\n\nconst connection = new Connection(config.rpcUrl, {\n  commitment: \"confirmed\",\n  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n});\n\nconst app = new Hono();\n\napp.use(\n  \"*\",\n  cors({\n    origin: \"*\",\n    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n    allowHeaders: [\"Content-Type\", \"Authorization\"],\n  }),\n);\n\n// Request logging — correlate frontend fetch timing with server-side processing\napp.use(\"*\", async (c, next) => {\n  const start = Date.now();\n  await next();\n  const ms = Date.now() - start;\n  const method = c.req.method;\n  const path = c.req.path;\n  // Skip noisy health checks and OPTIONS preflight\n  if (path === \"/health\" || method === \"OPTIONS\") return;\n  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n});\n\n// Auth routes — no JWT middleware (these are the login endpoints)\n// Lighter rate limiting by IP for auth endpoints\napp.use(\n  \"/auth/*\",\n  createRateLimitMiddleware({\n    perWallet: 20,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\napp.route(\n  \"/auth\",\n  createAuthRoutes({\n    authDb,\n    jwtSecret: config.jwtSecret,\n    cluster: config.cluster,\n    challengeTtlSeconds: config.challengeTtlSeconds,\n    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    refreshTokenTtlDays: config.refreshTokenTtlDays,\n  }),\n);\n\n// Profile routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/profile/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/profile\", createProfileRoutes({ db }));\n\n// JWT auth middleware for fairness endpoints\napp.use(\n  \"/fairness/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\n\n// Rate limiting — per-wallet and global limits on POST requests\napp.use(\n  \"/fairness/*\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\n// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\nconst entropyAccount = new PublicKey(config.entropyAccount);\nconst retrySettler = createRetrySettler({\n  db,\n  connection,\n  settleRound: (pda) =>\n    settleRound(\n      { db, connection, serverKeypair: config.serverKeypair, entropyAccount },\n      pda,\n    ),\n});\n\n// PDA watcher — WebSocket-based instant join detection\nconst pdaWatcher = createPdaWatcher({\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  db,\n  onJoinDetected: async (pda, targetSlot) => {\n    // Update DB phase if still in 'created'\n    const round = await db.getRoundByPda(pda);\n    if (round && round.phase === \"created\") {\n      await db.updateRoundPhase(pda, \"locked\", {\n        target_slot: targetSlot.toString(),\n      });\n      await db.insertOperatorEvent(pda, \"match_detected\", {\n        targetSlot: targetSlot.toString(),\n        source: \"pda-watcher\",\n        game: round.game,\n      });\n    }\n\n    // Check if target slot already passed — settle immediately if so\n    const currentSlot = await connection.getSlot();\n    if (BigInt(currentSlot) >= targetSlot) {\n      await retrySettler.attemptSettle(pda);\n      pdaWatcher.unwatch(pda);\n    }\n    // If target slot not reached yet, poll worker will pick it up next cycle\n  },\n});\n\nconst worker = createSettlementWorker({\n  db,\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  pollIntervalMs: config.workerPollIntervalMs,\n  onSettleReady: async (pda) => {\n    await retrySettler.attemptSettle(pda);\n    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n  },\n  isFinalized: (pda) => retrySettler.isFinalized(pda),\n});\nworker.start();\n\n// Close Call clock worker — fetches boundary prices + settles open rounds\n// Rounds are created on-demand by players via /closecall/bet\nconst closeCallClock = createCloseCallClockWorker({\n  connection,\n  serverKeypair: config.serverKeypair,\n  db: sql,\n});\ncloseCallClock.start();\n\n// Coinflip fairness routes\napp.route(\n  \"/fairness/coinflip\",\n  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n);\napp.route(\n  \"/fairness/lord\",\n  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n);\n\n// Close Call routes (create-round co-signing + candle history + read queries)\napp.route(\"/closecall\", createCloseCallRoutes({\n  db,\n  connection,\n  serverKeypair: config.serverKeypair,\n  clockWorker: closeCallClock,\n  sql,\n}));\n\n// Price routes — public, no auth\napp.route(\"/price\", createPriceRoutes());\n\n// Round verification routes\napp.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n\n// Health endpoint — wired after worker exists so we can query its status\napp.route(\n  \"/health\",\n  createHealthRoutes({\n    db,\n    connection,\n    serverKey: config.serverKeypair.publicKey,\n    isWorkerRunning: () => worker.isRunning,\n    minSolBalance: config.minSolBalance,\n  }),\n);\n\nconst port = config.port;\nlogger.info(\"fairness-backend started\", { port });\n\nserve({\n  fetch: app.fetch,\n  port,\n});\n\nexport default {\n  port,\n  fetch: app.fetch,\n};\n","numLines":219,"startLine":1,"totalLines":219}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DDd78cjfC6tVk7reML5b96","type":"tool_result","content":"     1→import { Keypair } from \"@solana/web3.js\";\n     2→import { applyDbSchemaToUrl, loadDbSchemaFromEnv } from \"./db-config.js\";\n     3→\n     4→export interface Config {\n     5→  port: number;\n     6→  databaseUrl: string;\n     7→  dbSchema: string;\n     8→  rpcUrl: string;\n     9→  wsRpcUrl: string | undefined;\n    10→  serverKeypair: Keypair;\n    11→  jwtSecret: Uint8Array;\n    12→  cluster: string;\n    13→  challengeTtlSeconds: number;\n    14→  accessTokenTtlSeconds: number;\n    15→  refreshTokenTtlDays: number;\n    16→  rateLimitPerWallet: number;\n    17→  rateLimitGlobal: number;\n    18→  workerPollIntervalMs: number;\n    19→  entropyAccount: string;\n    20→  pythBtcUsdAccount: string;\n    21→  minSolBalance: number;\n    22→}\n    23→\n    24→function requireEnv(name: string): string {\n    25→  const value = process.env[name];\n    26→  if (!value) {\n    27→    throw new Error(`Missing required environment variable: ${name}`);\n    28→  }\n    29→  return value;\n    30→}\n    31→\n    32→function parseKeypair(raw: string): Keypair {\n    33→  try {\n    34→    const bytes = JSON.parse(raw) as number[];\n    35→    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n    36→  } catch {\n    37→    throw new Error(\n    38→      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    39→    );\n    40→  }\n    41→}\n    42→\n    43→export function loadConfig(): Config {\n    44→  const dbSchema = loadDbSchemaFromEnv();\n    45→\n    46→  return {\n    47→    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    48→    databaseUrl: applyDbSchemaToUrl(requireEnv(\"DATABASE_URL\"), dbSchema),\n    49→    dbSchema,\n    50→    rpcUrl: requireEnv(\"RPC_URL\"),\n    51→    wsRpcUrl: process.env.WS_RPC_URL || undefined,\n    52→    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    53→    jwtSecret: (() => {\n    54→      const explicit = process.env.JWT_SECRET;\n    55→      if (explicit) return new TextEncoder().encode(explicit);\n    56→      // Derive from first 32 bytes of server keypair secret key\n    57→      const kp = parseKeypair(requireEnv(\"SERVER_KEYPAIR\"));\n    58→      return kp.secretKey.slice(0, 32);\n    59→    })(),\n    60→    cluster: process.env.SOLANA_CLUSTER ?? \"devnet\",\n    61→    challengeTtlSeconds: parseInt(\n    62→      process.env.CHALLENGE_TTL_SECONDS ?? \"300\",\n    63→      10,\n    64→    ),\n    65→    accessTokenTtlSeconds: parseInt(\n    66→      process.env.ACCESS_TOKEN_TTL_SECONDS ?? \"86400\",\n    67→      10,\n    68→    ),\n    69→    refreshTokenTtlDays: parseInt(\n    70→      process.env.REFRESH_TOKEN_TTL_DAYS ?? \"14\",\n    71→      10,\n    72→    ),\n    73→    rateLimitPerWallet: parseInt(\n    74→      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n    75→      10,\n    76→    ),\n    77→    rateLimitGlobal: parseInt(\n    78→      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n    79→      10,\n    80→    ),\n    81→    workerPollIntervalMs: parseInt(\n    82→      process.env.WORKER_POLL_INTERVAL_MS ?? \"1000\",\n    83→      10,\n    84→    ),\n    85→    entropyAccount: process.env.ENTROPY_ACCOUNT ?? \"SysvarS1otHashes111111111111111111111111111\",\n    86→    pythBtcUsdAccount: process.env.PYTH_BTC_USD_ACCOUNT ?? \"4cSM2e6rvbGQUFiJbqytoVMi5GgghSMr8LwVrT9VPSPo\",\n    87→    minSolBalance: parseFloat(process.env.MIN_SOL_BALANCE ?? \"0.1\"),\n    88→  };\n    89→}\n    90→"}]},"parent_tool_use_id":null,"session_id":"65e92302-5cfe-46cf-9b29-9f2a90a53e10","uuid":"51de2849-5872-47f3-90ac-47d2dfa6e5f9","timestamp":"2026-03-21T13:24:26.489Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/config.ts","content":"import { Keypair } from \"@solana/web3.js\";\nimport { applyDbSchemaToUrl, loadDbSchemaFromEnv } from \"./db-config.js\";\n\nexport interface Config {\n  port: number;\n  databaseUrl: string;\n  dbSchema: string;\n  rpcUrl: string;\n  wsRpcUrl: string | undefined;\n  serverKeypair: Keypair;\n  jwtSecret: Uint8Array;\n  cluster: string;\n  challengeTtlSeconds: number;\n  accessTokenTtlSeconds: number;\n  refreshTokenTtlDays: number;\n  rateLimitPerWallet: number;\n  rateLimitGlobal: number;\n  workerPollIntervalMs: number;\n  entropyAccount: string;\n  pythBtcUsdAccount: string;\n  minSolBalance: number;\n}\n\nfunction requireEnv(name: string): string {\n  const value = process.env[name];\n  if (!value) {\n    throw new Error(`Missing required environment variable: ${name}`);\n  }\n  return value;\n}\n\nfunction parseKeypair(raw: string): Keypair {\n  try {\n    const bytes = JSON.parse(raw) as number[];\n    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n  } catch {\n    throw new Error(\n      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    );\n  }\n}\n\nexport function loadConfig(): Config {\n  const dbSchema = loadDbSchemaFromEnv();\n\n  return {\n    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    databaseUrl: applyDbSchemaToUrl(requireEnv(\"DATABASE_URL\"), dbSchema),\n    dbSchema,\n    rpcUrl: requireEnv(\"RPC_URL\"),\n    wsRpcUrl: process.env.WS_RPC_URL || undefined,\n    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    jwtSecret: (() => {\n      const explicit = process.env.JWT_SECRET;\n      if (explicit) return new TextEncoder().encode(explicit);\n      // Derive from first 32 bytes of server keypair secret key\n      const kp = parseKeypair(requireEnv(\"SERVER_KEYPAIR\"));\n      return kp.secretKey.slice(0, 32);\n    })(),\n    cluster: process.env.SOLANA_CLUSTER ?? \"devnet\",\n    challengeTtlSeconds: parseInt(\n      process.env.CHALLENGE_TTL_SECONDS ?? \"300\",\n      10,\n    ),\n    accessTokenTtlSeconds: parseInt(\n      process.env.ACCESS_TOKEN_TTL_SECONDS ?? \"