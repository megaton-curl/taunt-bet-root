{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_018CjS3zRTxQ5d4kXeQaUAri","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_018ZDDjX1uBCLePRJGuvTqN9","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/fixtures.ts","old_string":"import { test as base, expect, type Page } from \"@playwright/test\";\n\n/**\n * Shared visual-regression fixture.\n *\n * Extends the default Playwright `test` with a `stablePage` fixture that:\n *  (a) Injects CSS to disable all animations and transitions\n *  (b) Waits for document.fonts.ready\n *  (c) Waits for network idle\n *\n * Usage:\n *   import { test, expect } from \"../fixtures\";\n *   test(\"home page\", async ({ stablePage }) => {\n *     await stablePage.goto(\"/\");\n *     await expect(stablePage).toHaveScreenshot(\"home.png\");\n *   });\n */\nexport const test = base.extend<{ stablePage: Page }>({\n  stablePage: async ({ page }, use) => {\n    // (a) Inject CSS that kills all animations and transitions before any navigation\n    await page.addStyleTag({\n      content: `\n        *, *::before, *::after {\n          animation-duration: 0s !important;\n          animation-delay: 0s !important;\n          transition-duration: 0s !important;\n          transition-delay: 0s !important;\n          scroll-behavior: auto !important;\n        }\n      `,\n    });\n\n    // Store the original goto so we can wrap it\n    const originalGoto = page.goto.bind(page);\n\n    // Override goto to always wait for fonts + network idle after navigation\n    page.goto = async (url: string, options?: Parameters<typeof page.goto>[1]) => {\n      const response = await originalGoto(url, {\n        waitUntil: \"networkidle\",\n        ...options,\n      });\n\n      // Re-inject the animation-disabling CSS (navigation clears addStyleTag)\n      await page.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n        `,\n      });\n\n      // (b) Wait for all fonts to finish loading\n      await page.evaluate(() => document.fonts.ready);\n\n      // (c) Small settle time for any remaining paints\n      await page.waitForTimeout(200);\n\n      return response;\n    };\n\n    await use(page);\n  },\n});\n\nexport { expect };","new_string":"import { test as base, expect, type Page } from \"@playwright/test\";\n\nconst FREEZE_CSS = `\n  *, *::before, *::after {\n    animation-duration: 0s !important;\n    animation-delay: 0s !important;\n    transition-duration: 0s !important;\n    transition-delay: 0s !important;\n    scroll-behavior: auto !important;\n  }\n  /* Pause SVG SMIL animations */\n  svg { animation-play-state: paused !important; }\n`;\n\n/**\n * Shared visual-regression fixture.\n *\n * Extends the default Playwright `test` with a `stablePage` fixture that:\n *  (a) Seeds Math.random() and Date.now() for determinism\n *  (b) Injects CSS to disable all CSS + SVG animations/transitions\n *  (c) Pauses SVG SMIL animations via JS\n *  (d) Waits for document.fonts.ready and network idle\n */\nexport const test = base.extend<{ stablePage: Page }>({\n  stablePage: async ({ page }, use) => {\n    // (a) Deterministic Math.random (seeded PRNG) and frozen Date.now\n    await page.addInitScript(() => {\n      // Mulberry32 seeded PRNG — deterministic sequence from seed 42\n      let seed = 42;\n      Math.random = () => {\n        seed |= 0;\n        seed = (seed + 0x6d2b79f5) | 0;\n        let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);\n        t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;\n        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;\n      };\n\n      // Freeze Date.now to a fixed timestamp (2026-01-01T00:00:00Z)\n      const frozen = 1767225600000;\n      Date.now = () => frozen;\n    });\n\n    // Store the original goto so we can wrap it\n    const originalGoto = page.goto.bind(page);\n\n    // Override goto to always wait for fonts + network idle after navigation\n    page.goto = async (url: string, options?: Parameters<typeof page.goto>[1]) => {\n      const response = await originalGoto(url, {\n        waitUntil: \"networkidle\",\n        ...options,\n      });\n\n      // (b) Inject animation-disabling CSS (navigation clears addStyleTag)\n      await page.addStyleTag({ content: FREEZE_CSS });\n\n      // (c) Pause all SVG SMIL animations\n      await page.evaluate(() => {\n        document.querySelectorAll(\"svg\").forEach((svg) => {\n          if (typeof svg.pauseAnimations === \"function\") {\n            svg.pauseAnimations();\n          }\n        });\n      });\n\n      // (d) Wait for all fonts to finish loading\n      await page.evaluate(() => document.fonts.ready);\n\n      // Settle time for remaining paints\n      await page.waitForTimeout(300);\n\n      return response;\n    };\n\n    await use(page);\n  },\n});\n\nexport { expect };"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":381,"cache_read_input_tokens":48447,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":381},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"82717d21-cff7-43a1-a235-f97f60a95616","uuid":"cd568be2-d7d6-458f-bf86-55da45a9112b"}
