-disabling CSS (navigation clears addStyleTag)\n      await page.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n        `,\n      });\n\n      // (b) Wait for all fonts to finish loading\n      await page.evaluate(() => document.fonts.ready);\n\n      // (c) Small settle time for any remaining paints\n      await page.waitForTimeout(200);\n\n      return response;\n    };\n\n    await use(page);\n  },\n});\n\nexport { expect };","newString":"import { test as base, expect, type Page } from \"@playwright/test\";\n\nconst FREEZE_CSS = `\n  *, *::before, *::after {\n    animation-duration: 0s !important;\n    animation-delay: 0s !important;\n    transition-duration: 0s !important;\n    transition-delay: 0s !important;\n    scroll-behavior: auto !important;\n  }\n  /* Pause SVG SMIL animations */\n  svg { animation-play-state: paused !important; }\n`;\n\n/**\n * Shared visual-regression fixture.\n *\n * Extends the default Playwright `test` with a `stablePage` fixture that:\n *  (a) Seeds Math.random() and Date.now() for determinism\n *  (b) Injects CSS to disable all CSS + SVG animations/transitions\n *  (c) Pauses SVG SMIL animations via JS\n *  (d) Waits for document.fonts.ready and network idle\n */\nexport const test = base.extend<{ stablePage: Page }>({\n  stablePage: async ({ page }, use) => {\n    // (a) Deterministic Math.random (seeded PRNG) and frozen Date.now\n    await page.addInitScript(() => {\n      // Mulberry32 seeded PRNG — deterministic sequence from seed 42\n      let seed = 42;\n      Math.random = () => {\n        seed |= 0;\n        seed = (seed + 0x6d2b79f5) | 0;\n        let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);\n        t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;\n        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;\n      };\n\n      // Freeze Date.now to a fixed timestamp (2026-01-01T00:00:00Z)\n      const frozen = 1767225600000;\n      Date.now = () => frozen;\n    });\n\n    // Store the original goto so we can wrap it\n    const originalGoto = page.goto.bind(page);\n\n    // Override goto to always wait for fonts + network idle after navigation\n    page.goto = async (url: string, options?: Parameters<typeof page.goto>[1]) => {\n      const response = await originalGoto(url, {\n        waitUntil: \"networkidle\",\n        ...options,\n      });\n\n      // (b) Inject animation-disabling CSS (navigation clears addStyleTag)\n      await page.addStyleTag({ content: FREEZE_CSS });\n\n      // (c) Pause all SVG SMIL animations\n      await page.evaluate(() => {\n        document.querySelectorAll(\"svg\").forEach((svg) => {\n          if (typeof svg.pauseAnimations === \"function\") {\n            svg.pauseAnimations();\n          }\n        });\n      });\n\n      // (d) Wait for all fonts to finish loading\n      await page.evaluate(() => document.fonts.ready);\n\n      // Settle time for remaining paints\n      await page.waitForTimeout(300);\n\n      return response;\n    };\n\n    await use(page);\n  },\n});\n\nexport { expect };","originalFile":"import { test as base, expect, type Page } from \"@playwright/test\";\n\n/**\n * Shared visual-regression fixture.\n *\n * Extends the default Playwright `test` with a `stablePage` fixture that:\n *  (a) Injects CSS to disable all animations and transitions\n *  (b) Waits for document.fonts.ready\n *  (c) Waits for network idle\n *\n * Usage:\n *   import { test, expect } from \"../fixtures\";\n *   test(\"home page\", async ({ stablePage }) => {\n *     await stablePage.goto(\"/\");\n *     await expect(stablePage).toHaveScreenshot(\"home.png\");\n *   });\n */\nexport const test = base.extend<{ stablePage: Page }>({\n  stablePage: async ({ page }, use) => {\n    // (a) Inject CSS that kills all animations and transitions before any navigation\n    await page.addStyleTag({\n      content: `\n        *, *::before, *::after {\n          animation-duration: 0s !important;\n          animation-delay: 0s !important;\n          transition-duration: 0s !important;\n          transition-delay: 0s !important;\n          scroll-behavior: auto !important;\n        }\n      `,\n    });\n\n    // Store the original goto so we can wrap it\n    const originalGoto = page.goto.bind(page);\n\n    // Override goto to always wait for fonts + network idle after navigation\n    page.goto = async (url: string, options?: Parameters<typeof page.goto>[1]) => {\n      const response = await originalGoto(url, {\n        waitUntil: \"networkidle\",\n        ...options,\n      });\n\n      // Re-inject the animation-disabling CSS (navigation clears addStyleTag)\n      await page.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n        `,\n      });\n\n      // (b) Wait for all fonts to finish loading\n      await page.evaluate(() => document.fonts.ready);\n\n      // (c) Small settle time for any remaining paints\n      await page.waitForTimeout(200);\n\n      return response;\n    };\n\n    await use(page);\n  },\n});\n\nexport { expect };\n","structuredPatch":[{"oldStart":1,"oldLines":33,"newStart":1,"newLines":43,"lines":[" import { test as base, expect, type Page } from \"@playwright/test\";"," ","+const FREEZE_CSS = `","+  *, *::before, *::after {","+    animation-duration: 0s !important;","+    animation-delay: 0s !important;","+    transition-duration: 0s !important;","+    transition-delay: 0s !important;","+    scroll-behavior: auto !important;","+  }","+  /* Pause SVG SMIL animations */","+  svg { animation-play-state: paused !important; }","+`;","+"," /**","  * Shared visual-regression fixture.","  *","  * Extends the default Playwright `test` with a `stablePage` fixture that:","- *  (a) Injects CSS to disable all animations and transitions","- *  (b) Waits for document.fonts.ready","- *  (c) Waits for network idle","- *","- * Usage:","- *   import { test, expect } from \"../fixtures\";","- *   test(\"home page\", async ({ stablePage }) => {","- *     await stablePage.goto(\"/\");","- *     await expect(stablePage).toHaveScreenshot(\"home.png\");","- *   });","+ *  (a) Seeds Math.random() and Date.now() for determinism","+ *  (b) Injects CSS to disable all CSS + SVG animations/transitions","+ *  (c) Pauses SVG SMIL animations via JS","+ *  (d) Waits for document.fonts.ready and network idle","  */"," export const test = base.extend<{ stablePage: Page }>({","   stablePage: async ({ page }, use) => {","-    // (a) Inject CSS that kills all animations and transitions before any navigation","-    await page.addStyleTag({","-      content: `","-        *, *::before, *::after {","-          animation-duration: 0s !important;","-          animation-delay: 0s !important;","-          transition-duration: 0s !important;","-          transition-delay: 0s !important;","-          scroll-behavior: auto !important;","-        }","-      `,","+    // (a) Deterministic Math.random (seeded PRNG) and frozen Date.now","+    await page.addInitScript(() => {","+      // Mulberry32 seeded PRNG — deterministic sequence from seed 42","+      let seed = 42;","+      Math.random = () => {","+        seed |= 0;","+        seed = (seed + 0x6d2b79f5) | 0;","+        let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);","+        t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;","+        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;","+      };","+","+      // Freeze Date.now to a fixed timestamp (2026-01-01T00:00:00Z)","+      const frozen = 1767225600000;","+      Date.now = () =>