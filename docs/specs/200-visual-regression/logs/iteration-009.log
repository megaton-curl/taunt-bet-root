{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MMB28DmYUXRqWoC8qefi35","type":"tool_result","content":"     1→/**\n     2→ * RNG Buff Indicator - Star overlay on boss avatar when buff is active\n     3→ *\n     4→ * The RNG Buff is granted when a boss is defeated before the timer ends.\n     5→ * It allows players to randomly receive treasure chests when wagering.\n     6→ */\n     7→\n     8→import { useBossRaid } from \"../hooks\";\n     9→\n    10→export function RNGBuffIndicator() {\n    11→  const { hasRNGBuff, rngBuff } = useBossRaid();\n    12→\n    13→  if (!hasRNGBuff || !rngBuff) {\n    14→    return null;\n    15→  }\n    16→\n    17→  // Calculate time remaining until buff expires\n    18→  const now = Date.now();\n    19→  const remaining = Math.max(0, rngBuff.expiresAt - now);\n    20→  const minutes = Math.floor(remaining / 60000);\n    21→  const seconds = Math.floor((remaining % 60000) / 1000);\n    22→\n    23→  return (\n    24→    <div className=\"rng-buff-indicator\" title=\"RNG Buff Active! Chance to drop treasure chests when wagering.\">\n    25→      <div className=\"rng-buff-indicator__star\">\n    26→        <svg viewBox=\"0 0 24 24\" width=\"28\" height=\"28\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n    27→          <path\n    28→            d=\"M12 2L14.4 8.2L21 9.2L16 14L17.6 21L12 17.8L6.4 21L8 14L3 9.2L9.6 8.2L12 2Z\"\n    29→            fill=\"url(#buff-gradient)\"\n    30→            stroke=\"#f0b820\"\n    31→            strokeWidth=\"1.5\"\n    32→            strokeLinejoin=\"round\"\n    33→          />\n    34→          <defs>\n    35→            <linearGradient id=\"buff-gradient\" x1=\"12\" y1=\"2\" x2=\"12\" y2=\"21\" gradientUnits=\"userSpaceOnUse\">\n    36→              <stop stopColor=\"#ffeb3b\" />\n    37→              <stop offset=\"1\" stopColor=\"#ff9800\" />\n    38→            </linearGradient>\n    39→          </defs>\n    40→        </svg>\n    41→        <span className=\"rng-buff-indicator__pulse\" />\n    42→      </div>\n    43→      <span className=\"rng-buff-indicator__timer\">\n    44→        {minutes}:{seconds.toString().padStart(2, \"0\")}\n    45→      </span>\n    46→    </div>\n    47→  );\n    48→}\n    49→"}]},"parent_tool_use_id":"toolu_01EydLtiHqaYQnrjxSZpp45Y","session_id":"82717d21-cff7-43a1-a235-f97f60a95616","uuid":"99bbd9df-299a-4412-b02a-828a1d53d18c"}
