              </div>\n  1246→            </div>\n  1247→\n  1248→            <div className=\"verify-section\">\n  1249→              <h3>Quick Lookup</h3>\n  1250→              <p>Enter a round ID to fetch its verification data automatically.</p>\n  1251→              <div className=\"quick-lookup\">\n  1252→                <input\n  1253→                  type=\"text\"\n  1254→                  placeholder=\"Enter Round ID...\"\n  1255→                  className=\"verify-input\"\n  1256→                />\n  1257→                <button className=\"lookup-btn\">Lookup</button>\n  1258→              </div>\n  1259→            </div>\n  1260→          </div>\n  1261→        )}\n  1262→\n  1263→        {activeTab === 'seeds' && (\n  1264→          <div className=\"fairness-seeds\">\n  1265→            <h3>Active Commitments</h3>\n  1266→            <p>These are the current seed commitments for ongoing rounds. The actual seeds will be revealed after each round completes.</p>\n  1267→\n  1268→            <div className=\"seeds-table\">\n  1269→              <div className=\"seeds-header\">\n  1270→                <span>Game</span>\n  1271→                <span>Tier</span>\n  1272→                <span>Commitment Hash</span>\n  1273→                <span>Status</span>\n  1274→                <span>Time</span>\n  1275→              </div>\n  1276→              {activeSeeds.map((seed, i) => (\n  1277→                <div className=\"seed-row\" key={i}>\n  1278→                  <span className=\"seed-game\">{seed.game}</span>\n  1279→                  <span className=\"seed-tier\">{seed.tier}</span>\n  1280→                  <span className=\"seed-hash\">{seed.commitment}</span>\n  1281→                  <span className={`seed-status ${seed.status.toLowerCase()}`}>{seed.status}</span>\n  1282→                  <span className=\"seed-time\">{seed.expiresIn}</span>\n  1283→                </div>\n  1284→              ))}\n  1285→            </div>\n  1286→\n  1287→        