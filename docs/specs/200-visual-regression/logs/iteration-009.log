{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019cDQ3ZAWjxFVg3N3jpGoy4","type":"tool_result","content":"     1→/**\n     2→ * Raid Boss Avatar - Dragon bosses with color variants and tier-based visuals\n     3→ *\n     4→ * Dragons:\n     5→ * 1. Verdant Drake (green) - 50 HP\n     6→ * 2. Crimson Wyrm (red) - 75 HP\n     7→ * 3. Shadow Dragon (black) - 100 HP\n     8→ * 4. Golden Drake (golden) - 150 HP\n     9→ * 5. Diamond Dragon (diamond) - 200 HP\n    10→ */\n    11→\n    12→import type { PhaseThreshold, BossType, LootTier } from \"../types\";\n    13→\n    14→interface RaidBossAvatarProps {\n    15→  phase: PhaseThreshold;\n    16→  size?: \"small\" | \"large\";\n    17→  defeated?: boolean;\n    18→  bossType?: BossType;\n    19→  hasBonusJackpot?: boolean;\n    20→  lootTier?: LootTier;\n    21→}\n    22→\n    23→// Tier-based colors for visual intensity (loot tier affects glow/aura)\n    24→const TIER_COLORS = {\n    25→  bronze: { primary: \"#cd7f32\", glow: \"#a05a20\", accent: \"#8b5a2b\" },\n    26→  silver: { primary: \"#c0c0c0\", glow: \"#a8a8a8\", accent: \"#808080\" },\n    27→  gold: { primary: \"#f0b820\", glow: \"#ffaa00\", accent: \"#f0b820\" },\n    28→  emerald: { primary: \"#40c080\", glow: \"#60e0a0\", accent: \"#30a060\" },\n    29→  diamond: { primary: \"#b9f2ff\", glow: \"#b0c8e0\", accent: \"#00ffff\" },\n    30→};\n    31→\n    32→// Dragon color schemes per boss type\n    33→const DRAGON_COLORS: Record<BossType, {\n    34→  scale: string;\n    35→  scaleDark: string;\n    36→  scaleDarkest: string;\n    37→  neckScale: string;\n    38→  neckScaleDark: string;\n    39→  spike: string;\n    40→  spikeHighlight: string;\n    41→  eye: string;\n    42→  breathPrimary: string;\n    43→  breathSecondary: string;\n    44→  fang: string;\n    45→}> = {\n    46→  green_dragon: {\n    47→    scale: \"#1e3a1e\",\n    48→    scaleDark: \"#142a14\",\n    49→    scaleDarkest: \"#0a1a0a\",\n    50→    neckScale: \"#2a4a2a\",\n    51→    neckScaleDark: \"#1e3a1e\",\n    52→    spike: \"#0e200e\",\n    53→    spikeHighlight: \"#2a4a2a\",\n    54→    eye: \"#45b058\",\n    55→    breathPrimary: \"#2a6a30\",\n    56→    breathSecondary: \"#45b058\",\n    57→    fang: \"#c8c8d0\",\n    58→  },\n    59→  red_dragon: {\n    60→    scale: \"#3a1a1a\",\n    61→    scaleDark: \"#2a1010\",\n    62→    scaleDarkest: \"#1a0808\",\n    63→    neckScale: \"#4a2a2a\",\n    64→    neckScaleDark: \"#3a1a1a\",\n    65→    spike: \"#200e0e\",\n    66→    spikeHighlight: \"#4a2a2a\",\n    67→    eye: \"#ff4422\",\n    68→    breathPrimary: \"#a03020\",\n    69→    breathSecondary: \"#ff4422\",\n    70→    fang: \"#c8c8d0\",\n    71→  },\n    72→  black_dragon: {\n    73→    scale: \"#2a2a32\",\n    74→    scaleDark: \"#1a1a22\",\n    75→    scaleDarkest: \"#0e0e14\",\n    76→    neckScale: \"#4a4a58\",\n    77→    neckScaleDark: \"#3a3a48\",\n    78→    spike: \"#1a1a20\",\n    79→    spikeHighlight: \"#3a3a42\",\n    80→    eye: \"#cc2020\",\n    81→    breathPrimary: \"#6a2060\",\n    82→    breathSecondary: \"#802030\",\n    83→    fang: \"#c8c8d0\",\n    84→  },\n    85→  golden_dragon: {\n    86→    scale: \"#3a2e14\",\n    87→    scaleDark: \"#2a2010\",\n    88→    scaleDarkest: \"#1a140a\",\n    89→    neckScale: \"#5a4a28\",\n    90→    neckScaleDark: \"#4a3a1e\",\n    91→    spike: \"#201a0e\",\n    92→    spikeHighlight: \"#5a4a28\",\n    93→    eye: \"#f0b820\",\n    94→    breathPrimary: \"#8a6020\",\n    95→    breathSecondary: \"#f0b820\",\n    96→    fang: \"#f0e0c0\",\n    97→  },\n    98→  diamond_dragon: {\n    99→    scale: \"#2a3040\",\n   100→    scaleDark: \"#1a2030\",\n   101→    scaleDarkest: \"#0e1420\",\n   102→    neckScale: \"#4a5a70\",\n   103→    neckScaleDark: \"#3a4a60\",\n   104→    spike: \"#1a2030\",\n   105→    spikeHighlight: \"#4a5a70\",\n   106→    eye: \"#60d0ff\",\n   107→    breathPrimary: \"#2060a0\",\n   108→    breathSecondary: \"#80d0ff\",\n   109→    fang: \"#e0f0ff\",\n   110→  },\n   111→};\n   112→\n   113→// ============ Dragon Boss (parameterized by color) ============\n   114→function DragonBoss({ tier = \"bronze\", dragonType = \"black_dragon\" as BossType }: { tier?: LootTier; dragonType?: BossType }) {\n   115→  const colors = TIER_COLORS[tier];\n   116→  const isHighTier = tier === \"emerald\" || tier === \"diamond\";\n   117→  const isTopTier = tier === \"diamond\";\n   118→\n   119→  const dc = DRAGON_COLORS[dragonType];\n   120→\n   121→  return (\n   122→    <>\n   123→      {/* ========== BREATH - Colored flames from mouth ========== */}\n   124→      {/* Outer breath glow */}\n   125→      <ellipse cx=\"32\" cy=\"58\" rx=\"14\" ry=\"8\" fill={dc.breathPrimary} opacity=\"0.3\">\n   126→        <animate attributeName=\"opacity\" values=\"0.2;0.4;0.2\" dur=\"2s\" repeatCount=\"indefinite\" />\n   127→        <animate attributeName=\"ry\" values=\"8;10;8\" dur=\"2s\" repeatCount=\"indefinite\" />\n   128→      </ellipse>\n   129→      {/* Middle breath */}\n   130→      <ellipse cx=\"32\" cy=\"56\" rx=\"10\" ry=\"6\" fill={dc.breathSecondary} opacity=\"0.4\">\n   131→        <animate attributeName=\"opacity\" values=\"0.3;0.5;0.3\" dur=\"1.8s\" repeatCount=\"indefinite\" begin=\"0.2s\" />\n   132→      </ellipse>\n   133→      {/* Inner breath core */}\n   134→      <ellipse cx=\"32\" cy=\"54\" rx=\"6\" ry=\"4\" fill={dc.eye} opacity=\"0.5\">\n   135→        <animate attributeName=\"opacity\" values=\"0.4;0.6;0.4\" dur=\"1.5s\" repeatCount=\"indefinite\" begin=\"0.4s\" />\n   136→      </ellipse>\n   137→      {/* Breath particles */}\n   138→      <circle cx=\"26\" cy=\"60\" r=\"1.5\" fill={dc.breathPrimary} opacity=\"0.5\">\n   139→        <animate attributeName=\"cy\" values=\"60;64;60\" dur=\"2s\" repeatCount=\"indefinite\" />\n   140→        <animate attributeName=\"opacity\" values=\"0.5;0.2;0.5\" dur=\"2s\" repeatCount=\"indefinite\" />\n   141→      </circle>\n   142→      <circle cx=\"38\" cy=\"62\" r=\"1\" fill={dc.breathSecondary} opacity=\"0.4\">\n   143→        <animate attributeName=\"cy\" values=\"62;66;62\" dur=\"2.2s\" repeatCount=\"indefinite\" begin=\"0.3s\" />\n   144→        <animate attributeName=\"opacity\" values=\"0.4;0.1;0.4\" dur=\"2.2s\" repeatCount=\"indefinite\" begin=\"0.3s\" />\n   145→      </circle>\n   146→      <circle cx=\"32\" cy=\"62\" r=\"1.2\" fill={dc.eye} opacity=\"0.4\">\n   147→        <animate attributeName=\"cy\" values=\"62;68;62\" dur=\"1.8s\" repeatCount=\"indefinite\" begin=\"0.5s\" />\n   148→        <animate attributeName=\"opacity\" values=\"0.4;0.1;0.4\" dur=\"1.8s\" repeatCount=\"indefinite\" begin=\"0.5s\" />\n   149→      </circle>\n   150→\n   151→      {/* ========== NECK - Scaled with small spikes ========== */}\n   152→      {/* Neck base - centered, going down */}\n   153→      <path\n   154→        d=\"M 20 40 L 16 52 L 18 64 L 46 64 L 48 52 L 44 40 Z\"\n   155→        fill={dc.neckScale}\n   156→      />\n   157→      {/* Neck center darker area */}\n   158→      <path\n   159→        d=\"M 24 42 L 22 52 L 24 62 L 40 62 L 42 52 L 40 42 Z\"\n   160→        fill={dc.neckScaleDark}\n   161→        opacity=\"0.5\"\n   162→      />\n   163→      {/* Neck scale rows - horizontal lines */}\n   164→      {[...Array(5)].map((_, i) => (\n   165→        <path\n   166→          key={`neck-row-${i}`}\n   167→          d={`M ${18 + i * 0.5} ${46 + i * 4} L ${46 - i * 0.5} ${46 + i * 4}`}\n   168→          stroke={dc.scaleDarkest}\n   169→          strokeWidth=\"1\"\n   170→          fill=\"none\"\n   171→          opacity=\"0.4\"\n   172→        />\n   173→      ))}\n   174→      {/* Individual neck scales */}\n   175→      {[...Array(12)].map((_, i) => (\n   176→        <ellipse\n   177→          key={`neck-scale-${i}`}\n   178→          cx={22 + (i % 4) * 7}\n   179→          cy={48 + Math.floor(i / 4) * 5}\n   180→          rx=\"2.5\"\n   181→          ry=\"1.8\"\n   182→          fill={dc.scaleDark}\n   183→          opacity=\"0.5\"\n   184→        />\n   185→      ))}\n   186→      {/* Small neck spikes - left side */}\n   187→      <polygon points=\"16,48 12,46 16,52\" fill={dc.spike} />\n   188→      <polygon points=\"15,54 10,52 15,58\" fill={dc.spike} />\n   189→      <polygon points=\"16,60 12,58 17,64\" fill={dc.spike} />\n   190→      {/* Small neck spikes - right side */}\n   191→      <polygon points=\"48,48 52,46 48,52\" fill={dc.spike} />\n   192→      <polygon points=\"49,54 54,52 49,58\" fill={dc.spike} />\n   193→      <polygon points=\"48,60 52,58 47,64\" fill={dc.spike} />\n   194→\n   195→      {/* ========== HEAD - Front-facing ========== */}\n   196→      {/* Main head shape */}\n   197→      <ellipse cx=\"32\" cy=\"26\" rx=\"18\" ry=\"16\" fill={dc.scale} className=\"raid-boss-avatar__head\" />\n   198→      {/* Head darker center/depth */}\n   199→      <ellipse cx=\"32\" cy=\"28\" rx=\"14\" ry=\"12\" fill={dc.scaleDark} opacity=\"0.4\" />\n   200→\n   201→      {/* Brow ridge - prominent */}\n   202→      <path d=\"M 12 20 Q 22 14, 32 16 Q 42 14, 52 20\" stroke={dc.scaleDarkest} strokeWidth=\"4\" fill=\"none\" />\n   203→      <path d=\"M 14 22 Q 23 18, 32 19 Q 41 18, 50 22\" stroke={dc.scale} strokeWidth=\"2\" fill=\"none\" />\n   204→\n   205→      {/* Snout/muzzle - front facing */}\n   206→      <ellipse cx=\"32\" cy=\"36\" rx=\"10\" ry=\"6\" fill={dc.scale} />\n   207→      <ellipse cx=\"32\" cy=\"37\" rx=\"7\" ry=\"4\" fill={dc.scaleDark} opacity=\"0.5\" />\n   208→\n   209→      {/* Nostrils */}\n   210→      <ellipse cx=\"27\" cy=\"34\" rx=\"2\" ry=\"1.5\" fill={dc.scaleDarkest} />\n   211→      <ellipse cx=\"37\" cy=\"34\" rx=\"2\" ry=\"1.5\" fill={dc.scaleDarkest} />\n   212→      {/* Nostril glow (heat) */}\n   213→      <ellipse cx=\"27\" cy=\"34\" rx=\"1.5\" ry=\"1\" fill={dc.breathSecondary} opacity=\"0.3\">\n   214→        <animate attributeName=\"opacity\" values=\"0.2;0.4;0.2\" dur=\"2s\" repeatCount=\"indefinite\" />\n   215→      </ellipse>\n   216→      <ellipse cx=\"37\" cy=\"34\" rx=\"1.5\" ry=\"1\" fill={dc.breathSecondary} opacity=\"0.3\">\n   217→        <animate attributeName=\"opacity\" values=\"0.2;0.4;0.2\" dur=\"2s\" repeatCount=\"indefinite\" begin=\"0.5s\" />\n   218→      </ellipse>\n   219→\n   220→      {/* ========== HEAD SPIKES - Three main spikes ========== */}\n   221→      {/* Center spike - largest */}\n   222→      <polygon points=\"32,16 28,2 32,6 36,2 32,16\" fill={dc.spike} />\n   223→      <polygon points=\"32,14 30,4 32,7 34,4 32,14\" fill={dc.spikeHighlight} opacity=\"0.4\" />\n   224→\n   225→      {/* Left spike */}\n   226→      <polygon points=\"20,18 12,4 16,8 18,2 22,16\" fill={dc.spike} />\n   227→      <polygon points=\"20,16 14,6 17,9 18,4 21,15\" fill={dc.spikeHighlight} opacity=\"0.4\" />\n   228→\n   229→      {/* Right spike */}\n   230→      <polygon points=\"44,18 52,4 48,8 46,2 42,16\" fill={dc.spike} />\n   231→      <polygon points=\"44,16 50,6 47,9 46,4 43,15\" fill={dc.spikeHighlight} opacity=\"0.4\" />\n   232→\n   233→      {/* Small side spikes */}\n   234→      <polygon points=\"10,24 4,18 8,22\" fill={dc.spike} />\n   235→      <polygon points=\"54,24 60,18 56,22\" fill={dc.spike} />\n   236→\n   237→      {/* Small forehead spikes */}\n   238→      <polygon points=\"26,18 24,12 28,17\" fill={dc.spike} />\n   239→      <polygon points=\"38,18 40,12 36,17\" fill={dc.spike} />\n   240→\n   241→      {/* ========== HEAD SCALES TEXTURE ========== */}\n   242→      {/* Scale pattern on forehead */}\n   243→      {[...Array(6)].map((_, i) => (\n   244→        <ellipse\n   245→          key={`head-scale-${i}`}\n   246→          cx={22 + (i % 3) * 10}\n   247→          cy={22 + Math.floor(i / 3) * 6}\n   248→          rx=\"3\"\n   249→          ry=\"2\"\n   250→          fill={dc.scaleDark}\n   251→          opacity=\"0.5\"\n   252→        />\n   253→      ))}\n   254→\n   255→      {/* ========== EYES - Glowing, front-facing ========== */}\n   256→      {/* Left eye socket */}\n   257→      <ellipse cx=\"22\" cy=\"26\" rx=\"6\" ry=\"5\" fill={dc.scaleDarkest} />\n   258→      {/* Left eye glow */}\n   259→      <ellipse cx=\"22\" cy=\"26\" rx=\"4.5\" ry=\"4\" fill=\"#1a0a0a\" />\n   260→      <ellipse cx=\"22\" cy=\"26\" rx=\"3.5\" ry=\"3\" fill={dc.eye} filter=\"url(#boss-tier-glow)\" className=\"raid-boss-avatar__eye\">\n   261→        <animate attributeName=\"opacity\" values=\"0.8;1;0.8\" dur=\"2s\" repeatCount=\"indefinite\" />\n   262→      </ellipse>\n   263→      {/* Left pupil slit */}\n   264→      <ellipse cx=\"22\" cy=\"26\" rx=\"1\" ry=\"2.5\" fill=\"#0a0008\" />\n   265→      {/* Left eye highlight */}\n   266→      <ellipse cx=\"24\" cy=\"24\" rx=\"1\" ry=\"0.6\" fill=\"#ffffff\" opacity=\"0.7\" />\n   267→      {/* Left eye glow aura */}\n   268→      <ellipse cx=\"22\" cy=\"26\" rx=\"7\" ry=\"6\" fill={dc.eye} opacity=\"0.2\">\n   269→        <animate attributeName=\"opacity\" values=\"0.1;0.3;0.1\" dur=\"2s\" repeatCount=\"indefinite\" />\n   270→      </ellipse>\n   271→\n   272→      {/* Right eye socket */}\n   273→      <ellipse cx=\"42\" cy=\"26\" rx=\"6\" ry=\"5\" fill={dc.scaleDarkest} />\n   274→      {/* Right eye glow */}\n   275→      <ellipse cx=\"42\" cy=\"26\" rx=\"4.5\" ry=\"4\" fill=\"#1a0a0a\" />\n   276→      <ellipse cx=\"42\" cy=\"26\" rx=\"3.5\" ry=\"3\" fill={dc.eye} filter=\"url(#boss-tier-glow)\" className=\"raid-boss-avatar__eye\">\n   277→        <animate attributeName=\"opacity\" values=\"0.8;1;0.8\" dur=\"2s\" repeatCount=\"indefinite\" begin=\"0.3s\" />\n   278→      </ellipse>\n   279→      {/* Right pupil slit */}\n   280→      <ellipse cx=\"42\" cy=\"26\" rx=\"1\" ry=\"2.5\" fill=\"#0a0008\" />\n   281→      {/* Right eye highlight */}\n   282→      <ellipse cx=\"44\" cy=\"24\" rx=\"1\" ry=\"0.6\" fill=\"#ffffff\" opacity=\"0.7\" />\n   283→      {/* Right eye glow aura */}\n   284→      <ellipse cx=\"42\" cy=\"26\" rx=\"7\" ry=\"6\" fill={dc.eye} opacity=\"0.2\">\n   285→        <animate attributeName=\"opacity\" values=\"0.1;0.3;0.1\" dur=\"2s\" repeatCount=\"indefinite\" begin=\"0.3s\" />\n   286→      </ellipse>\n   287→\n   288→      {/* ========== MOUTH - Open, breathing fire ========== */}\n   289→      {/* Upper jaw */}\n   290→      <path d=\"M 22 40 Q 27 38, 32 38 Q 37 38, 42 40\" stroke={dc.scaleDark} strokeWidth=\"2\" fill=\"none\" />\n   291→\n   292→      {/* Mouth opening */}\n   293→      <ellipse cx=\"32\" cy=\"46\" rx=\"10\" ry=\"6\" fill=\"#0a0008\" />\n   294→\n   295→      {/* Inner mouth glow */}\n   296→      <ellipse cx=\"32\" cy=\"46\" rx=\"8\" ry=\"4\" fill={dc.breathPrimary} opacity=\"0.6\">\n   297→        <animate attributeName=\"opacity\" values=\"0.4;0.7;0.4\" dur=\"2s\" repeatCount=\"indefinite\" />\n   298→      </ellipse>\n   299→      <ellipse cx=\"32\" cy=\"46\" rx=\"5\" ry=\"2.5\" fill={dc.breathSecondary} opacity=\"0.7\">\n   300→        <animate attributeName=\"opacity\" values=\"0.5;0.8;0.5\" dur=\"1.8s\" repeatCount=\"indefinite\" begin=\"0.2s\" />\n   301→      </ellipse>\n   302→\n   303→      {/* Upper fangs */}\n   304→      <polygon points=\"24,40 22,46 26,42\" fill={dc.fang} />\n   305→      <polygon points=\"28,39 26,44 30,41\" fill={dc.fang} opacity=\"0.9\" />\n   306→      <polygon points=\"36,39 38,44 34,41\" fill={dc.fang} opacity=\"0.9\" />\n   307→      <polygon points=\"40,40 42,46 38,42\" fill={dc.fang} />\n   308→\n   309→      {/* Lower fangs */}\n   310→      <polygon points=\"26,50 24,46 28,49\" fill={dc.fang} />\n   311→      <polygon points=\"38,50 40,46 36,49\" fill={dc.fang} />\n   312→\n   313→      {/* ========== TIER-BASED ENHANCEMENTS ========== */}\n   314→      {tier !== \"bronze\" && (\n   315→        <>\n   316→          {/* Silver+ enhanced eye glow */}\n   317→          <ellipse cx=\"22\" cy=\"26\" rx=\"8\" ry=\"7\" fill={dc.eye} opacity=\"0.1\">\n   318→            <animate attributeName=\"opacity\" values=\"0.05;0.15;0.05\" dur=\"2s\" repeatCount=\"indefinite\" />\n   319→          </ellipse>\n   320→          <ellipse cx=\"42\" cy=\"26\" rx=\"8\" ry=\"7\" fill={dc.eye} opacity=\"0.1\">\n   321→            <animate attributeName=\"opacity\" values=\"0.05;0.15;0.05\" dur=\"2s\" repeatCount=\"indefinite\" begin=\"0.3s\" />\n   322→          </ellipse>\n   323→          {/* Enhanced breath */}\n   324→          <ellipse cx=\"32\" cy=\"60\" rx=\"12\" ry=\"6\" fill={dc.breathPrimary} opacity=\"0.2\">\n   325→            <animate attributeName=\"opacity\" values=\"0.1;0.3;0.1\" dur=\"2.5s\" repeatCount=\"indefinite\" />\n   326→          </ellipse>\n   327→        </>\n   328→      )}\n   329→\n   330→      {tier === \"gold\" || isHighTier ? (\n   331→        <>\n   332→          {/* Gold+ spike tips glow */}\n   333→          <ellipse cx=\"32\" cy=\"4\" rx=\"2\" ry=\"1.5\" fill={dc.eye} opacity=\"0.3\" />\n   334→          <ellipse cx=\"16\" cy=\"4\" rx=\"1.5\" ry=\"1\" fill={dc.eye} opacity=\"0.25\" />\n   335→          <ellipse cx=\"48\" cy=\"4\" rx=\"1.5\" ry=\"1\" fill={dc.eye} opacity=\"0.25\" />\n   336→          {/* Enhanced mouth glow */}\n   337→          <ellipse cx=\"32\" cy=\"46\" rx=\"10\" ry=\"5\" fill={dc.breathSecondary} opacity=\"0.2\">\n   338→            <animate attributeName=\"opacity\" values=\"0.15;0.3;0.15\" dur=\"2s\" repeatCount=\"indefinite\" />\n   339→          </ellipse>\n   340→        </>\n   341→      ) : null}\n   342→\n   343→      {isHighTier && (\n   344→        <>\n   345→          {/* Emerald+ vein glow on face */}\n   346→          <path d=\"M 16 24 L 18 28\" stroke={dc.eye} strokeWidth=\"1\" fill=\"none\" opacity=\"0.4\">\n   347→            <animate attributeName=\"opacity\" values=\"0.2;0.5;0.2\" dur=\"3s\" repeatCount=\"indefinite\" />\n   348→          </path>\n   349→          <path d=\"M 48 24 L 46 28\" stroke={dc.eye} strokeWidth=\"1\" fill=\"none\" opacity=\"0.4\">\n   350→            <animate attributeName=\"opacity\" values=\"0.2;0.5;0.2\" dur=\"3s\" repeatCount=\"indefinite\" begin=\"0.5s\" />\n   351→          </path>\n   352→          {/* Subtle aura */}\n   353→          <ellipse cx=\"32\" cy=\"32\" rx=\"28\" ry=\"26\" fill=\"none\" stroke={dc.eye} strokeWidth=\"0.8\" opacity=\"0.15\" />\n   354→        </>\n   355→      )}\n   356→\n   357→      {isTopTier && (\n   358→        <>\n   359→          {/* Diamond - intense effects */}\n   360→          <ellipse cx=\"32\" cy=\"26\" rx=\"24\" ry=\"20\" fill={dc.eye} opacity=\"0.08\">\n   361→            <animate attributeName=\"opacity\" values=\"0.05;0.12;0.05\" dur=\"1.5s\" repeatCount=\"indefinite\" />\n   362→          </ellipse>\n   363→          {/* Rune on forehead */}\n   364→          <text x=\"32\" y=\"20\" fill={dc.eye} fontSize=\"5\" textAnchor=\"middle\" opacity=\"0.6\">&#x2666;</text>\n   365→          {/* Outer magical aura */}\n   366→          <ellipse cx=\"32\" cy=\"36\" rx=\"30\" ry=\"28\" fill=\"none\" stroke={colors.glow} strokeWidth=\"1\" opacity=\"0.2\" />\n   367→          {/* More intense breath */}\n   368→          <ellipse cx=\"32\" cy=\"58\" rx=\"16\" ry=\"10\" fill={dc.breathPrimary} opacity=\"0.25\">\n   369→            <animate attributeName=\"opacity\" values=\"0.15;0.35;0.15\" dur=\"1.5s\" repeatCount=\"indefinite\" />\n   370→          </ellipse>\n   371→        </>\n   372→      )}\n   373→    </>\n   374→  );\n   375→}\n   376→\n   377→// ============ Main Export Component ============\n   378→export function KrakenAvatar({\n   379→  phase,\n   380→  size = \"small\",\n   381→  defeated = false,\n   382→  bossType = \"green_dragon\",\n   383→  hasBonusJackpot = false,\n   384→  lootTier = \"bronze\",\n   385→}: RaidBossAvatarProps) {\n   386→  const sizeClass = size === \"large\" ? \"raid-boss-avatar--large\" : \"\";\n   387→  const phaseClass = `raid-boss-avatar--${phase}`;\n   388→  const defeatedClass = defeated ? \"raid-boss-avatar--defeated\" : \"\";\n   389→  const jackpotClass = hasBonusJackpot ? \"raid-boss-avatar--jackpot\" : \"\";\n   390→  const tierClass = `raid-boss-avatar--tier-${lootTier}`;\n   391→\n   392→  const colors = TIER_COLORS[lootTier];\n   393→  const dc = DRAGON_COLORS[bossType];\n   394→\n   395→  return (\n   396→    <div className={`raid-boss-avatar ${sizeClass} ${phaseClass} ${defeatedClass} ${jackpotClass} ${tierClass}`}>\n   397→      {/* Golden haze overlay for bonus jackpot */}\n   398→      {hasBonusJackpot && (\n   399→        <div className=\"raid-boss-avatar__haze raid-boss-avatar__haze--legendary\" />\n   400→      )}\n   401→\n   402→      <svg\n   403→        viewBox=\"0 0 64 64\"\n   404→        className=\"raid-boss-avatar__svg\"\n   405→        xmlns=\"http://www.w3.org/2000/svg\"\n   406→      >\n   407→        {/* Shared filters and gradients */}\n   408→        <defs>\n   409→          {/* Tier-based glow filter */}\n   410→          <filter id=\"boss-tier-glow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n   411→            <feGaussianBlur stdDeviation=\"2\" result=\"blur\" />\n   412→            <feFlood floodColor={dc.eye} result=\"color\" />\n   413→            <feComposite in=\"color\" in2=\"blur\" operator=\"in\" result=\"glow\" />\n   414→            <feMerge>\n   415→              <feMergeNode in=\"glow\" />\n   416→              <feMergeNode in=\"SourceGraphic\" />\n   417→            </feMerge>\n   418→          </filter>\n   419→\n   420→          <linearGradient id=\"boss-dragon-bone\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\">\n   421→            <stop offset=\"0%\" stopColor=\"#6a6a7a\" />\n   422→            <stop offset=\"50%\" stopColor=\"#4a4a5a\" />\n   423→            <stop offset=\"100%\" stopColor=\"#2a2a3a\" />\n   424→          </linearGradient>\n   425→        </defs>\n   426→\n   427→        {/* Aura - color based on tier */}\n   428→        <ellipse\n   429→          cx=\"32\"\n   430→          cy=\"32\"\n   431→          rx=\"28\"\n   432→          ry=\"26\"\n   433→          fill={`${colors.glow}15`}\n   434→          className=\"raid-boss-avatar__aura\"\n   435→        />\n   436→\n   437→        <DragonBoss tier={lootTier} dragonType={bossType} />\n   438→      </svg>\n   439→\n   440→      {/* Status indicator */}\n   441→      {phase === \"critical\" && !defeated && (\n   442→        <div className=\"raid-boss-avatar__status raid-boss-avatar__status--critical\">!</div>\n   443→      )}\n   444→      {defeated && (\n   445→        <div className=\"raid-boss-avatar__status raid-boss-avatar__status--defeated\">X</div>\n   446→      )}\n   447→    </div>\n   448→  );\n   449→}\n   450→"}]},"parent_tool_use_id":"toolu_01EydLtiHqaYQnrjxSZpp45Y","session_id":"82717d21-cff7-43a1-a235-f97f60a95616","uuid":"3bb8e62c-ad19-4af6-92de-43ba78f63586"}
