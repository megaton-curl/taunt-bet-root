lues(bytes);\n    62→  return Array.from(bytes)\n    63→    .map((b) => b.toString(16).padStart(2, \"0\"))\n    64→    .join(\"\");\n    65→}\n    66→\n    67→export function delay(ms: number): Promise<void> {\n    68→  return new Promise((resolve) => setTimeout(resolve, ms));\n    69→}\n    70→\n    71→export function solToLamports(sol: number): number {\n    72→  return Math.floor(sol * 1_000_000_000);\n    73→}\n    74→\n    75→export function lamportsToSol(lamports: number): number {\n    76→  return lamports / 1_000_000_000;\n    77→}\n    78→\n    79→export function getPublicKeyFromAddress(address: string): PublicKey {\n    80→  return new PublicKey(address);\n    81→}\n    82→"}]},"parent_tool_use_id":null,"session_id":"abe33f0b-f1dd-4b96-a953-f5438b0c7570","uuid":"9dca84f7-6c01-4925-ae5c-89e0573c21b4","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/wallet/src/mock/MockWalletState.ts","content":"import { Keypair, PublicKey } from \"@solana/web3.js\";\n\nexport interface MockConfig {\n  initialBalance: number; // in SOL\n  autoConnect: boolean;\n  simulatedLatency: number; // ms\n  persistState: boolean;\n}\n\nexport const DEFAULT_MOCK_CONFIG: MockConfig = {\n  initialBalance: 1000,\n  autoConnect: false,\n  simulatedLatency: 500,\n  persistState: true,\n};\n\nconst STORAGE_KEY = \"rng-utopia-mock-wallet\";\n\ninterface PersistedState {\n  address: string;\n  balance: number; // in lamports\n}\n\nexport function createMockKeypair(): Keypair {\n  return Keypair.generate();\n}\n\nexport function loadPersistedState(): PersistedState | null {\n  if (typeof window === \"undefined\") return null;\n  try {\n    const stored = localStorage.getItem(STORAGE_KEY);\n    if (stored) {\n      return JSON.parse(stored);\n    }\n  } catch {\n    // Ignore parse errors\n  }\n  return null;\n}\n\nexport function persistState(state: PersistedState): void {\n  if (typeof window === \"undefined\") return;\n  try {\n    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));\n  } catch {\n    // Ignore storage errors\n  }\n}\n\nexport function clearPersistedState(): void {\n  if (typeof window === \"undefined\") return;\n  try {\n    localStorage.removeItem(STORAGE_KEY);\n  } catch {\n    // Ignore storage errors\n  }\n}\n\nexport function generateMockSignature(): string {\n  const bytes = new Uint8Array(64);\n  crypto.getRandomValues(bytes);\n  return Array.from(bytes)\n    .map((b) => b.toString(16).padStart(2, \"0\"))\n    .join(\"\");\n}\n\nexport function delay(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nexport function solToLamports(sol: number): number {\n  return Math.floor(sol * 1_000_000_000);\n}\n\nexport function lamportsToSol(lamports: number): number {\n  return lamports / 1_000_000_000;\n}\n\nexport function getPublicKeyFromAddress(address: string): PublicKey {\n  return new PublicKey(address);\n}\n","numLines":82,"startLine":1,"totalLines":82}}}
