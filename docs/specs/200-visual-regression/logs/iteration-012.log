{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QYAgoR7GJ5GctS4F2eq2LF","type":"tool_result","content":"     1→import { test as base, expect, type Page } from \"@playwright/test\";\n     2→\n     3→const FREEZE_CSS = `\n     4→  *, *::before, *::after {\n     5→    animation-duration: 0s !important;\n     6→    animation-delay: 0s !important;\n     7→    transition-duration: 0s !important;\n     8→    transition-delay: 0s !important;\n     9→    scroll-behavior: auto !important;\n    10→  }\n    11→  /* Pause SVG SMIL animations */\n    12→  svg { animation-play-state: paused !important; }\n    13→`;\n    14→\n    15→/**\n    16→ * Shared visual-regression fixture.\n    17→ *\n    18→ * Extends the default Playwright `test` with a `stablePage` fixture that:\n    19→ *  (a) Seeds Math.random() and Date.now() for determinism\n    20→ *  (b) Injects CSS to disable all CSS + SVG animations/transitions\n    21→ *  (c) Pauses SVG SMIL animations via JS\n    22→ *  (d) Waits for document.fonts.ready and network idle\n    23→ */\n    24→export const test = base.extend<{ stablePage: Page }>({\n    25→  stablePage: async ({ page }, use) => {\n    26→    // (a) Deterministic Math.random (seeded PRNG) and frozen Date.now\n    27→    await page.addInitScript(() => {\n    28→      // Mulberry32 seeded PRNG — deterministic sequence from seed 42\n    29→      let seed = 42;\n    30→      Math.random = () => {\n    31→        seed |= 0;\n    32→        seed = (seed + 0x6d2b79f5) | 0;\n    33→        let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);\n    34→        t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;\n    35→        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;\n    36→      };\n    37→\n    38→      // Freeze Date.now to a fixed timestamp (2026-01-01T00:00:00Z)\n    39→      const frozen = 1767225600000;\n    40→      Date.now = () => frozen;\n    41→    });\n    42→\n    43→    // Store the original goto so we can wrap it\n    44→    const originalGoto = page.goto.bind(page);\n    45→\n    46→    // Override goto to always wait for fonts + network idle after navigation\n    47→    page.goto = async (url: string, options?: Parameters<typeof page.goto>[1]) => {\n    48→      const response = await originalGoto(url, {\n    49→        waitUntil: \"networkidle\",\n    50→        ...options,\n    51→      });\n    52→\n    53→      // (b) Inject animation-disabling CSS (navigation clears addStyleTag)\n    54→      await page.addStyleTag({ content: FREEZE_CSS });\n    55→\n    56→      // (c) Pause all SVG SMIL animations\n    57→      await page.evaluate(() => {\n    58→        document.querySelectorAll(\"svg\").forEach((svg) => {\n    59→          if (typeof svg.pauseAnimations === \"function\") {\n    60→            svg.pauseAnimations();\n    61→          }\n    62→        });\n    63→      });\n    64→\n    65→      // (d) Wait for all fonts to finish loading\n    66→      await page.evaluate(() => document.fonts.ready);\n    67→\n    68→      // Settle time for remaining paints\n    69→      await page.waitForTimeout(300);\n    70→\n    71→      return response;\n    72→    };\n    73→\n    74→    await use(page);\n    75→  },\n    76→});\n    77→\n    78→export { expect };\n    79→"}]},"parent_tool_use_id":null,"session_id":"abe33f0b-f1dd-4b96-a953-f5438b0c7570","uuid":"12cee708-cb9a-437b-8e47-26412e43a51a","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/fixtures.ts","content":"import { test as base, expect, type Page } from \"@playwright/test\";\n\nconst FREEZE_CSS = `\n  *, *::before, *::after {\n    animation-duration: 0s !important;\n    animation-delay: 0s !important;\n    transition-duration: 0s !important;\n    transition-delay: 0s !important;\n    scroll-behavior: auto !important;\n  }\n  /* Pause SVG SMIL animations */\n  svg { animation-play-state: paused !important; }\n`;\n\n/**\n * Shared visual-regression fixture.\n *\n * Extends the default Playwright `test` with a `stablePage` fixture that:\n *  (a) Seeds Math.random() and Date.now() for determinism\n *  (b) Injects CSS to disable all CSS + SVG animations/transitions\n *  (c) Pauses SVG SMIL animations via JS\n *  (d) Waits for document.fonts.ready and network idle\n */\nexport const test = base.extend<{ stablePage: Page }>({\n  stablePage: async ({ page }, use) => {\n    // (a) Deterministic Math.random (seeded PRNG) and frozen Date.now\n    await page.addInitScript(() => {\n      // Mulberry32 seeded PRNG — deterministic sequence from seed 42\n      let seed = 42;\n      Math.random = () => {\n        seed |= 0;\n        seed = (seed + 0x6d2b79f5) | 0;\n        let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);\n        t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;\n        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;\n      };\n\n      // Freeze Date.now to a fixed timestamp (2026-01-01T00:00:00Z)\n      const frozen = 1767225600000;\n      Date.now = () => frozen;\n    });\n\n    // Store the original goto so we can wrap it\n    const originalGoto = page.goto.bind(page);\n\n    // Override goto to always wait for fonts + network idle after navigation\n    page.goto = async (url: string, options?: Parameters<typeof page.goto>[1]) => {\n      const response = await originalGoto(url, {\n        waitUntil: \"networkidle\",\n        ...options,\n      });\n\n      // (b) Inject animation-disabling CSS (navigation clears addStyleTag)\n      await page.addStyleTag({ content: FREEZE_CSS });\n\n      // (c) Pause all SVG SMIL animations\n      await page.evaluate(() => {\n        document.querySelectorAll(\"svg\").forEach((svg) => {\n          if (typeof svg.pauseAnimations === \"function\") {\n            svg.pauseAnimations();\n          }\n        });\n      });\n\n      // (d) Wait for all fonts to finish loading\n      await page.evaluate(() => document.fonts.ready);\n\n      // Settle time for remaining paints\n      await page.waitForTimeout(300);\n\n      return response;\n    };\n\n    await use(page);\n  },\n});\n\nexport { expect };\n","numLines":79,"startLine":1,"totalLines":79}}}
