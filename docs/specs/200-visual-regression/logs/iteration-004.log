aces/rng-utopia/sources/rng-utopia/package.json","content":"{\n  \"name\": \"rng-utopia\",\n  \"version\": \"0.1.0\",\n  \"private\": true,\n  \"description\": \"Peer-to-peer on-chain casino platform on Solana\",\n  \"packageManager\": \"pnpm@9.15.0\",\n  \"engines\": {\n    \"node\": \">=20\"\n  },\n  \"scripts\": {\n    \"dev\": \"turbo run dev\",\n    \"build\": \"cd apps/platform && NODE_OPTIONS=--max-old-space-size=4096 pnpm run build\",\n    \"build:all\": \"turbo run build\",\n    \"lint\": \"turbo run lint\",\n    \"lint:fix\": \"turbo run lint:fix\",\n    \"typecheck\": \"turbo run typecheck\",\n    \"test\": \"turbo run test\",\n    \"test:visual\": \"turbo run test:visual\",\n    \"clean\": \"turbo run clean && rm -rf node_modules\",\n    \"dev:platform\": \"pnpm --filter @rng-utopia/platform dev\",\n    \"build:platform\": \"pnpm --filter @rng-utopia/platform build\",\n    \"dev:programs\": \"cd solana && anchor build\",\n    \"test:programs\": \"cd solana && anchor test --skip-local-validator --skip-deploy\",\n    \"format\": \"prettier --write \\\"**/*.{ts,tsx,js,jsx,json,md}\\\"\",\n    \"format:check\": \"prettier --check \\\"**/*.{ts,tsx,js,jsx,json,md}\\\"\"\n  },\n  \"devDependencies\": {\n    \"prettier\": \"^3.2.5\",\n    \"turbo\": \"^2.3.0\"\n  },\n  \"keywords\": [\n    \"solana\",\n    \"casino\",\n    \"p2p\",\n    \"gaming\",\n    \"vrf\",\n    \"provably-fair\"\n  ],\n  \"license\": \"UNLICENSED\"\n}\n","numLines":41,"startLine":1,"totalLines":41}}}
