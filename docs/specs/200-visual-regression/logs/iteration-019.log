g dependencies...${NC}\"\n    50→        pnpm install\n    51→    fi\n    52→\n    53→    echo -e \"${GREEN}[STEP] Linting...${NC}\"\n    54→    pnpm lint\n    55→\n    56→    echo -e \"${GREEN}[STEP] Typechecking...${NC}\"\n    57→    pnpm typecheck\n    58→\n    59→    echo -e \"${GREEN}[STEP] Building frontend entrypoint (apps/platform)...${NC}\"\n    60→    pnpm build\n    61→\n    62→    echo -e \"${GREEN}[STEP] Testing (TS packages)...${NC}\"\n    63→    pnpm test\n    64→\n    65→    cd ../..\n    66→}\n    67→\n    68→# ---------------------------------------------------------------------------\n    69→# Anchor steps (build + test)\n    70→# ---------------------------------------------------------------------------\n    71→run_anchor() {\n    72→    if ! command -v anchor &>/dev/null; then\n    73→        echo -e \"${YELLOW}[SKIP] Anchor tests (anchor CLI not found)${NC}\"\n    74→        return 0\n    75→    fi\n    76→\n    77→    cd sources/rng-utopia/solana\n    78→\n    79→    if [ ! -d \"node_modules\" ]; then\n    80→        pnpm install --ignore-workspace\n    81→    fi\n    82→\n    83→    echo -e \"${GREEN}[STEP] Building Anchor programs...${NC}\"\n    84→    anchor build\n    85→\n    86→    echo -e \"${GREEN}[STEP] Testing (Anchor programs)...${NC}\"\n    87→    anchor test --skip-local-validator --skip-deploy\n    88→\n    89→    cd ../../..\n    90→}\n    91→\n    92→# ---------------------------------------------------------------------------\n    93→# Run based on mode\n    94→# ---------------------------------------------------------------------------\n    95→case \"$MODE\" in\n    96→    full)\n    97→        run_ts\n    98→        run_anchor\n    99→        ;;\n   100→    ts)\n   101→        run_ts\n   102→        ;;\n   103→    anchor)\n   104→        run_anchor\n   105→        ;;\n   106→esac\n   107→\n   108→echo -e \"${GREEN}=== VERIFICATION PASSED ($MODE) ===${NC}\"\n   109→exit 0\n   110→"}]},"parent_tool_use_id":null,"session_id":"35ded62a-ee21-4735-813b-25c7c462021e","uuid":"3a20f4b9-9a43-47f4-9bf8-d2d717096c1a","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/scripts/verify","content":"#!/bin/bash\nset -e\n\n# =============================================================================\n# verify — End-to-end verification for RNG Utopia\n#\n# Usage:\n#   ./scripts/verify              Full verification (all steps)\n#   ./scripts/verify --anchor     Anchor programs only (build + test)\n#   ./scripts/verify --ts         TypeScript only (lint + typecheck + build + test)\n# =============================================================================\n\n# Color codes\nGREEN='\\033[0;32m'\nRED='\\033[0;31m'\nYELLOW='\\033[0;33m'\nNC='\\033[0m'\n\nMODE=\"${1:-full}\"\n\n# Normalize flags\ncase \"$MODE\" in\n    --anchor|--anchor-only|anchor) MODE=\"anchor\" ;;\n    --ts|--ts-only|ts) MODE=\"ts\" ;;\n    --full|full|\"\") MODE=\"full\" ;;\n    *)\n        echo \"Usage: ./scripts/verify [--anchor|--ts|--full]\"\n        exit 1\n        ;;\nesac\n\necho -e \"${GREEN}=== RNG Utopia Verification ($MODE) ===${NC}\"\n\n# Check for submodule\nif [ ! -f \"sources/rng-utopia/package.json\" ]; then\n    echo -e \"${RED}[FAIL] Submodule not initialized.${NC}\"\n    echo \"Run: git submodule update --init --recursive\"\n    exit 1\nfi\n\n# ---------------------------------------------------------------------------\n# TypeScript steps (lint, typecheck, build, test)\n# ---------------------------------------------------------------------------\nrun_ts() {\n    cd sources/rng-utopia\n\n    # Install dependencies if missing\n    if [ ! -d \"node_modules\" ]; then\n        echo -e \"${GREEN}[INFO] Installing dependencies...${NC}\"\n        pnpm install\n    fi\n\n    echo -e \"${GREEN}[STEP] Linting...${NC}\"\n    pnpm lint\n\n    echo -e \"${GREEN}[STEP] Typechecking...${NC}\"\n    pnpm typecheck\n\n    echo -e \"${GREEN}[STEP] Building frontend entrypoint (apps/platform)...${NC}\"\n    pnpm build\n\n    echo -e \"${GREEN}[STEP] Testing (TS packages)...${NC}\"\n    pnpm test\n\n    cd ../..\n}\n\n# ---------------------------------------------------------------------------\n# Anchor steps (build + test)\n# ---------------------------------------------------------------------------\nrun_anchor() {\n    if ! command -v anchor &>/dev/null; then\n        echo -e \"${YELLOW}[SKIP] Anchor tests (anchor CLI not found)${NC}\"\n        return 0\n    fi\n\n    cd sources/rng-utopia/solana\n\n    if [ ! -d \"node_modules\" ]; then\n        pnpm install --ignore-workspace\n    fi\n\n    echo -e \"${GREEN}[STEP] Building Anchor programs...${NC}\"\n    anchor build\n\n    echo -e \"${GREEN}[STEP] Testing (Anchor programs)...${NC}\"\n    anchor test --skip-local-validator --skip-deploy\n\n    cd ../../..\n}\n\n# ---------------------------------------------------------------------------\n# Run based on mode\n# ---------------------------------------------------------------------------\ncase \"$MODE\" in\n    full)\n        run_ts\n        run_anchor\n        ;;\n    ts)\n        run_ts\n        ;;\n    anchor)\n        run_anchor\n        ;;\nesac\n\necho -e \"${GREEN}=== VERIFICATION PASSED ($MODE) ===${NC}\"\nexit 0\n","numLines":110,"startLine":1,"totalLines":110}}}
