ort url('https://fonts.googleapis.com/css2?family=Press+Start+2P&family=MedievalSharp&display=swap');\n\n/* ============ CSS Custom Properties ============ */\n:root {\n  /* Night sky backdrop (reference: #1a233e) */\n  --color-bg: #1a233e;\n  --color-bg-darker: #0e1428;\n\n  /* Parchment surfaces */\n  --color-surface: #c8b890;\n  --color-surface-elevated: #d4c8a8;\n\n  /* Dark bar (header, footer, buttons, cards) */\n  --color-bar: #3a3228;\n  --color-bar-light: #4a4238;\n  --color-bar-dark: #2e2620;\n\n  /* Parchment texture */\n  --parchment-texture:\n    radial-gradient(ellipse 40% 50% at 20% 30%, rgba(180, 160, 120, 0.3) 0%, transparent 70%),\n    radial-gradient(ellipse 30% 40% at 70% 65%, rgba(170, 150, 110, 0.25) 0%, transparent 70%),\n    radial-gradient(ellipse 35% 30% at 50% 80%, rgba(160, 140, 100, 0.2) 0%, transparent 60%);\n\n  /* Medieval panel background — dark leather/stone with subtle noise */","numLines":30,"startLine":1,"totalLines":17345}}}
