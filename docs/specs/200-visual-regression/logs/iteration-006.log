{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01Cv8j841uBq3qo73FUpDZqo","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01LFraF5VKCpFyCt52aFH4y9","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/fixtures.ts","content":"import { test as base, expect } from \"@playwright/test\";\n\n/**\n * Shared visual-regression fixture.\n *\n * Extends the default Playwright `test` with a `stablePage` fixture that:\n *  (a) Injects CSS to disable all animations and transitions\n *  (b) Waits for document.fonts.ready\n *  (c) Waits for network idle\n *\n * Usage:\n *   import { test, expect } from \"../fixtures\";\n *   test(\"home page\", async ({ stablePage }) => {\n *     await stablePage.goto(\"/\");\n *     await expect(stablePage).toHaveScreenshot(\"home.png\");\n *   });\n */\nexport const test = base.extend<{ stablePage: ReturnType<typeof base[\"page\"] extends Promise<infer T> ? T : never> }>({\n  stablePage: async ({ page }, use) => {\n    // (a) Inject CSS that kills all animations and transitions before any navigation\n    await page.addStyleTag({\n      content: `\n        *, *::before, *::after {\n          animation-duration: 0s !important;\n          animation-delay: 0s !important;\n          transition-duration: 0s !important;\n          transition-delay: 0s !important;\n          scroll-behavior: auto !important;\n        }\n      `,\n    });\n\n    // Store the original goto so we can wrap it\n    const originalGoto = page.goto.bind(page);\n\n    // Override goto to always wait for fonts + network idle after navigation\n    page.goto = async (url: string, options?: Parameters<typeof page.goto>[1]) => {\n      const response = await originalGoto(url, {\n        waitUntil: \"networkidle\",\n        ...options,\n      });\n\n      // Re-inject the animation-disabling CSS (navigation clears addStyleTag)\n      await page.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n        `,\n      });\n\n      // (b) Wait for all fonts to finish loading\n      await page.evaluate(() => document.fonts.ready);\n\n      // (c) Small settle time for any remaining paints\n      await page.waitForTimeout(200);\n\n      return response;\n    };\n\n    await use(page);\n  },\n});\n\nexport { expect };\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":336,"cache_read_input_tokens":65788,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":336},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"fa292fd5-d07e-4e2d-9d66-18303d0ed43d","uuid":"78b6ca8b-0a96-45af-bb1c-05a7c66936cd"}
