{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NcwKXn4RSqPTJW1xGDSHsA","type":"tool_result","content":"     1→import { test as base, expect, type Page } from \"@playwright/test\";\n     2→\n     3→/**\n     4→ * Shared visual-regression fixture.\n     5→ *\n     6→ * Extends the default Playwright `test` with a `stablePage` fixture that:\n     7→ *  (a) Injects CSS to disable all animations and transitions\n     8→ *  (b) Waits for document.fonts.ready\n     9→ *  (c) Waits for network idle\n    10→ *\n    11→ * Usage:\n    12→ *   import { test, expect } from \"../fixtures\";\n    13→ *   test(\"home page\", async ({ stablePage }) => {\n    14→ *     await stablePage.goto(\"/\");\n    15→ *     await expect(stablePage).toHaveScreenshot(\"home.png\");\n    16→ *   });\n    17→ */\n    18→export const test = base.extend<{ stablePage: Page }>({\n    19→  stablePage: async ({ page }, use) => {\n    20→    // (a) Inject CSS that kills all animations and transitions before any navigation\n    21→    await page.addStyleTag({\n    22→      content: `\n    23→        *, *::before, *::after {\n    24→          animation-duration: 0s !important;\n    25→          animation-delay: 0s !important;\n    26→          transition-duration: 0s !important;\n    27→          transition-delay: 0s !important;\n    28→          scroll-behavior: auto !important;\n    29→        }\n    30→      `,\n    31→    });\n    32→\n    33→    // Store the original goto so we can wrap it\n    34→    const originalGoto = page.goto.bind(page);\n    35→\n    36→    // Override goto to always wait for fonts + network idle after navigation\n    37→    page.goto = async (url: string, options?: Parameters<typeof page.goto>[1]) => {\n    38→      const response = await originalGoto(url, {\n    39→        waitUntil: \"networkidle\",\n    40→        ...options,\n    41→      });\n    42→\n    43→      // Re-inject the animation-disabling CSS (navigation clears addStyleTag)\n    44→      await page.addStyleTag({\n    45→        content: `\n    46→          *, *::before, *::after {\n    47→            animation-duration: 0s !important;\n    48→            animation-delay: 0s !important;\n    49→            transition-duration: 0s !important;\n    50→            transition-delay: 0s !important;\n    51→            scroll-behavior: auto !important;\n    52→          }\n    53→        `,\n    54→      });\n    55→\n    56→      // (b) Wait for all fonts to finish loading\n    57→      await page.evaluate(() => document.fonts.ready);\n    58→\n    59→      // (c) Small settle time for any remaining paints\n    60→      await page.waitForTimeout(200);\n    61→\n    62→      return response;\n    63→    };\n    64→\n    65→    await use(page);\n    66→  },\n    67→});\n    68→\n    69→export { expect };\n    70→"}]},"parent_tool_use_id":null,"session_id":"7909f204-ec95-4a06-b5b5-a3f62aeb383f","uuid":"55b9a108-36ff-4f28-bfa2-2bedb4999947","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/fixtures.ts","content":"import { test as base, expect, type Page } from \"@playwright/test\";\n\n/**\n * Shared visual-regression fixture.\n *\n * Extends the default Playwright `test` with a `stablePage` fixture that:\n *  (a) Injects CSS to disable all animations and transitions\n *  (b) Waits for document.fonts.ready\n *  (c) Waits for network idle\n *\n * Usage:\n *   import { test, expect } from \"../fixtures\";\n *   test(\"home page\", async ({ stablePage }) => {\n *     await stablePage.goto(\"/\");\n *     await expect(stablePage).toHaveScreenshot(\"home.png\");\n *   });\n */\nexport const test = base.extend<{ stablePage: Page }>({\n  stablePage: async ({ page }, use) => {\n    // (a) Inject CSS that kills all animations and transitions before any navigation\n    await page.addStyleTag({\n      content: `\n        *, *::before, *::after {\n          animation-duration: 0s !important;\n          animation-delay: 0s !important;\n          transition-duration: 0s !important;\n          transition-delay: 0s !important;\n          scroll-behavior: auto !important;\n        }\n      `,\n    });\n\n    // Store the original goto so we can wrap it\n    const originalGoto = page.goto.bind(page);\n\n    // Override goto to always wait for fonts + network idle after navigation\n    page.goto = async (url: string, options?: Parameters<typeof page.goto>[1]) => {\n      const response = await originalGoto(url, {\n        waitUntil: \"networkidle\",\n        ...options,\n      });\n\n      // Re-inject the animation-disabling CSS (navigation clears addStyleTag)\n      await page.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n        `,\n      });\n\n      // (b) Wait for all fonts to finish loading\n      await page.evaluate(() => document.fonts.ready);\n\n      // (c) Small settle time for any remaining paints\n      await page.waitForTimeout(200);\n\n      return response;\n    };\n\n    await use(page);\n  },\n});\n\nexport { expect };\n","numLines":70,"startLine":1,"totalLines":70}}}
