225\t\n226\texport const PlayerStatsSchema = z.object({\n227\t  gamesPlayed: z.number().int(),\n228\t  totalWagered: LamportsStringSchema,\n229\t  totalWins: z.number().int(),\n230\t  winRate: z.number(),\n231\t  winStreakCurrent: z.number().int(),\n232\t  winStreakBest: z.number().int(),\n233\t  netPnl: LamportsStringSchema,\n234\t  gameBreakdown: GameBreakdownMapSchema,\n235\t});\n236\t\n237\texport const PublicStatsSchema = z.object({\n238\t  gamesPlayed: z.number().int(),\n239\t  totalWins: z.number().int(),\n240\t  winRate: z.number(),\n241\t});\n242\t\n243\texport const PlayerProfileSchema = z.object({\n244\t  userId: UserIdSchema,\n245\t  username: z.string(),\n246\t  avatarUrl: z.string().nullable(),\n247\t  heatMultiplier: z.number(),\n248\t  pointsBalance: z.string().describe(\"BigInt as string\"),\n249\t  stats: PlayerStatsSchema,\n250\t  usernameNextEditAt: IsoDateTimeSchema.nullable(),\n251\t  createdAt: IsoDateTimeSchema,\n252\t  telegramLinked: z.boolean(),\n253\t});\n254\t\n255\texport const PublicPlayerProfileSchema = z.object({\n256\t  userId: UserIdSchema,\n257\t  username: z.string(),\n258\t  avatarUrl: z.string().nullable(),\n259\t  heatMultiplier: z.number(),\n260\t  stats: PublicStatsSchema,\n261\t  createdAt: IsoDateTimeSchema,\n262\t});\n263\t\n264\texport const LeaderboardEntrySchema = z.object({\n265\t  rank: z.number().int(),\n266\t  userId: z.string(),\n267\t  username: z.string(),\n268\t  avatarUrl: z.string().nullable(),\n269\t  totalWagered: LamportsStringSchema,\n270\t  gamesPlayed: z.number().int(),\n271\t  totalWins: z.number().int(),\n272\t  winRate: z.number(),\n273\t  netPnl: LamportsStringSchema,\n274\t});\n275\t\n276\texport const LeaderboardResponseSchema = z.object({\n277\t  game: LeaderboardGameIdSchema,\n278\t  weekStart: IsoDateTimeSchema,\n279\t  weekEnd: IsoDateTimeSchema,\n280\t  entries: z.array(LeaderboardEntrySchema),\n281\t});\n282\t\n283\texport const PriceResponseSchema = z.object({\n284\t  price: z.number().desc