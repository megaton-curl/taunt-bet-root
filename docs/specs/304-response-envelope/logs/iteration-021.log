);\n387\t\n388\t// ── Challenge schemas ───────────────────────────────────────────────────\n389\t\n390\texport const ChallengeRewardSchema = z.object({\n391\t  type: z.enum([\"points\", \"crate\"]),\n392\t  amount: z.number().optional().describe(\"Present for points rewards, absent for crate rewards\"),\n393\t});\n394\t\n395\texport const ChallengeAssignmentSchema = z.object({\n396\t  id: z.number().int(),\n397\t  title: z.string(),\n398\t  description: z.string(),\n399\t  progress: z.number().int(),\n400\t  target: z.number().int(),\n401\t  status: z.enum([\"active\", \"completed\", \"expired\"]),\n402\t  reward: ChallengeRewardSchema,\n403\t  completedAt: IsoDateTimeSchema.nullable().optional(),\n404\t});\n405\t\n406\texport const ChallengeHistoryEntrySchema = z.object({\n407\t  id: z.number().int(),\n408\t  title: z.string(),\n409\t  description: z.string(),\n410\t  completedAt: IsoDateTimeSchema,\n411\t  reward: ChallengeRewardSchema,\n412\t});\n413\t\n414\texport const CompletionBonusSchema = z\n415\t  .object({\n416\t    title: z.string(),\n417\t    required: z.number().int().describe(\"Number of challenges needed\"),\n418\t    completed: z.number().int().describe(\"Number currently completed\"),\n419\t    status: z.enum([\"active\", \"completed\"]),\n420\t    reward: ChallengeRewardSchema,\n421\t  })\n422\t  .partial()\n423\t  .nullable()\n424\t  .describe(\n425\t    \"Bonus earned when enough challenges in a period are completed. Null if no bonus configured.\",\n426\t  );\n427\t\n428\t// ── Points schemas ──────────────────────────────────────────────────────\n429\t\n430\texport const PointGrantEntrySchema = z.object({\n431\t  id: z.number().int(),\n432\t  sourceType: z.string(),\n433\t  sourceId: z.string(),\n434\t  amount: z.number(),\n435\t  metadata: z.record(z.string(), z.unknown()),\n436\t  createdAt: IsoDateTimeSchema,\n437\t});\n438\t\n439\texport const CrateDropEntrySchema = z.object({\n440\t  id: z.number().int(),\n441\t  crateType: z.string(),\n4