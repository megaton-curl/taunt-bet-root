\",\n  FORBIDDEN: \"FORBIDDEN\",\n  RATE_LIMITED: \"RATE_LIMITED\",\n  VALIDATION_FAILED: \"VALIDATION_FAILED\",\n  INVALID_REQUEST: \"INVALID_REQUEST\",\n  INVALID_PARAMS: \"INVALID_PARAMS\",\n\n  INVALID_SIGNATURE: \"INVALID_SIGNATURE\",\n  CHALLENGE_EXPIRED: \"CHALLENGE_EXPIRED\",\n  REFRESH_TOKEN_INVALID: \"REFRESH_TOKEN_INVALID\",\n\n  CODE_ALREADY_SET: \"CODE_ALREADY_SET\",\n  CODE_TAKEN: \"CODE_TAKEN\",\n  CODE_NOT_FOUND: \"CODE_NOT_FOUND\",\n  INVALID_CODE: \"INVALID_CODE\",\n  SELF_REFERRAL: \"SELF_REFERRAL\",\n  ALREADY_LINKED: \"ALREADY_LINKED\",\n  ZERO_BALANCE: \"ZERO_BALANCE\",\n  BELOW_THRESHOLD: \"BELOW_THRESHOLD\",\n  CLAIM_NOT_FOUND: \"CLAIM_NOT_FOUND\",\n\n  PROFILE_NOT_FOUND: \"PROFILE_NOT_FOUND\",\n  USERNAME_TAKEN: \"USERNAME_TAKEN\",\n  USERNAME_COOLDOWN: \"USERNAME_COOLDOWN\",\n  INVALID_USERNAME: \"INVALID_USERNAME\",\n\n  MATCH_NOT_FOUND: \"MATCH_NOT_FOUND\",\n  MATCH_PHASE_INVALID: \"MATCH_PHASE_INVALID\",\n  ROUND_NOT_FOUND: \"ROUND_NOT_FOUND\",\n  BET_TOO_SMALL: \"BET_TOO_SMALL\",\n  BET_TOO_LARGE: \"BET_TOO_LARGE\",\n\n  TELEGRAM_NOT_LINKED: \"TELEGRAM_NOT_LINKED\",\n  TELEGRAM_ALREADY_LINKED: \"TELEGRAM_ALREADY_LINKED\",\n  TELEGRAM_TOKEN_EXPIRED: \"TELEGRAM_TOKEN_EXPIRED\",\n\n  PRICE_UNAVAILABLE: \"PRICE_UNAVAILABLE\",\n  NOT_FOUND: \"NOT_FOUND\",\n  CONFLICT: \"CONFLICT\",\n  PRECONDITION_FAILED: \"PRECONDITION_FAILED\",\n} as const;\n\nexport type ApiErrorCode = (typeof API_ERROR_CODES)[keyof typeof API_ERROR_CODES];\n\n// ---------------------------------------------------------------------------\n// Legacy helpers (to be deleted in the cleanup iteration once all public\n// routes have migrated to the envelope helpers in `api-envelope.ts`).\n// ---------------------------------------------------------------------------\n\nexport interface ErrorResponseBody {\n  error: string;\n}\n\nexport interface StructuredErrorDetail {\n  code: string;\n  message: string;\n  retryable?: boolean;\n}\n\nexport interface StructuredErrorResponseBody {\n  error: StructuredErrorDetail;\n}\n\nexport function errorMessage(error: string): ErrorResponseBody {\n  return { error };\n}\n\nexport function structuredErrorMessage(\n  code: string,\n  message: string,\n  retryable?: boolean,\n): StructuredErrorResponseBody {\n  return {\n    error: retryable === undefined ? { code, message } : { code, message, retryable },\n  };\n}\n","structuredPatch":[{"oldStart":51,"oldLines":36,"newStart":51,"newLines":3,"lines":[" } as const;"," "," export type ApiErrorCode = (typeof API_ERROR_CODES)[keyof typeof API_ERROR_CODES];","-","-// ---------------------------------------------------------------------------","-// Legacy helpers (to be deleted in the cleanup iteration once all public","-// routes have migrated to the envelope helpers in `api-envelope.ts`).","-// ---------------------------------------------------------------------------","-","-export interface ErrorResponseBody {","-  error: string;","-}","-","-export interface StructuredErrorDetail {","-  code: string;","-  message: string;","-  retryable?: boolean;","-}","-","-export interface StructuredErrorResponseBody {","-  error: StructuredErrorDetail;","-}","-","-export function errorMessage(error: string): ErrorResponseBody {","-  return { error };","-}","-","-export function structuredErrorMessage(","-  code: string,","-  message: string,","-  retryable?: boolean,","-): StructuredErrorResponseBody {","-  return {","-    error: retryable === undefined ? { code, message } : { code, message, retryable },","-  };","-}"]}],"userModified":false,"replaceAll":false}}
