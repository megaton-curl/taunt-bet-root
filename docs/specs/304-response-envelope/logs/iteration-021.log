ndResponseSchema = CommitRevealRoundResponseBaseSchema.extend({\n497\t  game: z.literal(PUBLIC_GAME_IDS.flipYou),\n498\t  resultSide: z.number().int().optional(),\n499\t});\n500\t\n501\texport const PotShotRoundResponseSchema = CommitRevealRoundResponseBaseSchema.extend({\n502\t  game: z.literal(PUBLIC_GAME_IDS.potShot),\n503\t  winningEntryIndex: z.number().int().optional(),\n504\t  winningOffset: z.string().nullable().optional(),\n505\t  rentRefund: z.number().int().nullable().optional(),\n506\t  totalAmountLamports: z.number().int().nullable().optional(),\n507\t});\n508\t\n509\texport const UnifiedCloseCallRoundResponseSchema = z.object({\n510\t  pda: z.string(),\n511\t  game: z.literal(PUBLIC_GAME_IDS.closeCall),\n512\t  phase: z.enum([\"open\", \"settled\", \"refunded\"]),\n513\t  matchId: z.string(),\n514\t  openPrice: z.number(),\n515\t  openPriceExpo: z.number().int(),\n516\t  greenPool: z.number().int(),\n517\t  redPool: z.number().int(),\n518\t  totalPool: z.number().int(),\n519\t  greenEntries: z.array(CloseCallEntrySchema),\n520\t  redEntries: z.array(CloseCallEntrySchema),\n521\t  greenCount: z.number().int(),\n522\t  redCount: z.number().int(),\n523\t  createdAt: IsoDateTimeSchema,\n524\t  closePrice: z.number().nullable().optional(),\n525\t  outcome: z.enum([\"pending\", \"green\", \"red\", \"refund\"]).optional(),\n526\t  totalFee: z.number().int().optional(),\n527\t  settleTx: z.string().nullable().optional(),\n528\t  settledAt: IsoDateTimeSchema.nullable().optional(),\n529\t  verification: CloseCallRoundVerificationSchema.optional(),\n530\t});\n531\t\n532\texport const RoundResponseSchema = z.discriminatedUnion(\"game\", [\n533\t  FlipYouRoundResponseSchema,\n534\t  PotShotRoundResponseSchema,\n535\t  UnifiedCloseCallRoundResponseSchema,\n536\t]);\n537\t\n538\texport const TransactionsPageResponseSchema = cursorPageResponseSchema(\n539\t  \"transactions\",\n540\t  TransactionSchema,\n541\t);\n542\t\n543\texport const RoundsHistoryResponseSchema = listEnvelopeResponseSchema(\n544\t  \"rounds\",\n545\t  RoundResponseSchema,\n546\t);\n547\t\n548\texport const ReferralListResponseSchema = z.object({\n549\t  items: z.array(ReferralListItemSchema),\n550\t});\n551\t\n552\texport function singleFieldResponseSchema(\n553\t  fieldName: string,\n554\t  fieldSchema: z.ZodTypeAny,\n555\t) {\n556\t  return z.object({ [fieldName]: fieldSchema } as Record<string, z.ZodTypeAny>);\n557\t}\n558\t\n559\texport function cursorPageResponseSchema(\n560\t  fieldName: string,\n561\t  itemSchema: z.ZodTypeAny,\n562\t) {\n563\t  return z.object({\n564\t    [fieldName]: z.array(itemSchema),\n565\t    nextCursor: z.string().nullable(),\n566\t  } as Record<string, z.ZodTypeAny>);\n567\t}\n568\t\n569\texport function listEnvelopeResponseSchema(\n570\t  fieldName: string,\n571\t  itemSchema: z.ZodTypeAny,\n572\t) {\n573\t  return z.object({\n574\t    [fieldName]: z.array(itemSchema),\n575\t  } as Record<string, z.ZodTypeAny>);\n576\t}\n577\t\n578\texport function roundEnvelopeResponseSchema(\n579\t  fieldName: string,\n580\t  roundSchema: z.ZodTypeAny,\n581\t  options: { nullable?: boolean } = {},\n582\t) {\n583\t  return z.object({\n584\t    [fieldName]: options.nullable ? roundSchema.nullable() : roundSchema,\n585\t  } as Record<string, z.ZodTypeAny>);\n586\t}\n587\t"}]},"parent_tool_use_id":null,"session_id":"7f07b191-956b-4c1a-9ea0-ecc453c615ba","uuid":"65c2bf3f-b4bc-45be-879d-284b38efbc7a","timestamp":"2026-04-22T10:51:47.812Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/contracts/validators.ts","content":"import { z } from \"zod\";\nimport {\n  PUBLIC_COMMIT_REVEAL_GAME_ID_VALUES,\n  PUBLIC_GAME_IDS,\n  PUBLIC_GAME_ID_VALUES,\n} from \"./public-games.js\";\n\nconst IsoDateTimeSchema = z.string().datetime();\nconst LamportsStringSchema = z.string().describe(\"Lamports as string\");\nconst UserIdSchema = z.string().describe(\"Short user ID (usr_xxxxxxxx)\");\nconst LeaderboardGameIdValues = [...PUBLIC_GAME_ID_VALUES, \"all\"] as const;\n\nfunction coerceClampedInteger(\n  raw: unknown,\n  defaultValue: number,\n  min: number,\n  max?: number,\n): number {\n  if (raw === undefined || raw === null || raw === \"\") {\n    return defaultValue;\n  }\n\n  const parsed = typeof raw === \"number\" ? raw : parseInt(String(raw), 10);\n  if (!Number.isFinite(parsed) || Number.isNaN(parsed) || parsed < min) {\n    return defaultValue;\n  }\n\n  return max === undefined ? parsed : Math.min(parsed, max);\n}\n\nfunction queryIntegerSchema(defaultValue: number, min: number, max?: number) {\n  const base = z.number().int().min(min);\n  const bounded = max === undefined ? base : base.max(max);\n\n  return z.preprocess(\n    (raw) => coerceClampedInteger(raw, defaultValue, min, max),\n    bounded.default(defaultValue),\n  );\n}\n\nexport const PublicGameIdSchema = z.enum(PUBLIC_GAME_ID_VALUES);\nexport const PublicCommitRevealGameIdSchema = z.enum(PUBLIC_COMMIT_REVEAL_GAME_ID_VALUES);\nexport const LeaderboardGameIdSchema = z.enum(LeaderboardGameIdValues);\n\nexport const ErrorResponseSchema = z.object({\n  error: z.string(),\n});\n\nexport const StructuredErrorDetailSchema = z.object({\n  code: z.string(),\n  message: z.string(),\n  retryable: z.boolean().optional(),\n});\n\nexport const StructuredErrorResponseSchema = z.object({\n  error: StructuredErrorDetailSchema,\n});\n\nexport const OkResponseSchema = z.object({\n  ok: z.boolean(),\n});\n\nexport const CodeResponseSchema = z.object({\n  code: z.string(),\n});\n\n// GET /referral/code: `code` is null when the user hasn't set one yet.\n// Empty state is a valid answer to \"what's my code?\", not an error.\nexport const MaybeCodeResponseSchema = z.object({\n  code: z.string().nullable(),\n});\n\nexport const ExistsResponseSchema = z.object({\n  exists: z.boolean(),\n});\n\nexport const UsernameUpdateResponseSchema = z.object({\n  username: z.string(),\n  nextEditAvailableAt: z.string().datetime().nullable(),\n});\n\nexport const UsernameCooldownResponseSchema = z.object({\n  error: z.string(),\n  nextEditAvailableAt: z.string().datetime(),\n});\n\nexport const ReferralCodeSchema = z\n  .string()\n  .trim()\n  .toLowerCase()\n  .regex(/^[a-z0-9-]{3,16}$/)\n  .describe(\"3-16 chars, lowercase alphanumeric + hyphens\");\n\nexport const ReferralCodeBodySchema = z.object({\n  code: ReferralCodeSchema,\n});\n\nexport const ApplyReferralCodeBodySchema = z.object({\n  code: z.string().trim().toLowerCase().min(1),\n});\n\nexport const ReferralApplyResponseSchema = z.object({\n  referrerUserId: z.string(),\n  benefit: z.string(),\n});\n\n// GET /referral/referrer: all four fields are nullable together — they are\n// all populated when the caller is linked to a referrer, and all null when\n// they aren't. Not being referred is a valid answer, not an error.\nexport const ReferralReferrerResponseSchema = z.object({\n  referrerUserId: z.string().nullable(),\n  referrerUsername: z.string().nullable(),\n  referrerCode: z.string().nullable(),\n  linkedAt: z.string().datetime().nullable(),\n});\n\nexport const ReferralListItemSchema = z.object({\n  refereeUserId: z.string(),\n  refereeUsername: z.string(),\n  createdAt: z.string().datetime(),\n});\n\nexport const UsernameBodySchema = z.object({\n  username: z.string().regex(/^[a-zA-Z0-9_-]{3,20}$/),\n});\n\nexport const ConfirmTransactionBodySchema = z.object({\n  game: PublicGameIdSchema,\n  matchId: z.string(),\n  txType: z.enum([\"deposit\", \"refund\"]),\n  txSig: z.string(),\n  amountLamports: z.number().int().positive(),\n});\n\nexport const TransactionHistoryQuerySchema = z.object({\n  cursor: z.string().optional(),\n  limit: queryIntegerSchema(20, 1, 50),\n  game: PublicGameIdSchema.optional(),\n});\n\nexport const LeaderboardQuerySchema = z.object({\n  game: PublicGameIdSchema.optional(),\n  limit: queryIntegerSchema(20, 1, 100),\n  offset: queryIntegerSchema(0, 0),\n});\n\nexport const RoundsHistoryQuerySchema = z.object({\n  game: PublicCommitRevealGameIdSchema,\n  limit: queryIntegerSchema(20, 1, 50),\n});\n\nexport const PotShotEntrySchema = z.object({\n  player: z.string().describe(\"Base58 wallet address\"),\n  amountLamports: z.number().int(),\n});\n\nexport const PotShotRoundSchema = z.object({\n  matchId: z.string(),\n  pda: z.string(),\n  phase: z.enum([\"waiting\", \"active\", \"locked\", \"resolving\", \"settled\", \"refunded\"]),\n  creator: z.string(),\n  commitment: z.string(),\n  entries: z.array(PotShotEntrySchema),\n  totalAmountLamports: z.number().int(),\n  distinctPlayers: z.number().int(),\n  countdownStartedAt: z.number().int().nullable(),\n  countdownEndsAt: z.number().int().nullable(),\n  createdAt: z.string().datetime(),\n});\n\nexport const CloseCallEntrySchema = z.object({\n  player: z.string(),\n  amountLamports: z.number().int(),\n});\n\nexport const CloseCallRoundSchema = z.object({\n  roundId: z.string(),\n  pda: z.string(),\n  phase: z.enum([\"open\", \"settled\", \"refunded\"]),\n  openPrice: z.number(),\n  openPriceExpo: z.number().int(),\n  closePrice: z.number().nullable().optional(),\n  outcome: z.enum([\"pending\", \"green\", \"red\", \"refund\"]).optional(),\n  greenPool: z.number().int(),\n  redPool: z.number().int(),\n  totalPool: z.number().int(),\n  totalFee: z.number().int().optional(),\n  greenEntries: z.array(CloseCallEntrySchema),\n  redEntries: z.array(CloseCallEntrySchema),\n  greenCount: z.number().int(),\n  redCount: z.number().int(),\n  settleTx: z.string().nullable().optional(),\n  createdAt: z.string().datetime(),\n  settledAt: z.string().datetime().nullable().optional(),\n});\n\nexport const TransactionSchema = z.object({\n  id: z.string(),\n  game: PublicGameIdSchema,\n  matchId: z.string(),\n  txType: z.enum([\"deposit\", \"refund\"]),\n  amountLamports: LamportsStringSchema,\n  txSig: z.string(),\n  createdAt: IsoDateTimeSchema,\n});\n\nexport const PublicReferralLookupResponseSchema = z.object({\n  userId: UserIdSchema,\n  username: z.string(),\n  referralCode: z.string().nullable(),\n});\n\nexport const GameBreakdownStatsSchema = z.object({\n  gamesPlayed: z.number().int(),\n  totalWagered: LamportsStringSchema,\n  totalWins: z.number().int(),\n  winRate: z.number(),\n  netPnl: LamportsStringSchema,\n});\n\nexport const GameBreakdownMapSchema = z\n  .object({})\n  .catchall(GameBreakdownStatsSchema)\n  .describe(\"Per-game stats keyed by frontend game name (flip-you, pot-shot, close-call)\");\n\nexport const PlayerStatsSchema = z.object({\n  gamesPlayed: z.number().int(),\n  totalWagered: LamportsStringSchema,\n  totalWins: z.number().int(),\n  winRate: z.number(),\n  winStreakCurrent: z.number().int(),\n  winStreakBest: z.number().int(),\n  netPnl: LamportsStringSchema,\n  gameBreakdown: GameBreakdownMapSchema,\n});\n\nexport const PublicStatsSchema = z.object({\n  gamesPlayed: z.number().int(),\n  totalWins: z.number().int(),\n  winRate: z.number(),\n});\n\nexport const PlayerProfileSchema = z.object({\n  userId: UserIdSchema,\n  username: z.string(),\n  avatarUrl: z.string().nullable(),\n  heatMultiplier: z.number(),\n  pointsBalance: z.string().describe(\"BigInt as string\"),\n  stats: PlayerStatsSchema,\n  usernameNextEditAt: IsoDateTimeSchema.nullable(),\n  createdAt: IsoDateTimeSchema,\n  telegramLinked: z.boolean(),\n});\n\nexport const PublicPlayerProfileSchema = z.object({\n  userId: UserIdSchema,\n  username: z.string(),\n  avatarUrl: z.string().nullable(),\n  heatMultiplier: z.number(),\n  stats: PublicStatsSchema,\n  createdAt: IsoDateTimeSchema,\n});\n\nexport const LeaderboardEntrySchema = z.object({\n  rank: z.number().int(),\n  userId: z.string(),\n  username: z.string(),\n  avatarUrl: z.string().nullable(),\n  totalWagered: LamportsStringSchema,\n  gamesPlayed: z.number().int(),\n  totalWins: z.number().int(),\n  winRate: z.number(),\n  netPnl: LamportsStringSchema,\n});\n\nexport const LeaderboardResponseSchema = z.object({\n  game: LeaderboardGameIdSchema,\n  weekStart: IsoDateTimeSchema,\n  weekEnd: IsoDateTimeSchema,\n  entries: z.array(LeaderboardEntrySchema),\n});\n\nexport const PriceResponseSchema = z.object({\n  price: z.number().describe(\"SOL/USD price\"),\n  updatedAt: IsoDateTimeSchema,\n});\n\nexport const DogpileCurrentResponseSchema = z\n  .object({\n    id: z.number().int(),\n    multiplier: z.number(),\n    startsAt: IsoDateTimeSchema,\n    endsAt: IsoDateTimeSchema,\n    status: z.enum([\"active\", \"scheduled\"]),\n    startsIn: z.number().int().optional(),\n    endsIn: z.number().int().optional(),\n  })\n  .nullable();\n\nexport const DogpileScheduleItemSchema = z.object({\n  id: z.number().int(),\n  multiplier: z.number(),\n  startsAt: IsoDateTimeSchema,\n  endsAt: IsoDateTimeSchema,\n  status: z.string(),\n});\n\nexport const DogpileScheduleResponseSchema = z.object({\n  items: z.array(DogpileScheduleItemSchema),\n});\n\n// ── Auth responses ──────────────────────────────────────────────────────\n\nexport const ChallengeNonceResponseSchema = z.object({\n  nonce: z.string().describe(\"64-char hex nonce\"),\n  message: z.string().describe(\"Human-readable sign-in message\"),\n  expiresAt: IsoDateTimeSchema,\n});\n\nexport const TokenResponseSchema = z.object({\n  accessToken: z.string().describe(\"HS256 JWT\"),\n  accessExpiresAt: IsoDateTimeSchema,\n  refreshToken: z.string().describe(\"Opaque 96-char hex token\"),\n  refreshExpiresAt: IsoDateTimeSchema,\n});\n\n// ── Game create responses ───────────────────────────────────────────────\n\nexport const FlipYouCreateResponseSchema = z.object({\n  transaction: z.string().describe(\"Base64-encoded partially-signed transaction\"),\n  matchPda: z.string().describe(\"Base58 match PDA address\"),\n  matchId: z.string().describe(\"16-char hex match ID\"),\n  commitment: z.string().describe(\"SHA256 hex commitment\"),\n  lastValidBlockHeight: z.number().int(),\n});\n\nexport const PotShotCreateResponseSchema = z.object({\n  transaction: z.string().describe(\"Base64-encoded partially-signed transaction\"),\n  roundPda: z.string().describe(\"Base58 round PDA address\"),\n  matchId: z.string().describe(\"16-char hex match ID\"),\n  commitment: z.string().describe(\"SHA256 hex commitment\"),\n  lastValidBlockHeight: z.number().int(),\n});\n\nexport const CandleSchema = z.object({\n  openTime: z.number().int().describe(\"Millisecond timestamp\"),\n  closeTime: z.number().int().describe(\"Millisecond timestamp\"),\n  open: z.number(),\n  close: z.number(),\n  high: z.number(),\n  low: z.number(),\n  outcome: z.enum([\"green\", \"red\"]).nullable(),\n});\n\nexport const CloseCallBetResponseSchema = z.object({\n  transaction: z.string().describe(\"Base64-encoded partially-signed transaction\"),\n  minuteTs: z.number().int().describe(\"Unix timestamp (seconds) of the minute boundary\"),\n  roundPda: z.string(),\n});\n\n// ── Referral detail schemas ─────────────────────────────────────────────\n\nexport const ReferralStatsSchema = z.object({\n  referredCount: z.number().int(),\n  activeCount: z.number().int(),\n  totalVolumeLamports: LamportsStringSchema,\n  totalEarnedLamports: LamportsStringSchema,\n  totalRebateLamports: LamportsStringSchema,\n  pendingLamports: LamportsStringSchema,\n});\n\nexport const ReferralEarningSchema = z.object({\n  roundId: z.string(),\n  gameType: z.string(),\n  refereeWallet: z.string(),\n  wagerLamports: LamportsStringSchema,\n  earnedLamports: LamportsStringSchema,\n  createdAt: IsoDateTimeSchema,\n});\n\nexport const ClaimResponseSchema = z.object({\n  claimId: z.string(),\n  amountLamports: LamportsStringSchema,\n  status: z.string(),\n  txSignature: z.string().optional(),\n});\n\n// ── Challenge schemas ───────────────────────────────────────────────────\n\nexport const ChallengeRewardSchema = z.object({\n  type: z.enum([\"points\", \"crate\"]),\n  amount: z.number().optional().describe(\"Present for points rewards, absent for crate rewards\"),\n});\n\nexport const ChallengeAssignmentSchema = z.object({\n  id: z.number().int(),\n  title: z.string(),\n  description: z.string(),\n  progress: z.number().int(),\n  target: z.number().int(),\n  status: z.enum([\"active\", \"completed\", \"expired\"]),\n  reward: ChallengeRewardSchema,\n  completedAt: IsoDateTimeSchema.nullable().optional(),\n});\n\nexport const ChallengeHistoryEntrySchema = z.object({\n  id: z.number().int(),\n  title: z.string(),\n  description: z.string(),\n  completedAt: IsoDateTimeSchema,\n  reward: ChallengeRewardSchema,\n});\n\nexport const CompletionBonusSchema = z\n  .object({\n    title: z.string(),\n    required: z.number().int().describe(\"Number of challenges needed\"),\n    completed: z.number().int().describe(\"Number currently completed\"),\n    status: z.enum([\"active\", \"completed\"]),\n    reward: ChallengeRewardSchema,\n  })\n  .partial()\n  .nullable()\n  .describe(\n    \"Bonus earned when enough challenges in a period are completed. Null if no bonus configured.\",\n  );\n\n// ── Points schemas ──────────────────────────────────────────────────────\n\nexport const PointGrantEntrySchema = z.object({\n  id: z.number().int(),\n  sourceType: z.string(),\n  sourceId: z.string(),\n  amount: z.number(),\n  metadata: z.record(z.string(), z.unknown()),\n  createdAt: IsoDateTimeSchema,\n});\n\nexport const CrateDropEntrySchema = z.object({\n  id: z.number().int(),\n  crateType: z.string(),\n  contentsAmount: z.string(),\n  status: z.string(),\n  createdAt: IsoDateTimeSchema,\n  grantedAt: IsoDateTimeSchema.nullable(),\n});\n\n// ── Health ───────────────────────────────────────────────────────────────\n\nexport const HealthResponseSchema = z.object({\n  status: z.string(),\n  version: z.string(),\n  workerRunning: z.boolean(),\n});\n\nexport const CommitRevealRoundVerificationSchema = z.object({\n  commitmentCheck: z.string(),\n  resultFormula: z.string(),\n  entropySource: z.string(),\n});\n\nexport const CloseCallRoundVerificationSchema = z.object({\n  priceSource: z.string(),\n  outcome: z.string(),\n});\n\nexport const RoundVerificationSchema = z.union([\n  CommitRevealRoundVerificationSchema,\n  CloseCallRoundVerificationSchema,\n]);\n\nexport const RoundEntrySchema = PotShotEntrySchema;\n\nconst CommitRevealRoundResponseBaseSchema = z.object({\n  pda: z.string(),\n  phase: z.enum([\"created\", \"locked\", \"settling\", \"settled\", \"expired\"]),\n  creator: z.string(),\n  commitment: z.string(),\n  amountLamports: z.number().int(),\n  side: z.number().int(),\n  matchId: z.string(),\n  createdAt: IsoDateTimeSchema,\n  updatedAt: IsoDateTimeSchema,\n  targetSlot: z.number().int().optional(),\n  secret: z.string().describe(\"Only present when settled\").optional(),\n  resultHash: z.string().nullable().optional(),\n  winner: z.string().optional(),\n  settleTx: z.string().optional(),\n  entropy: z.string().nullable().optional(),\n  payoutAmount: z.number().int().nullable().optional(),\n  feeAmount: z.number().int().nullable().optional(),\n  verification: CommitRevealRoundVerificationSchema.optional(),\n  entries: z.array(RoundEntrySchema).optional(),\n});\n\nexport const FlipYouRoundResponseSchema = CommitRevealRoundResponseBaseSchema.extend({\n  game: z.literal(PUBLIC_GAME_IDS.flipYou),\n  resultSide: z.number().int().optional(),\n});\n\nexport const PotShotRoundResponseSchema = CommitRevealRoundResponseBaseSchema.extend({\n  game: z.literal(PUBLIC_GAME_IDS.potShot),\n  winningEntryIndex: z.number().int().optional(),\n  winningOffset: z.string().nullable().optional(),\n  rentRefund: z.number().int().nullable().optional(),\n  totalAmountLamports: z.number().int().nullable().optional(),\n});\n\nexport const UnifiedCloseCallRoundResponseSchema = z.object({\n  pda: z.string(),\n  game: z.literal(PUBLIC_GAME_IDS.closeCall),\n  phase: z.enum([\"open\", \"settled\", \"refunded\"]),\n  matchId: z.string(),\n  openPrice: z.number(),\n  openPriceExpo: z.number().int(),\n  greenPool: z.number().int(),\n  redPool: z.number().int(),\n  totalPool: z.number().int(),\n  greenEntries: z.array(CloseCallEntrySchema),\n  redEntries: z.array(CloseCallEntrySchema),\n  greenCount: z.number().int(),\n  redCount: z.number().int(),\n  createdAt: IsoDateTimeSchema,\n  closePrice: z.number().nullable().optional(),\n  outcome: z.enum([\"pending\", \"green\", \"red\", \"refund\"]).optional(),\n  totalFee: z.number().int().optional(),\n  settleTx: z.string().nullable().optional(),\n  settledAt: IsoDateTimeSchema.nullable().optional(),\n  verification: CloseCallRoundVerificationSchema.optional(),\n});\n\nexport const RoundResponseSchema = z.discriminatedUnion(\"game\", [\n  FlipYouRoundResponseSchema,\n  PotShotRoundResponseSchema,\n  UnifiedCloseCallRoundResponseSchema,\n]);\n\nexport const TransactionsPageResponseSchema = cursorPageResponseSchema(\n  \"transactions\",\n  TransactionSchema,\n);\n\nexport const RoundsHistoryResponseSchema = listEnvelopeResponseSchema(\n  \"rounds\",\n  RoundResponseSchema,\n);\n\nexport const ReferralListResponseSchema = z.object({\n  items: z.array(ReferralListItemSchema),\n});\n\nexport function singleFieldResponseSchema(\n  fieldName: string,\n  fieldSchema: z.ZodTypeAny,\n) {\n  return z.object({ [fieldName]: fieldSchema } as Record<string, z.ZodTypeAny>);\n}\n\nexport function cursorPageResponseSchema(\n  fieldName: string,\n  itemSchema: z.ZodTypeAny,\n) {\n  return z.object({\n    [fieldName]: z.array(itemSchema),\n    nextCursor: z.string().nullable(),\n  } as Record<string, z.ZodTypeAny>);\n}\n\nexport function listEnvelopeResponseSchema(\n  fieldName: string,\n  itemSchema: z.ZodTypeAny,\n) {\n  return z.object({\n    [fieldName]: z.array(itemSchema),\n  } as Record<string, z.ZodTypeAny>);\n}\n\nexport function roundEnvelopeResponseSchema(\n  fieldName: string,\n  roundSchema: z.ZodTypeAny,\n  options: { nullable?: boolean } = {},\n) {\n  return z.object({\n    [fieldName]: options.nullable ? roundSchema.nullable() : roundSchema,\n  } as Record<string, z.ZodTypeAny>);\n}\n","numLines":587,"startLine":1,"totalLines":587}}}
