,\"message\":\"rate limit exceeded: wallet limit\",\"path\":\"/test\",\"identity\":\"wallet1\",\"currentCount\":1,\"limit\":1,\"windowMs\":60000}\n{\"timestamp\":\"2026-04-22T10:53:00.528Z\",\"level\":\"warn\",\"message\":\"rate limit exceeded: wallet limit\",\"path\":\"/test\",\"identity\":\"wallet1\",\"currentCount\":1,\"limit\":1,\"windowMs\":60000}\n{\"timestamp\":\"2026-04-22T10:53:00.529Z\",\"level\":\"warn\",\"message\":\"rate limit exceeded: wallet limit\",\"path\":\"/test\",\"identity\":\"wallet2\",\"currentCount\":1,\"limit\":1,\"windowMs\":60000}\n{\"timestamp\":\"2026-04-22T10:53:00.532Z\",\"level\":\"warn\",\"message\":\"rate limit exceeded: global limit\",\"path\":\"/test\",\"currentCount\":3,\"limit\":3,\"windowMs\":60000}\n{\"timestamp\":\"2026-04-22T10:53:00.536Z\",\"level\":\"warn\",\"message\":\"rate limit exceeded: global limit\",\"path\":\"/test\",\"currentCount\":1,\"limit\":1,\"windowMs\":30000}\n ✓ src/__tests__/rate-limit.test.ts (7 tests) 68ms\n ✓ packages/fairness/src/crash.test.ts (10 tests) 75ms\n ✓ src/__tests__/fairness.test.ts (11 tests) 37ms\n ✓ packages/game-engine/src/payouts.test.ts (15 tests) 13ms\n ✓ src/__tests__/openapi-invalid-request-hook.test.ts (4 tests) 47ms\n ✓ src/__tests__/api-errors.test.ts (5 tests) 15ms\n ✓ packages/fairness/src/verification.test.ts (7 tests) 30ms\n ✓ src/__tests__/profile-me-zeroed.test.ts (1 test) 55ms\n ✓ packages/game-engine/src/flipyou.test.ts (10 tests) 8ms\n ✓ packages/fairness/src/commitment.test.ts (6 tests) 18ms\n ✓ src/__tests__/username-gen.test.ts (3 tests) 18ms\n ✓ src/__tests__/config.test.ts (3 tests) 110ms\n\n Test Files  20 passed (20)\n      Tests  214 passed (214)\n   Start at  10:52:56\n   Duration  7.54s (transform 2.21s, setup 0ms, collect 12.45s, tests 1.24s, environment 5ms, prepare 7.92s)","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
