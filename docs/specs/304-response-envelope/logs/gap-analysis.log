{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ViPi8ywHcyHgWuCV9pUPHq","type":"tool_result","content":"1\t/**\n2\t * Price routes — cached SOL/USD price from Pyth Hermes.\n3\t */\n4\t\n5\timport { createRoute } from \"@hono/zod-openapi\";\n6\timport { HermesClient } from \"@pythnetwork/hermes-client\";\n7\timport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n8\timport {\n9\t  envelope,\n10\t  err,\n11\t  ok,\n12\t  ErrorEnvelopeSchema,\n13\t} from \"../contracts/api-envelope.js\";\n14\timport { logger } from \"../logger.js\";\n15\timport { PriceResponseSchema } from \"../contracts/validators.js\";\n16\timport { createOpenApiApp } from \"../openapi/hono.js\";\n17\t\n18\t// SOL/USD Pyth feed ID (same on mainnet + devnet)\n19\tconst SOL_USD_FEED_ID =\n20\t  \"0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d\";\n21\t\n22\tconst CACHE_TTL_MS = 60_000; // 60 seconds\n23\t\n24\tinterface CachedPrice {\n25\t  price: number;\n26\t  updatedAt: string;\n27\t  fetchedAt: number; // Date.now() for TTL check\n28\t}\n29\t\n30\tlet cached: CachedPrice | null = null;\n31\t\n32\tconst client = new HermesClient(\"https://hermes.pyth.network\", {});\n33\t\n34\texport async function fetchSolPrice(): Promise<CachedPrice | null> {\n35\t  // Return cached if still fresh\n36\t  if (cached && Date.now() - cached.fetchedAt < CACHE_TTL_MS) {\n37\t    return cached;\n38\t  }\n39\t\n40\t  try {\n41\t    const updates = await client.getLatestPriceUpdates([SOL_USD_FEED_ID], {\n42\t      encoding: \"base64\",\n43\t      parsed: true,\n44\t    });\n45\t    const feed = updates.parsed?.[0];\n46\t    if (!feed?.price) return cached; // stale cache better than nothing\n47\t\n48\t    const price = Number(feed.price.price) * Math.pow(10, feed.price.expo);\n49\t    const updatedAt = new Date(feed.price.publish_time * 1000).toISOString();\n50\t\n51\t    cached = { price, updatedAt, fetchedAt: Date.now() };\n52\t    return cached;\n53\t  } catch (fetchError) {\n54\t    logger.warn(\"hermes: SOL/USD fetch failed\", {\n55\t      error: fetchError instanceof Error ? fetchError.message : String(fetchError),\n56\t    });\n57\t    return cached; // return stale cache on error\n58\t  }\n59\t}\n60\t\n61\tconst solUsdRoute = createRoute({\n62\t  method: \"get\",\n63\t  path: \"/sol-usd\",\n64\t  tags: [\"Price\"],\n65\t  summary: \"Get cached SOL/USD price\",\n66\t  responses: {\n67\t    200: {\n68\t      content: { \"application/json\": { schema: envelope(PriceResponseSchema) } },\n69\t      description: \"Price data\",\n70\t    },\n71\t    503: {\n72\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n73\t      description: \"Price unavailable\",\n74\t    },\n75\t  },\n76\t});\n77\t\n78\texport function createPriceRoutes() {\n79\t  const app = createOpenApiApp();\n80\t\n81\t  app.openapi(solUsdRoute, async (c) => {\n82\t    const result = await fetchSolPrice();\n83\t    if (!result) {\n84\t      return err(\n85\t        c,\n86\t        503,\n87\t        API_ERROR_CODES.PRICE_UNAVAILABLE,\n88\t        \"Price unavailable\",\n89\t        { retryable: true },\n90\t      );\n91\t    }\n92\t    return ok(c, {\n93\t      price: result.price,\n94\t      updatedAt: result.updatedAt,\n95\t    });\n96\t  });\n97\t\n98\t  return app;\n99\t}\n100\t"}]},"parent_tool_use_id":null,"session_id":"d389cde2-b9da-44f3-bb5b-97934b5b5fad","uuid":"bbd9a9f8-ce02-4cf2-8541-0c56141da6d4","timestamp":"2026-04-22T11:38:28.651Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/price.ts","content":"/**\n * Price routes — cached SOL/USD price from Pyth Hermes.\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { HermesClient } from \"@pythnetwork/hermes-client\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  err,\n  ok,\n  ErrorEnvelopeSchema,\n} from \"../contracts/api-envelope.js\";\nimport { logger } from \"../logger.js\";\nimport { PriceResponseSchema } from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\n// SOL/USD Pyth feed ID (same on mainnet + devnet)\nconst SOL_USD_FEED_ID =\n  \"0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d\";\n\nconst CACHE_TTL_MS = 60_000; // 60 seconds\n\ninterface CachedPrice {\n  price: number;\n  updatedAt: string;\n  fetchedAt: number; // Date.now() for TTL check\n}\n\nlet cached: CachedPrice | null = null;\n\nconst client = new HermesClient(\"https://hermes.pyth.network\", {});\n\nexport async function fetchSolPrice(): Promise<CachedPrice | null> {\n  // Return cached if still fresh\n  if (cached && Date.now() - cached.fetchedAt < CACHE_TTL_MS) {\n    return cached;\n  }\n\n  try {\n    const updates = await client.getLatestPriceUpdates([SOL_USD_FEED_ID], {\n      encoding: \"base64\",\n      parsed: true,\n    });\n    const feed = updates.parsed?.[0];\n    if (!feed?.price) return cached; // stale cache better than nothing\n\n    const price = Number(feed.price.price) * Math.pow(10, feed.price.expo);\n    const updatedAt = new Date(feed.price.publish_time * 1000).toISOString();\n\n    cached = { price, updatedAt, fetchedAt: Date.now() };\n    return cached;\n  } catch (fetchError) {\n    logger.warn(\"hermes: SOL/USD fetch failed\", {\n      error: fetchError instanceof Error ? fetchError.message : String(fetchError),\n    });\n    return cached; // return stale cache on error\n  }\n}\n\nconst solUsdRoute = createRoute({\n  method: \"get\",\n  path: \"/sol-usd\",\n  tags: [\"Price\"],\n  summary: \"Get cached SOL/USD price\",\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(PriceResponseSchema) } },\n      description: \"Price data\",\n    },\n    503: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Price unavailable\",\n    },\n  },\n});\n\nexport function createPriceRoutes() {\n  const app = createOpenApiApp();\n\n  app.openapi(solUsdRoute, async (c) => {\n    const result = await fetchSolPrice();\n    if (!result) {\n      return err(\n        c,\n        503,\n        API_ERROR_CODES.PRICE_UNAVAILABLE,\n        \"Price unavailable\",\n        { retryable: true },\n      );\n    }\n    return ok(c, {\n      price: result.price,\n      updatedAt: result.updatedAt,\n    });\n  });\n\n  return app;\n}\n","numLines":100,"startLine":1,"totalLines":100}}}
