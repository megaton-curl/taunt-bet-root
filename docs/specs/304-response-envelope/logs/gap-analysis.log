{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0118qEhuySFpH7UxDaTtRQKM","type":"tool_result","content":"1\t/**\n2\t * GET /health — cheap process-local liveness probe.\n3\t *\n4\t * No DB queries. No network calls. Must stay trivial so floods can't hurt.\n5\t */\n6\t\n7\timport { createRoute } from \"@hono/zod-openapi\";\n8\timport { envelope, ok } from \"../contracts/api-envelope.js\";\n9\timport { HealthResponseSchema } from \"../contracts/validators.js\";\n10\timport { createOpenApiApp } from \"../openapi/hono.js\";\n11\t\n12\texport interface HealthDeps {\n13\t  isWorkerRunning: () => boolean;\n14\t}\n15\t\n16\tconst healthRoute = createRoute({\n17\t  method: \"get\",\n18\t  path: \"/\",\n19\t  tags: [\"Health\"],\n20\t  summary: \"Service health check\",\n21\t  responses: {\n22\t    200: {\n23\t      content: { \"application/json\": { schema: envelope(HealthResponseSchema) } },\n24\t      description: \"Health status\",\n25\t    },\n26\t  },\n27\t});\n28\t\n29\texport function createHealthRoutes(deps: HealthDeps) {\n30\t  const { isWorkerRunning } = deps;\n31\t  const app = createOpenApiApp();\n32\t\n33\t  app.openapi(healthRoute, (c) =>\n34\t    ok(c, {\n35\t      status: \"ok\",\n36\t      version: \"0.1.0\",\n37\t      workerRunning: isWorkerRunning(),\n38\t    }),\n39\t  );\n40\t\n41\t  return app;\n42\t}\n43\t"}]},"parent_tool_use_id":null,"session_id":"d389cde2-b9da-44f3-bb5b-97934b5b5fad","uuid":"5999dfeb-979f-43e1-a3c5-a528e66a20b2","timestamp":"2026-04-22T11:38:26.088Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/health.ts","content":"/**\n * GET /health — cheap process-local liveness probe.\n *\n * No DB queries. No network calls. Must stay trivial so floods can't hurt.\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { envelope, ok } from \"../contracts/api-envelope.js\";\nimport { HealthResponseSchema } from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface HealthDeps {\n  isWorkerRunning: () => boolean;\n}\n\nconst healthRoute = createRoute({\n  method: \"get\",\n  path: \"/\",\n  tags: [\"Health\"],\n  summary: \"Service health check\",\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(HealthResponseSchema) } },\n      description: \"Health status\",\n    },\n  },\n});\n\nexport function createHealthRoutes(deps: HealthDeps) {\n  const { isWorkerRunning } = deps;\n  const app = createOpenApiApp();\n\n  app.openapi(healthRoute, (c) =>\n    ok(c, {\n      status: \"ok\",\n      version: \"0.1.0\",\n      workerRunning: isWorkerRunning(),\n    }),\n  );\n\n  return app;\n}\n","numLines":43,"startLine":1,"totalLines":43}}}
