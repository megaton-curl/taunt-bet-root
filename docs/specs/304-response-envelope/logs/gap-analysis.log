{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013cWEvXCGGgby1fB8r8NXP4","type":"tool_result","content":"80\t\n81\t      return ok(c, {\n82\t        token,\n83\t        deepLink: `https://t.me/${telegramBotUsername}?start=${token}`,\n84\t        expiresAt: expiresAt.toISOString(),\n85\t        botUrl: `https://t.me/${telegramBotUsername}`,\n86\t        communityUrl: communityInviteUrl ?? null,\n87\t      });\n88\t    } catch (generateError) {\n89\t      logger.error(\"telegram generate-link failed\", {\n90\t        userId,\n91\t        error:\n92\t          generateError instanceof Error\n93\t            ? generateError.message\n94\t            : \"Unknown error\",\n95\t      });\n96\t      return err(\n97\t        c,\n98\t        500,\n99\t        API_ERROR_CODES.PRECONDITION_FAILED,\n100\t        \"Failed to generate link token\",\n101\t      );\n102\t    }\n103\t  });\n104\t\n105\t  // -------------------------------------------------------------------------\n106\t  // POST /redeem-link — service-auth\n107\t  // -------------------------------------------------------------------------\n108\t  app.post(\"/redeem-link\", serviceAuth, async (c) => {\n109\t    let body: { token?: string; telegramUserId?: string; telegramUsername?: string };\n110\t    try {\n111\t      body = await c.req.json();\n112\t    } catch {\n113\t      return err(\n114\t        c,\n115\t        422,\n116\t        API_ERROR_CODES.VALIDATION_FAILED,\n117\t        \"Invalid request body\",\n118\t      );\n119\t    }\n120\t\n121\t    const { token, telegramUserId, telegramUsername } = body;\n122\t    if (!token || !telegramUserId) {\n123\t      return err(\n124\t        c,\n125\t        422,\n126\t        API_ERROR_CODES.VALIDATION_FAILED,\n127\t        \"Missing required fields\",\n128\t      );\n129\t    }\n130\t\n131\t    try {\n132\t      const existingTg = await db.getActiveLinkByTelegramId(telegramUserId);\n133\t      if (existingTg) {\n134\t        return err(\n135