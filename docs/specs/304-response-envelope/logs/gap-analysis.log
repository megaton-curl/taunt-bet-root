{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MhNZSm1t37dvEns86hfMrP","type":"tool_result","content":"380\t    if (!onlyTrue) return false;\n381\t    return \"data\" in properties;\n382\t  }\n383\t\n384\t  /** Returns `true` if `schema` is an envelope `oneOf` of success + error variants. */\n385\t  function isEnvelopeSchema(spec: AnyRecord, schema: AnyRecord): boolean {\n386\t    const oneOf = schema.oneOf as unknown[] | undefined;\n387\t    if (!Array.isArray(oneOf) || oneOf.length < 2) return false;\n388\t    let hasSuccess = false;\n389\t    let hasError = false;\n390\t    for (const variant of oneOf) {\n391\t      const resolved = resolveSchema(spec, variant);\n392\t      if (isSuccessEnvelopeVariant(resolved)) hasSuccess = true;\n393\t      if (isErrorEnvelope(resolved)) hasError = true;\n394\t    }\n395\t    return hasSuccess && hasError;\n396\t  }\n397\t\n398\t  function* iterPublicJsonResponses(spec: AnyRecord): Generator<{\n399\t    path: string;\n400\t    method: string;\n401\t    status: string;\n402\t    schema: AnyRecord;\n403\t  }> {\n404\t    for (const [path, methods] of Object.entries(spec.paths as AnyRecord)) {\n405\t      for (const [method, operation] of Object.entries(methods as AnyRecord)) {\n406\t        if (!VALID_METHODS.has(method)) continue;\n407\t        const op = operation as AnyRecord;\n408\t        const responses = op.responses as AnyRecord | undefined;\n409\t        if (!responses) continue;\n410\t        for (const [status, response] of Object.entries(responses)) {\n411\t          const res = response as AnyRecord;\n412\t          const content = res.content as AnyRecord | undefined;\n413\t          const json = content?.[\"application/json\"] as AnyRecord | undefined;\n414\t          const schema = json?.schema;\n415\t          if (!schema) continue;\n416\t          yield { path, method, status, schema: schema as AnyRecord };\n417\t        }\n418\t      }\n419\t    }\n420\t  }\n421\t\n422\t  it(\"every 2xx JSON body uses the success envelope shape\", () => {\n423\t    const violations: string[] = [];\n424\t    for (const { path, method, status, schema } of iterPublicJsonResponses(spec)) {\n425\t      if (!/^2\\d\\d$/.test(status)) continue;\n426\t      // 204 has no body — skipped because it has no JSON content at all.\n427\t      const resolved = resolveSchema(spec, schema);\n428\t      if (!isEnvelopeSchema(spec, resolved)) {\n429\t        violations.push(`${method.toUpperCase()} ${path} → ${status}`);\n430\t      }\n431\t    }\n432\t    expect(\n433\t      violations,\n434\t      `2xx responses missing envelope shape:\\n${violations.join(\"\\n\")}`,\n435\t    ).toHaveLength(0);\n436\t  });\n437\t\n438\t  it(\"every 4xx/5xx JSON body uses the error envelope shape\", () => {\n439\t    const violations: string[] = [];\n440\t    for (const { path, method, status, schema } of iterPublicJsonResponses(spec)) {\n441\t      if (!/^[45]\\d\\d$/.test(status)) continue;\n442\t      const resolved = resolveSchema(spec, schema);\n443\t      // Accept either $ref to ErrorEnvelope (top-level) or inline error shape.\n444\t      const schemaRecord = schema as AnyRecord;\n445\t      const directRef =\n446\t        typeof schemaRecord.$ref === \"string\" &&\n447\t        schemaRecord.$ref === \"#/components/schemas/ErrorEnvelope\";\n448\t      if (!directRef && !isErrorEnvelope(resolved)) {\n449\t        violations.push(`${method.toUpperCase()} ${path} → ${status}`);\n450\t      }\n451\t    }\n452\t    expect(\n453\t      violations,\n454\t      `4xx/5xx responses missing error envelope shape:\\n${violations.join(\"\\n\")}`,\n455\t    ).toHaveLength(0);\n456\t  });\n457\t\n458\t  it(\"ApiError and ErrorEnvelope appear exactly once in components.schemas\", () => {\n459\t    const components = (spec.components as AnyRecord)?.schemas as AnyRecord | undefined;\n460\t    expect(components, \"spec.components.schemas missing\").toBeDefined();\n461\t    expect(components!.ApiError, \"ApiError component not registered\").toBeDefined();\n462\t    expect(components!.ErrorEnvelope, \"ErrorEnvelope component not registered\").toBeDefined();\n463\t    // Exactly one registration per name — object keys are unique, so the\n464\t    // presence + type checks above are sufficient. We also verify the\n465\t    // expected structural fields to pin the shape.\n466\t    const apiError = components!.ApiError as AnyRecord;\n467\t    const apiErrorProps = apiError.properties as AnyRecord | undefined;\n468\t    expect(apiErrorProps?.code).toBeDefined();\n469\t    expect(apiErrorProps?.message).toBeDefined();"}]},"parent_tool_use_id":null,"session_id":"d389cde2-b9da-44f3-bb5b-97934b5b5fad","uuid":"f5f3466f-c7b7-4f10-839d-42609a5329eb","timestamp":"2026-04-22T11:40:25.661Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/openapi-contract.test.ts","content":"    if (!onlyTrue) return false;\n    return \"data\" in properties;\n  }\n\n  /** Returns `true` if `schema` is an envelope `oneOf` of success + error variants. */\n  function isEnvelopeSchema(spec: AnyRecord, schema: AnyRecord): boolean {\n    const oneOf = schema.oneOf as unknown[] | undefined;\n    if (!Array.isArray(oneOf) || oneOf.length < 2) return false;\n    let hasSuccess = false;\n    let hasError = false;\n    for (const variant of oneOf) {\n      const resolved = resolveSchema(spec, variant);\n      if (isSuccessEnvelopeVariant(resolved)) hasSuccess = true;\n      if (isErrorEnvelope(resolved)) hasError = true;\n    }\n    return hasSuccess && hasError;\n  }\n\n  function* iterPublicJsonResponses(spec: AnyRecord): Generator<{\n    path: string;\n    method: string;\n    status: string;\n    schema: AnyRecord;\n  }> {\n    for (const [path, methods] of Object.entries(spec.paths as AnyRecord)) {\n      for (const [method, operation] of Object.entries(methods as AnyRecord)) {\n        if (!VALID_METHODS.has(method)) continue;\n        const op = operation as AnyRecord;\n        const responses = op.responses as AnyRecord | undefined;\n        if (!responses) continue;\n        for (const [status, response] of Object.entries(responses)) {\n          const res = response as AnyRecord;\n          const content = res.content as AnyRecord | undefined;\n          const json = content?.[\"application/json\"] as AnyRecord | undefined;\n          const schema = json?.schema;\n          if (!schema) continue;\n          yield { path, method, status, schema: schema as AnyRecord };\n        }\n      }\n    }\n  }\n\n  it(\"every 2xx JSON body uses the success envelope shape\", () => {\n    const violations: string[] = [];\n    for (const { path, method, status, schema } of iterPublicJsonResponses(spec)) {\n      if (!/^2\\d\\d$/.test(status)) continue;\n      // 204 has no body — skipped because it has no JSON content at all.\n      const resolved = resolveSchema(spec, schema);\n      if (!isEnvelopeSchema(spec, resolved)) {\n        violations.push(`${method.toUpperCase()} ${path} → ${status}`);\n      }\n    }\n    expect(\n      violations,\n      `2xx responses missing envelope shape:\\n${violations.join(\"\\n\")}`,\n    ).toHaveLength(0);\n  });\n\n  it(\"every 4xx/5xx JSON body uses the error envelope shape\", () => {\n    const violations: string[] = [];\n    for (const { path, method, status, schema } of iterPublicJsonResponses(spec)) {\n      if (!/^[45]\\d\\d$/.test(status)) continue;\n      const resolved = resolveSchema(spec, schema);\n      // Accept either $ref to ErrorEnvelope (top-level) or inline error shape.\n      const schemaRecord = schema as AnyRecord;\n      const directRef =\n        typeof schemaRecord.$ref === \"string\" &&\n        schemaRecord.$ref === \"#/components/schemas/ErrorEnvelope\";\n      if (!directRef && !isErrorEnvelope(resolved)) {\n        violations.push(`${method.toUpperCase()} ${path} → ${status}`);\n      }\n    }\n    expect(\n      violations,\n      `4xx/5xx responses missing error envelope shape:\\n${violations.join(\"\\n\")}`,\n    ).toHaveLength(0);\n  });\n\n  it(\"ApiError and ErrorEnvelope appear exactly once in components.schemas\", () => {\n    const components = (spec.components as AnyRecord)?.schemas as AnyRecord | undefined;\n    expect(components, \"spec.components.schemas missing\").toBeDefined();\n    expect(components!.ApiError, \"ApiError component not registered\").toBeDefined();\n    expect(components!.ErrorEnvelope, \"ErrorEnvelope component not registered\").toBeDefined();\n    // Exactly one registration per name — object keys are unique, so the\n    // presence + type checks above are sufficient. We also verify the\n    // expected structural fields to pin the shape.\n    const apiError = components!.ApiError as AnyRecord;\n    const apiErrorProps = apiError.properties as AnyRecord | undefined;\n    expect(apiErrorProps?.code).toBeDefined();\n    expect(apiErrorProps?.message).toBeDefined();","numLines":90,"startLine":380,"totalLines":477}}}
