{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DCQsHvR4TWsJ2R38dJwJcy","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport {\n3\t  API_ERROR_CODES,\n4\t  type ApiErrorCode,\n5\t} from \"../contracts/api-errors.js\";\n6\t\n7\tdescribe(\"API_ERROR_CODES catalog\", () => {\n8\t  it(\"is the single source of truth: every key equals its value\", () => {\n9\t    for (const [key, value] of Object.entries(API_ERROR_CODES)) {\n10\t      expect(value).toBe(key);\n11\t    }\n12\t  });\n13\t\n14\t  it(\"contains only SCREAMING_SNAKE_CASE entries\", () => {\n15\t    for (const value of Object.values(API_ERROR_CODES)) {\n16\t      expect(value).toMatch(/^[A-Z][A-Z0-9_]*$/);\n17\t    }\n18\t  });\n19\t\n20\t  it(\"emits unique code values with no duplicates\", () => {\n21\t    const values = Object.values(API_ERROR_CODES);\n22\t    const unique = new Set(values);\n23\t    expect(unique.size).toBe(values.length);\n24\t  });\n25\t\n26\t  it(\"is frozen-shaped (as const) so keys and values align at the type level\", () => {\n27\t    const probe: ApiErrorCode = API_ERROR_CODES.AUTH_REQUIRED;\n28\t    expect(probe).toBe(\"AUTH_REQUIRED\");\n29\t  });\n30\t\n31\t  it(\"covers every error code declared by FR-2\", () => {\n32\t    const expected = [\n33\t      \"AUTH_REQUIRED\",\n34\t      \"FORBIDDEN\",\n35\t      \"RATE_LIMITED\",\n36\t      \"VALIDATION_FAILED\",\n37\t      \"INVALID_REQUEST\",\n38\t      \"INVALID_PARAMS\",\n39\t      \"INVALID_SIGNATURE\",\n40\t      \"CHALLENGE_EXPIRED\",\n41\t      \"REFRESH_TOKEN_INVALID\",\n42\t      \"CODE_ALREADY_SET\",\n43\t      \"CODE_TAKEN\",\n44\t      \"CODE_NOT_FOUND\",\n45\t      \"INVALID_CODE\",\n46\t      \"SELF_REFERRAL\",\n47\t      \"ALREADY_LINKED\",\n48\t      \"ZERO_BALANCE\",\n49\t      \"BELOW_THRESHOLD\",\n50\t      \"CLAIM_NOT_FOUND\","}]},"parent_tool_use_id":null,"session_id":"d389cde2-b9da-44f3-bb5b-97934b5b5fad","uuid":"8a0526a3-aba3-4bd9-849d-8033c7