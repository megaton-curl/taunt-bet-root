{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LpdJMtPq3ocARnGrUqPmua","type":"tool_result","content":"1\t/**\n2\t * In-memory sliding-window rate limiting middleware.\n3\t *\n4\t * Applies per-identity and global limits to POST requests only.\n5\t * Counters reset on service restart (acceptable for MVP).\n6\t */\n7\t\n8\timport type { MiddlewareHandler } from \"hono\";\n9\timport { logger } from \"../logger.js\";\n10\timport { err } from \"../contracts/api-envelope.js\";\n11\timport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n12\t\n13\texport interface RateLimitConfig {\n14\t  /** Max POST requests per authenticated identity per window (default 10). */\n15\t  perWallet: number;\n16\t  /** Max total POST requests per window (default 100). */\n17\t  global: number;\n18\t  /** Window size in milliseconds (default 60_000 = 1 minute). */\n19\t  windowMs: number;\n20\t}\n21\t\n22\tinterface SlidingWindow {\n23\t  timestamps: number[];\n24\t}\n25\t\n26\t/**\n27\t * Prune timestamps older than the window and return the current count.\n28\t */\n29\tfunction countInWindow(window: SlidingWindow, now: number, windowMs: number): number {\n30\t  const cutoff = now - windowMs;\n31\t  // Remove expired entries from the front\n32\t  while (window.timestamps.length > 0 && window.timestamps[0]! <= cutoff) {\n33\t    window.timestamps.shift();\n34\t  }\n35\t  return window.timestamps.length;\n36\t}\n37\t\n38\t/**\n39\t * Creates a Hono middleware that rate-limits POST requests.\n40\t *\n41\t * - Per-identity: keyed by authenticated `userId` when present, else wallet/body fallback.\n42\t * - Global: all POST requests combined.\n43\t * - Returns 429 with `Retry-After` header when either limit is exceeded.\n44\t * - GET requests pass through without rate limiting.\n45\t */\n46\texport function createRateLimitMiddleware(config: RateLimitConfig): MiddlewareHandler {\n47\t  const walletWindows = new Map<string, SlidingWindow>();\n48\t  const globalWindow: SlidingWindow = { timestamps: [] };\n49\t\n50\t  return async (c, next) => {\n51\t    if (c.req.method !== \"POST\") {\n52\t      return next();\n53\t    }\n54\t\n55\t    const now = Date.now();\n56\t    const retryAfterSeconds = Math.ceil(config.windowMs / 1000);\n57\t\n58\t    // Check global limit first\n59\t    const globalCount = countInWindow(globalWindow, now, config.windowMs);\n60\t    if (globalCount >= config.global) {\n61\t      logger.warn(\"rate limit exceeded: global limit\", {\n62\t        path: c.req.path,\n63\t        currentCount: globalCount,\n64\t        limit: config.global,\n65\t        windowMs: config.windowMs,\n66\t      });\n67\t      c.header(\"Retry-After\", String(retryAfterSeconds));\n68\t      return err(c, 429, API_ERROR_CODES.RATE_LIMITED, \"Too many requests\", {\n69\t        retryable: true,\n70\t        details: { retryAfterMs: config.windowMs },\n71\t      });\n72\t    }\n73\t\n74\t    // Extract identity: prefer canonical userId, then body wallet (pre-auth), then IP.\n75\t    let identity: string | undefined;\n76\t    try {\n77\t      identity = c.get(\"userId\") as string | undefined;\n78\t    } catch {\n79\t      // Context variable not set — expected for pre-auth routes\n80\t    }\n81\t    if (!identity) {\n82\t      try {\n83\t        const body = await c.req.json();\n84\t        identity = typeof body.wallet === \"string\" ? body.wallet : undefined;\n85\t      } catch {\n86\t        // If body is not parseable, fall back to IP-based limiting\n87\t      }\n88\t    }\n89\t    // Final fallback: key on IP for pre-auth routes (e.g., /auth/*)\n90\t    if (!identity) {\n91\t      identity = c.req.header(\"x-forwarded-for\")?.split(\",\")[0]?.trim()\n92\t        ?? c.req.header(\"x-real-ip\")\n93\t        ?? \"unknown-ip\";\n94\t    }\n95\t\n96\t    // Check per-identity limit\n97\t    if (identity) {\n98\t      let wWindow = walletWindows.get(identity);\n99\t      if (!wWindow) {\n100\t        wWindow = { timestamps: [] };\n101\t        walletWindows.set(identity, wWindow);\n102\t      }\n103\t      const walletCount = countInWindow(wWindow, now, config.windowMs);\n104\t      if (walletCount >= config.perWallet) {\n105\t        logger.warn(\"rate limit exceeded: wallet limit\", {\n106\t          path: c.req.path,\n107\t          identity,\n108\t          currentCount: walletCount,\n109\t          limit: config.perWallet,\n110\t          windowMs: config.windowMs,\n111\t        });\n112\t        c.header(\"Retry-After\", String(retryAfterSeconds));\n113\t        return err(c, 429, API_ERROR_CODES.RATE_LIMITED, \"Too many requests\", {\n114\t          retryable: true,\n115\t          details: { retryAfterMs: config.windowMs },\n116\t        });\n117\t      }\n118\t      wWindow.timestamps.push(now);\n119\t    }\n120\t\n121\t    // Record in global window\n122\t    globalWindow.timestamps.push(now);\n123\t\n124\t    return next();\n125\t  };\n126\t}\n127\t"}]},"parent_tool_use_id":null,"session_id":"d389cde2-b9da-44f3-bb5b-97934b5b5fad","uuid":"3a70ad0c-ce62-45af-b76f-9ac6124ea465","timestamp":"2026-04-22T11:37:14.508Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/middleware/rate-limit.ts","content":"/**\n * In-memory sliding-window rate limiting middleware.\n *\n * Applies per-identity and global limits to POST requests only.\n * Counters reset on service restart (acceptable for MVP).\n */\n\nimport type { MiddlewareHandler } from \"hono\";\nimport { logger } from \"../logger.js\";\nimport { err } from \"../contracts/api-envelope.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n\nexport interface RateLimitConfig {\n  /** Max POST requests per authenticated identity per window (default 10). */\n  perWallet: number;\n  /** Max total POST requests per window (default 100). */\n  global: number;\n  /** Window size in milliseconds (default 60_000 = 1 minute). */\n  windowMs: number;\n}\n\ninterface SlidingWindow {\n  timestamps: number[];\n}\n\n/**\n * Prune timestamps older than the window and return the current count.\n */\nfunction countInWindow(window: SlidingWindow, now: number, windowMs: number): number {\n  const cutoff = now - windowMs;\n  // Remove expired entries from the front\n  while (window.timestamps.length > 0 && window.timestamps[0]! <= cutoff) {\n    window.timestamps.shift();\n  }\n  return window.timestamps.length;\n}\n\n/**\n * Creates a Hono middleware that rate-limits POST requests.\n *\n * - Per-identity: keyed by authenticated `userId` when present, else wallet/body fallback.\n * - Global: all POST requests combined.\n * - Returns 429 with `Retry-After` header when either limit is exceeded.\n * - GET requests pass through without rate limiting.\n */\nexport function createRateLimitMiddleware(config: RateLimitConfig): MiddlewareHandler {\n  const walletWindows = new Map<string, SlidingWindow>();\n  const globalWindow: SlidingWindow = { timestamps: [] };\n\n  return async (c, next) => {\n    if (c.req.method !== \"POST\") {\n      return next();\n    }\n\n    const now = Date.now();\n    const retryAfterSeconds = Math.ceil(config.windowMs / 1000);\n\n    // Check global limit first\n    const globalCount = countInWindow(globalWindow, now, config.windowMs);\n    if (globalCount >= config.global) {\n      logger.warn(\"rate limit exceeded: global limit\", {\n        path: c.req.path,\n        currentCount: globalCount,\n        limit: config.global,\n        windowMs: config.windowMs,\n      });\n      c.header(\"Retry-After\", String(retryAfterSeconds));\n      return err(c, 429, API_ERROR_CODES.RATE_LIMITED, \"Too many requests\", {\n        retryable: true,\n        details: { retryAfterMs: config.windowMs },\n      });\n    }\n\n    // Extract identity: prefer canonical userId, then body wallet (pre-auth), then IP.\n    let identity: string | undefined;\n    try {\n      identity = c.get(\"userId\") as string | undefined;\n    } catch {\n      // Context variable not set — expected for pre-auth routes\n    }\n    if (!identity) {\n      try {\n        const body = await c.req.json();\n        identity = typeof body.wallet === \"string\" ? body.wallet : undefined;\n      } catch {\n        // If body is not parseable, fall back to IP-based limiting\n      }\n    }\n    // Final fallback: key on IP for pre-auth routes (e.g., /auth/*)\n    if (!identity) {\n      identity = c.req.header(\"x-forwarded-for\")?.split(\",\")[0]?.trim()\n        ?? c.req.header(\"x-real-ip\")\n        ?? \"unknown-ip\";\n    }\n\n    // Check per-identity limit\n    if (identity) {\n      let wWindow = walletWindows.get(identity);\n      if (!wWindow) {\n        wWindow = { timestamps: [] };\n        walletWindows.set(identity, wWindow);\n      }\n      const walletCount = countInWindow(wWindow, now, config.windowMs);\n      if (walletCount >= config.perWallet) {\n        logger.warn(\"rate limit exceeded: wallet limit\", {\n          path: c.req.path,\n          identity,\n          currentCount: walletCount,\n          limit: config.perWallet,\n          windowMs: config.windowMs,\n        });\n        c.header(\"Retry-After\", String(retryAfterSeconds));\n        return err(c, 429, API_ERROR_CODES.RATE_LIMITED, \"Too many requests\", {\n          retryable: true,\n          details: { retryAfterMs: config.windowMs },\n        });\n      }\n      wWindow.timestamps.push(now);\n    }\n\n    // Record in global window\n    globalWindow.timestamps.push(now);\n\n    return next();\n  };\n}\n","numLines":127,"startLine":1,"totalLines":127}}}
