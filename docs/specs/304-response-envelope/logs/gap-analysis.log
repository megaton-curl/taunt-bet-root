ing(),\n53\t      earnedLamports: z.string(),\n54\t      createdAt: z.string().datetime(),\n55\t    }),\n56\t  ),\n57\t  pagination: z.object({\n58\t    page: z.number().int(),\n59\t    totalPages: z.number().int(),\n60\t  }),"}]},"parent_tool_use_id":null,"session_id":"d389cde2-b9da-44f3-bb5b-97934b5b5fad","uuid":"bed13008-2256-4647-b34e-e20fab788acf","timestamp":"2026-04-22T11:37:49.885Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/referral.ts","content":"/**\n * Referral routes — code management, linking, stats, earnings, and claims.\n *\n * WAITLIST-CONTRACT: the waitlist calls POST/GET /code, POST /apply,\n * GET /referrer, GET /stats, GET /referrals. /earnings and /claim are NOT\n * consumed by waitlist. Request/response shape for the consumed set is\n * pinned in `__tests__/waitlist-contract.test.ts`; keep\n * `waitlist/src/lib/referral-api.ts` in lockstep.\n */\n\nimport { createRoute, z } from \"@hono/zod-openapi\";\nimport type postgres from \"postgres\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport type { Config } from \"../config.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport {\n  ApplyReferralCodeBodySchema,\n  ClaimResponseSchema,\n  CodeResponseSchema,\n  MaybeCodeResponseSchema,\n  ReferralApplyResponseSchema,\n  ReferralCodeBodySchema,\n  ReferralListResponseSchema,\n  ReferralReferrerResponseSchema,\n  ReferralStatsSchema,\n} from \"../contracts/validators.js\";\nimport { logger } from \"../logger.js\";\nimport { emitEvent } from \"../queue/emit-event.js\";\nimport { EventTypes } from \"../queue/event-types.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface ReferralRoutesDeps {\n  db: Db;\n  sql: postgres.Sql;\n  config: Config;\n}\n\nconst EarningsResponseSchema = z.object({\n  ite