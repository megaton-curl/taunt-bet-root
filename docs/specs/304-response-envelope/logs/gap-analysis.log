() => {\n51\t    const app = createTestApp({ perWallet: 1, global: 100, windowMs: 60_000 });\n52\t    await app.request(\"/test\", post(\"wallet1\"));\n53\t    const res = await app.request(\"/test\", post(\"wallet1\"));\n54\t    expect(res.status).toBe(429);\n55\t    expect(res.headers.get(\"Retry-After\")).toBe(\"60\");\n56\t  });\n57\t\n58\t  it(\"tracks wallets independently\", async () => {\n59\t    const app = createTestApp({ perWallet: 1, global: 100, windowMs: 60_000 });\n60\t    const r1 = await app.request(\"/test\", post(\"wallet1\"));"}]},"parent_tool_use_id":null,"session_id":"d389cde2-b9da-44f3-bb5b-97934b5b5fad","uuid":"fe4b1336-e584-4090-93df-3e97792842af","timestamp":"2026-04-22T11:40:36.989Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/rate-limit.test.ts","content":"import { describe, it, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { createRateLimitMiddleware } from \"../middleware/rate-limit.js\";\n\nfunction createTestApp(\n  config = { perWallet: 3, global: 10, windowMs: 60_000 },\n) {\n  const app = new Hono();\n  app.use(\"/*\", createRateLimitMiddleware(config));\n  app.post(\"/test\", (c) => c.json({ ok: true }));\n  app.get(\"/test\", (c) => c.json({ ok: true }));\n  return app;\n}\n\nfunction post(wallet: string) {\n  return {\n    method: \"POST\" as const,\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ wallet }),\n  };\n}\n\ndescribe(\"rate-limit middleware\", () => {\n  it(\"allows requests within per-wallet limit\", async () => {\n    const app = createTestApp({ perWallet: 3, global: 100, windowMs: 60_000 });\n    for (let i = 0; i < 3; i++) {\n      const res = await app.request(\"/test\", post(\"wallet1\"));\n      expect(res.status).toBe(200);\n    }\n  });\n\n  it(\"blocks requests exceeding per-wallet limit\", async () => {\n    const app = createTestApp({ perWallet: 2, global: 100, windowMs: 60_000 });\n    await app.request(\"/test\", post(\"wallet1\"));\n    await app.request(\"/test\", post(\"wallet1\"));\n    const res = await app.request(\"/test\", post(\"wallet1\"));\n    expect(res.status).toBe(429);\n    const body = await res.json();\n    expect(body).toEqual({\n      ok: false,\n      error: {\n        code: \"RATE_LIMITED\",\n        message: \"Too many requests\",\n        retryable: true,\n        details: { retryAfterMs: 60_000 },\n      },\n    });\n  });\n\n  it(\"returns Retry-After header on per-wallet 429\", async () => {\n    const app = createTestApp({ perWallet: 1, global: 100, windowMs: 60_000 });\n    await app.request(\"/test\", post(\"wallet1\"));\n    const res = await app.request(\"/test\", post(\"wallet1\"));\n    expect(res.status).toBe(429);\n    expect(res.headers.get(\"Retry-After\")).toBe(\"60\");\n  });\n\n  it(\"tracks wallets independently\", async () => {\n    const app = createTestApp({ perWallet: 1, global: 100, windowMs: 60_000 });\n    const r1 = await app.request(\"/test\", post(\"wallet1\"));","numLines":60,"startLine":1,"totalLines":110}}}
