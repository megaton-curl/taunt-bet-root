{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016hDKKcinpFUJLxE3S5BZCM","type":"tool_result","content":"1\t/**\n2\t * JWT Bearer token authentication middleware.\n3\t *\n4\t * Verifies HS256 JWT access tokens on POST requests.\n5\t * Sets c.set(\"userId\", payload.sub) for downstream handlers.\n6\t * Wallet is NOT in the JWT — routes that need wallet resolve it from the profile.\n7\t * GET requests pass through without authentication.\n8\t */\n9\t\n10\timport { createMiddleware } from \"hono/factory\";\n11\timport { jwtVerify } from \"jose\";\n12\timport { logger } from \"../logger.js\";\n13\timport { err } from \"../contracts/api-envelope.js\";\n14\timport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n15\timport type { AppEnv } from \"../hono-env.js\";\n16\t\n17\texport interface JwtAuthConfig {\n18\t  jwtSecret: Uint8Array;\n19\t  /** When true, require JWT for all HTTP methods (not just POST). Default: false */\n20\t  requireAllMethods?: boolean;\n21\t}\n22\t\n23\texport function createJwtAuthMiddleware(config: JwtAuthConfig) {\n24\t  return createMiddleware<AppEnv>(async (c, next) => {\n25\t    // Skip authentication for non-POST requests (GET, OPTIONS, etc.)\n26\t    // unless requireAllMethods is set (e.g., profile endpoints)\n27\t    if (!config.requireAllMethods && c.req.method !== \"POST\") {\n28\t      return next();\n29\t    }\n30\t\n31\t    const authHeader = c.req.header(\"Authorization\");\n32\t    if (!authHeader || !authHeader.startsWith(\"Bearer \")) {\n33\t      logger.warn(\"jwt auth rejected: missing or invalid Authorization header\", {\n34\t        path: c.req.path,\n35\t      });\n36\t      return err(\n37\t        c,\n38\t        401,\n39\t        API_ERROR_CODES.AUTH_REQUIRED,\n40\t        \"Missing or invalid Authorization header\",\n41\t      );\n42\t    }\n43\t\n44\t    const token = authHeader.slice(7);\n45\t    try {\n46\t      const { payload } = await jwtVerify(token, config.jwtSecret, {\n47\t        algorithms: [\"HS256\"],\n48\t      });\n49\t\n50\t      if (typeof payload.sub !== \"string\") {\n51\t        logger.warn(\"jwt auth rejected: missing sub claim\", {\n52\t          path: c.req.path,\n53\t        });\n54\t        return err(\n55\t          c,\n56\t          401,\n57\t          API_ERROR_CODES.AUTH_REQUIRED,\n58\t          \"Invalid token: missing subject\",\n59\t        );\n60\t      }\n61\t\n62\t      c.set(\"userId\", payload.sub);\n63\t      return next();\n64\t    } catch (verifyError) {\n65\t      logger.warn(\"jwt auth rejected: token verification failed\", {\n66\t        path: c.req.path,\n67\t        error:\n68\t          verifyError instanceof Error ? verifyError.message : \"Unknown error\",\n69\t      });\n70\t      return err(\n71\t        c,\n72\t        401,\n73\t        API_ERROR_CODES.AUTH_REQUIRED,\n74\t        \"Invalid or expired token\",\n75\t      );\n76\t    }\n77\t  });\n78\t}\n79\t"}]},"parent_tool_use_id":null,"session_id":"d389cde2-b9da-44f3-bb5b-97934b5b5fad","uuid":"6d90424a-7144-4e2d-abd7-deaadf9926d9","timestamp":"2026-04-22T11:37:11.810Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/middleware/jwt-auth.ts","content":"/**\n * JWT Bearer token authentication middleware.\n *\n * Verifies HS256 JWT access tokens on POST requests.\n * Sets c.set(\"userId\", payload.sub) for downstream handlers.\n * Wallet is NOT in the JWT — routes that need wallet resolve it from the profile.\n * GET requests pass through without authentication.\n */\n\nimport { createMiddleware } from \"hono/factory\";\nimport { jwtVerify } from \"jose\";\nimport { logger } from \"../logger.js\";\nimport { err } from \"../contracts/api-envelope.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport type { AppEnv } from \"../hono-env.js\";\n\nexport interface JwtAuthConfig {\n  jwtSecret: Uint8Array;\n  /** When true, require JWT for all HTTP methods (not just POST). Default: false */\n  requireAllMethods?: boolean;\n}\n\nexport function createJwtAuthMiddleware(config: JwtAuthConfig) {\n  return createMiddleware<AppEnv>(async (c, next) => {\n    // Skip authentication for non-POST requests (GET, OPTIONS, etc.)\n    // unless requireAllMethods is set (e.g., profile endpoints)\n    if (!config.requireAllMethods && c.req.method !== \"POST\") {\n      return next();\n    }\n\n    const authHeader = c.req.header(\"Authorization\");\n    if (!authHeader || !authHeader.startsWith(\"Bearer \")) {\n      logger.warn(\"jwt auth rejected: missing or invalid Authorization header\", {\n        path: c.req.path,\n      });\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.AUTH_REQUIRED,\n        \"Missing or invalid Authorization header\",\n      );\n    }\n\n    const token = authHeader.slice(7);\n    try {\n      const { payload } = await jwtVerify(token, config.jwtSecret, {\n        algorithms: [\"HS256\"],\n      });\n\n      if (typeof payload.sub !== \"string\") {\n        logger.warn(\"jwt auth rejected: missing sub claim\", {\n          path: c.req.path,\n        });\n        return err(\n          c,\n          401,\n          API_ERROR_CODES.AUTH_REQUIRED,\n          \"Invalid token: missing subject\",\n        );\n      }\n\n      c.set(\"userId\", payload.sub);\n      return next();\n    } catch (verifyError) {\n      logger.warn(\"jwt auth rejected: token verification failed\", {\n        path: c.req.path,\n        error:\n          verifyError instanceof Error ? verifyError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.AUTH_REQUIRED,\n        \"Invalid or expired token\",\n      );\n    }\n  });\n}\n","numLines":79,"startLine":1,"totalLines":79}}}
