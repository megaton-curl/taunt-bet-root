{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019AFB9RbokTDPAbH8G9CkfP","type":"tool_result","content":"1\t/**\n2\t * Telegram link routes — generate deep-link tokens and redeem them.\n3\t *\n4\t * POST /generate-link — JWT required. Returns a one-time deep-link token.\n5\t * All other endpoints use service-auth via X-Telegram-Webhook-Secret header.\n6\t *\n7\t * WAITLIST-CONTRACT: the waitlist calls POST /generate-link\n8\t * (`waitlist/src/components/TelegramCard.tsx`) and branches on both\n9\t * `alreadyLinked: true` and `deepLink` payloads. This file is plain Hono\n10\t * (no OpenAPI schema), so the response shape is locked by handler invocation\n11\t * in `__tests__/waitlist-contract.test.ts` — updating either response branch\n12\t * requires updating that test AND the waitlist consumer in the same change.\n13\t */\n14\t\n15\timport { randomBytes } from \"node:crypto\";\n16\timport { Hono } from \"hono\";\n17\timport { createMiddleware } from \"hono/factory\";\n18\timport type { AppEnv } from \"../hono-env.js\";\n19\timport type { Db } from \"../db.js\";\n20\timport { logger } from \"../logger.js\";\n21\timport { ok, err } from \"../contracts/api-envelope.js\";\n22\timport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n23\t\n24\texport interface TelegramLinkRoutesDeps {\n25\t  db: Db;\n26\t  telegramBotUsername: string;\n27\t  telegramWebhookSecret: string;\n28\t  communityInviteUrl: string | undefined;\n29\t  linkTokenTtlSeconds: number;\n30\t}\n31\t\n32\texport function createTelegramLinkRoutes(deps: TelegramLinkRoutesDeps) {\n33\t  const { db, telegramBotUsername, telegramWebhookSecret, communityInviteUrl, linkTokenTtlSeconds } = deps;\n34\t  const app = new Hono<AppEnv>();\n35\t\n36\t  // Service-auth middleware for bot-facing endpoints\n37\t  const serviceAuth = createMiddleware(async (c, next) => {\n38\t    if (c.req.header(\"X-Telegram-Webhook-Secret\") !== telegramWebhookSecret) {\n39\t      return err(\n40\t        c,\n41\t        401,\n42\t        API_ERROR_CODES.AUTH_REQUIRED,\n43\t        \"Missing or invalid service secret\",\n44\t      );\n45\t    }\n46\t    return next();\n47\t  });\n48\t\n49\t  // -------------------------------------------------------------------------\n50\t  // POST /generate-link — JWT required\n51\t  // -------------------------------------------------------------------------\n52\t  app.post(\"/generate-link\", async (c) => {\n53\t    const userId = c.get(\"userId\");\n54\t    if (!userId) {\n55\t      return err(\n56\t        c,\n57\t        401,\n58\t        API_ERROR_CODES.AUTH_REQUIRED,\n59\t        \"Authentication required\",\n60\t      );\n61\t    }\n62\t\n63\t    try {\n64\t      const existing = await db.getActiveLink(userId);\n65\t      if (existing) {\n66\t        return ok(c, {\n67\t          alreadyLinked: true as const,\n68\t          telegramUserId: existing.telegram_user_id,\n69\t          telegramUsername: existing.telegram_username,\n70\t          linkedAt: existing.redeemed_at?.toISOString() ?? null,\n71\t          botUrl: `https://t.me/${telegramBotUsername}`,\n72\t          communityUrl: communityInviteUrl ?? null,\n73\t        });\n74\t      }\n75\t\n76\t      const token = randomBytes(32).toString(\"hex\");\n77\t      const expiresAt = new Date(Date.now() + linkTokenTtlSeconds * 1000);\n78\t\n79\t      await db.generateLinkToken(userId, token, expiresAt);\n80\t"}]},"parent_tool_use_id":null,"session_id":"d389cde2-b9da-44f3-bb5b-97934b5b5fad","uuid":"b879f17c-2562-4d54-9e59-59f8034b7f73","timestamp":"2026-04-22T11:38:31.936Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/telegram-link.ts","content":"/**\n * Telegram link routes — generate deep-link tokens and redeem them.\n *\n * POST /generate-link — JWT required. Returns a one-time deep-link token.\n * All other endpoints use service-auth via X-Telegram-Webhook-Secret header.\n *\n * WAITLIST-CONTRACT: the waitlist calls POST /generate-link\n * (`waitlist/src/components/TelegramCard.tsx`) and branches on both\n * `alreadyLinked: true` and `deepLink` payloads. This file is plain Hono\n * (no OpenAPI schema), so the response shape is locked by handler invocation\n * in `__tests__/waitlist-contract.test.ts` — updating either response branch\n * requires updating that test AND the waitlist consumer in the same change.\n */\n\nimport { randomBytes } from \"node:crypto\";\nimport { Hono } from \"hono\";\nimport { createMiddleware } from \"hono/factory\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { ok, err } from \"../contracts/api-envelope.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n\nexport interface TelegramLinkRoutesDeps {\n  db: Db;\n  telegramBotUsername: string;\n  telegramWebhookSecret: string;\n  communityInviteUrl: string | undefined;\n  linkTokenTtlSeconds: number;\n}\n\nexport function createTelegramLinkRoutes(deps: TelegramLinkRoutesDeps) {\n  const { db, telegramBotUsername, telegramWebhookSecret, communityInviteUrl, linkTokenTtlSeconds } = deps;\n  const app = new Hono<AppEnv>();\n\n  // Service-auth middleware for bot-facing endpoints\n  const serviceAuth = createMiddleware(async (c, next) => {\n    if (c.req.header(\"X-Telegram-Webhook-Secret\") !== telegramWebhookSecret) {\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.AUTH_REQUIRED,\n        \"Missing or invalid service secret\",\n      );\n    }\n    return next();\n  });\n\n  // -------------------------------------------------------------------------\n  // POST /generate-link — JWT required\n  // -------------------------------------------------------------------------\n  app.post(\"/generate-link\", async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.AUTH_REQUIRED,\n        \"Authentication required\",\n      );\n    }\n\n    try {\n      const existing = await db.getActiveLink(userId);\n      if (existing) {\n        return ok(c, {\n          alreadyLinked: true as const,\n          telegramUserId: existing.telegram_user_id,\n          telegramUsername: existing.telegram_username,\n          linkedAt: existing.redeemed_at?.toISOString() ?? null,\n          botUrl: `https://t.me/${telegramBotUsername}`,\n          communityUrl: communityInviteUrl ?? null,\n        });\n      }\n\n      const token = randomBytes(32).toString(\"hex\");\n      const expiresAt = new Date(Date.now() + linkTokenTtlSeconds * 1000);\n\n      await db.generateLinkToken(userId, token, expiresAt);\n","numLines":80,"startLine":1,"totalLines":308}}}
