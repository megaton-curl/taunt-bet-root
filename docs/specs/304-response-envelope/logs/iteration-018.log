{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VoZtaT6o2bXM3wRUCn9ggE","type":"tool_result","content":"1\t/**\n2\t * Price routes — cached SOL/USD price from Pyth Hermes.\n3\t */\n4\t\n5\timport { createRoute } from \"@hono/zod-openapi\";\n6\timport { HermesClient } from \"@pythnetwork/hermes-client\";\n7\timport { errorMessage } from \"../contracts/api-errors.js\";\n8\timport { logger } from \"../logger.js\";\n9\timport { PriceResponseSchema, ErrorResponseSchema } from \"../contracts/validators.js\";\n10\timport { createOpenApiApp } from \"../openapi/hono.js\";\n11\t\n12\t// SOL/USD Pyth feed ID (same on mainnet + devnet)\n13\tconst SOL_USD_FEED_ID =\n14\t  \"0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d\";\n15\t\n16\tconst CACHE_TTL_MS = 60_000; // 60 seconds\n17\t\n18\tinterface CachedPrice {\n19\t  price: number;\n20\t  updatedAt: string;\n21\t  fetchedAt: number; // Date.now() for TTL check\n22\t}\n23\t\n24\tlet cached: CachedPrice | null = null;\n25\t\n26\tconst client = new HermesClient(\"https://hermes.pyth.network\", {});\n27\t\n28\texport async function fetchSolPrice(): Promise<CachedPrice | null> {\n29\t  // Return cached if still fresh\n30\t  if (cached && Date.now() - cached.fetchedAt < CACHE_TTL_MS) {\n31\t    return cached;\n32\t  }\n33\t\n34\t  try {\n35\t    const updates = await client.getLatestPriceUpdates([SOL_USD_FEED_ID], {\n36\t      encoding: \"base64\",\n37\t      parsed: true,\n38\t    });\n39\t    const feed = updates.parsed?.[0];\n40\t    if (!feed?.price) return cached; // stale cache better than nothing\n41\t\n42\t    const price = Number(feed.price.price) * Math.pow(10, feed.price.expo);\n43\t    const updatedAt = new Date(feed.price.publish_time * 1000).toISOString();\n44\t\n45\t    cached = { price, updatedAt, fetchedAt: Date.now() };\n46\t    return cached;\n47\t  } catch (err) {\n48\t    logger.warn(\"hermes: SOL/USD fetch failed\", {\n49\t      error: err instanceof Error ? err.message : String(err),\n50\t    });\n51\t    return cached; // return stale cache on error\n52\t  }\n53\t}\n54\t\n55\tconst solUsdRoute = createRoute({\n56\t  method: \"get\",\n57\t  path: \"/sol-usd\",\n58\t  tags: [\"Price\"],\n59\t  summary: \"Get cached SOL/USD price\",\n60\t  responses: {\n61\t    200: {\n62\t      content: { \"application/json\": { schema: PriceResponseSchema } },\n63\t      description: \"Price data\",\n64\t    },\n65\t    503: {\n66\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n67\t      description: \"Price unavailable\",\n68\t    },\n69\t  },\n70\t});\n71\t\n72\texport function createPriceRoutes() {\n73\t  const app = createOpenApiApp();\n74\t\n75\t  app.openapi(solUsdRoute, async (c) => {\n76\t    const result = await fetchSolPrice();\n77\t    if (!result) {\n78\t      return c.json(errorMessage(\"Price unavailable\"), 503);\n79\t    }\n80\t    return c.json({\n81\t      price: result.price,\n82\t      updatedAt: result.updatedAt,\n83\t    }, 200);\n84\t  });\n85\t\n86\t  return app;\n87\t}\n88\t"}]},"parent_tool_use_id":null,"session_id":"e1f2b82f-71d7-453b-a3f1-507c397497df","uuid":"f58d2c95-a4f5-4bcf-ac2e-a90f6649e1ef","timestamp":"2026-04-22T10:42:48.660Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/price.ts","content":"/**\n * Price routes — cached SOL/USD price from Pyth Hermes.\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { HermesClient } from \"@pythnetwork/hermes-client\";\nimport { errorMessage } from \"../contracts/api-errors.js\";\nimport { logger } from \"../logger.js\";\nimport { PriceResponseSchema, ErrorResponseSchema } from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\n// SOL/USD Pyth feed ID (same on mainnet + devnet)\nconst SOL_USD_FEED_ID =\n  \"0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d\";\n\nconst CACHE_TTL_MS = 60_000; // 60 seconds\n\ninterface CachedPrice {\n  price: number;\n  updatedAt: string;\n  fetchedAt: number; // Date.now() for TTL check\n}\n\nlet cached: CachedPrice | null = null;\n\nconst client = new HermesClient(\"https://hermes.pyth.network\", {});\n\nexport async function fetchSolPrice(): Promise<CachedPrice | null> {\n  // Return cached if still fresh\n  if (cached && Date.now() - cached.fetchedAt < CACHE_TTL_MS) {\n    return cached;\n  }\n\n  try {\n    const updates = await client.getLatestPriceUpdates([SOL_USD_FEED_ID], {\n      encoding: \"base64\",\n      parsed: true,\n    });\n    const feed = updates.parsed?.[0];\n    if (!feed?.price) return cached; // stale cache better than nothing\n\n    const price = Number(feed.price.price) * Math.pow(10, feed.price.expo);\n    const updatedAt = new Date(feed.price.publish_time * 1000).toISOString();\n\n    cached = { price, updatedAt, fetchedAt: Date.now() };\n    return cached;\n  } catch (err) {\n    logger.warn(\"hermes: SOL/USD fetch failed\", {\n      error: err instanceof Error ? err.message : String(err),\n    });\n    return cached; // return stale cache on error\n  }\n}\n\nconst solUsdRoute = createRoute({\n  method: \"get\",\n  path: \"/sol-usd\",\n  tags: [\"Price\"],\n  summary: \"Get cached SOL/USD price\",\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: PriceResponseSchema } },\n      description: \"Price data\",\n    },\n    503: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Price unavailable\",\n    },\n  },\n});\n\nexport function createPriceRoutes() {\n  const app = createOpenApiApp();\n\n  app.openapi(solUsdRoute, async (c) => {\n    const result = await fetchSolPrice();\n    if (!result) {\n      return c.json(errorMessage(\"Price unavailable\"), 503);\n    }\n    return c.json({\n      price: result.price,\n      updatedAt: result.updatedAt,\n    }, 200);\n  });\n\n  return app;\n}\n","numLines":88,"startLine":1,"totalLines":88}}}
