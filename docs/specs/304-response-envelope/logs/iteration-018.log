 updatedAt = new Date(feed.price.publish_time * 1000).toISOString();\n\n    cached = { price, updatedAt, fetchedAt: Date.now() };\n    return cached;\n  } catch (fetchError) {\n    logger.warn(\"hermes: SOL/USD fetch failed\", {\n      error: fetchError instanceof Error ? fetchError.message : String(fetchError),\n    });\n    return cached; // return stale cache on error\n  }\n}\n\nconst solUsdRoute = createRoute({\n  method: \"get\",\n  path: \"/sol-usd\",\n  tags: [\"Price\"],\n  summary: \"Get cached SOL/USD price\",\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(PriceResponseSchema) } },\n      description: \"Price data\",\n    },\n    503: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Price unavailable\",\n    },\n  },\n});\n\nexport function createPriceRoutes() {\n  const app = createOpenApiApp();\n\n  app.openapi(solUsdRoute, async (c) => {\n    const result = await fetchSolPrice();\n    if (!result) {\n      return err(\n        c,\n        503,\n        API_ERROR_CODES.PRICE_UNAVAILABLE,\n        \"Price unavailable\",\n        { retryable: true },\n      );\n    }\n    return ok(c, {\n      price: result.price,\n      updatedAt: result.updatedAt,\n    });\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":4,"oldLines":9,"newStart":4,"newLines":15,"lines":[" "," import { createRoute } from \"@hono/zod-openapi\";"," import { HermesClient } from \"@pythnetwork/hermes-client\";","-import { errorMessage } from \"../contracts/api-errors.js\";","+import { API_ERROR_CODES } from \"../contracts/api-errors.js\";","+import {","+  envelope,","+  err,","+  ok,","+  ErrorEnvelopeSchema,","+} from \"../contracts/api-envelope.js\";"," import { logger } from \"../logger.js\";","-import { PriceResponseSchema, ErrorResponseSchema } from \"../contracts/validators.js\";","+import { PriceResponseSchema } from \"../contracts/validators.js\";"," import { createOpenApiApp } from \"../openapi/hono.js\";"," "," // SOL/USD Pyth feed ID (same on mainnet + devnet)"]},{"oldStart":44,"oldLines":9,"newStart":50,"newLines":9,"lines":[" ","     cached = { price, updatedAt, fetchedAt: Date.now() };","     return cached;","-  } catch (err) {","+  } catch (fetchError) {","     logger.warn(\"hermes: SOL/USD fetch failed\", {","-      error: err instanceof Error ? err.message : String(err),","+      error: fetchError instanceof Error ? fetchError.message : String(fetchError),","     });","     return cached; // return stale cache on error","   }"]},{"oldStart":59,"oldLines":11,"newStart":65,"newLines":11,"lines":["   summary: \"Get cached SOL/USD price\",","   responses: {","     200: {","-      content: { \"application/json\": { schema: PriceResponseSchema } },","+      content: { \"application/json\": { schema: envelope(PriceResponseSchema) } },","       description: \"Price data\",","     },","     503: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Price unavailable\",","     },","   },"]},{"oldStart":75,"oldLines":12,"newStart":81,"newLines":18,"lines":["   app.openapi(solUsdRoute, async (c) => {","     const result = await fetchSolPrice();","     if (!result) {","-      return c.json(errorMessage(\"Price unavailable\"), 503);","+      return err(","+        c,","+        503,","+        API_ERROR_CODES.PRICE_UNAVAILABLE,","+        \"Price unavailable\",","+        { retryable: true },","+      );","     }","-    return c.json({","+    return ok(c, {","       price: result.price,","       updatedAt: result.updatedAt,","-    }, 200);","+    });","   });"," ","   return app;"]}],"originalFile":"/**\n * Price routes — cached SOL/USD price from Pyth Hermes.\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { HermesClient } from \"@pythnetwork/hermes-client\";\nimport { errorMessage } from \"../contracts/api-errors.js\";\nimport { logger } from \"../logger.js\";\nimport { PriceResponseSchema, ErrorResponseSchema } from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\n// SOL/USD Pyth feed ID (same on mainnet + devnet)\nconst SOL_USD_FEED_ID =\n  \"0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d\";\n\nconst CACHE_TTL_MS = 60_000; // 60 seconds\n\ninterface CachedPrice {\n  price: number;\n  updatedAt: string;\n  fetchedAt: number; // Date.now() for TTL check\n}\n\nlet cached: CachedPrice | null = null;\n\nconst client = new HermesClient(\"https://hermes.pyth.network\", {});\n\nexport async function fetchSolPrice(): Promise<CachedPrice | null> {\n  // Return cached if still fresh\n  if (cached && Date.now() - cached.fetchedAt < CACHE_TTL_MS) {\n    return cached;\n  }\n\n  try {\n    const updates = await client.getLatestPriceUpdates([SOL_USD_FEED_ID], {\n      encoding: \"base64\",\n      parsed: true,\n    });\n    const feed = updates.parsed?.[0];\n    if (!feed?.price) return cached; // stale cache better than nothing\n\n    const price = Number(feed.price.price) * Math.pow(10, feed.price.expo);\n    const updatedAt = new Date(feed.price.publish_time * 1000).toISOString();\n\n    cached = { price, updatedAt, fetchedAt: Date.now() };\n    return cached;\n  } catch (err) {\n    logger.warn(\"hermes: SOL/USD fetch failed\", {\n      error: err instanceof Error ? err.message : String(err),\n    });\n    return cached; // return stale cache on error\n  }\n}\n\nconst solUsdRoute = createRoute({\n  method: \"get\",\n  path: \"/sol-usd\",\n  tags: [\"Price\"],\n  summary: \"Get cached SOL/USD price\",\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: PriceResponseSchema } },\n      description: \"Price data\",\n    },\n    503: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Price unavailable\",\n    },\n  },\n});\n\nexport function createPriceRoutes() {\n  const app = createOpenApiApp();\n\n  app.openapi(solUsdRoute, async (c) => {\n    const result = await fetchSolPrice();\n    if (!result) {\n      return c.json(errorMessage(\"Price unavailable\"), 503);\n    }\n    return c.json({\n      price: result.price,\n      updatedAt: result.updatedAt,\n    }, 200);\n  });\n\n  return app;\n}\n","userModified":false}}
