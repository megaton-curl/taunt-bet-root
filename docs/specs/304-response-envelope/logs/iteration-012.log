{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01QLiz98mQj8voKG2qBf3Jmk","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011FubBRfeyL1ogP3uxSUVZ6","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/src/routes/potshot-create.ts","content":"/**\n * Pot Shot routes.\n *\n * GET  /pot-shot/current        — active round state\n * POST /pot-shot/create         — create a new round\n * GET  /pot-shot/history        — recent settled rounds\n * GET  /pot-shot/by-id/:matchId — lookup by match ID\n * GET  /pot-shot/verify/:pda    — lookup by PDA with verification data\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\nimport { computeCommitment, generateMatchId, generateSecret } from \"../fairness.js\";\nimport { buildCreateLordRoundTx, deriveLordRoundPda } from \"../tx-builder.js\";\nimport type { Db, Round, OperatorEvent } from \"../db.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport { logger } from \"../logger.js\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { PdaWatcher } from \"../worker/pda-watcher.js\";\nimport { decodeLordRound, type DecodedPotShotRound } from \"../worker/account-decoder.js\";\nimport {\n  PotShotCreateResponseSchema,\n  PotShotRoundResponseSchema,\n  PotShotRoundSchema,\n  RoundEntrySchema,\n  listEnvelopeResponseSchema,\n  roundEnvelopeResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface LordCreateRoutesDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  pdaWatcher?: PdaWatcher;\n}\n\nconst MIN_WAGER_LAMPORTS = 1_000_000;\n\nfunction isValidBase58(s: string): boolean {\n  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n}\n\nconst PHASE_NAMES = [\"waiting\", \"active\", \"locked\", \"resolving\", \"settled\", \"refunded\"] as const;\nconst DB_PHASE_TO_POTSHOT_PHASE = {\n  created: \"waiting\",\n  locked: \"locked\",\n  settling: \"resolving\",\n  settled: \"settled\",\n  expired: \"refunded\",\n} as const;\n\ntype RoundEntry = z.infer<typeof RoundEntrySchema>;\ntype PotShotCurrentRoundResponse = z.infer<typeof PotShotRoundSchema>;\ntype PotShotRoundResponse = z.infer<typeof PotShotRoundResponseSchema>;\n\nfunction formatLordRound(\n  round: DecodedPotShotRound,\n  pda: PublicKey,\n  dbRound: { match_id: string; commitment: Buffer; phase: string } | undefined,\n): PotShotCurrentRoundResponse {\n  const entries = round.entries.map((e) => ({\n    player: e.player.toBase58(),\n    amountLamports: Number(e.amountLamports),\n  }));\n\n  return {\n    matchId: dbRound?.match_id ?? Buffer.from(round.matchId).toString(\"hex\"),\n    pda: pda.toBase58(),\n    phase: PHASE_NAMES[round.phase] ?? \"waiting\",\n    creator: round.creator.toBase58(),\n    commitment: dbRound\n      ? dbRound.commitment.toString(\"hex\")\n      : Buffer.from(round.commitment).toString(\"hex\"),\n    entries,\n    totalAmountLamports: Number(round.totalAmountLamports),\n    distinctPlayers: round.distinctPlayers,\n    countdownStartedAt: Number(round.countdownStartedAt) > 0\n      ? Number(round.countdownStartedAt)\n      : null,\n    countdownEndsAt: Number(round.countdownEndsAt) > 0\n      ? Number(round.countdownEndsAt)\n      : null,\n    createdAt: new Date(Number(round.createdAt) * 1000).toISOString(),\n  };\n}\n\n// ── Request schemas ──────────────────────────────────────────────────────\n\nconst PotShotCreateBodySchema = z.object({\n  wallet: z.string(),\n  amountLamports: z.number().int().min(MIN_WAGER_LAMPORTS),\n});\n\nconst LimitQuerySchema = z.object({\n  limit: z.string().optional(),\n});\n\nconst MatchIdParamSchema = z.object({\n  matchId: z.string(),\n});\n\nconst PdaParamSchema = z.object({\n  pda: z.string(),\n});\n\n// ── Route definitions ────────────────────────────────────────────────────\n\nconst PotShotCurrentResponseSchema = roundEnvelopeResponseSchema(\n  \"round\",\n  PotShotRoundSchema,\n  { nullable: true },\n);\n\nconst PotShotHistoryResponseSchema = listEnvelopeResponseSchema(\n  \"rounds\",\n  PotShotRoundResponseSchema,\n);\n\nconst currentRoute = createRoute({\n  method: \"get\",\n  path: \"/current\",\n  tags: [\"PotShot\"],\n  summary: \"Get active Pot Shot round\",\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: envelope(PotShotCurrentResponseSchema),\n        },\n      },\n      description: \"Active round or null\",\n    },\n  },\n});\n\nconst createRoundRoute = createRoute({\n  method: \"post\",\n  path: \"/create\",\n  tags: [\"PotShot\"],\n  summary: \"Create a new Pot Shot round\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": { schema: PotShotCreateBodySchema },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(PotShotCreateResponseSchema) } },\n      description: \"Round created successfully\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid wallet format\",\n    },\n    403: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Wallet mismatch with authenticated session\",\n    },\n    409: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Round already active or ID collision\",\n    },\n    422: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid request body\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Transaction build failed\",\n    },\n  },\n});\n\nconst psHistoryRoute = createRoute({\n  method: \"get\",\n  path: \"/history\",\n  tags: [\"PotShot\"],\n  summary: \"Get recent settled Pot Shot rounds\",\n  request: {\n    query: LimitQuerySchema,\n  },\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: envelope(PotShotHistoryResponseSchema),\n        },\n      },\n      description: \"List of settled rounds\",\n    },\n  },\n});\n\nconst psByIdRoute = createRoute({\n  method: \"get\",\n  path: \"/by-id/{matchId}\",\n  tags: [\"PotShot\"],\n  summary: \"Lookup Pot Shot round by ID\",\n  request: {\n    params: MatchIdParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(PotShotRoundResponseSchema) } },\n      description: \"Round found\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid match ID format\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Round not found\",\n    },\n  },\n});\n\nconst psVerifyRoute = createRoute({\n  method: \"get\",\n  path: \"/verify/{pda}\",\n  tags: [\"PotShot\"],\n  summary: \"Lookup Pot Shot round by PDA with verification data\",\n  request: {\n    params: PdaParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(PotShotRoundResponseSchema) } },\n      description: \"Round verification data\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Round not found\",\n    },\n  },\n});\n\n// ── Factory ──────────────────────────────────────────────────────────────\n\nexport function createPotShotRoutes(deps: LordCreateRoutesDeps) {\n  const { db, connection, serverKeypair, pdaWatcher } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // GET /current — return the single active lord round (if any)\n  app.openapi(currentRoute, async (c) => {\n    try {\n      // Query DB for any lord round not in a terminal phase\n      const [created, locked, settling] = await Promise.all([\n        db.getRoundsByPhase(\"created\"),\n        db.getRoundsByPhase(\"locked\"),\n        db.getRoundsByPhase(\"settling\"),\n      ]);\n\n      // Sort ASC (oldest first) — if a race condition created two rounds,\n      // the first one gets played to completion before the second surfaces.\n      const activeDbRound = [...created, ...locked, ...settling]\n        .filter((r) => r.game === \"potshot\")\n        .sort((a, b) => a.created_at.getTime() - b.created_at.getTime())[0];\n\n      if (!activeDbRound) {\n        return ok(c, { round: null });\n      }\n\n      // Fetch the on-chain account to get current entries/pool state\n      const roundPda = new PublicKey(activeDbRound.pda);\n      try {\n        const accountInfo = await connection.getAccountInfo(roundPda);\n        if (accountInfo) {\n          const decoded = decodeLordRound(Buffer.from(accountInfo.data));\n          return ok(c, {\n            round: formatLordRound(decoded, roundPda, activeDbRound),\n          });\n        }\n      } catch (fetchError) {\n        logger.warn(\"lord current: on-chain fetch failed, returning DB-only\", {\n          pda: activeDbRound.pda,\n          error: fetchError instanceof Error ? fetchError.message : String(fetchError),\n        });\n      }\n\n      // Fallback: return DB data without on-chain enrichment\n      return ok(c, {\n        round: {\n          matchId: activeDbRound.match_id,\n          pda: activeDbRound.pda,\n          phase: DB_PHASE_TO_POTSHOT_PHASE[activeDbRound.phase],\n          creator: activeDbRound.creator,\n          commitment: activeDbRound.commitment.toString(\"hex\"),\n          entries: [],\n          totalAmountLamports: activeDbRound.amount_lamports,\n          distinctPlayers: 1,\n          countdownStartedAt: null,\n          countdownEndsAt: null,\n          createdAt: activeDbRound.created_at.toISOString(),\n        },\n      });\n    } catch (queryError) {\n      logger.error(\"lord current: query failed\", {\n        error: queryError instanceof Error ? queryError.message : String(queryError),\n      });\n      return ok(c, { round: null });\n    }\n  });\n\n  // POST /create\n  app.openapi(createRoundRoute, async (c) => {\n    const body = c.req.valid(\"json\");\n\n    // Additional validation: base58 format\n    if (!isValidBase58(body.wallet)) {\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"wallet must be a valid base58 public key\",\n        { retryable: false },\n      );\n    }\n\n    const userId = c.get(\"userId\");\n    const profile = userId ? await db.getProfileByUserId(userId) : null;\n    if (profile && body.wallet !== profile.wallet) {\n      return err(\n        c,\n        403,\n        API_ERROR_CODES.FORBIDDEN,\n        \"Wallet does not match authenticated session\",\n        { retryable: false },\n      );\n    }\n\n    // Single active round check: reject if a lord round is already in progress\n    const [created, locked, settling] = await Promise.all([\n      db.getRoundsByPhase(\"created\"),\n      db.getRoundsByPhase(\"locked\"),\n      db.getRoundsByPhase(\"settling\"),\n    ]);\n    const activeRound = [...created, ...locked, ...settling].find(\n      (r) => r.game === \"potshot\",\n    );\n    if (activeRound) {\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.CONFLICT,\n        \"A round is already active\",\n        {\n          retryable: false,\n          details: {\n            activeRound: {\n              matchId: activeRound.match_id,\n              pda: activeRound.pda,\n            },\n          },\n        },\n      );\n    }\n\n    let creatorPubkey: PublicKey;\n    try {\n      creatorPubkey = new PublicKey(body.wallet);\n    } catch {\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"wallet is not a valid public key\",\n        { retryable: false },\n      );\n    }\n\n    const secret = generateSecret();\n    const commitment = computeCommitment(secret);\n    const matchId = generateMatchId();\n    const matchIdHex = matchId.toString(\"hex\");\n    const [roundPda] = deriveLordRoundPda(matchId);\n    const roundPdaStr = roundPda.toBase58();\n\n    const existing = await db.getRoundByPda(roundPdaStr);\n    if (existing) {\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.CONFLICT,\n        \"Round ID collision — please retry\",\n        { retryable: true },\n      );\n    }\n\n    let transaction: string;\n    let lastValidBlockHeight: number;\n    try {\n      const result = await buildCreateLordRoundTx({\n        connection,\n        creator: creatorPubkey,\n        serverKeypair,\n        commitment,\n        amountLamports: body.amountLamports,\n        matchId,\n      });\n      transaction = result.transaction;\n      lastValidBlockHeight = result.lastValidBlockHeight;\n    } catch (buildError) {\n      logger.error(\"lord create failed: transaction build error\", {\n        wallet: body.wallet,\n        roundPda: roundPdaStr,\n        error: buildError instanceof Error ? buildError.message : \"Failed to build transaction\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to build transaction\",\n      );\n    }\n\n    try {\n      await db.insertRound({\n        pda: roundPdaStr,\n        game: \"potshot\",\n        creator: body.wallet,\n        serverKey: serverKeypair.publicKey.toBase58(),\n        secret,\n        commitment,\n        amountLamports: body.amountLamports,\n        side: 0,\n        matchId: matchIdHex,\n        phase: \"created\",\n      });\n    } catch (insertError) {\n      if (insertError instanceof Error && insertError.message.includes(\"duplicate\")) {\n        return err(\n          c,\n          409,\n          API_ERROR_CODES.CONFLICT,\n          \"Round ID collision — please retry\",\n          { retryable: true },\n        );\n      }\n      throw insertError;\n    }\n\n    // Write participation-time game entry\n    try {\n      if (profile) {\n        await db.upsertGameEntry({\n          userId: profile.user_id,\n          wallet: body.wallet,\n          game: \"potshot\",\n          roundPda: roundPdaStr,\n          matchId: matchIdHex,\n          amountLamports: body.amountLamports,\n        });\n      }\n    } catch (entryError) {\n      logger.warn(\"lord create: game_entry insert failed\", {\n        error: entryError instanceof Error ? entryError.message : String(entryError),\n      });\n    }\n\n    await db.insertOperatorEvent(roundPdaStr, \"secret_generated\", {\n      creator: body.wallet,\n      amountLamports: body.amountLamports,\n      matchId: matchIdHex,\n      game: \"potshot\",\n    });\n\n    // Subscribe to PDA for instant join/countdown detection via WebSocket\n    pdaWatcher?.watch(roundPdaStr);\n\n    return ok(c, {\n      transaction,\n      roundPda: roundPdaStr,\n      matchId: matchIdHex,\n      commitment: commitment.toString(\"hex\"),\n      lastValidBlockHeight,\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /history — recent settled Pot Shot rounds\n  // -----------------------------------------------------------------------\n\n  app.openapi(psHistoryRoute, async (c) => {\n    const { limit: limitParam } = c.req.valid(\"query\");\n    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 50);\n\n    const rounds = await db.getRecentSettledRounds(\"potshot\", limit);\n    const settleEvents = await db.getLatestOperatorEventsForPdas(\n      rounds.map((r) => r.pda),\n      \"settle_confirmed\",\n    );\n\n    return ok(c, {\n      rounds: rounds.map((r) => formatPotShotRound(r, settleEvents.get(r.pda))),\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /by-id/:matchId — lookup by 16-char hex match ID\n  // -----------------------------------------------------------------------\n\n  app.openapi(psByIdRoute, async (c) => {\n    const { matchId } = c.req.valid(\"param\");\n    if (!/^[0-9a-f]{16}$/i.test(matchId)) {\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"matchId must be a 16-char hex string\",\n        { retryable: false },\n      );\n    }\n\n    const round = await db.getRoundByMatchId(matchId.toLowerCase());\n    if (!round || round.game !== \"potshot\") {\n      return err(c, 404, API_ERROR_CODES.ROUND_NOT_FOUND, \"Round not found\");\n    }\n\n    return ok(c, await enrichPotShotRound(db, round));\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /verify/:pda — lookup by PDA with full verification data\n  // -----------------------------------------------------------------------\n\n  app.openapi(psVerifyRoute, async (c) => {\n    const { pda } = c.req.valid(\"param\");\n    const round = await db.getRoundByPda(pda);\n    if (!round || round.game !== \"potshot\") {\n      return err(c, 404, API_ERROR_CODES.ROUND_NOT_FOUND, \"Round not found\");\n    }\n\n    return ok(c, await enrichPotShotRound(db, round));\n  });\n\n  return app;\n}\n\n// ---------------------------------------------------------------------------\n// Pot Shot response formatting\n// ---------------------------------------------------------------------------\n\nfunction getEventPayload(event: OperatorEvent | undefined): Record<string, unknown> | null {\n  if (!event || typeof event.payload !== \"object\" || event.payload === null) return null;\n  return event.payload as Record<string, unknown>;\n}\n\nfunction getNullableString(value: unknown): string | null | undefined {\n  if (value === null) return null;\n  return typeof value === \"string\" ? value : undefined;\n}\n\nfunction getNullableInt(value: unknown): number | null | undefined {\n  if (value === null) return null;\n  return typeof value === \"number\" && Number.isInteger(value) ? value : undefined;\n}\n\nfunction getRoundEntries(value: unknown): RoundEntry[] | undefined {\n  const parsed = z.array(RoundEntrySchema).safeParse(value);\n  return parsed.success ? parsed.data : undefined;\n}\n\nfunction formatPotShotRound(round: Round, settleEvent?: OperatorEvent): PotShotRoundResponse {\n  const isSettled = round.phase === \"settled\";\n  const settlePayload = getEventPayload(settleEvent);\n\n  const response: PotShotRoundResponse = {\n    pda: round.pda,\n    game: \"pot-shot\",\n    phase: round.phase,\n    creator: round.creator,\n    commitment: round.commitment.toString(\"hex\"),\n    amountLamports: round.amount_lamports,\n    side: round.side,\n    matchId: round.match_id,\n    createdAt: round.created_at.toISOString(),\n    updatedAt: round.updated_at.toISOString(),\n  };\n\n  if (round.target_slot !== null) {\n    response.targetSlot = Number(round.target_slot);\n  }\n\n  if (isSettled) {\n    response.secret = round.secret.toString(\"hex\");\n    response.resultHash = round.result_hash ? round.result_hash.toString(\"hex\") : null;\n    if (round.result_side !== null) {\n      response.winningEntryIndex = round.result_side;\n    }\n    if (round.winner) {\n      response.winner = round.winner;\n    }\n    if (round.settle_tx) {\n      response.settleTx = round.settle_tx;\n    }\n    response.totalAmountLamports = round.amount_lamports;\n    response.verification = {\n      commitmentCheck: \"sha256(secret) == commitment\",\n      resultFormula: \"sha256(secret || entropy || pda || algorithmVersion)\",\n      entropySource: \"SlotHashes sysvar at target_slot\",\n    };\n\n    if (Array.isArray(round.entries)) {\n      response.entries = round.entries;\n    }\n\n    if (settlePayload) {\n      const entries = getRoundEntries(settlePayload.entries);\n      const entropy = getNullableString(settlePayload.entropy);\n      const payoutAmount = getNullableInt(settlePayload.payoutAmount);\n      const feeAmount = getNullableInt(settlePayload.feeAmount);\n      const winningOffset = getNullableString(settlePayload.winningOffset);\n      const totalAmountLamports = getNullableInt(settlePayload.totalAmountLamports);\n      const rentRefund = getNullableInt(settlePayload.rentRefund);\n\n      if (!response.entries && entries) {\n        response.entries = entries;\n      }\n      if (entropy !== undefined) {\n        response.entropy = entropy;\n      }\n      if (payoutAmount !== undefined) {\n        response.payoutAmount = payoutAmount;\n      }\n      if (feeAmount !== undefined) {\n        response.feeAmount = feeAmount;\n      }\n      if (winningOffset !== undefined) {\n        response.winningOffset = winningOffset;\n      }\n      if (totalAmountLamports !== undefined) {\n        response.totalAmountLamports = totalAmountLamports;\n      }\n      if (rentRefund !== undefined) {\n        response.rentRefund = rentRefund;\n      }\n    }\n  }\n\n  return response;\n}\n\nasync function enrichPotShotRound(db: Db, round: Round) {\n  let settleEvent: OperatorEvent | undefined;\n  if (round.phase === \"settled\") {\n    try {\n      settleEvent = await db.getLatestOperatorEvent(round.pda, \"settle_confirmed\");\n    } catch {\n      // Gracefully degrade\n    }\n  }\n  return formatPotShotRound(round, settleEvent);\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2214,"cache_read_input_tokens":111791,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2214},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"32e06d79-d550-426e-9fdd-421cb060dd82","uuid":"09327ae1-7c99-41de-9ddb-6b241991e4a4"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011FubBRfeyL1ogP3uxSUVZ6","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/src/routes/potshot-create.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"32e06d79-d550-426e-9fdd-421cb060dd82","uuid":"94d468a9-dda5-47c5-bdb7-75078dce6fa4","timestamp":"2026-04-22T10:21:24.422Z","tool_use_result":{"type":"update","filePath":"/workspaces/rng-utopia/backend/src/routes/potshot-create.ts","content":"/**\n * Pot Shot routes.\n *\n * GET  /pot-shot/current        — active round state\n * POST /pot-shot/create         — create a new round\n * GET  /pot-shot/history        — recent settled rounds\n * GET  /pot-shot/by-id/:matchId — lookup by match ID\n * GET  /pot-shot/verify/:pda    — lookup by PDA with verification data\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\nimport { computeCommitment, generateMatchId, generateSecret } from \"../fairness.js\";\nimport { buildCreateLordRoundTx, deriveLordRoundPda } from \"../tx-builder.js\";\nimport type { Db, Round, OperatorEvent } from \"../db.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport { logger } from \"../logger.js\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { PdaWatcher } from \"../worker/pda-watcher.js\";\nimport { decodeLordRound, type DecodedPotShotRound } from \"../worker/account-decoder.js\";\nimport {\n  PotShotCreateResponseSchema,\n  PotShotRoundResponseSchema,\n  PotShotRoundSchema,\n  RoundEntrySchema,\n  listEnvelopeResponseSchema,\n  roundEnvelopeResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface LordCreateRoutesDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  pdaWatcher?: PdaWatcher;\n}\n\nconst MIN_WAGER_LAMPORTS = 1_000_000;\n\nfunction isValidBase58(s: string): boolean {\n  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n}\n\nconst PHASE_NAMES = [\"waiting\", \"active\", \"locked\", \"resolving\", \"settled\", \"refunded\"] as const;\nconst DB_PHASE_TO_POTSHOT_PHASE = {\n  created: \"waiting\",\n  locked: \"locked\",\n  settling: \"resolving\",\n  settled: \"settled\",\n  expired: \"refunded\",\n} as const;\n\ntype RoundEntry = z.infer<typeof RoundEntrySchema>;\ntype PotShotCurrentRoundResponse = z.infer<typeof PotShotRoundSchema>;\ntype PotShotRoundResponse = z.infer<typeof PotShotRoundResponseSchema>;\n\nfunction formatLordRound(\n  round: DecodedPotShotRound,\n  pda: PublicKey,\n  dbRound: { match_id: string; commitment: Buffer; phase: string } | undefined,\n): PotShotCurrentRoundResponse {\n  const entries = round.entries.map((e) => ({\n    player: e.player.toBase58(),\n    amountLamports: Number(e.amountLamports),\n  }));\n\n  return {\n    matchId: dbRound?.match_id ?? Buffer.from(round.matchId).toString(\"hex\"),\n    pda: pda.toBase58(),\n    phase: PHASE_NAMES[round.phase] ?? \"waiting\",\n    creator: round.creator.toBase58(),\n    commitment: dbRound\n      ? dbRound.commitment.toString(\"hex\")\n      : Buffer.from(round.commitment).toString(\"hex\"),\n    entries,\n    totalAmountLamports: Number(round.totalAmountLamports),\n    distinctPlayers: round.distinctPlayers,\n    countdownStartedAt: Number(round.countdownStartedAt) > 0\n      ? Number(round.countdownStartedAt)\n      : null,\n    countdownEndsAt: Number(round.countdownEndsAt) > 0\n      ? Number(round.countdownEndsAt)\n      : null,\n    createdAt: new Date(Number(round.createdAt) * 1000).toISOString(),\n  };\n}\n\n// ── Request schemas ──────────────────────────────────────────────────────\n\nconst PotShotCreateBodySchema = z.object({\n  wallet: z.string(),\n  amountLamports: z.number().int().min(MIN_WAGER_LAMPORTS),\n});\n\nconst LimitQuerySchema = z.object({\n  limit: z.string().optional(),\n});\n\nconst MatchIdParamSchema = z.object({\n  matchId: z.string(),\n});\n\nconst PdaParamSchema = z.object({\n  pda: z.string(),\n});\n\n// ── Route definitions ────────────────────────────────────────────────────\n\nconst PotShotCurrentResponseSchema = roundEnvelopeResponseSchema(\n  \"round\",\n  PotShotRoundSchema,\n  { nullable: true },\n);\n\nconst PotShotHistoryResponseSchema = listEnvelopeResponseSchema(\n  \"rounds\",\n  PotShotRoundResponseSchema,\n);\n\nconst currentRoute = createRoute({\n  method: \"get\",\n  path: \"/current\",\n  tags: [\"PotShot\"],\n  summary: \"Get active Pot Shot round\",\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: envelope(PotShotCurrentResponseSchema),\n        },\n      },\n      description: \"Active round or null\",\n    },\n  },\n});\n\nconst createRoundRoute = createRoute({\n  method: \"post\",\n  path: \"/create\",\n  tags: [\"PotShot\"],\n  summary: \"Create a new Pot Shot round\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": { schema: PotShotCreateBodySchema },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(PotShotCreateResponseSchema) } },\n      description: \"Round created successfully\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid wallet format\",\n    },\n    403: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Wallet mismatch with authenticated session\",\n    },\n    409: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Round already active or ID collision\",\n    },\n    422: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid request body\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Transaction build failed\",\n    },\n  },\n});\n\nconst psHistoryRoute = createRoute({\n  method: \"get\",\n  path: \"/history\",\n  tags: [\"PotShot\"],\n  summary: \"Get recent settled Pot Shot rounds\",\n  request: {\n    query: LimitQuerySchema,\n  },\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: envelope(PotShotHistoryResponseSchema),\n        },\n      },\n      description: \"List of settled rounds\",\n    },\n  },\n});\n\nconst psByIdRoute = createRoute({\n  method: \"get\",\n  path: \"/by-id/{matchId}\",\n  tags: [\"PotShot\"],\n  summary: \"Lookup Pot Shot round by ID\",\n  request: {\n    params: MatchIdParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(PotShotRoundResponseSchema) } },\n      description: \"Round found\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid match ID format\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Round not found\",\n    },\n  },\n});\n\nconst psVerifyRoute = createRoute({\n  method: \"get\",\n  path: \"/verify/{pda}\",\n  tags: [\"PotShot\"],\n  summary: \"Lookup Pot Shot round by PDA with verification data\",\n  request: {\n    params: PdaParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(PotShotRoundResponseSchema) } },\n      description: \"Round verification data\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Round not found\",\n    },\n  },\n});\n\n// ── Factory ──────────────────────────────────────────────────────────────\n\nexport function createPotShotRoutes(deps: LordCreateRoutesDeps) {\n  const { db, connection, serverKeypair, pdaWatcher } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // GET /current — return the single active lord round (if any)\n  app.openapi(currentRoute, async (c) => {\n    try {\n      // Query DB for any lord round not in a terminal phase\n      const [created, locked, settling] = await Promise.all([\n        db.getRoundsByPhase(\"created\"),\n        db.getRoundsByPhase(\"locked\"),\n        db.getRoundsByPhase(\"settling\"),\n      ]);\n\n      // Sort ASC (oldest first) — if a race condition created two rounds,\n      // the first one gets played to completion before the second surfaces.\n      const activeDbRound = [...created, ...locked, ...settling]\n        .filter((r) => r.game === \"potshot\")\n        .sort((a, b) => a.created_at.getTime() - b.created_at.getTime())[0];\n\n      if (!activeDbRound) {\n        return ok(c, { round: null });\n      }\n\n      // Fetch the on-chain account to get current entries/pool state\n      const roundPda = new PublicKey(activeDbRound.pda);\n      try {\n        const accountInfo = await connection.getAccountInfo(roundPda);\n        if (accountInfo) {\n          const decoded = decodeLordRound(Buffer.from(accountInfo.data));\n          return ok(c, {\n            round: formatLordRound(decoded, roundPda, activeDbRound),\n          });\n        }\n      } catch (fetchError) {\n        logger.warn(\"lord current: on-chain fetch failed, returning DB-only\", {\n          pda: activeDbRound.pda,\n          error: fetchError instanceof Error ? fetchError.message : String(fetchError),\n        });\n      }\n\n      // Fallback: return DB data without on-chain enrichment\n      return ok(c, {\n        round: {\n          matchId: activeDbRound.match_id,\n          pda: activeDbRound.pda,\n          phase: DB_PHASE_TO_POTSHOT_PHASE[activeDbRound.phase],\n          creator: activeDbRound.creator,\n          commitment: activeDbRound.commitment.toString(\"hex\"),\n          entries: [],\n          totalAmountLamports: activeDbRound.amount_lamports,\n          distinctPlayers: 1,\n          countdownStartedAt: null,\n          countdownEndsAt: null,\n          createdAt: activeDbRound.created_at.toISOString(),\n        },\n      });\n    } catch (queryError) {\n      logger.error(\"lord current: query failed\", {\n        error: queryError instanceof Error ? queryError.message : String(queryError),\n      });\n      return ok(c, { round: null });\n    }\n  });\n\n  // POST /create\n  app.openapi(createRoundRoute, async (c) => {\n    const body = c.req.valid(\"json\");\n\n    // Additional validation: base58 format\n    if (!isValidBase58(body.wallet)) {\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"wallet must be a valid base58 public key\",\n        { retryable: false },\n      );\n    }\n\n    const userId = c.get(\"userId\");\n    const profile = userId ? await db.getProfileByUserId(userId) : null;\n    if (profile && body.wallet !== profile.wallet) {\n      return err(\n        c,\n        403,\n        API_ERROR_CODES.FORBIDDEN,\n        \"Wallet does not match authenticated session\",\n        { retryable: false },\n      );\n    }\n\n    // Single active round check: reject if a lord round is already in progress\n    const [created, locked, settling] = await Promise.all([\n      db.getRoundsByPhase(\"created\"),\n      db.getRoundsByPhase(\"locked\"),\n      db.getRoundsByPhase(\"settling\"),\n    ]);\n    const activeRound = [...created, ...locked, ...settling].find(\n      (r) => r.game === \"potshot\",\n    );\n    if (activeRound) {\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.CONFLICT,\n        \"A round is already active\",\n        {\n          retryable: false,\n          details: {\n            activeRound: {\n              matchId: activeRound.match_id,\n              pda: activeRound.pda,\n            },\n          },\n        },\n      );\n    }\n\n    let creatorPubkey: PublicKey;\n    try {\n      creatorPubkey = new PublicKey(body.wallet);\n    } catch {\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"wallet is not a valid public key\",\n        { retryable: false },\n      );\n    }\n\n    const secret = generateSecret();\n    const commitment = computeCommitment(secret);\n    const matchId = generateMatchId();\n    const matchIdHex = matchId.toString(\"hex\");\n    const [roundPda] = deriveLordRoundPda(matchId);\n    const roundPdaStr = roundPda.toBase58();\n\n    const existing = await db.getRoundByPda(roundPdaStr);\n    if (existing) {\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.CONFLICT,\n        \"Round ID collision — please retry\",\n        { retryable: true },\n      );\n    }\n\n    let transaction: string;\n    let lastValidBlockHeight: number;\n    try {\n      const result = await buildCreateLordRoundTx({\n        connection,\n        creator: creatorPubkey,\n        serverKeypair,\n        commitment,\n        amountLamports: body.amountLamports,\n        matchId,\n      });\n      transaction = result.transaction;\n      lastValidBlockHeight = result.lastValidBlockHeight;\n    } catch (buildError) {\n      logger.error(\"lord create failed: transaction build error\", {\n        wallet: body.wallet,\n        roundPda: roundPdaStr,\n        error: buildError instanceof Error ? buildError.message : \"Failed to build transaction\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to build transaction\",\n      );\n    }\n\n    try {\n      await db.insertRound({\n        pda: roundPdaStr,\n        game: \"potshot\",\n        creator: body.wallet,\n        serverKey: serverKeypair.publicKey.toBase58(),\n        secret,\n        commitment,\n        amountLamports: body.amountLamports,\n        side: 0,\n        matchId: matchIdHex,\n        phase: \"created\",\n      });\n    } catch (insertError) {\n      if (insertError instanceof Error && insertError.message.includes(\"duplicate\")) {\n        return err(\n          c,\n          409,\n          API_ERROR_CODES.CONFLICT,\n          \"Round ID collision — please retry\",\n          { retryable: true },\n        );\n      }\n      throw insertError;\n    }\n\n    // Write participation-time game entry\n    try {\n      if (profile) {\n        await db.upsertGameEntry({\n          userId: profile.user_id,\n          wallet: body.wallet,\n          game: \"potshot\",\n          roundPda: roundPdaStr,\n          matchId: matchIdHex,\n          amountLamports: body.amountLamports,\n        });\n      }\n    } catch (entryError) {\n      logger.warn(\"lord create: game_entry insert failed\", {\n        error: entryError instanceof Error ? entryError.message : String(entryError),\n      });\n    }\n\n    await db.insertOperatorEvent(roundPdaStr, \"secret_generated\", {\n      creator: body.wallet,\n      amountLamports: body.amountLamports,\n      matchId: matchIdHex,\n      game: \"potshot\",\n    });\n\n    // Subscribe to PDA for instant join/countdown detection via WebSocket\n    pdaWatcher?.watch(roundPdaStr);\n\n    return ok(c, {\n      transaction,\n      roundPda: roundPdaStr,\n      matchId: matchIdHex,\n      commitment: commitment.toString(\"hex\"),\n      lastValidBlockHeight,\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /history — recent settled Pot Shot rounds\n  // -----------------------------------------------------------------------\n\n  app.openapi(psHistoryRoute, async (c) => {\n    const { limit: limitParam } = c.req.valid(\"query\");\n    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 50);\n\n    const rounds = await db.getRecentSettledRounds(\"potshot\", limit);\n    const settleEvents = await db.getLatestOperatorEventsForPdas(\n      rounds.map((r) => r.pda),\n      \"settle_confirmed\",\n    );\n\n    return ok(c, {\n      rounds: rounds.map((r) => formatPotShotRound(r, settleEvents.get(r.pda))),\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /by-id/:matchId — lookup by 16-char hex match ID\n  // -----------------------------------------------------------------------\n\n  app.openapi(psByIdRoute, async (c) => {\n    const { matchId } = c.req.valid(\"param\");\n    if (!/^[0-9a-f]{16}$/i.test(matchId)) {\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"matchId must be a 16-char hex string\",\n        { retryable: false },\n      );\n    }\n\n    const round = await db.getRoundByMatchId(matchId.toLowerCase());\n    if (!round || round.game !== \"potshot\") {\n      return err(c, 404, API_ERROR_CODES.ROUND_NOT_FOUND, \"Round not found\");\n    }\n\n    return ok(c, await enrichPotShotRound(db, round));\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /verify/:pda — lookup by PDA with full verification data\n  // -----------------------------------------------------------------------\n\n  app.openapi(psVerifyRoute, async (c) => {\n    const { pda } = c.req.valid(\"param\");\n    const round = await db.getRoundByPda(pda);\n    if (!round || round.game !== \"potshot\") {\n      return err(c, 404, API_ERROR_CODES.ROUND_NOT_FOUND, \"Round not found\");\n    }\n\n    return ok(c, await enrichPotShotRound(db, round));\n  });\n\n  return app;\n}\n\n// ---------------------------------------------------------------------------\n// Pot Shot response formatting\n// ---------------------------------------------------------------------------\n\nfunction getEventPayload(event: OperatorEvent | undefined): Record<string, unknown> | null {\n  if (!event || typeof event.payload !== \"object\" || event.payload === null) return null;\n  return event.payload as Record<string, unknown>;\n}\n\nfunction getNullableString(value: unknown): string | null | undefined {\n  if (value === null) return null;\n  return typeof value === \"string\" ? value : undefined;\n}\n\nfunction getNullableInt(value: unknown): number | null | undefined {\n  if (value === null) return null;\n  return typeof value === \"number\" && Number.isInteger(value) ? value : undefined;\n}\n\nfunction getRoundEntries(value: unknown): RoundEntry[] | undefined {\n  const parsed = z.array(RoundEntrySchema).safeParse(value);\n  return parsed.success ? parsed.data : undefined;\n}\n\nfunction formatPotShotRound(round: Round, settleEvent?: OperatorEvent): PotShotRoundResponse {\n  const isSettled = round.phase === \"settled\";\n  const settlePayload = getEventPayload(settleEvent);\n\n  const response: PotShotRoundResponse = {\n    pda: round.pda,\n    game: \"pot-shot\",\n    phase: round.phase,\n    creator: round.creator,\n    commitment: round.commitment.toString(\"hex\"),\n    amountLamports: round.amount_lamports,\n    side: round.side,\n    matchId: round.match_id,\n    createdAt: round.created_at.toISOString(),\n    updatedAt: round.updated_at.toISOString(),\n  };\n\n  if (round.target_slot !== null) {\n    response.targetSlot = Number(round.target_slot);\n  }\n\n  if (isSettled) {\n    response.secret = round.secret.toString(\"hex\");\n    response.resultHash = round.result_hash ? round.result_hash.toString(\"hex\") : null;\n    if (round.result_side !== null) {\n      response.winningEntryIndex = round.result_side;\n    }\n    if (round.winner) {\n      response.winner = round.winner;\n    }\n    if (round.settle_tx) {\n      response.settleTx = round.settle_tx;\n    }\n    response.totalAmountLamports = round.amount_lamports;\n    response.verification = {\n      commitmentCheck: \"sha256(secret) == commitment\",\n      resultFormula: \"sha256(secret || entropy || pda || algorithmVersion)\",\n      entropySource: \"SlotHashes sysvar at target_slot\",\n    };\n\n    if (Array.isArray(round.entries)) {\n      response.entries = round.entries;\n    }\n\n    if (settlePayload) {\n      const entries = getRoundEntries(settlePayload.entries);\n      const entropy = getNullableString(settlePayload.entropy);\n      const payoutAmount = getNullableInt(settlePayload.payoutAmount);\n      const feeAmount = getNullableInt(settlePayload.feeAmount);\n      const winningOffset = getNullableString(settlePayload.winningOffset);\n      const totalAmountLamports = getNullableInt(settlePayload.totalAmountLamports);\n      const rentRefund = getNullableInt(settlePayload.rentRefund);\n\n      if (!response.entries && entries) {\n        response.entries = entries;\n      }\n      if (entropy !== undefined) {\n        response.entropy = entropy;\n      }\n      if (payoutAmount !== undefined) {\n        response.payoutAmount = payoutAmount;\n      }\n      if (feeAmount !== undefined) {\n        response.feeAmount = feeAmount;\n      }\n      if (winningOffset !== undefined) {\n        response.winningOffset = winningOffset;\n      }\n      if (totalAmountLamports !== undefined) {\n        response.totalAmountLamports = totalAmountLamports;\n      }\n      if (rentRefund !== undefined) {\n        response.rentRefund = rentRefund;\n      }\n    }\n  }\n\n  return response;\n}\n\nasync function enrichPotShotRound(db: Db, round: Round) {\n  let settleEvent: OperatorEvent | undefined;\n  if (round.phase === \"settled\") {\n    try {\n      settleEvent = await db.getLatestOperatorEvent(round.pda, \"settle_confirmed\");\n    } catch {\n      // Gracefully degrade\n    }\n  }\n  return formatPotShotRound(round, settleEvent);\n}\n","structuredPatch":[{"oldStart":14,"oldLines":13,"newStart":14,"newLines":18,"lines":[" import { computeCommitment, generateMatchId, generateSecret } from \"../fairness.js\";"," import { buildCreateLordRoundTx, deriveLordRoundPda } from \"../tx-builder.js\";"," import type { Db, Round, OperatorEvent } from \"../db.js\";","-import { errorMessage } from \"../contracts/api-errors.js\";","+import { API_ERROR_CODES } from \"../contracts/api-errors.js\";","+import {","+  envelope,","+  ErrorEnvelopeSchema,","+  ok,","+  err,","+} from \"../contracts/api-envelope.js\";"," import { logger } from \"../logger.js\";"," import type { AppEnv } from \"../hono-env.js\";"," import type { PdaWatcher } from \"../worker/pda-watcher.js\";"," import { decodeLordRound, type DecodedPotShotRound } from \"../worker/account-decoder.js\";"," import {","-  ErrorResponseSchema,","   PotShotCreateResponseSchema,","   PotShotRoundResponseSchema,","   PotShotRoundSchema,"]},{"oldStart":119,"oldLines":17,"newStart":124,"newLines":6,"lines":["   PotShotRoundResponseSchema,"," );"," ","-const PotShotCreateConflictResponseSchema = z.union([","-  ErrorResponseSchema,","-  z.object({","-    error: z.string(),","-    activeRound: z.object({","-      matchId: z.string(),","-      pda: z.string(),","-    }),","-  }),","-]);","-"," const currentRoute = createRoute({","   method: \"get\",","   path: \"/current\","]},{"oldStart":139,"oldLines":7,"newStart":133,"newLines":7,"lines":["     200: {","       content: {","         \"application/json\": {","-          schema: PotShotCurrentResponseSchema,","+          schema: envelope(PotShotCurrentResponseSchema),","         },","       },","       description: \"Active round or null\","]},{"oldStart":163,"oldLines":23,"newStart":157,"newLines":27,"lines":["   },","   responses: {","     200: {","-      content: { \"application/json\": { schema: PotShotCreateResponseSchema } },","+      content: { \"application/json\": { schema: envelope(PotShotCreateResponseSchema) } },","       description: \"Round created successfully\",","     },","     400: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","-      description: \"Invalid request\",","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","+      description: \"Invalid wallet format\",","     },","     403: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","-      description: \"Wallet mismatch\",","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","+      description: \"Wallet mismatch with authenticated session\",","     },","     409: {","-      content: { \"application/json\": { schema: PotShotCreateConflictResponseSchema } },","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Round already active or ID collision\",","     },","+    422: {","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","+      description: \"Invalid request body\",","+    },","     500: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Transaction build failed\",","     },","   },"]},{"oldStart":197,"oldLines":7,"newStart":195,"newLines":7,"lines":["     200: {","       content: {","         \"application/json\": {","-          schema: PotShotHistoryResponseSchema,","+          schema: envelope(PotShotHistoryResponseSchema),","         },","       },","       description: \"List of settled rounds\","]},{"oldStart":215,"oldLines":15,"newStart":213,"newLines":15,"lines":["   },","   responses: {","     200: {","-      content: { \"application/json\": { schema: PotShotRoundResponseSchema } },","+      content: { \"application/json\": { schema: envelope(PotShotRoundResponseSchema) } },","       description: \"Round found\",","     },","     400: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Invalid match ID format\",","     },","     404: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Round not found\",","     },","   },"]},{"oldStart":239,"oldLines":11,"newStart":237,"newLines":11,"lines":["   },","   responses: {","     200: {","-      content: { \"application/json\": { schema: PotShotRoundResponseSchema } },","+      content: { \"application/json\": { schema: envelope(PotShotRoundResponseSchema) } },","       description: \"Round verification data\",","     },","     404: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Round not found\",","     },","   },"]},{"oldStart":272,"oldLines":7,"newStart":270,"newLines":7,"lines":["         .sort((a, b) => a.created_at.getTime() - b.created_at.getTime())[0];"," ","       if (!activeDbRound) {","-        return c.json({ round: null }, 200);","+        return ok(c, { round: null });","       }"," ","       // Fetch the on-chain account to get current entries/pool state"]},{"oldStart":281,"oldLines":19,"newStart":279,"newLines":19,"lines":["         const accountInfo = await connection.getAccountInfo(roundPda);","         if (accountInfo) {","           const decoded = decodeLordRound(Buffer.from(accountInfo.data));","-          return c.json({","+          return ok(c, {","             round: formatLordRound(decoded, roundPda, activeDbRound),","-          }, 200);","+          });","         }","-      } catch (err) {","+      } catch (fetchError) {","         logger.warn(\"lord current: on-chain fetch failed, returning DB-only\", {","           pda: activeDbRound.pda,","-          error: err instanceof Error ? err.message : String(err),","+          error: fetchError instanceof Error ? fetchError.message : String(fetchError),","         });","       }"," ","       // Fallback: return DB data without on-chain enrichment","-      return c.json({","+      return ok(c, {","         round: {","           matchId: activeDbRound.match_id,","           pda: activeDbRound.pda,"]},{"oldStart":307,"oldLines":12,"newStart":305,"newLines":12,"lines":["           countdownEndsAt: null,","           createdAt: activeDbRound.created_at.toISOString(),","         },","-      }, 200);","-    } catch (err) {","+      });","+    } catch (queryError) {","       logger.error(\"lord current: query failed\", {","-        error: err instanceof Error ? err.message : String(err),","+        error: queryError instanceof Error ? queryError.message : String(queryError),","       });","-      return c.json({ round: null }, 200);","+      return ok(c, { round: null });","     }","   });"," "]},{"oldStart":322,"oldLines":16,"newStart":320,"newLines":25,"lines":[" ","     // Additional validation: base58 format","     if (!isValidBase58(body.wallet)) {","-      return c.json(","-        { error: \"wallet must be a valid base58 public key\" },","+      return err(","+        c,","         400,","+        API_ERROR_CODES.INVALID_REQUEST,","+        \"wallet must be a valid base58 public key\",","+        { retryable: false },","       );","     }"," ","     const userId = c.get(\"userId\");","     const profile = userId ? await db.getProfileByUserId(userId) : null;","     if (profile && body.wallet !== profile.wallet) {","-      return c.json({ error: \"Wallet does not match authenticated session\" }, 403);","+      return err(","+        c,","+        403,","+        API_ERROR_CODES.FORBIDDEN,","+        \"Wallet does not match authenticated session\",","+        { retryable: false },","+      );","     }"," ","     // Single active round check: reject if a lord round is already in progress"]},{"oldStart":344,"oldLines":15,"newStart":351,"newLines":20,"lines":["       (r) => r.game === \"potshot\",","     );","     if (activeRound) {","-      return c.json(","+      return err(","+        c,","+        409,","+        API_ERROR_CODES.CONFLICT,","+        \"A round is already active\",","         {","-          error: \"A round is already active\",","-          activeRound: {","-            matchId: activeRound.match_id,","-            pda: activeRound.pda,","+          retryable: false,","+          details: {","+            activeRound: {","+              matchId: activeRound.match_id,","+              pda: activeRound.pda,","+            },","           },","         },","-        409,","       );","     }"," "]},{"oldStart":360,"oldLines":7,"newStart":372,"newLines":13,"lines":["     try {","       creatorPubkey = new PublicKey(body.wallet);","     } catch {","-      return c.json({ error: \"wallet is not a valid public key\" }, 400);","+      return err(","+        c,","+        400,","+        API_ERROR_CODES.INVALID_REQUEST,","+        \"wallet is not a valid public key\",","+        { retryable: false },","+      );","     }"," ","     const secret = generateSecret();"]},{"oldStart":372,"oldLines":7,"newStart":390,"newLines":13,"lines":[" ","     const existing = await db.getRoundByPda(roundPdaStr);","     if (existing) {","-      return c.json({ error: \"Round ID collision — please retry\" }, 409);","+      return err(","+        c,","+        409,","+        API_ERROR_CODES.CONFLICT,","+        \"Round ID collision — please retry\",","+        { retryable: true },","+      );","     }"," ","     let transaction: string;"]},{"oldStart":388,"oldLines":13,"newStart":412,"newLines":18,"lines":["       });","       transaction = result.transaction;","       lastValidBlockHeight = result.lastValidBlockHeight;","-    } catch (err) {","+    } catch (buildError) {","       logger.error(\"lord create failed: transaction build error\", {","         wallet: body.wallet,","         roundPda: roundPdaStr,","-        error: err instanceof Error ? err.message : \"Failed to build transaction\",","+        error: buildError instanceof Error ? buildError.message : \"Failed to build transaction\",","       });","-      return c.json({ error: \"Failed to build transaction\" }, 500);","+      return err(","+        c,","+        500,","+        API_ERROR_CODES.PRECONDITION_FAILED,","+        \"Failed to build transaction\",","+      );","     }"," ","     try {"]},{"oldStart":410,"oldLines":11,"newStart":439,"newLines":17,"lines":["         matchId: matchIdHex,","         phase: \"created\",","       });","-    } catch (err) {","-      if (err instanceof Error && err.message.includes(\"duplicate\")) {","-        return c.json({ error: \"Round ID collision — please retry\" }, 409);","+    } catch (insertError) {","+      if (insertError instanceof Error && insertError.message.includes(\"duplicate\")) {","+        return err(","+          c,","+          409,","+          API_ERROR_CODES.CONFLICT,","+          \"Round ID collision — please retry\",","+          { retryable: true },","+        );","       }","-      throw err;","+      throw insertError;","     }"," ","     // Write participation-time game entry"]},{"oldStart":429,"oldLines":9,"newStart":464,"newLines":9,"lines":["           amountLamports: body.amountLamports,","         });","       }","-    } catch (err) {","+    } catch (entryError) {","       logger.warn(\"lord create: game_entry insert failed\", {","-        error: err instanceof Error ? err.message : String(err),","+        error: entryError instanceof Error ? entryError.message : String(entryError),","       });","     }"," "]},{"oldStart":445,"oldLines":13,"newStart":480,"newLines":13,"lines":["     // Subscribe to PDA for instant join/countdown detection via WebSocket","     pdaWatcher?.watch(roundPdaStr);"," ","-    return c.json({","+    return ok(c, {","       transaction,","       roundPda: roundPdaStr,","       matchId: matchIdHex,","       commitment: commitment.toString(\"hex\"),","       lastValidBlockHeight,","-    }, 200);","+    });","   });"," ","   // -----------------------------------------------------------------------"]},{"oldStart":468,"oldLines":9,"newStart":503,"newLines":9,"lines":["       \"settle_confirmed\",","     );"," ","-    return c.json({","+    return ok(c, {","       rounds: rounds.map((r) => formatPotShotRound(r, settleEvents.get(r.pda))),","-    }, 200);","+    });","   });"," ","   // -----------------------------------------------------------------------"]},{"oldStart":480,"oldLines":15,"newStart":515,"newLines":21,"lines":["   app.openapi(psByIdRoute, async (c) => {","     const { matchId } = c.req.valid(\"param\");","     if (!/^[0-9a-f]{16}$/i.test(matchId)) {","-      return c.json(errorMessage(\"matchId must be a 16-char hex string\"), 400);","+      return err(","+        c,","+        400,","+        API_ERROR_CODES.INVALID_REQUEST,","+        \"matchId must be a 16-char hex string\",","+        { retryable: false },","+      );","     }"," ","     const round = await db.getRoundByMatchId(matchId.toLowerCase());","     if (!round || round.game !== \"potshot\") {","-      return c.json(errorMessage(\"Round not found\"), 404);","+      return err(c, 404, API_ERROR_CODES.ROUND_NOT_FOUND, \"Round not found\");","     }"," ","-    return c.json(await enrichPotShotRound(db, round), 200);","+    return ok(c, await enrichPotShotRound(db, round));","   });"," ","   // -----------------------------------------------------------------------"]},{"oldStart":499,"oldLines":10,"newStart":540,"newLines":10,"lines":["     const { pda } = c.req.valid(\"param\");","     const round = await db.getRoundByPda(pda);","     if (!round || round.game !== \"potshot\") {","-      return c.json(errorMessage(\"Round not found\"), 404);","+      return err(c, 404, API_ERROR_CODES.ROUND_NOT_FOUND, \"Round not found\");","     }"," ","-    return c.json(await enrichPotShotRound(db, round), 200);","+    return ok(c, await enrichPotShotRound(db, round));","   });"," ","   return app;"]}],"originalFile":"/**\n * Pot Shot routes.\n *\n * GET  /pot-shot/current        — active round state\n * POST /pot-shot/create         — create a new round\n * GET  /pot-shot/history        — recent settled rounds\n * GET  /pot-shot/by-id/:matchId — lookup by match ID\n * GET  /pot-shot/verify/:pda    — lookup by PDA with verification data\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\nimport { computeCommitment, generateMatchId, generateSecret } from \"../fairness.js\";\nimport { buildCreateLordRoundTx, deriveLordRoundPda } from \"../tx-builder.js\";\nimport type { Db, Round, OperatorEvent } from \"../db.js\";\nimport { errorMessage } from \"../contracts/api-errors.js\";\nimport { logger } from \"../logger.js\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { PdaWatcher } from \"../worker/pda-watcher.js\";\nimport { decodeLordRound, type DecodedPotShotRound } from \"../worker/account-decoder.js\";\nimport {\n  ErrorResponseSchema,\n  PotShotCreateResponseSchema,\n  PotShotRoundResponseSchema,\n  PotShotRoundSchema,\n  RoundEntrySchema,\n  listEnvelopeResponseSchema,\n  roundEnvelopeResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface LordCreateRoutesDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  pdaWatcher?: PdaWatcher;\n}\n\nconst MIN_WAGER_LAMPORTS = 1_000_000;\n\nfunction isValidBase58(s: string): boolean {\n  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n}\n\nconst PHASE_NAMES = [\"waiting\", \"active\", \"locked\", \"resolving\", \"settled\", \"refunded\"] as const;\nconst DB_PHASE_TO_POTSHOT_PHASE = {\n  created: \"waiting\",\n  locked: \"locked\",\n  settling: \"resolving\",\n  settled: \"settled\",\n  expired: \"refunded\",\n} as const;\n\ntype RoundEntry = z.infer<typeof RoundEntrySchema>;\ntype PotShotCurrentRoundResponse = z.infer<typeof PotShotRoundSchema>;\ntype PotShotRoundResponse = z.infer<typeof PotShotRoundResponseSchema>;\n\nfunction formatLordRound(\n  round: DecodedPotShotRound,\n  pda: PublicKey,\n  dbRound: { match_id: string; commitment: Buffer; phase: string } | undefined,\n): PotShotCurrentRoundResponse {\n  const entries = round.entries.map((e) => ({\n    player: e.player.toBase58(),\n    amountLamports: Number(e.amountLamports),\n  }));\n\n  return {\n    matchId: dbRound?.match_id ?? Buffer.from(round.matchId).toString(\"hex\"),\n    pda: pda.toBase58(),\n    phase: PHASE_NAMES[round.phase] ?? \"waiting\",\n    creator: round.creator.toBase58(),\n    commitment: dbRound\n      ? dbRound.commitment.toString(\"hex\")\n      : Buffer.from(round.commitment).toString(\"hex\"),\n    entries,\n    totalAmountLamports: Number(round.totalAmountLamports),\n    distinctPlayers: round.distinctPlayers,\n    countdownStartedAt: Number(round.countdownStartedAt) > 0\n      ? Number(round.countdownStartedAt)\n      : null,\n    countdownEndsAt: Number(round.countdownEndsAt) > 0\n      ? Number(round.countdownEndsAt)\n      : null,\n    createdAt: new Date(Number(round.createdAt) * 1000).toISOString(),\n  };\n}\n\n// ── Request schemas ──────────────────────────────────────────────────────\n\nconst PotShotCreateBodySchema = z.object({\n  wallet: z.string(),\n  amountLamports: z.number().int().min(MIN_WAGER_LAMPORTS),\n});\n\nconst LimitQuerySchema = z.object({\n  limit: z.string().optional(),\n});\n\nconst MatchIdParamSchema = z.object({\n  matchId: z.string(),\n});\n\nconst PdaParamSchema = z.object({\n  pda: z.string(),\n});\n\n// ── Route definitions ────────────────────────────────────────────────────\n\nconst PotShotCurrentResponseSchema = roundEnvelopeResponseSchema(\n  \"round\",\n  PotShotRoundSchema,\n  { nullable: true },\n);\n\nconst PotShotHistoryResponseSchema = listEnvelopeResponseSchema(\n  \"rounds\",\n  PotShotRoundResponseSchema,\n);\n\nconst PotShotCreateConflictResponseSchema = z.union([\n  ErrorResponseSchema,\n  z.object({\n    error: z.string(),\n    activeRound: z.object({\n      matchId: z.string(),\n      pda: z.string(),\n    }),\n  }),\n]);\n\nconst currentRoute = createRoute({\n  method: \"get\",\n  path: \"/current\",\n  tags: [\"PotShot\"],\n  summary: \"Get active Pot Shot round\",\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: PotShotCurrentResponseSchema,\n        },\n      },\n      description: \"Active round or null\",\n    },\n  },\n});\n\nconst createRoundRoute = createRoute({\n  method: \"post\",\n  path: \"/create\",\n  tags: [\"PotShot\"],\n  summary: \"Create a new Pot Shot round\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": { schema: PotShotCreateBodySchema },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: PotShotCreateResponseSchema } },\n      description: \"Round created successfully\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Invalid request\",\n    },\n    403: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Wallet mismatch\",\n    },\n    409: {\n      content: { \"application/json\": { schema: PotShotCreateConflictResponseSchema } },\n      description: \"Round already active or ID collision\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Transaction build failed\",\n    },\n  },\n});\n\nconst psHistoryRoute = createRoute({\n  method: \"get\",\n  path: \"/history\",\n  tags: [\"PotShot\"],\n  summary: \"Get recent settled Pot Shot rounds\",\n  request: {\n    query: LimitQuerySchema,\n  },\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: PotShotHistoryResponseSchema,\n        },\n      },\n      description: \"List of settled rounds\",\n    },\n  },\n});\n\nconst psByIdRoute = createRoute({\n  method: \"get\",\n  path: \"/by-id/{matchId}\",\n  tags: [\"PotShot\"],\n  summary: \"Lookup Pot Shot round by ID\",\n  request: {\n    params: MatchIdParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: PotShotRoundResponseSchema } },\n      description: \"Round found\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Invalid match ID format\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Round not found\",\n    },\n  },\n});\n\nconst psVerifyRoute = createRoute({\n  method: \"get\",\n  path: \"/verify/{pda}\",\n  tags: [\"PotShot\"],\n  summary: \"Lookup Pot Shot round by PDA with verification data\",\n  request: {\n    params: PdaParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: PotShotRoundResponseSchema } },\n      description: \"Round verification data\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Round not found\",\n    },\n  },\n});\n\n// ── Factory ──────────────────────────────────────────────────────────────\n\nexport function createPotShotRoutes(deps: LordCreateRoutesDeps) {\n  const { db, connection, serverKeypair, pdaWatcher } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // GET /current — return the single active lord round (if any)\n  app.openapi(currentRoute, async (c) => {\n    try {\n      // Query DB for any lord round not in a terminal phase\n      const [created, locked, settling] = await Promise.all([\n        db.getRoundsByPhase(\"created\"),\n        db.getRoundsByPhase(\"locked\"),\n        db.getRoundsByPhase(\"settling\"),\n      ]);\n\n      // Sort ASC (oldest first) — if a race condition created two rounds,\n      // the first one gets played to completion before the second surfaces.\n      const activeDbRound = [...created, ...locked, ...settling]\n        .filter((r) => r.game === \"potshot\")\n        .sort((a, b) => a.created_at.getTime() - b.created_at.getTime())[0];\n\n      if (!activeDbRound) {\n        return c.json({ round: null }, 200);\n      }\n\n      // Fetch the on-chain account to get current entries/pool state\n      const roundPda = new PublicKey(activeDbRound.pda);\n      try {\n        const accountInfo = await connection.getAccountInfo(roundPda);\n        if (accountInfo) {\n          const decoded = decodeLordRound(Buffer.from(accountInfo.data));\n          return c.json({\n            round: formatLordRound(decoded, roundPda, activeDbRound),\n          }, 200);\n        }\n      } catch (err) {\n        logger.warn(\"lord current: on-chain fetch failed, returning DB-only\", {\n          pda: activeDbRound.pda,\n          error: err instanceof Error ? err.message : String(err),\n        });\n      }\n\n      // Fallback: return DB data without on-chain enrichment\n      return c.json({\n        round: {\n          matchId: activeDbRound.match_id,\n          pda: activeDbRound.pda,\n          phase: DB_PHASE_TO_POTSHOT_PHASE[activeDbRound.phase],\n          creator: activeDbRound.creator,\n          commitment: activeDbRound.commitment.toString(\"hex\"),\n          entries: [],\n          totalAmountLamports: activeDbRound.amount_lamports,\n          distinctPlayers: 1,\n          countdownStartedAt: null,\n          countdownEndsAt: null,\n          createdAt: activeDbRound.created_at.toISOString(),\n        },\n      }, 200);\n    } catch (err) {\n      logger.error(\"lord current: query failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ round: null }, 200);\n    }\n  });\n\n  // POST /create\n  app.openapi(createRoundRoute, async (c) => {\n    const body = c.req.valid(\"json\");\n\n    // Additional validation: base58 format\n    if (!isValidBase58(body.wallet)) {\n      return c.json(\n        { error: \"wallet must be a valid base58 public key\" },\n        400,\n      );\n    }\n\n    const userId = c.get(\"userId\");\n    const profile = userId ? await db.getProfileByUserId(userId) : null;\n    if (profile && body.wallet !== profile.wallet) {\n      return c.json({ error: \"Wallet does not match authenticated session\" }, 403);\n    }\n\n    // Single active round check: reject if a lord round is already in progress\n    const [created, locked, settling] = await Promise.all([\n      db.getRoundsByPhase(\"created\"),\n      db.getRoundsByPhase(\"locked\"),\n      db.getRoundsByPhase(\"settling\"),\n    ]);\n    const activeRound = [...created, ...locked, ...settling].find(\n      (r) => r.game === \"potshot\",\n    );\n    if (activeRound) {\n      return c.json(\n        {\n          error: \"A round is already active\",\n          activeRound: {\n            matchId: activeRound.match_id,\n            pda: activeRound.pda,\n          },\n        },\n        409,\n      );\n    }\n\n    let creatorPubkey: PublicKey;\n    try {\n      creatorPubkey = new PublicKey(body.wallet);\n    } catch {\n      return c.json({ error: \"wallet is not a valid public key\" }, 400);\n    }\n\n    const secret = generateSecret();\n    const commitment = computeCommitment(secret);\n    const matchId = generateMatchId();\n    const matchIdHex = matchId.toString(\"hex\");\n    const [roundPda] = deriveLordRoundPda(matchId);\n    const roundPdaStr = roundPda.toBase58();\n\n    const existing = await db.getRoundByPda(roundPdaStr);\n    if (existing) {\n      return c.json({ error: \"Round ID collision — please retry\" }, 409);\n    }\n\n    let transaction: string;\n    let lastValidBlockHeight: number;\n    try {\n      const result = await buildCreateLordRoundTx({\n        connection,\n        creator: creatorPubkey,\n        serverKeypair,\n        commitment,\n        amountLamports: body.amountLamports,\n        matchId,\n      });\n      transaction = result.transaction;\n      lastValidBlockHeight = result.lastValidBlockHeight;\n    } catch (err) {\n      logger.error(\"lord create failed: transaction build error\", {\n        wallet: body.wallet,\n        roundPda: roundPdaStr,\n        error: err instanceof Error ? err.message : \"Failed to build transaction\",\n      });\n      return c.json({ error: \"Failed to build transaction\" }, 500);\n    }\n\n    try {\n      await db.insertRound({\n        pda: roundPdaStr,\n        game: \"potshot\",\n        creator: body.wallet,\n        serverKey: serverKeypair.publicKey.toBase58(),\n        secret,\n        commitment,\n        amountLamports: body.amountLamports,\n        side: 0,\n        matchId: matchIdHex,\n        phase: \"created\",\n      });\n    } catch (err) {\n      if (err instanceof Error && err.message.includes(\"duplicate\")) {\n        return c.json({ error: \"Round ID collision — please retry\" }, 409);\n      }\n      throw err;\n    }\n\n    // Write participation-time game entry\n    try {\n      if (profile) {\n        await db.upsertGameEntry({\n          userId: profile.user_id,\n          wallet: body.wallet,\n          game: \"potshot\",\n          roundPda: roundPdaStr,\n          matchId: matchIdHex,\n          amountLamports: body.amountLamports,\n        });\n      }\n    } catch (err) {\n      logger.warn(\"lord create: game_entry insert failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n\n    await db.insertOperatorEvent(roundPdaStr, \"secret_generated\", {\n      creator: body.wallet,\n      amountLamports: body.amountLamports,\n      matchId: matchIdHex,\n      game: \"potshot\",\n    });\n\n    // Subscribe to PDA for instant join/countdown detection via WebSocket\n    pdaWatcher?.watch(roundPdaStr);\n\n    return c.json({\n      transaction,\n      roundPda: roundPdaStr,\n      matchId: matchIdHex,\n      commitment: commitment.toString(\"hex\"),\n      lastValidBlockHeight,\n    }, 200);\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /history — recent settled Pot Shot rounds\n  // -----------------------------------------------------------------------\n\n  app.openapi(psHistoryRoute, async (c) => {\n    const { limit: limitParam } = c.req.valid(\"query\");\n    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 50);\n\n    const rounds = await db.getRecentSettledRounds(\"potshot\", limit);\n    const settleEvents = await db.getLatestOperatorEventsForPdas(\n      rounds.map((r) => r.pda),\n      \"settle_confirmed\",\n    );\n\n    return c.json({\n      rounds: rounds.map((r) => formatPotShotRound(r, settleEvents.get(r.pda))),\n    }, 200);\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /by-id/:matchId — lookup by 16-char hex match ID\n  // -----------------------------------------------------------------------\n\n  app.openapi(psByIdRoute, async (c) => {\n    const { matchId } = c.req.valid(\"param\");\n    if (!/^[0-9a-f]{16}$/i.test(matchId)) {\n      return c.json(errorMessage(\"matchId must be a 16-char hex string\"), 400);\n    }\n\n    const round = await db.getRoundByMatchId(matchId.toLowerCase());\n    if (!round || round.game !== \"potshot\") {\n      return c.json(errorMessage(\"Round not found\"), 404);\n    }\n\n    return c.json(await enrichPotShotRound(db, round), 200);\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /verify/:pda — lookup by PDA with full verification data\n  // -----------------------------------------------------------------------\n\n  app.openapi(psVerifyRoute, async (c) => {\n    const { pda } = c.req.valid(\"param\");\n    const round = await db.getRoundByPda(pda);\n    if (!round || round.game !== \"potshot\") {\n      return c.json(errorMessage(\"Round not found\"), 404);\n    }\n\n    return c.json(await enrichPotShotRound(db, round), 200);\n  });\n\n  return app;\n}\n\n// ---------------------------------------------------------------------------\n// Pot Shot response formatting\n// ---------------------------------------------------------------------------\n\nfunction getEventPayload(event: OperatorEvent | undefined): Record<string, unknown> | null {\n  if (!event || typeof event.payload !== \"object\" || event.payload === null) return null;\n  return event.payload as Record<string, unknown>;\n}\n\nfunction getNullableString(value: unknown): string | null | undefined {\n  if (value === null) return null;\n  return typeof value === \"string\" ? value : undefined;\n}\n\nfunction getNullableInt(value: unknown): number | null | undefined {\n  if (value === null) return null;\n  return typeof value === \"number\" && Number.isInteger(value) ? value : undefined;\n}\n\nfunction getRoundEntries(value: unknown): RoundEntry[] | undefined {\n  const parsed = z.array(RoundEntrySchema).safeParse(value);\n  return parsed.success ? parsed.data : undefined;\n}\n\nfunction formatPotShotRound(round: Round, settleEvent?: OperatorEvent): PotShotRoundResponse {\n  const isSettled = round.phase === \"settled\";\n  const settlePayload = getEventPayload(settleEvent);\n\n  const response: PotShotRoundResponse = {\n    pda: round.pda,\n    game: \"pot-shot\",\n    phase: round.phase,\n    creator: round.creator,\n    commitment: round.commitment.toString(\"hex\"),\n    amountLamports: round.amount_lamports,\n    side: round.side,\n    matchId: round.match_id,\n    createdAt: round.created_at.toISOString(),\n    updatedAt: round.updated_at.toISOString(),\n  };\n\n  if (round.target_slot !== null) {\n    response.targetSlot = Number(round.target_slot);\n  }\n\n  if (isSettled) {\n    response.secret = round.secret.toString(\"hex\");\n    response.resultHash = round.result_hash ? round.result_hash.toString(\"hex\") : null;\n    if (round.result_side !== null) {\n      response.winningEntryIndex = round.result_side;\n    }\n    if (round.winner) {\n      response.winner = round.winner;\n    }\n    if (round.settle_tx) {\n      response.settleTx = round.settle_tx;\n    }\n    response.totalAmountLamports = round.amount_lamports;\n    response.verification = {\n      commitmentCheck: \"sha256(secret) == commitment\",\n      resultFormula: \"sha256(secret || entropy || pda || algorithmVersion)\",\n      entropySource: \"SlotHashes sysvar at target_slot\",\n    };\n\n    if (Array.isArray(round.entries)) {\n      response.entries = round.entries;\n    }\n\n    if (settlePayload) {\n      const entries = getRoundEntries(settlePayload.entries);\n      const entropy = getNullableString(settlePayload.entropy);\n      const payoutAmount = getNullableInt(settlePayload.payoutAmount);\n      const feeAmount = getNullableInt(settlePayload.feeAmount);\n      const winningOffset = getNullableString(settlePayload.winningOffset);\n      const totalAmountLamports = getNullableInt(settlePayload.totalAmountLamports);\n      const rentRefund = getNullableInt(settlePayload.rentRefund);\n\n      if (!response.entries && entries) {\n        response.entries = entries;\n      }\n      if (entropy !== undefined) {\n        response.entropy = entropy;\n      }\n      if (payoutAmount !== undefined) {\n        response.payoutAmount = payoutAmount;\n      }\n      if (feeAmount !== undefined) {\n        response.feeAmount = feeAmount;\n      }\n      if (winningOffset !== undefined) {\n        response.winningOffset = winningOffset;\n      }\n      if (totalAmountLamports !== undefined) {\n        response.totalAmountLamports = totalAmountLamports;\n      }\n      if (rentRefund !== undefined) {\n        response.rentRefund = rentRefund;\n      }\n    }\n  }\n\n  return response;\n}\n\nasync function enrichPotShotRound(db: Db, round: Round) {\n  let settleEvent: OperatorEvent | undefined;\n  if (round.phase === \"settled\") {\n    try {\n      settleEvent = await db.getLatestOperatorEvent(round.pda, \"settle_confirmed\");\n    } catch {\n      // Gracefully degrade\n    }\n  }\n  return formatPotShotRound(round, settleEvent);\n}\n","userModified":false}}
