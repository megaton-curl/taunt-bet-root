{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UqMnyVtJCZDGdXi2KSGf6P","type":"tool_result","content":"1\t/**\n2\t * Pot Shot routes.\n3\t *\n4\t * GET  /pot-shot/current        — active round state\n5\t * POST /pot-shot/create         — create a new round\n6\t * GET  /pot-shot/history        — recent settled rounds\n7\t * GET  /pot-shot/by-id/:matchId — lookup by match ID\n8\t * GET  /pot-shot/verify/:pda    — lookup by PDA with verification data\n9\t */\n10\t\n11\timport { createRoute } from \"@hono/zod-openapi\";\n12\timport { z } from \"zod\";\n13\timport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\n14\timport { computeCommitment, generateMatchId, generateSecret } from \"../fairness.js\";\n15\timport { buildCreateLordRoundTx, deriveLordRoundPda } from \"../tx-builder.js\";\n16\timport type { Db, Round, OperatorEvent } from \"../db.js\";\n17\timport { errorMessage } from \"../contracts/api-errors.js\";\n18\timport { logger } from \"../logger.js\";\n19\timport type { AppEnv } from \"../hono-env.js\";\n20\timport type { PdaWatcher } from \"../worker/pda-watcher.js\";\n21\timport { decodeLordRound, type DecodedPotShotRound } from \"../worker/account-decoder.js\";\n22\timport {\n23\t  ErrorResponseSchema,\n24\t  PotShotCreateResponseSchema,\n25\t  PotShotRoundResponseSchema,\n26\t  PotShotRoundSchema,\n27\t  RoundEntrySchema,\n28\t  listEnvelopeResponseSchema,\n29\t  roundEnvelopeResponseSchema,\n30\t} from \"../contracts/validators.js\";\n31\timport { createOpenApiApp } from \"../openapi/hono.js\";\n32\t\n33\texport interface LordCreateRoutesDeps {\n34\t  db: Db;\n35\t  connection: Connection;\n36\t  serverKeypair: Keypair;\n37\t  pdaWatcher?: PdaWatcher;\n38\t}\n39\t\n40\tconst MIN_WAGER_LAMPORTS = 1_000_000;\n41\t\n42\tfunction isValidBase58(s: string): boolean {\n43\t  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n44\t}\n45\t\n46\tconst PHASE_NAMES = [\"waiting\", \"active\", \"locked\", \"resolving\", \"settled\", \"refunded\"] as const;\n47\tconst DB_PHASE_TO_POTSHOT_PHASE = {\n48\t  created: \"waiting\",\n49\t  locked: \"locked\",\n50\t  settling: \"resolving\",\n51\t  settled: \"settled\",\n52\t  expired: \"refunded\",\n53\t} as const;\n54\t\n55\ttype RoundEntry = z.infer<typeof RoundEntrySchema>;\n56\ttype PotShotCurrentRoundResponse = z.infer<typeof PotShotRoundSchema>;\n57\ttype PotShotRoundResponse = z.infer<typeof PotShotRoundResponseSchema>;\n58\t\n59\tfunction formatLordRound(\n60\t  round: DecodedPotShotRound,\n61\t  pda: PublicKey,\n62\t  dbRound: { match_id: string; commitment: Buffer; phase: string } | undefined,\n63\t): PotShotCurrentRoundResponse {\n64\t  const entries = round.entries.map((e) => ({\n65\t    player: e.player.toBase58(),\n66\t    amountLamports: Number(e.amountLamports),\n67\t  }));\n68\t\n69\t  return {\n70\t    matchId: dbRound?.match_id ?? Buffer.from(round.matchId).toString(\"hex\"),\n71\t    pda: pda.toBase58(),\n72\t    phase: PHASE_NAMES[round.phase] ?? \"waiting\",\n73\t    creator: round.creator.toBase58(),\n74\t    commitment: dbRound\n75\t      ? dbRound.commitment.toString(\"hex\")\n76\t      : Buffer.from(round.commitment).toString(\"hex\"),\n77\t    entries,\n78\t    totalAmountLamports: Number(round.totalAmountLamports),\n79\t    distinctPlayers: round.distinctPlayers,\n80\t    countdownStartedAt: Number(round.countdownStartedAt) > 0\n81\t      ? Number(round.countdownStartedAt)\n82\t      : null,\n83\t    countdownEndsAt: Number(round.countdownEndsAt) > 0\n84\t      ? Number(round.countdownEndsAt)\n85\t      : null,\n86\t    createdAt: new Date(Number(round.createdAt) * 1000).toISOString(),\n87\t  };\n88\t}\n89\t\n90\t// ── Request schemas ──────────────────────────────────────────────────────\n91\t\n92\tconst PotShotCreateBodySchema = z.object({\n93\t  wallet: z.string(),\n94\t  amountLamports: z.number().int().min(MIN_WAGER_LAMPORTS),\n95\t});\n96\t\n97\tconst LimitQuerySchema = z.object({\n98\t  limit: z.string().optional(),\n99\t});\n100\t\n101\tconst MatchIdParamSchema = z.object({\n102\t  matchId: z.string(),\n103\t});\n104\t\n105\tconst PdaParamSchema = z.object({\n106\t  pda: z.string(),\n107\t});\n108\t\n109\t// ── Route definitions ────────────────────────────────────────────────────\n110\t\n111\tconst PotShotCurrentResponseSchema = roundEnvelopeResponseSchema(\n112\t  \"round\",\n113\t  PotShotRoundSchema,\n114\t  { nullable: true },\n115\t);\n116\t\n117\tconst PotShotHistoryResponseSchema = listEnvelopeResponseSchema(\n118\t  \"rounds\",\n119\t  PotShotRoundResponseSchema,\n120\t);\n121\t\n122\tconst PotShotCreateConflictResponseSchema = z.union([\n123\t  ErrorResponseSchema,\n124\t  z.object({\n125\t    error: z.string(),\n126\t    activeRound: z.object({\n127\t      matchId: z.string(),\n128\t      pda: z.string(),\n129\t    }),\n130\t  }),\n131\t]);\n132\t\n133\tconst currentRoute = createRoute({\n134\t  method: \"get\",\n135\t  path: \"/current\",\n136\t  tags: [\"PotShot\"],\n137\t  summary: \"Get active Pot Shot round\",\n138\t  responses: {\n139\t    200: {\n140\t      content: {\n141\t        \"application/json\": {\n142\t          schema: PotShotCurrentResponseSchema,\n143\t        },\n144\t      },\n145\t      description: \"Active round or null\",\n146\t    },\n147\t  },\n148\t});\n149\t\n150\tconst createRoundRoute = createRoute({\n151\t  method: \"post\",\n152\t  path: \"/create\",\n153\t  tags: [\"PotShot\"],\n154\t  summary: \"Create a new Pot Shot round\",\n155\t  security: [{ bearerAuth: [] }],\n156\t  request: {\n157\t    body: {\n158\t      required: true,\n159\t      content: {\n160\t        \"application/json\": { schema: PotShotCreateBodySchema },\n161\t      },\n162\t    },\n163\t  },\n164\t  responses: {\n165\t    200: {\n166\t      content: { \"application/json\": { schema: PotShotCreateResponseSchema } },\n167\t      description: \"Round created successfully\",\n168\t    },\n169\t    400: {\n170\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n171\t      description: \"Invalid request\",\n172\t    },\n173\t    403: {\n174\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n175\t      description: \"Wallet mismatch\",\n176\t    },\n177\t    409: {\n178\t      content: { \"application/json\": { schema: PotShotCreateConflictResponseSchema } },\n179\t      description: \"Round already active or ID collision\",\n180\t    },\n181\t    500: {\n182\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n183\t      description: \"Transaction build failed\",\n184\t    },\n185\t  },\n186\t});\n187\t\n188\tconst psHistoryRoute = createRoute({\n189\t  method: \"get\",\n190\t  path: \"/history\",\n191\t  tags: [\"PotShot\"],\n192\t  summary: \"Get recent settled Pot Shot rounds\",\n193\t  request: {\n194\t    query: LimitQuerySchema,\n195\t  },\n196\t  responses: {\n197\t    200: {\n198\t      content: {\n199\t        \"application/json\": {\n200\t          schema: PotShotHistoryResponseSchema,\n201\t        },\n202\t      },\n203\t      description: \"List of settled rounds\",\n204\t    },\n205\t  },\n206\t});\n207\t\n208\tconst psByIdRoute = createRoute({\n209\t  method: \"get\",\n210\t  path: \"/by-id/{matchId}\",\n211\t  tags: [\"PotShot\"],\n212\t  summary: \"Lookup Pot Shot round by ID\",\n213\t  request: {\n214\t    params: MatchIdParamSchema,\n215\t  },\n216\t  responses: {\n217\t    200: {\n218\t      content: { \"application/json\": { schema: PotShotRoundResponseSchema } },\n219\t      description: \"Round found\",\n220\t    },\n221\t    400: {\n222\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n223\t      description: \"Invalid match ID format\",\n224\t    },\n225\t    404: {\n226\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n227\t      description: \"Round not found\",\n228\t    },\n229\t  },\n230\t});\n231\t\n232\tconst psVerifyRoute = createRoute({\n233\t  method: \"get\",\n234\t  path: \"/verify/{pda}\",\n235\t  tags: [\"PotShot\"],\n236\t  summary: \"Lookup Pot Shot round by PDA with verification data\",\n237\t  request: {\n238\t    params: PdaParamSchema,\n239\t  },\n240\t  responses: {\n241\t    200: {\n242\t      content: { \"application/json\": { schema: PotShotRoundResponseSchema } },\n243\t      description: \"Round verification data\",\n244\t    },\n245\t    404: {\n246\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n247\t      description: \"Round not found\",\n248\t    },\n249\t  },\n250\t});\n251\t\n252\t// ── Factory ──────────────────────────────────────────────────────────────\n253\t\n254\texport function createPotShotRoutes(deps: LordCreateRoutesDeps) {\n255\t  const { db, connection, serverKeypair, pdaWatcher } = deps;\n256\t  const app = createOpenApiApp<AppEnv>();\n257\t\n258\t  // GET /current — return the single active lord round (if any)\n259\t  app.openapi(currentRoute, async (c) => {\n260\t    try {\n261\t      // Query DB for any lord round not in a terminal phase\n262\t      const [created, locked, settling] = await Promise.all([\n263\t        db.getRoundsByPhase(\"created\"),\n264\t        db.getRoundsByPhase(\"locked\"),\n265\t        db.getRoundsByPhase(\"settling\"),\n266\t      ]);\n267\t\n268\t      // Sort ASC (oldest first) — if a race condition created two rounds,\n269\t      // the first one gets played to completion before the second surfaces.\n270\t      const activeDbRound = [...created, ...locked, ...settling]\n271\t        .filter((r) => r.game === \"potshot\")\n272\t        .sort((a, b) => a.created_at.getTime() - b.created_at.getTime())[0];\n273\t\n274\t      if (!activeDbRound) {\n275\t        return c.json({ round: null }, 200);\n276\t      }\n277\t\n278\t      // Fetch the on-chain account to get current entries/pool state\n279\t      const roundPda = new PublicKey(activeDbRound.pda);\n280\t      try {\n281\t        const accountInfo = await connection.getAccountInfo(roundPda);\n282\t        if (accountInfo) {\n283\t          const decoded = decodeLordRound(Buffer.from(accountInfo.data));\n284\t          return c.json({\n285\t            round: formatLordRound(decoded, roundPda, activeDbRound),\n286\t          }, 200);\n287\t        }\n288\t      } catch (err) {\n289\t        logger.warn(\"lord current: on-chain fetch failed, returning DB-only\", {\n290\t          pda: activeDbRound.pda,\n291\t          error: err instanceof Error ? err.message : String(err),\n292\t        });\n293\t      }\n294\t\n295\t      // Fallback: return DB data without on-chain enrichment\n296\t      return c.json({\n297\t        round: {\n298\t          matchId: activeDbRound.match_id,\n299\t          pda: activeDbRound.pda,\n300\t          phase: DB_PHASE_TO_POTSHOT_PHASE[activeDbRound.phase],\n301\t          creator: activeDbRound.creator,\n302\t          commitment: activeDbRound.commitment.toString(\"hex\"),\n303\t          entries: [],\n304\t          totalAmountLamports: activeDbRound.amount_lamports,\n305\t          distinctPlayers: 1,\n306\t          countdownStartedAt: null,\n307\t          countdownEndsAt: null,\n308\t          createdAt: activeDbRound.created_at.toISOString(),\n309\t        },\n310\t      }, 200);\n311\t    } catch (err) {\n312\t      logger.error(\"lord current: query failed\", {\n313\t        error: err instanceof Error ? err.message : String(err),\n314\t      });\n315\t      return c.json({ round: null }, 200);\n316\t    }\n317\t  });\n318\t\n319\t  // POST /create\n320\t  app.openapi(createRoundRoute, async (c) => {\n321\t    const body = c.req.valid(\"json\");\n322\t\n323\t    // Additional validation: base58 format\n324\t    if (!isValidBase58(body.wallet)) {\n325\t      return c.json(\n326\t        { error: \"wallet must be a valid base58 public key\" },\n327\t        400,\n328\t      );\n329\t    }\n330\t\n331\t    const userId = c.get(\"userId\");\n332\t    const profile = userId ? await db.getProfileByUserId(userId) : null;\n333\t    if (profile && body.wallet !== profile.wallet) {\n334\t      return c.json({ error: \"Wallet does not match authenticated session\" }, 403);\n335\t    }\n336\t\n337\t    // Single active round check: reject if a lord round is already in progress\n338\t    const [created, locked, settling] = await Promise.all([\n339\t      db.getRoundsByPhase(\"created\"),\n340\t      db.getRoundsByPhase(\"locked\"),\n341\t      db.getRoundsByPhase(\"settling\"),\n342\t    ]);\n343\t    const activeRound = [...created, ...locked, ...settling].find(\n344\t      (r) => r.game === \"potshot\",\n345\t    );\n346\t    if (activeRound) {\n347\t      return c.json(\n348\t        {\n349\t          error: \"A round is already active\",\n350\t          activeRound: {\n351\t            matchId: activeRound.match_id,\n352\t            pda: activeRound.pda,\n353\t          },\n354\t        },\n355\t        409,\n356\t      );\n357\t    }\n358\t\n359\t    let creatorPubkey: PublicKey;\n360\t    try {\n361\t      creatorPubkey = new PublicKey(body.wallet);\n362\t    } catch {\n363\t      return c.json({ error: \"wallet is not a valid public key\" }, 400);\n364\t    }\n365\t\n366\t    const secret = generateSecret();\n367\t    const commitment = computeCommitment(secret);\n368\t    const matchId = generateMatchId();\n369\t    const matchIdHex = matchId.toString(\"hex\");\n370\t    const [roundPda] = deriveLordRoundPda(matchId);\n371\t    const roundPdaStr = roundPda.toBase58();\n372\t\n373\t    const existing = await db.getRoundByPda(roundPdaStr);\n374\t    if (existing) {\n375\t      return c.json({ error: \"Round ID collision — please retry\" }, 409);\n376\t    }\n377\t\n378\t    let transaction: string;\n379\t    let lastValidBlockHeight: number;\n380\t    try {\n381\t      const result = await buildCreateLordRoundTx({\n382\t        connection,\n383\t        creator: creatorPubkey,\n384\t        serverKeypair,\n385\t        commitment,\n386\t        amountLamports: body.amountLamports,\n387\t        matchId,\n388\t      });\n389\t      transaction = result.transaction;\n390\t      lastValidBlockHeight = result.lastValidBlockHeight;\n391\t    } catch (err) {\n392\t      logger.error(\"lord create failed: transaction build error\", {\n393\t        wallet: body.wallet,\n394\t        roundPda: roundPdaStr,\n395\t        error: err instanceof Error ? err.message : \"Failed to build transaction\",\n396\t      });\n397\t      return c.json({ error: \"Failed to build transaction\" }, 500);\n398\t    }\n399\t\n400\t    try {\n401\t      await db.insertRound({\n402\t        pda: roundPdaStr,\n403\t        game: \"potshot\",\n404\t        creator: body.wallet,\n405\t        serverKey: serverKeypair.publicKey.toBase58(),\n406\t        secret,\n407\t        commitment,\n408\t        amountLamports: body.amountLamports,\n409\t        side: 0,\n410\t        matchId: matchIdHex,\n411\t        phase: \"created\",\n412\t      });\n413\t    } catch (err) {\n414\t      if (err instanceof Error && err.message.includes(\"duplicate\")) {\n415\t        return c.json({ error: \"Round ID collision — please retry\" }, 409);\n416\t      }\n417\t      throw err;\n418\t    }\n419\t\n420\t    // Write participation-time game entry\n421\t    try {\n422\t      if (profile) {\n423\t        await db.upsertGameEntry({\n424\t          userId: profile.user_id,\n425\t          wallet: body.wallet,\n426\t          game: \"potshot\",\n427\t          roundPda: roundPdaStr,\n428\t          matchId: matchIdHex,\n429\t          amountLamports: body.amountLamports,\n430\t        });\n431\t      }\n432\t    } catch (err) {\n433\t      logger.warn(\"lord create: game_entry insert failed\", {\n434\t        error: err instanceof Error ? err.message : String(err),\n435\t      });\n436\t    }\n437\t\n438\t    await db.insertOperatorEvent(roundPdaStr, \"secret_generated\", {\n439\t      creator: body.wallet,\n440\t      amountLamports: body.amountLamports,\n441\t      matchId: matchIdHex,\n442\t      game: \"potshot\",\n443\t    });\n444\t\n445\t    // Subscribe to PDA for instant join/countdown detection via WebSocket\n446\t    pdaWatcher?.watch(roundPdaStr);\n447\t\n448\t    return c.json({\n449\t      transaction,\n450\t      roundPda: roundPdaStr,\n451\t      matchId: matchIdHex,\n452\t      commitment: commitment.toString(\"hex\"),\n453\t      lastValidBlockHeight,\n454\t    }, 200);\n455\t  });\n456\t\n457\t  // -----------------------------------------------------------------------\n458\t  // GET /history — recent settled Pot Shot rounds\n459\t  // -----------------------------------------------------------------------\n460\t\n461\t  app.openapi(psHistoryRoute, async (c) => {\n462\t    const { limit: limitParam } = c.req.valid(\"query\");\n463\t    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 50);\n464\t\n465\t    const rounds = await db.getRecentSettledRounds(\"potshot\", limit);\n466\t    const settleEvents = await db.getLatestOperatorEventsForPdas(\n467\t      rounds.map((r) => r.pda),\n468\t      \"settle_confirmed\",\n469\t    );\n470\t\n471\t    return c.json({\n472\t      rounds: rounds.map((r) => formatPotShotRound(r, settleEvents.get(r.pda))),\n473\t    }, 200);\n474\t  });\n475\t\n476\t  // -----------------------------------------------------------------------\n477\t  // GET /by-id/:matchId — lookup by 16-char hex match ID\n478\t  // -----------------------------------------------------------------------\n479\t\n480\t  app.openapi(psByIdRoute, async (c) => {\n481\t    const { matchId } = c.req.valid(\"param\");\n482\t    if (!/^[0-9a-f]{16}$/i.test(matchId)) {\n483\t      return c.json(errorMessage(\"matchId must be a 16-char hex string\"), 400);\n484\t    }\n485\t\n486\t    const round = await db.getRoundByMatchId(matchId.toLowerCase());\n487\t    if (!round || round.game !== \"potshot\") {\n488\t      return c.json(errorMessage(\"Round not found\"), 404);\n489\t    }\n490\t\n491\t    return c.json(await enrichPotShotRound(db, round), 200);\n492\t  });\n493\t\n494\t  // -----------------------------------------------------------------------\n495\t  // GET /verify/:pda — lookup by PDA with full verification data\n496\t  // -----------------------------------------------------------------------\n497\t\n498\t  app.openapi(psVerifyRoute, async (c) => {\n499\t    const { pda } = c.req.valid(\"param\");\n500\t    const round = await db.getRoundByPda(pda);\n501\t    if (!round || round.game !== \"potshot\") {\n502\t      return c.json(errorMessage(\"Round not found\"), 404);\n503\t    }\n504\t\n505\t    return c.json(await enrichPotShotRound(db, round), 200);\n506\t  });\n507\t\n508\t  return app;\n509\t}\n510\t\n511\t// ---------------------------------------------------------------------------\n512\t// Pot Shot response formatting\n513\t// ---------------------------------------------------------------------------\n514\t\n515\tfunction getEventPayload(event: OperatorEvent | undefined): Record<string, unknown> | null {\n516\t  if (!event || typeof event.payload !== \"object\" || event.payload === null) return null;\n517\t  return event.payload as Record<string, unknown>;\n518\t}\n519\t\n520\tfunction getNullableString(value: unknown): string | null | undefined {\n521\t  if (value === null) return null;\n522\t  return typeof value === \"string\" ? value : undefined;\n523\t}\n524\t\n525\tfunction getNullableInt(value: unknown): number | null | undefined {\n526\t  if (value === null) return null;\n527\t  return typeof value === \"number\" && Number.isInteger(value) ? value : undefined;\n528\t}\n529\t\n530\tfunction getRoundEntries(value: unknown): RoundEntry[] | undefined {\n531\t  const parsed = z.array(RoundEntrySchema).safeParse(value);\n532\t  return parsed.success ? parsed.data : undefined;\n533\t}\n534\t\n535\tfunction formatPotShotRound(round: Round, settleEvent?: OperatorEvent): PotShotRoundResponse {\n536\t  const isSettled = round.phase === \"settled\";\n537\t  const settlePayload = getEventPayload(settleEvent);\n538\t\n539\t  const response: PotShotRoundResponse = {\n540\t    pda: round.pda,\n541\t    game: \"pot-shot\",\n542\t    phase: round.phase,\n543\t    creator: round.creator,\n544\t    commitment: round.commitment.toString(\"hex\"),\n545\t    amountLamports: round.amount_lamports,\n546\t    side: round.side,\n547\t    matchId: round.match_id,\n548\t    createdAt: round.created_at.toISOString(),\n549\t    updatedAt: round.updated_at.toISOString(),\n550\t  };\n551\t\n552\t  if (round.target_slot !== null) {\n553\t    response.targetSlot = Number(round.target_slot);\n554\t  }\n555\t\n556\t  if (isSettled) {\n557\t    response.secret = round.secret.toString(\"hex\");\n558\t    response.resultHash = round.result_hash ? round.result_hash.toString(\"hex\") : null;\n559\t    if (round.result_side !== null) {\n560\t      response.winningEntryIndex = round.result_side;\n561\t    }\n562\t    if (round.winner) {\n563\t      response.winner = round.winner;\n564\t    }\n565\t    if (round.settle_tx) {\n566\t      response.settleTx = round.settle_tx;\n567\t    }\n568\t    response.totalAmountLamports = round.amount_lamports;\n569\t    response.verification = {\n570\t      commitmentCheck: \"sha256(secret) == commitment\",\n571\t      resultFormula: \"sha256(secret || entropy || pda || algorithmVersion)\",\n572\t      entropySource: \"SlotHashes sysvar at target_slot\",\n573\t    };\n574\t\n575\t    if (Array.isArray(round.entries)) {\n576\t      response.entries = round.entries;\n577\t    }\n578\t\n579\t    if (settlePayload) {\n580\t      const entries = getRoundEntries(settlePayload.entries);\n581\t      const entropy = getNullableString(settlePayload.entropy);\n582\t      const payoutAmount = getNullableInt(settlePayload.payoutAmount);\n583\t      const feeAmount = getNullableInt(settlePayload.feeAmount);\n584\t      const winningOffset = getNullableString(settlePayload.winningOffset);\n585\t      const totalAmountLamports = getNullableInt(settlePayload.totalAmountLamports);\n586\t      const rentRefund = getNullableInt(settlePayload.rentRefund);\n587\t\n588\t      if (!response.entries && entries) {\n589\t        response.entries = entries;\n590\t      }\n591\t      if (entropy !== undefined) {\n592\t        response.entropy = entropy;\n593\t      }\n594\t      if (payoutAmount !== undefined) {\n595\t        response.payoutAmount = payoutAmount;\n596\t      }\n597\t      if (feeAmount !== undefined) {\n598\t        response.feeAmount = feeAmount;\n599\t      }\n600\t      if (winningOffset !== undefined) {\n601\t        response.winningOffset = winningOffset;\n602\t      }\n603\t      if (totalAmountLamports !== undefined) {\n604\t        response.totalAmountLamports = totalAmountLamports;\n605\t      }\n606\t      if (rentRefund !== undefined) {\n607\t        response.rentRefund = rentRefund;\n608\t      }\n609\t    }\n610\t  }\n611\t\n612\t  return response;\n613\t}\n614\t\n615\tasync function enrichPotShotRound(db: Db, round: Round) {\n616\t  let settleEvent: OperatorEvent | undefined;\n617\t  if (round.phase === \"settled\") {\n618\t    try {\n619\t      settleEvent = await db.getLatestOperatorEvent(round.pda, \"settle_confirmed\");\n620\t    } catch {\n621\t      // Gracefully degrade\n622\t    }\n623\t  }\n624\t  return formatPotShotRound(round, settleEvent);\n625\t}\n626\t"}]},"parent_tool_use_id":null,"session_id":"32e06d79-d550-426e-9fdd-421cb060dd82","uuid":"08f1c164-6d5a-4d82-a491-627c2ffe9eea","timestamp":"2026-04-22T10:18:47.806Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/potshot-create.ts","content":"/**\n * Pot Shot routes.\n *\n * GET  /pot-shot/current        — active round state\n * POST /pot-shot/create         — create a new round\n * GET  /pot-shot/history        — recent settled rounds\n * GET  /pot-shot/by-id/:matchId — lookup by match ID\n * GET  /pot-shot/verify/:pda    — lookup by PDA with verification data\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\nimport { computeCommitment, generateMatchId, generateSecret } from \"../fairness.js\";\nimport { buildCreateLordRoundTx, deriveLordRoundPda } from \"../tx-builder.js\";\nimport type { Db, Round, OperatorEvent } from \"../db.js\";\nimport { errorMessage } from \"../contracts/api-errors.js\";\nimport { logger } from \"../logger.js\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { PdaWatcher } from \"../worker/pda-watcher.js\";\nimport { decodeLordRound, type DecodedPotShotRound } from \"../worker/account-decoder.js\";\nimport {\n  ErrorResponseSchema,\n  PotShotCreateResponseSchema,\n  PotShotRoundResponseSchema,\n  PotShotRoundSchema,\n  RoundEntrySchema,\n  listEnvelopeResponseSchema,\n  roundEnvelopeResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface LordCreateRoutesDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  pdaWatcher?: PdaWatcher;\n}\n\nconst MIN_WAGER_LAMPORTS = 1_000_000;\n\nfunction isValidBase58(s: string): boolean {\n  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n}\n\nconst PHASE_NAMES = [\"waiting\", \"active\", \"locked\", \"resolving\", \"settled\", \"refunded\"] as const;\nconst DB_PHASE_TO_POTSHOT_PHASE = {\n  created: \"waiting\",\n  locked: \"locked\",\n  settling: \"resolving\",\n  settled: \"settled\",\n  expired: \"refunded\",\n} as const;\n\ntype RoundEntry = z.infer<typeof RoundEntrySchema>;\ntype PotShotCurrentRoundResponse = z.infer<typeof PotShotRoundSchema>;\ntype PotShotRoundResponse = z.infer<typeof PotShotRoundResponseSchema>;\n\nfunction formatLordRound(\n  round: DecodedPotShotRound,\n  pda: PublicKey,\n  dbRound: { match_id: string; commitment: Buffer; phase: string } | undefined,\n): PotShotCurrentRoundResponse {\n  const entries = round.entries.map((e) => ({\n    player: e.player.toBase58(),\n    amountLamports: Number(e.amountLamports),\n  }));\n\n  return {\n    matchId: dbRound?.match_id ?? Buffer.from(round.matchId).toString(\"hex\"),\n    pda: pda.toBase58(),\n    phase: PHASE_NAMES[round.phase] ?? \"waiting\",\n    creator: round.creator.toBase58(),\n    commitment: dbRound\n      ? dbRound.commitment.toString(\"hex\")\n      : Buffer.from(round.commitment).toString(\"hex\"),\n    entries,\n    totalAmountLamports: Number(round.totalAmountLamports),\n    distinctPlayers: round.distinctPlayers,\n    countdownStartedAt: Number(round.countdownStartedAt) > 0\n      ? Number(round.countdownStartedAt)\n      : null,\n    countdownEndsAt: Number(round.countdownEndsAt) > 0\n      ? Number(round.countdownEndsAt)\n      : null,\n    createdAt: new Date(Number(round.createdAt) * 1000).toISOString(),\n  };\n}\n\n// ── Request schemas ──────────────────────────────────────────────────────\n\nconst PotShotCreateBodySchema = z.object({\n  wallet: z.string(),\n  amountLamports: z.number().int().min(MIN_WAGER_LAMPORTS),\n});\n\nconst LimitQuerySchema = z.object({\n  limit: z.string().optional(),\n});\n\nconst MatchIdParamSchema = z.object({\n  matchId: z.string(),\n});\n\nconst PdaParamSchema = z.object({\n  pda: z.string(),\n});\n\n// ── Route definitions ────────────────────────────────────────────────────\n\nconst PotShotCurrentResponseSchema = roundEnvelopeResponseSchema(\n  \"round\",\n  PotShotRoundSchema,\n  { nullable: true },\n);\n\nconst PotShotHistoryResponseSchema = listEnvelopeResponseSchema(\n  \"rounds\",\n  PotShotRoundResponseSchema,\n);\n\nconst PotShotCreateConflictResponseSchema = z.union([\n  ErrorResponseSchema,\n  z.object({\n    error: z.string(),\n    activeRound: z.object({\n      matchId: z.string(),\n      pda: z.string(),\n    }),\n  }),\n]);\n\nconst currentRoute = createRoute({\n  method: \"get\",\n  path: \"/current\",\n  tags: [\"PotShot\"],\n  summary: \"Get active Pot Shot round\",\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: PotShotCurrentResponseSchema,\n        },\n      },\n      description: \"Active round or null\",\n    },\n  },\n});\n\nconst createRoundRoute = createRoute({\n  method: \"post\",\n  path: \"/create\",\n  tags: [\"PotShot\"],\n  summary: \"Create a new Pot Shot round\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": { schema: PotShotCreateBodySchema },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: PotShotCreateResponseSchema } },\n      description: \"Round created successfully\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Invalid request\",\n    },\n    403: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Wallet mismatch\",\n    },\n    409: {\n      content: { \"application/json\": { schema: PotShotCreateConflictResponseSchema } },\n      description: \"Round already active or ID collision\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Transaction build failed\",\n    },\n  },\n});\n\nconst psHistoryRoute = createRoute({\n  method: \"get\",\n  path: \"/history\",\n  tags: [\"PotShot\"],\n  summary: \"Get recent settled Pot Shot rounds\",\n  request: {\n    query: LimitQuerySchema,\n  },\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: PotShotHistoryResponseSchema,\n        },\n      },\n      description: \"List of settled rounds\",\n    },\n  },\n});\n\nconst psByIdRoute = createRoute({\n  method: \"get\",\n  path: \"/by-id/{matchId}\",\n  tags: [\"PotShot\"],\n  summary: \"Lookup Pot Shot round by ID\",\n  request: {\n    params: MatchIdParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: PotShotRoundResponseSchema } },\n      description: \"Round found\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Invalid match ID format\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Round not found\",\n    },\n  },\n});\n\nconst psVerifyRoute = createRoute({\n  method: \"get\",\n  path: \"/verify/{pda}\",\n  tags: [\"PotShot\"],\n  summary: \"Lookup Pot Shot round by PDA with verification data\",\n  request: {\n    params: PdaParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: PotShotRoundResponseSchema } },\n      description: \"Round verification data\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Round not found\",\n    },\n  },\n});\n\n// ── Factory ──────────────────────────────────────────────────────────────\n\nexport function createPotShotRoutes(deps: LordCreateRoutesDeps) {\n  const { db, connection, serverKeypair, pdaWatcher } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // GET /current — return the single active lord round (if any)\n  app.openapi(currentRoute, async (c) => {\n    try {\n      // Query DB for any lord round not in a terminal phase\n      const [created, locked, settling] = await Promise.all([\n        db.getRoundsByPhase(\"created\"),\n        db.getRoundsByPhase(\"locked\"),\n        db.getRoundsByPhase(\"settling\"),\n      ]);\n\n      // Sort ASC (oldest first) — if a race condition created two rounds,\n      // the first one gets played to completion before the second surfaces.\n      const activeDbRound = [...created, ...locked, ...settling]\n        .filter((r) => r.game === \"potshot\")\n        .sort((a, b) => a.created_at.getTime() - b.created_at.getTime())[0];\n\n      if (!activeDbRound) {\n        return c.json({ round: null }, 200);\n      }\n\n      // Fetch the on-chain account to get current entries/pool state\n      const roundPda = new PublicKey(activeDbRound.pda);\n      try {\n        const accountInfo = await connection.getAccountInfo(roundPda);\n        if (accountInfo) {\n          const decoded = decodeLordRound(Buffer.from(accountInfo.data));\n          return c.json({\n            round: formatLordRound(decoded, roundPda, activeDbRound),\n          }, 200);\n        }\n      } catch (err) {\n        logger.warn(\"lord current: on-chain fetch failed, returning DB-only\", {\n          pda: activeDbRound.pda,\n          error: err instanceof Error ? err.message : String(err),\n        });\n      }\n\n      // Fallback: return DB data without on-chain enrichment\n      return c.json({\n        round: {\n          matchId: activeDbRound.match_id,\n          pda: activeDbRound.pda,\n          phase: DB_PHASE_TO_POTSHOT_PHASE[activeDbRound.phase],\n          creator: activeDbRound.creator,\n          commitment: activeDbRound.commitment.toString(\"hex\"),\n          entries: [],\n          totalAmountLamports: activeDbRound.amount_lamports,\n          distinctPlayers: 1,\n          countdownStartedAt: null,\n          countdownEndsAt: null,\n          createdAt: activeDbRound.created_at.toISOString(),\n        },\n      }, 200);\n    } catch (err) {\n      logger.error(\"lord current: query failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ round: null }, 200);\n    }\n  });\n\n  // POST /create\n  app.openapi(createRoundRoute, async (c) => {\n    const body = c.req.valid(\"json\");\n\n    // Additional validation: base58 format\n    if (!isValidBase58(body.wallet)) {\n      return c.json(\n        { error: \"wallet must be a valid base58 public key\" },\n        400,\n      );\n    }\n\n    const userId = c.get(\"userId\");\n    const profile = userId ? await db.getProfileByUserId(userId) : null;\n    if (profile && body.wallet !== profile.wallet) {\n      return c.json({ error: \"Wallet does not match authenticated session\" }, 403);\n    }\n\n    // Single active round check: reject if a lord round is already in progress\n    const [created, locked, settling] = await Promise.all([\n      db.getRoundsByPhase(\"created\"),\n      db.getRoundsByPhase(\"locked\"),\n      db.getRoundsByPhase(\"settling\"),\n    ]);\n    const activeRound = [...created, ...locked, ...settling].find(\n      (r) => r.game === \"potshot\",\n    );\n    if (activeRound) {\n      return c.json(\n        {\n          error: \"A round is already active\",\n          activeRound: {\n            matchId: activeRound.match_id,\n            pda: activeRound.pda,\n          },\n        },\n        409,\n      );\n    }\n\n    let creatorPubkey: PublicKey;\n    try {\n      creatorPubkey = new PublicKey(body.wallet);\n    } catch {\n      return c.json({ error: \"wallet is not a valid public key\" }, 400);\n    }\n\n    const secret = generateSecret();\n    const commitment = computeCommitment(secret);\n    const matchId = generateMatchId();\n    const matchIdHex = matchId.toString(\"hex\");\n    const [roundPda] = deriveLordRoundPda(matchId);\n    const roundPdaStr = roundPda.toBase58();\n\n    const existing = await db.getRoundByPda(roundPdaStr);\n    if (existing) {\n      return c.json({ error: \"Round ID collision — please retry\" }, 409);\n    }\n\n    let transaction: string;\n    let lastValidBlockHeight: number;\n    try {\n      const result = await buildCreateLordRoundTx({\n        connection,\n        creator: creatorPubkey,\n        serverKeypair,\n        commitment,\n        amountLamports: body.amountLamports,\n        matchId,\n      });\n      transaction = result.transaction;\n      lastValidBlockHeight = result.lastValidBlockHeight;\n    } catch (err) {\n      logger.error(\"lord create failed: transaction build error\", {\n        wallet: body.wallet,\n        roundPda: roundPdaStr,\n        error: err instanceof Error ? err.message : \"Failed to build transaction\",\n      });\n      return c.json({ error: \"Failed to build transaction\" }, 500);\n    }\n\n    try {\n      await db.insertRound({\n        pda: roundPdaStr,\n        game: \"potshot\",\n        creator: body.wallet,\n        serverKey: serverKeypair.publicKey.toBase58(),\n        secret,\n        commitment,\n        amountLamports: body.amountLamports,\n        side: 0,\n        matchId: matchIdHex,\n        phase: \"created\",\n      });\n    } catch (err) {\n      if (err instanceof Error && err.message.includes(\"duplicate\")) {\n        return c.json({ error: \"Round ID collision — please retry\" }, 409);\n      }\n      throw err;\n    }\n\n    // Write participation-time game entry\n    try {\n      if (profile) {\n        await db.upsertGameEntry({\n          userId: profile.user_id,\n          wallet: body.wallet,\n          game: \"potshot\",\n          roundPda: roundPdaStr,\n          matchId: matchIdHex,\n          amountLamports: body.amountLamports,\n        });\n      }\n    } catch (err) {\n      logger.warn(\"lord create: game_entry insert failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n\n    await db.insertOperatorEvent(roundPdaStr, \"secret_generated\", {\n      creator: body.wallet,\n      amountLamports: body.amountLamports,\n      matchId: matchIdHex,\n      game: \"potshot\",\n    });\n\n    // Subscribe to PDA for instant join/countdown detection via WebSocket\n    pdaWatcher?.watch(roundPdaStr);\n\n    return c.json({\n      transaction,\n      roundPda: roundPdaStr,\n      matchId: matchIdHex,\n      commitment: commitment.toString(\"hex\"),\n      lastValidBlockHeight,\n    }, 200);\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /history — recent settled Pot Shot rounds\n  // -----------------------------------------------------------------------\n\n  app.openapi(psHistoryRoute, async (c) => {\n    const { limit: limitParam } = c.req.valid(\"query\");\n    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 50);\n\n    const rounds = await db.getRecentSettledRounds(\"potshot\", limit);\n    const settleEvents = await db.getLatestOperatorEventsForPdas(\n      rounds.map((r) => r.pda),\n      \"settle_confirmed\",\n    );\n\n    return c.json({\n      rounds: rounds.map((r) => formatPotShotRound(r, settleEvents.get(r.pda))),\n    }, 200);\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /by-id/:matchId — lookup by 16-char hex match ID\n  // -----------------------------------------------------------------------\n\n  app.openapi(psByIdRoute, async (c) => {\n    const { matchId } = c.req.valid(\"param\");\n    if (!/^[0-9a-f]{16}$/i.test(matchId)) {\n      return c.json(errorMessage(\"matchId must be a 16-char hex string\"), 400);\n    }\n\n    const round = await db.getRoundByMatchId(matchId.toLowerCase());\n    if (!round || round.game !== \"potshot\") {\n      return c.json(errorMessage(\"Round not found\"), 404);\n    }\n\n    return c.json(await enrichPotShotRound(db, round), 200);\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /verify/:pda — lookup by PDA with full verification data\n  // -----------------------------------------------------------------------\n\n  app.openapi(psVerifyRoute, async (c) => {\n    const { pda } = c.req.valid(\"param\");\n    const round = await db.getRoundByPda(pda);\n    if (!round || round.game !== \"potshot\") {\n      return c.json(errorMessage(\"Round not found\"), 404);\n    }\n\n    return c.json(await enrichPotShotRound(db, round), 200);\n  });\n\n  return app;\n}\n\n// ---------------------------------------------------------------------------\n// Pot Shot response formatting\n// ---------------------------------------------------------------------------\n\nfunction getEventPayload(event: OperatorEvent | undefined): Record<string, unknown> | null {\n  if (!event || typeof event.payload !== \"object\" || event.payload === null) return null;\n  return event.payload as Record<string, unknown>;\n}\n\nfunction getNullableString(value: unknown): string | null | undefined {\n  if (value === null) return null;\n  return typeof value === \"string\" ? value : undefined;\n}\n\nfunction getNullableInt(value: unknown): number | null | undefined {\n  if (value === null) return null;\n  return typeof value === \"number\" && Number.isInteger(value) ? value : undefined;\n}\n\nfunction getRoundEntries(value: unknown): RoundEntry[] | undefined {\n  const parsed = z.array(RoundEntrySchema).safeParse(value);\n  return parsed.success ? parsed.data : undefined;\n}\n\nfunction formatPotShotRound(round: Round, settleEvent?: OperatorEvent): PotShotRoundResponse {\n  const isSettled = round.phase === \"settled\";\n  const settlePayload = getEventPayload(settleEvent);\n\n  const response: PotShotRoundResponse = {\n    pda: round.pda,\n    game: \"pot-shot\",\n    phase: round.phase,\n    creator: round.creator,\n    commitment: round.commitment.toString(\"hex\"),\n    amountLamports: round.amount_lamports,\n    side: round.side,\n    matchId: round.match_id,\n    createdAt: round.created_at.toISOString(),\n    updatedAt: round.updated_at.toISOString(),\n  };\n\n  if (round.target_slot !== null) {\n    response.targetSlot = Number(round.target_slot);\n  }\n\n  if (isSettled) {\n    response.secret = round.secret.toString(\"hex\");\n    response.resultHash = round.result_hash ? round.result_hash.toString(\"hex\") : null;\n    if (round.result_side !== null) {\n      response.winningEntryIndex = round.result_side;\n    }\n    if (round.winner) {\n      response.winner = round.winner;\n    }\n    if (round.settle_tx) {\n      response.settleTx = round.settle_tx;\n    }\n    response.totalAmountLamports = round.amount_lamports;\n    response.verification = {\n      commitmentCheck: \"sha256(secret) == commitment\",\n      resultFormula: \"sha256(secret || entropy || pda || algorithmVersion)\",\n      entropySource: \"SlotHashes sysvar at target_slot\",\n    };\n\n    if (Array.isArray(round.entries)) {\n      response.entries = round.entries;\n    }\n\n    if (settlePayload) {\n      const entries = getRoundEntries(settlePayload.entries);\n      const entropy = getNullableString(settlePayload.entropy);\n      const payoutAmount = getNullableInt(settlePayload.payoutAmount);\n      const feeAmount = getNullableInt(settlePayload.feeAmount);\n      const winningOffset = getNullableString(settlePayload.winningOffset);\n      const totalAmountLamports = getNullableInt(settlePayload.totalAmountLamports);\n      const rentRefund = getNullableInt(settlePayload.rentRefund);\n\n      if (!response.entries && entries) {\n        response.entries = entries;\n      }\n      if (entropy !== undefined) {\n        response.entropy = entropy;\n      }\n      if (payoutAmount !== undefined) {\n        response.payoutAmount = payoutAmount;\n      }\n      if (feeAmount !== undefined) {\n        response.feeAmount = feeAmount;\n      }\n      if (winningOffset !== undefined) {\n        response.winningOffset = winningOffset;\n      }\n      if (totalAmountLamports !== undefined) {\n        response.totalAmountLamports = totalAmountLamports;\n      }\n      if (rentRefund !== undefined) {\n        response.rentRefund = rentRefund;\n      }\n    }\n  }\n\n  return response;\n}\n\nasync function enrichPotShotRound(db: Db, round: Round) {\n  let settleEvent: OperatorEvent | undefined;\n  if (round.phase === \"settled\") {\n    try {\n      settleEvent = await db.getLatestOperatorEvent(round.pda, \"settle_confirmed\");\n    } catch {\n      // Gracefully degrade\n    }\n  }\n  return formatPotShotRound(round, settleEvent);\n}\n","numLines":626,"startLine":1,"totalLines":626}}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01VEv3W75pYiaZRdVsc5RUu9","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01P2a1vxAZ8mjvtPtWDCXhNb","name":"Read","input":{"file_path":"/workspaces/rng-utopia/backend/src/routes/create.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":26596,"cache_read_input_tokens":42371,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":26596},"output_tokens":57,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"32e06d79-d550-426e-9fdd-421cb060dd82","uuid":"5da7b378-36a9-43c2-875f-5bdb840276b7"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P2a1vxAZ8mjvtPtWDCXhNb","type":"tool_result","content":"1\t/**\n2\t * Flip You routes.\n3\t *\n4\t * POST /flip-you/create   — create a new match\n5\t * GET  /flip-you/history   — recent settled matches\n6\t * GET  /flip-you/by-id/:matchId — lookup by match ID\n7\t * GET  /flip-you/verify/:pda    — lookup by PDA with verification data\n8\t */\n9\t\n10\timport { createRoute } from \"@hono/zod-openapi\";\n11\timport { z } from \"zod\";\n12\timport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\n13\timport { generateSecret, computeCommitment, generateMatchId, deriveMatchPda } from \"../fairness.js\";\n14\timport { buildCreateMatchTx } from \"../tx-builder.js\";\n15\timport type { Db, Round, OperatorEvent } from \"../db.js\";\n16\timport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n17\timport {\n18\t  envelope,\n19\t  ErrorEnvelopeSchema,\n20\t  ok,\n21\t  err,\n22\t} from \"../contracts/api-envelope.js\";\n23\timport { logger } from \"../logger.js\";\n24\timport type { AppEnv } from \"../hono-env.js\";\n25\timport type { PdaWatcher } from \"../worker/pda-watcher.js\";\n26\timport {\n27\t  FlipYouCreateResponseSchema,\n28\t  FlipYouRoundResponseSchema,\n29\t  RoundEntrySchema,\n30\t  listEnvelopeResponseSchema,\n31\t} from \"../contracts/validators.js\";\n32\timport { createOpenApiApp } from \"../openapi/hono.js\";\n33\t\n34\texport interface CreateRoutesDeps {\n35\t  db: Db;\n36\t  connection: Connection;\n37\t  serverKeypair: Keypair;\n38\t  pdaWatcher?: PdaWatcher;\n39\t}\n40\t\n41\t/** Minimum wager in lamports: 0.001 SOL */\n42\tconst MIN_WAGER_LAMPORTS = 1_000_000;\n43\tconst MAX_WAGER_LAMPORTS = 100_000_000_000; // 100 SOL\n44\t\n45\tfunction isValidBase58(s: string): boolean {\n46\t  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n47\t}\n48\t\n49\t// ── Request schemas ──────────────────────────────────────────────────────\n50\t\n51\tconst FlipYouCreateBodySchema = z.object({\n52\t  wallet: z.string(),\n53\t  amountLamports: z.number().int().min(MIN_WAGER_LAMPORTS).max(MAX_WAGER_LAMPORTS),\n54\t  side: z.union([z.literal(0), z.literal(1)]),\n55\t});\n56\t\n57\tconst LimitQuerySchema = z.object({\n58\t  limit: z.string().optional(),\n59\t});\n60\t\n61\tconst MatchIdParamSchema = z.object({\n62\t  matchId: z.string(),\n63\t});\n64\t\n65\tconst PdaParamSchema = z.object({\n66\t  pda: z.string(),\n67\t});\n68\t\n69\t// ── Route definitions ────────────────────────────────────────────────────\n70\t\n71\tconst createMatchRoute = createRoute({\n72\t  method: \"post\",\n73\t  path: \"/create\",\n74\t  tags: [\"FlipYou\"],\n75\t  summary: \"Create a new Flip You match\",\n76\t  security: [{ bearerAuth: [] }],\n77\t  request: {\n78\t    body: {\n79\t      required: true,\n80\t      content: {\n81\t        \"application/json\": { schema: FlipYouCreateBodySchema },\n82\t      },\n83\t    },\n84\t  },\n85\t  responses: {\n86\t    200: {\n87\t      content: { \"application/json\": { schema: envelope(FlipYouCreateResponseSchema) } },\n88\t      description: \"Match created successfully\",\n89\t    },\n90\t    400: {\n91\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n92\t      description: \"Invalid wallet format\",\n93\t    },\n94\t    403: {\n95\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n96\t      description: \"Wallet mismatch with authenticated session\",\n97\t    },\n98\t    409: {\n99\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n100\t      description: \"Match ID collision\",\n101\t    },\n102\t    422: {\n103\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n104\t      description: \"Invalid request body\",\n105\t    },\n106\t    500: {\n107\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n108\t      description: \"Transaction build failed\",\n109\t    },\n110\t  },\n111\t});\n112\t\n113\tconst FlipYouHistoryResponseSchema = listEnvelopeResponseSchema(\n114\t  \"rounds\",\n115\t  FlipYouRoundResponseSchema,\n116\t);\n117\t\n118\ttype RoundEntry = z.infer<typeof RoundEntrySchema>;\n119\ttype FlipYouRoundResponse = z.infer<typeof FlipYouRoundResponseSchema>;\n120\t\n121\tconst historyRoute = createRoute({\n122\t  method: \"get\",\n123\t  path: \"/history\",\n124\t  tags: [\"FlipYou\"],\n125\t  summary: \"Get recent settled matches\",\n126\t  request: {\n127\t    query: LimitQuerySchema,\n128\t  },\n129\t  responses: {\n130\t    200: {\n131\t      content: {\n132\t        \"application/json\": {\n133\t          schema: envelope(FlipYouHistoryResponseSchema),\n134\t        },\n135\t      },\n136\t      description: \"List of settled matches\",\n137\t    },\n138\t  },\n139\t});\n140\t\n141\tconst byIdRoute = createRoute({\n142\t  method: \"get\",\n143\t  path: \"/by-id/{matchId}\",\n144\t  tags: [\"FlipYou\"],\n145\t  summary: \"Lookup match by ID\",\n146\t  request: {\n147\t    params: MatchIdParamSchema,\n148\t  },\n149\t  responses: {\n150\t    200: {\n151\t      content: { \"application/json\": { schema: envelope(FlipYouRoundResponseSchema) } },\n152\t      description: \"Match found\",\n153\t    },\n154\t    400: {\n155\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n156\t      description: \"Invalid match ID format\",\n157\t    },\n158\t    404: {\n159\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n160\t      description: \"Match not found\",\n161\t    },\n162\t  },\n163\t});\n164\t\n165\tconst verifyRoute = createRoute({\n166\t  method: \"get\",\n167\t  path: \"/verify/{pda}\",\n168\t  tags: [\"FlipYou\"],\n169\t  summary: \"Lookup match by PDA with verification data\",\n170\t  request: {\n171\t    params: PdaParamSchema,\n172\t  },\n173\t  responses: {\n174\t    200: {\n175\t      content: { \"application/json\": { schema: envelope(FlipYouRoundResponseSchema) } },\n176\t      description: \"Match verification data\",\n177\t    },\n178\t    404: {\n179\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n180\t      description: \"Match not found\",\n181\t    },\n182\t  },\n183\t});\n184\t\n185\t// ── Factory ──────────────────────────────────────────────────────────────\n186\t\n187\texport function createFlipYouRoutes(deps: CreateRoutesDeps) {\n188\t  const { db, connection, serverKeypair, pdaWatcher } = deps;\n189\t\n190\t  const app = createOpenApiApp<AppEnv>();\n191\t\n192\t  // POST /create\n193\t  app.openapi(createMatchRoute, async (c) => {\n194\t    // 1. Parse + validate request body (Zod handles shape validation)\n195\t    const body = c.req.valid(\"json\");\n196\t\n197\t    // Additional validation: base58 format\n198\t    if (!isValidBase58(body.wallet)) {\n199\t      logger.warn(\"flipyou create rejected: invalid wallet format\", {\n200\t        wallet: body.wallet,\n201\t      });\n202\t      return err(\n203\t        c,\n204\t        400,\n205\t        API_ERROR_CODES.INVALID_REQUEST,\n206\t        \"wallet must be a valid base58 public key\",\n207\t        { retryable: false },\n208\t      );\n209\t    }\n210\t\n211\t    // 2. Defense-in-depth: verify body wallet matches authenticated user's profile\n212\t    const userId = c.get(\"userId\");\n213\t    const profile = userId ? await db.getProfileByUserId(userId) : null;\n214\t    if (profile && body.wallet !== profile.wallet) {\n215\t      logger.warn(\"flipyou create rejected: wallet mismatch with profile\", {\n216\t        bodyWallet: body.wallet,\n217\t        profileWallet: profile.wallet,\n218\t      });\n219\t      return err(\n220\t        c,\n221\t        403,\n222\t        API_ERROR_CODES.FORBIDDEN,\n223\t        \"Wallet does not match authenticated session\",\n224\t        { retryable: false },\n225\t      );\n226\t    }\n227\t\n228\t    // 3. Validate wallet is a real public key\n229\t    let creatorPubkey: PublicKey;\n230\t    try {\n231\t      creatorPubkey = new PublicKey(body.wallet);\n232\t    } catch {\n233\t      logger.warn(\"flipyou create rejected: invalid wallet\", {\n234\t        wallet: body.wallet,\n235\t      });\n236\t      return err(\n237\t        c,\n238\t        400,\n239\t        API_ERROR_CODES.INVALID_REQUEST,\n240\t        \"wallet is not a valid public key\",\n241\t        { retryable: false },\n242\t      );\n243\t    }\n244\t\n245\t    logger.info(\"flipyou create requested\", {\n246\t      wallet: body.wallet,\n247\t      amountLamports: body.amountLamports,\n248\t      side: body.side,\n249\t    });\n250\t\n251\t    // 4. Generate secret + commitment + matchId\n252\t    const secret = generateSecret();\n253\t    const commitment = computeCommitment(secret);\n254\t    const matchId = generateMatchId();\n255\t\n256\t    // 5. Derive PDA\n257\t    const [matchPda] = deriveMatchPda(creatorPubkey, matchId);\n258\t    const matchPdaStr = matchPda.toBase58();\n259\t\n260\t    // 6. Check for duplicate PDA in DB (409 Conflict)\n261\t    const existing = await db.getRoundByPda(matchPdaStr);\n262\t    if (existing) {\n263\t      logger.warn(\"flipyou create rejected: duplicate match PDA\", {\n264\t        wallet: body.wallet,\n265\t        matchPda: matchPdaStr,\n266\t        matchId: matchId.toString(\"hex\"),\n267\t      });\n268\t      return err(\n269\t        c,\n270\t        409,\n271\t        API_ERROR_CODES.CONFLICT,\n272\t        \"Match ID collision — please retry\",\n273\t        { retryable: true },\n274\t      );\n275\t    }\n276\t\n277\t    // 7. Build + partial-sign transaction\n278\t    let transaction: string;\n279\t    let lastValidBlockHeight: number;\n280\t    try {\n281\t      const result = await buildCreateMatchTx({\n282\t        connection,\n283\t        creator: creatorPubkey,\n284\t        serverKeypair,\n285\t        commitment,\n286\t        amountLamports: body.amountLamports,\n287\t        side: body.side,\n288\t        matchId,\n289\t      });\n290\t      transaction = result.transaction;\n291\t      lastValidBlockHeight = result.lastValidBlockHeight;\n292\t    } catch (buildError) {\n293\t      logger.error(\"flipyou create failed: transaction build error\", {\n294\t        wallet: body.wallet,\n295\t        matchPda: matchPdaStr,\n296\t        matchId: matchId.toString(\"hex\"),\n297\t        error: buildError instanceof Error ? buildError.message : \"Failed to build transaction\",\n298\t      });\n299\t      return err(\n300\t        c,\n301\t        500,\n302\t        API_ERROR_CODES.PRECONDITION_FAILED,\n303\t        \"Failed to build transaction\",\n304\t      );\n305\t    }\n306\t\n307\t    // 8. Store round in DB (phase: created)\n308\t    try {\n309\t      await db.insertRound({\n310\t        pda: matchPdaStr,\n311\t        game: \"flipyou\",\n312\t        creator: body.wallet,\n313\t        serverKey: serverKeypair.publicKey.toBase58(),\n314\t        secret,\n315\t        commitment,\n316\t        amountLamports: body.amountLamports,\n317\t        side: body.side,\n318\t        matchId: matchId.toString(\"hex\"),\n319\t        phase: \"created\",\n320\t      });\n321\t    } catch (insertError) {\n322\t      // Handle race condition — another request inserted the same PDA\n323\t      if (insertError instanceof Error && insertError.message.includes(\"duplicate\")) {\n324\t        logger.warn(\"flipyou create rejected: round insert duplicate\", {\n325\t          wallet: body.wallet,\n326\t          matchPda: matchPdaStr,\n327\t          matchId: matchId.toString(\"hex\"),\n328\t        });\n329\t        return err(\n330\t          c,\n331\t          409,\n332\t          API_ERROR_CODES.CONFLICT,\n333\t          \"Match ID collision — please retry\",\n334\t          { retryable: true },\n335\t        );\n336\t      }\n337\t      logger.error(\"flipyou create failed: round insert error\", {\n338\t        wallet: body.wallet,\n339\t        matchPda: matchPdaStr,\n340\t        matchId: matchId.toString(\"hex\"),\n341\t        error: insertError instanceof Error ? insertError.message : String(insertError),\n342\t      });\n343\t      throw insertError;\n344\t    }\n345\t\n346\t    // 9. Write participation-time game entry (visible before settlement)\n347\t    try {\n348\t      if (profile) {\n349\t        await db.upsertGameEntry({\n350\t          userId: profile.user_id,\n351\t          wallet: body.wallet,\n352\t          game: \"flipyou\",\n353\t          roundPda: matchPdaStr,\n354\t          matchId: matchId.toString(\"hex\"),\n355\t          amountLamports: body.amountLamports,\n356\t          side: body.side === 0 ? \"heads\" : \"tails\",\n357\t        });\n358\t      }\n359\t    } catch (entryError) {\n360\t      // Non-fatal — entry will be created at settlement if this fails\n361\t      logger.warn(\"flipyou create: game_entry insert failed\", {\n362\t        error: entryError instanceof Error ? entryError.message : String(entryError),\n363\t      });\n364\t    }\n365\t\n366\t    // 10. Write operator event\n367\t    await db.insertOperatorEvent(matchPdaStr, \"secret_generated\", {\n368\t      creator: body.wallet,\n369\t      amountLamports: body.amountLamports,\n370\t      side: body.side,\n371\t      matchId: matchId.toString(\"hex\"),\n372\t    });\n373\t\n374\t    // 9b. Subscribe to PDA for instant join detection via WebSocket\n375\t    pdaWatcher?.watch(matchPdaStr);\n376\t\n377\t    logger.info(\"flipyou create prepared\", {\n378\t      wallet: body.wallet,\n379\t      matchPda: matchPdaStr,\n380\t      matchId: matchId.toString(\"hex\"),\n381\t      amountLamports: body.amountLamports,\n382\t      side: body.side,\n383\t      lastValidBlockHeight,\n384\t    });\n385\t\n386\t    // 10. Return response\n387\t    return ok(c, {\n388\t      transaction,\n389\t      matchPda: matchPdaStr,\n390\t      matchId: matchId.toString(\"hex\"),\n391\t      commitment: commitment.toString(\"hex\"),\n392\t      lastValidBlockHeight,\n393\t    });\n394\t  });\n395\t\n396\t  // -----------------------------------------------------------------------\n397\t  // GET /history — recent settled Flip You matches\n398\t  // -----------------------------------------------------------------------\n399\t\n400\t  app.openapi(historyRoute, async (c) => {\n401\t    const { limit: limitParam } = c.req.valid(\"query\");\n402\t    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 50);\n403\t\n404\t    const rounds = await db.getRecentSettledRounds(\"flipyou\", limit);\n405\t    const settleEvents = await db.getLatestOperatorEventsForPdas(\n406\t      rounds.map((r) => r.pda),\n407\t      \"settle_confirmed\",\n408\t    );\n409\t\n410\t    return ok(c, {\n411\t      rounds: rounds.map((r) => formatFlipYouRound(r, settleEvents.get(r.pda))),\n412\t    });\n413\t  });\n414\t\n415\t  // -----------------------------------------------------------------------\n416\t  // GET /by-id/:matchId — lookup by 16-char hex match ID\n417\t  // -----------------------------------------------------------------------\n418\t\n419\t  app.openapi(byIdRoute, async (c) => {\n420\t    const { matchId } = c.req.valid(\"param\");\n421\t    if (!/^[0-9a-f]{16}$/i.test(matchId)) {\n422\t      return err(\n423\t        c,\n424\t        400,\n425\t        API_ERROR_CODES.INVALID_REQUEST,\n426\t        \"matchId must be a 16-char hex string\",\n427\t        { retryable: false },\n428\t      );\n429\t    }\n430\t\n431\t    const round = await db.getRoundByMatchId(matchId.toLowerCase());\n432\t    if (!round || round.game !== \"flipyou\") {\n433\t      return err(c, 404, API_ERROR_CODES.MATCH_NOT_FOUND, \"Match not found\");\n434\t    }\n435\t\n436\t    return ok(c, await enrichFlipYouRound(db, round));\n437\t  });\n438\t\n439\t  // -----------------------------------------------------------------------\n440\t  // GET /verify/:pda — lookup by PDA with full verification data\n441\t  // -----------------------------------------------------------------------\n442\t\n443\t  app.openapi(verifyRoute, async (c) => {\n444\t    const { pda } = c.req.valid(\"param\");\n445\t    const round = await db.getRoundByPda(pda);\n446\t    if (!round || round.game !== \"flipyou\") {\n447\t      return err(c, 404, API_ERROR_CODES.MATCH_NOT_FOUND, \"Match not found\");\n448\t    }\n449\t\n450\t    return ok(c, await enrichFlipYouRound(db, round));\n451\t  });\n452\t\n453\t  return app;\n454\t}\n455\t\n456\t// ---------------------------------------------------------------------------\n457\t// FlipYou response formatting\n458\t// ---------------------------------------------------------------------------\n459\t\n460\tfunction getEventPayload(event: OperatorEvent | undefined): Record<string, unknown> | null {\n461\t  if (!event || typeof event.payload !== \"object\" || event.payload === null) return null;\n462\t  return event.payload as Record<string, unknown>;\n463\t}\n464\t\n465\tfunction getNullableString(value: unknown): string | null | undefined {\n466\t  if (value === null) return null;\n467\t  return typeof value === \"string\" ? value : undefined;\n468\t}\n469\t\n470\tfunction getNullableInt(value: unknown): number | null | undefined {\n471\t  if (value === null) return null;\n472\t  return typeof value === \"number\" && Number.isInteger(value) ? value : undefined;\n473\t}\n474\t\n475\tfunction getRoundEntries(value: unknown): RoundEntry[] | undefined {\n476\t  const parsed = z.array(RoundEntrySchema).safeParse(value);\n477\t  return parsed.success ? parsed.data : undefined;\n478\t}\n479\t\n480\tfunction formatFlipYouRound(round: Round, settleEvent?: OperatorEvent): FlipYouRoundResponse {\n481\t  const isSettled = round.phase === \"settled\";\n482\t  const settlePayload = getEventPayload(settleEvent);\n483\t\n484\t  const response: FlipYouRoundResponse = {\n485\t    pda: round.pda,\n486\t    game: \"flip-you\",\n487\t    phase: round.phase,\n488\t    creator: round.creator,\n489\t    commitment: round.commitment.toString(\"hex\"),\n490\t    amountLamports: round.amount_lamports,\n491\t    side: round.side,\n492\t    matchId: round.match_id,\n493\t    createdAt: round.created_at.toISOString(),\n494\t    updatedAt: round.updated_at.toISOString(),\n495\t  };\n496\t\n497\t  if (round.target_slot !== null) {\n498\t    response.targetSlot = Number(round.target_slot);\n499\t  }\n500\t\n501\t  if (isSettled) {\n502\t    response.secret = round.secret.toString(\"hex\");\n503\t    response.resultHash = round.result_hash ? round.result_hash.toString(\"hex\") : null;\n504\t    if (round.result_side !== null) {\n505\t      response.resultSide = round.result_side;\n506\t    }\n507\t    if (round.winner) {\n508\t      response.winner = round.winner;\n509\t    }\n510\t    if (round.settle_tx) {\n511\t      response.settleTx = round.settle_tx;\n512\t    }\n513\t    response.verification = {\n514\t      commitmentCheck: \"sha256(secret) == commitment\",\n515\t      resultFormula: \"sha256(secret || entropy || pda || algorithmVersion)\",\n516\t      entropySource: \"SlotHashes sysvar at target_slot\",\n517\t    };\n518\t\n519\t    if (Array.isArray(round.entries)) {\n520\t      response.entries = round.entries;\n521\t    }\n522\t\n523\t    if (settlePayload) {\n524\t      const entries = getRoundEntries(settlePayload.entries);\n525\t      const entropy = getNullableString(settlePayload.entropy);\n526\t      const payoutAmount = getNullableInt(settlePayload.payoutAmount);\n527\t      const feeAmount = getNullableInt(settlePayload.feeAmount);\n528\t\n529\t      if (!response.entries && entries) {\n530\t        response.entries = entries;\n531\t      }\n532\t      if (entropy !== undefined) {\n533\t        response.entropy = entropy;\n534\t      }\n535\t      if (payoutAmount !== undefined) {\n536\t        response.payoutAmount = payoutAmount;\n537\t      }\n538\t      if (feeAmount !== undefined) {\n539\t        response.feeAmount = feeAmount;\n540\t      }\n541\t    }\n542\t  }\n543\t\n544\t  return response;\n545\t}\n546\t\n547\tasync function enrichFlipYouRound(db: Db, round: Round) {\n548\t  let settleEvent: OperatorEvent | undefined;\n549\t  if (round.phase === \"settled\") {\n550\t    try {\n551\t      settleEvent = await db.getLatestOperatorEvent(round.pda, \"settle_confirmed\");\n552\t    } catch {\n553\t      // Gracefully degrade\n554\t    }\n555\t  }\n556\t  return formatFlipYouRound(round, settleEvent);\n557\t}\n558\t"}]},"parent_tool_use_id":null,"session_id":"32e06d79-d550-426e-9fdd-421cb060dd82","uuid":"b6d7ea09-b29c-49ca-b080-3599dc73906b","timestamp":"2026-04-22T10:18:48.174Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/create.ts","content":"/**\n * Flip You routes.\n *\n * POST /flip-you/create   — create a new match\n * GET  /flip-you/history   — recent settled matches\n * GET  /flip-you/by-id/:matchId — lookup by match ID\n * GET  /flip-you/verify/:pda    — lookup by PDA with verification data\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\nimport { generateSecret, computeCommitment, generateMatchId, deriveMatchPda } from \"../fairness.js\";\nimport { buildCreateMatchTx } from \"../tx-builder.js\";\nimport type { Db, Round, OperatorEvent } from \"../db.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport { logger } from \"../logger.js\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { PdaWatcher } from \"../worker/pda-watcher.js\";\nimport {\n  FlipYouCreateResponseSchema,\n  FlipYouRoundResponseSchema,\n  RoundEntrySchema,\n  listEnvelopeResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface CreateRoutesDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  pdaWatcher?: PdaWatcher;\n}\n\n/** Minimum wager in lamports: 0.001 SOL */\nconst MIN_WAGER_LAMPORTS = 1_000_000;\nconst MAX_WAGER_LAMPORTS = 100_000_000_000; // 100 SOL\n\nfunction isValidBase58(s: string): boolean {\n  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n}\n\n// ── Request schemas ──────────────────────────────────────────────────────\n\nconst FlipYouCreateBodySchema = z.object({\n  wallet: z.string(),\n  amountLamports: z.number().int().min(MIN_WAGER_LAMPORTS).max(MAX_WAGER_LAMPORTS),\n  side: z.union([z.literal(0), z.literal(1)]),\n});\n\nconst LimitQuerySchema = z.object({\n  limit: z.string().optional(),\n});\n\nconst MatchIdParamSchema = z.object({\n  matchId: z.string(),\n});\n\nconst PdaParamSchema = z.object({\n  pda: z.string(),\n});\n\n// ── Route definitions ────────────────────────────────────────────────────\n\nconst createMatchRoute = createRoute({\n  method: \"post\",\n  path: \"/create\",\n  tags: [\"FlipYou\"],\n  summary: \"Create a new Flip You match\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": { schema: FlipYouCreateBodySchema },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(FlipYouCreateResponseSchema) } },\n      description: \"Match created successfully\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid wallet format\",\n    },\n    403: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Wallet mismatch with authenticated session\",\n    },\n    409: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Match ID collision\",\n    },\n    422: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid request body\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Transaction build failed\",\n    },\n  },\n});\n\nconst FlipYouHistoryResponseSchema = listEnvelopeResponseSchema(\n  \"rounds\",\n  FlipYouRoundResponseSchema,\n);\n\ntype RoundEntry = z.infer<typeof RoundEntrySchema>;\ntype FlipYouRoundResponse = z.infer<typeof FlipYouRoundResponseSchema>;\n\nconst historyRoute = createRoute({\n  method: \"get\",\n  path: \"/history\",\n  tags: [\"FlipYou\"],\n  summary: \"Get recent settled matches\",\n  request: {\n    query: LimitQuerySchema,\n  },\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: envelope(FlipYouHistoryResponseSchema),\n        },\n      },\n      description: \"List of settled matches\",\n    },\n  },\n});\n\nconst byIdRoute = createRoute({\n  method: \"get\",\n  path: \"/by-id/{matchId}\",\n  tags: [\"FlipYou\"],\n  summary: \"Lookup match by ID\",\n  request: {\n    params: MatchIdParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(FlipYouRoundResponseSchema) } },\n      description: \"Match found\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid match ID format\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Match not found\",\n    },\n  },\n});\n\nconst verifyRoute = createRoute({\n  method: \"get\",\n  path: \"/verify/{pda}\",\n  tags: [\"FlipYou\"],\n  summary: \"Lookup match by PDA with verification data\",\n  request: {\n    params: PdaParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(FlipYouRoundResponseSchema) } },\n      description: \"Match verification data\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Match not found\",\n    },\n  },\n});\n\n// ── Factory ──────────────────────────────────────────────────────────────\n\nexport function createFlipYouRoutes(deps: CreateRoutesDeps) {\n  const { db, connection, serverKeypair, pdaWatcher } = deps;\n\n  const app = createOpenApiApp<AppEnv>();\n\n  // POST /create\n  app.openapi(createMatchRoute, async (c) => {\n    // 1. Parse + validate request body (Zod handles shape validation)\n    const body = c.req.valid(\"json\");\n\n    // Additional validation: base58 format\n    if (!isValidBase58(body.wallet)) {\n      logger.warn(\"flipyou create rejected: invalid wallet format\", {\n        wallet: body.wallet,\n      });\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"wallet must be a valid base58 public key\",\n        { retryable: false },\n      );\n    }\n\n    // 2. Defense-in-depth: verify body wallet matches authenticated user's profile\n    const userId = c.get(\"userId\");\n    const profile = userId ? await db.getProfileByUserId(userId) : null;\n    if (profile && body.wallet !== profile.wallet) {\n      logger.warn(\"flipyou create rejected: wallet mismatch with profile\", {\n        bodyWallet: body.wallet,\n        profileWallet: profile.wallet,\n      });\n      return err(\n        c,\n        403,\n        API_ERROR_CODES.FORBIDDEN,\n        \"Wallet does not match authenticated session\",\n        { retryable: false },\n      );\n    }\n\n    // 3. Validate wallet is a real public key\n    let creatorPubkey: PublicKey;\n    try {\n      creatorPubkey = new PublicKey(body.wallet);\n    } catch {\n      logger.warn(\"flipyou create rejected: invalid wallet\", {\n        wallet: body.wallet,\n      });\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"wallet is not a valid public key\",\n        { retryable: false },\n      );\n    }\n\n    logger.info(\"flipyou create requested\", {\n      wallet: body.wallet,\n      amountLamports: body.amountLamports,\n      side: body.side,\n    });\n\n    // 4. Generate secret + commitment + matchId\n    const secret = generateSecret();\n    const commitment = computeCommitment(secret);\n    const matchId = generateMatchId();\n\n    // 5. Derive PDA\n    const [matchPda] = deriveMatchPda(creatorPubkey, matchId);\n    const matchPdaStr = matchPda.toBase58();\n\n    // 6. Check for duplicate PDA in DB (409 Conflict)\n    const existing = await db.getRoundByPda(matchPdaStr);\n    if (existing) {\n      logger.warn(\"flipyou create rejected: duplicate match PDA\", {\n        wallet: body.wallet,\n        matchPda: matchPdaStr,\n        matchId: matchId.toString(\"hex\"),\n      });\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.CONFLICT,\n        \"Match ID collision — please retry\",\n        { retryable: true },\n      );\n    }\n\n    // 7. Build + partial-sign transaction\n    let transaction: string;\n    let lastValidBlockHeight: number;\n    try {\n      const result = await buildCreateMatchTx({\n        connection,\n        creator: creatorPubkey,\n        serverKeypair,\n        commitment,\n        amountLamports: body.amountLamports,\n        side: body.side,\n        matchId,\n      });\n      transaction = result.transaction;\n      lastValidBlockHeight = result.lastValidBlockHeight;\n    } catch (buildError) {\n      logger.error(\"flipyou create failed: transaction build error\", {\n        wallet: body.wallet,\n        matchPda: matchPdaStr,\n        matchId: matchId.toString(\"hex\"),\n        error: buildError instanceof Error ? buildError.message : \"Failed to build transaction\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to build transaction\",\n      );\n    }\n\n    // 8. Store round in DB (phase: created)\n    try {\n      await db.insertRound({\n        pda: matchPdaStr,\n        game: \"flipyou\",\n        creator: body.wallet,\n        serverKey: serverKeypair.publicKey.toBase58(),\n        secret,\n        commitment,\n        amountLamports: body.amountLamports,\n        side: body.side,\n        matchId: matchId.toString(\"hex\"),\n        phase: \"created\",\n      });\n    } catch (insertError) {\n      // Handle race condition — another request inserted the same PDA\n      if (insertError instanceof Error && insertError.message.includes(\"duplicate\")) {\n        logger.warn(\"flipyou create rejected: round insert duplicate\", {\n          wallet: body.wallet,\n          matchPda: matchPdaStr,\n          matchId: matchId.toString(\"hex\"),\n        });\n        return err(\n          c,\n          409,\n          API_ERROR_CODES.CONFLICT,\n          \"Match ID collision — please retry\",\n          { retryable: true },\n        );\n      }\n      logger.error(\"flipyou create failed: round insert error\", {\n        wallet: body.wallet,\n        matchPda: matchPdaStr,\n        matchId: matchId.toString(\"hex\"),\n        error: insertError instanceof Error ? insertError.message : String(insertError),\n      });\n      throw insertError;\n    }\n\n    // 9. Write participation-time game entry (visible before settlement)\n    try {\n      if (profile) {\n        await db.upsertGameEntry({\n          userId: profile.user_id,\n          wallet: body.wallet,\n          game: \"flipyou\",\n          roundPda: matchPdaStr,\n          matchId: matchId.toString(\"hex\"),\n          amountLamports: body.amountLamports,\n          side: body.side === 0 ? \"heads\" : \"tails\",\n        });\n      }\n    } catch (entryError) {\n      // Non-fatal — entry will be created at settlement if this fails\n      logger.warn(\"flipyou create: game_entry insert failed\", {\n        error: entryError instanceof Error ? entryError.message : String(entryError),\n      });\n    }\n\n    // 10. Write operator event\n    await db.insertOperatorEvent(matchPdaStr, \"secret_generated\", {\n      creator: body.wallet,\n      amountLamports: body.amountLamports,\n      side: body.side,\n      matchId: matchId.toString(\"hex\"),\n    });\n\n    // 9b. Subscribe to PDA for instant join detection via WebSocket\n    pdaWatcher?.watch(matchPdaStr);\n\n    logger.info(\"flipyou create prepared\", {\n      wallet: body.wallet,\n      matchPda: matchPdaStr,\n      matchId: matchId.toString(\"hex\"),\n      amountLamports: body.amountLamports,\n      side: body.side,\n      lastValidBlockHeight,\n    });\n\n    // 10. Return response\n    return ok(c, {\n      transaction,\n      matchPda: matchPdaStr,\n      matchId: matchId.toString(\"hex\"),\n      commitment: commitment.toString(\"hex\"),\n      lastValidBlockHeight,\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /history — recent settled Flip You matches\n  // -----------------------------------------------------------------------\n\n  app.openapi(historyRoute, async (c) => {\n    const { limit: limitParam } = c.req.valid(\"query\");\n    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 50);\n\n    const rounds = await db.getRecentSettledRounds(\"flipyou\", limit);\n    const settleEvents = await db.getLatestOperatorEventsForPdas(\n      rounds.map((r) => r.pda),\n      \"settle_confirmed\",\n    );\n\n    return ok(c, {\n      rounds: rounds.map((r) => formatFlipYouRound(r, settleEvents.get(r.pda))),\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /by-id/:matchId — lookup by 16-char hex match ID\n  // -----------------------------------------------------------------------\n\n  app.openapi(byIdRoute, async (c) => {\n    const { matchId } = c.req.valid(\"param\");\n    if (!/^[0-9a-f]{16}$/i.test(matchId)) {\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"matchId must be a 16-char hex string\",\n        { retryable: false },\n      );\n    }\n\n    const round = await db.getRoundByMatchId(matchId.toLowerCase());\n    if (!round || round.game !== \"flipyou\") {\n      return err(c, 404, API_ERROR_CODES.MATCH_NOT_FOUND, \"Match not found\");\n    }\n\n    return ok(c, await enrichFlipYouRound(db, round));\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /verify/:pda — lookup by PDA with full verification data\n  // -----------------------------------------------------------------------\n\n  app.openapi(verifyRoute, async (c) => {\n    const { pda } = c.req.valid(\"param\");\n    const round = await db.getRoundByPda(pda);\n    if (!round || round.game !== \"flipyou\") {\n      return err(c, 404, API_ERROR_CODES.MATCH_NOT_FOUND, \"Match not found\");\n    }\n\n    return ok(c, await enrichFlipYouRound(db, round));\n  });\n\n  return app;\n}\n\n// ---------------------------------------------------------------------------\n// FlipYou response formatting\n// ---------------------------------------------------------------------------\n\nfunction getEventPayload(event: OperatorEvent | undefined): Record<string, unknown> | null {\n  if (!event || typeof event.payload !== \"object\" || event.payload === null) return null;\n  return event.payload as Record<string, unknown>;\n}\n\nfunction getNullableString(value: unknown): string | null | undefined {\n  if (value === null) return null;\n  return typeof value === \"string\" ? value : undefined;\n}\n\nfunction getNullableInt(value: unknown): number | null | undefined {\n  if (value === null) return null;\n  return typeof value === \"number\" && Number.isInteger(value) ? value : undefined;\n}\n\nfunction getRoundEntries(value: unknown): RoundEntry[] | undefined {\n  const parsed = z.array(RoundEntrySchema).safeParse(value);\n  return parsed.success ? parsed.data : undefined;\n}\n\nfunction formatFlipYouRound(round: Round, settleEvent?: OperatorEvent): FlipYouRoundResponse {\n  const isSettled = round.phase === \"settled\";\n  const settlePayload = getEventPayload(settleEvent);\n\n  const response: FlipYouRoundResponse = {\n    pda: round.pda,\n    game: \"flip-you\",\n    phase: round.phase,\n    creator: round.creator,\n    commitment: round.commitment.toString(\"hex\"),\n    amountLamports: round.amount_lamports,\n    side: round.side,\n    matchId: round.match_id,\n    createdAt: round.created_at.toISOString(),\n    updatedAt: round.updated_at.toISOString(),\n  };\n\n  if (round.target_slot !== null) {\n    response.targetSlot = Number(round.target_slot);\n  }\n\n  if (isSettled) {\n    response.secret = round.secret.toString(\"hex\");\n    response.resultHash = round.result_hash ? round.result_hash.toString(\"hex\") : null;\n    if (round.result_side !== null) {\n      response.resultSide = round.result_side;\n    }\n    if (round.winner) {\n      response.winner = round.winner;\n    }\n    if (round.settle_tx) {\n      response.settleTx = round.settle_tx;\n    }\n    response.verification = {\n      commitmentCheck: \"sha256(secret) == commitment\",\n      resultFormula: \"sha256(secret || entropy || pda || algorithmVersion)\",\n      entropySource: \"SlotHashes sysvar at target_slot\",\n    };\n\n    if (Array.isArray(round.entries)) {\n      response.entries = round.entries;\n    }\n\n    if (settlePayload) {\n      const entries = getRoundEntries(settlePayload.entries);\n      const entropy = getNullableString(settlePayload.entropy);\n      const payoutAmount = getNullableInt(settlePayload.payoutAmount);\n      const feeAmount = getNullableInt(settlePayload.feeAmount);\n\n      if (!response.entries && entries) {\n        response.entries = entries;\n      }\n      if (entropy !== undefined) {\n        response.entropy = entropy;\n      }\n      if (payoutAmount !== undefined) {\n        response.payoutAmount = payoutAmount;\n      }\n      if (feeAmount !== undefined) {\n        response.feeAmount = feeAmount;\n      }\n    }\n  }\n\n  return response;\n}\n\nasync function enrichFlipYouRound(db: Db, round: Round) {\n  let settleEvent: OperatorEvent | undefined;\n  if (round.phase === \"settled\") {\n    try {\n      settleEvent = await db.getLatestOperatorEvent(round.pda, \"settle_confirmed\");\n    } catch {\n      // Gracefully degrade\n    }\n  }\n  return formatFlipYouRound(round, settleEvent);\n}\n","numLines":558,"startLine":1,"totalLines":558}}}
