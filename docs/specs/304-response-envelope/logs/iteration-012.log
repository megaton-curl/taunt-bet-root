{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NgKgDVc6UtTWSdd9ZG9gSS","type":"tool_result","content":"1\timport { OpenAPIHono } from \"@hono/zod-openapi\";\n2\timport type { Context, Env } from \"hono\";\n3\timport type { z } from \"zod\";\n4\timport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n5\timport { err } from \"../contracts/api-envelope.js\";\n6\t\n7\ttype InvalidRequestResult =\n8\t  | { success: true }\n9\t  | { success: false; error: z.ZodError };\n10\t\n11\texport function invalidRequestHook<E extends Env, P extends string>(\n12\t  result: InvalidRequestResult,\n13\t  c: Context<E, P>,\n14\t) {\n15\t  if (result.success) return;\n16\t  return err(c, 422, API_ERROR_CODES.VALIDATION_FAILED, \"Invalid request\", {\n17\t    retryable: false,\n18\t    details: result.error.issues,\n19\t  });\n20\t}\n21\t\n22\texport function createOpenApiApp<E extends Env = Env>() {\n23\t  return new OpenAPIHono<E>({\n24\t    defaultHook: invalidRequestHook,\n25\t  });\n26\t}\n27\t"}]},"parent_tool_use_id":null,"session_id":"32e06d79-d550-426e-9fdd-421cb060dd82","uuid":"5f5eed6b-b0aa-48f4-b69e-317a86727e86","timestamp":"2026-04-22T10:19:52.827Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/openapi/hono.ts","content":"import { OpenAPIHono } from \"@hono/zod-openapi\";\nimport type { Context, Env } from \"hono\";\nimport type { z } from \"zod\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport { err } from \"../contracts/api-envelope.js\";\n\ntype InvalidRequestResult =\n  | { success: true }\n  | { success: false; error: z.ZodError };\n\nexport function invalidRequestHook<E extends Env, P extends string>(\n  result: InvalidRequestResult,\n  c: Context<E, P>,\n) {\n  if (result.success) return;\n  return err(c, 422, API_ERROR_CODES.VALIDATION_FAILED, \"Invalid request\", {\n    retryable: false,\n    details: result.error.issues,\n  });\n}\n\nexport function createOpenApiApp<E extends Env = Env>() {\n  return new OpenAPIHono<E>({\n    defaultHook: invalidRequestHook,\n  });\n}\n","numLines":27,"startLine":1,"totalLines":27}}}
