{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0171EcqbgFPZYiTLNCRYtcnh","type":"tool_result","content":"1\timport { useEffect, useState } from \"react\";\n2\timport { IconTelegram } from \"./icons\";\n3\timport { useSession } from \"@/context/SessionContext\";\n4\t\n5\tconst rawBackendUrl = import.meta.env.VITE_FAIRNESS_BACKEND_URL;\n6\t\n7\tif (!rawBackendUrl) {\n8\t  throw new Error(\"Missing required VITE_FAIRNESS_BACKEND_URL\");\n9\t}\n10\t\n11\tconst BACKEND_URL = rawBackendUrl.replace(/\\/$/, \"\");\n12\t\n13\tfunction Corner({ position }: { position: \"top-left\" | \"top-right\" | \"bottom-left\" | \"bottom-right\" }) {\n14\t  const base = \"absolute size-3 border-pink shadow-[0px_0px_32px_2px_var(--color-pink-glow)]\";\n15\t  const positions = {\n16\t    \"top-left\": \"-left-px -top-px border-l border-t\",\n17\t    \"top-right\": \"-right-px -top-px border-r border-t\",\n18\t    \"bottom-left\": \"-bottom-px -left-px border-b border-l\",\n19\t    \"bottom-right\": \"-bottom-px -right-px border-b border-r\",\n20\t  };\n21\t  return <div className={`${base} ${positions[position]}`} />;\n22\t}\n23\t\n24\ttype CardState =\n25\t  | { step: \"probing\" }\n26\t  | { step: \"idle\" }\n27\t  | { step: \"loading\" }\n28\t  | { step: \"linked\"; botUrl: string | null; communityUrl: string | null }\n29\t  | { step: \"error\" };\n30\t\n31\texport default function TelegramCard() {\n32\t  const { accessToken } = useSession();\n33\t  const [state, setState] = useState<CardState>({ step: \"probing\" });\n34\t\n35\t  // On mount, probe link status via the same endpoint. For already-linked\n36\t  // users the backend returns { alreadyLinked: true, ... } without generating\n37\t  // a new token (idempotent). For unlinked users it returns a throwaway\n38\t  // deepLink that we intentionally discard — the real one is generated when\n39\t  // the user clicks JOIN TELEGRAM.\n40\t  useEffect(() => {\n41\t    if (!accessToken) return;\n42\t    if (state.step !== \"probing\") return; // only probe from the initial state\n43\t    let cancelled = false;\n44\t    const ctrl = new AbortController();\n45\t    const timeoutId = window.setTimeout(() => ctrl.abort(), 8000);\n46\t    (async () => {\n47\t      try {\n48\t        const res = await fetch(`${BACKEND_URL}/telegram/generate-link`, {\n49\t          method: \"POST\",\n50\t          headers: {\n51\t            \"Content-Type\": \"application/json\",\n52\t            Authorization: `Bearer ${accessToken}`,\n53\t          },\n54\t          signal: ctrl.signal,\n55\t        });\n56\t        if (!res.ok) throw new Error(\"Failed\");\n57\t        const data = await res.json();\n58\t        if (cancelled) return;\n59\t        if (data.alreadyLinked) {\n60\t          setState({\n61\t            step: \"linked\",\n62\t            botUrl: data.botUrl ?? null,\n63\t            communityUrl: data.communityUrl ?? null,\n64\t          });\n65\t        } else {\n66\t          setState({ step: \"idle\" });\n67\t        }\n68\t      } catch {\n69\t        if (!cancelled) setState({ step: \"idle\" });\n70\t      } finally {\n71\t        window.clearTimeout(timeoutId);\n72\t      }\n73\t    })();\n74\t    return () => {\n75\t      cancelled = true;\n76\t      ctrl.abort();\n77\t      window.clearTimeout(timeoutId);\n78\t    };\n79\t  }, [accessToken, state.step]);\n80\t\n81\t  async function handleJoin() {\n82\t    if (!accessToken) return;\n83\t    setState({ step: \"loading\" });\n84\t    try {\n85\t      const res = await fetch(`${BACKEND_URL}/telegram/generate-link`, {\n86\t        method: \"POST\",\n87\t        headers: {\n88\t          \"Content-Type\": \"application/json\",\n89\t          Authorization: `Bearer ${accessToken}`,\n90\t        },\n91\t      });\n92\t      if (!res.ok) throw new Error(\"Failed\");\n93\t      const data = await res.json();\n94\t\n95\t      if (data.alreadyLinked) {\n96\t        setState({ step: \"linked\", botUrl: data.botUrl ?? null, communityUrl: data.communityUrl ?? null });\n97\t      } else if (data.deepLink) {\n98\t        window.open(data.deepLink, \"_blank\", \"noopener\");\n99\t        setState({ step: \"linked\", botUrl: data.botUrl ?? null, communityUrl: data.communityUrl ?? null });\n100\t      }\n101\t    } catch {\n102\t      setState({ step: \"error\" });\n103\t    }\n104\t  }\n105\t\n106\t  const linkBtn = \"flex flex-1 items-center justify-center gap-2 border border-white/30 bg-white/[0.06] px-6 py-3 font-body text-base font-bold uppercase leading-6 text-white transition-[color,border-color,background-color,box-shadow] duration-200 ease-out hover:border-lime/60 hover:bg-lime/[0.06] hover:text-lime hover:shadow-[0_0_24px_0_rgba(175,252,65,0.18)]\";\n107\t\n108\t  return (\n109\t    <section\n110\t      className=\"relative flex flex-1 flex-col gap-6 border border-border p-6 shadow-[0px_32px_64px_0px_#020218]\"\n111\t      style={{\n112\t        backgroundImage: `\n113\t          radial-gradient(ellipse at center top, rgba(255,26,130,0.16) 0%, transparent 50%),\n114\t          radial-gradient(ellipse at center bottom, rgba(22,22,45,0) 0%, rgba(22,22,45,1) 100%),\n115\t          linear-gradient(90deg, #16162d 0%, #16162d 100%)\n116\t        `,\n117\t      }}\n118\t    >\n119\t      <Corner position=\"top-left\" />\n120\t      <Corner position=\"top-right\" />\n121\t      <Corner position=\"bottom-left\" />\n122\t      <Corner position=\"bottom-right\" />\n123\t\n124\t      <div className=\"relative z-10 flex flex-col gap-2\">\n125\t        <h2 className=\"font-heading text-[32px] font-medium leading-10 text-white\">\n126\t          JOIN OUR TELEGRAM\n127\t        </h2>\n128\t        <p\n129\t          className=\"text-base leading-6 tracking-[-0.32px] text-text-default\"\n130\t          style={{ fontFeatureSettings: \"'zero' 1, 'ss04' 1\" }}\n131\t        >\n132\t          Get launch updates, early access invites, and pre-launch event info\n133\t          directly from the TAUNT bot.\n134\t        </p>\n135\t      </div>\n136\t\n137\t      <div className=\"relative z-10 flex flex-col gap-3\">\n138\t        {state.step === \"linked\" ? (\n139\t          <>\n140\t            <div className=\"flex w-full items-center justify-center gap-2 border border-lime/30 bg-lime/10 px-6 py-3 font-body text-base font-bold uppercase leading-6 text-lime\">\n141\t              <IconTelegram className=\"size-5\" />\n142\t              TELEGRAM LINKED\n143\t            </div>\n144\t            <div className=\"flex gap-3\">\n145\t              {state.botUrl && (\n146\t                <a href={state.botUrl} target=\"_blank\" rel=\"noopener noreferrer\" className={linkBtn}>\n147\t                  <IconTelegram className=\"size-4\" />\n148\t                  Open Bot\n149\t                </a>\n150\t              )}\n151\t              {state.communityUrl && (\n152\t                <a href={state.communityUrl} target=\"_blank\" rel=\"noopener noreferrer\" className={linkBtn}>\n153\t                  <IconTelegram className=\"size-4\" />\n154\t                  Join Community\n155\t                </a>\n156\t              )}\n157\t            </div>\n158\t          </>\n159\t        ) : (\n160\t          <button\n161\t            type=\"button\"\n162\t            className=\"flex w-full items-center justify-center gap-2 border border-white/30 bg-pink px-6 py-3 font-body text-base font-bold uppercase leading-6 text-pink-950 shadow-[0px_6px_12px_0px_rgba(2,2,24,0.16)] transition-colors hover:brightness-110 disabled:opacity-50\"\n163\t            onClick={() => void handleJoin()}\n164\t            disabled={state.step === \"loading\" || state.step === \"probing\" || !accessToken}\n165\t          >\n166\t            <IconTelegram className=\"size-5\" />\n167\t            {state.step === \"loading\"\n168\t              ? \"OPENING...\"\n169\t              : state.step === \"probing\"\n170\t                ? \"CHECKING...\"\n171\t                : state.step === \"error\"\n172\t                  ? \"RETRY\"\n173\t                  : \"JOIN TELEGRAM\"}\n174\t          </button>\n175\t        )}\n176\t      </div>\n177\t    </section>\n178\t  );\n179\t}\n180\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_0155fuBK9qQegS1fcVcrMhgr","session_id":"3be46b6c-3354-4668-9b8a-f4306801d133","uuid":"10560278-4aff-4cb8-b82e-f6199b1d9ece","timestamp":"2026-04-22T11:16:00.738Z"}
