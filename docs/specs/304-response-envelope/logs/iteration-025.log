───────────────────────────── */\n67\t\n68\t/** Check whether a referral code exists (no auth required). */\n69\texport async function checkReferralCode(\n70\t  code: string,\n71\t): Promise<boolean> {\n72\t  try {\n73\t    const res = await fetch(\n74\t      `${BACKEND_URL}/public-referral/code/${encodeURIComponent(code)}`,\n75\t    );\n76\t    if (!res.ok) return false;\n77\t    const body = (await res.json()) as { exists: boolean };\n78\t    return body.exists === true;\n79\t  } catch {\n80\t    return false;\n81\t  }\n82\t}\n83\t\n84\t/* ── Authenticated API ─────────────────────────────────────────── */\n85\t\n86\texport async function setReferralCode(\n87\t  token: string,\n88\t  code: string,\n89\t): Promise<ReferralCodeResponse> {\n90\t  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n91\t    method: \"POST\",\n92\t    headers: authHeaders(token),\n93\t    body: JSON.stringify({ code }),\n94\t  });\n95\t  return parseResponse<ReferralCodeResponse>(res);\n96\t}\n97\t\n98\texport async function getReferralCode(\n99\t  token: string,\n100\t): Promise<ReferralCodeResponse> {\n101\t  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n102\t    headers: authHeaders(token),\n103\t  });\n104\t  return parseResponse<ReferralCodeResponse>(res);\n105\t}\n106\t\n107\texport async function applyReferralCode(\n108\t  token: string,\n109\t  code: string,\n110\t): Promise<ApplyReferralResponse> {\n111\t  const res = await fetch(`${BACKEND_URL}/referral/apply`, {\n112\t    method: \"POST\",\n113\t    headers: authHeaders(token),\n114\t    body: JSON.stringify({ code }),\n115\t  });\n116\t  return parseResponse<ApplyReferralResponse>(res);\n117\t}\n118\t\n119\texport async function getReferrer(\n120\t  token: string,\n121\t): Promise<ReferrerResponse> {\n122\t  const res = await fetch(`${BACKEND_URL}/referral/referrer`, {\n123\t    headers: authHeaders(token),\n124\t  });\n125\t  return parseResponse<ReferrerResponse>(res);\n126\t}\n127\t\n128\texport async function getReferralStats(\n129\t  token: string,\n130\t): Promise<ReferralStatsResponse> {\n131\t  const res = await fetch(`${BACKEND_URL}/referral/stats`, {\n132\t    headers: authHeaders(token),\n133\t  });\n134\t  return parseResponse<ReferralStatsResponse>(res);\n135\t}\n136\t\n137\texport async function getReferrals(\n138\t  token: string,\n139\t): Promise<{ items: WaitlistReferral[] }> {\n140\t  const res = await fetch(`${BACKEND_URL}/referral/referrals`, {\n141\t    headers: authHeaders(token),\n142\t  });\n143\t  return parseResponse<{ items: WaitlistReferral[] }>(res);\n144\t}\n145\t"}]},"parent_tool_use_id":null,"session_id":"3be46b6c-3354-4668-9b8a-f4306801d133","uuid":"57dff9fa-5407-4f7e-b5c6-28de5ea0a191","timestamp":"2026-04-22T11:16:47.959Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/waitlist/src/lib/referral-api.ts","content":"const rawBackendUrl = import.meta.env.VITE_FAIRNESS_BACKEND_URL;\n\nif (!rawBackendUrl) {\n  throw new Error(\"Missing required VITE_FAIRNESS_BACKEND_URL\");\n}\n\nconst BACKEND_URL = rawBackendUrl.replace(/\\/$/, \"\");\n\n/* ── Response types ─────────────────────────────────────────────── */\n\nexport interface ReferralCodeResponse {\n  code: string;\n}\n\nexport interface ApplyReferralResponse {\n  referrerUserId: string;\n  benefit: string;\n}\n\nexport interface ReferrerResponse {\n  referrerUserId: string;\n  referrerUsername: string;\n  referrerCode: string | null;\n  linkedAt: string;\n}\n\nexport interface ReferralStatsResponse {\n  referredCount: number;\n  activeCount: number;\n  totalVolumeLamports: string;\n  totalEarnedLamports: string;\n  totalRebateLamports: string;\n  pendingLamports: string;\n}\n\nexport interface WaitlistReferral {\n  refereeUserId: string;\n  refereeUsername: string;\n  createdAt: string;\n}\n\n/* ── Helpers ────────────────────────────────────────────────────── */\n\nasync function parseResponse<T>(res: Response): Promise<T> {\n  const json = await res.json();\n  if (!res.ok) {\n    const err = json?.error;\n    const msg =\n      typeof err === \"string\"\n        ? err\n        : typeof err?.message === \"string\"\n          ? err.message\n          : `Request failed (${res.status})`;\n    throw new Error(msg);\n  }\n  return json as T;\n}\n\nfunction authHeaders(token: string): Record<string, string> {\n  return {\n    \"Content-Type\": \"application/json\",\n    Authorization: `Bearer ${token}`,\n  };\n}\n\n/* ── Public (no auth) ──────────────────────────────────────────── */\n\n/** Check whether a referral code exists (no auth required). */\nexport async function checkReferralCode(\n  code: string,\n): Promise<boolean> {\n  try {\n    const res = await fetch(\n      `${BACKEND_URL}/public-referral/code/${encodeURIComponent(code)}`,\n    );\n    if (!res.ok) return false;\n    const body = (await res.json()) as { exists: boolean };\n    return body.exists === true;\n  } catch {\n    return false;\n  }\n}\n\n/* ── Authenticated API ─────────────────────────────────────────── */\n\nexport async function setReferralCode(\n  token: string,\n  code: string,\n): Promise<ReferralCodeResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    method: \"POST\",\n    headers: authHeaders(token),\n    body: JSON.stringify({ code }),\n  });\n  return parseResponse<ReferralCodeResponse>(res);\n}\n\nexport async function getReferralCode(\n  token: string,\n): Promise<ReferralCodeResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ReferralCodeResponse>(res);\n}\n\nexport async function applyReferralCode(\n  token: string,\n  code: string,\n): Promise<ApplyReferralResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/apply`, {\n    method: \"POST\",\n    headers: authHeaders(token),\n    body: JSON.stringify({ code }),\n  });\n  return parseResponse<ApplyReferralResponse>(res);\n}\n\nexport async function getReferrer(\n  token: string,\n): Promise<ReferrerResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/referrer`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ReferrerResponse>(res);\n}\n\nexport async function getReferralStats(\n  token: string,\n): Promise<ReferralStatsResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/stats`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ReferralStatsResponse>(res);\n}\n\nexport async function getReferrals(\n  token: string,\n): Promise<{ items: WaitlistReferral[] }> {\n  const res = await fetch(`${BACKEND_URL}/referral/referrals`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<{ items: WaitlistReferral[] }>(res);\n}\n","numLines":145,"startLine":1,"totalLines":145}}}
