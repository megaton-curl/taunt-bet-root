{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RdWphkmtKQsQkpNkTVk32e","type":"tool_result","content":"1\t/**\n2\t * Thin fetch wrappers for the /auth/* backend endpoints.\n3\t */\n4\t\n5\tconst rawBackendUrl = import.meta.env.VITE_FAIRNESS_BACKEND_URL as\n6\t  | string\n7\t  | undefined;\n8\t\n9\tif (!rawBackendUrl) {\n10\t  throw new Error(\"Missing required VITE_FAIRNESS_BACKEND_URL\");\n11\t}\n12\t\n13\tconst BACKEND_URL = rawBackendUrl.replace(/\\/$/, \"\");\n14\t\n15\texport interface ChallengeResponse {\n16\t  nonce: string;\n17\t  message: string;\n18\t  expiresAt: string;\n19\t}\n20\t\n21\texport interface VerifyResponse {\n22\t  accessToken: string;\n23\t  accessExpiresAt: string;\n24\t  refreshToken: string;\n25\t  refreshExpiresAt: string;\n26\t}\n27\t\n28\texport interface RefreshResponse {\n29\t  accessToken: string;\n30\t  accessExpiresAt: string;\n31\t  refreshToken: string;\n32\t  refreshExpiresAt: string;\n33\t}\n34\t\n35\tasync function parseResponse<T>(res: Response): Promise<T> {\n36\t  const json = await res.json();\n37\t  if (!res.ok) {\n38\t    const msg = typeof json?.error === \"string\" ? json.error : `Auth request failed (${res.status})`;\n39\t    throw new Error(msg);\n40\t  }\n41\t  return json as T;\n42\t}\n43\t\n44\texport async function requestChallenge(wallet: string): Promise<ChallengeResponse> {\n45\t  const res = await fetch(`${BACKEND_URL}/auth/challenge`, {\n46\t    method: \"POST\",\n47\t    headers: { \"Content-Type\": \"application/json\" },\n48\t    body: JSON.stringify({ wallet }),\n49\t  });\n50\t  return parseResponse<ChallengeResponse>(res);\n51\t}\n52\t\n53\texport async function verifyChallenge(\n54\t  nonce: string,\n55\t  wallet: string,\n56\t  signature: string,\n57\t): Promise<VerifyResponse> {\n58\t  const res = await fetch(`${BACKEND_URL}/auth/verify`, {\n59\t    method: \"POST\",\n60\t    headers: { \"Content-Type\": \"application/json\" },\n61\t    body: JSON.stringify({ nonce, wallet, signature }),\n62\t  });\n63\t  return parseResponse<VerifyResponse>(res);\n64\t}\n65\t\n66\texport async function refreshSession(refreshToken: string): Promise<RefreshResponse> {\n67\t  const res = await fetch(`${BACKEND_URL}/auth/refresh`, {\n68\t    method: \"POST\",\n69\t    headers: { \"Content-Type\": \"application/json\" },\n70\t    body: JSON.stringify({ refreshToken }),\n71\t  });\n72\t  return parseResponse<RefreshResponse>(res);\n73\t}\n74\t\n75\texport async function logout(refreshToken: string): Promise<void> {\n76\t  await fetch(`${BACKEND_URL}/auth/logout`, {\n77\t    method: \"POST\",\n78\t    headers: { \"Content-Type\": \"application/json\" },\n79\t    body: JSON.stringify({ refreshToken }),\n80\t  });\n81\t}\n82\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01E5hECb4PxMbsEvCF4MW2iD","session_id":"3be46b6c-3354-4668-9b8a-f4306801d133","uuid":"8e40b3a3-1c31-4c7e-b9f1-676d06770105","timestamp":"2026-04-22T11:16:23.447Z"}
