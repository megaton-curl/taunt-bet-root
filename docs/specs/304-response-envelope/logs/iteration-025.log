et, signature }),\n62\t  });\n63\t  return parseResponse<VerifyResponse>(res);\n64\t}\n65\t\n66\texport async function refreshSession(refreshToken: string): Promise<RefreshResponse> {\n67\t  const res = await fetch(`${BACKEND_URL}/auth/refresh`, {\n68\t    method: \"POST\",\n69\t    headers: { \"Content-Type\": \"application/json\" },\n70\t    body: JSON.stringify({ refreshToken }),\n71\t  });\n72\t  return parseResponse<RefreshResponse>(res);\n73\t}\n74\t\n75\texport async function logout(refreshToken: string): Promise<void> {\n76\t  await fetch(`${BACKEND_URL}/auth/logout`, {\n77\t    method: \"POST\",\n78\t    headers: { \"Content-Type\": \"application/json\" },\n79\t    body: JSON.stringify({ refreshToken }),\n80\t  });\n81\t}\n82\t"}]},"parent_tool_use_id":null,"session_id":"3be46b6c-3354-4668-9b8a-f4306801d133","uuid":"cbd3e4af-5cba-4348-955d-08cb2c2124d0","timestamp":"2026-04-22T11:16:52.845Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/webapp/src/lib/auth/api.ts","content":"/**\n * Thin fetch wrappers for the /auth/* backend endpoints.\n */\n\nconst rawBackendUrl = import.meta.env.VITE_FAIRNESS_BACKEND_URL as\n  | string\n  | undefined;\n\nif (!rawBackendUrl) {\n  throw new Error(\"Missing required VITE_FAIRNESS_BACKEND_URL\");\n}\n\nconst BACKEND_URL = rawBackendUrl.replace(/\\/$/, \"\");\n\nexport interface ChallengeResponse {\n  nonce: string;\n  message: string;\n  expiresAt: string;\n}\n\nexport interface VerifyResponse {\n  accessToken: string;\n  accessExpiresAt: string;\n  refreshToken: string;\n  refreshExpiresAt: string;\n}\n\nexport interface RefreshResponse {\n  accessToken: string;\n  accessExpiresAt: string;\n  refreshToken: string;\n  refreshExpiresAt: string;\n}\n\nasync function parseResponse<T>(res: Response): Promise<T> {\n  const json = await res.json();\n  if (!res.ok) {\n    const msg = typeof json?.error === \"string\" ? json.error : `Auth request failed (${res.status})`;\n    throw new Error(msg);\n  }\n  return json as T;\n}\n\nexport async function requestChallenge(wallet: string): Promise<ChallengeResponse> {\n  const res = await fetch(`${BACKEND_URL}/auth/challenge`, {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ wallet }),\n  });\n  return parseResponse<ChallengeResponse>(res);\n}\n\nexport async function verifyChallenge(\n  nonce: string,\n  wallet: string,\n  signature: string,\n): Promise<VerifyResponse> {\n  const res = await fetch(`${BACKEND_URL}/auth/verify`, {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ nonce, wallet, signature }),\n  });\n  return parseResponse<VerifyResponse>(res);\n}\n\nexport async function refreshSession(refreshToken: string): Promise<RefreshResponse> {\n  const res = await fetch(`${BACKEND_URL}/auth/refresh`, {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ refreshToken }),\n  });\n  return parseResponse<RefreshResponse>(res);\n}\n\nexport async function logout(refreshToken: string): Promise<void> {\n  await fetch(`${BACKEND_URL}/auth/logout`, {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ refreshToken }),\n  });\n}\n","numLines":82,"startLine":1,"totalLines":82}}}
