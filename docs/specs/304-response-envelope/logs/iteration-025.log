{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016UgmpYSk6rfNJwAYeRDpsD","type":"tool_result","content":"1\tconst rawBackendUrl = import.meta.env.VITE_FAIRNESS_BACKEND_URL;\n2\t\n3\tif (!rawBackendUrl) {\n4\t  throw new Error(\"Missing required VITE_FAIRNESS_BACKEND_URL\");\n5\t}\n6\t\n7\tconst BACKEND_URL = rawBackendUrl.replace(/\\/$/, \"\");\n8\t\n9\t/* ── Response types ─────────────────────────────────────────────── */\n10\t\n11\texport interface ReferralCodeResponse {\n12\t  code: string;\n13\t}\n14\t\n15\texport interface ApplyReferralResponse {\n16\t  referrerUserId: string;\n17\t  benefit: string;\n18\t}\n19\t\n20\texport interface ReferrerResponse {\n21\t  referrerUserId: string;\n22\t  referrerUsername: string;\n23\t  referrerCode: string | null;\n24\t  linkedAt: string;\n25\t}\n26\t\n27\texport interface ReferralStatsResponse {\n28\t  referredCount: number;\n29\t  activeCount: number;\n30\t  totalVolumeLamports: string;\n31\t  totalEarnedLamports: string;\n32\t  totalRebateLamports: string;\n33\t  pendingLamports: string;\n34\t}\n35\t\n36\texport interface WaitlistReferral {\n37\t  refereeUserId: string;\n38\t  refereeUsername: string;\n39\t  createdAt: string;\n40\t}\n41\t\n42\t/* ── Helpers ────────────────────────────────────────────────────── */\n43\t\n44\tasync function parseResponse<T>(res: Response): Promise<T> {\n45\t  const json = await res.json();\n46\t  if (!res.ok) {\n47\t    const err = json?.error;\n48\t    const msg =\n49\t      typeof err === \"string\"\n50\t        ? err\n51\t        : typeof err?.message === \"string\"\n52\t          ? err.message\n53\t          : `Request failed (${res.status})`;\n54\t    throw new Error(msg);\n55\t  }\n56\t  return json as T;\n57\t}\n58\t\n59\tfunction authHeaders(token: string): Record<string, string> {\n60\t  return {\n61\t    \"Content-Type\": \"application/json\",\n62\t    Authorization: `Bearer ${token}`,\n63\t  };\n64\t}\n65\t\n66\t/* ── Public (no auth) ──────────────────────────────────────────── */\n67\t\n68\t/** Check whether a referral code exists (no auth required). */\n69\texport async function checkReferralCode(\n70\t  code: string,\n71\t): Promise<boolean> {\n72\t  try {\n73\t    const res = await fetch(\n74\t      `${BACKEND_URL}/public-referral/code/${encodeURIComponent(code)}`,\n75\t    );\n76\t    if (!res.ok) return false;\n77\t    const body = (await res.json()) as { exists: boolean };\n78\t    return body.exists === true;\n79\t  } catch {\n80\t    return false;\n81\t  }\n82\t}\n83\t\n84\t/* ── Authenticated API ─────────────────────────────────────────── */\n85\t\n86\texport async function setReferralCode(\n87\t  token: string,\n88\t  code: string,\n89\t): Promise<ReferralCodeResponse> {\n90\t  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n91\t    method: \"POST\",\n92\t    headers: authHeaders(token),\n93\t    body: JSON.stringify({ code }),\n94\t  });\n95\t  return parseResponse<ReferralCodeResponse>(res);\n96\t}\n97\t\n98\texport async function getReferralCode(\n99\t  token: string,\n100\t): Promise<ReferralCodeResponse> {\n101\t  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n102\t    headers: authHeaders(token),\n103\t  });\n104\t  return parseResponse<ReferralCodeResponse>(res);\n105\t}\n106\t\n107\texport async function applyReferralCode(\n108\t  token: string,\n109\t  code: string,\n110\t): Promise<ApplyReferralResponse> {\n111\t  const res = await fetch(`${BACKEND_URL}/referral/apply`, {\n112\t    method: \"POST\",\n113\t    headers: authHeaders(token),\n114\t    body: JSON.stringify({ code }),\n115\t  });\n116\t  return parseResponse<ApplyReferralResponse>(res);\n117\t}\n118\t\n119\texport async function getReferrer(\n120\t  token: string,\n121\t): Promise<ReferrerResponse> {\n122\t  const res = await fetch(`${BACKEND_URL}/referral/referrer`, {\n123\t    headers: authHeaders(token),\n124\t  });\n125\t  return parseResponse<ReferrerResponse>(res);\n126\t}\n127\t\n128\texport async function getReferralStats(\n129\t  token: string,\n130\t): Promise<ReferralStatsResponse> {\n131\t  const res = await fetch(`${BACKEND_URL}/referral/stats`, {\n132\t    headers: authHeaders(token),\n133\t  });\n134\t  return parseResponse<ReferralStatsResponse>(res);\n135\t}\n136\t\n137\texport async function getReferrals(\n138\t  token: string,\n139\t): Promise<{ items: WaitlistReferral[] }> {\n140\t  const res = await fetch(`${BACKEND_URL}/referral/referrals`, {\n141\t    headers: authHeaders(token),\n142\t  });\n143\t  return parseResponse<{ items: WaitlistReferral[] }>(res);\n144\t}\n145\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_0155fuBK9qQegS1fcVcrMhgr","session_id":"3be46b6c-3354-4668-9b8a-f4306801d133","uuid":"08e056aa-6d91-4a3c-9cd0-f94a579a08ae","timestamp":"2026-04-22T11:16:00.523Z"}
