/ deepLink that we intentionally discard — the real one is generated when\n  // the user clicks JOIN TELEGRAM.\n  useEffect(() => {\n    if (!accessToken) return;\n    if (state.step !== \"probing\") return; // only probe from the initial state\n    let cancelled = false;\n    const ctrl = new AbortController();\n    const timeoutId = window.setTimeout(() => ctrl.abort(), 8000);\n    (async () => {\n      try {\n        const res = await fetch(`${BACKEND_URL}/telegram/generate-link`, {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\",\n            Authorization: `Bearer ${accessToken}`,\n          },\n          signal: ctrl.signal,\n        });\n        if (!res.ok) throw new Error(\"Failed\");\n        const data = await res.json();\n        if (cancelled) return;\n        if (data.alreadyLinked) {\n          setState({\n            step: \"linked\",\n            botUrl: data.botUrl ?? null,\n            communityUrl: data.communityUrl ?? null,\n          });\n        } else {\n          setState({ step: \"idle\" });\n        }\n      } catch {\n        if (!cancelled) setState({ step: \"idle\" });\n      } finally {\n        window.clearTimeout(timeoutId);\n      }\n    })();\n    return () => {\n      cancelled = true;\n      ctrl.abort();\n      window.clearTimeout(timeoutId);\n    };\n  }, [accessToken, state.step]);\n\n  async function handleJoin() {\n    if (!accessToken) return;\n    setState({ step: \"loading\" });\n    try {\n      const res = await fetch(`${BACKEND_URL}/telegram/generate-link`, {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${accessToken}`,\n        },\n      });\n      if (!res.ok) throw new Error(\"Failed\");\n      const data = await res.json();\n\n      if (data.alreadyLinked) {\n        setState({ step: \"linked\", botUrl: data.botUrl ?? null, communityUrl: data.communityUrl ?? null });\n      }