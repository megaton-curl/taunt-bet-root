{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012hZVui2LMseExNX99osBPR","type":"tool_result","content":"1\timport {\n2\t  useInfiniteQuery,\n3\t  useMutation,\n4\t  useQuery,\n5\t  useQueryClient,\n6\t} from \"@tanstack/react-query\";\n7\timport { authFetch, ApiError, BACKEND_URL } from \"@/lib/api\";\n8\timport { lamportsToSol } from \"@/lib/constants\";\n9\t\n10\t// ── Types ──────────────────────────────────────────────\n11\t\n12\texport { ApiError, lamportsToSol };\n13\t\n14\texport type TxType = \"deposit\" | \"payout\" | \"refund\";\n15\t\n16\texport type Transaction = {\n17\t  id: string;\n18\t  game: string;\n19\t  matchId: string;\n20\t  txType: TxType;\n21\t  amountLamports: string;\n22\t  txSig: string;\n23\t  createdAt: string;\n24\t};\n25\t\n26\ttype TransactionsPage = {\n27\t  transactions: Transaction[];\n28\t  nextCursor: string | null;\n29\t};\n30\t\n31\texport type ReferrerInfo = {\n32\t  referrerWallet: string;\n33\t  referrerCode: string;\n34\t  linkedAt: string;\n35\t};\n36\t\n37\texport type ReferralStats = {\n38\t  referredCount: number;\n39\t  activeCount: number;\n40\t  totalVolumeLamports: string;\n41\t  totalEarnedLamports: string;\n42\t  totalRebateLamports: string;\n43\t  pendingLamports: string;\n44\t};\n45\t\n46\t// ── Transactions ───────────────────────────────────────\n47\t\n48\texport function useTransactions(enabled: boolean, game?: string) {\n49\t  return useInfiniteQuery({\n50\t    queryKey: [\"profile\", \"transactions\", game],\n51\t    queryFn: async ({ pageParam }) => {\n52\t      const params = new URLSearchParams({ limit: \"50\" });\n53\t      if (pageParam) params.set(\"cursor\", pageParam);\n54\t      if (game) params.set(\"game\", game);\n55\t      return authFetch<TransactionsPage>(\n56\t        `/profile/transactions?${params.toString()}`,\n57\t      );\n58\t    },\n59\t    initialPageParam: undefined as string | undefined,\n60\t    getNextPageParam: (lastPage) => lastPage.nextCursor ?? undefined,\n61\t    enabled,\n62\t    staleTime: 60_000,\n63\t  });\n64\t}\n65\t\n66\t/** Flatten all loaded pages into a single transaction array. */\n67\texport function flattenTransactions(\n68\t  pages: TransactionsPage[] | undefined,\n69\t): Transaction[] {\n70\t  if (!pages) return [];\n71\t  return pages.flatMap((p) => p.transactions);\n72\t}\n73\t\n74\t// ── SOL Price ──────────────────────────────────────────\n75\t\n76\texport function useSolPrice() {\n77\t  return useQuery({\n78\t    queryKey: [\"price\", \"sol-usd\"],\n79\t    queryFn: async () => {\n80\t      const res = await fetch(`${BACKEND_URL}/price/sol-usd`);\n81\t      if (!res.ok) return null;\n82\t      const data = (await res.json()) as { price: number };\n83\t      return data.price;\n84\t    },\n85\t    staleTime: 60_000,\n86\t    refetchInterval: 60_000,\n87\t  });\n88\t}\n89\t\n90\t// ── Referral ───────────────────────────────────────────\n91\t\n92\texport function useReferralCode(enabled: boolean) {\n93\t  return useQuery({\n94\t    queryKey: [\"referral\", \"code\"],\n95\t    queryFn: async () => {\n96\t      try {\n97\t        return await authFetch<{ code: string }>(\"/referral/code\");\n98\t      } catch (err) {\n99\t        if (err instanceof ApiError && err.status === 404) return null;\n100\t        throw err;\n101\t      }\n102\t    },\n103\t    enabled,\n104\t    staleTime: Infinity,\n105\t  });\n106\t}\n107\t\n108\texport function useSetReferralCode() {\n109\t  const qc = useQueryClient();\n110\t  return useMutation({\n111\t    mutationFn: (code: string) =>\n112\t      authFetch<{ code: string }>(\"/referral/code\", {\n113\t        method: \"POST\",\n114\t        body: JSON.stringify({ code }),\n115\t      }),\n116\t    onSuccess: () => qc.invalidateQueries({ queryKey: [\"referral\", \"code\"] }),\n117\t  });\n118\t}\n119\t\n120\texport function useReferrer(enabled: boolean) {\n121\t  return useQuery({\n122\t    queryKey: [\"referral\", \"referrer\"],\n123\t    queryFn: async () => {\n124\t      try {\n125\t        return await authFetch<ReferrerInfo>(\"/referral/referrer\");\n126\t      } catch (err) {\n127\t        if (err instanceof ApiError && err.status === 404) return null;\n128\t        throw err;\n129\t      }\n130\t    },\n131\t    enabled,\n132\t    staleTime: Infinity,\n133\t  });\n134\t}\n135\t\n136\texport function useApplyReferralCode() {\n137\t  const qc = useQueryClient();\n138\t  return useMutation({\n139\t    mutationFn: (code: string) =>\n140\t      authFetch<void>(\"/referral/apply\", {\n141\t        method: \"POST\",\n142\t        body: JSON.stringify({ code }),\n143\t      }),\n144\t    onSuccess: () =>\n145\t      qc.invalidateQueries({ queryKey: [\"referral\", \"referrer\"] }),\n146\t  });\n147\t}\n148\t\n149\texport function useReferralStats(enabled: boolean) {\n150\t  return useQuery({\n151\t    queryKey: [\"referral\", \"stats\"],\n152\t    queryFn: () => authFetch<ReferralStats>(\"/referral/stats\"),\n153\t    enabled,\n154\t    staleTime: 60_000,\n155\t  });\n156\t}\n157\t"}]},"parent_tool_use_id":null,"session_id":"3be46b6c-3354-4668-9b8a-f4306801d133","uuid":"78186f07-cec0-463c-b1d5-caa104dc204f","timestamp":"2026-04-22T11:16:58.164Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/webapp/src/pages/profile/profile-data.ts","content":"import {\n  useInfiniteQuery,\n  useMutation,\n  useQuery,\n  useQueryClient,\n} from \"@tanstack/react-query\";\nimport { authFetch, ApiError, BACKEND_URL } from \"@/lib/api\";\nimport { lamportsToSol } from \"@/lib/constants\";\n\n// ── Types ──────────────────────────────────────────────\n\nexport { ApiError, lamportsToSol };\n\nexport type TxType = \"deposit\" | \"payout\" | \"refund\";\n\nexport type Transaction = {\n  id: string;\n  game: string;\n  matchId: string;\n  txType: TxType;\n  amountLamports: string;\n  txSig: string;\n  createdAt: string;\n};\n\ntype TransactionsPage = {\n  transactions: Transaction[];\n  nextCursor: string | null;\n};\n\nexport type ReferrerInfo = {\n  referrerWallet: string;\n  referrerCode: string;\n  linkedAt: string;\n};\n\nexport type ReferralStats = {\n  referredCount: number;\n  activeCount: number;\n  totalVolumeLamports: string;\n  totalEarnedLamports: string;\n  totalRebateLamports: string;\n  pendingLamports: string;\n};\n\n// ── Transactions ───────────────────────────────────────\n\nexport function useTransactions(enabled: boolean, game?: string) {\n  return useInfiniteQuery({\n    queryKey: [\"profile\", \"transactions\", game],\n    queryFn: async ({ pageParam }) => {\n      const params = new URLSearchParams({ limit: \"50\" });\n      if (pageParam) params.set(\"cursor\", pageParam);\n      if (game) params.set(\"game\", game);\n      return authFetch<TransactionsPage>(\n        `/profile/transactions?${params.toString()}`,\n      );\n    },\n    initialPageParam: undefined as string | undefined,\n    getNextPageParam: (lastPage) => lastPage.nextCursor ?? undefined,\n    enabled,\n    staleTime: 60_000,\n  });\n}\n\n/** Flatten all loaded pages into a single transaction array. */\nexport function flattenTransactions(\n  pages: TransactionsPage[] | undefined,\n): Transaction[] {\n  if (!pages) return [];\n  return pages.flatMap((p) => p.transactions);\n}\n\n// ── SOL Price ──────────────────────────────────────────\n\nexport function useSolPrice() {\n  return useQuery({\n    queryKey: [\"price\", \"sol-usd\"],\n    queryFn: async () => {\n      const res = await fetch(`${BACKEND_URL}/price/sol-usd`);\n      if (!res.ok) return null;\n      const data = (await res.json()) as { price: number };\n      return data.price;\n    },\n    staleTime: 60_000,\n    refetchInterval: 60_000,\n  });\n}\n\n// ── Referral ───────────────────────────────────────────\n\nexport function useReferralCode(enabled: boolean) {\n  return useQuery({\n    queryKey: [\"referral\", \"code\"],\n    queryFn: async () => {\n      try {\n        return await authFetch<{ code: string }>(\"/referral/code\");\n      } catch (err) {\n        if (err instanceof ApiError && err.status === 404) return null;\n        throw err;\n      }\n    },\n    enabled,\n    staleTime: Infinity,\n  });\n}\n\nexport function useSetReferralCode() {\n  const qc = useQueryClient();\n  return useMutation({\n    mutationFn: (code: string) =>\n      authFetch<{ code: string }>(\"/referral/code\", {\n        method: \"POST\",\n        body: JSON.stringify({ code }),\n      }),\n    onSuccess: () => qc.invalidateQueries({ queryKey: [\"referral\", \"code\"] }),\n  });\n}\n\nexport function useReferrer(enabled: boolean) {\n  return useQuery({\n    queryKey: [\"referral\", \"referrer\"],\n    queryFn: async () => {\n      try {\n        return await authFetch<ReferrerInfo>(\"/referral/referrer\");\n      } catch (err) {\n        if (err instanceof ApiError && err.status === 404) return null;\n        throw err;\n      }\n    },\n    enabled,\n    staleTime: Infinity,\n  });\n}\n\nexport function useApplyReferralCode() {\n  const qc = useQueryClient();\n  return useMutation({\n    mutationFn: (code: string) =>\n      authFetch<void>(\"/referral/apply\", {\n        method: \"POST\",\n        body: JSON.stringify({ code }),\n      }),\n    onSuccess: () =>\n      qc.invalidateQueries({ queryKey: [\"referral\", \"referrer\"] }),\n  });\n}\n\nexport function useReferralStats(enabled: boolean) {\n  return useQuery({\n    queryKey: [\"referral\", \"stats\"],\n    queryFn: () => authFetch<ReferralStats>(\"/referral/stats\"),\n    enabled,\n    staleTime: 60_000,\n  });\n}\n","numLines":157,"startLine":1,"totalLines":157}}}
