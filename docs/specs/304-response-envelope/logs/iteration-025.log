{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AtJVcVz787svZjFiR4LP4w","type":"tool_result","content":"1\timport type {\n2\t  BackendClient,\n3\t  LeaderboardResult,\n4\t  RedeemLinkResult,\n5\t  ReferralInfo,\n6\t} from \"./commands.js\";\n7\t\n8\tinterface FetchClient {\n9\t  (input: string, init?: RequestInit): Promise<Response>;\n10\t}\n11\t\n12\timport { trimTrailingSlash } from \"./utils.js\";\n13\t\n14\texport interface BackendClientConfig {\n15\t  backendUrl: string;\n16\t  serviceSecret?: string;\n17\t  fetchImpl?: FetchClient;\n18\t  /** Per-request timeout in ms. Default: 5000. */\n19\t  timeoutMs?: number;\n20\t  /** Optional logger for structured error diagnostics. */\n21\t  logger?: { error(message: string, meta?: unknown): void };\n22\t}\n23\t\n24\t/**\n25\t * Backend public JSON responses use the shared envelope contract:\n26\t *   { ok: true,  data }   — success (2xx)\n27\t *   { ok: false, error: { code, message, retryable?, details? } }   — failure (4xx/5xx)\n28\t * See docs/specs/304-response-envelope/spec.md.\n29\t */\n30\tinterface ApiEnvelopeSuccess<T> {\n31\t  ok: true;\n32\t  data: T;\n33\t}\n34\t\n35\tinterface ApiEnvelopeError {\n36\t  ok: false;\n37\t  error: {\n38\t    code: string;\n39\t    message: string;\n40\t    retryable?: boolean;\n41\t    details?: unknown;\n42\t  };\n43\t}\n44\t\n45\ttype ApiEnvelope<T> = ApiEnvelopeSuccess<T> | ApiEnvelopeError;\n46\t\n47\tfunction isEnvelope<T>(value: unknown): value is ApiEnvelope<T> {\n48\t  return typeof value === \"object\" && value !== null && \"ok\" in value;\n49\t}\n50\t\n51\texport function createBackendClient(config: BackendClientConfig): BackendClient {\n52\t  const fetchImpl = config.fetchImpl ?? fetch;\n53\t  const baseUrl = trimTrailingSlash(config.backendUrl);\n54\t  const timeoutMs = config.timeoutMs ?? 5_000;\n55\t  const logger = config.logger;\n56\t\n57\t  function serviceHeaders(): Record<string, string> {\n58\t    return config.serviceSecret\n59\t      ? { \"X-Telegram-Webhook-Secret\": config.serviceSecret }\n60\t      : {};\n61\t  }\n62\t\n63\t  async function requestWithTimeout(\n64\t    op: string,\n65\t    url: string,\n66\t    init: RequestInit,\n67\t  ): Promise<Response | null> {\n68\t    const controller = new AbortController();\n69\t    const timer = setTimeout(() => controller.abort(), timeoutMs);\n70\t    try {\n71\t      return await fetchImpl(url, { ...init, signal: controller.signal });\n72\t    } catch (error) {\n73\t      const isAbort =\n74\t        (error instanceof Error && error.name === \"AbortError\") ||\n75\t        (error instanceof DOMException && error.name === \"AbortError\");\n76\t      logger?.error(\"backend request failed\", {\n77\t        op,\n78\t        url,\n79\t        reason: isAbort ? \"timeout\" : \"network_error\",\n80\t        timeoutMs,\n81\t        error: error instanceof Error ? error.message : String(error),\n82\t      });\n83\t      return null;\n84\t    } finally {\n85\t      clearTimeout(timer);\n86\t    }\n87\t  }\n88\t\n89\t  async function parseEnvelope<T>(\n90\t    op: string,\n91\t    response: Response,\n92\t  ): Promise<ApiEnvelope<T> | null> {\n93\t    try {\n94\t      const body = (await response.json()) as unknown;\n95\t      if (!isEnvelope<T>(body)) {\n96\t        logger?.error(\"backend response missing envelope\", {\n97\t          op,\n98\t          status: response.status,\n99\t        });\n100\t        return null;\n101\t      }\n102\t      return body;\n103\t    } catch (error) {\n104\t      logger?.error(\"backend response parse failed\", {\n105\t        op,\n106\t        status: response.status,\n107\t        error: error instanceof Error ? error.message : String(error),\n108\t      });\n109\t      return null;\n110\t    }\n111\t  }\n112\t\n113\t  return {\n114\t    async getLinkedUserId(telegramUserId): Promise<string | null> {\n115\t      if (!config.serviceSecret) return null;\n116\t      const response = await requestWithTimeout(\n117\t        \"getLinkedUserId\",\n118\t        `${baseUrl}/telegram/linked-user?telegramUserId=${encodeURIComponent(telegramUserId)}`,\n119\t        { headers: serviceHeaders() },\n120\t      );\n121\t      if (!response) return null;\n122\t      const envelope = await parseEnvelope<{ userId: string }>(\n123\t        \"getLinkedUserId\",\n124\t        response,\n125\t      );\n126\t      if (!envelope || !envelope.ok) return null;\n127\t      return envelope.data.userId;\n128\t    },\n129\t\n130\t    async redeemTelegramLink(token, telegramUserId, telegramUsername): Promise<RedeemLinkResult> {\n131\t      if (!config.serviceSecret) {\n132\t        return { ok: false, error: \"UNAUTHORIZED\" };\n133\t      }\n134\t\n135\t      const response = await requestWithTimeout(\n136\t        \"redeemTelegramLink\",\n137\t        `${baseUrl}/telegram/redeem-link`,\n138\t        {\n139\t          method: \"POST\",\n140\t          headers: {\n141\t            \"Content-Type\": \"application/json\",\n142\t            ...serviceHeaders(),\n143\t          },\n144\t          body: JSON.stringify({ token, telegramUserId, telegramUsername }),\n145\t        },\n146\t      );\n147\t      if (!response) return { ok: false, error: \"UNKNOWN\" };\n148\t\n149\t      const envelope = await parseEnvelope<{\n150\t        userId: string;\n151\t        username: string | null;\n152\t        alreadyLinked: boolean;\n153\t      }>(\"redeemTelegramLink\", response);\n154\t      if (!envelope) return { ok: false, error: \"UNKNOWN\" };\n155\t\n156\t      if (envelope.ok) {\n157\t        return {\n158\t          ok: true,\n159\t          userId: envelope.data.userId,\n160\t          username: envelope.data.username,\n161\t          alreadyLinked: envelope.data.alreadyLinked,\n162\t        };\n163\t      }\n164\t\n165\t      switch (envelope.error.code) {\n166\t        case \"TELEGRAM_ALREADY_LINKED\":\n167\t          return { ok: false, error: \"TELEGRAM_ALREADY_LINKED\" };\n168\t        case \"TELEGRAM_TOKEN_EXPIRED\":\n169\t          return { ok: false, error: \"TOKEN_NOT_FOUND\" };\n170\t        case \"AUTH_REQUIRED\":\n171\t          return { ok: false, error: \"UNAUTHORIZED\" };\n172\t        default:\n173\t          return { ok: false, error: \"UNKNOWN\" };\n174\t      }\n175\t    },\n176\t\n177\t    async getReferralInfo(telegramUserId): Promise<ReferralInfo | null> {\n178\t      if (!config.serviceSecret) return null;\n179\t      const response = await requestWithTimeout(\n180\t        \"getReferralInfo\",\n181\t        `${baseUrl}/telegram/referral-info?telegramUserId=${encodeURIComponent(telegramUserId)}`,\n182\t        { headers: serviceHeaders() },\n183\t      );\n184\t      if (!response) return null;\n185\t      const envelope = await parseEnvelope<ReferralInfo>(\n186\t        \"getReferralInfo\",\n187\t        response,\n188\t      );\n189\t      if (!envelope || !envelope.ok) return null;\n190\t      return envelope.data;\n191\t    },\n192\t\n193\t    async getReferralLeaderboard(telegramUserId): Promise<LeaderboardResult | null> {\n194\t      if (!config.serviceSecret) return null;\n195\t      const response = await requestWithTimeout(\n196\t        \"getReferralLeaderboard\",\n197\t        `${baseUrl}/telegram/referral-leaderboard?telegramUserId=${encodeURIComponent(telegramUserId)}`,\n198\t        { headers: serviceHeaders() },\n199\t      );\n200\t      if (!response) return null;\n201\t      const envelope = await parseEnvelope<LeaderboardResult>(\n202\t        \"getReferralLeaderboard\",\n203\t        response,\n204\t      );\n205\t      if (!envelope || !envelope.ok) return null;\n206\t      return envelope.data;\n207\t    },\n208\t  };\n209\t}\n210\t"}]},"parent_tool_use_id":null,"session_id":"3be46b6c-3354-4668-9b8a-f4306801d133","uuid":"cc97b907-ebb7-4daf-a49e-5c608b0521ab","timestamp":"2026-04-22T11:17:05.072Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/telegram/src/backend-client.ts","content":"import type {\n  BackendClient,\n  LeaderboardResult,\n  RedeemLinkResult,\n  ReferralInfo,\n} from \"./commands.js\";\n\ninterface FetchClient {\n  (input: string, init?: RequestInit): Promise<Response>;\n}\n\nimport { trimTrailingSlash } from \"./utils.js\";\n\nexport interface BackendClientConfig {\n  backendUrl: string;\n  serviceSecret?: string;\n  fetchImpl?: FetchClient;\n  /** Per-request timeout in ms. Default: 5000. */\n  timeoutMs?: number;\n  /** Optional logger for structured error diagnostics. */\n  logger?: { error(message: string, meta?: unknown): void };\n}\n\n/**\n * Backend public JSON responses use the shared envelope contract:\n *   { ok: true,  data }   — success (2xx)\n *   { ok: false, error: { code, message, retryable?, details? } }   — failure (4xx/5xx)\n * See docs/specs/304-response-envelope/spec.md.\n */\ninterface ApiEnvelopeSuccess<T> {\n  ok: true;\n  data: T;\n}\n\ninterface ApiEnvelopeError {\n  ok: false;\n  error: {\n    code: string;\n    message: string;\n    retryable?: boolean;\n    details?: unknown;\n  };\n}\n\ntype ApiEnvelope<T> = ApiEnvelopeSuccess<T> | ApiEnvelopeError;\n\nfunction isEnvelope<T>(value: unknown): value is ApiEnvelope<T> {\n  return typeof value === \"object\" && value !== null && \"ok\" in value;\n}\n\nexport function createBackendClient(config: BackendClientConfig): BackendClient {\n  const fetchImpl = config.fetchImpl ?? fetch;\n  const baseUrl = trimTrailingSlash(config.backendUrl);\n  const timeoutMs = config.timeoutMs ?? 5_000;\n  const logger = config.logger;\n\n  function serviceHeaders(): Record<string, string> {\n    return config.serviceSecret\n      ? { \"X-Telegram-Webhook-Secret\": config.serviceSecret }\n      : {};\n  }\n\n  async function requestWithTimeout(\n    op: string,\n    url: string,\n    init: RequestInit,\n  ): Promise<Response | null> {\n    const controller = new AbortController();\n    const timer = setTimeout(() => controller.abort(), timeoutMs);\n    try {\n      return await fetchImpl(url, { ...init, signal: controller.signal });\n    } catch (error) {\n      const isAbort =\n        (error instanceof Error && error.name === \"AbortError\") ||\n        (error instanceof DOMException && error.name === \"AbortError\");\n      logger?.error(\"backend request failed\", {\n        op,\n        url,\n        reason: isAbort ? \"timeout\" : \"network_error\",\n        timeoutMs,\n        error: error instanceof Error ? error.message : String(error),\n      });\n      return null;\n    } finally {\n      clearTimeout(timer);\n    }\n  }\n\n  async function parseEnvelope<T>(\n    op: string,\n    response: Response,\n  ): Promise<ApiEnvelope<T> | null> {\n    try {\n      const body = (await response.json()) as unknown;\n      if (!isEnvelope<T>(body)) {\n        logger?.error(\"backend response missing envelope\", {\n          op,\n          status: response.status,\n        });\n        return null;\n      }\n      return body;\n    } catch (error) {\n      logger?.error(\"backend response parse failed\", {\n        op,\n        status: response.status,\n        error: error instanceof Error ? error.message : String(error),\n      });\n      return null;\n    }\n  }\n\n  return {\n    async getLinkedUserId(telegramUserId): Promise<string | null> {\n      if (!config.serviceSecret) return null;\n      const response = await requestWithTimeout(\n        \"getLinkedUserId\",\n        `${baseUrl}/telegram/linked-user?telegramUserId=${encodeURIComponent(telegramUserId)}`,\n        { headers: serviceHeaders() },\n      );\n      if (!response) return null;\n      const envelope = await parseEnvelope<{ userId: string }>(\n        \"getLinkedUserId\",\n        response,\n      );\n      if (!envelope || !envelope.ok) return null;\n      return envelope.data.userId;\n    },\n\n    async redeemTelegramLink(token, telegramUserId, telegramUsername): Promise<RedeemLinkResult> {\n      if (!config.serviceSecret) {\n        return { ok: false, error: \"UNAUTHORIZED\" };\n      }\n\n      const response = await requestWithTimeout(\n        \"redeemTelegramLink\",\n        `${baseUrl}/telegram/redeem-link`,\n        {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\",\n            ...serviceHeaders(),\n          },\n          body: JSON.stringify({ token, telegramUserId, telegramUsername }),\n        },\n      );\n      if (!response) return { ok: false, error: \"UNKNOWN\" };\n\n      const envelope = await parseEnvelope<{\n        userId: string;\n        username: string | null;\n        alreadyLinked: boolean;\n      }>(\"redeemTelegramLink\", response);\n      if (!envelope) return { ok: false, error: \"UNKNOWN\" };\n\n      if (envelope.ok) {\n        return {\n          ok: true,\n          userId: envelope.data.userId,\n          username: envelope.data.username,\n          alreadyLinked: envelope.data.alreadyLinked,\n        };\n      }\n\n      switch (envelope.error.code) {\n        case \"TELEGRAM_ALREADY_LINKED\":\n          return { ok: false, error: \"TELEGRAM_ALREADY_LINKED\" };\n        case \"TELEGRAM_TOKEN_EXPIRED\":\n          return { ok: false, error: \"TOKEN_NOT_FOUND\" };\n        case \"AUTH_REQUIRED\":\n          return { ok: false, error: \"UNAUTHORIZED\" };\n        default:\n          return { ok: false, error: \"UNKNOWN\" };\n      }\n    },\n\n    async getReferralInfo(telegramUserId): Promise<ReferralInfo | null> {\n      if (!config.serviceSecret) return null;\n      const response = await requestWithTimeout(\n        \"getReferralInfo\",\n        `${baseUrl}/telegram/referral-info?telegramUserId=${encodeURIComponent(telegramUserId)}`,\n        { headers: serviceHeaders() },\n      );\n      if (!response) return null;\n      const envelope = await parseEnvelope<ReferralInfo>(\n        \"getReferralInfo\",\n        response,\n      );\n      if (!envelope || !envelope.ok) return null;\n      return envelope.data;\n    },\n\n    async getReferralLeaderboard(telegramUserId): Promise<LeaderboardResult | null> {\n      if (!config.serviceSecret) return null;\n      const response = await requestWithTimeout(\n        \"getReferralLeaderboard\",\n        `${baseUrl}/telegram/referral-leaderboard?telegramUserId=${encodeURIComponent(telegramUserId)}`,\n        { headers: serviceHeaders() },\n      );\n      if (!response) return null;\n      const envelope = await parseEnvelope<LeaderboardResult>(\n        \"getReferralLeaderboard\",\n        response,\n      );\n      if (!envelope || !envelope.ok) return null;\n      return envelope.data;\n    },\n  };\n}\n","numLines":210,"startLine":1,"totalLines":210}}}
