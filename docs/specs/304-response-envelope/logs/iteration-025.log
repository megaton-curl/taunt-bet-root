{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Lqyvc4Ga3bD7LoEeJ9Ehnf","type":"tool_result","content":"1\t/**\n2\t * Shared transaction error parser.\n3\t *\n4\t * Each game calls `createTransactionErrorParser` with its own game-specific\n5\t * checks and a log label. The returned function runs game overrides first,\n6\t * then falls through to the shared checks that are common across all games.\n7\t */\n8\t\n9\texport type ErrorCheck = (msg: string) => string | null;\n10\t\n11\texport interface TransactionErrorParserOptions {\n12\t  logLabel: string;\n13\t  gameChecks?: ErrorCheck[];\n14\t}\n15\t\n16\tconst sharedChecks: ErrorCheck[] = [\n17\t  (msg) =>\n18\t    msg.includes(\"Wallet not connected\") ||\n19\t    msg.includes(\"WalletNotConnectedError\")\n20\t      ? \"Wallet not connected. Please connect your wallet first.\"\n21\t      : null,\n22\t\n23\t  (msg) =>\n24\t    msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")\n25\t      ? \"Transaction cancelled by user.\"\n26\t      : null,\n27\t\n28\t  (msg) =>\n29\t    msg.includes(\"insufficient lamports\") ||\n30\t    msg.includes(\"Insufficient funds\") ||\n31\t    msg.includes(\"0x1\")\n32\t      ? \"Insufficient balance. You need more SOL to complete this transaction.\"\n33\t      : null,\n34\t\n35\t  (msg) =>\n36\t    msg.includes(\"Failed to fetch\") ||\n37\t    msg.includes(\"NetworkError\") ||\n38\t    msg.includes(\"ECONNREFUSED\")\n39\t      ? \"Network error. Please check your connection and try again.\"\n40\t      : null,\n41\t\n42\t  (msg) =>\n43\t    msg.includes(\"Simulation failed\") ||\n44\t    msg.includes(\"Transaction simulation failed\") ||\n45\t    msg.includes(\"Transaction will fail\")\n46\t      ? \"Transaction simulation failed. The game state may have changed.\"\n47\t      : null,\n48\t\n49\t  (msg) =>\n50\t    msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")\n51\t      ? \"Transaction expired. Please try again.\"\n52\t      : null,\n53\t\n54\t  (msg) =>\n55\t    msg.includes(\"Unexpected error\")\n56\t      ? \"Wallet encountered an error sending the transaction. Please try again.\"\n57\t      : null,\n58\t];\n59\t\n60\tfunction checkBackendRequestError(err: unknown): string | null {\n61\t  if (\n62\t    typeof err === \"object\" &&\n63\t    err !== null &&\n64\t    \"status\" in err &&\n65\t    typeof (err as Record<string, unknown>).status === \"number\" &&\n66\t    \"message\" in err\n67\t  ) {\n68\t    const status = (err as { status: number }).status;\n69\t    const message = (err as { message: string }).message;\n70\t\n71\t    if (status === 401)\n72\t      return \"Backend authentication failed. Please approve message signing and try again.\";\n73\t    if (status === 409)\n74\t      return \"Action failed due to a conflict — please retry.\";\n75\t    if (status === 429)\n76\t      return \"Too many attempts. Please wait a moment and try again.\";\n77\t    return message;\n78\t  }\n79\t  return null;\n80\t}\n81\t\n82\texport function createTransactionErrorParser(\n83\t  options: TransactionErrorParserOptions,\n84\t): (err: unknown) => string {\n85\t  const { logLabel, gameChecks = [] } = options;\n86\t\n87\t  return (err: unknown): string => {\n88\t    const backendResult = checkBackendRequestError(err);\n89\t    if (backendResult !== null) return backendResult;\n90\t\n91\t    const msg = err instanceof Error ? err.message : String(err);\n92\t\n93\t    for (const check of gameChecks) {\n94\t      const result = check(msg);\n95\t      if (result !== null) return result;\n96\t    }\n97\t\n98\t    for (const check of sharedChecks) {\n99\t      const result = check(msg);\n100\t      if (result !== null) return result;\n101\t    }\n102\t\n103\t    console.error(`[${logLabel}] unhandled transaction error:`, err);\n104\t    return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n105\t  };\n106\t}\n107\t"}]},"parent_tool_use_id":null,"session_id":"3be46b6c-3354-4668-9b8a-f4306801d133","uuid":"7aa02e46-deea-491a-8cd6-3db769a63dbb","timestamp":"2026-04-22T11:16:55.841Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/webapp/src/lib/parse-transaction-error.ts","content":"/**\n * Shared transaction error parser.\n *\n * Each game calls `createTransactionErrorParser` with its own game-specific\n * checks and a log label. The returned function runs game overrides first,\n * then falls through to the shared checks that are common across all games.\n */\n\nexport type ErrorCheck = (msg: string) => string | null;\n\nexport interface TransactionErrorParserOptions {\n  logLabel: string;\n  gameChecks?: ErrorCheck[];\n}\n\nconst sharedChecks: ErrorCheck[] = [\n  (msg) =>\n    msg.includes(\"Wallet not connected\") ||\n    msg.includes(\"WalletNotConnectedError\")\n      ? \"Wallet not connected. Please connect your wallet first.\"\n      : null,\n\n  (msg) =>\n    msg.includes(\"User rejected\") || msg.includes(\"Transaction cancelled\")\n      ? \"Transaction cancelled by user.\"\n      : null,\n\n  (msg) =>\n    msg.includes(\"insufficient lamports\") ||\n    msg.includes(\"Insufficient funds\") ||\n    msg.includes(\"0x1\")\n      ? \"Insufficient balance. You need more SOL to complete this transaction.\"\n      : null,\n\n  (msg) =>\n    msg.includes(\"Failed to fetch\") ||\n    msg.includes(\"NetworkError\") ||\n    msg.includes(\"ECONNREFUSED\")\n      ? \"Network error. Please check your connection and try again.\"\n      : null,\n\n  (msg) =>\n    msg.includes(\"Simulation failed\") ||\n    msg.includes(\"Transaction simulation failed\") ||\n    msg.includes(\"Transaction will fail\")\n      ? \"Transaction simulation failed. The game state may have changed.\"\n      : null,\n\n  (msg) =>\n    msg.includes(\"blockhash not found\") || msg.includes(\"Blockhash not found\")\n      ? \"Transaction expired. Please try again.\"\n      : null,\n\n  (msg) =>\n    msg.includes(\"Unexpected error\")\n      ? \"Wallet encountered an error sending the transaction. Please try again.\"\n      : null,\n];\n\nfunction checkBackendRequestError(err: unknown): string | null {\n  if (\n    typeof err === \"object\" &&\n    err !== null &&\n    \"status\" in err &&\n    typeof (err as Record<string, unknown>).status === \"number\" &&\n    \"message\" in err\n  ) {\n    const status = (err as { status: number }).status;\n    const message = (err as { message: string }).message;\n\n    if (status === 401)\n      return \"Backend authentication failed. Please approve message signing and try again.\";\n    if (status === 409)\n      return \"Action failed due to a conflict — please retry.\";\n    if (status === 429)\n      return \"Too many attempts. Please wait a moment and try again.\";\n    return message;\n  }\n  return null;\n}\n\nexport function createTransactionErrorParser(\n  options: TransactionErrorParserOptions,\n): (err: unknown) => string {\n  const { logLabel, gameChecks = [] } = options;\n\n  return (err: unknown): string => {\n    const backendResult = checkBackendRequestError(err);\n    if (backendResult !== null) return backendResult;\n\n    const msg = err instanceof Error ? err.message : String(err);\n\n    for (const check of gameChecks) {\n      const result = check(msg);\n      if (result !== null) return result;\n    }\n\n    for (const check of sharedChecks) {\n      const result = check(msg);\n      if (result !== null) return result;\n    }\n\n    console.error(`[${logLabel}] unhandled transaction error:`, err);\n    return `Transaction failed: ${msg.length > 100 ? msg.slice(0, 100) + \"...\" : msg}`;\n  };\n}\n","numLines":107,"startLine":1,"totalLines":107}}}
