er-lime/30 bg-lime/10 px-6 py-3 font-body text-base font-bold uppercase leading-6 text-lime\">\n              <IconTelegram className=\"size-5\" />\n              TELEGRAM LINKED\n            </div>\n            <div className=\"flex gap-3\">\n              {state.botUrl && (\n                <a href={state.botUrl} target=\"_blank\" rel=\"noopener noreferrer\" className={linkBtn}>\n                  <IconTelegram className=\"size-4\" />\n                  Open Bot\n                </a>\n              )}\n              {state.communityUrl && (\n                <a href={state.communityUrl} target=\"_blank\" rel=\"noopener noreferrer\" className={linkBtn}>\n                  <IconTelegram className=\"size-4\" />\n                  Join Community\n                </a>\n              )}\n            </div>\n          </>\n        ) : (\n          <button\n            type=\"button\"\n            className=\"flex w-full items-center justify-center gap-2 border border-white/30 bg-pink px-6 py-3 font-body text-base font-bold uppercase leading-6 text-pink-950 shadow-[0px_6px_12px_0px_rgba(2,2,24,0.16)] transition-colors hover:brightness-110 disabled:opacity-50\"\n            onClick={() => void handleJoin()}\n            disabled={state.step === \"loading\" || state.step === \"probing\" || !accessToken}\n          >\n            <IconTelegram className=\"size-5\" />\n            {state.step === \"loading\"\n              ? \"OPENING...\"\n              : state.step === \"probing\"\n                ? \"CHECKING...\"\n                : state.step === \"error\"\n                  ? \"RETRY\"\n                  : \"JOIN TELEGRAM\"}\n          </button>\n        )}\n      </div>\n    </section>\n  );\n}\n","numLines":180,"startLine":1,"totalLines":180}}}
