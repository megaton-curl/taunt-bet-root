{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017YnTEigYrpDaqvLdcz23XJ","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/src/__tests__/rate-limit.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"2ad458c3-c005-455d-991f-02c2d6dc2849","uuid":"01477d6b-3919-42ed-8a0b-489a84c13328","timestamp":"2026-04-22T09:30:36.145Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/rate-limit.test.ts","oldString":"    expect(res.headers.get(\"Retry-After\")).toBe(\"30\");\n    const body = await res.json();\n    expect(body.error.details).toEqual({ retryAfterMs: 30_000 });\n  });","newString":"    expect(res.headers.get(\"Retry-After\")).toBe(\"30\");\n    const body = (await res.json()) as { error: { details: unknown } };\n    expect(body.error.details).toEqual({ retryAfterMs: 30_000 });\n  });","originalFile":"import { describe, it, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { createRateLimitMiddleware } from \"../middleware/rate-limit.js\";\n\nfunction createTestApp(\n  config = { perWallet: 3, global: 10, windowMs: 60_000 },\n) {\n  const app = new Hono();\n  app.use(\"/*\", createRateLimitMiddleware(config));\n  app.post(\"/test\", (c) => c.json({ ok: true }));\n  app.get(\"/test\", (c) => c.json({ ok: true }));\n  return app;\n}\n\nfunction post(wallet: string) {\n  return {\n    method: \"POST\" as const,\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ wallet }),\n  };\n}\n\ndescribe(\"rate-limit middleware\", () => {\n  it(\"allows requests within per-wallet limit\", async () => {\n    const app = createTestApp({ perWallet: 3, global: 100, windowMs: 60_000 });\n    for (let i = 0; i < 3; i++) {\n      const res = await app.request(\"/test\", post(\"wallet1\"));\n      expect(res.status).toBe(200);\n    }\n  });\n\n  it(\"blocks requests exceeding per-wallet limit\", async () => {\n    const app = createTestApp({ perWallet: 2, global: 100, windowMs: 60_000 });\n    await app.request(\"/test\", post(\"wallet1\"));\n    await app.request(\"/test\", post(\"wallet1\"));\n    const res = await app.request(\"/test\", post(\"wallet1\"));\n    expect(res.status).toBe(429);\n    const body = await res.json();\n    expect(body).toEqual({\n      ok: false,\n      error: {\n        code: \"RATE_LIMITED\",\n        message: \"Too many requests\",\n        retryable: true,\n        details: { retryAfterMs: 60_000 },\n      },\n    });\n  });\n\n  it(\"returns Retry-After header on per-wallet 429\", async () => {\n    const app = createTestApp({ perWallet: 1, global: 100, windowMs: 60_000 });\n    await app.request(\"/test\", post(\"wallet1\"));\n    const res = await app.request(\"/test\", post(\"wallet1\"));\n    expect(res.status).toBe(429);\n    expect(res.headers.get(\"Retry-After\")).toBe(\"60\");\n  });\n\n  it(\"tracks wallets independently\", async () => {\n    const app = createTestApp({ perWallet: 1, global: 100, windowMs: 60_000 });\n    const r1 = await app.request(\"/test\", post(\"wallet1\"));\n    const r2 = await app.request(\"/test\", post(\"wallet2\"));\n    expect(r1.status).toBe(200);\n    expect(r2.status).toBe(200);\n    // wallet1 is now exhausted\n    const r3 = await app.request(\"/test\", post(\"wallet1\"));\n    expect(r3.status).toBe(429);\n    // wallet2 is also exhausted\n    const r4 = await app.request(\"/test\", post(\"wallet2\"));\n    expect(r4.status).toBe(429);\n  });\n\n  it(\"enforces global limit across all wallets\", async () => {\n    const app = createTestApp({ perWallet: 10, global: 3, windowMs: 60_000 });\n    await app.request(\"/test\", post(\"w1\"));\n    await app.request(\"/test\", post(\"w2\"));\n    await app.request(\"/test\", post(\"w3\"));\n    const res = await app.request(\"/test\", post(\"w4\"));\n    expect(res.status).toBe(429);\n    const body = await res.json();\n    expect(body).toEqual({\n      ok: false,\n      error: {\n        code: \"RATE_LIMITED\",\n        message: \"Too many requests\",\n        retryable: true,\n        details: { retryAfterMs: 60_000 },\n      },\n    });\n  });\n\n  it(\"returns correct Retry-After seconds based on window\", async () => {\n    const app = createTestApp({ perWallet: 10, global: 1, windowMs: 30_000 });\n    await app.request(\"/test\", post(\"w1\"));\n    const res = await app.request(\"/test\", post(\"w2\"));\n    expect(res.status).toBe(429);\n    expect(res.headers.get(\"Retry-After\")).toBe(\"30\");\n    const body = await res.json();\n    expect(body.error.details).toEqual({ retryAfterMs: 30_000 });\n  });\n\n  it(\"does not rate-limit GET requests\", async () => {\n    const app = createTestApp({ perWallet: 1, global: 1, windowMs: 60_000 });\n    // Exhaust POST limits\n    await app.request(\"/test\", post(\"w1\"));\n    // GET should still work\n    const res = await app.request(\"/test\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n  });\n});\n","structuredPatch":[{"oldStart":94,"oldLines":7,"newStart":94,"newLines":7,"lines":["     const res = await app.request(\"/test\", post(\"w2\"));","     expect(res.status).toBe(429);","     expect(res.headers.get(\"Retry-After\")).toBe(\"30\");","-    const body = await res.json();","+    const body = (await res.json()) as { error: { details: unknown } };","     expect(body.error.details).toEqual({ retryAfterMs: 30_000 });","   });"," "]}],"userModified":false,"replaceAll":false}}
