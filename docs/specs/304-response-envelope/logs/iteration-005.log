{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0124GCKVHKxVBEHK3rm4b6v8","type":"tool_result","content":"1\t/**\n2\t * In-memory sliding-window rate limiting middleware.\n3\t *\n4\t * Applies per-identity and global limits to POST requests only.\n5\t * Counters reset on service restart (acceptable for MVP).\n6\t */\n7\t\n8\timport type { MiddlewareHandler } from \"hono\";\n9\timport { logger } from \"../logger.js\";\n10\t\n11\texport interface RateLimitConfig {\n12\t  /** Max POST requests per authenticated identity per window (default 10). */\n13\t  perWallet: number;\n14\t  /** Max total POST requests per window (default 100). */\n15\t  global: number;\n16\t  /** Window size in milliseconds (default 60_000 = 1 minute). */\n17\t  windowMs: number;\n18\t}\n19\t\n20\tinterface SlidingWindow {\n21\t  timestamps: number[];\n22\t}\n23\t\n24\t/**\n25\t * Prune timestamps older than the window and return the current count.\n26\t */\n27\tfunction countInWindow(window: SlidingWindow, now: number, windowMs: number): number {\n28\t  const cutoff = now - windowMs;\n29\t  // Remove expired entries from the front\n30\t  while (window.timestamps.length > 0 && window.timestamps[0]! <= cutoff) {\n31\t    window.timestamps.shift();\n32\t  }\n33\t  return window.timestamps.length;\n34\t}\n35\t\n36\t/**\n37\t * Creates a Hono middleware that rate-limits POST requests.\n38\t *\n39\t * - Per-identity: keyed by authenticated `userId` when present, else wallet/body fallback.\n40\t * - Global: all POST requests combined.\n41\t * - Returns 429 with `Retry-After` header when either limit is exceeded.\n42\t * - GET requests pass through without rate limiting.\n43\t */\n44\texport function createRateLimitMiddleware(config: RateLimitConfig): MiddlewareHandler {\n45\t  const walletWindows = new Map<string, SlidingWindow>();\n46\t  const globalWindow: SlidingWindow = { timestamps: [] };\n47\t\n48\t  return async (c, next) => {\n49\t    if (c.req.method !== \"POST\") {\n50\t      return next();\n51\t    }\n52\t\n53\t    const now = Date.now();\n54\t    const retryAfterSeconds = Math.ceil(config.windowMs / 1000);\n55\t\n56\t    // Check global limit first\n57\t    const globalCount = countInWindow(globalWindow, now, config.windowMs);\n58\t    if (globalCount >= config.global) {\n59\t      logger.warn(\"rate limit exceeded: global limit\", {\n60\t        path: c.req.path,\n61\t        currentCount: globalCount,\n62\t        limit: config.global,\n63\t        windowMs: config.windowMs,\n64\t      });\n65\t      c.header(\"Retry-After\", String(retryAfterSeconds));\n66\t      return c.json({ error: \"Too many requests\" }, 429);\n67\t    }\n68\t\n69\t    // Extract identity: prefer canonical userId, then body wallet (pre-auth), then IP.\n70\t    let identity: string | undefined;\n71\t    try {\n72\t      identity = c.get(\"userId\") as string | undefined;\n73\t    } catch {\n74\t      // Context variable not set — expected for pre-auth routes\n75\t    }\n76\t    if (!identity) {\n77\t      try {\n78\t        const body = await c.req.json();\n79\t        identity = typeof body.wallet === \"string\" ? body.wallet : undefined;\n80\t      } catch {\n81\t        // If body is not parseable, fall back to IP-based limiting\n82\t      }\n83\t    }\n84\t    // Final fallback: key on IP for pre-auth routes (e.g., /auth/*)\n85\t    if (!identity) {\n86\t      identity = c.req.header(\"x-forwarded-for\")?.split(\",\")[0]?.trim()\n87\t        ?? c.req.header(\"x-real-ip\")\n88\t        ?? \"unknown-ip\";\n89\t    }\n90\t\n91\t    // Check per-identity limit\n92\t    if (identity) {\n93\t      let wWindow = walletWindows.get(identity);\n94\t      if (!wWindow) {\n95\t        wWindow = { timestamps: [] };\n96\t        walletWindows.set(identity, wWindow);\n97\t      }\n98\t      const walletCount = countInWindow(wWindow, now, config.windowMs);\n99\t      if (walletCount >= config.perWallet) {\n100\t        logger.warn(\"rate limit exceeded: wallet limit\", {\n101\t          path: c.req.path,\n102\t          identity,\n103\t          currentCount: walletCount,\n104\t          limit: config.perWallet,\n105\t          windowMs: config.windowMs,\n106\t        });\n107\t        c.header(\"Retry-After\", String(retryAfterSeconds));\n108\t        return c.json({ error: \"Too many requests\" }, 429);\n109\t      }\n110\t      wWindow.timestamps.push(now);\n111\t    }\n112\t\n113\t    // Record in global window\n114\t    globalWindow.timestamps.push(now);\n115\t\n116\t    return next();\n117\t  };\n118\t}\n119\t"}]},"parent_tool_use_id":null,"session_id":"2ad458c3-c005-455d-991f-02c2d6dc2849","uuid":"77e3a6f3-5798-4faf-b543-b30b58998a11","timestamp":"2026-04-22T09:29:17.783Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/middleware/rate-limit.ts","content":"/**\n * In-memory sliding-window rate limiting middleware.\n *\n * Applies per-identity and global limits to POST requests only.\n * Counters reset on service restart (acceptable for MVP).\n */\n\nimport type { MiddlewareHandler } from \"hono\";\nimport { logger } from \"../logger.js\";\n\nexport interface RateLimitConfig {\n  /** Max POST requests per authenticated identity per window (default 10). */\n  perWallet: number;\n  /** Max total POST requests per window (default 100). */\n  global: number;\n  /** Window size in milliseconds (default 60_000 = 1 minute). */\n  windowMs: number;\n}\n\ninterface SlidingWindow {\n  timestamps: number[];\n}\n\n/**\n * Prune timestamps older than the window and return the current count.\n */\nfunction countInWindow(window: SlidingWindow, now: number, windowMs: number): number {\n  const cutoff = now - windowMs;\n  // Remove expired entries from the front\n  while (window.timestamps.length > 0 && window.timestamps[0]! <= cutoff) {\n    window.timestamps.shift();\n  }\n  return window.timestamps.length;\n}\n\n/**\n * Creates a Hono middleware that rate-limits POST requests.\n *\n * - Per-identity: keyed by authenticated `userId` when present, else wallet/body fallback.\n * - Global: all POST requests combined.\n * - Returns 429 with `Retry-After` header when either limit is exceeded.\n * - GET requests pass through without rate limiting.\n */\nexport function createRateLimitMiddleware(config: RateLimitConfig): MiddlewareHandler {\n  const walletWindows = new Map<string, SlidingWindow>();\n  const globalWindow: SlidingWindow = { timestamps: [] };\n\n  return async (c, next) => {\n    if (c.req.method !== \"POST\") {\n      return next();\n    }\n\n    const now = Date.now();\n    const retryAfterSeconds = Math.ceil(config.windowMs / 1000);\n\n    // Check global limit first\n    const globalCount = countInWindow(globalWindow, now, config.windowMs);\n    if (globalCount >= config.global) {\n      logger.warn(\"rate limit exceeded: global limit\", {\n        path: c.req.path,\n        currentCount: globalCount,\n        limit: config.global,\n        windowMs: config.windowMs,\n      });\n      c.header(\"Retry-After\", String(retryAfterSeconds));\n      return c.json({ error: \"Too many requests\" }, 429);\n    }\n\n    // Extract identity: prefer canonical userId, then body wallet (pre-auth), then IP.\n    let identity: string | undefined;\n    try {\n      identity = c.get(\"userId\") as string | undefined;\n    } catch {\n      // Context variable not set — expected for pre-auth routes\n    }\n    if (!identity) {\n      try {\n        const body = await c.req.json();\n        identity = typeof body.wallet === \"string\" ? body.wallet : undefined;\n      } catch {\n        // If body is not parseable, fall back to IP-based limiting\n      }\n    }\n    // Final fallback: key on IP for pre-auth routes (e.g., /auth/*)\n    if (!identity) {\n      identity = c.req.header(\"x-forwarded-for\")?.split(\",\")[0]?.trim()\n        ?? c.req.header(\"x-real-ip\")\n        ?? \"unknown-ip\";\n    }\n\n    // Check per-identity limit\n    if (identity) {\n      let wWindow = walletWindows.get(identity);\n      if (!wWindow) {\n        wWindow = { timestamps: [] };\n        walletWindows.set(identity, wWindow);\n      }\n      const walletCount = countInWindow(wWindow, now, config.windowMs);\n      if (walletCount >= config.perWallet) {\n        logger.warn(\"rate limit exceeded: wallet limit\", {\n          path: c.req.path,\n          identity,\n          currentCount: walletCount,\n          limit: config.perWallet,\n          windowMs: config.windowMs,\n        });\n        c.header(\"Retry-After\", String(retryAfterSeconds));\n        return c.json({ error: \"Too many requests\" }, 429);\n      }\n      wWindow.timestamps.push(now);\n    }\n\n    // Record in global window\n    globalWindow.timestamps.push(now);\n\n    return next();\n  };\n}\n","numLines":119,"startLine":1,"totalLines":119}}}
