{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015upCboV19PnwsJL78M95y2","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/src/middleware/rate-limit.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"2ad458c3-c005-455d-991f-02c2d6dc2849","uuid":"32dc07c6-3430-4832-92a6-e04d05afecd2","timestamp":"2026-04-22T09:29:28.993Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/src/middleware/rate-limit.ts","oldString":"import type { MiddlewareHandler } from \"hono\";\nimport { logger } from \"../logger.js\";","newString":"import type { MiddlewareHandler } from \"hono\";\nimport { logger } from \"../logger.js\";\nimport { err } from \"../contracts/api-envelope.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";","originalFile":"/**\n * In-memory sliding-window rate limiting middleware.\n *\n * Applies per-identity and global limits to POST requests only.\n * Counters reset on service restart (acceptable for MVP).\n */\n\nimport type { MiddlewareHandler } from \"hono\";\nimport { logger } from \"../logger.js\";\n\nexport interface RateLimitConfig {\n  /** Max POST requests per authenticated identity per window (default 10). */\n  perWallet: number;\n  /** Max total POST requests per window (default 100). */\n  global: number;\n  /** Window size in milliseconds (default 60_000 = 1 minute). */\n  windowMs: number;\n}\n\ninterface SlidingWindow {\n  timestamps: number[];\n}\n\n/**\n * Prune timestamps older than the window and return the current count.\n */\nfunction countInWindow(window: SlidingWindow, now: number, windowMs: number): number {\n  const cutoff = now - windowMs;\n  // Remove expired entries from the front\n  while (window.timestamps.length > 0 && window.timestamps[0]! <= cutoff) {\n    window.timestamps.shift();\n  }\n  return window.timestamps.length;\n}\n\n/**\n * Creates a Hono middleware that rate-limits POST requests.\n *\n * - Per-identity: keyed by authenticated `userId` when present, else wallet/body fallback.\n * - Global: all POST requests combined.\n * - Returns 429 with `Retry-After` header when either limit is exceeded.\n * - GET requests pass through without rate limiting.\n */\nexport function createRateLimitMiddleware(config: RateLimitConfig): MiddlewareHandler {\n  const walletWindows = new Map<string, SlidingWindow>();\n  const globalWindow: SlidingWindow = { timestamps: [] };\n\n  return async (c, next) => {\n    if (c.req.method !== \"POST\") {\n      return next();\n    }\n\n    const now = Date.now();\n    const retryAfterSeconds = Math.ceil(config.windowMs / 1000);\n\n    // Check global limit first\n    const globalCount = countInWindow(globalWindow, now, config.windowMs);\n    if (globalCount >= config.global) {\n      logger.warn(\"rate limit exceeded: global limit\", {\n        path: c.req.path,\n        currentCount: globalCount,\n        limit: config.global,\n        windowMs: config.windowMs,\n      });\n      c.header(\"Retry-After\", String(retryAfterSeconds));\n      return c.json({ error: \"Too many requests\" }, 429);\n    }\n\n    // Extract identity: prefer canonical userId, then body wallet (pre-auth), then IP.\n    let identity: string | undefined;\n    try {\n      identity = c.get(\"userId\") as string | undefined;\n    } catch {\n      // Context variable not set — expected for pre-auth routes\n    }\n    if (!identity) {\n      try {\n        const body = await c.req.json();\n        identity = typeof body.wallet === \"string\" ? body.wallet : undefined;\n      } catch {\n        // If body is not parseable, fall back to IP-based limiting\n      }\n    }\n    // Final fallback: key on IP for pre-auth routes (e.g., /auth/*)\n    if (!identity) {\n      identity = c.req.header(\"x-forwarded-for\")?.split(\",\")[0]?.trim()\n        ?? c.req.header(\"x-real-ip\")\n        ?? \"unknown-ip\";\n    }\n\n    // Check per-identity limit\n    if (identity) {\n      let wWindow = walletWindows.get(identity);\n      if (!wWindow) {\n        wWindow = { timestamps: [] };\n        walletWindows.set(identity, wWindow);\n      }\n      const walletCount = countInWindow(wWindow, now, config.windowMs);\n      if (walletCount >= config.perWallet) {\n        logger.warn(\"rate limit exceeded: wallet limit\", {\n          path: c.req.path,\n          identity,\n          currentCount: walletCount,\n          limit: config.perWallet,\n          windowMs: config.windowMs,\n        });\n        c.header(\"Retry-After\", String(retryAfterSeconds));\n        return c.json({ error: \"Too many requests\" }, 429);\n      }\n      wWindow.timestamps.push(now);\n    }\n\n    // Record in global window\n    globalWindow.timestamps.push(now);\n\n    return next();\n  };\n}\n","structuredPatch":[{"oldStart":7,"oldLines":6,"newStart":7,"newLines":8,"lines":[" "," import type { MiddlewareHandler } from \"hono\";"," import { logger } from \"../logger.js\";","+import { err } from \"../contracts/api-envelope.js\";","+import { API_ERROR_CODES } from \"../contracts/api-errors.js\";"," "," export interface RateLimitConfig {","   /** Max POST requests per authenticated identity per window (default 10). */"]}],"userModified":false,"replaceAll":false}}
