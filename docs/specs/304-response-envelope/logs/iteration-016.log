{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CekEJRUBxhPUvAFm9Ujbxd","type":"tool_result","content":"1\t/* eslint-disable @typescript-eslint/no-explicit-any */\n2\timport { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";\n3\timport { Hono } from \"hono\";\n4\timport type { Db } from \"../db.js\";\n5\timport { createDogpileRoutes } from \"../routes/dogpile.js\";\n6\timport {\n7\t  closeIntegrationDb,\n8\t  type IntegrationDbContext,\n9\t  openIntegrationDb,\n10\t  resetIntegrationState,\n11\t  type TestSql,\n12\t} from \"./integration-test-helpers.js\";\n13\t\n14\tdescribe(\"Dogpile public routes\", () => {\n15\t  let ctx: IntegrationDbContext;\n16\t  let rawSql: TestSql;\n17\t  let db: Db;\n18\t  let app: Hono;\n19\t\n20\t  beforeAll(async () => {\n21\t    ctx = await openIntegrationDb();\n22\t    rawSql = ctx.rawSql;\n23\t    db = ctx.db;\n24\t  });\n25\t\n26\t  afterAll(async () => {\n27\t    await closeIntegrationDb(ctx);\n28\t  });\n29\t\n30\t  beforeEach(async () => {\n31\t    await resetIntegrationState(rawSql);\n32\t    app = new Hono();\n33\t    app.route(\"/dogpile\", createDogpileRoutes({ db }));\n34\t  });\n35\t\n36\t  it(\"GET /dogpile/current prefers active events over scheduled events\", async () => {\n37\t    await rawSql`\n38\t      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n39\t      VALUES (now() - interval '1 hour', now() + interval '1 hour', 2.5, 'active')\n40\t    `;\n41\t    await rawSql`\n42\t      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n43\t      VALUES (now() + interval '2 hours', now() + interval '3 hours', 3.0, 'scheduled')\n44\t    `;\n45\t\n46\t    const res = await app.request(\"/dogpile/current\", { method: \"GET\" });\n47\t    expect(res.status).toBe(200);\n48\t    const body = (await res.json()) as Record<string, any>;\n49\t    expect(body).not.toBeNull();\n50\t    expect(body.status).toBe(\"active\");\n51\t    expect(body.multiplier).toBe(2.5);\n52\t    expect(body).toHaveProperty(\"id\");\n53\t    expect(body).toHaveProperty(\"startsAt\");\n54\t    expect(body).toHaveProperty(\"endsAt\");\n55\t    expect(body).toHaveProperty(\"endsIn\");\n56\t    expect(body.endsIn).toBeGreaterThan(0);\n57\t  });\n58\t\n59\t  it(\"GET /dogpile/current returns the next scheduled event when nothing is active\", async () => {\n60\t    await rawSql`\n61\t      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n62\t      VALUES (now() + interval '2 hours', now() + interval '3 hours', 3.0, 'scheduled')\n63\t    `;\n64\t\n65\t    const res = await app.request(\"/dogpile/current\", { method: \"GET\" });\n66\t    expect(res.status).toBe(200);\n67\t    const body = (await res.json()) as Record<string, any>;\n68\t    expect(body).not.toBeNull();\n69\t    expect(body.status).toBe(\"scheduled\");\n70\t    expect(body.multiplier).toBe(3.0);\n71\t    expect(body).toHaveProperty(\"startsIn\");\n72\t    expect(body.startsIn).toBeGreaterThan(0);\n73\t  });\n74\t\n75\t  it(\"GET /dogpile/current returns null when no events exist\", async () => {\n76\t    const res = await app.request(\"/dogpile/current\", { method: \"GET\" });\n77\t    expect(res.status).toBe(200);\n78\t    expect(await res.json()).toBeNull();\n79\t  });\n80\t\n81\t  it(\"GET /dogpile/schedule returns active and scheduled events ordered by start time\", async () => {\n82\t    await rawSql`\n83\t      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n84\t      VALUES (now() + interval '5 hours', now() + interval '6 hours', 2.0, 'scheduled')\n85\t    `;\n86\t    await rawSql`\n87\t      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n88\t      VALUES (now() - interval '1 hour', now() + interval '1 hour', 3.0, 'active')\n89\t    `;\n90\t    await rawSql`\n91\t      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n92\t      VALUES (now() - interval '5 hours', now() - interval '4 hours', 1.5, 'ended')\n93\t    `;\n94\t\n95\t    const res = await app.request(\"/dogpile/schedule\", { method: \"GET\" });\n96\t    expect(res.status).toBe(200);\n97\t    const body = (await res.json()) as Record<string, any>;\n98\t    expect(body.items).toHaveLength(2);\n99\t    expect(body.items[0].status).toBe(\"active\");\n100\t    expect(body.items[0].multiplier).toBe(3.0);\n101\t    expect(body.items[1].status).toBe(\"scheduled\");\n102\t    expect(body.items[1].multiplier).toBe(2.0);\n103\t    expect(body.items[0]).toHaveProperty(\"id\");\n104\t    expect(body.items[0]).toHaveProperty(\"startsAt\");\n105\t    expect(body.items[0]).toHaveProperty(\"endsAt\");\n106\t  });\n107\t\n108\t  it(\"GET /dogpile/schedule returns an empty array when nothing upcoming exists\", async () => {\n109\t    const res = await app.request(\"/dogpile/schedule\", { method: \"GET\" });\n110\t    expect(res.status).toBe(200);\n111\t    const body = (await res.json()) as Record<string, any>;\n112\t    expect(body.items).toHaveLength(0);\n113\t  });\n114\t});\n115\t"}]},"parent_tool_use_id":null,"session_id":"24254f8c-cb2f-4e73-9ccd-e40689b4ed3b","uuid":"bc08d131-12f9-4cf5-912e-d2a62f7c067b","timestamp":"2026-04-22T10:35:45.464Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/dogpile-public-routes.test.ts","content":"/* eslint-disable @typescript-eslint/no-explicit-any */\nimport { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";\nimport { Hono } from \"hono\";\nimport type { Db } from \"../db.js\";\nimport { createDogpileRoutes } from \"../routes/dogpile.js\";\nimport {\n  closeIntegrationDb,\n  type IntegrationDbContext,\n  openIntegrationDb,\n  resetIntegrationState,\n  type TestSql,\n} from \"./integration-test-helpers.js\";\n\ndescribe(\"Dogpile public routes\", () => {\n  let ctx: IntegrationDbContext;\n  let rawSql: TestSql;\n  let db: Db;\n  let app: Hono;\n\n  beforeAll(async () => {\n    ctx = await openIntegrationDb();\n    rawSql = ctx.rawSql;\n    db = ctx.db;\n  });\n\n  afterAll(async () => {\n    await closeIntegrationDb(ctx);\n  });\n\n  beforeEach(async () => {\n    await resetIntegrationState(rawSql);\n    app = new Hono();\n    app.route(\"/dogpile\", createDogpileRoutes({ db }));\n  });\n\n  it(\"GET /dogpile/current prefers active events over scheduled events\", async () => {\n    await rawSql`\n      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n      VALUES (now() - interval '1 hour', now() + interval '1 hour', 2.5, 'active')\n    `;\n    await rawSql`\n      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n      VALUES (now() + interval '2 hours', now() + interval '3 hours', 3.0, 'scheduled')\n    `;\n\n    const res = await app.request(\"/dogpile/current\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body).not.toBeNull();\n    expect(body.status).toBe(\"active\");\n    expect(body.multiplier).toBe(2.5);\n    expect(body).toHaveProperty(\"id\");\n    expect(body).toHaveProperty(\"startsAt\");\n    expect(body).toHaveProperty(\"endsAt\");\n    expect(body).toHaveProperty(\"endsIn\");\n    expect(body.endsIn).toBeGreaterThan(0);\n  });\n\n  it(\"GET /dogpile/current returns the next scheduled event when nothing is active\", async () => {\n    await rawSql`\n      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n      VALUES (now() + interval '2 hours', now() + interval '3 hours', 3.0, 'scheduled')\n    `;\n\n    const res = await app.request(\"/dogpile/current\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body).not.toBeNull();\n    expect(body.status).toBe(\"scheduled\");\n    expect(body.multiplier).toBe(3.0);\n    expect(body).toHaveProperty(\"startsIn\");\n    expect(body.startsIn).toBeGreaterThan(0);\n  });\n\n  it(\"GET /dogpile/current returns null when no events exist\", async () => {\n    const res = await app.request(\"/dogpile/current\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n    expect(await res.json()).toBeNull();\n  });\n\n  it(\"GET /dogpile/schedule returns active and scheduled events ordered by start time\", async () => {\n    await rawSql`\n      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n      VALUES (now() + interval '5 hours', now() + interval '6 hours', 2.0, 'scheduled')\n    `;\n    await rawSql`\n      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n      VALUES (now() - interval '1 hour', now() + interval '1 hour', 3.0, 'active')\n    `;\n    await rawSql`\n      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n      VALUES (now() - interval '5 hours', now() - interval '4 hours', 1.5, 'ended')\n    `;\n\n    const res = await app.request(\"/dogpile/schedule\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.items).toHaveLength(2);\n    expect(body.items[0].status).toBe(\"active\");\n    expect(body.items[0].multiplier).toBe(3.0);\n    expect(body.items[1].status).toBe(\"scheduled\");\n    expect(body.items[1].multiplier).toBe(2.0);\n    expect(body.items[0]).toHaveProperty(\"id\");\n    expect(body.items[0]).toHaveProperty(\"startsAt\");\n    expect(body.items[0]).toHaveProperty(\"endsAt\");\n  });\n\n  it(\"GET /dogpile/schedule returns an empty array when nothing upcoming exists\", async () => {\n    const res = await app.request(\"/dogpile/schedule\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.items).toHaveLength(0);\n  });\n});\n","numLines":115,"startLine":1,"totalLines":115}}}
