{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01TniQEkKaxRdYXrM7JAyvXS","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01UyqcpKpCsC3k9pAKgZe9e2","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/src/routes/dogpile.ts","content":"/**\n * Dogpile routes — public endpoints for dogpile event status and schedule.\n *\n * GET /current   — active dogpile event, or next scheduled, or null\n * GET /schedule  — upcoming dogpile events ordered by starts_at\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport { logger } from \"../logger.js\";\nimport {\n  DogpileCurrentResponseSchema,\n  DogpileScheduleResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface DogpileRoutesDeps {\n  db: Db;\n}\n\ninterface DogpileEventRow {\n  id: string;\n  multiplier: string;\n  starts_at: Date;\n  ends_at: Date;\n  status: string;\n  campaign_id: string | null;\n}\n\n// ---------------------------------------------------------------------------\n// Route definitions\n// ---------------------------------------------------------------------------\n\nconst currentRoute = createRoute({\n  method: \"get\",\n  path: \"/current\",\n  tags: [\"Dogpile\"],\n  summary: \"Get the active or next scheduled dogpile event\",\n  responses: {\n    200: {\n      content: {\n        \"application/json\": { schema: envelope(DogpileCurrentResponseSchema) },\n      },\n      description: \"Active dogpile event, next scheduled event, or null\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Failed to fetch dogpile status\",\n    },\n  },\n});\n\nconst scheduleRoute = createRoute({\n  method: \"get\",\n  path: \"/schedule\",\n  tags: [\"Dogpile\"],\n  summary: \"Get upcoming dogpile events\",\n  responses: {\n    200: {\n      content: {\n        \"application/json\": { schema: envelope(DogpileScheduleResponseSchema) },\n      },\n      description: \"Upcoming dogpile events ordered by start time\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Failed to fetch dogpile schedule\",\n    },\n  },\n});\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport function createDogpileRoutes(deps: DogpileRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // GET /current — active event > next scheduled > null\n  app.openapi(currentRoute, async (c) => {\n    try {\n      // Try active first\n      const active = await db.rawSql<DogpileEventRow[]>`\n        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n        FROM dogpile_events\n        WHERE status = 'active'\n        ORDER BY starts_at ASC\n        LIMIT 1\n      `;\n\n      if (active.length > 0) {\n        const e = active[0]!;\n        return ok(c, {\n          id: Number(e.id),\n          multiplier: Number(e.multiplier),\n          startsAt: e.starts_at.toISOString(),\n          endsAt: e.ends_at.toISOString(),\n          status: \"active\" as const,\n          endsIn: Math.max(0, e.ends_at.getTime() - Date.now()),\n        });\n      }\n\n      // Try next scheduled\n      const scheduled = await db.rawSql<DogpileEventRow[]>`\n        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n        FROM dogpile_events\n        WHERE status = 'scheduled'\n          AND starts_at > now()\n        ORDER BY starts_at ASC\n        LIMIT 1\n      `;\n\n      if (scheduled.length > 0) {\n        const e = scheduled[0]!;\n        return ok(c, {\n          id: Number(e.id),\n          multiplier: Number(e.multiplier),\n          startsAt: e.starts_at.toISOString(),\n          endsAt: e.ends_at.toISOString(),\n          status: \"scheduled\" as const,\n          startsIn: Math.max(0, e.starts_at.getTime() - Date.now()),\n        });\n      }\n\n      return ok(c, null);\n    } catch (queryError) {\n      logger.error(\"dogpile/current failed\", {\n        error: queryError instanceof Error ? queryError.message : String(queryError),\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch dogpile status\",\n      );\n    }\n  });\n\n  // GET /schedule — upcoming events ordered by starts_at\n  app.openapi(scheduleRoute, async (c) => {\n    try {\n      const rows = await db.rawSql<DogpileEventRow[]>`\n        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n        FROM dogpile_events\n        WHERE status IN ('scheduled', 'active')\n        ORDER BY starts_at ASC\n      `;\n\n      const items = rows.map((e: DogpileEventRow) => ({\n        id: Number(e.id),\n        multiplier: Number(e.multiplier),\n        startsAt: e.starts_at.toISOString(),\n        endsAt: e.ends_at.toISOString(),\n        status: e.status,\n      }));\n\n      return ok(c, { items });\n    } catch (queryError) {\n      logger.error(\"dogpile/schedule failed\", {\n        error: queryError instanceof Error ? queryError.message : String(queryError),\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch dogpile schedule\",\n      );\n    }\n  });\n\n  return app;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":6063,"cache_read_input_tokens":88788,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":6063},"output_tokens":51,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"24254f8c-cb2f-4e73-9ccd-e40689b4ed3b","uuid":"c3f0e852-808e-46ae-abe8-a52268b1677c"}
