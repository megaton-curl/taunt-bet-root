  description: \"Invalid wallet format\",\n166\t    },\n167\t    403: {\n168\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n169\t      description: \"Wallet mismatch with authenticated session\",\n170\t    },\n171\t    409: {\n172\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n173\t      description: \"Round already active or ID collision\",\n174\t    },\n175\t    422: {\n176\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n177\t      description: \"Invalid request body\",\n178\t    },\n179\t    500: {\n180\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n181\t      description: \"Transaction build failed\",\n182\t    },\n183\t  },\n184\t});\n185\t\n186\tconst psHistoryRoute = createRoute({\n187\t  method: \"get\",\n188\t  path: \"/history\",\n189\t  tags: [\"PotShot\"],\n190\t  summary: \"Get recent settled Pot Shot rounds\",\n191\t  request: {\n192\t    query: LimitQuerySchema,\n193\t  },\n194\t  responses: {\n195\t    200: {\n196\t      content: {\n197\t        \"application/json\": {\n198\t          schema: envelope(PotShotHistoryResponseSchema),\n199\t        },\n200\t      },\n201\t      description: \"List of settled rounds\",\n202\t    },\n203\t  },\n204\t});\n205\t\n206\tconst psByIdRoute = createRoute({\n207\t  method: \"get\",\n208\t  path: \"/by-id/{matchId}\",\n209\t  tags: [\"PotShot\"],\n210\t  summary: \"Lookup Pot Shot round by ID\",\n211\t  request: {\n212\t    params: MatchIdParamSchema,\n213\t  },\n214\t  responses: {\n215\t    200: {\n216\t      content: { \"application/json\": { schema: envelope(PotShotRoundResponseSchema) } },\n217\t      description: \"Round found\",\n218\t    },\n219\t    400: {\n220\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n221\t      description: \"Invalid match ID format\",\n222\t    },\n223\t    404: {\n224\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n225\t      description: \"Round not found\",\n226\t    },\n227\t  },\n228\t});\n229\t\n230\tconst psVerifyRoute = createRoute({\n231\t  method: \"get\",\n232\t  path: \"/verify/{pda}\",\n233\t  tags: [\"PotShot\"],\n234\t  summary: \"Lookup Pot Shot round by PDA with verification data\",\n235\t  request: {\n236\t    params: PdaParamSchema,\n237\t  },\n238\t  responses: {\n239\t    200: {\n240\t      content: { \"application/json\": { schema: envelope(PotShotRoundResponseSchema) } },\n241\t      description: \"Round verification data\",\n242\t    },\n243\t    404: {\n244\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n245\t      description: \"Round not found\",\n246\t    },\n247\t  },\n248\t});\n249\t\n250\t// ── Factory ──────────────────────────────────────────────────────────────\n251\t\n252\texport function createPotShotRoutes(deps: LordCreateRoutesDeps) {\n253\t  const { db, connection, serverKeypair, pdaWatcher } = deps;\n254\t  const app = createOpenApiApp<AppEnv>();\n255\t\n256\t  // GET /current — return the single active lord round (if any)\n257\t  app.openapi(currentRoute, async (c) => {\n258\t    try {\n259\t      // Query DB for any lord round not in a terminal phase\n260\t      const [created, locked, settling] = await Promise.all([\n261\t        db.getRoundsByPhase(\"created\"),\n262\t        db.getRoundsByPhase(\"locked\"),\n263\t        db.getRoundsByPhase(\"settling\"),\n264\t      ]);\n265\t\n266\t      // Sort ASC (oldest first) — if a race condition created two rounds,\n267\t      // the first one gets played to completion before the second surfaces.\n268\t      const activeDbRound = [...created, ...locked, ...settling]\n269\t        .filter((r) => r.game === \"potshot\")\n270\t        .sort((a, b) => a.created_at.getTime() - b.created_at.getTime())[0];\n271\t\n272\t      if (!activeDbRound) {\n273\t        return ok(c, { round: null });\n274\t      }\n275\t\n276\t      // Fetch the on-chain account to get current entries/pool state\n277\t      const roundPda = new PublicKey(activeDbRound.pda);\n278\t      try {\n279\t        const accountInfo = await connection.getAccountInfo(roundPda);\n280\t        if (accountInfo) {\n281\t          const decoded = decodeLordRound(Buffer.from(accountInfo.data));\n282\t          return ok(c, {\n283\t            round: formatLordRound(decoded, roundPda, activeDbRound),\n284\t          });\n285\t        }\n286\t      } catch (fetchError) {\n287\t        logger.warn(\"lord current: on-chain fetch failed, returning DB-only\", {\n288\t          pda: activeDbRound.pda,\n289\t          error: fetchError instanceof Error ? fetchError.message : String(fetchError),\n290\t        });\n291\t      }\n292\t\n293\t      // Fallback: return DB data without on-chain enrichment\n294\t      return ok(c, {\n295\t        round: {\n296\t          matchId: activeDbRound.match_id,\n297\t          pda: activeDbRound.pda,\n298\t          phase: DB_PHASE_TO_POTSHOT_PHASE[activeDbRound.phase],\n299\t          creator: activeDbRound.creator,"}]},"parent_tool_use_id":null,"session_id":"24254f8c-cb2f-4e73-9ccd-e40689b4ed3b","uuid":"a952c3dc-5788-41fd-b900-3265d61b5ff6","timestamp":"2026-04-22T10:36:02.044Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/potshot-create.ts","content":"});\n\nconst LimitQuerySchema = z.object({\n  limit: z.string().optional(),\n});\n\nconst MatchIdParamSchema = z.object({\n  matchId: z.string(),\n});\n\nconst PdaParamSchema = z.object({\n  pda: z.string(),\n});\n\n// ── Route definitions ────────────────────────────────────────────────────\n\nconst PotShotCurrentResponseSchema = roundEnvelopeResponseSchema(\n  \"round\",\n  PotShotRoundSchema,\n  { nullable: true },\n);\n\nconst PotShotHistoryResponseSchema = listEnvelopeResponseSchema(\n  \"rounds\",\n  PotShotRoundResponseSchema,\n);\n\nconst currentRoute = createRoute({\n  method: \"get\",\n  path: \"/current\",\n  tags: [\"PotShot\"],\n  summary: \"Get active Pot Shot round\",\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: envelope(PotShotCurrentResponseSchema),\n        },\n      },\n      description: \"Active round or null\",\n    },\n  },\n});\n\nconst createRoundRoute = createRoute({\n  method: \"post\",\n  path: \"/create\",\n  tags: [\"PotShot\"],\n  summary: \"Create a new Pot Shot round\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": { schema: PotShotCreateBodySchema },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(PotShotCreateResponseSchema) } },\n      description: \"Round created successfully\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid wallet format\",\n    },\n    403: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Wallet mismatch with authenticated session\",\n    },\n    409: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Round already active or ID collision\",\n    },\n    422: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid request body\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Transaction build failed\",\n    },\n  },\n});\n\nconst psHistoryRoute = createRoute({\n  method: \"get\",\n  path: \"/history\",\n  tags: [\"PotShot\"],\n  summary: \"Get recent settled Pot Shot rounds\",\n  request: {\n    query: LimitQuerySchema,\n  },\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: envelope(PotShotHistoryResponseSchema),\n        },\n      },\n      description: \"List of settled rounds\",\n    },\n  },\n});\n\nconst psByIdRoute = createRoute({\n  method: \"get\",\n  path: \"/by-id/{matchId}\",\n  tags: [\"PotShot\"],\n  summary: \"Lookup Pot Shot round by ID\",\n  request: {\n    params: MatchIdParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(PotShotRoundResponseSchema) } },\n      description: \"Round found\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid match ID format\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Round not found\",\n    },\n  },\n});\n\nconst psVerifyRoute = createRoute({\n  method: \"get\",\n  path: \"/verify/{pda}\",\n  tags: [\"PotShot\"],\n  summary: \"Lookup Pot Shot round by PDA with verification data\",\n  request: {\n    params: PdaParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(PotShotRoundResponseSchema) } },\n      description: \"Round verification data\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Round not found\",\n    },\n  },\n});\n\n// ── Factory ──────────────────────────────────────────────────────────────\n\nexport function createPotShotRoutes(deps: LordCreateRoutesDeps) {\n  const { db, connection, serverKeypair, pdaWatcher } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // GET /current — return the single active lord round (if any)\n  app.openapi(currentRoute, async (c) => {\n    try {\n      // Query DB for any lord round not in a terminal phase\n      const [created, locked, settling] = await Promise.all([\n        db.getRoundsByPhase(\"created\"),\n        db.getRoundsByPhase(\"locked\"),\n        db.getRoundsByPhase(\"settling\"),\n      ]);\n\n      // Sort ASC (oldest first) — if a race condition created two rounds,\n      // the first one gets played to completion before the second surfaces.\n      const activeDbRound = [...created, ...locked, ...settling]\n        .filter((r) => r.game === \"potshot\")\n        .sort((a, b) => a.created_at.getTime() - b.created_at.getTime())[0];\n\n      if (!activeDbRound) {\n        return ok(c, { round: null });\n      }\n\n      // Fetch the on-chain account to get current entries/pool state\n      const roundPda = new PublicKey(activeDbRound.pda);\n      try {\n        const accountInfo = await connection.getAccountInfo(roundPda);\n        if (accountInfo) {\n          const decoded = decodeLordRound(Buffer.from(accountInfo.data));\n          return ok(c, {\n            round: formatLordRound(decoded, roundPda, activeDbRound),\n          });\n        }\n      } catch (fetchError) {\n        logger.warn(\"lord current: on-chain fetch failed, returning DB-only\", {\n          pda: activeDbRound.pda,\n          error: fetchError instanceof Error ? fetchError.message : String(fetchError),\n        });\n      }\n\n      // Fallback: return DB data without on-chain enrichment\n      return ok(c, {\n        round: {\n          matchId: activeDbRound.match_id,\n          pda: activeDbRound.pda,\n          phase: DB_PHASE_TO_POTSHOT_PHASE[activeDbRound.phase],\n          creator: activeDbRound.creator,","numLines":200,"startLine":100,"totalLines":667}}}
