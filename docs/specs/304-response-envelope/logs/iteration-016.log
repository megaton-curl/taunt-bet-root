  — co-sign a bet tx (creates round or joins)\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\nimport type { CloseCallRound, Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { buildCloseCallBetTx } from \"../worker/settle-tx.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { decodeCloseCallRound, type DecodedCloseCallRound } from \"../worker/account-decoder.js\";\nimport type { CloseCallClockWorker } from \"../worker/closecall-clock.js\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport {\n  CloseCallBetResponseSchema,\n  CandleSchema,\n  CloseCallRoundSchema,\n  UnifiedCloseCallRoundResponseSchema,\n  listEnvelopeResponseSchema,\n  roundEnvelopeResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface CloseCallRoutesDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  clockWorker: CloseCallClockWorker;\n}\n\n/** Minimum wager in lamports: 0.001 SOL */\nconst MIN_WAGER_LAMPORTS = 1_000_000;\nconst MAX_WAGER_LAMPORTS = 100_000_000_000; // 100 SOL\n\nfunction isValidBase58(s: string): boolean {\n  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n}\n\n/** Convert a minuteTs bigint to an 8-byte LE buffer (for PDA seeds). */\nfunction minuteTsToBuffer(ts: bigint): Buffer {\n  const buf = Buffer.alloc(8);\n  buf.writeBigInt64LE(ts);\n  return buf;\n}\n\n/** Derive the CloseCallRound PDA for a given minute timestamp. */\nfunction deriveCloseCallRoundPda(minuteTs: bigint): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n    CLOSECALL_PROGRAM_ID,\n  );\n  return pda;\n}\n\nconst PHASE_NAMES = [\"open\", \"settled\", \"refunded\"] as const;\nconst OUTCOME_NAMES = [\"pending\", \"green\", \"red\", \"refund\"] as const;\n\ntype CloseCallRoundResponse = z.infer<typeof CloseCallRoundSchema>;\ntype CloseCallLookupResponse = z.infer<typeof UnifiedCloseCallRoundResponseSchema>;\n\n/** Format a decoded on-chain round into the same shape as formatCloseCallRound. */\nfunction formatOnChainRound(\n  round: DecodedCloseCallRound,\n  pda: PublicKey,\n): CloseCallRoundResponse {\n  const greenEntries = round.greenEntries.map((e) => ({\n    player: e.player.toBase58(),\n    amountLamports: Number(e.amountLamports),\n  }));\n  const redEntries = round.redEntries.map((e) => ({\n    player: e.player.toBase58(),\n    amountLamports: Number(e.amountLamports),\n  }));\n  const greenPool = Number(round.greenPool);\n  const redPool = Number(round.redPool);\n  const totalPool = greenPool + redPool;\n\n  return {\n    roundId: Number(round.minuteTs).toString(),\n    pda: pda.toBase58(),\n    phase: PHASE_NAMES[round.phase] ?? \"open\",\n    openPrice: Number(round.openPrice),\n    openPriceExpo: round.openPriceExpo,\n    closePrice: round.phase === 0 ? null : Number(round.closePrice),\n    outcome: OUTCOME_NAMES[round.outcome] ?? \"pending\",\n    greenPool,\n    redPool,\n    totalPool,\n    totalFee: Number(round.totalFee),\n    greenEntries,\n    redEntries,\n    greenCount: greenEntries.length,\n    redCount: redEntries.length,\n    settleTx: null,\n    createdAt: new Date(Number(round.createdAt) * 1000).toISOString(),\n    settledAt: null,\n  };\n}\n\nfunction formatCloseCallRound(round: CloseCallRound): CloseCallRoundResponse {\n  const totalPool = round.green_pool + round.red_pool;\n  return {\n    roundId: round.round_id,\n    pda: round.pda,\n    phase: round.phase,\n    openPrice: round.open_price,\n    openPriceExpo: round.open_price_expo,\n    closePrice: round.close_price,\n    outcome: round.outcome,\n    greenPool: round.green_pool,\n    redPool: round.red_pool,\n    totalPool,\n    totalFee: round.total_fee,\n    greenEntries: round.green_entries,\n    redEntries: round.red_entries,\n    greenCount: round.green_entries.length,\n    redCount: round.red_entries.length,\n    settleTx: round.settle_tx,\n    createdAt: round.created_at.toISOString(),\n    settledAt: round.settled_at ? round.settled_at.toISOString() : null,\n  };\n}\n\n// ── Request schemas ──────────────────────────────────────────────────────\n\nconst LimitQuerySchema = z.object({\n  limit: z.string().optional(),\n});\n\nconst RoundIdParamSchema = z.object({\n  roundId: z.string(),\n});\n\nconst CloseCallBetBodySchema = z.object({\n  playerPubkey: z.string(),\n  side: z.enum([\"green\", \"red\"]),\n  amountLamports: z.number().int().min(MIN_WAGER_LAMPORTS).max(MAX_WAGER_LAMPORTS),\n});\n\n// ── Route definitions ────────────────────────────────────────────────────\n\nconst CloseCallCurrentResponseSchema = roundEnvelopeResponseSchema(\n  \"round\",\n  CloseCallRoundSchema,\n  { nullable: true },\n);\n\nconst CloseCallHistoryResponseSchema = listEnvelopeResponseSchema(\n  \"rounds\",\n  CloseCallRoundSchema,\n);\n\nconst CloseCallCandlesResponseSchema = z.object({\n  candles: z.array(CandleSchema),\n  currentOpenPrice: z.number().nullable(),\n  currentMinuteTs: z.number().int().nullable(),\n});\n\nconst currentRoundRoute = createRoute({\n  method: \"get\",\n  path: \"/current-round\",\n  tags: [\"CloseCall\"],\n  summary: \"Get active Close Call round\",\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: envelope(CloseCallCurrentResponseSchema),\n        },\n      },\n      description: \"Active round or null\",\n    },\n  },\n});\n\nconst ccHistoryRoute = createRoute({\n  method: \"get\",\n  path: \"/history\",\n  tags: [\"CloseCall\"],\n  summary: \"Get recent settled/refunded Close Call rounds\",\n  request: {\n    query: LimitQuerySchema,\n  },\n  responses: {\n    200: {\n      content: {","numLines