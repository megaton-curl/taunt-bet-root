status: e.status,","       }));"," ","-      return c.json({ items }, 200);","-    } catch (err) {","+      return ok(c, { items });","+    } catch (queryError) {","       logger.error(\"dogpile/schedule failed\", {","-        error: err instanceof Error ? err.message : String(err),","+        error: queryError instanceof Error ? queryError.message : String(queryError),","       });","-      return c.json(errorMessage(\"Failed to fetch dogpile schedule\"), 500);","+      return err(","+        c,","+        500,","+        API_ERROR_CODES.PRECONDITION_FAILED,","+        \"Failed to fetch dogpile schedule\",","+      );","     }","   });"," "]}],"originalFile":"/**\n * Dogpile routes — public endpoints for dogpile event status and schedule.\n *\n * GET /current   — active dogpile event, or next scheduled, or null\n * GET /schedule  — upcoming dogpile events ordered by starts_at\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { errorMessage } from \"../contracts/api-errors.js\";\nimport { logger } from \"../logger.js\";\nimport {\n  DogpileCurrentResponseSchema,\n  DogpileScheduleResponseSchema,\n  ErrorResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface DogpileRoutesDeps {\n  db: Db;\n}\n\ninterface DogpileEventRow {\n  id: string;\n  multiplier: string;\n  starts_at: Date;\n  ends_at: Date;\n  status: string;\n  campaign_id: string | null;\n}\n\n// ---------------------------------------------------------------------------\n// Route definitions\n// ---------------------------------------------------------------------------\n\nconst currentRoute = createRoute({\n  method: \"get\",\n  path: \"/current\",\n  tags: [\"Dogpile\"],\n  summary: \"Get the active or next scheduled dogpile event\",\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: DogpileCurrentResponseSchema } },\n      description: \"Active dogpile event, next scheduled event, or null\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Failed to fetch dogpile status\",\n    },\n  },\n});\n\nconst scheduleRoute = createRoute({\n  method: \"get\",\n  path: \"/schedule\",\n  tags: [\"Dogpile\"],\n  summary: \"Get upcoming dogpile events\",\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: DogpileScheduleResponseSchema } },\n      description: \"Upcoming dogpile events ordered by start time\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Failed to fetch dogpile schedule\",\n    },\n  },\n});\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport function createDogpileRoutes(deps: DogpileRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // GET /current — active event > next scheduled > null\n  app.openapi(currentRoute, async (c) => {\n    try {\n      // Try active first\n      const active = await db.rawSql<DogpileEventRow[]>`\n        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n        FROM dogpile_events\n        WHERE status = 'active'\n        ORDER BY starts_at ASC\n        LIMIT 1\n      `;\n\n      if (active.length > 0) {\n        const e = active[0]!;\n        return c.json({\n          id: Number(e.id),\n          multiplier: Number(e.multiplier),\n          startsAt: e.starts_at.toISOString(),\n          endsAt: e.ends_at.toISOString(),\n          status: \"active\" as const,\n          endsIn: Math.max(0, e.ends_at.getTime() - Date.now()),\n        }, 200);\n      }\n\n      // Try next scheduled\n      const scheduled = await db.rawSql<DogpileEventRow[]>`\n        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n        FROM dogpile_events\n        WHERE status = 'scheduled'\n          AND starts_at > now()\n        ORDER BY starts_at ASC\n        LIMIT 1\n      `;\n\n      if (scheduled.length > 0) {\n        const e = scheduled[0]!;\n        return c.json({\n          id: Number(e.id),\n          multiplier: Number(e.multiplier),\n          startsAt: e.starts_at.toISOString(),\n          endsAt: e.ends_at.toISOString(),\n          status: \"scheduled\" as const,\n          startsIn: Math.max(0, e.starts_at.getTime() - Date.now()),\n        }, 200);\n      }\n\n      return c.json(null, 200);\n    } catch (err) {\n      logger.error(\"dogpile/current failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json(errorMessage(\"Failed to fetch dogpile status\"), 500);\n    }\n  });\n\n  // GET /schedule — upcoming events ordered by starts_at\n  app.openapi(scheduleRoute, async (c) => {\n    try {\n      const rows = await db.rawSql<DogpileEventRow[]>`\n        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n        FROM dogpile_events\n        WHERE status IN ('scheduled', 'active')\n        ORDER BY starts_at ASC\n      `;\n\n      const items = rows.map((e: DogpileEventRow) => ({\n        id: Number(e.id),\n        multiplier: Number(e.multiplier),\n        startsAt: e.starts_at.toISOString(),\n        endsAt: e.ends_at.toISOString(),\n        status: e.status,\n      }));\n\n      return c.json({ items }, 200);\n    } catch (err) {\n      logger.error(\"dogpile/schedule failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json(errorMessage(\"Failed to fetch dogpile schedule\"), 500);\n    }\n  });\n\n  return app;\n}\n","userModified":false}}
