{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019CZC3QAXTfnQoumgV8mqzD","type":"tool_result","content":"1\t/**\n2\t * Dogpile routes — public endpoints for dogpile event status and schedule.\n3\t *\n4\t * GET /current   — active dogpile event, or next scheduled, or null\n5\t * GET /schedule  — upcoming dogpile events ordered by starts_at\n6\t */\n7\t\n8\timport { createRoute } from \"@hono/zod-openapi\";\n9\timport type { AppEnv } from \"../hono-env.js\";\n10\timport type { Db } from \"../db.js\";\n11\timport { errorMessage } from \"../contracts/api-errors.js\";\n12\timport { logger } from \"../logger.js\";\n13\timport {\n14\t  DogpileCurrentResponseSchema,\n15\t  DogpileScheduleResponseSchema,\n16\t  ErrorResponseSchema,\n17\t} from \"../contracts/validators.js\";\n18\timport { createOpenApiApp } from \"../openapi/hono.js\";\n19\t\n20\t// ---------------------------------------------------------------------------\n21\t// Types\n22\t// ---------------------------------------------------------------------------\n23\t\n24\texport interface DogpileRoutesDeps {\n25\t  db: Db;\n26\t}\n27\t\n28\tinterface DogpileEventRow {\n29\t  id: string;\n30\t  multiplier: string;\n31\t  starts_at: Date;\n32\t  ends_at: Date;\n33\t  status: string;\n34\t  campaign_id: string | null;\n35\t}\n36\t\n37\t// ---------------------------------------------------------------------------\n38\t// Route definitions\n39\t// ---------------------------------------------------------------------------\n40\t\n41\tconst currentRoute = createRoute({\n42\t  method: \"get\",\n43\t  path: \"/current\",\n44\t  tags: [\"Dogpile\"],\n45\t  summary: \"Get the active or next scheduled dogpile event\",\n46\t  responses: {\n47\t    200: {\n48\t      content: { \"application/json\": { schema: DogpileCurrentResponseSchema } },\n49\t      description: \"Active dogpile event, next scheduled event, or null\",\n50\t    },\n51\t    500: {\n52\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n53\t      description: \"Failed to fetch dogpile status\",\n54\t    },\n55\t  },\n56\t});\n57\t\n58\tconst scheduleRoute = createRoute({\n59\t  method: \"get\",\n60\t  path: \"/schedule\",\n61\t  tags: [\"Dogpile\"],\n62\t  summary: \"Get upcoming dogpile events\",\n63\t  responses: {\n64\t    200: {\n65\t      content: { \"application/json\": { schema: DogpileScheduleResponseSchema } },\n66\t      description: \"Upcoming dogpile events ordered by start time\",\n67\t    },\n68\t    500: {\n69\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n70\t      description: \"Failed to fetch dogpile schedule\",\n71\t    },\n72\t  },\n73\t});\n74\t\n75\t// ---------------------------------------------------------------------------\n76\t// Route factory\n77\t// ---------------------------------------------------------------------------\n78\t\n79\texport function createDogpileRoutes(deps: DogpileRoutesDeps) {\n80\t  const { db } = deps;\n81\t  const app = createOpenApiApp<AppEnv>();\n82\t\n83\t  // GET /current — active event > next scheduled > null\n84\t  app.openapi(currentRoute, async (c) => {\n85\t    try {\n86\t      // Try active first\n87\t      const active = await db.rawSql<DogpileEventRow[]>`\n88\t        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n89\t        FROM dogpile_events\n90\t        WHERE status = 'active'\n91\t        ORDER BY starts_at ASC\n92\t        LIMIT 1\n93\t      `;\n94\t\n95\t      if (active.length > 0) {\n96\t        const e = active[0]!;\n97\t        return c.json({\n98\t          id: Number(e.id),\n99\t          multiplier: Number(e.multiplier),\n100\t          startsAt: e.starts_at.toISOString(),\n101\t          endsAt: e.ends_at.toISOString(),\n102\t          status: \"active\" as const,\n103\t          endsIn: Math.max(0, e.ends_at.getTime() - Date.now()),\n104\t        }, 200);\n105\t      }\n106\t\n107\t      // Try next scheduled\n108\t      const scheduled = await db.rawSql<DogpileEventRow[]>`\n109\t        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n110\t        FROM dogpile_events\n111\t        WHERE status = 'scheduled'\n112\t          AND starts_at > now()\n113\t        ORDER BY starts_at ASC\n114\t        LIMIT 1\n115\t      `;\n116\t\n117\t      if (scheduled.length > 0) {\n118\t        const e = scheduled[0]!;\n119\t        return c.json({\n120\t          id: Number(e.id),\n121\t          multiplier: Number(e.multiplier),\n122\t          startsAt: e.starts_at.toISOString(),\n123\t          endsAt: e.ends_at.toISOString(),\n124\t          status: \"scheduled\" as const,\n125\t          startsIn: Math.max(0, e.starts_at.getTime() - Date.now()),\n126\t        }, 200);\n127\t      }\n128\t\n129\t      return c.json(null, 200);\n130\t    } catch (err) {\n131\t      logger.error(\"dogpile/current failed\", {\n132\t        error: err instanceof Error ? err.message : String(err),\n133\t      });\n134\t      return c.json(errorMessage(\"Failed to fetch dogpile status\"), 500);\n135\t    }\n136\t  });\n137\t\n138\t  // GET /schedule — upcoming events ordered by starts_at\n139\t  app.openapi(scheduleRoute, async (c) => {\n140\t    try {\n141\t      const rows = await db.rawSql<DogpileEventRow[]>`\n142\t        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n143\t        FROM dogpile_events\n144\t        WHERE status IN ('scheduled', 'active')\n145\t        ORDER BY starts_at ASC\n146\t      `;\n147\t\n148\t      const items = rows.map((e: DogpileEventRow) => ({\n149\t        id: Number(e.id),\n150\t        multiplier: Number(e.multiplier),\n151\t        startsAt: e.starts_at.toISOString(),\n152\t        endsAt: e.ends_at.toISOString(),\n153\t        status: e.status,\n154\t      }));\n155\t\n156\t      return c.json({ items }, 200);\n157\t    } catch (err) {\n158\t      logger.error(\"dogpile/schedule failed\", {\n159\t        error: err instanceof Error ? err.message : String(err),\n160\t      });\n161\t      return c.json(errorMessage(\"Failed to fetch dogpile schedule\"), 500);\n162\t    }\n163\t  });\n164\t\n165\t  return app;\n166\t}\n167\t"}]},"parent_tool_use_id":null,"session_id":"24254f8c-cb2f-4e73-9ccd-e40689b4ed3b","uuid":"0f482ef2-b478-4fac-9de7-0b6062202e70","timestamp":"2026-04-22T10:35:41.864Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/dogpile.ts","content":"/**\n * Dogpile routes — public endpoints for dogpile event status and schedule.\n *\n * GET /current   — active dogpile event, or next scheduled, or null\n * GET /schedule  — upcoming dogpile events ordered by starts_at\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { errorMessage } from \"../contracts/api-errors.js\";\nimport { logger } from \"../logger.js\";\nimport {\n  DogpileCurrentResponseSchema,\n  DogpileScheduleResponseSchema,\n  ErrorResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface DogpileRoutesDeps {\n  db: Db;\n}\n\ninterface DogpileEventRow {\n  id: string;\n  multiplier: string;\n  starts_at: Date;\n  ends_at: Date;\n  status: string;\n  campaign_id: string | null;\n}\n\n// ---------------------------------------------------------------------------\n// Route definitions\n// ---------------------------------------------------------------------------\n\nconst currentRoute = createRoute({\n  method: \"get\",\n  path: \"/current\",\n  tags: [\"Dogpile\"],\n  summary: \"Get the active or next scheduled dogpile event\",\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: DogpileCurrentResponseSchema } },\n      description: \"Active dogpile event, next scheduled event, or null\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Failed to fetch dogpile status\",\n    },\n  },\n});\n\nconst scheduleRoute = createRoute({\n  method: \"get\",\n  path: \"/schedule\",\n  tags: [\"Dogpile\"],\n  summary: \"Get upcoming dogpile events\",\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: DogpileScheduleResponseSchema } },\n      description: \"Upcoming dogpile events ordered by start time\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Failed to fetch dogpile schedule\",\n    },\n  },\n});\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport function createDogpileRoutes(deps: DogpileRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // GET /current — active event > next scheduled > null\n  app.openapi(currentRoute, async (c) => {\n    try {\n      // Try active first\n      const active = await db.rawSql<DogpileEventRow[]>`\n        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n        FROM dogpile_events\n        WHERE status = 'active'\n        ORDER BY starts_at ASC\n        LIMIT 1\n      `;\n\n      if (active.length > 0) {\n        const e = active[0]!;\n        return c.json({\n          id: Number(e.id),\n          multiplier: Number(e.multiplier),\n          startsAt: e.starts_at.toISOString(),\n          endsAt: e.ends_at.toISOString(),\n          status: \"active\" as const,\n          endsIn: Math.max(0, e.ends_at.getTime() - Date.now()),\n        }, 200);\n      }\n\n      // Try next scheduled\n      const scheduled = await db.rawSql<DogpileEventRow[]>`\n        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n        FROM dogpile_events\n        WHERE status = 'scheduled'\n          AND starts_at > now()\n        ORDER BY starts_at ASC\n        LIMIT 1\n      `;\n\n      if (scheduled.length > 0) {\n        const e = scheduled[0]!;\n        return c.json({\n          id: Number(e.id),\n          multiplier: Number(e.multiplier),\n          startsAt: e.starts_at.toISOString(),\n          endsAt: e.ends_at.toISOString(),\n          status: \"scheduled\" as const,\n          startsIn: Math.max(0, e.starts_at.getTime() - Date.now()),\n        }, 200);\n      }\n\n      return c.json(null, 200);\n    } catch (err) {\n      logger.error(\"dogpile/current failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json(errorMessage(\"Failed to fetch dogpile status\"), 500);\n    }\n  });\n\n  // GET /schedule — upcoming events ordered by starts_at\n  app.openapi(scheduleRoute, async (c) => {\n    try {\n      const rows = await db.rawSql<DogpileEventRow[]>`\n        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n        FROM dogpile_events\n        WHERE status IN ('scheduled', 'active')\n        ORDER BY starts_at ASC\n      `;\n\n      const items = rows.map((e: DogpileEventRow) => ({\n        id: Number(e.id),\n        multiplier: Number(e.multiplier),\n        startsAt: e.starts_at.toISOString(),\n        endsAt: e.ends_at.toISOString(),\n        status: e.status,\n      }));\n\n      return c.json({ items }, 200);\n    } catch (err) {\n      logger.error(\"dogpile/schedule failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json(errorMessage(\"Failed to fetch dogpile schedule\"), 500);\n    }\n  });\n\n  return app;\n}\n","numLines":167,"startLine":1,"totalLines":167}}}
