{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UjnhApJa67W1nhcBPaF27P","type":"tool_result","content":"1\t/**\n2\t * Dogpile routes — public endpoints for dogpile event status and schedule.\n3\t *\n4\t * GET /current   — active dogpile event, or next scheduled, or null\n5\t * GET /schedule  — upcoming dogpile events ordered by starts_at\n6\t */\n7\t\n8\timport { createRoute } from \"@hono/zod-openapi\";\n9\timport type { AppEnv } from \"../hono-env.js\";\n10\timport type { Db } from \"../db.js\";\n11\timport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n12\timport {\n13\t  envelope,\n14\t  ErrorEnvelopeSchema,\n15\t  ok,\n16\t  err,\n17\t} from \"../contracts/api-envelope.js\";\n18\timport { logger } from \"../logger.js\";\n19\timport {\n20\t  DogpileCurrentResponseSchema,\n21\t  DogpileScheduleResponseSchema,\n22\t} from \"../contracts/validators.js\";\n23\timport { createOpenApiApp } from \"../openapi/hono.js\";\n24\t\n25\t// ---------------------------------------------------------------------------\n26\t// Types\n27\t// ---------------------------------------------------------------------------\n28\t\n29\texport interface DogpileRoutesDeps {\n30\t  db: Db;\n31\t}\n32\t\n33\tinterface DogpileEventRow {\n34\t  id: string;\n35\t  multiplier: string;\n36\t  starts_at: Date;\n37\t  ends_at: Date;\n38\t  status: string;\n39\t  campaign_id: string | null;\n40\t}\n41\t\n42\t// ---------------------------------------------------------------------------\n43\t// Route definitions\n44\t// ---------------------------------------------------------------------------\n45\t\n46\tconst currentRoute = createRoute({\n47\t  method: \"get\",\n48\t  path: \"/current\",\n49\t  tags: [\"Dogpile\"],\n50\t  summary: \"Get the active or next scheduled dogpile event\",\n51\t  responses: {\n52\t    200: {\n53\t      content: {\n54\t        \"application/json\": { schema: envelope(DogpileCurrentResponseSchema) },\n55\t      },\n56\t      description: \"Active dogpile event, next scheduled event, or null\",\n57\t    },\n58\t    500: {\n59\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n60\t      description: \"Failed to fetch dogpile status\",\n61\t    },\n62\t  },\n63\t});\n64\t\n65\tconst scheduleRoute = createRoute({\n66\t  method: \"get\",\n67\t  path: \"/schedule\",\n68\t  tags: [\"Dogpile\"],\n69\t  summary: \"Get upcoming dogpile events\",\n70\t  responses: {\n71\t    200: {\n72\t      content: {\n73\t        \"application/json\": { schema: envelope(DogpileScheduleResponseSchema) },\n74\t      },\n75\t      description: \"Upcoming dogpile events ordered by start time\",\n76\t    },\n77\t    500: {\n78\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n79\t      description: \"Failed to fetch dogpile schedule\",\n80\t    },\n81\t  },\n82\t});\n83\t\n84\t// ---------------------------------------------------------------------------\n85\t// Route factory\n86\t// ---------------------------------------------------------------------------\n87\t\n88\texport function createDogpileRoutes(deps: DogpileRoutesDeps) {\n89\t  const { db } = deps;\n90\t  const app = createOpenApiApp<AppEnv>();\n91\t\n92\t  // GET /current — active event > next scheduled > null\n93\t  app.openapi(currentRoute, async (c) => {\n94\t    try {\n95\t      // Try active first\n96\t      const active = await db.rawSql<DogpileEventRow[]>`\n97\t        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n98\t        FROM dogpile_events\n99\t        WHERE status = 'active'\n100\t        ORDER BY starts_at ASC\n101\t        LIMIT 1\n102\t      `;\n103\t\n104\t      if (active.length > 0) {\n105\t        const e = active[0]!;\n106\t        return ok(c, {\n107\t          id: Number(e.id),\n108\t          multiplier: Number(e.multiplier),\n109\t          startsAt: e.starts_at.toISOString(),\n110\t          endsAt: e.ends_at.toISOString(),\n111\t          status: \"active\" as const,\n112\t          endsIn: Math.max(0, e.ends_at.getTime() - Date.now()),\n113\t        });\n114\t      }\n115\t\n116\t      // Try next scheduled\n117\t      const scheduled = await db.rawSql<DogpileEventRow[]>`\n118\t        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n119\t        FROM dogpile_events\n120\t        WHERE status = 'scheduled'\n121\t          AND starts_at > now()\n122\t        ORDER BY starts_at ASC\n123\t        LIMIT 1\n124\t      `;\n125\t\n126\t      if (scheduled.length > 0) {\n127\t        const e = scheduled[0]!;\n128\t        return ok(c, {\n129\t          id: Number(e.id),\n130\t          multiplier: Number(e.multiplier),\n131\t          startsAt: e.starts_at.toISOString(),\n132\t          endsAt: e.ends_at.toISOString(),\n133\t          status: \"scheduled\" as const,\n134\t          startsIn: Math.max(0, e.starts_at.getTime() - Date.now()),\n135\t        });\n136\t      }\n137\t\n138\t      return ok(c, null);\n139\t    } catch (queryError) {\n140\t      logger.error(\"dogpile/current failed\", {\n141\t        error: queryError instanceof Error ? queryError.message : String(queryError),\n142\t      });\n143\t      return err(\n144\t        c,\n145\t        500,\n146\t        API_ERROR_CODES.PRECONDITION_FAILED,\n147\t        \"Failed to fetch dogpile status\",\n148\t      );\n149\t    }\n150\t  });\n151\t\n152\t  // GET /schedule — upcoming events ordered by starts_at\n153\t  app.openapi(scheduleRoute, async (c) => {\n154\t    try {\n155\t      const rows = await db.rawSql<DogpileEventRow[]>`\n156\t        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n157\t        FROM dogpile_events\n158\t        WHERE status IN ('scheduled', 'active')\n159\t        ORDER BY starts_at ASC\n160\t      `;\n161\t\n162\t      const items = rows.map((e: DogpileEventRow) => ({\n163\t        id: Number(e.id),\n164\t        multiplier: Number(e.multiplier),\n165\t        startsAt: e.starts_at.toISOString(),\n166\t        endsAt: e.ends_at.toISOString(),\n167\t        status: e.status,\n168\t      }));\n169\t\n170\t      return ok(c, { items });\n171\t    } catch (queryError) {\n172\t      logger.error(\"dogpile/schedule failed\", {\n173\t        error: queryError instanceof Error ? queryError.message : String(queryError),\n174\t      });\n175\t      return err(\n176\t        c,\n177\t        500,\n178\t        API_ERROR_CODES.PRECONDITION_FAILED,\n179\t        \"Failed to fetch dogpile schedule\",\n180\t      );\n181\t    }\n182\t  });\n183\t\n184\t  return app;\n185\t}\n186\t"}]},"parent_tool_use_id":null,"session_id":"d4c0a13e-52a1-4abb-9de9-52ca4763881b","uuid":"46099a57-3c78-4bc8-bf16-d64884a5eb9c","timestamp":"2026-04-22T10:39:26.477Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/dogpile.ts","content":"/**\n * Dogpile routes — public endpoints for dogpile event status and schedule.\n *\n * GET /current   — active dogpile event, or next scheduled, or null\n * GET /schedule  — upcoming dogpile events ordered by starts_at\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport { logger } from \"../logger.js\";\nimport {\n  DogpileCurrentResponseSchema,\n  DogpileScheduleResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface DogpileRoutesDeps {\n  db: Db;\n}\n\ninterface DogpileEventRow {\n  id: string;\n  multiplier: string;\n  starts_at: Date;\n  ends_at: Date;\n  status: string;\n  campaign_id: string | null;\n}\n\n// ---------------------------------------------------------------------------\n// Route definitions\n// ---------------------------------------------------------------------------\n\nconst currentRoute = createRoute({\n  method: \"get\",\n  path: \"/current\",\n  tags: [\"Dogpile\"],\n  summary: \"Get the active or next scheduled dogpile event\",\n  responses: {\n    200: {\n      content: {\n        \"application/json\": { schema: envelope(DogpileCurrentResponseSchema) },\n      },\n      description: \"Active dogpile event, next scheduled event, or null\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Failed to fetch dogpile status\",\n    },\n  },\n});\n\nconst scheduleRoute = createRoute({\n  method: \"get\",\n  path: \"/schedule\",\n  tags: [\"Dogpile\"],\n  summary: \"Get upcoming dogpile events\",\n  responses: {\n    200: {\n      content: {\n        \"application/json\": { schema: envelope(DogpileScheduleResponseSchema) },\n      },\n      description: \"Upcoming dogpile events ordered by start time\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Failed to fetch dogpile schedule\",\n    },\n  },\n});\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport function createDogpileRoutes(deps: DogpileRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // GET /current — active event > next scheduled > null\n  app.openapi(currentRoute, async (c) => {\n    try {\n      // Try active first\n      const active = await db.rawSql<DogpileEventRow[]>`\n        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n        FROM dogpile_events\n        WHERE status = 'active'\n        ORDER BY starts_at ASC\n        LIMIT 1\n      `;\n\n      if (active.length > 0) {\n        const e = active[0]!;\n        return ok(c, {\n          id: Number(e.id),\n          multiplier: Number(e.multiplier),\n          startsAt: e.starts_at.toISOString(),\n          endsAt: e.ends_at.toISOString(),\n          status: \"active\" as const,\n          endsIn: Math.max(0, e.ends_at.getTime() - Date.now()),\n        });\n      }\n\n      // Try next scheduled\n      const scheduled = await db.rawSql<DogpileEventRow[]>`\n        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n        FROM dogpile_events\n        WHERE status = 'scheduled'\n          AND starts_at > now()\n        ORDER BY starts_at ASC\n        LIMIT 1\n      `;\n\n      if (scheduled.length > 0) {\n        const e = scheduled[0]!;\n        return ok(c, {\n          id: Number(e.id),\n          multiplier: Number(e.multiplier),\n          startsAt: e.starts_at.toISOString(),\n          endsAt: e.ends_at.toISOString(),\n          status: \"scheduled\" as const,\n          startsIn: Math.max(0, e.starts_at.getTime() - Date.now()),\n        });\n      }\n\n      return ok(c, null);\n    } catch (queryError) {\n      logger.error(\"dogpile/current failed\", {\n        error: queryError instanceof Error ? queryError.message : String(queryError),\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch dogpile status\",\n      );\n    }\n  });\n\n  // GET /schedule — upcoming events ordered by starts_at\n  app.openapi(scheduleRoute, async (c) => {\n    try {\n      const rows = await db.rawSql<DogpileEventRow[]>`\n        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n        FROM dogpile_events\n        WHERE status IN ('scheduled', 'active')\n        ORDER BY starts_at ASC\n      `;\n\n      const items = rows.map((e: DogpileEventRow) => ({\n        id: Number(e.id),\n        multiplier: Number(e.multiplier),\n        startsAt: e.starts_at.toISOString(),\n        endsAt: e.ends_at.toISOString(),\n        status: e.status,\n      }));\n\n      return ok(c, { items });\n    } catch (queryError) {\n      logger.error(\"dogpile/schedule failed\", {\n        error: queryError instanceof Error ? queryError.message : String(queryError),\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch dogpile schedule\",\n      );\n    }\n  });\n\n  return app;\n}\n","numLines":186,"startLine":1,"totalLines":186}}}
