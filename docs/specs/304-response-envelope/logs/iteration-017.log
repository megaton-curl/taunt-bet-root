{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01K3fFy4B4gpR3Fj6B9LQJu9","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01RYq7jTdac1t9ULBgF7M7ri","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/src/routes/leaderboard.ts","content":"/**\n * Leaderboard routes — public weekly volume-based leaderboards.\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport {\n  LeaderboardQuerySchema,\n  LeaderboardResponseSchema,\n} from \"../contracts/validators.js\";\nimport { toDbGameId } from \"../contracts/public-games.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface LeaderboardRoutesDeps {\n  db: Db;\n}\n\nconst weeklyRoute = createRoute({\n  method: \"get\",\n  path: \"/weekly\",\n  tags: [\"Leaderboard\"],\n  summary: \"Weekly leaderboard ranked by wagered volume\",\n  request: {\n    query: LeaderboardQuerySchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(LeaderboardResponseSchema) } },\n      description: \"Leaderboard entries for the current ISO week (Monday-Sunday UTC)\",\n    },\n    422: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid game filter\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Failed to fetch leaderboard\",\n    },\n  },\n});\n\nexport function createLeaderboardRoutes(deps: LeaderboardRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  app.openapi(weeklyRoute, async (c) => {\n    const { game, limit, offset } = c.req.valid(\"query\");\n    const dbGame = game ? toDbGameId(game) : undefined;\n    if (game && !dbGame) {\n      return err(\n        c,\n        422,\n        API_ERROR_CODES.INVALID_PARAMS,\n        `Invalid game filter: ${game}`,\n      );\n    }\n\n    try {\n      const result = await db.getWeeklyLeaderboard(dbGame, limit, offset);\n      const responseGame: \"flip-you\" | \"pot-shot\" | \"close-call\" | \"all\" = game ?? \"all\";\n\n      return ok(c, {\n        game: responseGame,\n        weekStart: result.weekStart,\n        weekEnd: result.weekEnd,\n        entries: result.entries.map((e) => ({\n          rank: e.rank,\n          userId: e.userId,\n          username: e.username,\n          avatarUrl: e.avatarUrl,\n          totalWagered: String(e.totalWagered),\n          gamesPlayed: e.gamesPlayed,\n          totalWins: e.totalWins,\n          winRate: e.winRate,\n          netPnl: String(e.netPnl),\n        })),\n      });\n    } catch (queryError) {\n      logger.error(\"leaderboard/weekly failed\", {\n        error: queryError instanceof Error ? queryError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch leaderboard\",\n      );\n    }\n  });\n\n  return app;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":680,"cache_read_input_tokens":91334,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":680},"output_tokens":76,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d4c0a13e-52a1-4abb-9de9-52ca4763881b","uuid":"fc5feefc-8575-4e96-918e-ab699950843e"}
