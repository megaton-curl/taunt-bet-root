{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WsZZ1n7RFXDdkhHFkosCZs","type":"tool_result","content":"1\t/**\n2\t * Leaderboard routes — public weekly volume-based leaderboards.\n3\t */\n4\t\n5\timport { createRoute } from \"@hono/zod-openapi\";\n6\timport type { AppEnv } from \"../hono-env.js\";\n7\timport type { Db } from \"../db.js\";\n8\timport { logger } from \"../logger.js\";\n9\timport { errorMessage } from \"../contracts/api-errors.js\";\n10\timport {\n11\t  LeaderboardQuerySchema,\n12\t  LeaderboardResponseSchema,\n13\t  ErrorResponseSchema,\n14\t} from \"../contracts/validators.js\";\n15\timport { toDbGameId } from \"../contracts/public-games.js\";\n16\timport { createOpenApiApp } from \"../openapi/hono.js\";\n17\t\n18\texport interface LeaderboardRoutesDeps {\n19\t  db: Db;\n20\t}\n21\t\n22\tconst weeklyRoute = createRoute({\n23\t  method: \"get\",\n24\t  path: \"/weekly\",\n25\t  tags: [\"Leaderboard\"],\n26\t  summary: \"Weekly leaderboard ranked by wagered volume\",\n27\t  request: {\n28\t    query: LeaderboardQuerySchema,\n29\t  },\n30\t  responses: {\n31\t    200: {\n32\t      content: { \"application/json\": { schema: LeaderboardResponseSchema } },\n33\t      description: \"Leaderboard entries for the current ISO week (Monday-Sunday UTC)\",\n34\t    },\n35\t    400: {\n36\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n37\t      description: \"Invalid game filter\",\n38\t    },\n39\t    500: {\n40\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n41\t      description: \"Failed to fetch leaderboard\",\n42\t    },\n43\t  },\n44\t});\n45\t\n46\texport function createLeaderboardRoutes(deps: LeaderboardRoutesDeps) {\n47\t  const { db } = deps;\n48\t  const app = createOpenApiApp<AppEnv>();\n49\t\n50\t  app.openapi(weeklyRoute, async (c) => {\n51\t    const { game, limit, offset } = c.req.valid(\"query\");\n52\t    const dbGame = game ? toDbGameId(game) : undefined;\n53\t    if (game && !dbGame) {\n54\t      return c.json(errorMessage(`Invalid game filter: ${game}`), 400);\n55\t    }\n56\t\n57\t    try {\n58\t      const result = await db.getWeeklyLeaderboard(dbGame, limit, offset);\n59\t      const responseGame: \"flip-you\" | \"pot-shot\" | \"close-call\" | \"all\" = game ?? \"all\";\n60\t\n61\t      return c.json({\n62\t        game: responseGame,\n63\t        weekStart: result.weekStart,\n64\t        weekEnd: result.weekEnd,\n65\t        entries: result.entries.map((e) => ({\n66\t          rank: e.rank,\n67\t          userId: e.userId,\n68\t          username: e.username,\n69\t          avatarUrl: e.avatarUrl,\n70\t          totalWagered: String(e.totalWagered),\n71\t          gamesPlayed: e.gamesPlayed,\n72\t          totalWins: e.totalWins,\n73\t          winRate: e.winRate,\n74\t          netPnl: String(e.netPnl),\n75\t        })),\n76\t      }, 200);\n77\t    } catch (err) {\n78\t      logger.error(\"leaderboard/weekly failed\", {\n79\t        error: err instanceof Error ? err.message : \"Unknown error\",\n80\t      });\n81\t      return c.json(errorMessage(\"Failed to fetch leaderboard\"), 500);\n82\t    }\n83\t  });\n84\t\n85\t  return app;\n86\t}\n87\t"}]},"parent_tool_use_id":null,"session_id":"d4c0a13e-52a1-4abb-9de9-52ca4763881b","uuid":"5ae24d5e-b429-4a9c-bb29-03bafd7b5ca9","timestamp":"2026-04-22T10:39:15.294Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/leaderboard.ts","content":"/**\n * Leaderboard routes — public weekly volume-based leaderboards.\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { errorMessage } from \"../contracts/api-errors.js\";\nimport {\n  LeaderboardQuerySchema,\n  LeaderboardResponseSchema,\n  ErrorResponseSchema,\n} from \"../contracts/validators.js\";\nimport { toDbGameId } from \"../contracts/public-games.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface LeaderboardRoutesDeps {\n  db: Db;\n}\n\nconst weeklyRoute = createRoute({\n  method: \"get\",\n  path: \"/weekly\",\n  tags: [\"Leaderboard\"],\n  summary: \"Weekly leaderboard ranked by wagered volume\",\n  request: {\n    query: LeaderboardQuerySchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: LeaderboardResponseSchema } },\n      description: \"Leaderboard entries for the current ISO week (Monday-Sunday UTC)\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Invalid game filter\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Failed to fetch leaderboard\",\n    },\n  },\n});\n\nexport function createLeaderboardRoutes(deps: LeaderboardRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  app.openapi(weeklyRoute, async (c) => {\n    const { game, limit, offset } = c.req.valid(\"query\");\n    const dbGame = game ? toDbGameId(game) : undefined;\n    if (game && !dbGame) {\n      return c.json(errorMessage(`Invalid game filter: ${game}`), 400);\n    }\n\n    try {\n      const result = await db.getWeeklyLeaderboard(dbGame, limit, offset);\n      const responseGame: \"flip-you\" | \"pot-shot\" | \"close-call\" | \"all\" = game ?? \"all\";\n\n      return c.json({\n        game: responseGame,\n        weekStart: result.weekStart,\n        weekEnd: result.weekEnd,\n        entries: result.entries.map((e) => ({\n          rank: e.rank,\n          userId: e.userId,\n          username: e.username,\n          avatarUrl: e.avatarUrl,\n          totalWagered: String(e.totalWagered),\n          gamesPlayed: e.gamesPlayed,\n          totalWins: e.totalWins,\n          winRate: e.winRate,\n          netPnl: String(e.netPnl),\n        })),\n      }, 200);\n    } catch (err) {\n      logger.error(\"leaderboard/weekly failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json(errorMessage(\"Failed to fetch leaderboard\"), 500);\n    }\n  });\n\n  return app;\n}\n","numLines":87,"startLine":1,"totalLines":87}}}
