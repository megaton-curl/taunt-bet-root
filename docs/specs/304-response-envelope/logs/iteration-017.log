Routes(deps: LeaderboardRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  app.openapi(weeklyRoute, async (c) => {\n    const { game, limit, offset } = c.req.valid(\"query\");\n    const dbGame = game ? toDbGameId(game) : undefined;\n    if (game && !dbGame) {\n      return err(\n        c,\n        422,\n        API_ERROR_CODES.INVALID_PARAMS,\n        `Invalid game filter: ${game}`,\n      );\n    }\n\n    try {\n      const result = await db.getWeeklyLeaderboard(dbGame, limit, offset);\n      const responseGame: \"flip-you\" | \"pot-shot\" | \"close-call\" | \"all\" = game ?? \"all\";\n\n      return ok(c, {\n        game: responseGame,\n        weekStart: result.weekStart,\n        weekEnd: result.weekEnd,\n        entries: result.entries.map((e) => ({\n          rank: e.rank,\n          userId: e.userId,\n          username: e.username,\n          avatarUrl: e.avatarUrl,\n          totalWagered: String(e.totalWagered),\n          gamesPlayed: e.gamesPlayed,\n          totalWins: e.totalWins,\n          winRate: e.winRate,\n          netPnl: String(e.netPnl),\n        })),\n      });\n    } catch (queryError) {\n      logger.error(\"leaderboard/weekly failed\", {\n        error: queryError instanceof Error ? queryError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch leaderboard\",\n      );\n    }\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":6,"oldLines":11,"newStart":6,"newLines":16,"lines":[" import type { AppEnv } from \"../hono-env.js\";"," import type { Db } from \"../db.js\";"," import { logger } from \"../logger.js\";","-import { errorMessage } from \"../contracts/api-errors.js\";","+import { API_ERROR_CODES } from \"../contracts/api-errors.js\";"," import {","+  envelope,","+  ErrorEnvelopeSchema,","+  ok,","+  err,","+} from \"../contracts/api-envelope.js\";","+import {","   LeaderboardQuerySchema,","   LeaderboardResponseSchema,","-  ErrorResponseSchema,"," } from \"../contracts/validators.js\";"," import { toDbGameId } from \"../contracts/public-games.js\";"," import { createOpenApiApp } from \"../openapi/hono.js\";"]},{"oldStart":29,"oldLines":15,"newStart":34,"newLines":15,"lines":["   },","   responses: {","     200: {","-      content: { \"application/json\": { schema: LeaderboardResponseSchema } },","+      content: { \"application/json\": { schema: envelope(LeaderboardResponseSchema) } },","       description: \"Leaderboard entries for the current ISO week (Monday-Sunday UTC)\",","     },","-    400: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+    422: {","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Invalid game filter\",","     },","     500: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Failed to fetch leaderboard\",","     },","   },"]},{"oldStart":51,"oldLines":14,"newStart":56,"newLines":19,"lines":["     const { game, limit, offset } = c.req.valid(\"query\");","     const dbGame = game ? toDbGameId(game) : undefined;","     if (game && !dbGame) {","-      return c.json(errorMessage(`Invalid game filter: ${game}`), 400);","+      return err(","+        c,","+        422,","+        API_ERROR_CODES.INVALID_PARAMS,","+        `Invalid game filter: ${game}`,","+      );","     }"," ","     try {","       const result = await db.getWeeklyLeaderboard(dbGame, limit, offset);","       const responseGame: \"flip-you\" | \"pot-shot\" | \"close-call\" | \"all\" = game ?? \"all\";"," ","-      return c.json({","+      return ok(c, {","         game: responseGame,","         weekStart: result.weekStart,","         weekEnd: result.weekEnd,"]},{"oldStart":73,"oldLines":12,"newStart":83,"newLines":17,"lines":["           winRate: e.winRate,","           netPnl: String(e.netPnl),","         })),","-      }, 200);","-    } catch (err) {","+      });","+    } catch (queryError) {","       logger.error(\"leaderboard/weekly failed\", {","-        error: err instanceof Error ? err.message : \"Unknown error\",","+        error: queryError instanceof Error ? queryError.message : \"Unknown error\",","       });","-      return c.json(errorMessage(\"Failed to fetch leaderboard\"), 500);","+      return err(","+        c,","+        500,","+        API_ERROR_CODES.PRECONDITION_FAILED,","+        \"Failed to fetch leaderboard\",","+      );","     }","   });"," "]}],"originalFile":"/**\n * Leaderboard routes — public weekly volume-based leaderboards.\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { errorMessage } from \"../contracts/api-errors.js\";\nimport {\n  LeaderboardQuerySchema,\n  LeaderboardResponseSchema,\n  ErrorResponseSchema,\n} from \"../contracts/validators.js\";\nimport { toDbGameId } from \"../contracts/public-games.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface LeaderboardRoutesDeps {\n  db: Db;\n}\n\nconst weeklyRoute = createRoute({\n  method: \"get\",\n  path: \"/weekly\",\n  tags: [\"Leaderboard\"],\n  summary: \"Weekly leaderboard ranked by wagered volume\",\n  request: {\n    query: LeaderboardQuerySchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: LeaderboardResponseSchema } },\n      description: \"Leaderboard entries for the current ISO week (Monday-Sunday UTC)\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Invalid game filter\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Failed to fetch leaderboard\",\n    },\n  },\n});\n\nexport function createLeaderboardRoutes(deps: LeaderboardRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  app.openapi(weeklyRoute, async (c) => {\n    const { game, limit, offset } = c.req.valid(\"query\");\n    const dbGame = game ? toDbGameId(game) : undefined;\n    if (game && !dbGame) {\n      return c.json(errorMessage(`Invalid game filter: ${game}`), 400);\n    }\n\n    try {\n      const result = await db.getWeeklyLeaderboard(dbGame, limit, offset);\n      const responseGame: \"flip-you\" | \"pot-shot\" | \"close-call\" | \"all\" = game ?? \"all\";\n\n      return c.json({\n        game: responseGame,\n        weekStart: result.weekStart,\n        weekEnd: result.weekEnd,\n        entries: result.entries.map((e) => ({\n          rank: e.rank,\n          userId: e.userId,\n          username: e.username,\n          avatarUrl: e.avatarUrl,\n          totalWagered: String(e.totalWagered),\n          gamesPlayed: e.gamesPlayed,\n          totalWins: e.totalWins,\n          winRate: e.winRate,\n          netPnl: String(e.netPnl),\n        })),\n      }, 200);\n    } catch (err) {\n      logger.error(\"leaderboard/weekly failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json(errorMessage(\"Failed to fetch leaderboard\"), 500);\n    }\n  });\n\n  return app;\n}\n","userModified":false}}
