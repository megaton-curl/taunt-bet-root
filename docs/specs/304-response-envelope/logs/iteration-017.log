{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018npmp6xFmsipjSJQZWbUQn","type":"tool_result","content":"1\t/**\n2\t * Tests for weekly leaderboard + game_entries table.\n3\t *\n4\t * Requires a running PostgreSQL instance. Seeds game_entries directly\n5\t * and verifies getWeeklyLeaderboard returns correct rankings.\n6\t */\n7\t\n8\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n9\timport { Hono } from \"hono\";\n10\timport postgres from \"postgres\";\n11\timport { createDb, type Db } from \"../db.js\";\n12\timport { createLeaderboardRoutes } from \"../routes/leaderboard.js\";\n13\t\n14\tconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n15\t\n16\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n17\tfunction makeSql() {\n18\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n19\t  return postgres({\n20\t    host: \"/var/run/postgresql\",\n21\t    user: \"vscode\",\n22\t    database: \"taunt_bet_dev\",\n23\t  });\n24\t}\n25\t\n26\tconst TS = Date.now();\n27\tconst WALLET_A = \"LeaderboardTestA_\" + TS;\n28\tconst WALLET_B = \"LeaderboardTestB_\" + TS;\n29\tconst WALLET_C = \"LeaderboardTestC_\" + TS;\n30\tconst USER_A = \"usr_leada\" + TS;\n31\tconst USER_B = \"usr_leadb\" + TS;\n32\tconst USER_C = \"usr_leadc\" + TS;\n33\t\n34\tdescribe(\"Weekly leaderboard\", () => {\n35\t  let rawSql: ReturnType<typeof postgres>;\n36\t  let db: Db;\n37\t  let app: Hono;\n38\t\n39\t  beforeAll(async () => {\n40\t    rawSql = makeSql();\n41\t\n42\t    // Ensure game_entries table exists (matches consolidated migration schema)\n43\t    await rawSql`\n44\t      CREATE TABLE IF NOT EXISTS game_entries (\n45\t        id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n46\t        user_id         TEXT         NOT NULL,\n47\t        wallet          TEXT         NOT NULL,\n48\t        game            TEXT         NOT NULL,\n49\t        round_pda       TEXT         NOT NULL,\n50\t        match_id        TEXT         NOT NULL,\n51\t        amount_lamports BIGINT       NOT NULL,\n52\t        side            TEXT,\n53\t        is_winner       BOOLEAN,\n54\t        payout_lamports BIGINT       NOT NULL DEFAULT 0,\n55\t        created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n56\t        settled_at      TIMESTAMPTZ,\n57\t        UNIQUE (wallet, round_pda)\n58\t      )\n59\t    `;\n60\t    // Ensure player_profiles exists (for JOIN)\n61\t    await rawSql`\n62\t      CREATE TABLE IF NOT EXISTS player_profiles (\n63\t        id                   BIGSERIAL    PRIMARY KEY,\n64\t        user_id              TEXT         UNIQUE NOT NULL,\n65\t        wallet               TEXT         UNIQUE NOT NULL,\n66\t        username             TEXT         UNIQUE NOT NULL,\n67\t        username_updated_at  TIMESTAMPTZ,\n68\t        avatar_url           TEXT,\n69\t        heat_multiplier      NUMERIC      NOT NULL DEFAULT 1.0,\n70\t        points_balance       BIGINT       NOT NULL DEFAULT 0,\n71\t        created_at           TIMESTAMPTZ  NOT NULL DEFAULT now()\n72\t      )\n73\t    `;\n74\t    db = createDb(DATABASE_URL, rawSql);\n75\t  });\n76\t\n77\t  afterAll(async () => {\n78\t    await rawSql`DELETE FROM game_entries WHERE wallet LIKE 'LeaderboardTest%'`;\n79\t    await rawSql`DELETE FROM player_profiles WHERE wallet LIKE 'LeaderboardTest%'`;\n80\t    await rawSql.end();\n81\t  });\n82\t\n83\t  beforeEach(async () => {\n84\t    await rawSql`DELETE FROM game_entries WHERE wallet LIKE 'LeaderboardTest%'`;\n85\t    await rawSql`DELETE FROM player_profiles WHERE wallet LIKE 'LeaderboardTest%'`;\n86\t    app = new Hono();\n87\t    app.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n88\t    // Seed profiles for test wallets (leaderboard JOINs on user_id)\n89\t    await rawSql`\n90\t      INSERT INTO player_profiles (user_id, wallet, username) VALUES\n91\t        (${USER_A}, ${WALLET_A}, ${\"user_a_\" + TS}),\n92\t        (${USER_B}, ${WALLET_B}, ${\"user_b_\" + TS}),\n93\t        (${USER_C}, ${WALLET_C}, ${\"user_c_\" + TS})\n94\t      ON CONFLICT DO NOTHING\n95\t    `;\n96\t  });\n97\t\n98\t  it(\"returns empty leaderboard when no entries\", async () => {\n99\t    const result = await db.getWeeklyLeaderboard();\n100\t    // May have entries from other tests but our users shouldn't be there\n101\t    const ours = result.entries.filter((e) =>\n102\t      e.userId.startsWith(\"usr_lead\"),\n103\t    );\n104\t    expect(ours.length).toBe(0);\n105\t    expect(result.weekStart).toBeDefined();\n106\t    expect(result.weekEnd).toBeDefined();\n107\t  });\n108\t\n109\t  it(\"rejects legacy leaderboard game aliases at validation time\", async () => {\n110\t    const res = await app.request(\"/leaderboard/weekly?game=flipyou\");\n111\t\n112\t    expect(res.status).toBe(422);\n113\t    const body = (await res.json()) as {\n114\t      ok: false;\n115\t      error: { code: string; message: string };\n116\t    };\n117\t    expect(body.ok).toBe(false);\n118\t    expect(body.error.code).toBe(\"VALIDATION_FAILED\");\n119\t    expect(body.error.message).toBe(\"Invalid request\");\n120\t  });\n121\t\n122\t  it(\"ranks players by total wagered volume\", async () => {\n123\t    // Wallet A: 5 SOL wagered (2 games)\n124\t    await db.insertGameEntries([\n125\t      {\n126\t        userId: USER_A,\n127\t        wallet: WALLET_A,\n128\t        game: \"flipyou\",\n129\t        roundPda: \"pda_lb1\",\n130\t        matchId: \"lb_m1\",\n131\t        amountLamports: 3_000_000_000,\n132\t        isWinner: true,\n133\t        payoutLamports: 5_700_000_000,\n134\t        settledAt: new Date(),\n135\t      },\n136\t      {\n137\t        userId: USER_A,\n138\t        wallet: WALLET_A,\n139\t        game: \"flipyou\",\n140\t        roundPda: \"pda_lb2\",\n141\t        matchId: \"lb_m2\",\n142\t        amountLamports: 2_000_000_000,\n143\t        isWinner: false,\n144\t        payoutLamports: 0,\n145\t        settledAt: new Date(),\n146\t      },\n147\t    ]);\n148\t\n149\t    // Wallet B: 10 SOL wagered (1 game)\n150\t    await db.insertGameEntries([\n151\t      {\n152\t        userId: USER_B,\n153\t        wallet: WALLET_B,\n154\t        game: \"potshot\",\n155\t        roundPda: \"pda_lb3\",\n156\t        matchId: \"lb_m3\",\n157\t        amountLamports: 10_000_000_000,\n158\t        isWinner: true,\n159\t        payoutLamports: 18_000_000_000,\n160\t        settledAt: new Date(),\n161\t      },\n162\t    ]);\n163\t\n164\t    // Wallet C: 1 SOL wagered (1 game)\n165\t    await db.insertGameEntries([\n166\t      {\n167\t        userId: USER_C,\n168\t        wallet: WALLET_C,\n169\t        game: \"closecall\",\n170\t        roundPda: \"pda_lb4\",\n171\t        matchId: \"lb_m4\",\n172\t        amountLamports: 1_000_000_000,\n173\t        isWinner: false,\n174\t        payoutLamports: 0,\n175\t        settledAt: new Date(),\n176\t      },\n177\t    ]);\n178\t\n179\t    const result = await db.getWeeklyLeaderboard();\n180\t    const ours = result.entries.filter((e) =>\n181\t      e.userId.startsWith(\"usr_lead\"),\n182\t    );\n183\t\n184\t    // B (10 SOL) > A (5 SOL) > C (1 SOL)\n185\t    expect(ours.length).toBe(3);\n186\t    expect(ours[0]!.userId).toBe(USER_B);\n187\t    expect(ours[0]!.totalWagered).toBe(10_000_000_000n);\n188\t    expect(ours[0]!.gamesPlayed).toBe(1);\n189\t    expect(ours[0]!.totalWins).toBe(1);\n190\t\n191\t    expect(ours[1]!.userId).toBe(USER_A);\n192\t    expect(ours[1]!.totalWagered).toBe(5_000_000_000n);\n193\t    expect(ours[1]!.gamesPlayed).toBe(2);\n194\t    expect(ours[1]!.totalWins).toBe(1);\n195\t    expect(ours[1]!.winRate).toBeCloseTo(0.5);\n196\t\n197\t    expect(ours[2]!.userId).toBe(USER_C);\n198\t    expect(ours[2]!.totalWagered).toBe(1_000_000_000n);\n199\t    expect(ours[2]!.totalWins).toBe(0);\n200\t  });\n201\t\n202\t  it(\"filters by game type\", async () => {\n203\t    await db.insertGameEntries([\n204\t      {\n205\t        userId: USER_A,\n206\t        wallet: WALLET_A,\n207\t        game: \"flipyou\",\n208\t        roundPda: \"pda_gf1\",\n209\t        matchId: \"gf_m1\",\n210\t        amountLamports: 5_000_000_000,\n211\t        isWinner: true,\n212\t        payoutLamports: 9_500_000_000,\n213\t        settledAt: new Date(),\n214\t      },\n215\t      {\n216\t        userId: USER_A,\n217\t        wallet: WALLET_A,\n218\t        game: \"potshot\",\n219\t        roundPda: \"pda_gf2\",\n220\t        matchId: \"gf_m2\",\n221\t        amountLamports: 2_000_000_000,\n222\t        isWinner: false,\n223\t        payoutLamports: 0,\n224\t        settledAt: new Date(),\n225\t      },\n226\t    ]);\n227\t\n228\t    // FlipYou only\n229\t    const cfResult = await db.getWeeklyLeaderboard(\"flipyou\");\n230\t    const cfOurs = cfResult.entries.filter((e) =>\n231\t      e.userId.startsWith(\"usr_lead\"),\n232\t    );\n233\t    expect(cfOurs.length).toBe(1);\n234\t    expect(cfOurs[0]!.totalWagered).toBe(5_000_000_000n);\n235\t\n236\t    // Lord only\n237\t    const lordResult = await db.getWeeklyLeaderboard(\"potshot\");\n238\t    const lordOurs = lordResult.entries.filter((e) =>\n239\t      e.userId.startsWith(\"usr_lead\"),\n240\t    );\n241\t    expect(lordOurs.length).toBe(1);\n242\t    expect(lordOurs[0]!.totalWagered).toBe(2_000_000_000n);\n243\t\n244\t    // Global (both games)\n245\t    const allResult = await db.getWeeklyLeaderboard();\n246\t    const allOurs = allResult.entries.filter((e) =>\n247\t      e.userId.startsWith(\"usr_lead\"),\n248\t    );\n249\t    expect(allOurs.length).toBe(1);\n250\t    expect(allOurs[0]!.totalWagered).toBe(7_000_000_000n);\n251\t    expect(allOurs[0]!.gamesPlayed).toBe(2);\n252\t  });\n253\t\n254\t  it(\"computes net PnL correctly\", async () => {\n255\t    // Win 9.5 SOL on 5 SOL wager, lose 3 SOL → net = +1.5 SOL\n256\t    await db.insertGameEntries([\n257\t      {\n258\t        userId: USER_A,\n259\t        wallet: WALLET_A,\n260\t        game: \"flipyou\",\n261\t        roundPda: \"pda_pnl1\",\n262\t        matchId: \"pnl_m1\",\n263\t        amountLamports: 5_000_000_000,\n264\t        isWinner: true,\n265\t        payoutLamports: 9_500_000_000,\n266\t        settledAt: new Date(),\n267\t      },\n268\t      {\n269\t        userId: USER_A,\n270\t        wallet: WALLET_A,\n271\t        game: \"flipyou\",\n272\t        roundPda: \"pda_pnl2\",\n273\t        matchId: \"pnl_m2\",\n274\t        amountLamports: 3_000_000_000,\n275\t        isWinner: false,\n276\t        payoutLamports: 0,\n277\t        settledAt: new Date(),\n278\t      },\n279\t    ]);\n280\t\n281\t    const result = await db.getWeeklyLeaderboard();\n282\t    const entry = result.entries.find((e) => e.userId === USER_A);\n283\t    expect(entry).toBeDefined();\n284\t    // netPnl = (9.5 + 0) - (5 + 3) = 1.5 SOL = 1_500_000_000 lamports\n285\t    expect(entry!.netPnl).toBe(1_500_000_000n);\n286\t  });\n287\t\n288\t  it(\"respects limit and offset\", async () => {\n289\t    await db.insertGameEntries([\n290\t      {\n291\t        userId: USER_A,\n292\t        wallet: WALLET_A,\n293\t        game: \"flipyou\",\n294\t        roundPda: \"pda_pg1\",\n295\t        matchId: \"pg_m1\",\n296\t        amountLamports: 3_000_000_000,\n297\t        isWinner: false,\n298\t        payoutLamports: 0,\n299\t        settledAt: new Date(),\n300\t      },\n301\t      {\n302\t        userId: USER_B,\n303\t        wallet: WALLET_B,\n304\t        game: \"flipyou\",\n305\t        roundPda: \"pda_pg2\",\n306\t        matchId: \"pg_m2\",\n307\t        amountLamports: 5_000_000_000,\n308\t        isWinner: true,\n309\t        payoutLamports: 9_000_000_000,\n310\t        settledAt: new Date(),\n311\t      },\n312\t      {\n313\t        userId: USER_C,\n314\t        wallet: WALLET_C,\n315\t        game: \"flipyou\",\n316\t        roundPda: \"pda_pg3\",\n317\t        matchId: \"pg_m3\",\n318\t        amountLamports: 1_000_000_000,\n319\t        isWinner: false,\n320\t        payoutLamports: 0,\n321\t        settledAt: new Date(),\n322\t      },\n323\t    ]);\n324\t\n325\t    // Limit 2: should get B and A (top 2 by volume)\n326\t    const page1 = await db.getWeeklyLeaderboard(undefined, 2);\n327\t    const p1Ours = page1.entries.filter((e) =>\n328\t      e.userId.startsWith(\"usr_lead\"),\n329\t    );\n330\t    expect(p1Ours.length).toBeLessThanOrEqual(2);\n331\t  });\n332\t\n333\t  it(\"idempotent — duplicate insertGameEntries do not error\", async () => {\n334\t    const entry = {\n335\t      userId: USER_A,\n336\t      wallet: WALLET_A,\n337\t      game: \"flipyou\",\n338\t      roundPda: \"pda_idem1\",\n339\t      matchId: \"idem_m1\",\n340\t      amountLamports: 1_000_000_000,\n341\t      isWinner: true,\n342\t      payoutLamports: 1_900_000_000,\n343\t      settledAt: new Date(),\n344\t    };\n345\t\n346\t    await db.insertGameEntries([entry]);\n347\t    // Second insert should be silently ignored\n348\t    await db.insertGameEntries([entry]);\n349\t\n350\t    const result = await db.getWeeklyLeaderboard();\n351\t    const ours = result.entries.filter((e) => e.userId === USER_A);\n352\t    expect(ours.length).toBe(1);\n353\t    expect(ours[0]!.totalWagered).toBe(1_000_000_000n);\n354\t  });\n355\t\n356\t  it(\"uses profile username when available\", async () => {\n357\t    await rawSql`\n358\t      UPDATE player_profiles SET username = ${\"CoolDegen42\"}\n359\t      WHERE user_id = ${USER_A}\n360\t    `;\n361\t\n362\t    await db.insertGameEntries([\n363\t      {\n364\t        userId: USER_A,\n365\t        wallet: WALLET_A,\n366\t        game: \"flipyou\",\n367\t        roundPda: \"pda_usr1\",\n368\t        matchId: \"usr_m1\",\n369\t        amountLamports: 1_000_000_000,\n370\t        isWinner: true,\n371\t        payoutLamports: 1_900_000_000,\n372\t        settledAt: new Date(),\n373\t      },\n374\t    ]);\n375\t\n376\t    const result = await db.getWeeklyLeaderboard();\n377\t    const entry = result.entries.find((e) => e.userId === USER_A);\n378\t    expect(entry).toBeDefined();\n379\t    expect(entry!.username).toBe(\"CoolDegen42\");\n380\t  });\n381\t});\n382\t"}]},"parent_tool_use_id":null,"session_id":"d4c0a13e-52a1-4abb-9de9-52ca4763881b","uuid":"7634a7bc-132d-489a-a7ff-5501235358c0","timestamp":"2026-04-22T10:39:22.579Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/leaderboard.test.ts","content":"/**\n * Tests for weekly leaderboard + game_entries table.\n *\n * Requires a running PostgreSQL instance. Seeds game_entries directly\n * and verifies getWeeklyLeaderboard returns correct rankings.\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createLeaderboardRoutes } from \"../routes/leaderboard.js\";\n\nconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"taunt_bet_dev\",\n  });\n}\n\nconst TS = Date.now();\nconst WALLET_A = \"LeaderboardTestA_\" + TS;\nconst WALLET_B = \"LeaderboardTestB_\" + TS;\nconst WALLET_C = \"LeaderboardTestC_\" + TS;\nconst USER_A = \"usr_leada\" + TS;\nconst USER_B = \"usr_leadb\" + TS;\nconst USER_C = \"usr_leadc\" + TS;\n\ndescribe(\"Weekly leaderboard\", () => {\n  let rawSql: ReturnType<typeof postgres>;\n  let db: Db;\n  let app: Hono;\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n\n    // Ensure game_entries table exists (matches consolidated migration schema)\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS game_entries (\n        id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        user_id         TEXT         NOT NULL,\n        wallet          TEXT         NOT NULL,\n        game            TEXT         NOT NULL,\n        round_pda       TEXT         NOT NULL,\n        match_id        TEXT         NOT NULL,\n        amount_lamports BIGINT       NOT NULL,\n        side            TEXT,\n        is_winner       BOOLEAN,\n        payout_lamports BIGINT       NOT NULL DEFAULT 0,\n        created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n        settled_at      TIMESTAMPTZ,\n        UNIQUE (wallet, round_pda)\n      )\n    `;\n    // Ensure player_profiles exists (for JOIN)\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS player_profiles (\n        id                   BIGSERIAL    PRIMARY KEY,\n        user_id              TEXT         UNIQUE NOT NULL,\n        wallet               TEXT         UNIQUE NOT NULL,\n        username             TEXT         UNIQUE NOT NULL,\n        username_updated_at  TIMESTAMPTZ,\n        avatar_url           TEXT,\n        heat_multiplier      NUMERIC      NOT NULL DEFAULT 1.0,\n        points_balance       BIGINT       NOT NULL DEFAULT 0,\n        created_at           TIMESTAMPTZ  NOT NULL DEFAULT now()\n      )\n    `;\n    db = createDb(DATABASE_URL, rawSql);\n  });\n\n  afterAll(async () => {\n    await rawSql`DELETE FROM game_entries WHERE wallet LIKE 'LeaderboardTest%'`;\n    await rawSql`DELETE FROM player_profiles WHERE wallet LIKE 'LeaderboardTest%'`;\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`DELETE FROM game_entries WHERE wallet LIKE 'LeaderboardTest%'`;\n    await rawSql`DELETE FROM player_profiles WHERE wallet LIKE 'LeaderboardTest%'`;\n    app = new Hono();\n    app.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n    // Seed profiles for test wallets (leaderboard JOINs on user_id)\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username) VALUES\n        (${USER_A}, ${WALLET_A}, ${\"user_a_\" + TS}),\n        (${USER_B}, ${WALLET_B}, ${\"user_b_\" + TS}),\n        (${USER_C}, ${WALLET_C}, ${\"user_c_\" + TS})\n      ON CONFLICT DO NOTHING\n    `;\n  });\n\n  it(\"returns empty leaderboard when no entries\", async () => {\n    const result = await db.getWeeklyLeaderboard();\n    // May have entries from other tests but our users shouldn't be there\n    const ours = result.entries.filter((e) =>\n      e.userId.startsWith(\"usr_lead\"),\n    );\n    expect(ours.length).toBe(0);\n    expect(result.weekStart).toBeDefined();\n    expect(result.weekEnd).toBeDefined();\n  });\n\n  it(\"rejects legacy leaderboard game aliases at validation time\", async () => {\n    const res = await app.request(\"/leaderboard/weekly?game=flipyou\");\n\n    expect(res.status).toBe(422);\n    const body = (await res.json()) as {\n      ok: false;\n      error: { code: string; message: string };\n    };\n    expect(body.ok).toBe(false);\n    expect(body.error.code).toBe(\"VALIDATION_FAILED\");\n    expect(body.error.message).toBe(\"Invalid request\");\n  });\n\n  it(\"ranks players by total wagered volume\", async () => {\n    // Wallet A: 5 SOL wagered (2 games)\n    await db.insertGameEntries([\n      {\n        userId: USER_A,\n        wallet: WALLET_A,\n        game: \"flipyou\",\n        roundPda: \"pda_lb1\",\n        matchId: \"lb_m1\",\n        amountLamports: 3_000_000_000,\n        isWinner: true,\n        payoutLamports: 5_700_000_000,\n        settledAt: new Date(),\n      },\n      {\n        userId: USER_A,\n        wallet: WALLET_A,\n        game: \"flipyou\",\n        roundPda: \"pda_lb2\",\n        matchId: \"lb_m2\",\n        amountLamports: 2_000_000_000,\n        isWinner: false,\n        payoutLamports: 0,\n        settledAt: new Date(),\n      },\n    ]);\n\n    // Wallet B: 10 SOL wagered (1 game)\n    await db.insertGameEntries([\n      {\n        userId: USER_B,\n        wallet: WALLET_B,\n        game: \"potshot\",\n        roundPda: \"pda_lb3\",\n        matchId: \"lb_m3\",\n        amountLamports: 10_000_000_000,\n        isWinner: true,\n        payoutLamports: 18_000_000_000,\n        settledAt: new Date(),\n      },\n    ]);\n\n    // Wallet C: 1 SOL wagered (1 game)\n    await db.insertGameEntries([\n      {\n        userId: USER_C,\n        wallet: WALLET_C,\n        game: \"closecall\",\n        roundPda: \"pda_lb4\",\n        matchId: \"lb_m4\",\n        amountLamports: 1_000_000_000,\n        isWinner: false,\n        payoutLamports: 0,\n        settledAt: new Date(),\n      },\n    ]);\n\n    const result = await db.getWeeklyLeaderboard();\n    const ours = result.entries.filter((e) =>\n      e.userId.startsWith(\"usr_lead\"),\n    );\n\n    // B (10 SOL) > A (5 SOL) > C (1 SOL)\n    expect(ours.length).toBe(3);\n    expect(ours[0]!.userId).toBe(USER_B);\n    expect(ours[0]!.totalWagered).toBe(10_000_000_000n);\n    expect(ours[0]!.gamesPlayed).toBe(1);\n    expect(ours[0]!.totalWins).toBe(1);\n\n    expect(ours[1]!.userId).toBe(USER_A);\n    expect(ours[1]!.totalWagered).toBe(5_000_000_000n);\n    expect(ours[1]!.gamesPlayed).toBe(2);\n    expect(ours[1]!.totalWins).toBe(1);\n    expect(ours[1]!.winRate).toBeCloseTo(0.5);\n\n    expect(ours[2]!.userId).toBe(USER_C);\n    expect(ours[2]!.totalWagered).toBe(1_000_000_000n);\n    expect(ours[2]!.totalWins).toBe(0);\n  });\n\n  it(\"filters by game type\", async () => {\n    await db.insertGameEntries([\n      {\n        userId: USER_A,\n        wallet: WALLET_A,\n        game: \"flipyou\",\n        roundPda: \"pda_gf1\",\n        matchId: \"gf_m1\",\n        amountLamports: 5_000_000_000,\n        isWinner: true,\n        payoutLamports: 9_500_000_000,\n        settledAt: new Date(),\n      },\n      {\n        userId: USER_A,\n        wallet: WALLET_A,\n        game: \"potshot\",\n        roundPda: \"pda_gf2\",\n        matchId: \"gf_m2\",\n        amountLamports: 2_000_000_000,\n        isWinner: false,\n        payoutLamports: 0,\n        settledAt: new Date(),\n      },\n    ]);\n\n    // FlipYou only\n    const cfResult = await db.getWeeklyLeaderboard(\"flipyou\");\n    const cfOurs = cfResult.entries.filter((e) =>\n      e.userId.startsWith(\"usr_lead\"),\n    );\n    expect(cfOurs.length).toBe(1);\n    expect(cfOurs[0]!.totalWagered).toBe(5_000_000_000n);\n\n    // Lord only\n    const lordResult = await db.getWeeklyLeaderboard(\"potshot\");\n    const lordOurs = lordResult.entries.filter((e) =>\n      e.userId.startsWith(\"usr_lead\"),\n    );\n    expect(lordOurs.length).toBe(1);\n    expect(lordOurs[0]!.totalWagered).toBe(2_000_000_000n);\n\n    // Global (both games)\n    const allResult = await db.getWeeklyLeaderboard();\n    const allOurs = allResult.entries.filter((e) =>\n      e.userId.startsWith(\"usr_lead\"),\n    );\n    expect(allOurs.length).toBe(1);\n    expect(allOurs[0]!.totalWagered).toBe(7_000_000_000n);\n    expect(allOurs[0]!.gamesPlayed).toBe(2);\n  });\n\n  it(\"computes net PnL correctly\", async () => {\n    // Win 9.5 SOL on 5 SOL wager, lose 3 SOL → net = +1.5 SOL\n    await db.insertGameEntries([\n      {\n        userId: USER_A,\n        wallet: WALLET_A,\n        game: \"flipyou\",\n        roundPda: \"pda_pnl1\",\n        matchId: \"pnl_m1\",\n        amountLamports: 5_000_000_000,\n        isWinner: true,\n        payoutLamports: 9_500_000_000,\n        settledAt: new Date(),\n      },\n      {\n        userId: USER_A,\n        wallet: WALLET_A,\n        game: \"flipyou\",\n        roundPda: \"pda_pnl2\",\n        matchId: \"pnl_m2\",\n        amountLamports: 3_000_000_000,\n        isWinner: false,\n        payoutLamports: 0,\n        settledAt: new Date(),\n      },\n    ]);\n\n    const result = await db.getWeeklyLeaderboard();\n    const entry = result.entries.find((e) => e.userId === USER_A);\n    expect(entry).toBeDefined();\n    // netPnl = (9.5 + 0) - (5 + 3) = 1.5 SOL = 1_500_000_000 lamports\n    expect(entry!.netPnl).toBe(1_500_000_000n);\n  });\n\n  it(\"respects limit and offset\", async () => {\n    await db.insertGameEntries([\n      {\n        userId: USER_A,\n        wallet: WALLET_A,\n        game: \"flipyou\",\n        roundPda: \"pda_pg1\",\n        matchId: \"pg_m1\",\n        amountLamports: 3_000_000_000,\n        isWinner: false,\n        payoutLamports: 0,\n        settledAt: new Date(),\n      },\n      {\n        userId: USER_B,\n        wallet: WALLET_B,\n        game: \"flipyou\",\n        roundPda: \"pda_pg2\",\n        matchId: \"pg_m2\",\n        amountLamports: 5_000_000_000,\n        isWinner: true,\n        payoutLamports: 9_000_000_000,\n        settledAt: new Date(),\n      },\n      {\n        userId: USER_C,\n        wallet: WALLET_C,\n        game: \"flipyou\",\n        roundPda: \"pda_pg3\",\n        matchId: \"pg_m3\",\n        amountLamports: 1_000_000_000,\n        isWinner: false,\n        payoutLamports: 0,\n        settledAt: new Date(),\n      },\n    ]);\n\n    // Limit 2: should get B and A (top 2 by volume)\n    const page1 = await db.getWeeklyLeaderboard(undefined, 2);\n    const p1Ours = page1.entries.filter((e) =>\n      e.userId.startsWith(\"usr_lead\"),\n    );\n    expect(p1Ours.length).toBeLessThanOrEqual(2);\n  });\n\n  it(\"idempotent — duplicate insertGameEntries do not error\", async () => {\n    const entry = {\n      userId: USER_A,\n      wallet: WALLET_A,\n      game: \"flipyou\",\n      roundPda: \"pda_idem1\",\n      matchId: \"idem_m1\",\n      amountLamports: 1_000_000_000,\n      isWinner: true,\n      payoutLamports: 1_900_000_000,\n      settledAt: new Date(),\n    };\n\n    await db.insertGameEntries([entry]);\n    // Second insert should be silently ignored\n    await db.insertGameEntries([entry]);\n\n    const result = await db.getWeeklyLeaderboard();\n    const ours = result.entries.filter((e) => e.userId === USER_A);\n    expect(ours.length).toBe(1);\n    expect(ours[0]!.totalWagered).toBe(1_000_000_000n);\n  });\n\n  it(\"uses profile username when available\", async () => {\n    await rawSql`\n      UPDATE player_profiles SET username = ${\"CoolDegen42\"}\n      WHERE user_id = ${USER_A}\n    `;\n\n    await db.insertGameEntries([\n      {\n        userId: USER_A,\n        wallet: WALLET_A,\n        game: \"flipyou\",\n        roundPda: \"pda_usr1\",\n        matchId: \"usr_m1\",\n        amountLamports: 1_000_000_000,\n        isWinner: true,\n        payoutLamports: 1_900_000_000,\n        settledAt: new Date(),\n      },\n    ]);\n\n    const result = await db.getWeeklyLeaderboard();\n    const entry = result.entries.find((e) => e.userId === USER_A);\n    expect(entry).toBeDefined();\n    expect(entry!.username).toBe(\"CoolDegen42\");\n  });\n});\n","numLines":382,"startLine":1,"totalLines":382}}}
