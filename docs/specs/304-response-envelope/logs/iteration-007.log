{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Qfm1pBqaTKEr2Fqdp1QK6P","type":"tool_result","content":"1\t/**\n2\t * Auth routes: challenge/verify/refresh/logout for JWT session management.\n3\t *\n4\t * WAITLIST-CONTRACT: the waitlist (separate repo, launches first) calls every\n5\t * route in this file. Any change to request/response shape here must keep\n6\t * `waitlist/src/lib/auth-api.ts` in lockstep and is enforced by\n7\t * `__tests__/waitlist-contract.test.ts`. Ship a coordinated waitlist release\n8\t * before merging a breaking change.\n9\t */\n10\t\n11\timport { createRoute } from \"@hono/zod-openapi\";\n12\timport { z } from \"zod\";\n13\timport { randomBytes, createHash } from \"node:crypto\";\n14\timport nacl from \"tweetnacl\";\n15\timport bs58 from \"bs58\";\n16\timport { PublicKey } from \"@solana/web3.js\";\n17\timport { SignJWT } from \"jose\";\n18\timport type { AuthDb } from \"../auth-db.js\";\n19\timport type { Db } from \"../db.js\";\n20\timport { logger } from \"../logger.js\";\n21\timport {\n22\t  ChallengeNonceResponseSchema,\n23\t  TokenResponseSchema,\n24\t} from \"../contracts/validators.js\";\n25\timport {\n26\t  envelope,\n27\t  ErrorEnvelopeSchema,\n28\t  ok,\n29\t  err,\n30\t} from \"../contracts/api-envelope.js\";\n31\timport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n32\timport { createOpenApiApp } from \"../openapi/hono.js\";\n33\t\n34\texport interface AuthRoutesDeps {\n35\t  authDb: AuthDb;\n36\t  db: Db;\n37\t  jwtSecret: Uint8Array;\n38\t  cluster: string;\n39\t  challengeTtlSeconds: number;\n40\t  accessTokenTtlSeconds: number;\n41\t  refreshTokenTtlDays: number;\n42\t}\n43\t\n44\tfunction hashToken(token: string): Buffer {\n45\t  return createHash(\"sha256\").update(token).digest();\n46\t}\n47\t\n48\tfunction issueAccessToken(\n49\t  jwtSecret: Uint8Array,\n50\t  userId: string,\n51\t  now: number,\n52\t  accessTokenTtlSeconds: number,\n53\t): Promise<string> {\n54\t  return new SignJWT({})\n55\t    .setProtectedHeader({ alg: \"HS256\" })\n56\t    .setSubject(userId)\n57\t    .setIssuedAt(now)\n58\t    .setExpirationTime(now + accessTokenTtlSeconds)\n59\t    .sign(jwtSecret);\n60\t}\n61\t\n62\tfunction formatNetwork(cluster: string): string {\n63\t  const normalized = cluster.toLowerCase();\n64\t  if (normalized === \"devnet\") return \"Solana Devnet\";\n65\t  if (normalized === \"mainnet\" || normalized === \"mainnet-beta\") return \"Solana Mainnet\";\n66\t  return `Solana ${cluster}`;\n67\t}\n68\t\n69\tfunction buildSignInMessage(\n70\t  wallet: string,\n71\t  cluster: string,\n72\t  nonce: string,\n73\t  issuedAt: string,\n74\t): string {\n75\t  return [\n76\t    \"Sign this message to create your Taunt BET account.\",\n77\t    \"\",\n78\t    \"This only verifies ownership. No gas or funds are used.\",\n79\t    \"\",\n80\t    `Wallet: ${wallet}`,\n81\t    `Network: ${formatNetwork(cluster)}`,\n82\t    `Timestamp: ${issuedAt}`,\n83\t    `Nonce: ${nonce}`,\n84\t  ].join(\"\\n\");\n85\t}\n86\t\n87\t// ---------------------------------------------------------------------------\n88\t// Route definitions\n89\t// ---------------------------------------------------------------------------\n90\t\n91\tconst challengeRoute = createRoute({\n92\t  method: \"post\",\n93\t  path: \"/challenge\",\n94\t  tags: [\"Auth\"],\n95\t  summary: \"Request sign-in challenge\",\n96\t  request: {\n97\t    body: {\n98\t      required: true,\n99\t      content: {\n100\t        \"application/json\": {\n101\t          schema: z.object({\n102\t            wallet: z.string().min(1).describe(\"Base58 wallet address\"),\n103\t          }),\n104\t        },\n105\t      },\n106\t    },\n107\t  },\n108\t  responses: {\n109\t    200: {\n110\t      content: { \"application/json\": { schema: envelope(ChallengeNonceResponseSchema) } },\n111\t      description: \"Challenge issued\",\n112\t    },\n113\t    422: {\n114\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n115\t      description: \"Invalid request\",\n116\t    },\n117\t  },\n118\t});\n119\t\n120\tconst verifyRoute = createRoute({\n121\t  method: \"post\",\n122\t  path: \"/verify\",\n123\t  tags: [\"Auth\"],\n124\t  summary: \"Verify signature and issue tokens\",\n125\t  request: {\n126\t    body: {\n127\t      required: true,\n128\t      content: {\n129\t        \"application/json\": {\n130\t          schema: z.object({\n131\t            nonce: z.string(),\n132\t            wallet: z.string(),\n133\t            signature: z.string().describe(\"Base58-encoded Ed25519 signature\"),\n134\t          }),\n135\t        },\n136\t      },\n137\t    },\n138\t  },\n139\t  responses: {\n140\t    200: {\n141\t      content: { \"application/json\": { schema: envelope(TokenResponseSchema) } },\n142\t      description: \"Tokens issued\",\n143\t    },\n144\t    401: {\n145\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n146\t      description: \"Invalid signature or challenge\",\n147\t    },\n148\t    422: {\n149\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n150\t      description: \"Invalid request\",\n151\t    },\n152\t    500: {\n153\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n154\t      description: \"Server error\",\n155\t    },\n156\t  },\n157\t});\n158\t\n159\tconst refreshRoute = createRoute({\n160\t  method: \"post\",\n161\t  path: \"/refresh\",\n162\t  tags: [\"Auth\"],\n163\t  summary: \"Rotate refresh token and issue new access token\",\n164\t  request: {\n165\t    body: {\n166\t      required: true,\n167\t      content: {\n168\t        \"application/json\": {\n169\t          schema: z.object({\n170\t            refreshToken: z.string(),\n171\t          }),\n172\t        },\n173\t      },\n174\t    },\n175\t  },\n176\t  responses: {\n177\t    200: {\n178\t      content: { \"application/json\": { schema: envelope(TokenResponseSchema) } },\n179\t      description: \"New tokens issued\",\n180\t    },\n181\t    401: {\n182\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n183\t      description: \"Invalid or expired token\",\n184\t    },\n185\t    422: {\n186\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n187\t      description: \"Invalid request\",\n188\t    },\n189\t  },\n190\t});\n191\t\n192\tconst logoutRoute = createRoute({\n193\t  method: \"post\",\n194\t  path: \"/logout\",\n195\t  tags: [\"Auth\"],\n196\t  summary: \"Revoke refresh token\",\n197\t  request: {\n198\t    body: {\n199\t      content: {\n200\t        \"application/json\": {\n201\t          schema: z.object({\n202\t            refreshToken: z.string().optional(),\n203\t          }),\n204\t        },\n205\t      },\n206\t    },\n207\t  },\n208\t  responses: {\n209\t    204: {\n210\t      description: \"Logged out\",\n211\t    },\n212\t  },\n213\t});\n214\t\n215\t// ---------------------------------------------------------------------------\n216\t// Route factory\n217\t// ---------------------------------------------------------------------------\n218\t\n219\texport function createAuthRoutes(deps: AuthRoutesDeps) {\n220\t  const {\n221\t    authDb,\n222\t    db,\n223\t    jwtSecret,\n224\t    cluster,\n225\t    challengeTtlSeconds,\n226\t    accessTokenTtlSeconds,\n227\t    refreshTokenTtlDays,\n228\t  } = deps;\n229\t\n230\t  const app = createOpenApiApp();\n231\t\n232\t  // POST /challenge — generate nonce + human-readable message\n233\t  app.openapi(challengeRoute, async (c) => {\n234\t    const { wallet } = c.req.valid(\"json\");\n235\t\n236\t    const nonce = randomBytes(32).toString(\"hex\");\n237\t    const now = new Date();\n238\t    const expiresAt = new Date(now.getTime() + challengeTtlSeconds * 1000);\n239\t\n240\t    const message = buildSignInMessage(\n241\t      wallet,\n242\t      cluster,\n243\t      nonce,\n244\t      now.toISOString(),\n245\t    );\n246\t\n247\t    await authDb.insertChallenge(nonce, wallet, cluster, message, expiresAt);\n248\t\n249\t    logger.info(\"auth challenge issued\", { wallet, nonce });\n250\t\n251\t    return ok(c, {\n252\t      nonce,\n253\t      message,\n254\t      expiresAt: expiresAt.toISOString(),\n255\t    });\n256\t  });\n257\t\n258\t  // POST /verify — consume challenge, verify signature, issue tokens\n259\t  app.openapi(verifyRoute, async (c) => {\n260\t    const { nonce, wallet, signature } = c.req.valid(\"json\");\n261\t\n262\t    // Atomically consume the challenge\n263\t    const challenge = await authDb.consumeChallenge(nonce);\n264\t    if (!challenge) {\n265\t      logger.warn(\"auth verify rejected: challenge not found or expired\", {\n266\t        nonce,\n267\t        wallet,\n268\t      });\n269\t      return err(\n270\t        c,\n271\t        401,\n272\t        API_ERROR_CODES.CHALLENGE_EXPIRED,\n273\t        \"Challenge not found, expired, or already used\",\n274\t      );\n275\t    }\n276\t\n277\t    // Verify wallet matches challenge\n278\t    if (challenge.wallet !== wallet) {\n279\t      logger.warn(\"auth verify rejected: wallet mismatch\", {\n280\t        nonce,\n281\t        challengeWallet: challenge.wallet,\n282\t        requestWallet: wallet,\n283\t      });\n284\t      return err(\n285\t        c,\n286\t        401,\n287\t        API_ERROR_CODES.INVALID_SIGNATURE,\n288\t        \"Wallet does not match challenge\",\n289\t      );\n290\t    }\n291\t\n292\t    // Verify Ed25519 signature over the challenge message.\n293\t    // PublicKey validates base58 + 32-byte length + on-curve; signature only\n294\t    // needs base58 decode (raw 64-byte ed25519 sig, not a pubkey).\n295\t    let sigBytes: Uint8Array;\n296\t    let pubkeyBytes: Uint8Array;\n297\t    try {\n298\t      sigBytes = bs58.decode(signature);\n299\t      pubkeyBytes = new PublicKey(wallet).toBytes();\n300\t    } catch {\n301\t      return err(\n302\t        c,\n303\t        401,\n304\t        API_ERROR_CODES.INVALID_SIGNATURE,\n305\t        \"Invalid signature or wallet encoding\",\n306\t      );\n307\t    }\n308\t\n309\t    if (sigBytes.length !== 64) {\n310\t      return err(\n311\t        c,\n312\t        401,\n313\t        API_ERROR_CODES.INVALID_SIGNATURE,\n314\t        \"Invalid signature length\",\n315\t      );\n316\t    }\n317\t\n318\t    const messageBytes = new TextEncoder().encode(challenge.message);\n319\t    const valid = nacl.sign.detached.verify(messageBytes, sigBytes, pubkeyBytes);\n320\t    if (!valid) {\n321\t      logger.warn(\"auth verify rejected: signature verification failed\", {\n322\t        wallet,\n323\t      });\n324\t      return err(\n325\t        c,\n326\t        401,\n327\t        API_ERROR_CODES.INVALID_SIGNATURE,\n328\t        \"Invalid signature\",\n329\t      );\n330\t    }\n331\t\n332\t    let profile;\n333\t    try {\n334\t      profile = await db.getProfileByWallet(wallet);\n335\t      if (!profile) {\n336\t        profile = await db.createPlayerProfile(wallet);\n337\t        logger.info(\"player profile auto-created\", { wallet, userId: profile.user_id });\n338\t      }\n339\t    } catch (e) {\n340\t      logger.error(\"profile creation failed\", { wallet, error: e });\n341\t      return err(\n342\t        c,\n343\t        500,\n344\t        API_ERROR_CODES.PRECONDITION_FAILED,\n345\t        \"Failed to establish player profile\",\n346\t      );\n347\t    }\n348\t\n349\t    // Issue JWT access token\n350\t    const now = Math.floor(Date.now() / 1000);\n351\t    const accessToken = await issueAccessToken(\n352\t      jwtSecret,\n353\t      profile.user_id,\n354\t      now,\n355\t      accessTokenTtlSeconds,\n356\t    );\n357\t\n358\t    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n359\t\n360\t    // Generate opaque refresh token\n361\t    const refreshTokenRaw = randomBytes(48).toString(\"hex\");\n362\t    const refreshTokenHash = hashToken(refreshTokenRaw);\n363\t    const familyId = randomBytes(16).toString(\"hex\");\n364\t    const refreshExpiresAt = new Date(\n365\t      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n366\t    );\n367\t\n368\t    await authDb.insertRefreshToken(\n369\t      profile.user_id,\n370\t      wallet,\n371\t      refreshTokenHash,\n372\t      familyId,\n373\t      refreshExpiresAt,\n374\t    );\n375\t\n376\t    logger.info(\"auth session created\", { wallet, userId: profile.user_id });\n377\t\n378\t    return ok(c, {\n379\t      accessToken,\n380\t      accessExpiresAt,\n381\t      refreshToken: refreshTokenRaw,\n382\t      refreshExpiresAt: refreshExpiresAt.toISOString(),\n383\t    });\n384\t  });\n385\t\n386\t  // POST /refresh — rotate refresh token, issue new access token\n387\t  app.openapi(refreshRoute, async (c) => {\n388\t    const { refreshToken } = c.req.valid(\"json\");\n389\t\n390\t    const tokenHash = hashToken(refreshToken);\n391\t    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n392\t\n393\t    if (!stored) {\n394\t      logger.warn(\"auth refresh rejected: token not found\");\n395\t      return err(\n396\t        c,\n397\t        401,\n398\t        API_ERROR_CODES.REFRESH_TOKEN_INVALID,\n399\t        \"Invalid refresh token\",\n400\t      );\n401\t    }\n402\t\n403\t    // Reuse detection: if the token was already revoked, someone replayed it.\n404\t    // Revoke the entire family as a precaution.\n405\t    if (stored.revoked) {\n406\t      logger.warn(\"auth refresh rejected: token reuse detected, revoking family\", {\n407\t        userId: stored.user_id,\n408\t        wallet: stored.wallet,\n409\t        familyId: stored.family_id,\n410\t      });\n411\t      await authDb.revokeTokenFamily(stored.family_id);\n412\t      return err(\n413\t        c,\n414\t        401,\n415\t        API_ERROR_CODES.REFRESH_TOKEN_INVALID,\n416\t        \"Token reuse detected. Please sign in again.\",\n417\t      );\n418\t    }\n419\t\n420\t    // Check expiry\n421\t    if (new Date() > stored.expires_at) {\n422\t      logger.warn(\"auth refresh rejected: token expired\", {\n423\t        userId: stored.user_id,\n424\t        wallet: stored.wallet,\n425\t      });\n426\t      await authDb.revokeRefreshToken(stored.id);\n427\t      return err(\n428\t        c,\n429\t        401,\n430\t        API_ERROR_CODES.REFRESH_TOKEN_INVALID,\n431\t        \"Refresh token expired\",\n432\t      );\n433\t    }\n434\t\n435\t    // Revoke old token\n436\t    await authDb.revokeRefreshToken(stored.id);\n437\t\n438\t    // Issue new access token\n439\t    const now = Math.floor(Date.now() / 1000);\n440\t    const accessToken = await issueAccessToken(\n441\t      jwtSecret,\n442\t      stored.user_id,\n443\t      now,\n444\t      accessTokenTtlSeconds,\n445\t    );\n446\t\n447\t    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n448\t\n449\t    // Issue new refresh token in the same family\n450\t    const newRefreshRaw = randomBytes(48).toString(\"hex\");\n451\t    const newRefreshHash = hashToken(newRefreshRaw);\n452\t    const newRefreshExpiresAt = new Date(\n453\t      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n454\t    );\n455\t\n456\t    await authDb.insertRefreshToken(\n457\t      stored.user_id,\n458\t      stored.wallet,\n459\t      newRefreshHash,\n460\t      stored.family_id,\n461\t      newRefreshExpiresAt,\n462\t    );\n463\t\n464\t    logger.debug(\"auth token refreshed\", { userId: stored.user_id, wallet: stored.wallet });\n465\t\n466\t    return ok(c, {\n467\t      accessToken,\n468\t      accessExpiresAt,\n469\t      refreshToken: newRefreshRaw,\n470\t      refreshExpiresAt: newRefreshExpiresAt.toISOString(),\n471\t    });\n472\t  });\n473\t\n474\t  // POST /logout — revoke refresh token\n475\t  app.openapi(logoutRoute, async (c) => {\n476\t    const body = c.req.valid(\"json\");\n477\t\n478\t    if (!body.refreshToken) {\n479\t      return c.body(null, 204);\n480\t    }\n481\t\n482\t    const tokenHash = hashToken(body.refreshToken);\n483\t    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n484\t    if (stored) {\n485\t      await authDb.revokeRefreshToken(stored.id);\n486\t      logger.info(\"auth logout\", { userId: stored.user_id, wallet: stored.wallet });\n487\t    }\n488\t\n489\t    return c.body(null, 204);\n490\t  });\n491\t\n492\t  return app;\n493\t}\n494\t"}]},"parent_tool_use_id":null,"session_id":"eb7d01f2-3773-44f3-9eed-fc96d23e7071","uuid":"539434a6-11c1-4feb-80b6-2e749a0299f0","timestamp":"2026-04-22T09:48:22.397Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/auth.ts","content":"/**\n * Auth routes: challenge/verify/refresh/logout for JWT session management.\n *\n * WAITLIST-CONTRACT: the waitlist (separate repo, launches first) calls every\n * route in this file. Any change to request/response shape here must keep\n * `waitlist/src/lib/auth-api.ts` in lockstep and is enforced by\n * `__tests__/waitlist-contract.test.ts`. Ship a coordinated waitlist release\n * before merging a breaking change.\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport { randomBytes, createHash } from \"node:crypto\";\nimport nacl from \"tweetnacl\";\nimport bs58 from \"bs58\";\nimport { PublicKey } from \"@solana/web3.js\";\nimport { SignJWT } from \"jose\";\nimport type { AuthDb } from \"../auth-db.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport {\n  ChallengeNonceResponseSchema,\n  TokenResponseSchema,\n} from \"../contracts/validators.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface AuthRoutesDeps {\n  authDb: AuthDb;\n  db: Db;\n  jwtSecret: Uint8Array;\n  cluster: string;\n  challengeTtlSeconds: number;\n  accessTokenTtlSeconds: number;\n  refreshTokenTtlDays: number;\n}\n\nfunction hashToken(token: string): Buffer {\n  return createHash(\"sha256\").update(token).digest();\n}\n\nfunction issueAccessToken(\n  jwtSecret: Uint8Array,\n  userId: string,\n  now: number,\n  accessTokenTtlSeconds: number,\n): Promise<string> {\n  return new SignJWT({})\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userId)\n    .setIssuedAt(now)\n    .setExpirationTime(now + accessTokenTtlSeconds)\n    .sign(jwtSecret);\n}\n\nfunction formatNetwork(cluster: string): string {\n  const normalized = cluster.toLowerCase();\n  if (normalized === \"devnet\") return \"Solana Devnet\";\n  if (normalized === \"mainnet\" || normalized === \"mainnet-beta\") return \"Solana Mainnet\";\n  return `Solana ${cluster}`;\n}\n\nfunction buildSignInMessage(\n  wallet: string,\n  cluster: string,\n  nonce: string,\n  issuedAt: string,\n): string {\n  return [\n    \"Sign this message to create your Taunt BET account.\",\n    \"\",\n    \"This only verifies ownership. No gas or funds are used.\",\n    \"\",\n    `Wallet: ${wallet}`,\n    `Network: ${formatNetwork(cluster)}`,\n    `Timestamp: ${issuedAt}`,\n    `Nonce: ${nonce}`,\n  ].join(\"\\n\");\n}\n\n// ---------------------------------------------------------------------------\n// Route definitions\n// ---------------------------------------------------------------------------\n\nconst challengeRoute = createRoute({\n  method: \"post\",\n  path: \"/challenge\",\n  tags: [\"Auth\"],\n  summary: \"Request sign-in challenge\",\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": {\n          schema: z.object({\n            wallet: z.string().min(1).describe(\"Base58 wallet address\"),\n          }),\n        },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(ChallengeNonceResponseSchema) } },\n      description: \"Challenge issued\",\n    },\n    422: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid request\",\n    },\n  },\n});\n\nconst verifyRoute = createRoute({\n  method: \"post\",\n  path: \"/verify\",\n  tags: [\"Auth\"],\n  summary: \"Verify signature and issue tokens\",\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": {\n          schema: z.object({\n            nonce: z.string(),\n            wallet: z.string(),\n            signature: z.string().describe(\"Base58-encoded Ed25519 signature\"),\n          }),\n        },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(TokenResponseSchema) } },\n      description: \"Tokens issued\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid signature or challenge\",\n    },\n    422: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid request\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\nconst refreshRoute = createRoute({\n  method: \"post\",\n  path: \"/refresh\",\n  tags: [\"Auth\"],\n  summary: \"Rotate refresh token and issue new access token\",\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": {\n          schema: z.object({\n            refreshToken: z.string(),\n          }),\n        },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(TokenResponseSchema) } },\n      description: \"New tokens issued\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid or expired token\",\n    },\n    422: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid request\",\n    },\n  },\n});\n\nconst logoutRoute = createRoute({\n  method: \"post\",\n  path: \"/logout\",\n  tags: [\"Auth\"],\n  summary: \"Revoke refresh token\",\n  request: {\n    body: {\n      content: {\n        \"application/json\": {\n          schema: z.object({\n            refreshToken: z.string().optional(),\n          }),\n        },\n      },\n    },\n  },\n  responses: {\n    204: {\n      description: \"Logged out\",\n    },\n  },\n});\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport function createAuthRoutes(deps: AuthRoutesDeps) {\n  const {\n    authDb,\n    db,\n    jwtSecret,\n    cluster,\n    challengeTtlSeconds,\n    accessTokenTtlSeconds,\n    refreshTokenTtlDays,\n  } = deps;\n\n  const app = createOpenApiApp();\n\n  // POST /challenge — generate nonce + human-readable message\n  app.openapi(challengeRoute, async (c) => {\n    const { wallet } = c.req.valid(\"json\");\n\n    const nonce = randomBytes(32).toString(\"hex\");\n    const now = new Date();\n    const expiresAt = new Date(now.getTime() + challengeTtlSeconds * 1000);\n\n    const message = buildSignInMessage(\n      wallet,\n      cluster,\n      nonce,\n      now.toISOString(),\n    );\n\n    await authDb.insertChallenge(nonce, wallet, cluster, message, expiresAt);\n\n    logger.info(\"auth challenge issued\", { wallet, nonce });\n\n    return ok(c, {\n      nonce,\n      message,\n      expiresAt: expiresAt.toISOString(),\n    });\n  });\n\n  // POST /verify — consume challenge, verify signature, issue tokens\n  app.openapi(verifyRoute, async (c) => {\n    const { nonce, wallet, signature } = c.req.valid(\"json\");\n\n    // Atomically consume the challenge\n    const challenge = await authDb.consumeChallenge(nonce);\n    if (!challenge) {\n      logger.warn(\"auth verify rejected: challenge not found or expired\", {\n        nonce,\n        wallet,\n      });\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.CHALLENGE_EXPIRED,\n        \"Challenge not found, expired, or already used\",\n      );\n    }\n\n    // Verify wallet matches challenge\n    if (challenge.wallet !== wallet) {\n      logger.warn(\"auth verify rejected: wallet mismatch\", {\n        nonce,\n        challengeWallet: challenge.wallet,\n        requestWallet: wallet,\n      });\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.INVALID_SIGNATURE,\n        \"Wallet does not match challenge\",\n      );\n    }\n\n    // Verify Ed25519 signature over the challenge message.\n    // PublicKey validates base58 + 32-byte length + on-curve; signature only\n    // needs base58 decode (raw 64-byte ed25519 sig, not a pubkey).\n    let sigBytes: Uint8Array;\n    let pubkeyBytes: Uint8Array;\n    try {\n      sigBytes = bs58.decode(signature);\n      pubkeyBytes = new PublicKey(wallet).toBytes();\n    } catch {\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.INVALID_SIGNATURE,\n        \"Invalid signature or wallet encoding\",\n      );\n    }\n\n    if (sigBytes.length !== 64) {\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.INVALID_SIGNATURE,\n        \"Invalid signature length\",\n      );\n    }\n\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const valid = nacl.sign.detached.verify(messageBytes, sigBytes, pubkeyBytes);\n    if (!valid) {\n      logger.warn(\"auth verify rejected: signature verification failed\", {\n        wallet,\n      });\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.INVALID_SIGNATURE,\n        \"Invalid signature\",\n      );\n    }\n\n    let profile;\n    try {\n      profile = await db.getProfileByWallet(wallet);\n      if (!profile) {\n        profile = await db.createPlayerProfile(wallet);\n        logger.info(\"player profile auto-created\", { wallet, userId: profile.user_id });\n      }\n    } catch (e) {\n      logger.error(\"profile creation failed\", { wallet, error: e });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to establish player profile\",\n      );\n    }\n\n    // Issue JWT access token\n    const now = Math.floor(Date.now() / 1000);\n    const accessToken = await issueAccessToken(\n      jwtSecret,\n      profile.user_id,\n      now,\n      accessTokenTtlSeconds,\n    );\n\n    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n\n    // Generate opaque refresh token\n    const refreshTokenRaw = randomBytes(48).toString(\"hex\");\n    const refreshTokenHash = hashToken(refreshTokenRaw);\n    const familyId = randomBytes(16).toString(\"hex\");\n    const refreshExpiresAt = new Date(\n      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n    );\n\n    await authDb.insertRefreshToken(\n      profile.user_id,\n      wallet,\n      refreshTokenHash,\n      familyId,\n      refreshExpiresAt,\n    );\n\n    logger.info(\"auth session created\", { wallet, userId: profile.user_id });\n\n    return ok(c, {\n      accessToken,\n      accessExpiresAt,\n      refreshToken: refreshTokenRaw,\n      refreshExpiresAt: refreshExpiresAt.toISOString(),\n    });\n  });\n\n  // POST /refresh — rotate refresh token, issue new access token\n  app.openapi(refreshRoute, async (c) => {\n    const { refreshToken } = c.req.valid(\"json\");\n\n    const tokenHash = hashToken(refreshToken);\n    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n\n    if (!stored) {\n      logger.warn(\"auth refresh rejected: token not found\");\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.REFRESH_TOKEN_INVALID,\n        \"Invalid refresh token\",\n      );\n    }\n\n    // Reuse detection: if the token was already revoked, someone replayed it.\n    // Revoke the entire family as a precaution.\n    if (stored.revoked) {\n      logger.warn(\"auth refresh rejected: token reuse detected, revoking family\", {\n        userId: stored.user_id,\n        wallet: stored.wallet,\n        familyId: stored.family_id,\n      });\n      await authDb.revokeTokenFamily(stored.family_id);\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.REFRESH_TOKEN_INVALID,\n        \"Token reuse detected. Please sign in again.\",\n      );\n    }\n\n    // Check expiry\n    if (new Date() > stored.expires_at) {\n      logger.warn(\"auth refresh rejected: token expired\", {\n        userId: stored.user_id,\n        wallet: stored.wallet,\n      });\n      await authDb.revokeRefreshToken(stored.id);\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.REFRESH_TOKEN_INVALID,\n        \"Refresh token expired\",\n      );\n    }\n\n    // Revoke old token\n    await authDb.revokeRefreshToken(stored.id);\n\n    // Issue new access token\n    const now = Math.floor(Date.now() / 1000);\n    const accessToken = await issueAccessToken(\n      jwtSecret,\n      stored.user_id,\n      now,\n      accessTokenTtlSeconds,\n    );\n\n    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n\n    // Issue new refresh token in the same family\n    const newRefreshRaw = randomBytes(48).toString(\"hex\");\n    const newRefreshHash = hashToken(newRefreshRaw);\n    const newRefreshExpiresAt = new Date(\n      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n    );\n\n    await authDb.insertRefreshToken(\n      stored.user_id,\n      stored.wallet,\n      newRefreshHash,\n      stored.family_id,\n      newRefreshExpiresAt,\n    );\n\n    logger.debug(\"auth token refreshed\", { userId: stored.user_id, wallet: stored.wallet });\n\n    return ok(c, {\n      accessToken,\n      accessExpiresAt,\n      refreshToken: newRefreshRaw,\n      refreshExpiresAt: newRefreshExpiresAt.toISOString(),\n    });\n  });\n\n  // POST /logout — revoke refresh token\n  app.openapi(logoutRoute, async (c) => {\n    const body = c.req.valid(\"json\");\n\n    if (!body.refreshToken) {\n      return c.body(null, 204);\n    }\n\n    const tokenHash = hashToken(body.refreshToken);\n    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n    if (stored) {\n      await authDb.revokeRefreshToken(stored.id);\n      logger.info(\"auth logout\", { userId: stored.user_id, wallet: stored.wallet });\n    }\n\n    return c.body(null, 204);\n  });\n\n  return app;\n}\n","numLines":494,"startLine":1,"totalLines":494}}}
