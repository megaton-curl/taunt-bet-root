{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WhfMb8XDRm26TJDMThuuiW","type":"tool_result","content":"1\t/**\n2\t * Referral routes — code management, linking, stats, earnings, and claims.\n3\t *\n4\t * WAITLIST-CONTRACT: the waitlist calls POST/GET /code, POST /apply,\n5\t * GET /referrer, GET /stats, GET /referrals. /earnings and /claim are NOT\n6\t * consumed by waitlist. Request/response shape for the consumed set is\n7\t * pinned in `__tests__/waitlist-contract.test.ts`; keep\n8\t * `waitlist/src/lib/referral-api.ts` in lockstep.\n9\t */\n10\t\n11\timport { createRoute, z } from \"@hono/zod-openapi\";\n12\timport type postgres from \"postgres\";\n13\timport type { AppEnv } from \"../hono-env.js\";\n14\timport type { Db } from \"../db.js\";\n15\timport type { Config } from \"../config.js\";\n16\timport { errorMessage, structuredErrorMessage } from \"../contracts/api-errors.js\";\n17\timport {\n18\t  ApplyReferralCodeBodySchema,\n19\t  ClaimResponseSchema,\n20\t  CodeResponseSchema,\n21\t  ErrorResponseSchema,\n22\t  MaybeCodeResponseSchema,\n23\t  ReferralApplyResponseSchema,\n24\t  ReferralCodeBodySchema,\n25\t  ReferralListResponseSchema,\n26\t  ReferralReferrerResponseSchema,\n27\t  ReferralStatsSchema,\n28\t  StructuredErrorResponseSchema,\n29\t} from \"../contracts/validators.js\";\n30\timport { logger } from \"../logger.js\";\n31\timport { emitEvent } from \"../queue/emit-event.js\";\n32\timport { EventTypes } from \"../queue/event-types.js\";\n33\timport { createOpenApiApp } from \"../openapi/hono.js\";\n34\t\n35\texport interface ReferralRoutesDeps {\n36\t  db: Db;\n37\t  sql: postgres.Sql;\n38\t  config: Config;\n39\t}\n40\t\n41\texport function createReferralRoutes(deps: ReferralRoutesDeps) {\n42\t  const { db, sql, config } = deps;\n43\t  const app = createOpenApiApp<AppEnv>();\n44\t\n45\t  // ── POST /code — set the player's referral code (permanent) ────────────\n46\t\n47\t  const setCodeRoute = createRoute({\n48\t    method: \"post\",\n49\t    path: \"/code\",\n50\t    tags: [\"Referral\"],\n51\t    summary: \"Set referral code (permanent)\",\n52\t    security: [{ bearerAuth: [] }],\n53\t    request: {\n54\t      body: {\n55\t        required: true,\n56\t        content: { \"application/json\": { schema: ReferralCodeBodySchema } },\n57\t      },\n58\t    },\n59\t    responses: {\n60\t      200: {\n61\t        content: { \"application/json\": { schema: CodeResponseSchema } },\n62\t        description: \"Code set\",\n63\t      },\n64\t      400: {\n65\t        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n66\t        description: \"Invalid request body or code format\",\n67\t      },\n68\t      401: {\n69\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n70\t        description: \"Authentication required\",\n71\t      },\n72\t      404: {\n73\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n74\t        description: \"Profile not found\",\n75\t      },\n76\t      409: {\n77\t        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n78\t        description: \"Code already set or taken\",\n79\t      },\n80\t      500: {\n81\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n82\t        description: \"Failed to set referral code\",\n83\t      },\n84\t    },\n85\t  });\n86\t\n87\t  app.openapi(setCodeRoute, async (c) => {\n88\t    const userId = c.get(\"userId\");\n89\t    if (!userId) {\n90\t      return c.json(errorMessage(\"Authentication required\"), 401);\n91\t    }\n92\t    const profile = await db.getProfileByUserId(userId);\n93\t    if (!profile) {\n94\t      return c.json(errorMessage(\"Profile not found\"), 404);\n95\t    }\n96\t    const wallet = profile.wallet;\n97\t\n98\t    const { code } = c.req.valid(\"json\");\n99\t\n100\t    // Check if the user already has a code — codes are permanent\n101\t    const ownCode = await db.getReferralCodeByUserId(userId);\n102\t    if (ownCode) {\n103\t      return c.json(\n104\t        structuredErrorMessage(\n105\t          \"CODE_ALREADY_SET\",\n106\t          \"You already have a referral code. Codes cannot be changed.\",\n107\t          false,\n108\t        ),\n109\t        409,\n110\t      );\n111\t    }\n112\t\n113\t    // Check if this code is already taken by another user\n114\t    const existing = await db.getReferralCodeByCode(code);\n115\t    if (existing && existing.user_id !== userId) {\n116\t      return c.json(\n117\t        structuredErrorMessage(\"CODE_TAKEN\", \"This referral code is already in use\", false),\n118\t        409,\n119\t      );\n120\t    }\n121\t\n122\t    try {\n123\t      const result = await db.insertReferralCode(userId, wallet, code);\n124\t      logger.info(\"Referral code set\", { userId, wallet, code: result.code });\n125\t      return c.json({ code: result.code }, 200);\n126\t    } catch (err) {\n127\t      // Handle race condition: another wallet grabbed the code between check and insert\n128\t      const msg = err instanceof Error ? err.message : String(err);\n129\t      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n130\t        return c.json(\n131\t          structuredErrorMessage(\"CODE_TAKEN\", \"This referral code is already in use\", false),\n132\t          409,\n133\t        );\n134\t      }\n135\t      logger.error(\"Failed to set referral code\", {\n136\t        err: String(err),\n137\t        userId,\n138\t        wallet,\n139\t      });\n140\t      return c.json(errorMessage(\"Failed to set referral code\"), 500);\n141\t    }\n142\t  }, (result, c) => {\n143\t    if (result.success) return;\n144\t    return c.json(\n145\t      structuredErrorMessage(\n146\t        \"INVALID_CODE\",\n147\t        \"Referral code must be 3-16 lowercase letters, numbers, or hyphens.\",\n148\t        false,\n149\t      ),\n150\t      400,\n151\t    );\n152\t  });\n153\t\n154\t  // ── POST /apply — link the authenticated player to a referrer ──────────\n155\t\n156\t  const applyRoute = createRoute({\n157\t    method: \"post\",\n158\t    path: \"/apply\",\n159\t    tags: [\"Referral\"],\n160\t    summary: \"Apply a referral code (link to referrer)\",\n161\t    security: [{ bearerAuth: [] }],\n162\t    request: {\n163\t      body: {\n164\t        required: true,\n165\t        content: { \"application/json\": { schema: ApplyReferralCodeBodySchema } },\n166\t      },\n167\t    },\n168\t    responses: {\n169\t      200: {\n170\t        content: { \"application/json\": { schema: ReferralApplyResponseSchema } },\n171\t        description: \"Linked to referrer\",\n172\t      },\n173\t      400: {\n174\t        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n175\t        description: \"Invalid request body, empty code, or self-referral\",\n176\t      },\n177\t      401: {\n178\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n179\t        description: \"Authentication required\",\n180\t      },\n181\t      404: {\n182\t        content: {\n183\t          \"application/json\": {\n184\t            schema: z.union([ErrorResponseSchema, StructuredErrorResponseSchema]),\n185\t          },\n186\t        },\n187\t        description: \"Profile or code not found\",\n188\t      },\n189\t      409: {\n190\t        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n191\t        description: \"Already linked to a referrer\",\n192\t      },\n193\t      500: {\n194\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n195\t        description: \"Failed to apply referral code\",\n196\t      },\n197\t    },\n198\t  });\n199\t\n200\t  app.openapi(applyRoute, async (c) => {\n201\t    const userId = c.get(\"userId\");\n202\t    if (!userId) {\n203\t      return c.json(errorMessage(\"Authentication required\"), 401);\n204\t    }\n205\t    const profile = await db.getProfileByUserId(userId);\n206\t    if (!profile) {\n207\t      return c.json(errorMessage(\"Profile not found\"), 404);\n208\t    }\n209\t    const wallet = profile.wallet;\n210\t\n211\t    const { code } = c.req.valid(\"json\");\n212\t\n213\t    // Look up the referral code to find the referrer\n214\t    const codeRow = await db.getReferralCodeByCode(code);\n215\t    if (!codeRow) {\n216\t      return c.json(\n217\t        structuredErrorMessage(\"CODE_NOT_FOUND\", \"Referral code does not exist\", false),\n218\t        404,\n219\t      );\n220\t    }\n221\t\n222\t    // Self-referral check\n223\t    if (codeRow.user_id === userId) {\n224\t      return c.json(\n225\t        structuredErrorMessage(\"SELF_REFERRAL\", \"You cannot use your own referral code\", false),\n226\t        400,\n227\t      );\n228\t    }\n229\t\n230\t    // Check if the player already has a referrer\n231\t    const existingLink = await db.getReferralLinkByRefereeUserId(userId);\n232\t    if (existingLink) {\n233\t      return c.json(\n234\t        structuredErrorMessage(\n235\t          \"ALREADY_LINKED\",\n236\t          \"You are already linked to a referrer\",\n237\t          false,\n238\t        ),\n239\t        409,\n240\t      );\n241\t    }\n242\t\n243\t    try {\n244\t      await db.insertReferralLink({\n245\t        referrerUserId: codeRow.user_id,\n246\t        refereeUserId: userId,\n247\t        referrerWallet: codeRow.wallet,\n248\t        refereeWallet: wallet,\n249\t      });\n250\t      logger.info(\"Referral link created\", {\n251\t        referrerUserId: codeRow.user_id,\n252\t        refereeUserId: userId,\n253\t        code,\n254\t      });\n255\t      return c.json(\n256\t        {\n257\t          referrerUserId: codeRow.user_id,\n258\t          benefit: \"10% fee rebate on all games\",\n259\t        },\n260\t        200,\n261\t      );\n262\t    } catch (err) {\n263\t      // Handle race condition: another request linked this referee between check and insert\n264\t      const msg = err instanceof Error ? err.message : String(err);\n265\t      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n266\t        return c.json(\n267\t          structuredErrorMessage(\n268\t            \"ALREADY_LINKED\",\n269\t            \"You are already linked to a referrer\",\n270\t            false,\n271\t          ),\n272\t          409,\n273\t        );\n274\t      }\n275\t      logger.error(\"Failed to create referral link\", {\n276\t        err: String(err),\n277\t        userId,\n278\t        wallet,\n279\t        code,\n280\t      });\n281\t      return c.json(errorMessage(\"Failed to apply referral code\"), 500);\n282\t    }\n283\t  }, (result, c) => {\n284\t    if (result.success) return;\n285\t    return c.json(\n286\t      structuredErrorMessage(\n287\t        \"INVALID_CODE\",\n288\t        \"Referral code must be 3-16 lowercase letters, numbers, or hyphens.\",\n289\t        false,\n290\t      ),\n291\t      400,\n292\t    );\n293\t  });\n294\t\n295\t  // ── GET /code — return the authenticated player's current referral code ─\n296\t\n297\t  const getCodeRoute = createRoute({\n298\t    method: \"get\",\n299\t    path: \"/code\",\n300\t    tags: [\"Referral\"],\n301\t    summary: \"Get own referral code\",\n302\t    security: [{ bearerAuth: [] }],\n303\t    responses: {\n304\t      200: {\n305\t        content: { \"application/json\": { schema: MaybeCodeResponseSchema } },\n306\t        description: \"Code (null if not set)\",\n307\t      },\n308\t      401: {\n309\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n310\t        description: \"Authentication required\",\n311\t      },\n312\t    },\n313\t  });\n314\t\n315\t  app.openapi(getCodeRoute, async (c) => {\n316\t    const userId = c.get(\"userId\");\n317\t    if (!userId) return c.json(errorMessage(\"Authentication required\"), 401);\n318\t\n319\t    const row = await db.getReferralCodeByUserId(userId);\n320\t    return c.json({ code: row?.code ?? null }, 200);\n321\t  });\n322\t\n323\t  // ── GET /referrer — check if the authenticated player has a referrer ────\n324\t\n325\t  const referrerRoute = createRoute({\n326\t    method: \"get\",\n327\t    path: \"/referrer\",\n328\t    tags: [\"Referral\"],\n329\t    summary: \"Get own referrer info\",\n330\t    security: [{ bearerAuth: [] }],\n331\t    responses: {\n332\t      200: {\n333\t        content: { \"application/json\": { schema: ReferralReferrerResponseSchema } },\n334\t        description: \"Referrer info (all fields null if not linked)\",\n335\t      },\n336\t      401: {\n337\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n338\t        description: \"Authentication required\",\n339\t      },\n340\t      500: {\n341\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n342\t        description: \"Failed to fetch referrer\",\n343\t      },\n344\t    },\n345\t  });\n346\t\n347\t  app.openapi(referrerRoute, async (c) => {\n348\t    const userId = c.get(\"userId\");\n349\t    if (!userId) return c.json({ error: \"Authentication required\" }, 401);\n350\t\n351\t    try {\n352\t      const link = await db.getReferralLinkByRefereeUserId(userId);\n353\t      if (!link) {\n354\t        return c.json(\n355\t          {\n356\t            referrerUserId: null,\n357\t            referrerUsername: null,\n358\t            referrerCode: null,\n359\t            linkedAt: null,\n360\t          },\n361\t          200,\n362\t        );\n363\t      }\n364\t\n365\t      // Look up referrer's username and code for display\n366\t      const [referrerProfile, referrerCode] = await Promise.all([\n367\t        db.getProfileByUserId(link.referrer_user_id),\n368\t        db.getReferralCodeByUserId(link.referrer_user_id),\n369\t      ]);\n370\t\n371\t      return c.json(\n372\t        {\n373\t          referrerUserId: link.referrer_user_id,\n374\t          referrerUsername: referrerProfile?.username ?? link.referrer_user_id,\n375\t          referrerCode: referrerCode?.code ?? null,\n376\t          linkedAt: link.created_at.toISOString(),\n377\t        },\n378\t        200,\n379\t      );\n380\t    } catch (err) {\n381\t      logger.error(\"Failed to fetch referrer\", {\n382\t        err: String(err),\n383\t        userId,\n384\t      });\n385\t      return c.json({ error: \"Failed to fetch referrer\" }, 500);\n386\t    }\n387\t  });\n388\t\n389\t  // ── GET /stats — referral summary stats for authenticated user ──────────\n390\t\n391\t  const statsRoute = createRoute({\n392\t    method: \"get\",\n393\t    path: \"/stats\",\n394\t    tags: [\"Referral\"],\n395\t    summary: \"Get referral stats\",\n396\t    security: [{ bearerAuth: [] }],\n397\t    responses: {\n398\t      200: {\n399\t        content: { \"application/json\": { schema: ReferralStatsSchema } },\n400\t        description: \"Referral statistics\",\n401\t      },\n402\t      401: {\n403\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n404\t        description: \"Authentication required\",\n405\t      },\n406\t      500: {\n407\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n408\t        description: \"Failed to fetch referral stats\",\n409\t      },\n410\t    },\n411\t  });\n412\t\n413\t  app.openapi(statsRoute, async (c) => {\n414\t    const userId = c.get(\"userId\");\n415\t    if (!userId) return c.json({ error: \"Authentication required\" }, 401);\n416\t\n417\t    try {\n418\t      const stats = await db.getReferralStatsByUserId(userId);\n419\t      return c.json(\n420\t        {\n421\t          referredCount: stats.referred_count,\n422\t          activeCount: stats.active_count,\n423\t          totalVolumeLamports: stats.total_volume_lamports,\n424\t          totalEarnedLamports: stats.total_earned_lamports,\n425\t          totalRebateLamports: stats.total_rebate_lamports,\n426\t          pendingLamports: stats.pending_lamports,\n427\t        },\n428\t        200,\n429\t      );\n430\t    } catch (err) {\n431\t      logger.error(\"Failed to fetch referral stats\", {\n432\t        err: String(err),\n433\t        userId,\n434\t      });\n435\t      return c.json({ error: \"Failed to fetch referral stats\" }, 500);\n436\t    }\n437\t  });\n438\t\n439\t  // ── GET /referrals — unique referred users (last 10) ────────────────────\n440\t\n441\t  const referralsRoute = createRoute({\n442\t    method: \"get\",\n443\t    path: \"/referrals\",\n444\t    tags: [\"Referral\"],\n445\t    summary: \"List referred users (last 10)\",\n446\t    security: [{ bearerAuth: [] }],\n447\t    responses: {\n448\t      200: {\n449\t        content: { \"application/json\": { schema: ReferralListResponseSchema } },\n450\t        description: \"Referred users\",\n451\t      },\n452\t      401: {\n453\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n454\t        description: \"Authentication required\",\n455\t      },\n456\t      500: {\n457\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n458\t        description: \"Failed to fetch referrals\",\n459\t      },\n460\t    },\n461\t  });\n462\t\n463\t  app.openapi(referralsRoute, async (c) => {\n464\t    const userId = c.get(\"userId\");\n465\t    if (!userId) return c.json({ error: \"Authentication required\" }, 401);\n466\t\n467\t    try {\n468\t      const links = await db.getReferralLinksByReferrerUserId(userId);\n469\t      // Return last 10 unique referees with usernames, sorted by most recent first\n470\t      const recent = links.slice(0, 10);\n471\t      const profiles = await Promise.all(\n472\t        recent.map((l) => db.getProfileByUserId(l.referee_user_id)),\n473\t      );\n474\t      const items = recent.map((l, i) => ({\n475\t        refereeUserId: l.referee_user_id,\n476\t        refereeUsername: profiles[i]?.username ?? l.referee_user_id,\n477\t        createdAt: l.created_at.toISOString(),\n478\t      }));\n479\t      return c.json({ items }, 200);\n480\t    } catch (err) {\n481\t      logger.error(\"Failed to fetch referrals\", {\n482\t        err: String(err),\n483\t        userId,\n484\t      });\n485\t      return c.json({ error: \"Failed to fetch referrals\" }, 500);\n486\t    }\n487\t  });\n488\t\n489\t  // ── GET /earnings — paginated per-game earnings log ─────────────────────\n490\t\n491\t  const earningsRoute = createRoute({\n492\t    method: \"get\",\n493\t    path: \"/earnings\",\n494\t    tags: [\"Referral\"],\n495\t    summary: \"Get paginated referral earnings\",\n496\t    security: [{ bearerAuth: [] }],\n497\t    request: {\n498\t      query: z.object({\n499\t        page: z.coerce.number().int().min(1).default(1).optional(),\n500\t        limit: z.coerce.number().int().min(1).max(100).default(20).optional(),\n501\t      }),\n502\t    },\n503\t    responses: {\n504\t      200: {\n505\t        content: {\n506\t          \"application/json\": {\n507\t            schema: z.object({\n508\t              items: z.array(z.object({\n509\t                roundId: z.string(),\n510\t                gameType: z.string(),\n511\t                refereeUserId: z.string(),\n512\t                refereeUsername: z.string(),\n513\t                wagerLamports: z.string(),\n514\t                earnedLamports: z.string(),\n515\t                createdAt: z.string().datetime(),\n516\t              })),\n517\t              pagination: z.object({\n518\t                page: z.number().int(),\n519\t                totalPages: z.number().int(),\n520\t              }),\n521\t            }),\n522\t          },\n523\t        },\n524\t        description: \"Earnings list\",\n525\t      },\n526\t      400: {\n527\t        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n528\t        description: \"Invalid parameters\",\n529\t      },\n530\t      401: {\n531\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n532\t        description: \"Authentication required\",\n533\t      },\n534\t      500: {\n535\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n536\t        description: \"Failed to fetch referral earnings\",\n537\t      },\n538\t    },\n539\t  });\n540\t\n541\t  app.openapi(earningsRoute, async (c) => {\n542\t    const userId = c.get(\"userId\");\n543\t    if (!userId) return c.json({ error: \"Authentication required\" }, 401);\n544\t\n545\t    const query = c.req.valid(\"query\");\n546\t    const page = query.page ?? 1;\n547\t    const limit = query.limit ?? 20;\n548\t\n549\t    if (Number.isNaN(page) || Number.isNaN(limit)) {\n550\t      return c.json(\n551\t        {\n552\t          error: {\n553\t            code: \"INVALID_PARAMS\",\n554\t            message: \"page and limit must be positive integers\",\n555\t          },\n556\t        },\n557\t        400,\n558\t      );\n559\t    }\n560\t\n561\t    try {\n562\t      const result = await db.getReferralEarningsByUserId(userId, page, limit);\n563\t      // Resolve usernames for referees (batch-dedup by userId)\n564\t      const uniqueRefereeIds = [...new Set(result.items.map((e) => e.referee_user_id))];\n565\t      const refereeProfiles = await Promise.all(\n566\t        uniqueRefereeIds.map((id) => db.getProfileByUserId(id)),\n567\t      );\n568\t      const usernameMap = new Map(\n569\t        uniqueRefereeIds.map((id, i) => [id, refereeProfiles[i]?.username ?? id]),\n570\t      );\n571\t      return c.json(\n572\t        {\n573\t          items: result.items.map((e) => ({\n574\t            roundId: e.round_id,\n575\t            gameType: e.game_type,\n576\t            refereeUserId: e.referee_user_id,\n577\t            refereeUsername: usernameMap.get(e.referee_user_id) ?? e.referee_user_id,\n578\t            wagerLamports: String(e.wager_lamports),\n579\t            earnedLamports: String(e.referrer_earned_lamports),\n580\t            createdAt: e.created_at.toISOString(),\n581\t          })),\n582\t          pagination: {\n583\t            page,\n584\t            totalPages: result.totalPages,\n585\t          },\n586\t        },\n587\t        200,\n588\t      );\n589\t    } catch (err) {\n590\t      logger.error(\"Failed to fetch referral earnings\", {\n591\t        err: String(err),\n592\t        userId,\n593\t      });\n594\t      return c.json({ error: \"Failed to fetch referral earnings\" }, 500);\n595\t    }\n596\t  });\n597\t\n598\t  // ── POST /claim — request payout of pending referral earnings ───────────\n599\t\n600\t  const claimRoute = createRoute({\n601\t    method: \"post\",\n602\t    path: \"/claim\",\n603\t    tags: [\"Referral\"],\n604\t    summary: \"Request payout of pending referral earnings\",\n605\t    security: [{ bearerAuth: [] }],\n606\t    responses: {\n607\t      202: {\n608\t        content: { \"application/json\": { schema: ClaimResponseSchema } },\n609\t        description: \"Claim queued\",\n610\t      },\n611\t      400: {\n612\t        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n613\t        description: \"Zero balance or below threshold\",\n614\t      },\n615\t      401: {\n616\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n617\t        description: \"Authentication required\",\n618\t      },\n619\t      404: {\n620\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n621\t        description: \"Profile not found\",\n622\t      },\n623\t      500: {\n624\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n625\t        description: \"Failed to create referral claim\",\n626\t      },\n627\t    },\n628\t  });\n629\t\n630\t  app.openapi(claimRoute, async (c) => {\n631\t    const userId = c.get(\"userId\");\n632\t    if (!userId) {\n633\t      return c.json({ error: \"Authentication required\" }, 401);\n634\t    }\n635\t    const profile = await db.getProfileByUserId(userId);\n636\t    if (!profile) {\n637\t      return c.json({ error: \"Profile not found\" }, 404);\n638\t    }\n639\t    const wallet = profile.wallet;\n640\t\n641\t    try {\n642\t      // Snapshot pending balance\n643\t      const pendingStr = await db.getPendingBalanceByUserId(userId);\n644\t      const pendingLamports = BigInt(pendingStr);\n645\t\n646\t      if (pendingLamports <= 0n) {\n647\t        return c.json(\n648\t          {\n649\t            error: {\n650\t              code: \"ZERO_BALANCE\",\n651\t              message: \"No pending earnings to claim\",\n652\t              retryable: false,\n653\t            },\n654\t          },\n655\t          400,\n656\t        );\n657\t      }\n658\t\n659\t      if (pendingLamports < BigInt(config.referralMinClaimLamports)) {\n660\t        return c.json(\n661\t          {\n662\t            error: {\n663\t              code: \"BELOW_THRESHOLD\",\n664\t              message: `Minimum claim amount is ${config.referralMinClaimLamports} lamports (${(config.referralMinClaimLamports / 1e9).toFixed(2)} SOL)`,\n665\t              retryable: false,\n666\t            },\n667\t          },\n668\t          400,\n669\t        );\n670\t      }\n671\t\n672\t      // Atomically insert claim row + emit queue event\n673\t      const claim = await sql.begin(async (tx) => {\n674\t        const rows = await (tx as unknown as postgres.Sql)<\n675\t          {\n676\t            id: string;\n677\t            user_id: string;\n678\t            wallet: string;\n679\t            amount_lamports: string;\n680\t            status: string;\n681\t          }[]\n682\t        >`\n683\t          INSERT INTO referral_claims (user_id, wallet, amount_lamports, status)\n684\t          VALUES (${userId}, ${wallet}, ${pendingStr}, 'pending')\n685\t          RETURNING id, user_id, wallet, amount_lamports, status\n686\t        `;\n687\t        const row = rows[0]!;\n688\t\n689\t        await emitEvent(\n690\t          tx as unknown as postgres.Sql,\n691\t          EventTypes.REFERRAL_CLAIM_REQUESTED,\n692\t          {\n693\t            claimId: row.id,\n694\t            userId: row.user_id,\n695\t            wallet: row.wallet,\n696\t            amountLamports: row.amount_lamports,\n697\t            requestedAt: new Date().toISOString(),\n698\t          },\n699\t        );\n700\t\n701\t        return row;\n702\t      });\n703\t\n704\t      logger.info(\"Referral claim requested\", {\n705\t        userId,\n706\t        wallet,\n707\t        claimId: claim.id,\n708\t        amountLamports: claim.amount_lamports,\n709\t      });\n710\t\n711\t      return c.json(\n712\t        {\n713\t          claimId: claim.id,\n714\t          amountLamports: claim.amount_lamports,\n715\t          status: \"pending\",\n716\t        },\n717\t        202,\n718\t      );\n719\t    } catch (err) {\n720\t      logger.error(\"Failed to create referral claim\", {\n721\t        err: String(err),\n722\t        userId,\n723\t        wallet,\n724\t      });\n725\t      return c.json({ error: \"Failed to create referral claim\" }, 500);\n726\t    }\n727\t  });\n728\t\n729\t  // ── GET /claim/:claimId — poll claim status ─────────────────────────────\n730\t\n731\t  const getClaimRoute = createRoute({\n732\t    method: \"get\",\n733\t    path: \"/claim/{claimId}\",\n734\t    tags: [\"Referral\"],\n735\t    summary: \"Poll claim status\",\n736\t    security: [{ bearerAuth: [] }],\n737\t    request: {\n738\t      params: z.object({\n739\t        claimId: z.string().openapi({ description: \"Claim ID\" }),\n740\t      }),\n741\t    },\n742\t    responses: {\n743\t      200: {\n744\t        content: { \"application/json\": { schema: ClaimResponseSchema } },\n745\t        description: \"Claim status\",\n746\t      },\n747\t      401: {\n748\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n749\t        description: \"Authentication required\",\n750\t      },\n751\t      404: {\n752\t        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n753\t        description: \"Claim not found\",\n754\t      },\n755\t      500: {\n756\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n757\t        description: \"Failed to fetch referral claim\",\n758\t      },\n759\t    },\n760\t  });\n761\t\n762\t  app.openapi(getClaimRoute, async (c) => {\n763\t    const userId = c.get(\"userId\");\n764\t    if (!userId) return c.json({ error: \"Authentication required\" }, 401);\n765\t\n766\t    const { claimId } = c.req.valid(\"param\");\n767\t\n768\t    try {\n769\t      const claim = await db.getReferralClaim(claimId);\n770\t      if (!claim) {\n771\t        return c.json(\n772\t          {\n773\t            error: {\n774\t              code: \"CLAIM_NOT_FOUND\",\n775\t              message: \"Claim not found\",\n776\t            },\n777\t          },\n778\t          404,\n779\t        );\n780\t      }\n781\t\n782\t      // Only allow the claim owner to view their claim\n783\t      if (claim.user_id !== userId) {\n784\t        return c.json(\n785\t          {\n786\t            error: {\n787\t              code: \"CLAIM_NOT_FOUND\",\n788\t              message: \"Claim not found\",\n789\t            },\n790\t          },\n791\t          404,\n792\t        );\n793\t      }\n794\t\n795\t      return c.json(\n796\t        {\n797\t          claimId: claim.id,\n798\t          amountLamports: String(claim.amount_lamports),\n799\t          status: claim.status,\n800\t          ...(claim.tx_signature ? { txSignature: claim.tx_signature } : {}),\n801\t        },\n802\t        200,\n803\t      );\n804\t    } catch (err) {\n805\t      logger.error(\"Failed to fetch referral claim\", {\n806\t        err: String(err),\n807\t        userId,\n808\t        claimId,\n809\t      });\n810\t      return c.json({ error: \"Failed to fetch referral claim\" }, 500);\n811\t    }\n812\t  });\n813\t\n814\t  return app;\n815\t}\n816\t"}]},"parent_tool_use_id":null,"session_id":"eb7d01f2-3773-44f3-9eed-fc96d23e7071","uuid":"5d301d62-4e01-46a5-bc50-8bd1008414b0","timestamp":"2026-04-22T09:48:12.579Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/referral.ts","content":"/**\n * Referral routes — code management, linking, stats, earnings, and claims.\n *\n * WAITLIST-CONTRACT: the waitlist calls POST/GET /code, POST /apply,\n * GET /referrer, GET /stats, GET /referrals. /earnings and /claim are NOT\n * consumed by waitlist. Request/response shape for the consumed set is\n * pinned in `__tests__/waitlist-contract.test.ts`; keep\n * `waitlist/src/lib/referral-api.ts` in lockstep.\n */\n\nimport { createRoute, z } from \"@hono/zod-openapi\";\nimport type postgres from \"postgres\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport type { Config } from \"../config.js\";\nimport { errorMessage, structuredErrorMessage } from \"../contracts/api-errors.js\";\nimport {\n  ApplyReferralCodeBodySchema,\n  ClaimResponseSchema,\n  CodeResponseSchema,\n  ErrorResponseSchema,\n  MaybeCodeResponseSchema,\n  ReferralApplyResponseSchema,\n  ReferralCodeBodySchema,\n  ReferralListResponseSchema,\n  ReferralReferrerResponseSchema,\n  ReferralStatsSchema,\n  StructuredErrorResponseSchema,\n} from \"../contracts/validators.js\";\nimport { logger } from \"../logger.js\";\nimport { emitEvent } from \"../queue/emit-event.js\";\nimport { EventTypes } from \"../queue/event-types.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface ReferralRoutesDeps {\n  db: Db;\n  sql: postgres.Sql;\n  config: Config;\n}\n\nexport function createReferralRoutes(deps: ReferralRoutesDeps) {\n  const { db, sql, config } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // ── POST /code — set the player's referral code (permanent) ────────────\n\n  const setCodeRoute = createRoute({\n    method: \"post\",\n    path: \"/code\",\n    tags: [\"Referral\"],\n    summary: \"Set referral code (permanent)\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      body: {\n        required: true,\n        content: { \"application/json\": { schema: ReferralCodeBodySchema } },\n      },\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: CodeResponseSchema } },\n        description: \"Code set\",\n      },\n      400: {\n        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n        description: \"Invalid request body or code format\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Profile not found\",\n      },\n      409: {\n        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n        description: \"Code already set or taken\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to set referral code\",\n      },\n    },\n  });\n\n  app.openapi(setCodeRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json(errorMessage(\"Authentication required\"), 401);\n    }\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return c.json(errorMessage(\"Profile not found\"), 404);\n    }\n    const wallet = profile.wallet;\n\n    const { code } = c.req.valid(\"json\");\n\n    // Check if the user already has a code — codes are permanent\n    const ownCode = await db.getReferralCodeByUserId(userId);\n    if (ownCode) {\n      return c.json(\n        structuredErrorMessage(\n          \"CODE_ALREADY_SET\",\n          \"You already have a referral code. Codes cannot be changed.\",\n          false,\n        ),\n        409,\n      );\n    }\n\n    // Check if this code is already taken by another user\n    const existing = await db.getReferralCodeByCode(code);\n    if (existing && existing.user_id !== userId) {\n      return c.json(\n        structuredErrorMessage(\"CODE_TAKEN\", \"This referral code is already in use\", false),\n        409,\n      );\n    }\n\n    try {\n      const result = await db.insertReferralCode(userId, wallet, code);\n      logger.info(\"Referral code set\", { userId, wallet, code: result.code });\n      return c.json({ code: result.code }, 200);\n    } catch (err) {\n      // Handle race condition: another wallet grabbed the code between check and insert\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return c.json(\n          structuredErrorMessage(\"CODE_TAKEN\", \"This referral code is already in use\", false),\n          409,\n        );\n      }\n      logger.error(\"Failed to set referral code\", {\n        err: String(err),\n        userId,\n        wallet,\n      });\n      return c.json(errorMessage(\"Failed to set referral code\"), 500);\n    }\n  }, (result, c) => {\n    if (result.success) return;\n    return c.json(\n      structuredErrorMessage(\n        \"INVALID_CODE\",\n        \"Referral code must be 3-16 lowercase letters, numbers, or hyphens.\",\n        false,\n      ),\n      400,\n    );\n  });\n\n  // ── POST /apply — link the authenticated player to a referrer ──────────\n\n  const applyRoute = createRoute({\n    method: \"post\",\n    path: \"/apply\",\n    tags: [\"Referral\"],\n    summary: \"Apply a referral code (link to referrer)\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      body: {\n        required: true,\n        content: { \"application/json\": { schema: ApplyReferralCodeBodySchema } },\n      },\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: ReferralApplyResponseSchema } },\n        description: \"Linked to referrer\",\n      },\n      400: {\n        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n        description: \"Invalid request body, empty code, or self-referral\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: {\n          \"application/json\": {\n            schema: z.union([ErrorResponseSchema, StructuredErrorResponseSchema]),\n          },\n        },\n        description: \"Profile or code not found\",\n      },\n      409: {\n        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n        description: \"Already linked to a referrer\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to apply referral code\",\n      },\n    },\n  });\n\n  app.openapi(applyRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json(errorMessage(\"Authentication required\"), 401);\n    }\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return c.json(errorMessage(\"Profile not found\"), 404);\n    }\n    const wallet = profile.wallet;\n\n    const { code } = c.req.valid(\"json\");\n\n    // Look up the referral code to find the referrer\n    const codeRow = await db.getReferralCodeByCode(code);\n    if (!codeRow) {\n      return c.json(\n        structuredErrorMessage(\"CODE_NOT_FOUND\", \"Referral code does not exist\", false),\n        404,\n      );\n    }\n\n    // Self-referral check\n    if (codeRow.user_id === userId) {\n      return c.json(\n        structuredErrorMessage(\"SELF_REFERRAL\", \"You cannot use your own referral code\", false),\n        400,\n      );\n    }\n\n    // Check if the player already has a referrer\n    const existingLink = await db.getReferralLinkByRefereeUserId(userId);\n    if (existingLink) {\n      return c.json(\n        structuredErrorMessage(\n          \"ALREADY_LINKED\",\n          \"You are already linked to a referrer\",\n          false,\n        ),\n        409,\n      );\n    }\n\n    try {\n      await db.insertReferralLink({\n        referrerUserId: codeRow.user_id,\n        refereeUserId: userId,\n        referrerWallet: codeRow.wallet,\n        refereeWallet: wallet,\n      });\n      logger.info(\"Referral link created\", {\n        referrerUserId: codeRow.user_id,\n        refereeUserId: userId,\n        code,\n      });\n      return c.json(\n        {\n          referrerUserId: codeRow.user_id,\n          benefit: \"10% fee rebate on all games\",\n        },\n        200,\n      );\n    } catch (err) {\n      // Handle race condition: another request linked this referee between check and insert\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return c.json(\n          structuredErrorMessage(\n            \"ALREADY_LINKED\",\n            \"You are already linked to a referrer\",\n            false,\n          ),\n          409,\n        );\n      }\n      logger.error(\"Failed to create referral link\", {\n        err: String(err),\n        userId,\n        wallet,\n        code,\n      });\n      return c.json(errorMessage(\"Failed to apply referral code\"), 500);\n    }\n  }, (result, c) => {\n    if (result.success) return;\n    return c.json(\n      structuredErrorMessage(\n        \"INVALID_CODE\",\n        \"Referral code must be 3-16 lowercase letters, numbers, or hyphens.\",\n        false,\n      ),\n      400,\n    );\n  });\n\n  // ── GET /code — return the authenticated player's current referral code ─\n\n  const getCodeRoute = createRoute({\n    method: \"get\",\n    path: \"/code\",\n    tags: [\"Referral\"],\n    summary: \"Get own referral code\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: MaybeCodeResponseSchema } },\n        description: \"Code (null if not set)\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n    },\n  });\n\n  app.openapi(getCodeRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) return c.json(errorMessage(\"Authentication required\"), 401);\n\n    const row = await db.getReferralCodeByUserId(userId);\n    return c.json({ code: row?.code ?? null }, 200);\n  });\n\n  // ── GET /referrer — check if the authenticated player has a referrer ────\n\n  const referrerRoute = createRoute({\n    method: \"get\",\n    path: \"/referrer\",\n    tags: [\"Referral\"],\n    summary: \"Get own referrer info\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: ReferralReferrerResponseSchema } },\n        description: \"Referrer info (all fields null if not linked)\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to fetch referrer\",\n      },\n    },\n  });\n\n  app.openapi(referrerRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) return c.json({ error: \"Authentication required\" }, 401);\n\n    try {\n      const link = await db.getReferralLinkByRefereeUserId(userId);\n      if (!link) {\n        return c.json(\n          {\n            referrerUserId: null,\n            referrerUsername: null,\n            referrerCode: null,\n            linkedAt: null,\n          },\n          200,\n        );\n      }\n\n      // Look up referrer's username and code for display\n      const [referrerProfile, referrerCode] = await Promise.all([\n        db.getProfileByUserId(link.referrer_user_id),\n        db.getReferralCodeByUserId(link.referrer_user_id),\n      ]);\n\n      return c.json(\n        {\n          referrerUserId: link.referrer_user_id,\n          referrerUsername: referrerProfile?.username ?? link.referrer_user_id,\n          referrerCode: referrerCode?.code ?? null,\n          linkedAt: link.created_at.toISOString(),\n        },\n        200,\n      );\n    } catch (err) {\n      logger.error(\"Failed to fetch referrer\", {\n        err: String(err),\n        userId,\n      });\n      return c.json({ error: \"Failed to fetch referrer\" }, 500);\n    }\n  });\n\n  // ── GET /stats — referral summary stats for authenticated user ──────────\n\n  const statsRoute = createRoute({\n    method: \"get\",\n    path: \"/stats\",\n    tags: [\"Referral\"],\n    summary: \"Get referral stats\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: ReferralStatsSchema } },\n        description: \"Referral statistics\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to fetch referral stats\",\n      },\n    },\n  });\n\n  app.openapi(statsRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) return c.json({ error: \"Authentication required\" }, 401);\n\n    try {\n      const stats = await db.getReferralStatsByUserId(userId);\n      return c.json(\n        {\n          referredCount: stats.referred_count,\n          activeCount: stats.active_count,\n          totalVolumeLamports: stats.total_volume_lamports,\n          totalEarnedLamports: stats.total_earned_lamports,\n          totalRebateLamports: stats.total_rebate_lamports,\n          pendingLamports: stats.pending_lamports,\n        },\n        200,\n      );\n    } catch (err) {\n      logger.error(\"Failed to fetch referral stats\", {\n        err: String(err),\n        userId,\n      });\n      return c.json({ error: \"Failed to fetch referral stats\" }, 500);\n    }\n  });\n\n  // ── GET /referrals — unique referred users (last 10) ────────────────────\n\n  const referralsRoute = createRoute({\n    method: \"get\",\n    path: \"/referrals\",\n    tags: [\"Referral\"],\n    summary: \"List referred users (last 10)\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: ReferralListResponseSchema } },\n        description: \"Referred users\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to fetch referrals\",\n      },\n    },\n  });\n\n  app.openapi(referralsRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) return c.json({ error: \"Authentication required\" }, 401);\n\n    try {\n      const links = await db.getReferralLinksByReferrerUserId(userId);\n      // Return last 10 unique referees with usernames, sorted by most recent first\n      const recent = links.slice(0, 10);\n      const profiles = await Promise.all(\n        recent.map((l) => db.getProfileByUserId(l.referee_user_id)),\n      );\n      const items = recent.map((l, i) => ({\n        refereeUserId: l.referee_user_id,\n        refereeUsername: profiles[i]?.username ?? l.referee_user_id,\n        createdAt: l.created_at.toISOString(),\n      }));\n      return c.json({ items }, 200);\n    } catch (err) {\n      logger.error(\"Failed to fetch referrals\", {\n        err: String(err),\n        userId,\n      });\n      return c.json({ error: \"Failed to fetch referrals\" }, 500);\n    }\n  });\n\n  // ── GET /earnings — paginated per-game earnings log ─────────────────────\n\n  const earningsRoute = createRoute({\n    method: \"get\",\n    path: \"/earnings\",\n    tags: [\"Referral\"],\n    summary: \"Get paginated referral earnings\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      query: z.object({\n        page: z.coerce.number().int().min(1).default(1).optional(),\n        limit: z.coerce.number().int().min(1).max(100).default(20).optional(),\n      }),\n    },\n    responses: {\n      200: {\n        content: {\n          \"application/json\": {\n            schema: z.object({\n              items: z.array(z.object({\n                roundId: z.string(),\n                gameType: z.string(),\n                refereeUserId: z.string(),\n                refereeUsername: z.string(),\n                wagerLamports: z.string(),\n                earnedLamports: z.string(),\n                createdAt: z.string().datetime(),\n              })),\n              pagination: z.object({\n                page: z.number().int(),\n                totalPages: z.number().int(),\n              }),\n            }),\n          },\n        },\n        description: \"Earnings list\",\n      },\n      400: {\n        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n        description: \"Invalid parameters\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to fetch referral earnings\",\n      },\n    },\n  });\n\n  app.openapi(earningsRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) return c.json({ error: \"Authentication required\" }, 401);\n\n    const query = c.req.valid(\"query\");\n    const page = query.page ?? 1;\n    const limit = query.limit ?? 20;\n\n    if (Number.isNaN(page) || Number.isNaN(limit)) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_PARAMS\",\n            message: \"page and limit must be positive integers\",\n          },\n        },\n        400,\n      );\n    }\n\n    try {\n      const result = await db.getReferralEarningsByUserId(userId, page, limit);\n      // Resolve usernames for referees (batch-dedup by userId)\n      const uniqueRefereeIds = [...new Set(result.items.map((e) => e.referee_user_id))];\n      const refereeProfiles = await Promise.all(\n        uniqueRefereeIds.map((id) => db.getProfileByUserId(id)),\n      );\n      const usernameMap = new Map(\n        uniqueRefereeIds.map((id, i) => [id, refereeProfiles[i]?.username ?? id]),\n      );\n      return c.json(\n        {\n          items: result.items.map((e) => ({\n            roundId: e.round_id,\n            gameType: e.game_type,\n            refereeUserId: e.referee_user_id,\n            refereeUsername: usernameMap.get(e.referee_user_id) ?? e.referee_user_id,\n            wagerLamports: String(e.wager_lamports),\n            earnedLamports: String(e.referrer_earned_lamports),\n            createdAt: e.created_at.toISOString(),\n          })),\n          pagination: {\n            page,\n            totalPages: result.totalPages,\n          },\n        },\n        200,\n      );\n    } catch (err) {\n      logger.error(\"Failed to fetch referral earnings\", {\n        err: String(err),\n        userId,\n      });\n      return c.json({ error: \"Failed to fetch referral earnings\" }, 500);\n    }\n  });\n\n  // ── POST /claim — request payout of pending referral earnings ───────────\n\n  const claimRoute = createRoute({\n    method: \"post\",\n    path: \"/claim\",\n    tags: [\"Referral\"],\n    summary: \"Request payout of pending referral earnings\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      202: {\n        content: { \"application/json\": { schema: ClaimResponseSchema } },\n        description: \"Claim queued\",\n      },\n      400: {\n        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n        description: \"Zero balance or below threshold\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Profile not found\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to create referral claim\",\n      },\n    },\n  });\n\n  app.openapi(claimRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return c.json({ error: \"Profile not found\" }, 404);\n    }\n    const wallet = profile.wallet;\n\n    try {\n      // Snapshot pending balance\n      const pendingStr = await db.getPendingBalanceByUserId(userId);\n      const pendingLamports = BigInt(pendingStr);\n\n      if (pendingLamports <= 0n) {\n        return c.json(\n          {\n            error: {\n              code: \"ZERO_BALANCE\",\n              message: \"No pending earnings to claim\",\n              retryable: false,\n            },\n          },\n          400,\n        );\n      }\n\n      if (pendingLamports < BigInt(config.referralMinClaimLamports)) {\n        return c.json(\n          {\n            error: {\n              code: \"BELOW_THRESHOLD\",\n              message: `Minimum claim amount is ${config.referralMinClaimLamports} lamports (${(config.referralMinClaimLamports / 1e9).toFixed(2)} SOL)`,\n              retryable: false,\n            },\n          },\n          400,\n        );\n      }\n\n      // Atomically insert claim row + emit queue event\n      const claim = await sql.begin(async (tx) => {\n        const rows = await (tx as unknown as postgres.Sql)<\n          {\n            id: string;\n            user_id: string;\n            wallet: string;\n            amount_lamports: string;\n            status: string;\n          }[]\n        >`\n          INSERT INTO referral_claims (user_id, wallet, amount_lamports, status)\n          VALUES (${userId}, ${wallet}, ${pendingStr}, 'pending')\n          RETURNING id, user_id, wallet, amount_lamports, status\n        `;\n        const row = rows[0]!;\n\n        await emitEvent(\n          tx as unknown as postgres.Sql,\n          EventTypes.REFERRAL_CLAIM_REQUESTED,\n          {\n            claimId: row.id,\n            userId: row.user_id,\n            wallet: row.wallet,\n            amountLamports: row.amount_lamports,\n            requestedAt: new Date().toISOString(),\n          },\n        );\n\n        return row;\n      });\n\n      logger.info(\"Referral claim requested\", {\n        userId,\n        wallet,\n        claimId: claim.id,\n        amountLamports: claim.amount_lamports,\n      });\n\n      return c.json(\n        {\n          claimId: claim.id,\n          amountLamports: claim.amount_lamports,\n          status: \"pending\",\n        },\n        202,\n      );\n    } catch (err) {\n      logger.error(\"Failed to create referral claim\", {\n        err: String(err),\n        userId,\n        wallet,\n      });\n      return c.json({ error: \"Failed to create referral claim\" }, 500);\n    }\n  });\n\n  // ── GET /claim/:claimId — poll claim status ─────────────────────────────\n\n  const getClaimRoute = createRoute({\n    method: \"get\",\n    path: \"/claim/{claimId}\",\n    tags: [\"Referral\"],\n    summary: \"Poll claim status\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      params: z.object({\n        claimId: z.string().openapi({ description: \"Claim ID\" }),\n      }),\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: ClaimResponseSchema } },\n        description: \"Claim status\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n        description: \"Claim not found\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to fetch referral claim\",\n      },\n    },\n  });\n\n  app.openapi(getClaimRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) return c.json({ error: \"Authentication required\" }, 401);\n\n    const { claimId } = c.req.valid(\"param\");\n\n    try {\n      const claim = await db.getReferralClaim(claimId);\n      if (!claim) {\n        return c.json(\n          {\n            error: {\n              code: \"CLAIM_NOT_FOUND\",\n              message: \"Claim not found\",\n            },\n          },\n          404,\n        );\n      }\n\n      // Only allow the claim owner to view their claim\n      if (claim.user_id !== userId) {\n        return c.json(\n          {\n            error: {\n              code: \"CLAIM_NOT_FOUND\",\n              message: \"Claim not found\",\n            },\n          },\n          404,\n        );\n      }\n\n      return c.json(\n        {\n          claimId: claim.id,\n          amountLamports: String(claim.amount_lamports),\n          status: claim.status,\n          ...(claim.tx_signature ? { txSignature: claim.tx_signature } : {}),\n        },\n        200,\n      );\n    } catch (err) {\n      logger.error(\"Failed to fetch referral claim\", {\n        err: String(err),\n        userId,\n        claimId,\n      });\n      return c.json({ error: \"Failed to fetch referral claim\" }, 500);\n    }\n  });\n\n  return app;\n}\n","numLines":816,"startLine":1,"totalLines":816}}}
