 => ({","-            roundId: e.round_id,","-            gameType: e.game_type,","-            refereeUserId: e.referee_user_id,","-            refereeUsername: usernameMap.get(e.referee_user_id) ?? e.referee_user_id,","-            wagerLamports: String(e.wager_lamports),","-            earnedLamports: String(e.referrer_earned_lamports),","-            createdAt: e.created_at.toISOString(),","-          })),","-          pagination: {","-            page,","-            totalPages: result.totalPages,","-          },","+      return ok(c, {","+        items: result.items.map((e) => ({","+          roundId: e.round_id,","+          gameType: e.game_type,","+          refereeUserId: e.referee_user_id,","+          refereeUsername: usernameMap.get(e.referee_user_id) ?? e.referee_user_id,","+          wagerLamports: String(e.wager_lamports),","+          earnedLamports: String(e.referrer_earned_lamports),","+          createdAt: e.created_at.toISOString(),","+        })),","+        pagination: {","+          page,","+          totalPages: result.totalPages,","         },","-        200,","-      );","-    } catch (err) {","+      });","+    } catch (fetchError) {","       logger.error(\"Failed to fetch referral earnings\", {","-        err: String(err),","+        err: String(fetchError),","         userId,","       });","-      return c.json({ error: \"Failed to fetch referral earnings\" }, 500);","+      return err(","+        c,","+        500,","+        API_ERROR_CODES.PRECONDITION_FAILED,","+        \"Failed to fetch referral earnings\",","+      );","     }","   });"," "]},{"oldStart":605,"oldLines":23,"newStart":639,"newLines":25,"lines":["     security: [{ bearerAuth: [] }],","     responses: {","       202: {","-        content: { \"application/json\": { schema: ClaimResponseSchema } },","+        content: {","+          \"application/json\": { schema: envelope(ClaimResponseSchema) },","+        },","         description: \"Claim queued\",","       },","-      400: {","-        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },","-        description: \"Zero balance or below threshold\",","-      },","       401: {","-        content: { \"application/json\": { schema: ErrorResponseSchema } },","+        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","         description: \"Authentication required\",","       },","       404: {","-        content: { \"application/json\": { schema: ErrorResponseSchema } },","+        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","         description: \"Profile not found\",","       },","+      422: {","+        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","+        description: \"Zero balance or below threshold\",","+      },","       500: {","-        content: { \"application/json\": { schema: ErrorResponseSchema } },","+        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","         description: \"Failed to create referral claim\",","       },","     },"]},{"oldStart":630,"oldLines":11,"newStart":666,"newLines":11,"lines":["   app.openapi(claimRoute, async (c) => {","     const userId = c.get(\"userId\");","     if (!userId) {","-      return c.json({ error: \"Authentication required\" }, 401);","+      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");","     }","     const profile = await db.getProfileByUserId(userId);","     if (!profile) {","-      return c.json({ error: \"Profile not found\" }, 404);","+      return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");","     }","     const wallet = profile.wallet;"," "]},{"oldStart":644,"oldLines":28,"newStart":680,"newLines":22,"lines":["       const pendingLamports = BigInt(pendingStr);"," ","       if (pendingLamports <= 0n) {","-        return c.json(","-          {","-            error: {","-              code: \"ZERO_BALANCE\",","-              message: \"No pending earnings to claim\",","-              retryable: false,","-            },","-          },","-          400,","+        return err(","+          c,","+          422,","+          API_ERROR_CODES.ZERO_BALANCE,","+          \"No pending earnings to claim\",","+          { retryable: false },","         );","       }"," ","       if (pendingLamports < BigInt(config.referralMinClaimLamports)) {","-        return c.json(","-          {","-            error: {","-              code: \"BELOW_THRESHOLD\",","-              message: `Minimum claim amount is ${config.referralMinClaimLamports} lamports (${(config.referralMinClaimLamports / 1e9).toFixed(2)} SOL)`,","-              retryable: false,","-            },","-          },","-          400,","+        return err(","+          c,","+          422,","+          API_ERROR_CODES.BELOW_THRESHOLD,","+          `Minimum claim amount is ${config.referralMinClaimLamports} lamports (${(config.referralMinClaimLamports / 1e9).toFixed(2)} SOL)`,","+          { retryable: false },","         );","       }"," "]},{"oldStart":708,"oldLines":7,"newStart":738,"newLines":8,"lines":["         amountLamports: claim.amount_lamports,","       });"," ","-      return c.json(","+      return ok(","+        c,","         {","           claimId: claim.id,","           amountLamports: claim.amount_lamports,"]},{"oldStart":716,"oldLines":13,"newStart":747,"newLines":18,"lines":["         },","         202,","       );","-    } catch (err) {","+    } catch (claimError) {","       logger.error(\"Failed to create referral claim\", {","-        err: String(err),","+        err: String(claimError),","         userId,","         wallet,","       });","-      return c.json({ error: \"Failed to create referral claim\" }, 500);","+      return err(","+        c,","+        500,","+        API_ERROR_CODES.PRECONDITION_FAILED,","+        \"Failed to create referral claim\",","+      );","     }","   });"," "]},{"oldStart":741,"oldLines":19,"newStart":777,"newLines":21,"lines":["     },","     responses: {","       200: {","-        content: { \"application/json\": { schema: ClaimResponseSchema } },","+        content: {","+          \"application/json\": { schema: envelope(ClaimResponseSchema) },","+        },","         description: \"Claim status\",","       },","       401: {","-        content: { \"application/json\": { schema: ErrorResponseSchema } },","+        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","         description: \"Authentication required\",","       },","       404: {","-        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },","+        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","         description: \"Claim not found\",","       },","       500: {","-        content: { \"application/json\": { schema: ErrorResponseSchema } },","+        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","         description: \"Failed to fetch referral claim\",","       },","     },"]},{"oldStart":761,"oldLines":53,"newStart":799,"newLines":51,"lines":[" ","   app.openapi(getClaimRoute, async (c) => {","     const userId = c.get(\"userId\");","-    if (!userId) return c.json({ error: \"Authentication required\" }, 401);","+    if (!userId) {","+      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");","+    }"," ","     const { claimId } = c.req.valid(\"param\");"," ","     try {","       const claim = await db.getReferralClaim(claimId);","       if (!claim) {","-        return c.json(","-          {","-            error: {","-              code: \"CLAIM_NOT_FOUND\",","-              message: \"Claim not found\",","-            },","-          },","+        return err(","+          c,","           404,","+          API_ERROR_CODES.CLAIM_NOT_FOUND,","+          \"Claim not found\",","         );","       }"," ","       // Only allow the claim owner to view their claim","       if (claim.user_id !== userId) {","-        return c.json(","-          {","-            error: {","-              code: \"CLAIM_NOT_FOUND\",","-              message: \"Claim not found\",","-            },","-          },","+        return err(","+          c,","           404,","+          API_ERROR_CODES.CLAIM_NOT_FOUND,","+          \"Claim not found\",","         );","       }"," ","-      return c.json(","-        {","-          claimId: claim.id,","-          amountLamports: String(claim.amount_lamports),","-          status: claim.status,","-          ...(claim.tx_signature ? { txSignature: claim.tx_signature } : {}),","-        },","-        200,","-      );","-    } catch (err) {","+      return ok(c, {","+        claimId: claim.id,","+        amountLamports: String(claim.amount_lamports),","+        status: claim.status,","+        ...(claim.tx_signature ? { txSignature: claim.tx_signature } : {}),","+      });","+    } catch (fetchError) {","       logger.error(\"Failed to fetch referral claim\", {","-        err: String(err),","+        err: String(fetchError),","         userId,","         claimId,","       });","-      return c.json({ error: \"Failed to fetch referral claim\" }, 500);","+      return err(","+        c,","+        500,","+        API_ERROR_CODES.PRECONDITION_FAILED,","+        \"Failed to fetch referral claim\",","+      );","     }","   });"," "]}],"originalFile":"/**\n * Referral routes — code management, linking, stats, earnings, and claims.\n *\n * WAITLIST-CONTRACT: the waitlist calls POST/GET /code, POST /apply,\n * GET /referrer, GET /stats, GET /referrals. /earnings and /claim are NOT\n * consumed by waitlist. Request/response shape for the consumed set is\n * pinned in `__tests__/waitlist-contract.test.ts`; keep\n * `waitlist/src/lib/referral-api.ts` in lockstep.\n */\n\nimport { createRoute, z } from \"@hono/zod-openapi\";\nimport type postgres from \"postgres\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport type { Config } from \"../config.js\";\nimport { errorMessage, structuredErrorMessage } from \"../contracts/api-errors.js\";\nimport {\n  ApplyReferralCodeBodySchema,\n  ClaimResponseSchema,\n  CodeResponseSchema,\n  ErrorResponseSchema,\n  MaybeCodeResponseSchema,\n  ReferralApplyResponseSchema,\n  ReferralCodeBodySchema,\n  ReferralListResponseSchema,\n  ReferralReferrerResponseSchema,\n  ReferralStatsSchema,\n  StructuredErrorResponseSchema,\n} from \"../contracts/validators.js\";\nimport { logger } from \"../logger.js\";\nimport { emitEvent } from \"../queue/emit-event.js\";\nimport { EventTypes } from \"../queue/event-types.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface ReferralRoutesDeps {\n  db: Db;\n  sql: postgres.Sql;\n  config: Config;\n}\n\nexport function createReferralRoutes(deps: ReferralRoutesDeps) {\n  const { db, sql, config } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // ── POST /code — set the player's referral code (permanent) ────────────\n\n  const setCodeRoute = createRoute({\n    method: \"post\",\n    path: \"/code\",\n    tags: [\"Referral\"],\n    summary: \"Set referral code (permanent)\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      body: {\n        required: true,\n        content: { \"application/json\": { schema: ReferralCodeBodySchema } },\n      },\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: CodeResponseSchema } },\n        description: \"Code set\",\n      },\n      400: {\n        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n        description: \"Invalid request body or code format\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Profile not found\",\n      },\n      409: {\n        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n        description: \"Code already set or taken\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to set referral code\",\n      },\n    },\n  });\n\n  app.openapi(setCodeRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json(errorMessage(\"Authentication required\"), 401);\n    }\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return c.json(errorMessage(\"Profile not found\"), 404);\n    }\n    const wallet = profile.wallet;\n\n    const { code } = c.req.valid(\"json\");\n\n    // Check if the user already has a code — codes are permanent\n    const ownCode = await db.getReferralCodeByUserId(userId);\n    if (ownCode) {\n      return c.json(\n        structuredErrorMessage(\n          \"CODE_ALREADY_SET\",\n          \"You already have a referral code. Codes cannot be changed.\",\n          false,\n        ),\n        409,\n      );\n    }\n\n    // Check if this code is already taken by another user\n    const existing = await db.getReferralCodeByCode(code);\n    if (existing && existing.user_id !== userId) {\n      return c.json(\n        structuredErrorMessage(\"CODE_TAKEN\", \"This referral code is already in use\", false),\n        409,\n      );\n    }\n\n    try {\n      const result = await db.insertReferralCode(userId, wallet, code);\n      logger.info(\"Referral code set\", { userId, wallet, code: result.code });\n      return c.json({ code: result.code }, 200);\n    } catch (err) {\n      // Handle race condition: another wallet grabbed the code between check and insert\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return c.json(\n          structuredErrorMessage(\"CODE_TAKEN\", \"This referral code is already in use\", false),\n          409,\n        );\n      }\n      logger.error(\"Failed to set referral code\", {\n        err: String(err),\n        userId,\n        wallet,\n      });\n      return c.json(errorMessage(\"Failed to set referral code\"), 500);\n    }\n  }, (result, c) => {\n    if (result.success) return;\n    return c.json(\n      structuredErrorMessage(\n        \"INVALID_CODE\",\n        \"Referral code must be 3-16 lowercase letters, numbers, or hyphens.\",\n        false,\n      ),\n      400,\n    );\n  });\n\n  // ── POST /apply — link the authenticated player to a referrer ──────────\n\n  const applyRoute = createRoute({\n    method: \"post\",\n    path: \"/apply\",\n    tags: [\"Referral\"],\n    summary: \"Apply a referral code (link to referrer)\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      body: {\n        required: true,\n        content: { \"application/json\": { schema: ApplyReferralCodeBodySchema } },\n      },\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: ReferralApplyResponseSchema } },\n        description: \"Linked to referrer\",\n      },\n      400: {\n        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n        description: \"Invalid request body, empty code, or self-referral\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: {\n          \"application/json\": {\n            schema: z.union([ErrorResponseSchema, StructuredErrorResponseSchema]),\n          },\n        },\n        description: \"Profile or code not found\",\n      },\n      409: {\n        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n        description: \"Already linked to a referrer\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to apply referral code\",\n      },\n    },\n  });\n\n  app.openapi(applyRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json(errorMessage(\"Authentication required\"), 401);\n    }\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return c.json(errorMessage(\"Profile not found\"), 404);\n    }\n    const wallet = profile.wallet;\n\n    const { code } = c.req.valid(\"json\");\n\n    // Look up the referral code to find the referrer\n    const codeRow = await db.getReferralCodeByCode(code);\n    if (!codeRow) {\n      return c.json(\n        structuredErrorMessage(\"CODE_NOT_FOUND\", \"Referral code does not exist\", false),\n        404,\n      );\n    }\n\n    // Self-referral check\n    if (codeRow.user_id === userId) {\n      return c.json(\n        structuredErrorMessage(\"SELF_REFERRAL\", \"You cannot use your own referral code\", false),\n        400,\n      );\n    }\n\n    // Check if the player already has a referrer\n    const existingLink = await db.getReferralLinkByRefereeUserId(userId);\n    if (existingLink) {\n      return c.json(\n        structuredErrorMessage(\n          \"ALREADY_LINKED\",\n          \"You are already linked to a referrer\",\n          false,\n        ),\n        409,\n      );\n    }\n\n    try {\n      await db.insertReferralLink({\n        referrerUserId: codeRow.user_id,\n        refereeUserId: userId,\n        referrerWallet: codeRow.wallet,\n        refereeWallet: wallet,\n      });\n      logger.info(\"Referral link created\", {\n        referrerUserId: codeRow.user_id,\n        refereeUserId: userId,\n        code,\n      });\n      return c.json(\n        {\n          referrerUserId: codeRow.user_id,\n          benefit: \"10% fee rebate on all games\",\n        },\n        200,\n      );\n    } catch (err) {\n      // Handle race condition: another request linked this referee between check and insert\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return c.json(\n          structuredErrorMessage(\n            \"ALREADY_LINKED\",\n            \"You are already linked to a referrer\",\n            false,\n          ),\n          409,\n        );\n      }\n      logger.error(\"Failed to create referral link\", {\n        err: String(err),\n        userId,\n        wallet,\n        code,\n      });\n      return c.json(errorMessage(\"Failed to apply referral code\"), 500);\n    }\n  }, (result, c) => {\n    if (result.success) return;\n    return c.json(\n      structuredErrorMessage(\n        \"INVALID_CODE\",\n        \"Referral code must be 3-16 lowercase letters, numbers, or hyphens.\",\n        false,\n      ),\n      400,\n    );\n  });\n\n  // ── GET /code — return the authenticated player's current referral code ─\n\n  const getCodeRoute = createRoute({\n    method: \"get\",\n    path: \"/code\",\n    tags: [\"Referral\"],\n    summary: \"Get own referral code\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: MaybeCodeResponseSchema } },\n        description: \"Code (null if not set)\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n    },\n  });\n\n  app.openapi(getCodeRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) return c.json(errorMessage(\"Authentication required\"), 401);\n\n    const row = await db.getReferralCodeByUserId(userId);\n    return c.json({ code: row?.code ?? null }, 200);\n  });\n\n  // ── GET /referrer — check if the authenticated player has a referrer ────\n\n  const referrerRoute = createRoute({\n    method: \"get\",\n    path: \"/referrer\",\n    tags: [\"Referral\"],\n    summary: \"Get own referrer info\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: ReferralReferrerResponseSchema } },\n        description: \"Referrer info (all fields null if not linked)\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to fetch referrer\",\n      },\n    },\n  });\n\n  app.openapi(referrerRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) return c.json({ error: \"Authentication required\" }, 401);\n\n    try {\n      const link = await db.getReferralLinkByRefereeUserId(userId);\n      if (!link) {\n        return c.json(\n          {\n            referrerUserId: null,\n            referrerUsername: null,\n            referrerCode: null,\n            linkedAt: null,\n          },\n          200,\n        );\n      }\n\n      // Look up referrer's username and code for display\n      const [referrerProfile, referrerCode] = await Promise.all([\n        db.getProfileByUserId(link.referrer_user_id),\n        db.getReferralCodeByUserId(link.referrer_user_id),\n      ]);\n\n      return c.json(\n        {\n          referrerUserId: link.referrer_user_id,\n          referrerUsername: referrerProfile?.username ?? link.referrer_user_id,\n          referrerCode: referrerCode?.code ?? null,\n          linkedAt: link.created_at.toISOString(),\n        },\n        200,\n      );\n    } catch (err) {\n      logger.error(\"Failed to fetch referrer\", {\n        err: String(err),\n        userId,\n      });\n      return c.json({ error: \"Failed to fetch referrer\" }, 500);\n    }\n  });\n\n  // ── GET /stats — referral summary stats for authenticated user ──────────\n\n  const statsRoute = createRoute({\n    method: \"get\",\n    path: \"/stats\",\n    tags: [\"Referral\"],\n    summary: \"Get referral stats\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: ReferralStatsSchema } },\n        description: \"Referral statistics\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to fetch referral stats\",\n      },\n    },\n  });\n\n  app.openapi(statsRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) return c.json({ error: \"Authentication required\" }, 401);\n\n    try {\n      const stats = await db.getReferralStatsByUserId(userId);\n      return c.json(\n        {\n          referredCount: stats.referred_count,\n          activeCount: stats.active_count,\n          totalVolumeLamports: stats.total_volume_lamports,\n          totalEarnedLamports: stats.total_earned_lamports,\n          totalRebateLamports: stats.total_rebate_lamports,\n          pendingLamports: stats.pending_lamports,\n        },\n        200,\n      );\n    } catch (err) {\n      logger.error(\"Failed to fetch referral stats\", {\n        err: String(err),\n        userId,\n      });\n      return c.json({ error: \"Failed to fetch referral stats\" }, 500);\n    }\n  });\n\n  // ── GET /referrals — unique referred users (last 10) ────────────────────\n\n  const referralsRoute = createRoute({\n    method: \"get\",\n    path: \"/referrals\",\n    tags: [\"Referral\"],\n    summary: \"List referred users (last 10)\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: ReferralListResponseSchema } },\n        description: \"Referred users\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to fetch referrals\",\n      },\n    },\n  });\n\n  app.openapi(referralsRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) return c.json({ error: \"Authentication required\" }, 401);\n\n    try {\n      const links = await db.getReferralLinksByReferrerUserId(userId);\n      // Return last 10 unique referees with usernames, sorted by most recent first\n      const recent = links.slice(0, 10);\n      const profiles = await Promise.all(\n        recent.map((l) => db.getProfileByUserId(l.referee_user_id)),\n      );\n      const items = recent.map((l, i) => ({\n        refereeUserId: l.referee_user_id,\n        refereeUsername: profiles[i]?.username ?? l.referee_user_id,\n        createdAt: l.created_at.toISOString(),\n      }));\n      return c.json({ items }, 200);\n    } catch (err) {\n      logger.error(\"Failed to fetch referrals\", {\n        err: String(err),\n        userId,\n      });\n      return c.json({ error: \"Failed to fetch referrals\" }, 500);\n    }\n  });\n\n  // ── GET /earnings — paginated per-game earnings log ─────────────────────\n\n  const earningsRoute = createRoute({\n    method: \"get\",\n    path: \"/earnings\",\n    tags: [\"Referral\"],\n    summary: \"Get paginated referral earnings\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      query: z.object({\n        page: z.coerce.number().int().min(1).default(1).optional(),\n        limit: z.coerce.number().int().min(1).max(100).default(20).optional(),\n      }),\n    },\n    responses: {\n      200: {\n        content: {\n          \"application/json\": {\n            schema: z.object({\n              items: z.array(z.object({\n                roundId: z.string(),\n                gameType: z.string(),\n                refereeUserId: z.string(),\n                refereeUsername: z.string(),\n                wagerLamports: z.string(),\n                earnedLamports: z.string(),\n                createdAt: z.string().datetime(),\n              })),\n              pagination: z.object({\n                page: z.number().int(),\n                totalPages: z.number().int(),\n              }),\n            }),\n          },\n        },\n        description: \"Earnings list\",\n      },\n      400: {\n        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n        description: \"Invalid parameters\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to fetch referral earnings\",\n      },\n    },\n  });\n\n  app.openapi(earningsRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) return c.json({ error: \"Authentication required\" }, 401);\n\n    const query = c.req.valid(\"query\");\n    const page = query.page ?? 1;\n    const limit = query.limit ?? 20;\n\n    if (Number.isNaN(page) || Number.isNaN(limit)) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_PARAMS\",\n            message: \"page and limit must be positive integers\",\n          },\n        },\n        400,\n      );\n    }\n\n    try {\n      const result = await db.getReferralEarningsByUserId(userId, page, limit);\n      // Resolve usernames for referees (batch-dedup by userId)\n      const uniqueRefereeIds = [...new Set(result.items.map((e) => e.referee_user_id))];\n      const refereeProfiles = await Promise.all(\n        uniqueRefereeIds.map((id) => db.getProfileByUserId(id)),\n      );\n      const usernameMap = new Map(\n        uniqueRefereeIds.map((id, i) => [id, refereeProfiles[i]?.username ?? id]),\n      );\n      return c.json(\n        {\n          items: result.items.map((e) => ({\n            roundId: e.round_id,\n            gameType: e.game_type,\n            refereeUserId: e.referee_user_id,\n            refereeUsername: usernameMap.get(e.referee_user_id) ?? e.referee_user_id,\n            wagerLamports: String(e.wager_lamports),\n            earnedLamports: String(e.referrer_earned_lamports),\n            createdAt: e.created_at.toISOString(),\n          })),\n          pagination: {\n            page,\n            totalPages: result.totalPages,\n          },\n        },\n        200,\n      );\n    } catch (err) {\n      logger.error(\"Failed to fetch referral earnings\", {\n        err: String(err),\n        userId,\n      });\n      return c.json({ error: \"Failed to fetch referral earnings\" }, 500);\n    }\n  });\n\n  // ── POST /claim — request payout of pending referral earnings ───────────\n\n  const claimRoute = createRoute({\n    method: \"post\",\n    path: \"/claim\",\n    tags: [\"Referral\"],\n    summary: \"Request payout of pending referral earnings\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      202: {\n        content: { \"application/json\": { schema: ClaimResponseSchema } },\n        description: \"Claim queued\",\n      },\n      400: {\n        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n        description: \"Zero balance or below threshold\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Profile not found\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to create referral claim\",\n      },\n    },\n  });\n\n  app.openapi(claimRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return c.json({ error: \"Profile not found\" }, 404);\n    }\n    const wallet = profile.wallet;\n\n    try {\n      // Snapshot pending balance\n      const pendingStr = await db.getPendingBalanceByUserId(userId);\n      const pendingLamports = BigInt(pendingStr);\n\n      if (pendingLamports <= 0n) {\n        return c.json(\n          {\n            error: {\n              code: \"ZERO_BALANCE\",\n              message: \"No pending earnings to claim\",\n              retryable: false,\n            },\n          },\n          400,\n        );\n      }\n\n      if (pendingLamports < BigInt(config.referralMinClaimLamports)) {\n        return c.json(\n          {\n            error: {\n              code: \"BELOW_THRESHOLD\",\n              message: `Minimum claim amount is ${config.referralMinClaimLamports} lamports (${(config.referralMinClaimLamports / 1e9).toFixed(2)} SOL)`,\n              retryable: false,\n            },\n          },\n          400,\n        );\n      }\n\n      // Atomically insert claim row + emit queue event\n      const claim = await sql.begin(async (tx) => {\n        const rows = await (tx as unknown as postgres.Sql)<\n          {\n            id: string;\n            user_id: string;\n            wallet: string;\n            amount_lamports: string;\n            status: string;\n          }[]\n        >`\n          INSERT INTO referral_claims (user_id, wallet, amount_lamports, status)\n          VALUES (${userId}, ${wallet}, ${pendingStr}, 'pending')\n          RETURNING id, user_id, wallet, amount_lamports, status\n        `;\n        const row = rows[0]!;\n\n        await emitEvent(\n          tx as unknown as postgres.Sql,\n          EventTypes.REFERRAL_CLAIM_REQUESTED,\n          {\n            claimId: row.id,\n            userId: row.user_id,\n            wallet: row.wallet,\n            amountLamports: row.amount_lamports,\n            requestedAt: new Date().toISOString(),\n          },\n        );\n\n        return row;\n      });\n\n      logger.info(\"Referral claim requested\", {\n        userId,\n        wallet,\n        claimId: claim.id,\n        amountLamports: claim.amount_lamports,\n      });\n\n      return c.json(\n        {\n          claimId: claim.id,\n          amountLamports: claim.amount_lamports,\n          status: \"pending\",\n        },\n        202,\n      );\n    } catch (err) {\n      logger.error(\"Failed to create referral claim\", {\n        err: String(err),\n        userId,\n        wallet,\n      });\n      return c.json({ error: \"Failed to create referral claim\" }, 500);\n    }\n  });\n\n  // ── GET /claim/:claimId — poll claim status ─────────────────────────────\n\n  const getClaimRoute = createRoute({\n    method: \"get\",\n    path: \"/claim/{claimId}\",\n    tags: [\"Referral\"],\n    summary: \"Poll claim status\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      params: z.object({\n        claimId: z.string().openapi({ description: \"Claim ID\" }),\n      }),\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: ClaimResponseSchema } },\n        description: \"Claim status\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: StructuredErrorResponseSchema } },\n        description: \"Claim not found\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to fetch referral claim\",\n      },\n    },\n  });\n\n  app.openapi(getClaimRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) return c.json({ error: \"Authentication required\" }, 401);\n\n    const { claimId } = c.req.valid(\"param\");\n\n    try {\n      const claim = await db.getReferralClaim(claimId);\n      if (!claim) {\n        return c.json(\n          {\n            error: {\n              code: \"CLAIM_NOT_FOUND\",\n              message: \"Claim not found\",\n            },\n          },\n          404,\n        );\n      }\n\n      // Only allow the claim owner to view their claim\n      if (claim.user_id !== userId) {\n        return c.json(\n          {\n            error: {\n              code: \"CLAIM_NOT_FOUND\",\n              message: \"Claim not found\",\n            },\n          },\n          404,\n        );\n      }\n\n      return c.json(\n        {\n          claimId: claim.id,\n          amountLamports: String(claim.amount_lamports),\n          status: claim.status,\n          ...(claim.tx_signature ? { txSignature: claim.tx_signature } : {}),\n        },\n        200,\n      );\n    } catch (err) {\n      logger.error(\"Failed to fetch referral claim\", {\n        err: String(err),\n        userId,\n        claimId,\n      });\n      return c.json({ error: \"Failed to fetch referral claim\" }, 500);\n    }\n  });\n\n  return app;\n}\n","userModified":false}}
