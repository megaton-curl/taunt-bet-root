{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L4BnnPmdzsTiifHKrxBdC1","type":"tool_result","content":"1\t/* eslint-disable @typescript-eslint/no-explicit-any */\n2\t/**\n3\t * Referral route tests — set code, apply, stats, earnings, claim flows.\n4\t *\n5\t * Uses real Postgres (same pattern as auth-routes.test.ts) with TRUNCATE\n6\t * between tests for isolation.\n7\t */\n8\t\n9\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n10\timport { Hono } from \"hono\";\n11\timport { Keypair } from \"@solana/web3.js\";\n12\timport { SignJWT } from \"jose\";\n13\timport postgres from \"postgres\";\n14\timport { createDb, type Db } from \"../db.js\";\n15\timport { createReferralRoutes } from \"../routes/referral.js\";\n16\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n17\timport type { Config } from \"../config.js\";\n18\t\n19\t// ---------------------------------------------------------------------------\n20\t// Constants\n21\t// ---------------------------------------------------------------------------\n22\t\n23\tconst DATABASE_URL =\n24\t  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n25\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-referral-tests\");\n26\t\n27\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n28\tfunction makeSql() {\n29\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n30\t  // Dev container: postgres listens on Unix socket only\n31\t  return postgres({\n32\t    host: \"/var/run/postgresql\",\n33\t    user: \"vscode\",\n34\t    database: \"taunt_bet_dev\",\n35\t  });\n36\t}\n37\t\n38\t// ---------------------------------------------------------------------------\n39\t// Helpers\n40\t// ---------------------------------------------------------------------------\n41\t\n42\tasync function makeJwt(wallet: string): Promise<string> {\n43\t  const now = Math.floor(Date.now() / 1000);\n44\t  return new SignJWT({})\n45\t    .setProtectedHeader({ alg: \"HS256\" })\n46\t    .setSubject(userIdFromWallet(wallet))\n47\t    .setIssuedAt(now)\n48\t    .setExpirationTime(now + 3600)\n49\t    .sign(JWT_SECRET);\n50\t}\n51\t\n52\tfunction json(body: Record<string, any>) {\n53\t  return {\n54\t    headers: { \"Content-Type\": \"application/json\" },\n55\t    body: JSON.stringify(body),\n56\t  };\n57\t}\n58\t\n59\tfunction userIdFromWallet(wallet: string) {\n60\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n61\t}\n62\t\n63\t// ---------------------------------------------------------------------------\n64\t// Test suite\n65\t// ---------------------------------------------------------------------------\n66\t\n67\tdescribe(\"Referral routes\", () => {\n68\t  let rawSql: ReturnType<typeof postgres>;\n69\t  let db: Db;\n70\t  let app: Hono;\n71\t\n72\t  const referrerKp = Keypair.generate();\n73\t  const refereeKp = Keypair.generate();\n74\t  const referrer = referrerKp.publicKey.toBase58();\n75\t  const referee = refereeKp.publicKey.toBase58();\n76\t  const referrerUserId = userIdFromWallet(referrer);\n77\t  const refereeUserId = userIdFromWallet(referee);\n78\t\n79\t  const testConfig = {\n80\t    referralDefaultRateBps: 1000,\n81\t    referralMinClaimLamports: 10_000_000, // 0.01 SOL\n82\t  } as Config;\n83\t\n84\t  beforeAll(async () => {\n85\t    rawSql = makeSql();\n86\t    await rawSql`\n87\t      DROP TABLE IF EXISTS referral_claims, referral_earnings, referral_links, referral_codes, referral_kol_rates CASCADE\n88\t    `;\n89\t    await rawSql`\n90\t      CREATE TABLE referral_codes (\n91\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n92\t        user_id TEXT NOT NULL UNIQUE,\n93\t        wallet TEXT NOT NULL UNIQUE,\n94\t        code TEXT NOT NULL UNIQUE,\n95\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n96\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n97\t      )\n98\t    `;\n99\t    await rawSql`\n100\t      CREATE TABLE referral_links (\n101\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n102\t        referrer_user_id TEXT NOT NULL,\n103\t        referee_user_id TEXT NOT NULL UNIQUE,\n104\t        referrer_wallet TEXT NOT NULL,\n105\t        referee_wallet TEXT NOT NULL,\n106\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n107\t      )\n108\t    `;\n109\t    await rawSql`\n110\t      CREATE INDEX idx_referral_links_referrer ON referral_links (referrer_user_id)\n111\t    `;\n112\t    await rawSql`\n113\t      CREATE TABLE referral_earnings (\n114\t        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n115\t        referrer_user_id TEXT NOT NULL,\n116\t        referee_user_id TEXT NOT NULL,\n117\t        referrer_wallet TEXT NOT NULL,\n118\t        referee_wallet TEXT NOT NULL,\n119\t        round_id TEXT NOT NULL,\n120\t        game_type TEXT NOT NULL,\n121\t        wager_lamports BIGINT NOT NULL,\n122\t        fee_lamports BIGINT NOT NULL,\n123\t        referrer_earned_lamports BIGINT NOT NULL,\n124\t        referrer_rate_bps INTEGER NOT NULL,\n125\t        referee_rebate_lamports BIGINT NOT NULL,\n126\t        referee_rebate_rate_bps INTEGER NOT NULL,\n127\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n128\t        CONSTRAINT uq_referral_earnings_referee_round UNIQUE (referee_user_id, round_id)\n129\t      )\n130\t    `;\n131\t    await rawSql`\n132\t      CREATE INDEX idx_referral_earnings_referrer ON referral_earnings (referrer_user_id, created_at)\n133\t    `;\n134\t    await rawSql`\n135\t      CREATE INDEX idx_referral_earnings_referee ON referral_earnings (referee_user_id, created_at)\n136\t    `;\n137\t    await rawSql`\n138\t      CREATE INDEX idx_referral_earnings_round_id ON referral_earnings (round_id)\n139\t    `;\n140\t    await rawSql`\n141\t      CREATE TABLE referral_claims (\n142\t        id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n143\t        user_id TEXT NOT NULL,\n144\t        wallet TEXT NOT NULL,\n145\t        amount_lamports BIGINT NOT NULL,\n146\t        status TEXT NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'error', 'completed', 'failed')),\n147\t        retry_count INTEGER NOT NULL DEFAULT 0,\n148\t        tx_signature TEXT,\n149\t        error TEXT,\n150\t        requested_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n151\t        processed_at TIMESTAMPTZ\n152\t      )\n153\t    `;\n154\t    await rawSql`\n155\t      CREATE INDEX idx_referral_claims_user_id ON referral_claims (user_id, requested_at)\n156\t    `;\n157\t    await rawSql`\n158\t      CREATE INDEX idx_referral_claims_status ON referral_claims (status) WHERE status IN ('pending', 'processing')\n159\t    `;\n160\t    await rawSql`\n161\t      CREATE UNIQUE INDEX idx_referral_claims_user_active ON referral_claims (user_id) WHERE status IN ('pending', 'processing', 'error')\n162\t    `;\n163\t    await rawSql`\n164\t      CREATE TABLE referral_kol_rates (\n165\t        user_id TEXT PRIMARY KEY,\n166\t        wallet TEXT NOT NULL UNIQUE,\n167\t        rate_bps INTEGER NOT NULL,\n168\t        set_by TEXT NOT NULL,\n169\t        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n170\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n171\t      )\n172\t    `;\n173\t  });\n174\t\n175\t  afterAll(async () => {\n176\t    if (db) await db.close();\n177\t    await rawSql.end();\n178\t  });\n179\t\n180\t  beforeEach(async () => {\n181\t    await rawSql`TRUNCATE referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, event_queue RESTART IDENTITY CASCADE`;\n182\t    // Clean + recreate profiles for test wallets — routes resolve wallet\n183\t    // from profile via db.getProfileByUserId(userId).\n184\t    await rawSql`DELETE FROM player_profiles WHERE user_id IN (${referrerUserId}, ${refereeUserId})`;\n185\t    await rawSql`\n186\t      INSERT INTO player_profiles (user_id, wallet, username)\n187\t      VALUES (${referrerUserId}, ${referrer}, ${\"ref-er-\" + Date.now()}),\n188\t             (${refereeUserId}, ${referee}, ${\"ref-ee-\" + Date.now()})\n189\t    `;\n190\t\n191\t    db = createDb(DATABASE_URL, rawSql);\n192\t\n193\t    app = new Hono();\n194\t    app.use(\n195\t      \"/referral/*\",\n196\t      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n197\t    );\n198\t    app.route(\n199\t      \"/referral\",\n200\t      createReferralRoutes({ db, sql: rawSql, config: testConfig }),\n201\t    );\n202\t  });\n203\t\n204\t  // -----------------------------------------------------------------------\n205\t  // POST /referral/code — set custom code\n206\t  // -----------------------------------------------------------------------\n207\t\n208\t  describe(\"POST /referral/code\", () => {\n209\t    it(\"sets a valid custom code and returns code + url\", async () => {\n210\t      const token = await makeJwt(referrer);\n211\t      const res = await app.request(\"/referral/code\", {\n212\t        method: \"POST\",\n213\t        ...json({ code: \"my-code-123\" }),\n214\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n215\t      });\n216\t\n217\t      expect(res.status).toBe(200);\n218\t      const body = (await res.json()) as { code: string };\n219\t      expect(body.code).toBe(\"my-code-123\");\n220\t    });\n221\t\n222\t    it(\"rejects code shorter than 3 chars\", async () => {\n223\t      const token = await makeJwt(referrer);\n224\t      const res = await app.request(\"/referral/code\", {\n225\t        method: \"POST\",\n226\t        ...json({ code: \"ab\" }),\n227\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n228\t      });\n229\t\n230\t      expect(res.status).toBe(400);\n231\t      const body = (await res.json()) as { error: { code: string } };\n232\t      expect(body.error.code).toBe(\"INVALID_CODE\");\n233\t    });\n234\t\n235\t    it(\"rejects code longer than 16 chars\", async () => {\n236\t      const token = await makeJwt(referrer);\n237\t      const res = await app.request(\"/referral/code\", {\n238\t        method: \"POST\",\n239\t        ...json({ code: \"abcdefghijklmnopq\" }), // 17 chars\n240\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n241\t      });\n242\t\n243\t      expect(res.status).toBe(400);\n244\t    });\n245\t\n246\t    it(\"rejects code with uppercase or special chars\", async () => {\n247\t      const token = await makeJwt(referrer);\n248\t      const res = await app.request(\"/referral/code\", {\n249\t        method: \"POST\",\n250\t        ...json({ code: \"My_Code!\" }),\n251\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n252\t      });\n253\t\n254\t      expect(res.status).toBe(400);\n255\t    });\n256\t\n257\t    it(\"returns 409 when code is taken by another wallet\", async () => {\n258\t      // First wallet takes the code\n259\t      const token1 = await makeJwt(referrer);\n260\t      await app.request(\"/referral/code\", {\n261\t        method: \"POST\",\n262\t        ...json({ code: \"taken-code\" }),\n263\t        headers: { ...json({}).headers, Authorization: `Bearer ${token1}` },\n264\t      });\n265\t\n266\t      // Second wallet tries the same code\n267\t      const token2 = await makeJwt(referee);\n268\t      const res = await app.request(\"/referral/code\", {\n269\t        method: \"POST\",\n270\t        ...json({ code: \"taken-code\" }),\n271\t        headers: { ...json({}).headers, Authorization: `Bearer ${token2}` },\n272\t      });\n273\t\n274\t      expect(res.status).toBe(409);\n275\t      const body = (await res.json()) as { error: { code: string } };\n276\t      expect(body.error.code).toBe(\"CODE_TAKEN\");\n277\t    });\n278\t\n279\t    it(\"rejects changing an already-set code (codes are permanent)\", async () => {\n280\t      const token = await makeJwt(referrer);\n281\t\n282\t      // Set initial code\n283\t      await app.request(\"/referral/code\", {\n284\t        method: \"POST\",\n285\t        ...json({ code: \"first-code\" }),\n286\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n287\t      });\n288\t\n289\t      // Attempt to change — must be rejected\n290\t      const res = await app.request(\"/referral/code\", {\n291\t        method: \"POST\",\n292\t        ...json({ code: \"second-code\" }),\n293\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n294\t      });\n295\t\n296\t      expect(res.status).toBe(409);\n297\t      const body = (await res.json()) as { error: { code: string } };\n298\t      expect(body.error.code).toBe(\"CODE_ALREADY_SET\");\n299\t    });\n300\t\n301\t    it(\"rejects missing body\", async () => {\n302\t      const token = await makeJwt(referrer);\n303\t      const res = await app.request(\"/referral/code\", {\n304\t        method: \"POST\",\n305\t        headers: { Authorization: `Bearer ${token}` },\n306\t      });\n307\t\n308\t      expect(res.status).toBe(400);\n309\t      const body = (await res.json()) as { error: { code: string } };\n310\t      expect(body.error.code).toBe(\"INVALID_CODE\");\n311\t    });\n312\t  });\n313\t\n314\t  // -----------------------------------------------------------------------\n315\t  // GET /referral/code — retrieve current code\n316\t  // -----------------------------------------------------------------------\n317\t\n318\t  describe(\"GET /referral/code\", () => {\n319\t    it(\"returns existing code for wallet\", async () => {\n320\t      const token = await makeJwt(referrer);\n321\t\n322\t      // Set code first\n323\t      await app.request(\"/referral/code\", {\n324\t        method: \"POST\",\n325\t        ...json({ code: \"get-test\" }),\n326\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n327\t      });\n328\t\n329\t      const res = await app.request(\"/referral/code\", {\n330\t        method: \"GET\",\n331\t        headers: { Authorization: `Bearer ${token}` },\n332\t      });\n333\t\n334\t      expect(res.status).toBe(200);\n335\t      const body = (await res.json()) as { code: string };\n336\t      expect(body.code).toBe(\"get-test\");\n337\t    });\n338\t\n339\t    it(\"returns 200 with null code when not set\", async () => {\n340\t      const token = await makeJwt(referrer);\n341\t      const res = await app.request(\"/referral/code\", {\n342\t        method: \"GET\",\n343\t        headers: { Authorization: `Bearer ${token}` },\n344\t      });\n345\t\n346\t      expect(res.status).toBe(200);\n347\t      const body = (await res.json()) as { code: string | null };\n348\t      expect(body.code).toBeNull();\n349\t    });\n350\t  });\n351\t\n352\t  // -----------------------------------------------------------------------\n353\t  // POST /referral/apply — link referee to referrer\n354\t  // -----------------------------------------------------------------------\n355\t\n356\t  describe(\"POST /referral/apply\", () => {\n357\t    beforeEach(async () => {\n358\t      // Set up a referral code for the referrer\n359\t      const token = await makeJwt(referrer);\n360\t      await app.request(\"/referral/code\", {\n361\t        method: \"POST\",\n362\t        ...json({ code: \"apply-test\" }),\n363\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n364\t      });\n365\t    });\n366\t\n367\t    it(\"links referee to referrer via code\", async () => {\n368\t      const token = await makeJwt(referee);\n369\t      const res = await app.request(\"/referral/apply\", {\n370\t        method: \"POST\",\n371\t        ...json({ code: \"apply-test\" }),\n372\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n373\t      });\n374\t\n375\t      expect(res.status).toBe(200);\n376\t      const body = (await res.json()) as {\n377\t        referrerUserId: string;\n378\t        benefit: string;\n379\t      };\n380\t      expect(body.referrerUserId).toBe(referrerUserId);\n381\t      expect(body.benefit).toContain(\"10%\");\n382\t    });\n383\t\n384\t    it(\"rejects self-referral\", async () => {\n385\t      const token = await makeJwt(referrer); // referrer applying their own code\n386\t      const res = await app.request(\"/referral/apply\", {\n387\t        method: \"POST\",\n388\t        ...json({ code: \"apply-test\" }),\n389\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n390\t      });\n391\t\n392\t      expect(res.status).toBe(400);\n393\t      const body = (await res.json()) as { error: { code: string } };\n394\t      expect(body.error.code).toBe(\"SELF_REFERRAL\");\n395\t    });\n396\t\n397\t    it(\"returns 409 when already linked to a referrer\", async () => {\n398\t      const token = await makeJwt(referee);\n399\t\n400\t      // First apply succeeds\n401\t      await app.request(\"/referral/apply\", {\n402\t        method: \"POST\",\n403\t        ...json({ code: \"apply-test\" }),\n404\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n405\t      });\n406\t\n407\t      // Set up a second referrer code (needs a profile first)\n408\t      const other = Keypair.generate().publicKey.toBase58();\n409\t      const otherUserId = userIdFromWallet(other);\n410\t      await rawSql`\n411\t        INSERT INTO player_profiles (user_id, wallet, username)\n412\t        VALUES (${otherUserId}, ${other}, ${\"test-other-\" + Date.now()})\n413\t        ON CONFLICT (user_id) DO NOTHING\n414\t      `;\n415\t      const otherToken = await makeJwt(other);\n416\t      await app.request(\"/referral/code\", {\n417\t        method: \"POST\",\n418\t        ...json({ code: \"other-code\" }),\n419\t        headers: { ...json({}).headers, Authorization: `Bearer ${otherToken}` },\n420\t      });\n421\t\n422\t      // Second apply fails\n423\t      const res = await app.request(\"/referral/apply\", {\n424\t        method: \"POST\",\n425\t        ...json({ code: \"other-code\" }),\n426\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n427\t      });\n428\t\n429\t      expect(res.status).toBe(409);\n430\t      const body = (await res.json()) as { error: { code: string } };\n431\t      expect(body.error.code).toBe(\"ALREADY_LINKED\");\n432\t    });\n433\t\n434\t    it(\"returns 404 for non-existent code\", async () => {\n435\t      const token = await makeJwt(referee);\n436\t      const res = await app.request(\"/referral/apply\", {\n437\t        method: \"POST\",\n438\t        ...json({ code: \"nonexistent\" }),\n439\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n440\t      });\n441\t\n442\t      expect(res.status).toBe(404);\n443\t      const body = (await res.json()) as { error: { code: string } };\n444\t      expect(body.error.code).toBe(\"CODE_NOT_FOUND\");\n445\t    });\n446\t\n447\t    it(\"rejects empty code\", async () => {\n448\t      const token = await makeJwt(referee);\n449\t      const res = await app.request(\"/referral/apply\", {\n450\t        method: \"POST\",\n451\t        ...json({ code: \"\" }),\n452\t        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n453\t      });\n454\t\n455\t      expect(res.status).toBe(400);\n456\t    });\n457\t  });\n458\t\n459\t  // -----------------------------------------------------------------------\n460\t  // GET /referral/stats — summary stats\n461\t  // -----------------------------------------------------------------------\n462\t\n463\t  describe(\"GET /referral/stats\", () => {\n464\t    it(\"returns zeroed stats for wallet with no referrals\", async () => {\n465\t      const token = await makeJwt(referrer);\n466\t      const res = await app.request(\"/referral/stats\", {\n467\t        method: \"GET\",\n468\t        headers: { Authorization: `Bearer ${token}` },\n469\t      });\n470\t\n471\t      expect(res.status).toBe(200);\n472\t      const body = (await res.json()) as Record<string, any>;\n473\t      expect(body.referredCount).toBe(0);\n474\t      expect(body.activeCount).toBe(0);\n475\t      expect(body.totalVolumeLamports).toBe(\"0\");\n476\t      expect(body.totalEarnedLamports).toBe(\"0\");\n477\t      expect(body.pendingLamports).toBe(\"0\");\n478\t    });\n479\t\n480\t    it(\"reflects referred count after linking\", async () => {\n481\t      // Set up referrer code + link a referee\n482\t      const referrerToken = await makeJwt(referrer);\n483\t      await app.request(\"/referral/code\", {\n484\t        method: \"POST\",\n485\t        ...json({ code: \"stats-test\" }),\n486\t        headers: { ...json({}).headers, Authorization: `Bearer ${referrerToken}` },\n487\t      });\n488\t\n489\t      const refereeToken = await makeJwt(referee);\n490\t      await app.request(\"/referral/apply\", {\n491\t        method: \"POST\",\n492\t        ...json({ code: \"stats-test\" }),\n493\t        headers: { ...json({}).headers, Authorization: `Bearer ${refereeToken}` },\n494\t      });\n495\t\n496\t      const res = await app.request(\"/referral/stats\", {\n497\t        method: \"GET\",\n498\t        headers: { Authorization: `Bearer ${referrerToken}` },\n499\t      });\n500\t\n501\t      expect(res.status).toBe(200);\n502\t      const body = (await res.json()) as { referredCount: number };\n503\t      expect(body.referredCount).toBe(1);\n504\t    });\n505\t  });\n506\t\n507\t  // -----------------------------------------------------------------------\n508\t  // GET /referral/earnings — paginated earnings\n509\t  // -----------------------------------------------------------------------\n510\t\n511\t  describe(\"GET /referral/earnings\", () => {\n512\t    it(\"returns empty items when no earnings exist\", async () => {\n513\t      const token = await makeJwt(referrer);\n514\t      const res = await app.request(\"/referral/earnings\", {\n515\t        method: \"GET\",\n516\t        headers: { Authorization: `Bearer ${token}` },\n517\t      });\n518\t\n519\t      expect(res.status).toBe(200);\n520\t      const body = (await res.json()) as {\n521\t        items: unknown[];\n522\t        pagination: { page: number; totalPages: number };\n523\t      };\n524\t      expect(body.items).toHaveLength(0);\n525\t      expect(body.pagination.page).toBe(1);\n526\t      expect(body.pagination.totalPages).toBe(1); // min 1 page even when empty\n527\t    });\n528\t\n529\t    it(\"returns earnings after inserting one\", async () => {\n530\t      // Insert an earning directly via DB\n531\t      await db.insertReferralEarning({\n532\t        referrerUserId,\n533\t        refereeUserId,\n534\t        referrerWallet: referrer,\n535\t        refereeWallet: referee,\n536\t        roundId: \"test-round-001\",\n537\t        gameType: \"flipyou\",\n538\t        wagerLamports: 1_000_000_000,\n539\t        feeLamports: 50_000_000,\n540\t        referrerEarnedLamports: 5_000_000,\n541\t        referrerRateBps: 1000,\n542\t        refereeRebateLamports: 5_000_000,\n543\t        refereeRebateRateBps: 1000,\n544\t      });\n545\t\n546\t      const token = await makeJwt(referrer);\n547\t      const res = await app.request(\"/referral/earnings\", {\n548\t        method: \"GET\",\n549\t        headers: { Authorization: `Bearer ${token}` },\n550\t      });\n551\t\n552\t      expect(res.status).toBe(200);\n553\t      const body = (await res.json()) as {\n554\t        items: Array<{\n555\t          roundId: string;\n556\t          gameType: string;\n557\t          refereeUserId: string;\n558\t          wagerLamports: string;\n559\t          earnedLamports: string;\n560\t          createdAt: string;\n561\t        }>;\n562\t        pagination: { page: number; totalPages: number };\n563\t      };\n564\t      expect(body.items).toHaveLength(1);\n565\t      expect(body.items[0]!.roundId).toBe(\"test-round-001\");\n566\t      expect(body.items[0]!.gameType).toBe(\"flipyou\");\n567\t      expect(body.items[0]!.refereeUserId).toBe(refereeUserId);\n568\t      expect(body.items[0]!.wagerLamports).toBe(\"1000000000\");\n569\t      expect(body.items[0]!.earnedLamports).toBe(\"5000000\");\n570\t      expect(body.pagination.totalPages).toBe(1);\n571\t    });\n572\t\n573\t    it(\"respects page and limit query params\", async () => {\n574\t      // Insert 3 earnings\n575\t      for (let i = 1; i <= 3; i++) {\n576\t        await db.insertReferralEarning({\n577\t          referrerUserId,\n578\t          refereeUserId,\n579\t          referrerWallet: referrer,\n580\t          refereeWallet: referee,\n581\t          roundId: `round-${i}`,\n582\t          gameType: \"flipyou\",\n583\t          wagerLamports: 1_000_000_000,\n584\t          feeLamports: 50_000_000,\n585\t          referrerEarnedLamports: 5_000_000,\n586\t          referrerRateBps: 1000,\n587\t          refereeRebateLamports: 5_000_000,\n588\t          refereeRebateRateBps: 1000,\n589\t        });\n590\t      }\n591\t\n592\t      const token = await makeJwt(referrer);\n593\t      const res = await app.request(\"/referral/earnings?page=1&limit=2\", {\n594\t        method: \"GET\",\n595\t        headers: { Authorization: `Bearer ${token}` },\n596\t      });\n597\t\n598\t      expect(res.status).toBe(200);\n599\t      const body = (await res.json()) as {\n600\t        items: unknown[];\n601\t        pagination: { page: number; totalPages: number };\n602\t      };\n603\t      expect(body.items).toHaveLength(2);\n604\t      expect(body.pagination.totalPages).toBe(2);\n605\t    });\n606\t  });\n607\t\n608\t  // -----------------------------------------------------------------------\n609\t  // POST /referral/claim — claim flow\n610\t  // -----------------------------------------------------------------------\n611\t\n612\t  describe(\"POST /referral/claim\", () => {\n613\t    it(\"rejects claim with zero balance\", async () => {\n614\t      const token = await makeJwt(referrer);\n615\t      const res = await app.request(\"/referral/claim\", {\n616\t        method: \"POST\",\n617\t        headers: {\n618\t          \"Content-Type\": \"application/json\",\n619\t          Authorization: `Bearer ${token}`,\n620\t        },\n621\t      });\n622\t\n623\t      expect(res.status).toBe(400);\n624\t      const body = (await res.json()) as { error: { code: string } };\n625\t      expect(body.error.code).toBe(\"ZERO_BALANCE\");\n626\t    });\n627\t\n628\t    it(\"rejects claim below minimum threshold\", async () => {\n629\t      // Insert a small earning (below 0.01 SOL threshold)\n630\t      await db.insertReferralEarning({\n631\t        referrerUserId,\n632\t        refereeUserId,\n633\t        referrerWallet: referrer,\n634\t        refereeWallet: referee,\n635\t        roundId: \"small-round\",\n636\t        gameType: \"flipyou\",\n637\t        wagerLamports: 100_000_000, // 0.1 SOL\n638\t        feeLamports: 5_000_000, // 0.005 SOL\n639\t        referrerEarnedLamports: 500_000, // 0.0005 SOL — below 0.01 threshold\n640\t        referrerRateBps: 1000,\n641\t        refereeRebateLamports: 500_000,\n642\t        refereeRebateRateBps: 1000,\n643\t      });\n644\t\n645\t      const token = await makeJwt(referrer);\n646\t      const res = await app.request(\"/referral/claim\", {\n647\t        method: \"POST\",\n648\t        headers: {\n649\t          \"Content-Type\": \"application/json\",\n650\t          Authorization: `Bearer ${token}`,\n651\t        },\n652\t      });\n653\t\n654\t      expect(res.status).toBe(400);\n655\t      const body = (await res.json()) as { error: { code: string } };\n656\t      expect(body.error.code).toBe(\"BELOW_THRESHOLD\");\n657\t    });\n658\t\n659\t    it(\"creates a pending claim for valid balance\", async () => {\n660\t      // Insert a large enough earning\n661\t      await db.insertReferralEarning({\n662\t        referrerUserId,\n663\t        refereeUserId,\n664\t        referrerWallet: referrer,\n665\t        refereeWallet: referee,\n666\t        roundId: \"big-round\",\n667\t        gameType: \"flipyou\",\n668\t        wagerLamports: 10_000_000_000, // 10 SOL\n669\t        feeLamports: 500_000_000, // 0.5 SOL\n670\t        referrerEarnedLamports: 50_000_000, // 0.05 SOL — above threshold\n671\t        referrerRateBps: 1000,\n672\t        refereeRebateLamports: 50_000_000,\n673\t        refereeRebateRateBps: 1000,\n674\t      });\n675\t\n676\t      const token = await makeJwt(referrer);\n677\t      const res = await app.request(\"/referral/claim\", {\n678\t        method: \"POST\",\n679\t        headers: {\n680\t          \"Content-Type\": \"application/json\",\n681\t          Authorization: `Bearer ${token}`,\n682\t        },\n683\t      });\n684\t\n685\t      expect(res.status).toBe(202);\n686\t      const body = (await res.json()) as {\n687\t        claimId: string;\n688\t        amountLamports: string;\n689\t        status: string;\n690\t      };\n691\t      expect(body.claimId).toBeDefined();\n692\t      expect(body.amountLamports).toBe(\"50000000\");\n693\t      expect(body.status).toBe(\"pending\");\n694\t\n695\t      // Verify event was emitted\n696\t      const events =\n697\t        await rawSql`SELECT * FROM event_queue WHERE event_type = 'referral.claim_requested'`;\n698\t      expect(events.length).toBe(1);\n699\t    });\n700\t\n701\t    it(\"prevents double-claim by deducting pending balance\", async () => {\n702\t      // Insert earning\n703\t      await db.insertReferralEarning({\n704\t        referrerUserId,\n705\t        refereeUserId,\n706\t        referrerWallet: referrer,\n707\t        refereeWallet: referee,\n708\t        roundId: \"double-round\",\n709\t        gameType: \"flipyou\",\n710\t        wagerLamports: 10_000_000_000,\n711\t        feeLamports: 500_000_000,\n712\t        referrerEarnedLamports: 50_000_000,\n713\t        referrerRateBps: 1000,\n714\t        refereeRebateLamports: 50_000_000,\n715\t        refereeRebateRateBps: 1000,\n716\t      });\n717\t\n718\t      const token = await makeJwt(referrer);\n719\t\n720\t      // First claim succeeds\n721\t      const res1 = await app.request(\"/referral/claim\", {\n722\t        method: \"POST\",\n723\t        headers: {\n724\t          \"Content-Type\": \"application/json\",\n725\t          Authorization: `Bearer ${token}`,\n726\t        },\n727\t      });\n728\t      expect(res1.status).toBe(202);\n729\t\n730\t      // Second claim fails — balance consumed by pending claim\n731\t      const res2 = await app.request(\"/referral/claim\", {\n732\t        method: \"POST\",\n733\t        headers: {\n734\t          \"Content-Type\": \"application/json\",\n735\t          Authorization: `Bearer ${token}`,\n736\t        },\n737\t      });\n738\t      expect(res2.status).toBe(400);\n739\t      const body = (await res2.json()) as { error: { code: string } };\n740\t      expect(body.error.code).toBe(\"ZERO_BALANCE\");\n741\t    });\n742\t  });\n743\t\n744\t  // -----------------------------------------------------------------------\n745\t  // GET /referral/claim/:claimId — poll claim status\n746\t  // -----------------------------------------------------------------------\n747\t\n748\t  describe(\"GET /referral/claim/:claimId\", () => {\n749\t    it(\"returns claim status for the owner\", async () => {\n750\t      // Insert earning + create claim\n751\t      await db.insertReferralEarning({\n752\t        referrerUserId,\n753\t        refereeUserId,\n754\t        referrerWallet: referrer,\n755\t        refereeWallet: referee,\n756\t        roundId: \"poll-round\",\n757\t        gameType: \"flipyou\",\n758\t        wagerLamports: 10_000_000_000,\n759\t        feeLamports: 500_000_000,\n760\t        referrerEarnedLamports: 50_000_000,\n761\t        referrerRateBps: 1000,\n762\t        refereeRebateLamports: 50_000_000,\n763\t        refereeRebateRateBps: 1000,\n764\t      });\n765\t\n766\t      const token = await makeJwt(referrer);\n767\t      const claimRes = await app.request(\"/referral/claim\", {\n768\t        method: \"POST\",\n769\t        headers: {\n770\t          \"Content-Type\": \"application/json\",\n771\t          Authorization: `Bearer ${token}`,\n772\t        },\n773\t      });\n774\t      const claim = (await claimRes.json()) as { claimId: string };\n775\t\n776\t      // Poll status\n777\t      const res = await app.request(`/referral/claim/${claim.claimId}`, {\n778\t        method: \"GET\",\n779\t        headers: { Authorization: `Bearer ${token}` },\n780\t      });\n781\t\n782\t      expect(res.status).toBe(200);\n783\t      const body = (await res.json()) as {\n784\t        claimId: string;\n785\t        amountLamports: string;\n786\t        status: string;\n787\t      };\n788\t      expect(body.claimId).toBe(claim.claimId);\n789\t      expect(body.status).toBe(\"pending\");\n790\t    });\n791\t\n792\t    it(\"returns 404 for non-existent claim\", async () => {\n793\t      const token = await makeJwt(referrer);\n794\t      const res = await app.request(\n795\t        \"/referral/claim/00000000-0000-0000-0000-000000000000\",\n796\t        {\n797\t          method: \"GET\",\n798\t          headers: { Authorization: `Bearer ${token}` },\n799\t        },\n800\t      );\n801\t\n802\t      expect(res.status).toBe(404);\n803\t    });\n804\t\n805\t    it(\"returns 404 when another wallet tries to view a claim\", async () => {\n806\t      // Create earning + claim as referrer\n807\t      await db.insertReferralEarning({\n808\t        referrerUserId,\n809\t        refereeUserId,\n810\t        referrerWallet: referrer,\n811\t        refereeWallet: referee,\n812\t        roundId: \"auth-round\",\n813\t        gameType: \"flipyou\",\n814\t        wagerLamports: 10_000_000_000,\n815\t        feeLamports: 500_000_000,\n816\t        referrerEarnedLamports: 50_000_000,\n817\t        referrerRateBps: 1000,\n818\t        refereeRebateLamports: 50_000_000,\n819\t        refereeRebateRateBps: 1000,\n820\t      });\n821\t\n822\t      const referrerToken = await makeJwt(referrer);\n823\t      const claimRes = await app.request(\"/referral/claim\", {\n824\t        method: \"POST\",\n825\t        headers: {\n826\t          \"Content-Type\": \"application/json\",\n827\t          Authorization: `Bearer ${referrerToken}`,\n828\t        },\n829\t      });\n830\t      const claim = (await claimRes.json()) as { claimId: string };\n831\t\n832\t      // Try to view as referee (different wallet)\n833\t      const refereeToken = await makeJwt(referee);\n834\t      const res = await app.request(`/referral/claim/${claim.claimId}`, {\n835\t        method: \"GET\",\n836\t        headers: { Authorization: `Bearer ${refereeToken}` },\n837\t      });\n838\t\n839\t      expect(res.status).toBe(404);\n840\t    });\n841\t  });\n842\t\n843\t  // -----------------------------------------------------------------------\n844\t  // GET /referral/referrer — check referrer status\n845\t  // -----------------------------------------------------------------------\n846\t\n847\t  describe(\"GET /referral/referrer\", () => {\n848\t    it(\"returns 200 with null fields when not referred\", async () => {\n849\t      const token = await makeJwt(referee);\n850\t      const res = await app.request(\"/referral/referrer\", {\n851\t        method: \"GET\",\n852\t        headers: { Authorization: `Bearer ${token}` },\n853\t      });\n854\t\n855\t      expect(res.status).toBe(200);\n856\t      const body = (await res.json()) as {\n857\t        referrerUserId: string | null;\n858\t        referrerUsername: string | null;\n859\t        referrerCode: string | null;\n860\t        linkedAt: string | null;\n861\t      };\n862\t      expect(body.referrerUserId).toBeNull();\n863\t      expect(body.referrerUsername).toBeNull();\n864\t      expect(body.referrerCode).toBeNull();\n865\t      expect(body.linkedAt).toBeNull();\n866\t    });\n867\t\n868\t    it(\"returns referrer wallet after linking\", async () => {\n869\t      // Set up code + apply\n870\t      const referrerToken = await makeJwt(referrer);\n871\t      await app.request(\"/referral/code\", {\n872\t        method: \"POST\",\n873\t        ...json({ code: \"referrer-test\" }),\n874\t        headers: { ...json({}).headers, Authorization: `Bearer ${referrerToken}` },\n875\t      });\n876\t\n877\t      const refereeToken = await makeJwt(referee);\n878\t      await app.request(\"/referral/apply\", {\n879\t        method: \"POST\",\n880\t        ...json({ code: \"referrer-test\" }),\n881\t        headers: { ...json({}).headers, Authorization: `Bearer ${refereeToken}` },\n882\t      });\n883\t\n884\t      const res = await app.request(\"/referral/referrer\", {\n885\t        method: \"GET\",\n886\t        headers: { Authorization: `Bearer ${refereeToken}` },\n887\t      });\n888\t\n889\t      expect(res.status).toBe(200);\n890\t      const body = (await res.json()) as {\n891\t        referrerUserId: string;\n892\t        linkedAt: string;\n893\t      };\n894\t      expect(body.referrerUserId).toBe(referrerUserId);\n895\t      expect(body.linkedAt).toBeDefined();\n896\t    });\n897\t  });\n898\t\n899\t  // -----------------------------------------------------------------------\n900\t  // Auth — missing JWT\n901\t  // -----------------------------------------------------------------------\n902\t\n903\t  describe(\"Authentication\", () => {\n904\t    it(\"returns 401 for requests without JWT\", async () => {\n905\t      const res = await app.request(\"/referral/stats\", { method: \"GET\" });\n906\t      expect(res.status).toBe(401);\n907\t    });\n908\t  });\n909\t});\n910\t"}]},"parent_tool_use_id":null,"session_id":"eb7d01f2-3773-44f3-9eed-fc96d23e7071","uuid":"1b4792a1-6e25-4c36-aa91-cb3942f41337","timestamp":"2026-04-22T09:48:15.772Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/referral-routes.test.ts","content":"/* eslint-disable @typescript-eslint/no-explicit-any */\n/**\n * Referral route tests — set code, apply, stats, earnings, claim flows.\n *\n * Uses real Postgres (same pattern as auth-routes.test.ts) with TRUNCATE\n * between tests for isolation.\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport { SignJWT } from \"jose\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createReferralRoutes } from \"../routes/referral.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport type { Config } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-referral-tests\");\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  // Dev container: postgres listens on Unix socket only\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"taunt_bet_dev\",\n  });\n}\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\nasync function makeJwt(wallet: string): Promise<string> {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({})\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userIdFromWallet(wallet))\n    .setIssuedAt(now)\n    .setExpirationTime(now + 3600)\n    .sign(JWT_SECRET);\n}\n\nfunction json(body: Record<string, any>) {\n  return {\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify(body),\n  };\n}\n\nfunction userIdFromWallet(wallet: string) {\n  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n}\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"Referral routes\", () => {\n  let rawSql: ReturnType<typeof postgres>;\n  let db: Db;\n  let app: Hono;\n\n  const referrerKp = Keypair.generate();\n  const refereeKp = Keypair.generate();\n  const referrer = referrerKp.publicKey.toBase58();\n  const referee = refereeKp.publicKey.toBase58();\n  const referrerUserId = userIdFromWallet(referrer);\n  const refereeUserId = userIdFromWallet(referee);\n\n  const testConfig = {\n    referralDefaultRateBps: 1000,\n    referralMinClaimLamports: 10_000_000, // 0.01 SOL\n  } as Config;\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n    await rawSql`\n      DROP TABLE IF EXISTS referral_claims, referral_earnings, referral_links, referral_codes, referral_kol_rates CASCADE\n    `;\n    await rawSql`\n      CREATE TABLE referral_codes (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        user_id TEXT NOT NULL UNIQUE,\n        wallet TEXT NOT NULL UNIQUE,\n        code TEXT NOT NULL UNIQUE,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE referral_links (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        referrer_user_id TEXT NOT NULL,\n        referee_user_id TEXT NOT NULL UNIQUE,\n        referrer_wallet TEXT NOT NULL,\n        referee_wallet TEXT NOT NULL,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_links_referrer ON referral_links (referrer_user_id)\n    `;\n    await rawSql`\n      CREATE TABLE referral_earnings (\n        id BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        referrer_user_id TEXT NOT NULL,\n        referee_user_id TEXT NOT NULL,\n        referrer_wallet TEXT NOT NULL,\n        referee_wallet TEXT NOT NULL,\n        round_id TEXT NOT NULL,\n        game_type TEXT NOT NULL,\n        wager_lamports BIGINT NOT NULL,\n        fee_lamports BIGINT NOT NULL,\n        referrer_earned_lamports BIGINT NOT NULL,\n        referrer_rate_bps INTEGER NOT NULL,\n        referee_rebate_lamports BIGINT NOT NULL,\n        referee_rebate_rate_bps INTEGER NOT NULL,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        CONSTRAINT uq_referral_earnings_referee_round UNIQUE (referee_user_id, round_id)\n      )\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_earnings_referrer ON referral_earnings (referrer_user_id, created_at)\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_earnings_referee ON referral_earnings (referee_user_id, created_at)\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_earnings_round_id ON referral_earnings (round_id)\n    `;\n    await rawSql`\n      CREATE TABLE referral_claims (\n        id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n        user_id TEXT NOT NULL,\n        wallet TEXT NOT NULL,\n        amount_lamports BIGINT NOT NULL,\n        status TEXT NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'error', 'completed', 'failed')),\n        retry_count INTEGER NOT NULL DEFAULT 0,\n        tx_signature TEXT,\n        error TEXT,\n        requested_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        processed_at TIMESTAMPTZ\n      )\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_claims_user_id ON referral_claims (user_id, requested_at)\n    `;\n    await rawSql`\n      CREATE INDEX idx_referral_claims_status ON referral_claims (status) WHERE status IN ('pending', 'processing')\n    `;\n    await rawSql`\n      CREATE UNIQUE INDEX idx_referral_claims_user_active ON referral_claims (user_id) WHERE status IN ('pending', 'processing', 'error')\n    `;\n    await rawSql`\n      CREATE TABLE referral_kol_rates (\n        user_id TEXT PRIMARY KEY,\n        wallet TEXT NOT NULL UNIQUE,\n        rate_bps INTEGER NOT NULL,\n        set_by TEXT NOT NULL,\n        created_at TIMESTAMPTZ NOT NULL DEFAULT now(),\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n  });\n\n  afterAll(async () => {\n    if (db) await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, event_queue RESTART IDENTITY CASCADE`;\n    // Clean + recreate profiles for test wallets — routes resolve wallet\n    // from profile via db.getProfileByUserId(userId).\n    await rawSql`DELETE FROM player_profiles WHERE user_id IN (${referrerUserId}, ${refereeUserId})`;\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${referrerUserId}, ${referrer}, ${\"ref-er-\" + Date.now()}),\n             (${refereeUserId}, ${referee}, ${\"ref-ee-\" + Date.now()})\n    `;\n\n    db = createDb(DATABASE_URL, rawSql);\n\n    app = new Hono();\n    app.use(\n      \"/referral/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n    );\n    app.route(\n      \"/referral\",\n      createReferralRoutes({ db, sql: rawSql, config: testConfig }),\n    );\n  });\n\n  // -----------------------------------------------------------------------\n  // POST /referral/code — set custom code\n  // -----------------------------------------------------------------------\n\n  describe(\"POST /referral/code\", () => {\n    it(\"sets a valid custom code and returns code + url\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"my-code-123\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as { code: string };\n      expect(body.code).toBe(\"my-code-123\");\n    });\n\n    it(\"rejects code shorter than 3 chars\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"ab\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(400);\n      const body = (await res.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"INVALID_CODE\");\n    });\n\n    it(\"rejects code longer than 16 chars\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"abcdefghijklmnopq\" }), // 17 chars\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(400);\n    });\n\n    it(\"rejects code with uppercase or special chars\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"My_Code!\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(400);\n    });\n\n    it(\"returns 409 when code is taken by another wallet\", async () => {\n      // First wallet takes the code\n      const token1 = await makeJwt(referrer);\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"taken-code\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token1}` },\n      });\n\n      // Second wallet tries the same code\n      const token2 = await makeJwt(referee);\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"taken-code\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token2}` },\n      });\n\n      expect(res.status).toBe(409);\n      const body = (await res.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"CODE_TAKEN\");\n    });\n\n    it(\"rejects changing an already-set code (codes are permanent)\", async () => {\n      const token = await makeJwt(referrer);\n\n      // Set initial code\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"first-code\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      // Attempt to change — must be rejected\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"second-code\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(409);\n      const body = (await res.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"CODE_ALREADY_SET\");\n    });\n\n    it(\"rejects missing body\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(400);\n      const body = (await res.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"INVALID_CODE\");\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /referral/code — retrieve current code\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /referral/code\", () => {\n    it(\"returns existing code for wallet\", async () => {\n      const token = await makeJwt(referrer);\n\n      // Set code first\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"get-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      const res = await app.request(\"/referral/code\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as { code: string };\n      expect(body.code).toBe(\"get-test\");\n    });\n\n    it(\"returns 200 with null code when not set\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/code\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as { code: string | null };\n      expect(body.code).toBeNull();\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // POST /referral/apply — link referee to referrer\n  // -----------------------------------------------------------------------\n\n  describe(\"POST /referral/apply\", () => {\n    beforeEach(async () => {\n      // Set up a referral code for the referrer\n      const token = await makeJwt(referrer);\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"apply-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n    });\n\n    it(\"links referee to referrer via code\", async () => {\n      const token = await makeJwt(referee);\n      const res = await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"apply-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        referrerUserId: string;\n        benefit: string;\n      };\n      expect(body.referrerUserId).toBe(referrerUserId);\n      expect(body.benefit).toContain(\"10%\");\n    });\n\n    it(\"rejects self-referral\", async () => {\n      const token = await makeJwt(referrer); // referrer applying their own code\n      const res = await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"apply-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(400);\n      const body = (await res.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"SELF_REFERRAL\");\n    });\n\n    it(\"returns 409 when already linked to a referrer\", async () => {\n      const token = await makeJwt(referee);\n\n      // First apply succeeds\n      await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"apply-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      // Set up a second referrer code (needs a profile first)\n      const other = Keypair.generate().publicKey.toBase58();\n      const otherUserId = userIdFromWallet(other);\n      await rawSql`\n        INSERT INTO player_profiles (user_id, wallet, username)\n        VALUES (${otherUserId}, ${other}, ${\"test-other-\" + Date.now()})\n        ON CONFLICT (user_id) DO NOTHING\n      `;\n      const otherToken = await makeJwt(other);\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"other-code\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${otherToken}` },\n      });\n\n      // Second apply fails\n      const res = await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"other-code\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(409);\n      const body = (await res.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"ALREADY_LINKED\");\n    });\n\n    it(\"returns 404 for non-existent code\", async () => {\n      const token = await makeJwt(referee);\n      const res = await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"nonexistent\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(404);\n      const body = (await res.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"CODE_NOT_FOUND\");\n    });\n\n    it(\"rejects empty code\", async () => {\n      const token = await makeJwt(referee);\n      const res = await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(400);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /referral/stats — summary stats\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /referral/stats\", () => {\n    it(\"returns zeroed stats for wallet with no referrals\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/stats\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as Record<string, any>;\n      expect(body.referredCount).toBe(0);\n      expect(body.activeCount).toBe(0);\n      expect(body.totalVolumeLamports).toBe(\"0\");\n      expect(body.totalEarnedLamports).toBe(\"0\");\n      expect(body.pendingLamports).toBe(\"0\");\n    });\n\n    it(\"reflects referred count after linking\", async () => {\n      // Set up referrer code + link a referee\n      const referrerToken = await makeJwt(referrer);\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"stats-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${referrerToken}` },\n      });\n\n      const refereeToken = await makeJwt(referee);\n      await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"stats-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${refereeToken}` },\n      });\n\n      const res = await app.request(\"/referral/stats\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${referrerToken}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as { referredCount: number };\n      expect(body.referredCount).toBe(1);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /referral/earnings — paginated earnings\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /referral/earnings\", () => {\n    it(\"returns empty items when no earnings exist\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/earnings\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        items: unknown[];\n        pagination: { page: number; totalPages: number };\n      };\n      expect(body.items).toHaveLength(0);\n      expect(body.pagination.page).toBe(1);\n      expect(body.pagination.totalPages).toBe(1); // min 1 page even when empty\n    });\n\n    it(\"returns earnings after inserting one\", async () => {\n      // Insert an earning directly via DB\n      await db.insertReferralEarning({\n        referrerUserId,\n        refereeUserId,\n        referrerWallet: referrer,\n        refereeWallet: referee,\n        roundId: \"test-round-001\",\n        gameType: \"flipyou\",\n        wagerLamports: 1_000_000_000,\n        feeLamports: 50_000_000,\n        referrerEarnedLamports: 5_000_000,\n        referrerRateBps: 1000,\n        refereeRebateLamports: 5_000_000,\n        refereeRebateRateBps: 1000,\n      });\n\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/earnings\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        items: Array<{\n          roundId: string;\n          gameType: string;\n          refereeUserId: string;\n          wagerLamports: string;\n          earnedLamports: string;\n          createdAt: string;\n        }>;\n        pagination: { page: number; totalPages: number };\n      };\n      expect(body.items).toHaveLength(1);\n      expect(body.items[0]!.roundId).toBe(\"test-round-001\");\n      expect(body.items[0]!.gameType).toBe(\"flipyou\");\n      expect(body.items[0]!.refereeUserId).toBe(refereeUserId);\n      expect(body.items[0]!.wagerLamports).toBe(\"1000000000\");\n      expect(body.items[0]!.earnedLamports).toBe(\"5000000\");\n      expect(body.pagination.totalPages).toBe(1);\n    });\n\n    it(\"respects page and limit query params\", async () => {\n      // Insert 3 earnings\n      for (let i = 1; i <= 3; i++) {\n        await db.insertReferralEarning({\n          referrerUserId,\n          refereeUserId,\n          referrerWallet: referrer,\n          refereeWallet: referee,\n          roundId: `round-${i}`,\n          gameType: \"flipyou\",\n          wagerLamports: 1_000_000_000,\n          feeLamports: 50_000_000,\n          referrerEarnedLamports: 5_000_000,\n          referrerRateBps: 1000,\n          refereeRebateLamports: 5_000_000,\n          refereeRebateRateBps: 1000,\n        });\n      }\n\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/earnings?page=1&limit=2\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        items: unknown[];\n        pagination: { page: number; totalPages: number };\n      };\n      expect(body.items).toHaveLength(2);\n      expect(body.pagination.totalPages).toBe(2);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // POST /referral/claim — claim flow\n  // -----------------------------------------------------------------------\n\n  describe(\"POST /referral/claim\", () => {\n    it(\"rejects claim with zero balance\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n\n      expect(res.status).toBe(400);\n      const body = (await res.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"ZERO_BALANCE\");\n    });\n\n    it(\"rejects claim below minimum threshold\", async () => {\n      // Insert a small earning (below 0.01 SOL threshold)\n      await db.insertReferralEarning({\n        referrerUserId,\n        refereeUserId,\n        referrerWallet: referrer,\n        refereeWallet: referee,\n        roundId: \"small-round\",\n        gameType: \"flipyou\",\n        wagerLamports: 100_000_000, // 0.1 SOL\n        feeLamports: 5_000_000, // 0.005 SOL\n        referrerEarnedLamports: 500_000, // 0.0005 SOL — below 0.01 threshold\n        referrerRateBps: 1000,\n        refereeRebateLamports: 500_000,\n        refereeRebateRateBps: 1000,\n      });\n\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n\n      expect(res.status).toBe(400);\n      const body = (await res.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"BELOW_THRESHOLD\");\n    });\n\n    it(\"creates a pending claim for valid balance\", async () => {\n      // Insert a large enough earning\n      await db.insertReferralEarning({\n        referrerUserId,\n        refereeUserId,\n        referrerWallet: referrer,\n        refereeWallet: referee,\n        roundId: \"big-round\",\n        gameType: \"flipyou\",\n        wagerLamports: 10_000_000_000, // 10 SOL\n        feeLamports: 500_000_000, // 0.5 SOL\n        referrerEarnedLamports: 50_000_000, // 0.05 SOL — above threshold\n        referrerRateBps: 1000,\n        refereeRebateLamports: 50_000_000,\n        refereeRebateRateBps: 1000,\n      });\n\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n\n      expect(res.status).toBe(202);\n      const body = (await res.json()) as {\n        claimId: string;\n        amountLamports: string;\n        status: string;\n      };\n      expect(body.claimId).toBeDefined();\n      expect(body.amountLamports).toBe(\"50000000\");\n      expect(body.status).toBe(\"pending\");\n\n      // Verify event was emitted\n      const events =\n        await rawSql`SELECT * FROM event_queue WHERE event_type = 'referral.claim_requested'`;\n      expect(events.length).toBe(1);\n    });\n\n    it(\"prevents double-claim by deducting pending balance\", async () => {\n      // Insert earning\n      await db.insertReferralEarning({\n        referrerUserId,\n        refereeUserId,\n        referrerWallet: referrer,\n        refereeWallet: referee,\n        roundId: \"double-round\",\n        gameType: \"flipyou\",\n        wagerLamports: 10_000_000_000,\n        feeLamports: 500_000_000,\n        referrerEarnedLamports: 50_000_000,\n        referrerRateBps: 1000,\n        refereeRebateLamports: 50_000_000,\n        refereeRebateRateBps: 1000,\n      });\n\n      const token = await makeJwt(referrer);\n\n      // First claim succeeds\n      const res1 = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n      expect(res1.status).toBe(202);\n\n      // Second claim fails — balance consumed by pending claim\n      const res2 = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n      expect(res2.status).toBe(400);\n      const body = (await res2.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"ZERO_BALANCE\");\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /referral/claim/:claimId — poll claim status\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /referral/claim/:claimId\", () => {\n    it(\"returns claim status for the owner\", async () => {\n      // Insert earning + create claim\n      await db.insertReferralEarning({\n        referrerUserId,\n        refereeUserId,\n        referrerWallet: referrer,\n        refereeWallet: referee,\n        roundId: \"poll-round\",\n        gameType: \"flipyou\",\n        wagerLamports: 10_000_000_000,\n        feeLamports: 500_000_000,\n        referrerEarnedLamports: 50_000_000,\n        referrerRateBps: 1000,\n        refereeRebateLamports: 50_000_000,\n        refereeRebateRateBps: 1000,\n      });\n\n      const token = await makeJwt(referrer);\n      const claimRes = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n      const claim = (await claimRes.json()) as { claimId: string };\n\n      // Poll status\n      const res = await app.request(`/referral/claim/${claim.claimId}`, {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        claimId: string;\n        amountLamports: string;\n        status: string;\n      };\n      expect(body.claimId).toBe(claim.claimId);\n      expect(body.status).toBe(\"pending\");\n    });\n\n    it(\"returns 404 for non-existent claim\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\n        \"/referral/claim/00000000-0000-0000-0000-000000000000\",\n        {\n          method: \"GET\",\n          headers: { Authorization: `Bearer ${token}` },\n        },\n      );\n\n      expect(res.status).toBe(404);\n    });\n\n    it(\"returns 404 when another wallet tries to view a claim\", async () => {\n      // Create earning + claim as referrer\n      await db.insertReferralEarning({\n        referrerUserId,\n        refereeUserId,\n        referrerWallet: referrer,\n        refereeWallet: referee,\n        roundId: \"auth-round\",\n        gameType: \"flipyou\",\n        wagerLamports: 10_000_000_000,\n        feeLamports: 500_000_000,\n        referrerEarnedLamports: 50_000_000,\n        referrerRateBps: 1000,\n        refereeRebateLamports: 50_000_000,\n        refereeRebateRateBps: 1000,\n      });\n\n      const referrerToken = await makeJwt(referrer);\n      const claimRes = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${referrerToken}`,\n        },\n      });\n      const claim = (await claimRes.json()) as { claimId: string };\n\n      // Try to view as referee (different wallet)\n      const refereeToken = await makeJwt(referee);\n      const res = await app.request(`/referral/claim/${claim.claimId}`, {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${refereeToken}` },\n      });\n\n      expect(res.status).toBe(404);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /referral/referrer — check referrer status\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /referral/referrer\", () => {\n    it(\"returns 200 with null fields when not referred\", async () => {\n      const token = await makeJwt(referee);\n      const res = await app.request(\"/referral/referrer\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        referrerUserId: string | null;\n        referrerUsername: string | null;\n        referrerCode: string | null;\n        linkedAt: string | null;\n      };\n      expect(body.referrerUserId).toBeNull();\n      expect(body.referrerUsername).toBeNull();\n      expect(body.referrerCode).toBeNull();\n      expect(body.linkedAt).toBeNull();\n    });\n\n    it(\"returns referrer wallet after linking\", async () => {\n      // Set up code + apply\n      const referrerToken = await makeJwt(referrer);\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"referrer-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${referrerToken}` },\n      });\n\n      const refereeToken = await makeJwt(referee);\n      await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"referrer-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${refereeToken}` },\n      });\n\n      const res = await app.request(\"/referral/referrer\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${refereeToken}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        referrerUserId: string;\n        linkedAt: string;\n      };\n      expect(body.referrerUserId).toBe(referrerUserId);\n      expect(body.linkedAt).toBeDefined();\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // Auth — missing JWT\n  // -----------------------------------------------------------------------\n\n  describe(\"Authentication\", () => {\n    it(\"returns 401 for requests without JWT\", async () => {\n      const res = await app.request(\"/referral/stats\", { method: \"GET\" });\n      expect(res.status).toBe(401);\n    });\n  });\n});\n","numLines":910,"startLine":1,"totalLines":910}}}
