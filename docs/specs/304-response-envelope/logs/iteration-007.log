{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AUJtDDtENHmYjQvUEuwNDc","type":"tool_result","content":"120\t  // -----------------------------------------------------------------------\n121\t\n122\t  it(\"returns a challenge with nonce and message\", async () => {\n123\t    const wallet = creatorKeypair.publicKey.toBase58();\n124\t    const res = await app.request(\"/auth/challenge\", {\n125\t      method: \"POST\",\n126\t      headers: { \"Content-Type\": \"application/json\" },\n127\t      body: JSON.stringify({ wallet }),\n128\t    });\n129\t\n130\t    expect(res.status).toBe(200);\n131\t    const body = (await res.json()) as {\n132\t      ok: true;\n133\t      data: { nonce: string; message: string; expiresAt: string };\n134\t    };\n135\t    expect(body.ok).toBe(true);\n136\t    const json = body.data;\n137\t    expect(json.nonce).toBeDefined();\n138\t    expect(json.nonce.length).toBe(64); // 32 bytes hex\n139\t    expect(json.message).toContain(\"Sign this message to create your Taunt BET account.\");\n140\t    expect(json.message).toContain(wallet);\n141\t    expect(json.message).toContain(\"Solana Devnet\");\n142\t    expect(json.expiresAt).toBeDefined();\n143\t  });\n144\t\n145\t  it(\"rejects challenge with missing wallet\", async () => {\n146\t    const res = await app.request(\"/auth/challenge\", {\n147\t      method: \"POST\",\n148\t      headers: { \"Content-Type\": \"application/json\" },\n149\t      body: JSON.stringify({}),\n150\t    });\n151\t    expect(res.status).toBe(422);\n152\t  });\n153\t\n154\t  it(\"rejects challenge with missing body\", async () => {\n155\t    const res = await app.request(\"/auth/challenge\", {\n156\t      method: \"POST\",\n157\t    });\n158\t\n159\t    expect(res.status).toBe(422);\n160\t    const body = (await res.json()) as {\n161\t      ok: false;\n162\t      error: { code: string; message: string };\n163\t    };\n164\t    expect(body.ok).toBe(false);\n165\t    expect(body.error.code).toBe(\"VALIDATION_FAILED\");\n166\t    expect(body.error.message).toBe(\"Invalid request\");\n167\t  });\n168\t\n169\t  // -----------------------------------------------------------------------\n170\t  // Full flow: challenge → verify → refresh → logout\n171\t  // -----------------------------------------------------------------------\n172\t\n173\t  it(\"full auth flow: challenge → verify → refresh → logout\", async () => {\n174\t    const wallet = creatorKeypair.publicKey.toBase58();\n175\t\n176\t    // 1. Request challenge\n177\t    const challengeRes = await app.request(\"/auth/challenge\", {\n178\t      method: \"POST\",\n179\t      headers: { \"Content-Type\": \"application/json\" },"}]},"parent_tool_use_id":null,"session_id":"eb7d01f2-3773-44f3-9eed-fc96d23e7071","uuid":"40008d49-d6ba-465e-8628-0b5bef7e383f","timestamp":"2026-04-22T09:49:55.267Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/auth-routes.test.ts","content":"  // -----------------------------------------------------------------------\n\n  it(\"returns a challenge with nonce and message\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const res = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as {\n      ok: true;\n      data: { nonce: string; message: string; expiresAt: string };\n    };\n    expect(body.ok).toBe(true);\n    const json = body.data;\n    expect(json.nonce).toBeDefined();\n    expect(json.nonce.length).toBe(64); // 32 bytes hex\n    expect(json.message).toContain(\"Sign this message to create your Taunt BET account.\");\n    expect(json.message).toContain(wallet);\n    expect(json.message).toContain(\"Solana Devnet\");\n    expect(json.expiresAt).toBeDefined();\n  });\n\n  it(\"rejects challenge with missing wallet\", async () => {\n    const res = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({}),\n    });\n    expect(res.status).toBe(422);\n  });\n\n  it(\"rejects challenge with missing body\", async () => {\n    const res = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n    });\n\n    expect(res.status).toBe(422);\n    const body = (await res.json()) as {\n      ok: false;\n      error: { code: string; message: string };\n    };\n    expect(body.ok).toBe(false);\n    expect(body.error.code).toBe(\"VALIDATION_FAILED\");\n    expect(body.error.message).toBe(\"Invalid request\");\n  });\n\n  // -----------------------------------------------------------------------\n  // Full flow: challenge → verify → refresh → logout\n  // -----------------------------------------------------------------------\n\n  it(\"full auth flow: challenge → verify → refresh → logout\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n\n    // 1. Request challenge\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },","numLines":60,"startLine":120,"totalLines":414}}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_015ocaX2TyotKEL1zVbQEg76","type":"message","role":"assistant","content":[{"type":"text","text":"Now let me rewrite the referral.ts route file."}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1126,"cache_read_input_tokens":121489,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1126},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"eb7d01f2-3773-44f3-9eed-fc96d23e7071","uuid":"f393ecc3-c698-4041-9241-50e4a990d48d"}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_015ocaX2TyotKEL1zVbQEg76","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_013zeLAJ2K2SUTSXE5exiGvB","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/src/routes/referral.ts","content":"/**\n * Referral routes — code management, linking, stats, earnings, and claims.\n *\n * WAITLIST-CONTRACT: the waitlist calls POST/GET /code, POST /apply,\n * GET /referrer, GET /stats, GET /referrals. /earnings and /claim are NOT\n * consumed by waitlist. Request/response shape for the consumed set is\n * pinned in `__tests__/waitlist-contract.test.ts`; keep\n * `waitlist/src/lib/referral-api.ts` in lockstep.\n */\n\nimport { createRoute, z } from \"@hono/zod-openapi\";\nimport type postgres from \"postgres\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport type { Config } from \"../config.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport {\n  ApplyReferralCodeBodySchema,\n  ClaimResponseSchema,\n  CodeResponseSchema,\n  MaybeCodeResponseSchema,\n  ReferralApplyResponseSchema,\n  ReferralCodeBodySchema,\n  ReferralListResponseSchema,\n  ReferralReferrerResponseSchema,\n  ReferralStatsSchema,\n} from \"../contracts/validators.js\";\nimport { logger } from \"../logger.js\";\nimport { emitEvent } from \"../queue/emit-event.js\";\nimport { EventTypes } from \"../queue/event-types.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface ReferralRoutesDeps {\n  db: Db;\n  sql: postgres.Sql;\n  config: Config;\n}\n\nconst EarningsResponseSchema = z.object({\n  items: z.array(\n    z.object({\n      roundId: z.string(),\n      gameType: z.string(),\n      refereeUserId: z.string(),\n      refereeUsername: z.string(),\n      wagerLamports: z.string(),\n      earnedLamports: z.string(),\n      createdAt: z.string().datetime(),\n    }),\n  ),\n  pagination: z.object({\n    page: z.number().int(),\n    totalPages: z.number().int(),\n  }),\n});\n\nexport function createReferralRoutes(deps: ReferralRoutesDeps) {\n  const { db, sql, config } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // ── POST /code — set the player's referral code (permanent) ────────────\n\n  const setCodeRoute = createRoute({\n    method: \"post\",\n    path: \"/code\",\n    tags: [\"Referral\"],\n    summary: \"Set referral code (permanent)\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      body: {\n        required: true,\n        content: { \"application/json\": { schema: ReferralCodeBodySchema } },\n      },\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: envelope(CodeResponseSchema) } },\n        description: \"Code set\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Profile not found\",\n      },\n      409: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Code already set or taken\",\n      },\n      422: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Invalid request body or code format\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to set referral code\",\n      },\n    },\n  });\n\n  app.openapi(setCodeRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");\n    }\n    const wallet = profile.wallet;\n\n    const { code } = c.req.valid(\"json\");\n\n    // Check if the user already has a code — codes are permanent\n    const ownCode = await db.getReferralCodeByUserId(userId);\n    if (ownCode) {\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.CODE_ALREADY_SET,\n        \"You already have a referral code. Codes cannot be changed.\",\n        { retryable: false },\n      );\n    }\n\n    // Check if this code is already taken by another user\n    const existing = await db.getReferralCodeByCode(code);\n    if (existing && existing.user_id !== userId) {\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.CODE_TAKEN,\n        \"This referral code is already in use\",\n        { retryable: false },\n      );\n    }\n\n    try {\n      const result = await db.insertReferralCode(userId, wallet, code);\n      logger.info(\"Referral code set\", { userId, wallet, code: result.code });\n      return ok(c, { code: result.code });\n    } catch (insertError) {\n      // Handle race condition: another wallet grabbed the code between check and insert\n      const msg =\n        insertError instanceof Error ? insertError.message : String(insertError);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return err(\n          c,\n          409,\n          API_ERROR_CODES.CODE_TAKEN,\n          \"This referral code is already in use\",\n          { retryable: false },\n        );\n      }\n      logger.error(\"Failed to set referral code\", {\n        err: String(insertError),\n        userId,\n        wallet,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to set referral code\",\n      );\n    }\n  }, (result, c) => {\n    if (result.success) return;\n    return err(\n      c,\n      422,\n      API_ERROR_CODES.INVALID_CODE,\n      \"Referral code must be 3-16 lowercase letters, numbers, or hyphens.\",\n      { retryable: false, details: result.error.issues },\n    );\n  });\n\n  // ── POST /apply — link the authenticated player to a referrer ──────────\n\n  const applyRoute = createRoute({\n    method: \"post\",\n    path: \"/apply\",\n    tags: [\"Referral\"],\n    summary: \"Apply a referral code (link to referrer)\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      body: {\n        required: true,\n        content: { \"application/json\": { schema: ApplyReferralCodeBodySchema } },\n      },\n    },\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(ReferralApplyResponseSchema) },\n        },\n        description: \"Linked to referrer\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Profile or code not found\",\n      },\n      409: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Self-referral or already linked to a referrer\",\n      },\n      422: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Invalid request body or code format\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to apply referral code\",\n      },\n    },\n  });\n\n  app.openapi(applyRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");\n    }\n    const wallet = profile.wallet;\n\n    const { code } = c.req.valid(\"json\");\n\n    // Look up the referral code to find the referrer\n    const codeRow = await db.getReferralCodeByCode(code);\n    if (!codeRow) {\n      return err(\n        c,\n        404,\n        API_ERROR_CODES.CODE_NOT_FOUND,\n        \"Referral code does not exist\",\n        { retryable: false },\n      );\n    }\n\n    // Self-referral check\n    if (codeRow.user_id === userId) {\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.SELF_REFERRAL,\n        \"You cannot use your own referral code\",\n        { retryable: false },\n      );\n    }\n\n    // Check if the player already has a referrer\n    const existingLink = await db.getReferralLinkByRefereeUserId(userId);\n    if (existingLink) {\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.ALREADY_LINKED,\n        \"You are already linked to a referrer\",\n        { retryable: false },\n      );\n    }\n\n    try {\n      await db.insertReferralLink({\n        referrerUserId: codeRow.user_id,\n        refereeUserId: userId,\n        referrerWallet: codeRow.wallet,\n        refereeWallet: wallet,\n      });\n      logger.info(\"Referral link created\", {\n        referrerUserId: codeRow.user_id,\n        refereeUserId: userId,\n        code,\n      });\n      return ok(c, {\n        referrerUserId: codeRow.user_id,\n        benefit: \"10% fee rebate on all games\",\n      });\n    } catch (insertError) {\n      // Handle race condition: another request linked this referee between check and insert\n      const msg =\n        insertError instanceof Error ? insertError.message : String(insertError);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return err(\n          c,\n          409,\n          API_ERROR_CODES.ALREADY_LINKED,\n          \"You are already linked to a referrer\",\n          { retryable: false },\n        );\n      }\n      logger.error(\"Failed to create referral link\", {\n        err: String(insertError),\n        userId,\n        wallet,\n        code,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to apply referral code\",\n      );\n    }\n  }, (result, c) => {\n    if (result.success) return;\n    return err(\n      c,\n      422,\n      API_ERROR_CODES.INVALID_CODE,\n      \"Referral code must be 3-16 lowercase letters, numbers, or hyphens.\",\n      { retryable: false, details: result.error.issues },\n    );\n  });\n\n  // ── GET /code — return the authenticated player's current referral code ─\n\n  const getCodeRoute = createRoute({\n    method: \"get\",\n    path: \"/code\",\n    tags: [\"Referral\"],\n    summary: \"Get own referral code\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(MaybeCodeResponseSchema) },\n        },\n        description: \"Code (null if not set)\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n    },\n  });\n\n  app.openapi(getCodeRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    const row = await db.getReferralCodeByUserId(userId);\n    return ok(c, { code: row?.code ?? null });\n  });\n\n  // ── GET /referrer — check if the authenticated player has a referrer ────\n\n  const referrerRoute = createRoute({\n    method: \"get\",\n    path: \"/referrer\",\n    tags: [\"Referral\"],\n    summary: \"Get own referrer info\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(ReferralReferrerResponseSchema) },\n        },\n        description: \"Referrer info (all fields null if not linked)\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch referrer\",\n      },\n    },\n  });\n\n  app.openapi(referrerRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    try {\n      const link = await db.getReferralLinkByRefereeUserId(userId);\n      if (!link) {\n        return ok(c, {\n          referrerUserId: null,\n          referrerUsername: null,\n          referrerCode: null,\n          linkedAt: null,\n        });\n      }\n\n      // Look up referrer's username and code for display\n      const [referrerProfile, referrerCode] = await Promise.all([\n        db.getProfileByUserId(link.referrer_user_id),\n        db.getReferralCodeByUserId(link.referrer_user_id),\n      ]);\n\n      return ok(c, {\n        referrerUserId: link.referrer_user_id,\n        referrerUsername: referrerProfile?.username ?? link.referrer_user_id,\n        referrerCode: referrerCode?.code ?? null,\n        linkedAt: link.created_at.toISOString(),\n      });\n    } catch (fetchError) {\n      logger.error(\"Failed to fetch referrer\", {\n        err: String(fetchError),\n        userId,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch referrer\",\n      );\n    }\n  });\n\n  // ── GET /stats — referral summary stats for authenticated user ──────────\n\n  const statsRoute = createRoute({\n    method: \"get\",\n    path: \"/stats\",\n    tags: [\"Referral\"],\n    summary: \"Get referral stats\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(ReferralStatsSchema) },\n        },\n        description: \"Referral statistics\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch referral stats\",\n      },\n    },\n  });\n\n  app.openapi(statsRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    try {\n      const stats = await db.getReferralStatsByUserId(userId);\n      return ok(c, {\n        referredCount: stats.referred_count,\n        activeCount: stats.active_count,\n        totalVolumeLamports: stats.total_volume_lamports,\n        totalEarnedLamports: stats.total_earned_lamports,\n        totalRebateLamports: stats.total_rebate_lamports,\n        pendingLamports: stats.pending_lamports,\n      });\n    } catch (fetchError) {\n      logger.error(\"Failed to fetch referral stats\", {\n        err: String(fetchError),\n        userId,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch referral stats\",\n      );\n    }\n  });\n\n  // ── GET /referrals — unique referred users (last 10) ────────────────────\n\n  const referralsRoute = createRoute({\n    method: \"get\",\n    path: \"/referrals\",\n    tags: [\"Referral\"],\n    summary: \"List referred users (last 10)\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(ReferralListResponseSchema) },\n        },\n        description: \"Referred users\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch referrals\",\n      },\n    },\n  });\n\n  app.openapi(referralsRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    try {\n      const links = await db.getReferralLinksByReferrerUserId(userId);\n      // Return last 10 unique referees with usernames, sorted by most recent first\n      const recent = links.slice(0, 10);\n      const profiles = await Promise.all(\n        recent.map((l) => db.getProfileByUserId(l.referee_user_id)),\n      );\n      const items = recent.map((l, i) => ({\n        refereeUserId: l.referee_user_id,\n        refereeUsername: profiles[i]?.username ?? l.referee_user_id,\n        createdAt: l.created_at.toISOString(),\n      }));\n      return ok(c, { items });\n    } catch (fetchError) {\n      logger.error(\"Failed to fetch referrals\", {\n        err: String(fetchError),\n        userId,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch referrals\",\n      );\n    }\n  });\n\n  // ── GET /earnings — paginated per-game earnings log ─────────────────────\n\n  const earningsRoute = createRoute({\n    method: \"get\",\n    path: \"/earnings\",\n    tags: [\"Referral\"],\n    summary: \"Get paginated referral earnings\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      query: z.object({\n        page: z.coerce.number().int().min(1).default(1).optional(),\n        limit: z.coerce.number().int().min(1).max(100).default(20).optional(),\n      }),\n    },\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(EarningsResponseSchema) },\n        },\n        description: \"Earnings list\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      422: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Invalid parameters\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch referral earnings\",\n      },\n    },\n  });\n\n  app.openapi(earningsRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    const query = c.req.valid(\"query\");\n    const page = query.page ?? 1;\n    const limit = query.limit ?? 20;\n\n    try {\n      const result = await db.getReferralEarningsByUserId(userId, page, limit);\n      // Resolve usernames for referees (batch-dedup by userId)\n      const uniqueRefereeIds = [...new Set(result.items.map((e) => e.referee_user_id))];\n      const refereeProfiles = await Promise.all(\n        uniqueRefereeIds.map((id) => db.getProfileByUserId(id)),\n      );\n      const usernameMap = new Map(\n        uniqueRefereeIds.map((id, i) => [id, refereeProfiles[i]?.username ?? id]),\n      );\n      return ok(c, {\n        items: result.items.map((e) => ({\n          roundId: e.round_id,\n          gameType: e.game_type,\n          refereeUserId: e.referee_user_id,\n          refereeUsername: usernameMap.get(e.referee_user_id) ?? e.referee_user_id,\n          wagerLamports: String(e.wager_lamports),\n          earnedLamports: String(e.referrer_earned_lamports),\n          createdAt: e.created_at.toISOString(),\n        })),\n        pagination: {\n          page,\n          totalPages: result.totalPages,\n        },\n      });\n    } catch (fetchError) {\n      logger.error(\"Failed to fetch referral earnings\", {\n        err: String(fetchError),\n        userId,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch referral earnings\",\n      );\n    }\n  });\n\n  // ── POST /claim — request payout of pending referral earnings ───────────\n\n  const claimRoute = createRoute({\n    method: \"post\",\n    path: \"/claim\",\n    tags: [\"Referral\"],\n    summary: \"Request payout of pending referral earnings\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      202: {\n        content: {\n          \"application/json\": { schema: envelope(ClaimResponseSchema) },\n        },\n        description: \"Claim queued\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Profile not found\",\n      },\n      422: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Zero balance or below threshold\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to create referral claim\",\n      },\n    },\n  });\n\n  app.openapi(claimRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");\n    }\n    const wallet = profile.wallet;\n\n    try {\n      // Snapshot pending balance\n      const pendingStr = await db.getPendingBalanceByUserId(userId);\n      const pendingLamports = BigInt(pendingStr);\n\n      if (pendingLamports <= 0n) {\n        return err(\n          c,\n          422,\n          API_ERROR_CODES.ZERO_BALANCE,\n          \"No pending earnings to claim\",\n          { retryable: false },\n        );\n      }\n\n      if (pendingLamports < BigInt(config.referralMinClaimLamports)) {\n        return err(\n          c,\n          422,\n          API_ERROR_CODES.BELOW_THRESHOLD,\n          `Minimum claim amount is ${config.referralMinClaimLamports} lamports (${(config.referralMinClaimLamports / 1e9).toFixed(2)} SOL)`,\n          { retryable: false },\n        );\n      }\n\n      // Atomically insert claim row + emit queue event\n      const claim = await sql.begin(async (tx) => {\n        const rows = await (tx as unknown as postgres.Sql)<\n          {\n            id: string;\n            user_id: string;\n            wallet: string;\n            amount_lamports: string;\n            status: string;\n          }[]\n        >`\n          INSERT INTO referral_claims (user_id, wallet, amount_lamports, status)\n          VALUES (${userId}, ${wallet}, ${pendingStr}, 'pending')\n          RETURNING id, user_id, wallet, amount_lamports, status\n        `;\n        const row = rows[0]!;\n\n        await emitEvent(\n          tx as unknown as postgres.Sql,\n          EventTypes.REFERRAL_CLAIM_REQUESTED,\n          {\n            claimId: row.id,\n            userId: row.user_id,\n            wallet: row.wallet,\n            amountLamports: row.amount_lamports,\n            requestedAt: new Date().toISOString(),\n          },\n        );\n\n        return row;\n      });\n\n      logger.info(\"Referral claim requested\", {\n        userId,\n        wallet,\n        claimId: claim.id,\n        amountLamports: claim.amount_lamports,\n      });\n\n      return ok(\n        c,\n        {\n          claimId: claim.id,\n          amountLamports: claim.amount_lamports,\n          status: \"pending\",\n        },\n        202,\n      );\n    } catch (claimError) {\n      logger.error(\"Failed to create referral claim\", {\n        err: String(claimError),\n        userId,\n        wallet,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to create referral claim\",\n      );\n    }\n  });\n\n  // ── GET /claim/:claimId — poll claim status ─────────────────────────────\n\n  const getClaimRoute = createRoute({\n    method: \"get\",\n    path: \"/claim/{claimId}\",\n    tags: [\"Referral\"],\n    summary: \"Poll claim status\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      params: z.object({\n        claimId: z.string().openapi({ description: \"Claim ID\" }),\n      }),\n    },\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(ClaimResponseSchema) },\n        },\n        description: \"Claim status\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Claim not found\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch referral claim\",\n      },\n    },\n  });\n\n  app.openapi(getClaimRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    const { claimId } = c.req.valid(\"param\");\n\n    try {\n      const claim = await db.getReferralClaim(claimId);\n      if (!claim) {\n        return err(\n          c,\n          404,\n          API_ERROR_CODES.CLAIM_NOT_FOUND,\n          \"Claim not found\",\n        );\n      }\n\n      // Only allow the claim owner to view their claim\n      if (claim.user_id !== userId) {\n        return err(\n          c,\n          404,\n          API_ERROR_CODES.CLAIM_NOT_FOUND,\n          \"Claim not found\",\n        );\n      }\n\n      return ok(c, {\n        claimId: claim.id,\n        amountLamports: String(claim.amount_lamports),\n        status: claim.status,\n        ...(claim.tx_signature ? { txSignature: claim.tx_signature } : {}),\n      });\n    } catch (fetchError) {\n      logger.error(\"Failed to fetch referral claim\", {\n        err: String(fetchError),\n        userId,\n        claimId,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch referral claim\",\n      );\n    }\n  });\n\n  return app;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1126,"cache_read_input_tokens":121489,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1126},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"eb7d01f2-3773-44f3-9eed-fc96d23e7071","uuid":"27f9337d-4f5c-45be-ade6-6d467667e258"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013zeLAJ2K2SUTSXE5exiGvB","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/src/routes/referral.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"eb7d01f2-3773-44f3-9eed-fc96d23e7071","uuid":"a9f3476d-f60c-4b85-9a1a-c09214001020","timestamp":"2026-04-22T09:51:16.952Z","tool_use_result":{"type":"update","filePath":"/workspaces/rng-utopia/backend/src/routes/referral.ts","content":"/**\n * Referral routes — code management, linking, stats, earnings, and claims.\n *\n * WAITLIST-CONTRACT: the waitlist calls POST/GET /code, POST /apply,\n * GET /referrer, GET /stats, GET /referrals. /earnings and /claim are NOT\n * consumed by waitlist. Request/response shape for the consumed set is\n * pinned in `__tests__/waitlist-contract.test.ts`; keep\n * `waitlist/src/lib/referral-api.ts` in lockstep.\n */\n\nimport { createRoute, z } from \"@hono/zod-openapi\";\nimport type postgres from \"postgres\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport type { Config } from \"../config.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport {\n  ApplyReferralCodeBodySchema,\n  ClaimResponseSchema,\n  CodeResponseSchema,\n  MaybeCodeResponseSchema,\n  ReferralApplyResponseSchema,\n  ReferralCodeBodySchema,\n  ReferralListResponseSchema,\n  ReferralReferrerResponseSchema,\n  ReferralStatsSchema,\n} from \"../contracts/validators.js\";\nimport { logger } from \"../logger.js\";\nimport { emitEvent } from \"../queue/emit-event.js\";\nimport { EventTypes } from \"../queue/event-types.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface ReferralRoutesDeps {\n  db: Db;\n  sql: postgres.Sql;\n  config: Config;\n}\n\nconst EarningsResponseSchema = z.object({\n  items: z.array(\n    z.object({\n      roundId: z.string(),\n      gameType: z.string(),\n      refereeUserId: z.string(),\n      refereeUsername: z.string(),\n      wagerLamports: z.string(),\n      earnedLamports: z.string(),\n      createdAt: z.string().datetime(),\n    }),\n  ),\n  pagination: z.object({\n    page: z.number().int(),\n    totalPages: z.number().int(),\n  }),\n});\n\nexport function createReferralRoutes(deps: ReferralRoutesDeps) {\n  const { db, sql, config } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // ── POST /code — set the player's referral code (permanent) ────────────\n\n  const setCodeRoute = createRoute({\n    method: \"post\",\n    path: \"/code\",\n    tags: [\"Referral\"],\n    summary: \"Set referral code (permanent)\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      body: {\n        required: true,\n        content: { \"application/json\": { schema: ReferralCodeBodySchema } },\n      },\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: envelope(CodeResponseSchema) } },\n        description: \"Code set\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Profile not found\",\n      },\n      409: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Code already set or taken\",\n      },\n      422: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Invalid request body or code format\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to set referral code\",\n      },\n    },\n  });\n\n  app.openapi(setCodeRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");\n    }\n    const wallet = profile.wallet;\n\n    const { code } = c.req.valid(\"json\");\n\n    // Check if the user already has a code — codes are permanent\n    const ownCode = await db.getReferralCodeByUserId(userId);\n    if (ownCode) {\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.CODE_ALREADY_SET,\n        \"You already have a referral code. Codes cannot be changed.\",\n        { retryable: false },\n      );\n    }\n\n    // Check if this code is already taken by another user\n    const existing = await db.getReferralCodeByCode(code);\n    if (existing && existing.user_id !== userId) {\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.CODE_TAKEN,\n        \"This referral code is already in use\",\n        { retryable: false },\n      );\n    }\n\n    try {\n      const result = await db.insertReferralCode(userId, wallet, code);\n      logger.info(\"Referral code set\", { userId, wallet, code: result.code });\n      return ok(c, { code: result.code });\n    } catch (insertError) {\n      // Handle race condition: another wallet grabbed the code between check and insert\n      const msg =\n        insertError instanceof Error ? insertError.message : String(insertError);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return err(\n          c,\n          409,\n          API_ERROR_CODES.CODE_TAKEN,\n          \"This referral code is already in use\",\n          { retryable: false },\n        );\n      }\n      logger.error(\"Failed to set referral code\", {\n        err: String(insertError),\n        userId,\n        wallet,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to set referral code\",\n      );\n    }\n  }, (result, c) => {\n    if (result.success) return;\n    return err(\n      c,\n      422,\n      API_ERROR_CODES.INVALID_CODE,\n      \"Referral code must be 3-16 lowercase letters, numbers, or hyphens.\",\n      { retryable: false, details: result.error.issues },\n    );\n  });\n\n  // ── POST /apply — link the authenticated player to a referrer ──────────\n\n  const applyRoute = createRoute({\n    method: \"post\",\n    path: \"/apply\",\n    tags: [\"Referral\"],\n    summary: \"Apply a referral code (link to referrer)\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      body: {\n        required: true,\n        content: { \"application/json\": { schema: ApplyReferralCodeBodySchema } },\n      },\n    },\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(ReferralApplyResponseSchema) },\n        },\n        description: \"Linked to referrer\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Profile or code not found\",\n      },\n      409: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Self-referral or already linked to a referrer\",\n      },\n      422: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Invalid request body or code format\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to apply referral code\",\n      },\n    },\n  });\n\n  app.openapi(applyRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");\n    }\n    const wallet = profile.wallet;\n\n    const { code } = c.req.valid(\"json\");\n\n    // Look up the referral code to find the referrer\n    const codeRow = await db.getReferralCodeByCode(code);\n    if (!codeRow) {\n      return err(\n        c,\n        404,\n        API_ERROR_CODES.CODE_NOT_FOUND,\n        \"Referral code does not exist\",\n        { retryable: false },\n      );\n    }\n\n    // Self-referral check\n    if (codeRow.user_id === userId) {\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.SELF_REFERRAL,\n        \"You cannot use your own referral code\",\n        { retryable: false },\n      );\n    }\n\n    // Check if the player already has a referrer\n    const existingLink = await db.getReferralLinkByRefereeUserId(userId);\n    if (existingLink) {\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.ALREADY_LINKED,\n        \"You are already linked to a referrer\",\n        { retryable: false },\n      );\n    }\n\n    try {\n      await db.insertReferralLink({\n        referrerUserId: codeRow.user_id,\n        refereeUserId: userId,\n        referrerWallet: codeRow.wallet,\n        refereeWallet: wallet,\n      });\n      logger.info(\"Referral link created\", {\n        referrerUserId: codeRow.user_id,\n        refereeUserId: userId,\n        code,\n      });\n      return ok(c, {\n        referrerUserId: codeRow.user_id,\n        benefit: \"10% fee rebate on all games\",\n      });\n    } catch (insertError) {\n      // Handle race condition: another request linked this referee between check and insert\n      const msg =\n        insertError instanceof Error ? insertError.message : String(insertError);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return err(\n          c,\n          409,\n          API_ERROR_CODES.ALREADY_LINKED,\n          \"You are already linked to a referrer\",\n          { retryable: false },\n        );\n      }\n      logger.error(\"Failed to create referral link\", {\n        err: String(insertError),\n        userId,\n        wallet,\n        code,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to apply referral code\",\n      );\n    }\n  }, (result, c) => {\n    if (result.success) return;\n    return err(\n      c,\n      422,\n      API_ERROR_CODES.INVALID_CODE,\n      \"Referral code must be 3-16 lowercase letters, numbers, or hyphens.\",\n      { retryable: false, details: result.error.issues },\n    );\n  });\n\n  // ── GET /code — return the authenticated player's current referral code ─\n\n  const getCodeRoute = createRoute({\n    method: \"get\",\n    path: \"/code\",\n    tags: [\"Referral\"],\n    summary: \"Get own referral code\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(MaybeCodeResponseSchema) },\n        },\n        description: \"Code (null if not set)\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n    },\n  });\n\n  app.openapi(getCodeRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    const row = await db.getReferralCodeByUserId(userId);\n    return ok(c, { code: row?.code ?? null });\n  });\n\n  // ── GET /referrer — check if the authenticated player has a referrer ────\n\n  const referrerRoute = createRoute({\n    method: \"get\",\n    path: \"/referrer\",\n    tags: [\"Referral\"],\n    summary: \"Get own referrer info\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(ReferralReferrerResponseSchema) },\n        },\n        description: \"Referrer info (all fields null if not linked)\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch referrer\",\n      },\n    },\n  });\n\n  app.openapi(referrerRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    try {\n      const link = await db.getReferralLinkByRefereeUserId(userId);\n      if (!link) {\n        return ok(c, {\n          referrerUserId: null,\n          referrerUsername: null,\n          referrerCode: null,\n          linkedAt: null,\n        });\n      }\n\n      // Look up referrer's username and code for display\n      const [referrerProfile, referrerCode] = await Promise.all([\n        db.getProfileByUserId(link.referrer_user_id),\n        db.getReferralCodeByUserId(link.referrer_user_id),\n      ]);\n\n      return ok(c, {\n        referrerUserId: link.referrer_user_id,\n        referrerUsername: referrerProfile?.username ?? link.referrer_user_id,\n        referrerCode: referrerCode?.code ?? null,\n        linkedAt: link.created_at.toISOString(),\n      });\n    } catch (fetchError) {\n      logger.error(\"Failed to fetch referrer\", {\n        err: String(fetchError),\n        userId,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch referrer\",\n      );\n    }\n  });\n\n  // ── GET /stats — referral summary stats for authenticated user ──────────\n\n  const statsRoute = createRoute({\n    method: \"get\",\n    path: \"/stats\",\n    tags: [\"Referral\"],\n    summary: \"Get referral stats\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(ReferralStatsSchema) },\n        },\n        description: \"Referral statistics\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch referral stats\",\n      },\n    },\n  });\n\n  app.openapi(statsRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    try {\n      const stats = await db.getReferralStatsByUserId(userId);\n      return ok(c, {\n        referredCount: stats.referred_count,\n        activeCount: stats.active_count,\n        totalVolumeLamports: stats.total_volume_lamports,\n        totalEarnedLamports: stats.total_earned_lamports,\n        totalRebateLamports: stats.total_rebate_lamports,\n        pendingLamports: stats.pending_lamports,\n      });\n    } catch (fetchError) {\n      logger.error(\"Failed to fetch referral stats\", {\n        err: String(fetchError),\n        userId,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch referral stats\",\n      );\n    }\n  });\n\n  // ── GET /referrals — unique referred users (last 10) ────────────────────\n\n  const referralsRoute = createRoute({\n    method: \"get\",\n    path: \"/referrals\",\n    tags: [\"Referral\"],\n    summary: \"List referred users (last 10)\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(ReferralListResponseSchema) },\n        },\n        description: \"Referred users\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch referrals\",\n      },\n    },\n  });\n\n  app.openapi(referralsRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    try {\n      const links = await db.getReferralLinksByReferrerUserId(userId);\n      // Return last 10 unique referees with usernames, sorted by most recent first\n      const recent = links.slice(0, 10);\n      const profiles = await Promise.all(\n        recent.map((l) => db.getProfileByUserId(l.referee_user_id)),\n      );\n      const items = recent.map((l, i) => ({\n        refereeUserId: l.referee_user_id,\n        refereeUsername: profiles[i]?.username ?? l.referee_user_id,\n        createdAt: l.created_at.toISOString(),\n      }));\n      return ok(c, { items });\n    } catch (fetchError) {\n      logger.error(\"Failed to fetch referrals\", {\n        err: String(fetchError),\n        userId,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch referrals\",\n      );\n    }\n  });\n\n  // ── GET /earnings — paginated per-game earnings log ─────────────────────\n\n  const earningsRoute = createRoute({\n    method: \"get\",\n    path: \"/earnings\",\n    tags: [\"Referral\"],\n    summary: \"Get paginated referral earnings\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      query: z.object({\n        page: z.coerce.number().int().min(1).default(1).optional(),\n        limit: z.coerce.number().int().min(1).max(100).default(20).optional(),\n      }),\n    },\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(EarningsResponseSchema) },\n        },\n        description: \"Earnings list\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      422: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Invalid parameters\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch referral earnings\",\n      },\n    },\n  });\n\n  app.openapi(earningsRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    const query = c.req.valid(\"query\");\n    const page = query.page ?? 1;\n    const limit = query.limit ?? 20;\n\n    try {\n      const result = await db.getReferralEarningsByUserId(userId, page, limit);\n      // Resolve usernames for referees (batch-dedup by userId)\n      const uniqueRefereeIds = [...new Set(result.items.map((e) => e.referee_user_id))];\n      const refereeProfiles = await Promise.all(\n        uniqueRefereeIds.map((id) => db.getProfileByUserId(id)),\n      );\n      const usernameMap = new Map(\n        uniqueRefereeIds.map((id, i) => [id, refereeProfiles[i]?.username ?? id]),\n      );\n      return ok(c, {\n        items: result.items.map((e) => ({\n          roundId: e.round_id,\n          gameType: e.game_type,\n          refereeUserId: e.referee_user_id,\n          refereeUsername: usernameMap.get(e.referee_user_id) ?? e.referee_user_id,\n          wagerLamports: String(e.wager_lamports),\n          earnedLamports: String(e.referrer_earned_lamports),\n          createdAt: e.created_at.toISOString(),\n        })),\n        pagination: {\n          page,\n          totalPages: result.totalPages,\n        },\n      });\n    } catch (fetchError) {\n      logger.error(\"Failed to fetch referral earnings\", {\n        err: String(fetchError),\n        userId,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch referral earnings\",\n      );\n    }\n  });\n\n  // ── POST /claim — request payout of pending referral earnings ───────────\n\n  const claimRoute = createRoute({\n    method: \"post\",\n    path: \"/claim\",\n    tags: [\"Referral\"],\n    summary: \"Request payout of pending referral earnings\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      202: {\n        content: {\n          \"application/json\": { schema: envelope(ClaimResponseSchema) },\n        },\n        description: \"Claim queued\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Profile not found\",\n      },\n      422: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Zero balance or below threshold\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to create referral claim\",\n      },\n    },\n  });\n\n  app.openapi(claimRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");\n    }\n    const wallet = profile.wallet;\n\n    try {\n      // Snapshot pending balance\n      const pendingStr = await db.getPendingBalanceByUserId(userId);\n      const pendingLamports = BigInt(pendingStr);\n\n      if (pendingLamports <= 0n) {\n        return err(\n          c,\n          422,\n          API_ERROR_CODES.ZERO_BALANCE,\n          \"No pending earnings to claim\",\n          { retryable: false },\n        );\n      }\n\n      if (pendingLamports < BigInt(config.referralMinClaimLamports)) {\n        return err(\n          c,\n          422,\n          API_ERROR_CODES.BELOW_THRESHOLD,\n          `Minimum claim amount is ${config.referralMinClaimLamports} lamports (${(config.referralMinClaimLamports / 1e9).toFixed(2)} SOL)`,\n          { retryable: false },\n        );\n      }\n\n      // Atomically insert claim row + emit queue event\n      const claim = await sql.begin(async (tx) => {\n        const rows = await (tx as unknown as postgres.Sql)<\n          {\n            id: string;\n            user_id: string;\n            wallet: string;\n            amount_lamports: string;\n            status: string;\n          }[]\n        >`\n          INSERT INTO referral_claims (user_id, wallet, amount_lamports, status)\n          VALUES (${userId}, ${wallet}, ${pendingStr}, 'pending')\n          RETURNING id, user_id, wallet, amount_lamports, status\n        `;\n        const row = rows[0]!;\n\n        await emitEvent(\n          tx as unknown as postgres.Sql,\n          EventTypes.REFERRAL_CLAIM_REQUESTED,\n          {\n            claimId: row.id,\n            userId: row.user_id,\n            wallet: row.wallet,\n            amountLamports: row.amount_lamports,\n            requestedAt: new Date().toISOString(),\n          },\n        );\n\n        return row;\n      });\n\n      logger.info(\"Referral claim requested\", {\n        userId,\n        wallet,\n        claimId: claim.id,\n        amountLamports: claim.amount_lamports,\n      });\n\n      return ok(\n        c,\n        {\n          claimId: claim.id,\n          amountLamports: claim.amount_lamports,\n          status: \"pending\",\n        },\n        202,\n      );\n    } catch (claimError) {\n      logger.error(\"Failed to create referral claim\", {\n        err: String(claimError),\n        userId,\n        wallet,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to create referral claim\",\n      );\n    }\n  });\n\n  // ── GET /claim/:claimId — poll claim status ─────────────────────────────\n\n  const getClaimRoute = createRoute({\n    method: \"get\",\n    path: \"/claim/{claimId}\",\n    tags: [\"Referral\"],\n    summary: \"Poll claim status\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      params: z.object({\n        claimId: z.string().openapi({ description: \"Claim ID\" }),\n      }),\n    },\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(ClaimResponseSchema) },\n        },\n        description: \"Claim status\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Claim not found\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch referral claim\",\n      },\n    },\n  });\n\n  app.openapi(getClaimRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    const { claimId } = c.req.valid(\"param\");\n\n    try {\n      const claim = await db.getReferralClaim(claimId);\n      if (!claim) {\n        return err(\n          c,\n          404,\n          API_ERROR_CODES.CLAIM_NOT_FOUND,\n          \"Claim not found\",\n        );\n      }\n\n      // Only allow the claim owner to view their claim\n      if (claim.user_id !== userId) {\n        return err(\n          c,\n          404,\n          API_ERROR_CODES.CLAIM_NOT_FOUND,\n          \"Claim not found\",\n        );\n      }\n\n      return ok(c, {\n        claimId: claim.id,\n        amountLamports: String(claim.amount_lamports),\n        status: claim.status,\n        ...(claim.tx_signature ? { txSignature: claim.tx_signature } : {}),\n      });\n    } catch (fetchError) {\n      logger.error(\"Failed to fetch referral claim\", {\n        err: String(fetchError),\n        userId,\n        claimId,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch referral claim\",\n      );\n    }\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":13,"oldLines":19,"newStart":13,"newLines":23,"lines":[" import type { AppEnv } from \"../hono-env.js\";"," import type { Db } from \"../db.js\";"," import type { Config } from \"../config.js\";","-import { errorMessage, structuredErrorMessage } from \"../contracts/api-errors.js\";","+import { API_ERROR_CODES } from \"../contracts/api-errors.js\";"," import {","+  envelope,","+  ErrorEnvelopeSchema,","+  ok,","+  err,","+} from \"../contracts/api-envelope.js\";","+import {","   ApplyReferralCodeBodySchema,","   ClaimResponseSchema,","   CodeResponseSchema,","-  ErrorResponseSchema,","   MaybeCodeResponseSchema,","   ReferralApplyResponseSchema,","   ReferralCodeBodySchema,","   ReferralListResponseSchema,","   ReferralReferrerResponseSchema,","   ReferralStatsSchema,","-  StructuredErrorResponseSchema,"," } from \"../contracts/validators.js\";"," import { logger } from \"../logger.js\";"," import { emitEvent } from \"../queue/emit-event.js\";"]},{"oldStart":38,"oldLines":6,"newStart":42,"newLines":24,"lines":["   config: Config;"," }"," ","+const EarningsResponseSchema = z.object({","+  items: z.array(","+    z.object({","+      roundId: z.string(),","+      gameType: z.string(),","+      refereeUserId: z.string(),","+      refereeUsername: z.string(),","+      wagerLamports: z.string(),","+      earnedLamports: z.stri