{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SAGPg3crp8cDoR3dGwWxSL","type":"tool_result","content":"1\t/**\n2\t * Waitlist API contract guard.\n3\t *\n4\t * The waitlist app (separate repo, `waitlist/`) launches first and consumes\n5\t * a fixed subset of backend endpoints. This file pins the EXACT request and\n6\t * response shape for each of those endpoints. If any of these assertions\n7\t * fails, the waitlist is likely to break in production — STOP and think:\n8\t *\n9\t *   1. Is this change intentional?\n10\t *   2. Does the deployed waitlist already tolerate it?\n11\t *   3. Does the waitlist need a coordinated release BEFORE the backend ships?\n12\t *   4. Only then update WAITLIST_CONTRACT below AND update\n13\t *      `waitlist/src/lib/{auth-api,referral-api}.ts` + `TelegramCard.tsx`.\n14\t *\n15\t * Additive changes (new optional response fields) WILL fail this test on\n16\t * purpose — so the author is forced to confirm the waitlist will ignore them.\n17\t *\n18\t * Route files that back this contract carry a `WAITLIST-CONTRACT` banner\n19\t * pointing here.\n20\t */\n21\t\n22\t/* eslint-disable @typescript-eslint/no-explicit-any */\n23\t\n24\timport { describe, it, expect, beforeAll } from \"vitest\";\n25\timport { OpenAPIHono } from \"@hono/zod-openapi\";\n26\timport { Hono } from \"hono\";\n27\timport { createAuthRoutes } from \"../routes/auth.js\";\n28\timport { createReferralRoutes } from \"../routes/referral.js\";\n29\timport { createPublicReferralRoutes } from \"../routes/public-referral.js\";\n30\timport { createTelegramLinkRoutes } from \"../routes/telegram-link.js\";\n31\t\n32\ttype AnyRecord = Record<string, unknown>;\n33\t\n34\t// ---------------------------------------------------------------------------\n35\t// The contract. One entry per endpoint waitlist calls.\n36\t// ---------------------------------------------------------------------------\n37\t//\n38\t// `requestBody` = keys waitlist actually sends.\n39\t// `response`    = keys waitlist actually consumes (or would consume).\n40\t//\n41\t// Keep alphabetized inside each array. If you add, remove, or rename a key\n42\t// here, keep `waitlist/src/lib/*.ts` in lockstep.\n43\t//\n44\t// Source of truth (waitlist side, 2026-04-18):\n45\t//   waitlist/src/lib/auth-api.ts\n46\t//   waitlist/src/lib/referral-api.ts\n47\t//   waitlist/src/components/TelegramCard.tsx\n48\t\n49\tconst WAITLIST_CONTRACT = {\n50\t  // ── Auth (public, JSON) ───────────────────────────────────────────────\n51\t  \"POST /auth/challenge\": {\n52\t    requestBody: [\"wallet\"],\n53\t    response: [\"expiresAt\", \"message\", \"nonce\"],\n54\t    authRequired: false,\n55\t  },\n56\t  \"POST /auth/verify\": {\n57\t    requestBody: [\"nonce\", \"signature\", \"wallet\"],\n58\t    response: [\n59\t      \"accessExpiresAt\",\n60\t      \"accessToken\",\n61\t      \"refreshExpiresAt\",\n62\t      \"refreshToken\",\n63\t    ],\n64\t    authRequired: false,\n65\t  },\n66\t  \"POST /auth/refresh\": {\n67\t    requestBody: [\"refreshToken\"],\n68\t    response: [\n69\t      \"accessExpiresAt\",\n70\t      \"accessToken\",\n71\t      \"refreshExpiresAt\",\n72\t      \"refreshToken\",\n73\t    ],\n74\t    authRequired: false,\n75\t  },\n76\t  \"POST /auth/logout\": {\n77\t    requestBody: [\"refreshToken\"], // optional on backend, always sent by waitlist\n78\t    response: null, // 204 no body\n79\t    authRequired: false,\n80\t  },\n81\t\n82\t  // ── Public referral ──────────────────────────────────────────────────\n83\t  \"GET /public-referral/code/{code}\": {\n84\t    requestBody: null,\n85\t    response: [\"exists\"],\n86\t    authRequired: false,\n87\t  },\n88\t\n89\t  // ── Authenticated referral ───────────────────────────────────────────\n90\t  \"POST /referral/code\": {\n91\t    requestBody: [\"code\"],\n92\t    response: [\"code\"],\n93\t    authRequired: true,\n94\t  },\n95\t  \"GET /referral/code\": {\n96\t    requestBody: null,\n97\t    response: [\"code\"],\n98\t    authRequired: true,\n99\t  },\n100\t  \"POST /referral/apply\": {\n101\t    requestBody: [\"code\"],\n102\t    response: [\"benefit\", \"referrerUserId\"],\n103\t    authRequired: true,\n104\t  },\n105\t  \"GET /referral/referrer\": {\n106\t    requestBody: null,\n107\t    response: [\n108\t      \"linkedAt\",\n109\t      \"referrerCode\",\n110\t      \"referrerUserId\",\n111\t      \"referrerUsername\",\n112\t    ],\n113\t    authRequired: true,\n114\t  },\n115\t  \"GET /referral/stats\": {\n116\t    requestBody: null,\n117\t    response: [\n118\t      \"activeCount\",\n119\t      \"pendingLamports\",\n120\t      \"referredCount\",\n121\t      \"totalEarnedLamports\",\n122\t      \"totalRebateLamports\",\n123\t      \"totalVolumeLamports\",\n124\t    ],\n125\t    authRequired: true,\n126\t  },\n127\t  \"GET /referral/referrals\": {\n128\t    requestBody: null,\n129\t    response: [\"items\"],\n130\t    itemResponse: [\"createdAt\", \"refereeUserId\", \"refereeUsername\"],\n131\t    authRequired: true,\n132\t  },\n133\t} as const;\n134\t\n135\t// Telegram-link is plain Hono (no OpenAPI), validated by handler invocation\n136\t// below rather than spec introspection. Response keys include both the\n137\t// already-linked and new-token branches because the waitlist dispatches on\n138\t// `alreadyLinked`.\n139\tconst TELEGRAM_GENERATE_LINK_CONTRACT = {\n140\t  alreadyLinkedResponse: [\n141\t    \"alreadyLinked\",\n142\t    \"botUrl\",\n143\t    \"communityUrl\",\n144\t    \"linkedAt\",\n145\t    \"telegramUserId\",\n146\t    \"telegramUsername\",\n147\t  ],\n148\t  newTokenResponse: [\n149\t    \"botUrl\",\n150\t    \"communityUrl\",\n151\t    \"deepLink\",\n152\t    \"expiresAt\",\n153\t    \"token\",\n154\t  ],\n155\t  authRequired: true,\n156\t};\n157\t\n158\t// ---------------------------------------------------------------------------\n159\t// Spec builder\n160\t// ---------------------------------------------------------------------------\n161\t\n162\t/** Stub that returns `undefined` for every DB method. Routes never execute. */\n163\tfunction stubDb() {\n164\t  return new Proxy({} as any, {\n165\t    get: () => async () => undefined,\n166\t  });\n167\t}\n168\t\n169\tfunction buildSpecApp() {\n170\t  const app = new OpenAPIHono();\n171\t  const db = stubDb();\n172\t\n173\t  app.route(\n174\t    \"/auth\",\n175\t    createAuthRoutes({\n176\t      authDb: db,\n177\t      db,\n178\t      jwtSecret: new TextEncoder().encode(\"test\"),\n179\t      cluster: \"devnet\",\n180\t      challengeTtlSeconds: 60,\n181\t      accessTokenTtlSeconds: 60,\n182\t      refreshTokenTtlDays: 1,\n183\t    }),\n184\t  );\n185\t  app.route(\n186\t    \"/referral\",\n187\t    createReferralRoutes({\n188\t      db,\n189\t      sql: {} as any,\n190\t      config: {} as any,\n191\t    }),\n192\t  );\n193\t  app.route(\"/public-referral\", createPublicReferralRoutes({ db }));\n194\t\n195\t  app.openAPIRegistry.registerComponent(\"securitySchemes\", \"bearerAuth\", {\n196\t    type: \"http\",\n197\t    scheme: \"bearer\",\n198\t    bearerFormat: \"JWT\",\n199\t  });\n200\t\n201\t  app.doc(\"/openapi.json\", {\n202\t    openapi: \"3.0.3\",\n203\t    info: { title: \"Taunt Bet API (waitlist contract)\", version: \"0.1.0\" },\n204\t  });\n205\t\n206\t  return app;\n207\t}\n208\t\n209\tfunction resolveSchema(spec: AnyRecord, schema: unknown): AnyRecord {\n210\t  const record = schema as AnyRecord;\n211\t  if (typeof record?.$ref === \"string\") {\n212\t    const parts = record.$ref.replace(/^#\\//, \"\").split(\"/\");\n213\t    let cur: unknown = spec;\n214\t    for (const p of parts) cur = (cur as AnyRecord)?.[p];\n215\t    return resolveSchema(spec, cur);\n216\t  }\n217\t  return record;\n218\t}\n219\t\n220\tfunction requestBodyKeys(\n221\t  spec: AnyRecord,\n222\t  path: string,\n223\t  method: string,\n224\t): string[] {\n225\t  const op = ((spec.paths as AnyRecord)[path] as AnyRecord)?.[method] as\n226\t    | AnyRecord\n227\t    | undefined;\n228\t  const body = op?.requestBody as AnyRecord | undefined;\n229\t  const schema = (\n230\t    (body?.content as AnyRecord | undefined)?.[\"application/json\"] as\n231\t      | AnyRecord\n232\t      | undefined\n233\t  )?.schema;\n234\t  if (!schema) return [];\n235\t  const resolved = resolveSchema(spec, schema);\n236\t  return Object.keys((resolved.properties as AnyRecord | undefined) ?? {}).sort();\n237\t}\n238\t\n239\t/**\n240\t * Unwrap a response schema, descending into the success branch of an envelope\n241\t * (`{ ok: true, data: T }` inside a `oneOf` discriminated union) when present.\n242\t * Falls back to returning the resolved schema as-is for legacy non-enveloped\n243\t * responses.\n244\t */\n245\tfunction unwrapEnvelope(spec: AnyRecord, schema: unknown): AnyRecord {\n246\t  const resolved = resolveSchema(spec, schema);\n247\t\n248\t  const oneOf = resolved.oneOf as unknown[] | undefined;\n249\t  if (Array.isArray(oneOf)) {\n250\t    for (const variant of oneOf) {\n251\t      const variantResolved = resolveSchema(spec, variant);\n252\t      const props = variantResolved.properties as AnyRecord | undefined;\n253\t      const okProp = props?.ok as AnyRecord | undefined;\n254\t      const okEnum = okProp?.enum as unknown[] | undefined;\n255\t      if (okEnum && okEnum[0] === true && props && \"data\" in props) {\n256\t        return resolveSchema(spec, props.data);\n257\t      }\n258\t    }\n259\t  }\n260\t\n261\t  const properties = resolved.properties as AnyRecord | undefined;\n262\t  if (properties && \"ok\" in properties && \"data\" in properties) {\n263\t    return resolveSchema(spec, properties.data);\n264\t  }\n265\t\n266\t  return resolved;\n267\t}\n268\t\n269\tfunction responseKeys(\n270\t  spec: AnyRecord,\n271\t  path: string,\n272\t  method: string,\n273\t  status = \"200\",\n274\t): string[] {\n275\t  const op = ((spec.paths as AnyRecord)[path] as AnyRecord)?.[method] as\n276\t    | AnyRecord\n277\t    | undefined;\n278\t  const responses = op?.responses as AnyRecord | undefined;\n279\t  const entry = responses?.[status] as AnyRecord | undefined;\n280\t  const schema = (\n281\t    (entry?.content as AnyRecord | undefined)?.[\"application/json\"] as\n282\t      | AnyRecord\n283\t      | undefined\n284\t  )?.schema;\n285\t  if (!schema) return [];\n286\t  const unwrapped = unwrapEnvelope(spec, schema);\n287\t  return Object.keys((unwrapped.properties as AnyRecord | undefined) ?? {}).sort();\n288\t}\n289\t\n290\tfunction arrayItemKeys(\n291\t  spec: AnyRecord,\n292\t  path: string,\n293\t  method: string,\n294\t  arrayProperty: string,\n295\t): string[] {\n296\t  const op = ((spec.paths as AnyRecord)[path] as AnyRecord)?.[method] as\n297\t    | AnyRecord\n298\t    | undefined;\n299\t  const responses = op?.responses as AnyRecord | undefined;\n300\t  const entry = responses?.[\"200\"] as AnyRecord | undefined;\n301\t  const schema = (\n302\t    (entry?.content as AnyRecord | undefined)?.[\"application/json\"] as\n303\t      | AnyRecord\n304\t      | undefined\n305\t  )?.schema;\n306\t  const resolved = resolveSchema(spec, schema);\n307\t  const prop = (resolved.properties as AnyRecord)[arrayProperty] as AnyRecord;\n308\t  const itemResolved = resolveSchema(spec, prop.items);\n309\t  return Object.keys(\n310\t    (itemResolved.properties as AnyRecord | undefined) ?? {},\n311\t  ).sort();\n312\t}\n313\t\n314\tfunction isBearerProtected(\n315\t  spec: AnyRecord,\n316\t  path: string,\n317\t  method: string,\n318\t): boolean {\n319\t  const op = ((spec.paths as AnyRecord)[path] as AnyRecord)?.[method] as\n320\t    | AnyRecord\n321\t    | undefined;\n322\t  const security = op?.security as Array<AnyRecord> | undefined;\n323\t  if (!security) return false;\n324\t  return security.some((entry) => Object.keys(entry).includes(\"bearerAuth\"));\n325\t}\n326\t\n327\t// ---------------------------------------------------------------------------\n328\t// Tests\n329\t// ---------------------------------------------------------------------------\n330\t\n331\tdescribe(\"Waitlist ↔ backend API contract\", () => {\n332\t  let spec: AnyRecord;\n333\t\n334\t  beforeAll(async () => {\n335\t    const app = buildSpecApp();\n336\t    const res = await app.request(\"/openapi.json\");\n337\t    expect(res.status).toBe(200);\n338\t    spec = (await res.json()) as AnyRecord;\n339\t  });\n340\t\n341\t  for (const [key, contract] of Object.entries(WAITLIST_CONTRACT)) {\n342\t    const parts = key.split(\" \");\n343\t    const method = parts[0] as string;\n344\t    const path = parts[1] as string;\n345\t    const methodLower = method.toLowerCase();\n346\t\n347\t    describe(`${key}`, () => {\n348\t      it(\"exists in the generated OpenAPI spec\", () => {\n349\t        const paths = spec.paths as AnyRecord;\n350\t        expect(\n351\t          paths[path],\n352\t          `Waitlist calls ${key} but the OpenAPI spec has no such path.\\n` +\n353\t            \"Available paths: \" +\n354\t            Object.keys(paths).sort().join(\", \"),\n355\t        ).toBeDefined();\n356\t        expect((paths[path] as AnyRecord)[methodLower]).toBeDefined();\n357\t      });\n358\t\n359\t      if (contract.requestBody !== null) {\n360\t        it(\"request body has exactly the keys waitlist sends\", () => {\n361\t          const actual = requestBodyKeys(spec, path, methodLower);\n362\t          expect(\n363\t            actual,\n364\t            `Waitlist sends { ${contract.requestBody.join(\", \")} } to ${key}. ` +\n365\t              `Backend schema has { ${actual.join(\", \")} }. ` +\n366\t              \"Reconcile before merging.\",\n367\t          ).toEqual([...contract.requestBody].sort());\n368\t        });\n369\t      }\n370\t\n371\t      if (contract.response !== null) {\n372\t        it(\"200 response has exactly the keys waitlist consumes\", () => {\n373\t          const actual = responseKeys(spec, path, methodLower);\n374\t          expect(\n375\t            actual,\n376\t            `Waitlist consumes { ${contract.response.join(\", \")} } from ${key}. ` +\n377\t              `Backend returns { ${actual.join(\", \")} }. ` +\n378\t              \"Reconcile before merging.\",\n379\t          ).toEqual([...contract.response].sort());\n380\t        });\n381\t      }\n382\t\n383\t      if (\"itemResponse\" in contract && contract.itemResponse) {\n384\t        it(\"array item shape matches what waitlist renders\", () => {\n385\t          const actual = arrayItemKeys(spec, path, methodLower, \"items\");\n386\t          expect(actual).toEqual([...contract.itemResponse].sort());\n387\t        });\n388\t      }\n389\t\n390\t      it(`auth is ${contract.authRequired ? \"required\" : \"public\"}`, () => {\n391\t        expect(isBearerProtected(spec, path, methodLower)).toBe(\n392\t          contract.authRequired,\n393\t        );\n394\t      });\n395\t    });\n396\t  }\n397\t});\n398\t\n399\t// ---------------------------------------------------------------------------\n400\t// Telegram link — plain Hono, no OpenAPI schema. Invoke handler directly.\n401\t// ---------------------------------------------------------------------------\n402\t\n403\tdescribe(\"POST /telegram/generate-link (waitlist contract)\", () => {\n404\t  function buildApp(db: any) {\n405\t    // Inject userId via a stand-in middleware since route reads c.get(\"userId\")\n406\t    const outer = new Hono();\n407\t    outer.use(\"*\", async (c, next) => {\n408\t      c.set(\"userId\" as never, \"usr_alice\" as never);\n409\t      await next();\n410\t    });\n411\t    outer.route(\n412\t      \"/telegram\",\n413\t      createTelegramLinkRoutes({\n414\t        db,\n415\t        telegramBotUsername: \"taunt_bot\",\n416\t        telegramWebhookSecret: \"test\",\n417\t        communityInviteUrl: \"https://t.me/taunt\",\n418\t        linkTokenTtlSeconds: 300,\n419\t      }),\n420\t    );\n421\t    return outer;\n422\t  }\n423\t\n424\t  it(\"new-token branch returns exactly the keys waitlist reads\", async () => {\n425\t    const db = {\n426\t      getActiveLink: async () => null,\n427\t      generateLinkToken: async () => undefined,\n428\t    };\n429\t    const app = buildApp(db);\n430\t    const res = await app.request(\"/telegram/generate-link\", { method: \"POST\" });\n431\t    expect(res.status).toBe(200);\n432\t    const body = (await res.json()) as AnyRecord;\n433\t    expect(Object.keys(body).sort()).toEqual(\n434\t      [...TELEGRAM_GENERATE_LINK_CONTRACT.newTokenResponse].sort(),\n435\t    );\n436\t  });\n437\t\n438\t  it(\"already-linked branch returns exactly the keys waitlist reads\", async () => {\n439\t    const db = {\n440\t      getActiveLink: async () => ({\n441\t        telegram_user_id: \"123\",\n442\t        telegram_username: \"alice\",\n443\t        redeemed_at: new Date(),\n444\t      }),\n445\t    };\n446\t    const app = buildApp(db);\n447\t    const res = await app.request(\"/telegram/generate-link\", { method: \"POST\" });\n448\t    expect(res.status).toBe(200);\n449\t    const body = (await res.json()) as AnyRecord;\n450\t    expect(Object.keys(body).sort()).toEqual(\n451\t      [...TELEGRAM_GENERATE_LINK_CONTRACT.alreadyLinkedResponse].sort(),\n452\t    );\n453\t    expect(body.alreadyLinked).toBe(true);\n454\t  });\n455\t});\n456\t"}]},"parent_tool_use_id":null,"session_id":"eb7d01f2-3773-44f3-9eed-fc96d23e7071","uuid":"2ef0c02c-aa7e-46c8-ba83-ee2241bdb623","timestamp":"2026-04-22T09:48:30.986Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/waitlist-contract.test.ts","content":"/**\n * Waitlist API contract guard.\n *\n * The waitlist app (separate repo, `waitlist/`) launches first and consumes\n * a fixed subset of backend endpoints. This file pins the EXACT request and\n * response shape for each of those endpoints. If any of these assertions\n * fails, the waitlist is likely to break in production — STOP and think:\n *\n *   1. Is this change intentional?\n *   2. Does the deployed waitlist already tolerate it?\n *   3. Does the waitlist need a coordinated release BEFORE the backend ships?\n *   4. Only then update WAITLIST_CONTRACT below AND update\n *      `waitlist/src/lib/{auth-api,referral-api}.ts` + `TelegramCard.tsx`.\n *\n * Additive changes (new optional response fields) WILL fail this test on\n * purpose — so the author is forced to confirm the waitlist will ignore them.\n *\n * Route files that back this contract carry a `WAITLIST-CONTRACT` banner\n * pointing here.\n */\n\n/* eslint-disable @typescript-eslint/no-explicit-any */\n\nimport { describe, it, expect, beforeAll } from \"vitest\";\nimport { OpenAPIHono } from \"@hono/zod-openapi\";\nimport { Hono } from \"hono\";\nimport { createAuthRoutes } from \"../routes/auth.js\";\nimport { createReferralRoutes } from \"../routes/referral.js\";\nimport { createPublicReferralRoutes } from \"../routes/public-referral.js\";\nimport { createTelegramLinkRoutes } from \"../routes/telegram-link.js\";\n\ntype AnyRecord = Record<string, unknown>;\n\n// ---------------------------------------------------------------------------\n// The contract. One entry per endpoint waitlist calls.\n// ---------------------------------------------------------------------------\n//\n// `requestBody` = keys waitlist actually sends.\n// `response`    = keys waitlist actually consumes (or would consume).\n//\n// Keep alphabetized inside each array. If you add, remove, or rename a key\n// here, keep `waitlist/src/lib/*.ts` in lockstep.\n//\n// Source of truth (waitlist side, 2026-04-18):\n//   waitlist/src/lib/auth-api.ts\n//   waitlist/src/lib/referral-api.ts\n//   waitlist/src/components/TelegramCard.tsx\n\nconst WAITLIST_CONTRACT = {\n  // ── Auth (public, JSON) ───────────────────────────────────────────────\n  \"POST /auth/challenge\": {\n    requestBody: [\"wallet\"],\n    response: [\"expiresAt\", \"message\", \"nonce\"],\n    authRequired: false,\n  },\n  \"POST /auth/verify\": {\n    requestBody: [\"nonce\", \"signature\", \"wallet\"],\n    response: [\n      \"accessExpiresAt\",\n      \"accessToken\",\n      \"refreshExpiresAt\",\n      \"refreshToken\",\n    ],\n    authRequired: false,\n  },\n  \"POST /auth/refresh\": {\n    requestBody: [\"refreshToken\"],\n    response: [\n      \"accessExpiresAt\",\n      \"accessToken\",\n      \"refreshExpiresAt\",\n      \"refreshToken\",\n    ],\n    authRequired: false,\n  },\n  \"POST /auth/logout\": {\n    requestBody: [\"refreshToken\"], // optional on backend, always sent by waitlist\n    response: null, // 204 no body\n    authRequired: false,\n  },\n\n  // ── Public referral ──────────────────────────────────────────────────\n  \"GET /public-referral/code/{code}\": {\n    requestBody: null,\n    response: [\"exists\"],\n    authRequired: false,\n  },\n\n  // ── Authenticated referral ───────────────────────────────────────────\n  \"POST /referral/code\": {\n    requestBody: [\"code\"],\n    response: [\"code\"],\n    authRequired: true,\n  },\n  \"GET /referral/code\": {\n    requestBody: null,\n    response: [\"code\"],\n    authRequired: true,\n  },\n  \"POST /referral/apply\": {\n    requestBody: [\"code\"],\n    response: [\"benefit\", \"referrerUserId\"],\n    authRequired: true,\n  },\n  \"GET /referral/referrer\": {\n    requestBody: null,\n    response: [\n      \"linkedAt\",\n      \"referrerCode\",\n      \"referrerUserId\",\n      \"referrerUsername\",\n    ],\n    authRequired: true,\n  },\n  \"GET /referral/stats\": {\n    requestBody: null,\n    response: [\n      \"activeCount\",\n      \"pendingLamports\",\n      \"referredCount\",\n      \"totalEarnedLamports\",\n      \"totalRebateLamports\",\n      \"totalVolumeLamports\",\n    ],\n    authRequired: true,\n  },\n  \"GET /referral/referrals\": {\n    requestBody: null,\n    response: [\"items\"],\n    itemResponse: [\"createdAt\", \"refereeUserId\", \"refereeUsername\"],\n    authRequired: true,\n  },\n} as const;\n\n// Telegram-link is plain Hono (no OpenAPI), validated by handler invocation\n// below rather than spec introspection. Response keys include both the\n// already-linked and new-token branches because the waitlist dispatches on\n// `alreadyLinked`.\nconst TELEGRAM_GENERATE_LINK_CONTRACT = {\n  alreadyLinkedResponse: [\n    \"alreadyLinked\",\n    \"botUrl\",\n    \"communityUrl\",\n    \"linkedAt\",\n    \"telegramUserId\",\n    \"telegramUsername\",\n  ],\n  newTokenResponse: [\n    \"botUrl\",\n    \"communityUrl\",\n    \"deepLink\",\n    \"expiresAt\",\n    \"token\",\n  ],\n  authRequired: true,\n};\n\n// ---------------------------------------------------------------------------\n// Spec builder\n// ---------------------------------------------------------------------------\n\n/** Stub that returns `undefined` for every DB method. Routes never execute. */\nfunction stubDb() {\n  return new Proxy({} as any, {\n    get: () => async () => undefined,\n  });\n}\n\nfunction buildSpecApp() {\n  const app = new OpenAPIHono();\n  const db = stubDb();\n\n  app.route(\n    \"/auth\",\n    createAuthRoutes({\n      authDb: db,\n      db,\n      jwtSecret: new TextEncoder().encode(\"test\"),\n      cluster: \"devnet\",\n      challengeTtlSeconds: 60,\n      accessTokenTtlSeconds: 60,\n      refreshTokenTtlDays: 1,\n    }),\n  );\n  app.route(\n    \"/referral\",\n    createReferralRoutes({\n      db,\n      sql: {} as any,\n      config: {} as any,\n    }),\n  );\n  app.route(\"/public-referral\", createPublicReferralRoutes({ db }));\n\n  app.openAPIRegistry.registerComponent(\"securitySchemes\", \"bearerAuth\", {\n    type: \"http\",\n    scheme: \"bearer\",\n    bearerFormat: \"JWT\",\n  });\n\n  app.doc(\"/openapi.json\", {\n    openapi: \"3.0.3\",\n    info: { title: \"Taunt Bet API (waitlist contract)\", version: \"0.1.0\" },\n  });\n\n  return app;\n}\n\nfunction resolveSchema(spec: AnyRecord, schema: unknown): AnyRecord {\n  const record = schema as AnyRecord;\n  if (typeof record?.$ref === \"string\") {\n    const parts = record.$ref.replace(/^#\\//, \"\").split(\"/\");\n    let cur: unknown = spec;\n    for (const p of parts) cur = (cur as AnyRecord)?.[p];\n    return resolveSchema(spec, cur);\n  }\n  return record;\n}\n\nfunction requestBodyKeys(\n  spec: AnyRecord,\n  path: string,\n  method: string,\n): string[] {\n  const op = ((spec.paths as AnyRecord)[path] as AnyRecord)?.[method] as\n    | AnyRecord\n    | undefined;\n  const body = op?.requestBody as AnyRecord | undefined;\n  const schema = (\n    (body?.content as AnyRecord | undefined)?.[\"application/json\"] as\n      | AnyRecord\n      | undefined\n  )?.schema;\n  if (!schema) return [];\n  const resolved = resolveSchema(spec, schema);\n  return Object.keys((resolved.properties as AnyRecord | undefined) ?? {}).sort();\n}\n\n/**\n * Unwrap a response schema, descending into the success branch of an envelope\n * (`{ ok: true, data: T }` inside a `oneOf` discriminated union) when present.\n * Falls back to returning the resolved schema as-is for legacy non-enveloped\n * responses.\n */\nfunction unwrapEnvelope(spec: AnyRecord, schema: unknown): AnyRecord {\n  const resolved = resolveSchema(spec, schema);\n\n  const oneOf = resolved.oneOf as unknown[] | undefined;\n  if (Array.isArray(oneOf)) {\n    for (const variant of oneOf) {\n      const variantResolved = resolveSchema(spec, variant);\n      const props = variantResolved.properties as AnyRecord | undefined;\n      const okProp = props?.ok as AnyRecord | undefined;\n      const okEnum = okProp?.enum as unknown[] | undefined;\n      if (okEnum && okEnum[0] === true && props && \"data\" in props) {\n        return resolveSchema(spec, props.data);\n      }\n    }\n  }\n\n  const properties = resolved.properties as AnyRecord | undefined;\n  if (properties && \"ok\" in properties && \"data\" in properties) {\n    return resolveSchema(spec, properties.data);\n  }\n\n  return resolved;\n}\n\nfunction responseKeys(\n  spec: AnyRecord,\n  path: string,\n  method: string,\n  status = \"200\",\n): string[] {\n  const op = ((spec.paths as AnyRecord)[path] as AnyRecord)?.[method] as\n    | AnyRecord\n    | undefined;\n  const responses = op?.responses as AnyRecord | undefined;\n  const entry = responses?.[status] as AnyRecord | undefined;\n  const schema = (\n    (entry?.content as AnyRecord | undefined)?.[\"application/json\"] as\n      | AnyRecord\n      | undefined\n  )?.schema;\n  if (!schema) return [];\n  const unwrapped = unwrapEnvelope(spec, schema);\n  return Object.keys((unwrapped.properties as AnyRecord | undefined) ?? {}).sort();\n}\n\nfunction arrayItemKeys(\n  spec: AnyRecord,\n  path: string,\n  method: string,\n  arrayProperty: string,\n): string[] {\n  const op = ((spec.paths as AnyRecord)[path] as AnyRecord)?.[method] as\n    | AnyRecord\n    | undefined;\n  const responses = op?.responses as AnyRecord | undefined;\n  const entry = responses?.[\"200\"] as AnyRecord | undefined;\n  const schema = (\n    (entry?.content as AnyRecord | undefined)?.[\"application/json\"] as\n      | AnyRecord\n      | undefined\n  )?.schema;\n  const resolved = resolveSchema(spec, schema);\n  const prop = (resolved.properties as AnyRecord)[arrayProperty] as AnyRecord;\n  const itemResolved = resolveSchema(spec, prop.items);\n  return Object.keys(\n    (itemResolved.properties as AnyRecord | undefined) ?? {},\n  ).sort();\n}\n\nfunction isBearerProtected(\n  spec: AnyRecord,\n  path: string,\n  method: string,\n): boolean {\n  const op = ((spec.paths as AnyRecord)[path] as AnyRecord)?.[method] as\n    | AnyRecord\n    | undefined;\n  const security = op?.security as Array<AnyRecord> | undefined;\n  if (!security) return false;\n  return security.some((entry) => Object.keys(entry).includes(\"bearerAuth\"));\n}\n\n// ---------------------------------------------------------------------------\n// Tests\n// ---------------------------------------------------------------------------\n\ndescribe(\"Waitlist ↔ backend API contract\", () => {\n  let spec: AnyRecord;\n\n  beforeAll(async () => {\n    const app = buildSpecApp();\n    const res = await app.request(\"/openapi.json\");\n    expect(res.status).toBe(200);\n    spec = (await res.json()) as AnyRecord;\n  });\n\n  for (const [key, contract] of Object.entries(WAITLIST_CONTRACT)) {\n    const parts = key.split(\" \");\n    const method = parts[0] as string;\n    const path = parts[1] as string;\n    const methodLower = method.toLowerCase();\n\n    describe(`${key}`, () => {\n      it(\"exists in the generated OpenAPI spec\", () => {\n        const paths = spec.paths as AnyRecord;\n        expect(\n          paths[path],\n          `Waitlist calls ${key} but the OpenAPI spec has no such path.\\n` +\n            \"Available paths: \" +\n            Object.keys(paths).sort().join(\", \"),\n        ).toBeDefined();\n        expect((paths[path] as AnyRecord)[methodLower]).toBeDefined();\n      });\n\n      if (contract.requestBody !== null) {\n        it(\"request body has exactly the keys waitlist sends\", () => {\n          const actual = requestBodyKeys(spec, path, methodLower);\n          expect(\n            actual,\n            `Waitlist sends { ${contract.requestBody.join(\", \")} } to ${key}. ` +\n              `Backend schema has { ${actual.join(\", \")} }. ` +\n              \"Reconcile before merging.\",\n          ).toEqual([...contract.requestBody].sort());\n        });\n      }\n\n      if (contract.response !== null) {\n        it(\"200 response has exactly the keys waitlist consumes\", () => {\n          const actual = responseKeys(spec, path, methodLower);\n          expect(\n            actual,\n            `Waitlist consumes { ${contract.response.join(\", \")} } from ${key}. ` +\n              `Backend returns { ${actual.join(\", \")} }. ` +\n              \"Reconcile before merging.\",\n          ).toEqual([...contract.response].sort());\n        });\n      }\n\n      if (\"itemResponse\" in contract && contract.itemResponse) {\n        it(\"array item shape matches what waitlist renders\", () => {\n          const actual = arrayItemKeys(spec, path, methodLower, \"items\");\n          expect(actual).toEqual([...contract.itemResponse].sort());\n        });\n      }\n\n      it(`auth is ${contract.authRequired ? \"required\" : \"public\"}`, () => {\n        expect(isBearerProtected(spec, path, methodLower)).toBe(\n          contract.authRequired,\n        );\n      });\n    });\n  }\n});\n\n// ---------------------------------------------------------------------------\n// Telegram link — plain Hono, no OpenAPI schema. Invoke handler directly.\n// ---------------------------------------------------------------------------\n\ndescribe(\"POST /telegram/generate-link (waitlist contract)\", () => {\n  function buildApp(db: any) {\n    // Inject userId via a stand-in middleware since route reads c.get(\"userId\")\n    const outer = new Hono();\n    outer.use(\"*\", async (c, next) => {\n      c.set(\"userId\" as never, \"usr_alice\" as never);\n      await next();\n    });\n    outer.route(\n      \"/telegram\",\n      createTelegramLinkRoutes({\n        db,\n        telegramBotUsername: \"taunt_bot\",\n        telegramWebhookSecret: \"test\",\n        communityInviteUrl: \"https://t.me/taunt\",\n        linkTokenTtlSeconds: 300,\n      }),\n    );\n    return outer;\n  }\n\n  it(\"new-token branch returns exactly the keys waitlist reads\", async () => {\n    const db = {\n      getActiveLink: async () => null,\n      generateLinkToken: async () => undefined,\n    };\n    const app = buildApp(db);\n    const res = await app.request(\"/telegram/generate-link\", { method: \"POST\" });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as AnyRecord;\n    expect(Object.keys(body).sort()).toEqual(\n      [...TELEGRAM_GENERATE_LINK_CONTRACT.newTokenResponse].sort(),\n    );\n  });\n\n  it(\"already-linked branch returns exactly the keys waitlist reads\", async () => {\n    const db = {\n      getActiveLink: async () => ({\n        telegram_user_id: \"123\",\n        telegram_username: \"alice\",\n        redeemed_at: new Date(),\n      }),\n    };\n    const app = buildApp(db);\n    const res = await app.request(\"/telegram/generate-link\", { method: \"POST\" });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as AnyRecord;\n    expect(Object.keys(body).sort()).toEqual(\n      [...TELEGRAM_GENERATE_LINK_CONTRACT.alreadyLinkedResponse].sort(),\n    );\n    expect(body.alreadyLinked).toBe(true);\n  });\n});\n","numLines":456,"startLine":1,"totalLines":456}}}
