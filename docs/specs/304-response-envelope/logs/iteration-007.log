 claimId: string };\n      };\n      const claim = claimBody.data;\n\n      // Poll status\n      const res = await app.request(`/referral/claim/${claim.claimId}`, {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        ok: true;\n        data: {\n          claimId: string;\n          amountLamports: string;\n          status: string;\n        };\n      };\n      expect(body.ok).toBe(true);\n      expect(body.data.claimId).toBe(claim.claimId);\n      expect(body.data.status).toBe(\"pending\");\n    });\n\n    it(\"returns 404 for non-existent claim\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\n        \"/referral/claim/00000000-0000-0000-0000-000000000000\",\n        {\n          method: \"GET\",\n          headers: { Authorization: `Bearer ${token}` },\n        },\n      );\n\n      expect(res.status).toBe(404);\n      const body = (await res.json()) as {\n        ok: false;\n        error: { code: string };\n      };\n      expect(body.ok).toBe(false);\n      expect(body.error.code).toBe(\"CLAIM_NOT_FOUND\");\n    });\n\n    it(\"returns 404 when another wallet tries to view a claim\", async () => {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":571,"cache_read_input_tokens":145196,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":571},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"eb7d01f2-3773-44f3-9eed-fc96d23e7071","uuid":"93322de4-3247-45e0-a042-e7696277260f"}
