{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U7W28oRF8c4w75goGGJHf7","type":"tool_result","content":"1\t/**\n2\t * Auth routes: challenge/verify/refresh/logout for JWT session management.\n3\t *\n4\t * WAITLIST-CONTRACT: the waitlist (separate repo, launches first) calls every\n5\t * route in this file. Any change to request/response shape here must keep\n6\t * `waitlist/src/lib/auth-api.ts` in lockstep and is enforced by\n7\t * `__tests__/waitlist-contract.test.ts`. Ship a coordinated waitlist release\n8\t * before merging a breaking change.\n9\t */\n10\t\n11\timport { createRoute } from \"@hono/zod-openapi\";\n12\timport { z } from \"zod\";\n13\timport { randomBytes, createHash } from \"node:crypto\";\n14\timport nacl from \"tweetnacl\";\n15\timport bs58 from \"bs58\";\n16\timport { PublicKey } from \"@solana/web3.js\";\n17\timport { SignJWT } from \"jose\";\n18\timport type { AuthDb } from \"../auth-db.js\";\n19\timport type { Db } from \"../db.js\";\n20\timport { logger } from \"../logger.js\";\n21\timport {\n22\t  ChallengeNonceResponseSchema,\n23\t  TokenResponseSchema,\n24\t} from \"../contracts/validators.js\";\n25\timport {\n26\t  envelope,\n27\t  ErrorEnvelopeSchema,\n28\t  ok,\n29\t  err,\n30\t} from \"../contracts/api-envelope.js\";\n31\timport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n32\timport { createOpenApiApp } from \"../openapi/hono.js\";\n33\t\n34\texport interface AuthRoutesDeps {\n35\t  authDb: AuthDb;\n36\t  db: Db;\n37\t  jwtSecret: Uint8Array;\n38\t  cluster: string;\n39\t  challengeTtlSeconds: number;\n40\t  accessTokenTtlSeconds: number;\n41\t  refreshTokenTtlDays: number;\n42\t}\n43\t\n44\tfunction hashToken(token: string): Buffer {\n45\t  return createHash(\"sha256\").update(token).digest();\n46\t}\n47\t\n48\tfunction issueAccessToken(\n49\t  jwtSecret: Uint8Array,\n50\t  userId: string,\n51\t  now: number,\n52\t  accessTokenTtlSeconds: number,\n53\t): Promise<string> {\n54\t  return new SignJWT({})\n55\t    .setProtectedHeader({ alg: \"HS256\" })\n56\t    .setSubject(userId)\n57\t    .setIssuedAt(now)\n58\t    .setExpirationTime(now + accessTokenTtlSeconds)\n59\t    .sign(jwtSecret);\n60\t}\n61\t\n62\tfunction formatNetwork(cluster: string): string {\n63\t  const normalized = cluster.toLowerCase();\n64\t  if (normalized === \"devnet\") return \"Solana Devnet\";\n65\t  if (normalized === \"mainnet\" || normalized === \"mainnet-beta\") return \"Solana Mainnet\";\n66\t  return `Solana ${cluster}`;\n67\t}\n68\t\n69\tfunction buildSignInMessage(\n70\t  wallet: string,\n71\t  cluster: string,\n72\t  nonce: string,\n73\t  issuedAt: string,\n74\t): string {\n75\t  return [\n76\t    \"Sign this message to create your Taunt BET account.\",\n77\t    \"\",\n78\t    \"This only verifies ownership. No gas or funds are used.\",\n79\t    \"\",\n80\t    `Wallet: ${wallet}`,"}]},"parent_tool_use_id":null,"session_id":"7939b4c7-aefe-4219-88b2-4cc3995099e7","uuid":"29e34a84-ddd8-4378-afec-97b4738570cf","timestamp":"2026-04-22T10:54:39.431Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/auth.ts","content":"/**\n * Auth routes: challenge/verify/refresh/logout for JWT session management.\n *\n * WAITLIST-CONTRACT: the waitlist (separate repo, launches first) calls every\n * route in this file. Any change to request/response shape here must keep\n * `waitlist/src/lib/auth-api.ts` in lockstep and is enforced by\n * `__tests__/waitlist-contract.test.ts`. Ship a coordinated waitlist release\n * before merging a breaking change.\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport { randomBytes, createHash } from \"node:crypto\";\nimport nacl from \"tweetnacl\";\nimport bs58 from \"bs58\";\nimport { PublicKey } from \"@solana/web3.js\";\nimport { SignJWT } from \"jose\";\nimport type { AuthDb } from \"../auth-db.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport {\n  ChallengeNonceResponseSchema,\n  TokenResponseSchema,\n} from \"../contracts/validators.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface AuthRoutesDeps {\n  authDb: AuthDb;\n  db: Db;\n  jwtSecret: Uint8Array;\n  cluster: string;\n  challengeTtlSeconds: number;\n  accessTokenTtlSeconds: number;\n  refreshTokenTtlDays: number;\n}\n\nfunction hashToken(token: string): Buffer {\n  return createHash(\"sha256\").update(token).digest();\n}\n\nfunction issueAccessToken(\n  jwtSecret: Uint8Array,\n  userId: string,\n  now: number,\n  accessTokenTtlSeconds: number,\n): Promise<string> {\n  return new SignJWT({})\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userId)\n    .setIssuedAt(now)\n    .setExpirationTime(now + accessTokenTtlSeconds)\n    .sign(jwtSecret);\n}\n\nfunction formatNetwork(cluster: string): string {\n  const normalized = cluster.toLowerCase();\n  if (normalized === \"devnet\") return \"Solana Devnet\";\n  if (normalized === \"mainnet\" || normalized === \"mainnet-beta\") return \"Solana Mainnet\";\n  return `Solana ${cluster}`;\n}\n\nfunction buildSignInMessage(\n  wallet: string,\n  cluster: string,\n  nonce: string,\n  issuedAt: string,\n): string {\n  return [\n    \"Sign this message to create your Taunt BET account.\",\n    \"\",\n    \"This only verifies ownership. No gas or funds are used.\",\n    \"\",\n    `Wallet: ${wallet}`,","numLines":80,"startLine":1,"totalLines":494}}}
