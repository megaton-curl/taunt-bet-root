{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DHoqKVnDWsKobDMCwqXRa6","type":"tool_result","content":"1\timport { OpenAPIHono } from \"@hono/zod-openapi\";\n2\timport { cors } from \"hono/cors\";\n3\timport { serve } from \"@hono/node-server\";\n4\timport { Connection, PublicKey } from \"@solana/web3.js\";\n5\timport postgres from \"postgres\";\n6\timport { loadConfig } from \"./config.js\";\n7\timport { createDb } from \"./db.js\";\n8\timport { createAuthDb } from \"./auth-db.js\";\n9\timport { createFlipYouRoutes } from \"./routes/create.js\";\n10\timport { createPotShotRoutes } from \"./routes/potshot-create.js\";\n11\timport { createCloseCallRoutes } from \"./routes/closecall.js\";\n12\timport { createHealthRoutes } from \"./routes/health.js\";\n13\timport { createProfileRoutes } from \"./routes/profile.js\";\n14\timport { createPublicProfileRoutes } from \"./routes/public-profile.js\";\n15\timport { createPublicReferralRoutes } from \"./routes/public-referral.js\";\n16\timport { createPriceRoutes } from \"./routes/price.js\";\n17\timport { createAuthRoutes } from \"./routes/auth.js\";\n18\timport { createReferralRoutes } from \"./routes/referral.js\";\n19\timport { createLeaderboardRoutes } from \"./routes/leaderboard.js\";\n20\timport { createChallengeRoutes } from \"./routes/challenges.js\";\n21\timport { createPointsRoutes, createCrateRoutes } from \"./routes/points.js\";\n22\timport { createDogpileRoutes } from \"./routes/dogpile.js\";\n23\timport { createAdminRoutes } from \"./routes/admin.js\";\n24\timport { createInternalRoutes } from \"./routes/internal.js\";\n25\timport { createTelegramLinkRoutes } from \"./routes/telegram-link.js\";\n26\timport { swaggerUI } from \"@hono/swagger-ui\";\n27\timport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n28\timport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n29\timport { createSettlementWorker } from \"./worker/settlement.js\";\n30\timport { settleRound } from \"./worker/settle-tx.js\";\n31\timport { createRetrySettler } from \"./worker/retry.js\";\n32\timport { createPdaWatcher } from \"./worker/pda-watcher.js\";\n33\timport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n34\timport { createDogpileWorker } from \"./worker/dogpile-worker.js\";\n35\timport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\n36\timport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n37\timport { createRewardPoolFundHandler } from \"./queue/handlers/reward-pool-fund.js\";\n38\timport { createPointsGrantHandler } from \"./queue/handlers/points-grant.js\";\n39\timport { createCrateDropHandler } from \"./queue/handlers/crate-drop.js\";\n40\timport { createGameSettledHandler } from \"./queue/handlers/game-settled.js\";\n41\timport { createCrateSolPayoutHandler } from \"./queue/handlers/crate-sol-payout.js\";\n42\timport { createProfileUsernameSetHandler } from \"./queue/handlers/profile-username-set.js\";\n43\timport { fetchSolPrice } from \"./routes/price.js\";\n44\timport { logger } from \"./logger.js\";\n45\t\n46\tconst config = loadConfig();\n47\t\n48\t// Single postgres pool shared by game DB, auth DB, and all workers\n49\tconst sql = postgres(config.databaseUrl);\n50\tconst db = createDb(config.databaseUrl, sql);\n51\tconst authDb = createAuthDb(sql);\n52\t\n53\tconst connection = new Connection(config.rpcUrl, {\n54\t  commitment: \"confirmed\",\n55\t  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n56\t});\n57\t\n58\tconst app = new OpenAPIHono();\n59\t\n60\tapp.use(\n61\t  \"*\",\n62\t  cors({\n63\t    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n64\t    allowMethods: [\"GET\", \"POST\", \"PUT\", \"OPTIONS\"],\n65\t    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\", \"X-Admin-Key\"],\n66\t  }),\n67\t);\n68\t\n69\t// Request logging — correlate frontend fetch timing with server-side processing\n70\tapp.use(\"*\", async (c, next) => {\n71\t  const start = Date.now();\n72\t  await next();\n73\t  const ms = Date.now() - start;\n74\t  const method = c.req.method;\n75\t  const path = c.req.path;\n76\t  // Skip noisy health checks and OPTIONS preflight\n77\t  if (path === \"/health\" || method === \"OPTIONS\") return;\n78\t  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n79\t});\n80\t\n81\t// Auth routes — no JWT middleware (these are the login endpoints)\n82\t// Lighter rate limiting by IP for auth endpoints\n83\tapp.use(\n84\t  \"/auth/*\",\n85\t  createRateLimitMiddleware({\n86\t    perWallet: 20,\n87\t    global: config.rateLimitGlobal,\n88\t    windowMs: 60_000,\n89\t  }),\n90\t);\n91\t\n92\tapp.route(\n93\t  \"/auth\",\n94\t  createAuthRoutes({\n95\t    authDb,\n96\t    db,\n97\t    jwtSecret: config.jwtSecret,\n98\t    cluster: config.cluster,\n99\t    challengeTtlSeconds: config.challengeTtlSeconds,\n100\t    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n101\t    refreshTokenTtlDays: config.refreshTokenTtlDays,\n102\t  }),\n103\t);\n104\t\n105\t// Profile routes — authenticated GET endpoints (require JWT on all methods)\n106\tapp.use(\n107\t  \"/profile/*\",\n108\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n109\t);\n110\tapp.route(\"/profile\", createProfileRoutes({ db }));\n111\t\n112\t// Public profile routes — no auth required\n113\tapp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n114\tapp.route(\"/public-referral\", createPublicReferralRoutes({ db }));\n115\t\n116\t// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n117\tapp.use(\n118\t  \"/referral/*\",\n119\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n120\t);\n121\tapp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n122\t\n123\t// Rate limiting — per-wallet and global limits on POST requests\n124\tapp.use(\n125\t  \"/flip-you/*\",\n126\t  createRateLimitMiddleware({\n127\t    perWallet: config.rateLimitPerWallet,\n128\t    global: config.rateLimitGlobal,\n129\t    windowMs: 60_000,\n130\t  }),\n131\t);\n132\t// JWT auth middleware for game endpoints\n133\tapp.use(\n134\t  \"/flip-you/*\",\n135\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n136\t);\n137\tapp.use(\n138\t  \"/pot-shot/*\",\n139\t  createRateLimitMiddleware({\n140\t    perWallet: config.rateLimitPerWallet,\n141\t    global: config.rateLimitGlobal,\n142\t    windowMs: 60_000,\n143\t  }),\n144\t);\n145\tapp.use(\n146\t  \"/pot-shot/*\",\n147\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n148\t);\n149\t\n150\t// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n151\tconst entropyAccount = new PublicKey(config.entropyAccount);\n152\tconst retrySettler = createRetrySettler({\n153\t  db,\n154\t  connection,\n155\t  settleRound: (pda) =>\n156\t    settleRound(\n157\t      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n158\t      pda,\n159\t    ),\n160\t});\n161\t\n162\t// PDA watcher — WebSocket-based instant join detection\n163\tconst pdaWatcher = createPdaWatcher({\n164\t  connection,\n165\t  serverKey: config.serverKeypair.publicKey,\n166\t  db,\n167\t  onJoinDetected: async (pda, targetSlot) => {\n168\t    // Update DB phase if still in 'created'\n169\t    const round = await db.getRoundByPda(pda);\n170\t    if (round && round.phase === \"created\") {\n171\t      await db.updateRoundPhase(pda, \"locked\", {\n172\t        target_slot: targetSlot.toString(),\n173\t      });\n174\t      await db.insertOperatorEvent(pda, \"match_detected\", {\n175\t        targetSlot: targetSlot.toString(),\n176\t        source: \"pda-watcher\",\n177\t        game: round.game,\n178\t      });\n179\t    }\n180\t\n181\t    // Check if target slot already passed — settle immediately if so\n182\t    const currentSlot = await connection.getSlot();\n183\t    if (BigInt(currentSlot) >= targetSlot) {\n184\t      await retrySettler.attemptSettle(pda);\n185\t      pdaWatcher.unwatch(pda);\n186\t    }\n187\t    // If target slot not reached yet, poll worker will pick it up next cycle\n188\t  },\n189\t});\n190\t\n191\tconst worker = createSettlementWorker({\n192\t  db,\n193\t  connection,\n194\t  serverKey: config.serverKeypair.publicKey,\n195\t  pollIntervalMs: config.workerPollIntervalMs,\n196\t  onSettleReady: async (pda) => {\n197\t    await retrySettler.attemptSettle(pda);\n198\t    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n199\t  },\n200\t  isFinalized: (pda) => retrySettler.isFinalized(pda),\n201\t});\n202\tworker.start();\n203\t\n204\t// Close Call clock worker — fetches boundary prices + settles open rounds\n205\t// Rounds are created on-demand by players via /closecall/bet\n206\tconst closeCallClock = createCloseCallClockWorker({\n207\t  connection,\n208\t  serverKeypair: config.serverKeypair,\n209\t  db,\n210\t});\n211\tcloseCallClock.start();\n212\t\n213\t// Register event handlers before starting the worker\n214\tregisterHandler(\n215\t  EventTypes.REFERRAL_CLAIM_REQUESTED,\n216\t  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n217\t);\n218\tregisterHandler(\n219\t  EventTypes.GAME_SETTLED,\n220\t  createGameSettledHandler({ db }),\n221\t);\n222\tregisterHandler(\n223\t  EventTypes.REWARD_POOL_FUND,\n224\t  createRewardPoolFundHandler({ db }),\n225\t);\n226\tregisterHandler(\n227\t  EventTypes.POINTS_GRANT,\n228\t  createPointsGrantHandler({\n229\t    db,\n230\t    getSolPrice: async () => {\n231\t      const result = await fetchSolPrice();\n232\t      return result?.price ?? null;\n233\t    },\n234\t  }),\n235\t);\n236\tregisterHandler(\n237\t  EventTypes.CRATE_DROP,\n238\t  createCrateDropHandler({ db }),\n239\t);\n240\tregisterHandler(\n241\t  EventTypes.CRATE_SOL_PAYOUT,\n242\t  createCrateSolPayoutHandler({ db, connection, serverKeypair: config.serverKeypair }),\n243\t);\n244\tregisterHandler(\n245\t  EventTypes.PROFILE_USERNAME_SET,\n246\t  createProfileUsernameSetHandler({ db }),\n247\t);\n248\t\n249\t// Dogpile status worker — transitions scheduled→active→ended\n250\tconst dogpileWorker = createDogpileWorker({ db, pollIntervalMs: 10_000 });\n251\tdogpileWorker.start();\n252\tlogger.info(\"Dogpile worker started\");\n253\t\n254\t// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n255\tconst eventWorker = createEventWorker(sql, {\n256\t  pollIntervalMs: config.eventQueuePollMs,\n257\t});\n258\teventWorker.start();\n259\tlogger.info(\"Event queue worker started\", {\n260\t  pollIntervalMs: config.eventQueuePollMs,\n261\t});\n262\t\n263\t// Game-specific routes\n264\tapp.route(\n265\t  \"/flip-you\",\n266\t  createFlipYouRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n267\t);\n268\tapp.route(\n269\t  \"/pot-shot\",\n270\t  createPotShotRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n271\t);\n272\t\n273\t// Close Call — rate limiting + JWT on POST /bet (co-signs with server keypair)\n274\tapp.use(\n275\t  \"/closecall/bet\",\n276\t  createRateLimitMiddleware({\n277\t    perWallet: config.rateLimitPerWallet,\n278\t    global: config.rateLimitGlobal,\n279\t    windowMs: 60_000,\n280\t  }),\n281\t);\n282\tapp.use(\n283\t  \"/closecall/bet\",\n284\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n285\t);\n286\t\n287\t// Close Call routes (read endpoints are public, /bet is auth'd above)\n288\tapp.route(\"/closecall\", createCloseCallRoutes({\n289\t  db,\n290\t  connection,\n291\t  serverKeypair: config.serverKeypair,\n292\t  clockWorker: closeCallClock,\n293\t}));\n294\t\n295\t// Challenge routes — authenticated GET endpoints (require JWT on all methods)\n296\tapp.use(\n297\t  \"/challenges/*\",\n298\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n299\t);\n300\tapp.route(\"/challenges\", createChallengeRoutes({ db }));\n301\t\n302\t// Points routes — authenticated GET endpoints (require JWT on all methods)\n303\tapp.use(\n304\t  \"/points/*\",\n305\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n306\t);\n307\tapp.route(\"/points\", createPointsRoutes({ db }));\n308\t\n309\t// Crate routes — authenticated GET endpoints (require JWT on all methods)\n310\tapp.use(\n311\t  \"/crates/*\",\n312\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n313\t);\n314\tapp.route(\"/crates\", createCrateRoutes({ db }));\n315\t\n316\t// Dogpile routes — GET endpoints remain public; POST routes still require JWT\n317\tapp.use(\n318\t  \"/dogpile/*\",\n319\t  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n320\t);\n321\tapp.route(\"/dogpile\", createDogpileRoutes({ db }));\n322\t\n323\t// Admin API routes — requires ADMIN_API_KEY env var\n324\tif (config.adminApiKey) {\n325\t  app.route(\"/admin\", createAdminRoutes({ db, adminApiKey: config.adminApiKey }));\n326\t  logger.info(\"Admin API routes enabled at /admin\");\n327\t}\n328\t\n329\t// Telegram link routes — generate-link requires JWT, redeem-link uses webhook secret\n330\tif (config.telegramBotUsername && config.telegramWebhookSecret) {\n331\t  app.use(\n332\t    \"/telegram/generate-link\",\n333\t    createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n334\t  );\n335\t  app.route(\n336\t    \"/telegram\",\n337\t    createTelegramLinkRoutes({\n338\t      db,\n339\t      telegramBotUsername: config.telegramBotUsername,\n340\t      telegramWebhookSecret: config.telegramWebhookSecret,\n341\t      communityInviteUrl: config.telegramCommunityInviteUrl,\n342\t      linkTokenTtlSeconds: config.telegramLinkTokenTtlSeconds,\n343\t    }),\n344\t  );\n345\t  logger.info(\"Telegram link routes enabled at /telegram\");\n346\t}\n347\t\n348\t// Leaderboard routes — public, no auth\n349\tapp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n350\t\n351\t// Price routes — public, no auth\n352\tapp.route(\"/price\", createPriceRoutes());\n353\t\n354\t// Health endpoint — wired after worker exists so we can query its status\n355\tapp.route(\n356\t  \"/health\",\n357\t  createHealthRoutes({\n358\t    isWorkerRunning: () => worker.isRunning,\n359\t  }),\n360\t);\n361\t\n362\t// Register security scheme for OpenAPI spec\n363\tapp.openAPIRegistry.registerComponent(\"securitySchemes\", \"bearerAuth\", {\n364\t  type: \"http\",\n365\t  scheme: \"bearer\",\n366\t  bearerFormat: \"JWT\",\n367\t  description:\n368\t    \"HS256 JWT obtained via /auth/verify. Payload: { sub: userId (usr_* format) }. \" +\n369\t    \"No wallet claim - wallet resolved from player profile when needed.\",\n370\t});\n371\t\n372\t// OpenAPI docs + internal admin routes — only when ADMIN_TOKEN is set (dev/devnet only)\n373\tif (config.adminToken) {\n374\t  app.doc(\"/openapi.json\", {\n375\t    openapi: \"3.0.3\",\n376\t    info: {\n377\t      title: \"Taunt Bet API\",\n378\t      description:\n379\t        \"Backend API for Taunt Bet - handles game round creation, \" +\n380\t        \"settlement verification, player profiles, referrals, and price feeds.\",\n381\t      version: \"0.1.0\",\n382\t    },\n383\t    servers: [\n384\t      { url: \"https://api.dev.taunt.bet\", description: \"Devnet\" },\n385\t      { url: \"http://localhost:3100\", description: \"Local\" },\n386\t      { url: \"https://api.taunt.bet\", description: \"Production\" },\n387\t    ],\n388\t  });\n389\t  app.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n390\t  logger.info(\"OpenAPI docs enabled at /docs and /openapi.json\");\n391\t  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n392\t  logger.warn(\"Internal admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production\");\n393\t}\n394\t\n395\tconst port = config.port;\n396\tlogger.info(\"fairness-backend started\", {\n397\t  port,\n398\t  publicAppUrl: config.publicAppUrl,\n399\t  publicAppDomain: config.publicAppDomain,\n400\t});\n401\t\n402\tserve({\n403\t  fetch: app.fetch,\n404\t  port,\n405\t  hostname: \"0.0.0.0\",\n406\t});\n407\t\n408\texport default {\n409\t  port,\n410\t  fetch: app.fetch,\n411\t};\n412\t"}]},"parent_tool_use_id":null,"session_id":"7939b4c7-aefe-4219-88b2-4cc3995099e7","uuid":"f29f0bde-0ce8-486d-b087-700ca4531747","timestamp":"2026-04-22T10:54:10.251Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/index.ts","content":"import { OpenAPIHono } from \"@hono/zod-openapi\";\nimport { cors } from \"hono/cors\";\nimport { serve } from \"@hono/node-server\";\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport postgres from \"postgres\";\nimport { loadConfig } from \"./config.js\";\nimport { createDb } from \"./db.js\";\nimport { createAuthDb } from \"./auth-db.js\";\nimport { createFlipYouRoutes } from \"./routes/create.js\";\nimport { createPotShotRoutes } from \"./routes/potshot-create.js\";\nimport { createCloseCallRoutes } from \"./routes/closecall.js\";\nimport { createHealthRoutes } from \"./routes/health.js\";\nimport { createProfileRoutes } from \"./routes/profile.js\";\nimport { createPublicProfileRoutes } from \"./routes/public-profile.js\";\nimport { createPublicReferralRoutes } from \"./routes/public-referral.js\";\nimport { createPriceRoutes } from \"./routes/price.js\";\nimport { createAuthRoutes } from \"./routes/auth.js\";\nimport { createReferralRoutes } from \"./routes/referral.js\";\nimport { createLeaderboardRoutes } from \"./routes/leaderboard.js\";\nimport { createChallengeRoutes } from \"./routes/challenges.js\";\nimport { createPointsRoutes, createCrateRoutes } from \"./routes/points.js\";\nimport { createDogpileRoutes } from \"./routes/dogpile.js\";\nimport { createAdminRoutes } from \"./routes/admin.js\";\nimport { createInternalRoutes } from \"./routes/internal.js\";\nimport { createTelegramLinkRoutes } from \"./routes/telegram-link.js\";\nimport { swaggerUI } from \"@hono/swagger-ui\";\nimport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\nimport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\nimport { createSettlementWorker } from \"./worker/settlement.js\";\nimport { settleRound } from \"./worker/settle-tx.js\";\nimport { createRetrySettler } from \"./worker/retry.js\";\nimport { createPdaWatcher } from \"./worker/pda-watcher.js\";\nimport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\nimport { createDogpileWorker } from \"./worker/dogpile-worker.js\";\nimport { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\nimport { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\nimport { createRewardPoolFundHandler } from \"./queue/handlers/reward-pool-fund.js\";\nimport { createPointsGrantHandler } from \"./queue/handlers/points-grant.js\";\nimport { createCrateDropHandler } from \"./queue/handlers/crate-drop.js\";\nimport { createGameSettledHandler } from \"./queue/handlers/game-settled.js\";\nimport { createCrateSolPayoutHandler } from \"./queue/handlers/crate-sol-payout.js\";\nimport { createProfileUsernameSetHandler } from \"./queue/handlers/profile-username-set.js\";\nimport { fetchSolPrice } from \"./routes/price.js\";\nimport { logger } from \"./logger.js\";\n\nconst config = loadConfig();\n\n// Single postgres pool shared by game DB, auth DB, and all workers\nconst sql = postgres(config.databaseUrl);\nconst db = createDb(config.databaseUrl, sql);\nconst authDb = createAuthDb(sql);\n\nconst connection = new Connection(config.rpcUrl, {\n  commitment: \"confirmed\",\n  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n});\n\nconst app = new OpenAPIHono();\n\napp.use(\n  \"*\",\n  cors({\n    origin: \"*\", // Safe: auth is bearer-token only (no cookies). Restrict if cookie auth is ever added.\n    allowMethods: [\"GET\", \"POST\", \"PUT\", \"OPTIONS\"],\n    allowHeaders: [\"Content-Type\", \"Authorization\", \"X-Admin-Token\", \"X-Admin-Key\"],\n  }),\n);\n\n// Request logging — correlate frontend fetch timing with server-side processing\napp.use(\"*\", async (c, next) => {\n  const start = Date.now();\n  await next();\n  const ms = Date.now() - start;\n  const method = c.req.method;\n  const path = c.req.path;\n  // Skip noisy health checks and OPTIONS preflight\n  if (path === \"/health\" || method === \"OPTIONS\") return;\n  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n});\n\n// Auth routes — no JWT middleware (these are the login endpoints)\n// Lighter rate limiting by IP for auth endpoints\napp.use(\n  \"/auth/*\",\n  createRateLimitMiddleware({\n    perWallet: 20,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n\napp.route(\n  \"/auth\",\n  createAuthRoutes({\n    authDb,\n    db,\n    jwtSecret: config.jwtSecret,\n    cluster: config.cluster,\n    challengeTtlSeconds: config.challengeTtlSeconds,\n    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    refreshTokenTtlDays: config.refreshTokenTtlDays,\n  }),\n);\n\n// Profile routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/profile/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/profile\", createProfileRoutes({ db }));\n\n// Public profile routes — no auth required\napp.route(\"/public-profile\", createPublicProfileRoutes({ db }));\napp.route(\"/public-referral\", createPublicReferralRoutes({ db }));\n\n// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\napp.use(\n  \"/referral/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n\n// Rate limiting — per-wallet and global limits on POST requests\napp.use(\n  \"/flip-you/*\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\n// JWT auth middleware for game endpoints\napp.use(\n  \"/flip-you/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\napp.use(\n  \"/pot-shot/*\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\napp.use(\n  \"/pot-shot/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\n\n// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\nconst entropyAccount = new PublicKey(config.entropyAccount);\nconst retrySettler = createRetrySettler({\n  db,\n  connection,\n  settleRound: (pda) =>\n    settleRound(\n      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n      pda,\n    ),\n});\n\n// PDA watcher — WebSocket-based instant join detection\nconst pdaWatcher = createPdaWatcher({\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  db,\n  onJoinDetected: async (pda, targetSlot) => {\n    // Update DB phase if still in 'created'\n    const round = await db.getRoundByPda(pda);\n    if (round && round.phase === \"created\") {\n      await db.updateRoundPhase(pda, \"locked\", {\n        target_slot: targetSlot.toString(),\n      });\n      await db.insertOperatorEvent(pda, \"match_detected\", {\n        targetSlot: targetSlot.toString(),\n        source: \"pda-watcher\",\n        game: round.game,\n      });\n    }\n\n    // Check if target slot already passed — settle immediately if so\n    const currentSlot = await connection.getSlot();\n    if (BigInt(currentSlot) >= targetSlot) {\n      await retrySettler.attemptSettle(pda);\n      pdaWatcher.unwatch(pda);\n    }\n    // If target slot not reached yet, poll worker will pick it up next cycle\n  },\n});\n\nconst worker = createSettlementWorker({\n  db,\n  connection,\n  serverKey: config.serverKeypair.publicKey,\n  pollIntervalMs: config.workerPollIntervalMs,\n  onSettleReady: async (pda) => {\n    await retrySettler.attemptSettle(pda);\n    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n  },\n  isFinalized: (pda) => retrySettler.isFinalized(pda),\n});\nworker.start();\n\n// Close Call clock worker — fetches boundary prices + settles open rounds\n// Rounds are created on-demand by players via /closecall/bet\nconst closeCallClock = createCloseCallClockWorker({\n  connection,\n  serverKeypair: config.serverKeypair,\n  db,\n});\ncloseCallClock.start();\n\n// Register event handlers before starting the worker\nregisterHandler(\n  EventTypes.REFERRAL_CLAIM_REQUESTED,\n  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n);\nregisterHandler(\n  EventTypes.GAME_SETTLED,\n  createGameSettledHandler({ db }),\n);\nregisterHandler(\n  EventTypes.REWARD_POOL_FUND,\n  createRewardPoolFundHandler({ db }),\n);\nregisterHandler(\n  EventTypes.POINTS_GRANT,\n  createPointsGrantHandler({\n    db,\n    getSolPrice: async () => {\n      const result = await fetchSolPrice();\n      return result?.price ?? null;\n    },\n  }),\n);\nregisterHandler(\n  EventTypes.CRATE_DROP,\n  createCrateDropHandler({ db }),\n);\nregisterHandler(\n  EventTypes.CRATE_SOL_PAYOUT,\n  createCrateSolPayoutHandler({ db, connection, serverKeypair: config.serverKeypair }),\n);\nregisterHandler(\n  EventTypes.PROFILE_USERNAME_SET,\n  createProfileUsernameSetHandler({ db }),\n);\n\n// Dogpile status worker — transitions scheduled→active→ended\nconst dogpileWorker = createDogpileWorker({ db, pollIntervalMs: 10_000 });\ndogpileWorker.start();\nlogger.info(\"Dogpile worker started\");\n\n// Event queue worker — processes async side-effects (rewards, notifications, etc.)\nconst eventWorker = createEventWorker(sql, {\n  pollIntervalMs: config.eventQueuePollMs,\n});\neventWorker.start();\nlogger.info(\"Event queue worker started\", {\n  pollIntervalMs: config.eventQueuePollMs,\n});\n\n// Game-specific routes\napp.route(\n  \"/flip-you\",\n  createFlipYouRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n);\napp.route(\n  \"/pot-shot\",\n  createPotShotRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n);\n\n// Close Call — rate limiting + JWT on POST /bet (co-signs with server keypair)\napp.use(\n  \"/closecall/bet\",\n  createRateLimitMiddleware({\n    perWallet: config.rateLimitPerWallet,\n    global: config.rateLimitGlobal,\n    windowMs: 60_000,\n  }),\n);\napp.use(\n  \"/closecall/bet\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\n\n// Close Call routes (read endpoints are public, /bet is auth'd above)\napp.route(\"/closecall\", createCloseCallRoutes({\n  db,\n  connection,\n  serverKeypair: config.serverKeypair,\n  clockWorker: closeCallClock,\n}));\n\n// Challenge routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/challenges/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/challenges\", createChallengeRoutes({ db }));\n\n// Points routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/points/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/points\", createPointsRoutes({ db }));\n\n// Crate routes — authenticated GET endpoints (require JWT on all methods)\napp.use(\n  \"/crates/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n);\napp.route(\"/crates\", createCrateRoutes({ db }));\n\n// Dogpile routes — GET endpoints remain public; POST routes still require JWT\napp.use(\n  \"/dogpile/*\",\n  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n);\napp.route(\"/dogpile\", createDogpileRoutes({ db }));\n\n// Admin API routes — requires ADMIN_API_KEY env var\nif (config.adminApiKey) {\n  app.route(\"/admin\", createAdminRoutes({ db, adminApiKey: config.adminApiKey }));\n  logger.info(\"Admin API routes enabled at /admin\");\n}\n\n// Telegram link routes — generate-link requires JWT, redeem-link uses webhook secret\nif (config.telegramBotUsername && config.telegramWebhookSecret) {\n  app.use(\n    \"/telegram/generate-link\",\n    createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n  );\n  app.route(\n    \"/telegram\",\n    createTelegramLinkRoutes({\n      db,\n      telegramBotUsername: config.telegramBotUsername,\n      telegramWebhookSecret: config.telegramWebhookSecret,\n      communityInviteUrl: config.telegramCommunityInviteUrl,\n      linkTokenTtlSeconds: config.telegramLinkTokenTtlSeconds,\n    }),\n  );\n  logger.info(\"Telegram link routes enabled at /telegram\");\n}\n\n// Leaderboard routes — public, no auth\napp.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n\n// Price routes — public, no auth\napp.route(\"/price\", createPriceRoutes());\n\n// Health endpoint — wired after worker exists so we can query its status\napp.route(\n  \"/health\",\n  createHealthRoutes({\n    isWorkerRunning: () => worker.isRunning,\n  }),\n);\n\n// Register security scheme for OpenAPI spec\napp.openAPIRegistry.registerComponent(\"securitySchemes\", \"bearerAuth\", {\n  type: \"http\",\n  scheme: \"bearer\",\n  bearerFormat: \"JWT\",\n  description:\n    \"HS256 JWT obtained via /auth/verify. Payload: { sub: userId (usr_* format) }. \" +\n    \"No wallet claim - wallet resolved from player profile when needed.\",\n});\n\n// OpenAPI docs + internal admin routes — only when ADMIN_TOKEN is set (dev/devnet only)\nif (config.adminToken) {\n  app.doc(\"/openapi.json\", {\n    openapi: \"3.0.3\",\n    info: {\n      title: \"Taunt Bet API\",\n      description:\n        \"Backend API for Taunt Bet - handles game round creation, \" +\n        \"settlement verification, player profiles, referrals, and price feeds.\",\n      version: \"0.1.0\",\n    },\n    servers: [\n      { url: \"https://api.dev.taunt.bet\", description: \"Devnet\" },\n      { url: \"http://localhost:3100\", description: \"Local\" },\n      { url: \"https://api.taunt.bet\", description: \"Production\" },\n    ],\n  });\n  app.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n  logger.info(\"OpenAPI docs enabled at /docs and /openapi.json\");\n  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n  logger.warn(\"Internal admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production\");\n}\n\nconst port = config.port;\nlogger.info(\"fairness-backend started\", {\n  port,\n  publicAppUrl: config.publicAppUrl,\n  publicAppDomain: config.publicAppDomain,\n});\n\nserve({\n  fetch: app.fetch,\n  port,\n  hostname: \"0.0.0.0\",\n});\n\nexport default {\n  port,\n  fetch: app.fetch,\n};\n","numLines":412,"startLine":1,"totalLines":412}}}
