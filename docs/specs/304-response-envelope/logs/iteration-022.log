{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VkkRES2vPvML6RXFXxcTs4","type":"tool_result","content":"1\t/**\n2\t * Shared response envelope for public JSON routes.\n3\t *\n4\t * Every public JSON response body is either:\n5\t *   { ok: true,  data: <payload> }   — success (200/201/202)\n6\t *   { ok: false, error: ApiError }   — failure (4xx/5xx)\n7\t *\n8\t * Semantic HTTP status is preserved — handled domain failures MUST NOT be\n9\t * flattened into `200`. See `docs/specs/304-response-envelope/spec.md`.\n10\t */\n11\t\n12\timport { z } from \"zod\";\n13\timport type { Context, TypedResponse } from \"hono\";\n14\t\n15\texport type { ApiErrorCode } from \"./api-errors.js\";\n16\timport type { ApiErrorCode } from \"./api-errors.js\";\n17\t\n18\t/**\n19\t * Structured metadata accompanying an error (Zod issues, limits, etc.).\n20\t * Typed as JSON-serializable via a broad shape to stay compatible with\n21\t * hono's `TypedResponse` body constraint while accepting arbitrary objects\n22\t * (Zod issues, Date-like POJOs, etc.) at runtime.\n23\t */\n24\t// eslint-disable-next-line @typescript-eslint/no-explicit-any\n25\texport type ApiErrorDetails = any;\n26\t\n27\texport interface ApiError {\n28\t  code: ApiErrorCode;\n29\t  message: string;\n30\t  retryable?: boolean;\n31\t  details?: ApiErrorDetails;\n32\t}\n33\t\n34\texport interface ApiEnvelopeSuccess<T> {\n35\t  ok: true;\n36\t  data: T;\n37\t}\n38\t\n39\texport interface ApiEnvelopeError {\n40\t  ok: false;\n41\t  error: ApiError;\n42\t}\n43\t\n44\texport type ApiEnvelope<T> = ApiEnvelopeSuccess<T> | ApiEnvelopeError;\n45\t\n46\texport const ApiErrorSchema = z.object({\n47\t  code: z.string(),\n48\t  message: z.string(),\n49\t  retryable: z.boolean().optional(),\n50\t  details: z.unknown().optional(),\n51\t});\n52\t\n53\texport const ErrorEnvelopeSchema = z.object({\n54\t  ok: z.literal(false),\n55\t  error: ApiErrorSchema,\n56\t});\n57\t\n58\texport function envelope<T extends z.ZodTypeAny>(dataSchema: T) {\n59\t  return z.discriminatedUnion(\"ok\", [\n60\t    z.object({\n61\t      ok: z.literal(true),\n62\t      data: dataSchema,\n63\t    }),\n64\t    ErrorEnvelopeSchema,\n65\t  ]);\n66\t}\n67\t\n68\texport type SuccessStatus = 200 | 201 | 202;\n69\texport type ErrorStatus = 400 | 401 | 403 | 404 | 409 | 422 | 429 | 500 | 503;\n70\t\n71\t/* eslint-disable no-redeclare, no-undef */\n72\texport function ok<T>(\n73\t  c: Context,\n74\t  data: T,\n75\t): Response & TypedResponse<ApiEnvelopeSuccess<T>, 200, \"json\">;\n76\texport function ok<T, S extends SuccessStatus>(\n77\t  c: Context,\n78\t  data: T,\n79\t  status: S,\n80\t): Response & TypedResponse<ApiEnvelopeSuccess<T>, S, \"json\">;\n81\texport function ok<T>(c: Context, data: T, status: SuccessStatus = 200) {\n82\t  const body: ApiEnvelopeSuccess<T> = { ok: true, data };\n83\t  return c.json(body, status);\n84\t}\n85\t\n86\texport function err<S extends ErrorStatus>(\n87\t  c: Context,\n88\t  status: S,\n89\t  code: ApiErrorCode,\n90\t  message: string,\n91\t  opts?: { retryable?: boolean; details?: ApiErrorDetails },\n92\t): Response & TypedResponse<ApiEnvelopeError, S, \"json\"> {\n93\t  const error: ApiError = { code, message };\n94\t  if (opts?.retryable !== undefined) error.retryable = opts.retryable;\n95\t  if (opts?.details !== undefined) error.details = opts.details;\n96\t  const body: ApiEnvelopeError = { ok: false, error };\n97\t  return c.json(body, status);\n98\t}\n99\t/* eslint-enable no-redeclare, no-undef */\n100\t"}]},"parent_tool_use_id":null,"session_id":"7939b4c7-aefe-4219-88b2-4cc3995099e7","uuid":"fafec8e2-110a-4b87-a9eb-e16815076bb7","timestamp":"2026-04-22T10:54:21.715Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/contracts/api-envelope.ts","content":"/**\n * Shared response envelope for public JSON routes.\n *\n * Every public JSON response body is either:\n *   { ok: true,  data: <payload> }   — success (200/201/202)\n *   { ok: false, error: ApiError }   — failure (4xx/5xx)\n *\n * Semantic HTTP status is preserved — handled domain failures MUST NOT be\n * flattened into `200`. See `docs/specs/304-response-envelope/spec.md`.\n */\n\nimport { z } from \"zod\";\nimport type { Context, TypedResponse } from \"hono\";\n\nexport type { ApiErrorCode } from \"./api-errors.js\";\nimport type { ApiErrorCode } from \"./api-errors.js\";\n\n/**\n * Structured metadata accompanying an error (Zod issues, limits, etc.).\n * Typed as JSON-serializable via a broad shape to stay compatible with\n * hono's `TypedResponse` body constraint while accepting arbitrary objects\n * (Zod issues, Date-like POJOs, etc.) at runtime.\n */\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\nexport type ApiErrorDetails = any;\n\nexport interface ApiError {\n  code: ApiErrorCode;\n  message: string;\n  retryable?: boolean;\n  details?: ApiErrorDetails;\n}\n\nexport interface ApiEnvelopeSuccess<T> {\n  ok: true;\n  data: T;\n}\n\nexport interface ApiEnvelopeError {\n  ok: false;\n  error: ApiError;\n}\n\nexport type ApiEnvelope<T> = ApiEnvelopeSuccess<T> | ApiEnvelopeError;\n\nexport const ApiErrorSchema = z.object({\n  code: z.string(),\n  message: z.string(),\n  retryable: z.boolean().optional(),\n  details: z.unknown().optional(),\n});\n\nexport const ErrorEnvelopeSchema = z.object({\n  ok: z.literal(false),\n  error: ApiErrorSchema,\n});\n\nexport function envelope<T extends z.ZodTypeAny>(dataSchema: T) {\n  return z.discriminatedUnion(\"ok\", [\n    z.object({\n      ok: z.literal(true),\n      data: dataSchema,\n    }),\n    ErrorEnvelopeSchema,\n  ]);\n}\n\nexport type SuccessStatus = 200 | 201 | 202;\nexport type ErrorStatus = 400 | 401 | 403 | 404 | 409 | 422 | 429 | 500 | 503;\n\n/* eslint-disable no-redeclare, no-undef */\nexport function ok<T>(\n  c: Context,\n  data: T,\n): Response & TypedResponse<ApiEnvelopeSuccess<T>, 200, \"json\">;\nexport function ok<T, S extends SuccessStatus>(\n  c: Context,\n  data: T,\n  status: S,\n): Response & TypedResponse<ApiEnvelopeSuccess<T>, S, \"json\">;\nexport function ok<T>(c: Context, data: T, status: SuccessStatus = 200) {\n  const body: ApiEnvelopeSuccess<T> = { ok: true, data };\n  return c.json(body, status);\n}\n\nexport function err<S extends ErrorStatus>(\n  c: Context,\n  status: S,\n  code: ApiErrorCode,\n  message: string,\n  opts?: { retryable?: boolean; details?: ApiErrorDetails },\n): Response & TypedResponse<ApiEnvelopeError, S, \"json\"> {\n  const error: ApiError = { code, message };\n  if (opts?.retryable !== undefined) error.retryable = opts.retryable;\n  if (opts?.details !== undefined) error.details = opts.details;\n  const body: ApiEnvelopeError = { ok: false, error };\n  return c.json(body, status);\n}\n/* eslint-enable no-redeclare, no-undef */\n","numLines":100,"startLine":1,"totalLines":100}}}
