{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N9tk5UVkjdaDURqkFh4rBh","type":"tool_result","content":"80\t    `Wallet: ${wallet}`,\n81\t    `Network: ${formatNetwork(cluster)}`,\n82\t    `Timestamp: ${issuedAt}`,\n83\t    `Nonce: ${nonce}`,\n84\t  ].join(\"\\n\");\n85\t}\n86\t\n87\t// ---------------------------------------------------------------------------\n88\t// Route definitions\n89\t// ---------------------------------------------------------------------------\n90\t\n91\tconst challengeRoute = createRoute({\n92\t  method: \"post\",\n93\t  path: \"/challenge\",\n94\t  tags: [\"Auth\"],\n95\t  summary: \"Request sign-in challenge\",\n96\t  request: {\n97\t    body: {\n98\t      required: true,\n99\t      content: {\n100\t        \"application/json\": {\n101\t          schema: z.object({\n102\t            wallet: z.string().min(1).describe(\"Base58 wallet address\"),\n103\t          }),\n104\t        },\n105\t      },\n106\t    },\n107\t  },\n108\t  responses: {\n109\t    200: {\n110\t      content: { \"application/json\": { schema: envelope(ChallengeNonceResponseSchema) } },\n111\t      description: \"Challenge issued\",\n112\t    },\n113\t    422: {\n114\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n115\t      description: \"Invalid request\",\n116\t    },\n117\t  },\n118\t});\n119\t\n120\tconst verifyRoute = createRoute({\n121\t  method: \"post\",\n122\t  path: \"/verify\",\n123\t  tags: [\"Auth\"],\n124\t  summary: \"Verify signature and issue tokens\",\n125\t  request: {\n126\t    body: {\n127\t      required: true,\n128\t      content: {\n129\t        \"application/json\": {\n130\t          schema: z.object({\n131\t            nonce: z.string(),\n132\t            wallet: z.string(),\n133\t            signature: z.string().describe(\"Base58-encoded Ed25519 signature\"),\n134\t          }),\n135\t        },\n136\t      },\n137\t    },\n138\t  },\n139\t  responses: {\n140\t    200: {\n141\t      content: { \"application/json\": { schema: envelope(TokenResponseSchema) } },\n142\t      description: \"Tokens issued\",\n143\t    },\n144\t    401: {\n145\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n146\t      description: \"Invalid signature or challenge\",\n147\t    },\n148\t    422: {\n149\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n150\t      description: \"Invalid request\",\n151\t    },\n152\t    500: {\n153\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n154\t      description: \"Server error\",\n155\t    },\n156\t  },\n157\t});\n158\t\n159\tconst refreshRoute = createRoute({\n160\t  method: \"post\",\n161\t  path: \"/refresh\",\n162\t  tags: [\"Auth\"],\n163\t  summary: \"Rotate refresh token and issue new access token\",\n164\t  request: {\n165\t    body: {\n166\t      required: true,\n167\t      content: {\n168\t        \"application/json\": {\n169\t          schema: z.object({\n170\t            refreshToken: z.string(),\n171\t          }),\n172\t        },\n173\t      },\n174\t    },\n175\t  },\n176\t  responses: {\n177\t    200: {\n178\t      content: { \"application/json\": { schema: envelope(TokenResponseSchema) } },\n179\t      description: \"New tokens issued\",\n180\t    },\n181\t    401: {\n182\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n183\t      description: \"Invalid or expired token\",\n184\t    },\n185\t    422: {\n186\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n187\t      description: \"Invalid request\",\n188\t    },\n189\t  },\n190\t});\n191\t\n192\tconst logoutRoute = createRoute({\n193\t  method: \"post\",\n194\t  path: \"/logout\",\n195\t  tags: [\"Auth\"],\n196\t  summary: \"Revoke refresh token\",\n197\t  request: {\n198\t    body: {\n199\t      content: {\n200\t        \"application/json\": {\n201\t          schema: z.object({\n202\t            refreshToken: z.string().optional(),\n203\t          }),\n204\t        },\n205\t      },\n206\t    },\n207\t  },\n208\t  responses: {\n209\t    204: {\n210\t      description: \"Logged out\",\n211\t    },\n212\t  },\n213\t});\n214\t\n215\t// ---------------------------------------------------------------------------\n216\t// Route factory\n217\t// ---------------------------------------------------------------------------\n218\t\n219\texport function createAuthRoutes(deps: AuthRoutesDeps) {\n220\t  const {\n221\t    authDb,\n222\t    db,\n223\t    jwtSecret,\n224\t    cluster,\n225\t    challengeTtlSeconds,\n226\t    accessTokenTtlSeconds,\n227\t    refreshTokenTtlDays,\n228\t  } = deps;\n229\t\n230\t  const app = createOpenApiApp();\n231\t\n232\t  // POST /challenge — generate nonce + human-readable message\n233\t  app.openapi(challengeRoute, async (c) => {\n234\t    const { wallet } = c.req.valid(\"json\");\n235\t\n236\t    const nonce = randomBytes(32).toString(\"hex\");\n237\t    const now = new Date();\n238\t    const expiresAt = new Date(now.getTime() + challengeTtlSeconds * 1000);\n239\t\n240\t    const message = buildSignInMessage(\n241\t      wallet,\n242\t      cluster,\n243\t      nonce,\n244\t      now.toISOString(),\n245\t    );\n246\t\n247\t    await authDb.insertChallenge(nonce, wallet, cluster, message, expiresAt);\n248\t\n249\t    logger.info(\"auth challenge issued\", { wallet, nonce });\n250\t\n251\t    return ok(c, {\n252\t      nonce,\n253\t      message,\n254\t      expiresAt: expiresAt.toISOString(),\n255\t    });\n256\t  });\n257\t\n258\t  // POST /verify — consume challenge, verify signature, issue tokens\n259\t  app.openapi(verifyRoute, async (c) => {\n260\t    const { nonce, wallet, signature } = c.req.valid(\"json\");\n261\t\n262\t    // Atomically consume the challenge\n263\t    const challenge = await authDb.consumeChallenge(nonce);\n264\t    if (!challenge) {\n265\t      logger.warn(\"auth verify rejected: challenge not found or expired\", {\n266\t        nonce,\n267\t        wallet,\n268\t      });\n269\t      return err(\n270\t        c,\n271\t        401,\n272\t        API_ERROR_CODES.CHALLENGE_EXPIRED,\n273\t        \"Challenge not found, expired, or already used\",\n274\t      );\n275\t    }\n276\t\n277\t    // Verify wallet matches challenge\n278\t    if (challenge.wallet !== wallet) {\n279\t      logger.warn(\"auth verify rejected: wallet mismatch\", {\n280\t        nonce,\n281\t        challengeWallet: challenge.wallet,\n282\t        requestWallet: wallet,\n283\t      });\n284\t      return err(\n285\t        c,\n286\t        401,\n287\t        API_ERROR_CODES.INVALID_SIGNATURE,\n288\t        \"Wallet does not match challenge\",\n289\t      );\n290\t    }\n291\t\n292\t    // Verify Ed25519 signature over the challenge message.\n293\t    // PublicKey validates base58 + 32-byte length + on-curve; signature only\n294\t    // needs base58 decode (raw 64-byte ed25519 sig, not a pubkey).\n295\t    let sigBytes: Uint8Array;\n296\t    let pubkeyBytes: Uint8Array;\n297\t    try {\n298\t      sigBytes = bs58.decode(signature);\n299\t      pubkeyBytes = new PublicKey(wallet).toBytes();"}]},"parent_tool_use_id":null,"session_id":"7939b4c7-aefe-4219-88b2-4cc3995099e7","uuid":"dd3f5632-8061-44b6-ad34-81519a112e3a","timestamp":"2026-04-22T10:58:39.825Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/auth.ts","content":"    `Wallet: ${wallet}`,\n    `Network: ${formatNetwork(cluster)}`,\n    `Timestamp: ${issuedAt}`,\n    `Nonce: ${nonce}`,\n  ].join(\"\\n\");\n}\n\n// ---------------------------------------------------------------------------\n// Route definitions\n// ---------------------------------------------------------------------------\n\nconst challengeRoute = createRoute({\n  method: \"post\",\n  path: \"/challenge\",\n  tags: [\"Auth\"],\n  summary: \"Request sign-in challenge\",\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": {\n          schema: z.object({\n            wallet: z.string().min(1).describe(\"Base58 wallet address\"),\n          }),\n        },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(ChallengeNonceResponseSchema) } },\n      description: \"Challenge issued\",\n    },\n    422: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid request\",\n    },\n  },\n});\n\nconst verifyRoute = createRoute({\n  method: \"post\",\n  path: \"/verify\",\n  tags: [\"Auth\"],\n  summary: \"Verify signature and issue tokens\",\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": {\n          schema: z.object({\n            nonce: z.string(),\n            wallet: z.string(),\n            signature: z.string().describe(\"Base58-encoded Ed25519 signature\"),\n          }),\n        },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(TokenResponseSchema) } },\n      description: \"Tokens issued\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid signature or challenge\",\n    },\n    422: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid request\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\nconst refreshRoute = createRoute({\n  method: \"post\",\n  path: \"/refresh\",\n  tags: [\"Auth\"],\n  summary: \"Rotate refresh token and issue new access token\",\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": {\n          schema: z.object({\n            refreshToken: z.string(),\n          }),\n        },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(TokenResponseSchema) } },\n      description: \"New tokens issued\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid or expired token\",\n    },\n    422: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid request\",\n    },\n  },\n});\n\nconst logoutRoute = createRoute({\n  method: \"post\",\n  path: \"/logout\",\n  tags: [\"Auth\"],\n  summary: \"Revoke refresh token\",\n  request: {\n    body: {\n      content: {\n        \"application/json\": {\n          schema: z.object({\n            refreshToken: z.string().optional(),\n          }),\n        },\n      },\n    },\n  },\n  responses: {\n    204: {\n      description: \"Logged out\",\n    },\n  },\n});\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport function createAuthRoutes(deps: AuthRoutesDeps) {\n  const {\n    authDb,\n    db,\n    jwtSecret,\n    cluster,\n    challengeTtlSeconds,\n    accessTokenTtlSeconds,\n    refreshTokenTtlDays,\n  } = deps;\n\n  const app = createOpenApiApp();\n\n  // POST /challenge — generate nonce + human-readable message\n  app.openapi(challengeRoute, async (c) => {\n    const { wallet } = c.req.valid(\"json\");\n\n    const nonce = randomBytes(32).toString(\"hex\");\n    const now = new Date();\n    const expiresAt = new Date(now.getTime() + challengeTtlSeconds * 1000);\n\n    const message = buildSignInMessage(\n      wallet,\n      cluster,\n      nonce,\n      now.toISOString(),\n    );\n\n    await authDb.insertChallenge(nonce, wallet, cluster, message, expiresAt);\n\n    logger.info(\"auth challenge issued\", { wallet, nonce });\n\n    return ok(c, {\n      nonce,\n      message,\n      expiresAt: expiresAt.toISOString(),\n    });\n  });\n\n  // POST /verify — consume challenge, verify signature, issue tokens\n  app.openapi(verifyRoute, async (c) => {\n    const { nonce, wallet, signature } = c.req.valid(\"json\");\n\n    // Atomically consume the challenge\n    const challenge = await authDb.consumeChallenge(nonce);\n    if (!challenge) {\n      logger.warn(\"auth verify rejected: challenge not found or expired\", {\n        nonce,\n        wallet,\n      });\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.CHALLENGE_EXPIRED,\n        \"Challenge not found, expired, or already used\",\n      );\n    }\n\n    // Verify wallet matches challenge\n    if (challenge.wallet !== wallet) {\n      logger.warn(\"auth verify rejected: wallet mismatch\", {\n        nonce,\n        challengeWallet: challenge.wallet,\n        requestWallet: wallet,\n      });\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.INVALID_SIGNATURE,\n        \"Wallet does not match challenge\",\n      );\n    }\n\n    // Verify Ed25519 signature over the challenge message.\n    // PublicKey validates base58 + 32-byte length + on-curve; signature only\n    // needs base58 decode (raw 64-byte ed25519 sig, not a pubkey).\n    let sigBytes: Uint8Array;\n    let pubkeyBytes: Uint8Array;\n    try {\n      sigBytes = bs58.decode(signature);\n      pubkeyBytes = new PublicKey(wallet).toBytes();","numLines":220,"startLine":80,"totalLines":494}}}
