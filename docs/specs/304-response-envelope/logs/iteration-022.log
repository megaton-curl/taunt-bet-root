{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0116kiTDDDBHUP649YA4Takt","type":"tool_result","content":"85\t// Route factory\n86\t// ---------------------------------------------------------------------------\n87\t\n88\texport function createDogpileRoutes(deps: DogpileRoutesDeps) {\n89\t  const { db } = deps;\n90\t  const app = createOpenApiApp<AppEnv>();\n91\t\n92\t  // GET /current — active event > next scheduled > null\n93\t  app.openapi(currentRoute, async (c) => {\n94\t    try {\n95\t      // Try active first\n96\t      const active = await db.rawSql<DogpileEventRow[]>`\n97\t        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n98\t        FROM dogpile_events\n99\t        WHERE status = 'active'\n100\t        ORDER BY starts_at ASC\n101\t        LIMIT 1\n102\t      `;\n103\t\n104\t      if (active.length > 0) {\n105\t        const e = active[0]!;\n106\t        return ok(c, {\n107\t          id: Number(e.id),\n108\t          multiplier: Number(e.multiplier),\n109\t          startsAt: e.starts_at.toISOString(),\n110\t          endsAt: e.ends_at.toISOString(),\n111\t          status: \"active\" as const,\n112\t          endsIn: Math.max(0, e.ends_at.getTime() - Date.now()),\n113\t        });\n114\t      }\n115\t\n116\t      // Try next scheduled\n117\t      const scheduled = await db.rawSql<DogpileEventRow[]>`\n118\t        SELECT id, multiplier, starts_at, ends_at, status, campaign_id\n119\t        FROM dogpile_events\n120\t        WHERE status = 'scheduled'\n121\t          AND starts_at > now()\n122\t        ORDER BY starts_at ASC\n123\t        LIMIT 1\n124\t      `;\n125\t\n126\t      if (scheduled.length > 0) {\n127\t        const e = scheduled[0]!;\n128\t        return ok(c, {\n129\t          id: Number(e.id),\n130\t          multiplier: Number(e.multiplier),\n131\t          startsAt: e.starts_at.toISOString(),\n132\t          endsAt: e.ends_at.toISOString(),\n133\t          status: \"scheduled\" as const,\n134\t  