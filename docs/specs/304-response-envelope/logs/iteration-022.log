ing description:\\n${missing.join(\"\\n\")}`).toHaveLength(0);\n  });\n\n  // ─────────────────────────────────────────────────────────────────────\n  // Envelope contract (spec 304)\n  // ─────────────────────────────────────────────────────────────────────\n\n  /**\n   * Returns `true` if `schema` represents an `{ ok: false, error: ApiError }`\n   * body — either inline or via a `$ref` to the registered `ErrorEnvelope`\n   * component.\n   */\n  function isErrorEnvelope(schema: AnyRecord): boolean {\n    if (typeof schema.$ref === \"string\") {\n      if (schema.$ref === \"#/components/schemas/ErrorEnvelope\") return true;\n    }\n    const properties = schema.properties as AnyRecord | undefined;\n    if (!properties) return false;\n    const ok = properties.ok as AnyRecord | undefined;\n    if (!ok) return false;\n    const enumValues = ok.enum as unknown[] | undefined;\n    const onlyFalse = Array.isArray(enumValues) && enumValues.length === 1 && enumValues[0] === false;\n    if (!onlyFalse) return false;\n    return \"error\" in properties;\n  }\n\n  /**\n   * Returns `true` if `schema` represents the success branch of an\n   * `{ ok: true, data: T }` envelope.\n   */\n  function isSuccessEnvelopeVariant(schema: AnyRecord): boolean {\n    const properties = schema.properties as AnyRecord | undefined;\n    if (!properties) return false;\n    const ok = properties.ok as AnyRecord | undefined;\n    if (!ok) return false;\n    const enumValues = ok.enum as unknown[] | undefined;\n    const onlyTrue = Array.isArray(enumValues) && enumValues.length === 1 && enumValues[0] === true;\n    if (!onlyTrue) return false;\n    return \"data\" in properties;\n  }\n\n  /** Returns `true` if `schema` is an envelope `oneOf` of success + error variants. */\n  function isEnvelopeSchema(spec: AnyRecord, schema: AnyRecord): boolean {\n    const oneOf = schema.oneOf as unknown[] | undefined;\n    if (!Array.isArray(oneOf) || oneOf.length < 2) return false;\n    let hasSuccess = false;\n    let hasError = false;\n    for (const variant of oneOf) {\n      const resolved = resolveSchema(spec, variant);\n      if (isSuccessEnvelopeVariant(resolved)) hasSuccess = true;\n      if (isErrorEnvelope(resolved)) hasError = true;\n    }\n    return hasSuccess && hasError;\n  }\n\n  function* iterPublicJsonResponses(spec: AnyRecord): Generator<{\n    path: string;\n    method: string;\n    status: string;\n    schema: AnyRecord;\n  }> {\n    for (const [path, methods] of Object.entries(spec.paths as AnyRecord)) {\n      for (const [method, operation] of Object.entries(methods as AnyRecord)) {\n        if (!VALID_METHODS.has(method)) continue;\n        const op = operation as AnyRecord;\n        const responses = op.responses as AnyRecord | undefined;\n        if (!responses) continue;\n        for (const [status, response] of Object.entries(responses)) {\n          const res = response as AnyRecord;\n          const content = res.content as AnyRecord | undefined;\n          const json = content?.[\"application/json\"] as AnyRecord | undefined;\n          const schema = json?.schema;\n          if (!schema) continue;\n          yield { path, method, status, schema: schema as AnyRecord };\n        }\n      }\n    }\n  }\n\n  it(\"every 2xx JSON body uses the success envelope shape\", () => {\n    const violations: string[] = [];\n    for (const { path, method, status, schema } of iterPublicJsonResponses(spec)) {\n      if (!/^2\\d\\d$/.test(status)) continue;\n      // 204 has no body — skipped because it has no JSON content at all.\n      const resolved = resolveSchema(spec, schema);\n      if (!isEnvelopeSchema(spec, resolved)) {\n        violations.push(`${method.toUpperCase()} ${path} → ${status}`);\n      }\n    }\n    expect(\n      violations,\n      `2xx responses missing envelope shape:\\n${violations.join(\"\\n\")}`,\n    ).toHaveLength(0);\n  });\n\n  it(\"every 4xx/5xx JSON body uses the error envelope shape\", () => {\n    const violations: string[] = [];\n    for (const { path, method, status, schema } of iterPublicJsonResponses(spec)) {\n      if (!/^[45]\\d\\d$/.test(status)) continue;\n      const resolved = resolveSchema(spec, schema);\n      // Accept either $ref to ErrorEnvelope (top-level) or inline error shape.\n      const schemaRecord = schema as AnyRecord;\n      const directRef =\n        typeof schemaRecord.$ref === \"string\" &&\n        schemaRecord.$ref === \"#/components/schemas/ErrorEnvelope\";\n      if (!directRef && !isErrorEnvelope(resolved)) {\n        violations.push(`${method.toUpperCase()} ${path} → ${status}`);\n      }\n    }\n    expect(\n      violations,\n      `4xx/5xx responses missing error envelope shape:\\n${violations.join(\"\\n\")}`,\n    ).toHaveLength(0);\n  });\n\n  it(\"ApiError and ErrorEnvelope appear exactly once in components.schemas\", () => {\n    const components = (spec.components as AnyRecord)?.schemas as AnyRecord | undefined;\n    expect(components, \"spec.components.schemas missing\").toBeDefined();\n    expect(components!.ApiError, \"ApiError component not registered\").toBeDefined();\n    expect(components!.ErrorEnvelope, \"ErrorEnvelope component not registered\").toBeDefined();\n    // Exactly one registration per name — object keys are unique, so the\n    // presence + type checks above are sufficient. We also verify the\n    // expected structural fields to pin the shape.\n    const apiError = components!.ApiError as AnyRecord;\n    const apiErrorProps = apiError.properties as AnyRecord | undefined;\n    expect(apiErrorProps?.code).toBeDefined();\n    expect(apiErrorProps?.message).toBeDefined();\n\n    const errorEnvelope = components!.ErrorEnvelope as AnyRecord;\n    const envelopeProps = errorEnvelope.properties as AnyRecord | undefined;\n    expect(envelopeProps?.ok).toBeDefined();\n    expect(envelopeProps?.error).toBeDefined();\n  });\n});","originalFile":"/**\n * OpenAPI contract validation — ensures the auto-generated spec is\n * structurally sound, has expected paths, and every response has a description.\n *\n * Fetches the spec from the app's /openapi.json endpoint (auto-generated\n * by @hono/zod-openapi) rather than importing a static object.\n *\n * Runs without a database — uses the Hono test client.\n */\n\nimport { describe, expect, it, beforeAll } from \"vitest\";\nimport { OpenAPIHono } from \"@hono/zod-openapi\";\nimport { Keypair } from \"@solana/web3.js\";\n\n// Import route factories that DON'T need real deps (we only need the spec)\n// We build a minimal app that generates the same spec as the real one.\n// Instead, we import the real app's index module indirectly by constructing\n// a minimal OpenAPIHono that only has the doc endpoint.\n//\n// Actually, the simplest approach: import the real app and hit /openapi.json.\n// But the real app needs DB, connection, etc. So we build a test app with\n// the same route structure.\n//\n// Simplest viable approach: just import a few route factories and check\n// the spec they generate.\n\ntype AnyRecord = Record<string, unknown>;\n\n/** Recursively collect all \"$ref\" strings from the spec. */\nfunction collectRefs(obj: unknown): string[] {\n  const refs: string[] = [];\n  function walk(value: unknown) {\n    if (Array.isArray(value)) {\n      value.forEach(walk);\n    } else if (value && typeof value === \"object\") {\n      const record = value as AnyRecord;\n      if (typeof record.$ref === \"string\") {\n        refs.push(record.$ref);\n      }\n      Object.values(record).forEach(walk);\n    }\n  }\n  walk(obj);\n  return refs;\n}\n\nconst VALID_METHODS = new Set([\n  \"get\", \"post\", \"put\", \"delete\", \"patch\", \"options\", \"head\",\n]);\n\n// We need to construct a minimal app to generate the spec. Mount every\n// public route factory that emits an OpenAPI schema so the contract scan\n// covers the full declared public surface. Admin and internal routes are\n// plain Hono (no OpenAPI schemas) and are intentionally excluded per the\n// spec refinement decision (2026-04-22).\nimport { createHealthRoutes } from \"../routes/health.js\";\nimport { createPriceRoutes } from \"../routes/price.js\";\nimport { createLeaderboardRoutes } from \"../routes/leaderboard.js\";\nimport { createProfileRoutes } from \"../routes/profile.js\";\nimport { createFlipYouRoutes } from \"../routes/create.js\";\nimport { createPotShotRoutes } from \"../routes/potshot-create.js\";\nimport { createCloseCallRoutes } from \"../routes/closecall.js\";\nimport { createAuthRoutes } from \"../routes/auth.js\";\nimport { createReferralRoutes } from \"../routes/referral.js\";\nimport { createPublicProfileRoutes } from \"../routes/public-profile.js\";\nimport { createPublicReferralRoutes } from \"../routes/public-referral.js\";\nimport { createChallengeRoutes } from \"../routes/challenges.js\";\nimport { createPointsRoutes, createCrateRoutes } from \"../routes/points.js\";\nimport { createDogpileRoutes } from \"../routes/dogpile.js\";\n\nfunction resolveSchema(spec: AnyRecord, schema: unknown): AnyRecord {\n  const record = schema as AnyRecord;\n\n  if (typeof record?.$ref === \"string\") {\n    const path = record.$ref.replace(/^#\\//, \"\").split(\"/\");\n    let current: unknown = spec;\n    for (const segment of path) {\n      current = (current as AnyRecord)?.[segment];\n    }\n    return resolveSchema(spec, current);\n  }\n\n  if (Array.isArray(record?.allOf) && record.allOf.length > 0) {\n    return resolveSchema(spec, record.allOf[0]);\n  }\n\n  if (Array.isArray(record?.anyOf)) {\n    const concrete = record.anyOf.find((item) => {\n      const candidate = item as AnyRecord;\n      return typeof candidate?.$ref === \"string\" || candidate?.type === \"object\";\n    });\n    if (concrete) {\n      return resolveSchema(spec, concrete);\n    }\n  }\n\n  return record;\n}\n\n/**\n * Descend into the success branch of an `ApiEnvelope` (`{ ok: true, data: T }`)\n * within a `oneOf` discriminated union. Returns the resolved schema as-is for\n * legacy non-enveloped responses.\n */\nfunction unwrapEnvelope(spec: AnyRecord, schema: unknown): AnyRecord {\n  const resolved = resolveSchema(spec, schema);\n\n  const oneOf = resolved.oneOf as unknown[] | undefined;\n  if (Array.isArray(oneOf)) {\n    for (const variant of oneOf) {\n      const variantResolved = resolveSchema(spec, variant);\n      const props = variantResolved.properties as AnyRecord | undefined;\n      const okProp = props?.ok as AnyRecord | undefined;\n      const okEnum = okProp?.enum as unknown[] | undefined;\n      if (okEnum && okEnum[0] === true && props && \"data\" in props) {\n        return resolveSchema(spec, props.data);\n      }\n    }\n  }\n\n  const properties = resolved.properties as AnyRecord | undefined;\n  if (properties && \"ok\" in properties && \"data\" in properties) {\n    return resolveSchema(spec, properties.data);\n  }\n\n  return resolved;\n}\n\nfunction getJsonResponseSchema(\n  spec: AnyRecord,\n  path: string,\n  method: string,\n  status: string,\n): AnyRecord {\n  const paths = spec.paths as AnyRecord;\n  const operations = paths[path] as AnyRecord | undefined;\n  const operation = operations?.[method] as AnyRecord | undefined;\n  const responses = operation?.responses as AnyRecord | undefined;\n  const content = (responses?.[status] as AnyRecord | undefined)?.content as AnyRecord | undefined;\n  return unwrapEnvelope(\n    spec,\n    (content?.[\"application/json\"] as AnyRecord | undefined)?.schema,\n  );\n}\n\nfunction buildSpecApp() {\n  const app = new OpenAPIHono();\n  const serverKeypair = Keypair.generate();\n\n  // Stub DB that satisfies the interface minimally — only used for spec generation, never called\n  /* eslint-disable @typescript-eslint/no-explicit-any */\n  const stubDb = new Proxy({} as any, {\n    get: () => async () => ({ count: 0, oldestAgeSeconds: 0 }),\n  });\n  app.route(\"/health\", createHealthRoutes({ isWorkerRunning: () => true }));\n  app.route(\"/price\", createPriceRoutes());\n  app.route(\"/leaderboard\", createLeaderboardRoutes({ db: stubDb }));\n  app.route(\"/profile\", createProfileRoutes({ db: stubDb }));\n  app.route(\"/public-profile\", createPublicProfileRoutes({ db: stubDb }));\n  app.route(\"/public-referral\", createPublicReferralRoutes({ db: stubDb }));\n  app.route(\n    \"/auth\",\n    createAuthRoutes({\n      authDb: stubDb,\n      db: stubDb,\n      jwtSecret: new TextEncoder().encode(\"test\"),\n      cluster: \"devnet\",\n      challengeTtlSeconds: 60,\n      accessTokenTtlSeconds: 60,\n      refreshTokenTtlDays: 1,\n    }),\n  );\n  app.route(\n    \"/referral\",\n    createReferralRoutes({ db: stubDb, sql: {} as any, config: {} as any }),\n  );\n  app.route(\"/challenges\", createChallengeRoutes({ db: stubDb }));\n  app.route(\"/points\", createPointsRoutes({ db: stubDb }));\n  app.route(\"/crates\", createCrateRoutes({ db: stubDb }));\n  app.route(\"/dogpile\", createDogpileRoutes({ db: stubDb }));\n  app.route(\n    \"/flip-you\",\n    createFlipYouRoutes({\n      db: stubDb,\n      connection: {} as never,\n      serverKeypair,\n      pdaWatcher: { watch: () => undefined } as never,\n    }),\n  );\n  app.route(\n    \"/pot-shot\",\n    createPotShotRoutes({\n      db: stubDb,\n      connection: {} as never,\n      serverKeypair,\n      pdaWatcher: { watch: () => undefined } as never,\n    }),\n  );\n  app.route(\n    \"/closecall\",\n    createCloseCallRoutes({\n      db: stubDb,\n      connection: {} as never,\n      serverKeypair,\n      clockWorker: { getLatestBoundaryPrice: () => null } as never,\n    }),\n  );\n  /* eslint-enable @typescript-eslint/no-explicit-any */\n\n  app.openAPIRegistry.registerComponent(\"securitySchemes\", \"bearerAuth\", {\n    type: \"http\",\n    scheme: \"bearer\",\n    bearerFormat: \"JWT\",\n  });\n\n  app.doc(\"/openapi.json\", {\n    openapi: \"3.0.3\",\n    info: { title: \"Taunt Bet API\", version: \"0.1.0\" },\n  });\n\n  return app;\n}\n\ndescribe(\"OpenAPI contract (auto-generated)\", () => {\n  let spec: AnyRecord;\n\n  beforeAll(async () => {\n    const app = buildSpecApp();\n    const res = await app.request(\"/openapi.json\");\n    expect(res.status).toBe(200);\n    spec = (await res.json()) as AnyRecord;\n  });\n\n  it(\"is a valid OpenAPI 3.0.3 document\", () => {\n    expect(spec.openapi).toBe(\"3.0.3\");\n    expect(spec.info).toBeDefined();\n    expect((spec.info as AnyRecord).title).toBeTruthy();\n    const paths = spec.paths as AnyRecord;\n    expect(Object.keys(paths).length).toBeGreaterThan(0);\n  });\n\n  it(\"auto-generated spec contains expected paths\", () => {\n    const paths = Object.keys(spec.paths as AnyRecord);\n    // Spot-check a few expected endpoints from the mounted routes\n    expect(paths).toContain(\"/health\");\n    expect(paths).toContain(\"/price/sol-usd\");\n    expect(paths).toContain(\"/leaderboard/weekly\");\n    expect(paths).toContain(\"/profile/me\");\n    expect(paths).toContain(\"/flip-you/verify/{pda}\");\n    expect(paths).toContain(\"/pot-shot/current\");\n    expect(paths).toContain(\"/closecall/by-id/{roundId}\");\n  });\n\n  it(\"does not declare bearer auth globally\", () => {\n    expect(spec.security).toBeUndefined();\n  });\n\n  it(\"keeps public routes public and protected routes protected\", () => {\n    const paths = spec.paths as Record<string, AnyRecord>;\n    expect((paths[\"/health\"]?.get as AnyRecord | undefined)?.security).toBeUndefined();\n    expect((paths[\"/price/sol-usd\"]?.get as AnyRecord | undefined)?.security).toBeUndefined();\n    expect((paths[\"/profile/me\"]?.get as AnyRecord | undefined)?.security).toEqual([\n      { bearerAuth: [] },\n    ]);\n  });\n\n  it(\"documents round endpoints with concrete field schemas\", () => {\n    const flipVerifySchema = getJsonResponseSchema(spec, \"/flip-you/verify/{pda}\", \"get\", \"200\");\n    const flipEntriesSchema = resolveSchema(\n      spec,\n      ((flipVerifySchema.properties as AnyRecord).entries as AnyRecord)?.items,\n    );\n    expect((flipVerifySchema.properties as AnyRecord).matchId).toBeDefined();\n    expect((flipVerifySchema.properties as AnyRecord).verification).toBeDefined();\n    expect((flipEntriesSchema.properties as AnyRecord).player).toBeDefined();\n    expect((flipEntriesSchema.properties as AnyRecord).amountLamports).toBeDefined();\n\n    const potCurrentEnvelope = getJsonResponseSchema(spec, \"/pot-shot/current\", \"get\", \"200\");\n    const potCurrentSchema = resolveSchema(\n      spec,\n      (potCurrentEnvelope.properties as AnyRecord).round,\n    );\n    expect((potCurrentSchema.properties as AnyRecord).entries).toBeDefined();\n    expect((potCurrentSchema.properties as AnyRecord).countdownEndsAt).toBeDefined();\n\n    const closeByIdSchema = getJsonResponseSchema(spec, \"/closecall/by-id/{roundId}\", \"get\", \"200\");\n    const closeEntrySchema = resolveSchema(\n      spec,\n      ((closeByIdSchema.properties as AnyRecord).greenEntries as AnyRecord)?.items,\n    );\n    expect((closeByIdSchema.properties as AnyRecord).game).toBeDefined();\n    expect((closeByIdSchema.properties as AnyRecord).verification).toBeDefined();\n    expect((closeEntrySchema.properties as AnyRecord).player).toBeDefined();\n    expect((closeEntrySchema.properties as AnyRecord).amountLamports).toBeDefined();\n  });\n\n  it(\"all $ref references resolve\", () => {\n    const refs = collectRefs(spec);\n    // Collect all schema names (may be empty if no $refs are used)\n    const schemas = (spec.components as AnyRecord)?.schemas as AnyRecord | undefined;\n    const schemaNames = new Set(schemas ? Object.keys(schemas) : []);\n\n    const unresolved: string[] = [];\n    for (const ref of refs) {\n      const match = ref.match(/^#\\/components\\/schemas\\/(.+)$/);\n      if (match?.[1] && !schemaNames.has(match[1])) {\n        unresolved.push(ref);\n      }\n    }\n\n    expect(unresolved, `Unresolved $ref(s): ${unresolved.join(\", \")}`).toHaveLength(0);\n  });\n\n  it(\"every path uses only valid HTTP methods\", () => {\n    const invalid: string[] = [];\n    for (const [path, methods] of Object.entries(spec.paths as AnyRecord)) {\n      for (const method of Object.keys(methods as AnyRecord)) {\n        if (!VALID_METHODS.has(method)) {\n          invalid.push(`${method.toUpperCase()} ${path}`);\n        }\n      }\n    }\n\n    expect(invalid, `Invalid methods: ${invalid.join(\", \")}`).toHaveLength(0);\n  });\n\n  it(\"every response has a description\", () => {\n    const missing: string[] = [];\n    for (const [path, methods] of Object.entries(spec.paths as AnyRecord)) {\n      for (const [method, operation] of Object.entries(methods as AnyRecord)) {\n        const op = operation as AnyRecord;\n        const responses = op.responses as AnyRecord | undefined;\n        if (!responses) continue;\n        for (const [status, response] of Object.entries(responses)) {\n          const res = response as AnyRecord;\n          if (!res.description) {\n            missing.push(`${method.toUpperCase()} ${path} → ${status}`);\n          }\n        }\n      }\n    }\n\n    expect(missing, `Responses missing description:\\n${missing.join(\"\\n\")}`).toHaveLength(0);\n  });\n});\n","structuredPatch":[{"oldStart":342,"oldLines":4,"newStart":342,"newLines":135,"lines":[" ","     expect(missing, `Responses missing description:\\n${missing.join(\"\\n\")}`).toHaveLength(0);","   });","+","+  // ─────────────────────────────────────────────────────────────────────","+  // Envelope contract (spec 304)","+  // ─────────────────────────────────────────────────────────────────────","+","+  /**","+   * Returns `true` if `schema` represents an `{ ok: false, error: ApiError }`","+   * body — either inline or via a `$ref` to the registered `ErrorEnvelope`","+   * component.","+   */","+  function isErrorEnvelope(schema: AnyRecord): boolean {","+    if (typeof schema.$ref === \"string\") {","+      if (schema.$ref === \"#/components/schemas/ErrorEnvelope\") return true;","+    }","+    const properties = schema.properties as AnyRecord | undefined;","+    if (!properties) return false;","+    const ok = properties.ok as AnyRecord | undefined;","+    if (!ok) return false;","+    const enumValues = ok.enum as unknown[] | undefined;","+    const onlyFalse = Array.isArray(enumValues) && enumValues.length === 1 && enumValues[0] === false;","+    if (!onlyFalse) return false;","+    return \"error\" in properties;","+  }","+","+  /**","+   * Returns `true` if `schema` represents the success branch of an","+   * `{ ok: true, data: T }` envelope.","+   */","+  function isSuccessEnvelopeVariant(schema: AnyRecord): boolean {","+    const properties = schema.properties as AnyRecord | undefined;","+    if (!properties) return false;","+    const ok = properties.ok as AnyRecord | undefined;","+    if (!ok) return false;","+    const enumValues = ok.enum as unknown[] | undefined;","+    const onlyTrue = Array.isArray(enumValues) && enumValues.length === 1 && enumValues[0] === true;","+    if (!onlyTrue) return false;","+    return \"data\" in properties;","+  }","+","+  /** Returns `true` if `schema` is an envelope `oneOf` of success + error variants. */","+  function isEnvelopeSchema(spec: AnyRecord, schema: AnyRecord): boolean {","+    const oneOf = schema.oneOf as unknown[] | undefined;","+    if (!Array.isArray(oneOf) || oneOf.length < 2) return false;","+    let hasSuccess = false;","+    let hasError = false;","+    for (const variant of oneOf) {","+      const resolved = resolveSchema(spec, variant);","+      if (isSuccessEnvelopeVariant(resolved)) hasSuccess = true;","+      if (isErrorEnvelope(resolved)) hasError = true;","+    }","+    return hasSuccess && hasError;","+  }","+","+  function* iterPublicJsonResponses(spec: AnyRecord): Generator<{","+    path: string;","+    method: string;","+    status: string;","+    schema: AnyRecord;","+  }> {","+    for (const [path, methods] of Object.entries(spec.paths as AnyRecord)) {","+      for (const [method, operation] of Object.entries(methods as AnyRecord)) {","+        if (!VALID_METHODS.has(method)) continue;","+        const op = operation as AnyRecord;","+        const responses = op.responses as AnyRecord | undefined;","+        if (!responses) continue;","+        for (const [status, response] of Object.entries(responses)) {","+          const res = response as AnyRecord;","+          const content = res.content as AnyRecord | undefined;","+          const json = content?.[\"application/json\"] as AnyRecord | undefined;","+          const schema = json?.schema;","+          if (!schema) continue;","+          yield { path, method, status, schema: schema as AnyRecord };","+        }","+      }","+    }","+  }","+","+  it(\"every 2xx JSON body uses the success envelope shape\", () => {","+    const violations: string[] = [];","+    for (const { path, method, status, schema } of iterPublicJsonResponses(spec)) {","+      if (!/^2\\d\\d$/.test(status)) continue;","+      // 204 has no body — skipped because it has no JSON content at all.","+      const resolved = resolveSchema(spec, schema);","+      if (!isEnvelopeSchema(spec, resolved)) {","+        violations.push(`${method.toUpperCase()} ${path} → ${status}`);","+      }","+    }","+    expect(","+      violations,","+      `2xx responses missing envelope shape:\\n${violations.join(\"\\n\")}`,","+    ).toHaveLength(0);","+  });","+","+  it(\"every 4xx/5xx JSON body uses the error envelope shape\", () => {","+    const violations: string[] = [];","+    for (const { path, method, status, schema } of iterPublicJsonResponses(spec)) {","+      if (!/^[45]\\d\\d$/.test(status)) continue;","+      const resolved = resolveSchema(spec, schema);","+      // Accept either $ref to ErrorEnvelope (top-level) or inline error shape.","+      const schemaRecord = schema as AnyRecord;","+      const directRef =","+        typeof schemaRecord.$ref === \"string\" &&","+        schemaRecord.$ref === \"#/components/schemas/ErrorEnvelope\";","+      if (!directRef && !isErrorEnvelope(resolved)) {","+        violations.push(`${method.toUpperCase()} ${path} → ${status}`);","+      }","+    }","+    expect(","+      violations,","+      `4xx/5xx responses missing error envelope shape:\\n${violations.join(\"\\n\")}`,","+    ).toHaveLength(0);","+  });","+","+  it(\"ApiError and ErrorEnvelope appear exactly once in components.schemas\", () => {","+    const components = (spec.components as AnyRecord)?.schemas as AnyRecord | undefined;","+    expect(components, \"spec.components.schemas missing\").toBeDefined();","+    expect(components!.ApiError, \"ApiError component not registered\").toBeDefined();","+    expect(components!.ErrorEnvelope, \"ErrorEnvelope component not registered\").toBeDefined();","+    // Exactly one registration per name — object keys are unique, so the","+    // presence + type checks above are sufficient. We also verify the","+    // expected structural fields to pin the shape.","+    const apiError = components!.ApiError as AnyRecord;","+    const apiErrorProps = apiError.properties as AnyRecord | undefined;","+    expect(apiErrorProps?.code).toBeDefined();","+    expect(apiErrorProps?.message).toBeDefined();","+","+    const errorEnvelope = components!.ErrorEnvelope as AnyRecord;","+    const envelopeProps = errorEnvelope.properties as AnyRecord | undefined;","+    expect(envelopeProps?.ok).toBeDefined();","+    expect(envelopeProps?.error).toBeDefined();","+  });"," });"]}],"userModified":false,"replaceAll":false}}
