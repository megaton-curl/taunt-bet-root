{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JheWKEGYChpXhx1kXyLHUz","type":"tool_result","content":"1\t/**\n2\t * Internal admin routes — dev/devnet only.\n3\t *\n4\t * POST /reset-db — drop all tables, re-run migrations, then exit the process.\n5\t * Only registered when ADMIN_TOKEN env var is set.\n6\t */\n7\t\n8\timport { Hono } from \"hono\";\n9\timport type postgres from \"postgres\";\n10\timport type { Config } from \"../config.js\";\n11\timport { runMigrations } from \"../migrate.js\";\n12\timport { logger } from \"../logger.js\";\n13\t\n14\texport interface InternalRoutesDeps {\n15\t  config: Config;\n16\t  sql: postgres.Sql;\n17\t}\n18\t\n19\tfunction quoteIdentifier(identifier: string): string {\n20\t  if (!/^[A-Za-z_][A-Za-z0-9_]*$/.test(identifier)) {\n21\t    throw new Error(`Invalid schema name: ${identifier}`);\n22\t  }\n23\t  return `\"${identifier}\"`;\n24\t}\n25\t\n26\texport function createInternalRoutes(deps: InternalRoutesDeps) {\n27\t  const { config, sql } = deps;\n28\t  const app = new Hono();\n29\t\n30\t  app.post(\"/reset-db\", async (c) => {\n31\t    const token = c.req.header(\"X-Admin-Token\");\n32\t    if (!token || token !== config.adminToken) {\n33\t      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n34\t    }\n35\t\n36\t    logger.warn(\"reset-db: dropping all tables and re-running migrations\");\n37\t\n38\t    try {\n39\t      const schema = config.dbSchema;\n40\t      const quoted = quoteIdentifier(schema);\n41\t\n42\t      if (schema === \"public\") {\n43\t        await sql.unsafe(`DROP SCHEMA public CASCADE`);\n44\t        await sql.unsafe(`CREATE SCHEMA public`);\n45\t      } else {\n46\t        await sql.unsafe(`DROP SCHEMA IF EXISTS ${quoted} CASCADE`);\n47\t        await sql.unsafe(`CREATE SCHEMA ${quoted}`);\n48\t      }\n49\t\n50\t      await runMigrations(config.databaseUrl);\n51\t\n52\t      logger.warn(\"reset-db: complete — exiting process\");\n53\t\n54\t      // Let the response flush before exiting\n55\t      setTimeout(() => process.exit(0), 200);\n56\t\n57\t      return c.json({ ok: true, message: \"Database reset and migrations applied. Process exiting.\" });\n58\t    } catch (err) {\n59\t      logger.error(\"reset-db: failed\", {\n60\t        error: err instanceof Error ? err.message : String(err),"}]},"parent_tool_use_id":null,"session_id":"7939b4c7-aefe-4219-88b2-4cc3995099e7","uuid":"14c9eef7-6149-4131-8820-c899dfe36bf3","timestamp":"2026-04-22T10:54:48.239Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/internal.ts","content":"/**\n * Internal admin routes — dev/devnet only.\n *\n * POST /reset-db — drop all tables, re-run migrations, then exit the process.\n * Only registered when ADMIN_TOKEN env var is set.\n */\n\nimport { Hono } from \"hono\";\nimport type postgres from \"postgres\";\nimport type { Config } from \"../config.js\";\nimport { runMigrations } from \"../migrate.js\";\nimport { logger } from \"../logger.js\";\n\nexport interface InternalRoutesDeps {\n  config: Config;\n  sql: postgres.Sql;\n}\n\nfunction quoteIdentifier(identifier: string): string {\n  if (!/^[A-Za-z_][A-Za-z0-9_]*$/.test(identifier)) {\n    throw new Error(`Invalid schema name: ${identifier}`);\n  }\n  return `\"${identifier}\"`;\n}\n\nexport function createInternalRoutes(deps: InternalRoutesDeps) {\n  const { config, sql } = deps;\n  const app = new Hono();\n\n  app.post(\"/reset-db\", async (c) => {\n    const token = c.req.header(\"X-Admin-Token\");\n    if (!token || token !== config.adminToken) {\n      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n    }\n\n    logger.warn(\"reset-db: dropping all tables and re-running migrations\");\n\n    try {\n      const schema = config.dbSchema;\n      const quoted = quoteIdentifier(schema);\n\n      if (schema === \"public\") {\n        await sql.unsafe(`DROP SCHEMA public CASCADE`);\n        await sql.unsafe(`CREATE SCHEMA public`);\n      } else {\n        await sql.unsafe(`DROP SCHEMA IF EXISTS ${quoted} CASCADE`);\n        await sql.unsafe(`CREATE SCHEMA ${quoted}`);\n      }\n\n      await runMigrations(config.databaseUrl);\n\n      logger.warn(\"reset-db: complete — exiting process\");\n\n      // Let the response flush before exiting\n      setTimeout(() => process.exit(0), 200);\n\n      return c.json({ ok: true, message: \"Database reset and migrations applied. Process exiting.\" });\n    } catch (err) {\n      logger.error(\"reset-db: failed\", {\n        error: err instanceof Error ? err.message : String(err),","numLines":60,"startLine":1,"totalLines":71}}}
