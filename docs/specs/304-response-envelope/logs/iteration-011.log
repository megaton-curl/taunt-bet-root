{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01Lm55z4XYY6cUk7vASTNbV1","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01RfYXMWuDXHm8o6fUBFy64u","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/backend/src/__tests__/endpoints.test.ts","old_string":"      expect(res.status).toBe(403);\n    });\n\n    it(\"returns 409 with duplicate PDA (match ID collision)\", async () => {","new_string":"      expect(res.status).toBe(403);\n      const json = (await res.json()) as Record<string, any>;\n      expect(json.ok).toBe(false);\n      expect(json.error?.code).toBe(\"FORBIDDEN\");\n    });\n\n    it(\"returns 409 with duplicate PDA (match ID collision)\", async () => {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1860,"cache_read_input_tokens":122056,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1860},"output_tokens":72,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8252c9de-4a52-47bf-9061-0af7998830c4","uuid":"3af8b30a-cac6-4671-84b1-995fd4978768"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RfYXMWuDXHm8o6fUBFy64u","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/src/__tests__/endpoints.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"8252c9de-4a52-47bf-9061-0af7998830c4","uuid":"d5e1432c-7d3d-4941-8908-4d241fc0b099","timestamp":"2026-04-22T10:13:48.310Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/endpoints.test.ts","oldString":"      expect(res.status).toBe(403);\n    });\n\n    it(\"returns 409 with duplicate PDA (match ID collision)\", async () => {","newString":"      expect(res.status).toBe(403);\n      const json = (await res.json()) as Record<string, any>;\n      expect(json.ok).toBe(false);\n      expect(json.error?.code).toBe(\"FORBIDDEN\");\n    });\n\n    it(\"returns 409 with duplicate PDA (match ID collision)\", async () => {","originalFile":"/* eslint-disable @typescript-eslint/no-explicit-any */\n/**\n * HTTP endpoint tests — exercises the full middleware stack (rate limit + JWT auth)\n * and route handlers for all endpoints:\n *\n * POST /flipyou/create:\n *   - 200 with valid JWT\n *   - 401 with missing JWT\n *   - 401 with expired JWT\n *   - 409 with duplicate PDA (same wallet + match ID collision)\n *   - 429 when rate limit exceeded\n *\n * GET /flipyou/verify/:pda:\n *   - 200 for known PDA\n *   - 404 for unknown PDA\n *\n * GET /health:\n *   - 200 with expected fields\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect, vi } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair, LAMPORTS_PER_SOL } from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport { SignJWT } from \"jose\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createFlipYouRoutes } from \"../routes/create.js\";\nimport { createPotShotRoutes } from \"../routes/potshot-create.js\";\nimport { createHealthRoutes } from \"../routes/health.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport { createRateLimitMiddleware } from \"../middleware/rate-limit.js\";\nimport * as fairness from \"../fairness.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"taunt_bet_dev\",\n  });\n}\n\nconst AMOUNT_LAMPORTS = 5_000_000; // 0.005 SOL\nconst SIDE_HEADS = 0;\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-endpoint-tests\");\n\n// ---------------------------------------------------------------------------\n// Minimal mock Connection (only what routes + health need)\n// ---------------------------------------------------------------------------\n\nclass MockConnection {\n  async getLatestBlockhash() {\n    return {\n      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n      lastValidBlockHeight: 999_999,\n    };\n  }\n\n  async getAccountInfo() {\n    return null;\n  }\n\n  async getBalance() {\n    return 1.5 * LAMPORTS_PER_SOL;\n  }\n}\n\n// ---------------------------------------------------------------------------\n// JWT helper\n// ---------------------------------------------------------------------------\n\nfunction userIdFromWallet(wallet: string) {\n  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n}\n\nasync function makeJwt(wallet: string, opts?: { expiresIn?: number }) {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({})\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userIdFromWallet(wallet))\n    .setIssuedAt(now)\n    .setExpirationTime(now + (opts?.expiresIn ?? 3600))\n    .sign(JWT_SECRET);\n}\n\nfunction makeBody(wallet: string, overrides?: Partial<{ amountLamports: number; side: number }>) {\n  return {\n    wallet,\n    amountLamports: overrides?.amountLamports ?? AMOUNT_LAMPORTS,\n    side: overrides?.side ?? SIDE_HEADS,\n  };\n}\n\nfunction makeLordBody(wallet: string, overrides?: Partial<{ amountLamports: number }>) {\n  return {\n    wallet,\n    amountLamports: overrides?.amountLamports ?? AMOUNT_LAMPORTS,\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"HTTP endpoint tests\", () => {\n  let db: Db;\n  let rawSql: ReturnType<typeof postgres>;\n  let mockConn: MockConnection;\n\n  const serverKeypair = Keypair.generate();\n  const creatorKeypair = Keypair.generate();\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n    db = createDb(DATABASE_URL, rawSql);\n  });\n\n  afterAll(async () => {\n    await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE rounds, operator_events RESTART IDENTITY`;\n    // Ensure player_profiles exist for test wallets so profile-based wallet\n    // resolution works (routes call db.getProfileByUserId to get wallet).\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const userId = userIdFromWallet(wallet);\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${userId}, ${wallet}, ${\"test-creator-\" + Date.now()})\n      ON CONFLICT (user_id) DO UPDATE SET wallet = EXCLUDED.wallet\n    `;\n    mockConn = new MockConnection();\n  });\n\n  // -----------------------------------------------------------------------\n  // Helper: build a fresh Hono app with full middleware stack\n  // -----------------------------------------------------------------------\n\n  function buildApp(opts?: { perWallet?: number; global?: number }) {\n    const app = new Hono();\n\n    app.use(\n      \"/flipyou/*\",\n      createRateLimitMiddleware({\n        perWallet: opts?.perWallet ?? 10,\n        global: opts?.global ?? 100,\n        windowMs: 60_000,\n      }),\n    );\n    app.use(\n      \"/pot-shot/*\",\n      createRateLimitMiddleware({\n        perWallet: opts?.perWallet ?? 10,\n        global: opts?.global ?? 100,\n        windowMs: 60_000,\n      }),\n    );\n    app.use(\n      \"/flipyou/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n    );\n    app.use(\n      \"/pot-shot/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n    );\n\n    app.route(\n      \"/flipyou\",\n      createFlipYouRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n    app.route(\n      \"/pot-shot\",\n      createPotShotRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n\n    app.route(\n      \"/health\",\n      createHealthRoutes({\n        isWorkerRunning: () => true,\n      }),\n    );\n\n    return app;\n  }\n\n  // -----------------------------------------------------------------------\n  // POST /flipyou/create\n  // -----------------------------------------------------------------------\n\n  describe(\"POST /flipyou/create\", () => {\n    it(\"returns 200 with valid JWT\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const token = await makeJwt(wallet);\n      const body = makeBody(wallet);\n\n      const res = await app.request(\"/flipyou/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${token}`,\n        },\n        body: JSON.stringify(body),\n      });\n\n      expect(res.status).toBe(200);\n      const body_json = (await res.json()) as Record<string, any>;\n      expect(body_json.ok).toBe(true);\n      const data = body_json.data as Record<string, any>;\n      expect(data.transaction).toBeDefined();\n      expect(typeof data.transaction).toBe(\"string\");\n      expect(data.matchPda).toBeDefined();\n      expect(typeof data.matchPda).toBe(\"string\");\n      expect(data.commitment).toBeDefined();\n      expect(typeof data.commitment).toBe(\"string\");\n      expect(data.lastValidBlockHeight).toBeDefined();\n      expect(typeof data.lastValidBlockHeight).toBe(\"number\");\n      // Commitment should be 64 hex chars (32 bytes)\n      expect((data.commitment as string).length).toBe(64);\n    });\n\n    it(\"returns 401 with missing JWT\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const body = makeBody(wallet);\n\n      const res = await app.request(\"/flipyou/create\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify(body),\n      });\n\n      expect(res.status).toBe(401);\n      const json = (await res.json()) as Record<string, any>;\n      expect(json.ok).toBe(false);\n      expect(json.error?.code).toBe(\"AUTH_REQUIRED\");\n    });\n\n    it(\"returns 401 with expired JWT\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const token = await makeJwt(wallet, { expiresIn: -10 });\n      const body = makeBody(wallet);\n\n      const res = await app.request(\"/flipyou/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${token}`,\n        },\n        body: JSON.stringify(body),\n      });\n\n      expect(res.status).toBe(401);\n      const json = (await res.json()) as Record<string, any>;\n      expect(json.ok).toBe(false);\n      expect(json.error?.code).toBe(\"AUTH_REQUIRED\");\n    });\n\n    it(\"returns 403 when body wallet mismatches JWT wallet\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const otherWallet = Keypair.generate().publicKey.toBase58();\n      const token = await makeJwt(wallet);\n      const body = makeBody(otherWallet); // Different wallet in body\n\n      const res = await app.request(\"/flipyou/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${token}`,\n        },\n        body: JSON.stringify(body),\n      });\n\n      expect(res.status).toBe(403);\n    });\n\n    it(\"returns 409 with duplicate PDA (match ID collision)\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const fixedMatchId = Buffer.from(\"deadbeefcafebabe\", \"hex\");\n      const matchIdSpy = vi\n        .spyOn(fairness, \"generateMatchId\")\n        .mockReturnValue(fixedMatchId);\n\n      try {\n        const body = makeBody(wallet);\n\n        const res1 = await app.request(\"/flipyou/create\", {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\",\n            \"Authorization\": `Bearer ${await makeJwt(wallet)}`,\n          },\n          body: JSON.stringify(body),\n        });\n        expect(res1.status).toBe(200);\n\n        const res2 = await app.request(\"/flipyou/create\", {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\",\n            \"Authorization\": `Bearer ${await makeJwt(wallet)}`,\n          },\n          body: JSON.stringify(body),\n        });\n\n        expect(res2.status).toBe(409);\n        const json = (await res2.json()) as Record<string, any>;\n        expect(json.error).toBe(\"Match ID collision — please retry\");\n      } finally {\n        matchIdSpy.mockRestore();\n      }\n    });\n\n    it(\"returns 429 when rate limit exceeded\", async () => {\n      // Create app with very low per-wallet limit\n      const app = buildApp({ perWallet: 2, global: 100 });\n      const wallet = creatorKeypair.publicKey.toBase58();\n\n      // Send 2 requests (within limit)\n      for (let i = 0; i < 2; i++) {\n        const token = await makeJwt(wallet);\n        const body = makeBody(wallet);\n        const res = await app.request(\"/flipyou/create\", {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\",\n            \"Authorization\": `Bearer ${token}`,\n          },\n          body: JSON.stringify(body),\n        });\n        expect(res.status).toBe(200);\n      }\n\n      // Third request should be rate-limited\n      const token3 = await makeJwt(wallet);\n      const body3 = makeBody(wallet);\n      const res3 = await app.request(\"/flipyou/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${token3}`,\n        },\n        body: JSON.stringify(body3),\n      });\n      expect(res3.status).toBe(429);\n      expect(res3.headers.get(\"Retry-After\")).toBeDefined();\n      const json = (await res3.json()) as Record<string, any>;\n      expect(json.error).toContain(\"Too many\");\n    });\n\n    it(\"rate-limits repeated invalid JWT POSTs before auth rejects them\", async () => {\n      const app = buildApp({ perWallet: 2, global: 100 });\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const badToken = \"not-a-valid-jwt\";\n\n      for (let i = 0; i < 2; i++) {\n        const res = await app.request(\"/flipyou/create\", {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\",\n            \"Authorization\": `Bearer ${badToken}`,\n          },\n          body: JSON.stringify(makeBody(wallet)),\n        });\n\n        expect(res.status).toBe(401);\n      }\n\n      const res3 = await app.request(\"/flipyou/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${badToken}`,\n        },\n        body: JSON.stringify(makeBody(wallet)),\n      });\n\n      expect(res3.status).toBe(429);\n      expect(res3.headers.get(\"Retry-After\")).toBeDefined();\n      const json = (await res3.json()) as Record<string, any>;\n      expect(json.error).toContain(\"Too many\");\n    });\n  });\n\n  describe(\"POST /pot-shot/create\", () => {\n    it(\"returns 200 with valid JWT\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const token = await makeJwt(wallet);\n\n      const res = await app.request(\"/pot-shot/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n        body: JSON.stringify(makeLordBody(wallet)),\n      });\n\n      expect(res.status).toBe(200);\n      const json = (await res.json()) as Record<string, any>;\n      expect(typeof json.transaction).toBe(\"string\");\n      expect(typeof json.roundPda).toBe(\"string\");\n      expect(typeof json.matchId).toBe(\"string\");\n      expect(typeof json.commitment).toBe(\"string\");\n      expect(typeof json.lastValidBlockHeight).toBe(\"number\");\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // Per-game read endpoints\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /flipyou/verify/:pda\", () => {\n    it(\"returns 200 for a known FlipYou PDA\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const token = await makeJwt(wallet);\n\n      const createRes = await app.request(\"/flipyou/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${token}`,\n        },\n        body: JSON.stringify(makeBody(wallet)),\n      });\n      expect(createRes.status).toBe(200);\n      const createJson = (await createRes.json()) as { matchPda: string; matchId: string };\n\n      const verifyRes = await app.request(`/flipyou/verify/${createJson.matchPda}`);\n      expect(verifyRes.status).toBe(200);\n\n      const json = (await verifyRes.json()) as Record<string, any>;\n      expect(json.pda).toBe(createJson.matchPda);\n      expect(json.game).toBe(\"flip-you\");\n      expect(json.matchId).toBe(createJson.matchId);\n    });\n\n    it(\"returns 404 for a PotShot PDA\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const token = await makeJwt(wallet);\n\n      // Create a pot-shot round\n      const createRes = await app.request(\"/pot-shot/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n        body: JSON.stringify(makeLordBody(wallet)),\n      });\n      expect(createRes.status).toBe(200);\n      const createJson = (await createRes.json()) as { roundPda: string };\n\n      // Querying /flipyou/verify with a potshot PDA should 404\n      const verifyRes = await app.request(`/flipyou/verify/${createJson.roundPda}`);\n      expect(verifyRes.status).toBe(404);\n    });\n  });\n\n  describe(\"GET /flipyou/by-id/:matchId\", () => {\n    it(\"returns 200 for known match ID\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const token = await makeJwt(wallet);\n\n      const createRes = await app.request(\"/flipyou/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${token}`,\n        },\n        body: JSON.stringify(makeBody(wallet)),\n      });\n      expect(createRes.status).toBe(200);\n      const createJson = (await createRes.json()) as { matchId: string };\n\n      const byIdRes = await app.request(`/flipyou/by-id/${createJson.matchId}`);\n      expect(byIdRes.status).toBe(200);\n\n      const json = (await byIdRes.json()) as Record<string, any>;\n      expect(json.game).toBe(\"flip-you\");\n      expect(json.matchId).toBe(createJson.matchId);\n    });\n\n    it(\"returns 404 for unknown match ID\", async () => {\n      const app = buildApp();\n      const res = await app.request(\"/flipyou/by-id/deadbeefcafe0000\");\n      expect(res.status).toBe(404);\n    });\n  });\n\n  describe(\"GET /flipyou/history\", () => {\n    it(\"returns empty list when no settled rounds\", async () => {\n      const app = buildApp();\n      const res = await app.request(\"/flipyou/history\");\n      expect(res.status).toBe(200);\n      const json = (await res.json()) as Record<string, any>;\n      expect(json.rounds).toEqual([]);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /health\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /health\", () => {\n    it(\"returns cheap process-local health fields\", async () => {\n      const app = buildApp();\n      const res = await app.request(\"/health\");\n      expect(res.status).toBe(200);\n\n      const json = (await res.json()) as Record<string, any>;\n      expect(json.status).toBe(\"ok\");\n      expect(json.version).toBe(\"0.1.0\");\n      expect(json.workerRunning).toBe(true);\n    });\n  });\n});\n","structuredPatch":[{"oldStart":292,"oldLines":6,"newStart":292,"newLines":9,"lines":["       });"," ","       expect(res.status).toBe(403);","+      const json = (await res.json()) as Record<string, any>;","+      expect(json.ok).toBe(false);","+      expect(json.error?.code).toBe(\"FORBIDDEN\");","     });"," ","     it(\"returns 409 with duplicate PDA (match ID collision)\", async () => {"]}],"userModified":false,"replaceAll":false}}
