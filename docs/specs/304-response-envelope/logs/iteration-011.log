{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018gsTwKvDhKcvHBULCXAEaP","type":"tool_result","content":"1\t/* eslint-disable @typescript-eslint/no-explicit-any */\n2\t/**\n3\t * HTTP endpoint tests — exercises the full middleware stack (rate limit + JWT auth)\n4\t * and route handlers for all endpoints:\n5\t *\n6\t * POST /flipyou/create:\n7\t *   - 200 with valid JWT\n8\t *   - 401 with missing JWT\n9\t *   - 401 with expired JWT\n10\t *   - 409 with duplicate PDA (same wallet + match ID collision)\n11\t *   - 429 when rate limit exceeded\n12\t *\n13\t * GET /flipyou/verify/:pda:\n14\t *   - 200 for known PDA\n15\t *   - 404 for unknown PDA\n16\t *\n17\t * GET /health:\n18\t *   - 200 with expected fields\n19\t */\n20\t\n21\timport { describe, it, beforeAll, afterAll, beforeEach, expect, vi } from \"vitest\";\n22\timport { Hono } from \"hono\";\n23\timport { Keypair, LAMPORTS_PER_SOL } from \"@solana/web3.js\";\n24\timport type { Connection } from \"@solana/web3.js\";\n25\timport { SignJWT } from \"jose\";\n26\timport postgres from \"postgres\";\n27\timport { createDb, type Db } from \"../db.js\";\n28\timport { createFlipYouRoutes } from \"../routes/create.js\";\n29\timport { createPotShotRoutes } from \"../routes/potshot-create.js\";\n30\timport { createHealthRoutes } from \"../routes/health.js\";\n31\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n32\timport { createRateLimitMiddleware } from \"../middleware/rate-limit.js\";\n33\timport * as fairness from \"../fairness.js\";\n34\t\n35\t// ---------------------------------------------------------------------------\n36\t// Constants\n37\t// ---------------------------------------------------------------------------\n38\t\n39\tconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n40\t\n41\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n42\tfunction makeSql() {\n43\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n44\t  return postgres({\n45\t    host: \"/var/run/postgresql\",\n46\t    user: \"vscode\",\n47\t    database: \"taunt_bet_dev\",\n48\t  });\n49\t}\n50\t\n51\tconst AMOUNT_LAMPORTS = 5_000_000; // 0.005 SOL\n52\tconst SIDE_HEADS = 0;\n53\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-endpoint-tests\");\n54\t\n55\t// ---------------------------------------------------------------------------\n56\t// Minimal mock Connection (only what routes + health need)\n57\t// ---------------------------------------------------------------------------\n58\t\n59\tclass MockConnection {\n60\t  async getLatestBlockhash() {\n61\t    return {\n62\t      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n63\t      lastValidBlockHeight: 999_999,\n64\t    };\n65\t  }\n66\t\n67\t  async getAccountInfo() {\n68\t    return null;\n69\t  }\n70\t\n71\t  async getBalance() {\n72\t    return 1.5 * LAMPORTS_PER_SOL;\n73\t  }\n74\t}\n75\t\n76\t// ---------------------------------------------------------------------------\n77\t// JWT helper\n78\t// ---------------------------------------------------------------------------\n79\t\n80\tfunction userIdFromWallet(wallet: string) {\n81\t  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n82\t}\n83\t\n84\tasync function makeJwt(wallet: string, opts?: { expiresIn?: number }) {\n85\t  const now = Math.floor(Date.now() / 1000);\n86\t  return new SignJWT({})\n87\t    .setProtectedHeader({ alg: \"HS256\" })\n88\t    .setSubject(userIdFromWallet(wallet))\n89\t    .setIssuedAt(now)\n90\t    .setExpirationTime(now + (opts?.expiresIn ?? 3600))\n91\t    .sign(JWT_SECRET);\n92\t}\n93\t\n94\tfunction makeBody(wallet: string, overrides?: Partial<{ amountLamports: number; side: number }>) {\n95\t  return {\n96\t    wallet,\n97\t    amountLamports: overrides?.amountLamports ?? AMOUNT_LAMPORTS,\n98\t    side: overrides?.side ?? SIDE_HEADS,\n99\t  };\n100\t}\n101\t\n102\tfunction makeLordBody(wallet: string, overrides?: Partial<{ amountLamports: number }>) {\n103\t  return {\n104\t    wallet,\n105\t    amountLamports: overrides?.amountLamports ?? AMOUNT_LAMPORTS,\n106\t  };\n107\t}\n108\t\n109\t// ---------------------------------------------------------------------------\n110\t// Test suite\n111\t// ---------------------------------------------------------------------------\n112\t\n113\tdescribe(\"HTTP endpoint tests\", () => {\n114\t  let db: Db;\n115\t  let rawSql: ReturnType<typeof postgres>;\n116\t  let mockConn: MockConnection;\n117\t\n118\t  const serverKeypair = Keypair.generate();\n119\t  const creatorKeypair = Keypair.generate();\n120\t\n121\t  beforeAll(async () => {\n122\t    rawSql = makeSql();\n123\t    db = createDb(DATABASE_URL, rawSql);\n124\t  });\n125\t\n126\t  afterAll(async () => {\n127\t    await db.close();\n128\t    await rawSql.end();\n129\t  });\n130\t\n131\t  beforeEach(async () => {\n132\t    await rawSql`TRUNCATE rounds, operator_events RESTART IDENTITY`;\n133\t    // Ensure player_profiles exist for test wallets so profile-based wallet\n134\t    // resolution works (routes call db.getProfileByUserId to get wallet).\n135\t    const wallet = creatorKeypair.publicKey.toBase58();\n136\t    const userId = userIdFromWallet(wallet);\n137\t    await rawSql`\n138\t      INSERT INTO player_profiles (user_id, wallet, username)\n139\t      VALUES (${userId}, ${wallet}, ${\"test-creator-\" + Date.now()})\n140\t      ON CONFLICT (user_id) DO UPDATE SET wallet = EXCLUDED.wallet\n141\t    `;\n142\t    mockConn = new MockConnection();\n143\t  });\n144\t\n145\t  // -----------------------------------------------------------------------\n146\t  // Helper: build a fresh Hono app with full middleware stack\n147\t  // -----------------------------------------------------------------------\n148\t\n149\t  function buildApp(opts?: { perWallet?: number; global?: number }) {\n150\t    const app = new Hono();\n151\t\n152\t    app.use(\n153\t      \"/flipyou/*\",\n154\t      createRateLimitMiddleware({\n155\t        perWallet: opts?.perWallet ?? 10,\n156\t        global: opts?.global ?? 100,\n157\t        windowMs: 60_000,\n158\t      }),\n159\t    );\n160\t    app.use(\n161\t      \"/pot-shot/*\",\n162\t      createRateLimitMiddleware({\n163\t        perWallet: opts?.perWallet ?? 10,\n164\t        global: opts?.global ?? 100,\n165\t        windowMs: 60_000,\n166\t      }),\n167\t    );\n168\t    app.use(\n169\t      \"/flipyou/*\",\n170\t      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n171\t    );\n172\t    app.use(\n173\t      \"/pot-shot/*\",\n174\t      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n175\t    );\n176\t\n177\t    app.route(\n178\t      \"/flipyou\",\n179\t      createFlipYouRoutes({\n180\t        db,\n181\t        connection: mockConn as unknown as Connection,\n182\t        serverKeypair,\n183\t      }),\n184\t    );\n185\t    app.route(\n186\t      \"/pot-shot\",\n187\t      createPotShotRoutes({\n188\t        db,\n189\t        connection: mockConn as unknown as Connection,\n190\t        serverKeypair,\n191\t      }),\n192\t    );\n193\t\n194\t    app.route(\n195\t      \"/health\",\n196\t      createHealthRoutes({\n197\t        isWorkerRunning: () => true,\n198\t      }),\n199\t    );\n200\t\n201\t    return app;\n202\t  }\n203\t\n204\t  // -----------------------------------------------------------------------\n205\t  // POST /flipyou/create\n206\t  // -----------------------------------------------------------------------\n207\t\n208\t  describe(\"POST /flipyou/create\", () => {\n209\t    it(\"returns 200 with valid JWT\", async () => {\n210\t      const app = buildApp();\n211\t      const wallet = creatorKeypair.publicKey.toBase58();\n212\t      const token = await makeJwt(wallet);\n213\t      const body = makeBody(wallet);\n214\t\n215\t      const res = await app.request(\"/flipyou/create\", {\n216\t        method: \"POST\",\n217\t        headers: {\n218\t          \"Content-Type\": \"application/json\",\n219\t          \"Authorization\": `Bearer ${token}`,\n220\t        },\n221\t        body: JSON.stringify(body),\n222\t      });\n223\t\n224\t      expect(res.status).toBe(200);\n225\t      const json = (await res.json()) as Record<string, any>;\n226\t      expect(json.transaction).toBeDefined();\n227\t      expect(typeof json.transaction).toBe(\"string\");\n228\t      expect(json.matchPda).toBeDefined();\n229\t      expect(typeof json.matchPda).toBe(\"string\");\n230\t      expect(json.commitment).toBeDefined();\n231\t      expect(typeof json.commitment).toBe(\"string\");\n232\t      expect(json.lastValidBlockHeight).toBeDefined();\n233\t      expect(typeof json.lastValidBlockHeight).toBe(\"number\");\n234\t      // Commitment should be 64 hex chars (32 bytes)\n235\t      expect((json.commitment as string).length).toBe(64);\n236\t    });\n237\t\n238\t    it(\"returns 401 with missing JWT\", async () => {\n239\t      const app = buildApp();\n240\t      const wallet = creatorKeypair.publicKey.toBase58();\n241\t      const body = makeBody(wallet);\n242\t\n243\t      const res = await app.request(\"/flipyou/create\", {\n244\t        method: \"POST\",\n245\t        headers: { \"Content-Type\": \"application/json\" },\n246\t        body: JSON.stringify(body),\n247\t      });\n248\t\n249\t      expect(res.status).toBe(401);\n250\t      const json = (await res.json()) as Record<string, any>;\n251\t      expect(json.error).toBeDefined();\n252\t    });\n253\t\n254\t    it(\"returns 401 with expired JWT\", async () => {\n255\t      const app = buildApp();\n256\t      const wallet = creatorKeypair.publicKey.toBase58();\n257\t      const token = await makeJwt(wallet, { expiresIn: -10 });\n258\t      const body = makeBody(wallet);\n259\t\n260\t      const res = await app.request(\"/flipyou/create\", {\n261\t        method: \"POST\",\n262\t        headers: {\n263\t          \"Content-Type\": \"application/json\",\n264\t          \"Authorization\": `Bearer ${token}`,\n265\t        },\n266\t        body: JSON.stringify(body),\n267\t      });\n268\t\n269\t      expect(res.status).toBe(401);\n270\t      const json = (await res.json()) as Record<string, any>;\n271\t      expect(json.error).toBeDefined();\n272\t    });\n273\t\n274\t    it(\"returns 403 when body wallet mismatches JWT wallet\", async () => {\n275\t      const app = buildApp();\n276\t      const wallet = creatorKeypair.publicKey.toBase58();\n277\t      const otherWallet = Keypair.generate().publicKey.toBase58();\n278\t      const token = await makeJwt(wallet);\n279\t      const body = makeBody(otherWallet); // Different wallet in body\n280\t\n281\t      const res = await app.request(\"/flipyou/create\", {\n282\t        method: \"POST\",\n283\t        headers: {\n284\t          \"Content-Type\": \"application/json\",\n285\t          \"Authorization\": `Bearer ${token}`,\n286\t        },\n287\t        body: JSON.stringify(body),\n288\t      });\n289\t\n290\t      expect(res.status).toBe(403);\n291\t    });\n292\t\n293\t    it(\"returns 409 with duplicate PDA (match ID collision)\", async () => {\n294\t      const app = buildApp();\n295\t      const wallet = creatorKeypair.publicKey.toBase58();\n296\t      const fixedMatchId = Buffer.from(\"deadbeefcafebabe\", \"hex\");\n297\t      const matchIdSpy = vi\n298\t        .spyOn(fairness, \"generateMatchId\")\n299\t        .mockReturnValue(fixedMatchId);\n300\t\n301\t      try {\n302\t        const body = makeBody(wallet);\n303\t\n304\t        const res1 = await app.request(\"/flipyou/create\", {\n305\t          method: \"POST\",\n306\t          headers: {\n307\t            \"Content-Type\": \"application/json\",\n308\t            \"Authorization\": `Bearer ${await makeJwt(wallet)}`,\n309\t          },\n310\t          body: JSON.stringify(body),\n311\t        });\n312\t        expect(res1.status).toBe(200);\n313\t\n314\t        const res2 = await app.request(\"/flipyou/create\", {\n315\t          method: \"POST\",\n316\t          headers: {\n317\t            \"Content-Type\": \"application/json\",\n318\t            \"Authorization\": `Bearer ${await makeJwt(wallet)}`,\n319\t          },\n320\t          body: JSON.stringify(body),\n321\t        });\n322\t\n323\t        expect(res2.status).toBe(409);\n324\t        const json = (await res2.json()) as Record<string, any>;\n325\t        expect(json.error).toBe(\"Match ID collision — please retry\");\n326\t      } finally {\n327\t        matchIdSpy.mockRestore();\n328\t      }\n329\t    });\n330\t\n331\t    it(\"returns 429 when rate limit exceeded\", async () => {\n332\t      // Create app with very low per-wallet limit\n333\t      const app = buildApp({ perWallet: 2, global: 100 });\n334\t      const wallet = creatorKeypair.publicKey.toBase58();\n335\t\n336\t      // Send 2 requests (within limit)\n337\t      for (let i = 0; i < 2; i++) {\n338\t        const token = await makeJwt(wallet);\n339\t        const body = makeBody(wallet);\n340\t        const res = await app.request(\"/flipyou/create\", {\n341\t          method: \"POST\",\n342\t          headers: {\n343\t            \"Content-Type\": \"application/json\",\n344\t            \"Authorization\": `Bearer ${token}`,\n345\t          },\n346\t          body: JSON.stringify(body),\n347\t        });\n348\t        expect(res.status).toBe(200);\n349\t      }\n350\t\n351\t      // Third request should be rate-limited\n352\t      const token3 = await makeJwt(wallet);\n353\t      const body3 = makeBody(wallet);\n354\t      const res3 = await app.request(\"/flipyou/create\", {\n355\t        method: \"POST\",\n356\t        headers: {\n357\t          \"Content-Type\": \"application/json\",\n358\t          \"Authorization\": `Bearer ${token3}`,\n359\t        },\n360\t        body: JSON.stringify(body3),\n361\t      });\n362\t      expect(res3.status).toBe(429);\n363\t      expect(res3.headers.get(\"Retry-After\")).toBeDefined();\n364\t      const json = (await res3.json()) as Record<string, any>;\n365\t      expect(json.error).toContain(\"Too many\");\n366\t    });\n367\t\n368\t    it(\"rate-limits repeated invalid JWT POSTs before auth rejects them\", async () => {\n369\t      const app = buildApp({ perWallet: 2, global: 100 });\n370\t      const wallet = creatorKeypair.publicKey.toBase58();\n371\t      const badToken = \"not-a-valid-jwt\";\n372\t\n373\t      for (let i = 0; i < 2; i++) {\n374\t        const res = await app.request(\"/flipyou/create\", {\n375\t          method: \"POST\",\n376\t          headers: {\n377\t            \"Content-Type\": \"application/json\",\n378\t            \"Authorization\": `Bearer ${badToken}`,\n379\t          },\n380\t          body: JSON.stringify(makeBody(wallet)),\n381\t        });\n382\t\n383\t        expect(res.status).toBe(401);\n384\t      }\n385\t\n386\t      const res3 = await app.request(\"/flipyou/create\", {\n387\t        method: \"POST\",\n388\t        headers: {\n389\t          \"Content-Type\": \"application/json\",\n390\t          \"Authorization\": `Bearer ${badToken}`,\n391\t        },\n392\t        body: JSON.stringify(makeBody(wallet)),\n393\t      });\n394\t\n395\t      expect(res3.status).toBe(429);\n396\t      expect(res3.headers.get(\"Retry-After\")).toBeDefined();\n397\t      const json = (await res3.json()) as Record<string, any>;\n398\t      expect(json.error).toContain(\"Too many\");\n399\t    });\n400\t  });\n401\t\n402\t  describe(\"POST /pot-shot/create\", () => {\n403\t    it(\"returns 200 with valid JWT\", async () => {\n404\t      const app = buildApp();\n405\t      const wallet = creatorKeypair.publicKey.toBase58();\n406\t      const token = await makeJwt(wallet);\n407\t\n408\t      const res = await app.request(\"/pot-shot/create\", {\n409\t        method: \"POST\",\n410\t        headers: {\n411\t          \"Content-Type\": \"application/json\",\n412\t          Authorization: `Bearer ${token}`,\n413\t        },\n414\t        body: JSON.stringify(makeLordBody(wallet)),\n415\t      });\n416\t\n417\t      expect(res.status).toBe(200);\n418\t      const json = (await res.json()) as Record<string, any>;\n419\t      expect(typeof json.transaction).toBe(\"string\");\n420\t      expect(typeof json.roundPda).toBe(\"string\");\n421\t      expect(typeof json.matchId).toBe(\"string\");\n422\t      expect(typeof json.commitment).toBe(\"string\");\n423\t      expect(typeof json.lastValidBlockHeight).toBe(\"number\");\n424\t    });\n425\t  });\n426\t\n427\t  // -----------------------------------------------------------------------\n428\t  // Per-game read endpoints\n429\t  // -----------------------------------------------------------------------\n430\t\n431\t  describe(\"GET /flipyou/verify/:pda\", () => {\n432\t    it(\"returns 200 for a known FlipYou PDA\", async () => {\n433\t      const app = buildApp();\n434\t      const wallet = creatorKeypair.publicKey.toBase58();\n435\t      const token = await makeJwt(wallet);\n436\t\n437\t      const createRes = await app.request(\"/flipyou/create\", {\n438\t        method: \"POST\",\n439\t        headers: {\n440\t          \"Content-Type\": \"application/json\",\n441\t          \"Authorization\": `Bearer ${token}`,\n442\t        },\n443\t        body: JSON.stringify(makeBody(wallet)),\n444\t      });\n445\t      expect(createRes.status).toBe(200);\n446\t      const createJson = (await createRes.json()) as { matchPda: string; matchId: string };\n447\t\n448\t      const verifyRes = await app.request(`/flipyou/verify/${createJson.matchPda}`);\n449\t      expect(verifyRes.status).toBe(200);\n450\t\n451\t      const json = (await verifyRes.json()) as Record<string, any>;\n452\t      expect(json.pda).toBe(createJson.matchPda);\n453\t      expect(json.game).toBe(\"flip-you\");\n454\t      expect(json.matchId).toBe(createJson.matchId);\n455\t    });\n456\t\n457\t    it(\"returns 404 for a PotShot PDA\", async () => {\n458\t      const app = buildApp();\n459\t      const wallet = creatorKeypair.publicKey.toBase58();\n460\t      const token = await makeJwt(wallet);\n461\t\n462\t      // Create a pot-shot round\n463\t      const createRes = await app.request(\"/pot-shot/create\", {\n464\t        method: \"POST\",\n465\t        headers: {\n466\t          \"Content-Type\": \"application/json\",\n467\t          Authorization: `Bearer ${token}`,\n468\t        },\n469\t        body: JSON.stringify(makeLordBody(wallet)),\n470\t      });\n471\t      expect(createRes.status).toBe(200);\n472\t      const createJson = (await createRes.json()) as { roundPda: string };\n473\t\n474\t      // Querying /flipyou/verify with a potshot PDA should 404\n475\t      const verifyRes = await app.request(`/flipyou/verify/${createJson.roundPda}`);\n476\t      expect(verifyRes.status).toBe(404);\n477\t    });\n478\t  });\n479\t\n480\t  describe(\"GET /flipyou/by-id/:matchId\", () => {\n481\t    it(\"returns 200 for known match ID\", async () => {\n482\t      const app = buildApp();\n483\t      const wallet = creatorKeypair.publicKey.toBase58();\n484\t      const token = await makeJwt(wallet);\n485\t\n486\t      const createRes = await app.request(\"/flipyou/create\", {\n487\t        method: \"POST\",\n488\t        headers: {\n489\t          \"Content-Type\": \"application/json\",\n490\t          \"Authorization\": `Bearer ${token}`,\n491\t        },\n492\t        body: JSON.stringify(makeBody(wallet)),\n493\t      });\n494\t      expect(createRes.status).toBe(200);\n495\t      const createJson = (await createRes.json()) as { matchId: string };\n496\t\n497\t      const byIdRes = await app.request(`/flipyou/by-id/${createJson.matchId}`);\n498\t      expect(byIdRes.status).toBe(200);\n499\t\n500\t      const json = (await byIdRes.json()) as Record<string, any>;\n501\t      expect(json.game).toBe(\"flip-you\");\n502\t      expect(json.matchId).toBe(createJson.matchId);\n503\t    });\n504\t\n505\t    it(\"returns 404 for unknown match ID\", async () => {\n506\t      const app = buildApp();\n507\t      const res = await app.request(\"/flipyou/by-id/deadbeefcafe0000\");\n508\t      expect(res.status).toBe(404);\n509\t    });\n510\t  });\n511\t\n512\t  describe(\"GET /flipyou/history\", () => {\n513\t    it(\"returns empty list when no settled rounds\", async () => {\n514\t      const app = buildApp();\n515\t      const res = await app.request(\"/flipyou/history\");\n516\t      expect(res.status).toBe(200);\n517\t      const json = (await res.json()) as Record<string, any>;\n518\t      expect(json.rounds).toEqual([]);\n519\t    });\n520\t  });\n521\t\n522\t  // -----------------------------------------------------------------------\n523\t  // GET /health\n524\t  // -----------------------------------------------------------------------\n525\t\n526\t  describe(\"GET /health\", () => {\n527\t    it(\"returns cheap process-local health fields\", async () => {\n528\t      const app = buildApp();\n529\t      const res = await app.request(\"/health\");\n530\t      expect(res.status).toBe(200);\n531\t\n532\t      const json = (await res.json()) as Record<string, any>;\n533\t      expect(json.status).toBe(\"ok\");\n534\t      expect(json.version).toBe(\"0.1.0\");\n535\t      expect(json.workerRunning).toBe(true);\n536\t    });\n537\t  });\n538\t});\n539\t"}]},"parent_tool_use_id":null,"session_id":"8252c9de-4a52-47bf-9061-0af7998830c4","uuid":"f1481ca5-2997-4e7c-b210-108413ac1141","timestamp":"2026-04-22T10:10:11.624Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/endpoints.test.ts","content":"/* eslint-disable @typescript-eslint/no-explicit-any */\n/**\n * HTTP endpoint tests — exercises the full middleware stack (rate limit + JWT auth)\n * and route handlers for all endpoints:\n *\n * POST /flipyou/create:\n *   - 200 with valid JWT\n *   - 401 with missing JWT\n *   - 401 with expired JWT\n *   - 409 with duplicate PDA (same wallet + match ID collision)\n *   - 429 when rate limit exceeded\n *\n * GET /flipyou/verify/:pda:\n *   - 200 for known PDA\n *   - 404 for unknown PDA\n *\n * GET /health:\n *   - 200 with expected fields\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect, vi } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair, LAMPORTS_PER_SOL } from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport { SignJWT } from \"jose\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createFlipYouRoutes } from \"../routes/create.js\";\nimport { createPotShotRoutes } from \"../routes/potshot-create.js\";\nimport { createHealthRoutes } from \"../routes/health.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport { createRateLimitMiddleware } from \"../middleware/rate-limit.js\";\nimport * as fairness from \"../fairness.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"taunt_bet_dev\",\n  });\n}\n\nconst AMOUNT_LAMPORTS = 5_000_000; // 0.005 SOL\nconst SIDE_HEADS = 0;\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-endpoint-tests\");\n\n// ---------------------------------------------------------------------------\n// Minimal mock Connection (only what routes + health need)\n// ---------------------------------------------------------------------------\n\nclass MockConnection {\n  async getLatestBlockhash() {\n    return {\n      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n      lastValidBlockHeight: 999_999,\n    };\n  }\n\n  async getAccountInfo() {\n    return null;\n  }\n\n  async getBalance() {\n    return 1.5 * LAMPORTS_PER_SOL;\n  }\n}\n\n// ---------------------------------------------------------------------------\n// JWT helper\n// ---------------------------------------------------------------------------\n\nfunction userIdFromWallet(wallet: string) {\n  return `usr_${wallet.slice(0, 8).toLowerCase()}`;\n}\n\nasync function makeJwt(wallet: string, opts?: { expiresIn?: number }) {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({})\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userIdFromWallet(wallet))\n    .setIssuedAt(now)\n    .setExpirationTime(now + (opts?.expiresIn ?? 3600))\n    .sign(JWT_SECRET);\n}\n\nfunction makeBody(wallet: string, overrides?: Partial<{ amountLamports: number; side: number }>) {\n  return {\n    wallet,\n    amountLamports: overrides?.amountLamports ?? AMOUNT_LAMPORTS,\n    side: overrides?.side ?? SIDE_HEADS,\n  };\n}\n\nfunction makeLordBody(wallet: string, overrides?: Partial<{ amountLamports: number }>) {\n  return {\n    wallet,\n    amountLamports: overrides?.amountLamports ?? AMOUNT_LAMPORTS,\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"HTTP endpoint tests\", () => {\n  let db: Db;\n  let rawSql: ReturnType<typeof postgres>;\n  let mockConn: MockConnection;\n\n  const serverKeypair = Keypair.generate();\n  const creatorKeypair = Keypair.generate();\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n    db = createDb(DATABASE_URL, rawSql);\n  });\n\n  afterAll(async () => {\n    await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE rounds, operator_events RESTART IDENTITY`;\n    // Ensure player_profiles exist for test wallets so profile-based wallet\n    // resolution works (routes call db.getProfileByUserId to get wallet).\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const userId = userIdFromWallet(wallet);\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${userId}, ${wallet}, ${\"test-creator-\" + Date.now()})\n      ON CONFLICT (user_id) DO UPDATE SET wallet = EXCLUDED.wallet\n    `;\n    mockConn = new MockConnection();\n  });\n\n  // -----------------------------------------------------------------------\n  // Helper: build a fresh Hono app with full middleware stack\n  // -----------------------------------------------------------------------\n\n  function buildApp(opts?: { perWallet?: number; global?: number }) {\n    const app = new Hono();\n\n    app.use(\n      \"/flipyou/*\",\n      createRateLimitMiddleware({\n        perWallet: opts?.perWallet ?? 10,\n        global: opts?.global ?? 100,\n        windowMs: 60_000,\n      }),\n    );\n    app.use(\n      \"/pot-shot/*\",\n      createRateLimitMiddleware({\n        perWallet: opts?.perWallet ?? 10,\n        global: opts?.global ?? 100,\n        windowMs: 60_000,\n      }),\n    );\n    app.use(\n      \"/flipyou/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n    );\n    app.use(\n      \"/pot-shot/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n    );\n\n    app.route(\n      \"/flipyou\",\n      createFlipYouRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n    app.route(\n      \"/pot-shot\",\n      createPotShotRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n\n    app.route(\n      \"/health\",\n      createHealthRoutes({\n        isWorkerRunning: () => true,\n      }),\n    );\n\n    return app;\n  }\n\n  // -----------------------------------------------------------------------\n  // POST /flipyou/create\n  // -----------------------------------------------------------------------\n\n  describe(\"POST /flipyou/create\", () => {\n    it(\"returns 200 with valid JWT\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const token = await makeJwt(wallet);\n      const body = makeBody(wallet);\n\n      const res = await app.request(\"/flipyou/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${token}`,\n        },\n        body: JSON.stringify(body),\n      });\n\n      expect(res.status).toBe(200);\n      const json = (await res.json()) as Record<string, any>;\n      expect(json.transaction).toBeDefined();\n      expect(typeof json.transaction).toBe(\"string\");\n      expect(json.matchPda).toBeDefined();\n      expect(typeof json.matchPda).toBe(\"string\");\n      expect(json.commitment).toBeDefined();\n      expect(typeof json.commitment).toBe(\"string\");\n      expect(json.lastValidBlockHeight).toBeDefined();\n      expect(typeof json.lastValidBlockHeight).toBe(\"number\");\n      // Commitment should be 64 hex chars (32 bytes)\n      expect((json.commitment as string).length).toBe(64);\n    });\n\n    it(\"returns 401 with missing JWT\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const body = makeBody(wallet);\n\n      const res = await app.request(\"/flipyou/create\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify(body),\n      });\n\n      expect(res.status).toBe(401);\n      const json = (await res.json()) as Record<string, any>;\n      expect(json.error).toBeDefined();\n    });\n\n    it(\"returns 401 with expired JWT\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const token = await makeJwt(wallet, { expiresIn: -10 });\n      const body = makeBody(wallet);\n\n      const res = await app.request(\"/flipyou/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${token}`,\n        },\n        body: JSON.stringify(body),\n      });\n\n      expect(res.status).toBe(401);\n      const json = (await res.json()) as Record<string, any>;\n      expect(json.error).toBeDefined();\n    });\n\n    it(\"returns 403 when body wallet mismatches JWT wallet\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const otherWallet = Keypair.generate().publicKey.toBase58();\n      const token = await makeJwt(wallet);\n      const body = makeBody(otherWallet); // Different wallet in body\n\n      const res = await app.request(\"/flipyou/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${token}`,\n        },\n        body: JSON.stringify(body),\n      });\n\n      expect(res.status).toBe(403);\n    });\n\n    it(\"returns 409 with duplicate PDA (match ID collision)\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const fixedMatchId = Buffer.from(\"deadbeefcafebabe\", \"hex\");\n      const matchIdSpy = vi\n        .spyOn(fairness, \"generateMatchId\")\n        .mockReturnValue(fixedMatchId);\n\n      try {\n        const body = makeBody(wallet);\n\n        const res1 = await app.request(\"/flipyou/create\", {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\",\n            \"Authorization\": `Bearer ${await makeJwt(wallet)}`,\n          },\n          body: JSON.stringify(body),\n        });\n        expect(res1.status).toBe(200);\n\n        const res2 = await app.request(\"/flipyou/create\", {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\",\n            \"Authorization\": `Bearer ${await makeJwt(wallet)}`,\n          },\n          body: JSON.stringify(body),\n        });\n\n        expect(res2.status).toBe(409);\n        const json = (await res2.json()) as Record<string, any>;\n        expect(json.error).toBe(\"Match ID collision — please retry\");\n      } finally {\n        matchIdSpy.mockRestore();\n      }\n    });\n\n    it(\"returns 429 when rate limit exceeded\", async () => {\n      // Create app with very low per-wallet limit\n      const app = buildApp({ perWallet: 2, global: 100 });\n      const wallet = creatorKeypair.publicKey.toBase58();\n\n      // Send 2 requests (within limit)\n      for (let i = 0; i < 2; i++) {\n        const token = await makeJwt(wallet);\n        const body = makeBody(wallet);\n        const res = await app.request(\"/flipyou/create\", {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\",\n            \"Authorization\": `Bearer ${token}`,\n          },\n          body: JSON.stringify(body),\n        });\n        expect(res.status).toBe(200);\n      }\n\n      // Third request should be rate-limited\n      const token3 = await makeJwt(wallet);\n      const body3 = makeBody(wallet);\n      const res3 = await app.request(\"/flipyou/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${token3}`,\n        },\n        body: JSON.stringify(body3),\n      });\n      expect(res3.status).toBe(429);\n      expect(res3.headers.get(\"Retry-After\")).toBeDefined();\n      const json = (await res3.json()) as Record<string, any>;\n      expect(json.error).toContain(\"Too many\");\n    });\n\n    it(\"rate-limits repeated invalid JWT POSTs before auth rejects them\", async () => {\n      const app = buildApp({ perWallet: 2, global: 100 });\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const badToken = \"not-a-valid-jwt\";\n\n      for (let i = 0; i < 2; i++) {\n        const res = await app.request(\"/flipyou/create\", {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\",\n            \"Authorization\": `Bearer ${badToken}`,\n          },\n          body: JSON.stringify(makeBody(wallet)),\n        });\n\n        expect(res.status).toBe(401);\n      }\n\n      const res3 = await app.request(\"/flipyou/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${badToken}`,\n        },\n        body: JSON.stringify(makeBody(wallet)),\n      });\n\n      expect(res3.status).toBe(429);\n      expect(res3.headers.get(\"Retry-After\")).toBeDefined();\n      const json = (await res3.json()) as Record<string, any>;\n      expect(json.error).toContain(\"Too many\");\n    });\n  });\n\n  describe(\"POST /pot-shot/create\", () => {\n    it(\"returns 200 with valid JWT\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const token = await makeJwt(wallet);\n\n      const res = await app.request(\"/pot-shot/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n        body: JSON.stringify(makeLordBody(wallet)),\n      });\n\n      expect(res.status).toBe(200);\n      const json = (await res.json()) as Record<string, any>;\n      expect(typeof json.transaction).toBe(\"string\");\n      expect(typeof json.roundPda).toBe(\"string\");\n      expect(typeof json.matchId).toBe(\"string\");\n      expect(typeof json.commitment).toBe(\"string\");\n      expect(typeof json.lastValidBlockHeight).toBe(\"number\");\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // Per-game read endpoints\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /flipyou/verify/:pda\", () => {\n    it(\"returns 200 for a known FlipYou PDA\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const token = await makeJwt(wallet);\n\n      const createRes = await app.request(\"/flipyou/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${token}`,\n        },\n        body: JSON.stringify(makeBody(wallet)),\n      });\n      expect(createRes.status).toBe(200);\n      const createJson = (await createRes.json()) as { matchPda: string; matchId: string };\n\n      const verifyRes = await app.request(`/flipyou/verify/${createJson.matchPda}`);\n      expect(verifyRes.status).toBe(200);\n\n      const json = (await verifyRes.json()) as Record<string, any>;\n      expect(json.pda).toBe(createJson.matchPda);\n      expect(json.game).toBe(\"flip-you\");\n      expect(json.matchId).toBe(createJson.matchId);\n    });\n\n    it(\"returns 404 for a PotShot PDA\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const token = await makeJwt(wallet);\n\n      // Create a pot-shot round\n      const createRes = await app.request(\"/pot-shot/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n        body: JSON.stringify(makeLordBody(wallet)),\n      });\n      expect(createRes.status).toBe(200);\n      const createJson = (await createRes.json()) as { roundPda: string };\n\n      // Querying /flipyou/verify with a potshot PDA should 404\n      const verifyRes = await app.request(`/flipyou/verify/${createJson.roundPda}`);\n      expect(verifyRes.status).toBe(404);\n    });\n  });\n\n  describe(\"GET /flipyou/by-id/:matchId\", () => {\n    it(\"returns 200 for known match ID\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const token = await makeJwt(wallet);\n\n      const createRes = await app.request(\"/flipyou/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${token}`,\n        },\n        body: JSON.stringify(makeBody(wallet)),\n      });\n      expect(createRes.status).toBe(200);\n      const createJson = (await createRes.json()) as { matchId: string };\n\n      const byIdRes = await app.request(`/flipyou/by-id/${createJson.matchId}`);\n      expect(byIdRes.status).toBe(200);\n\n      const json = (await byIdRes.json()) as Record<string, any>;\n      expect(json.game).toBe(\"flip-you\");\n      expect(json.matchId).toBe(createJson.matchId);\n    });\n\n    it(\"returns 404 for unknown match ID\", async () => {\n      const app = buildApp();\n      const res = await app.request(\"/flipyou/by-id/deadbeefcafe0000\");\n      expect(res.status).toBe(404);\n    });\n  });\n\n  describe(\"GET /flipyou/history\", () => {\n    it(\"returns empty list when no settled rounds\", async () => {\n      const app = buildApp();\n      const res = await app.request(\"/flipyou/history\");\n      expect(res.status).toBe(200);\n      const json = (await res.json()) as Record<string, any>;\n      expect(json.rounds).toEqual([]);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /health\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /health\", () => {\n    it(\"returns cheap process-local health fields\", async () => {\n      const app = buildApp();\n      const res = await app.request(\"/health\");\n      expect(res.status).toBe(200);\n\n      const json = (await res.json()) as Record<string, any>;\n      expect(json.status).toBe(\"ok\");\n      expect(json.version).toBe(\"0.1.0\");\n      expect(json.workerRunning).toBe(true);\n    });\n  });\n});\n","numLines":539,"startLine":1,"totalLines":539}}}
