{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LnKUvKZiVtTMpewqH3BNkA","type":"tool_result","content":"1\t/**\n2\t * Referral routes — code management, linking, stats, earnings, and claims.\n3\t *\n4\t * WAITLIST-CONTRACT: the waitlist calls POST/GET /code, POST /apply,\n5\t * GET /referrer, GET /stats, GET /referrals. /earnings and /claim are NOT\n6\t * consumed by waitlist. Request/response shape for the consumed set is\n7\t * pinned in `__tests__/waitlist-contract.test.ts`; keep\n8\t * `waitlist/src/lib/referral-api.ts` in lockstep.\n9\t */\n10\t\n11\timport { createRoute, z } from \"@hono/zod-openapi\";\n12\timport type postgres from \"postgres\";\n13\timport type { AppEnv } from \"../hono-env.js\";\n14\timport type { Db } from \"../db.js\";\n15\timport type { Config } from \"../config.js\";\n16\timport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n17\timport {\n18\t  envelope,\n19\t  ErrorEnvelopeSchema,\n20\t  ok,\n21\t  err,\n22\t} from \"../contracts/api-envelope.js\";\n23\timport {\n24\t  ApplyReferralCodeBodySchema,\n25\t  ClaimResponseSchema,\n26\t  CodeResponseSchema,\n27\t  MaybeCodeResponseSchema,\n28\t  ReferralApplyResponseSchema,\n29\t  ReferralCodeBodySchema,\n30\t  ReferralListResponseSchema,\n31\t  ReferralReferrerResponseSchema,\n32\t  ReferralStatsSchema,\n33\t} from \"../contracts/validators.js\";\n34\timport { logger } from \"../logger.js\";\n35\timport { emitEvent } from \"../queue/emit-event.js\";\n36\timport { EventTypes } from \"../queue/event-types.js\";\n37\timport { createOpenApiApp } from \"../openapi/hono.js\";\n38\t\n39\texport interface ReferralRoutesDeps {\n40\t  db: Db;\n41\t  sql: postgres.Sql;\n42\t  config: Config;\n43\t}\n44\t\n45\tconst EarningsResponseSchema = z.object({\n46\t  items: z.array(\n47\t    z.object({\n48\t      roundId: z.string(),\n49\t      gameType: z.string(),\n50\t      refereeUserId: z.string(),\n51\t      refereeUsername: z.string(),\n52\t      wagerLamports: z.string(),\n53\t      earnedLamports: z.string(),\n54\t      createdAt: z.string().datetime(),\n55\t    }),\n56\t  ),\n57\t  pagination: z.object({\n58\t    page: z.number().int(),\n59\t    totalPages: z.number().int(),\n60\t  }),\n61\t});\n62\t\n63\texport function createReferralRoutes(deps: ReferralRoutesDeps) {\n64\t  const { db, sql, config } = deps;\n65\t  const app = createOpenApiApp<AppEnv>();\n66\t\n67\t  // ── POST /code — set the player's referral code (permanent) ────────────\n68\t\n69\t  const setCodeRoute = createRoute({\n70\t    method: \"post\",\n71\t    path: \"/code\",\n72\t    tags: [\"Referral\"],\n73\t    summary: \"Set referral code (permanent)\",\n74\t    security: [{ bearerAuth: [] }],\n75\t    request: {\n76\t      body: {\n77\t        required: true,\n78\t        content: { \"application/json\": { schema: ReferralCodeBodySchema } },\n79\t      },\n80\t    },"}]},"parent_tool_use_id":null,"session_id":"8252c9de-4a52-47bf-9061-0af7998830c4","uuid":"38ea54b6-4609-4d43-b5b4-ec4a8dea0a67","timestamp":"2026-04-22T10:10:17.263Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/referral.ts","content":"/**\n * Referral routes — code management, linking, stats, earnings, and claims.\n *\n * WAITLIST-CONTRACT: the waitlist calls POST/GET /code, POST /apply,\n * GET /referrer, GET /stats, GET /referrals. /earnings and /claim are NOT\n * consumed by waitlist. Request/response shape for the consumed set is\n * pinned in `__tests__/waitlist-contract.test.ts`; keep\n * `waitlist/src/lib/referral-api.ts` in lockstep.\n */\n\nimport { createRoute, z } from \"@hono/zod-openapi\";\nimport type postgres from \"postgres\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport type { Config } from \"../config.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport {\n  ApplyReferralCodeBodySchema,\n  ClaimResponseSchema,\n  CodeResponseSchema,\n  MaybeCodeResponseSchema,\n  ReferralApplyResponseSchema,\n  ReferralCodeBodySchema,\n  ReferralListResponseSchema,\n  ReferralReferrerResponseSchema,\n  ReferralStatsSchema,\n} from \"../contracts/validators.js\";\nimport { logger } from \"../logger.js\";\nimport { emitEvent } from \"../queue/emit-event.js\";\nimport { EventTypes } from \"../queue/event-types.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface ReferralRoutesDeps {\n  db: Db;\n  sql: postgres.Sql;\n  config: Config;\n}\n\nconst EarningsResponseSchema = z.object({\n  items: z.array(\n    z.object({\n      roundId: z.string(),\n      gameType: z.string(),\n      refereeUserId: z.string(),\n      refereeUsername: z.string(),\n      wagerLamports: z.string(),\n      earnedLamports: z.string(),\n      createdAt: z.string().datetime(),\n    }),\n  ),\n  pagination: z.object({\n    page: z.number().int(),\n    totalPages: z.number().int(),\n  }),\n});\n\nexport function createReferralRoutes(deps: ReferralRoutesDeps) {\n  const { db, sql, config } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // ── POST /code — set the player's referral code (permanent) ────────────\n\n  const setCodeRoute = createRoute({\n    method: \"post\",\n    path: \"/code\",\n    tags: [\"Referral\"],\n    summary: \"Set referral code (permanent)\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      body: {\n        required: true,\n        content: { \"application/json\": { schema: ReferralCodeBodySchema } },\n      },\n    },","numLines":80,"startLine":1,"totalLines":852}}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01Sc6twzctiMPAkghYsGN2xU","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01H68Qnnf1iMGrUez8LRVroV","name":"Read","input":{"file_path":"/workspaces/rng-utopia/backend/src/routes/referral.ts","offset":80,"limit":240},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1402,"cache_read_input_tokens":93485,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1402},"output_tokens":70,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8252c9de-4a52-47bf-9061-0af7998830c4","uuid":"cb3373a4-f7d8-4f52-ba21-39b6f4ac40c4"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H68Qnnf1iMGrUez8LRVroV","type":"tool_result","content":"80\t    },\n81\t    responses: {\n82\t      200: {\n83\t        content: { \"application/json\": { schema: envelope(CodeResponseSchema) } },\n84\t        description: \"Code set\",\n85\t      },\n86\t      401: {\n87\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n88\t        description: \"Authentication required\",\n89\t      },\n90\t      404: {\n91\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n92\t        description: \"Profile not found\",\n93\t      },\n94\t      409: {\n95\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n96\t        description: \"Code already set or taken\",\n97\t      },\n98\t      422: {\n99\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n100\t        description: \"Invalid request body or code format\",\n101\t      },\n102\t      500: {\n103\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n104\t        description: \"Failed to set referral code\",\n105\t      },\n106\t    },\n107\t  });\n108\t\n109\t  app.openapi(setCodeRoute, async (c) => {\n110\t    const userId = c.get(\"userId\");\n111\t    if (!userId) {\n112\t      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n113\t    }\n114\t    const profile = await db.getProfileByUserId(userId);\n115\t    if (!profile) {\n116\t      return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");\n117\t    }\n118\t    const wallet = profile.wallet;\n119\t\n120\t    const { code } = c.req.valid(\"json\");\n121\t\n122\t    // Check if the user already has a code — codes are permanent\n123\t    const ownCode = await db.getReferralCodeByUserId(userId);\n124\t    if (ownCode) {\n125\t      return err(\n126\t        c,\n127\t        409,\n128\t        API_ERROR_CODES.CODE_ALREADY_SET,\n129\t        \"You already have a referral code. Codes cannot be changed.\",\n130\t        { retryable: false },\n131\t      );\n132\t    }\n133\t\n134\t    // Check if this code is already taken by another user\n135\t    const existing = await db.getReferralCodeByCode(code);\n136\t    if (existing && existing.user_id !== userId) {\n137\t      return err(\n138\t        c,\n139\t        409,\n140\t        API_ERROR_CODES.CODE_TAKEN,\n141\t        \"This referral code is already in use\",\n142\t        { retryable: false },\n143\t      );\n144\t    }\n145\t\n146\t    try {\n147\t      const result = await db.insertReferralCode(userId, wallet, code);\n148\t      logger.info(\"Referral code set\", { userId, wallet, code: result.code });\n149\t      return ok(c, { code: result.code });\n150\t    } catch (insertError) {\n151\t      // Handle race condition: another wallet grabbed the code between check and insert\n152\t      const msg =\n153\t        insertError instanceof Error ? insertError.message : String(insertError);\n154\t      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n155\t        return err(\n156\t          c,\n157\t          409,\n158\t          API_ERROR_CODES.CODE_TAKEN,\n159\t          \"This referral code is already in use\",\n160\t          { retryable: false },\n161\t        );\n162\t      }\n163\t      logger.error(\"Failed to set referral code\", {\n164\t        err: String(insertError),\n165\t        userId,\n166\t        wallet,\n167\t      });\n168\t      return err(\n169\t        c,\n170\t        500,\n171\t        API_ERROR_CODES.PRECONDITION_FAILED,\n172\t        \"Failed to set referral code\",\n173\t      );\n174\t    }\n175\t  }, (result, c) => {\n176\t    if (result.success) return;\n177\t    return err(\n178\t      c,\n179\t      422,\n180\t      API_ERROR_CODES.INVALID_CODE,\n181\t      \"Referral code must be 3-16 lowercase letters, numbers, or hyphens.\",\n182\t      { retryable: false, details: result.error.is