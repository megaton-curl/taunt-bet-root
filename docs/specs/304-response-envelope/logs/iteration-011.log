l(),\n53\t});\n54\t\n55\texport const StructuredErrorResponseSchema = z.object({\n56\t  error: StructuredErrorDetailSchema,\n57\t});\n58\t\n59\texport const OkResponseSchema = z.object({\n60\t  ok: z.boolean(),\n61\t});\n62\t\n63\texport const CodeResponseSchema = z.object({\n64\t  code: z.string(),\n65\t});\n66\t\n67\t// GET /referral/code: `code` is null when the user hasn't set one yet.\n68\t// Empty state is a valid answer to \"what's my code?\", not an error.\n69\texport const MaybeCodeResponseSchema = z.object({\n70\t  code: z.string().nullable(),\n71\t});\n72\t\n73\texport const ExistsResponseSchema = z.object({\n74\t  exists: z.boolean(),\n75\t});\n76\t\n77\texport const UsernameUpdateResponseSchema = z.object({\n78\t  username: z.string(),\n79\t  nextEditAvailableAt: z.string().datetime().nullable(),\n80\t});\n81\t\n82\texport const UsernameCooldownResponseSchema = z.object({\n83\t  error: z.string(),\n84\t  nextEditAvailableAt: z.string().datetime(),\n85\t});\n86\t\n87\texport const ReferralCodeSchema = z\n88\t  .string()\n89\t  .trim()\n90\t  .toLowerCase()\n91\t  .regex(/^[a-z0-9-]{3,16}$/)\n92\t  .describe(\"3-16 chars, lowercase alphanumeric + hyphens\");\n93\t\n94\texport const ReferralCodeBodySchema = z.object({\n95\t  code: ReferralCodeSchema,\n96\t});\n97\t\n98\texport const ApplyReferralCodeBodySchema = z.object({\n99\t  code: z.string().trim().toLowerCase().min(1),\n100\t});"}]},"parent_tool_use_id":null,"session_id":"8252c9de-4a52-47bf-9061-0af7998830c4","uuid":"08551722-7b01-4596-958e-eed286bc01ec","timestamp":"2026-04-22T10:09:48.831Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/contracts/validators.ts","content":"import { z } from \"zod\";\nimport {\n  PUBLIC_COMMIT_REVEAL_GAME_ID_VALUES,\n  PUBLIC_GAME_IDS,\n  PUBLIC_GAME_ID_VALUES,\n} from \"./public-games.js\";\n\nconst IsoDateTimeSchema = z.string().datetime();\nconst LamportsStringSchema = z.string().describe(\"Lamports as string\");\nconst UserIdSchema = z.string().describe(\"Short user ID (usr_xxxxxxxx)\");\nconst LeaderboardGameIdValues = [...PUBLIC_GAME_ID_VALUES, \"all\"] as const;\n\nfunction coerceClampedInteger(\n  raw: unknown,\n  defaultValue: number,\n  min: number,\n  max?: number,\n): number {\n  if (raw === undefined || raw === null || raw === \"\") {\n    return defaultValue;\n  }\n\n  const parsed = typeof raw === \"number\" ? raw : parseInt(String(raw), 10);\n  if (!Number.isFinite(parsed) || Number.isNaN(parsed) || parsed < min) {\n    return defaultValue;\n  }\n\n  return max === undefined ? parsed : Math.min(parsed, max);\n}\n\nfunction queryIntegerSchema(defaultValue: number, min: number, max?: number) {\n  const base = z.number().int().min(min);\n  const bounded = max === undefined ? base : base.max(max);\n\n  return z.preprocess(\n    (raw) => coerceClampedInteger(raw, defaultValue, min, max),\n    bounded.default(defaultValue),\n  );\n}\n\nexport const PublicGameIdSchema = z.enum(PUBLIC_GAME_ID_VALUES);\nexport const PublicCommitRevealGameIdSchema = z.enum(PUBLIC_COMMIT_REVEAL_GAME_ID_VALUES);\nexport const LeaderboardGameIdSchema = z.enum(LeaderboardGameIdValues);\n\nexport const ErrorResponseSchema = z.object({\n  error: z.string(),\n});\n\nexport const StructuredErrorDetailSchema = z.object({\n  code: z.string(),\n  message: z.string(),\n  retryable: z.boolean().optional(),\n});\n\nexport const StructuredErrorResponseSchema = z.object({\n  error: StructuredErrorDetailSchema,\n});\n\nexport const OkResponseSchema = z.object({\n  ok: z.boolean(),\n});\n\nexport const CodeResponseSchema = z.object({\n  code: z.string(),\n});\n\n// GET /referral/code: `code` is null when the user hasn't set one yet.\n// Empty state is a valid answer to \"what's my code?\", not an error.\nexport const MaybeCodeResponseSchema = z.object({\n  code: z.string().nullable(),\n});\n\nexport const ExistsResponseSchema = z.object({\n  exists: z.boolean(),\n});\n\nexport const UsernameUpdateResponseSchema = z.object({\n  username: z.string(),\n  nextEditAvailableAt: z.string().datetime().nullable(),\n});\n\nexport const UsernameCooldownResponseSchema = z.object({\n  error: z.string(),\n  nextEditAvailableAt: z.string().datetime(),\n});\n\nexport const ReferralCodeSchema = z\n  .string()\n  .trim()\n  .toLowerCase()\n  .regex(/^[a-z0-9-]{3,16}$/)\n  .describe(\"3-16 chars, lowercase alphanumeric + hyphens\");\n\nexport const ReferralCodeBodySchema = z.object({\n  code: ReferralCodeSchema,\n});\n\nexport const ApplyReferralCodeBodySchema = z.object({\n  code: z.string().trim().toLowerCase().min(1),\n});","numLines":100,"startLine":1,"totalLines":587}}}
