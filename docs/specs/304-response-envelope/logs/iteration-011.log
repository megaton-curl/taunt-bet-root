{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M9Sh7YZpPzoVuw38uqFjLq","type":"tool_result","content":"1\t/**\n2\t * Flip You routes.\n3\t *\n4\t * POST /flip-you/create   — create a new match\n5\t * GET  /flip-you/history   — recent settled matches\n6\t * GET  /flip-you/by-id/:matchId — lookup by match ID\n7\t * GET  /flip-you/verify/:pda    — lookup by PDA with verification data\n8\t */\n9\t\n10\timport { createRoute } from \"@hono/zod-openapi\";\n11\timport { z } from \"zod\";\n12\timport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\n13\timport { generateSecret, computeCommitment, generateMatchId, deriveMatchPda } from \"../fairness.js\";\n14\timport { buildCreateMatchTx } from \"../tx-builder.js\";\n15\timport type { Db, Round, OperatorEvent } from \"../db.js\";\n16\timport { errorMessage } from \"../contracts/api-errors.js\";\n17\timport { logger } from \"../logger.js\";\n18\timport type { AppEnv } from \"../hono-env.js\";\n19\timport type { PdaWatcher } from \"../worker/pda-watcher.js\";\n20\timport {\n21\t  ErrorResponseSchema,\n22\t  FlipYouCreateResponseSchema,\n23\t  FlipYouRoundResponseSchema,\n24\t  RoundEntrySchema,\n25\t  listEnvelopeResponseSchema,\n26\t} from \"../contracts/validators.js\";\n27\timport { createOpenApiApp } from \"../openapi/hono.js\";\n28\t\n29\texport interface CreateRoutesDeps {\n30\t  db: Db;\n31\t  connection: Connection;\n32\t  serverKeypair: Keypair;\n33\t  pdaWatcher?: PdaWatcher;\n34\t}\n35\t\n36\t/** Minimum wager in lamports: 0.001 SOL */\n37\tconst MIN_WAGER_LAMPORTS = 1_000_000;\n38\tconst MAX_WAGER_LAMPORTS = 100_000_000_000; // 100 SOL\n39\t\n40\tfunction isValidBase58(s: string): boolean {\n41\t  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n42\t}\n43\t\n44\t// ── Request schemas ──────────────────────────────────────────────────────\n45\t\n46\tconst FlipYouCreateBodySchema = z.object({\n47\t  wallet: z.string(),\n48\t  amountLamports: z.number().int().min(MIN_WAGER_LAMPORTS).max(MAX_WAGER_LAMPORTS),\n49\t  side: z.union([z.literal(0), z.literal(1)]),\n50\t});\n51\t\n52\tconst LimitQuerySchema = z.object({\n53\t  limit: z.string().optional(),\n54\t});\n55\t\n56\tconst MatchIdParamSchema = z.object({\n57\t  matchId: z.string(),\n58\t});\n59\t\n60\tconst PdaParamSchema = z.object({\n61\t  pda: z.string(),\n62\t});\n63\t\n64\t// ── Route definitions ────────────────────────────────────────────────────\n65\t\n66\tconst createMatchRoute = createRoute({\n67\t  method: \"post\",\n68\t  path: \"/create\",\n69\t  tags: [\"FlipYou\"],\n70\t  summary: \"Create a new Flip You match\",\n71\t  security: [{ bearerAuth: [] }],\n72\t  request: {\n73\t    body: {\n74\t      required: true,\n75\t      content: {\n76\t        \"application/json\": { schema: FlipYouCreateBodySchema },\n77\t      },\n78\t    },\n79\t  },\n80\t  responses: {\n81\t    200: {\n82\t      content: { \"application/json\": { schema: FlipYouCreateResponseSchema } },\n83\t      description: \"Match created successfully\",\n84\t    },\n85\t    400: {\n86\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n87\t      description: \"Invalid request\",\n88\t    },\n89\t    403: {\n90\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n91\t      description: \"Wallet mismatch\",\n92\t    },\n93\t    409: {\n94\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n95\t      description: \"Match ID collision\",\n96\t    },\n97\t    500: {\n98\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n99\t      description: \"Transaction build failed\",\n100\t    },\n101\t  },\n102\t});\n103\t\n104\tconst FlipYouHistoryResponseSchema = listEnvelopeResponseSchema(\n105\t  \"rounds\",\n106\t  FlipYouRoundResponseSchema,\n107\t);\n108\t\n109\ttype RoundEntry = z.infer<typeof RoundEntrySchema>;\n110\ttype FlipYouRoundResponse = z.infer<typeof FlipYouRoundResponseSchema>;\n111\t\n112\tconst historyRoute = createRoute({\n113\t  method: \"get\",\n114\t  path: \"/history\",\n115\t  tags: [\"FlipYou\"],\n116\t  summary: \"Get recent settled matches\",\n117\t  request: {\n118\t    query: LimitQuerySchema,\n119\t  },\n120\t  responses: {\n121\t    200: {\n122\t      content: {\n123\t        \"application/json\": {\n124\t          schema: FlipYouHistoryResponseSchema,\n125\t        },\n126\t      },\n127\t      description: \"List of settled matches\",\n128\t    },\n129\t  },\n130\t});\n131\t\n132\tconst byIdRoute = createRoute({\n133\t  method: \"get\",\n134\t  path: \"/by-id/{matchId}\",\n135\t  tags: [\"FlipYou\"],\n136\t  summary: \"Lookup match by ID\",\n137\t  request: {\n138\t    params: MatchIdParamSchema,\n139\t  },\n140\t  responses: {\n141\t    200: {\n142\t      content: { \"application/json\": { schema: FlipYouRoundResponseSchema } },\n143\t      description: \"Match found\",\n144\t    },\n145\t    400: {\n146\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n147\t      description: \"Invalid match ID format\",\n148\t    },\n149\t    404: {\n150\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n151\t      description: \"Match not found\",\n152\t    },\n153\t  },\n154\t});\n155\t\n156\tconst verifyRoute = createRoute({\n157\t  method: \"get\",\n158\t  path: \"/verify/{pda}\",\n159\t  tags: [\"FlipYou\"],\n160\t  summary: \"Lookup match by PDA with verification data\",\n161\t  request: {\n162\t    params: PdaParamSchema,\n163\t  },\n164\t  responses: {\n165\t    200: {\n166\t      content: { \"application/json\": { schema: FlipYouRoundResponseSchema } },\n167\t      description: \"Match verification data\",\n168\t    },\n169\t    404: {\n170\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n171\t      description: \"Match not found\",\n172\t    },\n173\t  },\n174\t});\n175\t\n176\t// ── Factory ──────────────────────────────────────────────────────────────\n177\t\n178\texport function createFlipYouRoutes(deps: CreateRoutesDeps) {\n179\t  const { db, connection, serverKeypair, pdaWatcher } = deps;\n180\t\n181\t  const app = createOpenApiApp<AppEnv>();\n182\t\n183\t  // POST /create\n184\t  app.openapi(createMatchRoute, async (c) => {\n185\t    // 1. Parse + validate request body (Zod handles shape validation)\n186\t    const body = c.req.valid(\"json\");\n187\t\n188\t    // Additional validation: base58 format\n189\t    if (!isValidBase58(body.wallet)) {\n190\t      logger.warn(\"flipyou create rejected: invalid wallet format\", {\n191\t        wallet: body.wallet,\n192\t      });\n193\t      return c.json({ error: \"wallet must be a valid base58 public key\" }, 400);\n194\t    }\n195\t\n196\t    // 2. Defense-in-depth: verify body wallet matches authenticated user's profile\n197\t    const userId = c.get(\"userId\");\n198\t    const profile = userId ? await db.getProfileByUserId(userId) : null;\n199\t    if (profile && body.wallet !== profile.wallet) {\n200\t      logger.warn(\"flipyou create rejected: wallet mismatch with profile\", {\n201\t        bodyWallet: body.wallet,\n202\t        profileWallet: profile.wallet,\n203\t      });\n204\t      return c.json({ error: \"Wallet does not match authenticated session\" }, 403);\n205\t    }\n206\t\n207\t    // 3. Validate wallet is a real public key\n208\t    let creatorPubkey: PublicKey;\n209\t    try {\n210\t      creatorPubkey = new PublicKey(body.wallet);\n211\t    } catch {\n212\t      logger.warn(\"flipyou create rejected: invalid wallet\", {\n213\t        wallet: body.wallet,\n214\t      });\n215\t      return c.json({ error: \"wallet is not a valid public key\" }, 400);\n216\t    }\n217\t\n218\t    logger.info(\"flipyou create requested\", {\n219\t      wallet: body.wallet,\n220\t      amountLamports: body.amountLamports,\n221\t      side: body.side,\n222\t    });\n223\t\n224\t    // 4. Generate secret + commitment + matchId\n225\t    const secret = generateSecret();\n226\t    const commitment = computeCommitment(secret);\n227\t    const matchId = generateMatchId();\n228\t\n229\t    // 5. Derive PDA\n230\t    const [matchPda] = deriveMatchPda(creatorPubkey, matchId);\n231\t    const matchPdaStr = matchPda.toBase58();\n232\t\n233\t    // 6. Check for duplicate PDA in DB (409 Conflict)\n234\t    const existing = await db.getRoundByPda(matchPdaStr);\n235\t    if (existing) {\n236\t      logger.warn(\"flipyou create rejected: duplicate match PDA\", {\n237\t        wallet: body.wallet,\n238\t        matchPda: matchPdaStr,\n239\t        matchId: matchId.toString(\"hex\"),\n240\t      });\n241\t      return c.json(\n242\t        { error: \"Match ID collision — please retry\" },\n243\t        409,\n244\t      );\n245\t    }\n246\t\n247\t    // 7. Build + partial-sign transaction\n248\t    let transaction: string;\n249\t    let lastValidBlockHeight: number;\n250\t    try {\n251\t      const result = await buildCreateMatchTx({\n252\t        connection,\n253\t        creator: creatorPubkey,\n254\t        serverKeypair,\n255\t        commitment,\n256\t        amountLamports: body.amountLamports,\n257\t        side: body.side,\n258\t        matchId,\n259\t      });\n260\t      transaction = result.transaction;\n261\t      lastValidBlockHeight = result.lastValidBlockHeight;\n262\t    } catch (err) {\n263\t      logger.error(\"flipyou create failed: transaction build error\", {\n264\t        wallet: body.wallet,\n265\t        matchPda: matchPdaStr,\n266\t        matchId: matchId.toString(\"hex\"),\n267\t        error: err instanceof Error ? err.message : \"Failed to build transaction\",\n268\t      });\n269\t      return c.json(\n270\t        { error: \"Failed to build transaction\" },\n271\t        500,\n272\t      );\n273\t    }\n274\t\n275\t    // 8. Store round in DB (phase: created)\n276\t    try {\n277\t      await db.insertRound({\n278\t        pda: matchPdaStr,\n279\t        game: \"flipyou\",\n280\t        creator: body.wallet,\n281\t        serverKey: serverKeypair.publicKey.toBase58(),\n282\t        secret,\n283\t        commitment,\n284\t        amountLamports: body.amountLamports,\n285\t        side: body.side,\n286\t        matchId: matchId.toString(\"hex\"),\n287\t        phase: \"created\",\n288\t      });\n289\t    } catch (err) {\n290\t      // Handle race condition — another request inserted the same PDA\n291\t      if (err instanceof Error && err.message.includes(\"duplicate\")) {\n292\t        logger.warn(\"flipyou create rejected: round insert duplicate\", {\n293\t          wallet: body.wallet,\n294\t          matchPda: matchPdaStr,\n295\t          matchId: matchId.toString(\"hex\"),\n296\t        });\n297\t        return c.json(\n298\t          { error: \"Match ID collision — please retry\" },\n299\t          409,\n300\t        );\n301\t      }\n302\t      logger.error(\"flipyou create failed: round insert error\", {\n303\t        wallet: body.wallet,\n304\t        matchPda: matchPdaStr,\n305\t        matchId: matchId.toString(\"hex\"),\n306\t        error: err instanceof Error ? err.message : String(err),\n307\t      });\n308\t      throw err;\n309\t    }\n310\t\n311\t    // 9. Write participation-time game entry (visible before settlement)\n312\t    try {\n313\t      if (profile) {\n314\t        await db.upsertGameEntry({\n315\t          userId: profile.user_id,\n316\t          wallet: body.wallet,\n317\t          game: \"flipyou\",\n318\t          roundPda: matchPdaStr,\n319\t          matchId: matchId.toString(\"hex\"),\n320\t          amountLamports: body.amountLamports,\n321\t          side: body.side === 0 ? \"heads\" : \"tails\",\n322\t        });\n323\t      }\n324\t    } catch (err) {\n325\t      // Non-fatal — entry will be created at settlement if this fails\n326\t      logger.warn(\"flipyou create: game_entry insert failed\", {\n327\t        error: err instanceof Error ? err.message : String(err),\n328\t      });\n329\t    }\n330\t\n331\t    // 10. Write operator event\n332\t    await db.insertOperatorEvent(matchPdaStr, \"secret_generated\", {\n333\t      creator: body.wallet,\n334\t      amountLamports: body.amountLamports,\n335\t      side: body.side,\n336\t      matchId: matchId.toString(\"hex\"),\n337\t    });\n338\t\n339\t    // 9b. Subscribe to PDA for instant join detection via WebSocket\n340\t    pdaWatcher?.watch(matchPdaStr);\n341\t\n342\t    logger.info(\"flipyou create prepared\", {\n343\t      wallet: body.wallet,\n344\t      matchPda: matchPdaStr,\n345\t      matchId: matchId.toString(\"hex\"),\n346\t      amountLamports: body.amountLamports,\n347\t      side: body.side,\n348\t      lastValidBlockHeight,\n349\t    });\n350\t\n351\t    // 10. Return response\n352\t    return c.json({\n353\t      transaction,\n354\t      matchPda: matchPdaStr,\n355\t      matchId: matchId.toString(\"hex\"),\n356\t      commitment: commitment.toString(\"hex\"),\n357\t      lastValidBlockHeight,\n358\t    }, 200);\n359\t  });\n360\t\n361\t  // -----------------------------------------------------------------------\n362\t  // GET /history — recent settled Flip You matches\n363\t  // -----------------------------------------------------------------------\n364\t\n365\t  app.openapi(historyRoute, async (c) => {\n366\t    const { limit: limitParam } = c.req.valid(\"query\");\n367\t    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 50);\n368\t\n369\t    const rounds = await db.getRecentSettledRounds(\"flipyou\", limit);\n370\t    const settleEvents = await db.getLatestOperatorEventsForPdas(\n371\t      rounds.map((r) => r.pda),\n372\t      \"settle_confirmed\",\n373\t    );\n374\t\n375\t    return c.json({\n376\t      rounds: rounds.map((r) => formatFlipYouRound(r, settleEvents.get(r.pda))),\n377\t    }, 200);\n378\t  });\n379\t\n380\t  // -----------------------------------------------------------------------\n381\t  // GET /by-id/:matchId — lookup by 16-char hex match ID\n382\t  // -----------------------------------------------------------------------\n383\t\n384\t  app.openapi(byIdRoute, async (c) => {\n385\t    const { matchId } = c.req.valid(\"param\");\n386\t    if (!/^[0-9a-f]{16}$/i.test(matchId)) {\n387\t      return c.json(errorMessage(\"matchId must be a 16-char hex string\"), 400);\n388\t    }\n389\t\n390\t    const round = await db.getRoundByMatchId(matchId.toLowerCase());\n391\t    if (!round || round.game !== \"flipyou\") {\n392\t      return c.json(errorMessage(\"Match not found\"), 404);\n393\t    }\n394\t\n395\t    return c.json(await enrichFlipYouRound(db, round), 200);\n396\t  });\n397\t\n398\t  // -----------------------------------------------------------------------\n399\t  // GET /verify/:pda — lookup by PDA with full verification data\n400\t  // -----------------------------------------------------------------------\n401\t\n402\t  app.openapi(verifyRoute, async (c) => {\n403\t    const { pda } = c.req.valid(\"param\");\n404\t    const round = await db.getRoundByPda(pda);\n405\t    if (!round || round.game !== \"flipyou\") {\n406\t      return c.json(errorMessage(\"Match not found\"), 404);\n407\t    }\n408\t\n409\t    return c.json(await enrichFlipYouRound(db, round), 200);\n410\t  });\n411\t\n412\t  return app;\n413\t}\n414\t\n415\t// ---------------------------------------------------------------------------\n416\t// FlipYou response formatting\n417\t// ---------------------------------------------------------------------------\n418\t\n419\tfunction getEventPayload(event: OperatorEvent | undefined): Record<string, unknown> | null {\n420\t  if (!event || typeof event.payload !== \"object\" || event.payload === null) return null;\n421\t  return event.payload as Record<string, unknown>;\n422\t}\n423\t\n424\tfunction getNullableString(value: unknown): string | null | undefined {\n425\t  if (value === null) return null;\n426\t  return typeof value === \"string\" ? value : undefined;\n427\t}\n428\t\n429\tfunction getNullableInt(value: unknown): number | null | undefined {\n430\t  if (value === null) return null;\n431\t  return typeof value === \"number\" && Number.isInteger(value) ? value : undefined;\n432\t}\n433\t\n434\tfunction getRoundEntries(value: unknown): RoundEntry[] | undefined {\n435\t  const parsed = z.array(RoundEntrySchema).safeParse(value);\n436\t  return parsed.success ? parsed.data : undefined;\n437\t}\n438\t\n439\tfunction formatFlipYouRound(round: Round, settleEvent?: OperatorEvent): FlipYouRoundResponse {\n440\t  const isSettled = round.phase === \"settled\";\n441\t  const settlePayload = getEventPayload(settleEvent);\n442\t\n443\t  const response: FlipYouRoundResponse = {\n444\t    pda: round.pda,\n445\t    game: \"flip-you\",\n446\t    phase: round.phase,\n447\t    creator: round.creator,\n448\t    commitment: round.commitment.toString(\"hex\"),\n449\t    amountLamports: round.amount_lamports,\n450\t    side: round.side,\n451\t    matchId: round.match_id,\n452\t    createdAt: round.created_at.toISOString(),\n453\t    updatedAt: round.updated_at.toISOString(),\n454\t  };\n455\t\n456\t  if (round.target_slot !== null) {\n457\t    response.targetSlot = Number(round.target_slot);\n458\t  }\n459\t\n460\t  if (isSettled) {\n461\t    response.secret = round.secret.toString(\"hex\");\n462\t    response.resultHash = round.result_hash ? round.result_hash.toString(\"hex\") : null;\n463\t    if (round.result_side !== null) {\n464\t      response.resultSide = round.result_side;\n465\t    }\n466\t    if (round.winner) {\n467\t      response.winner = round.winner;\n468\t    }\n469\t    if (round.settle_tx) {\n470\t      response.settleTx = round.settle_tx;\n471\t    }\n472\t    response.verification = {\n473\t      commitmentCheck: \"sha256(secret) == commitment\",\n474\t      resultFormula: \"sha256(secret || entropy || pda || algorithmVersion)\",\n475\t      entropySource: \"SlotHashes sysvar at target_slot\",\n476\t    };\n477\t\n478\t    if (Array.isArray(round.entries)) {\n479\t      response.entries = round.entries;\n480\t    }\n481\t\n482\t    if (settlePayload) {\n483\t      const entries = getRoundEntries(settlePayload.entries);\n484\t      const entropy = getNullableString(settlePayload.entropy);\n485\t      const payoutAmount = getNullableInt(settlePayload.payoutAmount);\n486\t      const feeAmount = getNullableInt(settlePayload.feeAmount);\n487\t\n488\t      if (!response.entries && entries) {\n489\t        response.entries = entries;\n490\t      }\n491\t      if (entropy !== undefined) {\n492\t        response.entropy = entropy;\n493\t      }\n494\t      if (payoutAmount !== undefined) {\n495\t        response.payoutAmount = payoutAmount;\n496\t      }\n497\t      if (feeAmount !== undefined) {\n498\t        response.feeAmount = feeAmount;\n499\t      }\n500\t    }\n501\t  }\n502\t\n503\t  return response;\n504\t}\n505\t\n506\tasync function enrichFlipYouRound(db: Db, round: Round) {\n507\t  let settleEvent: OperatorEvent | undefined;\n508\t  if (round.phase === \"settled\") {\n509\t    try {\n510\t      settleEvent = await db.getLatestOperatorEvent(round.pda, \"settle_confirmed\");\n511\t    } catch {\n512\t      // Gracefully degrade\n513\t    }\n514\t  }\n515\t  return formatFlipYouRound(round, settleEvent);\n516\t}\n517\t"}]},"parent_tool_use_id":null,"session_id":"8252c9de-4a52-47bf-9061-0af7998830c4","uuid":"7b473ee5-03bb-4a3d-898c-248de7c4959a","timestamp":"2026-04-22T10:09:43.513Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/create.ts","content":"/**\n * Flip You routes.\n *\n * POST /flip-you/create   — create a new match\n * GET  /flip-you/history   — recent settled matches\n * GET  /flip-you/by-id/:matchId — lookup by match ID\n * GET  /flip-you/verify/:pda    — lookup by PDA with verification data\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\nimport { generateSecret, computeCommitment, generateMatchId, deriveMatchPda } from \"../fairness.js\";\nimport { buildCreateMatchTx } from \"../tx-builder.js\";\nimport type { Db, Round, OperatorEvent } from \"../db.js\";\nimport { errorMessage } from \"../contracts/api-errors.js\";\nimport { logger } from \"../logger.js\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { PdaWatcher } from \"../worker/pda-watcher.js\";\nimport {\n  ErrorResponseSchema,\n  FlipYouCreateResponseSchema,\n  FlipYouRoundResponseSchema,\n  RoundEntrySchema,\n  listEnvelopeResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface CreateRoutesDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  pdaWatcher?: PdaWatcher;\n}\n\n/** Minimum wager in lamports: 0.001 SOL */\nconst MIN_WAGER_LAMPORTS = 1_000_000;\nconst MAX_WAGER_LAMPORTS = 100_000_000_000; // 100 SOL\n\nfunction isValidBase58(s: string): boolean {\n  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n}\n\n// ── Request schemas ──────────────────────────────────────────────────────\n\nconst FlipYouCreateBodySchema = z.object({\n  wallet: z.string(),\n  amountLamports: z.number().int().min(MIN_WAGER_LAMPORTS).max(MAX_WAGER_LAMPORTS),\n  side: z.union([z.literal(0), z.literal(1)]),\n});\n\nconst LimitQuerySchema = z.object({\n  limit: z.string().optional(),\n});\n\nconst MatchIdParamSchema = z.object({\n  matchId: z.string(),\n});\n\nconst PdaParamSchema = z.object({\n  pda: z.string(),\n});\n\n// ── Route definitions ────────────────────────────────────────────────────\n\nconst createMatchRoute = createRoute({\n  method: \"post\",\n  path: \"/create\",\n  tags: [\"FlipYou\"],\n  summary: \"Create a new Flip You match\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": { schema: FlipYouCreateBodySchema },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: FlipYouCreateResponseSchema } },\n      description: \"Match created successfully\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Invalid request\",\n    },\n    403: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Wallet mismatch\",\n    },\n    409: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Match ID collision\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Transaction build failed\",\n    },\n  },\n});\n\nconst FlipYouHistoryResponseSchema = listEnvelopeResponseSchema(\n  \"rounds\",\n  FlipYouRoundResponseSchema,\n);\n\ntype RoundEntry = z.infer<typeof RoundEntrySchema>;\ntype FlipYouRoundResponse = z.infer<typeof FlipYouRoundResponseSchema>;\n\nconst historyRoute = createRoute({\n  method: \"get\",\n  path: \"/history\",\n  tags: [\"FlipYou\"],\n  summary: \"Get recent settled matches\",\n  request: {\n    query: LimitQuerySchema,\n  },\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: FlipYouHistoryResponseSchema,\n        },\n      },\n      description: \"List of settled matches\",\n    },\n  },\n});\n\nconst byIdRoute = createRoute({\n  method: \"get\",\n  path: \"/by-id/{matchId}\",\n  tags: [\"FlipYou\"],\n  summary: \"Lookup match by ID\",\n  request: {\n    params: MatchIdParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: FlipYouRoundResponseSchema } },\n      description: \"Match found\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Invalid match ID format\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Match not found\",\n    },\n  },\n});\n\nconst verifyRoute = createRoute({\n  method: \"get\",\n  path: \"/verify/{pda}\",\n  tags: [\"FlipYou\"],\n  summary: \"Lookup match by PDA with verification data\",\n  request: {\n    params: PdaParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: FlipYouRoundResponseSchema } },\n      description: \"Match verification data\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Match not found\",\n    },\n  },\n});\n\n// ── Factory ──────────────────────────────────────────────────────────────\n\nexport function createFlipYouRoutes(deps: CreateRoutesDeps) {\n  const { db, connection, serverKeypair, pdaWatcher } = deps;\n\n  const app = createOpenApiApp<AppEnv>();\n\n  // POST /create\n  app.openapi(createMatchRoute, async (c) => {\n    // 1. Parse + validate request body (Zod handles shape validation)\n    const body = c.req.valid(\"json\");\n\n    // Additional validation: base58 format\n    if (!isValidBase58(body.wallet)) {\n      logger.warn(\"flipyou create rejected: invalid wallet format\", {\n        wallet: body.wallet,\n      });\n      return c.json({ error: \"wallet must be a valid base58 public key\" }, 400);\n    }\n\n    // 2. Defense-in-depth: verify body wallet matches authenticated user's profile\n    const userId = c.get(\"userId\");\n    const profile = userId ? await db.getProfileByUserId(userId) : null;\n    if (profile && body.wallet !== profile.wallet) {\n      logger.warn(\"flipyou create rejected: wallet mismatch with profile\", {\n        bodyWallet: body.wallet,\n        profileWallet: profile.wallet,\n      });\n      return c.json({ error: \"Wallet does not match authenticated session\" }, 403);\n    }\n\n    // 3. Validate wallet is a real public key\n    let creatorPubkey: PublicKey;\n    try {\n      creatorPubkey = new PublicKey(body.wallet);\n    } catch {\n      logger.warn(\"flipyou create rejected: invalid wallet\", {\n        wallet: body.wallet,\n      });\n      return c.json({ error: \"wallet is not a valid public key\" }, 400);\n    }\n\n    logger.info(\"flipyou create requested\", {\n      wallet: body.wallet,\n      amountLamports: body.amountLamports,\n      side: body.side,\n    });\n\n    // 4. Generate secret + commitment + matchId\n    const secret = generateSecret();\n    const commitment = computeCommitment(secret);\n    const matchId = generateMatchId();\n\n    // 5. Derive PDA\n    const [matchPda] = deriveMatchPda(creatorPubkey, matchId);\n    const matchPdaStr = matchPda.toBase58();\n\n    // 6. Check for duplicate PDA in DB (409 Conflict)\n    const existing = await db.getRoundByPda(matchPdaStr);\n    if (existing) {\n      logger.warn(\"flipyou create rejected: duplicate match PDA\", {\n        wallet: body.wallet,\n        matchPda: matchPdaStr,\n        matchId: matchId.toString(\"hex\"),\n      });\n      return c.json(\n        { error: \"Match ID collision — please retry\" },\n        409,\n      );\n    }\n\n    // 7. Build + partial-sign transaction\n    let transaction: string;\n    let lastValidBlockHeight: number;\n    try {\n      const result = await buildCreateMatchTx({\n        connection,\n        creator: creatorPubkey,\n        serverKeypair,\n        commitment,\n        amountLamports: body.amountLamports,\n        side: body.side,\n        matchId,\n      });\n      transaction = result.transaction;\n      lastValidBlockHeight = result.lastValidBlockHeight;\n    } catch (err) {\n      logger.error(\"flipyou create failed: transaction build error\", {\n        wallet: body.wallet,\n        matchPda: matchPdaStr,\n        matchId: matchId.toString(\"hex\"),\n        error: err instanceof Error ? err.message : \"Failed to build transaction\",\n      });\n      return c.json(\n        { error: \"Failed to build transaction\" },\n        500,\n      );\n    }\n\n    // 8. Store round in DB (phase: created)\n    try {\n      await db.insertRound({\n        pda: matchPdaStr,\n        game: \"flipyou\",\n        creator: body.wallet,\n        serverKey: serverKeypair.publicKey.toBase58(),\n        secret,\n        commitment,\n        amountLamports: body.amountLamports,\n        side: body.side,\n        matchId: matchId.toString(\"hex\"),\n        phase: \"created\",\n      });\n    } catch (err) {\n      // Handle race condition — another request inserted the same PDA\n      if (err instanceof Error && err.message.includes(\"duplicate\")) {\n        logger.warn(\"flipyou create rejected: round insert duplicate\", {\n          wallet: body.wallet,\n          matchPda: matchPdaStr,\n          matchId: matchId.toString(\"hex\"),\n        });\n        return c.json(\n          { error: \"Match ID collision — please retry\" },\n          409,\n        );\n      }\n      logger.error(\"flipyou create failed: round insert error\", {\n        wallet: body.wallet,\n        matchPda: matchPdaStr,\n        matchId: matchId.toString(\"hex\"),\n        error: err instanceof Error ? err.message : String(err),\n      });\n      throw err;\n    }\n\n    // 9. Write participation-time game entry (visible before settlement)\n    try {\n      if (profile) {\n        await db.upsertGameEntry({\n          userId: profile.user_id,\n          wallet: body.wallet,\n          game: \"flipyou\",\n          roundPda: matchPdaStr,\n          matchId: matchId.toString(\"hex\"),\n          amountLamports: body.amountLamports,\n          side: body.side === 0 ? \"heads\" : \"tails\",\n        });\n      }\n    } catch (err) {\n      // Non-fatal — entry will be created at settlement if this fails\n      logger.warn(\"flipyou create: game_entry insert failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n    }\n\n    // 10. Write operator event\n    await db.insertOperatorEvent(matchPdaStr, \"secret_generated\", {\n      creator: body.wallet,\n      amountLamports: body.amountLamports,\n      side: body.side,\n      matchId: matchId.toString(\"hex\"),\n    });\n\n    // 9b. Subscribe to PDA for instant join detection via WebSocket\n    pdaWatcher?.watch(matchPdaStr);\n\n    logger.info(\"flipyou create prepared\", {\n      wallet: body.wallet,\n      matchPda: matchPdaStr,\n      matchId: matchId.toString(\"hex\"),\n      amountLamports: body.amountLamports,\n      side: body.side,\n      lastValidBlockHeight,\n    });\n\n    // 10. Return response\n    return c.json({\n      transaction,\n      matchPda: matchPdaStr,\n      matchId: matchId.toString(\"hex\"),\n      commitment: commitment.toString(\"hex\"),\n      lastValidBlockHeight,\n    }, 200);\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /history — recent settled Flip You matches\n  // -----------------------------------------------------------------------\n\n  app.openapi(historyRoute, async (c) => {\n    const { limit: limitParam } = c.req.valid(\"query\");\n    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 50);\n\n    const rounds = await db.getRecentSettledRounds(\"flipyou\", limit);\n    const settleEvents = await db.getLatestOperatorEventsForPdas(\n      rounds.map((r) => r.pda),\n      \"settle_confirmed\",\n    );\n\n    return c.json({\n      rounds: rounds.map((r) => formatFlipYouRound(r, settleEvents.get(r.pda))),\n    }, 200);\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /by-id/:matchId — lookup by 16-char hex match ID\n  // -----------------------------------------------------------------------\n\n  app.openapi(byIdRoute, async (c) => {\n    const { matchId } = c.req.valid(\"param\");\n    if (!/^[0-9a-f]{16}$/i.test(matchId)) {\n      return c.json(errorMessage(\"matchId must be a 16-char hex string\"), 400);\n    }\n\n    const round = await db.getRoundByMatchId(matchId.toLowerCase());\n    if (!round || round.game !== \"flipyou\") {\n      return c.json(errorMessage(\"Match not found\"), 404);\n    }\n\n    return c.json(await enrichFlipYouRound(db, round), 200);\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /verify/:pda — lookup by PDA with full verification data\n  // -----------------------------------------------------------------------\n\n  app.openapi(verifyRoute, async (c) => {\n    const { pda } = c.req.valid(\"param\");\n    const round = await db.getRoundByPda(pda);\n    if (!round || round.game !== \"flipyou\") {\n      return c.json(errorMessage(\"Match not found\"), 404);\n    }\n\n    return c.json(await enrichFlipYouRound(db, round), 200);\n  });\n\n  return app;\n}\n\n// ---------------------------------------------------------------------------\n// FlipYou response formatting\n// ---------------------------------------------------------------------------\n\nfunction getEventPayload(event: OperatorEvent | undefined): Record<string, unknown> | null {\n  if (!event || typeof event.payload !== \"object\" || event.payload === null) return null;\n  return event.payload as Record<string, unknown>;\n}\n\nfunction getNullableString(value: unknown): string | null | undefined {\n  if (value === null) return null;\n  return typeof value === \"string\" ? value : undefined;\n}\n\nfunction getNullableInt(value: unknown): number | null | undefined {\n  if (value === null) return null;\n  return typeof value === \"number\" && Number.isInteger(value) ? value : undefined;\n}\n\nfunction getRoundEntries(value: unknown): RoundEntry[] | undefined {\n  const parsed = z.array(RoundEntrySchema).safeParse(value);\n  return parsed.success ? parsed.data : undefined;\n}\n\nfunction formatFlipYouRound(round: Round, settleEvent?: OperatorEvent): FlipYouRoundResponse {\n  const isSettled = round.phase === \"settled\";\n  const settlePayload = getEventPayload(settleEvent);\n\n  const response: FlipYouRoundResponse = {\n    pda: round.pda,\n    game: \"flip-you\",\n    phase: round.phase,\n    creator: round.creator,\n    commitment: round.commitment.toString(\"hex\"),\n    amountLamports: round.amount_lamports,\n    side: round.side,\n    matchId: round.match_id,\n    createdAt: round.created_at.toISOString(),\n    updatedAt: round.updated_at.toISOString(),\n  };\n\n  if (round.target_slot !== null) {\n    response.targetSlot = Number(round.target_slot);\n  }\n\n  if (isSettled) {\n    response.secret = round.secret.toString(\"hex\");\n    response.resultHash = round.result_hash ? round.result_hash.toString(\"hex\") : null;\n    if (round.result_side !== null) {\n      response.resultSide = round.result_side;\n    }\n    if (round.winner) {\n      response.winner = round.winner;\n    }\n    if (round.settle_tx) {\n      response.settleTx = round.settle_tx;\n    }\n    response.verification = {\n      commitmentCheck: \"sha256(secret) == commitment\",\n      resultFormula: \"sha256(secret || entropy || pda || algorithmVersion)\",\n      entropySource: \"SlotHashes sysvar at target_slot\",\n    };\n\n    if (Array.isArray(round.entries)) {\n      response.entries = round.entries;\n    }\n\n    if (settlePayload) {\n      const entries = getRoundEntries(settlePayload.entries);\n      const entropy = getNullableString(settlePayload.entropy);\n      const payoutAmount = getNullableInt(settlePayload.payoutAmount);\n      const feeAmount = getNullableInt(settlePayload.feeAmount);\n\n      if (!response.entries && entries) {\n        response.entries = entries;\n      }\n      if (entropy !== undefined) {\n        response.entropy = entropy;\n      }\n      if (payoutAmount !== undefined) {\n        response.payoutAmount = payoutAmount;\n      }\n      if (feeAmount !== undefined) {\n        response.feeAmount = feeAmount;\n      }\n    }\n  }\n\n  return response;\n}\n\nasync function enrichFlipYouRound(db: Db, round: Round) {\n  let settleEvent: OperatorEvent | undefined;\n  if (round.phase === \"settled\") {\n    try {\n      settleEvent = await db.getLatestOperatorEvent(round.pda, \"settle_confirmed\");\n    } catch {\n      // Gracefully degrade\n    }\n  }\n  return formatFlipYouRound(round, settleEvent);\n}\n","numLines":517,"startLine":1,"totalLines":517}}}
