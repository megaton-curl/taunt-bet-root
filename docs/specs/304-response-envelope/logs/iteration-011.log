Res = await app.request(\"/flipyou/create\", {\n497:      const byIdRes = await app.request(`/flipyou/by-id/${createJson.matchId}`);\n501:      expect(json.game).toBe(\"flip-you\");\n507:      const res = await app.request(\"/flipyou/by-id/deadbeefcafe0000\");\n512:  describe(\"GET /flipyou/history\", () => {\n515:      const res = await app.request(\"/flipyou/history\");","numLines":34}}
