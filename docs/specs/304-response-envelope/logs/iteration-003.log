{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KPc5TRKE9LXQVZwmrA645A","type":"tool_result","content":"1\timport { OpenAPIHono } from \"@hono/zod-openapi\";\n2\timport type { Context, Env } from \"hono\";\n3\timport { errorMessage } from \"../contracts/api-errors.js\";\n4\t\n5\texport function invalidRequestHook<E extends Env, P extends string>(\n6\t  result: { success: true } | { success: false },\n7\t  c: Context<E, P>,\n8\t) {\n9\t  if (result.success) return;\n10\t  return c.json(errorMessage(\"Invalid request\"), 400);\n11\t}\n12\t\n13\texport function createOpenApiApp<E extends Env = Env>() {\n14\t  return new OpenAPIHono<E>({\n15\t    defaultHook: invalidRequestHook,\n16\t  });\n17\t}\n18\t"}]},"parent_tool_use_id":null,"session_id":"d672558b-a9e4-40c4-9f27-80a74607ea06","uuid":"01b4287c-21dc-4d4d-bd05-24f81e03e678","timestamp":"2026-04-22T09:20:44.565Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/openapi/hono.ts","content":"import { OpenAPIHono } from \"@hono/zod-openapi\";\nimport type { Context, Env } from \"hono\";\nimport { errorMessage } from \"../contracts/api-errors.js\";\n\nexport function invalidRequestHook<E extends Env, P extends string>(\n  result: { success: true } | { success: false },\n  c: Context<E, P>,\n) {\n  if (result.success) return;\n  return c.json(errorMessage(\"Invalid request\"), 400);\n}\n\nexport function createOpenApiApp<E extends Env = Env>() {\n  return new OpenAPIHono<E>({\n    defaultHook: invalidRequestHook,\n  });\n}\n","numLines":18,"startLine":1,"totalLines":18}}}
