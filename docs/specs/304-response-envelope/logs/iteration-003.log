{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KxMHQnspGBRmL1sEKjLDnw","type":"tool_result","content":"80\t    await rawSql.end();\n81\t  });\n82\t\n83\t  beforeEach(async () => {\n84\t    await rawSql`DELETE FROM game_entries WHERE wallet LIKE 'LeaderboardTest%'`;\n85\t    await rawSql`DELETE FROM player_profiles WHERE wallet LIKE 'LeaderboardTest%'`;\n86\t    app = new Hono();\n87\t    app.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n88\t    // Seed profiles for test wallets (leaderboard JOINs on user_id)\n89\t    await rawSql`\n90\t      INSERT INTO player_profiles (user_id, wallet, username) VALUES\n91\t        (${USER_A}, ${WALLET_A}, ${\"user_a_\" + TS}),\n92\t        (${USER_B}, ${WALLET_B}, ${\"user_b_\" + TS}),\n93\t        (${USER_C}, ${WALLET_C}, ${\"user_c_\" + TS})\n94\t      ON CONFLICT DO NOTHING\n95\t    `;\n96\t  });\n97\t\n98\t  it(\"returns empty leaderboard when no entries\", async () => {\n99\t    const result = await db.getWeeklyLeaderboard();\n100\t    // May have entries from other tests but our users shouldn't be there\n101\t    const ours = result.entries.filter((e) =>\n102\t      e.userId.startsWith(\"usr_lead\"),\n103\t    );\n104\t    expect(ours.length).toBe(0);\n105\t    expect(result.weekStart).toBeDefined();\n106\t    expect(result.weekEnd).toBeDefined();\n107\t  });\n108\t\n109\t  it(\"rejects legacy leaderboard game aliases at validation time\", async () => {\n110\t    const res = await app.request(\"/leaderboard/weekly?game=flipyou\");\n111\t\n112\t    expect(res.status).toBe(400);\n113\t    const body = (await res.json()) as { error: string };\n114\t    expect(body.error).toBe(\"Invalid request\");\n115\t  });\n116\t\n117\t  it(\"ranks players by total wagered volume\", async () => {\n118\t    // Wallet A: 5 SOL wagered (2 games)\n119\t    await db.insertGameEntries([\n120\t      {\n121\t        userId: USER_A,\n122\t        wallet: WALLET_A,\n123\t        game: \"flipyou\",\n124\t       