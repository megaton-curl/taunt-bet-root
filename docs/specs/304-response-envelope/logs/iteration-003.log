{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019WoXx18vn4zNrysx5Tom2j","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/src/__tests__/auth-routes.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"d672558b-a9e4-40c4-9f27-80a74607ea06","uuid":"eb021859-defe-40a8-8c79-d6469fea4c86","timestamp":"2026-04-22T09:24:27.099Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/auth-routes.test.ts","oldString":"  it(\"rejects challenge with missing wallet\", async () => {\n    const res = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({}),\n    });\n    expect(res.status).toBe(400);\n  });\n\n  it(\"rejects challenge with missing body\", async () => {\n    const res = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n    });\n\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as { error: string };\n    expect(body.error).toBe(\"Invalid request\");\n  });","newString":"  it(\"rejects challenge with missing wallet\", async () => {\n    const res = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({}),\n    });\n    expect(res.status).toBe(422);\n  });\n\n  it(\"rejects challenge with missing body\", async () => {\n    const res = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n    });\n\n    expect(res.status).toBe(422);\n    const body = (await res.json()) as {\n      ok: false;\n      error: { code: string; message: string };\n    };\n    expect(body.ok).toBe(false);\n    expect(body.error.code).toBe(\"VALIDATION_FAILED\");\n    expect(body.error.message).toBe(\"Invalid request\");\n  });","originalFile":"/**\n * Auth routes tests: challenge → verify → refresh → logout flows.\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport nacl from \"tweetnacl\";\nimport bs58 from \"bs58\";\nimport { jwtVerify } from \"jose\";\nimport postgres from \"postgres\";\nimport { createAuthDb, type AuthDb } from \"../auth-db.js\";\nimport { createAuthRoutes } from \"../routes/auth.js\";\nimport type { Db } from \"../db.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"taunt_bet_dev\",\n  });\n}\n\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-auth-route-tests\");\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"Auth routes: challenge → verify → refresh → logout\", () => {\n  let rawSql: ReturnType<typeof postgres>;\n  let authDb: AuthDb;\n  let app: Hono;\n  const profiles = new Map<string, { user_id: string; wallet: string }>();\n  const stubDb = {\n    getProfileByWallet: async (wallet: string) => {\n      const existing = profiles.get(wallet);\n      return existing\n        ? { ...existing, username: \"test-user\", username_updated_at: null, avatar_url: null, heat_multiplier: 1, points_balance: 0, created_at: new Date(), id: 1 }\n        : null;\n    },\n    createPlayerProfile: async (wallet: string) => {\n      const created = { user_id: \"usr_test1234\", wallet };\n      profiles.set(wallet, created);\n      return {\n        ...created,\n        username: \"test-user\",\n        username_updated_at: null,\n        avatar_url: null,\n        heat_multiplier: 1,\n        points_balance: 0,\n        created_at: new Date(),\n        id: 1,\n      };\n    },\n  } as unknown as Db;\n\n  const creatorKeypair = Keypair.generate();\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n    // Ensure auth tables exist\n    await rawSql`DROP TABLE IF EXISTS auth_challenges, refresh_tokens`;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS auth_challenges (\n        nonce TEXT PRIMARY KEY,\n        wallet TEXT NOT NULL,\n        cluster TEXT NOT NULL DEFAULT 'devnet',\n        message TEXT NOT NULL,\n        expires_at TIMESTAMPTZ NOT NULL,\n        used BOOLEAN DEFAULT FALSE,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS refresh_tokens (\n        id BIGSERIAL PRIMARY KEY,\n        user_id TEXT NOT NULL,\n        wallet TEXT NOT NULL,\n        token_hash BYTEA NOT NULL UNIQUE,\n        family_id TEXT NOT NULL,\n        expires_at TIMESTAMPTZ NOT NULL,\n        revoked BOOLEAN DEFAULT FALSE,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n  });\n\n  afterAll(async () => {\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE auth_challenges, refresh_tokens RESTART IDENTITY`;\n    profiles.clear();\n    authDb = createAuthDb(rawSql);\n    app = new Hono();\n    app.route(\n      \"/auth\",\n      createAuthRoutes({\n        authDb,\n        db: stubDb,\n        jwtSecret: JWT_SECRET,\n        cluster: \"devnet\",\n        challengeTtlSeconds: 300,\n        accessTokenTtlSeconds: 3600,\n        refreshTokenTtlDays: 14,\n      }),\n    );\n  });\n\n  // -----------------------------------------------------------------------\n  // POST /auth/challenge\n  // -----------------------------------------------------------------------\n\n  it(\"returns a challenge with nonce and message\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const res = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n\n    expect(res.status).toBe(200);\n    const json = (await res.json()) as { nonce: string; message: string; expiresAt: string };\n    expect(json.nonce).toBeDefined();\n    expect(json.nonce.length).toBe(64); // 32 bytes hex\n    expect(json.message).toContain(\"Sign this message to create your Taunt BET account.\");\n    expect(json.message).toContain(wallet);\n    expect(json.message).toContain(\"Solana Devnet\");\n    expect(json.expiresAt).toBeDefined();\n  });\n\n  it(\"rejects challenge with missing wallet\", async () => {\n    const res = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({}),\n    });\n    expect(res.status).toBe(400);\n  });\n\n  it(\"rejects challenge with missing body\", async () => {\n    const res = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n    });\n\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as { error: string };\n    expect(body.error).toBe(\"Invalid request\");\n  });\n\n  // -----------------------------------------------------------------------\n  // Full flow: challenge → verify → refresh → logout\n  // -----------------------------------------------------------------------\n\n  it(\"full auth flow: challenge → verify → refresh → logout\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n\n    // 1. Request challenge\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    expect(challengeRes.status).toBe(200);\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n\n    // 2. Sign the message\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    // 3. Verify\n    const verifyRes = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(verifyRes.status).toBe(200);\n    const tokens = (await verifyRes.json()) as {\n      accessToken: string;\n      accessExpiresAt: string;\n      refreshToken: string;\n      refreshExpiresAt: string;\n    };\n    expect(tokens.accessToken).toBeDefined();\n    expect(tokens.refreshToken).toBeDefined();\n    expect(tokens.accessExpiresAt).toBeDefined();\n    expect(tokens.refreshExpiresAt).toBeDefined();\n\n    // Verify JWT is valid and contains the correct user identity\n    const { payload } = await jwtVerify(tokens.accessToken, JWT_SECRET, {\n      algorithms: [\"HS256\"],\n    });\n    expect(payload.sub).toBe(\"usr_test1234\");\n\n    // 4. Refresh\n    const refreshRes = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n    });\n    expect(refreshRes.status).toBe(200);\n    const newTokens = (await refreshRes.json()) as {\n      accessToken: string;\n      refreshToken: string;\n    };\n    expect(newTokens.accessToken).toBeDefined();\n    expect(newTokens.refreshToken).toBeDefined();\n    // New refresh token should be different from the old one\n    expect(newTokens.refreshToken).not.toBe(tokens.refreshToken);\n\n    // 5. Old refresh token should no longer work (it was rotated)\n    const replayRes = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n    });\n    expect(replayRes.status).toBe(401);\n    const replayJson = (await replayRes.json()) as { error: string };\n    expect(replayJson.error).toContain(\"reuse\");\n\n    // 6. Logout with new token\n    const logoutRes = await app.request(\"/auth/logout\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n    });\n    expect(logoutRes.status).toBe(204);\n\n    // 7. Refresh after logout should fail\n    const postLogoutRefresh = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n    });\n    expect(postLogoutRefresh.status).toBe(401);\n  });\n\n  // -----------------------------------------------------------------------\n  // Edge cases\n  // -----------------------------------------------------------------------\n\n  it(\"rejects verify with wrong wallet\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const otherKeypair = Keypair.generate();\n\n    // Get challenge for the correct wallet\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n\n    // Sign with the correct keypair\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    // But claim to be a different wallet\n    const verifyRes = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({\n        nonce: challenge.nonce,\n        wallet: otherKeypair.publicKey.toBase58(),\n        signature,\n      }),\n    });\n    expect(verifyRes.status).toBe(401);\n  });\n\n  it(\"rejects verify with wrong signature\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const otherKeypair = Keypair.generate();\n\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n\n    // Sign with wrong keypair\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, otherKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    const verifyRes = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(verifyRes.status).toBe(401);\n  });\n\n  it(\"rejects verify with already-used nonce\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n\n    // Get and consume a challenge\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    // First verify — should succeed\n    const res1 = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(res1.status).toBe(200);\n\n    // Second verify with same nonce — should fail\n    const res2 = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(res2.status).toBe(401);\n  });\n\n  it(\"rejects refresh with invalid token\", async () => {\n    const res = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: \"not-a-real-token\" }),\n    });\n    expect(res.status).toBe(401);\n  });\n});\n","structuredPatch":[{"oldStart":143,"oldLines":7,"newStart":143,"newLines":7,"lines":["       headers: { \"Content-Type\": \"application/json\" },","       body: JSON.stringify({}),","     });","-    expect(res.status).toBe(400);","+    expect(res.status).toBe(422);","   });"," ","   it(\"rejects challenge with missing body\", async () => {"]},{"oldStart":151,"oldLines":9,"newStart":151,"newLines":14,"lines":["       method: \"POST\",","     });"," ","-    expect(res.status).toBe(400);","-    const body = (await res.json()) as { error: string };","-    expect(body.error).toBe(\"Invalid request\");","+    expect(res.status).toBe(422);","+    const body = (await res.json()) as {","+      ok: false;","+      error: { code: string; message: string };","+    };","+    expect(body.ok).toBe(false);","+    expect(body.error.code).toBe(\"VALIDATION_FAILED\");","+    expect(body.error.message).toBe(\"Invalid request\");","   });"," ","   // -----------------------------------------------------------------------"]}],"userModified":false,"replaceAll":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01A2Jsp7RMXB1EsT5HmqfCjH","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01AqqHFV3VLsUJjqziZkdv33","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/backend/src/__tests__/leaderboard.test.ts","old_string":"  it(\"rejects legacy leaderboard game aliases at validation time\", async () => {\n    const res = await app.request(\"/leaderboard/weekly?game=flipyou\");\n\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as { error: string };\n    expect(body.error).toBe(\"Invalid request\");\n  });","new_string":"  it(\"rejects legacy leaderboard game aliases at validation time\", async () => {\n    const res = await app.request(\"/leaderboard/weekly?game=flipyou\");\n\n    expect(res.status).toBe(422);\n    const body = (await res.json()) as {\n      ok: false;\n      error: { code: string; message: string };\n    };\n    expect(body.ok).toBe(false);\n    expect(body.error.code).toBe(\"VALIDATION_FAILED\");\n    expect(body.error.message).toBe(\"Invalid request\");\n  });"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":694,"cache_read_input_tokens":83399,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":694},"output_tokens":69,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d672558b-a9e4-40c4-9f27-80a74607ea06","uuid":"83851cba-8704-4ae9-ac7e-3ba52a477548"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AqqHFV3VLsUJjqziZkdv33","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/src/__tests__/leaderboard.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"d672558b-a9e4-40c4-9f27-80a74607ea06","uuid":"1270cd88-080e-44fc-bb17-cb122e35c529","timestamp":"2026-04-22T09:24:33.744Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/leaderboard.test.ts","oldString":"  it(\"rejects legacy leaderboard game aliases at validation time\", async () => {\n    const res = await app.request(\"/leaderboard/weekly?game=flipyou\");\n\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as { error: string };\n    expect(body.error).toBe(\"Invalid request\");\n  });","newString":"  it(\"rejects legacy leaderboard game aliases at validation time\", async () => {\n    const res = await app.request(\"/leaderboard/weekly?game=flipyou\");\n\n    expect(res.status).toBe(422);\n    const body = (await res.json()) as {\n      ok: false;\n      error: { code: string; message: string };\n    };\n    expect(body.ok).toBe(false);\n    expect(body.error.code).toBe(\"VALIDATION_FAILED\");\n    expect(body.error.message).toBe(\"Invalid request\");\n  });","originalFile":"/**\n * Tests for weekly leaderboard + game_entries table.\n *\n * Requires a running PostgreSQL instance. Seeds game_entries directly\n * and verifies getWeeklyLeaderboard returns correct rankings.\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createLeaderboardRoutes } from \"../routes/leaderboard.js\";\n\nconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"taunt_bet_dev\",\n  });\n}\n\nconst TS = Date.now();\nconst WALLET_A = \"LeaderboardTestA_\" + TS;\nconst WALLET_B = \"LeaderboardTestB_\" + TS;\nconst WALLET_C = \"LeaderboardTestC_\" + TS;\nconst USER_A = \"usr_leada\" + TS;\nconst USER_B = \"usr_leadb\" + TS;\nconst USER_C = \"usr_leadc\" + TS;\n\ndescribe(\"Weekly leaderboard\", () => {\n  let rawSql: ReturnType<typeof postgres>;\n  let db: Db;\n  let app: Hono;\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n\n    // Ensure game_entries table exists (matches consolidated migration schema)\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS game_entries (\n        id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n        user_id         TEXT         NOT NULL,\n        wallet          TEXT         NOT NULL,\n        game            TEXT         NOT NULL,\n        round_pda       TEXT         NOT NULL,\n        match_id        TEXT         NOT NULL,\n        amount_lamports BIGINT       NOT NULL,\n        side            TEXT,\n        is_winner       BOOLEAN,\n        payout_lamports BIGINT       NOT NULL DEFAULT 0,\n        created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n        settled_at      TIMESTAMPTZ,\n        UNIQUE (wallet, round_pda)\n      )\n    `;\n    // Ensure player_profiles exists (for JOIN)\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS player_profiles (\n        id                   BIGSERIAL    PRIMARY KEY,\n        user_id              TEXT         UNIQUE NOT NULL,\n        wallet               TEXT         UNIQUE NOT NULL,\n        username             TEXT         UNIQUE NOT NULL,\n        username_updated_at  TIMESTAMPTZ,\n        avatar_url           TEXT,\n        heat_multiplier      NUMERIC      NOT NULL DEFAULT 1.0,\n        points_balance       BIGINT       NOT NULL DEFAULT 0,\n        created_at           TIMESTAMPTZ  NOT NULL DEFAULT now()\n      )\n    `;\n    db = createDb(DATABASE_URL, rawSql);\n  });\n\n  afterAll(async () => {\n    await rawSql`DELETE FROM game_entries WHERE wallet LIKE 'LeaderboardTest%'`;\n    await rawSql`DELETE FROM player_profiles WHERE wallet LIKE 'LeaderboardTest%'`;\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`DELETE FROM game_entries WHERE wallet LIKE 'LeaderboardTest%'`;\n    await rawSql`DELETE FROM player_profiles WHERE wallet LIKE 'LeaderboardTest%'`;\n    app = new Hono();\n    app.route(\"/leaderboard\", createLeaderboardRoutes({ db }));\n    // Seed profiles for test wallets (leaderboard JOINs on user_id)\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username) VALUES\n        (${USER_A}, ${WALLET_A}, ${\"user_a_\" + TS}),\n        (${USER_B}, ${WALLET_B}, ${\"user_b_\" + TS}),\n        (${USER_C}, ${WALLET_C}, ${\"user_c_\" + TS})\n      ON CONFLICT DO NOTHING\n    `;\n  });\n\n  it(\"returns empty leaderboard when no entries\", async () => {\n    const result = await db.getWeeklyLeaderboard();\n    // May have entries from other tests but our users shouldn't be there\n    const ours = result.entries.filter((e) =>\n      e.userId.startsWith(\"usr_lead\"),\n    );\n    expect(ours.length).toBe(0);\n    expect(result.weekStart).toBeDefined();\n    expect(result.weekEnd).toBeDefined();\n  });\n\n  it(\"rejects legacy leaderboard game aliases at validation time\", async () => {\n    const res = await app.request(\"/leaderboard/weekly?game=flipyou\");\n\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as { error: string };\n    expect(body.error).toBe(\"Invalid request\");\n  });\n\n  it(\"ranks players by total wagered volume\", async () => {\n    // Wallet A: 5 SOL wagered (2 games)\n    await db.insertGameEntries([\n      {\n        userId: USER_A,\n        wallet: WALLET_A,\n        game: \"flipyou\",\n        roundPda: \"pda_lb1\",\n        matchId: \"lb_m1\",\n        amountLamports: 3_000_000_000,\n        isWinner: true,\n        payoutLamports: 5_700_000_000,\n        settledAt: new Date(),\n      },\n      {\n        userId: USER_A,\n        wallet: WALLET_A,\n        game: \"flipyou\",\n        roundPda: \"pda_lb2\",\n        matchId: \"lb_m2\",\n        amountLamports: 2_000_000_000,\n        isWinner: false,\n        payoutLamports: 0,\n        settledAt: new Date(),\n      },\n    ]);\n\n    // Wallet B: 10 SOL wagered (1 game)\n    await db.insertGameEntries([\n      {\n        userId: USER_B,\n        wallet: WALLET_B,\n        game: \"potshot\",\n        roundPda: \"pda_lb3\",\n        matchId: \"lb_m3\",\n        amountLamports: 10_000_000_000,\n        isWinner: true,\n        payoutLamports: 18_000_000_000,\n        settledAt: new Date(),\n      },\n    ]);\n\n    // Wallet C: 1 SOL wagered (1 game)\n    await db.insertGameEntries([\n      {\n        userId: USER_C,\n        wallet: WALLET_C,\n        game: \"closecall\",\n        roundPda: \"pda_lb4\",\n        matchId: \"lb_m4\",\n        amountLamports: 1_000_000_000,\n        isWinner: false,\n        payoutLamports: 0,\n        settledAt: new Date(),\n      },\n    ]);\n\n    const result = await db.getWeeklyLeaderboard();\n    const ours = result.entries.filter((e) =>\n      e.userId.startsWith(\"usr_lead\"),\n    );\n\n    // B (10 SOL) > A (5 SOL) > C (1 SOL)\n    expect(ours.length).toBe(3);\n    expect(ours[0]!.userId).toBe(USER_B);\n    expect(ours[0]!.totalWagered).toBe(10_000_000_000n);\n    expect(ours[0]!.gamesPlayed).toBe(1);\n    expect(ours[0]!.totalWins).toBe(1);\n\n    expect(ours[1]!.userId).toBe(USER_A);\n    expect(ours[1]!.totalWagered).toBe(5_000_000_000n);\n    expect(ours[1]!.gamesPlayed).toBe(2);\n    expect(ours[1]!.totalWins).toBe(1);\n    expect(ours[1]!.winRate).toBeCloseTo(0.5);\n\n    expect(ours[2]!.userId).toBe(USER_C);\n    expect(ours[2]!.totalWagered).toBe(1_000_000_000n);\n    expect(ours[2]!.totalWins).toBe(0);\n  });\n\n  it(\"filters by game type\", async () => {\n    await db.insertGameEntries([\n      {\n        userId: USER_A,\n        wallet: WALLET_A,\n        game: \"flipyou\",\n        roundPda: \"pda_gf1\",\n        matchId: \"gf_m1\",\n        amountLamports: 5_000_000_000,\n        isWinner: true,\n        payoutLamports: 9_500_000_000,\n        settledAt: new Date(),\n      },\n      {\n        userId: USER_A,\n        wallet: WALLET_A,\n        game: \"potshot\",\n        roundPda: \"pda_gf2\",\n        matchId: \"gf_m2\",\n        amountLamports: 2_000_000_000,\n        isWinner: false,\n        payoutLamports: 0,\n        settledAt: new Date(),\n      },\n    ]);\n\n    // FlipYou only\n    const cfResult = await db.getWeeklyLeaderboard(\"flipyou\");\n    const cfOurs = cfResult.entries.filter((e) =>\n      e.userId.startsWith(\"usr_lead\"),\n    );\n    expect(cfOurs.length).toBe(1);\n    expect(cfOurs[0]!.totalWagered).toBe(5_000_000_000n);\n\n    // Lord only\n    const lordResult = await db.getWeeklyLeaderboard(\"potshot\");\n    const lordOurs = lordResult.entries.filter((e) =>\n      e.userId.startsWith(\"usr_lead\"),\n    );\n    expect(lordOurs.length).toBe(1);\n    expect(lordOurs[0]!.totalWagered).toBe(2_000_000_000n);\n\n    // Global (both games)\n    const allResult = await db.getWeeklyLeaderboard();\n    const allOurs = allResult.entries.filter((e) =>\n      e.userId.startsWith(\"usr_lead\"),\n    );\n    expect(allOurs.length).toBe(1);\n    expect(allOurs[0]!.totalWagered).toBe(7_000_000_000n);\n    expect(allOurs[0]!.gamesPlayed).toBe(2);\n  });\n\n  it(\"computes net PnL correctly\", async () => {\n    // Win 9.5 SOL on 5 SOL wager, lose 3 SOL → net = +1.5 SOL\n    await db.insertGameEntries([\n      {\n        userId: USER_A,\n        wallet: WALLET_A,\n        game: \"flipyou\",\n        roundPda: \"pda_pnl1\",\n        matchId: \"pnl_m1\",\n        amountLamports: 5_000_000_000,\n        isWinner: true,\n        payoutLamports: 9_500_000_000,\n        settledAt: new Date(),\n      },\n      {\n        userId: USER_A,\n        wallet: WALLET_A,\n        game: \"flipyou\",\n        roundPda: \"pda_pnl2\",\n        matchId: \"pnl_m2\",\n        amountLamports: 3_000_000_000,\n        isWinner: false,\n        payoutLamports: 0,\n        settledAt: new Date(),\n      },\n    ]);\n\n    const result = await db.getWeeklyLeaderboard();\n    const entry = result.entries.find((e) => e.userId === USER_A);\n    expect(entry).toBeDefined();\n    // netPnl = (9.5 + 0) - (5 + 3) = 1.5 SOL = 1_500_000_000 lamports\n    expect(entry!.netPnl).toBe(1_500_000_000n);\n  });\n\n  it(\"respects limit and offset\", async () => {\n    await db.insertGameEntries([\n      {\n        userId: USER_A,\n        wallet: WALLET_A,\n        game: \"flipyou\",\n        roundPda: \"pda_pg1\",\n        matchId: \"pg_m1\",\n        amountLamports: 3_000_000_000,\n        isWinner: false,\n        payoutLamports: 0,\n        settledAt: new Date(),\n      },\n      {\n        userId: USER_B,\n        wallet: WALLET_B,\n        game: \"flipyou\",\n        roundPda: \"pda_pg2\",\n        matchId: \"pg_m2\",\n        amountLamports: 5_000_000_000,\n        isWinner: true,\n        payoutLamports: 9_000_000_000,\n        settledAt: new Date(),\n      },\n      {\n        userId: USER_C,\n        wallet: WALLET_C,\n        game: \"flipyou\",\n        roundPda: \"pda_pg3\",\n        matchId: \"pg_m3\",\n        amountLamports: 1_000_000_000,\n        isWinner: false,\n        payoutLamports: 0,\n        settledAt: new Date(),\n      },\n    ]);\n\n    // Limit 2: should get B and A (top 2 by volume)\n    const page1 = await db.getWeeklyLeaderboard(undefined, 2);\n    const p1Ours = page1.entries.filter((e) =>\n      e.userId.startsWith(\"usr_lead\"),\n    );\n    expect(p1Ours.length).toBeLessThanOrEqual(2);\n  });\n\n  it(\"idempotent — duplicate insertGameEntries do not error\", async () => {\n    const entry = {\n      userId: USER_A,\n      wallet: WALLET_A,\n      game: \"flipyou\",\n      roundPda: \"pda_idem1\",\n      matchId: \"idem_m1\",\n      amountLamports: 1_000_000_000,\n      isWinner: true,\n      payoutLamports: 1_900_000_000,\n      settledAt: new Date(),\n    };\n\n    await db.insertGameEntries([entry]);\n    // Second insert should be silently ignored\n    await db.insertGameEntries([entry]);\n\n    const result = await db.getWeeklyLeaderboard();\n    const ours = result.entries.filter((e) => e.userId === USER_A);\n    expect(ours.length).toBe(1);\n    expect(ours[0]!.totalWagered).toBe(1_000_000_000n);\n  });\n\n  it(\"uses profile username when available\", async () => {\n    await rawSql`\n      UPDATE player_profiles SET username = ${\"CoolDegen42\"}\n      WHERE user_id = ${USER_A}\n    `;\n\n    await db.insertGameEntries([\n      {\n        userId: USER_A,\n        wallet: WALLET_A,\n        game: \"flipyou\",\n        roundPda: \"pda_usr1\",\n        matchId: \"usr_m1\",\n        amountLamports: 1_000_000_000,\n        isWinner: true,\n        payoutLamports: 1_900_000_000,\n        settledAt: new Date(),\n      },\n    ]);\n\n    const result = await db.getWeeklyLeaderboard();\n    const entry = result.entries.find((e) => e.userId === USER_A);\n    expect(entry).toBeDefined();\n    expect(entry!.username).toBe(\"CoolDegen42\");\n  });\n});\n","structuredPatch":[{"oldStart":109,"oldLines":9,"newStart":109,"newLines":14,"lines":["   it(\"rejects legacy leaderboard game aliases at validation time\", async () => {","     const res = await app.request(\"/leaderboard/weekly?game=flipyou\");"," ","-    expect(res.status).toBe(400);","-    const body = (await res.json()) as { error: string };","-    expect(body.error).toBe(\"Invalid request\");","+    expect(res.status).toBe(422);","+    const body = (await res.json()) as {","+      ok: false;","+      error: { code: string; message: string };","+    };","+    expect(body.ok).toBe(false);","+    expect(body.error.code).toBe(\"VALIDATION_FAILED\");","+    expect(body.error.message).toBe(\"Invalid request\");","   });"," ","   it(\"ranks players by total wagered volume\", async () => {"]}],"userModified":false,"replaceAll":false}}
