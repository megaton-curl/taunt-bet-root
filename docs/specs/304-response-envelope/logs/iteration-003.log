{ code: null as string | null }));\n52\t\n53\t    const res = await app.request(\"/\");\n54\t    expect(res.status).toBe(200);\n55\t    const body = (await res.json()) as ApiEnvelopeSuccess<{ code: string | null }>;\n56\t    expect(body).toEqual({ ok: true, data: { code: null } });\n57\t  });\n58\t});\n59\t\n60\tdescribe(\"err()\", () => {\n61\t  const errorStatuses = [400, 401, 403, 404, 409, 422, 429, 500, 503] as const;\n62\t\n63\t  for (const status of errorStatuses) {\n64\t    it(`returns ${status} { ok: false, error } with code + message`, async () => {\n65\t      const app = makeApp();\n66\t      app.get(\"/\", (c) => err(c, status, \"NOT_FOUND\", \"something went wrong\"));\n67\t\n68\t      const res = await app.request(\"/\");\n69\t      expect(res.status).toBe(status);\n70\t      const body = (await res.json()) as ApiEnvelopeError;\n71\t      expect(body).toEqual({\n72\t        ok: false,\n73\t        error: { code: \"NOT_FOUND\", message: \"something went wrong\" },\n74\t      });\n75\t    });\n76\t  }\n77\t\n78\t  it(\"includes retryable when provided\", async () => {\n79\t    const app = makeApp();\n80\t    app.get(\"/\", (c) =>\n81\t      err(c, 429, \"RATE_LIMITED\", \"slow down\", { retryable: true }),\n82\t    );\n83\t\n84\t    const res = await app.request(\"/\");\n85\t    expect(res.status).toBe(429);\n86\t    const body = (await res.json()) as ApiEnvelopeError;\n87\t    expect(body.error.retryable).toBe(true);\n88\t    expect(body.error.code).toBe(\"RATE_LIMITED\");\n89\t  });\n90\t\n91\t  it(\"includes details when provided\", async () => {\n92\t    const app = makeApp();\n93\t    const issues = [{ path: [\"code\"], message: \"required\" }];\n94\t    app.get(\"/\", (c) =>\n95\t      err(c, 422, \"VALIDATION_FAILED\", \"Invalid request\", {\n96\t        retryable: false,\n97\t        details: issues,\n98\t      }),\n99\t    );\n100\t\n101\t    const res = await app.request(\"/\");\n102\t    expect(res.status).toBe(422);\n103\t    const body = (await res.json()) as ApiEnvelopeError;\n104\t    expect(body.error.retryable).toBe(false);\n105\t    expect(body.error.details).toEqual(issues);\n106\t  });\n107\t\n108\t  it(\"omits retryable/details when not provided\", async () => {\n109\t    const app = makeApp();\n110\t    app.get(\"/\", (c) => err(c, 404, \"NOT_FOUND\", \"missing\"));\n111\t\n112\t    const res = await app.request(\"/\");\n113\t    const body = (await res.json()) as ApiEnvelopeError;\n114\t    expect(body).toEqual({\n115\t      ok: false,\n116\t      error: { code: \"NOT_FOUND\", message: \"missing\" },\n117\t    });\n118\t    expect(body.error).not.toHaveProperty(\"retryable\");\n119\t    expect(body.error).not.toHaveProperty(\"details\");\n120\t  });\n121\t});\n122\t\n123\tdescribe(\"envelope()\", () => {\n124\t  const DataSchema = z.object({ id: z.number() });\n125\t  const schema = envelope(DataSchema);\n126\t\n127\t  it(\"parses a success envelope\", () => {\n128\t    const parsed = schema.parse({ ok: true, data: { id: 42 } });\n129\t    expect(parsed).toEqual({ ok: true, data: { id: 42 } });\n130\t  });\n131\t\n132\t  it(\"parses an error envelope\", () => {\n133\t    const parsed = schema.parse({\n134\t      ok: false,\n135\t      error: { code: \"BAD\", message: \"nope\" },\n136\t    });\n137\t    expect(parsed).toEqual({\n138\t      ok: false,\n139\t      error: { code: \"BAD\", message: \"nope\" },\n140\t    });\n141\t  });\n142\t\n143\t  it(\"parses an error envelope with retryable + details\", () => {\n144\t    const parsed = schema.parse({\n145\t      ok: false,\n146\t      error: {\n147\t        code: \"RATE_LIMITED\",\n148\t        message: \"slow down\",\n149\t        retryable: true,\n150\t        details: { retryAfterMs: 1000 },\n151\t      },\n152\t    });\n153\t    if (parsed.ok) throw new Error(\"expected error envelope\");\n154\t    expect(parsed.error.retryable).toBe(true);\n155\t    expect(parsed.error.details).toEqual({ retryAfterMs: 1000 });\n156\t  });\n157\t\n158\t  it(\"rejects a success envelope when data is wrong shape\", () => {\n159\t    expect(() => schema.parse({ ok: true, data: { id: \"not-a-number\" } })).toThrow();\n160\t  });\n161\t\n162\t  it(\"rejects an envelope with no ok discriminator\", () => {\n163\t    expect(() => schema.parse({ data: { id: 1 } })).toThrow();\n164\t  });\n165\t\n166\t  it(\"narrows via the `ok` discriminator\", () => {\n167\t    const parsed = schema.parse({ ok: true, data: { id: 7 } });\n168\t    if (parsed.ok) {\n169\t      expect(parsed.data.id).toBe(7);\n170\t    } else {\n171\t      throw new Error(\"expected success envelope\");\n172\t    }\n173\t  });\n174\t});\n175\t\n176\tdescribe(\"ApiErrorSchema + ErrorEnvelopeSchema\", () => {\n177\t  it(\"round-trips the minimal error shape\", () => {\n178\t    const input = { code: \"AUTH_REQUIRED\", message: \"sign in\" };\n179\t    expect(ApiErrorSchema.parse(input)).toEqual(input);\n180\t  });\n181\t\n182\t  it(\"round-trips an error with retryable + details\", () => {\n183\t    const input = {\n184\t      code: \"VALIDATION_FAILED\",\n185\t      message: \"Invalid request\",\n186\t      retryable: false,\n187\t      details: [{ path: [\"code\"], message: \"required\" }],\n188\t    };\n189\t    expect(ApiErrorSchema.parse(input)).toEqual(input);\n190\t  });\n191\t\n192\t  it(\"round-trips the envelope at the schema level\", () => {\n193\t    const input: ApiEnvelopeError = {\n194\t      ok: false,\n195\t      error: { code: \"NOT_FOUND\", message: \"missing\" },\n196\t    };\n197\t    expect(ErrorEnvelopeSchema.parse(input)).toEqual(input);\n198\t  });\n199\t\n200\t  it(\"rejects an error envelope with ok: true\", () => {\n201\t    expect(() =>\n202\t      ErrorEnvelopeSchema.parse({ ok: true, error: { code: \"X\", message: \"y\" } }),\n203\t    ).toThrow();\n204\t  });\n205\t});\n206\t"}]},"parent_tool_use_id":null,"session_id":"d672558b-a9e4-40c4-9f27-80a74607ea06","uuid":"4ae15878-c24f-4b80-9b5e-df5cafe45d53","timestamp":"2026-04-22T09:21: