{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01Bv44imaVobre51o55QhNeX","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015R6N2wvpPapRrKx33rpG2i","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/src/__tests__/openapi-invalid-request-hook.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport { createRoute, z } from \"@hono/zod-openapi\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\nimport {\n  ErrorEnvelopeSchema,\n  envelope,\n  type ApiEnvelopeError,\n} from \"../contracts/api-envelope.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n\nfunction makeApp() {\n  const app = createOpenApiApp();\n  const BodySchema = z.object({\n    name: z.string().min(1),\n    count: z.number().int().positive(),\n  });\n  const ResponseSchema = z.object({ echoed: z.string() });\n  const route = createRoute({\n    method: \"post\",\n    path: \"/echo\",\n    request: {\n      body: {\n        content: {\n          \"application/json\": { schema: BodySchema },\n        },\n      },\n    },\n    responses: {\n      200: {\n        description: \"ok\",\n        content: {\n          \"application/json\": { schema: envelope(ResponseSchema) },\n        },\n      },\n      422: {\n        description: \"invalid request\",\n        content: {\n          \"application/json\": { schema: ErrorEnvelopeSchema },\n        },\n      },\n    },\n  });\n\n  app.openapi(route, (c) => {\n    const body = c.req.valid(\"json\");\n    return c.json({ ok: true as const, data: { echoed: body.name } }, 200);\n  });\n\n  return app;\n}\n\ndescribe(\"invalidRequestHook\", () => {\n  it(\"returns 422 with a VALIDATION_FAILED error envelope when zod parse fails\", async () => {\n    const app = makeApp();\n    const res = await app.request(\"/echo\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ name: \"\", count: -1 }),\n    });\n\n    expect(res.status).toBe(422);\n    const body = (await res.json()) as ApiEnvelopeError;\n    expect(body.ok).toBe(false);\n    expect(body.error.code).toBe(API_ERROR_CODES.VALIDATION_FAILED);\n    expect(body.error.message).toBe(\"Invalid request\");\n    expect(body.error.retryable).toBe(false);\n    expect(Array.isArray(body.error.details)).toBe(true);\n  });\n\n  it(\"includes the Zod issue list in error.details\", async () => {\n    const app = makeApp();\n    const res = await app.request(\"/echo\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({}),\n    });\n\n    expect(res.status).toBe(422);\n    const body = (await res.json()) as ApiEnvelopeError;\n    const details = body.error.details as Array<{ path: (string | number)[]; message: string }>;\n    expect(details.length).toBeGreaterThan(0);\n    const paths = details.map((d) => d.path.join(\".\"));\n    expect(paths).toContain(\"name\");\n    expect(paths).toContain(\"count\");\n    for (const issue of details) {\n      expect(typeof issue.message).toBe(\"string\");\n    }\n  });\n\n  it(\"matches the shared ErrorEnvelopeSchema\", async () => {\n    const app = makeApp();\n    const res = await app.request(\"/echo\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ count: \"nope\" }),\n    });\n\n    expect(res.status).toBe(422);\n    const body = await res.json();\n    const parsed = ErrorEnvelopeSchema.parse(body);\n    expect(parsed.ok).toBe(false);\n    expect(parsed.error.code).toBe(API_ERROR_CODES.VALIDATION_FAILED);\n  });\n\n  it(\"passes through when the request is valid\", async () => {\n    const app = makeApp();\n    const res = await app.request(\"/echo\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ name: \"hi\", count: 2 }),\n    });\n\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as { ok: true; data: { echoed: string } };\n    expect(body).toEqual({ ok: true, data: { echoed: \"hi\" } });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":799,"cache_read_input_tokens":78658,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":799},"output_tokens":41,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d672558b-a9e4-40c4-9f27-80a74607ea06","uuid":"ff18781d-e19d-4494-808a-ee00d8c7d7e5"}
