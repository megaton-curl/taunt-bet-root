{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016mkr7T72KCRDnaAAzuM2HD","type":"tool_result","content":"1\timport { describe, it, expect } from \"vitest\";\n2\timport { createHash, randomBytes } from \"node:crypto\";\n3\timport { Keypair, PublicKey } from \"@solana/web3.js\";\n4\timport { generateSecret, computeCommitment, deriveMatchPda, generateMatchId } from \"../fairness.js\";\n5\t\n6\tdescribe(\"generateSecret\", () => {\n7\t  it(\"returns a 32-byte buffer\", () => {\n8\t    const secret = generateSecret();\n9\t    expect(Buffer.isBuffer(secret)).toBe(true);\n10\t    expect(secret.length).toBe(32);\n11\t  });\n12\t});\n13\t\n14\tdescribe(\"computeCommitment\", () => {\n15\t  it(\"returns sha256 of the secret bytes\", () => {\n16\t    // sha256 of the zero byte (0x00) — well-known constant\n17\t    const zeroByte = Buffer.from([0x00]);\n18\t    const expected =\n19\t      \"6e340b9cffb37a989ca544e6bb780a2c78901d3fb33738768511a30617afa01d\";\n20\t    expect(computeCommitment(zeroByte).toString(\"hex\")).toBe(expected);\n21\t  });\n22\t\n23\t  it(\"matches the packages/fairness commitment algorithm\", () => {\n24\t    // The fairness package computes sha256(hexToBytes(hexSeed)).\n25\t    // Our backend computes sha256(secretBuffer).\n26\t    // They must agree when given the same bytes.\n27\t    const seedHex =\n28\t      \"abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789\";\n29\t    const seedBytes = Buffer.from(seedHex, \"hex\");\n30\t\n31\t    const backendCommitment = computeCommitment(seedBytes).toString(\"hex\");\n32\t\n33\t    // Independently compute using Node crypto for cross-check\n34\t    const nodeCommitment = createHash(\"sha256\").update(seedBytes).digest(\"hex\");\n35\t\n36\t    expect(backendCommitment).toBe(nodeCommitment);\n37\t  });\n38\t\n39\t  it(\"is deterministic\", () => {\n40\t    const secret = Buffer.alloc(32, 0x42);"}]},"parent_tool_use_id":null,"session_id":"8cbb9ef5-acf2-4608-a258-6641cdf0da27","uuid":"ede9f22b-dd26-47ee-847c-ad616bcbe683","timestamp":"2026-04-22T09:10:59.031Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/fairness.test.ts","content":"import { describe, it, expect } from \"vitest\";\nimport { createHash, randomBytes } from \"node:crypto\";\nimport { Keypair, PublicKey } from \"@solana/web3.js\";\nimport { generateSecret, computeCommitment, deriveMatchPda, generateMatchId } from \"../fairness.js\";\n\ndescribe(\"generateSecret\", () => {\n  it(\"returns a 32-byte buffer\", () => {\n    const secret = generateSecret();\n    expect(Buffer.isBuffer(secret)).toBe(true);\n    expect(secret.length).toBe(32);\n  });\n});\n\ndescribe(\"computeCommitment\", () => {\n  it(\"returns sha256 of the secret bytes\", () => {\n    // sha256 of the zero byte (0x00) — well-known constant\n    const zeroByte = Buffer.from([0x00]);\n    const expected =\n      \"6e340b9cffb37a989ca544e6bb780a2c78901d3fb33738768511a30617afa01d\";\n    expect(computeCommitment(zeroByte).toString(\"hex\")).toBe(expected);\n  });\n\n  it(\"matches the packages/fairness commitment algorithm\", () => {\n    // The fairness package computes sha256(hexToBytes(hexSeed)).\n    // Our backend computes sha256(secretBuffer).\n    // They must agree when given the same bytes.\n    const seedHex =\n      \"abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789\";\n    const seedBytes = Buffer.from(seedHex, \"hex\");\n\n    const backendCommitment = computeCommitment(seedBytes).toString(\"hex\");\n\n    // Independently compute using Node crypto for cross-check\n    const nodeCommitment = createHash(\"sha256\").update(seedBytes).digest(\"hex\");\n\n    expect(backendCommitment).toBe(nodeCommitment);\n  });\n\n  it(\"is deterministic\", () => {\n    const secret = Buffer.alloc(32, 0x42);","numLines":40,"startLine":1,"totalLines":109}}}
