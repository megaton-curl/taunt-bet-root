{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KpVTzDLF2FtRgxYoPc2CE9","type":"tool_result","content":"1\t/**\n2\t * GET /health — cheap process-local liveness probe.\n3\t *\n4\t * No DB queries. No network calls. Must stay trivial so floods can't hurt.\n5\t */\n6\t\n7\timport { createRoute } from \"@hono/zod-openapi\";\n8\timport { HealthResponseSchema } from \"../contracts/validators.js\";\n9\timport { createOpenApiApp } from \"../openapi/hono.js\";\n10\t\n11\texport interface HealthDeps {\n12\t  isWorkerRunning: () => boolean;\n13\t}\n14\t\n15\tconst healthRoute = createRoute({\n16\t  method: \"get\",\n17\t  path: \"/\",\n18\t  tags: [\"Health\"],\n19\t  summary: \"Service health check\",\n20\t  responses: {\n21\t    200: {\n22\t      content: { \"application/json\": { schema: HealthResponseSchema } },\n23\t      description: \"Health status\",\n24\t    },\n25\t  },\n26\t});\n27\t\n28\texport function createHealthRoutes(deps: HealthDeps) {\n29\t  const { isWorkerRunning } = deps;\n30\t  const app = createOpenApiApp();\n31\t\n32\t  app.openapi(healthRoute, (c) =>\n33\t    c.json(\n34\t      {\n35\t        status: \"ok\",\n36\t        version: \"0.1.0\",\n37\t        workerRunning: isWorkerRunning(),\n38\t      },\n39\t      200,\n40\t    ),\n41\t  );\n42\t\n43\t  return app;\n44\t}\n45\t"}]},"parent_tool_use_id":null,"session_id":"8cbb9ef5-acf2-4608-a258-6641cdf0da27","uuid":"6e268280-989a-4f16-b0b6-609d586984ef","timestamp":"2026-04-22T09:11:18.311Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/health.ts","content":"/**\n * GET /health — cheap process-local liveness probe.\n *\n * No DB queries. No network calls. Must stay trivial so floods can't hurt.\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { HealthResponseSchema } from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface HealthDeps {\n  isWorkerRunning: () => boolean;\n}\n\nconst healthRoute = createRoute({\n  method: \"get\",\n  path: \"/\",\n  tags: [\"Health\"],\n  summary: \"Service health check\",\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: HealthResponseSchema } },\n      description: \"Health status\",\n    },\n  },\n});\n\nexport function createHealthRoutes(deps: HealthDeps) {\n  const { isWorkerRunning } = deps;\n  const app = createOpenApiApp();\n\n  app.openapi(healthRoute, (c) =>\n    c.json(\n      {\n        status: \"ok\",\n        version: \"0.1.0\",\n        workerRunning: isWorkerRunning(),\n      },\n      200,\n    ),\n  );\n\n  return app;\n}\n","numLines":45,"startLine":1,"totalLines":45}}}
