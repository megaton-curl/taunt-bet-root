{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01A7bvJ6zBQu8YHVHzmQyePm","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_017JusQPQisuUVzYifca75Bs","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/src/contracts/api-envelope.ts","content":"/**\n * Shared response envelope for public JSON routes.\n *\n * Every public JSON response body is either:\n *   { ok: true,  data: <payload> }   — success (200/201/202)\n *   { ok: false, error: ApiError }   — failure (4xx/5xx)\n *\n * Semantic HTTP status is preserved — handled domain failures MUST NOT be\n * flattened into `200`. See `docs/specs/304-response-envelope/spec.md`.\n */\n\nimport { z } from \"zod\";\nimport type { Context } from \"hono\";\n\n// TEMPORARY: `ApiErrorCode` will be redefined as the union of\n// `API_ERROR_CODES` values once `api-errors.ts` is rewritten in the next\n// iteration. Keeping it as `string` here lets this file ship standalone.\nexport type ApiErrorCode = string;\n\nexport interface ApiError {\n  code: ApiErrorCode;\n  message: string;\n  retryable?: boolean;\n  details?: unknown;\n}\n\nexport interface ApiEnvelopeSuccess<T> {\n  ok: true;\n  data: T;\n}\n\nexport interface ApiEnvelopeError {\n  ok: false;\n  error: ApiError;\n}\n\nexport type ApiEnvelope<T> = ApiEnvelopeSuccess<T> | ApiEnvelopeError;\n\nexport const ApiErrorSchema = z.object({\n  code: z.string(),\n  message: z.string(),\n  retryable: z.boolean().optional(),\n  details: z.unknown().optional(),\n});\n\nexport const ErrorEnvelopeSchema = z.object({\n  ok: z.literal(false),\n  error: ApiErrorSchema,\n});\n\nexport function envelope<T extends z.ZodTypeAny>(dataSchema: T) {\n  return z.discriminatedUnion(\"ok\", [\n    z.object({\n      ok: z.literal(true),\n      data: dataSchema,\n    }),\n    ErrorEnvelopeSchema,\n  ]);\n}\n\nexport type SuccessStatus = 200 | 201 | 202;\nexport type ErrorStatus = 400 | 401 | 403 | 404 | 409 | 422 | 429 | 500 | 503;\n\nexport function ok<T>(c: Context, data: T, status: SuccessStatus = 200) {\n  const body: ApiEnvelopeSuccess<T> = { ok: true, data };\n  return c.json(body, status);\n}\n\nexport function err(\n  c: Context,\n  status: ErrorStatus,\n  code: ApiErrorCode,\n  message: string,\n  opts?: { retryable?: boolean; details?: unknown },\n) {\n  const error: ApiError = { code, message };\n  if (opts?.retryable !== undefined) error.retryable = opts.retryable;\n  if (opts?.details !== undefined) error.details = opts.details;\n  const body: ApiEnvelopeError = { ok: false, error };\n  return c.json(body, status);\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1289,"cache_read_input_tokens":82343,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1289},"output_tokens":51,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8cbb9ef5-acf2-4608-a258-6641cdf0da27","uuid":"8577fc2f-a721-4a2b-aef1-4479928df28a"}
