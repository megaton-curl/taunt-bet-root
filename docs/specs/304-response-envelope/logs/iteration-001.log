{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GrtW3E4HAVBn1vBv5eFCHY","type":"tool_result","content":"1\t/**\n2\t * Auth routes: challenge/verify/refresh/logout for JWT session management.\n3\t *\n4\t * WAITLIST-CONTRACT: the waitlist (separate repo, launches first) calls every\n5\t * route in this file. Any change to request/response shape here must keep\n6\t * `waitlist/src/lib/auth-api.ts` in lockstep and is enforced by\n7\t * `__tests__/waitlist-contract.test.ts`. Ship a coordinated waitlist release\n8\t * before merging a breaking change.\n9\t */\n10\t\n11\timport { createRoute } from \"@hono/zod-openapi\";\n12\timport { z } from \"zod\";\n13\timport { randomBytes, createHash } from \"node:crypto\";\n14\timport nacl from \"tweetnacl\";\n15\timport bs58 from \"bs58\";\n16\timport { PublicKey } from \"@solana/web3.js\";\n17\timport { SignJWT } from \"jose\";\n18\timport type { AuthDb } from \"../auth-db.js\";\n19\timport type { Db } from \"../db.js\";\n20\timport { logger } from \"../logger.js\";\n21\timport {\n22\t  ChallengeNonceResponseSchema,\n23\t  TokenResponseSchema,\n24\t  ErrorResponseSchema,\n25\t} from \"../contracts/validators.js\";\n26\timport { createOpenApiApp } from \"../openapi/hono.js\";\n27\t\n28\texport interface AuthRoutesDeps {\n29\t  authDb: AuthDb;\n30\t  db: Db;\n31\t  jwtSecret: Uint8Array;\n32\t  cluster: string;\n33\t  challengeTtlSeconds: number;\n34\t  accessTokenTtlSeconds: number;\n35\t  refreshTokenTtlDays: number;\n36\t}\n37\t\n38\tfunction hashToken(token: string): Buffer {\n39\t  return createHash(\"sha256\").update(token).digest();\n40\t}\n41\t\n42\tfunction issueAccessToken(\n43\t  jwtSecret: Uint8Array,\n44\t  userId: string,\n45\t  now: number,\n46\t  accessTokenTtlSeconds: number,\n47\t): Promise<string> {\n48\t  return new SignJWT({})\n49\t    .setProtectedHeader({ alg: \"HS256\" })\n50\t    .setSubject(userId)\n51\t    .setIssuedAt(now)\n52\t    .setExpirationTime(now + accessTokenTtlSeconds)\n53\t    .sign(jwtSecret);\n54\t}\n55\t\n56\tfunction formatNetwork(cluster: string): string {\n57\t  const normalized = cluster.toLowerCase();\n58\t  if (normalized === \"devnet\") return \"Solana Devnet\";\n59\t  if (normalized === \"mainnet\" || normalized === \"mainnet-beta\") return \"Solana Mainnet\";\n60\t  return `Solana ${cluster}`;"}]},"parent_tool_use_id":null,"session_id":"8cbb9ef5-acf2-4608-a258-6641cdf0da27","uuid":"1f1fce75-94c3-41fe-9c05-8ee66cb3307d","timestamp":"2026-04-22T09:11:01.527Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/auth.ts","content":"/**\n * Auth routes: challenge/verify/refresh/logout for JWT session management.\n *\n * WAITLIST-CONTRACT: the waitlist (separate repo, launches first) calls every\n * route in this file. Any change to request/response shape here must keep\n * `waitlist/src/lib/auth-api.ts` in lockstep and is enforced by\n * `__tests__/waitlist-contract.test.ts`. Ship a coordinated waitlist release\n * before merging a breaking change.\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport { randomBytes, createHash } from \"node:crypto\";\nimport nacl from \"tweetnacl\";\nimport bs58 from \"bs58\";\nimport { PublicKey } from \"@solana/web3.js\";\nimport { SignJWT } from \"jose\";\nimport type { AuthDb } from \"../auth-db.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport {\n  ChallengeNonceResponseSchema,\n  TokenResponseSchema,\n  ErrorResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface AuthRoutesDeps {\n  authDb: AuthDb;\n  db: Db;\n  jwtSecret: Uint8Array;\n  cluster: string;\n  challengeTtlSeconds: number;\n  accessTokenTtlSeconds: number;\n  refreshTokenTtlDays: number;\n}\n\nfunction hashToken(token: string): Buffer {\n  return createHash(\"sha256\").update(token).digest();\n}\n\nfunction issueAccessToken(\n  jwtSecret: Uint8Array,\n  userId: string,\n  now: number,\n  accessTokenTtlSeconds: number,\n): Promise<string> {\n  return new SignJWT({})\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userId)\n    .setIssuedAt(now)\n    .setExpirationTime(now + accessTokenTtlSeconds)\n    .sign(jwtSecret);\n}\n\nfunction formatNetwork(cluster: string): string {\n  const normalized = cluster.toLowerCase();\n  if (normalized === \"devnet\") return \"Solana Devnet\";\n  if (normalized === \"mainnet\" || normalized === \"mainnet-beta\") return \"Solana Mainnet\";\n  return `Solana ${cluster}`;","numLines":60,"startLine":1,"totalLines":443}}}
