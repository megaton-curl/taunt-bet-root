{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WkgabtsGV7RCTh8bipJs18","type":"tool_result","content":"1\timport { z } from \"zod\";\n2\timport {\n3\t  PUBLIC_COMMIT_REVEAL_GAME_ID_VALUES,\n4\t  PUBLIC_GAME_IDS,\n5\t  PUBLIC_GAME_ID_VALUES,\n6\t} from \"./public-games.js\";\n7\t\n8\tconst IsoDateTimeSchema = z.string().datetime();\n9\tconst LamportsStringSchema = z.string().describe(\"Lamports as string\");\n10\tconst UserIdSchema = z.string().describe(\"Short user ID (usr_xxxxxxxx)\");\n11\tconst LeaderboardGameIdValues = [...PUBLIC_GAME_ID_VALUES, \"all\"] as const;\n12\t\n13\tfunction coerceClampedInteger(\n14\t  raw: unknown,\n15\t  defaultValue: number,\n16\t  min: number,\n17\t  max?: number,\n18\t): number {\n19\t  if (raw === undefined || raw === null || raw === \"\") {\n20\t    return defaultValue;\n21\t  }\n22\t\n23\t  const parsed = typeof raw === \"number\" ? raw : parseInt(String(raw), 10);\n24\t  if (!Number.isFinite(parsed) || Number.isNaN(parsed) || parsed < min) {\n25\t    return defaultValue;\n26\t  }\n27\t\n28\t  return max === undefined ? parsed : Math.min(parsed, max);\n29\t}\n30\t\n31\tfunction queryIntegerSchema(defaultValue: number, min: number, max?: number) {\n32\t  const base = z.number().int().min(min);\n33\t  const bounded = max === undefined ? base : base.max(max);\n34\t\n35\t  return z.preprocess(\n36\t    (raw) => coerceClampedInteger(raw, defaultValue, min, max),\n37\t    bounded.default(defaultValue),\n38\t  );\n39\t}\n40\t\n41\texport const PublicGameIdSchema = z.enum(PUBLIC_GAME_ID_VALUES);\n42\texport const PublicCommitRevealGameIdSchema = z.enum(PUBLIC_COMMIT_REVEAL_GAME_ID_VALUES);\n43\texport const LeaderboardGameIdSchema = z.enum(LeaderboardGameIdValues);\n44\t\n45\texport const ErrorResponseSchema = z.object({\n46\t  error: z.string(),\n47\t});\n48\t\n49\texport const StructuredErrorDetailSchema = z.object({\n50\t  code: z.string(),\n51\t  message: z.string(),\n52\t  retryable: z.boolean().optional(),\n53\t});\n54\t\n55\texport const StructuredErrorResponseSchema = z.object({\n56\t  error: StructuredErrorDetailSchema,\n57\t});\n58\t\n59\texport const OkResponseSchema = z.object({\n60\t  ok: z.boolean(),\n61\t});\n62\t\n63\texport const CodeResponseSchema = z.object({\n64\t  code: z.string(),\n65\t});\n66\t\n67\t// GET /referral/code: `code` is null when the user hasn't set one yet.\n68\t// Empty state is a valid answer to \"what's my code?\", not an error.\n69\texport const MaybeCodeResponseSchema = z.object({\n70\t  code: z.string().nullable(),\n71\t});\n72\t\n73\texport const ExistsResponseSchema = z.object({\n74\t  exists: z.boolean(),\n75\t});\n76\t\n77\texport const UsernameUpdateResponseSchema = z.object({\n78\t  username: z.string(),\n79\t  nextEditAvailableAt: z.string().datetime().nullable(),\n80\t});\n81\t\n82\texport const UsernameCooldownResponseSchema = z.object({\n83\t  error: z.string(),\n84\t  nextEditAvailableAt: z.string().datetime(),\n85\t});\n86\t\n87\texport const ReferralCodeSchema = z\n88\t  .string()\n89\t  .trim()\n90\t  .toLowerCase()\n91\t  .regex(/^[a-z0-9-]{3,16}$/)\n92\t  .describe(\"3-16 chars, lowercase alphanumeric + hyphens\");\n93\t\n94\texport const ReferralCodeBodySchema = z.object({\n95\t  code: ReferralCodeSchema,\n96\t});\n97\t\n98\texport const ApplyReferralCodeBodySchema = z.object({\n99\t  code: z.string().trim().toLowerCase().min(1),\n100\t});\n101\t\n102\texport const ReferralApplyResponseSchema = z.object({\n103\t  referrerUserId: z.string(),\n104\t  benefit: z.string(),\n105\t});\n106\t\n107\t// GET /referral/referrer: all four fields are nullable together — they are\n108\t// all populated when the caller is linked to a referrer, and all null when\n109\t// they aren't. Not being referred is a valid answer, not an error.\n110\texport const ReferralReferrerResponseSchema = z.object({\n111\t  referrerUserId: z.string().nullable(),\n112\t  referrerUsername: z.string().nullable(),\n113\t  referrerCode: z.string().nullable(),\n114\t  linkedAt: z.string().datetime().nullable(),\n115\t});\n116\t\n117\texport const ReferralListItemSchema = z.object({\n118\t  refereeUserId: z.string(),\n119\t  refereeUsername: z.string(),\n120\t  createdAt: z.string().datetime(),\n121\t});\n122\t\n123\texport const UsernameBodySchema = z.object({\n124\t  username: z.string().regex(/^[a-zA-Z0-9_-]{3,20}$/),\n125\t});\n126\t\n127\texport const ConfirmTransactionBodySchema = z.object({\n128\t  game: PublicGameIdSchema,\n129\t  matchId: z.string(),\n130\t  txType: z.enum([\"deposit\", \"refund\"]),\n131\t  txSig: z.string(),\n132\t  amountLamports: z.number().int().positive(),\n133\t});\n134\t\n135\texport const TransactionHistoryQuerySchema = z.object({\n136\t  cursor: z.string().optional(),\n137\t  limit: queryIntegerSchema(20, 1, 50),\n138\t  game: PublicGameIdSchema.optional(),\n139\t});\n140\t\n141\texport const LeaderboardQuerySchema = z.object({\n142\t  game: PublicGameIdSchema.optional(),\n143\t  limit: queryIntegerSchema(20, 1, 100),\n144\t  offset: queryIntegerSchema(0, 0),\n145\t});\n146\t\n147\texport const RoundsHistoryQuerySchema = z.object({\n148\t  game: PublicCommitRevealGameIdSchema,\n149\t  limit: queryIntegerSchema(20, 1, 50),\n150\t});\n151\t\n152\texport const PotShotEntrySchema = z.object({\n153\t  player: z.string().describe(\"Base58 wallet address\"),\n154\t  amountLamports: z.number().int(),\n155\t});\n156\t\n157\texport const PotShotRoundSchema = z.object({\n158\t  matchId: z.string(),\n159\t  pda: z.string(),\n160\t  phase: z.enum([\"waiting\", \"active\", \"locked\", \"resolving\", \"settled\", \"refunded\"]),\n161\t  creator: z.string(),\n162\t  commitment: z.string(),\n163\t  entries: z.array(PotShotEntrySchema),\n164\t  totalAmountLamports: z.number().int(),\n165\t  distinctPlayers: z.number().int(),\n166\t  countdownStartedAt: z.number().int().nullable(),\n167\t  countdownEndsAt: z.number().int().nullable(),\n168\t  createdAt: z.string().datetime(),\n169\t});\n170\t\n171\texport const CloseCallEntrySchema = z.object({\n172\t  player: z.string(),\n173\t  amountLamports: z.number().int(),\n174\t});\n175\t\n176\texport const CloseCallRoundSchema = z.object({\n177\t  roundId: z.string(),\n178\t  pda: z.string(),\n179\t  phase: z.enum([\"open\", \"settled\", \"refunded\"]),\n180\t  openPrice: z.number(),\n181\t  openPriceExpo: z.number().int(),\n182\t  closePrice: z.number().nullable().optional(),\n183\t  outcome: z.enum([\"pending\", \"green\", \"red\", \"refund\"]).optional(),\n184\t  greenPool: z.number().int(),\n185\t  redPool: z.number().int(),\n186\t  totalPool: z.number().int(),\n187\t  totalFee: z.number().int().optional(),\n188\t  greenEntries: z.array(CloseCallEntrySchema),\n189\t  redEntries: z.array(CloseCallEntrySchema),\n190\t  greenCount: z.number().int(),\n191\t  redCount: z.number().int(),\n192\t  settleTx: z.string().nullable().optional(),\n193\t  createdAt: z.string().datetime(),\n194\t  settledAt: z.string().datetime().nullable().optional(),\n195\t});\n196\t\n197\texport const TransactionSchema = z.object({\n198\t  id: z.string(),\n199\t  game: PublicGameIdSchema,\n200\t  matchId: z.string(),\n201\t  txType: z.enum([\"deposit\", \"refund\"]),\n202\t  amountLamports: LamportsStringSchema,\n203\t  txSig: z.string(),\n204\t  createdAt: IsoDateTimeSchema,\n205\t});\n206\t\n207\texport const PublicReferralLookupResponseSchema = z.object({\n208\t  userId: UserIdSchema,\n209\t  username: z.string(),\n210\t  referralCode: z.string().nullable(),\n211\t});\n212\t\n213\texport const GameBreakdownStatsSchema = z.object({\n214\t  gamesPlayed: z.number().int(),\n215\t  totalWagered: LamportsStringSchema,\n216\t  totalWins: z.number().int(),\n217\t  winRate: z.number(),\n218\t  netPnl: LamportsStringSchema,\n219\t});\n220\t\n221\texport const GameBreakdownMapSchema = z\n222\t  .object({})\n223\t  .catchall(GameBreakdownStatsSchema)\n224\t  .describe(\"Per-game stats keyed by frontend game name (flip-you, pot-shot, close-call)\");\n225\t\n226\texport const PlayerStatsSchema = z.object({\n227\t  gamesPlayed: z.number().int(),\n228\t  totalWagered: LamportsStringSchema,\n229\t  totalWins: z.number().int(),\n230\t  winRate: z.number(),\n231\t  winStreakCurrent: z.number().int(),\n232\t  winStreakBest: z.number().int(),\n233\t  netPnl: LamportsStringSchema,\n234\t  gameBreakdown: GameBreakdownMapSchema,\n235\t});\n236\t\n237\texport const PublicStatsSchema = z.object({\n238\t  gamesPlayed: z.number().int(),\n239\t  totalWins: z.number().int(),\n240\t  winRate: z.number(),\n241\t});\n242\t\n243\texport const PlayerProfileSchema = z.object({\n244\t  userId: UserIdSchema,\n245\t  username: z.string(),\n246\t  avatarUrl: z.string().nullable(),\n247\t  heatMultiplier: z.number(),\n248\t  pointsBalance: z.string().describe(\"BigInt as string\"),\n249\t  stats: PlayerStatsSchema,\n250\t  usernameNextEditAt: IsoDateTimeSchema.nullable(),\n251\t  createdAt: IsoDateTimeSchema,\n252\t  telegramLinked: z.boolean(),\n253\t});\n254\t\n255\texport const PublicPlayerProfileSchema = z.object({\n256\t  userId: UserIdSchema,\n257\t  username: z.string(),\n258\t  avatarUrl: z.string().nullable(),\n259\t  heatMultiplier: z.number(),\n260\t  stats: PublicStatsSchema,\n261\t  createdAt: IsoDateTimeSchema,\n262\t});\n263\t\n264\texport const LeaderboardEntrySchema = z.object({\n265\t  rank: z.number().int(),\n266\t  userId: z.string(),\n267\t  username: z.string(),\n268\t  avatarUrl: z.string().nullable(),\n269\t  totalWagered: LamportsStringSchema,\n270\t  gamesPlayed: z.number().int(),\n271\t  totalWins: z.number().int(),\n272\t  winRate: z.number(),\n273\t  netPnl: LamportsStringSchema,\n274\t});\n275\t\n276\texport const LeaderboardResponseSchema = z.object({\n277\t  game: LeaderboardGameIdSchema,\n278\t  weekStart: IsoDateTimeSchema,\n279\t  weekEnd: IsoDateTimeSchema,\n280\t  entries: z.array(LeaderboardEntrySchema),\n281\t});\n282\t\n283\texport const PriceResponseSchema = z.object({\n284\t  price: z.number().describe(\"SOL/USD price\"),\n285\t  updatedAt: IsoDateTimeSchema,\n286\t});\n287\t\n288\texport const DogpileCurrentResponseSchema = z\n289\t  .object({\n290\t    id: z.number().int(),\n291\t    multiplier: z.number(),\n292\t    startsAt: IsoDateTimeSchema,\n293\t    endsAt: IsoDateTimeSchema,\n294\t    status: z.enum([\"active\", \"scheduled\"]),\n295\t    startsIn: z.number().int().optional(),\n296\t    endsIn: z.number().int().optional(),\n297\t  })\n298\t  .nullable();\n299\t\n300\texport const DogpileScheduleItemSchema = z.object({\n301\t  id: z.number().int(),\n302\t  multiplier: z.number(),\n303\t  startsAt: IsoDateTimeSchema,\n304\t  endsAt: IsoDateTimeSchema,\n305\t  status: z.string(),\n306\t});\n307\t\n308\texport const DogpileScheduleResponseSchema = z.object({\n309\t  items: z.array(DogpileScheduleItemSchema),\n310\t});\n311\t\n312\t// ── Auth responses ──────────────────────────────────────────────────────\n313\t\n314\texport const ChallengeNonceResponseSchema = z.object({\n315\t  nonce: z.string().describe(\"64-char hex nonce\"),\n316\t  message: z.string().describe(\"Human-readable sign-in message\"),\n317\t  expiresAt: IsoDateTimeSchema,\n318\t});\n319\t\n320\texport const TokenResponseSchema = z.object({\n321\t  accessToken: z.string().describe(\"HS256 JWT\"),\n322\t  accessExpiresAt: IsoDateTimeSchema,\n323\t  refreshToken: z.string().describe(\"Opaque 96-char hex token\"),\n324\t  refreshExpiresAt: IsoDateTimeSchema,\n325\t});\n326\t\n327\t// ── Game create responses ───────────────────────────────────────────────\n328\t\n329\texport const FlipYouCreateResponseSchema = z.object({\n330\t  transaction: z.string().describe(\"Base64-encoded partially-signed transaction\"),\n331\t  matchPda: z.string().describe(\"Base58 match PDA address\"),\n332\t  matchId: z.string().describe(\"16-char hex match ID\"),\n333\t  commitment: z.string().describe(\"SHA256 hex commitment\"),\n334\t  lastValidBlockHeight: z.number().int(),\n335\t});\n336\t\n337\texport const PotShotCreateResponseSchema = z.object({\n338\t  transaction: z.string().describe(\"Base64-encoded partially-signed transaction\"),\n339\t  roundPda: z.string().describe(\"Base58 round PDA address\"),\n340\t  matchId: z.string().describe(\"16-char hex match ID\"),\n341\t  commitment: z.string().describe(\"SHA256 hex commitment\"),\n342\t  lastValidBlockHeight: z.number().int(),\n343\t});\n344\t\n345\texport const CandleSchema = z.object({\n346\t  openTime: z.number().int().describe(\"Millisecond timestamp\"),\n347\t  closeTime: z.number().int().describe(\"Millisecond timestamp\"),\n348\t  open: z.number(),\n349\t  close: z.number(),\n350\t  high: z.number(),\n351\t  low: z.number(),\n352\t  outcome: z.enum([\"green\", \"red\"]).nullable(),\n353\t});\n354\t\n355\texport const CloseCallBetResponseSchema = z.object({\n356\t  transaction: z.string().describe(\"Base64-encoded partially-signed transaction\"),\n357\t  minuteTs: z.number().int().describe(\"Unix timestamp (seconds) of the minute boundary\"),\n358\t  roundPda: z.string(),\n359\t});\n360\t\n361\t// ── Referral detail schemas ─────────────────────────────────────────────\n362\t\n363\texport const ReferralStatsSchema = z.object({\n364\t  referredCount: z.number().int(),\n365\t  activeCount: z.number().int(),\n366\t  totalVolumeLamports: LamportsStringSchema,\n367\t  totalEarnedLamports: LamportsStringSchema,\n368\t  totalRebateLamports: LamportsStringSchema,\n369\t  pendingLamports: LamportsStringSchema,\n370\t});\n371\t\n372\texport const ReferralEarningSchema = z.object({\n373\t  roundId: z.string(),\n374\t  gameType: z.string(),\n375\t  refereeWallet: z.string(),\n376\t  wagerLamports: LamportsStringSchema,\n377\t  earnedLamports: LamportsStringSchema,\n378\t  createdAt: IsoDateTimeSchema,\n379\t});\n380\t\n381\texport const ClaimResponseSchema = z.object({\n382\t  claimId: z.string(),\n383\t  amountLamports: LamportsStringSchema,\n384\t  status: z.string(),\n385\t  txSignature: z.string().optional(),\n386\t});\n387\t\n388\t// ── Challenge schemas ───────────────────────────────────────────────────\n389\t\n390\texport const ChallengeRewardSchema = z.object({\n391\t  type: z.enum([\"points\", \"crate\"]),\n392\t  amount: z.number().optional().describe(\"Present for points rewards, absent for crate rewards\"),\n393\t});\n394\t\n395\texport const ChallengeAssignmentSchema = z.object({\n396\t  id: z.number().int(),\n397\t  title: z.string(),\n398\t  description: z.string(),\n399\t  progress: z.number().int(),\n400\t  target: z.number().int(),\n401\t  status: z.enum([\"active\", \"completed\", \"expired\"]),\n402\t  reward: ChallengeRewardSchema,\n403\t  completedAt: IsoDateTimeSchema.nullable().optional(),\n404\t});\n405\t\n406\texport const ChallengeHistoryEntrySchema = z.object({\n407\t  id: z.number().int(),\n408\t  title: z.string(),\n409\t  description: z.string(),\n410\t  completedAt: IsoDateTimeSchema,\n411\t  reward: ChallengeRewardSchema,\n412\t});\n413\t\n414\texport const CompletionBonusSchema = z\n415\t  .object({\n416\t    title: z.string(),\n417\t    required: z.number().int().describe(\"Number of challenges needed\"),\n418\t    completed: z.number().int().describe(\"Number currently completed\"),\n419\t    status: z.enum([\"active\", \"completed\"]),\n420\t    reward: ChallengeRewardSchema,\n421\t  })\n422\t  .partial()\n423\t  .nullable()\n424\t  .describe(\n425\t    \"Bonus earned when enough challenges in a period are completed. Null if no bonus configured.\",\n426\t  );\n427\t\n428\t// ── Points schemas ──────────────────────────────────────────────────────\n429\t\n430\texport const PointGrantEntrySchema = z.object({\n431\t  id: z.number().int(),\n432\t  sourceType: z.string(),\n433\t  sourceId: z.string(),\n434\t  amount: z.number(),\n435\t  metadata: z.record(z.string(), z.unknown()),\n436\t  createdAt: IsoDateTimeSchema,\n437\t});\n438\t\n439\texport const CrateDropEntrySchema = z.object({\n440\t  id: z.number().int(),\n441\t  crateType: z.string(),\n4