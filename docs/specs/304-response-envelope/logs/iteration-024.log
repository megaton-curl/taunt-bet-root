{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Qt4dW3CRki3CUk2aZLNtFp","type":"tool_result","content":"1\t/**\n2\t * Telegram link routes — generate deep-link tokens and redeem them.\n3\t *\n4\t * POST /generate-link — JWT required. Returns a one-time deep-link token.\n5\t * All other endpoints use service-auth via X-Telegram-Webhook-Secret header.\n6\t *\n7\t * WAITLIST-CONTRACT: the waitlist calls POST /generate-link\n8\t * (`waitlist/src/components/TelegramCard.tsx`) and branches on both\n9\t * `alreadyLinked: true` and `deepLink` payloads. This file is plain Hono\n10\t * (no OpenAPI schema), so the response shape is locked by handler invocation\n11\t * in `__tests__/waitlist-contract.test.ts` — updating either response branch\n12\t * requires updating that test AND the waitlist consumer in the same change.\n13\t */\n14\t\n15\timport { randomBytes } from \"node:crypto\";\n16\timport { Hono } from \"hono\";\n17\timport { createMiddleware } from \"hono/factory\";\n18\timport type { AppEnv } from \"../hono-env.js\";\n19\timport type { Db } from \"../db.js\";\n20\timport { logger } from \"../logger.js\";\n21\timport { ok, err } from \"../contracts/api-envelope.js\";\n22\timport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n23\t\n24\texport interface TelegramLinkRoutesDeps {\n25\t  db: Db;\n26\t  telegramBotUsername: string;\n27\t  telegramWebhookSecret: string;\n28\t  communityInviteUrl: string | undefined;\n29\t  linkTokenTtlSeconds: number;\n30\t}\n31\t\n32\texport function createTelegramLinkRoutes(deps: TelegramLinkRoutesDeps) {\n33\t  const { db, telegramBotUsername, telegramWebhookSecret, communityInviteUrl, linkTokenTtlSeconds } = deps;\n34\t  const app = new Hono<AppEnv>();\n35\t\n36\t  // Service-auth middleware for bot-facing endpoints\n37\t  const serviceAuth = createMiddleware(async (c, next) => {\n38\t    if (c.req.header(\"X-Telegram-Webhook-Secret\") !== telegramWebhookSecret) {\n39\t      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n40\t    }\n41\t    return next();\n42\t  });\n43\t\n44\t  // -------------------------------------------------------------------------\n45\t  // POST /generate-link — JWT required\n46\t  // -------------------------------------------------------------------------\n47\t  app.post(\"/generate-link\", async (c) => {\n48\t    const userId = c.get(\"userId\");\n49\t    if (!userId) {\n50\t      return err(\n51\t        c,\n52\t        401,\n53\t        API_ERROR_CODES.AUTH_REQUIRED,\n54\t        \"Authentication required\",\n55\t      );\n56\t    }\n57\t\n58\t    try {\n59\t      const existing = await db.getActiveLink(userId);\n60\t      if (existing) {\n61\t        return ok(c, {\n62\t          alreadyLinked: true as const,\n63\t          telegramUserId: existing.telegram_user_id,\n64\t          telegramUsername: existing.telegram_username,\n65\t          linkedAt: existing.redeemed_at?.toISOString() ?? null,\n66\t          botUrl: `https://t.me/${telegramBotUsername}`,\n67\t          communityUrl: communityInviteUrl ?? null,\n68\t        });\n69\t      }\n70\t\n71\t      const token = randomBytes(32).toString(\"hex\");\n72\t      const expiresAt = new Date(Date.now() + linkTokenTtlSeconds * 1000);\n73\t\n74\t      await db.generateLinkToken(userId, token, expiresAt);\n75\t\n76\t      return ok(c, {\n77\t        token,\n78\t        deepLink: `https://t.me/${telegramBotUsername}?start=${token}`,\n79\t        expiresAt: expiresAt.toISOString(),\n80\t        botUrl: `https://t.me/${telegramBotUsername}`,\n81\t        communityUrl: communityInviteUrl ?? null,\n82\t      });\n83\t    } catch (generateError) {\n84\t      logger.error(\"telegram generate-link failed\", {\n85\t        userId,\n86\t        error:\n87\t          generateError instanceof Error\n88\t            ? generateError.message\n89\t            : \"Unknown error\",\n90\t      });\n91\t      return err(\n92\t        c,\n93\t        500,\n94\t        API_ERROR_CODES.PRECONDITION_FAILED,\n95\t        \"Failed to generate link token\",\n96\t      );\n97\t    }\n98\t  });\n99\t\n100\t  // -------------------------------------------------------------------------\n101\t  // POST /redeem-link — service-auth\n102\t  // -------------------------------------------------------------------------\n103\t  app.post(\"/redeem-link\", serviceAuth, async (c) => {\n104\t    let body: { token?: string; telegramUserId?: string; telegramUsername?: string };\n105\t    try {\n106\t      body = await c.req.json();\n107\t    } catch {\n108\t      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n109\t    }\n110\t\n111\t    const { token, telegramUserId, telegramUsername } = body;\n112\t    if (!token || !telegramUserId) {\n113\t      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n114\t    }\n115\t\n116\t    try {\n117\t      const existingTg = await db.getActiveLinkByTelegramId(telegramUserId);\n118\t      if (existingTg) {\n119\t        return c.json({\n120\t          error: \"TELEGRAM_ALREADY_LINKED\",\n121\t          existingUserId: existingTg.user_id,\n122\t        }, 409);\n123\t      }\n124\t\n125\t      const redeemed = await db.redeemLinkToken(\n126\t        token,\n127\t        telegramUserId,\n128\t        telegramUsername ?? null,\n129\t      );\n130\t\n131\t      if (!redeemed) {\n132\t        return c.json({ error: \"TOKEN_NOT_FOUND\" }, 404);\n133\t      }\n134\t\n135\t      const profile = await db.getProfileByUserId(redeemed.user_id);\n136\t\n137\t      return c.json({\n138\t        userId: redeemed.user_id,\n139\t        username: profile?.username ?? null,\n140\t        alreadyLinked: false,\n141\t      });\n142\t    } catch (err) {\n143\t      logger.error(\"telegram redeem-link failed\", {\n144\t        error: err instanceof Error ? err.message : \"Unknown error\",\n145\t      });\n146\t      return c.json({ error: \"Failed to redeem link token\" }, 500);\n147\t    }\n148\t  });\n149\t\n150\t  // -------------------------------------------------------------------------\n151\t  // GET /linked-user — resolve telegram ID → platform userId\n152\t  // -------------------------------------------------------------------------\n153\t  app.get(\"/linked-user\", serviceAuth, async (c) => {\n154\t    const telegramUserId = c.req.query(\"telegramUserId\");\n155\t    if (!telegramUserId) {\n156\t      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n157\t    }\n158\t\n159\t    try {\n160\t      const link = await db.getActiveLinkByTelegramId(telegramUserId);\n161\t      if (!link) {\n162\t        return c.json({ error: \"NOT_LINKED\" }, 404);\n163\t      }\n164\t\n165\t      return c.json({ userId: link.user_id });\n166\t    } catch (err) {\n167\t      logger.error(\"telegram linked-user lookup failed\", {\n168\t        error: err instanceof Error ? err.message : \"Unknown error\",\n169\t      });\n170\t      return c.json({ error: \"Failed to look up linked user\" }, 500);\n171\t    }\n172\t  });\n173\t\n174\t  // -------------------------------------------------------------------------\n175\t  // GET /referral-info — ref code + count for linked user\n176\t  // -------------------------------------------------------------------------\n177\t  app.get(\"/referral-info\", serviceAuth, async (c) => {\n178\t    const telegramUserId = c.req.query(\"telegramUserId\");\n179\t    if (!telegramUserId) {\n180\t      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n181\t    }\n182\t\n183\t    try {\n184\t      const link = await db.getActiveLinkByTelegramId(telegramUserId);\n185\t      if (!link) {\n186\t        return c.json({ error: \"NOT_LINKED\" }, 404);\n187\t      }\n188\t\n189\t      const userId = link.user_id;\n190\t      const [profile, codeRow, statsRow] = await Promise.all([\n191\t        db.getProfileByUserId(userId),\n192\t        db.getReferralCodeByUserId(userId),\n193\t        db.getReferralStatsByUserId(userId),\n194\t      ]);\n195\t\n196\t      return c.json({\n197\t        userId,\n198\t        username: profile?.username ?? null,\n199\t        referralCode: codeRow?.code ?? null,\n200\t        referredCount: statsRow.referred_count,\n201\t      });\n202\t    } catch (err) {\n203\t      logger.error(\"telegram referral-info failed\", {\n204\t        error: err instanceof Error ? err.message : \"Unknown error\",\n205\t      });\n206\t      return c.json({ error: \"Failed to fetch referral info\" }, 500);\n207\t    }\n208\t  });\n209\t\n210\t  // -------------------------------------------------------------------------\n211\t  // GET /referral-leaderboard — top referrers + user rank\n212\t  // -------------------------------------------------------------------------\n213\t  app.get(\"/referral-leaderboard\", serviceAuth, async (c) => {\n214\t    const telegramUserId = c.req.query(\"telegramUserId\");\n215\t\n216\t    try {\n217\t      // Resolve linked userId (optional — leaderboard works without it)\n218\t      let linkedUserId: string | undefined;\n219\t      if (telegramUserId) {\n220\t        const link = await db.getActiveLinkByTelegramId(telegramUserId);\n221\t        if (link) linkedUserId = link.user_id;\n222\t      }\n223\t\n224\t      const result = await db.getReferralLeaderboard(10, linkedUserId);\n225\t\n226\t      return c.json({\n227\t        entries: result.entries,\n228\t        userRank: result.userRank,\n229\t        userCount: result.userCount,\n230\t      });\n231\t    } catch (err) {\n232\t      logger.error(\"telegram referral-leaderboard failed\", {\n233\t        error: err instanceof Error ? err.message : \"Unknown error\",\n234\t      });\n235\t      return c.json({ error: \"Failed to fetch leaderboard\" }, 500);\n236\t    }\n237\t  });\n238\t\n239\t  return app;\n240\t}\n241\t"}]},"parent_tool_use_id":null,"session_id":"4cb6afe9-ffc2-4d89-84e3-9539172afcc4","uuid":"544719f0-ccd8-4e36-bb38-a9a01ccfb54b","timestamp":"2026-04-22T11:07:49.577Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/telegram-link.ts","content":"/**\n * Telegram link routes — generate deep-link tokens and redeem them.\n *\n * POST /generate-link — JWT required. Returns a one-time deep-link token.\n * All other endpoints use service-auth via X-Telegram-Webhook-Secret header.\n *\n * WAITLIST-CONTRACT: the waitlist calls POST /generate-link\n * (`waitlist/src/components/TelegramCard.tsx`) and branches on both\n * `alreadyLinked: true` and `deepLink` payloads. This file is plain Hono\n * (no OpenAPI schema), so the response shape is locked by handler invocation\n * in `__tests__/waitlist-contract.test.ts` — updating either response branch\n * requires updating that test AND the waitlist consumer in the same change.\n */\n\nimport { randomBytes } from \"node:crypto\";\nimport { Hono } from \"hono\";\nimport { createMiddleware } from \"hono/factory\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { ok, err } from \"../contracts/api-envelope.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n\nexport interface TelegramLinkRoutesDeps {\n  db: Db;\n  telegramBotUsername: string;\n  telegramWebhookSecret: string;\n  communityInviteUrl: string | undefined;\n  linkTokenTtlSeconds: number;\n}\n\nexport function createTelegramLinkRoutes(deps: TelegramLinkRoutesDeps) {\n  const { db, telegramBotUsername, telegramWebhookSecret, communityInviteUrl, linkTokenTtlSeconds } = deps;\n  const app = new Hono<AppEnv>();\n\n  // Service-auth middleware for bot-facing endpoints\n  const serviceAuth = createMiddleware(async (c, next) => {\n    if (c.req.header(\"X-Telegram-Webhook-Secret\") !== telegramWebhookSecret) {\n      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n    }\n    return next();\n  });\n\n  // -------------------------------------------------------------------------\n  // POST /generate-link — JWT required\n  // -------------------------------------------------------------------------\n  app.post(\"/generate-link\", async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.AUTH_REQUIRED,\n        \"Authentication required\",\n      );\n    }\n\n    try {\n      const existing = await db.getActiveLink(userId);\n      if (existing) {\n        return ok(c, {\n          alreadyLinked: true as const,\n          telegramUserId: existing.telegram_user_id,\n          telegramUsername: existing.telegram_username,\n          linkedAt: existing.redeemed_at?.toISOString() ?? null,\n          botUrl: `https://t.me/${telegramBotUsername}`,\n          communityUrl: communityInviteUrl ?? null,\n        });\n      }\n\n      const token = randomBytes(32).toString(\"hex\");\n      const expiresAt = new Date(Date.now() + linkTokenTtlSeconds * 1000);\n\n      await db.generateLinkToken(userId, token, expiresAt);\n\n      return ok(c, {\n        token,\n        deepLink: `https://t.me/${telegramBotUsername}?start=${token}`,\n        expiresAt: expiresAt.toISOString(),\n        botUrl: `https://t.me/${telegramBotUsername}`,\n        communityUrl: communityInviteUrl ?? null,\n      });\n    } catch (generateError) {\n      logger.error(\"telegram generate-link failed\", {\n        userId,\n        error:\n          generateError instanceof Error\n            ? generateError.message\n            : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to generate link token\",\n      );\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // POST /redeem-link — service-auth\n  // -------------------------------------------------------------------------\n  app.post(\"/redeem-link\", serviceAuth, async (c) => {\n    let body: { token?: string; telegramUserId?: string; telegramUsername?: string };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    const { token, telegramUserId, telegramUsername } = body;\n    if (!token || !telegramUserId) {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    try {\n      const existingTg = await db.getActiveLinkByTelegramId(telegramUserId);\n      if (existingTg) {\n        return c.json({\n          error: \"TELEGRAM_ALREADY_LINKED\",\n          existingUserId: existingTg.user_id,\n        }, 409);\n      }\n\n      const redeemed = await db.redeemLinkToken(\n        token,\n        telegramUserId,\n        telegramUsername ?? null,\n      );\n\n      if (!redeemed) {\n        return c.json({ error: \"TOKEN_NOT_FOUND\" }, 404);\n      }\n\n      const profile = await db.getProfileByUserId(redeemed.user_id);\n\n      return c.json({\n        userId: redeemed.user_id,\n        username: profile?.username ?? null,\n        alreadyLinked: false,\n      });\n    } catch (err) {\n      logger.error(\"telegram redeem-link failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to redeem link token\" }, 500);\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // GET /linked-user — resolve telegram ID → platform userId\n  // -------------------------------------------------------------------------\n  app.get(\"/linked-user\", serviceAuth, async (c) => {\n    const telegramUserId = c.req.query(\"telegramUserId\");\n    if (!telegramUserId) {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    try {\n      const link = await db.getActiveLinkByTelegramId(telegramUserId);\n      if (!link) {\n        return c.json({ error: \"NOT_LINKED\" }, 404);\n      }\n\n      return c.json({ userId: link.user_id });\n    } catch (err) {\n      logger.error(\"telegram linked-user lookup failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to look up linked user\" }, 500);\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // GET /referral-info — ref code + count for linked user\n  // -------------------------------------------------------------------------\n  app.get(\"/referral-info\", serviceAuth, async (c) => {\n    const telegramUserId = c.req.query(\"telegramUserId\");\n    if (!telegramUserId) {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    try {\n      const link = await db.getActiveLinkByTelegramId(telegramUserId);\n      if (!link) {\n        return c.json({ error: \"NOT_LINKED\" }, 404);\n      }\n\n      const userId = link.user_id;\n      const [profile, codeRow, statsRow] = await Promise.all([\n        db.getProfileByUserId(userId),\n        db.getReferralCodeByUserId(userId),\n        db.getReferralStatsByUserId(userId),\n      ]);\n\n      return c.json({\n        userId,\n        username: profile?.username ?? null,\n        referralCode: codeRow?.code ?? null,\n        referredCount: statsRow.referred_count,\n      });\n    } catch (err) {\n      logger.error(\"telegram referral-info failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch referral info\" }, 500);\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // GET /referral-leaderboard — top referrers + user rank\n  // -------------------------------------------------------------------------\n  app.get(\"/referral-leaderboard\", serviceAuth, async (c) => {\n    const telegramUserId = c.req.query(\"telegramUserId\");\n\n    try {\n      // Resolve linked userId (optional — leaderboard works without it)\n      let linkedUserId: string | undefined;\n      if (telegramUserId) {\n        const link = await db.getActiveLinkByTelegramId(telegramUserId);\n        if (link) linkedUserId = link.user_id;\n      }\n\n      const result = await db.getReferralLeaderboard(10, linkedUserId);\n\n      return c.json({\n        entries: result.entries,\n        userRank: result.userRank,\n        userCount: result.userCount,\n      });\n    } catch (err) {\n      logger.error(\"telegram referral-leaderboard failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch leaderboard\" }, 500);\n    }\n  });\n\n  return app;\n}\n","numLines":241,"startLine":1,"totalLines":241}}}
