{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_019c2fn1DVs95E2JjfYKAN3q","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_014URBiCnaxVMh8TC6CP9PdP","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/backend/src/routes/telegram-link.ts","old_string":"  // Service-auth middleware for bot-facing endpoints\n  const serviceAuth = createMiddleware(async (c, next) => {\n    if (c.req.header(\"X-Telegram-Webhook-Secret\") !== telegramWebhookSecret) {\n      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n    }\n    return next();\n  });","new_string":"  // Service-auth middleware for bot-facing endpoints\n  const serviceAuth = createMiddleware(async (c, next) => {\n    if (c.req.header(\"X-Telegram-Webhook-Secret\") !== telegramWebhookSecret) {\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.AUTH_REQUIRED,\n        \"Missing or invalid service secret\",\n      );\n    }\n    return next();\n  });"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1690,"cache_read_input_tokens":118367,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1690},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"4cb6afe9-ffc2-4d89-84e3-9539172afcc4","uuid":"bac4dcff-4ef3-4cb4-b6da-166ccda132e8"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014URBiCnaxVMh8TC6CP9PdP","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/src/routes/telegram-link.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"4cb6afe9-ffc2-4d89-84e3-9539172afcc4","uuid":"678be27f-4e6a-4b46-bdc4-2cc34e409b4d","timestamp":"2026-04-22T11:11:07.081Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/src/routes/telegram-link.ts","oldString":"  // Service-auth middleware for bot-facing endpoints\n  const serviceAuth = createMiddleware(async (c, next) => {\n    if (c.req.header(\"X-Telegram-Webhook-Secret\") !== telegramWebhookSecret) {\n      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n    }\n    return next();\n  });","newString":"  // Service-auth middleware for bot-facing endpoints\n  const serviceAuth = createMiddleware(async (c, next) => {\n    if (c.req.header(\"X-Telegram-Webhook-Secret\") !== telegramWebhookSecret) {\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.AUTH_REQUIRED,\n        \"Missing or invalid service secret\",\n      );\n    }\n    return next();\n  });","originalFile":"/**\n * Telegram link routes — generate deep-link tokens and redeem them.\n *\n * POST /generate-link — JWT required. Returns a one-time deep-link token.\n * All other endpoints use service-auth via X-Telegram-Webhook-Secret header.\n *\n * WAITLIST-CONTRACT: the waitlist calls POST /generate-link\n * (`waitlist/src/components/TelegramCard.tsx`) and branches on both\n * `alreadyLinked: true` and `deepLink` payloads. This file is plain Hono\n * (no OpenAPI schema), so the response shape is locked by handler invocation\n * in `__tests__/waitlist-contract.test.ts` — updating either response branch\n * requires updating that test AND the waitlist consumer in the same change.\n */\n\nimport { randomBytes } from \"node:crypto\";\nimport { Hono } from \"hono\";\nimport { createMiddleware } from \"hono/factory\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { ok, err } from \"../contracts/api-envelope.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n\nexport interface TelegramLinkRoutesDeps {\n  db: Db;\n  telegramBotUsername: string;\n  telegramWebhookSecret: string;\n  communityInviteUrl: string | undefined;\n  linkTokenTtlSeconds: number;\n}\n\nexport function createTelegramLinkRoutes(deps: TelegramLinkRoutesDeps) {\n  const { db, telegramBotUsername, telegramWebhookSecret, communityInviteUrl, linkTokenTtlSeconds } = deps;\n  const app = new Hono<AppEnv>();\n\n  // Service-auth middleware for bot-facing endpoints\n  const serviceAuth = createMiddleware(async (c, next) => {\n    if (c.req.header(\"X-Telegram-Webhook-Secret\") !== telegramWebhookSecret) {\n      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n    }\n    return next();\n  });\n\n  // -------------------------------------------------------------------------\n  // POST /generate-link — JWT required\n  // -------------------------------------------------------------------------\n  app.post(\"/generate-link\", async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.AUTH_REQUIRED,\n        \"Authentication required\",\n      );\n    }\n\n    try {\n      const existing = await db.getActiveLink(userId);\n      if (existing) {\n        return ok(c, {\n          alreadyLinked: true as const,\n          telegramUserId: existing.telegram_user_id,\n          telegramUsername: existing.telegram_username,\n          linkedAt: existing.redeemed_at?.toISOString() ?? null,\n          botUrl: `https://t.me/${telegramBotUsername}`,\n          communityUrl: communityInviteUrl ?? null,\n        });\n      }\n\n      const token = randomBytes(32).toString(\"hex\");\n      const expiresAt = new Date(Date.now() + linkTokenTtlSeconds * 1000);\n\n      await db.generateLinkToken(userId, token, expiresAt);\n\n      return ok(c, {\n        token,\n        deepLink: `https://t.me/${telegramBotUsername}?start=${token}`,\n        expiresAt: expiresAt.toISOString(),\n        botUrl: `https://t.me/${telegramBotUsername}`,\n        communityUrl: communityInviteUrl ?? null,\n      });\n    } catch (generateError) {\n      logger.error(\"telegram generate-link failed\", {\n        userId,\n        error:\n          generateError instanceof Error\n            ? generateError.message\n            : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to generate link token\",\n      );\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // POST /redeem-link — service-auth\n  // -------------------------------------------------------------------------\n  app.post(\"/redeem-link\", serviceAuth, async (c) => {\n    let body: { token?: string; telegramUserId?: string; telegramUsername?: string };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    const { token, telegramUserId, telegramUsername } = body;\n    if (!token || !telegramUserId) {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    try {\n      const existingTg = await db.getActiveLinkByTelegramId(telegramUserId);\n      if (existingTg) {\n        return c.json({\n          error: \"TELEGRAM_ALREADY_LINKED\",\n          existingUserId: existingTg.user_id,\n        }, 409);\n      }\n\n      const redeemed = await db.redeemLinkToken(\n        token,\n        telegramUserId,\n        telegramUsername ?? null,\n      );\n\n      if (!redeemed) {\n        return c.json({ error: \"TOKEN_NOT_FOUND\" }, 404);\n      }\n\n      const profile = await db.getProfileByUserId(redeemed.user_id);\n\n      return c.json({\n        userId: redeemed.user_id,\n        username: profile?.username ?? null,\n        alreadyLinked: false,\n      });\n    } catch (err) {\n      logger.error(\"telegram redeem-link failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to redeem link token\" }, 500);\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // GET /linked-user — resolve telegram ID → platform userId\n  // -------------------------------------------------------------------------\n  app.get(\"/linked-user\", serviceAuth, async (c) => {\n    const telegramUserId = c.req.query(\"telegramUserId\");\n    if (!telegramUserId) {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    try {\n      const link = await db.getActiveLinkByTelegramId(telegramUserId);\n      if (!link) {\n        return c.json({ error: \"NOT_LINKED\" }, 404);\n      }\n\n      return c.json({ userId: link.user_id });\n    } catch (err) {\n      logger.error(\"telegram linked-user lookup failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to look up linked user\" }, 500);\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // GET /referral-info — ref code + count for linked user\n  // -------------------------------------------------------------------------\n  app.get(\"/referral-info\", serviceAuth, async (c) => {\n    const telegramUserId = c.req.query(\"telegramUserId\");\n    if (!telegramUserId) {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    try {\n      const link = await db.getActiveLinkByTelegramId(telegramUserId);\n      if (!link) {\n        return c.json({ error: \"NOT_LINKED\" }, 404);\n      }\n\n      const userId = link.user_id;\n      const [profile, codeRow, statsRow] = await Promise.all([\n        db.getProfileByUserId(userId),\n        db.getReferralCodeByUserId(userId),\n        db.getReferralStatsByUserId(userId),\n      ]);\n\n      return c.json({\n        userId,\n        username: profile?.username ?? null,\n        referralCode: codeRow?.code ?? null,\n        referredCount: statsRow.referred_count,\n      });\n    } catch (err) {\n      logger.error(\"telegram referral-info failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch referral info\" }, 500);\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // GET /referral-leaderboard — top referrers + user rank\n  // -------------------------------------------------------------------------\n  app.get(\"/referral-leaderboard\", serviceAuth, async (c) => {\n    const telegramUserId = c.req.query(\"telegramUserId\");\n\n    try {\n      // Resolve linked userId (optional — leaderboard works without it)\n      let linkedUserId: string | undefined;\n      if (telegramUserId) {\n        const link = await db.getActiveLinkByTelegramId(telegramUserId);\n        if (link) linkedUserId = link.user_id;\n      }\n\n      const result = await db.getReferralLeaderboard(10, linkedUserId);\n\n      return c.json({\n        entries: result.entries,\n        userRank: result.userRank,\n        userCount: result.userCount,\n      });\n    } catch (err) {\n      logger.error(\"telegram referral-leaderboard failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch leaderboard\" }, 500);\n    }\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":36,"oldLines":7,"newStart":36,"newLines":12,"lines":["   // Service-auth middleware for bot-facing endpoints","   const serviceAuth = createMiddleware(async (c, next) => {","     if (c.req.header(\"X-Telegram-Webhook-Secret\") !== telegramWebhookSecret) {","-      return c.json({ error: \"UNAUTHORIZED\" }, 401);","+      return err(","+        c,","+        401,","+        API_ERROR_CODES.AUTH_REQUIRED,","+        \"Missing or invalid service secret\",","+      );","     }","     return next();","   });"]}],"userModified":false,"replaceAll":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01UcmQsnPigAubCMsoYiH5bW","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01JPQMXCc4naP7Jwz3zXScQs","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/backend/src/routes/telegram-link.ts","old_string":"  // -------------------------------------------------------------------------\n  // POST /redeem-link — service-auth\n  // -------------------------------------------------------------------------\n  app.post(\"/redeem-link\", serviceAuth, async (c) => {\n    let body: { token?: string; telegramUserId?: string; telegramUsername?: string };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    const { token, telegramUserId, telegramUsername } = body;\n    if (!token || !telegramUserId) {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    try {\n      const existingTg = await db.getActiveLinkByTelegramId(telegramUserId);\n      if (existingTg) {\n        return c.json({\n          error: \"TELEGRAM_ALREADY_LINKED\",\n          existingUserId: existingTg.user_id,\n        }, 409);\n      }\n\n      const redeemed = await db.redeemLinkToken(\n        token,\n        telegramUserId,\n        telegramUsername ?? null,\n      );\n\n      if (!redeemed) {\n        return c.json({ error: \"TOKEN_NOT_FOUND\" }, 404);\n      }\n\n      const profile = await db.getProfileByUserId(redeemed.user_id);\n\n      return c.json({\n        userId: redeemed.user_id,\n        username: profile?.username ?? null,\n        alreadyLinked: false,\n      });\n    } catch (err) {\n      logger.error(\"telegram redeem-link failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to redeem link token\" }, 500);\n    }\n  });","new_string":"  // -------------------------------------------------------------------------\n  // POST /redeem-link — service-auth\n  // -------------------------------------------------------------------------\n  app.post(\"/redeem-link\", serviceAuth, async (c) => {\n    let body: { token?: string; telegramUserId?: string; telegramUsername?: string };\n    try {\n      body = await c.req.json();\n    } catch {\n      return err(\n        c,\n        422,\n        API_ERROR_CODES.VALIDATION_FAILED,\n        \"Invalid request body\",\n      );\n    }\n\n    const { token, telegramUserId, telegramUsername } = body;\n    if (!token || !telegramUserId) {\n      return err(\n        c,\n        422,\n        API_ERROR_CODES.VALIDATION_FAILED,\n        \"Missing required fields\",\n      );\n    }\n\n    try {\n      const existingTg = await db.getActiveLinkByTelegramId(telegramUserId);\n      if (existingTg) {\n        return err(\n          c,\n          409,\n          API_ERROR_CODES.TELEGRAM_ALREADY_LINKED,\n          \"Telegram account already linked\",\n          { details: { existingUserId: existingTg.user_id } },\n        );\n      }\n\n      const redeemed = await db.redeemLinkToken(\n        token,\n        telegramUserId,\n        telegramUsername ?? null,\n      );\n\n      if (!redeemed) {\n        return err(\n          c,\n          404,\n          API_ERROR_CODES.TELEGRAM_TOKEN_EXPIRED,\n          \"Link token not found or expired\",\n        );\n      }\n\n      const profile = await db.getProfileByUserId(redeemed.user_id);\n\n      return ok(c, {\n        userId: redeemed.user_id,\n        username: profile?.username ?? null,\n        alreadyLinked: false as const,\n      });\n    } catch (redeemError) {\n      logger.error(\"telegram redeem-link failed\", {\n        error:\n          redeemError instanceof Error ? redeemError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to redeem link token\",\n      );\n    }\n  });"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":664,"cache_read_input_tokens":120057,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":664},"output_tokens":66,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"4cb6afe9-ffc2-4d89-84e3-9539172afcc4","uuid":"24d1910c-b013-46dc-b04e-360000a7816e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JPQMXCc4naP7Jwz3zXScQs","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/src/routes/telegram-link.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"4cb6afe9-ffc2-4d89-84e3-9539172afcc4","uuid":"a2d45079-d3e4-4d9a-8bbb-5b112954e80e","timestamp":"2026-04-22T11:11:19.862Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/src/routes/telegram-link.ts","oldString":"  // -------------------------------------------------------------------------\n  // POST /redeem-link — service-auth\n  // -------------------------------------------------------------------------\n  app.post(\"/redeem-link\", serviceAuth, async (c) => {\n    let body: { token?: string; telegramUserId?: string; telegramUsername?: string };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    const { token, telegramUserId, telegramUsername } = body;\n    if (!token || !telegramUserId) {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    try {\n      const existingTg = await db.getActiveLinkByTelegramId(telegramUserId);\n      if (existingTg) {\n        return c.json({\n          error: \"TELEGRAM_ALREADY_LINKED\",\n          existingUserId: existingTg.user_id,\n        }, 409);\n      }\n\n      const redeemed = await db.redeemLinkToken(\n        token,\n        telegramUserId,\n        telegramUsername ?? null,\n      );\n\n      if (!redeemed) {\n        return c.json({ error: \"TOKEN_NOT_FOUND\" }, 404);\n      }\n\n      const profile = await db.getProfileByUserId(redeemed.user_id);\n\n      return c.json({\n        userId: redeemed.user_id,\n        username: profile?.username ?? null,\n        alreadyLinked: false,\n      });\n    } catch (err) {\n      logger.error(\"telegram redeem-link failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to redeem link token\" }, 500);\n    }\n  });","newString":"  // -------------------------------------------------------------------------\n  // POST /redeem-link — service-auth\n  // -------------------------------------------------------------------------\n  app.post(\"/redeem-link\", serviceAuth, async (c) => {\n    let body: { token?: string; telegramUserId?: string; telegramUsername?: string };\n    try {\n      body = await c.req.json();\n    } catch {\n      return err(\n        c,\n        422,\n        API_ERROR_CODES.VALIDATION_FAILED,\n        \"Invalid request body\",\n      );\n    }\n\n    const { token, telegramUserId, telegramUsername } = body;\n    if (!token || !telegramUserId) {\n      return err(\n        c,\n        422,\n        API_ERROR_CODES.VALIDATION_FAILED,\n        \"Missing required fields\",\n      );\n    }\n\n    try {\n      const existingTg = await db.getActiveLinkByTelegramId(telegramUserId);\n      if (existingTg) {\n        return err(\n          c,\n          409,\n          API_ERROR_CODES.TELEGRAM_ALREADY_LINKED,\n          \"Telegram account already linked\",\n          { details: { existingUserId: existingTg.user_id } },\n        );\n      }\n\n      const redeemed = await db.redeemLinkToken(\n        token,\n        telegramUserId,\n        telegramUsername ?? null,\n      );\n\n      if (!redeemed) {\n        return err(\n          c,\n          404,\n          API_ERROR_CODES.TELEGRAM_TOKEN_EXPIRED,\n          \"Link token not found or expired\",\n        );\n      }\n\n      const profile = await db.getProfileByUserId(redeemed.user_id);\n\n      return ok(c, {\n        userId: redeemed.user_id,\n        username: profile?.username ?? null,\n        alreadyLinked: false as const,\n      });\n    } catch (redeemError) {\n      logger.error(\"telegram redeem-link failed\", {\n        error:\n          redeemError instanceof Error ? redeemError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to redeem link token\",\n      );\n    }\n  });","originalFile":"/**\n * Telegram link routes — generate deep-link tokens and redeem them.\n *\n * POST /generate-link — JWT required. Returns a one-time deep-link token.\n * All other endpoints use service-auth via X-Telegram-Webhook-Secret header.\n *\n * WAITLIST-CONTRACT: the waitlist calls POST /generate-link\n * (`waitlist/src/components/TelegramCard.tsx`) and branches on both\n * `alreadyLinked: true` and `deepLink` payloads. This file is plain Hono\n * (no OpenAPI schema), so the response shape is locked by handler invocation\n * in `__tests__/waitlist-contract.test.ts` — updating either response branch\n * requires updating that test AND the waitlist consumer in the same change.\n */\n\nimport { randomBytes } from \"node:crypto\";\nimport { Hono } from \"hono\";\nimport { createMiddleware } from \"hono/factory\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { ok, err } from \"../contracts/api-envelope.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n\nexport interface TelegramLinkRoutesDeps {\n  db: Db;\n  telegramBotUsername: string;\n  telegramWebhookSecret: string;\n  communityInviteUrl: string | undefined;\n  linkTokenTtlSeconds: number;\n}\n\nexport function createTelegramLinkRoutes(deps: TelegramLinkRoutesDeps) {\n  const { db, telegramBotUsername, telegramWebhookSecret, communityInviteUrl, linkTokenTtlSeconds } = deps;\n  const app = new Hono<AppEnv>();\n\n  // Service-auth middleware for bot-facing endpoints\n  const serviceAuth = createMiddleware(async (c, next) => {\n    if (c.req.header(\"X-Telegram-Webhook-Secret\") !== telegramWebhookSecret) {\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.AUTH_REQUIRED,\n        \"Missing or invalid service secret\",\n      );\n    }\n    return next();\n  });\n\n  // -------------------------------------------------------------------------\n  // POST /generate-link — JWT required\n  // -------------------------------------------------------------------------\n  app.post(\"/generate-link\", async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.AUTH_REQUIRED,\n        \"Authentication required\",\n      );\n    }\n\n    try {\n      const existing = await db.getActiveLink(userId);\n      if (existing) {\n        return ok(c, {\n          alreadyLinked: true as const,\n          telegramUserId: existing.telegram_user_id,\n          telegramUsername: existing.telegram_username,\n          linkedAt: existing.redeemed_at?.toISOString() ?? null,\n          botUrl: `https://t.me/${telegramBotUsername}`,\n          communityUrl: communityInviteUrl ?? null,\n        });\n      }\n\n      const token = randomBytes(32).toString(\"hex\");\n      const expiresAt = new Date(Date.now() + linkTokenTtlSeconds * 1000);\n\n      await db.generateLinkToken(userId, token, expiresAt);\n\n      return ok(c, {\n        token,\n        deepLink: `https://t.me/${telegramBotUsername}?start=${token}`,\n        expiresAt: expiresAt.toISOString(),\n        botUrl: `https://t.me/${telegramBotUsername}`,\n        communityUrl: communityInviteUrl ?? null,\n      });\n    } catch (generateError) {\n      logger.error(\"telegram generate-link failed\", {\n        userId,\n        error:\n          generateError instanceof Error\n            ? generateError.message\n            : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to generate link token\",\n      );\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // POST /redeem-link — service-auth\n  // -------------------------------------------------------------------------\n  app.post(\"/redeem-link\", serviceAuth, async (c) => {\n    let body: { token?: string; telegramUserId?: string; telegramUsername?: string };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    const { token, telegramUserId, telegramUsername } = body;\n    if (!token || !telegramUserId) {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    try {\n      const existingTg = await db.getActiveLinkByTelegramId(telegramUserId);\n      if (existingTg) {\n        return c.json({\n          error: \"TELEGRAM_ALREADY_LINKED\",\n          existingUserId: existingTg.user_id,\n        }, 409);\n      }\n\n      const redeemed = await db.redeemLinkToken(\n        token,\n        telegramUserId,\n        telegramUsername ?? null,\n      );\n\n      if (!redeemed) {\n        return c.json({ error: \"TOKEN_NOT_FOUND\" }, 404);\n      }\n\n      const profile = await db.getProfileByUserId(redeemed.user_id);\n\n      return c.json({\n        userId: redeemed.user_id,\n        username: profile?.username ?? null,\n        alreadyLinked: false,\n      });\n    } catch (err) {\n      logger.error(\"telegram redeem-link failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to redeem link token\" }, 500);\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // GET /linked-user — resolve telegram ID → platform userId\n  // -------------------------------------------------------------------------\n  app.get(\"/linked-user\", serviceAuth, async (c) => {\n    const telegramUserId = c.req.query(\"telegramUserId\");\n    if (!telegramUserId) {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    try {\n      const link = await db.getActiveLinkByTelegramId(telegramUserId);\n      if (!link) {\n        return c.json({ error: \"NOT_LINKED\" }, 404);\n      }\n\n      return c.json({ userId: link.user_id });\n    } catch (err) {\n      logger.error(\"telegram linked-user lookup failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to look up linked user\" }, 500);\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // GET /referral-info — ref code + count for linked user\n  // -------------------------------------------------------------------------\n  app.get(\"/referral-info\", serviceAuth, async (c) => {\n    const telegramUserId = c.req.query(\"telegramUserId\");\n    if (!telegramUserId) {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    try {\n      const link = await db.getActiveLinkByTelegramId(telegramUserId);\n      if (!link) {\n        return c.json({ error: \"NOT_LINKED\" }, 404);\n      }\n\n      const userId = link.user_id;\n      const [profile, codeRow, statsRow] = await Promise.all([\n        db.getProfileByUserId(userId),\n        db.getReferralCodeByUserId(userId),\n        db.getReferralStatsByUserId(userId),\n      ]);\n\n      return c.json({\n        userId,\n        username: profile?.username ?? null,\n        referralCode: codeRow?.code ?? null,\n        referredCount: statsRow.referred_count,\n      });\n    } catch (err) {\n      logger.error(\"telegram referral-info failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch referral info\" }, 500);\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // GET /referral-leaderboard — top referrers + user rank\n  // -------------------------------------------------------------------------\n  app.get(\"/referral-leaderboard\", serviceAuth, async (c) => {\n    const telegramUserId = c.req.query(\"telegramUserId\");\n\n    try {\n      // Resolve linked userId (optional — leaderboard works without it)\n      let linkedUserId: string | undefined;\n      if (telegramUserId) {\n        const link = await db.getActiveLinkByTelegramId(telegramUserId);\n        if (link) linkedUserId = link.user_id;\n      }\n\n      const result = await db.getReferralLeaderboard(10, linkedUserId);\n\n      return c.json({\n        entries: result.entries,\n        userRank: result.userRank,\n        userCount: result.userCount,\n      });\n    } catch (err) {\n      logger.error(\"telegram referral-leaderboard failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch leaderboard\" }, 500);\n    }\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":110,"oldLines":21,"newStart":110,"newLines":34,"lines":["     try {","       body = await c.req.json();","     } catch {","-      return c.json({ error: \"INVALID_REQUEST\" }, 400);","+      return err(","+        c,","+        422,","+        API_ERROR_CODES.VALIDATION_FAILED,","+        \"Invalid request body\",","+      );","     }"," ","     const { token, telegramUserId, telegramUsername } = body;","     if (!token || !telegramUserId) {","-      return c.json({ error: \"INVALID_REQUEST\" }, 400);","+      return err(","+        c,","+        422,","+        API_ERROR_CODES.VALIDATION_FAILED,","+        \"Missing required fields\",","+      );","     }"," ","     try {","       const existingTg = await db.getActiveLinkByTelegramId(telegramUserId);","       if (existingTg) {","-        return c.json({","-          error: \"TELEGRAM_ALREADY_LINKED\",","-          existingUserId: existingTg.user_id,","-        }, 409);","+        return err(","+          c,","+          409,","+          API_ERROR_CODES.TELEGRAM_ALREADY_LINKED,","+          \"Telegram account already linked\",","+          { details: { existingUserId: existingTg.user_id } },","+        );","       }"," ","       const redeemed = await db.redeemLinkToken("]},{"oldStart":134,"oldLines":21,"newStart":147,"newLines":32,"lines":["       );"," ","       if (!redeemed) {","-        return c.json({ error: \"TOKEN_NOT_FOUND\" }, 404);","+        return err(","+          c,","+          404,","+          API_ERROR_CODES.TELEGRAM_TOKEN_EXPIRED,","+          \"Link token not found or expired\",","+        );","       }"," ","       const profile = await db.getProfileByUserId(redeemed.user_id);"," ","-      return c.json({","+      return ok(c, {","         userId: redeemed.user_id,","         username: profile?.username ?? null,","-        alreadyLinked: false,","+        alreadyLinked: false as const,","       });","-    } catch (err) {","+    } catch (redeemError) {","       logger.error(\"telegram redeem-link failed\", {","-        error: err instanceof Error ? err.message : \"Unknown error\",","+        error:","+          redeemError instanceof Error ? redeemError.message : \"Unknown error\",","       });","-      return c.json({ error: \"Failed to redeem link token\" }, 500);","+      return err(","+        c,","+        500,","+        API_ERROR_CODES.PRECONDITION_FAILED,","+        \"Failed to redeem link token\",","+      );","     }","   });"," "]}],"userModified":false,"replaceAll":false}}
