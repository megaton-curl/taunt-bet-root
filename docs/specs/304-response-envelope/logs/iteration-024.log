lient {\n  (input: string, init?: RequestInit): Promise<Response>;\n}\n\nimport { trimTrailingSlash } from \"./utils.js\";\n\nexport interface BackendClientConfig {\n  backendUrl: string;\n  serviceSecret?: string;\n  fetchImpl?: FetchClient;\n  /** Per-request timeout in ms. Default: 5000. */\n  timeoutMs?: number;\n  /** Optional logger for structured error diagnostics. */\n  logger?: { error(message: string, meta?: unknown): void };\n}\n\nexport function createBackendClient(config: BackendClientConfig): BackendClient {\n  const fetchImpl = config.fetchImpl ?? fetch;\n  const baseUrl = trimTrailingSlash(config.backendUrl);\n  const timeoutMs = config.timeoutMs ?? 5_000;\n  const logger = config.logger;\n\n  function serviceHeaders(): Record<string, string> {\n    return config.serviceSecret\n      ? { \"X-Telegram-Webhook-Secret\": config.serviceSecret }\n      : {};\n  }\n\n  async function requestWithTimeout(\n    op: string,\n    url: string,\n    init: RequestInit,\n  ): Promise<Response | null> {\n    const controller = new AbortController();\n    const timer = setTimeout(() => controller.abort(), timeoutMs);\n    try {\n      return await fetchImpl(url, { ...init, signal: controller.signal });\n    } catch (error) {\n      const isAbort =\n        (error instanceof Error && error.name === \"AbortError\") ||\n        (error instanceof DOMException && error.name === \"AbortError\");\n      logger?.error(\"backend request failed\", {\n        op,\n        url,\n        reason: isAbort ? \"timeout\" : \"network_error\",\n        timeoutMs,\n        error: error instanceof Error ? error.message : String(error),\n      });\n      return null;\n    } finally {\n      clearTimeout(timer);\n    }\n  }\n\n  return {\n    async getLinkedUserId(telegramUserId): Promise<string | null> {\n      if (!config.serviceSecret) return null;\n      const response = await requestWithTimeout(\n        \"getLinkedUserId\",\n        `${baseUrl}/telegram/linked-user?telegramUserId=${encodeURIComponent(telegramUserId)}`,\n        { headers: serviceHeaders() },\n      );\n      if (!response) return null;\n      if (response.status === 404) return null;\n      if (!response.ok) return null;\n      try {\n        const data = (await response.json()) as { userId: string };\n        return data.userId;\n      } catch (error) {\n        logger?.error(\"backend response parse failed\", {\n          op: \"getLinkedUserId\",\n          error: error instanceof Error ? error.message : String(error),\n        });\n        return null;\n      }\n    },\n\n    async redeemTelegramLink(token, telegramUserId, telegramUsername): Promise<RedeemLinkResult> {\n      if (!config.serviceSecret) {\n        return { ok: false, error: \"UNAUTHORIZED\" };\n      }\n\n      const response = await requestWithTimeout(\n        \"redeemTelegramLink\",\n        `${baseUrl}/telegram/redeem-link`,\n        {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\",\n            ...serviceHeaders(),\n          },\n          body: JSON.stringify({ token, telegramUserId, telegramUsername }),\n        },\n      );\n      if (!response) return { ok: false, error: \"UNKNOWN\" };\n\n      try {\n        if (response.ok) {\n          const data = (await response.json()) as {\n            userId: string;\n            username: string | null;\n            alreadyLinked: boolean;\n          };\n          return { ok: true, ...data };\n        }\n\n        if (response.status === 409) {\n          const data = (await response.json()) as { error: string };\n          if (data.error === \"TELEGRAM_ALREADY_LINKED\") {\n            return { ok: false, error: \"TELEGRAM_ALREADY_LINKED\" };\n          }\n        }\n\n        if (response.status === 404) {\n          return { ok: false, error: \"TOKEN_NOT_FOUND\" };\n        }\n\n        return { ok: false, error: \"UNKNOWN\" };\n      } catch (error) {\n        logger?.error(\"backend response parse failed\", {\n          op: \"redeemTelegramLink\",\n          status: response.status,\n          error: error instanceof Error ? error.message : String(error),\n        });\n        return { ok: false, error: \"UNKNOWN\" };\n      }\n    },\n\n    async getReferralInfo(telegramUserId): Promise<ReferralInfo | null> {\n      if (!config.serviceSecret) return null;\n      const response = await requestWithTimeout(\n        \"getReferralInfo\",\n        `${baseUrl}/telegram/referral-info?telegramUserId=${encodeURIComponent(telegramUserId)}`,\n        { headers: serviceHeaders() },\n      );\n      if (!response) return null;\n      if (!response.ok) return null;\n      try {\n        return (await response.json()) as ReferralInfo;\n      } catch (error) {\n        logger?.error(\"backend response parse failed\", {\n          op: \"getReferralInfo\",\n          error: error instanceof Error ? error.message : String(error),\n        });\n        return null;\n      }\n    },\n\n    async getReferralLeaderboard(telegramUserId): Promise<LeaderboardResult | null> {\n      if (!config.serviceSecret) return null;\n      const response = await requestWithTimeout(\n        \"getReferralLeaderboard\",\n        `${baseUrl}/telegram/referral-leaderboard?telegramUserId=${encodeURIComponent(telegramUserId)}`,\n        { headers: serviceHeaders() },\n      );\n      if (!response) return null;\n      if (!response.ok) return null;\n      try {\n        return (await response.json()) as LeaderboardResult;\n      } catch (error) {\n        logger?.error(\"backend response parse failed\", {\n          op: \"getReferralLeaderboard\",\n          error: error instanceof Error ? error.message : String(error),\n        });\n        return null;\n      }\n    },\n  };\n}\n","userModified":false}}
