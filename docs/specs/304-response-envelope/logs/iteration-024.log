{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019tAGBjDqPRcRgy2YGSKuHU","type":"tool_result","content":"1\t/**\n2\t * Telegram link routes — generate deep-link tokens and redeem them.\n3\t *\n4\t * POST /generate-link — JWT required. Returns a one-time deep-link token.\n5\t * All other endpoints use service-auth via X-Telegram-Webhook-Secret header.\n6\t *\n7\t * WAITLIST-CONTRACT: the waitlist calls POST /generate-link\n8\t * (`waitlist/src/components/TelegramCard.tsx`) and branches on both\n9\t * `alreadyLinked: true` and `deepLink` payloads. This file is plain Hono\n10\t * (no OpenAPI schema), so the response shape is locked by handler invocation\n11\t * in `__tests__/waitlist-contract.test.ts` — updating either response branch\n12\t * requires updating that test AND the waitlist consumer in the same change.\n13\t */\n14\t\n15\timport { randomBytes } from \"node:crypto\";\n16\timport { Hono } from \"hono\";\n17\timport { createMiddleware } from \"hono/factory\";\n18\timport type { AppEnv } from \"../hono-env.js\";\n19\timport type { Db } from \"../db.js\";\n20\timport { logger } from \"../logger.js\";\n21\timport { ok, err } from \"../contracts/api-envelope.js\";\n22\timport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n23\t\n24\texport interface TelegramLinkRoutesDeps {\n25\t  db: Db;\n26\t  telegramBotUsername: string;\n27\t  telegramWebhookSecret: string;\n28\t  communityInviteUrl: string | undefined;\n29\t  linkTokenTtlSeconds: number;\n30\t}\n31\t\n32\texport function createTelegramLinkRoutes(deps: TelegramLinkRoutesDeps) {\n33\t  const { db, telegramBotUsername, telegramWebhookSecret, communityInviteUrl, linkTokenTtlSeconds } = deps;\n34\t  const app = new Hono<AppEnv>();\n35\t\n36\t  // Service-auth middleware for bot-facing endpoints\n37\t  const serviceAuth = createMiddleware(async (c, next) => {\n38\t    if (c.req.header(\"X-Telegram-Webhook-Secret\") !== telegramWebhookSecret) {\n39\t      return err(\n40\t        c,\n41\t        401,\n42\t        API_ERROR_CODES.AUTH_REQUIRED,\n43\t        \"Missing or invalid service secret\",\n44\t      );\n45\t    }\n46\t    return next();\n47\t  });\n48\t\n49\t  // -------------------------------------------------------------------------\n50\t  // POST /generate-link — JWT required\n51\t  // -------------------------------------------------------------------------\n52\t  app.post(\"/generate-link\", async (c) => {\n53\t    const userId = c.get(\"userId\");\n54\t    if (!userId) {\n55\t      return err(\n56\t        c,\n57\t        401,\n58\t        API_ERROR_CODES.AUTH_REQUIRED,\n59\t        \"Authentication required\",\n60\t      );\n61\t    }\n62\t\n63\t    try {\n64\t      const existing = await db.getActiveLink(userId);\n65\t      if (existing) {\n66\t        return ok(c, {\n67\t          alreadyLinked: true as const,\n68\t          telegramUserId: existing.telegram_user_id,\n69\t          telegramUsername: existing.telegram_username,\n70\t          linkedAt: existing.redeemed_at?.toISOString() ?? null,\n71\t          botUrl: `https://t.me/${telegramBotUsername}`,\n72\t          communityUrl: communityInviteUrl ?? null,\n73\t        });\n74\t      }\n75\t\n76\t      const token = randomBytes(32).toString(\"hex\");\n77\t      const expiresAt = new Date(Date.now() + linkTokenTtlSeconds * 1000);\n78\t\n79\t      await db.generateLinkToken(userId, token, expiresAt);\n80\t\n81\t      return ok(c, {\n82\t        token,\n83\t        deepLink: `https://t.me/${telegramBotUsername}?start=${token}`,\n84\t        expiresAt: expiresAt.toISOString(),\n85\t        botUrl: `https://t.me/${telegramBotUsername}`,\n86\t        communityUrl: communityInviteUrl ?? null,\n87\t      });\n88\t    } catch (generateError) {\n89\t      logger.error(\"telegram generate-link failed\", {\n90\t        userId,\n91\t        error:\n92\t          generateError instanceof Error\n93\t            ? generateError.message\n94\t            : \"Unknown error\",\n95\t      });\n96\t      return err(\n97\t        c,\n98\t        500,\n99\t        API_ERROR_CODES.PRECONDITION_FAILED,\n100\t        \"Failed to generate link token\",\n101\t      );\n102\t    }\n103\t  });\n104\t\n105\t  // -------------------------------------------------------------------------\n106\t  // POST /redeem-link — service-auth\n107\t  // -------------------------------------------------------------------------\n108\t  app.post(\"/redeem-link\", serviceAuth, async (c) => {\n109\t    let body: { token?: string; telegramUserId?: string; telegramUsername?: string };\n110\t    try {\n111\t      body = await c.req.json();\n112\t    } catch {\n113\t      return err(\n114\t        c,\n115\t        422,\n116\t        API_ERROR_CODES.VALIDATION_FAILED,\n117\t        \"Invalid request body\",\n118\t      );\n119\t    }\n120\t\n121\t    const { token, telegramUserId, telegramUsername } = body;\n122\t    if (!token || !telegramUserId) {\n123\t      return err(\n124\t        c,\n125\t        422,\n126\t        API_ERROR_CODES.VALIDATION_FAILED,\n127\t        \"Missing required fields\",\n128\t      );\n129\t    }\n130\t\n131\t    try {\n132\t      const existingTg = await db.getActiveLinkByTelegramId(telegramUserId);\n133\t      if (existingTg) {\n134\t        return err(\n135\t          c,\n136\t          409,\n137\t          API_ERROR_CODES.TELEGRAM_ALREADY_LINKED,\n138\t          \"Telegram account already linked\",\n139\t          { details: { existingUserId: existingTg.user_id } },\n140\t        );\n141\t      }\n142\t\n143\t      const redeemed = await db.redeemLinkToken(\n144\t        token,\n145\t        telegramUserId,\n146\t        telegramUsername ?? null,\n147\t      );\n148\t\n149\t      if (!redeemed) {\n150\t        return err(\n151\t          c,\n152\t          404,\n153\t          API_ERROR_CODES.TELEGRAM_TOKEN_EXPIRED,\n154\t          \"Link token not found or expired\",\n155\t        );\n156\t      }\n157\t\n158\t      const profile = await db.getProfileByUserId(redeemed.user_id);\n159\t\n160\t      return ok(c, {\n161\t        userId: redeemed.user_id,\n162\t        username: profile?.username ?? null,\n163\t        alreadyLinked: false as const,\n164\t      });\n165\t    } catch (redeemError) {\n166\t      logger.error(\"telegram redeem-link failed\", {\n167\t        error:\n168\t          redeemError instanceof Error ? redeemError.message : \"Unknown error\",\n169\t      });\n170\t      return err(\n171\t        c,\n172\t        500,\n173\t        API_ERROR_CODES.PRECONDITION_FAILED,\n174\t        \"Failed to redeem link token\",\n175\t      );\n176\t    }\n177\t  });\n178\t\n179\t  // -------------------------------------------------------------------------\n180\t  // GET /linked-user — resolve telegram ID → platform userId\n181\t  // -------------------------------------------------------------------------\n182\t  app.get(\"/linked-user\", serviceAuth, async (c) => {\n183\t    const telegramUserId = c.req.query(\"telegramUserId\");\n184\t    if (!telegramUserId) {\n185\t      return err(\n186\t        c,\n187\t        422,\n188\t        API_ERROR_CODES.VALIDATION_FAILED,\n189\t        \"Missing telegramUserId\",\n190\t      );\n191\t    }\n192\t\n193\t    try {\n194\t      const link = await db.getActiveLinkByTelegramId(telegramUserId);\n195\t      if (!link) {\n196\t        return err(\n197\t          c,\n198\t          404,\n199\t          API_ERROR_CODES.TELEGRAM_NOT_LINKED,\n200\t          \"Telegram account not linked\",\n201\t        );\n202\t      }\n203\t\n204\t      return ok(c, { userId: link.user_id });\n205\t    } catch (lookupError) {\n206\t      logger.error(\"telegram linked-user lookup failed\", {\n207\t        error:\n208\t          lookupError instanceof Error ? lookupError.message : \"Unknown error\",\n209\t      });\n210\t      return err(\n211\t        c,\n212\t        500,\n213\t        API_ERROR_CODES.PRECONDITION_FAILED,\n214\t        \"Failed to look up linked user\",\n215\t      );\n216\t    }\n217\t  });\n218\t\n219\t  // -------------------------------------------------------------------------\n220\t  // GET /referral-info — ref code + count for linked user\n221\t  // -------------------------------------------------------------------------\n222\t  app.get(\"/referral-info\", serviceAuth, async (c) => {\n223\t    const telegramUserId = c.req.query(\"telegramUserId\");\n224\t    if (!telegramUserId) {\n225\t      return err(\n226\t        c,\n227\t        422,\n228\t        API_ERROR_CODES.VALIDATION_FAILED,\n229\t        \"Missing telegramUserId\",\n230\t      );\n231\t    }\n232\t\n233\t    try {\n234\t      const link = await db.getActiveLinkByTelegramId(telegramUserId);\n235\t      if (!link) {\n236\t        return err(\n237\t          c,\n238\t          404,\n239\t          API_ERROR_CODES.TELEGRAM_NOT_LINKED,\n240\t          \"Telegram account not linked\",\n241\t        );\n242\t      }\n243\t\n244\t      const userId = link.user_id;\n245\t      const [profile, codeRow, statsRow] = await Promise.all([\n246\t        db.getProfileByUserId(userId),\n247\t        db.getReferralCodeByUserId(userId),\n248\t        db.getReferralStatsByUserId(userId),\n249\t      ]);\n250\t\n251\t      return ok(c, {\n252\t        userId,\n253\t        username: profile?.username ?? null,\n254\t        referralCode: codeRow?.code ?? null,\n255\t        referredCount: statsRow.referred_count,\n256\t      });\n257\t    } catch (fetchError) {\n258\t      logger.error(\"telegram referral-info failed\", {\n259\t        error:\n260\t          fetchError instanceof Error ? fetchError.message : \"Unknown error\",\n261\t      });\n262\t      return err(\n263\t        c,\n264\t        500,\n265\t        API_ERROR_CODES.PRECONDITION_FAILED,\n266\t        \"Failed to fetch referral info\",\n267\t      );\n268\t    }\n269\t  });\n270\t\n271\t  // -------------------------------------------------------------------------\n272\t  // GET /referral-leaderboard — top referrers + user rank\n273\t  // -------------------------------------------------------------------------\n274\t  app.get(\"/referral-leaderboard\", serviceAuth, async (c) => {\n275\t    const telegramUserId = c.req.query(\"telegramUserId\");\n276\t\n277\t    try {\n278\t      // Resolve linked userId (optional — leaderboard works without it)\n279\t      let linkedUserId: string | undefined;\n280\t      if (telegramUserId) {\n281\t        const link = await db.getActiveLinkByTelegramId(telegramUserId);\n282\t        if (link) linkedUserId = link.user_id;\n283\t      }\n284\t\n285\t      const result = await db.getReferralLeaderboard(10, linkedUserId);\n286\t\n287\t      return ok(c, {\n288\t        entries: result.entries,\n289\t        userRank: result.userRank,\n290\t        userCount: result.userCount,\n291\t      });\n292\t    } catch (fetchError) {\n293\t      logger.error(\"telegram referral-leaderboard failed\", {\n294\t        error:\n295\t          fetchError instanceof Error ? fetchError.message : \"Unknown error\",\n296\t      });\n297\t      return err(\n298\t        c,\n299\t        500,\n300\t        API_ERROR_CODES.PRECONDITION_FAILED,\n301\t        \"Failed to fetch leaderboard\",\n302\t      );\n303\t    }\n304\t  });\n305\t\n306\t  return app;\n307\t}\n308\t"}]},"parent_tool_use_id":null,"session_id":"4cb6afe9-ffc2-4d89-84e3-9539172afcc4","uuid":"a6260182-0f0c-4602-8710-ec7569c602a0","timestamp":"2026-04-22T11:11:53.939Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/telegram-link.ts","content":"/**\n * Telegram link routes — generate deep-link tokens and redeem them.\n *\n * POST /generate-link — JWT required. Returns a one-time deep-link token.\n * All other endpoints use service-auth via X-Telegram-Webhook-Secret header.\n *\n * WAITLIST-CONTRACT: the waitlist calls POST /generate-link\n * (`waitlist/src/components/TelegramCard.tsx`) and branches on both\n * `alreadyLinked: true` and `deepLink` payloads. This file is plain Hono\n * (no OpenAPI schema), so the response shape is locked by handler invocation\n * in `__tests__/waitlist-contract.test.ts` — updating either response branch\n * requires updating that test AND the waitlist consumer in the same change.\n */\n\nimport { randomBytes } from \"node:crypto\";\nimport { Hono } from \"hono\";\nimport { createMiddleware } from \"hono/factory\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { ok, err } from \"../contracts/api-envelope.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n\nexport interface TelegramLinkRoutesDeps {\n  db: Db;\n  telegramBotUsername: string;\n  telegramWebhookSecret: string;\n  communityInviteUrl: string | undefined;\n  linkTokenTtlSeconds: number;\n}\n\nexport function createTelegramLinkRoutes(deps: TelegramLinkRoutesDeps) {\n  const { db, telegramBotUsername, telegramWebhookSecret, communityInviteUrl, linkTokenTtlSeconds } = deps;\n  const app = new Hono<AppEnv>();\n\n  // Service-auth middleware for bot-facing endpoints\n  const serviceAuth = createMiddleware(async (c, next) => {\n    if (c.req.header(\"X-Telegram-Webhook-Secret\") !== telegramWebhookSecret) {\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.AUTH_REQUIRED,\n        \"Missing or invalid service secret\",\n      );\n    }\n    return next();\n  });\n\n  // -------------------------------------------------------------------------\n  // POST /generate-link — JWT required\n  // -------------------------------------------------------------------------\n  app.post(\"/generate-link\", async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.AUTH_REQUIRED,\n        \"Authentication required\",\n      );\n    }\n\n    try {\n      const existing = await db.getActiveLink(userId);\n      if (existing) {\n        return ok(c, {\n          alreadyLinked: true as const,\n          telegramUserId: existing.telegram_user_id,\n          telegramUsername: existing.telegram_username,\n          linkedAt: existing.redeemed_at?.toISOString() ?? null,\n          botUrl: `https://t.me/${telegramBotUsername}`,\n          communityUrl: communityInviteUrl ?? null,\n        });\n      }\n\n      const token = randomBytes(32).toString(\"hex\");\n      const expiresAt = new Date(Date.now() + linkTokenTtlSeconds * 1000);\n\n      await db.generateLinkToken(userId, token, expiresAt);\n\n      return ok(c, {\n        token,\n        deepLink: `https://t.me/${telegramBotUsername}?start=${token}`,\n        expiresAt: expiresAt.toISOString(),\n        botUrl: `https://t.me/${telegramBotUsername}`,\n        communityUrl: communityInviteUrl ?? null,\n      });\n    } catch (generateError) {\n      logger.error(\"telegram generate-link failed\", {\n        userId,\n        error:\n          generateError instanceof Error\n            ? generateError.message\n            : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to generate link token\",\n      );\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // POST /redeem-link — service-auth\n  // -------------------------------------------------------------------------\n  app.post(\"/redeem-link\", serviceAuth, async (c) => {\n    let body: { token?: string; telegramUserId?: string; telegramUsername?: string };\n    try {\n      body = await c.req.json();\n    } catch {\n      return err(\n        c,\n        422,\n        API_ERROR_CODES.VALIDATION_FAILED,\n        \"Invalid request body\",\n      );\n    }\n\n    const { token, telegramUserId, telegramUsername } = body;\n    if (!token || !telegramUserId) {\n      return err(\n        c,\n        422,\n        API_ERROR_CODES.VALIDATION_FAILED,\n        \"Missing required fields\",\n      );\n    }\n\n    try {\n      const existingTg = await db.getActiveLinkByTelegramId(telegramUserId);\n      if (existingTg) {\n        return err(\n          c,\n          409,\n          API_ERROR_CODES.TELEGRAM_ALREADY_LINKED,\n          \"Telegram account already linked\",\n          { details: { existingUserId: existingTg.user_id } },\n        );\n      }\n\n      const redeemed = await db.redeemLinkToken(\n        token,\n        telegramUserId,\n        telegramUsername ?? null,\n      );\n\n      if (!redeemed) {\n        return err(\n          c,\n          404,\n          API_ERROR_CODES.TELEGRAM_TOKEN_EXPIRED,\n          \"Link token not found or expired\",\n        );\n      }\n\n      const profile = await db.getProfileByUserId(redeemed.user_id);\n\n      return ok(c, {\n        userId: redeemed.user_id,\n        username: profile?.username ?? null,\n        alreadyLinked: false as const,\n      });\n    } catch (redeemError) {\n      logger.error(\"telegram redeem-link failed\", {\n        error:\n          redeemError instanceof Error ? redeemError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to redeem link token\",\n      );\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // GET /linked-user — resolve telegram ID → platform userId\n  // -------------------------------------------------------------------------\n  app.get(\"/linked-user\", serviceAuth, async (c) => {\n    const telegramUserId = c.req.query(\"telegramUserId\");\n    if (!telegramUserId) {\n      return err(\n        c,\n        422,\n        API_ERROR_CODES.VALIDATION_FAILED,\n        \"Missing telegramUserId\",\n      );\n    }\n\n    try {\n      const link = await db.getActiveLinkByTelegramId(telegramUserId);\n      if (!link) {\n        return err(\n          c,\n          404,\n          API_ERROR_CODES.TELEGRAM_NOT_LINKED,\n          \"Telegram account not linked\",\n        );\n      }\n\n      return ok(c, { userId: link.user_id });\n    } catch (lookupError) {\n      logger.error(\"telegram linked-user lookup failed\", {\n        error:\n          lookupError instanceof Error ? lookupError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to look up linked user\",\n      );\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // GET /referral-info — ref code + count for linked user\n  // -------------------------------------------------------------------------\n  app.get(\"/referral-info\", serviceAuth, async (c) => {\n    const telegramUserId = c.req.query(\"telegramUserId\");\n    if (!telegramUserId) {\n      return err(\n        c,\n        422,\n        API_ERROR_CODES.VALIDATION_FAILED,\n        \"Missing telegramUserId\",\n      );\n    }\n\n    try {\n      const link = await db.getActiveLinkByTelegramId(telegramUserId);\n      if (!link) {\n        return err(\n          c,\n          404,\n          API_ERROR_CODES.TELEGRAM_NOT_LINKED,\n          \"Telegram account not linked\",\n        );\n      }\n\n      const userId = link.user_id;\n      const [profile, codeRow, statsRow] = await Promise.all([\n        db.getProfileByUserId(userId),\n        db.getReferralCodeByUserId(userId),\n        db.getReferralStatsByUserId(userId),\n      ]);\n\n      return ok(c, {\n        userId,\n        username: profile?.username ?? null,\n        referralCode: codeRow?.code ?? null,\n        referredCount: statsRow.referred_count,\n      });\n    } catch (fetchError) {\n      logger.error(\"telegram referral-info failed\", {\n        error:\n          fetchError instanceof Error ? fetchError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch referral info\",\n      );\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // GET /referral-leaderboard — top referrers + user rank\n  // -------------------------------------------------------------------------\n  app.get(\"/referral-leaderboard\", serviceAuth, async (c) => {\n    const telegramUserId = c.req.query(\"telegramUserId\");\n\n    try {\n      // Resolve linked userId (optional — leaderboard works without it)\n      let linkedUserId: string | undefined;\n      if (telegramUserId) {\n        const link = await db.getActiveLinkByTelegramId(telegramUserId);\n        if (link) linkedUserId = link.user_id;\n      }\n\n      const result = await db.getReferralLeaderboard(10, linkedUserId);\n\n      return ok(c, {\n        entries: result.entries,\n        userRank: result.userRank,\n        userCount: result.userCount,\n      });\n    } catch (fetchError) {\n      logger.error(\"telegram referral-leaderboard failed\", {\n        error:\n          fetchError instanceof Error ? fetchError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch leaderboard\",\n      );\n    }\n  });\n\n  return app;\n}\n","numLines":308,"startLine":1,"totalLines":308}}}
