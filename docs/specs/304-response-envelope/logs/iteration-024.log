"network_error\",\n53\t        timeoutMs,\n54\t        error: error instanceof Error ? error.message : String(error),\n55\t      });\n56\t      return null;\n57\t    } finally {\n58\t      clearTimeout(timer);\n59\t    }\n60\t  }\n61\t\n62\t  return {\n63\t    async getLinkedUserId(telegramUserId): Promise<string | null> {\n64\t      if (!config.serviceSecret) return null;\n65\t      const response = await requestWithTimeout(\n66\t        \"getLinkedUserId\",\n67\t        `${baseUrl}/telegram/linked-user?telegramUserId=${encodeURIComponent(telegramUserId)}`,\n68\t        { headers: serviceHeaders() },\n69\t      );\n70\t      if (!response) return null;\n71\t      if (response.status === 404) return null;\n72\t      if (!response.ok) return null;\n73\t      try {\n74\t        const data = (await response.json()) as { userId: string };\n75\t        return data.userId;\n76\t      } catch (error) {\n77\t        logger?.error(\"backend response parse failed\", {\n78\t          op: \"getLinkedUserId\",\n79\t          error: error instanceof Error ? error.message : String(error),\n80\t        });\n81\t        return null;\n82\t      }\n83\t    },\n84\t\n85\t    async redeemTelegramLink(token, telegramUserId, telegramUsername): Promise<RedeemLinkResult> {\n86\t      if (!config.serviceSecret) {\n87\t        return { ok: false, error: \"UNAUTHORIZED\" };\n88\t      }\n89\t\n90\t      const response = await requestWithTimeout(\n91\t        \"redeemTelegramLink\",\n92\t        `${baseUrl}/telegram/redeem-link`,\n93\t        {\n94\t          method: \"POST\",\n95\t          headers: {\n96\t            \"Content-Type\": \"application/json\",\n97\t            ...serviceHeaders(),\n98\t          },\n99\t          body: JSON.stringify({ token, telegramUserId, telegramUsername }),\n100\t        },\n101\t      );\n102\t      if (!response) return { ok: false, error: \"UNKNOWN\" };\n103\t\n104\t      try {\n105\t        if (response.ok) {\n106\t          const data = (await response.