{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01JG7nbhgPSEjTna1C7BvzNy","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FNFdWKJaXSwYg8fM8r26Vs","name":"Write","input":{"file_path":"/workspaces/rng-utopia/telegram/src/__tests__/backend-client.test.ts","content":"import { describe, expect, it, vi } from \"vitest\";\nimport { createBackendClient } from \"../backend-client.js\";\n\nfunction envelopeSuccess<T>(data: T): Response {\n  return new Response(JSON.stringify({ ok: true, data }), {\n    status: 200,\n    headers: { \"Content-Type\": \"application/json\" },\n  });\n}\n\nfunction envelopeError(\n  status: number,\n  code: string,\n  message = \"error\",\n  extras?: { retryable?: boolean; details?: unknown },\n): Response {\n  const error: Record<string, unknown> = { code, message };\n  if (extras?.retryable !== undefined) error.retryable = extras.retryable;\n  if (extras?.details !== undefined) error.details = extras.details;\n  return new Response(JSON.stringify({ ok: false, error }), {\n    status,\n    headers: { \"Content-Type\": \"application/json\" },\n  });\n}\n\nfunction rawResponse(status: number, body: unknown): Response {\n  return new Response(JSON.stringify(body), {\n    status,\n    headers: { \"Content-Type\": \"application/json\" },\n  });\n}\n\ndescribe(\"createBackendClient envelope parsing\", () => {\n  describe(\"getLinkedUserId\", () => {\n    it(\"extracts userId from a success envelope\", async () => {\n      const fetchImpl = vi.fn().mockResolvedValue(\n        envelopeSuccess({ userId: \"usr_alice\" }),\n      );\n      const client = createBackendClient({\n        backendUrl: \"https://backend.test\",\n        serviceSecret: \"secret\",\n        fetchImpl,\n      });\n\n      const result = await client.getLinkedUserId(\"tg_123\");\n\n      expect(result).toBe(\"usr_alice\");\n      expect(fetchImpl).toHaveBeenCalledWith(\n        \"https://backend.test/telegram/linked-user?telegramUserId=tg_123\",\n        expect.objectContaining({\n          headers: { \"X-Telegram-Webhook-Secret\": \"secret\" },\n        }),\n      );\n    });\n\n    it(\"returns null when the envelope is an error\", async () => {\n      const fetchImpl = vi.fn().mockResolvedValue(\n        envelopeError(404, \"TELEGRAM_NOT_LINKED\"),\n      );\n      const client = createBackendClient({\n        backendUrl: \"https://backend.test\",\n        serviceSecret: \"secret\",\n        fetchImpl,\n      });\n\n      expect(await client.getLinkedUserId(\"tg_123\")).toBeNull();\n    });\n\n    it(\"returns null when the body is not an envelope\", async () => {\n      const fetchImpl = vi.fn().mockResolvedValue(\n        rawResponse(200, { userId: \"usr_legacy\" }),\n      );\n      const error = vi.fn();\n      const client = createBackendClient({\n        backendUrl: \"https://backend.test\",\n        serviceSecret: \"secret\",\n        fetchImpl,\n        logger: { error },\n      });\n\n      expect(await client.getLinkedUserId(\"tg_123\")).toBeNull();\n      expect(error).toHaveBeenCalledWith(\n        \"backend response missing envelope\",\n        expect.objectContaining({ op: \"getLinkedUserId\" }),\n      );\n    });\n\n    it(\"returns null when serviceSecret is missing\", async () => {\n      const fetchImpl = vi.fn();\n      const client = createBackendClient({\n        backendUrl: \"https://backend.test\",\n        fetchImpl,\n      });\n\n      expect(await client.getLinkedUserId(\"tg_123\")).toBeNull();\n      expect(fetchImpl).not.toHaveBeenCalled();\n    });\n  });\n\n  describe(\"redeemTelegramLink\", () => {\n    it(\"extracts the user payload from a success envelope\", async () => {\n      const fetchImpl = vi.fn().mockResolvedValue(\n        envelopeSuccess({\n          userId: \"usr_abc\",\n          username: \"CoolPlayer\",\n          alreadyLinked: false,\n        }),\n      );\n      const client = createBackendClient({\n        backendUrl: \"https://backend.test\",\n        serviceSecret: \"secret\",\n        fetchImpl,\n      });\n\n      const result = await client.redeemTelegramLink(\n        \"token-abc\",\n        \"tg_1\",\n        \"tg_user\",\n      );\n\n      expect(result).toEqual({\n        ok: true,\n        userId: \"usr_abc\",\n        username: \"CoolPlayer\",\n        alreadyLinked: false,\n      });\n    });\n\n    it(\"maps TELEGRAM_ALREADY_LINKED error code\", async () => {\n      const fetchImpl = vi.fn().mockResolvedValue(\n        envelopeError(409, \"TELEGRAM_ALREADY_LINKED\"),\n      );\n      const client = createBackendClient({\n        backendUrl: \"https://backend.test\",\n        serviceSecret: \"secret\",\n        fetchImpl,\n      });\n\n      expect(\n        await client.redeemTelegramLink(\"token\", \"tg_1\", null),\n      ).toEqual({ ok: false, error: \"TELEGRAM_ALREADY_LINKED\" });\n    });\n\n    it(\"maps TELEGRAM_TOKEN_EXPIRED to TOKEN_NOT_FOUND\", async () => {\n      const fetchImpl = vi.fn().mockResolvedValue(\n        envelopeError(404, \"TELEGRAM_TOKEN_EXPIRED\"),\n      );\n      const client = createBackendClient({\n        backendUrl: \"https://backend.test\",\n        serviceSecret: \"secret\",\n        fetchImpl,\n      });\n\n      expect(\n        await client.redeemTelegramLink(\"token\", \"tg_1\", null),\n      ).toEqual({ ok: false, error: \"TOKEN_NOT_FOUND\" });\n    });\n\n    it(\"maps AUTH_REQUIRED to UNAUTHORIZED\", async () => {\n      const fetchImpl = vi.fn().mockResolvedValue(\n        envelopeError(401, \"AUTH_REQUIRED\"),\n      );\n      const client = createBackendClient({\n        backendUrl: \"https://backend.test\",\n        serviceSecret: \"secret\",\n        fetchImpl,\n      });\n\n      expect(\n        await client.redeemTelegramLink(\"token\", \"tg_1\", null),\n      ).toEqual({ ok: false, error: \"UNAUTHORIZED\" });\n    });\n\n    it(\"falls back to UNKNOWN for other error codes\", async () => {\n      const fetchImpl = vi.fn().mockResolvedValue(\n        envelopeError(500, \"PRECONDITION_FAILED\"),\n      );\n      const client = createBackendClient({\n        backendUrl: \"https://backend.test\",\n        serviceSecret: \"secret\",\n        fetchImpl,\n      });\n\n      expect(\n        await client.redeemTelegramLink(\"token\", \"tg_1\", null),\n      ).toEqual({ ok: false, error: \"UNKNOWN\" });\n    });\n\n    it(\"returns UNAUTHORIZED when no service secret is configured\", async () => {\n      const fetchImpl = vi.fn();\n      const client = createBackendClient({\n        backendUrl: \"https://backend.test\",\n        fetchImpl,\n      });\n\n      expect(\n        await client.redeemTelegramLink(\"token\", \"tg_1\", null),\n      ).toEqual({ ok: false, error: \"UNAUTHORIZED\" });\n      expect(fetchImpl).not.toHaveBeenCalled();\n    });\n\n    it(\"returns UNKNOWN on network failure\", async () => {\n      const fetchImpl = vi.fn().mockRejectedValue(new Error(\"boom\"));\n      const client = createBackendClient({\n        backendUrl: \"https://backend.test\",\n        serviceSecret: \"secret\",\n        fetchImpl,\n        logger: { error: vi.fn() },\n      });\n\n      expect(\n        await client.redeemTelegramLink(\"token\", \"tg_1\", null),\n      ).toEqual({ ok: false, error: \"UNKNOWN\" });\n    });\n  });\n\n  describe(\"getReferralInfo\", () => {\n    it(\"extracts referral info from a success envelope\", async () => {\n      const info = {\n        userId: \"usr_alice\",\n        username: \"alice\",\n        referralCode: \"alpha\",\n        referredCount: 7,\n      };\n      const fetchImpl = vi.fn().mockResolvedValue(envelopeSuccess(info));\n      const client = createBackendClient({\n        backendUrl: \"https://backend.test\",\n        serviceSecret: \"secret\",\n        fetchImpl,\n      });\n\n      expect(await client.getReferralInfo(\"tg_1\")).toEqual(info);\n    });\n\n    it(\"returns null on error envelope\", async () => {\n      const fetchImpl = vi.fn().mockResolvedValue(\n        envelopeError(404, \"TELEGRAM_NOT_LINKED\"),\n      );\n      const client = createBackendClient({\n        backendUrl: \"https://backend.test\",\n        serviceSecret: \"secret\",\n        fetchImpl,\n      });\n\n      expect(await client.getReferralInfo(\"tg_1\")).toBeNull();\n    });\n  });\n\n  describe(\"getReferralLeaderboard\", () => {\n    it(\"extracts leaderboard from a success envelope\", async () => {\n      const leaderboard = {\n        entries: [{ rank: 1, username: \"alice\", count: 10 }],\n        userRank: 1,\n        userCount: 10,\n      };\n      const fetchImpl = vi.fn().mockResolvedValue(envelopeSuccess(leaderboard));\n      const client = createBackendClient({\n        backendUrl: \"https://backend.test\",\n        serviceSecret: \"secret\",\n        fetchImpl,\n      });\n\n      expect(await client.getReferralLeaderboard(\"tg_1\")).toEqual(leaderboard);\n    });\n\n    it(\"returns null on error envelope\", async () => {\n      const fetchImpl = vi.fn().mockResolvedValue(\n        envelopeError(500, \"PRECONDITION_FAILED\"),\n      );\n      const client = createBackendClient({\n        backendUrl: \"https://backend.test\",\n        serviceSecret: \"secret\",\n        fetchImpl,\n      });\n\n      expect(await client.getReferralLeaderboard(\"tg_1\")).toBeNull();\n    });\n\n    it(\"returns null when body is not JSON\", async () => {\n      const fetchImpl = vi.fn().mockResolvedValue(\n        new Response(\"<!doctype html>\", { status: 500 }),\n      );\n      const client = createBackendClient({\n        backendUrl: \"https://backend.test\",\n        serviceSecret: \"secret\",\n        fetchImpl,\n        logger: { error: vi.fn() },\n      });\n\n      expect(await client.getReferralLeaderboard(\"tg_1\")).toBeNull();\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":315,"cache_read_input_tokens":138258,"cach