          },\n414\t        }),\n415\t      });\n416\t\n417\t      expect(response.status).toBe(200);\n418\t    }\n419\t\n420\t    expect(router.handleTextCommand).toHaveBeenCalledTimes(2);\n421\t    expect(sendMessage).toHaveBeenCalledTimes(2);\n422\t    expect(router.handleTextCommand).toHaveBeenNthCalledWith(\n423\t      2,\n424\t      expect.objectContaining({\n425\t        chatId: 22,\n426\t        fromUserId: \"202\",\n427\t        isGroup: true,\n428\t      }),\n429\t    );\n430\t  });\n431\t});\n432\t"}]},"parent_tool_use_id":null,"session_id":"4cb6afe9-ffc2-4d89-84e3-9539172afcc4","uuid":"92dc3f2f-57e3-439f-acaf-d54bbfe8e24c","timestamp":"2026-04-22T11:12:22.602Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/telegram/src/__tests__/app.test.ts","content":"import { describe, expect, it, vi } from \"vitest\";\nimport { createApp } from \"../app.js\";\nimport { createRateLimiter } from \"../rate-limit.js\";\n\ndescribe(\"createApp\", () => {\n  it(\"rejects webhook requests without the configured secret\", async () => {\n    const sendMessage = vi.fn();\n    const app = createApp({\n      webhookSecret: \"telegram-secret\",\n      router: {\n        handleTextCommand: vi.fn(),\n      },\n      sendMessage,\n    });\n\n    const response = await app.request(\"/telegram/webhook\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({\n        update_id: 1,\n        message: {\n          message_id: 1,\n          chat: { id: 22, type: \"private\" },\n          text: \"/start\",\n        },\n      }),\n    });\n\n    expect(response.status).toBe(401);\n    expect(sendMessage).not.toHaveBeenCalled();\n  });\n\n  it(\"handles a Telegram command update and sends the routed response\", async () => {\n    const sendMessage = vi.fn().mockResolvedValue(undefined);\n    const router = {\n      handleTextCommand: vi.fn().mockResolvedValue({\n        chatId: 22,\n        text: \"hello from taunt\",\n      }),\n    };\n    const app = createApp({\n      webhookSecret: \"telegram-secret\",\n      router,\n      sendMessage,\n    });\n\n    const response = await app.request(\"/telegram/webhook\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"X-Telegram-Bot-Api-Secret-Token\": \"telegram-secret\",\n      },\n      body: JSON.stringify({\n        update_id: 1,\n        message: {\n          message_id: 1,\n          from: { id: 99, username: \"tg_user\" },\n          chat: { id: 22, type: \"private\" },\n          text: \"/start\",\n        },\n      }),\n    });\n\n    expect(response.status).toBe(200);\n    expect(router.handleTextCommand).toHaveBeenCalledWith({\n      chatId: 22,\n      text: \"/start\",\n      fromUserId: \"99\",\n      fromUsername: \"tg_user\",\n      isGroup: false,\n    });\n    expect(sendMessage).toHaveBeenCalledWith({\n      chatId: 22,\n      text: \"hello from taunt\",\n    });\n  });\n\n  it(\"sends prelude messages before the main Telegram reply\", async () => {\n    const sendMessage = vi.fn().mockResolvedValue(undefined);\n    const router = {\n      handleTextCommand: vi.fn().mockResolvedValue({\n        chatId: 22,\n        text: \"hello from taunt\",\n        beforeSend: [\n          {\n            kind: \"video\",\n            chatId: 22,\n            video: \"video-file-123\",\n          },\n        ],\n      }),\n    };\n    const app = createApp({\n      webhookSecret: \"telegram-secret\",\n      router,\n      sendMessage,\n    });\n\n    const response = await app.request(\"/telegram/webhook\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"X-Telegram-Bot-Api-Secret-Token\": \"telegram-secret\",\n      },\n      body: JSON.stringify({\n        update_id: 10,\n        message: {\n          message_id: 10,\n          from: { id: 99, username: \"tg_user\" },\n          chat: { id: 22, type: \"private\" },\n          text: \"/start\",\n        },\n      }),\n    });\n\n    expect(response.status).toBe(200);\n    expect(sendMessage).toHaveBeenNthCalledWith(1, {\n      kind: \"video\",\n      chatId: 22,\n      video: \"video-file-123\",\n    });\n    expect(sendMessage).toHaveBeenNthCalledWith(2, {\n      chatId: 22,\n      text: \"hello from taunt\",\n      beforeSend: [\n        {\n          kind: \"video\",\n          chatId: 22,\n          video: \"video-file-123\",\n        },\n      ],\n    });\n  });\n\n  it(\"ignores non-text updates without calling Telegram\", async () => {\n    const sendMessage = vi.fn().mockResolvedValue(undefined);\n    const app = createApp({\n      webhookSecret: \"telegram-secret\",\n      router: {\n        handleTextCommand: vi.fn(),\n      },\n      sendMessage,\n    });\n\n    const response = await app.request(\"/telegram/webhook\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"X-Telegram-Bot-Api-Secret-Token\": \"telegram-secret\",\n      },\n      body: JSON.stringify({\n        update_id: 2,\n        message: {\n          message_id: 2,\n          chat: { id: 22, type: \"private\" },\n        },\n      }),\n    });\n\n    expect(response.status).toBe(200);\n    expect(sendMessage).not.toHaveBeenCalled();\n  });\n\n  it(\"logs inbound animation file ids without routing a command\", async () => {\n    const sendMessage = vi.fn().mockResolvedValue(undefined);\n    const info = vi.fn();\n    const handleTextCommand = vi.fn();\n    const app = createApp({\n      webhookSecret: \"telegram-secret\",\n      mediaDebugChatId: \"22\",\n      mediaDebugUserId: \"99\",\n      router: {\n        handleTextCommand,\n      },\n      sendMessage,\n      logger: {\n        info,\n        error: vi.fn(),\n      },\n    });\n\n    const response = await app.request(\"/telegram/webhook\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"X-Telegram-Bot-Api-Secret-Token\": \"telegram-secret\",\n      },\n      body: JSON.stringify({\n        update_id: 4,\n        message: {\n          message_id: 4,\n          from: { id: 99, username: \"tg_user\" },\n          chat: { id: 22, type: \"private\" },\n          animation: {\n            file_id: \"anim-file-123\",\n            file_unique_id: \"unique-123\",\n            file_name: \"welcome.mp4\",\n            mime_type: \"video/mp4\",\n            file_size: 123456,\n            duration: 5,\n          },\n        },\n      }),\n    });\n\n    expect(response.status).toBe(200);\n    expect(handleTextCommand).not.toHaveBeenCalled();\n    expect(sendMessage).not.toHaveBeenCalled();\n    expect(info).toHaveBeenCalledWith(\"Received Telegram animation media\", {\n      chatId: 22,\n      updateId: 4,\n      fromUserId: \"99\",\n      fileId: \"anim-file-123\",\n      fileName: \"welcome.mp4\",\n      mimeType: \"video/mp4\",\n      fileSize: 123456,\n      durationSeconds: 5,\n    });\n  });\n\n  it(\"logs inbound message shape and document file ids without routing a command\", async () => {\n    const sendMessage = vi.fn().mockResolvedValue(undefined);\n    const info = vi.fn();\n    const handleTextCommand = vi.fn();\n    const app = createApp({\n      webhookSecret: \"telegram-secret\",\n      mediaDebugChatId: \"44\",\n      mediaDebugUserId: \"77\",\n      router: {\n        handleTextCommand,\n      },\n      sendMessage,\n      logger: {\n        info,\n        error: vi.fn(),\n      },\n    });\n\n    const response = await app.request(\"/telegram/webhook\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"X-Telegram-Bot-Api-Secret-Token\": \"telegram-secret\",\n      },\n      body: JSON.stringify({\n        update_id: 5,\n        message: {\n          message_id: 5,\n          from: { id: 77, username: \"tg_doc\" },\n          chat: { id: 44, type: \"private\" },\n          document: {\n            file_id: \"doc-file-123\",\n            file_name: \"welcome.mp4\",\n            mime_type: \"video/mp4\",\n            file_size: 654321,\n          },\n        },\n      }),\n    });\n\n    expect(response.status).toBe(200);\n    expect(handleTextCommand).not.toHaveBeenCalled();\n    expect(sendMessage).not.toHaveBeenCalled();\n    expect(info).toHaveBeenNthCalledWith(1, \"Received Telegram inbound message shape\", {\n      chatId: 44,\n      updateId: 5,\n      fromUserId: \"77\",\n      hasText: false,\n      hasAnimation: false,\n      hasVideo: false,\n      hasDocument: true,\n      hasPhoto: false,\n      hasSticker: false,\n    });\n    expect(info).toHaveBeenNthCalledWith(2, \"Received Telegram document media\", {\n      chatId: 44,\n      updateId: 5,\n      fromUserId: \"77\",\n      fileId: \"doc-file-123\",\n      fileName: \"welcome.mp4\",\n      mimeType: \"video/mp4\",\n      fileSize: 654321,\n    });\n  });\n\n  it(\"does not log media diagnostics for other chats or users\", async () => {\n    const sendMessage = vi.fn().mockResolvedValue(undefined);\n    const info = vi.fn();\n    const handleTextCommand = vi.fn();\n    const app = createApp({\n      webhookSecret: \"telegram-secret\",\n      mediaDebugChatId: \"8574477581\",\n      mediaDebugUserId: \"8574477581\",\n      router: {\n        handleTextCommand,\n      },\n      sendMessage,\n      logger: {\n        info,\n        error: vi.fn(),\n      },\n    });\n\n    const response = await app.request(\"/telegram/webhook\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"X-Telegram-Bot-Api-Secret-Token\": \"telegram-secret\",\n      },\n      body: JSON.stringify({\n        update_id: 6,\n        message: {\n          message_id: 6,\n          from: { id: 99, username: \"tg_user\" },\n          chat: { id: 22, type: \"private\" },\n          video: {\n            file_id: \"video-file-123\",\n            file_name: \"welcome.mp4\",\n            mime_type: \"video/mp4\",\n            file_size: 123456,\n            duration: 5,\n          },\n        },\n      }),\n    });\n\n    expect(response.status).toBe(200);\n    expect(handleTextCommand).not.toHaveBeenCalled();\n    expect(sendMessage).not.toHaveBeenCalled();\n    expect(info).not.toHaveBeenCalled();\n  });\n\n  it(\"returns 200 and logs when Telegram reply delivery fails\", async () => {\n    const sendMessage = vi.fn().mockRejectedValue(new Error(\"chat not found\"));\n    const error = vi.fn();\n    const app = createApp({\n      webhookSecret: \"telegram-secret\",\n      router: {\n        handleTextCommand: vi.fn().mockResolvedValue({\n          chatId: 22,\n          text: \"hello from taunt\",\n        }),\n      },\n      sendMessage,\n      logger: {\n        error,\n      },\n    });\n\n    const response = await app.request(\"/telegram/webhook\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"X-Telegram-Bot-Api-Secret-Token\": \"telegram-secret\",\n      },\n      body: JSON.stringify({\n        update_id: 3,\n        message: {\n          message_id: 3,\n          chat: { id: 22, type: \"private\" },\n          text: \"/start\",\n        },\n      }),\n    });\n\n    expect(response.status).toBe(200);\n    expect(sendMessage).toHaveBeenCalledTimes(1);\n    expect(error).toHaveBeenCalledWith(\n      \"Failed to deliver Telegram reply\",\n      expect.objectContaining({\n        chatId: 22,\n        text: \"/start\",\n      }),\n      expect.any(Error),\n    );\n  });\n\n  it(\"enforces a shared per-chat budget across different users\", async () => {\n    const sendMessage = vi.fn().mockResolvedValue(undefined);\n    const router = {\n      handleTextCommand: vi.fn().mockResolvedValue({\n        chatId: 22,\n        text: \"hello from taunt\",\n      }),\n    };\n    const app = createApp({\n      webhookSecret: \"telegram-secret\",\n      router,\n      sendMessage,\n      rateLimiter: createRateLimiter({\n        windowMs: 10_000,\n        max: 2,\n        now: () => 1_000,\n      }),\n    });\n\n    for (const fromId of [101, 202, 303]) {\n      const response = await app.request(\"/telegram/webhook\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"X-Telegram-Bot-Api-Secret-Token\": \"telegram-secret\",\n        },\n        body: JSON.stringify({\n          update_id: fromId,\n          message: {\n            message_id: fromId,\n            from: { id: fromId, username: `tg_${fromId}` },\n            chat: { id: 22, type: \"group\" },\n            text: \"/start\",\n          },\n        }),\n      });\n\n      expect(response.status).toBe(200);\n    }\n\n    expect(router.handleTextCommand).toHaveBeenCalledTimes(2);\n    expect(sendMessage).toHaveBeenCalledTimes(2);\n    expect(router.handleTextCommand).toHaveBeenNthCalledWith(\n      2,\n      expect.objectContaining({\n        chatId: 22,\n        fromUserId: \"202\",\n        isGroup: true,\n      }),\n    );\n  });\n});\n","numLines":432,"startLine":1,"totalLines":432}}}
