{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019A3M1Ekxxpv6ZWkDRvSekD","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport { createCommandRouter, getBotCommands } from \"../commands.js\";\n3\t\n4\timport type { RedeemLinkResult, ReferralInfo, LeaderboardResult } from \"../commands.js\";\n5\t\n6\tfunction buildRouter(overrides?: {\n7\t  redeemResult?: RedeemLinkResult;\n8\t  communityInviteUrl?: string;\n9\t  supportUsername?: string;\n10\t  botUsername?: string;\n11\t  welcomeVideoFileId?: string;\n12\t  linkedUserId?: string | null;\n13\t  referralInfo?: ReferralInfo | null;\n14\t  leaderboard?: LeaderboardResult | null;\n15\t}) {\n16\t  return createCommandRouter({\n17\t    publicAppUrl: \"https://taunt.bet\",\n18\t    referralPathPrefix: \"/ref\",\n19\t    communityInviteUrl: overrides?.communityInviteUrl,\n20\t    supportUsername: overrides?.supportUsername,\n21\t    botUsername: overrides?.botUsername,\n22\t    welcomeVideoFileId: overrides?.welcomeVideoFileId,\n23\t    backend: {\n24\t      async getLinkedUserId() {\n25\t        return overrides?.linkedUserId ?? null;\n26\t      },\n27\t      async redeemTelegramLink() {\n28\t        return overrides?.redeemResult ?? { ok: false as const, error: \"UNKNOWN\" as const };\n29\t      },\n30\t      async getReferralInfo() {\n31\t        return overrides?.referralInfo ?? null;\n32\t      },\n33\t      async getReferralLeaderboard() {\n34\t        return overrides?.leaderboard ?? null;\n35\t      },\n36\t    },\n37\t  });\n38\t}\n39\t\n40\tfunction cmd(text: string, chatId = 10, isGroup = false) {\n41\t  return { chatId, text, fromUserId: \"12345\", fromUsername: \"test_user\", isGroup };\n42\t}\n43\t\n44\tdescribe(\"createCommandRouter\", () => {\n45\t  it(\"/start shows help text with waitlist and community buttons\", async () => {\n46\t    const router = buildRouter({ communityInviteUrl: \"https://t.me/+abc\" });\n47\t\n48\t    const result = await router.handleTextCommand(cmd(\"/start\"));\n49\t\n50\t    expect(result?.parseMode).toBe(\"HTML\");\n51\t    expect(result?.text).toContain(\"<b>TAUNT Bot</b>\");\n52\t    expect(result?.text).toContain(\"/community\");\n53\t    expect(result?.text).toContain(\"/ref\");\n54\t    expect(result?.text).toContain(\"/leaderboard\");\n55\t    expect(result?.replyMarkup?.inline_keyboard).toEqual([\n56\t      [{ text: \"Join Waitlist\", url: \"https://taunt.bet\" }],\n57\t      [{ text: \"Join Community\", url: \"https://t.me/+abc\" }],\n58\t    ]);\n59\t  });\n60\t\n61\t  it(\"/start adds welcome video before help text when configured\", async () => {\n62\t    const router = buildRouter({\n63\t      communityInviteUrl: \"https://t.me/+abc\",\n64\t      welcomeVideoFileId: \"video-file-123\",\n65\t    });\n66\t\n67\t    const result = await router.handleTextCommand(cmd(\"/start\"));\n68\t\n69\t    expect(result?.beforeSend).toEqual([\n70\t      {\n71\t        kind: \"video\",\n72\t        chatId: 10,\n73\t        video: \"video-file-123\",\n74\t      },\n75\t    ]);\n76\t    expect(result?.text).toContain(\"<b>TAUNT Bot</b>\");\n77\t  });\n78\t\n79\t  it(\"/community shows invite button\", async () => {\n80\t    const router = buildRouter({ communityInviteUrl: \"https://t.me/+abc\" });\n81\t\n82\t    const result = await router.handleTextCommand(cmd(\"/community\"));\n83\t\n84\t    expect(result?.text).toContain(\"TAUNT Community\");\n85\t    expect(result?.replyMarkup?.inline_keyboard).toEqual([\n86\t      [{ text: \"Join Community\", url: \"https://t.me/+abc\" }],\n87\t    ]);\n88\t  });\n89\t\n90\t  it(\"/me shows profile info when linked\", async () => {\n91\t    const router = buildRouter({\n92\t      referralInfo: { userId: \"usr_alice\", username: \"alice\", referralCode: \"alpha\", referredCount: 7 },\n93\t    });\n94\t\n95\t    const result = await router.handleTextCommand(cmd(\"/me\"));\n96\t\n97\t    expect(result?.text).toContain(\"<b>alice</b>\");\n98\t    expect(result?.text).toContain(\"usr_alice\");\n99\t    expect(result?.text).toContain(\"7\");\n100\t    expect(result?.text).toContain(\"taunt.bet/ref/alpha\");\n101\t  });\n102\t\n103\t  it(\"/me shows not-linked when not linked\", async () => {\n104\t    const router = buildRouter();\n105\t\n106\t    const result = await router.handleTextCommand(cmd(\"/me\"));\n107\t\n108\t    expect(result?.text).toContain(\"isn't linked\");\n109\t  });\n110\t\n111\t  it(\"/me in group sends DM with fallback\", async () => {\n112\t    const router = buildRouter({\n113\t      referralInfo: { userId: \"usr_alice\", username: \"alice\", referralCode: \"alpha\", referredCount: 7 },\n114\t      botUsername: \"taunt_bot\",\n115\t    });\n116\t\n117\t    const result = await router.handleTextCommand(cmd(\"/me\", -100999, true));\n118\t\n119\t    // Primary message targets the user's DM\n120\t    expect(result?.chatId).toBe(12345);\n121\t    expect(result?.text).toContain(\"<b>alice</b>\");\n122\t\n123\t    // Fallback targets the group\n124\t    expect(result?.groupFallback?.chatId).toBe(-100999);\n125\t    expect(result?.groupFallback?.text).toContain(\"DM\");\n126\t    expect(result?.groupFallback?.replyMarkup?.inline_keyboard?.[0]?.[0]?.url).toBe(\"https://t.me/taunt_bot\");\n127\t  });\n128\t\n129\t  it(\"/community shows not-configured when no URL\", async () => {\n130\t    const router = buildRouter();\n131\t\n132\t    const result = await router.handleTextCommand(cmd(\"/community\"));\n133\t\n134\t    expect(result?.text).toContain(\"not set up yet\");\n135\t  });\n136\t});\n137\t\n138\tdescribe(\"/ref command\", () => {\n139\t  it(\"shows referral link and count when linked with code\", async () => {\n140\t    const router = buildRouter({\n141\t      referralInfo: { userId: \"usr_alice\", username: \"alice\", referralCode: \"alpha\", referredCount: 7 },\n142\t    });\n143\t\n144\t    const result = await router.handleTextCommand(cmd(\"/ref\"));\n145\t\n146\t    expect(result?.text).toContain(\"taunt.bet/ref/alpha\");\n147\t    expect(result?.text).toContain(\"7\");\n148\t    expect(result?.replyMarkup).toBeUndefined();\n149\t  });\n150\t\n151\t  it(\"shows no-code message when linked without referral code\", async () => {\n152\t    const router = buildRouter({\n153\t      referralInfo: { userId: \"usr_alice\", username: \"alice\", referralCode: null, referredCount: 0 },\n154\t    });\n155\t\n156\t    const result = await router.handleTextCommand(cmd(\"/ref\"));\n157\t\n158\t    expect(result?.text).toContain(\"don't have a referral code\");\n159\t  });\n160\t\n161\t  it(\"shows not-linked message when not linked\", async () => {\n162\t    const router = buildRouter();\n163\t\n164\t    const result = await router.handleTextCommand(cmd(\"/ref\"));\n165\t\n166\t    expect(result?.text).toContain(\"isn't linked\");\n167\t  });\n168\t});\n169\t\n170\tdescribe(\"/leaderboard command\", () => {\n171\t  it(\"shows top referrers and user rank when outside top 10\", async () => {\n172\t    const router = buildRouter({\n173\t      leaderboard: {\n174\t        entries: [\n175\t          { rank: 1, username: \"alice\", count: 50 },\n176\t          { rank: 2, username: \"bob\", count: 30 },\n177\t          { rank: 3, username: \"carol\", count: 20 },\n178\t        ],\n179\t        userRank: 47,\n180\t        userCount: 3,\n181\t      },\n182\t    });\n183\t\n184\t    const result = await router.handleTextCommand(cmd(\"/leaderboard\"));\n185\t\n186\t    expect(result?.text).toContain(\"<b>Top Referrers</b>\");\n187\t    expect(result?.text).toContain(\"<b>alice</b>\");\n188\t    expect(result?.text).toContain(\"50 referrals\");\n189\t    expect(result?.text).toContain(\"<b>bob</b>\");\n190\t    expect(result?.text).toContain(\"You: <b>#47</b>\");\n191\t    expect(result?.text).toContain(\"3 referrals\");\n192\t  });\n193\t\n194\t  it(\"does not show user rank when in top 10\", async () => {\n195\t    const router = buildRouter({\n196\t      leaderboard: {\n197\t        entries: [{ rank: 1, username: \"me\", count: 10 }],\n198\t        userRank: 1,\n199\t        userCount: 10,\n200\t      },\n201\t    });\n202\t\n203\t    const result = await router.handleTextCommand(cmd(\"/leaderboard\"));\n204\t\n205\t    expect(result?.text).not.toContain(\"You:\");\n206\t  });\n207\t\n208\t  it(\"shows empty message when no referrals\", async () => {\n209\t    const router = buildRouter({\n210\t      leaderboard: { entries: [], userRank: null, userCount: 0 },\n211\t    });\n212\t\n213\t    const result = await router.handleTextCommand(cmd(\"/leaderboard\"));\n214\t\n215\t    expect(result?.text).toContain(\"No referrals yet\");\n216\t  });\n217\t});\n218\t\n219\tdescribe(\"/help command\", () => {\n220\t  it(\"shows support button when username configured\", async () => {\n221\t    const router = buildRouter({ supportUsername: \"taunt_support\" });\n222\t\n223\t    const result = await router.handleTextCommand(cmd(\"/help\"));\n224\t\n225\t    expect(result?.text).toContain(\"Contact @TAUNT_bet for help.\");\n226\t    expect(result?.replyMarkup?.inline_keyboard).toEqual([\n227\t      [{ text: \"Contact @TAUNT_bet\", url: \"https://t.me/taunt_support\" }],\n228\t    ]);\n229\t  });\n230\t\n231\t  it(\"shows not-configured when no support username\", async () => {\n232\t    const router = buildRouter();\n233\t\n234\t    const result = await router.handleTextCommand(cmd(\"/help\"));\n235\t\n236\t    expect(result?.text).toContain(\"Contact @TAUNT_bet for help.\");\n237\t  });\n238\t});\n239\t\n240\tdescribe(\"deep-link /start <token>\", () => {\n241\t  it(\"sends welcome on successful link\", async () => {\n242\t    const router = buildRouter({\n243\t      redeemResult: { ok: true, userId: \"usr_abc\", username: \"CoolPlayer\", alreadyLinked: false },\n244\t      communityInviteUrl: \"https://t.me/+invite123\",\n245\t      welcomeVideoFileId: \"video-file-123\",\n246\t    });\n247\t\n248\t    const result = await router.handleTextCommand(cmd(\"/start abc123token\"));\n249\t\n250\t    expect(result?.text).toContain(\"<b>CoolPlayer</b>\");\n251\t    expect(result?.text).toContain(\"linked to TAUNT\");\n252\t    expect(result?.replyMarkup?.inline_keyboard).toEqual([\n253\t      [{ text: \"Join Waitlist\", url: \"https://taunt.bet\" }],\n254\t      [{ text: \"Join Community\", url: \"https://t.me/+invite123\" }],\n255\t    ]);\n256\t    expect(result?.beforeSend).toEqual([\n257\t      {\n258\t        kind: \"video\",\n259\t        chatId: 10,\n260\t        video: \"video-file-123\",\n261\t      },\n262\t    ]);\n263\t  });\n264\t\n265\t  it(\"shows already-linked message\", async () => {\n266\t    const router = buildRouter({\n267\t      redeemResult: { ok: true, userId: \"usr_abc\", username: \"CoolPlayer\", alreadyLinked: true },\n268\t    });\n269\t\n270\t    const result = await router.handleTextCommand(cmd(\"/start abc123token\"));\n271\t\n272\t    expect(result?.text).toContain(\"already linked\");\n273\t  });\n274\t\n275\t  it(\"shows expired/invalid message for bad token\", async () => {\n276\t    const router = buildRouter({\n277\t      redeemResult: { ok: false, error: \"TOKEN_NOT_FOUND\" },\n278\t    });\n279\t\n280\t    const result = await router.handleTextCommand(cmd(\"/start badtoken\"));\n281\t\n282\t    expect(result?.text).toContain(\"invalid or has expired\");\n283\t  });\n284\t});\n285\t\n286\tdescribe(\"getBotCommands\", () => {\n287\t  it(\"returns the pre-launch command menu\", () => {\n288\t    expect(getBotCommands()).toEqual([\n289\t      { command: \"start\", description: \"Welcome + link your account\" },\n290\t      { command: \"me\", description: \"Your linked TAUNT profile\" },\n291\t      { command: \"community\", description: \"Join the TAUNT community channel\" },\n292\t      { command: \"ref\", description: \"Your referral link + stats\" },\n293\t      { command: \"leaderboard\", description: \"Top 10 referrers\" },\n294\t      { command: \"help\", description: \"Contact @TAUNT_bet for help\" },\n295\t    ]);\n296\t  });\n297\t});\n298\t"}]},"parent_tool_use_id":null,"session_id":"4cb6afe9-ffc2-4d89-84e3-9539172afcc4","uuid":"f90bf6ed-6b37-400d-9397-b5270a2fb859","timestamp":"2026-04-22T11:09:19.418Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/telegram/src/__tests__/commands.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport { createCommandRouter, getBotCommands } from \"../commands.js\";\n\nimport type { RedeemLinkResult, ReferralInfo, LeaderboardResult } from \"../commands.js\";\n\nfunction buildRouter(overrides?: {\n  redeemResult?: RedeemLinkResult;\n  communityInviteUrl?: string;\n  supportUsername?: string;\n  botUsername?: string;\n  welcomeVideoFileId?: string;\n  linkedUserId?: string | null;\n  referralInfo?: ReferralInfo | null;\n  leaderboard?: LeaderboardResult | null;\n}) {\n  return createCommandRouter({\n    publicAppUrl: \"https://taunt.bet\",\n    referralPathPrefix: \"/ref\",\n    communityInviteUrl: overrides?.communityInviteUrl,\n    supportUsername: overrides?.supportUsername,\n    botUsername: overrides?.botUsername,\n    welcomeVideoFileId: overrides?.welcomeVideoFileId,\n    backend: {\n      async getLinkedUserId() {\n        return overrides?.linkedUserId ?? null;\n      },\n      async redeemTelegramLink() {\n        return overrides?.redeemResult ?? { ok: false as const, error: \"UNKNOWN\" as const };\n      },\n      async getReferralInfo() {\n        return overrides?.referralInfo ?? null;\n      },\n      async getReferralLeaderboard() {\n        return overrides?.leaderboard ?? null;\n      },\n    },\n  });\n}\n\nfunction cmd(text: string, chatId = 10, isGroup = false) {\n  return { chatId, text, fromUserId: \"12345\", fromUsername: \"test_user\", isGroup };\n}\n\ndescribe(\"createCommandRouter\", () => {\n  it(\"/start shows help text with waitlist and community buttons\", async () => {\n    const router = buildRouter({ communityInviteUrl: \"https://t.me/+abc\" });\n\n    const result = await router.handleTextCommand(cmd(\"/start\"));\n\n    expect(result?.parseMode).toBe(\"HTML\");\n    expect(result?.text).toContain(\"<b>TAUNT Bot</b>\");\n    expect(result?.text).toContain(\"/community\");\n    expect(result?.text).toContain(\"/ref\");\n    expect(result?.text).toContain(\"/leaderboard\");\n    expect(result?.replyMarkup?.inline_keyboard).toEqual([\n      [{ text: \"Join Waitlist\", url: \"https://taunt.bet\" }],\n      [{ text: \"Join Community\", url: \"https://t.me/+abc\" }],\n    ]);\n  });\n\n  it(\"/start adds welcome video before help text when configured\", async () => {\n    const router = buildRouter({\n      communityInviteUrl: \"https://t.me/+abc\",\n      welcomeVideoFileId: \"video-file-123\",\n    });\n\n    const result = await router.handleTextCommand(cmd(\"/start\"));\n\n    expect(result?.beforeSend).toEqual([\n      {\n        kind: \"video\",\n        chatId: 10,\n        video: \"video-file-123\",\n      },\n    ]);\n    expect(result?.text).toContain(\"<b>TAUNT Bot</b>\");\n  });\n\n  it(\"/community shows invite button\", async () => {\n    const router = buildRouter({ communityInviteUrl: \"https://t.me/+abc\" });\n\n    const result = await router.handleTextCommand(cmd(\"/community\"));\n\n    expect(result?.text).toContain(\"TAUNT Community\");\n    expect(result?.replyMarkup?.inline_keyboard).toEqual([\n      [{ text: \"Join Community\", url: \"https://t.me/+abc\" }],\n    ]);\n  });\n\n  it(\"/me shows profile info when linked\", async () => {\n    const router = buildRouter({\n      referralInfo: { userId: \"usr_alice\", username: \"alice\", referralCode: \"alpha\", referredCount: 7 },\n    });\n\n    const result = await router.handleTextCommand(cmd(\"/me\"));\n\n    expect(result?.text).toContain(\"<b>alice</b>\");\n    expect(result?.text).toContain(\"usr_alice\");\n    expect(result?.text).toContain(\"7\");\n    expect(result?.text).toContain(\"taunt.bet/ref/alpha\");\n  });\n\n  it(\"/me shows not-linked when not linked\", async () => {\n    const router = buildRouter();\n\n    const result = await router.handleTextCommand(cmd(\"/me\"));\n\n    expect(result?.text).toContain(\"isn't linked\");\n  });\n\n  it(\"/me in group sends DM with fallback\", async () => {\n    const router = buildRouter({\n      referralInfo: { userId: \"usr_alice\", username: \"alice\", referralCode: \"alpha\", referredCount: 7 },\n      botUsername: \"taunt_bot\",\n    });\n\n    const result = await router.handleTextCommand(cmd(\"/me\", -100999, true));\n\n    // Primary message targets the user's DM\n    expect(result?.chatId).toBe(12345);\n    expect(result?.text).toContain(\"<b>alice</b>\");\n\n    // Fallback targets the group\n    expect(result?.groupFallback?.chatId).toBe(-100999);\n    expect(result?.groupFallback?.text).toContain(\"DM\");\n    expect(result?.groupFallback?.replyMarkup?.inline_keyboard?.[0]?.[0]?.url).toBe(\"https://t.me/taunt_bot\");\n  });\n\n  it(\"/community shows not-configured when no URL\", async () => {\n    const router = buildRouter();\n\n    const result = await router.handleTextCommand(cmd(\"/community\"));\n\n    expect(result?.text).toContain(\"not set up yet\");\n  });\n});\n\ndescribe(\"/ref command\", () => {\n  it(\"shows referral link and count when linked with code\", async () => {\n    const router = buildRouter({\n      referralInfo: { userId: \"usr_alice\", username: \"alice\", referralCode: \"alpha\", referredCount: 7 },\n    });\n\n    const result = await router.handleTextCommand(cmd(\"/ref\"));\n\n    expect(result?.text).toContain(\"taunt.bet/ref/alpha\");\n    expect(result?.text).toContain(\"7\");\n    expect(result?.replyMarkup).toBeUndefined();\n  });\n\n  it(\"shows no-code message when linked without referral code\", async () => {\n    const router = buildRouter({\n      referralInfo: { userId: \"usr_alice\", username: \"alice\", referralCode: null, referredCount: 0 },\n    });\n\n    const result = await router.handleTextCommand(cmd(\"/ref\"));\n\n    expect(result?.text).toContain(\"don't have a referral code\");\n  });\n\n  it(\"shows not-linked message when not linked\", async () => {\n    const router = buildRouter();\n\n    const result = await router.handleTextCommand(cmd(\"/ref\"));\n\n    expect(result?.text).toContain(\"isn't linked\");\n  });\n});\n\ndescribe(\"/leaderboard command\", () => {\n  it(\"shows top referrers and user rank when outside top 10\", async () => {\n    const router = buildRouter({\n      leaderboard: {\n        entries: [\n          { rank: 1, username: \"alice\", count: 50 },\n          { rank: 2, username: \"bob\", count: 30 },\n          { rank: 3, username: \"carol\", count: 20 },\n        ],\n        userRank: 47,\n        userCount: 3,\n      },\n    });\n\n    const result = await router.handleTextCommand(cmd(\"/leaderboard\"));\n\n    expect(result?.text).toContain(\"<b>Top Referrers</b>\");\n    expect(result?.text).toContain(\"<b>alice</b>\");\n    expect(result?.text).toContain(\"50 referrals\");\n    expect(result?.text).toContain(\"<b>bob</b>\");\n    expect(result?.text).toContain(\"You: <b>#47</b>\");\n    expect(result?.text).toContain(\"3 referrals\");\n  });\n\n  it(\"does not show user rank when in top 10\", async () => {\n    const router = buildRouter({\n      leaderboard: {\n        entries: [{ rank: 1, username: \"me\", count: 10 }],\n        userRank: 1,\n        userCount: 10,\n      },\n    });\n\n    const result = await router.handleTextCommand(cmd(\"/leaderboard\"));\n\n    expect(result?.text).not.toContain(\"You:\");\n  });\n\n  it(\"shows empty message when no referrals\", async () => {\n    const router = buildRouter({\n      leaderboard: { entries: [], userRank: null, userCount: 0 },\n    });\n\n    const result = await router.handleTextCommand(cmd(\"/leaderboard\"));\n\n    expect(result?.text).toContain(\"No referrals yet\");\n  });\n});\n\ndescribe(\"/help command\", () => {\n  it(\"shows support button when username configured\", async () => {\n    const router = buildRouter({ supportUsername: \"taunt_support\" });\n\n    const result = await router.handleTextCommand(cmd(\"/help\"));\n\n    expect(result?.text).toContain(\"Contact @TAUNT_bet for help.\");\n    expect(result?.replyMarkup?.inline_keyboard).toEqual([\n      [{ text: \"Contact @TAUNT_bet\", url: \"https://t.me/taunt_support\" }],\n    ]);\n  });\n\n  it(\"shows not-configured when no support username\", async () => {\n    const router = buildRouter();\n\n    const result = await router.handleTextCommand(cmd(\"/help\"));\n\n    expect(result?.text).toContain(\"Contact @TAUNT_bet for help.\");\n  });\n});\n\ndescribe(\"deep-link /start <token>\", () => {\n  it(\"sends welcome on successful link\", async () => {\n    const router = buildRouter({\n      redeemResult: { ok: true, userId: \"usr_abc\", username: \"CoolPlayer\", alreadyLinked: false },\n      communityInviteUrl: \"https://t.me/+invite123\",\n      welcomeVideoFileId: \"video-file-123\",\n    });\n\n    const result = await router.handleTextCommand(cmd(\"/start abc123token\"));\n\n    expect(result?.text).toContain(\"<b>CoolPlayer</b>\");\n    expect(result?.text).toContain(\"linked to TAUNT\");\n    expect(result?.replyMarkup?.inline_keyboard).toEqual([\n      [{ text: \"Join Waitlist\", url: \"https://taunt.bet\" }],\n      [{ text: \"Join Community\", url: \"https://t.me/+invite123\" }],\n    ]);\n    expect(result?.beforeSend).toEqual([\n      {\n        kind: \"video\",\n        chatId: 10,\n        video: \"video-file-123\",\n      },\n    ]);\n  });\n\n  it(\"shows already-linked message\", async () => {\n    const router = buildRouter({\n      redeemResult: { ok: true, userId: \"usr_abc\", username: \"CoolPlayer\", alreadyLinked: true },\n    });\n\n    const result = await router.handleTextCommand(cmd(\"/start abc123token\"));\n\n    expect(result?.text).toContain(\"already linked\");\n  });\n\n  it(\"shows expired/invalid message for bad token\", async () => {\n    const router = buildRouter({\n      redeemResult: { ok: false, error: \"TOKEN_NOT_FOUND\" },\n    });\n\n    const result = await router.handleTextCommand(cmd(\"/start badtoken\"));\n\n    expect(result?.text).toContain(\"invalid or has expired\");\n  });\n});\n\ndescribe(\"getBotCommands\", () => {\n  it(\"returns the pre-launch command menu\", () => {\n    expect(getBotCommands()).toEqual([\n      { command: \"start\", description: \"Welcome + link your account\" },\n      { command: \"me\", description: \"Your linked TAUNT profile\" },\n      { command: \"community\", description: \"Join the TAUNT community channel\" },\n      { command: \"ref\", description: \"Your referral link + stats\" },\n      { command: \"leaderboard\", description: \"Top 10 referrers\" },\n      { command: \"help\", description: \"Contact @TAUNT_bet for help\" },\n    ]);\n  });\n});\n","numLines":298,"startLine":1,"totalLines":298}}}
