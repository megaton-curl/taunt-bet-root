{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TkM17UJKK39fWRvMvF6wnG","type":"tool_result","content":"1\t/**\n2\t * Public profile routes — unauthenticated lookup by user_id or username.\n3\t */\n4\t\n5\timport { createRoute, z } from \"@hono/zod-openapi\";\n6\timport type { Db } from \"../db.js\";\n7\timport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n8\timport {\n9\t  envelope,\n10\t  ErrorEnvelopeSchema,\n11\t  ok,\n12\t  err,\n13\t} from \"../contracts/api-envelope.js\";\n14\timport { PublicPlayerProfileSchema } from \"../contracts/validators.js\";\n15\timport { logger } from \"../logger.js\";\n16\timport { createOpenApiApp } from \"../openapi/hono.js\";\n17\t\n18\texport interface PublicProfileRoutesDeps {\n19\t  db: Db;\n20\t}\n21\t\n22\texport function createPublicProfileRoutes(deps: PublicProfileRoutesDeps) {\n23\t  const { db } = deps;\n24\t  const app = createOpenApiApp();\n25\t\n26\t  // GET /:identifier — public profile lookup (no auth)\n27\t  const getPublicProfile = createRoute({\n28\t    method: \"get\",\n29\t    path: \"/{identifier}\",\n30\t    tags: [\"Profile\"],\n31\t    summary: \"Get public profile by user ID or username\",\n32\t    request: {\n33\t      params: z.object({\n34\t        identifier: z.string().openapi({ description: \"User ID (usr_xxxxxxxx) or username\" }),\n35\t      }),\n36\t    },\n37\t    responses: {\n38\t      200: {\n39\t        content: { \"application/json\": { schema: envelope(PublicPlayerProfileSchema) } },\n40\t        description: \"Public profile with limited stats\",\n41\t      },\n42\t      404: {\n43\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n44\t        description: \"Profile not found\",\n45\t      },\n46\t      500: {\n47\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n48\t        description: \"Failed to fetch profile\",\n49\t      },\n50\t    },\n51\t  });\n52\t\n53\t  app.openapi(getPublicProfile, async (c) => {\n54\t    const { identifier } = c.req.valid(\"param\");\n55\t\n56\t    try {\n57\t      const profile = await db.getProfileByIdentifier(identifier);\n58\t      if (!profile) {\n59\t        return err(c, 404, API_ERROR_CODES.NOT_FOUND, \"Profile not found\");\n60\t      }\n61\t\n62\t      const publicStats = await db.getPublicPlayerStatsByUserId(profile.user_id);\n63\t\n64\t      return ok(c, {\n65\t        userId: profile.user_id,\n66\t        username: profile.username,\n67\t        avatarUrl: profile.avatar_url,\n68\t        heatMultiplier: profile.heat_multiplier,\n69\t        stats: {\n70\t          gamesPlayed: publicStats.gamesPlayed,\n71\t          totalWins: publicStats.totalWins,\n72\t          winRate: publicStats.winRate,\n73\t        },\n74\t        createdAt: profile.created_at.toISOString(),\n75\t      });\n76\t    } catch (lookupError) {\n77\t      logger.error(\"public-profile lookup failed\", {\n78\t        identifier,\n79\t        error: lookupError instanceof Error ? lookupError.message : \"Unknown error\",\n80\t      });\n81\t      return err(\n82\t        c,\n83\t        500,\n84\t        API_ERROR_CODES.PRECONDITION_FAILED,\n85\t        \"Failed to fetch profile\",\n86\t      );\n87\t    }\n88\t  });\n89\t\n90\t  return app;\n91\t}\n92\t"}]},"parent_tool_use_id":null,"session_id":"ea182426-3468-4ae1-8ebd-e6f6cd94f8d2","uuid":"eca6b01a-b2d7-44ba-a49f-e196fbc2fbfc","timestamp":"2026-04-22T10:28:54.743Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/public-profile.ts","content":"/**\n * Public profile routes — unauthenticated lookup by user_id or username.\n */\n\nimport { createRoute, z } from \"@hono/zod-openapi\";\nimport type { Db } from \"../db.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport { PublicPlayerProfileSchema } from \"../contracts/validators.js\";\nimport { logger } from \"../logger.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface PublicProfileRoutesDeps {\n  db: Db;\n}\n\nexport function createPublicProfileRoutes(deps: PublicProfileRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp();\n\n  // GET /:identifier — public profile lookup (no auth)\n  const getPublicProfile = createRoute({\n    method: \"get\",\n    path: \"/{identifier}\",\n    tags: [\"Profile\"],\n    summary: \"Get public profile by user ID or username\",\n    request: {\n      params: z.object({\n        identifier: z.string().openapi({ description: \"User ID (usr_xxxxxxxx) or username\" }),\n      }),\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: envelope(PublicPlayerProfileSchema) } },\n        description: \"Public profile with limited stats\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Profile not found\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch profile\",\n      },\n    },\n  });\n\n  app.openapi(getPublicProfile, async (c) => {\n    const { identifier } = c.req.valid(\"param\");\n\n    try {\n      const profile = await db.getProfileByIdentifier(identifier);\n      if (!profile) {\n        return err(c, 404, API_ERROR_CODES.NOT_FOUND, \"Profile not found\");\n      }\n\n      const publicStats = await db.getPublicPlayerStatsByUserId(profile.user_id);\n\n      return ok(c, {\n        userId: profile.user_id,\n        username: profile.username,\n        avatarUrl: profile.avatar_url,\n        heatMultiplier: profile.heat_multiplier,\n        stats: {\n          gamesPlayed: publicStats.gamesPlayed,\n          totalWins: publicStats.totalWins,\n          winRate: publicStats.winRate,\n        },\n        createdAt: profile.created_at.toISOString(),\n      });\n    } catch (lookupError) {\n      logger.error(\"public-profile lookup failed\", {\n        identifier,\n        error: lookupError instanceof Error ? lookupError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch profile\",\n      );\n    }\n  });\n\n  return app;\n}\n","numLines":92,"startLine":1,"totalLines":92}}}
