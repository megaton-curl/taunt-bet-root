leted).toBe(0);\n      expect(data.daily.bonus.status).toBe(\"active\");\n      expect(data.daily.bonus.reward).toHaveProperty(\"type\");\n\n      expect(data.weekly).toBeDefined();\n      expect(data.weekly.challenges).toHaveLength(2);\n      expect(data.weekly.resetsAt).toBeDefined();\n      for (const challenge of data.weekly.challenges) {\n        expect(challenge.status).toBe(\"active\");\n        expect(challenge.progress).toBe(0);\n      }\n\n      expect(data.onboarding).toBeDefined();\n      expect(data.onboarding).not.toBeNull();\n      expect(data.onboarding.completed).toBe(false);\n      expect(data.onboarding.steps).toBeDefined();\n      expect(data.onboarding.steps.length).toBeGreaterThanOrEqual(1);\n      expect(data.onboarding.steps[0].locked).toBe(false);\n      if (data.onboarding.steps.length > 1) {\n        expect(data.onboarding.steps[1].locked).toBe(true);\n      }\n\n      const assignments = await rawSql<{ period_key: string }[]>`\n        SELECT period_key FROM challenge_assignments WHERE user_id = ${testUserId}\n      `;\n      const dailyCount = assignments.filter(\n        (assignment) => assignment.period_key === dailyPeriodKey(),\n      ).length;\n      const weeklyCount = assignments.filter(\n        (assignment) => assignment.period_key === weeklyPeriodKey(),\n      ).length;\n      const onboardingCount = assignments.filter(\n        (assignment) => assignment.period_key === \"onboarding\",\n      ).length;\n      expect(dailyCount).toBe(3);\n      expect(weeklyCount).toBe(2);\n      expect(onboardingCount).toBe(1);\n    });\n\n    it(\"second call returns the same assignments without duplicates\", async () => {\n      const token = await makeJwt(testWallet, testUserId);\n\n      await app.request(\"/challenges/mine\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      const res = await app.request(\"/challenges/mine\", {\n        method: \"GET\",\n        headers: { Authorization: