d, threshold\n        FROM challenges\n        WHERE is_active = true\n        ORDER BY sort_order ASC\n        LIMIT 3\n      `;\n\n      for (let i = 0; i < 3; i++) {\n        await rawSql`\n          INSERT INTO challenge_assignments (\n            user_id,\n            challenge_id,\n            period_key,\n            target,\n            status,\n            progress,\n            completed_at\n          )\n          VALUES (\n            ${testUserId},\n            ${challenges[i]!.id},\n            ${`daily:2026-01-0${i + 1}`},\n            ${challenges[i]!.threshold},\n            'completed',\n            ${challenges[i]!.threshold},\n            ${new Date(Date.UTC(2026, 0, i + 1)).toISOString()}\n          )\n        `;\n      }\n\n      const token = await makeJwt(testWallet, testUserId);\n\n      const res1 = await app.request(\"/challenges/mine/history?limit=2\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n      expect(res1.status).toBe(200);\n      const body1 = (await res1.json()) as Record<string, any>;\n      expect(body1.items).toHaveLength(2);\n      expect(body1.items[0]).toHaveProperty(\"id\");\n      expect(body1.items[0]).toHaveProperty(\"title\");\n      expect(body1.items[0]).toHaveProperty(\"description\");\n      expect(body1.items[0]).toHaveProperty(\"completedAt\");\n      expect(body1.items[0]).toHaveProperty(\"reward\");\n      expect(body1.items[0].reward).toHaveProperty(\"type\");\n      expect(body1.nextCursor).not.toBeNull();\n\n      const res2 = await app.request(\n        `/challenges/mine/history?limit=2&cursor=${body1.nextCursor}`,\n        {\n          method: \"GET\",\n          headers: { Authorization: `Bearer ${token}` },\n        },\n      );\n      expect(res2.status).toBe(200);\n      const body2 = (await res2.json()) as Record<string, any>;\n      expect(body2.items).toHaveLength(1);\n      expect(body2.nextCursor).toBeNull();\n    });\n\n    it(\"ignores active assignments\", async () => {\n      const challenges = await rawSql<{ id: string; threshold: number }[]>`\n        SELECT id, threshold\n        FROM challenges\n        WHERE is_active = true\n        ORDER BY sort_order ASC\n        LIMIT 1\n      `;\n      await rawSql`\n        INSERT INTO challenge_assignments (\n          user_id,\n          challenge_id,\n          period_key,\n          target,\n          status\n        )\n        VALUES (${testUserId}, ${challenges[0]!.id}, 'daily:2026-01-01', ${challenges[0]!.threshold}, 'active')\n      `;\n\n      const token = await makeJwt(testWallet, testUserId);\n      const res = await app.request(\"/challenges/mine/history\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as Record<string, any>;\n      expect(body.items).toHaveLength(0);\n      expect(body.nextCursor).toBeNull();\n    });\n  });\n});\n","numLines":309,"startLine":1,"totalLines":309}}}
