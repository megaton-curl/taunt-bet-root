{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01645pQ8gxWWdfYw3qewnKW7","type":"tool_result","content":"1\t/**\n2\t * Challenge routes — player-facing challenge/quest endpoints.\n3\t *\n4\t * GET /mine           — returns active daily, weekly, and onboarding challenges\n5\t *                       with lazy assignment on first call per period.\n6\t * GET /mine/history   — paginated completed challenge assignments.\n7\t */\n8\t\n9\timport { createRoute } from \"@hono/zod-openapi\";\n10\timport { z } from \"zod\";\n11\timport type { AppEnv } from \"../hono-env.js\";\n12\timport type { Db } from \"../db.js\";\n13\timport { logger } from \"../logger.js\";\n14\timport { readRewardConfig } from \"../queue/handlers/reward-pool-fund.js\";\n15\timport {\n16\t  ChallengeAssignmentSchema,\n17\t  ChallengeHistoryEntrySchema,\n18\t  CompletionBonusSchema,\n19\t  ErrorResponseSchema,\n20\t} from \"../contracts/validators.js\";\n21\timport { createOpenApiApp } from \"../openapi/hono.js\";\n22\t\n23\t// Inferred types for handler return value typing\n24\ttype CompletionBonusType = z.infer<typeof CompletionBonusSchema>;\n25\ttype ChallengeAssignmentType = z.infer<typeof ChallengeAssignmentSchema>;\n26\ttype OnboardingStepType = ChallengeAssignmentType & { locked: boolean };\n27\ttype OnboardingType = { steps: OnboardingStepType[]; completed: boolean } | null;\n28\t\n29\t// ---------------------------------------------------------------------------\n30\t// Types\n31\t// ---------------------------------------------------------------------------\n32\t\n33\texport interface ChallengeRoutesDeps {\n34\t  db: Db;\n35\t}\n36\t\n37\tinterface ChallengeRow {\n38\t  id: string;\n39\t  campaign_id: string;\n40\t  title: string;\n41\t  description: string;\n42\t  action: string;\n43\t  scope: string;\n44\t  condition: string;\n45\t  threshold: number;\n46\t  reward_type: string;\n47\t  reward_amount: number | null;\n48\t  sort_order: number;\n49\t  prerequisite_id: string | null;\n50\t}\n51\t\n52\tinterface AssignmentRow {\n53\t  id: string;\n54\t  challenge_id: string;\n55\t  period_key: string;\n56\t  status: string;\n57\t  progress: number;\n58\t  target: number;\n59\t  expires_at: string | null;\n60\t  completed_at: string | null;\n61\t  title: string;\n62\t  description: string;\n63\t  reward_type: string;\n64\t  reward_amount: number | null;\n65\t  campaign_type: string;\n66\t}\n67\t\n68\tinterface CompletionBonusRow {\n69\t  id: string;\n70\t  title: string;\n71\t  required_count: number;\n72\t  reward_type: string;\n73\t  reward_amount: number | null;\n74\t}\n75\t\n76\tinterface BonusCompletionRow {\n77\t  id: string;\n78\t}\n79\t\n80\t// ---------------------------------------------------------------------------\n81\t// Period key helpers\n82\t// ---------------------------------------------------------------------------\n83\t\n84\t/** Returns \"daily:YYYY-MM-DD\" for the current UTC date. */\n85\texport function dailyPeriodKey(now?: Date): string {\n86\t  const d = now ?? new Date();\n87\t  return `daily:${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, \"0\")}-${String(d.getUTCDate()).padStart(2, \"0\")}`;\n88\t}\n89\t\n90\t/** Returns \"weekly:YYYY-Www\" for the current ISO week. */\n91\texport function weeklyPeriodKey(now?: Date): string {\n92\t  const d = now ?? new Date();\n93\t  // ISO week calculation\n94\t  const tmp = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()));\n95\t  tmp.setUTCDate(tmp.getUTCDate() + 4 - (tmp.getUTCDay() || 7));\n96\t  const yearStart = new Date(Date.UTC(tmp.getUTCFullYear(), 0, 1));\n97\t  const weekNo = Math.ceil(((tmp.getTime() - yearStart.getTime()) / 86400000 + 1) / 7);\n98\t  return `weekly:${tmp.getUTCFullYear()}-W${String(weekNo).padStart(2, \"0\")}`;\n99\t}\n100\t\n101\t/** Returns midnight UTC of the next day (daily reset). */\n102\texport function dailyResetsAt(now?: Date): string {\n103\t  const d = now ?? new Date();\n104\t  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + 1));\n105\t  return next.toISOString();\n106\t}\n107\t\n108\t/** Returns midnight UTC of next Monday (weekly reset). */\n109\texport function weeklyResetsAt(now?: Date): string {\n110\t  const d = now ?? new Date();\n111\t  const dayOfWeek = d.getUTCDay(); // 0=Sun, 1=Mon, ...\n112\t  const daysUntilMonday = dayOfWeek === 0 ? 1 : 8 - dayOfWeek;\n113\t  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + daysUntilMonday));\n114\t  return next.toISOString();\n115\t}\n116\t\n117\t// ---------------------------------------------------------------------------\n118\t// DB helpers\n119\t// ---------------------------------------------------------------------------\n120\t\n121\t/** Expire stale assignments (expires_at < now AND status='active'). */\n122\tasync function expireStaleAssignments(db: Db, userId: string): Promise<void> {\n123\t  await db.rawSql`\n124\t    UPDATE challenge_assignments\n125\t    SET status = 'expired'\n126\t    WHERE user_id = ${userId}\n127\t      AND status = 'active'\n128\t      AND expires_at IS NOT NULL\n129\t      AND expires_at < now()\n130\t  `;\n131\t}\n132\t\n133\t/** Get assignments for a user in a given period, joined with challenge metadata. */\n134\tasync function getAssignmentsForPeriod(\n135\t  db: Db,\n136\t  userId: string,\n137\t  periodKey: string,\n138\t): Promise<AssignmentRow[]> {\n139\t  return db.rawSql<AssignmentRow[]>`\n140\t    SELECT\n141\t      ca.id,\n142\t      ca.challenge_id,\n143\t      ca.period_key,\n144\t      ca.status,\n145\t      ca.progress,\n146\t      ca.target,\n147\t      ca.expires_at,\n148\t      ca.completed_at,\n149\t      c.title,\n150\t      c.description,\n151\t      c.reward_type,\n152\t      c.reward_amount,\n153\t      camp.campaign_type\n154\t    FROM challenge_assignments ca\n155\t    JOIN challenges c ON c.id = ca.challenge_id\n156\t    JOIN campaigns camp ON camp.id = c.campaign_id\n157\t    WHERE ca.user_id = ${userId}\n158\t      AND ca.period_key = ${periodKey}\n159\t    ORDER BY c.sort_order ASC\n160\t  `;\n161\t}\n162\t\n163\t/** Get top N active challenges for a campaign, ordered by sort_order ASC. */\n164\tasync function getActiveChallengesBySort(\n165\t  db: Db,\n166\t  campaignId: string,\n167\t  limit: number,\n168\t): Promise<ChallengeRow[]> {\n169\t  return db.rawSql<ChallengeRow[]>`\n170\t    SELECT id, campaign_id, title, description, action, scope, condition,\n171\t           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n172\t    FROM challenges\n173\t    WHERE campaign_id = ${campaignId}\n174\t      AND is_active = true\n175\t    ORDER BY sort_order ASC\n176\t    LIMIT ${limit}\n177\t  `;\n178\t}\n179\t\n180\t/** Get the campaign ID for a given campaign type. */\n181\tasync function getCampaignByType(\n182\t  db: Db,\n183\t  campaignType: string,\n184\t): Promise<{ id: string } | null> {\n185\t  const rows = await db.rawSql<{ id: string }[]>`\n186\t    SELECT id FROM campaigns\n187\t    WHERE campaign_type = ${campaignType}\n188\t      AND is_active = true\n189\t    ORDER BY id ASC\n190\t    LIMIT 1\n191\t  `;\n192\t  return rows[0] ?? null;\n193\t}\n194\t\n195\t/** Get all onboarding assignments for a user (any status). */\n196\tasync function getOnboardingAssignments(\n197\t  db: Db,\n198\t  userId: string,\n199\t): Promise<AssignmentRow[]> {\n200\t  return db.rawSql<AssignmentRow[]>`\n201\t    SELECT\n202\t      ca.id,\n203\t      ca.challenge_id,\n204\t      ca.period_key,\n205\t      ca.status,\n206\t      ca.progress,\n207\t      ca.target,\n208\t      ca.expires_at,\n209\t      ca.completed_at,\n210\t      c.title,\n211\t      c.description,\n212\t      c.reward_type,\n213\t      c.reward_amount,\n214\t      camp.campaign_type\n215\t    FROM challenge_assignments ca\n216\t    JOIN challenges c ON c.id = ca.challenge_id\n217\t    JOIN campaigns camp ON camp.id = c.campaign_id\n218\t    WHERE ca.user_id = ${userId}\n219\t      AND ca.period_key = 'onboarding'\n220\t    ORDER BY c.sort_order ASC\n221\t  `;\n222\t}\n223\t\n224\t/** Get all onboarding challenge templates (ordered by chain). */\n225\tasync function getOnboardingChallenges(\n226\t  db: Db,\n227\t  campaignId: string,\n228\t): Promise<ChallengeRow[]> {\n229\t  return db.rawSql<ChallengeRow[]>`\n230\t    SELECT id, campaign_id, title, description, action, scope, condition,\n231\t           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n232\t    FROM challenges\n233\t    WHERE campaign_id = ${campaignId}\n234\t      AND is_active = true\n235\t    ORDER BY sort_order ASC\n236\t  `;\n237\t}\n238\t\n239\t/** Get completion bonuses for a campaign. */\n240\tasync function getCompletionBonusesForCampaign(\n241\t  db: Db,\n242\t  campaignId: string,\n243\t): Promise<CompletionBonusRow[]> {\n244\t  return db.rawSql<CompletionBonusRow[]>`\n245\t    SELECT id, title, required_count, reward_type, reward_amount\n246\t    FROM completion_bonuses\n247\t    WHERE campaign_id = ${campaignId}\n248\t      AND is_active = true\n249\t  `;\n250\t}\n251\t\n252\t/** Check if a bonus was completed for a user in a given period. */\n253\tasync function getBonusCompletion(\n254\t  db: Db,\n255\t  userId: string,\n256\t  bonusId: string,\n257\t  periodKey: string,\n258\t): Promise<BonusCompletionRow | null> {\n259\t  const rows = await db.rawSql<BonusCompletionRow[]>`\n260\t    SELECT id FROM bonus_completions\n261\t    WHERE user_id = ${userId}\n262\t      AND bonus_id = ${bonusId}\n263\t      AND period_key = ${periodKey}\n264\t    LIMIT 1\n265\t  `;\n266\t  return rows[0] ?? null;\n267\t}\n268\t\n269\t/** Count completed assignments for a user in a period+campaign. */\n270\tasync function countCompleted(\n271\t  db: Db,\n272\t  userId: string,\n273\t  periodKey: string,\n274\t  campaignId: string,\n275\t): Promise<number> {\n276\t  const rows = await db.rawSql<{ count: string }[]>`\n277\t    SELECT COUNT(*)::TEXT AS count\n278\t    FROM challenge_assignments ca\n279\t    JOIN challenges c ON c.id = ca.challenge_id\n280\t    WHERE ca.user_id = ${userId}\n281\t      AND ca.period_key = ${periodKey}\n282\t      AND ca.status = 'completed'\n283\t      AND c.campaign_id = ${campaignId}\n284\t  `;\n285\t  return Number(rows[0]!.count);\n286\t}\n287\t\n288\t/** Create an assignment (idempotent via UNIQUE). */\n289\tasync function createAssignment(\n290\t  db: Db,\n291\t  userId: string,\n292\t  challengeId: string,\n293\t  periodKey: string,\n294\t  target: number,\n295\t  expiresAt: string | null,\n296\t): Promise<void> {\n297\t  await db.rawSql`\n298\t    INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n299\t    VALUES (${userId}, ${challengeId}, ${periodKey}, ${target}, ${expiresAt})\n300\t    ON CONFLICT (user_id, challenge_id, period_key) DO NOTHING\n301\t  `;\n302\t}\n303\t\n304\t// ---------------------------------------------------------------------------\n305\t// Response schemas\n306\t// ---------------------------------------------------------------------------\n307\t\n308\tconst OnboardingStepSchema = ChallengeAssignmentSchema.extend({\n309\t  locked: z.boolean().describe(\"True if prerequisite not yet completed\"),\n310\t});\n311\t\n312\tconst OnboardingSchema = z\n313\t  .object({\n314\t    steps: z.array(OnboardingStepSchema),\n315\t    completed: z.boolean(),\n316\t  })\n317\t  .nullable()\n318\t  .describe(\"Null when all onboarding steps are completed.\");\n319\t\n320\tconst PeriodChallengesSchema = z.object({\n321\t  challenges: z.array(ChallengeAssignmentSchema),\n322\t  bonus: CompletionBonusSchema,\n323\t  resetsAt: z.string().datetime(),\n324\t});\n325\t\n326\tconst MyChallengesResponseSchema = z.object({\n327\t  daily: PeriodChallengesSchema,\n328\t  weekly: PeriodChallengesSchema,\n329\t  onboarding: OnboardingSchema,\n330\t});\n331\t\n332\tconst ChallengeHistoryResponseSchema = z.object({\n333\t  items: z.array(ChallengeHistoryEntrySchema),\n334\t  nextCursor: z.string().nullable(),\n335\t});\n336\t\n337\t// ---------------------------------------------------------------------------\n338\t// Route definitions\n339\t// ---------------------------------------------------------------------------\n340\t\n341\tconst mineRoute = createRoute({\n342\t  method: \"get\",\n343\t  path: \"/mine\",\n344\t  tags: [\"Challenges\"],\n345\t  summary: \"Get active challenges for the authenticated player\",\n346\t  description:\n347\t    \"Returns daily, weekly, and onboarding challenges with lazy assignment on first call per period.\",\n348\t  security: [{ bearerAuth: [] }],\n349\t  responses: {\n350\t    200: {\n351\t      content: { \"application/json\": { schema: MyChallengesResponseSchema } },\n352\t      description: \"Active challenges grouped by period\",\n353\t    },\n354\t    401: {\n355\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n356\t      description: \"Authentication required\",\n357\t    },\n358\t    500: {\n359\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n360\t      description: \"Server error\",\n361\t    },\n362\t  },\n363\t});\n364\t\n365\tconst historyRoute = createRoute({\n366\t  method: \"get\",\n367\t  path: \"/mine/history\",\n368\t  tags: [\"Challenges\"],\n369\t  summary: \"Paginated completed challenge history\",\n370\t  security: [{ bearerAuth: [] }],\n371\t  request: {\n372\t    query: z.object({\n373\t      cursor: z.string().optional(),\n374\t      limit: z.coerce.number().int().min(1).max(50).optional(),\n375\t    }),\n376\t  },\n377\t  responses: {\n378\t    200: {\n379\t      content: { \"application/json\": { schema: ChallengeHistoryResponseSchema } },\n380\t      description: \"Completed challenge assignments\",\n381\t    },\n382\t    401: {\n383\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n384\t      description: \"Authentication required\",\n385\t    },\n386\t    500: {\n387\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n388\t      description: \"Server error\",\n389\t    },\n390\t  },\n391\t});\n392\t\n393\t// ---------------------------------------------------------------------------\n394\t// Route factory\n395\t// ---------------------------------------------------------------------------\n396\t\n397\texport function createChallengeRoutes(deps: ChallengeRoutesDeps) {\n398\t  const { db } = deps;\n399\t  const app = createOpenApiApp<AppEnv>();\n400\t\n401\t  app.openapi(mineRoute, async (c) => {\n402\t    const userId = c.get(\"userId\");\n403\t    if (!userId) {\n404\t      return c.json({ error: \"Authentication required\" }, 401);\n405\t    }\n406\t\n407\t    try {\n408\t      const now = new Date();\n409\t\n410\t      // 1. Expire stale assignments\n411\t      await expireStaleAssignments(db, userId);\n412\t\n413\t      // 2. Compute current period keys\n414\t      const dailyKey = dailyPeriodKey(now);\n415\t      const weeklyKey = weeklyPeriodKey(now);\n416\t\n417\t      // 3. Read config for challenge counts\n418\t      const dailyCountStr = await readRewardConfig(db, \"daily_challenge_count\");\n419\t      const weeklyCountStr = await readRewardConfig(db, \"weekly_challenge_count\");\n420\t      const dailyCount = dailyCountStr ? Number(dailyCountStr) : 3;\n421\t      const weeklyCount = weeklyCountStr ? Number(weeklyCountStr) : 2;\n422\t\n423\t      // 4. Look up campaign IDs\n424\t      const [dailyCampaign, weeklyCampaign, onboardingCampaign] = await Promise.all([\n425\t        getCampaignByType(db, \"daily\"),\n426\t        getCampaignByType(db, \"weekly\"),\n427\t        getCampaignByType(db, \"onboarding\"),\n428\t      ]);\n429\t\n430\t      // 5. Lazy assignment — daily\n431\t      let dailyAssignments = dailyCampaign\n432\t        ? await getAssignmentsForPeriod(db, userId, dailyKey)\n433\t        : [];\n434\t\n435\t      if (dailyAssignments.length === 0 && dailyCampaign) {\n436\t        const templates = await getActiveChallengesBySort(db, dailyCampaign.id, dailyCount);\n437\t        const dailyExpires = dailyResetsAt(now);\n438\t        for (const t of templates) {\n439\t          await createAssignment(db, userId, t.id, dailyKey, t.threshold, dailyExpires);\n440\t        }\n441\t        dailyAssignments = await getAssignmentsForPeriod(db, userId, dailyKey);\n442\t      }\n443\t\n444\t      // 6. Lazy assignment — weekly\n445\t      let weeklyAssignments = weeklyCampaign\n446\t        ? await getAssignmentsForPeriod(db, userId, weeklyKey)\n447\t        : [];\n448\t\n449\t      if (weeklyAssignments.length === 0 && weeklyCampaign) {\n450\t        const templates = await getActiveChallengesBySort(db, weeklyCampaign.id, weeklyCount);\n451\t        const weeklyExpires = weeklyResetsAt(now);\n452\t        for (const t of templates) {\n453\t          await createAssignment(db, userId, t.id, weeklyKey, t.threshold, weeklyExpires);\n454\t        }\n455\t        weeklyAssignments = await getAssignmentsForPeriod(db, userId, weeklyKey);\n456\t      }\n457\t\n458\t      // 7. Lazy assignment — onboarding\n459\t      let onboardingAssignments = onboardingCampaign\n460\t        ? await getOnboardingAssignments(db, userId)\n461\t        : [];\n462\t\n463\t      if (onboardingAssignments.length === 0 && onboardingCampaign) {\n464\t        // Assign first step (prerequisite_id IS NULL)\n465\t        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n466\t        const firstStep = allSteps.find((s) => s.prerequisite_id === null);\n467\t        if (firstStep) {\n468\t          await createAssignment(db, userId, firstStep.id, \"onboarding\", firstStep.threshold, null);\n469\t          onboardingAssignments = await getOnboardingAssignments(db, userId);\n470\t        }\n471\t      }\n472\t\n473\t      // 8. Build bonus status for daily\n474\t      let dailyBonus: CompletionBonusType = null;\n475\t      if (dailyCampaign) {\n476\t        const bonuses = await getCompletionBonusesForCampaign(db, dailyCampaign.id);\n477\t        if (bonuses.length > 0) {\n478\t          const bonus = bonuses[0]!;\n479\t          const completedCount = await countCompleted(db, userId, dailyKey, dailyCampaign.id);\n480\t          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, dailyKey);\n481\t          dailyBonus = {\n482\t            title: bonus.title,\n483\t            required: bonus.required_count,\n484\t            completed: completedCount,\n485\t            status: bonusCompletion ? \"completed\" as const : \"active\" as const,\n486\t            reward: {\n487\t              type: bonus.reward_type as \"points\" | \"crate\",\n488\t              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n489\t            },\n490\t          };\n491\t        }\n492\t      }\n493\t\n494\t      // 9. Build bonus status for weekly\n495\t      let weeklyBonus: CompletionBonusType = null;\n496\t      if (weeklyCampaign) {\n497\t        const bonuses = await getCompletionBonusesForCampaign(db, weeklyCampaign.id);\n498\t        if (bonuses.length > 0) {\n499\t          const bonus = bonuses[0]!;\n500\t          const completedCount = await countCompleted(db, userId, weeklyKey, weeklyCampaign.id);\n501\t          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, weeklyKey);\n502\t          weeklyBonus = {\n503\t            title: bonus.title,\n504\t            required: bonus.required_count,\n505\t            completed: completedCount,\n506\t            status: bonusCompletion ? \"completed\" as const : \"active\" as const,\n507\t            reward: {\n508\t              type: bonus.reward_type as \"points\" | \"crate\",\n509\t              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n510\t            },\n511\t          };\n512\t        }\n513\t      }\n514\t\n515\t      // 10. Build onboarding section\n516\t      let onboarding: OnboardingType = null;\n517\t      if (onboardingCampaign) {\n518\t        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n519\t        const assignedIds = new Set(onboardingAssignments.map((a) => a.challenge_id));\n520\t        const completedIds = new Set(\n521\t          onboardingAssignments.filter((a) => a.status === \"completed\").map((a) => a.challenge_id),\n522\t        );\n523\t        const allCompleted = allSteps.length > 0 && allSteps.every((s) => completedIds.has(s.id));\n524\t\n525\t        if (allCompleted) {\n526\t          onboarding = null;\n527\t        } else {\n528\t          const steps = allSteps.map((step) => {\n529\t            const assignment = onboardingAssignments.find((a) => a.challenge_id === step.id);\n530\t            const isAssigned = assignedIds.has(step.id);\n531\t            const locked = !isAssigned;\n532\t            return {\n533\t              id: Number(step.id),\n534\t              title: step.title,\n535\t              description: step.description,\n536\t              progress: assignment ? assignment.progress : 0,\n537\t              target: step.threshold,\n538\t              status: assignment ? assignment.status as \"active\" | \"completed\" | \"expired\" : \"active\",\n539\t              reward: {\n540\t                type: step.reward_type as \"points\" | \"crate\",\n541\t                ...(step.reward_amount != null ? { amount: step.reward_amount } : {}),\n542\t              },\n543\t              completedAt: assignment?.completed_at ?? null,\n544\t              locked,\n545\t            };\n546\t          });\n547\t          onboarding = { steps, completed: false };\n548\t        }\n549\t      }\n550\t\n551\t      // 11. Format response\n552\t      const formatChallenge = (a: AssignmentRow): ChallengeAssignmentType => ({\n553\t        id: Number(a.id),\n554\t        title: a.title,\n555\t        description: a.description,\n556\t        progress: a.progress,\n557\t        target: a.target,\n558\t        status: a.status as \"active\" | \"completed\" | \"expired\",\n559\t        reward: {\n560\t          type: a.reward_type as \"points\" | \"crate\",\n561\t          ...(a.reward_amount != null ? { amount: a.reward_amount } : {}),\n562\t        },\n563\t        completedAt: a.completed_at ?? null,\n564\t      });\n565\t\n566\t      return c.json({\n567\t        daily: {\n568\t          challenges: dailyAssignments.map(formatChallenge),\n569\t          bonus: dailyBonus,\n570\t          resetsAt: dailyResetsAt(now),\n571\t        },\n572\t        weekly: {\n573\t          challenges: weeklyAssignments.map(formatChallenge),\n574\t          bonus: weeklyBonus,\n575\t          resetsAt: weeklyResetsAt(now),\n576\t        },\n577\t        onboarding,\n578\t      }, 200);\n579\t    } catch (err) {\n580\t      logger.error(\"challenges/mine failed\", {\n581\t        userId,\n582\t        error: err instanceof Error ? err.message : String(err),\n583\t      });\n584\t      return c.json({ error: \"Failed to fetch challenges\" }, 500);\n585\t    }\n586\t  });\n587\t\n588\t  // GET /mine/history — paginated completed challenge assignments\n589\t  app.openapi(historyRoute, async (c) => {\n590\t    const userId = c.get(\"userId\");\n591\t    if (!userId) {\n592\t      return c.json({ error: \"Authentication required\" }, 401);\n593\t    }\n594\t\n595\t    const { cursor, limit: rawLimit } = c.req.valid(\"query\");\n596\t    const limit = rawLimit ?? 20;\n597\t\n598\t    try {\n599\t      const cursorFilter = cursor\n600\t        ? db.rawSql`AND ca.id < ${cursor}`\n601\t        : db.rawSql``;\n602\t\n603\t      const rows = await db.rawSql<\n604\t        {\n605\t          id: string;\n606\t          title: string;\n607\t          description: string;\n608\t          completed_at: Date;\n609\t          reward_type: string;\n610\t          reward_amount: number | null;\n611\t        }[]\n612\t      >`\n613\t        SELECT\n614\t          ca.id,\n615\t          c.title,\n616\t          c.description,\n617\t          ca.completed_at,\n618\t          c.reward_type,\n619\t          c.reward_amount\n620\t        FROM challenge_assignments ca\n621\t        JOIN challenges c ON c.id = ca.challenge_id\n622\t        WHERE ca.user_id = ${userId}\n623\t          AND ca.status = 'completed'\n624\t          ${cursorFilter}\n625\t        ORDER BY ca.id DESC\n626\t        LIMIT ${limit}\n627\t      `;\n628\t\n629\t      const items = rows.map((r: { id: string; title: string; description: string; completed_at: Date; reward_type: string; reward_amount: number | null }) => ({\n630\t        id: Number(r.id),\n631\t        title: r.title,\n632\t        description: r.description,\n633\t        completedAt: r.completed_at.toISOString(),\n634\t        reward: {\n635\t          type: r.reward_type as \"points\" | \"crate\",\n636\t          ...(r.reward_amount != null ? { amount: r.reward_amount } : {}),\n637\t        },\n638\t      }));\n639\t\n640\t      const nextCursor =\n641\t        items.length === limit ? String(items[items.length - 1]!.id) : null;\n642\t\n643\t      return c.json({ items, nextCursor }, 200);\n644\t    } catch (err) {\n645\t      logger.error(\"challenges/mine/history failed\", {\n646\t        userId,\n647\t        error: err instanceof Error ? err.message : String(err),\n648\t      });\n649\t      return c.json({ error: \"Failed to fetch challenge history\" }, 500);\n650\t    }\n651\t  });\n652\t\n653\t  return app;\n654\t}\n655\t"}]},"parent_tool_use_id":null,"session_id":"ea182426-3468-4ae1-8ebd-e6f6cd94f8d2","uuid":"57cbf063-cf6a-4c8a-b3d4-7ab15febc3af","timestamp":"2026-04-22T10:28:45.967Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/challenges.ts","content":"/**\n * Challenge routes — player-facing challenge/quest endpoints.\n *\n * GET /mine           — returns active daily, weekly, and onboarding challenges\n *                       with lazy assignment on first call per period.\n * GET /mine/history   — paginated completed challenge assignments.\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { readRewardConfig } from \"../queue/handlers/reward-pool-fund.js\";\nimport {\n  ChallengeAssignmentSchema,\n  ChallengeHistoryEntrySchema,\n  CompletionBonusSchema,\n  ErrorResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\n// Inferred types for handler return value typing\ntype CompletionBonusType = z.infer<typeof CompletionBonusSchema>;\ntype ChallengeAssignmentType = z.infer<typeof ChallengeAssignmentSchema>;\ntype OnboardingStepType = ChallengeAssignmentType & { locked: boolean };\ntype OnboardingType = { steps: OnboardingStepType[]; completed: boolean } | null;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface ChallengeRoutesDeps {\n  db: Db;\n}\n\ninterface ChallengeRow {\n  id: string;\n  campaign_id: string;\n  title: string;\n  description: string;\n  action: string;\n  scope: string;\n  condition: string;\n  threshold: number;\n  reward_type: string;\n  reward_amount: number | null;\n  sort_order: number;\n  prerequisite_id: string | null;\n}\n\ninterface AssignmentRow {\n  id: string;\n  challenge_id: string;\n  period_key: string;\n  status: string;\n  progress: number;\n  target: number;\n  expires_at: string | null;\n  completed_at: string | null;\n  title: string;\n  description: string;\n  reward_type: string;\n  reward_amount: number | null;\n  campaign_type: string;\n}\n\ninterface CompletionBonusRow {\n  id: string;\n  title: string;\n  required_count: number;\n  reward_type: string;\n  reward_amount: number | null;\n}\n\ninterface BonusCompletionRow {\n  id: string;\n}\n\n// ---------------------------------------------------------------------------\n// Period key helpers\n// ---------------------------------------------------------------------------\n\n/** Returns \"daily:YYYY-MM-DD\" for the current UTC date. */\nexport function dailyPeriodKey(now?: Date): string {\n  const d = now ?? new Date();\n  return `daily:${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, \"0\")}-${String(d.getUTCDate()).padStart(2, \"0\")}`;\n}\n\n/** Returns \"weekly:YYYY-Www\" for the current ISO week. */\nexport function weeklyPeriodKey(now?: Date): string {\n  const d = now ?? new Date();\n  // ISO week calculation\n  const tmp = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()));\n  tmp.setUTCDate(tmp.getUTCDate() + 4 - (tmp.getUTCDay() || 7));\n  const yearStart = new Date(Date.UTC(tmp.getUTCFullYear(), 0, 1));\n  const weekNo = Math.ceil(((tmp.getTime() - yearStart.getTime()) / 86400000 + 1) / 7);\n  return `weekly:${tmp.getUTCFullYear()}-W${String(weekNo).padStart(2, \"0\")}`;\n}\n\n/** Returns midnight UTC of the next day (daily reset). */\nexport function dailyResetsAt(now?: Date): string {\n  const d = now ?? new Date();\n  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + 1));\n  return next.toISOString();\n}\n\n/** Returns midnight UTC of next Monday (weekly reset). */\nexport function weeklyResetsAt(now?: Date): string {\n  const d = now ?? new Date();\n  const dayOfWeek = d.getUTCDay(); // 0=Sun, 1=Mon, ...\n  const daysUntilMonday = dayOfWeek === 0 ? 1 : 8 - dayOfWeek;\n  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + daysUntilMonday));\n  return next.toISOString();\n}\n\n// ---------------------------------------------------------------------------\n// DB helpers\n// ---------------------------------------------------------------------------\n\n/** Expire stale assignments (expires_at < now AND status='active'). */\nasync function expireStaleAssignments(db: Db, userId: string): Promise<void> {\n  await db.rawSql`\n    UPDATE challenge_assignments\n    SET status = 'expired'\n    WHERE user_id = ${userId}\n      AND status = 'active'\n      AND expires_at IS NOT NULL\n      AND expires_at < now()\n  `;\n}\n\n/** Get assignments for a user in a given period, joined with challenge metadata. */\nasync function getAssignmentsForPeriod(\n  db: Db,\n  userId: string,\n  periodKey: string,\n): Promise<AssignmentRow[]> {\n  return db.rawSql<AssignmentRow[]>`\n    SELECT\n      ca.id,\n      ca.challenge_id,\n      ca.period_key,\n      ca.status,\n      ca.progress,\n      ca.target,\n      ca.expires_at,\n      ca.completed_at,\n      c.title,\n      c.description,\n      c.reward_type,\n      c.reward_amount,\n      camp.campaign_type\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    JOIN campaigns camp ON camp.id = c.campaign_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = ${periodKey}\n    ORDER BY c.sort_order ASC\n  `;\n}\n\n/** Get top N active challenges for a campaign, ordered by sort_order ASC. */\nasync function getActiveChallengesBySort(\n  db: Db,\n  campaignId: string,\n  limit: number,\n): Promise<ChallengeRow[]> {\n  return db.rawSql<ChallengeRow[]>`\n    SELECT id, campaign_id, title, description, action, scope, condition,\n           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n    FROM challenges\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n    ORDER BY sort_order ASC\n    LIMIT ${limit}\n  `;\n}\n\n/** Get the campaign ID for a given campaign type. */\nasync function getCampaignByType(\n  db: Db,\n  campaignType: string,\n): Promise<{ id: string } | null> {\n  const rows = await db.rawSql<{ id: string }[]>`\n    SELECT id FROM campaigns\n    WHERE campaign_type = ${campaignType}\n      AND is_active = true\n    ORDER BY id ASC\n    LIMIT 1\n  `;\n  return rows[0] ?? null;\n}\n\n/** Get all onboarding assignments for a user (any status). */\nasync function getOnboardingAssignments(\n  db: Db,\n  userId: string,\n): Promise<AssignmentRow[]> {\n  return db.rawSql<AssignmentRow[]>`\n    SELECT\n      ca.id,\n      ca.challenge_id,\n      ca.period_key,\n      ca.status,\n      ca.progress,\n      ca.target,\n      ca.expires_at,\n      ca.completed_at,\n      c.title,\n      c.description,\n      c.reward_type,\n      c.reward_amount,\n      camp.campaign_type\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    JOIN campaigns camp ON camp.id = c.campaign_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = 'onboarding'\n    ORDER BY c.sort_order ASC\n  `;\n}\n\n/** Get all onboarding challenge templates (ordered by chain). */\nasync function getOnboardingChallenges(\n  db: Db,\n  campaignId: string,\n): Promise<ChallengeRow[]> {\n  return db.rawSql<ChallengeRow[]>`\n    SELECT id, campaign_id, title, description, action, scope, condition,\n           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n    FROM challenges\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n    ORDER BY sort_order ASC\n  `;\n}\n\n/** Get completion bonuses for a campaign. */\nasync function getCompletionBonusesForCampaign(\n  db: Db,\n  campaignId: string,\n): Promise<CompletionBonusRow[]> {\n  return db.rawSql<CompletionBonusRow[]>`\n    SELECT id, title, required_count, reward_type, reward_amount\n    FROM completion_bonuses\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n  `;\n}\n\n/** Check if a bonus was completed for a user in a given period. */\nasync function getBonusCompletion(\n  db: Db,\n  userId: string,\n  bonusId: string,\n  periodKey: string,\n): Promise<BonusCompletionRow | null> {\n  const rows = await db.rawSql<BonusCompletionRow[]>`\n    SELECT id FROM bonus_completions\n    WHERE user_id = ${userId}\n      AND bonus_id = ${bonusId}\n      AND period_key = ${periodKey}\n    LIMIT 1\n  `;\n  return rows[0] ?? null;\n}\n\n/** Count completed assignments for a user in a period+campaign. */\nasync function countCompleted(\n  db: Db,\n  userId: string,\n  periodKey: string,\n  campaignId: string,\n): Promise<number> {\n  const rows = await db.rawSql<{ count: string }[]>`\n    SELECT COUNT(*)::TEXT AS count\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = ${periodKey}\n      AND ca.status = 'completed'\n      AND c.campaign_id = ${campaignId}\n  `;\n  return Number(rows[0]!.count);\n}\n\n/** Create an assignment (idempotent via UNIQUE). */\nasync function createAssignment(\n  db: Db,\n  userId: string,\n  challengeId: string,\n  periodKey: string,\n  target: number,\n  expiresAt: string | null,\n): Promise<void> {\n  await db.rawSql`\n    INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n    VALUES (${userId}, ${challengeId}, ${periodKey}, ${target}, ${expiresAt})\n    ON CONFLICT (user_id, challenge_id, period_key) DO NOTHING\n  `;\n}\n\n// ---------------------------------------------------------------------------\n// Response schemas\n// ---------------------------------------------------------------------------\n\nconst OnboardingStepSchema = ChallengeAssignmentSchema.extend({\n  locked: z.boolean().describe(\"True if prerequisite not yet completed\"),\n});\n\nconst OnboardingSchema = z\n  .object({\n    steps: z.array(OnboardingStepSchema),\n    completed: z.boolean(),\n  })\n  .nullable()\n  .describe(\"Null when all onboarding steps are completed.\");\n\nconst PeriodChallengesSchema = z.object({\n  challenges: z.array(ChallengeAssignmentSchema),\n  bonus: CompletionBonusSchema,\n  resetsAt: z.string().datetime(),\n});\n\nconst MyChallengesResponseSchema = z.object({\n  daily: PeriodChallengesSchema,\n  weekly: PeriodChallengesSchema,\n  onboarding: OnboardingSchema,\n});\n\nconst ChallengeHistoryResponseSchema = z.object({\n  items: z.array(ChallengeHistoryEntrySchema),\n  nextCursor: z.string().nullable(),\n});\n\n// ---------------------------------------------------------------------------\n// Route definitions\n// ---------------------------------------------------------------------------\n\nconst mineRoute = createRoute({\n  method: \"get\",\n  path: \"/mine\",\n  tags: [\"Challenges\"],\n  summary: \"Get active challenges for the authenticated player\",\n  description:\n    \"Returns daily, weekly, and onboarding challenges with lazy assignment on first call per period.\",\n  security: [{ bearerAuth: [] }],\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: MyChallengesResponseSchema } },\n      description: \"Active challenges grouped by period\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\nconst historyRoute = createRoute({\n  method: \"get\",\n  path: \"/mine/history\",\n  tags: [\"Challenges\"],\n  summary: \"Paginated completed challenge history\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    query: z.object({\n      cursor: z.string().optional(),\n      limit: z.coerce.number().int().min(1).max(50).optional(),\n    }),\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: ChallengeHistoryResponseSchema } },\n      description: \"Completed challenge assignments\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport function createChallengeRoutes(deps: ChallengeRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  app.openapi(mineRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    try {\n      const now = new Date();\n\n      // 1. Expire stale assignments\n      await expireStaleAssignments(db, userId);\n\n      // 2. Compute current period keys\n      const dailyKey = dailyPeriodKey(now);\n      const weeklyKey = weeklyPeriodKey(now);\n\n      // 3. Read config for challenge counts\n      const dailyCountStr = await readRewardConfig(db, \"daily_challenge_count\");\n      const weeklyCountStr = await readRewardConfig(db, \"weekly_challenge_count\");\n      const dailyCount = dailyCountStr ? Number(dailyCountStr) : 3;\n      const weeklyCount = weeklyCountStr ? Number(weeklyCountStr) : 2;\n\n      // 4. Look up campaign IDs\n      const [dailyCampaign, weeklyCampaign, onboardingCampaign] = await Promise.all([\n        getCampaignByType(db, \"daily\"),\n        getCampaignByType(db, \"weekly\"),\n        getCampaignByType(db, \"onboarding\"),\n      ]);\n\n      // 5. Lazy assignment — daily\n      let dailyAssignments = dailyCampaign\n        ? await getAssignmentsForPeriod(db, userId, dailyKey)\n        : [];\n\n      if (dailyAssignments.length === 0 && dailyCampaign) {\n        const templates = await getActiveChallengesBySort(db, dailyCampaign.id, dailyCount);\n        const dailyExpires = dailyResetsAt(now);\n        for (const t of templates) {\n          await createAssignment(db, userId, t.id, dailyKey, t.threshold, dailyExpires);\n        }\n        dailyAssignments = await getAssignmentsForPeriod(db, userId, dailyKey);\n      }\n\n      // 6. Lazy assignment — weekly\n      let weeklyAssignments = weeklyCampaign\n        ? await getAssignmentsForPeriod(db, userId, weeklyKey)\n        : [];\n\n      if (weeklyAssignments.length === 0 && weeklyCampaign) {\n        const templates = await getActiveChallengesBySort(db, weeklyCampaign.id, weeklyCount);\n        const weeklyExpires = weeklyResetsAt(now);\n        for (const t of templates) {\n          await createAssignment(db, userId, t.id, weeklyKey, t.threshold, weeklyExpires);\n        }\n        weeklyAssignments = await getAssignmentsForPeriod(db, userId, weeklyKey);\n      }\n\n      // 7. Lazy assignment — onboarding\n      let onboardingAssignments = onboardingCampaign\n        ? await getOnboardingAssignments(db, userId)\n        : [];\n\n      if (onboardingAssignments.length === 0 && onboardingCampaign) {\n        // Assign first step (prerequisite_id IS NULL)\n        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n        const firstStep = allSteps.find((s) => s.prerequisite_id === null);\n        if (firstStep) {\n          await createAssignment(db, userId, firstStep.id, \"onboarding\", firstStep.threshold, null);\n          onboardingAssignments = await getOnboardingAssignments(db, userId);\n        }\n      }\n\n      // 8. Build bonus status for daily\n      let dailyBonus: CompletionBonusType = null;\n      if (dailyCampaign) {\n        const bonuses = await getCompletionBonusesForCampaign(db, dailyCampaign.id);\n        if (bonuses.length > 0) {\n          const bonus = bonuses[0]!;\n          const completedCount = await countCompleted(db, userId, dailyKey, dailyCampaign.id);\n          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, dailyKey);\n          dailyBonus = {\n            title: bonus.title,\n            required: bonus.required_count,\n            completed: completedCount,\n            status: bonusCompletion ? \"completed\" as const : \"active\" as const,\n            reward: {\n              type: bonus.reward_type as \"points\" | \"crate\",\n              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n            },\n          };\n        }\n      }\n\n      // 9. Build bonus status for weekly\n      let weeklyBonus: CompletionBonusType = null;\n      if (weeklyCampaign) {\n        const bonuses = await getCompletionBonusesForCampaign(db, weeklyCampaign.id);\n        if (bonuses.length > 0) {\n          const bonus = bonuses[0]!;\n          const completedCount = await countCompleted(db, userId, weeklyKey, weeklyCampaign.id);\n          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, weeklyKey);\n          weeklyBonus = {\n            title: bonus.title,\n            required: bonus.required_count,\n            completed: completedCount,\n            status: bonusCompletion ? \"completed\" as const : \"active\" as const,\n            reward: {\n              type: bonus.reward_type as \"points\" | \"crate\",\n              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n            },\n          };\n        }\n      }\n\n      // 10. Build onboarding section\n      let onboarding: OnboardingType = null;\n      if (onboardingCampaign) {\n        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n        const assignedIds = new Set(onboardingAssignments.map((a) => a.challenge_id));\n        const completedIds = new Set(\n          onboardingAssignments.filter((a) => a.status === \"completed\").map((a) => a.challenge_id),\n        );\n        const allCompleted = allSteps.length > 0 && allSteps.every((s) => completedIds.has(s.id));\n\n        if (allCompleted) {\n          onboarding = null;\n        } else {\n          const steps = allSteps.map((step) => {\n            const assignment = onboardingAssignments.find((a) => a.challenge_id === step.id);\n            const isAssigned = assignedIds.has(step.id);\n            const locked = !isAssigned;\n            return {\n              id: Number(step.id),\n              title: step.title,\n              description: step.description,\n              progress: assignment ? assignment.progress : 0,\n              target: step.threshold,\n              status: assignment ? assignment.status as \"active\" | \"completed\" | \"expired\" : \"active\",\n              reward: {\n                type: step.reward_type as \"points\" | \"crate\",\n                ...(step.reward_amount != null ? { amount: step.reward_amount } : {}),\n              },\n              completedAt: assignment?.completed_at ?? null,\n              locked,\n            };\n          });\n          onboarding = { steps, completed: false };\n        }\n      }\n\n      // 11. Format response\n      const formatChallenge = (a: AssignmentRow): ChallengeAssignmentType => ({\n        id: Number(a.id),\n        title: a.title,\n        description: a.description,\n        progress: a.progress,\n        target: a.target,\n        status: a.status as \"active\" | \"completed\" | \"expired\",\n        reward: {\n          type: a.reward_type as \"points\" | \"crate\",\n          ...(a.reward_amount != null ? { amount: a.reward_amount } : {}),\n        },\n        completedAt: a.completed_at ?? null,\n      });\n\n      return c.json({\n        daily: {\n          challenges: dailyAssignments.map(formatChallenge),\n          bonus: dailyBonus,\n          resetsAt: dailyResetsAt(now),\n        },\n        weekly: {\n          challenges: weeklyAssignments.map(formatChallenge),\n          bonus: weeklyBonus,\n          resetsAt: weeklyResetsAt(now),\n        },\n        onboarding,\n      }, 200);\n    } catch (err) {\n      logger.error(\"challenges/mine failed\", {\n        userId,\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ error: \"Failed to fetch challenges\" }, 500);\n    }\n  });\n\n  // GET /mine/history — paginated completed challenge assignments\n  app.openapi(historyRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    const { cursor, limit: rawLimit } = c.req.valid(\"query\");\n    const limit = rawLimit ?? 20;\n\n    try {\n      const cursorFilter = cursor\n        ? db.rawSql`AND ca.id < ${cursor}`\n        : db.rawSql``;\n\n      const rows = await db.rawSql<\n        {\n          id: string;\n          title: string;\n          description: string;\n          completed_at: Date;\n          reward_type: string;\n          reward_amount: number | null;\n        }[]\n      >`\n        SELECT\n          ca.id,\n          c.title,\n          c.description,\n          ca.completed_at,\n          c.reward_type,\n          c.reward_amount\n        FROM challenge_assignments ca\n        JOIN challenges c ON c.id = ca.challenge_id\n        WHERE ca.user_id = ${userId}\n          AND ca.status = 'completed'\n          ${cursorFilter}\n        ORDER BY ca.id DESC\n        LIMIT ${limit}\n      `;\n\n      const items = rows.map((r: { id: string; title: string; description: string; completed_at: Date; reward_type: string; reward_amount: number | null }) => ({\n        id: Number(r.id),\n        title: r.title,\n        description: r.description,\n        completedAt: r.completed_at.toISOString(),\n        reward: {\n          type: r.reward_type as \"points\" | \"crate\",\n          ...(r.reward_amount != null ? { amount: r.reward_amount } : {}),\n        },\n      }));\n\n      const nextCursor =\n        items.length === limit ? String(items[items.length - 1]!.id) : null;\n\n      return c.json({ items, nextCursor }, 200);\n    } catch (err) {\n      logger.error(\"challenges/mine/history failed\", {\n        userId,\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ error: \"Failed to fetch challenge history\" }, 500);\n    }\n  });\n\n  return app;\n}\n","numLines":655,"startLine":1,"totalLines":655}}}
