   expect(data1.items[0]).toHaveProperty(\"reward\");\n      expect(data1.items[0].reward).toHaveProperty(\"type\");\n      expect(data1.nextCursor).not.toBeNull();\n\n      const res2 = await app.request(\n        `/challenges/mine/history?limit=2&cursor=${data1.nextCursor}`,\n        {\n          method: \"GET\",\n          headers: { Authorization: `Bearer ${token}` },\n        },\n      );\n      expect(res2.status).toBe(200);\n      const body2 = (await res2.json()) as Record<string, any>;\n      expect(body2.ok).toBe(true);\n      const data2 = body2.data as Record<string, any>;\n      expect(data2.items).toHaveLength(1);\n      expect(data2.nextCursor).toBeNull();\n    });","originalFile":"/* eslint-disable @typescript-eslint/no-explicit-any */\nimport { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport {\n  createChallengeRoutes,\n  dailyPeriodKey,\n  weeklyPeriodKey,\n} from \"../routes/challenges.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport {\n  closeIntegrationDb,\n  type IntegrationDbContext,\n  JWT_SECRET,\n  makeJwt,\n  openIntegrationDb,\n  resetIntegrationState,\n  type TestSql,\n  userIdFromWallet,\n} from \"./integration-test-helpers.js\";\n\ndescribe(\"Challenge routes\", () => {\n  let ctx: IntegrationDbContext;\n  let rawSql: TestSql;\n  let db: Db;\n\n  beforeAll(async () => {\n    ctx = await openIntegrationDb();\n    rawSql = ctx.rawSql;\n    db = ctx.db;\n  });\n\n  afterAll(async () => {\n    await closeIntegrationDb(ctx);\n  });\n\n  describe(\"GET /challenges/mine\", () => {\n    let app: Hono;\n\n    const testWallet = Keypair.generate().publicKey.toBase58();\n    const testUserId = userIdFromWallet(testWallet);\n\n    beforeEach(async () => {\n      await resetIntegrationState(rawSql);\n\n      app = new Hono();\n      app.use(\n        \"/challenges/*\",\n        createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n      );\n      app.route(\"/challenges\", createChallengeRoutes({ db }));\n    });\n\n    it(\"first call creates daily, weekly, and onboarding assignments with the expected shape\", async () => {\n      const token = await makeJwt(testWallet, testUserId);\n\n      const res = await app.request(\"/challenges/mine\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as Record<string, any>;\n      expect(body.ok).toBe(true);\n      const data = body.data as Record<string, any>;\n\n      expect(data.daily).toBeDefined();\n      expect(data.daily.challenges).toHaveLength(3);\n      expect(data.daily.resetsAt).toBeDefined();\n      for (const challenge of data.daily.challenges) {\n        expect(challenge).toHaveProperty(\"id\");\n        expect(challenge).toHaveProperty(\"title\");\n        expect(challenge).toHaveProperty(\"description\");\n        expect(challenge).toHaveProperty(\"progress\");\n        expect(challenge).toHaveProperty(\"target\");\n        expect(challenge).toHaveProperty(\"status\");\n        expect(challenge).toHaveProperty(\"reward\");\n        expect(challenge.reward).toHaveProperty(\"type\");\n        expect(challenge).toHaveProperty(\"completedAt\");\n        expect(challenge.status).toBe(\"active\");\n        expect(challenge.progress).toBe(0);\n      }\n\n      expect(data.daily.bonus).toBeDefined();\n      expect(data.daily.bonus.required).toBe(3);\n      expect(data.daily.bonus.completed).toBe(0);\n      expect(data.daily.bonus.status).toBe(\"active\");\n      expect(data.daily.bonus.reward).toHaveProperty(\"type\");\n\n      expect(data.weekly).toBeDefined();\n      expect(data.weekly.challenges).toHaveLength(2);\n      expect(data.weekly.resetsAt).toBeDefined();\n      for (const challenge of data.weekly.challenges) {\n        expect(challenge.status).toBe(\"active\");\n        expect(challenge.progress).toBe(0);\n      }\n\n      expect(data.onboarding).toBeDefined();\n      expect(data.onboarding).not.toBeNull();\n      expect(data.onboarding.completed).toBe(false);\n      expect(data.onboarding.steps).toBeDefined();\n      expect(data.onboarding.steps.length).toBeGreaterThanOrEqual(1);\n      expect(data.onboarding.steps[0].locked).toBe(false);\n      if (data.onboarding.steps.length > 1) {\n        expect(data.onboarding.steps[1].locked).toBe(true);\n      }\n\n      const assignments = await rawSql<{ period_key: string }[]>`\n        SELECT period_key FROM challenge_assignments WHERE user_id = ${testUserId}\n      `;\n      const dailyCount = assignments.filter(\n        (assignment) => assignment.period_key === dailyPeriodKey(),\n      ).length;\n      const weeklyCount = assignments.filter(\n        (assignment) => assignment.period_key === weeklyPeriodKey(),\n      ).length;\n      const onboardingCount = assignments.filter(\n        (assignment) => assignment.period_key === \"onboarding\",\n      ).length;\n      expect(dailyCount).toBe(3);\n      expect(weeklyCount).toBe(2);\n      expect(onboardingCount).toBe(1);\n    });\n\n    it(\"second call returns the same assignments without duplicates\", async () => {\n      const token = await makeJwt(testWallet, testUserId);\n\n      await app.request(\"/challenges/mine\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      const res = await app.request(\"/challenges/mine\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as Record<string, any>;\n      expect(body.ok).toBe(true);\n      const data = body.data as Record<string, any>;\n      expect(data.daily.challenges).toHaveLength(3);\n      expect(data.weekly.challenges).toHaveLength(2);\n\n      const assignments = await rawSql<{ id: string }[]>`\n        SELECT id FROM challenge_assignments WHERE user_id = ${testUserId}\n      `;\n      expect(assignments.length).toBe(6);\n    });\n\n    it(\"expired assignments are marked expired on read\", async () => {\n      const token = await makeJwt(testWallet, testUserId);\n\n      const dailyCampaign = await rawSql<{ id: string }[]>`\n        SELECT id FROM campaigns WHERE campaign_type = 'daily' LIMIT 1\n      `;\n      const challenges = await rawSql<{ id: string; threshold: number }[]>`\n        SELECT id, threshold\n        FROM challenges\n        WHERE campaign_id = ${dailyCampaign[0]!.id} AND is_active = true\n        ORDER BY sort_order ASC\n        LIMIT 1\n      `;\n      await rawSql`\n        INSERT INTO challenge_assignments (\n          user_id,\n          challenge_id,\n          period_key,\n          target,\n          expires_at\n        )\n        VALUES (\n          ${testUserId},\n          ${challenges[0]!.id},\n          'daily:2020-01-01',\n          ${challenges[0]!.threshold},\n          '2020-01-02T00:00:00Z'\n        )\n      `;\n\n      const before = await rawSql<{ status: string }[]>`\n        SELECT status\n        FROM challenge_assignments\n        WHERE user_id = ${testUserId} AND period_key = 'daily:2020-01-01'\n      `;\n      expect(before[0]!.status).toBe(\"active\");\n\n      await app.request(\"/challenges/mine\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      const after = await rawSql<{ status: string }[]>`\n        SELECT status\n        FROM challenge_assignments\n        WHERE user_id = ${testUserId} AND period_key = 'daily:2020-01-01'\n      `;\n      expect(after[0]!.status).toBe(\"expired\");\n    });\n  });\n\n  describe(\"GET /challenges/mine/history\", () => {\n    let app: Hono;\n\n    const testWallet = Keypair.generate().publicKey.toBase58();\n    const testUserId = userIdFromWallet(testWallet);\n\n    beforeEach(async () => {\n      await resetIntegrationState(rawSql);\n\n      app = new Hono();\n      app.use(\n        \"/challenges/*\",\n        createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n      );\n      app.route(\"/challenges\", createChallengeRoutes({ db }));\n    });\n\n    it(\"paginates completed assignments\", async () => {\n      const challenges = await rawSql<{ id: string; threshold: number }[]>`\n        SELECT id, threshold\n        FROM challenges\n        WHERE is_active = true\n        ORDER BY sort_order ASC\n        LIMIT 3\n      `;\n\n      for (let i = 0; i < 3; i++) {\n        await rawSql`\n          INSERT INTO challenge_assignments (\n            user_id,\n            challenge_id,\n            period_key,\n            target,\n            status,\n            progress,\n            completed_at\n          )\n          VALUES (\n            ${testUserId},\n            ${challenges[i]!.id},\n            ${`daily:2026-01-0${i + 1}`},\n            ${challenges[i]!.threshold},\n            'completed',\n            ${challenges[i]!.threshold},\n            ${new Date(Date.UTC(2026, 0, i + 1)).toISOString()}\n          )\n        `;\n      }\n\n      const token = await makeJwt(testWallet, testUserId);\n\n      const res1 = await app.request(\"/challenges/mine/history?limit=2\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n      expect(res1.status).toBe(200);\n      const body1 = (await res1.json()) as Record<string, any>;\n      expect(body1.items).toHaveLength(2);\n      expect(body1.items[0]).toHaveProperty(\"id\");\n      expect(body1.items[0]).toHaveProperty(\"title\");\n      expect(body1.items[0]).toHaveProperty(\"description\");\n      expect(body1.items[0]).toHaveProperty(\"completedAt\");\n      expect(body1.items[0]).toHaveProperty(\"reward\");\n      expect(body1.items[0].reward).toHaveProperty(\"type\");\n      expect(body1.nextCursor).not.toBeNull();\n\n      const res2 = await app.request(\n        `/challenges/mine/history?limit=2&cursor=${body1.nextCursor}`,\n        {\n          method: \"GET\",\n          headers: { Authorization: `Bearer ${token}` },\n        },\n      );\n      expect(res2.status).toBe(200);\n      const body2 = (await res2.json()) as Record<string, any>;\n      expect(body2.items).toHaveLength(1);\n      expect(body2.nextCursor).toBeNull();\n    });\n\n    it(\"ignores active assignments\", async () => {\n      const challenges = await rawSql<{ id: string; threshold: number }[]>`\n        SELECT id, threshold\n        FROM challenges\n        WHERE is_active = true\n        ORDER BY sort_order ASC\n        LIMIT 1\n      `;\n      await rawSql`\n        INSERT INTO challenge_assignments (\n          user_id,\n          challenge_id,\n          period_key,\n          target,\n          status\n        )\n        VALUES (${testUserId}, ${challenges[0]!.id}, 'daily:2026-01-01', ${challenges[0]!.threshold}, 'active')\n      `;\n\n      const token = await makeJwt(testWallet, testUserId);\n      const res = await app.request(\"/challenges/mine/history\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as Record<string, any>;\n      expect(body.items).toHaveLength(0);\n      expect(body.nextCursor).toBeNull();\n    });\n  });\n});\n","structuredPatch":[{"oldStart":257,"oldLines":17,"newStart":257,"newLines":19,"lines":["       });","       expect(res1.status).toBe(200);","       const body1 = (await res1.json()) as Record<string, any>;","-      expect(body1.items).toHaveLength(2);","-      expect(body1.items[0]).toHaveProperty(\"id\");","-      expect(body1.items[0]).toHaveProperty(\"title\");","-      expect(body1.items[0]).toHaveProperty(\"description\");","-      expect(body1.items[0]).toHaveProperty(\"completedAt\");","-      expect(body1.items[0]).toHaveProperty(\"reward\")