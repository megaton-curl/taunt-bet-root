{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017rxHaRNwhnwymncT9WfHuu","type":"tool_result","content":"1\t/**\n2\t * Challenge routes — player-facing challenge/quest endpoints.\n3\t *\n4\t * GET /mine           — returns active daily, weekly, and onboarding challenges\n5\t *                       with lazy assignment on first call per period.\n6\t * GET /mine/history   — paginated completed challenge assignments.\n7\t */\n8\t\n9\timport { createRoute } from \"@hono/zod-openapi\";\n10\timport { z } from \"zod\";\n11\timport type { AppEnv } from \"../hono-env.js\";\n12\timport type { Db } from \"../db.js\";\n13\timport { logger } from \"../logger.js\";\n14\timport { readRewardConfig } from \"../queue/handlers/reward-pool-fund.js\";\n15\timport {\n16\t  ChallengeAssignmentSchema,\n17\t  ChallengeHistoryEntrySchema,\n18\t  CompletionBonusSchema,\n19\t} from \"../contracts/validators.js\";\n20\timport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n21\timport {\n22\t  envelope,\n23\t  ErrorEnvelopeSchema,\n24\t  ok,\n25\t  err,\n26\t} from \"../contracts/api-envelope.js\";\n27\timport { createOpenApiApp } from \"../openapi/hono.js\";\n28\t\n29\t// Inferred types for handler return value typing\n30\ttype CompletionBonusType = z.infer<typeof CompletionBonusSchema>;\n31\ttype ChallengeAssignmentType = z.infer<typeof ChallengeAssignmentSchema>;\n32\ttype OnboardingStepType = ChallengeAssignmentType & { locked: boolean };\n33\ttype OnboardingType = { steps: OnboardingStepType[]; completed: boolean } | null;\n34\t\n35\t// ---------------------------------------------------------------------------\n36\t// Types\n37\t// ---------------------------------------------------------------------------\n38\t\n39\texport interface ChallengeRoutesDeps {\n40\t  db: Db;\n41\t}\n42\t\n43\tinterface ChallengeRow {\n44\t  id: string;\n45\t  campaign_id: string;\n46\t  title: string;\n47\t  description: string;\n48\t  action: string;\n49\t  scope: string;\n50\t  condition: string;\n51\t  threshold: number;\n52\t  reward_type: string;\n53\t  reward_amount: number | null;\n54\t  sort_order: number;\n55\t  prerequisite_id: string | null;\n56\t}\n57\t\n58\tinterface AssignmentRow {\n59\t  id: string;\n60\t  challenge_id: string;\n61\t  period_key: string;\n62\t  status: string;\n63\t  progress: number;\n64\t  target: number;\n65\t  expires_at: string | null;\n66\t  completed_at: string | null;\n67\t  title: string;\n68\t  description: string;\n69\t  reward_type: string;\n70\t  reward_amount: number | null;\n71\t  campaign_type: string;\n72\t}\n73\t\n74\tinterface CompletionBonusRow {\n75\t  id: string;\n76\t  title: string;\n77\t  required_count: number;\n78\t  reward_type: string;\n79\t  reward_amount: number | null;\n80\t}\n81\t\n82\tinterface BonusCompletionRow {\n83\t  id: string;\n84\t}\n85\t\n86\t// ---------------------------------------------------------------------------\n87\t// Period key helpers\n88\t// ---------------------------------------------------------------------------\n89\t\n90\t/** Returns \"daily:YYYY-MM-DD\" for the current UTC date. */\n91\texport function dailyPeriodKey(now?: Date): string {\n92\t  const d = now ?? new Date();\n93\t  return `daily:${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, \"0\")}-${String(d.getUTCDate()).padStart(2, \"0\")}`;\n94\t}\n95\t\n96\t/** Returns \"weekly:YYYY-Www\" for the current ISO week. */\n97\texport function weeklyPeriodKey(now?: Date): string {\n98\t  const d = now ?? new Date();\n99\t  // ISO week calculation\n100\t  const tmp = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()));\n101\t  tmp.setUTCDate(tmp.getUTCDate() + 4 - (tmp.getUTCDay() || 7));\n102\t  const yearStart = new Date(Date.UTC(tmp.getUTCFullYear(), 0, 1));\n103\t  const weekNo = Math.ceil(((tmp.getTime() - yearStart.getTime()) / 86400000 + 1) / 7);\n104\t  return `weekly:${tmp.getUTCFullYear()}-W${String(weekNo).padStart(2, \"0\")}`;\n105\t}\n106\t\n107\t/** Returns midnight UTC of the next day (daily reset). */\n108\texport function dailyResetsAt(now?: Date): string {\n109\t  const d = now ?? new Date();\n110\t  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + 1));\n111\t  return next.toISOString();\n112\t}\n113\t\n114\t/** Returns midnight UTC of next Monday (weekly reset). */\n115\texport function weeklyResetsAt(now?: Date): string {\n116\t  const d = now ?? new Date();\n117\t  const dayOfWeek = d.getUTCDay(); // 0=Sun, 1=Mon, ...\n118\t  const daysUntilMonday = dayOfWeek === 0 ? 1 : 8 - dayOfWeek;\n119\t  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + daysUntilMonday));\n120\t  return next.toISOString();\n121\t}\n122\t\n123\t// ---------------------------------------------------------------------------\n124\t// DB helpers\n125\t// ---------------------------------------------------------------------------\n126\t\n127\t/** Expire stale assignments (expires_at < now AND status='active'). */\n128\tasync function expireStaleAssignments(db: Db, userId: string): Promise<void> {\n129\t  await db.rawSql`\n130\t    UPDATE challenge_assignments\n131\t    SET status = 'expired'\n132\t    WHERE user_id = ${userId}\n133\t      AND status = 'active'\n134\t      AND expires_at IS NOT NULL\n135\t      AND expires_at < now()\n136\t  `;\n137\t}\n138\t\n139\t/** Get assignments for a user in a given period, joined with challenge metadata. */\n140\tasync function getAssignmentsForPeriod(\n141\t  db: Db,\n142\t  userId: string,\n143\t  periodKey: string,\n144\t): Promise<AssignmentRow[]> {\n145\t  return db.rawSql<AssignmentRow[]>`\n146\t    SELECT\n147\t      ca.id,\n148\t      ca.challenge_id,\n149\t      ca.period_key,\n150\t      ca.status,\n151\t      ca.progress,\n152\t      ca.target,\n153\t      ca.expires_at,\n154\t      ca.completed_at,\n155\t      c.title,\n156\t      c.description,\n157\t      c.reward_type,\n158\t      c.reward_amount,\n159\t      camp.campaign_type\n160\t    FROM challenge_assignments ca\n161\t    JOIN challenges c ON c.id = ca.challenge_id\n162\t    JOIN campaigns camp ON camp.id = c.campaign_id\n163\t    WHERE ca.user_id = ${userId}\n164\t      AND ca.period_key = ${periodKey}\n165\t    ORDER BY c.sort_order ASC\n166\t  `;\n167\t}\n168\t\n169\t/** Get top N active challenges for a campaign, ordered by sort_order ASC. */\n170\tasync function getActiveChallengesBySort(\n171\t  db: Db,\n172\t  campaignId: string,\n173\t  limit: number,\n174\t): Promise<ChallengeRow[]> {\n175\t  return db.rawSql<ChallengeRow[]>`\n176\t    SELECT id, campaign_id, title, description, action, scope, condition,\n177\t           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n178\t    FROM challenges\n179\t    WHERE campaign_id = ${campaignId}\n180\t      AND is_active = true\n181\t    ORDER BY sort_order ASC\n182\t    LIMIT ${limit}\n183\t  `;\n184\t}\n185\t\n186\t/** Get the campaign ID for a given campaign type. */\n187\tasync function getCampaignByType(\n188\t  db: Db,\n189\t  campaignType: string,\n190\t): Promise<{ id: string } | null> {\n191\t  const rows = await db.rawSql<{ id: string }[]>`\n192\t    SELECT id FROM campaigns\n193\t    WHERE campaign_type = ${campaignType}\n194\t      AND is_active = true\n195\t    ORDER BY id ASC\n196\t    LIMIT 1\n197\t  `;\n198\t  return rows[0] ?? null;\n199\t}\n200\t\n201\t/** Get all onboarding assignments for a user (any status). */\n202\tasync function getOnboardingAssignments(\n203\t  db: Db,\n204\t  userId: string,\n205\t): Promise<AssignmentRow[]> {\n206\t  return db.rawSql<AssignmentRow[]>`\n207\t    SELECT\n208\t      ca.id,\n209\t      ca.challenge_id,\n210\t      ca.period_key,\n211\t      ca.status,\n212\t      ca.progress,\n213\t      ca.target,\n214\t      ca.expires_at,\n215\t      ca.completed_at,\n216\t      c.title,\n217\t      c.description,\n218\t      c.reward_type,\n219\t      c.reward_amount,\n220\t      camp.campaign_type\n221\t    FROM challenge_assignments ca\n222\t    JOIN challenges c ON c.id = ca.challenge_id\n223\t    JOIN campaigns camp ON camp.id = c.campaign_id\n224\t    WHERE ca.user_id = ${userId}\n225\t      AND ca.period_key = 'onboarding'\n226\t    ORDER BY c.sort_order ASC\n227\t  `;\n228\t}\n229\t\n230\t/** Get all onboarding challenge templates (ordered by chain). */\n231\tasync function getOnboardingChallenges(\n232\t  db: Db,\n233\t  campaignId: string,\n234\t): Promise<ChallengeRow[]> {\n235\t  return db.rawSql<ChallengeRow[]>`\n236\t    SELECT id, campaign_id, title, description, action, scope, condition,\n237\t           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n238\t    FROM challenges\n239\t    WHERE campaign_id = ${campaignId}\n240\t      AND is_active = true\n241\t    ORDER BY sort_order ASC\n242\t  `;\n243\t}\n244\t\n245\t/** Get completion bonuses for a campaign. */\n246\tasync function getCompletionBonusesForCampaign(\n247\t  db: Db,\n248\t  campaignId: string,\n249\t): Promise<CompletionBonusRow[]> {\n250\t  return db.rawSql<CompletionBonusRow[]>`\n251\t    SELECT id, title, required_count, reward_type, reward_amount\n252\t    FROM completion_bonuses\n253\t    WHERE campaign_id = ${campaignId}\n254\t      AND is_active = true\n255\t  `;\n256\t}\n257\t\n258\t/** Check if a bonus was completed for a user in a given period. */\n259\tasync function getBonusCompletion(\n260\t  db: Db,\n261\t  userId: string,\n262\t  bonusId: string,\n263\t  periodKey: string,\n264\t): Promise<BonusCompletionRow | null> {\n265\t  const rows = await db.rawSql<BonusCompletionRow[]>`\n266\t    SELECT id FROM bonus_completions\n267\t    WHERE user_id = ${userId}\n268\t      AND bonus_id = ${bonusId}\n269\t      AND period_key = ${periodKey}\n270\t    LIMIT 1\n271\t  `;\n272\t  return rows[0] ?? null;\n273\t}\n274\t\n275\t/** Count completed assignments for a user in a period+campaign. */\n276\tasync function countCompleted(\n277\t  db: Db,\n278\t  userId: string,\n279\t  periodKey: string,\n280\t  campaignId: string,\n281\t): Promise<number> {\n282\t  const rows = await db.rawSql<{ count: string }[]>`\n283\t    SELECT COUNT(*)::TEXT AS count\n284\t    FROM challenge_assignments ca\n285\t    JOIN challenges c ON c.id = ca.challenge_id\n286\t    WHERE ca.user_id = ${userId}\n287\t      AND ca.period_key = ${periodKey}\n288\t      AND ca.status = 'completed'\n289\t      AND c.campaign_id = ${campaignId}\n290\t  `;\n291\t  return Number(rows[0]!.count);\n292\t}\n293\t\n294\t/** Create an assignment (idempotent via UNIQUE). */\n295\tasync function createAssignment(\n296\t  db: Db,\n297\t  userId: string,\n298\t  challengeId: string,\n299\t  periodKey: string,\n300\t  target: number,\n301\t  expiresAt: string | null,\n302\t): Promise<void> {\n303\t  await db.rawSql`\n304\t    INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n305\t    VALUES (${userId}, ${challengeId}, ${periodKey}, ${target}, ${expiresAt})\n306\t    ON CONFLICT (user_id, challenge_id, period_key) DO NOTHING\n307\t  `;\n308\t}\n309\t\n310\t// ---------------------------------------------------------------------------\n311\t// Response schemas\n312\t// ---------------------------------------------------------------------------\n313\t\n314\tconst OnboardingStepSchema = ChallengeAssignmentSchema.extend({\n315\t  locked: z.boolean().describe(\"True if prerequisite not yet completed\"),\n316\t});\n317\t\n318\tconst OnboardingSchema = z\n319\t  .object({\n320\t    steps: z.array(OnboardingStepSchema),\n321\t    completed: z.boolean(),\n322\t  })\n323\t  .nullable()\n324\t  .describe(\"Null when all onboarding steps are completed.\");\n325\t\n326\tconst PeriodChallengesSchema = z.object({\n327\t  challenges: z.array(ChallengeAssignmentSchema),\n328\t  bonus: CompletionBonusSchema,\n329\t  resetsAt: z.string().datetime(),\n330\t});\n331\t\n332\tconst MyChallengesResponseSchema = z.object({\n333\t  daily: PeriodChallengesSchema,\n334\t  weekly: PeriodChallengesSchema,\n335\t  onboarding: OnboardingSchema,\n336\t});\n337\t\n338\tconst ChallengeHistoryResponseSchema = z.object({\n339\t  items: z.array(ChallengeHistoryEntrySchema),\n340\t  nextCursor: z.string().nullable(),\n341\t});\n342\t\n343\t// ---------------------------------------------------------------------------\n344\t// Route definitions\n345\t// ---------------------------------------------------------------------------\n346\t\n347\tconst mineRoute = createRoute({\n348\t  method: \"get\",\n349\t  path: \"/mine\",\n350\t  tags: [\"Challenges\"],\n351\t  summary: \"Get active challenges for the authenticated player\",\n352\t  description:\n353\t    \"Returns daily, weekly, and onboarding challenges with lazy assignment on first call per period.\",\n354\t  security: [{ bearerAuth: [] }],\n355\t  responses: {\n356\t    200: {\n357\t      content: { \"application/json\": { schema: envelope(MyChallengesResponseSchema) } },\n358\t      description: \"Active challenges grouped by period\",\n359\t    },\n360\t    401: {\n361\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n362\t      description: \"Authentication required\",\n363\t    },\n364\t    500: {\n365\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n366\t      description: \"Server error\",\n367\t    },\n368\t  },\n369\t});\n370\t\n371\tconst historyRoute = createRoute({\n372\t  method: \"get\",\n373\t  path: \"/mine/history\",\n374\t  tags: [\"Challenges\"],\n375\t  summary: \"Paginated completed challenge history\",\n376\t  security: [{ bearerAuth: [] }],\n377\t  request: {\n378\t    query: z.object({\n379\t      cursor: z.string().optional(),\n380\t      limit: z.coerce.number().int().min(1).max(50).optional(),\n381\t    }),\n382\t  },\n383\t  responses: {\n384\t    200: {\n385\t      content: { \"application/json\": { schema: envelope(ChallengeHistoryResponseSchema) } },\n386\t      description: \"Completed challenge assignments\",\n387\t    },\n388\t    401: {\n389\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n390\t      description: \"Authentication required\",\n391\t    },\n392\t    500: {\n393\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n394\t      description: \"Server error\",\n395\t    },\n396\t  },\n397\t});\n398\t\n399\t// ---------------------------------------------------------------------------\n400\t// Route factory\n401\t// ---------------------------------------------------------------------------\n402\t\n403\texport function createChallengeRoutes(deps: ChallengeRoutesDeps) {\n404\t  const { db } = deps;\n405\t  const app = createOpenApiApp<AppEnv>();\n406\t\n407\t  app.openapi(mineRoute, async (c) => {\n408\t    const userId = c.get(\"userId\");\n409\t    if (!userId) {\n410\t      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n411\t    }\n412\t\n413\t    try {\n414\t      const now = new Date();\n415\t\n416\t      // 1. Expire stale assignments\n417\t      await expireStaleAssignments(db, userId);\n418\t\n419\t      // 2. Compute current period keys\n420\t      const dailyKey = dailyPeriodKey(now);\n421\t      const weeklyKey = weeklyPeriodKey(now);\n422\t\n423\t      // 3. Read config for challenge counts\n424\t      const dailyCountStr = await readRewardConfig(db, \"daily_challenge_count\");\n425\t      const weeklyCountStr = await readRewardConfig(db, \"weekly_challenge_count\");\n426\t      const dailyCount = dailyCountStr ? Number(dailyCountStr) : 3;\n427\t      const weeklyCount = weeklyCountStr ? Number(weeklyCountStr) : 2;\n428\t\n429\t      // 4. Look up campaign IDs\n430\t      const [dailyCampaign, weeklyCampaign, onboardingCampaign] = await Promise.all([\n431\t        getCampaignByType(db, \"daily\"),\n432\t        getCampaignByType(db, \"weekly\"),\n433\t        getCampaignByType(db, \"onboarding\"),\n434\t      ]);\n435\t\n436\t      // 5. Lazy assignment — daily\n437\t      let dailyAssignments = dailyCampaign\n438\t        ? await getAssignmentsForPeriod(db, userId, dailyKey)\n439\t        : [];\n440\t\n441\t      if (dailyAssignments.length === 0 && dailyCampaign) {\n442\t        const templates = await getActiveChallengesBySort(db, dailyCampaign.id, dailyCount);\n443\t        const dailyExpires = dailyResetsAt(now);\n444\t        for (const t of templates) {\n445\t          await createAssignment(db, userId, t.id, dailyKey, t.threshold, dailyExpires);\n446\t        }\n447\t        dailyAssignments = await getAssignmentsForPeriod(db, userId, dailyKey);\n448\t      }\n449\t\n450\t      // 6. Lazy assignment — weekly\n451\t      let weeklyAssignments = weeklyCampaign\n452\t        ? await getAssignmentsForPeriod(db, userId, weeklyKey)\n453\t        : [];\n454\t\n455\t      if (weeklyAssignments.length === 0 && weeklyCampaign) {\n456\t        const templates = await getActiveChallengesBySort(db, weeklyCampaign.id, weeklyCount);\n457\t        const weeklyExpires = weeklyResetsAt(now);\n458\t        for (const t of templates) {\n459\t          await createAssignment(db, userId, t.id, weeklyKey, t.threshold, weeklyExpires);\n460\t        }\n461\t        weeklyAssignments = await getAssignmentsForPeriod(db, userId, weeklyKey);\n462\t      }\n463\t\n464\t      // 7. Lazy assignment — onboarding\n465\t      let onboardingAssignments = onboardingCampaign\n466\t        ? await getOnboardingAssignments(db, userId)\n467\t        : [];\n468\t\n469\t      if (onboardingAssignments.length === 0 && onboardingCampaign) {\n470\t        // Assign first step (prerequisite_id IS NULL)\n471\t        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n472\t        const firstStep = allSteps.find((s) => s.prerequisite_id === null);\n473\t        if (firstStep) {\n474\t          await createAssignment(db, userId, firstStep.id, \"onboarding\", firstStep.threshold, null);\n475\t          onboardingAssignments = await getOnboardingAssignments(db, userId);\n476\t        }\n477\t      }\n478\t\n479\t      // 8. Build bonus status for daily\n480\t      let dailyBonus: CompletionBonusType = null;\n481\t      if (dailyCampaign) {\n482\t        const bonuses = await getCompletionBonusesForCampaign(db, dailyCampaign.id);\n483\t        if (bonuses.length > 0) {\n484\t          const bonus = bonuses[0]!;\n485\t          const completedCount = await countCompleted(db, userId, dailyKey, dailyCampaign.id);\n486\t          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, dailyKey);\n487\t          dailyBonus = {\n488\t            title: bonus.title,\n489\t            required: bonus.required_count,\n490\t            completed: completedCount,\n491\t            status: bonusCompletion ? \"completed\" as const : \"active\" as const,\n492\t            reward: {\n493\t              type: bonus.reward_type as \"points\" | \"crate\",\n494\t              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n495\t            },\n496\t          };\n497\t        }\n498\t      }\n499\t\n500\t      // 9. Build bonus status for weekly\n501\t      let weeklyBonus: CompletionBonusType = null;\n502\t      if (weeklyCampaign) {\n503\t        const bonuses = await getCompletionBonusesForCampaign(db, weeklyCampaign.id);\n504\t        if (bonuses.length > 0) {\n505\t          const bonus = bonuses[0]!;\n506\t          const completedCount = await countCompleted(db, userId, weeklyKey, weeklyCampaign.id);\n507\t          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, weeklyKey);\n508\t          weeklyBonus = {\n509\t            title: bonus.title,\n510\t            required: bonus.required_count,\n511\t            completed: completedCount,\n512\t            status: bonusCompletion ? \"completed\" as const : \"active\" as const,\n513\t            reward: {\n514\t              type: bonus.reward_type as \"points\" | \"crate\",\n515\t              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n516\t            },\n517\t          };\n518\t        }\n519\t      }\n520\t\n521\t      // 10. Build onboarding section\n522\t      let onboarding: OnboardingType = null;\n523\t      if (onboardingCampaign) {\n524\t        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n525\t        const assignedIds = new Set(onboardingAssignments.map((a) => a.challenge_id));\n526\t        const completedIds = new Set(\n527\t          onboardingAssignments.filter((a) => a.status === \"completed\").map((a) => a.challenge_id),\n528\t        );\n529\t        const allCompleted = allSteps.length > 0 && allSteps.every((s) => completedIds.has(s.id));\n530\t\n531\t        if (allCompleted) {\n532\t          onboarding = null;\n533\t        } else {\n534\t          const steps = allSteps.map((step) => {\n535\t            const assignment = onboardingAssignments.find((a) => a.challenge_id === step.id);\n536\t            const isAssigned = assignedIds.has(step.id);\n537\t            const locked = !isAssigned;\n538\t            return {\n539\t              id: Number(step.id),\n540\t              title: step.title,\n541\t              description: step.description,\n542\t              progress: assignment ? assignment.progress : 0,\n543\t              target: step.threshold,\n544\t              status: assignment ? assignment.status as \"active\" | \"completed\" | \"expired\" : \"active\",\n545\t              reward: {\n546\t                type: step.reward_type as \"points\" | \"crate\",\n547\t                ...(step.reward_amount != null ? { amount: step.reward_amount } : {}),\n548\t              },\n549\t              completedAt: assignment?.completed_at ?? null,\n550\t              locked,\n551\t            };\n552\t          });\n553\t          onboarding = { steps, completed: false };\n554\t        }\n555\t      }\n556\t\n557\t      // 11. Format response\n558\t      const formatChallenge = (a: AssignmentRow): ChallengeAssignmentType => ({\n559\t        id: Number(a.id),\n560\t        title: a.title,\n561\t        description: a.description,\n562\t        progress: a.progress,\n563\t        target: a.target,\n564\t        status: a.status as \"active\" | \"completed\" | \"expired\",\n565\t        reward: {\n566\t          type: a.reward_type as \"points\" | \"crate\",\n567\t          ...(a.reward_amount != null ? { amount: a.reward_amount } : {}),\n568\t        },\n569\t        completedAt: a.completed_at ?? null,\n570\t      });\n571\t\n572\t      return ok(c, {\n573\t        daily: {\n574\t          challenges: dailyAssignments.map(formatChallenge),\n575\t          bonus: dailyBonus,\n576\t          resetsAt: dailyResetsAt(now),\n577\t        },\n578\t        weekly: {\n579\t          challenges: weeklyAssignments.map(formatChallenge),\n580\t          bonus: weeklyBonus,\n581\t          resetsAt: weeklyResetsAt(now),\n582\t        },\n583\t        onboarding,\n584\t      });\n585\t    } catch (fetchError) {\n586\t      logger.error(\"challenges/mine failed\", {\n587\t        userId,\n588\t        error: fetchError instanceof Error ? fetchError.message : String(fetchError),\n589\t      });\n590\t      return err(\n591\t        c,\n592\t        500,\n593\t        API_ERROR_CODES.PRECONDITION_FAILED,\n594\t        \"Failed to fetch challenges\",\n595\t      );\n596\t    }\n597\t  });\n598\t\n599\t  // GET /mine/history — paginated completed challenge assignments\n600\t  app.openapi(historyRoute, async (c) => {\n601\t    const userId = c.get(\"userId\");\n602\t    if (!userId) {\n603\t      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n604\t    }\n605\t\n606\t    const { cursor, limit: rawLimit } = c.req.valid(\"query\");\n607\t    const limit = rawLimit ?? 20;\n608\t\n609\t    try {\n610\t      const cursorFilter = cursor\n611\t        ? db.rawSql`AND ca.id < ${cursor}`\n612\t        : db.rawSql``;\n613\t\n614\t      const rows = await db.rawSql<\n615\t        {\n616\t          id: string;\n617\t          title: string;\n618\t          description: string;\n619\t          completed_at: Date;\n620\t          reward_type: string;\n621\t          reward_amount: number | null;\n622\t        }[]\n623\t      >`\n624\t        SELECT\n625\t          ca.id,\n626\t          c.title,\n627\t          c.description,\n628\t          ca.completed_at,\n629\t          c.reward_type,\n630\t          c.reward_amount\n631\t        FROM challenge_assignments ca\n632\t        JOIN challenges c ON c.id = ca.challenge_id\n633\t        WHERE ca.user_id = ${userId}\n634\t          AND ca.status = 'completed'\n635\t          ${cursorFilter}\n636\t        ORDER BY ca.id DESC\n637\t        LIMIT ${limit}\n638\t      `;\n639\t\n640\t      const items = rows.map((r: { id: string; title: string; description: string; completed_at: Date; reward_type: string; reward_amount: number | null }) => ({\n641\t        id: Number(r.id),\n642\t        title: r.title,\n643\t        description: r.description,\n644\t        completedAt: r.completed_at.toISOString(),\n645\t        reward: {\n646\t          type: r.reward_type as \"points\" | \"crate\",\n647\t          ...(r.reward_amount != null ? { amount: r.reward_amount } : {}),\n648\t        },\n649\t      }));\n650\t\n651\t      const nextCursor =\n652\t        items.length === limit ? String(items[items.length - 1]!.id) : null;\n653\t\n654\t      return ok(c, { items, nextCursor });\n655\t    } catch (queryError) {\n656\t      logger.error(\"challenges/mine/history failed\", {\n657\t        userId,\n658\t        error: queryError instanceof Error ? queryError.message : String(queryError),\n659\t      });\n660\t      return err(\n661\t        c,\n662\t        500,\n663\t        API_ERROR_CODES.PRECONDITION_FAILED,\n664\t        \"Failed to fetch challenge history\",\n665\t      );\n666\t    }\n667\t  });\n668\t\n669\t  return app;\n670\t}\n671\t"}]},"parent_tool_use_id":null,"session_id":"ea182426-3468-4ae1-8ebd-e6f6cd94f8d2","uuid":"790fe7b7-3df7-43b4-8fa2-7fd61f02897e","timestamp":"2026-04-22T10:29:37.931Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/challenges.ts","content":"/**\n * Challenge routes — player-facing challenge/quest endpoints.\n *\n * GET /mine           — returns active daily, weekly, and onboarding challenges\n *                       with lazy assignment on first call per period.\n * GET /mine/history   — paginated completed challenge assignments.\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { readRewardConfig } from \"../queue/handlers/reward-pool-fund.js\";\nimport {\n  ChallengeAssignmentSchema,\n  ChallengeHistoryEntrySchema,\n  CompletionBonusSchema,\n} from \"../contracts/validators.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\n// Inferred types for handler return value typing\ntype CompletionBonusType = z.infer<typeof CompletionBonusSchema>;\ntype ChallengeAssignmentType = z.infer<typeof ChallengeAssignmentSchema>;\ntype OnboardingStepType = ChallengeAssignmentType & { locked: boolean };\ntype OnboardingType = { steps: OnboardingStepType[]; completed: boolean } | null;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface ChallengeRoutesDeps {\n  db: Db;\n}\n\ninterface ChallengeRow {\n  id: string;\n  campaign_id: string;\n  title: string;\n  description: string;\n  action: string;\n  scope: string;\n  condition: string;\n  threshold: number;\n  reward_type: string;\n  reward_amount: number | null;\n  sort_order: number;\n  prerequisite_id: string | null;\n}\n\ninterface AssignmentRow {\n  id: string;\n  challenge_id: string;\n  period_key: string;\n  status: string;\n  progress: number;\n  target: number;\n  expires_at: string | null;\n  completed_at: string | null;\n  title: string;\n  description: string;\n  reward_type: string;\n  reward_amount: number | null;\n  campaign_type: string;\n}\n\ninterface CompletionBonusRow {\n  id: string;\n  title: string;\n  required_count: number;\n  reward_type: string;\n  reward_amount: number | null;\n}\n\ninterface BonusCompletionRow {\n  id: string;\n}\n\n// ---------------------------------------------------------------------------\n// Period key helpers\n// ---------------------------------------------------------------------------\n\n/** Returns \"daily:YYYY-MM-DD\" for the current UTC date. */\nexport function dailyPeriodKey(now?: Date): string {\n  const d = now ?? new Date();\n  return `daily:${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, \"0\")}-${String(d.getUTCDate()).padStart(2, \"0\")}`;\n}\n\n/** Returns \"weekly:YYYY-Www\" for the current ISO week. */\nexport function weeklyPeriodKey(now?: Date): string {\n  const d = now ?? new Date();\n  // ISO week calculation\n  const tmp = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()));\n  tmp.setUTCDate(tmp.getUTCDate() + 4 - (tmp.getUTCDay() || 7));\n  const yearStart = new Date(Date.UTC(tmp.getUTCFullYear(), 0, 1));\n  const weekNo = Math.ceil(((tmp.getTime() - yearStart.getTime()) / 86400000 + 1) / 7);\n  return `weekly:${tmp.getUTCFullYear()}-W${String(weekNo).padStart(2, \"0\")}`;\n}\n\n/** Returns midnight UTC of the next day (daily reset). */\nexport function dailyResetsAt(now?: Date): string {\n  const d = now ?? new Date();\n  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + 1));\n  return next.toISOString();\n}\n\n/** Returns midnight UTC of next Monday (weekly reset). */\nexport function weeklyResetsAt(now?: Date): string {\n  const d = now ?? new Date();\n  const dayOfWeek = d.getUTCDay(); // 0=Sun, 1=Mon, ...\n  const daysUntilMonday = dayOfWeek === 0 ? 1 : 8 - dayOfWeek;\n  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + daysUntilMonday));\n  return next.toISOString();\n}\n\n// ---------------------------------------------------------------------------\n// DB helpers\n// ---------------------------------------------------------------------------\n\n/** Expire stale assignments (expires_at < now AND status='active'). */\nasync function expireStaleAssignments(db: Db, userId: string): Promise<void> {\n  await db.rawSql`\n    UPDATE challenge_assignments\n    SET status = 'expired'\n    WHERE user_id = ${userId}\n      AND status = 'active'\n      AND expires_at IS NOT NULL\n      AND expires_at < now()\n  `;\n}\n\n/** Get assignments for a user in a given period, joined with challenge metadata. */\nasync function getAssignmentsForPeriod(\n  db: Db,\n  userId: string,\n  periodKey: string,\n): Promise<AssignmentRow[]> {\n  return db.rawSql<AssignmentRow[]>`\n    SELECT\n      ca.id,\n      ca.challenge_id,\n      ca.period_key,\n      ca.status,\n      ca.progress,\n      ca.target,\n      ca.expires_at,\n      ca.completed_at,\n      c.title,\n      c.description,\n      c.reward_type,\n      c.reward_amount,\n      camp.campaign_type\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    JOIN campaigns camp ON camp.id = c.campaign_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = ${periodKey}\n    ORDER BY c.sort_order ASC\n  `;\n}\n\n/** Get top N active challenges for a campaign, ordered by sort_order ASC. */\nasync function getActiveChallengesBySort(\n  db: Db,\n  campaignId: string,\n  limit: number,\n): Promise<ChallengeRow[]> {\n  return db.rawSql<ChallengeRow[]>`\n    SELECT id, campaign_id, title, description, action, scope, condition,\n           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n    FROM challenges\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n    ORDER BY sort_order ASC\n    LIMIT ${limit}\n  `;\n}\n\n/** Get the campaign ID for a given campaign type. */\nasync function getCampaignByType(\n  db: Db,\n  campaignType: string,\n): Promise<{ id: string } | null> {\n  const rows = await db.rawSql<{ id: string }[]>`\n    SELECT id FROM campaigns\n    WHERE campaign_type = ${campaignType}\n      AND is_active = true\n    ORDER BY id ASC\n    LIMIT 1\n  `;\n  return rows[0] ?? null;\n}\n\n/** Get all onboarding assignments for a user (any status). */\nasync function getOnboardingAssignments(\n  db: Db,\n  userId: string,\n): Promise<AssignmentRow[]> {\n  return db.rawSql<AssignmentRow[]>`\n    SELECT\n      ca.id,\n      ca.challenge_id,\n      ca.period_key,\n      ca.status,\n      ca.progress,\n      ca.target,\n      ca.expires_at,\n      ca.completed_at,\n      c.title,\n      c.description,\n      c.reward_type,\n      c.reward_amount,\n      camp.campaign_type\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    JOIN campaigns camp ON camp.id = c.campaign_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = 'onboarding'\n    ORDER BY c.sort_order ASC\n  `;\n}\n\n/** Get all onboarding challenge templates (ordered by chain). */\nasync function getOnboardingChallenges(\n  db: Db,\n  campaignId: string,\n): Promise<ChallengeRow[]> {\n  return db.rawSql<ChallengeRow[]>`\n    SELECT id, campaign_id, title, description, action, scope, condition,\n           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n    FROM challenges\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n    ORDER BY sort_order ASC\n  `;\n}\n\n/** Get completion bonuses for a campaign. */\nasync function getCompletionBonusesForCampaign(\n  db: Db,\n  campaignId: string,\n): Promise<CompletionBonusRow[]> {\n  return db.rawSql<CompletionBonusRow[]>`\n    SELECT id, title, required_count, reward_type, reward_amount\n    FROM completion_bonuses\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n  `;\n}\n\n/** Check if a bonus was completed for a user in a given period. */\nasync function getBonusCompletion(\n  db: Db,\n  userId: string,\n  bonusId: string,\n  periodKey: string,\n): Promise<BonusCompletionRow | null> {\n  const rows = await db.rawSql<BonusCompletionRow[]>`\n    SELECT id FROM bonus_completions\n    WHERE user_id = ${userId}\n      AND bonus_id = ${bonusId}\n      AND period_key = ${periodKey}\n    LIMIT 1\n  `;\n  return rows[0] ?? null;\n}\n\n/** Count completed assignments for a user in a period+campaign. */\nasync function countCompleted(\n  db: Db,\n  userId: string,\n  periodKey: string,\n  campaignId: string,\n): Promise<number> {\n  const rows = await db.rawSql<{ count: string }[]>`\n    SELECT COUNT(*)::TEXT AS count\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = ${periodKey}\n      AND ca.status = 'completed'\n      AND c.campaign_id = ${campaignId}\n  `;\n  return Number(rows[0]!.count);\n}\n\n/** Create an assignment (idempotent via UNIQUE). */\nasync function createAssignment(\n  db: Db,\n  userId: string,\n  challengeId: string,\n  periodKey: string,\n  target: number,\n  expiresAt: string | null,\n): Promise<void> {\n  await db.rawSql`\n    INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n    VALUES (${userId}, ${challengeId}, ${periodKey}, ${target}, ${expiresAt})\n    ON CONFLICT (user_id, challenge_id, period_key) DO NOTHING\n  `;\n}\n\n// ---------------------------------------------------------------------------\n// Response schemas\n// ---------------------------------------------------------------------------\n\nconst OnboardingStepSchema = ChallengeAssignmentSchema.extend({\n  locked: z.boolean().describe(\"True if prerequisite not yet completed\"),\n});\n\nconst OnboardingSchema = z\n  .object({\n    steps: z.array(OnboardingStepSchema),\n    completed: z.boolean(),\n  })\n  .nullable()\n  .describe(\"Null when all onboarding steps are completed.\");\n\nconst PeriodChallengesSchema = z.object({\n  challenges: z.array(ChallengeAssignmentSchema),\n  bonus: CompletionBonusSchema,\n  resetsAt: z.string().datetime(),\n});\n\nconst MyChallengesResponseSchema = z.object({\n  daily: PeriodChallengesSchema,\n  weekly: PeriodChallengesSchema,\n  onboarding: OnboardingSchema,\n});\n\nconst ChallengeHistoryResponseSchema = z.object({\n  items: z.array(ChallengeHistoryEntrySchema),\n  nextCursor: z.string().nullable(),\n});\n\n// ---------------------------------------------------------------------------\n// Route definitions\n// ---------------------------------------------------------------------------\n\nconst mineRoute = createRoute({\n  method: \"get\",\n  path: \"/mine\",\n  tags: [\"Challenges\"],\n  summary: \"Get active challenges for the authenticated player\",\n  description:\n    \"Returns daily, weekly, and onboarding challenges with lazy assignment on first call per period.\",\n  security: [{ bearerAuth: [] }],\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(MyChallengesResponseSchema) } },\n      description: \"Active challenges grouped by period\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\nconst historyRoute = createRoute({\n  method: \"get\",\n  path: \"/mine/history\",\n  tags: [\"Challenges\"],\n  summary: \"Paginated completed challenge history\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    query: z.object({\n      cursor: z.string().optional(),\n      limit: z.coerce.number().int().min(1).max(50).optional(),\n    }),\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(ChallengeHistoryResponseSchema) } },\n      description: \"Completed challenge assignments\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport function createChallengeRoutes(deps: ChallengeRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  app.openapi(mineRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    try {\n      const now = new Date();\n\n      // 1. Expire stale assignments\n      await expireStaleAssignments(db, userId);\n\n      // 2. Compute current period keys\n      const dailyKey = dailyPeriodKey(now);\n      const weeklyKey = weeklyPeriodKey(now);\n\n      // 3. Read config for challenge counts\n      const dailyCountStr = await readRewardConfig(db, \"daily_challenge_count\");\n      const weeklyCountStr = await readRewardConfig(db, \"weekly_challenge_count\");\n      const dailyCount = dailyCountStr ? Number(dailyCountStr) : 3;\n      const weeklyCount = weeklyCountStr ? Number(weeklyCountStr) : 2;\n\n      // 4. Look up campaign IDs\n      const [dailyCampaign, weeklyCampaign, onboardingCampaign] = await Promise.all([\n        getCampaignByType(db, \"daily\"),\n        getCampaignByType(db, \"weekly\"),\n        getCampaignByType(db, \"onboarding\"),\n      ]);\n\n      // 5. Lazy assignment — daily\n      let dailyAssignments = dailyCampaign\n        ? await getAssignmentsForPeriod(db, userId, dailyKey)\n        : [];\n\n      if (dailyAssignments.length === 0 && dailyCampaign) {\n        const templates = await getActiveChallengesBySort(db, dailyCampaign.id, dailyCount);\n        const dailyExpires = dailyResetsAt(now);\n        for (const t of templates) {\n          await createAssignment(db, userId, t.id, dailyKey, t.threshold, dailyExpires);\n        }\n        dailyAssignments = await getAssignmentsForPeriod(db, userId, dailyKey);\n      }\n\n      // 6. Lazy assignment — weekly\n      let weeklyAssignments = weeklyCampaign\n        ? await getAssignmentsForPeriod(db, userId, weeklyKey)\n        : [];\n\n      if (weeklyAssignments.length === 0 && weeklyCampaign) {\n        const templates = await getActiveChallengesBySort(db, weeklyCampaign.id, weeklyCount);\n        const weeklyExpires = weeklyResetsAt(now);\n        for (const t of templates) {\n          await createAssignment(db, userId, t.id, weeklyKey, t.threshold, weeklyExpires);\n        }\n        weeklyAssignments = await getAssignmentsForPeriod(db, userId, weeklyKey);\n      }\n\n      // 7. Lazy assignment — onboarding\n      let onboardingAssignments = onboardingCampaign\n        ? await getOnboardingAssignments(db, userId)\n        : [];\n\n      if (onboardingAssignments.length === 0 && onboardingCampaign) {\n        // Assign first step (prerequisite_id IS NULL)\n        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n        const firstStep = allSteps.find((s) => s.prerequisite_id === null);\n        if (firstStep) {\n          await createAssignment(db, userId, firstStep.id, \"onboarding\", firstStep.threshold, null);\n          onboardingAssignments = await getOnboardingAssignments(db, userId);\n        }\n      }\n\n      // 8. Build bonus status for daily\n      let dailyBonus: CompletionBonusType = null;\n      if (dailyCampaign) {\n        const bonuses = await getCompletionBonusesForCampaign(db, dailyCampaign.id);\n        if (bonuses.length > 0) {\n          const bonus = bonuses[0]!;\n          const completedCount = await countCompleted(db, userId, dailyKey, dailyCampaign.id);\n          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, dailyKey);\n          dailyBonus = {\n            title: bonus.title,\n            required: bonus.required_count,\n            completed: completedCount,\n            status: bonusCompletion ? \"completed\" as const : \"active\" as const,\n            reward: {\n              type: bonus.reward_type as \"points\" | \"crate\",\n              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n            },\n          };\n        }\n      }\n\n      // 9. Build bonus status for weekly\n      let weeklyBonus: CompletionBonusType = null;\n      if (weeklyCampaign) {\n        const bonuses = await getCompletionBonusesForCampaign(db, weeklyCampaign.id);\n        if (bonuses.length > 0) {\n          const bonus = bonuses[0]!;\n          const completedCount = await countCompleted(db, userId, weeklyKey, weeklyCampaign.id);\n          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, weeklyKey);\n          weeklyBonus = {\n            title: bonus.title,\n            required: bonus.required_count,\n            completed: completedCount,\n            status: bonusCompletion ? \"completed\" as const : \"active\" as const,\n            reward: {\n              type: bonus.reward_type as \"points\" | \"crate\",\n              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n            },\n          };\n        }\n      }\n\n      // 10. Build onboarding section\n      let onboarding: OnboardingType = null;\n      if (onboardingCampaign) {\n        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n        const assignedIds = new Set(onboardingAssignments.map((a) => a.challenge_id));\n        const completedIds = new Set(\n          onboardingAssignments.filter((a) => a.status === \"completed\").map((a) => a.challenge_id),\n        );\n        const allCompleted = allSteps.length > 0 && allSteps.every((s) => completedIds.has(s.id));\n\n        if (allCompleted) {\n          onboarding = null;\n        } else {\n          const steps = allSteps.map((step) => {\n            const assignment = onboardingAssignments.find((a) => a.challenge_id === step.id);\n            const isAssigned = assignedIds.has(step.id);\n            const locked = !isAssigned;\n            return {\n              id: Number(step.id),\n              title: step.title,\n              description: step.description,\n              progress: assignment ? assignment.progress : 0,\n              target: step.threshold,\n              status: assignment ? assignment.status as \"active\" | \"completed\" | \"expired\" : \"active\",\n              reward: {\n                type: step.reward_type as \"points\" | \"crate\",\n                ...(step.reward_amount != null ? { amount: step.reward_amount } : {}),\n              },\n              completedAt: assignment?.completed_at ?? null,\n              locked,\n            };\n          });\n          onboarding = { steps, completed: false };\n        }\n      }\n\n      // 11. Format response\n      const formatChallenge = (a: AssignmentRow): ChallengeAssignmentType => ({\n        id: Number(a.id),\n        title: a.title,\n        description: a.description,\n        progress: a.progress,\n        target: a.target,\n        status: a.status as \"active\" | \"completed\" | \"expired\",\n        reward: {\n          type: a.reward_type as \"points\" | \"crate\",\n          ...(a.reward_amount != null ? { amount: a.reward_amount } : {}),\n        },\n        completedAt: a.completed_at ?? null,\n      });\n\n      return ok(c, {\n        daily: {\n          challenges: dailyAssignments.map(formatChallenge),\n          bonus: dailyBonus,\n          resetsAt: dailyResetsAt(now),\n        },\n        weekly: {\n          challenges: weeklyAssignments.map(formatChallenge),\n          bonus: weeklyBonus,\n          resetsAt: weeklyResetsAt(now),\n        },\n        onboarding,\n      });\n    } catch (fetchError) {\n      logger.error(\"challenges/mine failed\", {\n        userId,\n        error: fetchError instanceof Error ? fetchError.message : String(fetchError),\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch challenges\",\n      );\n    }\n  });\n\n  // GET /mine/history — paginated completed challenge assignments\n  app.openapi(historyRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    const { cursor, limit: rawLimit } = c.req.valid(\"query\");\n    const limit = rawLimit ?? 20;\n\n    try {\n      const cursorFilter = cursor\n        ? db.rawSql`AND ca.id < ${cursor}`\n        : db.rawSql``;\n\n      const rows = await db.rawSql<\n        {\n          id: string;\n          title: string;\n          description: string;\n          completed_at: Date;\n          reward_type: string;\n          reward_amount: number | null;\n        }[]\n      >`\n        SELECT\n          ca.id,\n          c.title,\n          c.description,\n          ca.completed_at,\n          c.reward_type,\n          c.reward_amount\n        FROM challenge_assignments ca\n        JOIN challenges c ON c.id = ca.challenge_id\n        WHERE ca.user_id = ${userId}\n          AND ca.status = 'completed'\n          ${cursorFilter}\n        ORDER BY ca.id DESC\n        LIMIT ${limit}\n      `;\n\n      const items = rows.map((r: { id: string; title: string; description: string; completed_at: Date; reward_type: string; reward_amount: number | null }) => ({\n        id: Number(r.id),\n        title: r.title,\n        description: r.description,\n        completedAt: r.completed_at.toISOString(),\n        reward: {\n          type: r.reward_type as \"points\" | \"crate\",\n          ...(r.reward_amount != null ? { amount: r.reward_amount } : {}),\n        },\n      }));\n\n      const nextCursor =\n        items.length === limit ? String(items[items.length - 1]!.id) : null;\n\n      return ok(c, { items, nextCursor });\n    } catch (queryError) {\n      logger.error(\"challenges/mine/history failed\", {\n        userId,\n        error: queryError instanceof Error ? queryError.message : String(queryError),\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch challenge history\",\n      );\n    }\n  });\n\n  return app;\n}\n","numLines":671,"startLine":1,"totalLines":671}}}
