pect(assignments.length).toBe(6);\n146\t    });\n147\t\n148\t    it(\"expired assignments are marked expired on read\", async () => {\n149\t      const token = await makeJwt(testWallet, testUserId);\n150\t\n151\t      const dailyCampaign = await rawSql<{ id: string }[]>`\n152\t        SELECT id FROM campaigns WHERE campaign_type = 'daily' LIMIT 1\n153\t      `;\n154\t      const challenges = await rawSql<{ id: string; threshold: number }[]>`\n155\t        SELECT id, threshold\n156\t        FROM challenges\n157\t        WHERE campaign_id = ${dailyCampaign[0]!.id} AND is_active = true\n158\t        ORDER BY sort_order ASC\n159\t        LIMIT 1\n160\t      `;\n161\t      await rawSql`\n162\t        INSERT INTO challenge_assignments (\n163\t          user_id,\n164\t          challenge_id,\n165\t          period_key,\n166\t          target,\n167\t          expires_at\n168\t        )\n169\t        VALUES (\n170\t          ${testUserId},\n171\t          ${challenges[0]!.id},\n172\t          'daily:2020-01-01',\n173\t          ${challenges[0]!.threshold},\n174\t          '2020-01-02T00:00:00Z'\n175\t        )\n176\t      `;\n177\t\n178\t      const before = await rawSql<{ status: string }[]>`\n179\t        SELECT status\n180\t        FROM challenge_assignments\n181\t        WHERE user_id = ${testUserId} AND period_key = 'daily:2020-01-01'\n182\t      `;\n183\t      expect(before[0]!.status).toBe(\"active\");\n184\t\n185\t      await app.request(\"/challenges/mine\", {\n186\t        method: \"GET\",\n187\t        headers: { Authorization: `Bearer ${token}` },\n188\t      });\n189\t\n190\t      const after = await rawSql<{ status: string }[]>`\n191\t        SELECT status\n192\t        FROM challenge_assignments\n193\t        WHERE user_id = ${testUserId} AND period_key = 'daily:2020-01-01'\n194\t      `;\n195\t      expect(after[0]!.status).toBe(\"expired\");\n196\t    });\n197\t  });\n198\t\n199\t  describe(\"GET /challenges/mine/history\", () => {\n200\t    let app: Hono;\n