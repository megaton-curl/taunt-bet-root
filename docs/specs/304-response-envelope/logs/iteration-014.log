{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01L6eJ8weu2Yn8vdGrv42hDJ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_014bHmiUtzGgNiuA8JtbufK5","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/backend/src/routes/challenges.ts","old_string":"import { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { readRewardConfig } from \"../queue/handlers/reward-pool-fund.js\";\nimport {\n  ChallengeAssignmentSchema,\n  ChallengeHistoryEntrySchema,\n  CompletionBonusSchema,\n  ErrorResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";","new_string":"import { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { readRewardConfig } from \"../queue/handlers/reward-pool-fund.js\";\nimport {\n  ChallengeAssignmentSchema,\n  ChallengeHistoryEntrySchema,\n  CompletionBonusSchema,\n} from \"../contracts/validators.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3509,"cache_read_input_tokens":89111,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3509},"output_tokens":72,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"ea182426-3468-4ae1-8ebd-e6f6cd94f8d2","uuid":"c59ad77d-e43d-4858-9c07-47ae5b0d5a0e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014bHmiUtzGgNiuA8JtbufK5","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/src/routes/challenges.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"ea182426-3468-4ae1-8ebd-e6f6cd94f8d2","uuid":"e28946aa-9482-45b0-ba31-0ca8923eea89","timestamp":"2026-04-22T10:29:03.583Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/src/routes/challenges.ts","oldString":"import { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { readRewardConfig } from \"../queue/handlers/reward-pool-fund.js\";\nimport {\n  ChallengeAssignmentSchema,\n  ChallengeHistoryEntrySchema,\n  CompletionBonusSchema,\n  ErrorResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";","newString":"import { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { readRewardConfig } from \"../queue/handlers/reward-pool-fund.js\";\nimport {\n  ChallengeAssignmentSchema,\n  ChallengeHistoryEntrySchema,\n  CompletionBonusSchema,\n} from \"../contracts/validators.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";","originalFile":"/**\n * Challenge routes — player-facing challenge/quest endpoints.\n *\n * GET /mine           — returns active daily, weekly, and onboarding challenges\n *                       with lazy assignment on first call per period.\n * GET /mine/history   — paginated completed challenge assignments.\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { readRewardConfig } from \"../queue/handlers/reward-pool-fund.js\";\nimport {\n  ChallengeAssignmentSchema,\n  ChallengeHistoryEntrySchema,\n  CompletionBonusSchema,\n  ErrorResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\n// Inferred types for handler return value typing\ntype CompletionBonusType = z.infer<typeof CompletionBonusSchema>;\ntype ChallengeAssignmentType = z.infer<typeof ChallengeAssignmentSchema>;\ntype OnboardingStepType = ChallengeAssignmentType & { locked: boolean };\ntype OnboardingType = { steps: OnboardingStepType[]; completed: boolean } | null;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface ChallengeRoutesDeps {\n  db: Db;\n}\n\ninterface ChallengeRow {\n  id: string;\n  campaign_id: string;\n  title: string;\n  description: string;\n  action: string;\n  scope: string;\n  condition: string;\n  threshold: number;\n  reward_type: string;\n  reward_amount: number | null;\n  sort_order: number;\n  prerequisite_id: string | null;\n}\n\ninterface AssignmentRow {\n  id: string;\n  challenge_id: string;\n  period_key: string;\n  status: string;\n  progress: number;\n  target: number;\n  expires_at: string | null;\n  completed_at: string | null;\n  title: string;\n  description: string;\n  reward_type: string;\n  reward_amount: number | null;\n  campaign_type: string;\n}\n\ninterface CompletionBonusRow {\n  id: string;\n  title: string;\n  required_count: number;\n  reward_type: string;\n  reward_amount: number | null;\n}\n\ninterface BonusCompletionRow {\n  id: string;\n}\n\n// ---------------------------------------------------------------------------\n// Period key helpers\n// ---------------------------------------------------------------------------\n\n/** Returns \"daily:YYYY-MM-DD\" for the current UTC date. */\nexport function dailyPeriodKey(now?: Date): string {\n  const d = now ?? new Date();\n  return `daily:${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, \"0\")}-${String(d.getUTCDate()).padStart(2, \"0\")}`;\n}\n\n/** Returns \"weekly:YYYY-Www\" for the current ISO week. */\nexport function weeklyPeriodKey(now?: Date): string {\n  const d = now ?? new Date();\n  // ISO week calculation\n  const tmp = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()));\n  tmp.setUTCDate(tmp.getUTCDate() + 4 - (tmp.getUTCDay() || 7));\n  const yearStart = new Date(Date.UTC(tmp.getUTCFullYear(), 0, 1));\n  const weekNo = Math.ceil(((tmp.getTime() - yearStart.getTime()) / 86400000 + 1) / 7);\n  return `weekly:${tmp.getUTCFullYear()}-W${String(weekNo).padStart(2, \"0\")}`;\n}\n\n/** Returns midnight UTC of the next day (daily reset). */\nexport function dailyResetsAt(now?: Date): string {\n  const d = now ?? new Date();\n  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + 1));\n  return next.toISOString();\n}\n\n/** Returns midnight UTC of next Monday (weekly reset). */\nexport function weeklyResetsAt(now?: Date): string {\n  const d = now ?? new Date();\n  const dayOfWeek = d.getUTCDay(); // 0=Sun, 1=Mon, ...\n  const daysUntilMonday = dayOfWeek === 0 ? 1 : 8 - dayOfWeek;\n  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + daysUntilMonday));\n  return next.toISOString();\n}\n\n// ---------------------------------------------------------------------------\n// DB helpers\n// ---------------------------------------------------------------------------\n\n/** Expire stale assignments (expires_at < now AND status='active'). */\nasync function expireStaleAssignments(db: Db, userId: string): Promise<void> {\n  await db.rawSql`\n    UPDATE challenge_assignments\n    SET status = 'expired'\n    WHERE user_id = ${userId}\n      AND status = 'active'\n      AND expires_at IS NOT NULL\n      AND expires_at < now()\n  `;\n}\n\n/** Get assignments for a user in a given period, joined with challenge metadata. */\nasync function getAssignmentsForPeriod(\n  db: Db,\n  userId: string,\n  periodKey: string,\n): Promise<AssignmentRow[]> {\n  return db.rawSql<AssignmentRow[]>`\n    SELECT\n      ca.id,\n      ca.challenge_id,\n      ca.period_key,\n      ca.status,\n      ca.progress,\n      ca.target,\n      ca.expires_at,\n      ca.completed_at,\n      c.title,\n      c.description,\n      c.reward_type,\n      c.reward_amount,\n      camp.campaign_type\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    JOIN campaigns camp ON camp.id = c.campaign_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = ${periodKey}\n    ORDER BY c.sort_order ASC\n  `;\n}\n\n/** Get top N active challenges for a campaign, ordered by sort_order ASC. */\nasync function getActiveChallengesBySort(\n  db: Db,\n  campaignId: string,\n  limit: number,\n): Promise<ChallengeRow[]> {\n  return db.rawSql<ChallengeRow[]>`\n    SELECT id, campaign_id, title, description, action, scope, condition,\n           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n    FROM challenges\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n    ORDER BY sort_order ASC\n    LIMIT ${limit}\n  `;\n}\n\n/** Get the campaign ID for a given campaign type. */\nasync function getCampaignByType(\n  db: Db,\n  campaignType: string,\n): Promise<{ id: string } | null> {\n  const rows = await db.rawSql<{ id: string }[]>`\n    SELECT id FROM campaigns\n    WHERE campaign_type = ${campaignType}\n      AND is_active = true\n    ORDER BY id ASC\n    LIMIT 1\n  `;\n  return rows[0] ?? null;\n}\n\n/** Get all onboarding assignments for a user (any status). */\nasync function getOnboardingAssignments(\n  db: Db,\n  userId: string,\n): Promise<AssignmentRow[]> {\n  return db.rawSql<AssignmentRow[]>`\n    SELECT\n      ca.id,\n      ca.challenge_id,\n      ca.period_key,\n      ca.status,\n      ca.progress,\n      ca.target,\n      ca.expires_at,\n      ca.completed_at,\n      c.title,\n      c.description,\n      c.reward_type,\n      c.reward_amount,\n      camp.campaign_type\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    JOIN campaigns camp ON camp.id = c.campaign_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = 'onboarding'\n    ORDER BY c.sort_order ASC\n  `;\n}\n\n/** Get all onboarding challenge templates (ordered by chain). */\nasync function getOnboardingChallenges(\n  db: Db,\n  campaignId: string,\n): Promise<ChallengeRow[]> {\n  return db.rawSql<ChallengeRow[]>`\n    SELECT id, campaign_id, title, description, action, scope, condition,\n           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n    FROM challenges\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n    ORDER BY sort_order ASC\n  `;\n}\n\n/** Get completion bonuses for a campaign. */\nasync function getCompletionBonusesForCampaign(\n  db: Db,\n  campaignId: string,\n): Promise<CompletionBonusRow[]> {\n  return db.rawSql<CompletionBonusRow[]>`\n    SELECT id, title, required_count, reward_type, reward_amount\n    FROM completion_bonuses\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n  `;\n}\n\n/** Check if a bonus was completed for a user in a given period. */\nasync function getBonusCompletion(\n  db: Db,\n  userId: string,\n  bonusId: string,\n  periodKey: string,\n): Promise<BonusCompletionRow | null> {\n  const rows = await db.rawSql<BonusCompletionRow[]>`\n    SELECT id FROM bonus_completions\n    WHERE user_id = ${userId}\n      AND bonus_id = ${bonusId}\n      AND period_key = ${periodKey}\n    LIMIT 1\n  `;\n  return rows[0] ?? null;\n}\n\n/** Count completed assignments for a user in a period+campaign. */\nasync function countCompleted(\n  db: Db,\n  userId: string,\n  periodKey: string,\n  campaignId: string,\n): Promise<number> {\n  const rows = await db.rawSql<{ count: string }[]>`\n    SELECT COUNT(*)::TEXT AS count\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = ${periodKey}\n      AND ca.status = 'completed'\n      AND c.campaign_id = ${campaignId}\n  `;\n  return Number(rows[0]!.count);\n}\n\n/** Create an assignment (idempotent via UNIQUE). */\nasync function createAssignment(\n  db: Db,\n  userId: string,\n  challengeId: string,\n  periodKey: string,\n  target: number,\n  expiresAt: string | null,\n): Promise<void> {\n  await db.rawSql`\n    INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n    VALUES (${userId}, ${challengeId}, ${periodKey}, ${target}, ${expiresAt})\n    ON CONFLICT (user_id, challenge_id, period_key) DO NOTHING\n  `;\n}\n\n// ---------------------------------------------------------------------------\n// Response schemas\n// ---------------------------------------------------------------------------\n\nconst OnboardingStepSchema = ChallengeAssignmentSchema.extend({\n  locked: z.boolean().describe(\"True if prerequisite not yet completed\"),\n});\n\nconst OnboardingSchema = z\n  .object({\n    steps: z.array(OnboardingStepSchema),\n    completed: z.boolean(),\n  })\n  .nullable()\n  .describe(\"Null when all onboarding steps are completed.\");\n\nconst PeriodChallengesSchema = z.object({\n  challenges: z.array(ChallengeAssignmentSchema),\n  bonus: CompletionBonusSchema,\n  resetsAt: z.string().datetime(),\n});\n\nconst MyChallengesResponseSchema = z.object({\n  daily: PeriodChallengesSchema,\n  weekly: PeriodChallengesSchema,\n  onboarding: OnboardingSchema,\n});\n\nconst ChallengeHistoryResponseSchema = z.object({\n  items: z.array(ChallengeHistoryEntrySchema),\n  nextCursor: z.string().nullable(),\n});\n\n// ---------------------------------------------------------------------------\n// Route definitions\n// ---------------------------------------------------------------------------\n\nconst mineRoute = createRoute({\n  method: \"get\",\n  path: \"/mine\",\n  tags: [\"Challenges\"],\n  summary: \"Get active challenges for the authenticated player\",\n  description:\n    \"Returns daily, weekly, and onboarding challenges with lazy assignment on first call per period.\",\n  security: [{ bearerAuth: [] }],\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: MyChallengesResponseSchema } },\n      description: \"Active challenges grouped by period\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\nconst historyRoute = createRoute({\n  method: \"get\",\n  path: \"/mine/history\",\n  tags: [\"Challenges\"],\n  summary: \"Paginated completed challenge history\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    query: z.object({\n      cursor: z.string().optional(),\n      limit: z.coerce.number().int().min(1).max(50).optional(),\n    }),\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: ChallengeHistoryResponseSchema } },\n      description: \"Completed challenge assignments\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport function createChallengeRoutes(deps: ChallengeRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  app.openapi(mineRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    try {\n      const now = new Date();\n\n      // 1. Expire stale assignments\n      await expireStaleAssignments(db, userId);\n\n      // 2. Compute current period keys\n      const dailyKey = dailyPeriodKey(now);\n      const weeklyKey = weeklyPeriodKey(now);\n\n      // 3. Read config for challenge counts\n      const dailyCountStr = await readRewardConfig(db, \"daily_challenge_count\");\n      const weeklyCountStr = await readRewardConfig(db, \"weekly_challenge_count\");\n      const dailyCount = dailyCountStr ? Number(dailyCountStr) : 3;\n      const weeklyCount = weeklyCountStr ? Number(weeklyCountStr) : 2;\n\n      // 4. Look up campaign IDs\n      const [dailyCampaign, weeklyCampaign, onboardingCampaign] = await Promise.all([\n        getCampaignByType(db, \"daily\"),\n        getCampaignByType(db, \"weekly\"),\n        getCampaignByType(db, \"onboarding\"),\n      ]);\n\n      // 5. Lazy assignment — daily\n      let dailyAssignments = dailyCampaign\n        ? await getAssignmentsForPeriod(db, userId, dailyKey)\n        : [];\n\n      if (dailyAssignments.length === 0 && dailyCampaign) {\n        const templates = await getActiveChallengesBySort(db, dailyCampaign.id, dailyCount);\n        const dailyExpires = dailyResetsAt(now);\n        for (const t of templates) {\n          await createAssignment(db, userId, t.id, dailyKey, t.threshold, dailyExpires);\n        }\n        dailyAssignments = await getAssignmentsForPeriod(db, userId, dailyKey);\n      }\n\n      // 6. Lazy assignment — weekly\n      let weeklyAssignments = weeklyCampaign\n        ? await getAssignmentsForPeriod(db, userId, weeklyKey)\n        : [];\n\n      if (weeklyAssignments.length === 0 && weeklyCampaign) {\n        const templates = await getActiveChallengesBySort(db, weeklyCampaign.id, weeklyCount);\n        const weeklyExpires = weeklyResetsAt(now);\n        for (const t of templates) {\n          await createAssignment(db, userId, t.id, weeklyKey, t.threshold, weeklyExpires);\n        }\n        weeklyAssignments = await getAssignmentsForPeriod(db, userId, weeklyKey);\n      }\n\n      // 7. Lazy assignment — onboarding\n      let onboardingAssignments = onboardingCampaign\n        ? await getOnboardingAssignments(db, userId)\n        : [];\n\n      if (onboardingAssignments.length === 0 && onboardingCampaign) {\n        // Assign first step (prerequisite_id IS NULL)\n        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n        const firstStep = allSteps.find((s) => s.prerequisite_id === null);\n        if (firstStep) {\n          await createAssignment(db, userId, firstStep.id, \"onboarding\", firstStep.threshold, null);\n          onboardingAssignments = await getOnboardingAssignments(db, userId);\n        }\n      }\n\n      // 8. Build bonus status for daily\n      let dailyBonus: CompletionBonusType = null;\n      if (dailyCampaign) {\n        const bonuses = await getCompletionBonusesForCampaign(db, dailyCampaign.id);\n        if (bonuses.length > 0) {\n          const bonus = bonuses[0]!;\n          const completedCount = await countCompleted(db, userId, dailyKey, dailyCampaign.id);\n          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, dailyKey);\n          dailyBonus = {\n            title: bonus.title,\n            required: bonus.required_count,\n            completed: completedCount,\n            status: bonusCompletion ? \"completed\" as const : \"active\" as const,\n            reward: {\n              type: bonus.reward_type as \"points\" | \"crate\",\n              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n            },\n          };\n        }\n      }\n\n      // 9. Build bonus status for weekly\n      let weeklyBonus: CompletionBonusType = null;\n      if (weeklyCampaign) {\n        const bonuses = await getCompletionBonusesForCampaign(db, weeklyCampaign.id);\n        if (bonuses.length > 0) {\n          const bonus = bonuses[0]!;\n          const completedCount = await countCompleted(db, userId, weeklyKey, weeklyCampaign.id);\n          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, weeklyKey);\n          weeklyBonus = {\n            title: bonus.title,\n            required: bonus.required_count,\n            completed: completedCount,\n            status: bonusCompletion ? \"completed\" as const : \"active\" as const,\n            reward: {\n              type: bonus.reward_type as \"points\" | \"crate\",\n              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n            },\n          };\n        }\n      }\n\n      // 10. Build onboarding section\n      let onboarding: OnboardingType = null;\n      if (onboardingCampaign) {\n        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n        const assignedIds = new Set(onboardingAssignments.map((a) => a.challenge_id));\n        const completedIds = new Set(\n          onboardingAssignments.filter((a) => a.status === \"completed\").map((a) => a.challenge_id),\n        );\n        const allCompleted = allSteps.length > 0 && allSteps.every((s) => completedIds.has(s.id));\n\n        if (allCompleted) {\n          onboarding = null;\n        } else {\n          const steps = allSteps.map((step) => {\n            const assignment = onboardingAssignments.find((a) => a.challenge_id === step.id);\n            const isAssigned = assignedIds.has(step.id);\n            const locked = !isAssigned;\n            return {\n              id: Number(step.id),\n              title: step.title,\n              description: step.description,\n              progress: assignment ? assignment.progress : 0,\n              target: step.threshold,\n              status: assignment ? assignment.status as \"active\" | \"completed\" | \"expired\" : \"active\",\n              reward: {\n                type: step.reward_type as \"points\" | \"crate\",\n                ...(step.reward_amount != null ? { amount: step.reward_amount } : {}),\n              },\n              completedAt: assignment?.completed_at ?? null,\n              locked,\n            };\n          });\n          onboarding = { steps, completed: false };\n        }\n      }\n\n      // 11. Format response\n      const formatChallenge = (a: AssignmentRow): ChallengeAssignmentType => ({\n        id: Number(a.id),\n        title: a.title,\n        description: a.description,\n        progress: a.progress,\n        target: a.target,\n        status: a.status as \"active\" | \"completed\" | \"expired\",\n        reward: {\n          type: a.reward_type as \"points\" | \"crate\",\n          ...(a.reward_amount != null ? { amount: a.reward_amount } : {}),\n        },\n        completedAt: a.completed_at ?? null,\n      });\n\n      return c.json({\n        daily: {\n          challenges: dailyAssignments.map(formatChallenge),\n          bonus: dailyBonus,\n          resetsAt: dailyResetsAt(now),\n        },\n        weekly: {\n          challenges: weeklyAssignments.map(formatChallenge),\n          bonus: weeklyBonus,\n          resetsAt: weeklyResetsAt(now),\n        },\n        onboarding,\n      }, 200);\n    } catch (err) {\n      logger.error(\"challenges/mine failed\", {\n        userId,\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ error: \"Failed to fetch challenges\" }, 500);\n    }\n  });\n\n  // GET /mine/history — paginated completed challenge assignments\n  app.openapi(historyRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    const { cursor, limit: rawLimit } = c.req.valid(\"query\");\n    const limit = rawLimit ?? 20;\n\n    try {\n      const cursorFilter = cursor\n        ? db.rawSql`AND ca.id < ${cursor}`\n        : db.rawSql``;\n\n      const rows = await db.rawSql<\n        {\n          id: string;\n          title: string;\n          description: string;\n          completed_at: Date;\n          reward_type: string;\n          reward_amount: number | null;\n        }[]\n      >`\n        SELECT\n          ca.id,\n          c.title,\n          c.description,\n          ca.completed_at,\n          c.reward_type,\n          c.reward_amount\n        FROM challenge_assignments ca\n        JOIN challenges c ON c.id = ca.challenge_id\n        WHERE ca.user_id = ${userId}\n          AND ca.status = 'completed'\n          ${cursorFilter}\n        ORDER BY ca.id DESC\n        LIMIT ${limit}\n      `;\n\n      const items = rows.map((r: { id: string; title: string; description: string; completed_at: Date; reward_type: string; reward_amount: number | null }) => ({\n        id: Number(r.id),\n        title: r.title,\n        description: r.description,\n        completedAt: r.completed_at.toISOString(),\n        reward: {\n          type: r.reward_type as \"points\" | \"crate\",\n          ...(r.reward_amount != null ? { amount: r.reward_amount } : {}),\n        },\n      }));\n\n      const nextCursor =\n        items.length === limit ? String(items[items.length - 1]!.id) : null;\n\n      return c.json({ items, nextCursor }, 200);\n    } catch (err) {\n      logger.error(\"challenges/mine/history failed\", {\n        userId,\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ error: \"Failed to fetch challenge history\" }, 500);\n    }\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":16,"oldLines":8,"newStart":16,"newLines":14,"lines":["   ChallengeAssignmentSchema,","   ChallengeHistoryEntrySchema,","   CompletionBonusSchema,","-  ErrorResponseSchema,"," } from \"../contracts/validators.js\";","+import { API_ERROR_CODES } from \"../contracts/api-errors.js\";","+import {","+  envelope,","+  ErrorEnvelopeSchema,","+  ok,","+  err,","+} from \"../contracts/api-envelope.js\";"," import { createOpenApiApp } from \"../openapi/hono.js\";"," "," // Inferred types for handler return value typing"]}],"userModified":false,"replaceAll":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_015LYhSUk5EnveTqUJJAutGe","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01UAj4ZKjiYeyU37P5prXN73","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/backend/src/routes/challenges.ts","old_string":"  responses: {\n    200: {\n      content: { \"application/json\": { schema: MyChallengesResponseSchema } },\n      description: \"Active challenges grouped by period\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\nconst historyRoute = createRoute({","new_string":"  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(MyChallengesResponseSchema) } },\n      description: \"Active challenges grouped by period\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\nconst historyRoute = createRoute({"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":924,"cache_read_input_tokens":92620,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":924},"output_tokens":64,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"ea182426-3468-4ae1-8ebd-e6f6cd94f8d2","uuid":"417779f5-cec0-4e70-befc-9983f9e30062"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UAj4ZKjiYeyU37P5prXN73","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/src/routes/challenges.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"ea182426-3468-4ae1-8ebd-e6f6cd94f8d2","uuid":"f70543be-b5f1-439c-a413-9321aedc7b0f","timestamp":"2026-04-22T10:29:09.599Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/src/routes/challenges.ts","oldString":"  responses: {\n    200: {\n      content: { \"application/json\": { schema: MyChallengesResponseSchema } },\n      description: \"Active challenges grouped by period\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\nconst historyRoute = createRoute({","newString":"  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(MyChallengesResponseSchema) } },\n      description: \"Active challenges grouped by period\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\nconst historyRoute = createRoute({","originalFile":"/**\n * Challenge routes — player-facing challenge/quest endpoints.\n *\n * GET /mine           — returns active daily, weekly, and onboarding challenges\n *                       with lazy assignment on first call per period.\n * GET /mine/history   — paginated completed challenge assignments.\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { readRewardConfig } from \"../queue/handlers/reward-pool-fund.js\";\nimport {\n  ChallengeAssignmentSchema,\n  ChallengeHistoryEntrySchema,\n  CompletionBonusSchema,\n} from \"../contracts/validators.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\n// Inferred types for handler return value typing\ntype CompletionBonusType = z.infer<typeof CompletionBonusSchema>;\ntype ChallengeAssignmentType = z.infer<typeof ChallengeAssignmentSchema>;\ntype OnboardingStepType = ChallengeAssignmentType & { locked: boolean };\ntype OnboardingType = { steps: OnboardingStepType[]; completed: boolean } | null;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface ChallengeRoutesDeps {\n  db: Db;\n}\n\ninterface ChallengeRow {\n  id: string;\n  campaign_id: string;\n  title: string;\n  description: string;\n  action: string;\n  scope: string;\n  condition: string;\n  threshold: number;\n  reward_type: string;\n  reward_amount: number | null;\n  sort_order: number;\n  prerequisite_id: string | null;\n}\n\ninterface AssignmentRow {\n  id: string;\n  challenge_id: string;\n  period_key: string;\n  status: string;\n  progress: number;\n  target: number;\n  expires_at: string | null;\n  completed_at: string | null;\n  title: string;\n  description: string;\n  reward_type: string;\n  reward_amount: number | null;\n  campaign_type: string;\n}\n\ninterface CompletionBonusRow {\n  id: string;\n  title: string;\n  required_count: number;\n  reward_type: string;\n  reward_amount: number | null;\n}\n\ninterface BonusCompletionRow {\n  id: string;\n}\n\n// ---------------------------------------------------------------------------\n// Period key helpers\n// ---------------------------------------------------------------------------\n\n/** Returns \"daily:YYYY-MM-DD\" for the current UTC date. */\nexport function dailyPeriodKey(now?: Date): string {\n  const d = now ?? new Date();\n  return `daily:${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, \"0\")}-${String(d.getUTCDate()).padStart(2, \"0\")}`;\n}\n\n/** Returns \"weekly:YYYY-Www\" for the current ISO week. */\nexport function weeklyPeriodKey(now?: Date): string {\n  const d = now ?? new Date();\n  // ISO week calculation\n  const tmp = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()));\n  tmp.setUTCDate(tmp.getUTCDate() + 4 - (tmp.getUTCDay() || 7));\n  const yearStart = new Date(Date.UTC(tmp.getUTCFullYear(), 0, 1));\n  const weekNo = Math.ceil(((tmp.getTime() - yearStart.getTime()) / 86400000 + 1) / 7);\n  return `weekly:${tmp.getUTCFullYear()}-W${String(weekNo).padStart(2, \"0\")}`;\n}\n\n/** Returns midnight UTC of the next day (daily reset). */\nexport function dailyResetsAt(now?: Date): string {\n  const d = now ?? new Date();\n  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + 1));\n  return next.toISOString();\n}\n\n/** Returns midnight UTC of next Monday (weekly reset). */\nexport function weeklyResetsAt(now?: Date): string {\n  const d = now ?? new Date();\n  const dayOfWeek = d.getUTCDay(); // 0=Sun, 1=Mon, ...\n  const daysUntilMonday = dayOfWeek === 0 ? 1 : 8 - dayOfWeek;\n  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + daysUntilMonday));\n  return next.toISOString();\n}\n\n// ---------------------------------------------------------------------------\n// DB helpers\n// ---------------------------------------------------------------------------\n\n/** Expire stale assignments (expires_at < now AND status='active'). */\nasync function expireStaleAssignments(db: Db, userId: string): Promise<void> {\n  await db.rawSql`\n    UPDATE challenge_assignments\n    SET status = 'expired'\n    WHERE user_id = ${userId}\n      AND status = 'active'\n      AND expires_at IS NOT NULL\n      AND expires_at < now()\n  `;\n}\n\n/** Get assignments for a user in a given period, joined with challenge metadata. */\nasync function getAssignmentsForPeriod(\n  db: Db,\n  userId: string,\n  periodKey: string,\n): Promise<AssignmentRow[]> {\n  return db.rawSql<AssignmentRow[]>`\n    SELECT\n      ca.id,\n      ca.challenge_id,\n      ca.period_key,\n      ca.status,\n      ca.progress,\n      ca.target,\n      ca.expires_at,\n      ca.completed_at,\n      c.title,\n      c.description,\n      c.reward_type,\n      c.reward_amount,\n      camp.campaign_type\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    JOIN campaigns camp ON camp.id = c.campaign_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = ${periodKey}\n    ORDER BY c.sort_order ASC\n  `;\n}\n\n/** Get top N active challenges for a campaign, ordered by sort_order ASC. */\nasync function getActiveChallengesBySort(\n  db: Db,\n  campaignId: string,\n  limit: number,\n): Promise<ChallengeRow[]> {\n  return db.rawSql<ChallengeRow[]>`\n    SELECT id, campaign_id, title, description, action, scope, condition,\n           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n    FROM challenges\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n    ORDER BY sort_order ASC\n    LIMIT ${limit}\n  `;\n}\n\n/** Get the campaign ID for a given campaign type. */\nasync function getCampaignByType(\n  db: Db,\n  campaignType: string,\n): Promise<{ id: string } | null> {\n  const rows = await db.rawSql<{ id: string }[]>`\n    SELECT id FROM campaigns\n    WHERE campaign_type = ${campaignType}\n      AND is_active = true\n    ORDER BY id ASC\n    LIMIT 1\n  `;\n  return rows[0] ?? null;\n}\n\n/** Get all onboarding assignments for a user (any status). */\nasync function getOnboardingAssignments(\n  db: Db,\n  userId: string,\n): Promise<AssignmentRow[]> {\n  return db.rawSql<AssignmentRow[]>`\n    SELECT\n      ca.id,\n      ca.challenge_id,\n      ca.period_key,\n      ca.status,\n      ca.progress,\n      ca.target,\n      ca.expires_at,\n      ca.completed_at,\n      c.title,\n      c.description,\n      c.reward_type,\n      c.reward_amount,\n      camp.campaign_type\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    JOIN campaigns camp ON camp.id = c.campaign_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = 'onboarding'\n    ORDER BY c.sort_order ASC\n  `;\n}\n\n/** Get all onboarding challenge templates (ordered by chain). */\nasync function getOnboardingChallenges(\n  db: Db,\n  campaignId: string,\n): Promise<ChallengeRow[]> {\n  return db.rawSql<ChallengeRow[]>`\n    SELECT id, campaign_id, title, description, action, scope, condition,\n           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n    FROM challenges\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n    ORDER BY sort_order ASC\n  `;\n}\n\n/** Get completion bonuses for a campaign. */\nasync function getCompletionBonusesForCampaign(\n  db: Db,\n  campaignId: string,\n): Promise<CompletionBonusRow[]> {\n  return db.rawSql<CompletionBonusRow[]>`\n    SELECT id, title, required_count, reward_type, reward_amount\n    FROM completion_bonuses\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n  `;\n}\n\n/** Check if a bonus was completed for a user in a given period. */\nasync function getBonusCompletion(\n  db: Db,\n  userId: string,\n  bonusId: string,\n  periodKey: string,\n): Promise<BonusCompletionRow | null> {\n  const rows = await db.rawSql<BonusCompletionRow[]>`\n    SELECT id FROM bonus_completions\n    WHERE user_id = ${userId}\n      AND bonus_id = ${bonusId}\n      AND period_key = ${periodKey}\n    LIMIT 1\n  `;\n  return rows[0] ?? null;\n}\n\n/** Count completed assignments for a user in a period+campaign. */\nasync function countCompleted(\n  db: Db,\n  userId: string,\n  periodKey: string,\n  campaignId: string,\n): Promise<number> {\n  const rows = await db.rawSql<{ count: string }[]>`\n    SELECT COUNT(*)::TEXT AS count\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = ${periodKey}\n      AND ca.status = 'completed'\n      AND c.campaign_id = ${campaignId}\n  `;\n  return Number(rows[0]!.count);\n}\n\n/** Create an assignment (idempotent via UNIQUE). */\nasync function createAssignment(\n  db: Db,\n  userId: string,\n  challengeId: string,\n  periodKey: string,\n  target: number,\n  expiresAt: string | null,\n): Promise<void> {\n  await db.rawSql`\n    INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n    VALUES (${userId}, ${challengeId}, ${periodKey}, ${target}, ${expiresAt})\n    ON CONFLICT (user_id, challenge_id, period_key) DO NOTHING\n  `;\n}\n\n// ---------------------------------------------------------------------------\n// Response schemas\n// ---------------------------------------------------------------------------\n\nconst OnboardingStepSchema = ChallengeAssignmentSchema.extend({\n  locked: z.boolean().describe(\"True if prerequisite not yet completed\"),\n});\n\nconst OnboardingSchema = z\n  .object({\n    steps: z.array(OnboardingStepSchema),\n    completed: z.boolean(),\n  })\n  .nullable()\n  .describe(\"Null when all onboarding steps are completed.\");\n\nconst PeriodChallengesSchema = z.object({\n  challenges: z.array(ChallengeAssignmentSchema),\n  bonus: CompletionBonusSchema,\n  resetsAt: z.string().datetime(),\n});\n\nconst MyChallengesResponseSchema = z.object({\n  daily: PeriodChallengesSchema,\n  weekly: PeriodChallengesSchema,\n  onboarding: OnboardingSchema,\n});\n\nconst ChallengeHistoryResponseSchema = z.object({\n  items: z.array(ChallengeHistoryEntrySchema),\n  nextCursor: z.string().nullable(),\n});\n\n// ---------------------------------------------------------------------------\n// Route definitions\n// ---------------------------------------------------------------------------\n\nconst mineRoute = createRoute({\n  method: \"get\",\n  path: \"/mine\",\n  tags: [\"Challenges\"],\n  summary: \"Get active challenges for the authenticated player\",\n  description:\n    \"Returns daily, weekly, and onboarding challenges with lazy assignment on first call per period.\",\n  security: [{ bearerAuth: [] }],\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: MyChallengesResponseSchema } },\n      description: \"Active challenges grouped by period\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\nconst historyRoute = createRoute({\n  method: \"get\",\n  path: \"/mine/history\",\n  tags: [\"Challenges\"],\n  summary: \"Paginated completed challenge history\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    query: z.object({\n      cursor: z.string().optional(),\n      limit: z.coerce.number().int().min(1).max(50).optional(),\n    }),\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: ChallengeHistoryResponseSchema } },\n      description: \"Completed challenge assignments\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport function createChallengeRoutes(deps: ChallengeRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  app.openapi(mineRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    try {\n      const now = new Date();\n\n      // 1. Expire stale assignments\n      await expireStaleAssignments(db, userId);\n\n      // 2. Compute current period keys\n      const dailyKey = dailyPeriodKey(now);\n      const weeklyKey = weeklyPeriodKey(now);\n\n      // 3. Read config for challenge counts\n      const dailyCountStr = await readRewardConfig(db, \"daily_challenge_count\");\n      const weeklyCountStr = await readRewardConfig(db, \"weekly_challenge_count\");\n      const dailyCount = dailyCountStr ? Number(dailyCountStr) : 3;\n      const weeklyCount = weeklyCountStr ? Number(weeklyCountStr) : 2;\n\n      // 4. Look up campaign IDs\n      const [dailyCampaign, weeklyCampaign, onboardingCampaign] = await Promise.all([\n        getCampaignByType(db, \"daily\"),\n        getCampaignByType(db, \"weekly\"),\n        getCampaignByType(db, \"onboarding\"),\n      ]);\n\n      // 5. Lazy assignment — daily\n      let dailyAssignments = dailyCampaign\n        ? await getAssignmentsForPeriod(db, userId, dailyKey)\n        : [];\n\n      if (dailyAssignments.length === 0 && dailyCampaign) {\n        const templates = await getActiveChallengesBySort(db, dailyCampaign.id, dailyCount);\n        const dailyExpires = dailyResetsAt(now);\n        for (const t of templates) {\n          await createAssignment(db, userId, t.id, dailyKey, t.threshold, dailyExpires);\n        }\n        dailyAssignments = await getAssignmentsForPeriod(db, userId, dailyKey);\n      }\n\n      // 6. Lazy assignment — weekly\n      let weeklyAssignments = weeklyCampaign\n        ? await getAssignmentsForPeriod(db, userId, weeklyKey)\n        : [];\n\n      if (weeklyAssignments.length === 0 && weeklyCampaign) {\n        const templates = await getActiveChallengesBySort(db, weeklyCampaign.id, weeklyCount);\n        const weeklyExpires = weeklyResetsAt(now);\n        for (const t of templates) {\n          await createAssignment(db, userId, t.id, weeklyKey, t.threshold, weeklyExpires);\n        }\n        weeklyAssignments = await getAssignmentsForPeriod(db, userId, weeklyKey);\n      }\n\n      // 7. Lazy assignment — onboarding\n      let onboardingAssignments = onboardingCampaign\n        ? await getOnboardingAssignments(db, userId)\n        : [];\n\n      if (onboardingAssignments.length === 0 && onboardingCampaign) {\n        // Assign first step (prerequisite_id IS NULL)\n        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n        const firstStep = allSteps.find((s) => s.prerequisite_id === null);\n        if (firstStep) {\n          await createAssignment(db, userId, firstStep.id, \"onboarding\", firstStep.threshold, null);\n          onboardingAssignments = await getOnboardingAssignments(db, userId);\n        }\n      }\n\n      // 8. Build bonus status for daily\n      let dailyBonus: CompletionBonusType = null;\n      if (dailyCampaign) {\n        const bonuses = await getCompletionBonusesForCampaign(db, dailyCampaign.id);\n        if (bonuses.length > 0) {\n          const bonus = bonuses[0]!;\n          const completedCount = await countCompleted(db, userId, dailyKey, dailyCampaign.id);\n          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, dailyKey);\n          dailyBonus = {\n            title: bonus.title,\n            required: bonus.required_count,\n            completed: completedCount,\n            status: bonusCompletion ? \"completed\" as const : \"active\" as const,\n            reward: {\n              type: bonus.reward_type as \"points\" | \"crate\",\n              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n            },\n          };\n        }\n      }\n\n      // 9. Build bonus status for weekly\n      let weeklyBonus: CompletionBonusType = null;\n      if (weeklyCampaign) {\n        const bonuses = await getCompletionBonusesForCampaign(db, weeklyCampaign.id);\n        if (bonuses.length > 0) {\n          const bonus = bonuses[0]!;\n          const completedCount = await countCompleted(db, userId, weeklyKey, weeklyCampaign.id);\n          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, weeklyKey);\n          weeklyBonus = {\n            title: bonus.title,\n            required: bonus.required_count,\n            completed: completedCount,\n            status: bonusCompletion ? \"completed\" as const : \"active\" as const,\n            reward: {\n              type: bonus.reward_type as \"points\" | \"crate\",\n              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n            },\n          };\n        }\n      }\n\n      // 10. Build onboarding section\n      let onboarding: OnboardingType = null;\n      if (onboardingCampaign) {\n        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n        const assignedIds = new Set(onboardingAssignments.map((a) => a.challenge_id));\n        const completedIds = new Set(\n          onboardingAssignments.filter((a) => a.status === \"completed\").map((a) => a.challenge_id),\n        );\n        const allCompleted = allSteps.length > 0 && allSteps.every((s) => completedIds.has(s.id));\n\n        if (allCompleted) {\n          onboarding = null;\n        } else {\n          const steps = allSteps.map((step) => {\n            const assignment = onboardingAssignments.find((a) => a.challenge_id === step.id);\n            const isAssigned = assignedIds.has(step.id);\n            const locked = !isAssigned;\n            return {\n              id: Number(step.id),\n              title: step.title,\n              description: step.description,\n              progress: assignment ? assignment.progress : 0,\n              target: step.threshold,\n              status: assignment ? assignment.status as \"active\" | \"completed\" | \"expired\" : \"active\",\n              reward: {\n                type: step.reward_type as \"points\" | \"crate\",\n                ...(step.reward_amount != null ? { amount: step.reward_amount } : {}),\n              },\n              completedAt: assignment?.completed_at ?? null,\n              locked,\n            };\n          });\n          onboarding = { steps, completed: false };\n        }\n      }\n\n      // 11. Format response\n      const formatChallenge = (a: AssignmentRow): ChallengeAssignmentType => ({\n        id: Number(a.id),\n        title: a.title,\n        description: a.description,\n        progress: a.progress,\n        target: a.target,\n        status: a.status as \"active\" | \"completed\" | \"expired\",\n        reward: {\n          type: a.reward_type as \"points\" | \"crate\",\n          ...(a.reward_amount != null ? { amount: a.reward_amount } : {}),\n        },\n        completedAt: a.completed_at ?? null,\n      });\n\n      return c.json({\n        daily: {\n          challenges: dailyAssignments.map(formatChallenge),\n          bonus: dailyBonus,\n          resetsAt: dailyResetsAt(now),\n        },\n        weekly: {\n          challenges: weeklyAssignments.map(formatChallenge),\n          bonus: weeklyBonus,\n          resetsAt: weeklyResetsAt(now),\n        },\n        onboarding,\n      }, 200);\n    } catch (err) {\n      logger.error(\"challenges/mine failed\", {\n        userId,\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ error: \"Failed to fetch challenges\" }, 500);\n    }\n  });\n\n  // GET /mine/history — paginated completed challenge assignments\n  app.openapi(historyRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    const { cursor, limit: rawLimit } = c.req.valid(\"query\");\n    const limit = rawLimit ?? 20;\n\n    try {\n      const cursorFilter = cursor\n        ? db.rawSql`AND ca.id < ${cursor}`\n        : db.rawSql``;\n\n      const rows = await db.rawSql<\n        {\n          id: string;\n          title: string;\n          description: string;\n          completed_at: Date;\n          reward_type: string;\n          reward_amount: number | null;\n        }[]\n      >`\n        SELECT\n          ca.id,\n          c.title,\n          c.description,\n          ca.completed_at,\n          c.reward_type,\n          c.reward_amount\n        FROM challenge_assignments ca\n        JOIN challenges c ON c.id = ca.challenge_id\n        WHERE ca.user_id = ${userId}\n          AND ca.status = 'completed'\n          ${cursorFilter}\n        ORDER BY ca.id DESC\n        LIMIT ${limit}\n      `;\n\n      const items = rows.map((r: { id: string; title: string; description: string; completed_at: Date; reward_type: string; reward_amount: number | null }) => ({\n        id: Number(r.id),\n        title: r.title,\n        description: r.description,\n        completedAt: r.completed_at.toISOString(),\n        reward: {\n          type: r.reward_type as \"points\" | \"crate\",\n          ...(r.reward_amount != null ? { amount: r.reward_amount } : {}),\n        },\n      }));\n\n      const nextCursor =\n        items.length === limit ? String(items[items.length - 1]!.id) : null;\n\n      return c.json({ items, nextCursor }, 200);\n    } catch (err) {\n      logger.error(\"challenges/mine/history failed\", {\n        userId,\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ error: \"Failed to fetch challenge history\" }, 500);\n    }\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":354,"oldLines":15,"newStart":354,"newLines":15,"lines":["   security: [{ bearerAuth: [] }],","   responses: {","     200: {","-      content: { \"application/json\": { schema: MyChallengesResponseSchema } },","+      content: { \"application/json\": { schema: envelope(MyChallengesResponseSchema) } },","       description: \"Active challenges grouped by period\",","     },","     401: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Authentication required\",","     },","     500: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Server error\",","     },","   },"]}],"userModified":false,"replaceAll":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_018oC5PwRnpzZxSKSVUaZ7MN","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_012Kg1B698KdZxutLfg9oKHj","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/backend/src/routes/challenges.ts","old_string":"  responses: {\n    200: {\n      content: { \"application/json\": { schema: ChallengeHistoryResponseSchema } },\n      description: \"Completed challenge assignments\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Server error\",\n    },\n  },\n});","new_string":"  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(ChallengeHistoryResponseSchema) } },\n      description: \"Completed challenge assignments\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Server error\",\n    },\n  },\n});"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":545,"cache_read_input_tokens":93544,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":545},"output_tokens":72,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"ea182426-3468-4ae1-8ebd-e6f6cd94f8d2","uuid":"13f647ef-07a0-4c1b-91af-4dbcc70ae738"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012Kg1B698KdZxutLfg9oKHj","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/src/routes/challenges.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"ea182426-3468-4ae1-8ebd-e6f6cd94f8d2","uuid":"db80f81c-4134-4620-b0c9-b76e1d721f1f","timestamp":"2026-04-22T10:29:14.191Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/src/routes/challenges.ts","oldString":"  responses: {\n    200: {\n      content: { \"application/json\": { schema: ChallengeHistoryResponseSchema } },\n      description: \"Completed challenge assignments\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Server error\",\n    },\n  },\n});","newString":"  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(ChallengeHistoryResponseSchema) } },\n      description: \"Completed challenge assignments\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Server error\",\n    },\n  },\n});","originalFile":"/**\n * Challenge routes — player-facing challenge/quest endpoints.\n *\n * GET /mine           — returns active daily, weekly, and onboarding challenges\n *                       with lazy assignment on first call per period.\n * GET /mine/history   — paginated completed challenge assignments.\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { readRewardConfig } from \"../queue/handlers/reward-pool-fund.js\";\nimport {\n  ChallengeAssignmentSchema,\n  ChallengeHistoryEntrySchema,\n  CompletionBonusSchema,\n} from \"../contracts/validators.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\n// Inferred types for handler return value typing\ntype CompletionBonusType = z.infer<typeof CompletionBonusSchema>;\ntype ChallengeAssignmentType = z.infer<typeof ChallengeAssignmentSchema>;\ntype OnboardingStepType = ChallengeAssignmentType & { locked: boolean };\ntype OnboardingType = { steps: OnboardingStepType[]; completed: boolean } | null;\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface ChallengeRoutesDeps {\n  db: Db;\n}\n\ninterface ChallengeRow {\n  id: string;\n  campaign_id: string;\n  title: string;\n  description: string;\n  action: string;\n  scope: string;\n  condition: string;\n  threshold: number;\n  reward_type: string;\n  reward_amount: number | null;\n  sort_order: number;\n  prerequisite_id: string | null;\n}\n\ninterface AssignmentRow {\n  id: string;\n  challenge_id: string;\n  period_key: string;\n  status: string;\n  progress: number;\n  target: number;\n  expires_at: string | null;\n  completed_at: string | null;\n  title: string;\n  description: string;\n  reward_type: string;\n  reward_amount: number | null;\n  campaign_type: string;\n}\n\ninterface CompletionBonusRow {\n  id: string;\n  title: string;\n  required_count: number;\n  reward_type: string;\n  reward_amount: number | null;\n}\n\ninterface BonusCompletionRow {\n  id: string;\n}\n\n// ---------------------------------------------------------------------------\n// Period key helpers\n// ---------------------------------------------------------------------------\n\n/** Returns \"daily:YYYY-MM-DD\" for the current UTC date. */\nexport function dailyPeriodKey(now?: Date): string {\n  const d = now ?? new Date();\n  return `daily:${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, \"0\")}-${String(d.getUTCDate()).padStart(2, \"0\")}`;\n}\n\n/** Returns \"weekly:YYYY-Www\" for the current ISO week. */\nexport function weeklyPeriodKey(now?: Date): string {\n  const d = now ?? new Date();\n  // ISO week calculation\n  const tmp = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()));\n  tmp.setUTCDate(tmp.getUTCDate() + 4 - (tmp.getUTCDay() || 7));\n  const yearStart = new Date(Date.UTC(tmp.getUTCFullYear(), 0, 1));\n  const weekNo = Math.ceil(((tmp.getTime() - yearStart.getTime()) / 86400000 + 1) / 7);\n  return `weekly:${tmp.getUTCFullYear()}-W${String(weekNo).padStart(2, \"0\")}`;\n}\n\n/** Returns midnight UTC of the next day (daily reset). */\nexport function dailyResetsAt(now?: Date): string {\n  const d = now ?? new Date();\n  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + 1));\n  return next.toISOString();\n}\n\n/** Returns midnight UTC of next Monday (weekly reset). */\nexport function weeklyResetsAt(now?: Date): string {\n  const d = now ?? new Date();\n  const dayOfWeek = d.getUTCDay(); // 0=Sun, 1=Mon, ...\n  const daysUntilMonday = dayOfWeek === 0 ? 1 : 8 - dayOfWeek;\n  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + daysUntilMonday));\n  return next.toISOString();\n}\n\n// ---------------------------------------------------------------------------\n// DB helpers\n// ---------------------------------------------------------------------------\n\n/** Expire stale assignments (expires_at < now AND status='active'). */\nasync function expireStaleAssignments(db: Db, userId: string): Promise<void> {\n  await db.rawSql`\n    UPDATE challenge_assignments\n    SET status = 'expired'\n    WHERE user_id = ${userId}\n      AND status = 'active'\n      AND expires_at IS NOT NULL\n      AND expires_at < now()\n  `;\n}\n\n/** Get assignments for a user in a given period, joined with challenge metadata. */\nasync function getAssignmentsForPeriod(\n  db: Db,\n  userId: string,\n  periodKey: string,\n): Promise<AssignmentRow[]> {\n  return db.rawSql<AssignmentRow[]>`\n    SELECT\n      ca.id,\n      ca.challenge_id,\n      ca.period_key,\n      ca.status,\n      ca.progress,\n      ca.target,\n      ca.expires_at,\n      ca.completed_at,\n      c.title,\n      c.description,\n      c.reward_type,\n      c.reward_amount,\n      camp.campaign_type\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    JOIN campaigns camp ON camp.id = c.campaign_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = ${periodKey}\n    ORDER BY c.sort_order ASC\n  `;\n}\n\n/** Get top N active challenges for a campaign, ordered by sort_order ASC. */\nasync function getActiveChallengesBySort(\n  db: Db,\n  campaignId: string,\n  limit: number,\n): Promise<ChallengeRow[]> {\n  return db.rawSql<ChallengeRow[]>`\n    SELECT id, campaign_id, title, description, action, scope, condition,\n           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n    FROM challenges\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n    ORDER BY sort_order ASC\n    LIMIT ${limit}\n  `;\n}\n\n/** Get the campaign ID for a given campaign type. */\nasync function getCampaignByType(\n  db: Db,\n  campaignType: string,\n): Promise<{ id: string } | null> {\n  const rows = await db.rawSql<{ id: string }[]>`\n    SELECT id FROM campaigns\n    WHERE campaign_type = ${campaignType}\n      AND is_active = true\n    ORDER BY id ASC\n    LIMIT 1\n  `;\n  return rows[0] ?? null;\n}\n\n/** Get all onboarding assignments for a user (any status). */\nasync function getOnboardingAssignments(\n  db: Db,\n  userId: string,\n): Promise<AssignmentRow[]> {\n  return db.rawSql<AssignmentRow[]>`\n    SELECT\n      ca.id,\n      ca.challenge_id,\n      ca.period_key,\n      ca.status,\n      ca.progress,\n      ca.target,\n      ca.expires_at,\n      ca.completed_at,\n      c.title,\n      c.description,\n      c.reward_type,\n      c.reward_amount,\n      camp.campaign_type\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    JOIN campaigns camp ON camp.id = c.campaign_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = 'onboarding'\n    ORDER BY c.sort_order ASC\n  `;\n}\n\n/** Get all onboarding challenge templates (ordered by chain). */\nasync function getOnboardingChallenges(\n  db: Db,\n  campaignId: string,\n): Promise<ChallengeRow[]> {\n  return db.rawSql<ChallengeRow[]>`\n    SELECT id, campaign_id, title, description, action, scope, condition,\n           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n    FROM challenges\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n    ORDER BY sort_order ASC\n  `;\n}\n\n/** Get completion bonuses for a campaign. */\nasync function getCompletionBonusesForCampaign(\n  db: Db,\n  campaignId: string,\n): Promise<CompletionBonusRow[]> {\n  return db.rawSql<CompletionBonusRow[]>`\n    SELECT id, title, required_count, reward_type, reward_amount\n    FROM completion_bonuses\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n  `;\n}\n\n/** Check if a bonus was completed for a user in a given period. */\nasync function getBonusCompletion(\n  db: Db,\n  userId: string,\n  bonusId: string,\n  periodKey: string,\n): Promise<BonusCompletionRow | null> {\n  const rows = await db.rawSql<BonusCompletionRow[]>`\n    SELECT id FROM bonus_completions\n    WHERE user_id = ${userId}\n      AND bonus_id = ${bonusId}\n      AND period_key = ${periodKey}\n    LIMIT 1\n  `;\n  return rows[0] ?? null;\n}\n\n/** Count completed assignments for a user in a period+campaign. */\nasync function countCompleted(\n  db: Db,\n  userId: string,\n  periodKey: string,\n  campaignId: string,\n): Promise<number> {\n  const rows = await db.rawSql<{ count: string }[]>`\n    SELECT COUNT(*)::TEXT AS count\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = ${periodKey}\n      AND ca.status = 'completed'\n      AND c.campaign_id = ${campaignId}\n  `;\n  return Number(rows[0]!.count);\n}\n\n/** Create an assignment (idempotent via UNIQUE). */\nasync function createAssignment(\n  db: Db,\n  userId: string,\n  challengeId: string,\n  periodKey: string,\n  target: number,\n  expiresAt: string | null,\n): Promise<void> {\n  await db.rawSql`\n    INSERT INTO challenge_assignments (user_id, challenge_id, period_key, target, expires_at)\n    VALUES (${userId}, ${challengeId}, ${periodKey}, ${target}, ${expiresAt})\n    ON CONFLICT (user_id, challenge_id, period_key) DO NOTHING\n  `;\n}\n\n// ---------------------------------------------------------------------------\n// Response schemas\n// ---------------------------------------------------------------------------\n\nconst OnboardingStepSchema = ChallengeAssignmentSchema.extend({\n  locked: z.boolean().describe(\"True if prerequisite not yet completed\"),\n});\n\nconst OnboardingSchema = z\n  .object({\n    steps: z.array(OnboardingStepSchema),\n    completed: z.boolean(),\n  })\n  .nullable()\n  .describe(\"Null when all onboarding steps are completed.\");\n\nconst PeriodChallengesSchema = z.object({\n  challenges: z.array(ChallengeAssignmentSchema),\n  bonus: CompletionBonusSchema,\n  resetsAt: z.string().datetime(),\n});\n\nconst MyChallengesResponseSchema = z.object({\n  daily: PeriodChallengesSchema,\n  weekly: PeriodChallengesSchema,\n  onboarding: OnboardingSchema,\n});\n\nconst ChallengeHistoryResponseSchema = z.object({\n  items: z.array(ChallengeHistoryEntrySchema),\n  nextCursor: z.string().nullable(),\n});\n\n// ---------------------------------------------------------------------------\n// Route definitions\n// ---------------------------------------------------------------------------\n\nconst mineRoute = createRoute({\n  method: \"get\",\n  path: \"/mine\",\n  tags: [\"Challenges\"],\n  summary: \"Get active challenges for the authenticated player\",\n  description:\n    \"Returns daily, weekly, and onboarding challenges with lazy assignment on first call per period.\",\n  security: [{ bearerAuth: [] }],\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(MyChallengesResponseSchema) } },\n      description: \"Active challenges grouped by period\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\nconst historyRoute = createRoute({\n  method: \"get\",\n  path: \"/mine/history\",\n  tags: [\"Challenges\"],\n  summary: \"Paginated completed challenge history\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    query: z.object({\n      cursor: z.string().optional(),\n      limit: z.coerce.number().int().min(1).max(50).optional(),\n    }),\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: ChallengeHistoryResponseSchema } },\n      description: \"Completed challenge assignments\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport function createChallengeRoutes(deps: ChallengeRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  app.openapi(mineRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    try {\n      const now = new Date();\n\n      // 1. Expire stale assignments\n      await expireStaleAssignments(db, userId);\n\n      // 2. Compute current period keys\n      const dailyKey = dailyPeriodKey(now);\n      const weeklyKey = weeklyPeriodKey(now);\n\n      // 3. Read config for challenge counts\n      const dailyCountStr = await readRewardConfig(db, \"daily_challenge_count\");\n      const weeklyCountStr = await readRewardConfig(db, \"weekly_challenge_count\");\n      const dailyCount = dailyCountStr ? Number(dailyCountStr) : 3;\n      const weeklyCount = weeklyCountStr ? Number(weeklyCountStr) : 2;\n\n      // 4. Look up campaign IDs\n      const [dailyCampaign, weeklyCampaign, onboardingCampaign] = await Promise.all([\n        getCampaignByType(db, \"daily\"),\n        getCampaignByType(db, \"weekly\"),\n        getCampaignByType(db, \"onboarding\"),\n      ]);\n\n      // 5. Lazy assignment — daily\n      let dailyAssignments = dailyCampaign\n        ? await getAssignmentsForPeriod(db, userId, dailyKey)\n        : [];\n\n      if (dailyAssignments.length === 0 && dailyCampaign) {\n        const templates = await getActiveChallengesBySort(db, dailyCampaign.id, dailyCount);\n        const dailyExpires = dailyResetsAt(now);\n        for (const t of templates) {\n          await createAssignment(db, userId, t.id, dailyKey, t.threshold, dailyExpires);\n        }\n        dailyAssignments = await getAssignmentsForPeriod(db, userId, dailyKey);\n      }\n\n      // 6. Lazy assignment — weekly\n      let weeklyAssignments = weeklyCampaign\n        ? await getAssignmentsForPeriod(db, userId, weeklyKey)\n        : [];\n\n      if (weeklyAssignments.length === 0 && weeklyCampaign) {\n        const templates = await getActiveChallengesBySort(db, weeklyCampaign.id, weeklyCount);\n        const weeklyExpires = weeklyResetsAt(now);\n        for (const t of templates) {\n          await createAssignment(db, userId, t.id, weeklyKey, t.threshold, weeklyExpires);\n        }\n        weeklyAssignments = await getAssignmentsForPeriod(db, userId, weeklyKey);\n      }\n\n      // 7. Lazy assignment — onboarding\n      let onboardingAssignments = onboardingCampaign\n        ? await getOnboardingAssignments(db, userId)\n        : [];\n\n      if (onboardingAssignments.length === 0 && onboardingCampaign) {\n        // Assign first step (prerequisite_id IS NULL)\n        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n        const firstStep = allSteps.find((s) => s.prerequisite_id === null);\n        if (firstStep) {\n          await createAssignment(db, userId, firstStep.id, \"onboarding\", firstStep.threshold, null);\n          onboardingAssignments = await getOnboardingAssignments(db, userId);\n        }\n      }\n\n      // 8. Build bonus status for daily\n      let dailyBonus: CompletionBonusType = null;\n      if (dailyCampaign) {\n        const bonuses = await getCompletionBonusesForCampaign(db, dailyCampaign.id);\n        if (bonuses.length > 0) {\n          const bonus = bonuses[0]!;\n          const completedCount = await countCompleted(db, userId, dailyKey, dailyCampaign.id);\n          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, dailyKey);\n          dailyBonus = {\n            title: bonus.title,\n            required: bonus.required_count,\n            completed: completedCount,\n            status: bonusCompletion ? \"completed\" as const : \"active\" as const,\n            reward: {\n              type: bonus.reward_type as \"points\" | \"crate\",\n              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n            },\n          };\n        }\n      }\n\n      // 9. Build bonus status for weekly\n      let weeklyBonus: CompletionBonusType = null;\n      if (weeklyCampaign) {\n        const bonuses = await getCompletionBonusesForCampaign(db, weeklyCampaign.id);\n        if (bonuses.length > 0) {\n          const bonus = bonuses[0]!;\n          const completedCount = await countCompleted(db, userId, weeklyKey, weeklyCampaign.id);\n          const bonusCompletion = await getBonusCompletion(db, userId, bonus.id, weeklyKey);\n          weeklyBonus = {\n            title: bonus.title,\n            required: bonus.required_count,\n            completed: completedCount,\n            status: bonusCompletion ? \"completed\" as const : \"active\" as const,\n            reward: {\n              type: bonus.reward_type as \"points\" | \"crate\",\n              ...(bonus.reward_amount != null ? { amount: bonus.reward_amount } : {}),\n            },\n          };\n        }\n      }\n\n      // 10. Build onboarding section\n      let onboarding: OnboardingType = null;\n      if (onboardingCampaign) {\n        const allSteps = await getOnboardingChallenges(db, onboardingCampaign.id);\n        const assignedIds = new Set(onboardingAssignments.map((a) => a.challenge_id));\n        const completedIds = new Set(\n          onboardingAssignments.filter((a) => a.status === \"completed\").map((a) => a.challenge_id),\n        );\n        const allCompleted = allSteps.length > 0 && allSteps.every((s) => completedIds.has(s.id));\n\n        if (allCompleted) {\n          onboarding = null;\n        } else {\n          const steps = allSteps.map((step) => {\n            const assignment = onboardingAssignments.find((a) => a.challenge_id === step.id);\n            const isAssigned = assignedIds.has(step.id);\n            const locked = !isAssigned;\n            return {\n              id: Number(step.id),\n              title: step.title,\n              description: step.description,\n              progress: assignment ? assignment.progress : 0,\n              target: step.threshold,\n              status: assignment ? assignment.status as \"active\" | \"completed\" | \"expired\" : \"active\",\n              reward: {\n                type: step.reward_type as \"points\" | \"crate\",\n                ...(step.reward_amount != null ? { amount: step.reward_amount } : {}),\n              },\n              completedAt: assignment?.completed_at ?? null,\n              locked,\n            };\n          });\n          onboarding = { steps, completed: false };\n        }\n      }\n\n      // 11. Format response\n      const formatChallenge = (a: AssignmentRow): ChallengeAssignmentType => ({\n        id: Number(a.id),\n        title: a.title,\n        description: a.description,\n        progress: a.progress,\n        target: a.target,\n        status: a.status as \"active\" | \"completed\" | \"expired\",\n        reward: {\n          type: a.reward_type as \"points\" | \"crate\",\n          ...(a.reward_amount != null ? { amount: a.reward_amount } : {}),\n        },\n        completedAt: a.completed_at ?? null,\n      });\n\n      return c.json({\n        daily: {\n          challenges: dailyAssignments.map(formatChallenge),\n          bonus: dailyBonus,\n          resetsAt: dailyResetsAt(now),\n        },\n        weekly: {\n          challenges: weeklyAssignments.map(formatChallenge),\n          bonus: weeklyBonus,\n          resetsAt: weeklyResetsAt(now),\n        },\n        onboarding,\n      }, 200);\n    } catch (err) {\n      logger.error(\"challenges/mine failed\", {\n        userId,\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ error: \"Failed to fetch challenges\" }, 500);\n    }\n  });\n\n  // GET /mine/history — paginated completed challenge assignments\n  app.openapi(historyRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    const { cursor, limit: rawLimit } = c.req.valid(\"query\");\n    const limit = rawLimit ?? 20;\n\n    try {\n      const cursorFilter = cursor\n        ? db.rawSql`AND ca.id < ${cursor}`\n        : db.rawSql``;\n\n      const rows = await db.rawSql<\n        {\n          id: string;\n          title: string;\n          description: string;\n          completed_at: Date;\n          reward_type: string;\n          reward_amount: number | null;\n        }[]\n      >`\n        SELECT\n          ca.id,\n          c.title,\n          c.description,\n          ca.completed_at,\n          c.reward_type,\n          c.reward_amount\n        FROM challenge_assignments ca\n        JOIN challenges c ON c.id = ca.challenge_id\n        WHERE ca.user_id = ${userId}\n          AND ca.status = 'completed'\n          ${cursorFilter}\n        ORDER BY ca.id DESC\n        LIMIT ${limit}\n      `;\n\n      const items = rows.map((r: { id: string; title: string; description: string; completed_at: Date; reward_type: string; reward_amount: number | null }) => ({\n        id: Number(r.id),\n        title: r.title,\n        description: r.description,\n        completedAt: r.completed_at.toISOString(),\n        reward: {\n          type: r.reward_type as \"points\" | \"crate\",\n          ...(r.reward_amount != null ? { amount: r.reward_amount } : {}),\n        },\n      }));\n\n      const nextCursor =\n        items.length === limit ? String(items[items.length - 1]!.id) : null;\n\n      return c.json({ items, nextCursor }, 200);\n    } catch (err) {\n      logger.error(\"challenges/mine/history failed\", {\n        userId,\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ error: \"Failed to fetch challenge history\" }, 500);\n    }\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":382,"oldLines":15,"newStart":382,"newLines":15,"lines":["   },","   responses: {","     200: {","-      content: { \"application/json\": { schema: ChallengeHistoryResponseSchema } },","+      content: { \"application/json\": { schema: envelope(ChallengeHistoryResponseSchema) } },","       description: \"Completed challenge assignments\",","     },","     401: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Authentication required\",","     },","     500: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Server error\",","     },","   },"]}],"userModified":false,"replaceAll":false}}
