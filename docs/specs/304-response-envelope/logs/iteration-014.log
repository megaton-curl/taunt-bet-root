{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017QnsHDrWBFj5Qd3K1Sx5Do","type":"tool_result","content":"1\t/* eslint-disable @typescript-eslint/no-explicit-any */\n2\timport { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";\n3\timport { Hono } from \"hono\";\n4\timport { Keypair } from \"@solana/web3.js\";\n5\timport type { Db } from \"../db.js\";\n6\timport {\n7\t  createChallengeRoutes,\n8\t  dailyPeriodKey,\n9\t  weeklyPeriodKey,\n10\t} from \"../routes/challenges.js\";\n11\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n12\timport {\n13\t  closeIntegrationDb,\n14\t  type IntegrationDbContext,\n15\t  JWT_SECRET,\n16\t  makeJwt,\n17\t  openIntegrationDb,\n18\t  resetIntegrationState,\n19\t  type TestSql,\n20\t  userIdFromWallet,\n21\t} from \"./integration-test-helpers.js\";\n22\t\n23\tdescribe(\"Challenge routes\", () => {\n24\t  let ctx: IntegrationDbContext;\n25\t  let rawSql: TestSql;\n26\t  let db: Db;\n27\t\n28\t  beforeAll(async () => {\n29\t    ctx = await openIntegrationDb();\n30\t    rawSql = ctx.rawSql;\n31\t    db = ctx.db;\n32\t  });\n33\t\n34\t  afterAll(async () => {\n35\t    await closeIntegrationDb(ctx);\n36\t  });\n37\t\n38\t  describe(\"GET /challenges/mine\", () => {\n39\t    let app: Hono;\n40\t\n41\t    const testWallet = Keypair.generate().publicKey.toBase58();\n42\t    const testUserId = userIdFromWallet(testWallet);\n43\t\n44\t    beforeEach(async () => {\n45\t      await resetIntegrationState(rawSql);\n46\t\n47\t      app = new Hono();\n48\t      app.use(\n49\t        \"/challenges/*\",\n50\t        createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n51\t      );\n52\t      app.route(\"/challenges\", createChallengeRoutes({ db }));\n53\t    });\n54\t\n55\t    it(\"first call creates daily, weekly, and onboarding assignments with the expected shape\", async () => {\n56\t      const token = await makeJwt(testWallet, testUserId);\n57\t\n58\t      const res = await app.request(\"/challenges/mine\", {\n59\t        method: \"GET\",\n60\t        headers: { Authorization: `Bearer ${token}` },\n61\t      });\n62\t\n63\t      expect(res.status).toBe(200);\n64\t      const body = (await res.json()) as Record<string, any>;\n65\t\n66\t      expect(body.daily).toBeDefined();\n67\t      expect(body.daily.challenges).toHaveLength(3);\n68\t      expect(body.daily.resetsAt).toBeDefined();\n69\t      for (const challenge of body.daily.challenges) {\n70\t        expect(challenge).toHaveProperty(\"id\");\n71\t        expect(challenge).toHaveProperty(\"title\");\n72\t        expect(challenge).toHaveProperty(\"description\");\n73\t        expect(challenge).toHaveProperty(\"progress\");\n74\t        expect(challenge).toHaveProperty(\"target\");\n75\t        expect(challenge).toHaveProperty(\"status\");\n76\t        expect(challenge).toHaveProperty(\"reward\");\n77\t        expect(challenge.reward).toHaveProperty(\"type\");\n78\t        expect(challenge).toHaveProperty(\"completedAt\");\n79\t        expect(challenge.status).toBe(\"active\");\n80\t        expect(challenge.progress).toBe(0);\n81\t      }\n82\t\n83\t      expect(body.daily.bonus).toBeDefined();\n84\t      expect(body.daily.bonus.required).toBe(3);\n85\t      expect(body.daily.bonus.completed).toBe(0);\n86\t      expect(body.daily.bonus.status).toBe(\"active\");\n87\t      expect(body.daily.bonus.reward).toHaveProperty(\"type\");\n88\t\n89\t      expect(body.weekly).toBeDefined();\n90\t      expect(body.weekly.challenges).toHaveLength(2);\n91\t      expect(body.weekly.resetsAt).toBeDefined();\n92\t      for (const challenge of body.weekly.challenges) {\n93\t        expect(challenge.status).toBe(\"active\");\n94\t        expect(challenge.progress).toBe(0);\n95\t      }\n96\t\n97\t      expect(body.onboarding).toBeDefined();\n98\t      expect(body.onboarding).not.toBeNull();\n99\t      expect(body.onboarding.completed).toBe(false);\n100\t      expect(body.onboar