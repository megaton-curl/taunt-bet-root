{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Mj26QrXCUqwqfEFdqHcNwv","type":"tool_result","content":"1\timport { z } from \"zod\";\n2\timport {\n3\t  PUBLIC_COMMIT_REVEAL_GAME_ID_VALUES,\n4\t  PUBLIC_GAME_IDS,\n5\t  PUBLIC_GAME_ID_VALUES,\n6\t} from \"./public-games.js\";\n7\t\n8\tconst IsoDateTimeSchema = z.string().datetime();\n9\tconst LamportsStringSchema = z.string().describe(\"Lamports as string\");\n10\tconst UserIdSchema = z.string().describe(\"Short user ID (usr_xxxxxxxx)\");\n11\tconst LeaderboardGameIdValues = [...PUBLIC_GAME_ID_VALUES, \"all\"] as const;\n12\t\n13\tfunction coerceClampedInteger(\n14\t  raw: unknown,\n15\t  defaultValue: number,\n16\t  min: number,\n17\t  max?: number,\n18\t): number {\n19\t  if (raw === undefined || raw === null || raw === \"\") {\n20\t    return defaultValue;\n21\t  }\n22\t\n23\t  const parsed = typeof raw === \"number\" ? raw : parseInt(String(raw), 10);\n24\t  if (!Number.isFinite(parsed) || Number.isNaN(parsed) || parsed < min) {\n25\t    return defaultValue;\n26\t  }\n27\t\n28\t  return max === undefined ? parsed : Math.min(parsed, max);\n29\t}\n30\t\n31\tfunction queryIntegerSchema(defaultValue: number, min: number, max?: number) {\n32\t  const base = z.number().int().min(min);\n33\t  const bounded = max === undefined ? base : base.max(max);\n34\t\n35\t  return z.preprocess(\n36\t    (raw) => coerceClampedInteger(raw, defaultValue, min, max),\n37\t    bounded.default(defaultValue),\n38\t  );\n39\t}\n40\t\n41\texport const PublicGameIdSchema = z.enum(PUBLIC_GAME_ID_VALUES);\n42\texport const PublicCommitRevealGameIdSchema = z.enum(PUBLIC_COMMIT_REVEAL_GAME_ID_VALUES);\n43\texport const LeaderboardGameIdSchema = z.enum(LeaderboardGameIdValues);\n44\t\n45\texport const ErrorResponseSchema = z.object({\n46\t  error: z.string(),\n47\t});\n48\t\n49\texport const StructuredErrorDetailSchema = z.object({\n50\t  code: z.string(),\n51\t  message: z.string(),\n52\t  retryable: z.boolean().optional(),\n53\t});\n54\t\n55\texport const StructuredErrorResponseSchema = z.object({\n56\t  error: StructuredErrorDetailSchema,\n57\t});\n58\t\n59\texport const OkResponseSchema = z.object({\n60\t  ok: z.boolean(),\n61\t});\n62\t\n63\texport const CodeResponseSchema = z.object({\n64\t  code: z.string(),\n65\t});\n66\t\n67\t// GET /referral/code: `code` is null when the user hasn't set one yet.\n68\t// Empty state is a valid answer to \"what's my code?\", not an error.\n69\texport const MaybeCodeResponseSchema = z.object({\n70\t  code: z.string().nullable(),\n71\t});\n72\t\n73\texport const ExistsResponseSchema = z.object({\n74\t  exists: z.boolean(),\n75\t});\n76\t\n77\texport const UsernameUpdateResponseSchema = z.object({\n78\t  username: z.string(),\n79\t  nextEditAvailableAt: z.string().datetime().nullable(),\n80\t});\n81\t\n82\texport const UsernameCooldownResponseSchema = z.object({\n83\t  error: z.string(),\n84\t  nextEditAvailableAt: z.string().datetime(),\n85\t});\n86\t\n87\texport const ReferralCodeSchema = z\n88\t  .string()\n89\t  .trim()\n90\t  .toLowerCase()\n91\t  .regex(/^[a-z0-9-]{3,16}$/)\n92\t  .describe(\"3-16 chars, lowercase alphanumeric + hyphens\");\n93\t\n94\texport const ReferralCodeBodySchema = z.object({\n95\t  code: ReferralCodeSchema,\n96\t});\n97\t\n98\texport const ApplyReferralCodeBodySchema = z.object({\n99\t  code: z.string().trim().toLowerCase().min(1),\n100\t});\n101\t\n102\texport const ReferralApplyResponseSchema = z.object({\n103\t  referrerUserId: z.string(),\n104\t  benefit: z.string(),\n105\t});\n106\t\n107\t// GET /referral/referrer: all four fields are nullable together — they are\n108\t// all populated when the caller is linked to a referrer, and all null when\n109\t// they aren't. Not being referred is a valid answer, not an error.\n110\texport const ReferralReferrerResponseSchema = z.object({\n111\t  referrerUserId: z.string().nullable(),\n112\t  referrerUsername: z.string().nullable(),\n113\t  referrerCode: z.string().nul