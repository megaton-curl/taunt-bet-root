defined) error.retryable = opts.retryable;\n  if (opts?.details !== undefined) error.details = opts.details;\n  const body: ApiEnvelopeError = { ok: false, error };\n  return c.json(body, status);\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4279,"cache_read_input_tokens":141738,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4279},"output_tokens":39,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b184ad64-55fb-425e-85f4-42f002c1f5d8","uuid":"d8415c15-77f8-4ead-b373-630ca29a30db"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AMbZgbDJ1Ngq4pAAZ41PaM","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/src/contracts/api-envelope.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"b184ad64-55fb-425e-85f4-42f002c1f5d8","uuid":"df4ef2f9-4ca7-44ab-9114-2a383d9a0955","timestamp":"2026-04-22T09:40:28.086Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/src/contracts/api-envelope.ts","oldString":"export type SuccessStatus = 200 | 201 | 202;\nexport type ErrorStatus = 400 | 401 | 403 | 404 | 409 | 422 | 429 | 500 | 503;\n\nexport function ok<T, S extends SuccessStatus = 200>(\n  c: Context,\n  data: T,\n  status?: S,\n) {\n  const body: ApiEnvelopeSuccess<T> = { ok: true, data };\n  return c.json(body, (status ?? 200) as S);\n}\n\nexport function err<S extends ErrorStatus>(\n  c: Context,\n  status: S,\n  code: ApiErrorCode,\n  message: string,\n  opts?: { retryable?: boolean; details?: unknown },\n) {\n  const error: ApiError = { code, message };\n  if (opts?.retryable !== undefined) error.retryable = opts.retryable;\n  if (opts?.details !== undefined) error.details = opts.details;\n  const body: ApiEnvelopeError = { ok: false, error };\n  return c.json(body, status);\n}","newString":"export type SuccessStatus = 200 | 201 | 202;\nexport type ErrorStatus = 400 | 401 | 403 | 404 | 409 | 422 | 429 | 500 | 503;\n\nexport function ok<T>(\n  c: Context,\n  data: T,\n): ReturnType<Context[\"json\"]<ApiEnvelopeSuccess<T>, 200>>;\nexport function ok<T, S extends SuccessStatus>(\n  c: Context,\n  data: T,\n  status: S,\n): ReturnType<Context[\"json\"]<ApiEnvelopeSuccess<T>, S>>;\nexport function ok<T>(c: Context, data: T, status: SuccessStatus = 200) {\n  const body: ApiEnvelopeSuccess<T> = { ok: true, data };\n  return c.json(body, status);\n}\n\nexport function err<S extends ErrorStatus>(\n  c: Context,\n  status: S,\n  code: ApiErrorCode,\n  message: string,\n  opts?: { retryable?: boolean; details?: unknown },\n): ReturnType<Context[\"json\"]<ApiEnvelopeError, S>> {\n  const error: ApiError = { code, message };\n  if (opts?.retryable !== undefined) error.retryable = opts.retryable;\n  if (opts?.details !== undefined) error.details = opts.details;\n  const body: ApiEnvelopeError = { ok: false, error };\n  return c.json(body, status);\n}","originalFile":"/**\n * Shared response envelope for public JSON routes.\n *\n * Every public JSON response body is either:\n *   { ok: true,  data: <payload> }   — success (200/201/202)\n *   { ok: false, error: ApiError }   — failure (4xx/5xx)\n *\n * Semantic HTTP status is preserved — handled domain failures MUST NOT be\n * flattened into `200`. See `docs/specs/304-response-envelope/spec.md`.\n */\n\nimport { z } from \"zod\";\nimport type { Context } from \"hono\";\n\nexport type { ApiErrorCode } from \"./api-errors.js\";\nimport type { ApiErrorCode } from \"./api-errors.js\";\n\nexport interface ApiError {\n  code: ApiErrorCode;\n  message: string;\n  retryable?: boolean;\n  details?: unknown;\n}\n\nexport interface ApiEnvelopeSuccess<T> {\n  ok: true;\n  data: T;\n}\n\nexport interface ApiEnvelopeError {\n  ok: false;\n  error: ApiError;\n}\n\nexport type ApiEnvelope<T> = ApiEnvelopeSuccess<T> | ApiEnvelopeError;\n\nexport const ApiErrorSchema = z.object({\n  code: z.string(),\n  message: z.string(),\n  retryable: z.boolean().optional(),\n  details: z.unknown().optional(),\n});\n\nexport const ErrorEnvelopeSchema = z.object({\n  ok: z.literal(false),\n  error: ApiErrorSchema,\n});\n\nexport function envelope<T extends z.ZodTypeAny>(dataSchema: T) {\n  return z.discriminatedUnion(\"ok\", [\n    z.object({\n      ok: z.literal(true),\n      data: dataSchema,\n    }),\n    ErrorEnvelopeSchema,\n  ]);\n}\n\nexport type SuccessStatus = 200 | 201 | 202;\nexport type ErrorStatus = 400 | 401 | 403 | 404 | 409 | 422 | 429 | 500 | 503;\n\nexport function ok<T, S extends SuccessStatus = 200>(\n  c: Context,\n  data: T,\n  status?: S,\n) {\n  const body: ApiEnvelopeSuccess<T> = { ok: true, data };\n  return c.json(body, (status ?? 200) as S);\n}\n\nexport function err<S extends ErrorStatus>(\n  c: Context,\n  status: S,\n  code: ApiErrorCode,\n  message: string,\n  opts?: { retryable?: boolean; details?: unknown },\n) {\n  const error: ApiError = { code, message };\n  if (opts?.retryable !== undefined) error.retryable = opts.retryable;\n  if (opts?.details !== undefined) error.details = opts.details;\n  const body: ApiEnvelopeError = { ok: false, error };\n  return c.json(body, status);\n}\n","structuredPatch":[{"oldStart":59,"oldLines":13,"newStart":59,"newLines":18,"lines":[" export type SuccessStatus = 200 | 201 | 202;"," export type ErrorStatus = 400 | 401 | 403 | 404 | 409 | 422 | 429 | 500 | 503;"," ","-export function ok<T, S extends SuccessStatus = 200>(","+export function ok<T>(","   c: Context,","   data: T,","-  status?: S,","-) {","+): ReturnType<Context[\"json\"]<ApiEnvelopeSuccess<T>, 200>>;","+export function ok<T, S extends SuccessStatus>(","+  c: Context,","+  data: T,","+  status: S,","+): ReturnType<Context[\"json\"]<ApiEnvelopeSuccess<T>, S>>;","+export function ok<T>(c: Context, data: T, status: SuccessStatus = 200) {","   const body: ApiEnvelopeSuccess<T> = { ok: true, data };","-  return c.json(body, (status ?? 200) as S);","+  return c.json(body, status);"," }"," "," export function err<S extends ErrorStatus>("]},{"oldStart":74,"oldLines":7,"newStart":79,"newLines":7,"lines":["   code: ApiErrorCode,","   message: string,","   opts?: { retryable?: boolean; details?: unknown },","-) {","+): ReturnType<Context[\"json\"]<ApiEnvelopeError, S>> {","   const error: ApiError = { code, message };","   if (opts?.retryable !== undefined) error.retryable = opts.retryable;","   if (opts?.details !== undefined) error.details = opts.details;"]}],"userModified":false,"replaceAll":false}}
