 if (!body.refreshToken) {\n      return c.body(null, 204);\n    }\n\n    const tokenHash = hashToken(body.refreshToken);\n    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n    if (stored) {\n      await authDb.revokeRefreshToken(stored.id);\n      logger.info(\"auth logout\", { userId: stored.user_id, wallet: stored.wallet });\n    }\n\n    return c.body(null, 204);\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":107,"oldLines":11,"newStart":107,"newLines":11,"lines":["   },","   responses: {","     200: {","-      content: { \"application/json\": { schema: ChallengeNonceResponseSchema } },","+      content: { \"application/json\": { schema: envelope(ChallengeNonceResponseSchema) } },","       description: \"Challenge issued\",","     },","-    400: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+    422: {","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Invalid request\",","     },","   },"]}],"userModified":false,"replaceAll":false}}
