hallenge.message);\n    const valid = nacl.sign.detached.verify(messageBytes, sigBytes, pubkeyBytes);\n    if (!valid) {\n      logger.warn(\"auth verify rejected: signature verification failed\", {\n        wallet,\n      });\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.INVALID_SIGNATURE,\n        \"Invalid signature\",\n      );\n    }\n\n    let profile;\n    try {\n      profile = await db.getProfileByWallet(wallet);\n      if (!profile) {\n        profile = await db.createPlayerProfile(wallet);\n        logger.info(\"player profile auto-created\", { wallet, userId: profile.user_id });\n      }\n    } catch (e) {\n      logger.error(\"profile creation failed\", { wallet, error: e });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to establish player profile\",\n      );\n    }"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":649,"cache_read_input_tokens":111154,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":649},"output_tokens":72,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b184ad64-55fb-425e-85f4-42f002c1f5d8","uuid":"f3b3f6d7-6aa7-409e-a65f-476b2bdc3194"}
