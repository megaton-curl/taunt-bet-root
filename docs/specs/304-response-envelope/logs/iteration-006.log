n): string {\n  return [\n    \"Sign this message to create your Taunt BET account.\",\n    \"\",\n    \"This only verifies ownership. No gas or funds are used.\",\n    \"\",\n    `Wallet: ${wallet}`,\n    `Network: ${formatNetwork(cluster)}`,\n    `Timestamp: ${issuedAt}`,\n    `Nonce: ${nonce}`,\n  ].join(\"\\n\");\n}\n\n// ---------------------------------------------------------------------------\n// Route definitions\n// ---------------------------------------------------------------------------\n\nconst challengeRoute = createRoute({\n  method: \"post\",\n  path: \"/challenge\",\n  tags: [\"Auth\"],\n  summary: \"Request sign-in challenge\",\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": {\n          schema: z.object({\n            wallet: z.string().min(1).describe(\"Base58 wallet address\"),\n          }),\n        },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(ChallengeNonceResponseSchema) } },\n      description: \"Challenge issued\",\n    },\n    422: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid request\",\n    },\n  },\n});\n\nconst verifyRoute = createRoute({\n  method: \"post\",\n  path: \"/verify\",\n  tags: [\"Auth\"],\n  summary: \"Verify signature and issue tokens\",\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": {\n          schema: z.object({\n            nonce: z.string(),\n            wallet: z.string(),\n            signature: z.string().describe(\"Base58-encoded Ed25519 signature\"),\n          }),\n        },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: TokenResponseSchema } },\n      description: \"Tokens issued\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Missing fields\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Invalid signature or challenge\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\nconst refreshRoute = createRoute({\n  method: \"post\",\n  path: \"/refresh\",\n  tags: [\"Auth\"],\n  summary: \"Rotate refresh token and issue new access token\",\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": {\n          schema: z.object({\n            refreshToken: z.string(),\n          }),\n        },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: TokenResponseSchema } },\n      description: \"New tokens issued\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Missing refresh token\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Invalid or expired token\",\n    },\n  },\n});\n\nconst logoutRoute = createRoute({\n  method: \"post\",\n  path: \"/logout\",\n  tags: [\"Auth\"],\n  summary: \"Revoke refresh token\",\n  request: {\n    body: {\n      content: {\n        \"application/json\": {\n          schema: z.object({\n            refreshToken: z.string().optional(),\n          }),\n        },\n      },\n    },\n  },\n  responses: {\n    204: {\n      description: \"Logged out\",\n    },\n  },\n});\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport function createAuthRoutes(deps: AuthRoutesDeps) {\n  const {\n    authDb,\n    db,\n    jwtSecret,\n    cluster,\n    challengeTtlSeconds,\n    accessTokenTtlSeconds,\n    refreshTokenTtlDays,\n  } = deps;\n\n  const app = createOpenApiApp();\n\n  // POST /challenge — generate nonce + human-readable message\n  app.openapi(challengeRoute, async (c) => {\n    const { wallet } = c.req.valid(\"json\");\n\n    const nonce = randomBytes(32).toString(\"hex\");\n    const now = new Date();\n    const expiresAt = new Date(now.getTime() + challengeTtlSeconds * 1000);\n\n    const message = buildSignInMessage(\n      wallet,\n      cluster,\n      nonce,\n      now.toISOString(),\n    );\n\n    await authDb.insertChallenge(nonce, wallet, cluster, message, expiresAt);\n\n    logger.info(\"auth challenge issued\", { wallet, nonce });\n\n    return c.json({\n      nonce,\n      message,\n      expiresAt: expiresAt.toISOString(),\n    }, 200);\n  });\n\n  // POST /verify — consume challenge, verify signature, issue tokens\n  app.openapi(verifyRoute, async (c) => {\n    const { nonce, wallet, signature } = c.req.valid(\"json\");\n\n    // Atomically consume the challenge\n    const challenge = await authDb.consumeChallenge(nonce);\n    if (!challenge) {\n      logger.warn(\"auth verify rejected: challenge not found or expired\", {\n        nonce,\n        wallet,\n      });\n      return c.json({ error: \"Challenge not found, expired, or already used\" }, 401);\n    }\n\n    // Verify wallet matches challenge\n    if (challenge.wallet !== wallet) {\n      logger.warn(\"auth verify rejected: wallet mismatch\", {\n        nonce,\n        challengeWallet: challenge.wallet,\n        requestWallet: wallet,\n      });\n      return c.json({ error: \"Wallet does not match challenge\" }, 401);\n    }\n\n    // Verify Ed25519 signature over the challenge message.\n    // PublicKey validates base58 + 32-byte length + on-curve; signature only\n    // needs base58 decode (raw 64-byte ed25519 sig, not a pubkey).\n    let sigBytes: Uint8Array;\n    let pubkeyBytes: Uint8Array;\n    try {\n      sigBytes = bs58.decode(signature);\n      pubkeyBytes = new PublicKey(wallet).toBytes();\n    } catch {\n      return c.json({ error: \"Invalid signature or wallet encoding\" }, 401);\n    }\n\n    if (sigBytes.length !== 64) {\n      return c.json({ error: \"Invalid signature length\" }, 401);\n    }\n\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const valid = nacl.sign.detached.verify(messageBytes, sigBytes, pubkeyBytes);\n    if (!valid) {\n      logger.warn(\"auth verify rejected: signature verification failed\", {\n        wallet,\n      });\n      return c.json({ error: \"Invalid signature\" }, 401);\n    }\n\n    let profile;\n    try {\n      profile = await db.getProfileByWallet(wallet);\n      if (!profile) {\n        profile = await db.createPlayerProfile(wallet);\n        logger.info(\"player profile auto-created\", { wallet, userId: profile.user_id });\n      }\n    } catch (e) {\n      logger.error(\"profile creation failed\", { wallet, error: e });\n      return c.json({ error: \"Failed to establish player profile\" }, 500);\n    }\n\n    // Issue JWT access token\n    const now = Math.floor(Date.now() / 1000);\n    const accessToken = await issueAccessToken(\n      jwtSecret,\n      profile.user_id,\n      now,\n      accessTokenTtlSeconds,\n    );\n\n    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n\n    // Generate opaque refresh token\n    const refreshTokenRaw = randomBytes(48).toString(\"hex\");\n    const refreshTokenHash = hashToken(refreshTokenRaw);\n    const familyId = randomBytes(16).toString(\"hex\");\n    const refreshExpiresAt = new Date(\n      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n    );\n\n    await authDb.insertRefreshToken(\n      profile.user_id,\n      wallet,\n      refreshTokenHash,\n      familyId,\n      refreshExpiresAt,\n    );\n\n    logger.info(\"auth session created\", { wallet, userId: profile.user_id });\n\n    return c.json({\n      accessToken,\n      accessExpiresAt,\n      refreshToken: refreshTokenRaw,\n      refreshExpiresAt: refreshExpiresAt.toISOString(),\n    }, 200);\n  });\n\n  // POST /refresh — rotate refresh token, issue new access token\n  app.openapi(refreshRoute, async (c) => {\n    const { refreshToken } = c.req.valid(\"json\");\n\n    const tokenHash = hashToken(refreshToken);\n    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n\n    if (!stored) {\n      logger.warn(\"auth refresh rejected: token not found\");\n      return c.json({ error: \"Invalid refresh token\" }, 401);\n    }\n\n    // Reuse detection: if the token was already revoked, someone replayed it.\n    // Revoke the entire family as a precaution.\n    if (stored.revoked) {\n      logger.warn(\"auth refresh rejected: token reuse detected, revoking family\", {\n        userId: stored.user_id,\n        wallet: stored.wallet,\n        familyId: stored.family_id,\n      });\n      await authDb.revokeTokenFamily(stored.family_id);\n      return c.json({ error: \"Token reuse detected. Please sign in again.\" }, 401);\n    }\n\n    // Check expiry\n    if (new Date() > stored.expires_at) {\n      logger.warn(\"auth refresh rejected: token expired\", {\n        userId: stored.user_id,\n        wallet: stored.wallet,\n      });\n      await authDb.revokeRefreshToken(stored.id);\n      return c.json({ error: \"Refresh token expired\" }, 401);\n    }\n\n    // Revoke old token\n    await authDb.revokeRefreshToken(stored.id);\n\n    // Issue new access token\n    const now = Math.floor(Date.now() / 1000);\n    const accessToken = await issueAccessToken(\n      jwtSecret,\n      stored.user_id,\n      now,\n      accessTokenTtlSeconds,\n    );\n\n    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n\n    // Issue new refresh token in the same family\n    const newRefreshRaw = randomBytes(48).toString(\"hex\");\n    const newRefreshHash = hashToken(newRefreshRaw);\n    const newRefreshExpiresAt = new Date(\n      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n    );\n\n    await authDb.insertRefreshToken(\n      stored.user_id,\n      stored.wallet,\n      newRefreshHash,\n      stored.family_id,\n      newRefreshExpiresAt,\n    );\n\n    logger.debug(\"auth token refreshed\", { userId: stored.user_id, wallet: stored.wallet });\n\n    return c.json({\n      accessToken,\n      accessExpiresAt,\n      refreshToken: newRefreshRaw,\n      refreshExpiresAt: newRefreshExpiresAt.toISOString(),\n    }, 200);\n  });\n\n  // POST /logout — revoke refresh token\n  app.openapi(logoutRoute, async (c) => {\n    const body = c.req.valid(\"json\");\n\n    if (!body.refreshToken) {\n      return c.body(null, 204);\n    }\n\n    const tokenHash = hashToken(body.refreshToken);\n    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n    if (stored) {\n      await authDb.revokeRefreshToken(stored.id);\n      logger.info(\"auth logout\", { userId: stored.user_id, wallet: stored.wallet });\n    }\n\n    return c.body(null, 204);\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":138,"oldLines":19,"newStart":138,"newLines":19,"lines":["   },","   responses: {","     200: {","-      content: { \"application/json\": { schema: TokenResponseSchema } },","+      content: { \"application/json\": { schema: envelope(TokenResponseSchema) } },","       description: \"Tokens issued\",","     },","-    400: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","-      description: \"Missing fields\",","-    },","     401: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Invalid signature or challenge\",","     },","+    422: {","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","+      description: \"Invalid request\",","+    },","     500: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Server error\",","     },","   },"]}],"userModified":false,"replaceAll":false}}
