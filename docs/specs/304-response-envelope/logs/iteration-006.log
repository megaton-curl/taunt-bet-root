{\n      ok: z.literal(true),\n      data: dataSchema,\n    }),\n    ErrorEnvelopeSchema,\n  ]);\n}\n\nexport type SuccessStatus = 200 | 201 | 202;\nexport type ErrorStatus = 400 | 401 | 403 | 404 | 409 | 422 | 429 | 500 | 503;\n\nexport function ok<T>(\n  c: Context,\n  data: T,\n): ReturnType<Context[\"json\"]<ApiEnvelopeSuccess<T>, 200>>;\nexport function ok<T, S extends SuccessStatus>(\n  c: Context,\n  data: T,\n  status: S,\n): ReturnType<Context[\"json\"]<ApiEnvelopeSuccess<T>, S>>;\nexport function ok<T>(c: Context, data: T, status: SuccessStatus = 200) {\n  const body: ApiEnvelopeSuccess<T> = { ok: true, data };\n  return c.json(body, status);\n}\n\nexport function err<S extends ErrorStatus>(\n  c: Context,\n  status: S,\n  code: ApiErrorCode,\n  message: string,\n  opts?: { retryable?: boolean; details?: unknown },\n): ReturnType<Context[\"json\"]<ApiEnvelopeError, S>> {\n  const error: ApiError = { code, message };\n  if (opts?.retryable !== undefined) error.retryable = opts.retryable;\n  if (opts?.details !== undefined) error.details = opts.details;\n  const body: ApiEnvelopeError = { ok: false, error };\n  return c.json(body, status);\n}\n","structuredPatch":[{"oldStart":10,"oldLines":7,"newStart":10,"newLines":7,"lines":["  */"," "," import { z } from \"zod\";","-import type { Context } from \"hono\";","+import type { Context, TypedResponse } from \"hono\";"," "," export type { ApiErrorCode } from \"./api-errors.js\";"," import type { ApiErrorCode } from \"./api-errors.js\";"]}],"userModified":false,"replaceAll":false}}
