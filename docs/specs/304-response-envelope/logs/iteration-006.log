{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AUh4M6Yn8MGa44iLsGV8hG","type":"tool_result","content":"1\t/**\n2\t * Auth routes: challenge/verify/refresh/logout for JWT session management.\n3\t *\n4\t * WAITLIST-CONTRACT: the waitlist (separate repo, launches first) calls every\n5\t * route in this file. Any change to request/response shape here must keep\n6\t * `waitlist/src/lib/auth-api.ts` in lockstep and is enforced by\n7\t * `__tests__/waitlist-contract.test.ts`. Ship a coordinated waitlist release\n8\t * before merging a breaking change.\n9\t */\n10\t\n11\timport { createRoute } from \"@hono/zod-openapi\";\n12\timport { z } from \"zod\";\n13\timport { randomBytes, createHash } from \"node:crypto\";\n14\timport nacl from \"tweetnacl\";\n15\timport bs58 from \"bs58\";\n16\timport { PublicKey } from \"@solana/web3.js\";\n17\timport { SignJWT } from \"jose\";\n18\timport type { AuthDb } from \"../auth-db.js\";\n19\timport type { Db } from \"../db.js\";\n20\timport { logger } from \"../logger.js\";\n21\timport {\n22\t  ChallengeNonceResponseSchema,\n23\t  TokenResponseSchema,\n24\t  ErrorResponseSchema,\n25\t} from \"../contracts/validators.js\";\n26\timport { createOpenApiApp } from \"../openapi/hono.js\";\n27\t\n28\texport interface AuthRoutesDeps {\n29\t  authDb: AuthDb;\n30\t  db: Db;\n31\t  jwtSecret: Uint8Array;\n32\t  cluster: string;\n33\t  challengeTtlSeconds: number;\n34\t  accessTokenTtlSeconds: number;\n35\t  refreshTokenTtlDays: number;\n36\t}\n37\t\n38\tfunction hashToken(token: string): Buffer {\n39\t  return createHash(\"sha256\").update(token).digest();\n40\t}\n41\t\n42\tfunction issueAccessToken(\n43\t  jwtSecret: Uint8Array,\n44\t  userId: string,\n45\t  now: number,\n46\t  accessTokenTtlSeconds: number,\n47\t): Promise<string> {\n48\t  return new SignJWT({})\n49\t    .setProtectedHeader({ alg: \"HS256\" })\n50\t    .setSubject(userId)\n51\t    .setIssuedAt(now)\n52\t    .setExpirationTime(now + accessTokenTtlSeconds)\n53\t    .sign(jwtSecret);\n54\t}\n55\t\n56\tfunction formatNetwork(cluster: string): string {\n57\t  const normalized = cluster.toLowerCase();\n58\t  if (normalized === \"devnet\") return \"Solana Devnet\";\n59\t  if (normalized === \"mainnet\" || normalized === \"mainnet-beta\") return \"Solana Mainnet\";\n60\t  return `Solana ${cluster}`;\n61\t}\n62\t\n63\tfunction buildSignInMessage(\n64\t  wallet: string,\n65\t  cluster: string,\n66\t  nonce: string,\n67\t  issuedAt: string,\n68\t): string {\n69\t  return [\n70\t    \"Sign this message to create your Taunt BET account.\",\n71\t    \"\",\n72\t    \"This only verifies ownership. No gas or funds are used.\",\n73\t    \"\",\n74\t    `Wallet: ${wallet}`,\n75\t    `Network: ${formatNetwork(cluster)}`,\n76\t    `Timestamp: ${issuedAt}`,\n77\t    `Nonce: ${nonce}`,\n78\t  ].join(\"\\n\");\n79\t}\n80\t\n81\t// ---------------------------------------------------------------------------\n82\t// Route definitions\n83\t// ---------------------------------------------------------------------------\n84\t\n85\tconst challengeRoute = createRoute({\n86\t  method: \"post\",\n87\t  path: \"/challenge\",\n88\t  tags: [\"Auth\"],\n89\t  summary: \"Request sign-in challenge\",\n90\t  request: {\n91\t    body: {\n92\t      required: true,\n93\t      content: {\n94\t        \"application/json\": {\n95\t          schema: z.object({\n96\t            wallet: z.string().min(1).describe(\"Base58 wallet address\"),\n97\t          }),\n98\t        },\n99\t      },\n100\t    },\n101\t  },\n102\t  responses: {\n103\t    200: {\n104\t      content: { \"application/json\": { schema: ChallengeNonceResponseSchema } },\n105\t      description: \"Challenge issued\",\n106\t    },\n107\t    400: {\n108\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n109\t      description: \"Invalid request\",\n110\t    },\n111\t  },\n112\t});\n113\t\n114\tconst verifyRoute = createRoute({\n115\t  method: \"post\",\n116\t  path: \"/verify\",\n117\t  tags: [\"Auth\"],\n118\t  summary: \"Verify signature and issue tokens\",\n119\t  request: {\n120\t    body: {\n121\t      required: true,\n122\t      content: {\n123\t        \"application/json\": {\n124\t          schema: z.object({\n125\t            nonce: z.string(),\n126\t            wallet: z.string(),\n127\t            signature: z.string().describe(\"Base58-encoded Ed25519 signature\"),\n128\t          }),\n129\t        },\n130\t      },\n131\t    },\n132\t  },\n133\t  responses: {\n134\t    200: {\n135\t      content: { \"application/json\": { schema: TokenResponseSchema } },\n136\t      description: \"Tokens issued\",\n137\t    },\n138\t    400: {\n139\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n140\t      description: \"Missing fields\",\n141\t    },\n142\t    401: {\n143\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n144\t      description: \"Invalid signature or challenge\",\n145\t    },\n146\t    500: {\n147\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n148\t      description: \"Server error\",\n149\t    },\n150\t  },\n151\t});\n152\t\n153\tconst refreshRoute = createRoute({\n154\t  method: \"post\",\n155\t  path: \"/refresh\",\n156\t  tags: [\"Auth\"],\n157\t  summary: \"Rotate refresh token and issue new access token\",\n158\t  request: {\n159\t    body: {\n160\t      required: true,\n161\t      content: {\n162\t        \"application/json\": {\n163\t          schema: z.object({\n164\t            refreshToken: z.string(),\n165\t          }),\n166\t        },\n167\t      },\n168\t    },\n169\t  },\n170\t  responses: {\n171\t    200: {\n172\t      content: { \"application/json\": { schema: TokenResponseSchema } },\n173\t      description: \"New tokens issued\",\n174\t    },\n175\t    400: {\n176\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n177\t      description: \"Missing refresh token\",\n178\t    },\n179\t    401: {\n180\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n181\t      description: \"Invalid or expired token\",\n182\t    },\n183\t  },\n184\t});\n185\t\n186\tconst logoutRoute = createRoute({\n187\t  method: \"post\",\n188\t  path: \"/logout\",\n189\t  tags: [\"Auth\"],\n190\t  summary: \"Revoke refresh token\",\n191\t  request: {\n192\t    body: {\n193\t      content: {\n194\t        \"application/json\": {\n195\t          schema: z.object({\n196\t            refreshToken: z.string().optional(),\n197\t          }),\n198\t        },\n199\t      },\n200\t    },\n201\t  },\n202\t  responses: {\n203\t    204: {\n204\t      description: \"Logged out\",\n205\t    },\n206\t  },\n207\t});\n208\t\n209\t// ---------------------------------------------------------------------------\n210\t// Route factory\n211\t// ---------------------------------------------------------------------------\n212\t\n213\texport function createAuthRoutes(deps: AuthRoutesDeps) {\n214\t  const {\n215\t    authDb,\n216\t    db,\n217\t    jwtSecret,\n218\t    cluster,\n219\t    challengeTtlSeconds,\n220\t    accessTokenTtlSeconds,\n221\t    refreshTokenTtlDays,\n222\t  } = deps;\n223\t\n224\t  const app = createOpenApiApp();\n225\t\n226\t  // POST /challenge — generate nonce + human-readable message\n227\t  app.openapi(challengeRoute, async (c) => {\n228\t    const { wallet } = c.req.valid(\"json\");\n229\t\n230\t    const nonce = randomBytes(32).toString(\"hex\");\n231\t    const now = new Date();\n232\t    const expiresAt = new Date(now.getTime() + challengeTtlSeconds * 1000);\n233\t\n234\t    const message = buildSignInMessage(\n235\t      wallet,\n236\t      cluster,\n237\t      nonce,\n238\t      now.toISOString(),\n239\t    );\n240\t\n241\t    await authDb.insertChallenge(nonce, wallet, cluster, message, expiresAt);\n242\t\n243\t    logger.info(\"auth challenge issued\", { wallet, nonce });\n244\t\n245\t    return c.json({\n246\t      nonce,\n247\t      message,\n248\t      expiresAt: expiresAt.toISOString(),\n249\t    }, 200);\n250\t  });\n251\t\n252\t  // POST /verify — consume challenge, verify signature, issue tokens\n253\t  app.openapi(verifyRoute, async (c) => {\n254\t    const { nonce, wallet, signature } = c.req.valid(\"json\");\n255\t\n256\t    // Atomically consume the challenge\n257\t    const challenge = await authDb.consumeChallenge(nonce);\n258\t    if (!challenge) {\n259\t      logger.warn(\"auth verify rejected: challenge not found or expired\", {\n260\t        nonce,\n261\t        wallet,\n262\t      });\n263\t      return c.json({ error: \"Challenge not found, expired, or already used\" }, 401);\n264\t    }\n265\t\n266\t    // Verify wallet matches challenge\n267\t    if (challenge.wallet !== wallet) {\n268\t      logger.warn(\"auth verify rejected: wallet mismatch\", {\n269\t        nonce,\n270\t        challengeWallet: challenge.wallet,\n271\t        requestWallet: wallet,\n272\t      });\n273\t      return c.json({ error: \"Wallet does not match challenge\" }, 401);\n274\t    }\n275\t\n276\t    // Verify Ed25519 signature over the challenge message.\n277\t    // PublicKey validates base58 + 32-byte length + on-curve; signature only\n278\t    // needs base58 decode (raw 64-byte ed25519 sig, not a pubkey).\n279\t    let sigBytes: Uint8Array;\n280\t    let pubkeyBytes: Uint8Array;\n281\t    try {\n282\t      sigBytes = bs58.decode(signature);\n283\t      pubkeyBytes = new PublicKey(wallet).toBytes();\n284\t    } catch {\n285\t      return c.json({ error: \"Invalid signature or wallet encoding\" }, 401);\n286\t    }\n287\t\n288\t    if (sigBytes.length !== 64) {\n289\t      return c.json({ error: \"Invalid signature length\" }, 401);\n290\t    }\n291\t\n292\t    const messageBytes = new TextEncoder().encode(challenge.message);\n293\t    const valid = nacl.sign.detached.verify(messageBytes, sigBytes, pubkeyBytes);\n294\t    if (!valid) {\n295\t      logger.warn(\"auth verify rejected: signature verification failed\", {\n296\t        wallet,\n297\t      });\n298\t      return c.json({ error: \"Invalid signature\" }, 401);\n299\t    }\n300\t\n301\t    let profile;\n302\t    try {\n303\t      profile = await db.getProfileByWallet(wallet);\n304\t      if (!profile) {\n305\t        profile = await db.createPlayerProfile(wallet);\n306\t        logger.info(\"player profile auto-created\", { wallet, userId: profile.user_id });\n307\t      }\n308\t    } catch (e) {\n309\t      logger.error(\"profile creation failed\", { wallet, error: e });\n310\t      return c.json({ error: \"Failed to establish player profile\" }, 500);\n311\t    }\n312\t\n313\t    // Issue JWT access token\n314\t    const now = Math.floor(Date.now() / 1000);\n315\t    const accessToken = await issueAccessToken(\n316\t      jwtSecret,\n317\t      profile.user_id,\n318\t      now,\n319\t      accessTokenTtlSeconds,\n320\t    );\n321\t\n322\t    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n323\t\n324\t    // Generate opaque refresh token\n325\t    const refreshTokenRaw = randomBytes(48).toString(\"hex\");\n326\t    const refreshTokenHash = hashToken(refreshTokenRaw);\n327\t    const familyId = randomBytes(16).toString(\"hex\");\n328\t    const refreshExpiresAt = new Date(\n329\t      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n330\t    );\n331\t\n332\t    await authDb.insertRefreshToken(\n333\t      profile.user_id,\n334\t      wallet,\n335\t      refreshTokenHash,\n336\t      familyId,\n337\t      refreshExpiresAt,\n338\t    );\n339\t\n340\t    logger.info(\"auth session created\", { wallet, userId: profile.user_id });\n341\t\n342\t    return c.json({\n343\t      accessToken,\n344\t      accessExpiresAt,\n345\t      refreshToken: refreshTokenRaw,\n346\t      refreshExpiresAt: refreshExpiresAt.toISOString(),\n347\t    }, 200);\n348\t  });\n349\t\n350\t  // POST /refresh — rotate refresh token, issue new access token\n351\t  app.openapi(refreshRoute, async (c) => {\n352\t    const { refreshToken } = c.req.valid(\"json\");\n353\t\n354\t    const tokenHash = hashToken(refreshToken);\n355\t    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n356\t\n357\t    if (!stored) {\n358\t      logger.warn(\"auth refresh rejected: token not found\");\n359\t      return c.json({ error: \"Invalid refresh token\" }, 401);\n360\t    }\n361\t\n362\t    // Reuse detection: if the token was already revoked, someone replayed it.\n363\t    // Revoke the entire family as a precaution.\n364\t    if (stored.revoked) {\n365\t      logger.warn(\"auth refresh rejected: token reuse detected, revoking family\", {\n366\t        userId: stored.user_id,\n367\t        wallet: stored.wallet,\n368\t        familyId: stored.family_id,\n369\t      });\n370\t      await authDb.revokeTokenFamily(stored.family_id);\n371\t      return c.json({ error: \"Token reuse detected. Please sign in again.\" }, 401);\n372\t    }\n373\t\n374\t    // Check expiry\n375\t    if (new Date() > stored.expires_at) {\n376\t      logger.warn(\"auth refresh rejected: token expired\", {\n377\t        userId: stored.user_id,\n378\t        wallet: stored.wallet,\n379\t      });\n380\t      await authDb.revokeRefreshToken(stored.id);\n381\t      return c.json({ error: \"Refresh token expired\" }, 401);\n382\t    }\n383\t\n384\t    // Revoke old token\n385\t    await authDb.revokeRefreshToken(stored.id);\n386\t\n387\t    // Issue new access token\n388\t    const now = Math.floor(Date.now() / 1000);\n389\t    const accessToken = await issueAccessToken(\n390\t      jwtSecret,\n391\t      stored.user_id,\n392\t      now,\n393\t      accessTokenTtlSeconds,\n394\t    );\n395\t\n396\t    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n397\t\n398\t    // Issue new refresh token in the same family\n399\t    const newRefreshRaw = randomBytes(48).toString(\"hex\");\n400\t    const newRefreshHash = hashToken(newRefreshRaw);\n401\t    const newRefreshExpiresAt = new Date(\n402\t      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n403\t    );\n404\t\n405\t    await authDb.insertRefreshToken(\n406\t      stored.user_id,\n407\t      stored.wallet,\n408\t      newRefreshHash,\n409\t      stored.family_id,\n410\t      newRefreshExpiresAt,\n411\t    );\n412\t\n413\t    logger.debug(\"auth token refreshed\", { userId: stored.user_id, wallet: stored.wallet });\n414\t\n415\t    return c.json({\n416\t      accessToken,\n417\t      accessExpiresAt,\n418\t      refreshToken: newRefreshRaw,\n419\t      refreshExpiresAt: newRefreshExpiresAt.toISOString(),\n420\t    }, 200);\n421\t  });\n422\t\n423\t  // POST /logout — revoke refresh token\n424\t  app.openapi(logoutRoute, async (c) => {\n425\t    const body = c.req.valid(\"json\");\n426\t\n427\t    if (!body.refreshToken) {\n428\t      return c.body(null, 204);\n429\t    }\n430\t\n431\t    const tokenHash = hashToken(body.refreshToken);\n432\t    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n433\t    if (stored) {\n434\t      await authDb.revokeRefreshToken(stored.id);\n435\t      logger.info(\"auth logout\", { userId: stored.user_id, wallet: stored.wallet });\n436\t    }\n437\t\n438\t    return c.body(null, 204);\n439\t  });\n440\t\n441\t  return app;\n442\t}\n443\t"}]},"parent_tool_use_id":null,"session_id":"b184ad64-55fb-425e-85f4-42f002c1f5d8","uuid":"8c03b25b-8b94-419f-9bf9-fdd7feef38c3","timestamp":"2026-04-22T09:33:02.602Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/auth.ts","content":"/**\n * Auth routes: challenge/verify/refresh/logout for JWT session management.\n *\n * WAITLIST-CONTRACT: the waitlist (separate repo, launches first) calls every\n * route in this file. Any change to request/response shape here must keep\n * `waitlist/src/lib/auth-api.ts` in lockstep and is enforced by\n * `__tests__/waitlist-contract.test.ts`. Ship a coordinated waitlist release\n * before merging a breaking change.\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport { randomBytes, createHash } from \"node:crypto\";\nimport nacl from \"tweetnacl\";\nimport bs58 from \"bs58\";\nimport { PublicKey } from \"@solana/web3.js\";\nimport { SignJWT } from \"jose\";\nimport type { AuthDb } from \"../auth-db.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport {\n  ChallengeNonceResponseSchema,\n  TokenResponseSchema,\n  ErrorResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface AuthRoutesDeps {\n  authDb: AuthDb;\n  db: Db;\n  jwtSecret: Uint8Array;\n  cluster: string;\n  challengeTtlSeconds: number;\n  accessTokenTtlSeconds: number;\n  refreshTokenTtlDays: number;\n}\n\nfunction hashToken(token: string): Buffer {\n  return createHash(\"sha256\").update(token).digest();\n}\n\nfunction issueAccessToken(\n  jwtSecret: Uint8Array,\n  userId: string,\n  now: number,\n  accessTokenTtlSeconds: number,\n): Promise<string> {\n  return new SignJWT({})\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userId)\n    .setIssuedAt(now)\n    .setExpirationTime(now + accessTokenTtlSeconds)\n    .sign(jwtSecret);\n}\n\nfunction formatNetwork(cluster: string): string {\n  const normalized = cluster.toLowerCase();\n  if (normalized === \"devnet\") return \"Solana Devnet\";\n  if (normalized === \"mainnet\" || normalized === \"mainnet-beta\") return \"Solana Mainnet\";\n  return `Solana ${cluster}`;\n}\n\nfunction buildSignInMessage(\n  wallet: string,\n  cluster: string,\n  nonce: string,\n  issuedAt: string,\n): string {\n  return [\n    \"Sign this message to create your Taunt BET account.\",\n    \"\",\n    \"This only verifies ownership. No gas or funds are used.\",\n    \"\",\n    `Wallet: ${wallet}`,\n    `Network: ${formatNetwork(cluster)}`,\n    `Timestamp: ${issuedAt}`,\n    `Nonce: ${nonce}`,\n  ].join(\"\\n\");\n}\n\n// ---------------------------------------------------------------------------\n// Route definitions\n// ---------------------------------------------------------------------------\n\nconst challengeRoute = createRoute({\n  method: \"post\",\n  path: \"/challenge\",\n  tags: [\"Auth\"],\n  summary: \"Request sign-in challenge\",\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": {\n          schema: z.object({\n            wallet: z.string().min(1).describe(\"Base58 wallet address\"),\n          }),\n        },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: ChallengeNonceResponseSchema } },\n      description: \"Challenge issued\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Invalid request\",\n    },\n  },\n});\n\nconst verifyRoute = createRoute({\n  method: \"post\",\n  path: \"/verify\",\n  tags: [\"Auth\"],\n  summary: \"Verify signature and issue tokens\",\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": {\n          schema: z.object({\n            nonce: z.string(),\n            wallet: z.string(),\n            signature: z.string().describe(\"Base58-encoded Ed25519 signature\"),\n          }),\n        },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: TokenResponseSchema } },\n      description: \"Tokens issued\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Missing fields\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Invalid signature or challenge\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\nconst refreshRoute = createRoute({\n  method: \"post\",\n  path: \"/refresh\",\n  tags: [\"Auth\"],\n  summary: \"Rotate refresh token and issue new access token\",\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": {\n          schema: z.object({\n            refreshToken: z.string(),\n          }),\n        },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: TokenResponseSchema } },\n      description: \"New tokens issued\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Missing refresh token\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Invalid or expired token\",\n    },\n  },\n});\n\nconst logoutRoute = createRoute({\n  method: \"post\",\n  path: \"/logout\",\n  tags: [\"Auth\"],\n  summary: \"Revoke refresh token\",\n  request: {\n    body: {\n      content: {\n        \"application/json\": {\n          schema: z.object({\n            refreshToken: z.string().optional(),\n          }),\n        },\n      },\n    },\n  },\n  responses: {\n    204: {\n      description: \"Logged out\",\n    },\n  },\n});\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport function createAuthRoutes(deps: AuthRoutesDeps) {\n  const {\n    authDb,\n    db,\n    jwtSecret,\n    cluster,\n    challengeTtlSeconds,\n    accessTokenTtlSeconds,\n    refreshTokenTtlDays,\n  } = deps;\n\n  const app = createOpenApiApp();\n\n  // POST /challenge — generate nonce + human-readable message\n  app.openapi(challengeRoute, async (c) => {\n    const { wallet } = c.req.valid(\"json\");\n\n    const nonce = randomBytes(32).toString(\"hex\");\n    const now = new Date();\n    const expiresAt = new Date(now.getTime() + challengeTtlSeconds * 1000);\n\n    const message = buildSignInMessage(\n      wallet,\n      cluster,\n      nonce,\n      now.toISOString(),\n    );\n\n    await authDb.insertChallenge(nonce, wallet, cluster, message, expiresAt);\n\n    logger.info(\"auth challenge issued\", { wallet, nonce });\n\n    return c.json({\n      nonce,\n      message,\n      expiresAt: expiresAt.toISOString(),\n    }, 200);\n  });\n\n  // POST /verify — consume challenge, verify signature, issue tokens\n  app.openapi(verifyRoute, async (c) => {\n    const { nonce, wallet, signature } = c.req.valid(\"json\");\n\n    // Atomically consume the challenge\n    const challenge = await authDb.consumeChallenge(nonce);\n    if (!challenge) {\n      logger.warn(\"auth verify rejected: challenge not found or expired\", {\n        nonce,\n        wallet,\n      });\n      return c.json({ error: \"Challenge not found, expired, or already used\" }, 401);\n    }\n\n    // Verify wallet matches challenge\n    if (challenge.wallet !== wallet) {\n      logger.warn(\"auth verify rejected: wallet mismatch\", {\n        nonce,\n        challengeWallet: challenge.wallet,\n        requestWallet: wallet,\n      });\n      return c.json({ error: \"Wallet does not match challenge\" }, 401);\n    }\n\n    // Verify Ed25519 signature over the challenge message.\n    // PublicKey validates base58 + 32-byte length + on-curve; signature only\n    // needs base58 decode (raw 64-byte ed25519 sig, not a pubkey).\n    let sigBytes: Uint8Array;\n    let pubkeyBytes: Uint8Array;\n    try {\n      sigBytes = bs58.decode(signature);\n      pubkeyBytes = new PublicKey(wallet).toBytes();\n    } catch {\n      return c.json({ error: \"Invalid signature or wallet encoding\" }, 401);\n    }\n\n    if (sigBytes.length !== 64) {\n      return c.json({ error: \"Invalid signature length\" }, 401);\n    }\n\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const valid = nacl.sign.detached.verify(messageBytes, sigBytes, pubkeyBytes);\n    if (!valid) {\n      logger.warn(\"auth verify rejected: signature verification failed\", {\n        wallet,\n      });\n      return c.json({ error: \"Invalid signature\" }, 401);\n    }\n\n    let profile;\n    try {\n      profile = await db.getProfileByWallet(wallet);\n      if (!profile) {\n        profile = await db.createPlayerProfile(wallet);\n        logger.info(\"player profile auto-created\", { wallet, userId: profile.user_id });\n      }\n    } catch (e) {\n      logger.error(\"profile creation failed\", { wallet, error: e });\n      return c.json({ error: \"Failed to establish player profile\" }, 500);\n    }\n\n    // Issue JWT access token\n    const now = Math.floor(Date.now() / 1000);\n    const accessToken = await issueAccessToken(\n      jwtSecret,\n      profile.user_id,\n      now,\n      accessTokenTtlSeconds,\n    );\n\n    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n\n    // Generate opaque refresh token\n    const refreshTokenRaw = randomBytes(48).toString(\"hex\");\n    const refreshTokenHash = hashToken(refreshTokenRaw);\n    const familyId = randomBytes(16).toString(\"hex\");\n    const refreshExpiresAt = new Date(\n      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n    );\n\n    await authDb.insertRefreshToken(\n      profile.user_id,\n      wallet,\n      refreshTokenHash,\n      familyId,\n      refreshExpiresAt,\n    );\n\n    logger.info(\"auth session created\", { wallet, userId: profile.user_id });\n\n    return c.json({\n      accessToken,\n      accessExpiresAt,\n      refreshToken: refreshTokenRaw,\n      refreshExpiresAt: refreshExpiresAt.toISOString(),\n    }, 200);\n  });\n\n  // POST /refresh — rotate refresh token, issue new access token\n  app.openapi(refreshRoute, async (c) => {\n    const { refreshToken } = c.req.valid(\"json\");\n\n    const tokenHash = hashToken(refreshToken);\n    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n\n    if (!stored) {\n      logger.warn(\"auth refresh rejected: token not found\");\n      return c.json({ error: \"Invalid refresh token\" }, 401);\n    }\n\n    // Reuse detection: if the token was already revoked, someone replayed it.\n    // Revoke the entire family as a precaution.\n    if (stored.revoked) {\n      logger.warn(\"auth refresh rejected: token reuse detected, revoking family\", {\n        userId: stored.user_id,\n        wallet: stored.wallet,\n        familyId: stored.family_id,\n      });\n      await authDb.revokeTokenFamily(stored.family_id);\n      return c.json({ error: \"Token reuse detected. Please sign in again.\" }, 401);\n    }\n\n    // Check expiry\n    if (new Date() > stored.expires_at) {\n      logger.warn(\"auth refresh rejected: token expired\", {\n        userId: stored.user_id,\n        wallet: stored.wallet,\n      });\n      await authDb.revokeRefreshToken(stored.id);\n      return c.json({ error: \"Refresh token expired\" }, 401);\n    }\n\n    // Revoke old token\n    await authDb.revokeRefreshToken(stored.id);\n\n    // Issue new access token\n    const now = Math.floor(Date.now() / 1000);\n    const accessToken = await issueAccessToken(\n      jwtSecret,\n      stored.user_id,\n      now,\n      accessTokenTtlSeconds,\n    );\n\n    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n\n    // Issue new refresh token in the same family\n    const newRefreshRaw = randomBytes(48).toString(\"hex\");\n    const newRefreshHash = hashToken(newRefreshRaw);\n    const newRefreshExpiresAt = new Date(\n      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n    );\n\n    await authDb.insertRefreshToken(\n      stored.user_id,\n      stored.wallet,\n      newRefreshHash,\n      stored.family_id,\n      newRefreshExpiresAt,\n    );\n\n    logger.debug(\"auth token refreshed\", { userId: stored.user_id, wallet: stored.wallet });\n\n    return c.json({\n      accessToken,\n      accessExpiresAt,\n      refreshToken: newRefreshRaw,\n      refreshExpiresAt: newRefreshExpiresAt.toISOString(),\n    }, 200);\n  });\n\n  // POST /logout — revoke refresh token\n  app.openapi(logoutRoute, async (c) => {\n    const body = c.req.valid(\"json\");\n\n    if (!body.refreshToken) {\n      return c.body(null, 204);\n    }\n\n    const tokenHash = hashToken(body.refreshToken);\n    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n    if (stored) {\n      await authDb.revokeRefreshToken(stored.id);\n      logger.info(\"auth logout\", { userId: stored.user_id, wallet: stored.wallet });\n    }\n\n    return c.body(null, 204);\n  });\n\n  return app;\n}\n","numLines":443,"startLine":1,"totalLines":443}}}
