"NOT_FOUND\",\n49\t  CONFLICT: \"CONFLICT\",\n50\t  PRECONDITION_FAILED: \"PRECONDITION_FAILED\",\n51\t} as const;\n52\t\n53\texport type ApiErrorCode = (typeof API_ERROR_CODES)[keyof typeof API_ERROR_CODES];\n54\t\n55\t// ---------------------------------------------------------------------------\n56\t// Legacy helpers (to be deleted in the cleanup iteration once all public\n57\t// routes have migrated to the envelope helpers in `api-envelope.ts`).\n58\t// ---------------------------------------------------------------------------\n59\t\n60\texport interface ErrorResponseBody {\n61\t  error: string;\n62\t}\n63\t\n64\texport interface StructuredErrorDetail {\n65\t  code: string;\n66\t  message: string;\n67\t  retryable?: boolean;\n68\t}\n69\t\n70\texport interface StructuredErrorResponseBody {\n71\t  error: StructuredErrorDetail;\n72\t}\n73\t\n74\texport function errorMessage(error: string): ErrorResponseBody {\n75\t  return { error };\n76\t}\n77\t\n78\texport function structuredErrorMessage(\n79\t  code: string,\n80\t  message: string,\n81\t  retryable?: boolean,\n82\t): StructuredErrorResponseBody {\n83\t  return {\n84\t    error: retryable === undefined ? { code, message } : { code, message, retryable },\n85\t  };\n86\t}\n87\t"}]},"parent_tool_use_id":null,"session_id":"b184ad64-55fb-425e-85f4-42f002c1f5d8","uuid":"9302da0a-f10d-49d6-a359-56a6e1845f7b","timestamp":"2026-04-22T09:34:30.010Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/contracts/api-errors.ts","content":"/**\n * Central catalog of stable public API error codes.\n *\n * Every `error.code` emitted on a public JSON route MUST come from this\n * catalog. Code values are SCREAMING_SNAKE_CASE and stable across versions —\n * renaming a shipped code is a breaking change. See FR-2 in\n * `docs/specs/304-response-envelope/spec.md`.\n */\n\nexport const API_ERROR_CODES = {\n  AUTH_REQUIRED: \"AUTH_REQUIRED\",\n  FORBIDDEN: \"FORBIDDEN\",\n  RATE_LIMITED: \"RATE_LIMITED\",\n  VALIDATION_FAILED: \"VALIDATION_FAILED\",\n  INVALID_REQUEST: \"INVALID_REQUEST\",\n  INVALID_PARAMS: \"INVALID_PARAMS\",\n\n  INVALID_SIGNATURE: \"INVALID_SIGNATURE\",\n  CHALLENGE_EXPIRED: \"CHALLENGE_EXPIRED\",\n  REFRESH_TOKEN_INVALID: \"REFRESH_TOKEN_INVALID\",\n\n  CODE_ALREADY_SET: \"CODE_ALREADY_SET\",\n  CODE_TAKEN: \"CODE_TAKEN\",\n  CODE_NOT_FOUND: \"CODE_NOT_FOUND\",\n  INVALID_CODE: \"INVALID_CODE\",\n  SELF_REFERRAL: \"SELF_REFERRAL\",\n  ALREADY_LINKED: \"ALREADY_LINKED\",\n  ZERO_BALANCE: \"ZERO_BALANCE\",\n  BELOW_THRESHOLD: \"BELOW_THRESHOLD\",\n  CLAIM_NOT_FOUND: \"CLAIM_NOT_FOUND\",\n\n  PROFILE_NOT_FOUND: \"PROFILE_NOT_FOUND\",\n  USERNAME_TAKEN: \"USERNAME_TAKEN\",\n  USERNAME_COOLDOWN: \"USERNAME_COOLDOWN\",\n  INVALID_USERNAME: \"INVALID_USERNAME\",\n\n  MATCH_NOT_FOUND: \"MATCH_NOT_FOUND\",\n  MATCH_PHASE_INVALID: \"MATCH_PHASE_INVALID\",\n  ROUND_NOT_FOUND: \"ROUND_NOT_FOUND\",\n  BET_TOO_SMALL: \"BET_TOO_SMALL\",\n  BET_TOO_LARGE: \"BET_TOO_LARGE\",\n\n  TELEGRAM_NOT_LINKED: \"TELEGRAM_NOT_LINKED\",\n  TELEGRAM_ALREADY_LINKED: \"TELEGRAM_ALREADY_LINKED\",\n  TELEGRAM_TOKEN_EXPIRED: \"TELEGRAM_TOKEN_EXPIRED\",\n\n  PRICE_UNAVAILABLE: \"PRICE_UNAVAILABLE\",\n  NOT_FOUND: \"NOT_FOUND\",\n  CONFLICT: \"CONFLICT\",\n  PRECONDITION_FAILED: \"PRECONDITION_FAILED\",\n} as const;\n\nexport type ApiErrorCode = (typeof API_ERROR_CODES)[keyof typeof API_ERROR_CODES];\n\n// ---------------------------------------------------------------------------\n// Legacy helpers (to be deleted in the cleanup iteration once all public\n// routes have migrated to the envelope helpers in `api-envelope.ts`).\n// ---------------------------------------------------------------------------\n\nexport interface ErrorResponseBody {\n  error: string;\n}\n\nexport interface StructuredErrorDetail {\n  code: string;\n  message: string;\n  retryable?: boolean;\n}\n\nexport interface StructuredErrorResponseBody {\n  error: StructuredErrorDetail;\n}\n\nexport function e