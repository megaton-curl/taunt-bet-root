{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TewsycmRuyB81FR8mVaESw","type":"tool_result","content":"1\t/**\n2\t * Shared response envelope for public JSON routes.\n3\t *\n4\t * Every public JSON response body is either:\n5\t *   { ok: true,  data: <payload> }   — success (200/201/202)\n6\t *   { ok: false, error: ApiError }   — failure (4xx/5xx)\n7\t *\n8\t * Semantic HTTP status is preserved — handled domain failures MUST NOT be\n9\t * flattened into `200`. See `docs/specs/304-response-envelope/spec.md`.\n10\t */\n11\t\n12\timport { z } from \"zod\";\n13\timport type { Context } from \"hono\";\n14\t\n15\texport type { ApiErrorCode } from \"./api-errors.js\";\n16\timport type { ApiErrorCode } from \"./api-errors.js\";\n17\t\n18\texport interface ApiError {\n19\t  code: ApiErrorCode;\n20\t  message: string;\n21\t  retryable?: boolean;\n22\t  details?: unknown;\n23\t}\n24\t\n25\texport interface ApiEnvelopeSuccess<T> {\n26\t  ok: true;\n27\t  data: T;\n28\t}\n29\t\n30\texport interface ApiEnvelopeError {\n31\t  ok: false;\n32\t  error: ApiError;\n33\t}\n34\t\n35\texport type ApiEnvelope<T> = ApiEnvelopeSuccess<T> | ApiEnvelopeError;\n36\t\n37\texport const ApiErrorSchema = z.object({\n38\t  code: z.string(),\n39\t  message: z.string(),\n40\t  retryable: z.boolean().optional(),\n41\t  details: z.unknown().optional(),\n42\t});\n43\t\n44\texport const ErrorEnvelopeSchema = z.object({\n45\t  ok: z.literal(false),\n46\t  error: ApiErrorSchema,\n47\t});\n48\t\n49\texport function envelope<T extends z.ZodTypeAny>(dataSchema: T) {\n50\t  return z.discriminatedUnion(\"ok\", [\n51\t    z.object({\n52\t      ok: z.literal(true),\n53\t      data: dataSchema,\n54\t    }),\n55\t    ErrorEnvelopeSchema,\n56\t  ]);\n57\t}\n58\t\n59\texport type SuccessStatus = 200 | 201 | 202;\n60\texport type ErrorStatus = 400 | 401 | 403 | 404 | 409 | 422 | 429 | 500 | 503;\n61\t\n62\texport function ok<T>(c: Context, data: T, status: SuccessStatus = 200) {\n63\t  const body: ApiEnvelopeSuccess<T> = { ok: true, data };\n64\t  return c.json(body, status);\n65\t}\n66\t\n67\texport function err(\n68\t  c: Context,\n69\t  status: ErrorStatus,\n70\t  code: ApiErrorCode,\n71\t  message: string,\n72\t  opts?: { retryable?: boolean; details?: unknown },\n73\t) {\n74\t  const error: ApiError = { code, message };\n75\t  if (opts?.retryable !== undefined) error.retryable = opts.retryable;\n76\t  if (opts?.details !== undefined) error.details = opts.details;\n77\t  const body: ApiEnvelopeError = { ok: false, error };\n78\t  return c.json(body, status);\n79\t}\n80\t"}]},"parent_tool_use_id":null,"session_id":"b184ad64-55fb-425e-85f4-42f002c1f5d8","uuid":"6197efb4-aa91-4fac-9489-7ced1c60010d","timestamp":"2026-04-22T09:33:09.562Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/contracts/api-envelope.ts","content":"/**\n * Shared response envelope for public JSON routes.\n *\n * Every public JSON response body is either:\n *   { ok: true,  data: <payload> }   — success (200/201/202)\n *   { ok: false, error: ApiError }   — failure (4xx/5xx)\n *\n * Semantic HTTP status is preserved — handled domain failures MUST NOT be\n * flattened into `200`. See `docs/specs/304-response-envelope/spec.md`.\n */\n\nimport { z } from \"zod\";\nimport type { Context } from \"hono\";\n\nexport type { ApiErrorCode } from \"./api-errors.js\";\nimport type { ApiErrorCode } from \"./api-errors.js\";\n\nexport interface ApiError {\n  code: ApiErrorCode;\n  message: string;\n  retryable?: boolean;\n  details?: unknown;\n}\n\nexport interface ApiEnvelopeSuccess<T> {\n  ok: true;\n  data: T;\n}\n\nexport interface ApiEnvelopeError {\n  ok: false;\n  error: ApiError;\n}\n\nexport type ApiEnvelope<T> = ApiEnvelopeSuccess<T> | ApiEnvelopeError;\n\nexport const ApiErrorSchema = z.object({\n  code: z.string(),\n  message: z.string(),\n  retryable: z.boolean().optional(),\n  details: z.unknown().optional(),\n});\n\nexport const ErrorEnvelopeSchema = z.object({\n  ok: z.literal(false),\n  error: ApiErrorSchema,\n});\n\nexport function envelope<T extends z.ZodTypeAny>(dataSchema: T) {\n  return z.discriminatedUnion(\"ok\", [\n    z.object({\n      ok: z.literal(true),\n      data: dataSchema,\n    }),\n    ErrorEnvelopeSchema,\n  ]);\n}\n\nexport type SuccessStatus = 200 | 201 | 202;\nexport type ErrorStatus = 400 | 401 | 403 | 404 | 409 | 422 | 429 | 500 | 503;\n\nexport function ok<T>(c: Context, data: T, status: SuccessStatus = 200) {\n  const body: ApiEnvelopeSuccess<T> = { ok: true, data };\n  return c.json(body, status);\n}\n\nexport function err(\n  c: Context,\n  status: ErrorStatus,\n  code: ApiErrorCode,\n  message: string,\n  opts?: { retryable?: boolean; details?: unknown },\n) {\n  const error: ApiError = { code, message };\n  if (opts?.retryable !== undefined) error.retryable = opts.retryable;\n  if (opts?.details !== undefined) error.details = opts.details;\n  const body: ApiEnvelopeError = { ok: false, error };\n  return c.json(body, status);\n}\n","numLines":80,"startLine":1,"totalLines":80}}}
