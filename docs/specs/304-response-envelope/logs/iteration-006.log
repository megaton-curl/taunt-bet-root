 data: T;\n}\n\nexport interface ApiEnvelopeError {\n  ok: false;\n  error: ApiError;\n}\n\nexport type ApiEnvelope<T> = ApiEnvelopeSuccess<T> | ApiEnvelopeError;\n\nexport const ApiErrorSchema = z.object({\n  code: z.string(),\n  message: z.string(),\n  retryable: z.boolean().optional(),\n  details: z.unknown().optional(),\n});\n\nexport const ErrorEnvelopeSchema = z.object({\n  ok: z.literal(false),\n  error: ApiErrorSchema,\n});\n\nexport function envelope<T extends z.ZodTypeAny>(dataSchema: T) {\n  return z.discriminatedUnion(\"ok\", [\n    z.object({\n      ok: z.literal(true),\n      data: dataSchema,\n    }),\n    ErrorEnvelopeSchema,\n  ]);\n}\n\nexport type SuccessStatus = 200 | 201 | 202;\nexport type ErrorStatus = 400 | 401 | 403 | 404 | 409 | 422 | 429 | 500 | 503;\n\nexport function ok<T>(\n  c: Context,\n  data: T,\n): Response & TypedResponse<ApiEnvelopeSuccess<T>, 200, \"json\">;\nexport function ok<T, S extends SuccessStatus>(\n  c: Context,\n  data: T,\n  status: S,\n): Response & TypedResponse<ApiEnvelopeSuccess<T>, S, \"json\">;\nexport function ok<T>(c: Context, data: T, status: SuccessStatus = 200) {\n  const body: ApiEnvelopeSuccess<T> = { ok: true, data };\n  return c.json(body, status);\n}\n\nexport function err<S extends ErrorStatus>(\n  c: Context,\n  status: S,\n  code: ApiErrorCode,\n  message: string,\n  opts?: { retryable?: boolean; details?: unknown },\n): Response & TypedResponse<ApiEnvelopeError, S, \"json\"> {\n  const error: ApiError = { code, message };\n  if (opts?.retryable !== undefined) error.retryable = opts.retryable;\n  if (opts?.details !== undefined) error.details = opts.details;\n  const body: ApiEnvelopeError = { ok: false, error };\n  // `details` is intentionally typed as `unknown` at the interface level so\n  // callers can pass structured metadata (Zod issues, limits, etc.) without\n  // up-front shape constraints. Hono's TypedResponse narrows unknown to\n  // JSONValue; runtime values are always JSON-serializable, so cast here.\n  return c.json(body, status) as Response &\n    TypedResponse<ApiEnvelopeError, S, \"json\">;\n}\n","structuredPatch":[{"oldStart":11,"oldLines":6,"newStart":11,"newLines":7,"lines":[" "," import { z } from \"zod\";"," import type { Context, TypedResponse } from \"hono\";","+import type { JSONValue } from \"hono/utils/types\";"," "," export type { ApiErrorCode } from \"./api-errors.js\";"," import type { ApiErrorCode } from \"./api-errors.js\";"]},{"oldStart":19,"oldLines":7,"newStart":20,"newLines":7,"lines":["   code: ApiErrorCode;","   message: string;","   retryable?: boolean;","-  details?: unknown;","+  details?: JSONValue;"," }"," "," export interface ApiEnvelopeSuccess<T> {"]}],"userModified":false,"replaceAll":false}}
