{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N4L7T7byFHDqW8ZQn3fqhS","type":"tool_result","content":"400\t\n401\t    // Wallet B tries the same name (case-insensitive)\n402\t    const res2 = await app.request(\"/profile/username\", {\n403\t      method: \"PUT\",\n404\t      headers: {\n405\t        Authorization: `Bearer ${tokenB}`,\n406\t        \"Content-Type\": \"application/json\",\n407\t      },\n408\t      body: JSON.stringify({ username: username.toLowerCase() }),\n409\t    });\n410\t    expect(res2.status).toBe(409);\n411\t    const body = (await res2.json()) as {\n412\t      ok: false;\n413\t      error: { code: string; message: string };\n414\t    };\n415\t    expect(body.ok).toBe(false);\n416\t    expect(body.error.code).toBe(\"USERNAME_TAKEN\");\n417\t  });\n418\t\n419\t  // -----------------------------------------------------------------------\n420\t  // (6) GET /public-profile/:username returns limited public data\n421\t  // -----------------------------------------------------------------------\n422\t\n423\t  it(\"GET /public-profile/:username returns public profile\", async () => {\n424\t    const { accessToken } = await authenticateWallet(app, keypairA);\n425\t    const username = makeUniqueUsername(\"PublicUser\");\n426\t\n427\t    // Set a known username\n428\t    await app.request(\"/profile/username\", {\n429\t      method: \"PUT\",\n430\t      headers: {\n431\t        Authorization: `Bearer ${accessToken}`,\n432\t        \"Content-Type\": \"application/json\",\n433\t      },\n434\t      body: JSON.stringify({ username }),\n435\t    });\n436\t\n437\t    // Fetch public profile (no auth)\n438\t    const res = await app.request(`/public-profile/${username}`);\n439\t    expect(res.status).toBe(200);\n440\t    const body = (await res.json()) as Record<string, any>;\n441\t\n442\t    expect(body.userId).toMatch(/^usr_[a-z0-9]{8}$/);\n443\t    expect(body.username).toBe(username);\n444\t    expect(body.heatMultiplier).toBe(1);\n445\t    expect(body.createdAt).toBeDefined();\n446\t\n447\t    // Public stats — limited fields only\n448\t    const stats = body.stats as Record<string, any>;\n449\t    expect(stats.gamesPlayed).toBe(0);\n450\t    expect(stats.totalWins).toBe(0);\n451\t    expect(stats.winRate).toBe(0);\n452\t\n453\t    // Must NOT have private fields\n454\t    expect(body).not.toHaveProperty(\"wallet\");\n455\t    expect(body).not.toHaveProperty(\"pointsBalance\");\n456\t    expect(stats).not.toHaveProperty(\"totalWagered\");\n457\t    expect(stats).not.toHaveProperty(\"netPnl\");\n458\t    expect(stats).not.toHaveProperty(\"winStreakCurrent\");\n459\t    expect(stats).not.toHaveProperty(\"winStreakBest\");\n460\t  });\n461\t\n462\t  // -----------------------------------------------------------------------\n463\t  // (7) GET /public-profile/:user_id returns same data\n464\t  // -----------------------------------------------------------------------\n465\t\n466\t  it(\"GET /public-profile/:user_id resolves by user_id\", async () => {\n467\t    const { accessToken } = await authenticateWallet(app, keypairA);\n468\t\n469\t    // Get the userId from /profile/me\n470\t    const meRes = await app.request(\"/profile/me\", {\n471\t      method: \"GET\",\n472\t      headers: { Authorization: `Bearer ${accessToken}` },\n473\t    });\n474\t    const meEnvelope = (await meRes.json()) as {\n475\t      ok: true;\n476\t      data: { userId: string; username: string };\n477\t    };\n478\t    const userId = meEnvelope.data.userId;\n479\t\n480\t    // Fetch via user_id (public-profile converts in a later iteration)\n481\t    const res = await app.request(`/public-profile/${userId}`);\n482\t    expect(res.status).toBe(200);\n483\t    const body = (await res.json()) as { userId: string; username: string };\n484\t    expect(body.userId).toBe(userId);\n485\t    expect(body.username).toBe(meEnvelope.data.username);\n486\t\n487\t    // No wallet\n488\t    expect(body).not.toHaveProperty(\"wallet\");\n489\t  });\n490\t\n491\t  // -----------------------------------------------------------------------\n492\t  // (8) No wallet field in any response (additional checks)\n493\t  // -----------------------------------------------------------------------\n494\t\n495\t  it(\"no wallet field in any response\", async () => {\n496\t    const { accessToken } = await authenticateWallet(app, keypairA);\n497\t    const username = makeUniqueUsername(\"NoWalletChk\");\n498\t\n499\t    // GET /profile/me\n500\t    const meRes = await app.request(\"/profile/me\", {\n501\t      method: \"GET\",\n502\t      headers: { Authorization: `Bearer ${accessToken}` },\n503\t    });\n504\t    const meBody = await meRes.text();\n505\t    expect(meBody).not.toContain(keypairA.publicKey.toBase58());\n506\t\n507\t    // PUT /profile/username\n508\t    const putRes = await app.request(\"/profile/username\", {\n509\t      method: \"PUT\",\n510\t      headers: {\n511\t        Authorization: `Bearer ${accessToken}`,\n512\t        \"Content-Type\": \"application/json\",\n513\t      },\n514\t      body: JSON.stringify({ username }),\n515\t    });\n516\t    const putBody = await putRes.text();\n517\t    expect(putBody).not.toContain(keypairA.publicKey.toBase58());\n518\t\n519\t    // GET /public-profile\n520\t    const pubRes = await app.request(`/public-profile/${username}`);\n521\t    const pubBody = await pubRes.text();\n522\t    expect(pubBody).not.toContain(keypairA.publicKey.toBase58());\n523\t  });\n524\t\n525\t  // -----------------------------------------------------------------------\n526\t  // Edge: 404 for unknown identifier\n527\t  // -----------------------------------------------------------------------\n528\t\n529\t  it(\"GET /public-profile/:identifier returns 404 for unknown\", async () => {\n530\t    const res = await app.request(\"/public-profile/nonexistent_user\");\n531\t    expect(res.status).toBe(404);\n532\t    const body = (await res.json()) as { error: string };\n533\t    expect(body.error).toBe(\"NOT_FOUND\");\n534\t  });\n535\t\n536\t  // -----------------------------------------------------------------------\n537\t  // Edge: invalid username format\n538\t  // -----------------------------------------------------------------------\n539\t\n540\t  it(\"PUT /profile/username returns 422 for invalid format\", async () => {\n541\t    const { accessToken } = await authenticateWallet(app, keypairA);\n542\t\n543\t    const res = await app.request(\"/profile/username\", {\n544\t      method: \"PUT\",\n545\t      headers: {\n546\t        Authorization: `Bearer ${accessToken}`,\n547\t        \"Content-Type\": \"application/json\",\n548\t      },\n549\t      body: JSON.stringify({ username: \"ab\" }), // too short"}]},"parent_tool_use_id":null,"session_id":"987c86d5-a6c5-46a2-ac20-b9162c4f9c5d","uuid":"828ecea6-feb9-484c-90e9-98512a2f3268","timestamp":"2026-04-22T10:06:32.497Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/profile.test.ts","content":"\n    // Wallet B tries the same name (case-insensitive)\n    const res2 = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${tokenB}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: username.toLowerCase() }),\n    });\n    expect(res2.status).toBe(409);\n    const body = (await res2.json()) as {\n      ok: false;\n      error: { code: string; message: string };\n    };\n    expect(body.ok).toBe(false);\n    expect(body.error.code).toBe(\"USERNAME_TAKEN\");\n  });\n\n  // -----------------------------------------------------------------------\n  // (6) GET /public-profile/:username returns limited public data\n  // -----------------------------------------------------------------------\n\n  it(\"GET /public-profile/:username returns public profile\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n    const username = makeUniqueUsername(\"PublicUser\");\n\n    // Set a known username\n    await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username }),\n    });\n\n    // Fetch public profile (no auth)\n    const res = await app.request(`/public-profile/${username}`);\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n\n    expect(body.userId).toMatch(/^usr_[a-z0-9]{8}$/);\n    expect(body.username).toBe(username);\n    expect(body.heatMultiplier).toBe(1);\n    expect(body.createdAt).toBeDefined();\n\n    // Public stats — limited fields only\n    const stats = body.stats as Record<string, any>;\n    expect(stats.gamesPlayed).toBe(0);\n    expect(stats.totalWins).toBe(0);\n    expect(stats.winRate).toBe(0);\n\n    // Must NOT have private fields\n    expect(body).not.toHaveProperty(\"wallet\");\n    expect(body).not.toHaveProperty(\"pointsBalance\");\n    expect(stats).not.toHaveProperty(\"totalWagered\");\n    expect(stats).not.toHaveProperty(\"netPnl\");\n    expect(stats).not.toHaveProperty(\"winStreakCurrent\");\n    expect(stats).not.toHaveProperty(\"winStreakBest\");\n  });\n\n  // -----------------------------------------------------------------------\n  // (7) GET /public-profile/:user_id returns same data\n  // -----------------------------------------------------------------------\n\n  it(\"GET /public-profile/:user_id resolves by user_id\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    // Get the userId from /profile/me\n    const meRes = await app.request(\"/profile/me\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${accessToken}` },\n    });\n    const meEnvelope = (await meRes.json()) as {\n      ok: true;\n      data: { userId: string; username: string };\n    };\n    const userId = meEnvelope.data.userId;\n\n    // Fetch via user_id (public-profile converts in a later iteration)\n    const res = await app.request(`/public-profile/${userId}`);\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as { userId: string; username: string };\n    expect(body.userId).toBe(userId);\n    expect(body.username).toBe(meEnvelope.data.username);\n\n    // No wallet\n    expect(body).not.toHaveProperty(\"wallet\");\n  });\n\n  // -----------------------------------------------------------------------\n  // (8) No wallet field in any response (additional checks)\n  // -----------------------------------------------------------------------\n\n  it(\"no wallet field in any response\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n    const username = makeUniqueUsername(\"NoWalletChk\");\n\n    // GET /profile/me\n    const meRes = await app.request(\"/profile/me\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${accessToken}` },\n    });\n    const meBody = await meRes.text();\n    expect(meBody).not.toContain(keypairA.publicKey.toBase58());\n\n    // PUT /profile/username\n    const putRes = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username }),\n    });\n    const putBody = await putRes.text();\n    expect(putBody).not.toContain(keypairA.publicKey.toBase58());\n\n    // GET /public-profile\n    const pubRes = await app.request(`/public-profile/${username}`);\n    const pubBody = await pubRes.text();\n    expect(pubBody).not.toContain(keypairA.publicKey.toBase58());\n  });\n\n  // -----------------------------------------------------------------------\n  // Edge: 404 for unknown identifier\n  // -----------------------------------------------------------------------\n\n  it(\"GET /public-profile/:identifier returns 404 for unknown\", async () => {\n    const res = await app.request(\"/public-profile/nonexistent_user\");\n    expect(res.status).toBe(404);\n    const body = (await res.json()) as { error: string };\n    expect(body.error).toBe(\"NOT_FOUND\");\n  });\n\n  // -----------------------------------------------------------------------\n  // Edge: invalid username format\n  // -----------------------------------------------------------------------\n\n  it(\"PUT /profile/username returns 422 for invalid format\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: \"ab\" }), // too short","numLines":150,"startLine":400,"totalLines":599}}}
