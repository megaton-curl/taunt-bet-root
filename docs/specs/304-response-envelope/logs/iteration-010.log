{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Dg86eDuNh15F9tELTJrmka","type":"tool_result","content":"1\t/**\n2\t * Public profile routes — unauthenticated lookup by user_id or username.\n3\t */\n4\t\n5\timport { createRoute, z } from \"@hono/zod-openapi\";\n6\timport type { Db } from \"../db.js\";\n7\timport { errorMessage } from \"../contracts/api-errors.js\";\n8\timport {\n9\t  ErrorResponseSchema,\n10\t  PublicPlayerProfileSchema,\n11\t} from \"../contracts/validators.js\";\n12\timport { logger } from \"../logger.js\";\n13\timport { createOpenApiApp } from \"../openapi/hono.js\";\n14\t\n15\texport interface PublicProfileRoutesDeps {\n16\t  db: Db;\n17\t}\n18\t\n19\texport function createPublicProfileRoutes(deps: PublicProfileRoutesDeps) {\n20\t  const { db } = deps;\n21\t  const app = createOpenApiApp();\n22\t\n23\t  // GET /:identifier — public profile lookup (no auth)\n24\t  const getPublicProfile = createRoute({\n25\t    method: \"get\",\n26\t    path: \"/{identifier}\",\n27\t    tags: [\"Profile\"],\n28\t    summary: \"Get public profile by user ID or username\",\n29\t    request: {\n30\t      params: z.object({\n31\t        identifier: z.string().openapi({ description: \"User ID (usr_xxxxxxxx) or username\" }),\n32\t      }),\n33\t    },\n34\t    responses: {\n35\t      200: {\n36\t        content: { \"application/json\": { schema: PublicPlayerProfileSchema } },\n37\t        description: \"Public profile with limited stats\",\n38\t      },\n39\t      404: {\n40\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n41\t        description: \"Profile not found\",\n42\t      },\n43\t      500: {\n44\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n45\t        description: \"Failed to fetch profile\",\n46\t      },\n47\t    },\n48\t  });\n49\t\n50\t  app.openapi(getPublicProfile, async (c) => {\n51\t    const { identifier } = c.req.valid(\"param\");\n52\t\n53\t    try {\n54\t      const profile = await db.getProfileByIdentifier(identifier);\n55\t      if (!profile) {\n56\t        return c.json(errorMessage(\"NOT_FOUND\"), 404);\n57\t      }\n58\t\n59\t      const publicStats = await db.getPublicPlayerStatsByUserId(profile.user_id);\n60\t\n61\t      return c.json(\n62\t        {\n63\t          userId: profile.user_id,\n64\t          username: profile.username,\n65\t          avatarUrl: profile.avatar_url,\n66\t          heatMultiplier: profile.heat_multiplier,\n67\t          stats: {\n68\t            gamesPlayed: publicStats.gamesPlayed,\n69\t            totalWins: publicStats.totalWins,\n70\t            winRate: publicStats.winRate,\n71\t          },\n72\t          createdAt: profile.created_at.toISOString(),\n73\t        },\n74\t        200,\n75\t      );\n76\t    } catch (err) {\n77\t      logger.error(\"public-profile lookup failed\", {\n78\t        identifier,\n79\t        error: err instanceof Error ? err.message : \"Unknown error\",\n80\t      });\n81\t      return c.json(errorMessage(\"Failed to fetch profile\"), 500);\n82\t    }\n83\t  });\n84\t\n85\t  return app;\n86\t}\n87\t"}]},"parent_tool_use_id":null,"session_id":"987c86d5-a6c5-46a2-ac20-b9162c4f9c5d","uuid":"55122144-6e96-42d6-9989-f691ff6081f2","timestamp":"2026-04-22T10:06:22.208Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/public-profile.ts","content":"/**\n * Public profile routes — unauthenticated lookup by user_id or username.\n */\n\nimport { createRoute, z } from \"@hono/zod-openapi\";\nimport type { Db } from \"../db.js\";\nimport { errorMessage } from \"../contracts/api-errors.js\";\nimport {\n  ErrorResponseSchema,\n  PublicPlayerProfileSchema,\n} from \"../contracts/validators.js\";\nimport { logger } from \"../logger.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface PublicProfileRoutesDeps {\n  db: Db;\n}\n\nexport function createPublicProfileRoutes(deps: PublicProfileRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp();\n\n  // GET /:identifier — public profile lookup (no auth)\n  const getPublicProfile = createRoute({\n    method: \"get\",\n    path: \"/{identifier}\",\n    tags: [\"Profile\"],\n    summary: \"Get public profile by user ID or username\",\n    request: {\n      params: z.object({\n        identifier: z.string().openapi({ description: \"User ID (usr_xxxxxxxx) or username\" }),\n      }),\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: PublicPlayerProfileSchema } },\n        description: \"Public profile with limited stats\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Profile not found\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to fetch profile\",\n      },\n    },\n  });\n\n  app.openapi(getPublicProfile, async (c) => {\n    const { identifier } = c.req.valid(\"param\");\n\n    try {\n      const profile = await db.getProfileByIdentifier(identifier);\n      if (!profile) {\n        return c.json(errorMessage(\"NOT_FOUND\"), 404);\n      }\n\n      const publicStats = await db.getPublicPlayerStatsByUserId(profile.user_id);\n\n      return c.json(\n        {\n          userId: profile.user_id,\n          username: profile.username,\n          avatarUrl: profile.avatar_url,\n          heatMultiplier: profile.heat_multiplier,\n          stats: {\n            gamesPlayed: publicStats.gamesPlayed,\n            totalWins: publicStats.totalWins,\n            winRate: publicStats.winRate,\n          },\n          createdAt: profile.created_at.toISOString(),\n        },\n        200,\n      );\n    } catch (err) {\n      logger.error(\"public-profile lookup failed\", {\n        identifier,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json(errorMessage(\"Failed to fetch profile\"), 500);\n    }\n  });\n\n  return app;\n}\n","numLines":87,"startLine":1,"totalLines":87}}}
