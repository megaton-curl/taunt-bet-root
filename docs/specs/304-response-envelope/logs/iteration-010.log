{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AP4NpKGEQwk7hT4P2kBN5K","type":"tool_result","content":"1\t/**\n2\t * Public referral routes — unauthenticated lookup by user_id or username.\n3\t *\n4\t * WAITLIST-CONTRACT: the waitlist calls GET /code/{code} before wallet\n5\t * connection to validate a pending referral. Shape pinned in\n6\t * `__tests__/waitlist-contract.test.ts`; keep\n7\t * `waitlist/src/lib/referral-api.ts` (checkReferralCode) in lockstep.\n8\t */\n9\t\n10\timport { createRoute, z } from \"@hono/zod-openapi\";\n11\timport type { Db } from \"../db.js\";\n12\timport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n13\timport {\n14\t  envelope,\n15\t  ErrorEnvelopeSchema,\n16\t  ok,\n17\t  err,\n18\t} from \"../contracts/api-envelope.js\";\n19\timport {\n20\t  ExistsResponseSchema,\n21\t  PublicReferralLookupResponseSchema,\n22\t  ReferralCodeSchema,\n23\t} from \"../contracts/validators.js\";\n24\timport { logger } from \"../logger.js\";\n25\timport { createOpenApiApp } from \"../openapi/hono.js\";\n26\t\n27\texport interface PublicReferralRoutesDeps {\n28\t  db: Db;\n29\t}\n30\t\n31\texport function createPublicReferralRoutes(deps: PublicReferralRoutesDeps) {\n32\t  const { db } = deps;\n33\t  const app = createOpenApiApp();\n34\t\n35\t  /**\n36\t   * Check whether a referral code exists.\n37\t   * Used by the waitlist before wallet connection.\n38\t   */\n39\t  const checkCodeRoute = createRoute({\n40\t    method: \"get\",\n41\t    path: \"/code/{code}\",\n42\t    tags: [\"Referral\"],\n43\t    summary: \"Check whether a referral code exists\",\n44\t    request: {\n45\t      params: z.object({\n46\t        code: z.string().openapi({ description: \"Referral code to check\" }),\n47\t      }),\n48\t    },\n49\t    responses: {\n50\t      200: {\n51\t        content: { \"application/json\": { schema: envelope(ExistsResponseSchema) } },\n52\t        description: \"Referral code existence\",\n53\t      },\n54\t      500: {\n55\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n56\t        description: \"Failed to check referral code\",\n57\t      },\n58\t    },\n59\t  });\n60\t\n61\t  app.openapi(checkCodeRoute, async (c) => {\n62\t    const { code: rawCode } = c.req.valid(\"param\");\n63\t    const parsedCode = ReferralCodeSchema.safeParse(rawCode);\n64\t    if (!parsedCode.success) {\n65\t      return ok(c, { exists: false });\n66\t    }\n67\t    const code = parsedCode.data;\n68\t\n69\t    try {\n70\t      const row = await db.getReferralCodeByCode(code);\n71\t      return ok(c, { exists: !!row });\n72\t    } catch (lookupError) {\n73\t      logger.error(\"public-referral code check failed\", {\n74\t        code,\n75\t        error: lookupError instanceof Error ? lookupError.message : \"Unknown error\",\n76\t      });\n77\t      return err(\n78\t        c,\n79\t        500,\n80\t        API_ERROR_CODES.PRECONDITION_FAILED,\n81\t        \"Failed to check referral code\",\n82\t      );\n83\t    }\n84\t  });\n85\t\n86\t  const lookupRoute = createRoute({\n87\t    method: \"get\",\n88\t    path: \"/{identifier}\",\n89\t    tags: [\"Referral\"],\n90\t    summary: \"Get public referral info by user ID or username\",\n91\t    request: {\n92\t      params: z.object({\n93\t        identifier: z.string().openapi({ description: \"User ID (usr_xxxxxxxx) or username\" }),\n94\t      }),\n95\t    },\n96\t    responses: {\n97\t      200: {\n98\t        content: { \"application/json\": { schema: envelope(PublicReferralLookupResponseSchema) } },\n99\t        description: \"Public referral lookup result\",\n100\t      },\n101\t      404: {\n102\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n103\t        description: \"Profile not found\",\n104\t      },\n105\t      500: {\n106\t        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n107\t        description: \"Failed to fetch referral\",\n108\t      },\n109\t    },\n110\t  });\n111\t\n112\t  app.openapi(lookupRoute, async (c) => {\n113\t    const { identifier } = c.req.valid(\"param\");\n114\t\n115\t    try {\n116\t      const profile = await db.getProfileByIdentifier(identifier);\n117\t      if (!profile) {\n118\t        return err(c, 404, API_ERROR_CODES.NOT_FOUND, \"Profile not found\");\n119\t      }\n120\t\n121\t      const referralCode = await db.getReferralCodeByUserId(profile.user_id);\n122\t      return ok(c, {\n123\t        userId: profile.user_id,\n124\t        username: profile.username,\n125\t        referralCode: referralCode?.code ?? null,\n126\t      });\n127\t    } catch (lookupError) {\n128\t      logger.error(\"public-referral lookup failed\", {\n129\t        identifier,\n130\t        error: lookupError instanceof Error ? lookupError.message : \"Unknown error\",\n131\t      });\n132\t      return err(\n133\t        c,\n134\t        500,\n135\t        API_ERROR_CODES.PRECONDITION_FAILED,\n136\t        \"Failed to fetch referral\",\n137\t      );\n138\t    }\n139\t  });\n140\t\n141\t  return app;\n142\t}\n143\t"}]},"parent_tool_use_id":null,"session_id":"987c86d5-a6c5-46a2-ac20-b9162c4f9c5d","uuid":"87729e18-4dc3-452d-9d1b-f7e28b8d1462","timestamp":"2026-04-22T10:06:40.247Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/public-referral.ts","content":"/**\n * Public referral routes — unauthenticated lookup by user_id or username.\n *\n * WAITLIST-CONTRACT: the waitlist calls GET /code/{code} before wallet\n * connection to validate a pending referral. Shape pinned in\n * `__tests__/waitlist-contract.test.ts`; keep\n * `waitlist/src/lib/referral-api.ts` (checkReferralCode) in lockstep.\n */\n\nimport { createRoute, z } from \"@hono/zod-openapi\";\nimport type { Db } from \"../db.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport {\n  ExistsResponseSchema,\n  PublicReferralLookupResponseSchema,\n  ReferralCodeSchema,\n} from \"../contracts/validators.js\";\nimport { logger } from \"../logger.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface PublicReferralRoutesDeps {\n  db: Db;\n}\n\nexport function createPublicReferralRoutes(deps: PublicReferralRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp();\n\n  /**\n   * Check whether a referral code exists.\n   * Used by the waitlist before wallet connection.\n   */\n  const checkCodeRoute = createRoute({\n    method: \"get\",\n    path: \"/code/{code}\",\n    tags: [\"Referral\"],\n    summary: \"Check whether a referral code exists\",\n    request: {\n      params: z.object({\n        code: z.string().openapi({ description: \"Referral code to check\" }),\n      }),\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: envelope(ExistsResponseSchema) } },\n        description: \"Referral code existence\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to check referral code\",\n      },\n    },\n  });\n\n  app.openapi(checkCodeRoute, async (c) => {\n    const { code: rawCode } = c.req.valid(\"param\");\n    const parsedCode = ReferralCodeSchema.safeParse(rawCode);\n    if (!parsedCode.success) {\n      return ok(c, { exists: false });\n    }\n    const code = parsedCode.data;\n\n    try {\n      const row = await db.getReferralCodeByCode(code);\n      return ok(c, { exists: !!row });\n    } catch (lookupError) {\n      logger.error(\"public-referral code check failed\", {\n        code,\n        error: lookupError instanceof Error ? lookupError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to check referral code\",\n      );\n    }\n  });\n\n  const lookupRoute = createRoute({\n    method: \"get\",\n    path: \"/{identifier}\",\n    tags: [\"Referral\"],\n    summary: \"Get public referral info by user ID or username\",\n    request: {\n      params: z.object({\n        identifier: z.string().openapi({ description: \"User ID (usr_xxxxxxxx) or username\" }),\n      }),\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: envelope(PublicReferralLookupResponseSchema) } },\n        description: \"Public referral lookup result\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Profile not found\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch referral\",\n      },\n    },\n  });\n\n  app.openapi(lookupRoute, async (c) => {\n    const { identifier } = c.req.valid(\"param\");\n\n    try {\n      const profile = await db.getProfileByIdentifier(identifier);\n      if (!profile) {\n        return err(c, 404, API_ERROR_CODES.NOT_FOUND, \"Profile not found\");\n      }\n\n      const referralCode = await db.getReferralCodeByUserId(profile.user_id);\n      return ok(c, {\n        userId: profile.user_id,\n        username: profile.username,\n        referralCode: referralCode?.code ?? null,\n      });\n    } catch (lookupError) {\n      logger.error(\"public-referral lookup failed\", {\n        identifier,\n        error: lookupError instanceof Error ? lookupError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch referral\",\n      );\n    }\n  });\n\n  return app;\n}\n","numLines":143,"startLine":1,"totalLines":143}}}
