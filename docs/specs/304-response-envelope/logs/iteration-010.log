  content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch profile\",\n      },\n    },\n  });\n\n  app.openapi(getPublicProfile, async (c) => {\n    const { identifier } = c.req.valid(\"param\");\n\n    try {\n      const profile = await db.getProfileByIdentifier(identifier);\n      if (!profile) {\n        return err(c, 404, API_ERROR_CODES.NOT_FOUND, \"Profile not found\");\n      }\n\n      const publicStats = await db.getPublicPlayerStatsByUserId(profile.user_id);\n\n      return ok(c, {\n        userId: profile.user_id,\n        username: profile.username,\n        avatarUrl: profile.avatar_url,\n        heatMultiplier: profile.heat_multiplier,\n        stats: {\n          gamesPlayed: publicStats.gamesPlayed,\n          totalWins: publicStats.totalWins,\n          winRate: publicStats.winRate,\n        },\n        createdAt: profile.created_at.toISOString(),\n      });\n    } catch (lookupError) {\n      logger.error(\"public-profile lookup failed\", {\n        identifier,\n        error: lookupError instanceof Error ? lookupError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch profile\",\n      );\n    }\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":4,"oldLines":11,"newStart":4,"newLines":14,"lines":[" "," import { createRoute, z } from \"@hono/zod-openapi\";"," import type { Db } from \"../db.js\";","-import { errorMessage } from \"../contracts/api-errors.js\";","+import { API_ERROR_CODES } from \"../contracts/api-errors.js\";"," import {","-  ErrorResponseSchema,","-  PublicPlayerProfileSchema,","-} from \"../contracts/validators.js\";","+  envelope,","+  ErrorEnvelopeSchema,","+  ok,","+  err,","+} from \"../contracts/api-envelope.js\";","+import { PublicPlayerProfileSchema } from \"../contracts/validators.js\";"," import { logger } from \"../logger.js\";"," import { createOpenApiAp