{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01HPoDZ8k51Pb2EwiWcwRoxZ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01YQNdWM6BCjjuRCHaynhZNU","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/src/routes/public-profile.ts","content":"/**\n * Public profile routes — unauthenticated lookup by user_id or username.\n */\n\nimport { createRoute, z } from \"@hono/zod-openapi\";\nimport type { Db } from \"../db.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport { PublicPlayerProfileSchema } from \"../contracts/validators.js\";\nimport { logger } from \"../logger.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface PublicProfileRoutesDeps {\n  db: Db;\n}\n\nexport function createPublicProfileRoutes(deps: PublicProfileRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp();\n\n  // GET /:identifier — public profile lookup (no auth)\n  const getPublicProfile = createRoute({\n    method: \"get\",\n    path: \"/{identifier}\",\n    tags: [\"Profile\"],\n    summary: \"Get public profile by user ID or username\",\n    request: {\n      params: z.object({\n        identifier: z.string().openapi({ description: \"User ID (usr_xxxxxxxx) or username\" }),\n      }),\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: envelope(PublicPlayerProfileSchema) } },\n        description: \"Public profile with limited stats\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Profile not found\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch profile\",\n      },\n    },\n  });\n\n  app.openapi(getPublicProfile, async (c) => {\n    const { identifier } = c.req.valid(\"param\");\n\n    try {\n      const profile = await db.getProfileByIdentifier(identifier);\n      if (!profile) {\n        return err(c, 404, API_ERROR_CODES.NOT_FOUND, \"Profile not found\");\n      }\n\n      const publicStats = await db.getPublicPlayerStatsByUserId(profile.user_id);\n\n      return ok(c, {\n        userId: profile.user_id,\n        username: profile.username,\n        avatarUrl: profile.avatar_url,\n        heatMultiplier: profile.heat_multiplier,\n        stats: {\n          gamesPlayed: publicStats.gamesPlayed,\n          totalWins: publicStats.totalWins,\n          winRate: publicStats.winRate,\n        },\n        createdAt: profile.created_at.toISOString(),\n      });\n    } catch (lookupError) {\n      logger.error(\"public-profile lookup failed\", {\n        identifier,\n        error: lookupError instanceof Error ? lookupError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch profile\",\n      );\n    }\n  });\n\n  return app;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2030,"cache_read_input_tokens":73659,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2030},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"987c86d5-a6c5-46a2-ac20-b9162c4f9c5d","uuid":"a11418e9-f8d8-479d-a5b4-6ddb91986872"}
