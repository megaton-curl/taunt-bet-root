{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UK15WBvjYdrK12ib4RqSS8","type":"tool_result","content":"1\timport { describe, it, expect } from \"vitest\";\n2\timport { Hono } from \"hono\";\n3\timport { SignJWT } from \"jose\";\n4\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n5\timport type { AppEnv } from \"../hono-env.js\";\n6\t\n7\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-key-for-jwt-auth-tests\");\n8\t\n9\tfunction createTestApp() {\n10\t  const app = new Hono<AppEnv>();\n11\t  app.use(\"/*\", createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }));\n12\t  app.post(\"/test\", (c) =>\n13\t    c.json({ ok: true, userId: c.get(\"userId\") }),\n14\t  );\n15\t  app.get(\"/test\", (c) => c.json({ ok: true }));\n16\t  return app;\n17\t}\n18\t\n19\tasync function makeJwt(\n20\t  userId: string,\n21\t  opts?: { expiresIn?: number; secret?: Uint8Array },\n22\t) {\n23\t  const secret = opts?.secret ?? JWT_SECRET;\n24\t  const now = Math.floor(Date.now() / 1000);\n25\t  return new SignJWT({})\n26\t    .setSubject(userId)\n27\t    .setProtectedHeader({ alg: \"HS256\" })\n28\t    .setIssuedAt(now)\n29\t    .setExpirationTime(now + (opts?.expiresIn ?? 3600))\n30\t    .sign(secret);\n31\t}\n32\t\n33\tfunction post(token?: string) {\n34\t  const headers: Record<string, string> = { \"Content-Type\": \"application/json\" };\n35\t  if (token) {\n36\t    headers[\"Authorization\"] = `Bearer ${token}`;\n37\t  }\n38\t  return {\n39\t    method: \"POST\" as const,\n40\t    headers,\n41\t    body: JSON.stringify({ data: \"test\" }),\n42\t  };\n43\t}\n44\t\n45\tdescribe(\"JWT auth middleware\", () => {\n46\t  it(\"accepts a valid JWT\", async () => {\n47\t    const app = createTestApp();\n48\t    const token = await makeJwt(\"usr_test1234\");\n49\t    const res = await app.request(\"/test\", post(token));\n50\t    expect(res.status).toBe(200);\n51\t    const json = (await res.json()) as { ok: boolean; userId: string };\n52\t    expect(json.ok).toBe(true);\n53\t    expect(json.userId).toBe(\"usr_test1234\");\n54\t  });\n55\t\n56\t  it(\"rejects missing Authorization header\", async () => {\n57\t    const app = createTestApp();\n58\t    const res = await app.request(\"/test\", post());\n59\t    expect(res.status).toBe(401);\n60\t  });\n61\t\n62\t  it(\"rejects malformed Authorization header\", async () => {\n63\t    const app = createTestApp();\n64\t    const res = await app.request(\"/test\", {\n65\t      method: \"POST\",\n66\t      headers: {\n67\t        \"Content-Type\": \"application/json\",\n68\t        \"Authorization\": \"Basic abc123\",\n69\t      },\n70\t      body: JSON.stringify({}),\n71\t    });\n72\t    expect(res.status).toBe(401);\n73\t  });\n74\t\n75\t  it(\"rejects an expired JWT\", async () => {\n76\t    const app = createTestApp();\n77\t    const token = await makeJwt(\"usr_test1234\", { expiresIn: -10 });\n78\t    const res = await app.request(\"/test\", post(token));\n79\t    expect(res.status).toBe(401);\n80\t  });\n81\t\n82\t  it(\"rejects a JWT signed with wrong secret\", async () => {\n83\t    const app = createTestApp();\n84\t    const wrongSecret = new TextEncoder().encode(\"wrong-secret-key\");\n85\t    const token = await makeJwt(\"usr_test1234\", { secret: wrongSecret });\n86\t    const res = await app.request(\"/test\", post(token));\n87\t    expect(res.status).toBe(401);\n88\t  });\n89\t\n90\t  it(\"passes GET requests without authentication\", async () => {\n91\t    const app = createTestApp();\n92\t    const res = await app.request(\"/test\", { method: \"GET\" });\n93\t    expect(res.status).toBe(200);\n94\t  });\n95\t\n96\t  it(\"sets userId from JWT sub claim (no wallet in JWT)\", async () => {\n97\t    const app = createTestApp();\n98\t    const userId = \"usr_test1234\";\n99\t    const token = await makeJwt(userId);\n100\t    const res = await app.request(\"/test\", post(token));\n101\t    expect(res.status).toBe(200);\n102\t    const json = (await res.json()) as { userId: string };\n103\t    expect(json.userId).toBe(userId);\n104\t  });\n105\t});\n106\t"}]},"parent_tool_use_id":null,"session_id":"1929aeea-d286-4cb9-ab7d-a3d475dae282","uuid":"e0196a3c-2663-4cbb-853a-865e80d12b3a","timestamp":"2026-04-22T09:26:19.921Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/auth.test.ts","content":"import { describe, it, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { SignJWT } from \"jose\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport type { AppEnv } from \"../hono-env.js\";\n\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-key-for-jwt-auth-tests\");\n\nfunction createTestApp() {\n  const app = new Hono<AppEnv>();\n  app.use(\"/*\", createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }));\n  app.post(\"/test\", (c) =>\n    c.json({ ok: true, userId: c.get(\"userId\") }),\n  );\n  app.get(\"/test\", (c) => c.json({ ok: true }));\n  return app;\n}\n\nasync function makeJwt(\n  userId: string,\n  opts?: { expiresIn?: number; secret?: Uint8Array },\n) {\n  const secret = opts?.secret ?? JWT_SECRET;\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({})\n    .setSubject(userId)\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setIssuedAt(now)\n    .setExpirationTime(now + (opts?.expiresIn ?? 3600))\n    .sign(secret);\n}\n\nfunction post(token?: string) {\n  const headers: Record<string, string> = { \"Content-Type\": \"application/json\" };\n  if (token) {\n    headers[\"Authorization\"] = `Bearer ${token}`;\n  }\n  return {\n    method: \"POST\" as const,\n    headers,\n    body: JSON.stringify({ data: \"test\" }),\n  };\n}\n\ndescribe(\"JWT auth middleware\", () => {\n  it(\"accepts a valid JWT\", async () => {\n    const app = createTestApp();\n    const token = await makeJwt(\"usr_test1234\");\n    const res = await app.request(\"/test\", post(token));\n    expect(res.status).toBe(200);\n    const json = (await res.json()) as { ok: boolean; userId: string };\n    expect(json.ok).toBe(true);\n    expect(json.userId).toBe(\"usr_test1234\");\n  });\n\n  it(\"rejects missing Authorization header\", async () => {\n    const app = createTestApp();\n    const res = await app.request(\"/test\", post());\n    expect(res.status).toBe(401);\n  });\n\n  it(\"rejects malformed Authorization header\", async () => {\n    const app = createTestApp();\n    const res = await app.request(\"/test\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": \"Basic abc123\",\n      },\n      body: JSON.stringify({}),\n    });\n    expect(res.status).toBe(401);\n  });\n\n  it(\"rejects an expired JWT\", async () => {\n    const app = createTestApp();\n    const token = await makeJwt(\"usr_test1234\", { expiresIn: -10 });\n    const res = await app.request(\"/test\", post(token));\n    expect(res.status).toBe(401);\n  });\n\n  it(\"rejects a JWT signed with wrong secret\", async () => {\n    const app = createTestApp();\n    const wrongSecret = new TextEncoder().encode(\"wrong-secret-key\");\n    const token = await makeJwt(\"usr_test1234\", { secret: wrongSecret });\n    const res = await app.request(\"/test\", post(token));\n    expect(res.status).toBe(401);\n  });\n\n  it(\"passes GET requests without authentication\", async () => {\n    const app = createTestApp();\n    const res = await app.request(\"/test\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n  });\n\n  it(\"sets userId from JWT sub claim (no wallet in JWT)\", async () => {\n    const app = createTestApp();\n    const userId = \"usr_test1234\";\n    const token = await makeJwt(userId);\n    const res = await app.request(\"/test\", post(token));\n    expect(res.status).toBe(200);\n    const json = (await res.json()) as { userId: string };\n    expect(json.userId).toBe(userId);\n  });\n});\n","numLines":106,"startLine":1,"totalLines":106}}}
