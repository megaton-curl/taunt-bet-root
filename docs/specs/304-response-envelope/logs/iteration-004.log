{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VKeNaDntkhWyBxzkBmnfXT","type":"tool_result","content":"1\t/**\n2\t * JWT Bearer token authentication middleware.\n3\t *\n4\t * Verifies HS256 JWT access tokens on POST requests.\n5\t * Sets c.set(\"userId\", payload.sub) for downstream handlers.\n6\t * Wallet is NOT in the JWT — routes that need wallet resolve it from the profile.\n7\t * GET requests pass through without authentication.\n8\t */\n9\t\n10\timport { createMiddleware } from \"hono/factory\";\n11\timport { jwtVerify } from \"jose\";\n12\timport { logger } from \"../logger.js\";\n13\timport type { AppEnv } from \"../hono-env.js\";\n14\t\n15\texport interface JwtAuthConfig {\n16\t  jwtSecret: Uint8Array;\n17\t  /** When true, require JWT for all HTTP methods (not just POST). Default: false */\n18\t  requireAllMethods?: boolean;\n19\t}\n20\t\n21\texport function createJwtAuthMiddleware(config: JwtAuthConfig) {\n22\t  return createMiddleware<AppEnv>(async (c, next) => {\n23\t    // Skip authentication for non-POST requests (GET, OPTIONS, etc.)\n24\t    // unless requireAllMethods is set (e.g., profile endpoints)\n25\t    if (!config.requireAllMethods && c.req.method !== \"POST\") {\n26\t      return next();\n27\t    }\n28\t\n29\t    const authHeader = c.req.header(\"Authorization\");\n30\t    if (!authHeader || !authHeader.startsWith(\"Bearer \")) {\n31\t      logger.warn(\"jwt auth rejected: missing or invalid Authorization header\", {\n32\t        path: c.req.path,\n33\t      });\n34\t      return c.json({ error: \"Missing or invalid Authorization header\" }, 401);\n35\t    }\n36\t\n37\t    const token = authHeader.slice(7);\n38\t    try {\n39\t      const { payload } = await jwtVerify(token, config.jwtSecret, {\n40\t        algorithms: [\"HS256\"],\n41\t      });\n42\t\n43\t      if (typeof payload.sub !== \"string\") {\n44\t        logger.warn(\"jwt auth rejected: missing sub claim\", {\n45\t          path: c.req.path,\n46\t        });\n47\t        return c.json({ error: \"Invalid token: missing subject\" }, 401);\n48\t      }\n49\t\n50\t      c.set(\"userId\", payload.sub);\n51\t      return next();\n52\t    } catch (err) {\n53\t      logger.warn(\"jwt auth rejected: token verification failed\", {\n54\t        path: c.req.path,\n55\t        error: err instanceof Error ? err.message : \"Unknown error\",\n56\t      });\n57\t      return c.json({ error: \"Invalid or expired token\" }, 401);\n58\t    }\n59\t  });\n60\t}\n61\t"}]},"parent_tool_use_id":null,"session_id":"1929aeea-d286-4cb9-ab7d-a3d475dae282","uuid":"2b2da663-7465-4c3f-bb8a-7e2f425ba3b6","timestamp":"2026-04-22T09:26:16.556Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/middleware/jwt-auth.ts","content":"/**\n * JWT Bearer token authentication middleware.\n *\n * Verifies HS256 JWT access tokens on POST requests.\n * Sets c.set(\"userId\", payload.sub) for downstream handlers.\n * Wallet is NOT in the JWT — routes that need wallet resolve it from the profile.\n * GET requests pass through without authentication.\n */\n\nimport { createMiddleware } from \"hono/factory\";\nimport { jwtVerify } from \"jose\";\nimport { logger } from \"../logger.js\";\nimport type { AppEnv } from \"../hono-env.js\";\n\nexport interface JwtAuthConfig {\n  jwtSecret: Uint8Array;\n  /** When true, require JWT for all HTTP methods (not just POST). Default: false */\n  requireAllMethods?: boolean;\n}\n\nexport function createJwtAuthMiddleware(config: JwtAuthConfig) {\n  return createMiddleware<AppEnv>(async (c, next) => {\n    // Skip authentication for non-POST requests (GET, OPTIONS, etc.)\n    // unless requireAllMethods is set (e.g., profile endpoints)\n    if (!config.requireAllMethods && c.req.method !== \"POST\") {\n      return next();\n    }\n\n    const authHeader = c.req.header(\"Authorization\");\n    if (!authHeader || !authHeader.startsWith(\"Bearer \")) {\n      logger.warn(\"jwt auth rejected: missing or invalid Authorization header\", {\n        path: c.req.path,\n      });\n      return c.json({ error: \"Missing or invalid Authorization header\" }, 401);\n    }\n\n    const token = authHeader.slice(7);\n    try {\n      const { payload } = await jwtVerify(token, config.jwtSecret, {\n        algorithms: [\"HS256\"],\n      });\n\n      if (typeof payload.sub !== \"string\") {\n        logger.warn(\"jwt auth rejected: missing sub claim\", {\n          path: c.req.path,\n        });\n        return c.json({ error: \"Invalid token: missing subject\" }, 401);\n      }\n\n      c.set(\"userId\", payload.sub);\n      return next();\n    } catch (err) {\n      logger.warn(\"jwt auth rejected: token verification failed\", {\n        path: c.req.path,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Invalid or expired token\" }, 401);\n    }\n  });\n}\n","numLines":61,"startLine":1,"totalLines":61}}}
