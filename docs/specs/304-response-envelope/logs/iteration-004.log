{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B6TgtkHiRK7WfUPmWAwAcG","type":"tool_result","content":"1\t/**\n2\t * Auth routes tests: challenge → verify → refresh → logout flows.\n3\t */\n4\t\n5\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n6\timport { Hono } from \"hono\";\n7\timport { Keypair } from \"@solana/web3.js\";\n8\timport nacl from \"tweetnacl\";\n9\timport bs58 from \"bs58\";\n10\timport { jwtVerify } from \"jose\";\n11\timport postgres from \"postgres\";\n12\timport { createAuthDb, type AuthDb } from \"../auth-db.js\";\n13\timport { createAuthRoutes } from \"../routes/auth.js\";\n14\timport type { Db } from \"../db.js\";\n15\t\n16\t// ---------------------------------------------------------------------------\n17\t// Constants\n18\t// ---------------------------------------------------------------------------\n19\t\n20\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n21\tfunction makeSql() {\n22\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n23\t  return postgres({\n24\t    host: \"/var/run/postgresql\",\n25\t    user: \"vscode\",\n26\t    database: \"taunt_bet_dev\",\n27\t  });\n28\t}\n29\t\n30\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-auth-route-tests\");\n31\t\n32\t// ---------------------------------------------------------------------------\n33\t// Test suite\n34\t// ---------------------------------------------------------------------------\n35\t\n36\tdescribe(\"Auth routes: challenge → verify → refresh → logout\", () => {\n37\t  let rawSql: ReturnType<typeof postgres>;\n38\t  let authDb: AuthDb;\n39\t  let app: Hono;\n40\t  const profiles = new Map<string, { user_id: string; wallet: string }>();\n41\t  const stubDb = {\n42\t    getProfileByWallet: async (wallet: string) => {\n43\t      const existing = profiles.get(wallet);\n44\t      return existing\n45\t        ? { ...existing, username: \"test-user\", username_updated_at: null, avatar_url: null, heat_multiplier: 1, points_balance: 0, created_at: new Date(), id: 1 }\n46\t        : null;\n47\t    },\n48\t    createPlayerProfile: async (wallet: string) => {\n49\t      const created = { user_id: \"usr_test1234\", wallet };\n50\t      profiles.set(wallet, created);\n51\t      return {\n52\t        ...created,\n53\t        username: \"test-user\",\n54\t        username_updated_at: null,\n55\t        avatar_url: null,\n56\t        heat_multiplier: 1,\n57\t        points_balance: 0,\n58\t        created_at: new Date(),\n59\t        id: 1,\n60\t      };\n61\t    },\n62\t  } as unknown as Db;\n63\t\n64\t  const creatorKeypair = Keypair.generate();\n65\t\n66\t  beforeAll(async () => {\n67\t    rawSql = makeSql();\n68\t    // Ensure auth tables exist\n69\t    await rawSql`DROP TABLE IF EXISTS auth_challenges, refresh_tokens`;\n70\t    await rawSql`\n71\t      CREATE TABLE IF NOT EXISTS auth_challenges (\n72\t        nonce TEXT PRIMARY KEY,\n73\t        wallet TEXT NOT NULL,\n74\t        cluster TEXT NOT NULL DEFAULT 'devnet',\n75\t        message TEXT NOT NULL,\n76\t        expires_at TIMESTAMPTZ NOT NULL,\n77\t        used BOOLEAN DEFAULT FALSE,\n78\t        created_at TIMESTAMPTZ DEFAULT now()\n79\t      )\n80\t    `;\n81\t    await rawSql`\n82\t      CREATE TABLE IF NOT EXISTS refresh_tokens (\n83\t        id BIGSERIAL PRIMARY KEY,\n84\t        user_id TEXT NOT NULL,\n85\t        wallet TEXT NOT NULL,\n86\t        token_hash BYTEA NOT NULL UNIQUE,\n87\t        family_id TEXT NOT NULL,\n88\t        expires_at TIMESTAMPTZ NOT NULL,\n89\t        revoked BOOLEAN DEFAULT FALSE,\n90\t        created_at TIMESTAMPTZ DEFAULT now()\n91\t      )\n92\t    `;\n93\t  });\n94\t\n95\t  afterAll(async () => {\n96\t    await rawSql.end();\n97\t  });\n98\t\n99\t  beforeEach(async () => {\n100\t    await rawSql`TRUNCATE auth_challenges, refresh_tokens RESTART IDENTITY`;\n101\t    profiles.clear();\n102\t    authDb = createAuthDb(rawSql);\n103\t    app = new Hono();\n104\t    app.route(\n105\t      \"/auth\",\n106\t      createAuthRoutes({\n107\t        authDb,\n108\t        db: stubDb,\n109\t        jwtSecret: JWT_SECRET,\n110\t        cluster: \"devnet\",\n111\t        challengeTtlSeconds: 300,\n112\t        accessTokenTtlSeconds: 3600,\n113\t        refreshTokenTtlDays: 14,\n114\t      }),\n115\t    );\n116\t  });\n117\t\n118\t  // -----------------------------------------------------------------------\n119\t  // POST /auth/challenge\n120\t  // -----------------------------------------------------------------------\n121\t\n122\t  it(\"returns a challenge with nonce and message\", async () => {\n123\t    const wallet = creatorKeypair.publicKey.toBase58();\n124\t    const res = await app.request(\"/auth/challenge\", {\n125\t      method: \"POST\",\n126\t      headers: { \"Content-Type\": \"application/json\" },\n127\t      body: JSON.stringify({ wallet }),\n128\t    });\n129\t\n130\t    expect(res.status).toBe(200);\n131\t    const json = (await res.json()) as { nonce: string; message: string; expiresAt: string };\n132\t    expect(json.nonce).toBeDefined();\n133\t    expect(json.nonce.length).toBe(64); // 32 bytes hex\n134\t    expect(json.message).toContain(\"Sign this message to create your Taunt BET account.\");\n135\t    expect(json.message).toContain(wallet);\n136\t    expect(json.message).toContain(\"Solana Devnet\");\n137\t    expect(json.expiresAt).toBeDefined();\n138\t  });\n139\t\n140\t  it(\"rejects challenge with missing wallet\", async () => {\n141\t    const res = await app.request(\"/auth/challenge\", {\n142\t      method: \"POST\",\n143\t      headers: { \"Content-Type\": \"application/json\" },\n144\t      body: JSON.stringify({}),\n145\t    });\n146\t    expect(res.status).toBe(422);\n147\t  });\n148\t\n149\t  it(\"rejects challenge with missing body\", async () => {\n150\t    const res = await app.request(\"/auth/challenge\", {\n151\t      method: \"POST\",\n152\t    });\n153\t\n154\t    expect(res.status).toBe(422);\n155\t    const body = (await res.json()) as {\n156\t      ok: false;\n157\t      error: { code: string; message: string };\n158\t    };\n159\t    expect(body.ok).toBe(false);\n160\t    expect(body.error.code).toBe(\"VALIDATION_FAILED\");\n161\t    expect(body.error.message).toBe(\"Invalid request\");\n162\t  });\n163\t\n164\t  // -----------------------------------------------------------------------\n165\t  // Full flow: challenge → verify → refresh → logout\n166\t  // -----------------------------------------------------------------------\n167\t\n168\t  it(\"full auth flow: challenge → verify → refresh → logout\", async () => {\n169\t    const wallet = creatorKeypair.publicKey.toBase58();\n170\t\n171\t    // 1. Request challenge\n172\t    const challengeRes = await app.request(\"/auth/challenge\", {\n173\t      method: \"POST\",\n174\t      headers: { \"Content-Type\": \"application/json\" },\n175\t      body: JSON.stringify({ wallet }),\n176\t    });\n177\t    expect(challengeRes.status).toBe(200);\n178\t    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n179\t\n180\t    // 2. Sign the message\n181\t    const messageBytes = new TextEncoder().encode(challenge.message);\n182\t    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n183\t    const signature = bs58.encode(signatureBytes);\n184\t\n185\t    // 3. Verify\n186\t    const verifyRes = await app.request(\"/auth/verify\", {\n187\t      method: \"POST\",\n188\t      headers: { \"Content-Type\": \"application/json\" },\n189\t      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n190\t    });\n191\t    expect(verifyRes.status).toBe(200);\n192\t    const tokens = (await verifyRes.json()) as {\n193\t      accessToken: string;\n194\t      accessExpiresAt: string;\n195\t      refreshToken: string;\n196\t      refreshExpiresAt: string;\n197\t    };\n198\t    expect(tokens.accessToken).toBeDefined();\n199\t    expect(tokens.refreshToken).toBeDefined();\n200\t    expect(tokens.accessExpiresAt).toBeDefined();\n201\t    expect(tokens.refreshExpiresAt).toBeDefined();\n202\t\n203\t    // Verify JWT is valid and contains the correct user identity\n204\t    const { payload } = await jwtVerify(tokens.accessToken, JWT_SECRET, {\n205\t      algorithms: [\"HS256\"],\n206\t    });\n207\t    expect(payload.sub).toBe(\"usr_test1234\");\n208\t\n209\t    // 4. Refresh\n210\t    const refreshRes = await app.request(\"/auth/refresh\", {\n211\t      method: \"POST\",\n212\t      headers: { \"Content-Type\": \"application/json\" },\n213\t      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n214\t    });\n215\t    expect(refreshRes.status).toBe(200);\n216\t    const newTokens = (await refreshRes.json()) as {\n217\t      accessToken: string;\n218\t      refreshToken: string;\n219\t    };\n220\t    expect(newTokens.accessToken).toBeDefined();\n221\t    expect(newTokens.refreshToken).toBeDefined();\n222\t    // New refresh token should be different from the old one\n223\t    expect(newTokens.refreshToken).not.toBe(tokens.refreshToken);\n224\t\n225\t    // 5. Old refresh token should no longer work (it was rotated)\n226\t    const replayRes = await app.request(\"/auth/refresh\", {\n227\t      method: \"POST\",\n228\t      headers: { \"Content-Type\": \"application/json\" },\n229\t      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n230\t    });\n231\t    expect(replayRes.status).toBe(401);\n232\t    const replayJson = (await replayRes.json()) as { error: string };\n233\t    expect(replayJson.error).toContain(\"reuse\");\n234\t\n235\t    // 6. Logout with new token\n236\t    const logoutRes = await app.request(\"/auth/logout\", {\n237\t      method: \"POST\",\n238\t      headers: { \"Content-Type\": \"application/json\" },\n239\t      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n240\t    });\n241\t    expect(logoutRes.status).toBe(204);\n242\t\n243\t    // 7. Refresh after logout should fail\n244\t    const postLogoutRefresh = await app.request(\"/auth/refresh\", {\n245\t      method: \"POST\",\n246\t      headers: { \"Content-Type\": \"application/json\" },\n247\t      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n248\t    });\n249\t    expect(postLogoutRefresh.status).toBe(401);\n250\t  });\n251\t\n252\t  // -----------------------------------------------------------------------\n253\t  // Edge cases\n254\t  // -----------------------------------------------------------------------\n255\t\n256\t  it(\"rejects verify with wrong wallet\", async () => {\n257\t    const wallet = creatorKeypair.publicKey.toBase58();\n258\t    const otherKeypair = Keypair.generate();\n259\t\n260\t    // Get challenge for the correct wallet\n261\t    const challengeRes = await app.request(\"/auth/challenge\", {\n262\t      method: \"POST\",\n263\t      headers: { \"Content-Type\": \"application/json\" },\n264\t      body: JSON.stringify({ wallet }),\n265\t    });\n266\t    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n267\t\n268\t    // Sign with the correct keypair\n269\t    const messageBytes = new TextEncoder().encode(challenge.message);\n270\t    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n271\t    const signature = bs58.encode(signatureBytes);\n272\t\n273\t    // But claim to be a different wallet\n274\t    const verifyRes = await app.request(\"/auth/verify\", {\n275\t      method: \"POST\",\n276\t      headers: { \"Content-Type\": \"application/json\" },\n277\t      body: JSON.stringify({\n278\t        nonce: challenge.nonce,\n279\t        wallet: otherKeypair.publicKey.toBase58(),\n280\t        signature,\n281\t      }),\n282\t    });\n283\t    expect(verifyRes.status).toBe(401);\n284\t  });\n285\t\n286\t  it(\"rejects verify with wrong signature\", async () => {\n287\t    const wallet = creatorKeypair.publicKey.toBase58();\n288\t    const otherKeypair = Keypair.generate();\n289\t\n290\t    const challengeRes = await app.request(\"/auth/challenge\", {\n291\t      method: \"POST\",\n292\t      headers: { \"Content-Type\": \"application/json\" },\n293\t      body: JSON.stringify({ wallet }),\n294\t    });\n295\t    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n296\t\n297\t    // Sign with wrong keypair\n298\t    const messageBytes = new TextEncoder().encode(challenge.message);\n299\t    const signatureBytes = nacl.sign.detached(messageBytes, otherKeypair.secretKey);\n300\t    const signature = bs58.encode(signatureBytes);\n301\t\n302\t    const verifyRes = await app.request(\"/auth/verify\", {\n303\t      method: \"POST\",\n304\t      headers: { \"Content-Type\": \"application/json\" },\n305\t      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n306\t    });\n307\t    expect(verifyRes.status).toBe(401);\n308\t  });\n309\t\n310\t  it(\"rejects verify with already-used nonce\", async () => {\n311\t    const wallet = creatorKeypair.publicKey.toBase58();\n312\t\n313\t    // Get and consume a challenge\n314\t    const challengeRes = await app.request(\"/auth/challenge\", {\n315\t      method: \"POST\",\n316\t      headers: { \"Content-Type\": \"application/json\" },\n317\t      body: JSON.stringify({ wallet }),\n318\t    });\n319\t    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n320\t    const messageBytes = new TextEncoder().encode(challenge.message);\n321\t    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n322\t    const signature = bs58.encode(signatureBytes);\n323\t\n324\t    // First verify — should succeed\n325\t    const res1 = await app.request(\"/auth/verify\", {\n326\t      method: \"POST\",\n327\t      headers: { \"Content-Type\": \"application/json\" },\n328\t      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n329\t    });\n330\t    expect(res1.status).toBe(200);\n331\t\n332\t    // Second verify with same nonce — should fail\n333\t    const res2 = await app.request(\"/auth/verify\", {\n334\t      method: \"POST\",\n335\t      headers: { \"Content-Type\": \"application/json\" },\n336\t      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n337\t    });\n338\t    expect(res2.status).toBe(401);\n339\t  });\n340\t\n341\t  it(\"rejects refresh with invalid token\", async () => {\n342\t    const res = await app.request(\"/auth/refresh\", {\n343\t      method: \"POST\",\n344\t      headers: { \"Content-Type\": \"application/json\" },\n345\t      body: JSON.stringify({ refreshToken: \"not-a-real-token\" }),\n346\t    });\n347\t    expect(res.status).toBe(401);\n348\t  });\n349\t});\n350\t"}]},"parent_tool_use_id":null,"session_id":"1929aeea-d286-4cb9-ab7d-a3d475dae282","uuid":"cf23f907-8d6d-40b9-96a0-e15c4398abc5","timestamp":"2026-04-22T09:26:22.058Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/auth-routes.test.ts","content":"/**\n * Auth routes tests: challenge → verify → refresh → logout flows.\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport nacl from \"tweetnacl\";\nimport bs58 from \"bs58\";\nimport { jwtVerify } from \"jose\";\nimport postgres from \"postgres\";\nimport { createAuthDb, type AuthDb } from \"../auth-db.js\";\nimport { createAuthRoutes } from \"../routes/auth.js\";\nimport type { Db } from \"../db.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"taunt_bet_dev\",\n  });\n}\n\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-auth-route-tests\");\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"Auth routes: challenge → verify → refresh → logout\", () => {\n  let rawSql: ReturnType<typeof postgres>;\n  let authDb: AuthDb;\n  let app: Hono;\n  const profiles = new Map<string, { user_id: string; wallet: string }>();\n  const stubDb = {\n    getProfileByWallet: async (wallet: string) => {\n      const existing = profiles.get(wallet);\n      return existing\n        ? { ...existing, username: \"test-user\", username_updated_at: null, avatar_url: null, heat_multiplier: 1, points_balance: 0, created_at: new Date(), id: 1 }\n        : null;\n    },\n    createPlayerProfile: async (wallet: string) => {\n      const created = { user_id: \"usr_test1234\", wallet };\n      profiles.set(wallet, created);\n      return {\n        ...created,\n        username: \"test-user\",\n        username_updated_at: null,\n        avatar_url: null,\n        heat_multiplier: 1,\n        points_balance: 0,\n        created_at: new Date(),\n        id: 1,\n      };\n    },\n  } as unknown as Db;\n\n  const creatorKeypair = Keypair.generate();\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n    // Ensure auth tables exist\n    await rawSql`DROP TABLE IF EXISTS auth_challenges, refresh_tokens`;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS auth_challenges (\n        nonce TEXT PRIMARY KEY,\n        wallet TEXT NOT NULL,\n        cluster TEXT NOT NULL DEFAULT 'devnet',\n        message TEXT NOT NULL,\n        expires_at TIMESTAMPTZ NOT NULL,\n        used BOOLEAN DEFAULT FALSE,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS refresh_tokens (\n        id BIGSERIAL PRIMARY KEY,\n        user_id TEXT NOT NULL,\n        wallet TEXT NOT NULL,\n        token_hash BYTEA NOT NULL UNIQUE,\n        family_id TEXT NOT NULL,\n        expires_at TIMESTAMPTZ NOT NULL,\n        revoked BOOLEAN DEFAULT FALSE,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n  });\n\n  afterAll(async () => {\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE auth_challenges, refresh_tokens RESTART IDENTITY`;\n    profiles.clear();\n    authDb = createAuthDb(rawSql);\n    app = new Hono();\n    app.route(\n      \"/auth\",\n      createAuthRoutes({\n        authDb,\n        db: stubDb,\n        jwtSecret: JWT_SECRET,\n        cluster: \"devnet\",\n        challengeTtlSeconds: 300,\n        accessTokenTtlSeconds: 3600,\n        refreshTokenTtlDays: 14,\n      }),\n    );\n  });\n\n  // -----------------------------------------------------------------------\n  // POST /auth/challenge\n  // -----------------------------------------------------------------------\n\n  it(\"returns a challenge with nonce and message\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const res = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n\n    expect(res.status).toBe(200);\n    const json = (await res.json()) as { nonce: string; message: string; expiresAt: string };\n    expect(json.nonce).toBeDefined();\n    expect(json.nonce.length).toBe(64); // 32 bytes hex\n    expect(json.message).toContain(\"Sign this message to create your Taunt BET account.\");\n    expect(json.message).toContain(wallet);\n    expect(json.message).toContain(\"Solana Devnet\");\n    expect(json.expiresAt).toBeDefined();\n  });\n\n  it(\"rejects challenge with missing wallet\", async () => {\n    const res = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({}),\n    });\n    expect(res.status).toBe(422);\n  });\n\n  it(\"rejects challenge with missing body\", async () => {\n    const res = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n    });\n\n    expect(res.status).toBe(422);\n    const body = (await res.json()) as {\n      ok: false;\n      error: { code: string; message: string };\n    };\n    expect(body.ok).toBe(false);\n    expect(body.error.code).toBe(\"VALIDATION_FAILED\");\n    expect(body.error.message).toBe(\"Invalid request\");\n  });\n\n  // -----------------------------------------------------------------------\n  // Full flow: challenge → verify → refresh → logout\n  // -----------------------------------------------------------------------\n\n  it(\"full auth flow: challenge → verify → refresh → logout\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n\n    // 1. Request challenge\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    expect(challengeRes.status).toBe(200);\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n\n    // 2. Sign the message\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    // 3. Verify\n    const verifyRes = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(verifyRes.status).toBe(200);\n    const tokens = (await verifyRes.json()) as {\n      accessToken: string;\n      accessExpiresAt: string;\n      refreshToken: string;\n      refreshExpiresAt: string;\n    };\n    expect(tokens.accessToken).toBeDefined();\n    expect(tokens.refreshToken).toBeDefined();\n    expect(tokens.accessExpiresAt).toBeDefined();\n    expect(tokens.refreshExpiresAt).toBeDefined();\n\n    // Verify JWT is valid and contains the correct user identity\n    const { payload } = await jwtVerify(tokens.accessToken, JWT_SECRET, {\n      algorithms: [\"HS256\"],\n    });\n    expect(payload.sub).toBe(\"usr_test1234\");\n\n    // 4. Refresh\n    const refreshRes = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n    });\n    expect(refreshRes.status).toBe(200);\n    const newTokens = (await refreshRes.json()) as {\n      accessToken: string;\n      refreshToken: string;\n    };\n    expect(newTokens.accessToken).toBeDefined();\n    expect(newTokens.refreshToken).toBeDefined();\n    // New refresh token should be different from the old one\n    expect(newTokens.refreshToken).not.toBe(tokens.refreshToken);\n\n    // 5. Old refresh token should no longer work (it was rotated)\n    const replayRes = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n    });\n    expect(replayRes.status).toBe(401);\n    const replayJson = (await replayRes.json()) as { error: string };\n    expect(replayJson.error).toContain(\"reuse\");\n\n    // 6. Logout with new token\n    const logoutRes = await app.request(\"/auth/logout\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n    });\n    expect(logoutRes.status).toBe(204);\n\n    // 7. Refresh after logout should fail\n    const postLogoutRefresh = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n    });\n    expect(postLogoutRefresh.status).toBe(401);\n  });\n\n  // -----------------------------------------------------------------------\n  // Edge cases\n  // -----------------------------------------------------------------------\n\n  it(\"rejects verify with wrong wallet\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const otherKeypair = Keypair.generate();\n\n    // Get challenge for the correct wallet\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n\n    // Sign with the correct keypair\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    // But claim to be a different wallet\n    const verifyRes = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({\n        nonce: challenge.nonce,\n        wallet: otherKeypair.publicKey.toBase58(),\n        signature,\n      }),\n    });\n    expect(verifyRes.status).toBe(401);\n  });\n\n  it(\"rejects verify with wrong signature\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const otherKeypair = Keypair.generate();\n\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n\n    // Sign with wrong keypair\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, otherKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    const verifyRes = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(verifyRes.status).toBe(401);\n  });\n\n  it(\"rejects verify with already-used nonce\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n\n    // Get and consume a challenge\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    // First verify — should succeed\n    const res1 = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(res1.status).toBe(200);\n\n    // Second verify with same nonce — should fail\n    const res2 = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(res2.status).toBe(401);\n  });\n\n  it(\"rejects refresh with invalid token\", async () => {\n    const res = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: \"not-a-real-token\" }),\n    });\n    expect(res.status).toBe(401);\n  });\n});\n","numLines":350,"startLine":1,"totalLines":350}}}
