  expect(body.ok).toBe(false);\n    expect(body.error.code).toBe(\"AUTH_REQUIRED\");\n    expect(body.error.message).toBe(\"Missing or invalid Authorization header\");\n  });\n\n  it(\"rejects malformed Authorization header\", async () => {\n    const app = createTestApp();\n    const res = await app.request(\"/test\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": \"Basic abc123\",\n      },\n      body: JSON.stringify({}),\n    });\n    expect(res.status).toBe(401);\n    const body = (await res.json()) as {\n      ok: false;\n      error: { code: string };\n    };\n    expect(body.ok).toBe(false);\n    expect(body.error.code).toBe(\"AUTH_REQUIRED\");\n  });\n\n  it(\"rejects an expired JWT\", async () => {\n    const app = createTestApp();\n    const token = await makeJwt(\"usr_test1234\", { expiresIn: -10 });\n    const res = await app.request(\"/test\", post(token));\n    expect(res.status).toBe(401);\n    const body = (await res.json()) as {\n      ok: false;\n      error: { code: string; message: string };\n    };\n    expect(body.ok).toBe(false);\n    expect(body.error.code).toBe(\"AUTH_REQUIRED\");\n    expect(body.error.message).toBe(\"Invalid or expired token\");\n  });\n\n  it(\"rejects a JWT signed with wrong secret\", async () => {\n    const app = createTestApp();\n    const wrongSecret = new TextEncoder().encode(\"wrong-secret-key\");\n    const token = await makeJwt(\"usr_test1234\", { secret: wrongSecret });\n    const res = await app.request(\"/test\", post(token));\n    expect(res.status).toBe(401);\n    const body = (await res.json()) as {\n      ok: false;\n      error: { code: string };\n    };\n    expect(body.ok).toBe(false);\n    expect(body.error.code).toBe(\"AUTH_REQUIRED\");\n  });","originalFile":"import { describe, it, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { SignJWT } from \"jose\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport type { AppEnv } from \"../hono-env.js\";\n\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-key-for-jwt-auth-tests\");\n\nfunction createTestApp() {\n  const app = new Hono<AppEnv>();\n  app.use(\"/*\", createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }));\n  app.post(\"/test\", (c) =>\n    c.json({ ok: true, userId: c.get(\"userId\") }),\n  );\n  app.get(\"/test\", (c) => c.json({ ok: true }));\n  return app;\n}\n\nasync function makeJwt(\n  userId: string,\n  opts?: { expiresIn?: number; secret?: Uint8Array },\n) {\n  const secret = opts?.secret ?? JWT_SECRET;\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({})\n    .setSubject(userId)\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setIssuedAt(now)\n    .setExpirationTime(now + (opts?.expiresIn ?? 3600))\n    .sign(secret);\n}\n\nfunction post(token?: string) {\n  const headers: Record<string, string> = { \"Content-Type\": \"application/json\" };\n  if (token) {\n    headers[\"Authorization\"] = `Bearer ${token}`;\n  }\n  return {\n    method: \"POST\" as const,\n    headers,\n    body: JSON.stringify({ data: \"test\" }),\n  };\n}\n\ndescribe(\"JWT auth middleware\", () => {\n  it(\"accepts a valid JWT\", async () => {\n    const app = createTestApp();\n    const token = await makeJwt(\"usr_test1234\");\n    const res = await app.request(\"/test\", post(token));\n    expect(res.status).toBe(200);\n    const json = (await res.json()) as { ok: boolean; userId: string };\n    expect(json.ok).toBe(true);\n    expect(json.userId).toBe(\"usr_test1234\");\n  });\n\n  it(\"rejects missing Authorization header\", async () => {\n    const app = createTestApp();\n    const res = await app.request(\"/test\", post());\n    expect(res.status).toBe(401);\n  });\n\n  it(\"rejects malformed Authorization header\", async () => {\n    const app = createTestApp();\n    const res = await app.request(\"/test\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": \"Basic abc123\",\n      },\n      body: JSON.stringify({}),\n    });\n    expect(res.status).toBe(401);\n  });\n\n  it(\"rejects an expired JWT\", async () => {\n    const app = createTestApp();\n    const token = await makeJwt(\"usr_test1234\", { expiresIn: -10 });\n    const res = await app.request(\"/test\", post(token));\n    expect(res.status).toBe(401);\n  });\n\n  it(\"rejects a JWT signed with wrong secret\", async () => {\n    const app = createTestApp();\n    const wrongSecret = new TextEncoder().encode(\"wrong-secret-key\");\n    const token = await makeJwt(\"usr_test1234\", { secret: wrongSecret });\n    const res = await app.request(\"/test\", post(token));\n    expect(res.status).toBe(401);\n  });\n\n  it(\"passes GET requests without authentication\", async () => {\n    const app = createTestApp();\n    const res = await app.request(\"/test\", { method: \"GET\" });\n    expect(res.status).toBe(200);\n  });\n\n  it(\"sets userId from JWT sub claim (no wallet in JWT)\", async () => {\n    const app = createTestApp();\n    const userId = \"usr_test1234\";\n    const token = await makeJwt(userId);\n    const res = await app.request(\"/test\", post(token));\n    expect(res.status).toBe(200);\n    const json = (await res.json()) as { userId: string };\n    expect(json.userId).toBe(userId);\n  });\n});\n","structuredPatch":[{"oldStart":57,"oldLines":6,"newStart":57,"newLines":13,"lines":["     const app = createTestApp();","     const res = await app.request(\"/test\", post());","     expect(res.status).toBe(401);","+    const body = (await res.json()) as {","+      ok: false;","+      error: { code: string; message: string };","+    };","+    expect(body.ok).toBe(false);","+    expect(body.error.code).toBe(\"AUTH_REQUIRED\");","+    expect(body.error.message).toBe(\"Missing or invalid Authorization header\");","   });"," ","   it(\"rejects malformed Authorization header\", async () => {"]},{"oldStart"