th rejected: token verification failed\", {\n        path: c.req.path,\n        error:\n          verifyError instanceof Error ? verifyError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        401,\n        API_ERROR_CODES.AUTH_REQUIRED,\n        \"Invalid or expired token\",\n      );\n    }\n  });\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1210,"cache_read_input_tokens":69664,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1210},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"1929aeea-d286-4cb9-ab7d-a3d475dae282","uuid":"f5514203-fe4f-43be-8842-12511bb549a3"}
