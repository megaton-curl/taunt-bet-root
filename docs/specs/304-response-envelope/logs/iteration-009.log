{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_019iZWuD5379t5XPrKL1B1T1","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0188UntaAZFkaTF7pVNSDPwv","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/src/routes/profile.ts","content":"/**\n * Profile routes — transaction history for the authenticated player.\n */\n\nimport { createRoute, z } from \"@hono/zod-openapi\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { emitEvent } from \"../queue/emit-event.js\";\nimport { EventTypes } from \"../queue/event-types.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport {\n  ConfirmTransactionBodySchema,\n  PlayerProfileSchema,\n  TransactionHistoryQuerySchema,\n  TransactionsPageResponseSchema,\n  UsernameBodySchema,\n  UsernameUpdateResponseSchema,\n} from \"../contracts/validators.js\";\nimport { toDbGameId, toPublicGameId } from \"../contracts/public-games.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface ProfileRoutesDeps {\n  db: Db;\n}\n\nconst ConfirmTxSuccessSchema = z.object({\n  recorded: z.literal(true),\n});\n\nexport function createProfileRoutes(deps: ProfileRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // GET /me — full profile + stats for authenticated player\n  const meRoute = createRoute({\n    method: \"get\",\n    path: \"/me\",\n    tags: [\"Profile\"],\n    summary: \"Get own profile with full stats\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: envelope(PlayerProfileSchema) } },\n        description: \"Player profile with aggregate stats\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Profile not found\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch profile\",\n      },\n    },\n  });\n\n  app.openapi(meRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    try {\n      const profile = await db.getProfileByUserId(userId);\n      if (!profile) {\n        return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");\n      }\n\n      const [pointRows, telegramLink] = await Promise.all([\n        db.rawSql<{ balance: string }[]>`\n          SELECT balance::TEXT AS balance\n          FROM player_points\n          WHERE user_id = ${userId}\n        `,\n        db.getActiveLink(userId),\n      ]);\n      const pointsBalance = pointRows[0]?.balance ?? \"0\";\n      // Temporary production safety valve: there are no live games right now, so\n      // `/profile/me` skips the game-derived stats queries and returns zeroed\n      // values instead. We will restore proper stats computation in a later pass.\n      const zeroedStats = {\n        gamesPlayed: 0,\n        totalWagered: \"0\",\n        totalWins: 0,\n        winRate: 0,\n        winStreakCurrent: 0,\n        winStreakBest: 0,\n        netPnl: \"0\",\n        gameBreakdown: {},\n      };\n\n      const usernameNextEditAt = profile.username_updated_at\n        ? new Date(profile.username_updated_at.getTime() + 30 * 24 * 60 * 60 * 1000).toISOString()\n        : null;\n\n      return ok(c, {\n        userId: profile.user_id,\n        username: profile.username,\n        avatarUrl: profile.avatar_url,\n        heatMultiplier: profile.heat_multiplier,\n        pointsBalance,\n        stats: zeroedStats,\n        usernameNextEditAt,\n        createdAt: profile.created_at.toISOString(),\n        telegramLinked: Boolean(telegramLink?.telegram_user_id),\n      });\n    } catch (fetchError) {\n      logger.error(\"profile/me failed\", {\n        userId,\n        error: fetchError instanceof Error ? fetchError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch profile\",\n      );\n    }\n  });\n\n  // PUT /username — change username for authenticated player\n  const usernameRoute = createRoute({\n    method: \"put\",\n    path: \"/username\",\n    tags: [\"Profile\"],\n    summary: \"Change username\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      body: {\n        required: true,\n        content: { \"application/json\": { schema: UsernameBodySchema } },\n      },\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: envelope(UsernameUpdateResponseSchema) } },\n        description: \"Username updated\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Profile not found\",\n      },\n      409: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Username taken\",\n      },\n      422: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Invalid username format\",\n      },\n      429: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Cooldown active (30-day limit)\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to update username\",\n      },\n    },\n  });\n\n  app.openapi(usernameRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    const { username } = c.req.valid(\"json\");\n\n    try {\n      const profile = await db.getProfileByUserId(userId);\n      if (!profile) {\n        return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");\n      }\n\n      // Check cooldown before calling updateUsername to return proper 429\n      if (profile.username_updated_at) {\n        const cooldownMs = 30 * 24 * 60 * 60 * 1000; // 30 days\n        const elapsed = Date.now() - new Date(profile.username_updated_at).getTime();\n        if (elapsed < cooldownMs) {\n          const nextEditAvailableAt = new Date(\n            new Date(profile.username_updated_at).getTime() + cooldownMs,\n          ).toISOString();\n          return err(\n            c,\n            429,\n            API_ERROR_CODES.USERNAME_COOLDOWN,\n            \"Username change cooldown active\",\n            { retryable: true, details: { nextEditAvailableAt } },\n          );\n        }\n      }\n\n      const isFirstChange = !profile.username_updated_at;\n      const updated = await db.updateUsernameByUserId(userId, username);\n\n      if (isFirstChange) {\n        await emitEvent(db.rawSql, EventTypes.PROFILE_USERNAME_SET, {\n          userId,\n          wallet: profile.wallet,\n        });\n      }\n\n      const nextEditAvailableAt = updated.username_updated_at\n        ? new Date(updated.username_updated_at.getTime() + 30 * 24 * 60 * 60 * 1000).toISOString()\n        : null;\n\n      return ok(c, { username: updated.username, nextEditAvailableAt });\n    } catch (updateError: unknown) {\n      // UNIQUE violation from postgres (case-insensitive index)\n      const errCode = (updateError as { code?: string })?.code;\n      if (\n        (updateError instanceof Error && updateError.message.includes(\"unique\")) ||\n        errCode === \"23505\"\n      ) {\n        return err(\n          c,\n          409,\n          API_ERROR_CODES.USERNAME_TAKEN,\n          \"Username is already taken\",\n          { retryable: false },\n        );\n      }\n      // Cooldown from db.updateUsername (race condition fallback)\n      if (updateError && typeof updateError === \"object\" && \"cooldown\" in updateError) {\n        const cooldownErr = updateError as unknown as { nextEditAvailableAt: Date };\n        if (cooldownErr.nextEditAvailableAt) {\n          return err(\n            c,\n            429,\n            API_ERROR_CODES.USERNAME_COOLDOWN,\n            \"Username change cooldown active\",\n            {\n              retryable: true,\n              details: {\n                nextEditAvailableAt: cooldownErr.nextEditAvailableAt.toISOString(),\n              },\n            },\n          );\n        }\n      }\n      logger.error(\"profile/username update failed\", {\n        userId,\n        error: updateError instanceof Error ? updateError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to update username\",\n      );\n    }\n  }, (result, c) => {\n    if (result.success) return;\n    return err(\n      c,\n      422,\n      API_ERROR_CODES.INVALID_USERNAME,\n      \"Username must be 3-20 characters (letters, digits, underscore, hyphen)\",\n      { retryable: false, details: result.error.issues },\n    );\n  });\n\n  // GET /transactions — cursor-paginated transaction history\n  const transactionsRoute = createRoute({\n    method: \"get\",\n    path: \"/transactions\",\n    tags: [\"Profile\"],\n    summary: \"Get player transaction history\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      query: TransactionHistoryQuerySchema,\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: envelope(TransactionsPageResponseSchema) } },\n        description: \"Paginated transaction list\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      422: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Invalid query parameters\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch transactions\",\n      },\n    },\n  });\n\n  app.openapi(transactionsRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    const { cursor, limit, game } = c.req.valid(\"query\");\n    const dbGame = game ? toDbGameId(game) : undefined;\n    if (game && !dbGame) {\n      return err(\n        c,\n        422,\n        API_ERROR_CODES.INVALID_PARAMS,\n        `Invalid game filter: ${game}`,\n        { retryable: false },\n      );\n    }\n\n    try {\n      const rows = await db.getTransactionsByUserId(userId, cursor, limit, dbGame);\n\n      const transactions = rows.map((row) => ({\n        id: row.id,\n        game: toPublicGameId(row.game) ?? row.game,\n        matchId: row.match_id,\n        txType: row.tx_type,\n        amountLamports: String(row.amount_lamports),\n        txSig: row.tx_sig,\n        createdAt: row.created_at.toISOString(),\n      }));\n\n      const nextCursor =\n        transactions.length === limit\n          ? String(transactions[transactions.length - 1]!.id)\n          : null;\n\n      return ok(c, { transactions, nextCursor });\n    } catch (queryError) {\n      logger.error(\"profile transactions query failed\", {\n        userId,\n        error: queryError instanceof Error ? queryError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch transactions\",\n      );\n    }\n  });\n\n  // POST /confirm-tx — frontend reports a confirmed on-chain transaction\n  const confirmTxRoute = createRoute({\n    method: \"post\",\n    path: \"/confirm-tx\",\n    tags: [\"Profile\"],\n    summary: \"Report a confirmed on-chain transaction\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      body: {\n        required: true,\n        content: { \"application/json\": { schema: ConfirmTransactionBodySchema } },\n      },\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: envelope(ConfirmTxSuccessSchema) } },\n        description: \"Transaction recorded\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Profile not found\",\n      },\n      422: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Missing or invalid fields\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to record transaction\",\n      },\n    },\n  });\n\n  app.openapi(confirmTxRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");\n    }\n    const wallet = profile.wallet;\n\n    const body = c.req.valid(\"json\");\n\n    // Map to DB game name\n    const dbGame = toDbGameId(body.game);\n    if (!dbGame) {\n      return err(\n        c,\n        422,\n        API_ERROR_CODES.INVALID_PARAMS,\n        `Invalid game: ${body.game}`,\n        { retryable: false },\n      );\n    }\n\n    try {\n      await db.insertTransaction({\n        userId,\n        wallet,\n        game: dbGame,\n        matchId: body.matchId,\n        txType: body.txType as \"deposit\" | \"refund\",\n        amountLamports: body.amountLamports,\n        txSig: body.txSig,\n      });\n      return ok(c, { recorded: true as const });\n    } catch (insertError) {\n      logger.error(\"confirm-tx failed\", {\n        userId,\n        wallet,\n        txType: body.txType,\n        error: insertError instanceof Error ? insertError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to record transaction\",\n      );\n    }\n  }, (result, c) => {\n    if (result.success) return;\n    return err(\n      c,\n      422,\n      API_ERROR_CODES.VALIDATION_FAILED,\n      \"Missing or invalid fields\",\n      { retryable: false, details: result.error.issues },\n    );\n  });\n\n  return app;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2777,"cache_read_input_tokens":100334,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2777},"output_tokens":41,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c369c0ad-be87-4942-b868-52215f926351","uuid":"e40bbded-edbb-4bc9-b684-5ad41c0649a7"}
