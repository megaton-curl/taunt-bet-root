{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0163qegwDKpPGApgMdgFFGi7","type":"tool_result","content":"1\t/**\n2\t * Profile routes — transaction history for the authenticated player.\n3\t */\n4\t\n5\timport { createRoute } from \"@hono/zod-openapi\";\n6\timport type { AppEnv } from \"../hono-env.js\";\n7\timport type { Db } from \"../db.js\";\n8\timport { logger } from \"../logger.js\";\n9\timport { emitEvent } from \"../queue/emit-event.js\";\n10\timport { EventTypes } from \"../queue/event-types.js\";\n11\timport { errorMessage } from \"../contracts/api-errors.js\";\n12\timport {\n13\t  ConfirmTransactionBodySchema,\n14\t  ErrorResponseSchema,\n15\t  OkResponseSchema,\n16\t  PlayerProfileSchema,\n17\t  TransactionHistoryQuerySchema,\n18\t  TransactionsPageResponseSchema,\n19\t  UsernameBodySchema,\n20\t  UsernameCooldownResponseSchema,\n21\t  UsernameUpdateResponseSchema,\n22\t} from \"../contracts/validators.js\";\n23\timport { toDbGameId, toPublicGameId } from \"../contracts/public-games.js\";\n24\timport { createOpenApiApp } from \"../openapi/hono.js\";\n25\t\n26\texport interface ProfileRoutesDeps {\n27\t  db: Db;\n28\t}\n29\t\n30\texport function createProfileRoutes(deps: ProfileRoutesDeps) {\n31\t  const { db } = deps;\n32\t  const app = createOpenApiApp<AppEnv>();\n33\t\n34\t  // GET /me — full profile + stats for authenticated player\n35\t  const meRoute = createRoute({\n36\t    method: \"get\",\n37\t    path: \"/me\",\n38\t    tags: [\"Profile\"],\n39\t    summary: \"Get own profile with full stats\",\n40\t    security: [{ bearerAuth: [] }],\n41\t    responses: {\n42\t      200: {\n43\t        content: { \"application/json\": { schema: PlayerProfileSchema } },\n44\t        description: \"Player profile with aggregate stats\",\n45\t      },\n46\t      401: {\n47\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n48\t        description: \"Authentication required\",\n49\t      },\n50\t      404: {\n51\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n52\t        description: \"Profile not found\",\n53\t      },\n54\t      500: {\n55\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n56\t        description: \"Failed to fetch profile\",\n57\t      },\n58\t    },\n59\t  });\n60\t\n61\t  app.openapi(meRoute, async (c) => {\n62\t    const userId = c.get(\"userId\");\n63\t    if (!userId) {\n64\t      return c.json(errorMessage(\"Authentication required\"), 401);\n65\t    }\n66\t\n67\t    try {\n68\t      const profile = await db.getProfileByUserId(userId);\n69\t      if (!profile) {\n70\t        return c.json(errorMessage(\"PROFILE_NOT_FOUND\"), 404);\n71\t      }\n72\t\n73\t      const [pointRows, telegramLink] = await Promise.all([\n74\t        db.rawSql<{ balance: string }[]>`\n75\t          SELECT balance::TEXT AS balance\n76\t          FROM player_points\n77\t          WHERE user_id = ${userId}\n78\t        `,\n79\t        db.getActiveLink(userId),\n80\t      ]);\n81\t      const pointsBalance = pointRows[0]?.balance ?? \"0\";\n82\t      // Temporary production safety valve: there are no live games right now, so\n83\t      // `/profile/me` skips the game-derived stats queries and returns zeroed\n84\t      // values instead. We will restore proper stats computation in a later pass.\n85\t      const zeroedStats = {\n86\t        gamesPlayed: 0,\n87\t        totalWagered: \"0\",\n88\t        totalWins: 0,\n89\t        winRate: 0,\n90\t        winStreakCurrent: 0,\n91\t        winStreakBest: 0,\n92\t        netPnl: \"0\",\n93\t        gameBreakdown: {},\n94\t      };\n95\t\n96\t      // Serialize BigInt fields as strings, compute next edit timestamp\n97\t      const usernameNextEditAt = profile.username_updated_at\n98\t        ? new Date(profile.username_updated_at.getTime() + 30 * 24 * 60 * 60 * 1000).toISOString()\n99\t        : null;\n100\t\n101\t      return c.json(\n102\t        {\n103\t          userId: profile.user_id,\n104\t          username: profile.username,\n105\t          avatarUrl: profile.avatar_url,\n106\t          heatMultiplier: profile.heat_multiplier,\n107\t          pointsBalance,\n108\t          stats: zeroedStats,\n109\t          usernameNextEditAt,\n110\t          createdAt: profile.created_at.toISOString(),\n111\t          telegramLinked: Boolean(telegramLink?.telegram_user_id),\n112\t        },\n113\t        200,\n114\t      );\n115\t    } catch (err) {\n116\t      logger.error(\"profile/me failed\", {\n117\t        userId,\n118\t        error: err instanceof Error ? err.message : \"Unknown error\",\n119\t      });\n120\t      return c.json(errorMessage(\"Failed to fetch profile\"), 500);\n121\t    }\n122\t  });\n123\t\n124\t  // PUT /username — change username for authenticated player\n125\t  const usernameRoute = createRoute({\n126\t    method: \"put\",\n127\t    path: \"/username\",\n128\t    tags: [\"Profile\"],\n129\t    summary: \"Change username\",\n130\t    security: [{ bearerAuth: [] }],\n131\t    request: {\n132\t      body: {\n133\t        required: true,\n134\t        content: { \"application/json\": { schema: UsernameBodySchema } },\n135\t      },\n136\t    },\n137\t    responses: {\n138\t      200: {\n139\t        content: { \"application/json\": { schema: UsernameUpdateResponseSchema } },\n140\t        description: \"Username updated\",\n141\t      },\n142\t      400: {\n143\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n144\t        description: \"Invalid username format\",\n145\t      },\n146\t      401: {\n147\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n148\t        description: \"Authentication required\",\n149\t      },\n150\t      404: {\n151\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n152\t        description: \"Profile not found\",\n153\t      },\n154\t      409: {\n155\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n156\t        description: \"Username taken\",\n157\t      },\n158\t      429: {\n159\t        content: { \"application/json\": { schema: UsernameCooldownResponseSchema } },\n160\t        description: \"Cooldown active (30-day limit)\",\n161\t      },\n162\t      500: {\n163\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n164\t        description: \"Failed to update username\",\n165\t      },\n166\t    },\n167\t  });\n168\t\n169\t  app.openapi(usernameRoute, async (c) => {\n170\t    const userId = c.get(\"userId\");\n171\t    if (!userId) {\n172\t      return c.json(errorMessage(\"Authentication required\"), 401);\n173\t    }\n174\t\n175\t    const { username } = c.req.valid(\"json\");\n176\t\n177\t    try {\n178\t      const profile = await db.getProfileByUserId(userId);\n179\t      if (!profile) {\n180\t        return c.json(errorMessage(\"PROFILE_NOT_FOUND\"), 404);\n181\t      }\n182\t\n183\t      // Check cooldown before calling updateUsername to return proper 429\n184\t      if (profile.username_updated_at) {\n185\t        const cooldownMs = 30 * 24 * 60 * 60 * 1000; // 30 days\n186\t        const elapsed = Date.now() - new Date(profile.username_updated_at).getTime();\n187\t        if (elapsed < cooldownMs) {\n188\t          const nextEditAvailableAt = new Date(\n189\t            new Date(profile.username_updated_at).getTime() + cooldownMs,\n190\t          ).toISOString();\n191\t          return c.json({ ...errorMessage(\"COOLDOWN_ACTIVE\"), nextEditAvailableAt }, 429);\n192\t        }\n193\t      }\n194\t\n195\t      const isFirstChange = !profile.username_updated_at;\n196\t      const updated = await db.updateUsernameByUserId(userId, username);\n197\t\n198\t      if (isFirstChange) {\n199\t        await emitEvent(db.rawSql, EventTypes.PROFILE_USERNAME_SET, {\n200\t          userId,\n201\t          wallet: profile.wallet,\n202\t        });\n203\t      }\n204\t\n205\t      const nextEditAvailableAt = updated.username_updated_at\n206\t        ? new Date(updated.username_updated_at.getTime() + 30 * 24 * 60 * 60 * 1000).toISOString()\n207\t        : null;\n208\t\n209\t      return c.json({ username: updated.username, nextEditAvailableAt }, 200);\n210\t    } catch (err: unknown) {\n211\t      // UNIQUE violation from postgres (case-insensitive index)\n212\t      const errCode = (err as { code?: string })?.code;\n213\t      if (\n214\t        (err instanceof Error && err.message.includes(\"unique\")) || errCode === \"23505\"\n215\t      ) {\n216\t        return c.json(errorMessage(\"USERNAME_TAKEN\"), 409);\n217\t      }\n218\t      // Cooldown from db.updateUsername (race condition fallback)\n219\t      if (err && typeof err === \"object\" && \"cooldown\" in err) {\n220\t        const cooldownErr = err as unknown as { nextEditAvailableAt: Date };\n221\t        if (cooldownErr.nextEditAvailableAt) {\n222\t          return c.json(\n223\t            {\n224\t              ...errorMessage(\"COOLDOWN_ACTIVE\"),\n225\t              nextEditAvailableAt: cooldownErr.nextEditAvailableAt.toISOString(),\n226\t            },\n227\t            429,\n228\t          );\n229\t        }\n230\t      }\n231\t      logger.error(\"profile/username update failed\", {\n232\t        userId,\n233\t        error: err instanceof Error ? err.message : \"Unknown error\",\n234\t      });\n235\t      return c.json(errorMessage(\"Failed to update username\"), 500);\n236\t    }\n237\t  }, (result, c) => {\n238\t    if (result.success) return;\n239\t    return c.json(errorMessage(\"INVALID_FORMAT\"), 400);\n240\t  });\n241\t\n242\t  // GET /transactions — cursor-paginated transaction history\n243\t  const transactionsRoute = createRoute({\n244\t    method: \"get\",\n245\t    path: \"/transactions\",\n246\t    tags: [\"Profile\"],\n247\t    summary: \"Get player transaction history\",\n248\t    security: [{ bearerAuth: [] }],\n249\t    request: {\n250\t      query: TransactionHistoryQuerySchema,\n251\t    },\n252\t    responses: {\n253\t      200: {\n254\t        content: { \"application/json\": { schema: TransactionsPageResponseSchema } },\n255\t        description: \"Paginated transaction list\",\n256\t      },\n257\t      400: {\n258\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n259\t        description: \"Invalid query parameters\",\n260\t      },\n261\t      401: {\n262\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n263\t        description: \"Authentication required\",\n264\t      },\n265\t      500: {\n266\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n267\t        description: \"Failed to fetch transactions\",\n268\t      },\n269\t    },\n270\t  });\n271\t\n272\t  app.openapi(transactionsRoute, async (c) => {\n273\t    const userId = c.get(\"userId\");\n274\t    if (!userId) {\n275\t      return c.json(errorMessage(\"Authentication required\"), 401);\n276\t    }\n277\t\n278\t    const { cursor, limit, game } = c.req.valid(\"query\");\n279\t    const dbGame = game ? toDbGameId(game) : undefined;\n280\t    if (game && !dbGame) {\n281\t      return c.json(errorMessage(`Invalid game filter: ${game}`), 400);\n282\t    }\n283\t\n284\t    try {\n285\t      const rows = await db.getTransactionsByUserId(userId, cursor, limit, dbGame);\n286\t\n287\t      const transactions = rows.map((row) => ({\n288\t        id: row.id,\n289\t        game: toPublicGameId(row.game) ?? row.game,\n290\t        matchId: row.match_id,\n291\t        txType: row.tx_type,\n292\t        amountLamports: String(row.amount_lamports),\n293\t        txSig: row.tx_sig,\n294\t        createdAt: row.created_at.toISOString(),\n295\t      }));\n296\t\n297\t      const nextCursor =\n298\t        transactions.length === limit\n299\t          ? String(transactions[transactions.length - 1]!.id)\n300\t          : null;\n301\t\n302\t      return c.json({ transactions, nextCursor }, 200);\n303\t    } catch (err) {\n304\t      logger.error(\"profile transactions query failed\", {\n305\t        userId,\n306\t        error: err instanceof Error ? err.message : \"Unknown error\",\n307\t      });\n308\t      return c.json(errorMessage(\"Failed to fetch transactions\"), 500);\n309\t    }\n310\t  });\n311\t\n312\t  // POST /confirm-tx — frontend reports a confirmed on-chain transaction\n313\t  const confirmTxRoute = createRoute({\n314\t    method: \"post\",\n315\t    path: \"/confirm-tx\",\n316\t    tags: [\"Profile\"],\n317\t    summary: \"Report a confirmed on-chain transaction\",\n318\t    security: [{ bearerAuth: [] }],\n319\t    request: {\n320\t      body: {\n321\t        required: true,\n322\t        content: { \"application/json\": { schema: ConfirmTransactionBodySchema } },\n323\t      },\n324\t    },\n325\t    responses: {\n326\t      200: {\n327\t        content: { \"application/json\": { schema: OkResponseSchema } },\n328\t        description: \"Transaction recorded\",\n329\t      },\n330\t      400: {\n331\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n332\t        description: \"Missing or invalid fields\",\n333\t      },\n334\t      401: {\n335\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n336\t        description: \"Authentication required\",\n337\t      },\n338\t      404: {\n339\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n340\t        description: \"Profile not found\",\n341\t      },\n342\t      500: {\n343\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n344\t        description: \"Failed to record transaction\",\n345\t      },\n346\t    },\n347\t  });\n348\t\n349\t  app.openapi(confirmTxRoute, async (c) => {\n350\t    const userId = c.get(\"userId\");\n351\t    if (!userId) {\n352\t      return c.json(errorMessage(\"Authentication required\"), 401);\n353\t    }\n354\t    const profile = await db.getProfileByUserId(userId);\n355\t    if (!profile) {\n356\t      return c.json(errorMessage(\"Profile not found\"), 404);\n357\t    }\n358\t    const wallet = profile.wallet;\n359\t\n360\t    const body = c.req.valid(\"json\");\n361\t\n362\t    // Map to DB game name\n363\t    const dbGame = toDbGameId(body.game);\n364\t    if (!dbGame) {\n365\t      return c.json(errorMessage(`Invalid game: ${body.game}`), 400);\n366\t    }\n367\t\n368\t    try {\n369\t      await db.insertTransaction({\n370\t        userId,\n371\t        wallet,\n372\t        game: dbGame,\n373\t        matchId: body.matchId,\n374\t        txType: body.txType as \"deposit\" | \"refund\",\n375\t        amountLamports: body.amountLamports,\n376\t        txSig: body.txSig,\n377\t      });\n378\t      return c.json({ ok: true }, 200);\n379\t    } catch (err) {\n380\t      logger.error(\"confirm-tx failed\", {\n381\t        userId,\n382\t        wallet,\n383\t        txType: body.txType,\n384\t        error: err instanceof Error ? err.message : \"Unknown error\",\n385\t      });\n386\t      return c.json(errorMessage(\"Failed to record transaction\"), 500);\n387\t    }\n388\t  }, (result, c) => {\n389\t    if (result.success) return;\n390\t    return c.json(errorMessage(\"Missing or invalid fields\"), 400);\n391\t  });\n392\t\n393\t  return app;\n394\t}\n395\t"}]},"parent_tool_use_id":null,"session_id":"c369c0ad-be87-4942-b868-52215f926351","uuid":"c2901275-0ab3-49f4-b9e6-67e242f726c8","timestamp":"2026-04-22T09:59:59.398Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/profile.ts","content":"/**\n * Profile routes — transaction history for the authenticated player.\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { emitEvent } from \"../queue/emit-event.js\";\nimport { EventTypes } from \"../queue/event-types.js\";\nimport { errorMessage } from \"../contracts/api-errors.js\";\nimport {\n  ConfirmTransactionBodySchema,\n  ErrorResponseSchema,\n  OkResponseSchema,\n  PlayerProfileSchema,\n  TransactionHistoryQuerySchema,\n  TransactionsPageResponseSchema,\n  UsernameBodySchema,\n  UsernameCooldownResponseSchema,\n  UsernameUpdateResponseSchema,\n} from \"../contracts/validators.js\";\nimport { toDbGameId, toPublicGameId } from \"../contracts/public-games.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface ProfileRoutesDeps {\n  db: Db;\n}\n\nexport function createProfileRoutes(deps: ProfileRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // GET /me — full profile + stats for authenticated player\n  const meRoute = createRoute({\n    method: \"get\",\n    path: \"/me\",\n    tags: [\"Profile\"],\n    summary: \"Get own profile with full stats\",\n    security: [{ bearerAuth: [] }],\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: PlayerProfileSchema } },\n        description: \"Player profile with aggregate stats\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Profile not found\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to fetch profile\",\n      },\n    },\n  });\n\n  app.openapi(meRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json(errorMessage(\"Authentication required\"), 401);\n    }\n\n    try {\n      const profile = await db.getProfileByUserId(userId);\n      if (!profile) {\n        return c.json(errorMessage(\"PROFILE_NOT_FOUND\"), 404);\n      }\n\n      const [pointRows, telegramLink] = await Promise.all([\n        db.rawSql<{ balance: string }[]>`\n          SELECT balance::TEXT AS balance\n          FROM player_points\n          WHERE user_id = ${userId}\n        `,\n        db.getActiveLink(userId),\n      ]);\n      const pointsBalance = pointRows[0]?.balance ?? \"0\";\n      // Temporary production safety valve: there are no live games right now, so\n      // `/profile/me` skips the game-derived stats queries and returns zeroed\n      // values instead. We will restore proper stats computation in a later pass.\n      const zeroedStats = {\n        gamesPlayed: 0,\n        totalWagered: \"0\",\n        totalWins: 0,\n        winRate: 0,\n        winStreakCurrent: 0,\n        winStreakBest: 0,\n        netPnl: \"0\",\n        gameBreakdown: {},\n      };\n\n      // Serialize BigInt fields as strings, compute next edit timestamp\n      const usernameNextEditAt = profile.username_updated_at\n        ? new Date(profile.username_updated_at.getTime() + 30 * 24 * 60 * 60 * 1000).toISOString()\n        : null;\n\n      return c.json(\n        {\n          userId: profile.user_id,\n          username: profile.username,\n          avatarUrl: profile.avatar_url,\n          heatMultiplier: profile.heat_multiplier,\n          pointsBalance,\n          stats: zeroedStats,\n          usernameNextEditAt,\n          createdAt: profile.created_at.toISOString(),\n          telegramLinked: Boolean(telegramLink?.telegram_user_id),\n        },\n        200,\n      );\n    } catch (err) {\n      logger.error(\"profile/me failed\", {\n        userId,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json(errorMessage(\"Failed to fetch profile\"), 500);\n    }\n  });\n\n  // PUT /username — change username for authenticated player\n  const usernameRoute = createRoute({\n    method: \"put\",\n    path: \"/username\",\n    tags: [\"Profile\"],\n    summary: \"Change username\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      body: {\n        required: true,\n        content: { \"application/json\": { schema: UsernameBodySchema } },\n      },\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: UsernameUpdateResponseSchema } },\n        description: \"Username updated\",\n      },\n      400: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Invalid username format\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Profile not found\",\n      },\n      409: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Username taken\",\n      },\n      429: {\n        content: { \"application/json\": { schema: UsernameCooldownResponseSchema } },\n        description: \"Cooldown active (30-day limit)\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to update username\",\n      },\n    },\n  });\n\n  app.openapi(usernameRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json(errorMessage(\"Authentication required\"), 401);\n    }\n\n    const { username } = c.req.valid(\"json\");\n\n    try {\n      const profile = await db.getProfileByUserId(userId);\n      if (!profile) {\n        return c.json(errorMessage(\"PROFILE_NOT_FOUND\"), 404);\n      }\n\n      // Check cooldown before calling updateUsername to return proper 429\n      if (profile.username_updated_at) {\n        const cooldownMs = 30 * 24 * 60 * 60 * 1000; // 30 days\n        const elapsed = Date.now() - new Date(profile.username_updated_at).getTime();\n        if (elapsed < cooldownMs) {\n          const nextEditAvailableAt = new Date(\n            new Date(profile.username_updated_at).getTime() + cooldownMs,\n          ).toISOString();\n          return c.json({ ...errorMessage(\"COOLDOWN_ACTIVE\"), nextEditAvailableAt }, 429);\n        }\n      }\n\n      const isFirstChange = !profile.username_updated_at;\n      const updated = await db.updateUsernameByUserId(userId, username);\n\n      if (isFirstChange) {\n        await emitEvent(db.rawSql, EventTypes.PROFILE_USERNAME_SET, {\n          userId,\n          wallet: profile.wallet,\n        });\n      }\n\n      const nextEditAvailableAt = updated.username_updated_at\n        ? new Date(updated.username_updated_at.getTime() + 30 * 24 * 60 * 60 * 1000).toISOString()\n        : null;\n\n      return c.json({ username: updated.username, nextEditAvailableAt }, 200);\n    } catch (err: unknown) {\n      // UNIQUE violation from postgres (case-insensitive index)\n      const errCode = (err as { code?: string })?.code;\n      if (\n        (err instanceof Error && err.message.includes(\"unique\")) || errCode === \"23505\"\n      ) {\n        return c.json(errorMessage(\"USERNAME_TAKEN\"), 409);\n      }\n      // Cooldown from db.updateUsername (race condition fallback)\n      if (err && typeof err === \"object\" && \"cooldown\" in err) {\n        const cooldownErr = err as unknown as { nextEditAvailableAt: Date };\n        if (cooldownErr.nextEditAvailableAt) {\n          return c.json(\n            {\n              ...errorMessage(\"COOLDOWN_ACTIVE\"),\n              nextEditAvailableAt: cooldownErr.nextEditAvailableAt.toISOString(),\n            },\n            429,\n          );\n        }\n      }\n      logger.error(\"profile/username update failed\", {\n        userId,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json(errorMessage(\"Failed to update username\"), 500);\n    }\n  }, (result, c) => {\n    if (result.success) return;\n    return c.json(errorMessage(\"INVALID_FORMAT\"), 400);\n  });\n\n  // GET /transactions — cursor-paginated transaction history\n  const transactionsRoute = createRoute({\n    method: \"get\",\n    path: \"/transactions\",\n    tags: [\"Profile\"],\n    summary: \"Get player transaction history\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      query: TransactionHistoryQuerySchema,\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: TransactionsPageResponseSchema } },\n        description: \"Paginated transaction list\",\n      },\n      400: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Invalid query parameters\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to fetch transactions\",\n      },\n    },\n  });\n\n  app.openapi(transactionsRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json(errorMessage(\"Authentication required\"), 401);\n    }\n\n    const { cursor, limit, game } = c.req.valid(\"query\");\n    const dbGame = game ? toDbGameId(game) : undefined;\n    if (game && !dbGame) {\n      return c.json(errorMessage(`Invalid game filter: ${game}`), 400);\n    }\n\n    try {\n      const rows = await db.getTransactionsByUserId(userId, cursor, limit, dbGame);\n\n      const transactions = rows.map((row) => ({\n        id: row.id,\n        game: toPublicGameId(row.game) ?? row.game,\n        matchId: row.match_id,\n        txType: row.tx_type,\n        amountLamports: String(row.amount_lamports),\n        txSig: row.tx_sig,\n        createdAt: row.created_at.toISOString(),\n      }));\n\n      const nextCursor =\n        transactions.length === limit\n          ? String(transactions[transactions.length - 1]!.id)\n          : null;\n\n      return c.json({ transactions, nextCursor }, 200);\n    } catch (err) {\n      logger.error(\"profile transactions query failed\", {\n        userId,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json(errorMessage(\"Failed to fetch transactions\"), 500);\n    }\n  });\n\n  // POST /confirm-tx — frontend reports a confirmed on-chain transaction\n  const confirmTxRoute = createRoute({\n    method: \"post\",\n    path: \"/confirm-tx\",\n    tags: [\"Profile\"],\n    summary: \"Report a confirmed on-chain transaction\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      body: {\n        required: true,\n        content: { \"application/json\": { schema: ConfirmTransactionBodySchema } },\n      },\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: OkResponseSchema } },\n        description: \"Transaction recorded\",\n      },\n      400: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Missing or invalid fields\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Authentication required\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Profile not found\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to record transaction\",\n      },\n    },\n  });\n\n  app.openapi(confirmTxRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json(errorMessage(\"Authentication required\"), 401);\n    }\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return c.json(errorMessage(\"Profile not found\"), 404);\n    }\n    const wallet = profile.wallet;\n\n    const body = c.req.valid(\"json\");\n\n    // Map to DB game name\n    const dbGame = toDbGameId(body.game);\n    if (!dbGame) {\n      return c.json(errorMessage(`Invalid game: ${body.game}`), 400);\n    }\n\n    try {\n      await db.insertTransaction({\n        userId,\n        wallet,\n        game: dbGame,\n        matchId: body.matchId,\n        txType: body.txType as \"deposit\" | \"refund\",\n        amountLamports: body.amountLamports,\n        txSig: body.txSig,\n      });\n      return c.json({ ok: true }, 200);\n    } catch (err) {\n      logger.error(\"confirm-tx failed\", {\n        userId,\n        wallet,\n        txType: body.txType,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json(errorMessage(\"Failed to record transaction\"), 500);\n    }\n  }, (result, c) => {\n    if (result.success) return;\n    return c.json(errorMessage(\"Missing or invalid fields\"), 400);\n  });\n\n  return app;\n}\n","numLines":395,"startLine":1,"totalLines":395}}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01AfgBkVhi9HQubEW9m4G9DJ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Dt2DocNZGCVEgG9z2aRXht","name":"Read","input":{"file_path":"/workspaces/rng-utopia/backend/src/__tests__/profile.test.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":16438,"cache_read_input_tokens":56384,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":16438},"output_tokens":46,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"c369c0ad-be87-4942-b868-52215f926351","uuid":"5944eb1e-88b7-4758-b7cd-47c1ba0fd320"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Dt2DocNZGCVEgG9z2aRXht","type":"tool_result","content":"1\t/* eslint-disable @typescript-eslint/no-explicit-any */\n2\t/**\n3\t * Integration test for profile lifecycle:\n4\t * auth → profile auto-created → GET /profile/me → PUT /profile/username →\n5\t * cooldown → taken username → GET /public-profile/:identifier → no wallet leaks\n6\t */\n7\t\n8\timport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n9\timport { randomUUID } from \"node:crypto\";\n10\timport { Hono } from \"hono\";\n11\timport { Keypair } from \"@solana/web3.js\";\n12\timport nacl from \"tweetnacl\";\n13\timport bs58 from \"bs58\";\n14\timport postgres from \"postgres\";\n15\timport { createAuthDb, type AuthDb } from \"../auth-db.js\";\n16\timport { createAuthRoutes } from \"../routes/auth.js\";\n17\timport { createProfileRoutes } from \"../routes/profile.js\";\n18\timport { createPublicProfileRoutes } from \"../routes/public-profile.js\";\n19\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n20\timport { createDb, type Db } from \"../db.js\";\n21\t\n22\t// ---------------------------------------------------------------------------\n23\t// Constants\n24\t// ---------------------------------------------------------------------------\n25\t\n26\tconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n27\t\n28\t/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n29\tfunction makeSql() {\n30\t  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n31\t  return postgres({\n32\t    host: \"/var/run/postgresql\",\n33\t    user: \"vscode\",\n34\t    database: \"taunt_bet_dev\",\n35\t  });\n36\t}\n37\t\n38\tconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-profile-tests\");\n39\t\n40\t// ---------------------------------------------------------------------------\n41\t// Helpers\n42\t// ---------------------------------------------------------------------------\n43\t\n44\t/** Perform challenge → sign → verify and return access token + wallet. */\n45\tasync function authenticateWallet(\n46\t  app: Hono,\n47\t  keypair: Keypair,\n48\t): Promise<{ accessToken: string; wallet: string }> {\n49\t  const wallet = keypair.publicKey.toBase58();\n50\t\n51\t  // 1. Challenge\n52\t  const challengeRes = await app.request(\"/auth/challenge\", {\n53\t    method: \"POST\",\n54\t    headers: { \"Content-Type\": \"application/json\" },\n55\t    body: JSON.stringify({ wallet }),\n56\t  });\n57\t  expect(challengeRes.status).toBe(200);\n58\t  const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n59\t\n60\t  // 2. Sign\n61\t  const messageBytes = new TextEncoder().encode(challenge.message);\n62\t  const signatureBytes = nacl.sign.detached(messageBytes, keypair.secretKey);\n63\t  const signature = bs58.encode(signatureBytes);\n64\t\n65\t  // 3. Verify\n66\t  const verifyRes = await app.request(\"/auth/verify\", {\n67\t    method: \"POST\",\n68\t    headers: { \"Content-Type\": \"application/json\" },\n69\t    body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n70\t  });\n71\t  expect(verifyRes.status).toBe(200);\n72\t  const tokens = (await verifyRes.json()) as { accessToken: string };\n73\t  return { accessToken: tokens.accessToken, wallet };\n74\t}\n75\t\n76\tfunction makeUniqueUsername(prefix: string): string {\n77\t  const safePrefix = prefix.replace(/[^a-zA-Z0-9_]/g, \"\").slice(0, 12);\n78\t  const suffix = randomUUID().replace(/-/g, \"\").slice(0, 8);\n79\t  return `${safePrefix}${suffix}`.slice(0, 20);\n80\t}\n81\t\n82\t// ---------------------------------------------------------------------------\n83\t// Suite\n84\t// ---------------------------------------------------------------------------\n85\t\n86\tdescribe(\"Profile lifecycle integration\", () => {\n87\t  let rawSql: ReturnType<typeof postgres>;\n88\t  let authDb: AuthDb;\n89\t  let db: Db;\n90\t  let app: Hono;\n91\t\n92\t  const keypairA = Keypair.generate();\n93\t  const keypairB = Keypair.generate();\n94\t\n95\t  beforeAll(async () => {\n96\t    rawSql = makeSql();\n97\t\n98\t    // Ensure required tables exist\n99\t    await rawSql`DROP TABLE IF EXISTS auth_challenges, refresh_tokens`;\n100\t    await rawSql`\n101\t      CREATE TABLE IF NOT EXISTS auth_challenges (\n102\t        nonce TEXT PRIMARY KEY,\n103\t        wallet TEXT NOT NULL,\n104\t        cluster TEXT NOT NULL DEFAULT 'devnet',\n105\t        message TEXT NOT NULL,\n106\t        expires_at TIMESTAMPTZ NOT NULL,\n107\t        used BOOLEAN DEFAULT FALSE,\n108\t        created_at TIMESTAMPTZ DEFAULT now()\n109\t      )\n110\t    `;\n111\t    await rawSql`\n112\t      CREATE TABLE IF NOT EXISTS refresh_tokens (\n113\t        id BIGSERIAL PRIMARY KEY,\n114\t        user_id TEXT NOT NULL,\n115\t        wallet TEXT NOT NULL,\n116\t        token_hash BYTEA NOT NULL UNIQUE,\n117\t        family_id TEXT NOT NULL,\n118\t        expires_at TIMESTAMPTZ NOT NULL,\n119\t        revoked BOOLEAN DEFAULT FALSE,\n120\t        created_at TIMESTAMPTZ DEFAULT now()\n121\t      )\n122\t    `;\n123\t    await rawSql`\n124\t      CREATE TABLE IF NOT EXISTS player_profiles (\n125\t        id BIGSERIAL PRIMARY KEY,\n126\t        user_id TEXT UNIQUE NOT NULL,\n127\t        wallet TEXT UNIQUE NOT NULL,\n128\t        username TEXT UNIQUE NOT NULL,\n129\t        username_updated_at TIMESTAMPTZ,\n130\t        avatar_url TEXT,\n131\t        heat_multiplier NUMERIC DEFAULT 1.0,\n132\t        points_balance BIGINT DEFAULT 0,\n133\t        created_at TIMESTAMPTZ DEFAULT now()\n134\t      )\n135\t    `;\n136\t    // Case-insensitive uniqueness index\n137\t    await rawSql`\n138\t      CREATE UNIQUE INDEX IF NOT EXISTS idx_player_profiles_username_lower\n139\t      ON player_profiles (LOWER(username))\n140\t    `;\n141\t    // transactions table (needed for stats queries)\n142\t    await rawSql`\n143\t      CREATE TABLE IF NOT EXISTS transactions (\n144\t        id BIGSERIAL PRIMARY KEY,\n145\t        wallet TEXT NOT NULL,\n146\t        game TEXT NOT NULL,\n147\t        match_id TEXT NOT NULL,\n148\t        tx_type TEXT NOT NULL,\n149\t        amount_lamports BIGINT NOT NULL,\n150\t        tx_sig TEXT,\n151\t        created_at TIMESTAMPTZ DEFAULT now(),\n152\t        UNIQUE(wallet, match_id, tx_type, tx_sig)\n153\t      )\n154\t    `;\n155\t    await rawSql`\n156\t      CREATE TABLE IF NOT EXISTS player_points (\n157\t        user_id TEXT PRIMARY KEY,\n158\t        wallet TEXT NOT NULL UNIQUE,\n159\t        balance BIGINT NOT NULL DEFAULT 0,\n160\t        lifetime_earned BIGINT NOT NULL DEFAULT 0,\n161\t        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n162\t      )\n163\t    `;\n164\t  });\n165\t\n166\t  afterAll(async () => {\n167\t    // Clean up test data\n168\t    const walletA = keypairA.publicKey.toBase58();\n169\t    const walletB = keypairB.publicKey.toBase58();\n170\t    await rawSql`DELETE FROM player_profiles WHERE wallet IN (${walletA}, ${walletB})`;\n171\t    await rawSql`DELETE FROM transactions WHERE wallet IN (${walletA}, ${walletB})`;\n172\t    await rawSql.end();\n173\t  });\n174\t\n175\t  beforeEach(async () => {\n176\t    // Clean per-test state\n177\t    const walletA = keypairA.publicKey.toBase58();\n178\t    const walletB = keypairB.publicKey.toBase58();\n179\t    await rawSql`TRUNCATE auth_challenges, refresh_tokens RESTART IDENTITY`;\n180\t    await rawSql`DELETE FROM player_profiles WHERE wallet IN (${walletA}, ${walletB})`;\n181\t    await rawSql`DELETE FROM transactions WHERE wallet IN (${walletA}, ${walletB})`;\n182\t    await rawSql`DELETE FROM player_points`;\n183\t\n184\t    authDb = createAuthDb(rawSql);\n185\t    db = createDb(DATABASE_URL, rawSql);\n186\t    app = new Hono();\n187\t\n188\t    // Auth routes (no middleware)\n189\t    app.route(\n190\t      \"/auth\",\n191\t      createAuthRoutes({\n192\t        authDb,\n193\t        db,\n194\t        jwtSecret: JWT_SECRET,\n195\t        cluster: \"devnet\",\n196\t        challengeTtlSeconds: 300,\n197\t        accessTokenTtlSeconds: 3600,\n198\t        refreshTokenTtlDays: 14,\n199\t      }),\n200\t    );\n201\t\n202\t    // Profile routes (JWT protected)\n203\t    app.use(\n204\t      \"/profile/*\",\n205\t      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n206\t    );\n207\t    app.route(\"/profile\", createProfileRoutes({ db }));\n208\t\n209\t    // Public profile (no auth)\n210\t    app.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n211\t  });\n212\t\n213\t  // -----------------------------------------------------------------------\n214\t  // (1) Auth creates profile automatically\n215\t  // -----------------------------------------------------------------------\n216\t\n217\t  it(\"POST /auth/verify auto-creates player_profiles row\", async () => {\n218\t    const { wallet } = await authenticateWallet(app, keypairA);\n219\t\n220\t    // Verify profile exists in DB\n221\t    const rows = await rawSql`\n222\t      SELECT user_id, wallet, username FROM player_profiles WHERE wallet = ${wallet}\n223\t    `;\n224\t    expect(rows.length).toBe(1);\n225\t    const row = rows[0]!;\n226\t    expect(row.user_id).toMatch(/^usr_[a-z0-9]{8}$/);\n227\t    expect(row.username).toMatch(/^[a-z]+-[a-z]+-\\d{4}$/);\n228\t    expect(row.wallet).toBe(wallet);\n229\t  });\n230\t\n231\t  // -----------------------------------------------------------------------\n232\t  // (2) GET /profile/me returns profile + empty stats\n233\t  // -----------------------------------------------------------------------\n234\t\n235\t  it(\"GET /profile/me returns profile with empty stats\", async () => {\n236\t    const { accessToken } = await authenticateWallet(app, keypairA);\n237\t\n238\t    const res = await app.request(\"/profile/me\", {\n239\t      method: \"GET\",\n240\t      headers: { Authorization: `Bearer ${accessToken}` },\n241\t    });\n242\t    expect(res.status).toBe(200);\n243\t    const body = (await res.json()) as Record<string, any>;\n244\t\n245\t    // Has expected fields\n246\t    expect(body.userId).toMatch(/^usr_[a-z0-9]{8}$/);\n247\t    expect(body.username).toBeDefined();\n248\t    expect(body.createdAt).toBeDefined();\n249\t    expect(body.heatMultiplier).toBe(1);\n250\t    expect(body.pointsBalance).toBe(\"0\");\n251\t    expect(body.usernameNextEditAt).toBeNull(); // first edit free\n252\t\n253\t    // Stats should be empty/zero\n254\t    const stats = body.stats as Record<string, any>;\n255\t    expect(stats.gamesPlayed).toBe(0);\n256\t    expect(stats.totalWagered).toBe(\"0\");\n257\t    expect(stats.totalWins).toBe(0);\n258\t    expect(stats.winRate).toBe(0);\n259\t    expect(stats.winStreakCurrent).toBe(0);\n260\t    expect(stats.winStreakBest).toBe(0);\n261\t    expect(stats.netPnl).toBe(\"0\");\n262\t\n263\t    // No wallet field\n264\t    expect(body).not.toHaveProperty(\"wallet\");\n265\t  });\n266\t\n267\t  it(\"GET /profile/me returns points balance from player_points\", async () => {\n268\t    const { accessToken, wallet } = await authenticateWallet(app, keypairA);\n269\t\n270\t    const initialRes = await app.request(\"/profile/me\", {\n271\t      method: \"GET\",\n272\t      headers: { Authorization: `Bearer ${accessToken}` },\n273\t    });\n274\t    expect(initialRes.status).toBe(200);\n275\t    const initialBody = (await initialRes.json()) as { userId: string; pointsBalance: string };\n276\t    expect(initialBody.pointsBalance).toBe(\"0\");\n277\t\n278\t    await rawSql`\n279\t      INSERT INTO player_points (user_id, wallet, balance, lifetime_earned)\n280\t      VALUES (${initialBody.userId}, ${wallet}, 1337, 2048)\n281\t    `;\n282\t\n283\t    const res = await app.request(\"/profile/me\", {\n284\t      method: \"GET\",\n285\t      headers: { Authorization: `Bearer ${accessToken}` },\n286\t    });\n287\t    expect(res.status).toBe(200);\n288\t\n289\t    const body = (await res.json()) as Record<string, any>;\n290\t    expect(body.pointsBalance).toBe(\"1337\");\n291\t  });\n292\t\n293\t  // -----------------------------------------------------------------------\n294\t  // (3) PUT /profile/username succeeds on first edit\n295\t  // -----------------------------------------------------------------------\n296\t\n297\t  it(\"PUT /profile/username succeeds with valid name\", async () => {\n298\t    const { accessToken } = await authenticateWallet(app, keypairA);\n299\t    const username = makeUniqueUsername(\"CoolPlayer\");\n300\t\n301\t    const res = await app.request(\"/profile/username\", {\n302\t      method: \"PUT\",\n303\t      headers: {\n304\t        Authorization: `Bearer ${accessToken}`,\n305\t        \"Content-Type\": \"application/json\",\n306\t      },\n307\t      body: JSON.stringify({ username }),\n308\t    });\n309\t    expect(res.status).toBe(200);\n310\t    const body = (await res.json()) as { username: string; nextEditAvailableAt: string };\n311\t    expect(body.username).toBe(username);\n312\t    expect(body.nextEditAvailableAt).toBeDefined();\n313\t    // nextEditAvailableAt should be ~30 days from now\n314\t    const nextEdit = new Date(body.nextEditAvailableAt).getTime();\n315\t    const thirtyDays = 30 * 24 * 60 * 60 * 1000;\n316\t    expect(nextEdit).toBeGreaterThan(Date.now() + thirtyDays - 60_000);\n317\t  });\n318\t\n319\t  // -----------------------------------------------------------------------\n320\t  // (4) PUT /profile/username again immediately → 429 cooldown\n321\t  // -----------------------------------------------------------------------\n322\t\n323\t  it(\"PUT /profile/username returns 429 on cooldown\", async () => {\n324\t    const { accessToken } = await authenticateWallet(app, keypairA);\n325\t    const firstUsername = makeUniqueUsername(\"FirstName\");\n326\t    const secondUsername = makeUniqueUsername(\"SecondName\");\n327\t\n328\t    // First edit — succeeds\n329\t    const res1 = await app.request(\"/profile/username\", {\n330\t      method: \"PUT\",\n331\t      headers: {\n332\t        Authorization: `Bearer ${accessToken}`,\n333\t        \"Content-Type\": \"application/json\",\n334\t      },\n335\t      body: JSON.stringify({ username: firstUsername }),\n336\t    });\n337\t    expect(res1.status).toBe(200);\n338\t\n339\t    // Second edit — should be blocked by cooldown\n340\t    const res2 = await app.request(\"/profile/username\", {\n341\t      method: \"PUT\",\n342\t      headers: {\n343\t        Authorization: `Bearer ${accessToken}`,\n344\t        \"Content-Type\": \"application/json\",\n345\t      },\n346\t      body: JSON.stringify({ username: secondUsername }),\n347\t    });\n348\t    expect(res2.status).toBe(429);\n349\t    const body = (await res2.json()) as { error: string; nextEditAvailableAt: string };\n350\t    expect(body.error).toBe(\"COOLDOWN_ACTIVE\");\n351\t    expect(body.nextEditAvailableAt).toBeDefined();\n352\t  });\n353\t\n354\t  // -----------------------------------------------------------------------\n355\t  // (5) PUT /profile/username with taken name → 409\n356\t  // -----------------------------------------------------------------------\n357\t\n358\t  it(\"PUT /profile/username returns 409 for taken username\", async () => {\n359\t    // Authenticate both wallets (creates profiles)\n360\t    const { accessToken: tokenA } = await authenticateWallet(app, keypairA);\n361\t    const { accessToken: tokenB } = await authenticateWallet(app, keypairB);\n362\t    const username = makeUniqueUsername(\"UniqueName\");\n363\t\n364\t    // Wallet A takes a name\n365\t    const res1 = await app.request(\"/profile/username\", {\n366\t      method: \"PUT\",\n367\t      headers: {\n368\t        Authorization: `Bearer ${tokenA}`,\n369\t        \"Content-Type\": \"application/json\",\n370\t      },\n371\t      body: JSON.stringify({ username }),\n372\t    });\n373\t    expect(res1.status).toBe(200);\n374\t\n375\t    // Wallet B tries the same name (case-insensitive)\n376\t    const res2 = await app.request(\"/profile/username\", {\n377\t      method: \"PUT\",\n378\t      headers: {\n379\t        Authorization: `Bearer ${tokenB}`,\n380\t        \"Content-Type\": \"application/json\",\n381\t      },\n382\t      body: JSON.stringify({ username: username.toLowerCase() }),\n383\t    });\n384\t    expect(res2.status).toBe(409);\n385\t    const body = (await res2.json()) as { error: string };\n386\t    expect(body.error).toBe(\"USERNAME_TAKEN\");\n387\t  });\n388\t\n389\t  // -----------------------------------------------------------------------\n390\t  // (6) GET /public-profile/:username returns limited public data\n391\t  // -----------------------------------------------------------------------\n392\t\n393\t  it(\"GET /public-profile/:username returns public profile\", async () => {\n394\t    const { accessToken } = await authenticateWallet(app, keypairA);\n395\t    const username = makeUniqueUsername(\"PublicUser\");\n396\t\n397\t    // Set a known username\n398\t    await app.request(\"/profile/username\", {\n399\t      method: \"PUT\",\n400\t      headers: {\n401\t        Authorization: `Bearer ${accessToken}`,\n402\t        \"Content-Type\": \"application/json\",\n403\t      },\n404\t      body: JSON.stringify({ username }),\n405\t    });\n406\t\n407\t    // Fetch public profile (no auth)\n408\t    const res = await app.request(`/public-profile/${username}`);\n409\t    expect(res.status).toBe(200);\n410\t    const body = (await res.json()) as Record<string, any>;\n411\t\n412\t    expect(body.userId).toMatch(/^usr_[a-z0-9]{8}$/);\n413\t    expect(body.username).toBe(username);\n414\t    expect(body.heatMultiplier).toBe(1);\n415\t    expect(body.createdAt).toBeDefined();\n416\t\n417\t    // Public stats — limited fields only\n418\t    const stats = body.stats as Record<string, any>;\n419\t    expect(stats.gamesPlayed).toBe(0);\n420\t    expect(stats.totalWins).toBe(0);\n421\t    expect(stats.winRate).toBe(0);\n422\t\n423\t    // Must NOT have private fields\n424\t    expect(body).not.toHaveProperty(\"wallet\");\n425\t    expect(body).not.toHaveProperty(\"pointsBalance\");\n426\t    expect(stats).not.toHaveProperty(\"totalWagered\");\n427\t    expect(stats).not.toHaveProperty(\"netPnl\");\n428\t    expect(stats).not.toHaveProperty(\"winStreakCurrent\");\n429\t    expect(stats).not.toHaveProperty(\"winStreakBest\");\n430\t  });\n431\t\n432\t  // -----------------------------------------------------------------------\n433\t  // (7) GET /public-profile/:user_id returns same data\n434\t  // -----------------------------------------------------------------------\n435\t\n436\t  it(\"GET /public-profile/:user_id resolves by user_id\", async () => {\n437\t    const { accessToken } = await authenticateWallet(app, keypairA);\n438\t\n439\t    // Get the userId from /profile/me\n440\t    const meRes = await app.request(\"/profile/me\", {\n441\t      method: \"GET\",\n442\t      headers: { Authorization: `Bearer ${accessToken}` },\n443\t    });\n444\t    const meBody = (await meRes.json()) as { userId: string; username: string };\n445\t    const userId = meBody.userId;\n446\t\n447\t    // Fetch via user_id\n448\t    const res = await app.request(`/public-profile/${userId}`);\n449\t    expect(res.status).toBe(200);\n450\t    const body = (await res.json()) as { userId: string; username: string };\n451\t    expect(body.userId).toBe(userId);\n452\t    expect(body.username).toBe(meBody.username);\n453\t\n454\t    // No wallet\n455\t    expect(body).not.toHaveProperty(\"wallet\");\n456\t  });\n457\t\n458\t  // -----------------------------------------------------------------------\n459\t  // (8) No wallet field in any response (additional checks)\n460\t  // -----------------------------------------------------------------------\n461\t\n462\t  it(\"no wallet field in any response\", async () => {\n463\t    const { accessToken } = await authenticateWallet(app, keypairA);\n464\t    const username = makeUniqueUsername(\"NoWalletChk\");\n465\t\n466\t    // GET /profile/me\n467\t    const meRes = await app.request(\"/profile/me\", {\n468\t      method: \"GET\",\n469\t      headers: { Authorization: `Bearer ${accessToken}` },\n470\t    });\n471\t    const meBody = await meRes.text();\n472\t    expect(meBody).not.toContain(keypairA.publicKey.toBase58());\n473\t\n474\t    // PUT /profile/username\n475\t    const putRes = await app.request(\"/profile/username\", {\n476\t      method: \"PUT\",\n477\t      headers: {\n478\t        Authorization: `Bearer ${accessToken}`,\n479\t        \"Content-Type\": \"application/json\",\n480\t      },\n481\t      body: JSON.stringify({ username }),\n482\t    });\n483\t    const putBody = await putRes.text();\n484\t    expect(putBody).not.toContain(keypairA.publicKey.toBase58());\n485\t\n486\t    // GET /public-profile\n487\t    const pubRes = await app.request(`/public-profile/${username}`);\n488\t    const pubBody = await pubRes.text();\n489\t    expect(pubBody).not.toContain(keypairA.publicKey.toBase58());\n490\t  });\n491\t\n492\t  // -----------------------------------------------------------------------\n493\t  // Edge: 404 for unknown identifier\n494\t  // -----------------------------------------------------------------------\n495\t\n496\t  it(\"GET /public-profile/:identifier returns 404 for unknown\", async () => {\n497\t    const res = await app.request(\"/public-profile/nonexistent_user\");\n498\t    expect(res.status).toBe(404);\n499\t    const body = (await res.json()) as { error: string };\n500\t    expect(body.error).toBe(\"NOT_FOUND\");\n501\t  });\n502\t\n503\t  // -----------------------------------------------------------------------\n504\t  // Edge: invalid username format\n505\t  // -----------------------------------------------------------------------\n506\t\n507\t  it(\"PUT /profile/username returns 400 for invalid format\", async () => {\n508\t    const { accessToken } = await authenticateWallet(app, keypairA);\n509\t\n510\t    const res = await app.request(\"/profile/username\", {\n511\t      method: \"PUT\",\n512\t      headers: {\n513\t        Authorization: `Bearer ${accessToken}`,\n514\t        \"Content-Type\": \"application/json\",\n515\t      },\n516\t      body: JSON.stringify({ username: \"ab\" }), // too short\n517\t    });\n518\t    expect(res.status).toBe(400);\n519\t    const body = (await res.json()) as { error: string };\n520\t    expect(body.error).toBe(\"INVALID_FORMAT\");\n521\t  });\n522\t\n523\t  it(\"PUT /profile/username returns 400 for missing body\", async () => {\n524\t    const { accessToken } = await authenticateWallet(app, keypairA);\n525\t\n526\t    const res = await app.request(\"/profile/username\", {\n527\t      method: \"PUT\",\n528\t      headers: {\n529\t        Authorization: `Bearer ${accessToken}`,\n530\t      },\n531\t    });\n532\t\n533\t    expect(res.status).toBe(400);\n534\t    const body = (await res.json()) as { error: string };\n535\t    expect(body.error).toBe(\"INVALID_FORMAT\");\n536\t  });\n537\t\n538\t  it(\"POST /profile/confirm-tx returns 400 for missing body\", async () => {\n539\t    const { accessToken } = await authenticateWallet(app, keypairA);\n540\t\n541\t    const res = await app.request(\"/profile/confirm-tx\", {\n542\t      method: \"POST\",\n543\t      headers: {\n544\t        Authorization: `Bearer ${accessToken}`,\n545\t      },\n546\t    });\n547\t\n548\t    expect(res.status).toBe(400);\n549\t    const body = (await res.json()) as { error: string };\n550\t    expect(body.error).toBe(\"Missing or invalid fields\");\n551\t  });\n552\t});\n553\t"}]},"parent_tool_use_id":null,"session_id":"c369c0ad-be87-4942-b868-52215f926351","uuid":"1a64da11-345e-4d17-a8f1-8efdd4914be4","timestamp":"2026-04-22T10:00:02.358Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/profile.test.ts","content":"/* eslint-disable @typescript-eslint/no-explicit-any */\n/**\n * Integration test for profile lifecycle:\n * auth → profile auto-created → GET /profile/me → PUT /profile/username →\n * cooldown → taken username → GET /public-profile/:identifier → no wallet leaks\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { randomUUID } from \"node:crypto\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport nacl from \"tweetnacl\";\nimport bs58 from \"bs58\";\nimport postgres from \"postgres\";\nimport { createAuthDb, type AuthDb } from \"../auth-db.js\";\nimport { createAuthRoutes } from \"../routes/auth.js\";\nimport { createProfileRoutes } from \"../routes/profile.js\";\nimport { createPublicProfileRoutes } from \"../routes/public-profile.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport { createDb, type Db } from \"../db.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"taunt_bet_dev\",\n  });\n}\n\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-profile-tests\");\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\n/** Perform challenge → sign → verify and return access token + wallet. */\nasync function authenticateWallet(\n  app: Hono,\n  keypair: Keypair,\n): Promise<{ accessToken: string; wallet: string }> {\n  const wallet = keypair.publicKey.toBase58();\n\n  // 1. Challenge\n  const challengeRes = await app.request(\"/auth/challenge\", {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ wallet }),\n  });\n  expect(challengeRes.status).toBe(200);\n  const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n\n  // 2. Sign\n  const messageBytes = new TextEncoder().encode(challenge.message);\n  const signatureBytes = nacl.sign.detached(messageBytes, keypair.secretKey);\n  const signature = bs58.encode(signatureBytes);\n\n  // 3. Verify\n  const verifyRes = await app.request(\"/auth/verify\", {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n  });\n  expect(verifyRes.status).toBe(200);\n  const tokens = (await verifyRes.json()) as { accessToken: string };\n  return { accessToken: tokens.accessToken, wallet };\n}\n\nfunction makeUniqueUsername(prefix: string): string {\n  const safePrefix = prefix.replace(/[^a-zA-Z0-9_]/g, \"\").slice(0, 12);\n  const suffix = randomUUID().replace(/-/g, \"\").slice(0, 8);\n  return `${safePrefix}${suffix}`.slice(0, 20);\n}\n\n// ---------------------------------------------------------------------------\n// Suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"Profile lifecycle integration\", () => {\n  let rawSql: ReturnType<typeof postgres>;\n  let authDb: AuthDb;\n  let db: Db;\n  let app: Hono;\n\n  const keypairA = Keypair.generate();\n  const keypairB = Keypair.generate();\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n\n    // Ensure required tables exist\n    await rawSql`DROP TABLE IF EXISTS auth_challenges, refresh_tokens`;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS auth_challenges (\n        nonce TEXT PRIMARY KEY,\n        wallet TEXT NOT NULL,\n        cluster TEXT NOT NULL DEFAULT 'devnet',\n        message TEXT NOT NULL,\n        expires_at TIMESTAMPTZ NOT NULL,\n        used BOOLEAN DEFAULT FALSE,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS refresh_tokens (\n        id BIGSERIAL PRIMARY KEY,\n        user_id TEXT NOT NULL,\n        wallet TEXT NOT NULL,\n        token_hash BYTEA NOT NULL UNIQUE,\n        family_id TEXT NOT NULL,\n        expires_at TIMESTAMPTZ NOT NULL,\n        revoked BOOLEAN DEFAULT FALSE,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS player_profiles (\n        id BIGSERIAL PRIMARY KEY,\n        user_id TEXT UNIQUE NOT NULL,\n        wallet TEXT UNIQUE NOT NULL,\n        username TEXT UNIQUE NOT NULL,\n        username_updated_at TIMESTAMPTZ,\n        avatar_url TEXT,\n        heat_multiplier NUMERIC DEFAULT 1.0,\n        points_balance BIGINT DEFAULT 0,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n    // Case-insensitive uniqueness index\n    await rawSql`\n      CREATE UNIQUE INDEX IF NOT EXISTS idx_player_profiles_username_lower\n      ON player_profiles (LOWER(username))\n    `;\n    // transactions table (needed for stats queries)\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS transactions (\n        id BIGSERIAL PRIMARY KEY,\n        wallet TEXT NOT NULL,\n        game TEXT NOT NULL,\n        match_id TEXT NOT NULL,\n        tx_type TEXT NOT NULL,\n        amount_lamports BIGINT NOT NULL,\n        tx_sig TEXT,\n        created_at TIMESTAMPTZ DEFAULT now(),\n        UNIQUE(wallet, match_id, tx_type, tx_sig)\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS player_points (\n        user_id TEXT PRIMARY KEY,\n        wallet TEXT NOT NULL UNIQUE,\n        balance BIGINT NOT NULL DEFAULT 0,\n        lifetime_earned BIGINT NOT NULL DEFAULT 0,\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n  });\n\n  afterAll(async () => {\n    // Clean up test data\n    const walletA = keypairA.publicKey.toBase58();\n    const walletB = keypairB.publicKey.toBase58();\n    await rawSql`DELETE FROM player_profiles WHERE wallet IN (${walletA}, ${walletB})`;\n    await rawSql`DELETE FROM transactions WHERE wallet IN (${walletA}, ${walletB})`;\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    // Clean per-test state\n    const walletA = keypairA.publicKey.toBase58();\n    const walletB = keypairB.publicKey.toBase58();\n    await rawSql`TRUNCATE auth_challenges, refresh_tokens RESTART IDENTITY`;\n    await rawSql`DELETE FROM player_profiles WHERE wallet IN (${walletA}, ${walletB})`;\n    await rawSql`DELETE FROM transactions WHERE wallet IN (${walletA}, ${walletB})`;\n    await rawSql`DELETE FROM player_points`;\n\n    authDb = createAuthDb(rawSql);\n    db = createDb(DATABASE_URL, rawSql);\n    app = new Hono();\n\n    // Auth routes (no middleware)\n    app.route(\n      \"/auth\",\n      createAuthRoutes({\n        authDb,\n        db,\n        jwtSecret: JWT_SECRET,\n        cluster: \"devnet\",\n        challengeTtlSeconds: 300,\n        accessTokenTtlSeconds: 3600,\n        refreshTokenTtlDays: 14,\n      }),\n    );\n\n    // Profile routes (JWT protected)\n    app.use(\n      \"/profile/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n    );\n    app.route(\"/profile\", createProfileRoutes({ db }));\n\n    // Public profile (no auth)\n    app.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n  });\n\n  // -----------------------------------------------------------------------\n  // (1) Auth creates profile automatically\n  // -----------------------------------------------------------------------\n\n  it(\"POST /auth/verify auto-creates player_profiles row\", async () => {\n    const { wallet } = await authenticateWallet(app, keypairA);\n\n    // Verify profile exists in DB\n    const rows = await rawSql`\n      SELECT user_id, wallet, username FROM player_profiles WHERE wallet = ${wallet}\n    `;\n    expect(rows.length).toBe(1);\n    const row = rows[0]!;\n    expect(row.user_id).toMatch(/^usr_[a-z0-9]{8}$/);\n    expect(row.username).toMatch(/^[a-z]+-[a-z]+-\\d{4}$/);\n    expect(row.wallet).toBe(wallet);\n  });\n\n  // -----------------------------------------------------------------------\n  // (2) GET /profile/me returns profile + empty stats\n  // -----------------------------------------------------------------------\n\n  it(\"GET /profile/me returns profile with empty stats\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/me\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${accessToken}` },\n    });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n\n    // Has expected fields\n    expect(body.userId).toMatch(/^usr_[a-z0-9]{8}$/);\n    expect(body.username).toBeDefined();\n    expect(body.createdAt).toBeDefined();\n    expect(body.heatMultiplier).toBe(1);\n    expect(body.pointsBalance).toBe(\"0\");\n    expect(body.usernameNextEditAt).toBeNull(); // first edit free\n\n    // Stats should be empty/zero\n    const stats = body.stats as Record<string, any>;\n    expect(stats.gamesPlayed).toBe(0);\n    expect(stats.totalWagered).toBe(\"0\");\n    expect(stats.totalWins).toBe(0);\n    expect(stats.winRate).toBe(0);\n    expect(stats.winStreakCurrent).toBe(0);\n    expect(stats.winStreakBest).toBe(0);\n    expect(stats.netPnl).toBe(\"0\");\n\n    // No wallet field\n    expect(body).not.toHaveProperty(\"wallet\");\n  });\n\n  it(\"GET /profile/me returns points balance from player_points\", async () => {\n    const { accessToken, wallet } = await authenticateWallet(app, keypairA);\n\n    const initialRes = await app.request(\"/profile/me\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${accessToken}` },\n    });\n    expect(initialRes.status).toBe(200);\n    const initialBody = (await initialRes.json()) as { userId: string; pointsBalance: string };\n    expect(initialBody.pointsBalance).toBe(\"0\");\n\n    await rawSql`\n      INSERT INTO player_points (user_id, wallet, balance, lifetime_earned)\n      VALUES (${initialBody.userId}, ${wallet}, 1337, 2048)\n    `;\n\n    const res = await app.request(\"/profile/me\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${accessToken}` },\n    });\n    expect(res.status).toBe(200);\n\n    const body = (await res.json()) as Record<string, any>;\n    expect(body.pointsBalance).toBe(\"1337\");\n  });\n\n  // -----------------------------------------------------------------------\n  // (3) PUT /profile/username succeeds on first edit\n  // -----------------------------------------------------------------------\n\n  it(\"PUT /profile/username succeeds with valid name\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n    const username = makeUniqueUsername(\"CoolPlayer\");\n\n    const res = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username }),\n    });\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as { username: string; nextEditAvailableAt: string };\n    expect(body.username).toBe(username);\n    expect(body.nextEditAvailableAt).toBeDefined();\n    // nextEditAvailableAt should be ~30 days from now\n    const nextEdit = new Date(body.nextEditAvailableAt).getTime();\n    const thirtyDays = 30 * 24 * 60 * 60 * 1000;\n    expect(nextEdit).toBeGreaterThan(Date.now() + thirtyDays - 60_000);\n  });\n\n  // -----------------------------------------------------------------------\n  // (4) PUT /profile/username again immediately → 429 cooldown\n  // -----------------------------------------------------------------------\n\n  it(\"PUT /profile/username returns 429 on cooldown\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n    const firstUsername = makeUniqueUsername(\"FirstName\");\n    const secondUsername = makeUniqueUsername(\"SecondName\");\n\n    // First edit — succeeds\n    const res1 = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: firstUsername }),\n    });\n    expect(res1.status).toBe(200);\n\n    // Second edit — should be blocked by cooldown\n    const res2 = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: secondUsername }),\n    });\n    expect(res2.status).toBe(429);\n    const body = (await res2.json()) as { error: string; nextEditAvailableAt: string };\n    expect(body.error).toBe(\"COOLDOWN_ACTIVE\");\n    expect(body.nextEditAvailableAt).toBeDefined();\n  });\n\n  // -----------------------------------------------------------------------\n  // (5) PUT /profile/username with taken name → 409\n  // -----------------------------------------------------------------------\n\n  it(\"PUT /profile/username returns 409 for taken username\", async () => {\n    // Authenticate both wallets (creates profiles)\n    const { accessToken: tokenA } = await authenticateWallet(app, keypairA);\n    const { accessToken: tokenB } = await authenticateWallet(app, keypairB);\n    const username = makeUniqueUsername(\"UniqueName\");\n\n    // Wallet A takes a name\n    const res1 = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${tokenA}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username }),\n    });\n    expect(res1.status).toBe(200);\n\n    // Wallet B tries the same name (case-insensitive)\n    const res2 = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${tokenB}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: username.toLowerCase() }),\n    });\n    expect(res2.status).toBe(409);\n    const body = (await res2.json()) as { error: string };\n    expect(body.error).toBe(\"USERNAME_TAKEN\");\n  });\n\n  // -----------------------------------------------------------------------\n  // (6) GET /public-profile/:username returns limited public data\n  // -----------------------------------------------------------------------\n\n  it(\"GET /public-profile/:username returns public profile\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n    const username = makeUniqueUsername(\"PublicUser\");\n\n    // Set a known username\n    await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username }),\n    });\n\n    // Fetch public profile (no auth)\n    const res = await app.request(`/public-profile/${username}`);\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n\n    expect(body.userId).toMatch(/^usr_[a-z0-9]{8}$/);\n    expect(body.username).toBe(username);\n    expect(body.heatMultiplier).toBe(1);\n    expect(body.createdAt).toBeDefined();\n\n    // Public stats — limited fields only\n    const stats = body.stats as Record<string, any>;\n    expect(stats.gamesPlayed).toBe(0);\n    expect(stats.totalWins).toBe(0);\n    expect(stats.winRate).toBe(0);\n\n    // Must NOT have private fields\n    expect(body).not.toHaveProperty(\"wallet\");\n    expect(body).not.toHaveProperty(\"pointsBalance\");\n    expect(stats).not.toHaveProperty(\"totalWagered\");\n    expect(stats).not.toHaveProperty(\"netPnl\");\n    expect(stats).not.toHaveProperty(\"winStreakCurrent\");\n    expect(stats).not.toHaveProperty(\"winStreakBest\");\n  });\n\n  // -----------------------------------------------------------------------\n  // (7) GET /public-profile/:user_id returns same data\n  // -----------------------------------------------------------------------\n\n  it(\"GET /public-profile/:user_id resolves by user_id\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    // Get the userId from /profile/me\n    const meRes = await app.request(\"/profile/me\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${accessToken}` },\n    });\n    const meBody = (await meRes.json()) as { userId: string; username: string };\n    const userId = meBody.userId;\n\n    // Fetch via user_id\n    const res = await app.request(`/public-profile/${userId}`);\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as { userId: string; username: string };\n    expect(body.userId).toBe(userId);\n    expect(body.username).toBe(meBody.username);\n\n    // No wallet\n    expect(body).not.toHaveProperty(\"wallet\");\n  });\n\n  // -----------------------------------------------------------------------\n  // (8) No wallet field in any response (additional checks)\n  // -----------------------------------------------------------------------\n\n  it(\"no wallet field in any response\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n    const username = makeUniqueUsername(\"NoWalletChk\");\n\n    // GET /profile/me\n    const meRes = await app.request(\"/profile/me\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${accessToken}` },\n    });\n    const meBody = await meRes.text();\n    expect(meBody).not.toContain(keypairA.publicKey.toBase58());\n\n    // PUT /profile/username\n    const putRes = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username }),\n    });\n    const putBody = await putRes.text();\n    expect(putBody).not.toContain(keypairA.publicKey.toBase58());\n\n    // GET /public-profile\n    const pubRes = await app.request(`/public-profile/${username}`);\n    const pubBody = await pubRes.text();\n    expect(pubBody).not.toContain(keypairA.publicKey.toBase58());\n  });\n\n  // -----------------------------------------------------------------------\n  // Edge: 404 for unknown identifier\n  // -----------------------------------------------------------------------\n\n  it(\"GET /public-profile/:identifier returns 404 for unknown\", async () => {\n    const res = await app.request(\"/public-profile/nonexistent_user\");\n    expect(res.status).toBe(404);\n    const body = (await res.json()) as { error: string };\n    expect(body.error).toBe(\"NOT_FOUND\");\n  });\n\n  // -----------------------------------------------------------------------\n  // Edge: invalid username format\n  // -----------------------------------------------------------------------\n\n  it(\"PUT /profile/username returns 400 for invalid format\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: \"ab\" }), // too short\n    });\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as { error: string };\n    expect(body.error).toBe(\"INVALID_FORMAT\");\n  });\n\n  it(\"PUT /profile/username returns 400 for missing body\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n      },\n    });\n\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as { error: string };\n    expect(body.error).toBe(\"INVALID_FORMAT\");\n  });\n\n  it(\"POST /profile/confirm-tx returns 400 for missing body\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/confirm-tx\", {\n      method: \"POST\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n      },\n    });\n\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as { error: string };\n    expect(body.error).toBe(\"Missing or invalid fields\");\n  });\n});\n","numLines":553,"startLine":1,"totalLines":553}}}
