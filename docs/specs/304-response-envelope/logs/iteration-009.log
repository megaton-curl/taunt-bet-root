{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EH9wSg6VqXwYQKvheL31Sb","type":"tool_result","content":"1\t/**\n2\t * OpenAPI contract validation — ensures the auto-generated spec is\n3\t * structurally sound, has expected paths, and every response has a description.\n4\t *\n5\t * Fetches the spec from the app's /openapi.json endpoint (auto-generated\n6\t * by @hono/zod-openapi) rather than importing a static object.\n7\t *\n8\t * Runs without a database — uses the Hono test client.\n9\t */\n10\t\n11\timport { describe, expect, it, beforeAll } from \"vitest\";\n12\timport { OpenAPIHono } from \"@hono/zod-openapi\";\n13\timport { Keypair } from \"@solana/web3.js\";\n14\t\n15\t// Import route factories that DON'T need real deps (we only need the spec)\n16\t// We build a minimal app that generates the same spec as the real one.\n17\t// Instead, we import the real app's index module indirectly by constructing\n18\t// a minimal OpenAPIHono that only has the doc endpoint.\n19\t//\n20\t// Actually, the simplest approach: import the real app and hit /openapi.json.\n21\t// But the real app needs DB, connection, etc. So we build a test app with\n22\t// the same route structure.\n23\t//\n24\t// Simplest viable approach: just import a few route factories and check\n25\t// the spec they generate.\n26\t\n27\ttype AnyRecord = Record<string, unknown>;\n28\t\n29\t/** Recursively collect all \"$ref\" strings from the spec. */\n30\tfunction collectRefs(obj: unknown): string[] {\n31\t  const refs: string[] = [];\n32\t  function walk(value: unknown) {\n33\t    if (Array.isArray(value)) {\n34\t      value.forEach(walk);\n35\t    } else if (value && typeof value === \"object\") {\n36\t      const record = value as AnyRecord;\n37\t      if (typeof record.$ref === \"string\") {\n38\t        refs.push(record.$ref);\n39\t      }\n40\t      Object.values(record).forEach(walk);\n41\t    }\n42\t  }\n43\t  walk(obj);\n44\t  return refs;\n45\t}\n46\t\n47\tconst VALID_METHODS = new Set([\n48\t  \"get\", \"post\", \"put\", \"delete\", \"patch\", \"options\", \"head\",\n49\t]);\n50\t\n51\t// We need to construct a minimal app to generate the spec. Import route\n52\t// factories that don't need heavy deps (health, price, leaderboard).\n53\timport { createHealthRoutes } from \"../routes/health.js\";\n54\timport { createPriceRoutes } from \"../routes/price.js\";\n55\timport { createLeaderboardRoutes } from \"../routes/leaderboard.js\";\n56\timport { createProfileRoutes } from \"../routes/profile.js\";\n57\timport { createFlipYouRoutes } from \"../routes/create.js\";\n58\timport { createPotShotRoutes } from \"../routes/potshot-create.js\";\n59\timport { createCloseCallRoutes } from \"../routes/closecall.js\";\n60\t\n61\tfunction resolveSchema(spec: AnyRecord, schema: unknown): AnyRecord {\n62\t  const record = schema as AnyRecord;\n63\t\n64\t  if (typeof record?.$ref === \"string\") {\n65\t    const path = record.$ref.replace(/^#\\//, \"\").split(\"/\");\n66\t    let current: unknown = spec;\n67\t    for (const segment of path) {\n68\t      current = (current as AnyRecord)?.[segment];\n69\t    }\n70\t    return resolveSchema(spec, current);\n71\t  }\n72\t\n73\t  if (Array.isArray(record?.allOf) && record.allOf.length > 0) {\n74\t    return resolveSchema(spec, record.allOf[0]);\n75\t  }\n76\t\n77\t  if (Array.isArray(record?.anyOf)) {\n78\t    const concrete = record.anyOf.find((item) => {\n79\t      const candidate = item as AnyRecord;\n80\t      return typeof candidate?.$ref === \"string\" || candidate?.type === \"object\";\n81\t    });\n82\t    if (concrete) {\n83\t      return resolveSchema(spec, concrete);\n84\t    }\n85\t  }\n86\t\n87\t  return record;\n88\t}\n89\t\n90\tfunction getJsonResponseSchema(\n91\t  spec: AnyRecord,\n92\t  path: string,\n93\t  method: string,\n94\t  status: string,\n95\t): AnyRecord {\n96\t  const paths = spec.paths as AnyRecord;\n97\t  const operations = paths[path] as AnyRecord | undefined;\n98\t  const operation = operations?.[method] as AnyRecord | undefined;\n99\t  const responses = operation?.responses as AnyRecord | undefined;\n100\t  const content = (responses?.[status] as AnyRecord | undefined)?.content as AnyRecord | undefined;\n101\t  return resolveSchema(\n102\t    spec,\n103\t    (content?.[\"application/json\"] as AnyRecord | undefined)?.schema,\n104\t  );\n105\t}\n106\t\n107\tfunction buildSpecApp() {\n108\t  const app = new OpenAPIHono();\n109\t  const serverKeypair = Keypair.generate();\n110\t\n111\t  // Stub DB that satisfies the interface minimally — only used for spec generation, never called\n112\t  /* eslint-disable @typescript-eslint/no-explicit-any */\n113\t  const stubDb = new Proxy({} as any, {\n114\t    get: () => async () => ({ count: 0, oldestAgeSeconds: 0 }),\n115\t  });\n116\t  app.route(\"/health\", createHealthRoutes({ isWorkerRunning: () => true }));\n117\t  /* eslint-enable @typescript-eslint/no-explicit-any */\n118\t  app.route(\"/price\", createPriceRoutes());\n119\t  app.route(\"/leaderboard\", createLeaderboardRoutes({ db: stubDb }));\n120\t  app.route(\"/profile\", createProfileRoutes({ db: stubDb }));\n121\t  app.route(\n122\t    \"/flip-you\",\n123\t    createFlipYouRoutes({\n124\t      db: stubDb,\n125\t      connection: {} as never,\n126\t      serverKeypair,\n127\t      pdaWatcher: { watch: () => undefined } as never,\n128\t    }),\n129\t  );\n130\t  app.route(\n131\t    \"/pot-shot\",\n132\t    createPotShotRoutes({\n133\t      db: stubDb,\n134\t      connection: {} as never,\n135\t      serverKeypair,\n136\t      pdaWatcher: { watch: () => undefined } as never,\n137\t    }),\n138\t  );\n139\t  app.route(\n140\t    \"/closecall\",\n141\t    createCloseCallRoutes({\n142\t      db: stubDb,\n143\t      connection: {} as never,\n144\t      serverKeypair,\n145\t      clockWorker: { getLatestBoundaryPrice: () => null } as never,\n146\t    }),\n147\t  );\n148\t\n149\t  app.openAPIRegistry.registerComponent(\"securitySchemes\", \"bearerAuth\", {\n150\t    type: \"http\",\n151\t    scheme: \"bearer\",\n152\t    bearerFormat: \"JWT\",\n153\t  });\n154\t\n155\t  app.doc(\"/openapi.json\", {\n156\t    openapi: \"3.0.3\",\n157\t    info: { title: \"Taunt Bet API\", version: \"0.1.0\" },\n158\t  });\n159\t\n160\t  return app;\n161\t}\n162\t\n163\tdescribe(\"OpenAPI contract (auto-generated)\", () => {\n164\t  let spec: AnyRecord;\n165\t\n166\t  beforeAll(async () => {\n167\t    const app = buildSpecApp();\n168\t    const res = await app.request(\"/openapi.json\");\n169\t    expect(res.status).toBe(200);\n170\t    spec = (await res.json()) as AnyRecord;\n171\t  });\n172\t\n173\t  it(\"is a valid OpenAPI 3.0.3 document\", () => {\n174\t    expect(spec.openapi).toBe(\"3.0.3\");\n175\t    expect(spec.info).toBeDefined();\n176\t    expect((spec.info as AnyRecord).title).toBeTruthy();\n177\t    const paths = spec.paths as AnyRecord;\n178\t    expect(Object.keys(paths).length).toBeGreaterThan(0);\n179\t  });\n180\t\n181\t  it(\"auto-generated spec contains expected paths\", () => {\n182\t    const paths = Object.keys(spec.paths as AnyRecord);\n183\t    // Spot-check a few expected endpoints from the mounted routes\n184\t    expect(paths).toContain(\"/health\");\n185\t    expect(paths).toContain(\"/price/sol-usd\");\n186\t    expect(paths).toContain(\"/leaderboard/weekly\");\n187\t    expect(paths).toContain(\"/profile/me\");\n188\t    expect(paths).toContain(\"/flip-you/verify/{pda}\");\n189\t    expect(paths).toContain(\"/pot-shot/current\");\n190\t    expect(paths).toContain(\"/closecall/by-id/{roundId}\");\n191\t  });\n192\t\n193\t  it(\"does not declare bearer auth globally\", () => {\n194\t    expect(spec.security).toBeUndefined();\n195\t  });\n196\t\n197\t  it(\"keeps public routes public and protected routes protected\", () => {\n198\t    const paths = spec.paths as Record<string, AnyRecord>;\n199\t    expect((paths[\"/health\"]?.get as AnyRecord | undefined)?.security).toBeUndefined();\n200\t    expect((paths[\"/price/sol-usd\"]?.get as AnyRecord | undefined)?.security).toBeUndefined();\n201\t    expect((paths[\"/profile/me\"]?.get as AnyRecord | undefined)?.security).toEqual([\n202\t      { bearerAuth: [] },\n203\t    ]);\n204\t  });\n205\t\n206\t  it(\"documents round endpoints with concrete field schemas\", () => {\n207\t    const flipVerifySchema = getJsonResponseSchema(spec, \"/flip-you/verify/{pda}\", \"get\", \"200\");\n208\t    const flipEntriesSchema = resolveSchema(\n209\t      spec,\n210\t      ((flipVerifySchema.properties as AnyRecord).entries as AnyRecord)?.items,\n211\t    );\n212\t    expect((flipVerifySchema.properties as AnyRecord).matchId).toBeDefined();\n213\t    expect((flipVerifySchema.properties as AnyRecord).verification).toBeDefined();\n214\t    expect((flipEntriesSchema.properties as AnyRecord).player).toBeDefined();\n215\t    expect((flipEntriesSchema.properties as AnyRecord).amountLamports).toBeDefined();\n216\t\n217\t    const potCurrentEnvelope = getJsonResponseSchema(spec, \"/pot-shot/current\", \"get\", \"200\");\n218\t    const potCurrentSchema = resolveSchema(\n219\t      spec,\n220\t      (potCurrentEnvelope.properties as AnyRecord).round,\n221\t    );\n222\t    expect((potCurrentSchema.properties as AnyRecord).entries).toBeDefined();\n223\t    expect((potCurrentSchema.properties as AnyRecord).countdownEndsAt).toBeDefined();\n224\t\n225\t    const closeByIdSchema = getJsonResponseSchema(spec, \"/closecall/by-id/{roundId}\", \"get\", \"200\");\n226\t    const closeEntrySchema = resolveSchema(\n227\t      spec,\n228\t      ((closeByIdSchema.properties as AnyRecord).greenEntries as AnyRecord)?.items,\n229\t    );\n230\t    expect((closeByIdSchema.properties as AnyRecord).game).toBeDefined();\n231\t    expect((closeByIdSchema.properties as AnyRecord).verification).toBeDefined();\n232\t    expect((closeEntrySchema.properties as AnyRecord).player).toBeDefined();\n233\t    expect((closeEntrySchema.properties as AnyRecord).amountLamports).toBeDefined();\n234\t  });\n235\t\n236\t  it(\"all $ref references resolve\", () => {\n237\t    const refs = collectRefs(spec);\n238\t    // Collect all schema names (may be empty if no $refs are used)\n239\t    const schemas = (spec.components as AnyRecord)?.schemas as AnyRecord | undefined;\n240\t    const schemaNames = new Set(schemas ? Object.keys(schemas) : []);\n241\t\n242\t    const unresolved: string[] = [];\n243\t    for (const ref of refs) {\n244\t      const match = ref.match(/^#\\/components\\/schemas\\/(.+)$/);\n245\t      if (match?.[1] && !schemaNames.has(match[1])) {\n246\t        unresolved.push(ref);\n247\t      }\n248\t    }\n249\t\n250\t    expect(unresolved, `Unresolved $ref(s): ${unresolved.join(\", \")}`).toHaveLength(0);\n251\t  });\n252\t\n253\t  it(\"every path uses only valid HTTP methods\", () => {\n254\t    const invalid: string[] = [];\n255\t    for (const [path, methods] of Object.entries(spec.paths as AnyRecord)) {\n256\t      for (const method of Object.keys(methods as AnyRecord)) {\n257\t        if (!VALID_METHODS.has(method)) {\n258\t          invalid.push(`${method.toUpperCase()} ${path}`);\n259\t        }\n260\t      }\n261\t    }\n262\t\n263\t    expect(invalid, `Invalid methods: ${invalid.join(\", \")}`).toHaveLength(0);\n264\t  });\n265\t\n266\t  it(\"every response has a description\", () => {\n267\t    const missing: string[] = [];\n268\t    for (const [path, methods] of Object.entries(spec.paths as AnyRecord)) {\n269\t      for (const [method, operation] of Object.entries(methods as AnyRecord)) {\n270\t        const op = operation as AnyRecord;\n271\t        const responses = op.responses as AnyRecord | undefined;\n272\t        if (!responses) continue;\n273\t        for (const [status, response] of Object.entries(responses)) {\n274\t          const res = response as AnyRecord;\n275\t          if (!res.description) {\n276\t            missing.push(`${method.toUpperCase()} ${path} → ${status}`);\n277\t          }\n278\t        }\n279\t      }\n280\t    }\n281\t\n282\t    expect(missing, `Responses missing description:\\n${missing.join(\"\\n\")}`).toHaveLength(0);\n283\t  });\n284\t});\n285\t"}]},"parent_tool_use_id":null,"session_id":"c369c0ad-be87-4942-b868-52215f926351","uuid":"eb7b6ed4-1c20-40fc-b4b0-a10ff18143e4","timestamp":"2026-04-22T10:03:25.767Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/openapi-contract.test.ts","content":"/**\n * OpenAPI contract validation — ensures the auto-generated spec is\n * structurally sound, has expected paths, and every response has a description.\n *\n * Fetches the spec from the app's /openapi.json endpoint (auto-generated\n * by @hono/zod-openapi) rather than importing a static object.\n *\n * Runs without a database — uses the Hono test client.\n */\n\nimport { describe, expect, it, beforeAll } from \"vitest\";\nimport { OpenAPIHono } from \"@hono/zod-openapi\";\nimport { Keypair } from \"@solana/web3.js\";\n\n// Import route factories that DON'T need real deps (we only need the spec)\n// We build a minimal app that generates the same spec as the real one.\n// Instead, we import the real app's index module indirectly by constructing\n// a minimal OpenAPIHono that only has the doc endpoint.\n//\n// Actually, the simplest approach: import the real app and hit /openapi.json.\n// But the real app needs DB, connection, etc. So we build a test app with\n// the same route structure.\n//\n// Simplest viable approach: just import a few route factories and check\n// the spec they generate.\n\ntype AnyRecord = Record<string, unknown>;\n\n/** Recursively collect all \"$ref\" strings from the spec. */\nfunction collectRefs(obj: unknown): string[] {\n  const refs: string[] = [];\n  function walk(value: unknown) {\n    if (Array.isArray(value)) {\n      value.forEach(walk);\n    } else if (value && typeof value === \"object\") {\n      const record = value as AnyRecord;\n      if (typeof record.$ref === \"string\") {\n        refs.push(record.$ref);\n      }\n      Object.values(record).forEach(walk);\n    }\n  }\n  walk(obj);\n  return refs;\n}\n\nconst VALID_METHODS = new Set([\n  \"get\", \"post\", \"put\", \"delete\", \"patch\", \"options\", \"head\",\n]);\n\n// We need to construct a minimal app to generate the spec. Import route\n// factories that don't need heavy deps (health, price, leaderboard).\nimport { createHealthRoutes } from \"../routes/health.js\";\nimport { createPriceRoutes } from \"../routes/price.js\";\nimport { createLeaderboardRoutes } from \"../routes/leaderboard.js\";\nimport { createProfileRoutes } from \"../routes/profile.js\";\nimport { createFlipYouRoutes } from \"../routes/create.js\";\nimport { createPotShotRoutes } from \"../routes/potshot-create.js\";\nimport { createCloseCallRoutes } from \"../routes/closecall.js\";\n\nfunction resolveSchema(spec: AnyRecord, schema: unknown): AnyRecord {\n  const record = schema as AnyRecord;\n\n  if (typeof record?.$ref === \"string\") {\n    const path = record.$ref.replace(/^#\\//, \"\").split(\"/\");\n    let current: unknown = spec;\n    for (const segment of path) {\n      current = (current as AnyRecord)?.[segment];\n    }\n    return resolveSchema(spec, current);\n  }\n\n  if (Array.isArray(record?.allOf) && record.allOf.length > 0) {\n    return resolveSchema(spec, record.allOf[0]);\n  }\n\n  if (Array.isArray(record?.anyOf)) {\n    const concrete = record.anyOf.find((item) => {\n      const candidate = item as AnyRecord;\n      return typeof candidate?.$ref === \"string\" || candidate?.type === \"object\";\n    });\n    if (concrete) {\n      return resolveSchema(spec, concrete);\n    }\n  }\n\n  return record;\n}\n\nfunction getJsonResponseSchema(\n  spec: AnyRecord,\n  path: string,\n  method: string,\n  status: string,\n): AnyRecord {\n  const paths = spec.paths as AnyRecord;\n  const operations = paths[path] as AnyRecord | undefined;\n  const operation = operations?.[method] as AnyRecord | undefined;\n  const responses = operation?.responses as AnyRecord | undefined;\n  const content = (responses?.[status] as AnyRecord | undefined)?.content as AnyRecord | undefined;\n  return resolveSchema(\n    spec,\n    (content?.[\"application/json\"] as AnyRecord | undefined)?.schema,\n  );\n}\n\nfunction buildSpecApp() {\n  const app = new OpenAPIHono();\n  const serverKeypair = Keypair.generate();\n\n  // Stub DB that satisfies the interface minimally — only used for spec generation, never called\n  /* eslint-disable @typescript-eslint/no-explicit-any */\n  const stubDb = new Proxy({} as any, {\n    get: () => async () => ({ count: 0, oldestAgeSeconds: 0 }),\n  });\n  app.route(\"/health\", createHealthRoutes({ isWorkerRunning: () => true }));\n  /* eslint-enable @typescript-eslint/no-explicit-any */\n  app.route(\"/price\", createPriceRoutes());\n  app.route(\"/leaderboard\", createLeaderboardRoutes({ db: stubDb }));\n  app.route(\"/profile\", createProfileRoutes({ db: stubDb }));\n  app.route(\n    \"/flip-you\",\n    createFlipYouRoutes({\n      db: stubDb,\n      connection: {} as never,\n      serverKeypair,\n      pdaWatcher: { watch: () => undefined } as never,\n    }),\n  );\n  app.route(\n    \"/pot-shot\",\n    createPotShotRoutes({\n      db: stubDb,\n      connection: {} as never,\n      serverKeypair,\n      pdaWatcher: { watch: () => undefined } as never,\n    }),\n  );\n  app.route(\n    \"/closecall\",\n    createCloseCallRoutes({\n      db: stubDb,\n      connection: {} as never,\n      serverKeypair,\n      clockWorker: { getLatestBoundaryPrice: () => null } as never,\n    }),\n  );\n\n  app.openAPIRegistry.registerComponent(\"securitySchemes\", \"bearerAuth\", {\n    type: \"http\",\n    scheme: \"bearer\",\n    bearerFormat: \"JWT\",\n  });\n\n  app.doc(\"/openapi.json\", {\n    openapi: \"3.0.3\",\n    info: { title: \"Taunt Bet API\", version: \"0.1.0\" },\n  });\n\n  return app;\n}\n\ndescribe(\"OpenAPI contract (auto-generated)\", () => {\n  let spec: AnyRecord;\n\n  beforeAll(async () => {\n    const app = buildSpecApp();\n    const res = await app.request(\"/openapi.json\");\n    expect(res.status).toBe(200);\n    spec = (await res.json()) as AnyRecord;\n  });\n\n  it(\"is a valid OpenAPI 3.0.3 document\", () => {\n    expect(spec.openapi).toBe(\"3.0.3\");\n    expect(spec.info).toBeDefined();\n    expect((spec.info as AnyRecord).title).toBeTruthy();\n    const paths = spec.paths as AnyRecord;\n    expect(Object.keys(paths).length).toBeGreaterThan(0);\n  });\n\n  it(\"auto-generated spec contains expected paths\", () => {\n    const paths = Object.keys(spec.paths as AnyRecord);\n    // Spot-check a few expected endpoints from the mounted routes\n    expect(paths).toContain(\"/health\");\n    expect(paths).toContain(\"/price/sol-usd\");\n    expect(paths).toContain(\"/leaderboard/weekly\");\n    expect(paths).toContain(\"/profile/me\");\n    expect(paths).toContain(\"/flip-you/verify/{pda}\");\n    expect(paths).toContain(\"/pot-shot/current\");\n    expect(paths).toContain(\"/closecall/by-id/{roundId}\");\n  });\n\n  it(\"does not declare bearer auth globally\", () => {\n    expect(spec.security).toBeUndefined();\n  });\n\n  it(\"keeps public routes public and protected routes protected\", () => {\n    const paths = spec.paths as Record<string, AnyRecord>;\n    expect((paths[\"/health\"]?.get as AnyRecord | undefined)?.security).toBeUndefined();\n    expect((paths[\"/price/sol-usd\"]?.get as AnyRecord | undefined)?.security).toBeUndefined();\n    expect((paths[\"/profile/me\"]?.get as AnyRecord | undefined)?.security).toEqual([\n      { bearerAuth: [] },\n    ]);\n  });\n\n  it(\"documents round endpoints with concrete field schemas\", () => {\n    const flipVerifySchema = getJsonResponseSchema(spec, \"/flip-you/verify/{pda}\", \"get\", \"200\");\n    const flipEntriesSchema = resolveSchema(\n      spec,\n      ((flipVerifySchema.properties as AnyRecord).entries as AnyRecord)?.items,\n    );\n    expect((flipVerifySchema.properties as AnyRecord).matchId).toBeDefined();\n    expect((flipVerifySchema.properties as AnyRecord).verification).toBeDefined();\n    expect((flipEntriesSchema.properties as AnyRecord).player).toBeDefined();\n    expect((flipEntriesSchema.properties as AnyRecord).amountLamports).toBeDefined();\n\n    const potCurrentEnvelope = getJsonResponseSchema(spec, \"/pot-shot/current\", \"get\", \"200\");\n    const potCurrentSchema = resolveSchema(\n      spec,\n      (potCurrentEnvelope.properties as AnyRecord).round,\n    );\n    expect((potCurrentSchema.properties as AnyRecord).entries).toBeDefined();\n    expect((potCurrentSchema.properties as AnyRecord).countdownEndsAt).toBeDefined();\n\n    const closeByIdSchema = getJsonResponseSchema(spec, \"/closecall/by-id/{roundId}\", \"get\", \"200\");\n    const closeEntrySchema = resolveSchema(\n      spec,\n      ((closeByIdSchema.properties as AnyRecord).greenEntries as AnyRecord)?.items,\n    );\n    expect((closeByIdSchema.properties as AnyRecord).game).toBeDefined();\n    expect((closeByIdSchema.properties as AnyRecord).verification).toBeDefined();\n    expect((closeEntrySchema.properties as AnyRecord).player).toBeDefined();\n    expect((closeEntrySchema.properties as AnyRecord).amountLamports).toBeDefined();\n  });\n\n  it(\"all $ref references resolve\", () => {\n    const refs = collectRefs(spec);\n    // Collect all schema names (may be empty if no $refs are used)\n    const schemas = (spec.components as AnyRecord)?.schemas as AnyRecord | undefined;\n    const schemaNames = new Set(schemas ? Object.keys(schemas) : []);\n\n    const unresolved: string[] = [];\n    for (const ref of refs) {\n      const match = ref.match(/^#\\/components\\/schemas\\/(.+)$/);\n      if (match?.[1] && !schemaNames.has(match[1])) {\n        unresolved.push(ref);\n      }\n    }\n\n    expect(unresolved, `Unresolved $ref(s): ${unresolved.join(\", \")}`).toHaveLength(0);\n  });\n\n  it(\"every path uses only valid HTTP methods\", () => {\n    const invalid: string[] = [];\n    for (const [path, methods] of Object.entries(spec.paths as AnyRecord)) {\n      for (const method of Object.keys(methods as AnyRecord)) {\n        if (!VALID_METHODS.has(method)) {\n          invalid.push(`${method.toUpperCase()} ${path}`);\n        }\n      }\n    }\n\n    expect(invalid, `Invalid methods: ${invalid.join(\", \")}`).toHaveLength(0);\n  });\n\n  it(\"every response has a description\", () => {\n    const missing: string[] = [];\n    for (const [path, methods] of Object.entries(spec.paths as AnyRecord)) {\n      for (const [method, operation] of Object.entries(methods as AnyRecord)) {\n        const op = operation as AnyRecord;\n        const responses = op.responses as AnyRecord | undefined;\n        if (!responses) continue;\n        for (const [status, response] of Object.entries(responses)) {\n          const res = response as AnyRecord;\n          if (!res.description) {\n            missing.push(`${method.toUpperCase()} ${path} → ${status}`);\n          }\n        }\n      }\n    }\n\n    expect(missing, `Responses missing description:\\n${missing.join(\"\\n\")}`).toHaveLength(0);\n  });\n});\n","numLines":285,"startLine":1,"totalLines":285}}}
