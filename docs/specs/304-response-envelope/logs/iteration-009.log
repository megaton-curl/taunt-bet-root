veLink,\n    });\n\n    const token = await makeJwt(\"usr_zeroed\");\n    const res = await app.request(\"/profile/me\", {\n      method: \"GET\",\n      headers: {\n        Authorization: `Bearer ${token}`,\n      },\n    });\n\n    expect(res.status).toBe(200);\n    expect(await res.json()).toMatchObject({\n      userId: \"usr_zeroed\",\n      username: \"zeroed-user\",\n      pointsBalance: \"0\",\n      telegramLinked: false,\n      stats: {\n        gamesPlayed: 0,\n        totalWagered: \"0\",\n        totalWins: 0,\n        winRate: 0,\n        winStreakCurrent: 0,\n        winStreakBest: 0,\n        netPnl: \"0\",\n        gameBreakdown: {},\n      },\n    });\n    expect(getPlayerStatsByUserId).not.toHaveBeenCalled();\n    expect(getWinStreaksByUserId).not.toHaveBeenCalled();\n    expect(getGameBreakdownByUserId).not.toHaveBeenCalled();\n    expect(rawSql).toHaveBeenCalledTimes(1);\n    expect(getActiveLink).toHaveBeenCalledWith(\"usr_zeroed\");\n  });\n});\n","numLines":92,"startLine":1,"totalLines":92}}}
