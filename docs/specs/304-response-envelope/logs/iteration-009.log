* eslint-disable @typescript-eslint/no-explicit-any */\n/**\n * Integration test for profile lifecycle:\n * auth → profile auto-created → GET /profile/me → PUT /profile/username →\n * cooldown → taken username → GET /public-profile/:identifier → no wallet leaks\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { randomUUID } from \"node:crypto\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport nacl from \"tweetnacl\";\nimport bs58 from \"bs58\";\nimport postgres from \"postgres\";\nimport { createAuthDb, type AuthDb } from \"../auth-db.js\";\nimport { createAuthRoutes } from \"../routes/auth.js\";\nimport { createProfileRoutes } from \"../routes/profile.js\";\nimport { createPublicProfileRoutes } from \"../routes/public-profile.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport { createDb, type Db } from \"../db.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/taunt_bet_dev\";\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"taunt_bet_dev\",\n  });\n}\n\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-profile-tests\");\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\n/** Perform challenge → sign → verify and return access token + wallet. */\nasync function authenticateWallet(\n  app: Hono,\n  keypair: Keypair,\n): Promise<{ accessToken: string; wallet: string }> {\n  const wallet = keypair.publicKey.toBase58();\n\n  // 1. Challenge\n  const challengeRes = await app.request(\"/auth/challenge\", {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ wallet }),\n  });\n  expect(challengeRes.status).toBe(200);\n  const challengeBody = (await challengeRes.json()) as {\n    ok: true;\n    data: { nonce: string; message: string };\n  };\n  const challenge = challengeBody.data;\n\n  // 2. Sign\n  const messageBytes = new TextEncoder().encode(challenge.message);\n  const signatureBytes = nacl.sign.detached(messageBytes, keypair.secretKey);\n  const signature = bs58.encode(signatureBytes);\n\n  // 3. Verify\n  const verifyRes = await app.request(\"/auth/verify\", {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n  });\n  expect(verifyRes.status).toBe(200);\n  const verifyBody = (await verifyRes.json()) as {\n    ok: true;\n    data: { accessToken: string };\n  };\n  return { accessToken: verifyBody.data.accessToken, wallet };\n}\n\nfunction makeUniqueUsername(prefix: string): string {\n  const safePrefix = prefix.replace(/[^a-zA-Z0-9_]/g, \"\").slice(0, 12);\n  const suffix = randomUUID().replace(/-/g, \"\").slice(0, 8);\n  return `${safePrefix}${suffix}`.slice(0, 20);\n}\n\n// ---------------------------------------------------------------------------\n// Suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"Profile lifecycle integration\", () => {\n  let rawSql: ReturnType<typeof postgres>;\n  let authDb: AuthDb;\n  let db: Db;\n  let app: Hono;\n\n  const keypairA = Keypair.generate();\n  const keypairB = Keypair.generate();\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n\n    // Ensure required tables exist\n    await rawSql`DROP TABLE IF EXISTS auth_challenges, refresh_tokens`;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS auth_challenges (\n        nonce TEXT PRIMARY KEY,\n        wallet TEXT NOT NULL,\n        cluster TEXT NOT NULL DEFAULT 'devnet',\n        message TEXT NOT NULL,\n        expires_at TIMESTAMPTZ NOT NULL,\n        used BOOLEAN DEFAULT FALSE,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS refresh_tokens (\n        id BIGSERIAL PRIMARY KEY,\n        user_id TEXT NOT NULL,\n        wallet TEXT NOT NULL,\n        token_hash BYTEA NOT NULL UNIQUE,\n        family_id TEXT NOT NULL,\n        expires_at TIMESTAMPTZ NOT NULL,\n        revoked BOOLEAN DEFAULT FALSE,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS player_profiles (\n        id BIGSERIAL PRIMARY KEY,\n        user_id TEXT UNIQUE NOT NULL,\n        wallet TEXT UNIQUE NOT NULL,\n        username TEXT UNIQUE NOT NULL,\n        username_updated_at TIMESTAMPTZ,\n        avatar_url TEXT,\n        heat_multiplier NUMERIC DEFAULT 1.0,\n        points_balance BIGINT DEFAULT 0,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n    // Case-insensitive uniqueness index\n    await rawSql`\n      CREATE UNIQUE INDEX IF NOT EXISTS idx_player_profiles_username_lower\n      ON player_profiles (LOWER(username))\n    `;\n    // transactions table (needed for stats queries)\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS transactions (\n        id BIGSERIAL PRIMARY KEY,\n        wallet TEXT NOT NULL,\n        game TEXT NOT NULL,\n        match_id TEXT NOT NULL,\n        tx_type TEXT NOT NULL,\n        amount_lamports BIGINT NOT NULL,\n        tx_sig TEXT,\n        created_at TIMESTAMPTZ DEFAULT now(),\n        UNIQUE(wallet, match_id, tx_type, tx_sig)\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS player_points (\n        user_id TEXT PRIMARY KEY,\n        wallet TEXT NOT NULL UNIQUE,\n        balance BIGINT NOT NULL DEFAULT 0,\n        lifetime_earned BIGINT NOT NULL DEFAULT 0,\n        updated_at TIMESTAMPTZ NOT NULL DEFAULT now()\n      )\n    `;\n  });\n\n  afterAll(async () => {\n    // Clean up test data\n    const walletA = keypairA.publicKey.toBase58();\n    const walletB = keypairB.publicKey.toBase58();\n    await rawSql`DELETE FROM player_profiles WHERE wallet IN (${walletA}, ${walletB})`;\n    await rawSql`DELETE FROM transactions WHERE wallet IN (${walletA}, ${walletB})`;\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    // Clean per-test state\n    const walletA = keypairA.publicKey.toBase58();\n    const walletB = keypairB.publicKey.toBase58();\n    await rawSql`TRUNCATE auth_challenges, refresh_tokens RESTART IDENTITY`;\n    await rawSql`DELETE FROM player_profiles WHERE wallet IN (${walletA}, ${walletB})`;\n    await rawSql`DELETE FROM transactions WHERE wallet IN (${walletA}, ${walletB})`;\n    await rawSql`DELETE FROM player_points`;\n\n    authDb = createAuthDb(rawSql);\n    db = createDb(DATABASE_URL, rawSql);\n    app = new Hono();\n\n    // Auth routes (no middleware)\n    app.route(\n      \"/auth\",\n      createAuthRoutes({\n        authDb,\n        db,\n        jwtSecret: JWT_SECRET,\n        cluster: \"devnet\",\n        challengeTtlSeconds: 300,\n        accessTokenTtlSeconds: 3600,\n        refreshTokenTtlDays: 14,\n      }),\n    );\n\n    // Profile routes (JWT protected)\n    app.use(\n      \"/profile/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n    );\n    app.route(\"/profile\", createProfileRoutes({ db }));\n\n    // Public profile (no auth)\n    app.route(\"/public-profile\", createPublicProfileRoutes({ db }));\n  });\n\n  // -----------------------------------------------------------------------\n  // (1) Auth creates profile automatically\n  // -----------------------------------------------------------------------\n\n  it(\"POST /auth/verify auto-creates player_profiles row\", async () => {\n    const { wallet } = await authenticateWallet(app, keypairA);\n\n    // Verify profile exists in DB\n    const rows = await rawSql`\n      SELECT user_id, wallet, username FROM player_profiles WHERE wallet = ${wallet}\n    `;\n    expect(rows.length).toBe(1);\n    const row = rows[0]!;\n    expect(row.user_id).toMatch(/^usr_[a-z0-9]{8}$/);\n    expect(row.username).toMatch(/^[a-z]+-[a-z]+-\\d{4}$/);\n    expect(row.wallet).toBe(wallet);\n  });\n\n  // -----------------------------------------------------------------------\n  // (2) GET /profile/me returns profile + empty stats\n  // -----------------------------------------------------------------------\n\n  it(\"GET /profile/me returns profile with empty stats\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/me\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${accessToken}` },\n    });\n    expect(res.status).toBe(200);\n    const envelope = (await res.json()) as { ok: true; data: Record<string, any> };\n    expect(envelope.ok).toBe(true);\n    const body = envelope.data;\n\n    // Has expected fields\n    expect(body.userId).toMatch(/^usr_[a-z0-9]{8}$/);\n    expect(body.username).toBeDefined();\n    expect(body.createdAt).toBeDefined();\n    expect(body.heatMultiplier).toBe(1);\n    expect(body.pointsBalance).toBe(\"0\");\n    expect(body.usernameNextEditAt).toBeNull(); // first edit free\n\n    // Stats should be empty/zero\n    const stats = body.stats as Record<string, any>;\n    expect(stats.gamesPlayed).toBe(0);\n    expect(stats.totalWagered).toBe(\"0\");\n    expect(stats.totalWins).toBe(0);\n    expect(stats.winRate).toBe(0);\n    expect(stats.winStreakCurrent).toBe(0);\n    expect(stats.winStreakBest).toBe(0);\n    expect(stats.netPnl).toBe(\"0\");\n\n    // No wallet field\n    expect(body).not.toHaveProperty(\"wallet\");\n  });\n\n  it(\"GET /profile/me returns points balance from player_points\", async () => {\n    const { accessToken, wallet } = await authenticateWallet(app, keypairA);\n\n    const initialRes = await app.request(\"/profile/me\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${accessToken}` },\n    });\n    expect(initialRes.status).toBe(200);\n    const initialEnvelope = (await initialRes.json()) as {\n      ok: true;\n      data: { userId: string; pointsBalance: string };\n    };\n    expect(initialEnvelope.data.pointsBalance).toBe(\"0\");\n\n    await rawSql`\n      INSERT INTO player_points (user_id, wallet, balance, lifetime_earned)\n      VALUES (${initialEnvelope.data.userId}, ${wallet}, 1337, 2048)\n    `;\n\n    const res = await app.request(\"/profile/me\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${accessToken}` },\n    });\n    expect(res.status).toBe(200);\n\n    const envelope = (await res.json()) as { ok: true; data: Record<string, any> };\n    expect(envelope.data.pointsBalance).toBe(\"1337\");\n  });\n\n  // -----------------------------------------------------------------------\n  // (3) PUT /profile/username succeeds on first edit\n  // -----------------------------------------------------------------------\n\n  it(\"PUT /profile/username succeeds with valid name\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n    const username = makeUniqueUsername(\"CoolPlayer\");\n\n    const res = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username }),\n    });\n    expect(res.status).toBe(200);\n    const envelope = (await res.json()) as {\n      ok: true;\n      data: { username: string; nextEditAvailableAt: string };\n    };\n    expect(envelope.ok).toBe(true);\n    expect(envelope.data.username).toBe(username);\n    expect(envelope.data.nextEditAvailableAt).toBeDefined();\n    // nextEditAvailableAt should be ~30 days from now\n    const nextEdit = new Date(envelope.data.nextEditAvailableAt).getTime();\n    const thirtyDays = 30 * 24 * 60 * 60 * 1000;\n    expect(nextEdit).toBeGreaterThan(Date.now() + thirtyDays - 60_000);\n  });\n\n  // -----------------------------------------------------------------------\n  // (4) PUT /profile/username again immediately → 429 cooldown\n  // -----------------------------------------------------------------------\n\n  it(\"PUT /profile/username returns 429 on cooldown\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n    const firstUsername = makeUniqueUsername(\"FirstName\");\n    const secondUsername = makeUniqueUsername(\"SecondName\");\n\n    // First edit — succeeds\n    const res1 = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: firstUsername }),\n    });\n    expect(res1.status).toBe(200);\n\n    // Second edit — should be blocked by cooldown\n    const res2 = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: secondUsername }),\n    });\n    expect(res2.status).toBe(429);\n    const body = (await res2.json()) as {\n      ok: false;\n      error: {\n        code: string;\n        message: string;\n        retryable?: boolean;\n        details?: { nextEditAvailableAt: string };\n      };\n    };\n    expect(body.ok).toBe(false);\n    expect(body.error.code).toBe(\"USERNAME_COOLDOWN\");\n    expect(body.error.retryable).toBe(true);\n    expect(body.error.details?.nextEditAvailableAt).toBeDefined();\n  });\n\n  // -----------------------------------------------------------------------\n  // (5) PUT /profile/username with taken name → 409\n  // -----------------------------------------------------------------------\n\n  it(\"PUT /profile/username returns 409 for taken username\", async () => {\n    // Authenticate both wallets (creates profiles)\n    const { accessToken: tokenA } = await authenticateWallet(app, keypairA);\n    const { accessToken: tokenB } = await authenticateWallet(app, keypairB);\n    const username = makeUniqueUsername(\"UniqueName\");\n\n    // Wallet A takes a name\n    const res1 = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${tokenA}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username }),\n    });\n    expect(res1.status).toBe(200);\n\n    // Wallet B tries the same name (case-insensitive)\n    const res2 = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${tokenB}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: username.toLowerCase() }),\n    });\n    expect(res2.status).toBe(409);\n    const body = (await res2.json()) as {\n      ok: false;\n      error: { code: string; message: string };\n    };\n    expect(body.ok).toBe(false);\n    expect(body.error.code).toBe(\"USERNAME_TAKEN\");\n  });\n\n  // -----------------------------------------------------------------------\n  // (6) GET /public-profile/:username returns limited public data\n  // -----------------------------------------------------------------------\n\n  it(\"GET /public-profile/:username returns public profile\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n    const username = makeUniqueUsername(\"PublicUser\");\n\n    // Set a known username\n    await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username }),\n    });\n\n    // Fetch public profile (no auth)\n    const res = await app.request(`/public-profile/${username}`);\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as Record<string, any>;\n\n    expect(body.userId).toMatch(/^usr_[a-z0-9]{8}$/);\n    expect(body.username).toBe(username);\n    expect(body.heatMultiplier).toBe(1);\n    expect(body.createdAt).toBeDefined();\n\n    // Public stats — limited fields only\n    const stats = body.stats as Record<string, any>;\n    expect(stats.gamesPlayed).toBe(0);\n    expect(stats.totalWins).toBe(0);\n    expect(stats.winRate).toBe(0);\n\n    // Must NOT have private fields\n    expect(body).not.toHaveProperty(\"wallet\");\n    expect(body).not.toHaveProperty(\"pointsBalance\");\n    expect(stats).not.toHaveProperty(\"totalWagered\");\n    expect(stats).not.toHaveProperty(\"netPnl\");\n    expect(stats).not.toHaveProperty(\"winStreakCurrent\");\n    expect(stats).not.toHaveProperty(\"winStreakBest\");\n  });\n\n  // -----------------------------------------------------------------------\n  // (7) GET /public-profile/:user_id returns same data\n  // -----------------------------------------------------------------------\n\n  it(\"GET /public-profile/:user_id resolves by user_id\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    // Get the userId from /profile/me\n    const meRes = await app.request(\"/profile/me\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${accessToken}` },\n    });\n    const meBody = (await meRes.json()) as { userId: string; username: string };\n    const userId = meBody.userId;\n\n    // Fetch via user_id\n    const res = await app.request(`/public-profile/${userId}`);\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as { userId: string; username: string };\n    expect(body.userId).toBe(userId);\n    expect(body.username).toBe(meBody.username);\n\n    // No wallet\n    expect(body).not.toHaveProperty(\"wallet\");\n  });\n\n  // -----------------------------------------------------------------------\n  // (8) No wallet field in any response (additional checks)\n  // -----------------------------------------------------------------------\n\n  it(\"no wallet field in any response\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n    const username = makeUniqueUsername(\"NoWalletChk\");\n\n    // GET /profile/me\n    const meRes = await app.request(\"/profile/me\", {\n      method: \"GET\",\n      headers: { Authorization: `Bearer ${accessToken}` },\n    });\n    const meBody = await meRes.text();\n    expect(meBody).not.toContain(keypairA.publicKey.toBase58());\n\n    // PUT /profile/username\n    const putRes = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username }),\n    });\n    const putBody = await putRes.text();\n    expect(putBody).not.toContain(keypairA.publicKey.toBase58());\n\n    // GET /public-profile\n    const pubRes = await app.request(`/public-profile/${username}`);\n    const pubBody = await pubRes.text();\n    expect(pubBody).not.toContain(keypairA.publicKey.toBase58());\n  });\n\n  // -----------------------------------------------------------------------\n  // Edge: 404 for unknown identifier\n  // -----------------------------------------------------------------------\n\n  it(\"GET /public-profile/:identifier returns 404 for unknown\", async () => {\n    const res = await app.request(\"/public-profile/nonexistent_user\");\n    expect(res.status).toBe(404);\n    const body = (await res.json()) as { error: string };\n    expect(body.error).toBe(\"NOT_FOUND\");\n  });\n\n  // -----------------------------------------------------------------------\n  // Edge: invalid username format\n  // -----------------------------------------------------------------------\n\n  it(\"PUT /profile/username returns 400 for invalid format\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: \"ab\" }), // too short\n    });\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as { error: string };\n    expect(body.error).toBe(\"INVALID_FORMAT\");\n  });\n\n  it(\"PUT /profile/username returns 400 for missing body\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n      },\n    });\n\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as { error: string };\n    expect(body.error).toBe(\"INVALID_FORMAT\");\n  });\n\n  it(\"POST /profile/confirm-tx returns 400 for missing body\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/confirm-tx\", {\n      method: \"POST\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n      },\n    });\n\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as { error: string };\n    expect(body.error).toBe(\"Missing or invalid fields\");\n  });\n});\n","structuredPatch":[{"oldStart":471,"oldLines":15,"newStart":471,"newLines":18,"lines":["       method: \"GET\",","       headers: { Authorization: `Bearer ${accessToken}` },","     });","-    const meBody = (await meRes.json()) as { userId: string; username: string };","-    const userId = meBody.userId;","+    const meEnvelope = (await meRes.json()) as {","+      ok: true;","+      data: { userId: string; username: string };","+    };","+    const userId = meEnvelope.data.userId;"," ","-    // Fetch via user_id","+    // Fetch via user_id (public-profile converts in a later iteration)","     const res = await app.request(`/public-profile/${userId}`);","     expect(res.status).toBe(200);","     const body = (await res.json()) as { userId: string; username: string };","     expect(body.userId).toBe(userId);","-    expect(body.username).toBe(meBody.username);","+    expect(body.username).toBe(meEnvelope.data.username);"," ","     // No wallet","     expect(body).not.toHaveProperty(\"wallet\");"]}],"userModified":false,"replaceAll":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_015QW9TUrgnPAb4JV5MQNpHT","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FcmP6CWAcRRmRsm8qf1FLE","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/backend/src/__tests__/profile.test.ts","old_string":"  it(\"PUT /profile/username returns 400 for invalid format\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: \"ab\" }), // too short\n    });\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as { error: string };\n    expect(body.error).toBe(\"INVALID_FORMAT\");\n  });\n\n  it(\"PUT /profile/username returns 400 for missing body\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n      },\n    });\n\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as { error: string };\n    expect(body.error).toBe(\"INVALID_FORMAT\");\n  });\n\n  it(\"POST /profile/confirm-tx returns 400 for missing body\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/confirm-tx\", {\n      method: \"POST\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n      },\n    });\n\n    expect(res.status).toBe(400);\n    const body = (await res.json()) as { error: string };\n    expect(body.error).toBe(\"Missing or invalid fields\");\n  });\n});","new_string":"  it(\"PUT /profile/username returns 422 for invalid format\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n        \"Content-Type\": \"application/json\",\n      },\n      body: JSON.stringify({ username: \"ab\" }), // too short\n    });\n    expect(res.status).toBe(422);\n    const body = (await res.json()) as {\n      ok: false;\n      error: { code: string; message: string; retryable?: boolean; details?: unknown };\n    };\n    expect(body.ok).toBe(false);\n    expect(body.error.code).toBe(\"INVALID_USERNAME\");\n    expect(Array.isArray(body.error.details)).toBe(true);\n  });\n\n  it(\"PUT /profile/username returns 422 for missing body\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/username\", {\n      method: \"PUT\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n      },\n    });\n\n    expect(res.status).toBe(422);\n    const body = (await res.json()) as {\n      ok: false;\n      error: { code: string; message: string };\n    };\n    expect(body.ok).toBe(false);\n    expect(body.error.code).toBe(\"INVALID_USERNAME\");\n  });\n\n  it(\"POST /profile/confirm-tx returns 422 for missing body\", async () => {\n    const { accessToken } = await authenticateWallet(app, keypairA);\n\n    const res = await app.request(\"/profile/confirm-tx\", {\n      method: \"POST\",\n      headers: {\n        Authorization: `Bearer ${accessToken}`,\n      },\n    });\n\n    expect(res.status).toBe(422);\n    const body = (await res.json()) as {\n      ok: false;\n      error: { code: string; message: string };\n    };\n    expect(body.ok).toBe(false);\n    expect(body.error.code).toBe(\"VALIDATION_FAILED\");\n  });\n});"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":803,"cache_read_input