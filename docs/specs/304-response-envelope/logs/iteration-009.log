 new SignJWT({})\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userId)\n    .setIssuedAt(now)\n    .setExpirationTime(now + 3600)\n    .sign(JWT_SECRET);\n}\n\nfunction buildApp(db: Partial<Db>) {\n  const app = new Hono();\n  app.use(\"/profile/*\", createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }));\n  app.route(\"/profile\", createProfileRoutes({ db: db as Db }));\n  return app;\n}\n\ndescribe(\"GET /profile/me temporary zeroed stats\", () => {\n  it(\"returns zeroed game stats without calling game stat queries\", async () => {\n    const getPlayerStatsByUserId = vi.fn(async () => {\n      throw new Error(\"getPlayerStatsByUserId should not be called\");\n    });\n    const getWinStreaksByUserId = vi.fn(async () => {\n      throw new Error(\"getWinStreaksByUserId should not be called\");\n    });\n    const getGameBreakdownByUserId = vi.fn(async () => {\n      throw new Error(\"getGameBreakdownByUserId should not be called\");\n    });\n    const rawSql = vi.fn(async () => []);\n    const getActiveLink = vi.fn(async () => null);\n\n    const app = buildApp({\n      getProfileByUserId: vi.fn(async () => ({\n        id: 1,\n        user_id: \"usr_zeroed\",\n        wallet: \"wallet_zeroed\",\n        username: \"zeroed-user\",\n        username_updated_at: null,\n        avatar_url: null,\n        heat_multiplier: 1,\n        points_balance: 0,\n        created_at: new Date(\"2026-01-01T00:00:00.000Z\"),\n      })),\n      getPlayerStatsByUserId,\n      getWinStreaksByUserId,\n      getGameBreakdownByUserId,\n      rawSql: rawSql as Db[\"rawSql\"],\n      getActiveLink,\n    });\n\n    const token = await makeJwt(\"usr_zeroed\");\n    const res = await app.request(\"/profile/me\", {\n      method: \"GET\",\n      headers: {\n        Authorization: `Bearer ${token}`,\n      },\n    });\n\n    expect(res.status).toBe(200);\n    expect(await res.json()).toMatchObject({\n      userId: \"usr_zeroed\",\n      username: \"zeroed-user\",\n      pointsBalance: \"0\",\n      telegramLinked: false,\n      stats: {\n        gamesPlayed: 0,\n        totalWagered: \"0\",\n        totalWins: 0,\n        winRate: 0,\n        winStreakCurrent: 0,\n        winStreakBest: 0,\n        netPnl: \"0\",\n        gameBreakdown: {},\n      },\n    });\n    expect(getPlayerStatsByUserId).not.toHaveBeenCalled();\n    expect(getWinStreaksByUserId).not.toHaveBeenCalled();\n    expect(getGameBreakdownByUserId).not.toHaveBeenCalled();\n    expect(rawSql).toHaveBeenCalledTimes(1);\n    expect(getActiveLink).toHaveBeenCalledWith(\"usr_zeroed\");\n  });\n});\n","structuredPatch":[{"oldStart":67,"oldLines":19,"newStart":67,"newLines":22,"lines":[" ","     expect(res.status).toBe(200);","     expect(await res.json()).toMatchObject({","-      userId: \"usr_zeroed\",","-      username: \"zeroed-user\",","-      pointsBalance: \"0\",","-      telegramLinked: false,","-      stats: {","-        gamesPlayed: 0,","-        totalWagered: \"0\",","-        totalWins: 0,","-        winRate: 0,","-        winStreakCurrent: 0,","-        winStreakBest: 0,","-        netPnl: \"0\",","-        gameBreakdown: {},","+      ok: true,","+      data: {","+        userId: \"usr_zeroed\",","+        username: \"zeroed-user\",","+        pointsBalance: \"0\",","+        telegramLinked: false,","+        stats: {","+          gamesPlayed: 0,","+          totalWagered: \"0\",","+          totalWins: 0,","+          winRate: 0,","+          winStreakCurrent: 0,","+          winStreakBest: 0,","+          netPnl: \"0\",","+          gameBreakdown: {},","+        },","       },","     });","     expect(getPlayerStatsByUserId).not.toHaveBeenCalled();"]}],"userModified":false,"replaceAll":false}}
