{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WyooLcFHxwTxemLAxiJrfG","type":"tool_result","content":"360\t);\n361\t\n362\t// Register security scheme for OpenAPI spec\n363\tapp.openAPIRegistry.registerComponent(\"securitySchemes\", \"bearerAuth\", {\n364\t  type: \"http\",\n365\t  scheme: \"bearer\",\n366\t  bearerFormat: \"JWT\",\n367\t  description:\n368\t    \"HS256 JWT obtained via /auth/verify. Payload: { sub: userId (usr_* format) }. \" +\n369\t    \"No wallet claim - wallet resolved from player profile when needed.\",\n370\t});\n371\t\n372\t// OpenAPI docs + internal admin routes — only when ADMIN_TOKEN is set (dev/devnet only)\n373\tif (config.adminToken) {\n374\t  app.doc(\"/openapi.json\", {\n375\t    openapi: \"3.0.3\",\n376\t    info: {\n377\t      title: \"Taunt Bet API\",\n378\t      description:\n379\t        \"Backend API for Taunt Bet - handles game round creation, \" +\n380\t        \"settlement verification, player profiles, referrals, and price feeds.\",\n381\t      version: \"0.1.0\",\n382\t    },\n383\t    servers: [\n384\t      { url: \"https://api.dev.taunt.bet\", description: \"Devnet\" },\n385\t      { url: \"http://localhost:3100\", description: \"Local\" },\n386\t      { url: \"https://api.taunt.bet\", description: \"Production\" },\n387\t    ],\n388\t  });\n389\t  app.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n390\t  logger.info(\"OpenAPI docs enabled at /docs and /openapi.json\");\n391\t  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n392\t  logger.warn(\"Internal admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production\");\n393\t}\n394\t\n395\tconst port = config.port;\n396\tlogger.info(\"fairness-backend started\", {\n397\t  port,\n398\t  publicAppUrl: config.publicAppUrl,\n399\t  publicAppDomain: config.publicAppDomain,"}]},"parent_tool_use_id":null,"session_id":"736bbedb-6401-4318-a325-ee85001d8ebf","uuid":"1105806e-327e-49f2-b196-f0f7b8ca8ccc","timestamp":"2026-04-22T11:20:40.868Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/index.ts","content":");\n\n// Register security scheme for OpenAPI spec\napp.openAPIRegistry.registerComponent(\"securitySchemes\", \"bearerAuth\", {\n  type: \"http\",\n  scheme: \"bearer\",\n  bearerFormat: \"JWT\",\n  description:\n    \"HS256 JWT obtained via /auth/verify. Payload: { sub: userId (usr_* format) }. \" +\n    \"No wallet claim - wallet resolved from player profile when needed.\",\n});\n\n// OpenAPI docs + internal admin routes — only when ADMIN_TOKEN is set (dev/devnet only)\nif (config.adminToken) {\n  app.doc(\"/openapi.json\", {\n    openapi: \"3.0.3\",\n    info: {\n      title: \"Taunt Bet API\",\n      description:\n        \"Backend API for Taunt Bet - handles game round creation, \" +\n        \"settlement verification, player profiles, referrals, and price feeds.\",\n      version: \"0.1.0\",\n    },\n    servers: [\n      { url: \"https://api.dev.taunt.bet\", description: \"Devnet\" },\n      { url: \"http://localhost:3100\", description: \"Local\" },\n      { url: \"https://api.taunt.bet\", description: \"Production\" },\n    ],\n  });\n  app.get(\"/docs\", swaggerUI({ url: \"/openapi.json\" }));\n  logger.info(\"OpenAPI docs enabled at /docs and /openapi.json\");\n  app.route(\"/internal\", createInternalRoutes({ config, sql }));\n  logger.warn(\"Internal admin routes enabled at /internal — do NOT set ADMIN_TOKEN in production\");\n}\n\nconst port = config.port;\nlogger.info(\"fairness-backend started\", {\n  port,\n  publicAppUrl: config.publicAppUrl,\n  publicAppDomain: config.publicAppDomain,","numLines":40,"startLine":360,"totalLines":412}}}
