{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019b2GUdhmBoZ5vkZ1ZV8M9w","type":"tool_result","content":"370\t});\n371\t\n372\t// OpenAPI docs + internal admin routes — only when ADMIN_TOKEN is set (dev/devnet only)\n373\tif (config.adminToken) {\n374\t  app.doc(\"/openapi.json\", {\n375\t    openapi: \"3.0.3\",\n376\t    info: {\n377\t      title: \"Taunt Bet API\",\n378\t      description:\n379\t        \"Backend API for Taunt Bet - handles game round creation, \" +\n380\t        \"settlement verification, player profiles, referrals, and price feeds.\\n\\n\" +\n381\t        \"## Response envelope contract\\n\\n\" +\n382\t        \"Every public JSON response uses one of two body shapes:\\n\\n\" +\n383\t        \"- Success: `{ ok: true, data }` at `200` / `201` / `202` (or `204 No Content`).\\n\" +\n384\t        \"- Failure: `{ ok: false, error: { code, message, retryable?, details? } }` at \" +\n385\t        \"`400` / `401` / `403` / `404` / `409` / `422` / `429` / `5xx`.\\n\\n\" +\n386\t        \"`ok` is the discriminator; HTTP status codes keep their transport and application \" +\n387\t        \"meaning (validation → `422`, auth → `401/403`, cooldown → `429`, conflict → `409`, \" +\n388\t        \"missing → `404`). Empty-state reads (e.g. `GET /referral/code`, `GET /referral/referrer`, \" +\n389\t        \"`GET /points/mine`) return `200` with nullable or default payloads when absence is the \" +\n390\t        \"documented success answer. Error `code` values come from the stable catalog in \" +\n391\t        \"`backend/src/contracts/api-errors.ts`.\\n\\n\" +\n392\t        \"Canonical reference: `docs/specs/304-response-envelope/spec.md`.\",\n393\t      version: \"0.1.0\",\n394\t    },\n395\t    servers: [\n396\t      { url: \"https://api.dev.taunt.bet\", description: \"Devnet\" },\n397\t      { url: \"http://localhost:3100\", description: \"Local\" },\n398\t      { url: \"https://api.taunt.bet\", description: \"Production\" },\n399\t    ],"}]},"parent_tool_use_id":null,"session_id":"736bbedb-6401-4318-a325-ee85001d8ebf","uuid":"d14413a7-1f99-4c6f-a1b8-b0eb264c0b39","timestamp":"2026-04-22T11:22:38.062Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/index.ts","content":"});\n\n// OpenAPI docs + internal admin routes — only when ADMIN_TOKEN is set (dev/devnet only)\nif (config.adminToken) {\n  app.doc(\"/openapi.json\", {\n    openapi: \"3.0.3\",\n    info: {\n      title: \"Taunt Bet API\",\n      description:\n        \"Backend API for Taunt Bet - handles game round creation, \" +\n        \"settlement verification, player profiles, referrals, and price feeds.\\n\\n\" +\n        \"## Response envelope contract\\n\\n\" +\n        \"Every public JSON response uses one of two body shapes:\\n\\n\" +\n        \"- Success: `{ ok: true, data }` at `200` / `201` / `202` (or `204 No Content`).\\n\" +\n        \"- Failure: `{ ok: false, error: { code, message, retryable?, details? } }` at \" +\n        \"`400` / `401` / `403` / `404` / `409` / `422` / `429` / `5xx`.\\n\\n\" +\n        \"`ok` is the discriminator; HTTP status codes keep their transport and application \" +\n        \"meaning (validation → `422`, auth → `401/403`, cooldown → `429`, conflict → `409`, \" +\n        \"missing → `404`). Empty-state reads (e.g. `GET /referral/code`, `GET /referral/referrer`, \" +\n        \"`GET /points/mine`) return `200` with nullable or default payloads when absence is the \" +\n        \"documented success answer. Error `code` values come from the stable catalog in \" +\n        \"`backend/src/contracts/api-errors.ts`.\\n\\n\" +\n        \"Canonical reference: `docs/specs/304-response-envelope/spec.md`.\",\n      version: \"0.1.0\",\n    },\n    servers: [\n      { url: \"https://api.dev.taunt.bet\", description: \"Devnet\" },\n      { url: \"http://localhost:3100\", description: \"Local\" },\n      { url: \"https://api.taunt.bet\", description: \"Production\" },\n    ],","numLines":30,"startLine":370,"totalLines":424}}}
