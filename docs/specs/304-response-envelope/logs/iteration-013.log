{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XTwmpsgnsE4Sx84hqLGYEb","type":"tool_result","content":"1\t/**\n2\t * Pot Shot routes.\n3\t *\n4\t * GET  /pot-shot/current        — active round state\n5\t * POST /pot-shot/create         — create a new round\n6\t * GET  /pot-shot/history        — recent settled rounds\n7\t * GET  /pot-shot/by-id/:matchId — lookup by match ID\n8\t * GET  /pot-shot/verify/:pda    — lookup by PDA with verification data\n9\t */\n10\t\n11\timport { createRoute } from \"@hono/zod-openapi\";\n12\timport { z } from \"zod\";\n13\timport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\n14\timport { computeCommitment, generateMatchId, generateSecret } from \"../fairness.js\";\n15\timport { buildCreateLordRoundTx, deriveLordRoundPda } from \"../tx-builder.js\";\n16\timport type { Db, Round, OperatorEvent } from \"../db.js\";\n17\timport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n18\timport {\n19\t  envelope,\n20\t  ErrorEnvelopeSchema,\n21\t  ok,\n22\t  err,\n23\t} from \"../contracts/api-envelope.js\";\n24\timport { logger } from \"../logger.js\";\n25\timport type { AppEnv } from \"../hono-env.js\";\n26\timport type { PdaWatcher } from \"../worker/pda-watcher.js\";\n27\timport { decodeLordRound, type DecodedPotShotRound } from \"../worker/account-decoder.js\";\n28\timport {\n29\t  PotShotCreateResponseSchema,\n30\t  PotShotRoundResponseSchema,\n31\t  PotShotRoundSchema,\n32\t  RoundEntrySchema,\n33\t  listEnvelopeResponseSchema,\n34\t  roundEnvelopeResponseSchema,\n35\t} from \"../contracts/validators.js\";\n36\timport { createOpenApiApp } from \"../openapi/hono.js\";\n37\t\n38\texport interface LordCreateRoutesDeps {\n39\t  db: Db;\n40\t  connection: Connection;\n41\t  serverKeypair: Keypair;\n42\t  pdaWatcher?: PdaWatcher;\n43\t}\n44\t\n45\tconst MIN_WAGER_LAMPORTS = 1_000_000;\n46\t\n47\tfunction isValidBase58(s: string): boolean {\n48\t  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n49\t}\n50\t\n51\tconst PHASE_NAMES = [\"waiting\", \"active\", \"locked\", \"resolving\", \"settled\", \"refunded\"] as const;\n52\tconst DB_PHASE_TO_POTSHOT_PHASE = {\n53\t  created: \"waiting\",\n54\t  locked: \"locked\",\n55\t  settling: \"resolving\",\n56\t  settled: \"settled\",\n57\t  expired: \"refunded\",\n58\t} as const;\n59\t\n60\ttype RoundEntry = z.infer<typeof RoundEntrySchema>;\n61\ttype PotShotCurrentRoundResponse = z.infer<typeof PotShotRoundSchema>;\n62\ttype PotShotRoundResponse = z.infer<typeof PotShotRoundResponseSchema>;\n63\t\n64\tfunction formatLordRound(\n65\t  round: DecodedPotShotRound,\n66\t  pda: PublicKey,\n67\t  dbRound: { match_id: string; commitment: Buffer; phase: string } | undefined,\n68\t): PotShotCurrentRoundResponse {\n69\t  const entries = round.entries.map((e) => ({\n70\t    player: e.player.toBase58(),\n71\t    amountLamports: Number(e.amountLamports),\n72\t  }));\n73\t\n74\t  return {\n75\t    matchId: dbRound?.match_id ?? Buffer.from(round.matchId).toString(\"hex\"),\n76\t    pda: pda.toBase58(),\n77\t    phase: PHASE_NAMES[round.phase] ?? \"waiting\",\n78\t    creator: round.creator.toBase58(),\n79\t    commitment: dbRound\n80\t      ? dbRound.commitment.toString(\"hex\")\n81\t      : Buffer.from(round.commitment).toString(\"hex\"),\n82\t    entries,\n83\t    totalAmountLamports: Number(round.totalAmountLamports),\n84\t    distinctPlayers: round.distinctPlayers,\n85\t    countdownStartedAt: Number(round.countdownStartedAt) > 0\n86\t      ? Number(round.countdownStartedAt)\n87\t      : null,\n88\t    countdownEndsAt: Number(round.countdownEndsAt) > 0\n89\t      ? Number(round.countdownEndsAt)\n90\t      : null,\n91\t    createdAt: new Date(Number(round.createdAt) * 1000).toISOString(),\n92\t  };\n93\t}\n94\t\n95\t// ── Request schemas ──────────────────────────────────────────────────────\n96\t\n97\tconst PotShotCreateBodySchema = z.object({\n98\t  wallet: z.string(),\n99\t  amountLamports: z.number().int().min(MIN_WAGER_LAMPORTS),\n100\t});\n101\t\n102\tconst LimitQuerySchema = z.object({\n103\t  limit: z.string().optional(),\n104\t});\n105\t\n106\tconst MatchIdParamSchema = z.object({\n107\t  matchId: z.string(),\n108\t});\n109\t\n110\tconst PdaParamSchema = z.object({\n111\t  pda: z.string(),\n112\t});\n113\t\n114\t// ── Route definitions ────────────────────────────────────────────────────\n115\t\n116\tconst PotShotCurrentResponseSchema = roundEnvelopeResponseSchema(\n117\t  \"round\",\n118\t  PotShotRoundSchema,\n119\t  { nullable: true },\n120\t);\n121\t\n122\tconst PotShotHistoryResponseSchema = listEnvelopeResponseSchema(\n123\t  \"rounds\",\n124\t  PotShotRoundResponseSchema,\n125\t);\n126\t\n127\tconst currentRoute = createRoute({\n128\t  method: \"get\",\n129\t  path: \"/current\",\n130\t  tags: [\"PotShot\"],\n131\t  summary: \"Get active Pot Shot round\",\n132\t  responses: {\n133\t    200: {\n134\t      content: {\n135\t        \"application/json\": {\n136\t          schema: envelope(PotShotCurrentResponseSchema),\n137\t        },\n138\t      },\n139\t      description: \"Active round or null\",\n140\t    },\n141\t  },\n142\t});\n143\t\n144\tconst createRoundRoute = createRoute({\n145\t  method: \"post\",\n146\t  path: \"/create\",\n147\t  tags: [\"PotShot\"],\n148\t  summary: \"Create a new Pot Shot round\",\n149\t  security: [{ bearerAuth: [] }],\n150\t  request: {\n151\t    body: {\n152\t      required: true,\n153\t      content: {\n154\t        \"application/json\": { schema: PotShotCreateBodySchema },\n155\t      },\n156\t    },\n157\t  },\n158\t  responses: {\n159\t    200: {\n160\t      content: { \"application/json\": { schema: envelope(PotShotCreateResponseSchema) } },\n161\t      description: \"Round created successfully\",\n162\t    },\n163\t    400: {\n164\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n165\t      description: \"Invalid wallet format\",\n166\t    },\n167\t    403: {\n168\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n169\t      description: \"Wallet mismatch with authenticated session\",\n170\t    },\n171\t    409: {\n172\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n173\t      description: \"Round already active or ID collision\",\n174\t    },\n175\t    422: {\n176\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n177\t      description: \"Invalid request body\",\n178\t    },\n179\t    500: {\n180\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n181\t      description: \"Transaction build failed\",\n182\t    },\n183\t  },\n184\t});\n185\t\n186\tconst psHistoryRoute = createRoute({\n187\t  method: \"get\",\n188\t  path: \"/history\",\n189\t  tags: [\"PotShot\"],\n190\t  summary: \"Get recent settled Pot Shot rounds\",\n191\t  request: {\n192\t    query: LimitQuerySchema,\n193\t  },\n194\t  responses: {\n195\t    200: {\n196\t      content: {\n197\t        \"application/json\": {\n198\t          schema: envelope(PotShotHistoryResponseSchema),\n199\t        },\n200\t      },\n201\t      description: \"List of settled rounds\",\n202\t    },\n203\t  },\n204\t});\n205\t\n206\tconst psByIdRoute = createRoute({\n207\t  method: \"get\",\n208\t  path: \"/by-id/{matchId}\",\n209\t  tags: [\"PotShot\"],\n210\t  summary: \"Lookup Pot Shot round by ID\",\n211\t  request: {\n212\t    params: MatchIdParamSchema,\n213\t  },\n214\t  responses: {\n215\t    200: {\n216\t      content: { \"application/json\": { schema: envelope(PotShotRoundResponseSchema) } },\n217\t      description: \"Round found\",\n218\t    },\n219\t    400: {\n220\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n221\t      description: \"Invalid match ID format\",\n222\t    },\n223\t    404: {\n224\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n225\t      description: \"Round not found\",\n226\t    },\n227\t  },\n228\t});\n229\t\n230\tconst psVerifyRoute = createRoute({\n231\t  method: \"get\",\n232\t  path: \"/verify/{pda}\",\n233\t  tags: [\"PotShot\"],\n234\t  summary: \"Lookup Pot Shot round by PDA with verification data\",\n235\t  request: {\n236\t    params: PdaParamSchema,\n237\t  },\n238\t  responses: {\n239\t    200: {\n240\t      content: { \"application/json\": { schema: envelope(PotShotRoundResponseSchema) } },\n241\t      description: \"Round verification data\",\n242\t    },\n243\t    404: {\n244\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n245\t      description: \"Round not found\",\n246\t    },\n247\t  },\n248\t});\n249\t\n250\t// ── Factory ──────────────────────────────────────────────────────────────\n251\t\n252\texport function createPotShotRoutes(deps: LordCreateRoutesDeps) {\n253\t  const { db, connection, serverKeypair, pdaWatcher } = deps;\n254\t  const app = createOpenApiApp<AppEnv>();\n255\t\n256\t  // GET /current — return the single active lord round (if any)\n257\t  app.openapi(currentRoute, async (c) => {\n258\t    try {\n259\t      // Query DB for any lord round not in a terminal phase\n260\t      const [created, locked, settling] = await Promise.all([\n261\t        db.getRoundsByPhase(\"created\"),\n262\t        db.getRoundsByPhase(\"locked\"),\n263\t        db.getRoundsByPhase(\"settling\"),\n264\t      ]);\n265\t\n266\t      // Sort ASC (oldest first) — if a race condition created two rounds,\n267\t      // the first one gets played to completion before the second surfaces.\n268\t      const activeDbRound = [...created, ...locked, ...settling]\n269\t        .filter((r) => r.game === \"potshot\")\n270\t        .sort((a, b) => a.created_at.getTime() - b.created_at.getTime())[0];\n271\t\n272\t      if (!activeDbRound) {\n273\t        return ok(c, { round: null });\n274\t      }\n275\t\n276\t      // Fetch the on-chain account to get current entries/pool state\n277\t      const roundPda = new PublicKey(activeDbRound.pda);\n278\t      try {\n279\t        const accountInfo = await connection.getAccountInfo(roundPda);\n280\t        if (accountInfo) {\n281\t          const decoded = decodeLordRound(Buffer.from(accountInfo.data));\n282\t          return ok(c, {\n283\t            round: formatLordRound(decoded, roundPda, activeDbRound),\n284\t          });\n285\t        }\n286\t      } catch (fetchError) {\n287\t        logger.warn(\"lord current: on-chain fetch failed, returning DB-only\", {\n288\t          pda: activeDbRound.pda,\n289\t          error: fetchError instanceof Error ? fetchError.message : String(fetchError),\n290\t        });\n291\t      }\n292\t\n293\t      // Fallback: return DB data without on-chain enrichment\n294\t      return ok(c, {\n295\t        round: {\n296\t          matchId: activeDbRound.match_id,\n297\t          pda: activeDbRound.pda,\n298\t          phase: DB_PHASE_TO_POTSHOT_PHASE[activeDbRound.phase],\n299\t          creator: activeDbRound.creator,\n300\t          commitment: activeDbRound.commitment.toString(\"hex\"),\n301\t          entries: [],\n302\t          totalAmountLamports: activeDbRound.amount_lamports,\n303\t          distinctPlayers: 1,\n304\t          countdownStartedAt: null,\n305\t          countdownEndsAt: null,\n306\t          createdAt: activeDbRound.created_at.toISOString(),\n307\t        },\n308\t      });\n309\t    } catch (queryError) {\n310\t      logger.error(\"lord current: query failed\", {\n311\t        error: queryError instanceof Error ? queryError.message : String(queryError),\n312\t      });\n313\t      return ok(c, { round: null });\n314\t    }\n315\t  });\n316\t\n317\t  // POST /create\n318\t  app.openapi(createRoundRoute, async (c) => {\n319\t    const body = c.req.valid(\"json\");\n320\t\n321\t    // Additional validation: base58 format\n322\t    if (!isValidBase58(body.wallet)) {\n323\t      return err(\n324\t        c,\n325\t        400,\n326\t        API_ERROR_CODES.INVALID_REQUEST,\n327\t        \"wallet must be a valid base58 public key\",\n328\t        { retryable: false },\n329\t      );\n330\t    }\n331\t\n332\t    const userId = c.get(\"userId\");\n333\t    const profile = userId ? await db.getProfileByUserId(userId) : null;\n334\t    if (profile && body.wallet !== profile.wallet) {\n335\t      return err(\n336\t        c,\n337\t        403,\n338\t        API_ERROR_CODES.FORBIDDEN,\n339\t        \"Wallet does not match authenticated session\",\n340\t        { retryable: false },\n341\t      );\n342\t    }\n343\t\n344\t    // Single active round check: reject if a lord round is already in progress\n345\t    const [created, locked, settling] = await Promise.all([\n346\t      db.getRoundsByPhase(\"created\"),\n347\t      db.getRoundsByPhase(\"locked\"),\n348\t      db.getRoundsByPhase(\"settling\"),\n349\t    ]);\n350\t    const activeRound = [...created, ...locked, ...settling].find(\n351\t      (r) => r.game === \"potshot\",\n352\t    );\n353\t    if (activeRound) {\n354\t      return err(\n355\t        c,\n356\t        409,\n357\t        API_ERROR_CODES.CONFLICT,\n358\t        \"A round is already active\",\n359\t        {\n360\t          retryable: false,\n361\t          details: {\n362\t            activeRound: {\n363\t              matchId: activeRound.match_id,\n364\t              pda: activeRound.pda,\n365\t            },\n366\t          },\n367\t        },\n368\t      );\n369\t    }\n370\t\n371\t    let creatorPubkey: PublicKey;\n372\t    try {\n373\t      creatorPubkey = new PublicKey(body.wallet);\n374\t    } catch {\n375\t      return err(\n376\t        c,\n377\t        400,\n378\t        API_ERROR_CODES.INVALID_REQUEST,\n379\t        \"wallet is not a valid public key\",\n380\t        { retryable: false },\n381\t      );\n382\t    }\n383\t\n384\t    const secret = generateSecret();\n385\t    const commitment = computeCommitment(secret);\n386\t    const matchId = generateMatchId();\n387\t    const matchIdHex = matchId.toString(\"hex\");\n388\t    const [roundPda] = deriveLordRoundPda(matchId);\n389\t    const roundPdaStr = roundPda.toBase58();\n390\t\n391\t    const existing = await db.getRoundByPda(roundPdaStr);\n392\t    if (existing) {\n393\t      return err(\n394\t        c,\n395\t        409,\n396\t        API_ERROR_CODES.CONFLICT,\n397\t        \"Round ID collision — please retry\",\n398\t        { retryable: true },\n399\t      );\n400\t    }\n401\t\n402\t    let transaction: string;\n403\t    let lastValidBlockHeight: number;\n404\t    try {\n405\t      const result = await buildCreateLordRoundTx({\n406\t        connection,\n407\t        creator: creatorPubkey,\n408\t        serverKeypair,\n409\t        commitment,\n410\t        amountLamports: body.amountLamports,\n411\t        matchId,\n412\t      });\n413\t      transaction = result.transaction;\n414\t      lastValidBlockHeight = result.lastValidBlockHeight;\n415\t    } catch (buildError) {\n416\t      logger.error(\"lord create failed: transaction build error\", {\n417\t        wallet: body.wallet,\n418\t        roundPda: roundPdaStr,\n419\t        error: buildError instanceof Error ? buildError.message : \"Failed to build transaction\",\n420\t      });\n421\t      return err(\n422\t        c,\n423\t        500,\n424\t        API_ERROR_CODES.PRECONDITION_FAILED,\n425\t        \"Failed to build transaction\",\n426\t      );\n427\t    }\n428\t\n429\t    try {\n430\t      await db.insertRound({\n431\t        pda: roundPdaStr,\n432\t        game: \"potshot\",\n433\t        creator: body.wallet,\n434\t        serverKey: serverKeypair.publicKey.toBase58(),\n435\t        secret,\n436\t        commitment,\n437\t        amountLamports: body.amountLamports,\n438\t        side: 0,\n439\t        matchId: matchIdHex,\n440\t        phase: \"created\",\n441\t      });\n442\t    } catch (insertError) {\n443\t      if (insertError instanceof Error && insertError.message.includes(\"duplicate\")) {\n444\t        return err(\n445\t          c,\n446\t          409,\n447\t          API_ERROR_CODES.CONFLICT,\n448\t          \"Round ID collision — please retry\",\n449\t          { retryable: true },\n450\t        );\n451\t      }\n452\t      throw insertError;\n453\t    }\n454\t\n455\t    // Write participation-time game entry\n456\t    try {\n457\t      if (profile) {\n458\t        await db.upsertGameEntry({\n459\t          userId: profile.user_id,\n460\t          wallet: body.wallet,\n461\t          game: \"potshot\",\n462\t          roundPda: roundPdaStr,\n463\t          matchId: matchIdHex,\n464\t          amountLamports: body.amountLamports,\n465\t        });\n466\t      }\n467\t    } catch (entryError) {\n468\t      logger.warn(\"lord create: game_entry insert failed\", {\n469\t        error: entryError instanceof Error ? entryError.message : String(entryError),\n470\t      });\n471\t    }\n472\t\n473\t    await db.insertOperatorEvent(roundPdaStr, \"secret_generated\", {\n474\t      creator: body.wallet,\n475\t      amountLamports: body.amountLamports,\n476\t      matchId: matchIdHex,\n477\t      game: \"potshot\",\n478\t    });\n479\t\n480\t    // Subscribe to PDA for instant join/countdown detection via WebSocket\n481\t    pdaWatcher?.watch(roundPdaStr);\n482\t\n483\t    return ok(c, {\n484\t      transaction,\n485\t      roundPda: roundPdaStr,\n486\t      matchId: matchIdHex,\n487\t      commitment: commitment.toString(\"hex\"),\n488\t      lastValidBlockHeight,\n489\t    });\n490\t  });\n491\t\n492\t  // -----------------------------------------------------------------------\n493\t  // GET /history — recent settled Pot Shot rounds\n494\t  // -----------------------------------------------------------------------\n495\t\n496\t  app.openapi(psHistoryRoute, async (c) => {\n497\t    const { limit: limitParam } = c.req.valid(\"query\");\n498\t    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 50);\n499\t\n500\t    const rounds = await db.getRecentSettledRounds(\"potshot\", limit);\n501\t    const settleEvents = await db.getLatestOperatorEventsForPdas(\n502\t      rounds.map((r) => r.pda),\n503\t      \"settle_confirmed\",\n504\t    );\n505\t\n506\t    return ok(c, {\n507\t      rounds: rounds.map((r) => formatPotShotRound(r, settleEvents.get(r.pda))),\n508\t    });\n509\t  });\n510\t\n511\t  // -----------------------------------------------------------------------\n512\t  // GET /by-id/:matchId — lookup by 16-char hex match ID\n513\t  // -----------------------------------------------------------------------\n514\t\n515\t  app.openapi(psByIdRoute, async (c) => {\n516\t    const { matchId } = c.req.valid(\"param\");\n517\t    if (!/^[0-9a-f]{16}$/i.test(matchId)) {\n518\t      return err(\n519\t        c,\n520\t        400,\n521\t        API_ERROR_CODES.INVALID_REQUEST,\n522\t        \"matchId must be a 16-char hex string\",\n523\t        { retryable: false },\n524\t      );\n525\t    }\n526\t\n527\t    const round = await db.getRoundByMatchId(matchId.toLowerCase());\n528\t    if (!round || round.game !== \"potshot\") {\n529\t      return err(c, 404, API_ERROR_CODES.ROUND_NOT_FOUND, \"Round not found\");\n530\t    }\n531\t\n532\t    return ok(c, await enrichPotShotRound(db, round));\n533\t  });\n534\t\n535\t  // -----------------------------------------------------------------------\n536\t  // GET /verify/:pda — lookup by PDA with full verification data\n537\t  // -----------------------------------------------------------------------\n538\t\n539\t  app.openapi(psVerifyRoute, async (c) => {\n540\t    const { pda } = c.req.valid(\"param\");\n541\t    const round = await db.getRoundByPda(pda);\n542\t    if (!round || round.game !== \"potshot\") {\n543\t      return err(c, 404, API_ERROR_CODES.ROUND_NOT_FOUND, \"Round not found\");\n544\t    }\n545\t\n546\t    return ok(c, await enrichPotShotRound(db, round));\n547\t  });\n548\t\n549\t  return app;\n550\t}\n551\t\n552\t// ---------------------------------------------------------------------------\n553\t// Pot Shot response formatting\n554\t// ---------------------------------------------------------------------------\n555\t\n556\tfunction getEventPayload(event: OperatorEvent | undefined): Record<string, unknown> | null {\n557\t  if (!event || typeof event.payload !== \"object\" || event.payload === null) return null;\n558\t  return event.payload as Record<string, unknown>;\n559\t}\n560\t\n561\tfunction getNullableString(value: unknown): string | null | undefined {\n562\t  if (value === null) return null;\n563\t  return typeof value === \"string\" ? value : undefined;\n564\t}\n565\t\n566\tfunction getNullableInt(value: unknown): number | null | undefined {\n567\t  if (value === null) return null;\n568\t  return typeof value === \"number\" && Number.isInteger(value) ? value : undefined;\n569\t}\n570\t\n571\tfunction getRoundEntries(value: unknown): RoundEntry[] | undefined {\n572\t  const parsed = z.array(RoundEntrySchema).safeParse(value);\n573\t  return parsed.success ? parsed.data : undefined;\n574\t}\n575\t\n576\tfunction formatPotShotRound(round: Round, settleEvent?: OperatorEvent): PotShotRoundResponse {\n577\t  const isSettled = round.phase === \"settled\";\n578\t  const settlePayload = getEventPayload(settleEvent);\n579\t\n580\t  const response: PotShotRoundResponse = {\n581\t    pda: round.pda,\n582\t    game: \"pot-shot\",\n583\t    phase: round.phase,\n584\t    creator: round.creator,\n585\t    commitment: round.commitment.toString(\"hex\"),\n586\t    amountLamports: round.amount_lamports,\n587\t    side: round.side,\n588\t    matchId: round.match_id,\n589\t    createdAt: round.created_at.toISOString(),\n590\t    updatedAt: round.updated_at.toISOString(),\n591\t  };\n592\t\n593\t  if (round.target_slot !== null) {\n594\t    response.targetSlot = Number(round.target_slot);\n595\t  }\n596\t\n597\t  if (isSettled) {\n598\t    response.secret = round.secret.toString(\"hex\");\n599\t    response.resultHash = round.result_hash ? round.result_hash.toString(\"hex\") : null;\n600\t    if (round.result_side !== null) {\n601\t      response.winningEntryIndex = round.result_side;\n602\t    }\n603\t    if (round.winner) {\n604\t      response.winner = round.winner;\n605\t    }\n606\t    if (round.settle_tx) {\n607\t      response.settleTx = round.settle_tx;\n608\t    }\n609\t    response.totalAmountLamports = round.amount_lamports;\n610\t    response.verification = {\n611\t      commitmentCheck: \"sha256(secret) == commitment\",\n612\t      resultFormula: \"sha256(secret || entropy || pda || algorithmVersion)\",\n613\t      entropySource: \"SlotHashes sysvar at target_slot\",\n614\t    };\n615\t\n616\t    if (Array.isArray(round.entries)) {\n617\t      response.entries = round.entries;\n618\t    }\n619\t\n620\t    if (settlePayload) {\n621\t      const entries = getRoundEntries(settlePayload.entries);\n622\t      const entropy = getNullableString(settlePayload.entropy);\n623\t      const payoutAmount = getNullableInt(settlePayload.payoutAmount);\n624\t      const feeAmount = getNullableInt(settlePayload.feeAmount);\n625\t      const winningOffset = getNullableString(settlePayload.winningOffset);\n626\t      const totalAmountLamports = getNullableInt(settlePayload.totalAmountLamports);\n627\t      const rentRefund = getNullableInt(settlePayload.rentRefund);\n628\t\n629\t      if (!response.entries && entries) {\n630\t        response.entries = entries;\n631\t      }\n632\t      if (entropy !== undefined) {\n633\t        response.entropy = entropy;\n634\t      }\n635\t      if (payoutAmount !== undefined) {\n636\t        response.payoutAmount = payoutAmount;\n637\t      }\n638\t      if (feeAmount !== undefined) {\n639\t        response.feeAmount = feeAmount;\n640\t      }\n641\t      if (winningOffset !== undefined) {\n642\t        response.winningOffset = winningOffset;\n643\t      }\n644\t      if (totalAmountLamports !== undefined) {\n645\t        response.totalAmountLamports = totalAmountLamports;\n646\t      }\n647\t      if (rentRefund !== undefined) {\n648\t        response.rentRefund = rentRefund;\n649\t      }\n650\t    }\n651\t  }\n652\t\n653\t  return response;\n654\t}\n655\t\n656\tasync function enrichPotShotRound(db: Db, round: Round) {\n657\t  let settleEvent: OperatorEvent | undefined;\n658\t  if (round.phase === \"settled\") {\n659\t    try {\n660\t      settleEvent = await db.getLatestOperatorEvent(round.pda, \"settle_confirmed\");\n661\t    } catch {\n662\t      // Gracefully degrade\n663\t    }\n664\t  }\n665\t  return formatPotShotRound(round, settleEvent);\n666\t}\n667\t"}]},"parent_tool_use_id":null,"session_id":"a8190fd2-127a-4607-a6d7-99b6b936e439","uuid":"f97e2dd7-cd1e-4b83-9d0d-d4d9179d65f6","timestamp":"2026-04-22T10:24:26.664Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/potshot-create.ts","content":"/**\n * Pot Shot routes.\n *\n * GET  /pot-shot/current        — active round state\n * POST /pot-shot/create         — create a new round\n * GET  /pot-shot/history        — recent settled rounds\n * GET  /pot-shot/by-id/:matchId — lookup by match ID\n * GET  /pot-shot/verify/:pda    — lookup by PDA with verification data\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\nimport { computeCommitment, generateMatchId, generateSecret } from \"../fairness.js\";\nimport { buildCreateLordRoundTx, deriveLordRoundPda } from \"../tx-builder.js\";\nimport type { Db, Round, OperatorEvent } from \"../db.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport { logger } from \"../logger.js\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { PdaWatcher } from \"../worker/pda-watcher.js\";\nimport { decodeLordRound, type DecodedPotShotRound } from \"../worker/account-decoder.js\";\nimport {\n  PotShotCreateResponseSchema,\n  PotShotRoundResponseSchema,\n  PotShotRoundSchema,\n  RoundEntrySchema,\n  listEnvelopeResponseSchema,\n  roundEnvelopeResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface LordCreateRoutesDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  pdaWatcher?: PdaWatcher;\n}\n\nconst MIN_WAGER_LAMPORTS = 1_000_000;\n\nfunction isValidBase58(s: string): boolean {\n  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n}\n\nconst PHASE_NAMES = [\"waiting\", \"active\", \"locked\", \"resolving\", \"settled\", \"refunded\"] as const;\nconst DB_PHASE_TO_POTSHOT_PHASE = {\n  created: \"waiting\",\n  locked: \"locked\",\n  settling: \"resolving\",\n  settled: \"settled\",\n  expired: \"refunded\",\n} as const;\n\ntype RoundEntry = z.infer<typeof RoundEntrySchema>;\ntype PotShotCurrentRoundResponse = z.infer<typeof PotShotRoundSchema>;\ntype PotShotRoundResponse = z.infer<typeof PotShotRoundResponseSchema>;\n\nfunction formatLordRound(\n  round: DecodedPotShotRound,\n  pda: PublicKey,\n  dbRound: { match_id: string; commitment: Buffer; phase: string } | undefined,\n): PotShotCurrentRoundResponse {\n  const entries = round.entries.map((e) => ({\n    player: e.player.toBase58(),\n    amountLamports: Number(e.amountLamports),\n  }));\n\n  return {\n    matchId: dbRound?.match_id ?? Buffer.from(round.matchId).toString(\"hex\"),\n    pda: pda.toBase58(),\n    phase: PHASE_NAMES[round.phase] ?? \"waiting\",\n    creator: round.creator.toBase58(),\n    commitment: dbRound\n      ? dbRound.commitment.toString(\"hex\")\n      : Buffer.from(round.commitment).toString(\"hex\"),\n    entries,\n    totalAmountLamports: Number(round.totalAmountLamports),\n    distinctPlayers: round.distinctPlayers,\n    countdownStartedAt: Number(round.countdownStartedAt) > 0\n      ? Number(round.countdownStartedAt)\n      : null,\n    countdownEndsAt: Number(round.countdownEndsAt) > 0\n      ? Number(round.countdownEndsAt)\n      : null,\n    createdAt: new Date(Number(round.createdAt) * 1000).toISOString(),\n  };\n}\n\n// ── Request schemas ──────────────────────────────────────────────────────\n\nconst PotShotCreateBodySchema = z.object({\n  wallet: z.string(),\n  amountLamports: z.number().int().min(MIN_WAGER_LAMPORTS),\n});\n\nconst LimitQuerySchema = z.object({\n  limit: z.string().optional(),\n});\n\nconst MatchIdParamSchema = z.object({\n  matchId: z.string(),\n});\n\nconst PdaParamSchema = z.object({\n  pda: z.string(),\n});\n\n// ── Route definitions ────────────────────────────────────────────────────\n\nconst PotShotCurrentResponseSchema = roundEnvelopeResponseSchema(\n  \"round\",\n  PotShotRoundSchema,\n  { nullable: true },\n);\n\nconst PotShotHistoryResponseSchema = listEnvelopeResponseSchema(\n  \"rounds\",\n  PotShotRoundResponseSchema,\n);\n\nconst currentRoute = createRoute({\n  method: \"get\",\n  path: \"/current\",\n  tags: [\"PotShot\"],\n  summary: \"Get active Pot Shot round\",\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: envelope(PotShotCurrentResponseSchema),\n        },\n      },\n      description: \"Active round or null\",\n    },\n  },\n});\n\nconst createRoundRoute = createRoute({\n  method: \"post\",\n  path: \"/create\",\n  tags: [\"PotShot\"],\n  summary: \"Create a new Pot Shot round\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": { schema: PotShotCreateBodySchema },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(PotShotCreateResponseSchema) } },\n      description: \"Round created successfully\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid wallet format\",\n    },\n    403: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Wallet mismatch with authenticated session\",\n    },\n    409: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Round already active or ID collision\",\n    },\n    422: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid request body\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Transaction build failed\",\n    },\n  },\n});\n\nconst psHistoryRoute = createRoute({\n  method: \"get\",\n  path: \"/history\",\n  tags: [\"PotShot\"],\n  summary: \"Get recent settled Pot Shot rounds\",\n  request: {\n    query: LimitQuerySchema,\n  },\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: envelope(PotShotHistoryResponseSchema),\n        },\n      },\n      description: \"List of settled rounds\",\n    },\n  },\n});\n\nconst psByIdRoute = createRoute({\n  method: \"get\",\n  path: \"/by-id/{matchId}\",\n  tags: [\"PotShot\"],\n  summary: \"Lookup Pot Shot round by ID\",\n  request: {\n    params: MatchIdParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(PotShotRoundResponseSchema) } },\n      description: \"Round found\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid match ID format\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Round not found\",\n    },\n  },\n});\n\nconst psVerifyRoute = createRoute({\n  method: \"get\",\n  path: \"/verify/{pda}\",\n  tags: [\"PotShot\"],\n  summary: \"Lookup Pot Shot round by PDA with verification data\",\n  request: {\n    params: PdaParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(PotShotRoundResponseSchema) } },\n      description: \"Round verification data\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Round not found\",\n    },\n  },\n});\n\n// ── Factory ──────────────────────────────────────────────────────────────\n\nexport function createPotShotRoutes(deps: LordCreateRoutesDeps) {\n  const { db, connection, serverKeypair, pdaWatcher } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // GET /current — return the single active lord round (if any)\n  app.openapi(currentRoute, async (c) => {\n    try {\n      // Query DB for any lord round not in a terminal phase\n      const [created, locked, settling] = await Promise.all([\n        db.getRoundsByPhase(\"created\"),\n        db.getRoundsByPhase(\"locked\"),\n        db.getRoundsByPhase(\"settling\"),\n      ]);\n\n      // Sort ASC (oldest first) — if a race condition created two rounds,\n      // the first one gets played to completion before the second surfaces.\n      const activeDbRound = [...created, ...locked, ...settling]\n        .filter((r) => r.game === \"potshot\")\n        .sort((a, b) => a.created_at.getTime() - b.created_at.getTime())[0];\n\n      if (!activeDbRound) {\n        return ok(c, { round: null });\n      }\n\n      // Fetch the on-chain account to get current entries/pool state\n      const roundPda = new PublicKey(activeDbRound.pda);\n      try {\n        const accountInfo = await connection.getAccountInfo(roundPda);\n        if (accountInfo) {\n          const decoded = decodeLordRound(Buffer.from(accountInfo.data));\n          return ok(c, {\n            round: formatLordRound(decoded, roundPda, activeDbRound),\n          });\n        }\n      } catch (fetchError) {\n        logger.warn(\"lord current: on-chain fetch failed, returning DB-only\", {\n          pda: activeDbRound.pda,\n          error: fetchError instanceof Error ? fetchError.message : String(fetchError),\n        });\n      }\n\n      // Fallback: return DB data without on-chain enrichment\n      return ok(c, {\n        round: {\n          matchId: activeDbRound.match_id,\n          pda: activeDbRound.pda,\n          phase: DB_PHASE_TO_POTSHOT_PHASE[activeDbRound.phase],\n          creator: activeDbRound.creator,\n          commitment: activeDbRound.commitment.toString(\"hex\"),\n          entries: [],\n          totalAmountLamports: activeDbRound.amount_lamports,\n          distinctPlayers: 1,\n          countdownStartedAt: null,\n          countdownEndsAt: null,\n          createdAt: activeDbRound.created_at.toISOString(),\n        },\n      });\n    } catch (queryError) {\n      logger.error(\"lord current: query failed\", {\n        error: queryError instanceof Error ? queryError.message : String(queryError),\n      });\n      return ok(c, { round: null });\n    }\n  });\n\n  // POST /create\n  app.openapi(createRoundRoute, async (c) => {\n    const body = c.req.valid(\"json\");\n\n    // Additional validation: base58 format\n    if (!isValidBase58(body.wallet)) {\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"wallet must be a valid base58 public key\",\n        { retryable: false },\n      );\n    }\n\n    const userId = c.get(\"userId\");\n    const profile = userId ? await db.getProfileByUserId(userId) : null;\n    if (profile && body.wallet !== profile.wallet) {\n      return err(\n        c,\n        403,\n        API_ERROR_CODES.FORBIDDEN,\n        \"Wallet does not match authenticated session\",\n        { retryable: false },\n      );\n    }\n\n    // Single active round check: reject if a lord round is already in progress\n    const [created, locked, settling] = await Promise.all([\n      db.getRoundsByPhase(\"created\"),\n      db.getRoundsByPhase(\"locked\"),\n      db.getRoundsByPhase(\"settling\"),\n    ]);\n    const activeRound = [...created, ...locked, ...settling].find(\n      (r) => r.game === \"potshot\",\n    );\n    if (activeRound) {\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.CONFLICT,\n        \"A round is already active\",\n        {\n          retryable: false,\n          details: {\n            activeRound: {\n              matchId: activeRound.match_id,\n              pda: activeRound.pda,\n            },\n          },\n        },\n      );\n    }\n\n    let creatorPubkey: PublicKey;\n    try {\n      creatorPubkey = new PublicKey(body.wallet);\n    } catch {\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"wallet is not a valid public key\",\n        { retryable: false },\n      );\n    }\n\n    const secret = generateSecret();\n    const commitment = computeCommitment(secret);\n    const matchId = generateMatchId();\n    const matchIdHex = matchId.toString(\"hex\");\n    const [roundPda] = deriveLordRoundPda(matchId);\n    const roundPdaStr = roundPda.toBase58();\n\n    const existing = await db.getRoundByPda(roundPdaStr);\n    if (existing) {\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.CONFLICT,\n        \"Round ID collision — please retry\",\n        { retryable: true },\n      );\n    }\n\n    let transaction: string;\n    let lastValidBlockHeight: number;\n    try {\n      const result = await buildCreateLordRoundTx({\n        connection,\n        creator: creatorPubkey,\n        serverKeypair,\n        commitment,\n        amountLamports: body.amountLamports,\n        matchId,\n      });\n      transaction = result.transaction;\n      lastValidBlockHeight = result.lastValidBlockHeight;\n    } catch (buildError) {\n      logger.error(\"lord create failed: transaction build error\", {\n        wallet: body.wallet,\n        roundPda: roundPdaStr,\n        error: buildError instanceof Error ? buildError.message : \"Failed to build transaction\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to build transaction\",\n      );\n    }\n\n    try {\n      await db.insertRound({\n        pda: roundPdaStr,\n        game: \"potshot\",\n        creator: body.wallet,\n        serverKey: serverKeypair.publicKey.toBase58(),\n        secret,\n        commitment,\n        amountLamports: body.amountLamports,\n        side: 0,\n        matchId: matchIdHex,\n        phase: \"created\",\n      });\n    } catch (insertError) {\n      if (insertError instanceof Error && insertError.message.includes(\"duplicate\")) {\n        return err(\n          c,\n          409,\n          API_ERROR_CODES.CONFLICT,\n          \"Round ID collision — please retry\",\n          { retryable: true },\n        );\n      }\n      throw insertError;\n    }\n\n    // Write participation-time game entry\n    try {\n      if (profile) {\n        await db.upsertGameEntry({\n          userId: profile.user_id,\n          wallet: body.wallet,\n          game: \"potshot\",\n          roundPda: roundPdaStr,\n          matchId: matchIdHex,\n          amountLamports: body.amountLamports,\n        });\n      }\n    } catch (entryError) {\n      logger.warn(\"lord create: game_entry insert failed\", {\n        error: entryError instanceof Error ? entryError.message : String(entryError),\n      });\n    }\n\n    await db.insertOperatorEvent(roundPdaStr, \"secret_generated\", {\n      creator: body.wallet,\n      amountLamports: body.amountLamports,\n      matchId: matchIdHex,\n      game: \"potshot\",\n    });\n\n    // Subscribe to PDA for instant join/countdown detection via WebSocket\n    pdaWatcher?.watch(roundPdaStr);\n\n    return ok(c, {\n      transaction,\n      roundPda: roundPdaStr,\n      matchId: matchIdHex,\n      commitment: commitment.toString(\"hex\"),\n      lastValidBlockHeight,\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /history — recent settled Pot Shot rounds\n  // -----------------------------------------------------------------------\n\n  app.openapi(psHistoryRoute, async (c) => {\n    const { limit: limitParam } = c.req.valid(\"query\");\n    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 50);\n\n    const rounds = await db.getRecentSettledRounds(\"potshot\", limit);\n    const settleEvents = await db.getLatestOperatorEventsForPdas(\n      rounds.map((r) => r.pda),\n      \"settle_confirmed\",\n    );\n\n    return ok(c, {\n      rounds: rounds.map((r) => formatPotShotRound(r, settleEvents.get(r.pda))),\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /by-id/:matchId — lookup by 16-char hex match ID\n  // -----------------------------------------------------------------------\n\n  app.openapi(psByIdRoute, async (c) => {\n    const { matchId } = c.req.valid(\"param\");\n    if (!/^[0-9a-f]{16}$/i.test(matchId)) {\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"matchId must be a 16-char hex string\",\n        { retryable: false },\n      );\n    }\n\n    const round = await db.getRoundByMatchId(matchId.toLowerCase());\n    if (!round || round.game !== \"potshot\") {\n      return err(c, 404, API_ERROR_CODES.ROUND_NOT_FOUND, \"Round not found\");\n    }\n\n    return ok(c, await enrichPotShotRound(db, round));\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /verify/:pda — lookup by PDA with full verification data\n  // -----------------------------------------------------------------------\n\n  app.openapi(psVerifyRoute, async (c) => {\n    const { pda } = c.req.valid(\"param\");\n    const round = await db.getRoundByPda(pda);\n    if (!round || round.game !== \"potshot\") {\n      return err(c, 404, API_ERROR_CODES.ROUND_NOT_FOUND, \"Round not found\");\n    }\n\n    return ok(c, await enrichPotShotRound(db, round));\n  });\n\n  return app;\n}\n\n// ---------------------------------------------------------------------------\n// Pot Shot response formatting\n// ---------------------------------------------------------------------------\n\nfunction getEventPayload(event: OperatorEvent | undefined): Record<string, unknown> | null {\n  if (!event || typeof event.payload !== \"object\" || event.payload === null) return null;\n  return event.payload as Record<string, unknown>;\n}\n\nfunction getNullableString(value: unknown): string | null | undefined {\n  if (value === null) return null;\n  return typeof value === \"string\" ? value : undefined;\n}\n\nfunction getNullableInt(value: unknown): number | null | undefined {\n  if (value === null) return null;\n  return typeof value === \"number\" && Number.isInteger(value) ? value : undefined;\n}\n\nfunction getRoundEntries(value: unknown): RoundEntry[] | undefined {\n  const parsed = z.array(RoundEntrySchema).safeParse(value);\n  return parsed.success ? parsed.data : undefined;\n}\n\nfunction formatPotShotRound(round: Round, settleEvent?: OperatorEvent): PotShotRoundResponse {\n  const isSettled = round.phase === \"settled\";\n  const settlePayload = getEventPayload(settleEvent);\n\n  const response: PotShotRoundResponse = {\n    pda: round.pda,\n    game: \"pot-shot\",\n    phase: round.phase,\n    creator: round.creator,\n    commitment: round.commitment.toString(\"hex\"),\n    amountLamports: round.amount_lamports,\n    side: round.side,\n    matchId: round.match_id,\n    createdAt: round.created_at.toISOString(),\n    updatedAt: round.updated_at.toISOString(),\n  };\n\n  if (round.target_slot !== null) {\n    response.targetSlot = Number(round.target_slot);\n  }\n\n  if (isSettled) {\n    response.secret = round.secret.toString(\"hex\");\n    response.resultHash = round.result_hash ? round.result_hash.toString(\"hex\") : null;\n    if (round.result_side !== null) {\n      response.winningEntryIndex = round.result_side;\n    }\n    if (round.winner) {\n      response.winner = round.winner;\n    }\n    if (round.settle_tx) {\n      response.settleTx = round.settle_tx;\n    }\n    response.totalAmountLamports = round.amount_lamports;\n    response.verification = {\n      commitmentCheck: \"sha256(secret) == commitment\",\n      resultFormula: \"sha256(secret || entropy || pda || algorithmVersion)\",\n      entropySource: \"SlotHashes sysvar at target_slot\",\n    };\n\n    if (Array.isArray(round.entries)) {\n      response.entries = round.entries;\n    }\n\n    if (settlePayload) {\n      const entries = getRoundEntries(settlePayload.entries);\n      const entropy = getNullableString(settlePayload.entropy);\n      const payoutAmount = getNullableInt(settlePayload.payoutAmount);\n      const feeAmount = getNullableInt(settlePayload.feeAmount);\n      const winningOffset = getNullableString(settlePayload.winningOffset);\n      const totalAmountLamports = getNullableInt(settlePayload.totalAmountLamports);\n      const rentRefund = getNullableInt(settlePayload.rentRefund);\n\n      if (!response.entries && entries) {\n        response.entries = entries;\n      }\n      if (entropy !== undefined) {\n        response.entropy = entropy;\n      }\n      if (payoutAmount !== undefined) {\n        response.payoutAmount = payoutAmount;\n      }\n      if (feeAmount !== undefined) {\n        response.feeAmount = feeAmount;\n      }\n      if (winningOffset !== undefined) {\n        response.winningOffset = winningOffset;\n      }\n      if (totalAmountLamports !== undefined) {\n        response.totalAmountLamports = totalAmountLamports;\n      }\n      if (rentRefund !== undefined) {\n        response.rentRefund = rentRefund;\n      }\n    }\n  }\n\n  return response;\n}\n\nasync function enrichPotShotRound(db: Db, round: Round) {\n  let settleEvent: OperatorEvent | undefined;\n  if (round.phase === \"settled\") {\n    try {\n      settleEvent = await db.getLatestOperatorEvent(round.pda, \"settle_confirmed\");\n    } catch {\n      // Gracefully degrade\n    }\n  }\n  return formatPotShotRound(round, settleEvent);\n}\n","numLines":667,"startLine":1,"totalLines":667}}}
