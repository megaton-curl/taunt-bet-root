{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LCXeUEXNXbyNw6vLXyeowu","type":"tool_result","content":"1\t/**\n2\t * Close Call API routes.\n3\t *\n4\t * GET  /closecall/current-round  — active round + pool state\n5\t * GET  /closecall/history        — last N settled/refunded rounds\n6\t * GET  /closecall/by-id/:roundId — lookup by round ID (minute timestamp)\n7\t * GET  /closecall/candles        — last N minute-boundary candles from DB\n8\t * POST /closecall/bet            — co-sign a bet tx (creates round or joins)\n9\t */\n10\t\n11\timport { createRoute } from \"@hono/zod-openapi\";\n12\timport { z } from \"zod\";\n13\timport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\n14\timport type { CloseCallRound, Db } from \"../db.js\";\n15\timport { logger } from \"../logger.js\";\n16\timport { buildCloseCallBetTx } from \"../worker/settle-tx.js\";\n17\timport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n18\timport { decodeCloseCallRound, type DecodedCloseCallRound } from \"../worker/account-decoder.js\";\n19\timport type { CloseCallClockWorker } from \"../worker/closecall-clock.js\";\n20\timport type { AppEnv } from \"../hono-env.js\";\n21\timport {\n22\t  ErrorResponseSchema,\n23\t  CloseCallBetResponseSchema,\n24\t  CandleSchema,\n25\t  CloseCallRoundSchema,\n26\t  UnifiedCloseCallRoundResponseSchema,\n27\t  listEnvelopeResponseSchema,\n28\t  roundEnvelopeResponseSchema,\n29\t} from \"../contracts/validators.js\";\n30\timport { createOpenApiApp } from \"../openapi/hono.js\";\n31\t\n32\texport interface CloseCallRoutesDeps {\n33\t  db: Db;\n34\t  connection: Connection;\n35\t  serverKeypair: Keypair;\n36\t  clockWorker: CloseCallClockWorker;\n37\t}\n38\t\n39\t/** Minimum wager in lamports: 0.001 SOL */\n40\tconst MIN_WAGER_LAMPORTS = 1_000_000;\n41\tconst MAX_WAGER_LAMPORTS = 100_000_000_000; // 100 SOL\n42\t\n43\tfunction isValidBase58(s: string): boolean {\n44\t  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n45\t}\n46\t\n47\t/** Convert a minuteTs bigint to an 8-byte LE buffer (for PDA seeds). */\n48\tfunction minuteTsToBuffer(ts: bigint): Buffer {\n49\t  const buf = Buffer.alloc(8);\n50\t  buf.writeBigInt64LE(ts);\n51\t  return buf;\n52\t}\n53\t\n54\t/** Derive the CloseCallRound PDA for a given minute timestamp. */\n55\tfunction deriveCloseCallRoundPda(minuteTs: bigint): PublicKey {\n56\t  const [pda] = PublicKey.findProgramAddressSync(\n57\t    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n58\t    CLOSECALL_PROGRAM_ID,\n59\t  );\n60\t  return pda;\n61\t}\n62\t\n63\tconst PHASE_NAMES = [\"open\", \"settled\", \"refunded\"] as const;\n64\tconst OUTCOME_NAMES = [\"pending\", \"green\", \"red\", \"refund\"] as const;\n65\t\n66\ttype CloseCallRoundResponse = z.infer<typeof CloseCallRoundSchema>;\n67\ttype CloseCallLookupResponse = z.infer<typeof UnifiedCloseCallRoundResponseSchema>;\n68\t\n69\t/** Format a decoded on-chain round into the same shape as formatCloseCallRound. */\n70\tfunction formatOnChainRound(\n71\t  round: DecodedCloseCallRound,\n72\t  pda: PublicKey,\n73\t): CloseCallRoundResponse {\n74\t  const greenEntries = round.greenEntries.map((e) => ({\n75\t    player: e.player.toBase58(),\n76\t    amountLamports: Number(e.amountLamports),\n77\t  }));\n78\t  const redEntries = round.redEntries.map((e) => ({\n79\t    player: e.player.toBase58(),\n80\t    amountLamports: Number(e.amountLamports),\n81\t  }));\n82\t  const greenPool = Number(round.greenPool);\n83\t  const redPool = Number(round.redPool);\n84\t  const totalPool = greenPool + redPool;\n85\t\n86\t  return {\n87\t    roundId: Number(round.minuteTs).toString(),\n88\t    pda: pda.toBase58(),\n89\t    phase: PHASE_NAMES[round.phase] ?? \"open\",\n90\t    openPrice: Number(round.openPrice),\n91\t    openPriceExpo: round.openPriceExpo,\n92\t    closePrice: round.phase === 0 ? null : Number(round.closePrice),\n93\t    outcome: OUTCOME_NAMES[round.outcome] ?? \"pending\",\n94\t    greenPool,\n95\t    redPool,\n96\t    totalPool,\n97\t    totalFee: Number(round.totalFee),\n98\t    greenEntries,\n99\t    redEntries,\n100\t    greenCount: greenEntries.length,\n101\t    redCount: redEntries.length,\n102\t    settleTx: null,\n103\t    createdAt: new Date(Number(round.createdAt) * 1000).toISOString(),\n104\t    settledAt: null,\n105\t  };\n106\t}\n107\t\n108\tfunction formatCloseCallRound(round: CloseCallRound): CloseCallRoundResponse {\n109\t  const totalPool = round.green_pool + round.red_pool;\n110\t  return {\n111\t    roundId: round.round_id,\n112\t    pda: round.pda,\n113\t    phase: round.phase,\n114\t    openPrice: round.open_price,\n115\t    openPriceExpo: round.open_price_expo,\n116\t    closePrice: round.close_price,\n117\t    outcome: round.outcome,\n118\t    greenPool: round.green_pool,\n119\t    redPool: round.red_pool,\n120\t    totalPool,\n121\t    totalFee: round.total_fee,\n122\t    greenEntries: round.green_entries,\n123\t    redEntries: round.red_entries,\n124\t    greenCount: round.green_entries.length,\n125\t    redCount: round.red_entries.length,\n126\t    settleTx: round.settle_tx,\n127\t    createdAt: round.created_at.toISOString(),\n128\t    settledAt: round.settled_at ? round.settled_at.toISOString() : null,\n129\t  };\n130\t}\n131\t\n132\t// ── Request schemas ──────────────────────────────────────────────────────\n133\t\n134\tconst LimitQuerySchema = z.object({\n135\t  limit: z.string().optional(),\n136\t});\n137\t\n138\tconst RoundIdParamSchema = z.object({\n139\t  roundId: z.string(),\n140\t});\n141\t\n142\tconst CloseCallBetBodySchema = z.object({\n143\t  playerPubkey: z.string(),\n144\t  side: z.enum([\"green\", \"red\"]),\n145\t  amountLamports: z.number().int().min(MIN_WAGER_LAMPORTS).max(MAX_WAGER_LAMPORTS),\n146\t});\n147\t\n148\t// ── Route definitions ────────────────────────────────────────────────────\n149\t\n150\tconst CloseCallCurrentResponseSchema = roundEnvelopeResponseSchema(\n151\t  \"round\",\n152\t  CloseCallRoundSchema,\n153\t  { nullable: true },\n154\t);\n155\t\n156\tconst CloseCallHistoryResponseSchema = listEnvelopeResponseSchema(\n157\t  \"rounds\",\n158\t  CloseCallRoundSchema,\n159\t);\n160\t\n161\tconst currentRoundRoute = createRoute({\n162\t  method: \"get\",\n163\t  path: \"/current-round\",\n164\t  tags: [\"CloseCall\"],\n165\t  summary: \"Get active Close Call round\",\n166\t  responses: {\n167\t    200: {\n168\t      content: {\n169\t        \"application/json\": {\n170\t          schema: CloseCallCurrentResponseSchema,\n171\t        },\n172\t      },\n173\t      description: \"Active round or null\",\n174\t    },\n175\t  },\n176\t});\n177\t\n178\tconst ccHistoryRoute = createRoute({\n179\t  method: \"get\",\n180\t  path: \"/history\",\n181\t  tags: [\"CloseCall\"],\n182\t  summary: \"Get recent settled/refunded Close Call rounds\",\n183\t  request: {\n184\t    query: LimitQuerySchema,\n185\t  },\n186\t  responses: {\n187\t    200: {\n188\t      content: {\n189\t        \"application/json\": {\n190\t          schema: CloseCallHistoryResponseSchema,\n191\t        },\n192\t      },\n193\t      description: \"List of settled rounds\",\n194\t    },\n195\t  },\n196\t});\n197\t\n198\tconst ccByIdRoute = createRoute({\n199\t  method: \"get\",\n200\t  path: \"/by-id/{roundId}\",\n201\t  tags: [\"CloseCall\"],\n202\t  summary: \"Lookup Close Call round by ID\",\n203\t  request: {\n204\t    params: RoundIdParamSchema,\n205\t  },\n206\t  responses: {\n207\t    200: {\n208\t      content: { \"application/json\": { schema: UnifiedCloseCallRoundResponseSchema } },\n209\t      description: \"Round found\",\n210\t    },\n211\t    400: {\n212\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n213\t      description: \"Invalid round ID format\",\n214\t    },\n215\t    404: {\n216\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n217\t      description: \"Round not found\",\n218\t    },\n219\t  },\n220\t});\n221\t\n222\tconst candlesRoute = createRoute({\n223\t  method: \"get\",\n224\t  path: \"/candles\",\n225\t  tags: [\"CloseCall\"],\n226\t  summary: \"Get recent minute-boundary candles\",\n227\t  request: {\n228\t    query: LimitQuerySchema,\n229\t  },\n230\t  responses: {\n231\t    200: {\n232\t      content: {\n233\t        \"application/json\": {\n234\t          schema: z.object({\n235\t            candles: z.array(CandleSchema),\n236\t            currentOpenPrice: z.number().nullable(),\n237\t            currentMinuteTs: z.number().int().nullable(),\n238\t          }),\n239\t        },\n240\t      },\n241\t      description: \"Candle data\",\n242\t    },\n243\t  },\n244\t});\n245\t\n246\tconst betRoute = createRoute({\n247\t  method: \"post\",\n248\t  path: \"/bet\",\n249\t  tags: [\"CloseCall\"],\n250\t  summary: \"Co-sign a Close Call bet transaction\",\n251\t  security: [{ bearerAuth: [] }],\n252\t  request: {\n253\t    body: {\n254\t      required: true,\n255\t      content: {\n256\t        \"application/json\": { schema: CloseCallBetBodySchema },\n257\t      },\n258\t    },\n259\t  },\n260\t  responses: {\n261\t    200: {\n262\t      content: { \"application/json\": { schema: CloseCallBetResponseSchema } },\n263\t      description: \"Bet transaction built successfully\",\n264\t    },\n265\t    400: {\n266\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n267\t      description: \"Invalid request\",\n268\t    },\n269\t    401: {\n270\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n271\t      description: \"Authentication required\",\n272\t    },\n273\t    403: {\n274\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n275\t      description: \"Wallet mismatch\",\n276\t    },\n277\t    404: {\n278\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n279\t      description: \"Profile not found\",\n280\t    },\n281\t    500: {\n282\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n283\t      description: \"Transaction build failed\",\n284\t    },\n285\t    503: {\n286\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n287\t      description: \"No price data available\",\n288\t    },\n289\t  },\n290\t});\n291\t\n292\t// ── Factory ──────────────────────────────────────────────────────────────\n293\t\n294\texport function createCloseCallRoutes(deps: CloseCallRoutesDeps) {\n295\t  const { db, connection, serverKeypair, clockWorker } = deps;\n296\t  const app = createOpenApiApp<AppEnv>();\n297\t\n298\t  app.openapi(currentRoundRoute, async (c) => {\n299\t    // Derive PDAs for current and previous minute — the round may still be\n300\t    // open from the previous minute if not yet settled.\n301\t    const nowMinuteTs = BigInt(Math.floor(Date.now() / 60_000) * 60);\n302\t    const prevMinuteTs = nowMinuteTs - 60n;\n303\t\n304\t    const currentPda = deriveCloseCallRoundPda(nowMinuteTs);\n305\t    const prevPda = deriveCloseCallRoundPda(prevMinuteTs);\n306\t\n307\t    try {\n308\t      const [currentInfo, prevInfo] = await Promise.all([\n309\t        connection.getAccountInfo(currentPda),\n310\t        connection.getAccountInfo(prevPda),\n311\t      ]);\n312\t\n313\t      // Prefer the current minute's round; fall back to previous if it's still open\n314\t      if (currentInfo) {\n315\t        const round = decodeCloseCallRound(Buffer.from(currentInfo.data));\n316\t        return c.json({ round: formatOnChainRound(round, currentPda) }, 200);\n317\t      }\n318\t\n319\t      if (prevInfo) {\n320\t        const round = decodeCloseCallRound(Buffer.from(prevInfo.data));\n321\t        // Only return previous-minute round if it's still open (phase 0)\n322\t        if (round.phase === 0) {\n323\t          return c.json({ round: formatOnChainRound(round, prevPda) }, 200);\n324\t        }\n325\t      }\n326\t\n327\t      return c.json({ round: null }, 200);\n328\t    } catch (err) {\n329\t      logger.error(\"closecall current-round: on-chain lookup failed\", {\n330\t        error: err instanceof Error ? err.message : String(err),\n331\t      });\n332\t      return c.json({ round: null }, 200);\n333\t    }\n334\t  });\n335\t\n336\t  app.openapi(ccHistoryRoute, async (c) => {\n337\t    const { limit: limitParam } = c.req.valid(\"query\");\n338\t    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 100);\n339\t    const rounds = await db.getCloseCallHistory(limit);\n340\t    return c.json({ rounds: rounds.map(formatCloseCallRound) }, 200);\n341\t  });\n342\t\n343\t  // -----------------------------------------------------------------------\n344\t  // GET /by-id/:roundId — lookup by round ID (numeric minute timestamp)\n345\t  // -----------------------------------------------------------------------\n346\t\n347\t  app.openapi(ccByIdRoute, async (c) => {\n348\t    const { roundId } = c.req.valid(\"param\");\n349\t    if (!/^[0-9]{1,20}$/.test(roundId)) {\n350\t      return c.json({ error: \"roundId must be a numeric timestamp\" }, 400);\n351\t    }\n352\t\n353\t    const round = await db.getCloseCallRound(roundId);\n354\t    if (!round) {\n355\t      return c.json({ error: \"Round not found\" }, 404);\n356\t    }\n357\t\n358\t    const totalPool = round.green_pool + round.red_pool;\n359\t    const isSettled = round.phase === \"settled\" || round.phase === \"refunded\";\n360\t\n361\t    const response: CloseCallLookupResponse = {\n362\t      pda: round.pda,\n363\t      game: \"close-call\",\n364\t      phase: round.phase,\n365\t      matchId: round.round_id,\n366\t      openPrice: round.open_price,\n367\t      openPriceExpo: round.open_price_expo,\n368\t      greenPool: round.green_pool,\n369\t      redPool: round.red_pool,\n370\t      totalPool,\n371\t      greenEntries: round.green_entries,\n372\t      redEntries: round.red_entries,\n373\t      greenCount: round.green_entries.length,\n374\t      redCount: round.red_entries.length,\n375\t      createdAt: round.created_at.toISOString(),\n376\t    };\n377\t\n378\t    if (isSettled) {\n379\t      response.closePrice = round.close_price;\n380\t      response.outcome = round.outcome;\n381\t      response.totalFee = round.total_fee;\n382\t      response.settleTx = round.settle_tx;\n383\t      response.settledAt = round.settled_at ? round.settled_at.toISOString() : null;\n384\t      response.verification = {\n385\t        priceSource: \"Pyth Network push oracle\",\n386\t        outcome:\n387\t          round.outcome === \"green\"\n388\t            ? \"close > open\"\n389\t            : round.outcome === \"red\"\n390\t              ? \"close < open\"\n391\t              : \"refund (equal price, one-sided, or single player)\",\n392\t      };\n393\t    }\n394\t\n395\t    return c.json(response, 200);\n396\t  });\n397\t\n398\t  // -----------------------------------------------------------------------\n399\t  // GET /candles — returns last N minute-boundary candles from DB\n400\t  // -----------------------------------------------------------------------\n401\t\n402\t  app.openapi(candlesRoute, async (c) => {\n403\t    const { limit: limitParam } = c.req.valid(\"query\");\n404\t    const limit = Math.min(Math.max(parseInt(limitParam ?? \"5\", 10) || 5, 1), 60);\n405\t\n406\t    try {\n407\t      // We need limit+1 boundary prices to form `limit` candles.\n408\t      // Each candle = two consecutive boundary prices.\n409\t      const candles_raw = await db.getCloseCallCandles(limit + 1);\n410\t      const rows = candles_raw.map((cc) => ({\n411\t        minute_ts: String(cc.minuteTs),\n412\t        price_human: cc.priceHuman,\n413\t      }));\n414\t\n415\t      if (rows.length < 2) {\n416\t        // Not enough data to form even one candle\n417\t        const bp = clockWorker.getLatestBoundaryPrice();\n418\t        return c.json({\n419\t          candles: [],\n420\t          currentOpenPrice: bp ? bp.priceHuman : null,\n421\t          currentMinuteTs: bp ? bp.minuteTs : null,\n422\t        }, 200);\n423\t      }\n424\t\n425\t      // Rows come DESC, reverse to ASC for pairing\n426\t      const sorted = rows.reverse();\n427\t\n428\t      // Build candles from consecutive boundary pairs\n429\t      const candles: Array<{\n430\t        openTime: number;\n431\t        closeTime: number;\n432\t        open: number;\n433\t        close: number;\n434\t        high: number;\n435\t        low: number;\n436\t        outcome: \"green\" | \"red\" | null;\n437\t      }> = [];\n438\t\n439\t      for (let i = 0; i < sorted.length - 1; i++) {\n440\t        const openBoundary = sorted[i]!;\n441\t        const closeBoundary = sorted[i + 1]!;\n442\t        const openTs = Number(openBoundary.minute_ts);\n443\t        const closeTs = Number(closeBoundary.minute_ts);\n444\t        const open = openBoundary.price_human;\n445\t        const close = closeBoundary.price_human;\n446\t\n447\t        // Only pair consecutive minute boundaries (60s apart)\n448\t        if (closeTs - openTs !== 60) continue;\n449\t\n450\t        const high = Math.max(open, close);\n451\t        const low = Math.min(open, close);\n452\t\n453\t        // Determine outcome: green if close > open, red if close < open, null if equal\n454\t        let outcome: \"green\" | \"red\" | null = null;\n455\t        if (close > open) outcome = \"green\";\n456\t        else if (close < open) outcome = \"red\";\n457\t\n458\t        candles.push({\n459\t          openTime: openTs * 1000,\n460\t          closeTime: closeTs * 1000,\n461\t          open,\n462\t          close,\n463\t          high,\n464\t          low,\n465\t          outcome,\n466\t        });\n467\t      }\n468\t\n469\t      // Current open price = latest boundary price\n470\t      const bp = clockWorker.getLatestBoundaryPrice();\n471\t\n472\t      return c.json({\n473\t        candles,\n474\t        currentOpenPrice: bp ? bp.priceHuman : null,\n475\t        currentMinuteTs: bp ? bp.minuteTs : null,\n476\t      }, 200);\n477\t    } catch (err) {\n478\t      logger.error(\"closecall candles: query failed\", {\n479\t        error: err instanceof Error ? err.message : String(err),\n480\t      });\n481\t      return c.json({ candles: [], currentOpenPrice: null, currentMinuteTs: null }, 200);\n482\t    }\n483\t  });\n484\t\n485\t  /**\n486\t   * POST /bet — co-sign a bet transaction.\n487\t   *\n488\t   * Uses init_if_needed — creates round on first bet, joins on subsequent.\n489\t   * The server partially signs (pays rent on first call), and returns the\n490\t   * serialized tx for the frontend to add the player signature + submit.\n491\t   */\n492\t  app.openapi(betRoute, async (c) => {\n493\t    // 1. Parse + validate request body (Zod handles shape validation)\n494\t    const body = c.req.valid(\"json\");\n495\t\n496\t    // Additional validation: base58 format\n497\t    if (!isValidBase58(body.playerPubkey)) {\n498\t      logger.warn(\"closecall bet rejected: invalid playerPubkey format\", {\n499\t        playerPubkey: body.playerPubkey,\n500\t      });\n501\t      return c.json({ error: \"playerPubkey must be a valid base58 public key\" }, 400);\n502\t    }\n503\t\n504\t    // 2. Validate playerPubkey\n505\t    let playerPubkey: PublicKey;\n506\t    try {\n507\t      playerPubkey = new PublicKey(body.playerPubkey);\n508\t    } catch {\n509\t      return c.json({ error: \"playerPubkey is not a valid public key\" }, 400);\n510\t    }\n511\t\n512\t    // 3. Enforce that the authenticated session is bound to the requested wallet\n513\t    const userId = c.get(\"userId\");\n514\t    if (!userId) {\n515\t      return c.json({ error: \"Authentication required\" }, 401);\n516\t    }\n517\t\n518\t    const profile = await db.getProfileByUserId(userId);\n519\t    if (!profile) {\n520\t      return c.json({ error: \"Profile not found\" }, 404);\n521\t    }\n522\t\n523\t    if (profile.wallet !== body.playerPubkey) {\n524\t      logger.warn(\"closecall bet rejected: wallet mismatch with profile\", {\n525\t        bodyWallet: body.playerPubkey,\n526\t        profileWallet: profile.wallet,\n527\t      });\n528\t      return c.json({ error: \"Wallet does not match authenticated session\" }, 403);\n529\t    }\n530\t\n531\t    // 4. Get the latest boundary price from the clock worker (cached)\n532\t    const boundaryPrice = clockWorker.getLatestBoundaryPrice();\n533\t    if (!boundaryPrice) {\n534\t      logger.warn(\"closecall bet: no cached boundary price\");\n535\t      return c.json(\n536\t        { error: \"No price data available yet. Wait for next minute boundary.\" },\n537\t        503,\n538\t      );\n539\t    }\n540\t\n541\t    // 5. Compute minuteTs + build partially-signed tx\n542\t    const minuteTs = BigInt(Math.floor(Date.now() / 60_000) * 60);\n543\t    const sideNum = body.side === \"green\" ? 0 : 1;\n544\t\n545\t    try {\n546\t      const { tx, roundPda } = await buildCloseCallBetTx(\n547\t        { connection, serverKeypair },\n548\t        playerPubkey,\n549\t        minuteTs,\n550\t        sideNum,\n551\t        BigInt(body.amountLamports),\n552\t        boundaryPrice.price,\n553\t        boundaryPrice.expo,\n554\t      );\n555\t\n556\t      const serialized = tx.serialize({ requireAllSignatures: false }).toString(\"base64\");\n557\t\n558\t      // Persist round to DB (upsert — idempotent if round already exists)\n559\t      try {\n560\t        await db.insertCloseCallRound({\n561\t          roundId: String(Number(minuteTs)),\n562\t          pda: roundPda.toBase58(),\n563\t          serverKey: serverKeypair.publicKey.toBase58(),\n564\t          openPrice: Number(boundaryPrice.price),\n565\t          openPriceExpo: boundaryPrice.expo,\n566\t        });\n567\t      } catch (dbErr) {\n568\t        logger.warn(\"closecall bet: DB round insert failed (tx still returned)\", {\n569\t          error: dbErr instanceof Error ? dbErr.message : String(dbErr),\n570\t        });\n571\t      }\n572\t\n573\t      // Write participation-time game entry\n574\t      try {\n575\t        await db.upsertGameEntry({\n576\t          userId: profile.user_id,\n577\t          wallet: body.playerPubkey,\n578\t          game: \"closecall\",\n579\t          roundPda: roundPda.toBase58(),\n580\t          matchId: String(Number(minuteTs)),\n581\t          amountLamports: body.amountLamports,\n582\t          side: body.side,\n583\t        });\n584\t      } catch (entryErr) {\n585\t        logger.warn(\"closecall bet: game_entry insert failed\", {\n586\t          error: entryErr instanceof Error ? entryErr.message : String(entryErr),\n587\t        });\n588\t      }\n589\t\n590\t      logger.info(\"closecall bet: tx built\", {\n591\t        minuteTs: Number(minuteTs),\n592\t        roundPda: roundPda.toBase58(),\n593\t        player: body.playerPubkey,\n594\t        side: body.side,\n595\t        amountLamports: body.amountLamports,\n596\t        openPrice: boundaryPrice.priceHuman,\n597\t      });\n598\t\n599\t      return c.json({\n600\t        transaction: serialized,\n601\t        minuteTs: Number(minuteTs),\n602\t        roundPda: roundPda.toBase58(),\n603\t      }, 200);\n604\t    } catch (err) {\n605\t      logger.error(\"closecall bet: tx build failed\", {\n606\t        error: err instanceof Error ? err.message : String(err),\n607\t      });\n608\t      return c.json({ error: \"Failed to build transaction\" }, 500);\n609\t    }\n610\t  });\n611\t\n612\t  return app;\n613\t}\n614\t"}]},"parent_tool_use_id":null,"session_id":"a8190fd2-127a-4607-a6d7-99b6b936e439","uuid":"5b41f4e3-29c5-4511-bb7e-aa0fc6aa01e4","timestamp":"2026-04-22T10:24:17.456Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/closecall.ts","content":"/**\n * Close Call API routes.\n *\n * GET  /closecall/current-round  — active round + pool state\n * GET  /closecall/history        — last N settled/refunded rounds\n * GET  /closecall/by-id/:roundId — lookup by round ID (minute timestamp)\n * GET  /closecall/candles        — last N minute-boundary candles from DB\n * POST /closecall/bet            — co-sign a bet tx (creates round or joins)\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\nimport type { CloseCallRound, Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { buildCloseCallBetTx } from \"../worker/settle-tx.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { decodeCloseCallRound, type DecodedCloseCallRound } from \"../worker/account-decoder.js\";\nimport type { CloseCallClockWorker } from \"../worker/closecall-clock.js\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport {\n  ErrorResponseSchema,\n  CloseCallBetResponseSchema,\n  CandleSchema,\n  CloseCallRoundSchema,\n  UnifiedCloseCallRoundResponseSchema,\n  listEnvelopeResponseSchema,\n  roundEnvelopeResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface CloseCallRoutesDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  clockWorker: CloseCallClockWorker;\n}\n\n/** Minimum wager in lamports: 0.001 SOL */\nconst MIN_WAGER_LAMPORTS = 1_000_000;\nconst MAX_WAGER_LAMPORTS = 100_000_000_000; // 100 SOL\n\nfunction isValidBase58(s: string): boolean {\n  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n}\n\n/** Convert a minuteTs bigint to an 8-byte LE buffer (for PDA seeds). */\nfunction minuteTsToBuffer(ts: bigint): Buffer {\n  const buf = Buffer.alloc(8);\n  buf.writeBigInt64LE(ts);\n  return buf;\n}\n\n/** Derive the CloseCallRound PDA for a given minute timestamp. */\nfunction deriveCloseCallRoundPda(minuteTs: bigint): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n    CLOSECALL_PROGRAM_ID,\n  );\n  return pda;\n}\n\nconst PHASE_NAMES = [\"open\", \"settled\", \"refunded\"] as const;\nconst OUTCOME_NAMES = [\"pending\", \"green\", \"red\", \"refund\"] as const;\n\ntype CloseCallRoundResponse = z.infer<typeof CloseCallRoundSchema>;\ntype CloseCallLookupResponse = z.infer<typeof UnifiedCloseCallRoundResponseSchema>;\n\n/** Format a decoded on-chain round into the same shape as formatCloseCallRound. */\nfunction formatOnChainRound(\n  round: DecodedCloseCallRound,\n  pda: PublicKey,\n): CloseCallRoundResponse {\n  const greenEntries = round.greenEntries.map((e) => ({\n    player: e.player.toBase58(),\n    amountLamports: Number(e.amountLamports),\n  }));\n  const redEntries = round.redEntries.map((e) => ({\n    player: e.player.toBase58(),\n    amountLamports: Number(e.amountLamports),\n  }));\n  const greenPool = Number(round.greenPool);\n  const redPool = Number(round.redPool);\n  const totalPool = greenPool + redPool;\n\n  return {\n    roundId: Number(round.minuteTs).toString(),\n    pda: pda.toBase58(),\n    phase: PHASE_NAMES[round.phase] ?? \"open\",\n    openPrice: Number(round.openPrice),\n    openPriceExpo: round.openPriceExpo,\n    closePrice: round.phase === 0 ? null : Number(round.closePrice),\n    outcome: OUTCOME_NAMES[round.outcome] ?? \"pending\",\n    greenPool,\n    redPool,\n    totalPool,\n    totalFee: Number(round.totalFee),\n    greenEntries,\n    redEntries,\n    greenCount: greenEntries.length,\n    redCount: redEntries.length,\n    settleTx: null,\n    createdAt: new Date(Number(round.createdAt) * 1000).toISOString(),\n    settledAt: null,\n  };\n}\n\nfunction formatCloseCallRound(round: CloseCallRound): CloseCallRoundResponse {\n  const totalPool = round.green_pool + round.red_pool;\n  return {\n    roundId: round.round_id,\n    pda: round.pda,\n    phase: round.phase,\n    openPrice: round.open_price,\n    openPriceExpo: round.open_price_expo,\n    closePrice: round.close_price,\n    outcome: round.outcome,\n    greenPool: round.green_pool,\n    redPool: round.red_pool,\n    totalPool,\n    totalFee: round.total_fee,\n    greenEntries: round.green_entries,\n    redEntries: round.red_entries,\n    greenCount: round.green_entries.length,\n    redCount: round.red_entries.length,\n    settleTx: round.settle_tx,\n    createdAt: round.created_at.toISOString(),\n    settledAt: round.settled_at ? round.settled_at.toISOString() : null,\n  };\n}\n\n// ── Request schemas ──────────────────────────────────────────────────────\n\nconst LimitQuerySchema = z.object({\n  limit: z.string().optional(),\n});\n\nconst RoundIdParamSchema = z.object({\n  roundId: z.string(),\n});\n\nconst CloseCallBetBodySchema = z.object({\n  playerPubkey: z.string(),\n  side: z.enum([\"green\", \"red\"]),\n  amountLamports: z.number().int().min(MIN_WAGER_LAMPORTS).max(MAX_WAGER_LAMPORTS),\n});\n\n// ── Route definitions ────────────────────────────────────────────────────\n\nconst CloseCallCurrentResponseSchema = roundEnvelopeResponseSchema(\n  \"round\",\n  CloseCallRoundSchema,\n  { nullable: true },\n);\n\nconst CloseCallHistoryResponseSchema = listEnvelopeResponseSchema(\n  \"rounds\",\n  CloseCallRoundSchema,\n);\n\nconst currentRoundRoute = createRoute({\n  method: \"get\",\n  path: \"/current-round\",\n  tags: [\"CloseCall\"],\n  summary: \"Get active Close Call round\",\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: CloseCallCurrentResponseSchema,\n        },\n      },\n      description: \"Active round or null\",\n    },\n  },\n});\n\nconst ccHistoryRoute = createRoute({\n  method: \"get\",\n  path: \"/history\",\n  tags: [\"CloseCall\"],\n  summary: \"Get recent settled/refunded Close Call rounds\",\n  request: {\n    query: LimitQuerySchema,\n  },\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: CloseCallHistoryResponseSchema,\n        },\n      },\n      description: \"List of settled rounds\",\n    },\n  },\n});\n\nconst ccByIdRoute = createRoute({\n  method: \"get\",\n  path: \"/by-id/{roundId}\",\n  tags: [\"CloseCall\"],\n  summary: \"Lookup Close Call round by ID\",\n  request: {\n    params: RoundIdParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: UnifiedCloseCallRoundResponseSchema } },\n      description: \"Round found\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Invalid round ID format\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Round not found\",\n    },\n  },\n});\n\nconst candlesRoute = createRoute({\n  method: \"get\",\n  path: \"/candles\",\n  tags: [\"CloseCall\"],\n  summary: \"Get recent minute-boundary candles\",\n  request: {\n    query: LimitQuerySchema,\n  },\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: z.object({\n            candles: z.array(CandleSchema),\n            currentOpenPrice: z.number().nullable(),\n            currentMinuteTs: z.number().int().nullable(),\n          }),\n        },\n      },\n      description: \"Candle data\",\n    },\n  },\n});\n\nconst betRoute = createRoute({\n  method: \"post\",\n  path: \"/bet\",\n  tags: [\"CloseCall\"],\n  summary: \"Co-sign a Close Call bet transaction\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": { schema: CloseCallBetBodySchema },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: CloseCallBetResponseSchema } },\n      description: \"Bet transaction built successfully\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Invalid request\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Authentication required\",\n    },\n    403: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Wallet mismatch\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Profile not found\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Transaction build failed\",\n    },\n    503: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"No price data available\",\n    },\n  },\n});\n\n// ── Factory ──────────────────────────────────────────────────────────────\n\nexport function createCloseCallRoutes(deps: CloseCallRoutesDeps) {\n  const { db, connection, serverKeypair, clockWorker } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  app.openapi(currentRoundRoute, async (c) => {\n    // Derive PDAs for current and previous minute — the round may still be\n    // open from the previous minute if not yet settled.\n    const nowMinuteTs = BigInt(Math.floor(Date.now() / 60_000) * 60);\n    const prevMinuteTs = nowMinuteTs - 60n;\n\n    const currentPda = deriveCloseCallRoundPda(nowMinuteTs);\n    const prevPda = deriveCloseCallRoundPda(prevMinuteTs);\n\n    try {\n      const [currentInfo, prevInfo] = await Promise.all([\n        connection.getAccountInfo(currentPda),\n        connection.getAccountInfo(prevPda),\n      ]);\n\n      // Prefer the current minute's round; fall back to previous if it's still open\n      if (currentInfo) {\n        const round = decodeCloseCallRound(Buffer.from(currentInfo.data));\n        return c.json({ round: formatOnChainRound(round, currentPda) }, 200);\n      }\n\n      if (prevInfo) {\n        const round = decodeCloseCallRound(Buffer.from(prevInfo.data));\n        // Only return previous-minute round if it's still open (phase 0)\n        if (round.phase === 0) {\n          return c.json({ round: formatOnChainRound(round, prevPda) }, 200);\n        }\n      }\n\n      return c.json({ round: null }, 200);\n    } catch (err) {\n      logger.error(\"closecall current-round: on-chain lookup failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ round: null }, 200);\n    }\n  });\n\n  app.openapi(ccHistoryRoute, async (c) => {\n    const { limit: limitParam } = c.req.valid(\"query\");\n    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 100);\n    const rounds = await db.getCloseCallHistory(limit);\n    return c.json({ rounds: rounds.map(formatCloseCallRound) }, 200);\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /by-id/:roundId — lookup by round ID (numeric minute timestamp)\n  // -----------------------------------------------------------------------\n\n  app.openapi(ccByIdRoute, async (c) => {\n    const { roundId } = c.req.valid(\"param\");\n    if (!/^[0-9]{1,20}$/.test(roundId)) {\n      return c.json({ error: \"roundId must be a numeric timestamp\" }, 400);\n    }\n\n    const round = await db.getCloseCallRound(roundId);\n    if (!round) {\n      return c.json({ error: \"Round not found\" }, 404);\n    }\n\n    const totalPool = round.green_pool + round.red_pool;\n    const isSettled = round.phase === \"settled\" || round.phase === \"refunded\";\n\n    const response: CloseCallLookupResponse = {\n      pda: round.pda,\n      game: \"close-call\",\n      phase: round.phase,\n      matchId: round.round_id,\n      openPrice: round.open_price,\n      openPriceExpo: round.open_price_expo,\n      greenPool: round.green_pool,\n      redPool: round.red_pool,\n      totalPool,\n      greenEntries: round.green_entries,\n      redEntries: round.red_entries,\n      greenCount: round.green_entries.length,\n      redCount: round.red_entries.length,\n      createdAt: round.created_at.toISOString(),\n    };\n\n    if (isSettled) {\n      response.closePrice = round.close_price;\n      response.outcome = round.outcome;\n      response.totalFee = round.total_fee;\n      response.settleTx = round.settle_tx;\n      response.settledAt = round.settled_at ? round.settled_at.toISOString() : null;\n      response.verification = {\n        priceSource: \"Pyth Network push oracle\",\n        outcome:\n          round.outcome === \"green\"\n            ? \"close > open\"\n            : round.outcome === \"red\"\n              ? \"close < open\"\n              : \"refund (equal price, one-sided, or single player)\",\n      };\n    }\n\n    return c.json(response, 200);\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /candles — returns last N minute-boundary candles from DB\n  // -----------------------------------------------------------------------\n\n  app.openapi(candlesRoute, async (c) => {\n    const { limit: limitParam } = c.req.valid(\"query\");\n    const limit = Math.min(Math.max(parseInt(limitParam ?? \"5\", 10) || 5, 1), 60);\n\n    try {\n      // We need limit+1 boundary prices to form `limit` candles.\n      // Each candle = two consecutive boundary prices.\n      const candles_raw = await db.getCloseCallCandles(limit + 1);\n      const rows = candles_raw.map((cc) => ({\n        minute_ts: String(cc.minuteTs),\n        price_human: cc.priceHuman,\n      }));\n\n      if (rows.length < 2) {\n        // Not enough data to form even one candle\n        const bp = clockWorker.getLatestBoundaryPrice();\n        return c.json({\n          candles: [],\n          currentOpenPrice: bp ? bp.priceHuman : null,\n          currentMinuteTs: bp ? bp.minuteTs : null,\n        }, 200);\n      }\n\n      // Rows come DESC, reverse to ASC for pairing\n      const sorted = rows.reverse();\n\n      // Build candles from consecutive boundary pairs\n      const candles: Array<{\n        openTime: number;\n        closeTime: number;\n        open: number;\n        close: number;\n        high: number;\n        low: number;\n        outcome: \"green\" | \"red\" | null;\n      }> = [];\n\n      for (let i = 0; i < sorted.length - 1; i++) {\n        const openBoundary = sorted[i]!;\n        const closeBoundary = sorted[i + 1]!;\n        const openTs = Number(openBoundary.minute_ts);\n        const closeTs = Number(closeBoundary.minute_ts);\n        const open = openBoundary.price_human;\n        const close = closeBoundary.price_human;\n\n        // Only pair consecutive minute boundaries (60s apart)\n        if (closeTs - openTs !== 60) continue;\n\n        const high = Math.max(open, close);\n        const low = Math.min(open, close);\n\n        // Determine outcome: green if close > open, red if close < open, null if equal\n        let outcome: \"green\" | \"red\" | null = null;\n        if (close > open) outcome = \"green\";\n        else if (close < open) outcome = \"red\";\n\n        candles.push({\n          openTime: openTs * 1000,\n          closeTime: closeTs * 1000,\n          open,\n          close,\n          high,\n          low,\n          outcome,\n        });\n      }\n\n      // Current open price = latest boundary price\n      const bp = clockWorker.getLatestBoundaryPrice();\n\n      return c.json({\n        candles,\n        currentOpenPrice: bp ? bp.priceHuman : null,\n        currentMinuteTs: bp ? bp.minuteTs : null,\n      }, 200);\n    } catch (err) {\n      logger.error(\"closecall candles: query failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ candles: [], currentOpenPrice: null, currentMinuteTs: null }, 200);\n    }\n  });\n\n  /**\n   * POST /bet — co-sign a bet transaction.\n   *\n   * Uses init_if_needed — creates round on first bet, joins on subsequent.\n   * The server partially signs (pays rent on first call), and returns the\n   * serialized tx for the frontend to add the player signature + submit.\n   */\n  app.openapi(betRoute, async (c) => {\n    // 1. Parse + validate request body (Zod handles shape validation)\n    const body = c.req.valid(\"json\");\n\n    // Additional validation: base58 format\n    if (!isValidBase58(body.playerPubkey)) {\n      logger.warn(\"closecall bet rejected: invalid playerPubkey format\", {\n        playerPubkey: body.playerPubkey,\n      });\n      return c.json({ error: \"playerPubkey must be a valid base58 public key\" }, 400);\n    }\n\n    // 2. Validate playerPubkey\n    let playerPubkey: PublicKey;\n    try {\n      playerPubkey = new PublicKey(body.playerPubkey);\n    } catch {\n      return c.json({ error: \"playerPubkey is not a valid public key\" }, 400);\n    }\n\n    // 3. Enforce that the authenticated session is bound to the requested wallet\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return c.json({ error: \"Profile not found\" }, 404);\n    }\n\n    if (profile.wallet !== body.playerPubkey) {\n      logger.warn(\"closecall bet rejected: wallet mismatch with profile\", {\n        bodyWallet: body.playerPubkey,\n        profileWallet: profile.wallet,\n      });\n      return c.json({ error: \"Wallet does not match authenticated session\" }, 403);\n    }\n\n    // 4. Get the latest boundary price from the clock worker (cached)\n    const boundaryPrice = clockWorker.getLatestBoundaryPrice();\n    if (!boundaryPrice) {\n      logger.warn(\"closecall bet: no cached boundary price\");\n      return c.json(\n        { error: \"No price data available yet. Wait for next minute boundary.\" },\n        503,\n      );\n    }\n\n    // 5. Compute minuteTs + build partially-signed tx\n    const minuteTs = BigInt(Math.floor(Date.now() / 60_000) * 60);\n    const sideNum = body.side === \"green\" ? 0 : 1;\n\n    try {\n      const { tx, roundPda } = await buildCloseCallBetTx(\n        { connection, serverKeypair },\n        playerPubkey,\n        minuteTs,\n        sideNum,\n        BigInt(body.amountLamports),\n        boundaryPrice.price,\n        boundaryPrice.expo,\n      );\n\n      const serialized = tx.serialize({ requireAllSignatures: false }).toString(\"base64\");\n\n      // Persist round to DB (upsert — idempotent if round already exists)\n      try {\n        await db.insertCloseCallRound({\n          roundId: String(Number(minuteTs)),\n          pda: roundPda.toBase58(),\n          serverKey: serverKeypair.publicKey.toBase58(),\n          openPrice: Number(boundaryPrice.price),\n          openPriceExpo: boundaryPrice.expo,\n        });\n      } catch (dbErr) {\n        logger.warn(\"closecall bet: DB round insert failed (tx still returned)\", {\n          error: dbErr instanceof Error ? dbErr.message : String(dbErr),\n        });\n      }\n\n      // Write participation-time game entry\n      try {\n        await db.upsertGameEntry({\n          userId: profile.user_id,\n          wallet: body.playerPubkey,\n          game: \"closecall\",\n          roundPda: roundPda.toBase58(),\n          matchId: String(Number(minuteTs)),\n          amountLamports: body.amountLamports,\n          side: body.side,\n        });\n      } catch (entryErr) {\n        logger.warn(\"closecall bet: game_entry insert failed\", {\n          error: entryErr instanceof Error ? entryErr.message : String(entryErr),\n        });\n      }\n\n      logger.info(\"closecall bet: tx built\", {\n        minuteTs: Number(minuteTs),\n        roundPda: roundPda.toBase58(),\n        player: body.playerPubkey,\n        side: body.side,\n        amountLamports: body.amountLamports,\n        openPrice: boundaryPrice.priceHuman,\n      });\n\n      return c.json({\n        transaction: serialized,\n        minuteTs: Number(minuteTs),\n        roundPda: roundPda.toBase58(),\n      }, 200);\n    } catch (err) {\n      logger.error(\"closecall bet: tx build failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ error: \"Failed to build transaction\" }, 500);\n    }\n  });\n\n  return app;\n}\n","numLines":614,"startLine":1,"totalLines":614}}}
