{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QCpWnZbGoutaQjNR8PeVZ7","type":"tool_result","content":"1\t/**\n2\t * Flip You routes.\n3\t *\n4\t * POST /flip-you/create   — create a new match\n5\t * GET  /flip-you/history   — recent settled matches\n6\t * GET  /flip-you/by-id/:matchId — lookup by match ID\n7\t * GET  /flip-you/verify/:pda    — lookup by PDA with verification data\n8\t */\n9\t\n10\timport { createRoute } from \"@hono/zod-openapi\";\n11\timport { z } from \"zod\";\n12\timport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\n13\timport { generateSecret, computeCommitment, generateMatchId, deriveMatchPda } from \"../fairness.js\";\n14\timport { buildCreateMatchTx } from \"../tx-builder.js\";\n15\timport type { Db, Round, OperatorEvent } from \"../db.js\";\n16\timport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\n17\timport {\n18\t  envelope,\n19\t  ErrorEnvelopeSchema,\n20\t  ok,\n21\t  err,\n22\t} from \"../contracts/api-envelope.js\";\n23\timport { logger } from \"../logger.js\";\n24\timport type { AppEnv } from \"../hono-env.js\";\n25\timport type { PdaWatcher } from \"../worker/pda-watcher.js\";\n26\timport {\n27\t  FlipYouCreateResponseSchema,\n28\t  FlipYouRoundResponseSchema,\n29\t  RoundEntrySchema,\n30\t  listEnvelopeResponseSchema,\n31\t} from \"../contracts/validators.js\";\n32\timport { createOpenApiApp } from \"../openapi/hono.js\";\n33\t\n34\texport interface CreateRoutesDeps {\n35\t  db: Db;\n36\t  connection: Connection;\n37\t  serverKeypair: Keypair;\n38\t  pdaWatcher?: PdaWatcher;\n39\t}\n40\t\n41\t/** Minimum wager in lamports: 0.001 SOL */\n42\tconst MIN_WAGER_LAMPORTS = 1_000_000;\n43\tconst MAX_WAGER_LAMPORTS = 100_000_000_000; // 100 SOL\n44\t\n45\tfunction isValidBase58(s: string): boolean {\n46\t  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n47\t}\n48\t\n49\t// ── Request schemas ──────────────────────────────────────────────────────\n50\t\n51\tconst FlipYouCreateBodySchema = z.object({\n52\t  wallet: z.string(),\n53\t  amountLamports: z.number().int().min(MIN_WAGER_LAMPORTS).max(MAX_WAGER_LAMPORTS),\n54\t  side: z.union([z.literal(0), z.literal(1)]),\n55\t});\n56\t\n57\tconst LimitQuerySchema = z.object({\n58\t  limit: z.string().optional(),\n59\t});\n60\t\n61\tconst MatchIdParamSchema = z.object({\n62\t  matchId: z.string(),\n63\t});\n64\t\n65\tconst PdaParamSchema = z.object({\n66\t  pda: z.string(),\n67\t});\n68\t\n69\t// ── Route definitions ────────────────────────────────────────────────────\n70\t\n71\tconst createMatchRoute = createRoute({\n72\t  method: \"post\",\n73\t  path: \"/create\",\n74\t  tags: [\"FlipYou\"],\n75\t  summary: \"Create a new Flip You match\",\n76\t  security: [{ bearerAuth: [] }],\n77\t  request: {\n78\t    body: {\n79\t      required: true,\n80\t      content: {\n81\t        \"application/json\": { schema: FlipYouCreateBodySchema },\n82\t      },\n83\t    },\n84\t  },\n85\t  responses: {\n86\t    200: {\n87\t      content: { \"application/json\": { schema: envelope(FlipYouCreateResponseSchema) } },\n88\t      description: \"Match created successfully\",\n89\t    },\n90\t    400: {\n91\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n92\t      description: \"Invalid wallet format\",\n93\t    },\n94\t    403: {\n95\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n96\t      description: \"Wallet mismatch with authenticated session\",\n97\t    },\n98\t    409: {\n99\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n100\t      description: \"Match ID collision\",\n101\t    },\n102\t    422: {\n103\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n104\t      description: \"Invalid request body\",\n105\t    },\n106\t    500: {\n107\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n108\t      description: \"Transaction build failed\",\n109\t    },\n110\t  },\n111\t});\n112\t\n113\tconst FlipYouHistoryResponseSchema = listEnvelopeResponseSchema(\n114\t  \"rounds\",\n115\t  FlipYouRoundResponseSchema,\n116\t);\n117\t\n118\ttype RoundEntry = z.infer<typeof RoundEntrySchema>;\n119\ttype FlipYouRoundResponse = z.infer<typeof FlipYouRoundResponseSchema>;\n120\t\n121\tconst historyRoute = createRoute({\n122\t  method: \"get\",\n123\t  path: \"/history\",\n124\t  tags: [\"FlipYou\"],\n125\t  summary: \"Get recent settled matches\",\n126\t  request: {\n127\t    query: LimitQuerySchema,\n128\t  },\n129\t  responses: {\n130\t    200: {\n131\t      content: {\n132\t        \"application/json\": {\n133\t          schema: envelope(FlipYouHistoryResponseSchema),\n134\t        },\n135\t      },\n136\t      description: \"List of settled matches\",\n137\t    },\n138\t  },\n139\t});\n140\t\n141\tconst byIdRoute = createRoute({\n142\t  method: \"get\",\n143\t  path: \"/by-id/{matchId}\",\n144\t  tags: [\"FlipYou\"],\n145\t  summary: \"Lookup match by ID\",\n146\t  request: {\n147\t    params: MatchIdParamSchema,\n148\t  },\n149\t  responses: {\n150\t    200: {\n151\t      content: { \"application/json\": { schema: envelope(FlipYouRoundResponseSchema) } },\n152\t      description: \"Match found\",\n153\t    },\n154\t    400: {\n155\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n156\t      description: \"Invalid match ID format\",\n157\t    },\n158\t    404: {\n159\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n160\t      description: \"Match not found\",\n161\t    },\n162\t  },\n163\t});\n164\t\n165\tconst verifyRoute = createRoute({\n166\t  method: \"get\",\n167\t  path: \"/verify/{pda}\",\n168\t  tags: [\"FlipYou\"],\n169\t  summary: \"Lookup match by PDA with verification data\",\n170\t  request: {\n171\t    params: PdaParamSchema,\n172\t  },\n173\t  responses: {\n174\t    200: {\n175\t      content: { \"application/json\": { schema: envelope(FlipYouRoundResponseSchema) } },\n176\t      description: \"Match verification data\",\n177\t    },\n178\t    404: {\n179\t      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n180\t      description: \"Match not found\",\n181\t    },\n182\t  },\n183\t});\n184\t\n185\t// ── Factory ──────────────────────────────────────────────────────────────\n186\t\n187\texport function createFlipYouRoutes(deps: CreateRoutesDeps) {\n188\t  const { db, connection, serverKeypair, pdaWatcher } = deps;\n189\t\n190\t  const app = createOpenApiApp<AppEnv>();\n191\t\n192\t  // POST /create\n193\t  app.openapi(createMatchRoute, async (c) => {\n194\t    // 1. Parse + validate request body (Zod handles shape validation)\n195\t    const body = c.req.valid(\"json\");\n196\t\n197\t    // Additional validation: base58 format\n198\t    if (!isValidBase58(body.wallet)) {\n199\t      logger.warn(\"flipyou create rejected: invalid wallet format\", {\n200\t        wallet: body.wallet,\n201\t      });\n202\t      return err(\n203\t        c,\n204\t        400,\n205\t        API_ERROR_CODES.INVALID_REQUEST,\n206\t        \"wallet must be a valid base58 public key\",\n207\t        { retryable: false },\n208\t      );\n209\t    }\n210\t\n211\t    // 2. Defense-in-depth: verify body wallet matches authenticated user's profile\n212\t    const userId = c.get(\"userId\");\n213\t    const profile = userId ? await db.getProfileByUserId(userId) : null;\n214\t    if (profile && body.wallet !== profile.wallet) {\n215\t      logger.warn(\"flipyou create rejected: wallet mismatch with profile\", {\n216\t        bodyWallet: body.wallet,\n217\t        profileWallet: profile.wallet,\n218\t      });\n219\t      return err(\n220\t        c,\n221\t        403,\n222\t        API_ERROR_CODES.FORBIDDEN,\n223\t        \"Wallet does not match authenticated session\",\n224\t        { retryable: false },\n225\t      );\n226\t    }\n227\t\n228\t    // 3. Validate wallet is a real public key\n229\t    let creatorPubkey: PublicKey;\n230\t    try {\n231\t      creatorPubkey = new PublicKey(body.wallet);\n232\t    } catch {\n233\t      logger.warn(\"flipyou create rejected: invalid wallet\", {\n234\t        wallet: body.wallet,\n235\t      });\n236\t      return err(\n237\t        c,\n238\t        400,\n239\t        API_ERROR_CODES.INVALID_REQUEST,\n240\t        \"wallet is not a valid public key\",\n241\t        { retryable: false },\n242\t      );\n243\t    }\n244\t\n245\t    logger.info(\"flipyou create requested\", {\n246\t      wallet: body.wallet,\n247\t      amountLamports: body.amountLamports,\n248\t      side: body.side,\n249\t    });\n250\t\n251\t    // 4. Generate secret + commitment + matchId\n252\t    const secret = generateSecret();\n253\t    const commitment = computeCommitment(secret);\n254\t    const matchId = generateMatchId();\n255\t\n256\t    // 5. Derive PDA\n257\t    const [matchPda] = deriveMatchPda(creatorPubkey, matchId);\n258\t    const matchPdaStr = matchPda.toBase58();\n259\t\n260\t    // 6. Check for duplicate PDA in DB (409 Conflict)\n261\t    const existing = await db.getRoundByPda(matchPdaStr);\n262\t    if (existing) {\n263\t      logger.warn(\"flipyou create rejected: duplicate match PDA\", {\n264\t        wallet: body.wallet,\n265\t        matchPda: matchPdaStr,\n266\t        matchId: matchId.toString(\"hex\"),\n267\t      });\n268\t      return err(\n269\t        c,\n270\t        409,\n271\t        API_ERROR_CODES.CONFLICT,\n272\t        \"Match ID collision — please retry\",\n273\t        { retryable: true },\n274\t      );\n275\t    }\n276\t\n277\t    // 7. Build + partial-sign transaction\n278\t    let transaction: string;\n279\t    let lastValidBlockHeight: number;\n280\t    try {\n281\t      const result = await buildCreateMatchTx({\n282\t        connection,\n283\t        creator: creatorPubkey,\n284\t        serverKeypair,\n285\t        commitment,\n286\t        amountLamports: body.amountLamports,\n287\t        side: body.side,\n288\t        matchId,\n289\t      });\n290\t      transaction = result.transaction;\n291\t      lastValidBlockHeight = result.lastValidBlockHeight;\n292\t    } catch (buildError) {\n293\t      logger.error(\"flipyou create failed: transaction build error\", {\n294\t        wallet: body.wallet,\n295\t        matchPda: matchPdaStr,\n296\t        matchId: matchId.toString(\"hex\"),\n297\t        error: buildError instanceof Error ? buildError.message : \"Failed to build transaction\",\n298\t      });\n299\t      return err(\n300\t        c,\n301\t        500,\n302\t        API_ERROR_CODES.PRECONDITION_FAILED,\n303\t        \"Failed to build transaction\",\n304\t      );\n305\t    }\n306\t\n307\t    // 8. Store round in DB (phase: created)\n308\t    try {\n309\t      await db.insertRound({\n310\t        pda: matchPdaStr,\n311\t        game: \"flipyou\",\n312\t        creator: body.wallet,\n313\t        serverKey: serverKeypair.publicKey.toBase58(),\n314\t        secret,\n315\t        commitment,\n316\t        amountLamports: body.amountLamports,\n317\t        side: body.side,\n318\t        matchId: matchId.toString(\"hex\"),\n319\t        phase: \"created\",\n320\t      });\n321\t    } catch (insertError) {\n322\t      // Handle race condition — another request inserted the same PDA\n323\t      if (insertError instanceof Error && insertError.message.includes(\"duplicate\")) {\n324\t        logger.warn(\"flipyou create rejected: round insert duplicate\", {\n325\t          wallet: body.wallet,\n326\t          matchPda: matchPdaStr,\n327\t          matchId: matchId.toString(\"hex\"),\n328\t        });\n329\t        return err(\n330\t          c,\n331\t          409,\n332\t          API_ERROR_CODES.CONFLICT,\n333\t          \"Match ID collision — please retry\",\n334\t          { retryable: true },\n335\t        );\n336\t      }\n337\t      logger.error(\"flipyou create failed: round insert error\", {\n338\t        wallet: body.wallet,\n339\t        matchPda: matchPdaStr,\n340\t        matchId: matchId.toString(\"hex\"),\n341\t        error: insertError instanceof Error ? insertError.message : String(insertError),\n342\t      });\n343\t      throw insertError;\n344\t    }\n345\t\n346\t    // 9. Write participation-time game entry (visible before settlement)\n347\t    try {\n348\t      if (profile) {\n349\t        await db.upsertGameEntry({\n350\t          userId: profile.user_id,\n351\t          wallet: body.wallet,\n352\t          game: \"flipyou\",\n353\t          roundPda: matchPdaStr,\n354\t          matchId: matchId.toString(\"hex\"),\n355\t          amountLamports: body.amountLamports,\n356\t          side: body.side === 0 ? \"heads\" : \"tails\",\n357\t        });\n358\t      }\n359\t    } catch (entryError) {\n360\t      // Non-fatal — entry will be created at settlement if this fails\n361\t      logger.warn(\"flipyou create: game_entry insert failed\", {\n362\t        error: entryError instanceof Error ? entryError.message : String(entryError),\n363\t      });\n364\t    }\n365\t\n366\t    // 10. Write operator event\n367\t    await db.insertOperatorEvent(matchPdaStr, \"secret_generated\", {\n368\t      creator: body.wallet,\n369\t      amountLamports: body.amountLamports,\n370\t      side: body.side,\n371\t      matchId: matchId.toString(\"hex\"),\n372\t    });\n373\t\n374\t    // 9b. Subscribe to PDA for instant join detection via WebSocket\n375\t    pdaWatcher?.watch(matchPdaStr);\n376\t\n377\t    logger.info(\"flipyou create prepared\", {\n378\t      wallet: body.wallet,\n379\t      matchPda: matchPdaStr,\n380\t      matchId: matchId.toString(\"hex\"),\n381\t      amountLamports: body.amountLamports,\n382\t      side: body.side,\n383\t      lastValidBlockHeight,\n384\t    });\n385\t\n386\t    // 10. Return response\n387\t    return ok(c, {\n388\t      transaction,\n389\t      matchPda: matchPdaStr,\n390\t      matchId: matchId.toString(\"hex\"),\n391\t      commitment: commitment.toString(\"hex\"),\n392\t      lastValidBlockHeight,\n393\t    });\n394\t  });\n395\t\n396\t  // -----------------------------------------------------------------------\n397\t  // GET /history — recent settled Flip You matches\n398\t  // -----------------------------------------------------------------------\n399\t\n400\t  app.openapi(historyRoute, async (c) => {\n401\t    const { limit: limitParam } = c.req.valid(\"query\");\n402\t    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 50);\n403\t\n404\t    const rounds = await db.getRecentSettledRounds(\"flipyou\", limit);\n405\t    const settleEvents = await db.getLatestOperatorEventsForPdas(\n406\t      rounds.map((r) => r.pda),\n407\t      \"settle_confirmed\",\n408\t    );\n409\t\n410\t    return ok(c, {\n411\t      rounds: rounds.map((r) => formatFlipYouRound(r, settleEvents.get(r.pda))),\n412\t    });\n413\t  });\n414\t\n415\t  // -----------------------------------------------------------------------\n416\t  // GET /by-id/:matchId — lookup by 16-char hex match ID\n417\t  // -----------------------------------------------------------------------\n418\t\n419\t  app.openapi(byIdRoute, async (c) => {\n420\t    const { matchId } = c.req.valid(\"param\");\n421\t    if (!/^[0-9a-f]{16}$/i.test(matchId)) {\n422\t      return err(\n423\t        c,\n424\t        400,\n425\t        API_ERROR_CODES.INVALID_REQUEST,\n426\t        \"matchId must be a 16-char hex string\",\n427\t        { retryable: false },\n428\t      );\n429\t    }\n430\t\n431\t    const round = await db.getRoundByMatchId(matchId.toLowerCase());\n432\t    if (!round || round.game !== \"flipyou\") {\n433\t      return err(c, 404, API_ERROR_CODES.MATCH_NOT_FOUND, \"Match not found\");\n434\t    }\n435\t\n436\t    return ok(c, await enrichFlipYouRound(db, round));\n437\t  });\n438\t\n439\t  // -----------------------------------------------------------------------\n440\t  // GET /verify/:pda — lookup by PDA with full verification data\n441\t  // -----------------------------------------------------------------------\n442\t\n443\t  app.openapi(verifyRoute, async (c) => {\n444\t    const { pda } = c.req.valid(\"param\");\n445\t    const round = await db.getRoundByPda(pda);\n446\t    if (!round || round.game !== \"flipyou\") {\n447\t      return err(c, 404, API_ERROR_CODES.MATCH_NOT_FOUND, \"Match not found\");\n448\t    }\n449\t\n450\t    return ok(c, await enrichFlipYouRound(db, round));\n451\t  });\n452\t\n453\t  return app;\n454\t}\n455\t\n456\t// ---------------------------------------------------------------------------\n457\t// FlipYou response formatting\n458\t// ---------------------------------------------------------------------------\n459\t\n460\tfunction getEventPayload(event: OperatorEvent | undefined): Record<string, unknown> | null {\n461\t  if (!event || typeof event.payload !== \"object\" || event.payload === null) return null;\n462\t  return event.payload as Record<string, unknown>;\n463\t}\n464\t\n465\tfunction getNullableString(value: unknown): string | null | undefined {\n466\t  if (value === null) return null;\n467\t  return typeof value === \"string\" ? value : undefined;\n468\t}\n469\t\n470\tfunction getNullableInt(value: unknown): number | null | undefined {\n471\t  if (value === null) return null;\n472\t  return typeof value === \"number\" && Number.isInteger(value) ? value : undefined;\n473\t}\n474\t\n475\tfunction getRoundEntries(value: unknown): RoundEntry[] | undefined {\n476\t  const parsed = z.array(RoundEntrySchema).safeParse(value);\n477\t  return parsed.success ? parsed.data : undefined;\n478\t}\n479\t\n480\tfunction formatFlipYouRound(round: Round, settleEvent?: OperatorEvent): FlipYouRoundResponse {\n481\t  const isSettled = round.phase === \"settled\";\n482\t  const settlePayload = getEventPayload(settleEvent);\n483\t\n484\t  const response: FlipYouRoundResponse = {\n485\t    pda: round.pda,\n486\t    game: \"flip-you\",\n487\t    phase: round.phase,\n488\t    creator: round.creator,\n489\t    commitment: round.commitment.toString(\"hex\"),\n490\t    amountLamports: round.amount_lamports,\n491\t    side: round.side,\n492\t    matchId: round.match_id,\n493\t    createdAt: round.created_at.toISOString(),\n494\t    updatedAt: round.updated_at.toISOString(),\n495\t  };\n496\t\n497\t  if (round.target_slot !== null) {\n498\t    response.targetSlot = Number(round.target_slot);\n499\t  }\n500\t\n501\t  if (isSettled) {\n502\t    response.secret = round.secret.toString(\"hex\");\n503\t    response.resultHash = round.result_hash ? round.result_hash.toString(\"hex\") : null;\n504\t    if (round.result_side !== null) {\n505\t      response.resultSide = round.result_side;\n506\t    }\n507\t    if (round.winner) {\n508\t      response.winner = round.winner;\n509\t    }\n510\t    if (round.settle_tx) {\n511\t      response.settleTx = round.settle_tx;\n512\t    }\n513\t    response.verification = {\n514\t      commitmentCheck: \"sha256(secret) == commitment\",\n515\t      resultFormula: \"sha256(secret || entropy || pda || algorithmVersion)\",\n516\t      entropySource: \"SlotHashes sysvar at target_slot\",\n517\t    };\n518\t\n519\t    if (Array.isArray(round.entries)) {\n520\t      response.entries = round.entries;\n521\t    }\n522\t\n523\t    if (settlePayload) {\n524\t      const entries = getRoundEntries(settlePayload.entries);\n525\t      const entropy = getNullableString(settlePayload.entropy);\n526\t      const payoutAmount = getNullableInt(settlePayload.payoutAmount);\n527\t      const feeAmount = getNullableInt(settlePayload.feeAmount);\n528\t\n529\t      if (!response.entries && entries) {\n530\t        response.entries = entries;\n531\t      }\n532\t      if (entropy !== undefined) {\n533\t        response.entropy = entropy;\n534\t      }\n535\t      if (payoutAmount !== undefined) {\n536\t        response.payoutAmount = payoutAmount;\n537\t      }\n538\t      if (feeAmount !== undefined) {\n539\t        response.feeAmount = feeAmount;\n540\t      }\n541\t    }\n542\t  }\n543\t\n544\t  return response;\n545\t}\n546\t\n547\tasync function enrichFlipYouRound(db: Db, round: Round) {\n548\t  let settleEvent: OperatorEvent | undefined;\n549\t  if (round.phase === \"settled\") {\n550\t    try {\n551\t      settleEvent = await db.getLatestOperatorEvent(round.pda, \"settle_confirmed\");\n552\t    } catch {\n553\t      // Gracefully degrade\n554\t    }\n555\t  }\n556\t  return formatFlipYouRound(round, settleEvent);\n557\t}\n558\t"}]},"parent_tool_use_id":null,"session_id":"a8190fd2-127a-4607-a6d7-99b6b936e439","uuid":"d09d7d61-9565-431e-a71a-76da1b390a17","timestamp":"2026-04-22T10:24:51.524Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/create.ts","content":"/**\n * Flip You routes.\n *\n * POST /flip-you/create   — create a new match\n * GET  /flip-you/history   — recent settled matches\n * GET  /flip-you/by-id/:matchId — lookup by match ID\n * GET  /flip-you/verify/:pda    — lookup by PDA with verification data\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\nimport { generateSecret, computeCommitment, generateMatchId, deriveMatchPda } from \"../fairness.js\";\nimport { buildCreateMatchTx } from \"../tx-builder.js\";\nimport type { Db, Round, OperatorEvent } from \"../db.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport { logger } from \"../logger.js\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { PdaWatcher } from \"../worker/pda-watcher.js\";\nimport {\n  FlipYouCreateResponseSchema,\n  FlipYouRoundResponseSchema,\n  RoundEntrySchema,\n  listEnvelopeResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface CreateRoutesDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  pdaWatcher?: PdaWatcher;\n}\n\n/** Minimum wager in lamports: 0.001 SOL */\nconst MIN_WAGER_LAMPORTS = 1_000_000;\nconst MAX_WAGER_LAMPORTS = 100_000_000_000; // 100 SOL\n\nfunction isValidBase58(s: string): boolean {\n  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n}\n\n// ── Request schemas ──────────────────────────────────────────────────────\n\nconst FlipYouCreateBodySchema = z.object({\n  wallet: z.string(),\n  amountLamports: z.number().int().min(MIN_WAGER_LAMPORTS).max(MAX_WAGER_LAMPORTS),\n  side: z.union([z.literal(0), z.literal(1)]),\n});\n\nconst LimitQuerySchema = z.object({\n  limit: z.string().optional(),\n});\n\nconst MatchIdParamSchema = z.object({\n  matchId: z.string(),\n});\n\nconst PdaParamSchema = z.object({\n  pda: z.string(),\n});\n\n// ── Route definitions ────────────────────────────────────────────────────\n\nconst createMatchRoute = createRoute({\n  method: \"post\",\n  path: \"/create\",\n  tags: [\"FlipYou\"],\n  summary: \"Create a new Flip You match\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": { schema: FlipYouCreateBodySchema },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(FlipYouCreateResponseSchema) } },\n      description: \"Match created successfully\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid wallet format\",\n    },\n    403: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Wallet mismatch with authenticated session\",\n    },\n    409: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Match ID collision\",\n    },\n    422: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid request body\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Transaction build failed\",\n    },\n  },\n});\n\nconst FlipYouHistoryResponseSchema = listEnvelopeResponseSchema(\n  \"rounds\",\n  FlipYouRoundResponseSchema,\n);\n\ntype RoundEntry = z.infer<typeof RoundEntrySchema>;\ntype FlipYouRoundResponse = z.infer<typeof FlipYouRoundResponseSchema>;\n\nconst historyRoute = createRoute({\n  method: \"get\",\n  path: \"/history\",\n  tags: [\"FlipYou\"],\n  summary: \"Get recent settled matches\",\n  request: {\n    query: LimitQuerySchema,\n  },\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: envelope(FlipYouHistoryResponseSchema),\n        },\n      },\n      description: \"List of settled matches\",\n    },\n  },\n});\n\nconst byIdRoute = createRoute({\n  method: \"get\",\n  path: \"/by-id/{matchId}\",\n  tags: [\"FlipYou\"],\n  summary: \"Lookup match by ID\",\n  request: {\n    params: MatchIdParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(FlipYouRoundResponseSchema) } },\n      description: \"Match found\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid match ID format\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Match not found\",\n    },\n  },\n});\n\nconst verifyRoute = createRoute({\n  method: \"get\",\n  path: \"/verify/{pda}\",\n  tags: [\"FlipYou\"],\n  summary: \"Lookup match by PDA with verification data\",\n  request: {\n    params: PdaParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(FlipYouRoundResponseSchema) } },\n      description: \"Match verification data\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Match not found\",\n    },\n  },\n});\n\n// ── Factory ──────────────────────────────────────────────────────────────\n\nexport function createFlipYouRoutes(deps: CreateRoutesDeps) {\n  const { db, connection, serverKeypair, pdaWatcher } = deps;\n\n  const app = createOpenApiApp<AppEnv>();\n\n  // POST /create\n  app.openapi(createMatchRoute, async (c) => {\n    // 1. Parse + validate request body (Zod handles shape validation)\n    const body = c.req.valid(\"json\");\n\n    // Additional validation: base58 format\n    if (!isValidBase58(body.wallet)) {\n      logger.warn(\"flipyou create rejected: invalid wallet format\", {\n        wallet: body.wallet,\n      });\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"wallet must be a valid base58 public key\",\n        { retryable: false },\n      );\n    }\n\n    // 2. Defense-in-depth: verify body wallet matches authenticated user's profile\n    const userId = c.get(\"userId\");\n    const profile = userId ? await db.getProfileByUserId(userId) : null;\n    if (profile && body.wallet !== profile.wallet) {\n      logger.warn(\"flipyou create rejected: wallet mismatch with profile\", {\n        bodyWallet: body.wallet,\n        profileWallet: profile.wallet,\n      });\n      return err(\n        c,\n        403,\n        API_ERROR_CODES.FORBIDDEN,\n        \"Wallet does not match authenticated session\",\n        { retryable: false },\n      );\n    }\n\n    // 3. Validate wallet is a real public key\n    let creatorPubkey: PublicKey;\n    try {\n      creatorPubkey = new PublicKey(body.wallet);\n    } catch {\n      logger.warn(\"flipyou create rejected: invalid wallet\", {\n        wallet: body.wallet,\n      });\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"wallet is not a valid public key\",\n        { retryable: false },\n      );\n    }\n\n    logger.info(\"flipyou create requested\", {\n      wallet: body.wallet,\n      amountLamports: body.amountLamports,\n      side: body.side,\n    });\n\n    // 4. Generate secret + commitment + matchId\n    const secret = generateSecret();\n    const commitment = computeCommitment(secret);\n    const matchId = generateMatchId();\n\n    // 5. Derive PDA\n    const [matchPda] = deriveMatchPda(creatorPubkey, matchId);\n    const matchPdaStr = matchPda.toBase58();\n\n    // 6. Check for duplicate PDA in DB (409 Conflict)\n    const existing = await db.getRoundByPda(matchPdaStr);\n    if (existing) {\n      logger.warn(\"flipyou create rejected: duplicate match PDA\", {\n        wallet: body.wallet,\n        matchPda: matchPdaStr,\n        matchId: matchId.toString(\"hex\"),\n      });\n      return err(\n        c,\n        409,\n        API_ERROR_CODES.CONFLICT,\n        \"Match ID collision — please retry\",\n        { retryable: true },\n      );\n    }\n\n    // 7. Build + partial-sign transaction\n    let transaction: string;\n    let lastValidBlockHeight: number;\n    try {\n      const result = await buildCreateMatchTx({\n        connection,\n        creator: creatorPubkey,\n        serverKeypair,\n        commitment,\n        amountLamports: body.amountLamports,\n        side: body.side,\n        matchId,\n      });\n      transaction = result.transaction;\n      lastValidBlockHeight = result.lastValidBlockHeight;\n    } catch (buildError) {\n      logger.error(\"flipyou create failed: transaction build error\", {\n        wallet: body.wallet,\n        matchPda: matchPdaStr,\n        matchId: matchId.toString(\"hex\"),\n        error: buildError instanceof Error ? buildError.message : \"Failed to build transaction\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to build transaction\",\n      );\n    }\n\n    // 8. Store round in DB (phase: created)\n    try {\n      await db.insertRound({\n        pda: matchPdaStr,\n        game: \"flipyou\",\n        creator: body.wallet,\n        serverKey: serverKeypair.publicKey.toBase58(),\n        secret,\n        commitment,\n        amountLamports: body.amountLamports,\n        side: body.side,\n        matchId: matchId.toString(\"hex\"),\n        phase: \"created\",\n      });\n    } catch (insertError) {\n      // Handle race condition — another request inserted the same PDA\n      if (insertError instanceof Error && insertError.message.includes(\"duplicate\")) {\n        logger.warn(\"flipyou create rejected: round insert duplicate\", {\n          wallet: body.wallet,\n          matchPda: matchPdaStr,\n          matchId: matchId.toString(\"hex\"),\n        });\n        return err(\n          c,\n          409,\n          API_ERROR_CODES.CONFLICT,\n          \"Match ID collision — please retry\",\n          { retryable: true },\n        );\n      }\n      logger.error(\"flipyou create failed: round insert error\", {\n        wallet: body.wallet,\n        matchPda: matchPdaStr,\n        matchId: matchId.toString(\"hex\"),\n        error: insertError instanceof Error ? insertError.message : String(insertError),\n      });\n      throw insertError;\n    }\n\n    // 9. Write participation-time game entry (visible before settlement)\n    try {\n      if (profile) {\n        await db.upsertGameEntry({\n          userId: profile.user_id,\n          wallet: body.wallet,\n          game: \"flipyou\",\n          roundPda: matchPdaStr,\n          matchId: matchId.toString(\"hex\"),\n          amountLamports: body.amountLamports,\n          side: body.side === 0 ? \"heads\" : \"tails\",\n        });\n      }\n    } catch (entryError) {\n      // Non-fatal — entry will be created at settlement if this fails\n      logger.warn(\"flipyou create: game_entry insert failed\", {\n        error: entryError instanceof Error ? entryError.message : String(entryError),\n      });\n    }\n\n    // 10. Write operator event\n    await db.insertOperatorEvent(matchPdaStr, \"secret_generated\", {\n      creator: body.wallet,\n      amountLamports: body.amountLamports,\n      side: body.side,\n      matchId: matchId.toString(\"hex\"),\n    });\n\n    // 9b. Subscribe to PDA for instant join detection via WebSocket\n    pdaWatcher?.watch(matchPdaStr);\n\n    logger.info(\"flipyou create prepared\", {\n      wallet: body.wallet,\n      matchPda: matchPdaStr,\n      matchId: matchId.toString(\"hex\"),\n      amountLamports: body.amountLamports,\n      side: body.side,\n      lastValidBlockHeight,\n    });\n\n    // 10. Return response\n    return ok(c, {\n      transaction,\n      matchPda: matchPdaStr,\n      matchId: matchId.toString(\"hex\"),\n      commitment: commitment.toString(\"hex\"),\n      lastValidBlockHeight,\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /history — recent settled Flip You matches\n  // -----------------------------------------------------------------------\n\n  app.openapi(historyRoute, async (c) => {\n    const { limit: limitParam } = c.req.valid(\"query\");\n    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 50);\n\n    const rounds = await db.getRecentSettledRounds(\"flipyou\", limit);\n    const settleEvents = await db.getLatestOperatorEventsForPdas(\n      rounds.map((r) => r.pda),\n      \"settle_confirmed\",\n    );\n\n    return ok(c, {\n      rounds: rounds.map((r) => formatFlipYouRound(r, settleEvents.get(r.pda))),\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /by-id/:matchId — lookup by 16-char hex match ID\n  // -----------------------------------------------------------------------\n\n  app.openapi(byIdRoute, async (c) => {\n    const { matchId } = c.req.valid(\"param\");\n    if (!/^[0-9a-f]{16}$/i.test(matchId)) {\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"matchId must be a 16-char hex string\",\n        { retryable: false },\n      );\n    }\n\n    const round = await db.getRoundByMatchId(matchId.toLowerCase());\n    if (!round || round.game !== \"flipyou\") {\n      return err(c, 404, API_ERROR_CODES.MATCH_NOT_FOUND, \"Match not found\");\n    }\n\n    return ok(c, await enrichFlipYouRound(db, round));\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /verify/:pda — lookup by PDA with full verification data\n  // -----------------------------------------------------------------------\n\n  app.openapi(verifyRoute, async (c) => {\n    const { pda } = c.req.valid(\"param\");\n    const round = await db.getRoundByPda(pda);\n    if (!round || round.game !== \"flipyou\") {\n      return err(c, 404, API_ERROR_CODES.MATCH_NOT_FOUND, \"Match not found\");\n    }\n\n    return ok(c, await enrichFlipYouRound(db, round));\n  });\n\n  return app;\n}\n\n// ---------------------------------------------------------------------------\n// FlipYou response formatting\n// ---------------------------------------------------------------------------\n\nfunction getEventPayload(event: OperatorEvent | undefined): Record<string, unknown> | null {\n  if (!event || typeof event.payload !== \"object\" || event.payload === null) return null;\n  return event.payload as Record<string, unknown>;\n}\n\nfunction getNullableString(value: unknown): string | null | undefined {\n  if (value === null) return null;\n  return typeof value === \"string\" ? value : undefined;\n}\n\nfunction getNullableInt(value: unknown): number | null | undefined {\n  if (value === null) return null;\n  return typeof value === \"number\" && Number.isInteger(value) ? value : undefined;\n}\n\nfunction getRoundEntries(value: unknown): RoundEntry[] | undefined {\n  const parsed = z.array(RoundEntrySchema).safeParse(value);\n  return parsed.success ? parsed.data : undefined;\n}\n\nfunction formatFlipYouRound(round: Round, settleEvent?: OperatorEvent): FlipYouRoundResponse {\n  const isSettled = round.phase === \"settled\";\n  const settlePayload = getEventPayload(settleEvent);\n\n  const response: FlipYouRoundResponse = {\n    pda: round.pda,\n    game: \"flip-you\",\n    phase: round.phase,\n    creator: round.creator,\n    commitment: round.commitment.toString(\"hex\"),\n    amountLamports: round.amount_lamports,\n    side: round.side,\n    matchId: round.match_id,\n    createdAt: round.created_at.toISOString(),\n    updatedAt: round.updated_at.toISOString(),\n  };\n\n  if (round.target_slot !== null) {\n    response.targetSlot = Number(round.target_slot);\n  }\n\n  if (isSettled) {\n    response.secret = round.secret.toString(\"hex\");\n    response.resultHash = round.result_hash ? round.result_hash.toString(\"hex\") : null;\n    if (round.result_side !== null) {\n      response.resultSide = round.result_side;\n    }\n    if (round.winner) {\n      response.winner = round.winner;\n    }\n    if (round.settle_tx) {\n      response.settleTx = round.settle_tx;\n    }\n    response.verification = {\n      commitmentCheck: \"sha256(secret) == commitment\",\n      resultFormula: \"sha256(secret || entropy || pda || algorithmVersion)\",\n      entropySource: \"SlotHashes sysvar at target_slot\",\n    };\n\n    if (Array.isArray(round.entries)) {\n      response.entries = round.entries;\n    }\n\n    if (settlePayload) {\n      const entries = getRoundEntries(settlePayload.entries);\n      const entropy = getNullableString(settlePayload.entropy);\n      const payoutAmount = getNullableInt(settlePayload.payoutAmount);\n      const feeAmount = getNullableInt(settlePayload.feeAmount);\n\n      if (!response.entries && entries) {\n        response.entries = entries;\n      }\n      if (entropy !== undefined) {\n        response.entropy = entropy;\n      }\n      if (payoutAmount !== undefined) {\n        response.payoutAmount = payoutAmount;\n      }\n      if (feeAmount !== undefined) {\n        response.feeAmount = feeAmount;\n      }\n    }\n  }\n\n  return response;\n}\n\nasync function enrichFlipYouRound(db: Db, round: Round) {\n  let settleEvent: OperatorEvent | undefined;\n  if (round.phase === \"settled\") {\n    try {\n      settleEvent = await db.getLatestOperatorEvent(round.pda, \"settle_confirmed\");\n    } catch {\n      // Gracefully degrade\n    }\n  }\n  return formatFlipYouRound(round, settleEvent);\n}\n","numLines":558,"startLine":1,"totalLines":558}}}
