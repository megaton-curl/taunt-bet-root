et,\n49\t      username: \"test\",\n50\t      username_updated_at: null,\n51\t      avatar_url: null,\n52\t      heat_multiplier: 1,\n53\t      points_balance: 0,\n54\t      created_at: new Date(),\n55\t    }));\n56\t    const insertCloseCallRound = vi.fn();\n57\t    const upsertGameEntry = vi.fn();\n58\t    const getLatestBoundaryPrice = vi.fn(() => ({\n59\t      minuteTs: 0,\n60\t      price: 1n,\n61\t      expo: -8,\n62\t      priceHuman: 1,\n63\t    }));\n64\t\n65\t    const app = buildApp(\n66\t      {\n67\t        getProfileByUserId,\n68\t        insertCloseCallRound,\n69\t        upsertGameEntry,\n70\t      },\n71\t      { getLatestBoundaryPrice },\n72\t    );\n73\t\n74\t    const token = await makeJwt(\"usr_session\");\n75\t    const res = await app.request(\"/closecall/bet\", {\n76\t      method: \"POST\",\n77\t      headers: {\n78\t        \"Content-Type\": \"application/json\",\n79\t        Authorization: `Bearer ${token}`,\n80\t      },\n81\t      body: JSON.stringify({\n82\t        playerPubkey: requestWallet,\n83\t        side: \"green\",\n84\t        amountLamports: 1_000_000,\n85\t      }),\n86\t    });\n87\t\n88\t    expect(res.status).toBe(403);\n89\t    expect(await res.json()).toEqual({\n90\t      error: \"Wallet does not match authenticated session\",\n91\t    });\n92\t    expect(getProfileByUserId).toHaveBeenCalledWith(\"usr_session\");\n93\t    expect(getLatestBoundaryPrice).not.toHaveBeenCalled();\n94\t    expect(insertCloseCallRound).not.toHaveBeenCalled();\n95\t    expect(upsertGameEntry).not.toHaveBeenCalled();\n96\t  });\n97\t\n98\t  it(\"rejects bets when the authenticated profile does not exist\", async () => {\n99\t    const getProfileByUserId = vi.fn(async () => null);\n100\t    const getLatestBoundaryPrice = vi.fn(() => ({\n101\t      minuteTs: 0,\n102\t      price: 1n,\n103\t      expo: -8,\n104\t      priceHuman: 1,\n105\t    }));\n106\t\n107\t    const app = buildApp(\n108\t      {\n109\t        getProfileByUserId,\n110\t      },\n111\t      { getLatestBoundaryPrice },\n112\t    );\n113\t\n114\t    const token = await makeJwt(\"usr_missing\");\n115\t    const res = await app.request(\"/closecall/bet\", {\n116\t      method: \"POST\",\n117\t      headers: {\n118\t        \"Content-Type\": \"application/json\",\n119\t        Authorization: `Bearer ${token}`,\n120\t      },\n121\t      body: JSON.stringify({\n122\t        playerPubkey: Keypair.generate().publicKey.toBase58(),\n123\t        side: \"red\",\n124\t        amountLamports: 1_000_000,\n125\t      }),\n126\t    });\n127\t\n128\t    expect(res.status).toBe(404);\n129\t    expect(await res.json()).toEqual({\n130\t      error: \"Profile not found\",\n131\t    });\n132\t    expect(getProfileByUserId).toHaveBeenCalledWith(\"usr_missing\");\n133\t    expect(getLatestBoundaryPrice).not.toHaveBeenCalled();\n134\t  });\n135\t});\n136\t"}]},"parent_tool_use_id":null,"session_id":"a8190fd2-127a-4607-a6d7-99b6b936e439","uuid":"790fe4e0-ac4a-4aee-b5a1-f0dbe0652ea6","timestamp":"2026-04-22T10:24:20.397Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/closecall-routes.test.ts","content":"import { describe, expect, it, vi } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport { SignJWT } from \"jose\";\nimport type { Db } from \"../db.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport { createCloseCallRoutes } from \"../routes/closecall.js\";\n\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-closecall-route-tests\");\n\nasync function makeJwt(userId: string) {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({})\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setSubject(userId)\n    .setIssuedAt(now)\n    .setExpirationTime(now + 3600)\n    .sign(JWT_SECRET);\n}\n\nfunction buildApp(db: Partial<Db>, clockWorker?: { getLatestBoundaryPrice: () => unknown }) {\n  const app = new Hono();\n\n  app.use(\"/closecall/bet\", createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }));\n  app.route(\n    \"/closecall\",\n    createCloseCallRoutes({\n      db: db as Db,\n      connection: {} as Connection,\n      serverKeypair: Keypair.generate(),\n      clockWorker: (clockWorker ?? {\n        getLatestBoundaryPrice: () => null,\n      }) as never,\n    }),\n  );\n\n  return app;\n}\n\ndescribe(\"createCloseCallRoutes\", () => {\n  it(\"rejects bets when playerPubkey does not match the authenticated profile wallet\", async () => {\n    const profileWallet = Keypair.generate().publicKey.toBase58();\n    const requestWallet = Keypair.generate().publicKey.toBase58();\n    const getProfileByUserId = vi.fn(async () => ({\n      id: 1,\n      user_id: \"usr_session\",\n      wallet: profileWallet,\n      username: \"test\",\n      username_updated_at: null,\n      avatar_url: null,\n      heat_multiplier: 1,\n      points_balance: 0,\n      created_at: new Date(),\n    }));\n    const insertCloseCallRound = vi.fn();\n    const upsertGameEntry = vi.fn();\n    const getLatestBoundaryPrice = vi.fn(() => ({\n      minuteTs: 0,\n      price: 1n,\n      expo: -8,\n      priceHuman: 1,\n    }));\n\n    const app = buildApp(\n      {\n        getProfileByUserId,\n        insertCloseCallRound,\n        upsertGameEntry,\n      },\n      { getLatestBoundaryPrice },\n    );\n\n    const token = await makeJwt(\"usr_session\");\n    const res = await app.request(\"/closecall/bet\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        playerPubkey: requestWallet,\n        side: \"green\",\n        amountLamports: 1_000_000,\n      }),\n    });\n\n    expect(res.status).toBe(403);\n    expect(await res.json()).toEqual({\n      error: \"Wallet does not match authenticated session\",\n    });\n    expect(getProfileByUserId).toHaveBeenCalledWith(\"usr_session\");\n    expect(getLatestBoundaryPrice).not.toHaveBeenCalled();\n    expect(insertCloseCallRound).not.toHaveBeenCalled();\n    expect(upsertGameEntry).not.toHaveBeenCalled();\n  });\n\n  it(\"rejects bets when the authenticated profile does not exist\", async () => {\n    const getProfileByUserId = vi.fn(async () => null);\n    const getLatestBoundaryPrice = vi.fn(() => ({\n      minuteTs: 0,\n      price: 1n,\n      expo: -8,\n      priceHuman: 1,\n    }));\n\n    const app = buildApp(\n      {\n        getProfileByUserId,\n      },\n      { getLatestBoundaryPrice },\n    );\n\n    const token = await makeJwt(\"usr_missing\");\n    const res = await app.request(\"/closecall/bet\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        playerPubkey: Keypair.generate().publicKey.toBase58(),\n        side: \"red\",\n        amountLamports: 1_000_000,\n      }),\n    });\n\n    expect(res.status).toBe(404);\n    expect(await res.json()).toEqual({\n      error: \"Profile not found\",\n    });\n    expect(getProfileByUserId).toHaveBeenCalledWith(\"usr_missing\");\n    expect(getLatestBoundaryPrice).not.toHaveBeenCalled();\n  });\n});\n","numLines":136,"startLine":1,"totalLines":136}}}
