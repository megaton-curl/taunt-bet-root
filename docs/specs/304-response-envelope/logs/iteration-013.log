{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_019KmBk6hv27L3gZWm6Ye6x7","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0172sPPJnBfaJ3FddRKMEr5T","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/src/routes/closecall.ts","content":"/**\n * Close Call API routes.\n *\n * GET  /closecall/current-round  — active round + pool state\n * GET  /closecall/history        — last N settled/refunded rounds\n * GET  /closecall/by-id/:roundId — lookup by round ID (minute timestamp)\n * GET  /closecall/candles        — last N minute-boundary candles from DB\n * POST /closecall/bet            — co-sign a bet tx (creates round or joins)\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\nimport type { CloseCallRound, Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { buildCloseCallBetTx } from \"../worker/settle-tx.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { decodeCloseCallRound, type DecodedCloseCallRound } from \"../worker/account-decoder.js\";\nimport type { CloseCallClockWorker } from \"../worker/closecall-clock.js\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport {\n  CloseCallBetResponseSchema,\n  CandleSchema,\n  CloseCallRoundSchema,\n  UnifiedCloseCallRoundResponseSchema,\n  listEnvelopeResponseSchema,\n  roundEnvelopeResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface CloseCallRoutesDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  clockWorker: CloseCallClockWorker;\n}\n\n/** Minimum wager in lamports: 0.001 SOL */\nconst MIN_WAGER_LAMPORTS = 1_000_000;\nconst MAX_WAGER_LAMPORTS = 100_000_000_000; // 100 SOL\n\nfunction isValidBase58(s: string): boolean {\n  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n}\n\n/** Convert a minuteTs bigint to an 8-byte LE buffer (for PDA seeds). */\nfunction minuteTsToBuffer(ts: bigint): Buffer {\n  const buf = Buffer.alloc(8);\n  buf.writeBigInt64LE(ts);\n  return buf;\n}\n\n/** Derive the CloseCallRound PDA for a given minute timestamp. */\nfunction deriveCloseCallRoundPda(minuteTs: bigint): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n    CLOSECALL_PROGRAM_ID,\n  );\n  return pda;\n}\n\nconst PHASE_NAMES = [\"open\", \"settled\", \"refunded\"] as const;\nconst OUTCOME_NAMES = [\"pending\", \"green\", \"red\", \"refund\"] as const;\n\ntype CloseCallRoundResponse = z.infer<typeof CloseCallRoundSchema>;\ntype CloseCallLookupResponse = z.infer<typeof UnifiedCloseCallRoundResponseSchema>;\n\n/** Format a decoded on-chain round into the same shape as formatCloseCallRound. */\nfunction formatOnChainRound(\n  round: DecodedCloseCallRound,\n  pda: PublicKey,\n): CloseCallRoundResponse {\n  const greenEntries = round.greenEntries.map((e) => ({\n    player: e.player.toBase58(),\n    amountLamports: Number(e.amountLamports),\n  }));\n  const redEntries = round.redEntries.map((e) => ({\n    player: e.player.toBase58(),\n    amountLamports: Number(e.amountLamports),\n  }));\n  const greenPool = Number(round.greenPool);\n  const redPool = Number(round.redPool);\n  const totalPool = greenPool + redPool;\n\n  return {\n    roundId: Number(round.minuteTs).toString(),\n    pda: pda.toBase58(),\n    phase: PHASE_NAMES[round.phase] ?? \"open\",\n    openPrice: Number(round.openPrice),\n    openPriceExpo: round.openPriceExpo,\n    closePrice: round.phase === 0 ? null : Number(round.closePrice),\n    outcome: OUTCOME_NAMES[round.outcome] ?? \"pending\",\n    greenPool,\n    redPool,\n    totalPool,\n    totalFee: Number(round.totalFee),\n    greenEntries,\n    redEntries,\n    greenCount: greenEntries.length,\n    redCount: redEntries.length,\n    settleTx: null,\n    createdAt: new Date(Number(round.createdAt) * 1000).toISOString(),\n    settledAt: null,\n  };\n}\n\nfunction formatCloseCallRound(round: CloseCallRound): CloseCallRoundResponse {\n  const totalPool = round.green_pool + round.red_pool;\n  return {\n    roundId: round.round_id,\n    pda: round.pda,\n    phase: round.phase,\n    openPrice: round.open_price,\n    openPriceExpo: round.open_price_expo,\n    closePrice: round.close_price,\n    outcome: round.outcome,\n    greenPool: round.green_pool,\n    redPool: round.red_pool,\n    totalPool,\n    totalFee: round.total_fee,\n    greenEntries: round.green_entries,\n    redEntries: round.red_entries,\n    greenCount: round.green_entries.length,\n    redCount: round.red_entries.length,\n    settleTx: round.settle_tx,\n    createdAt: round.created_at.toISOString(),\n    settledAt: round.settled_at ? round.settled_at.toISOString() : null,\n  };\n}\n\n// ── Request schemas ──────────────────────────────────────────────────────\n\nconst LimitQuerySchema = z.object({\n  limit: z.string().optional(),\n});\n\nconst RoundIdParamSchema = z.object({\n  roundId: z.string(),\n});\n\nconst CloseCallBetBodySchema = z.object({\n  playerPubkey: z.string(),\n  side: z.enum([\"green\", \"red\"]),\n  amountLamports: z.number().int().min(MIN_WAGER_LAMPORTS).max(MAX_WAGER_LAMPORTS),\n});\n\n// ── Route definitions ────────────────────────────────────────────────────\n\nconst CloseCallCurrentResponseSchema = roundEnvelopeResponseSchema(\n  \"round\",\n  CloseCallRoundSchema,\n  { nullable: true },\n);\n\nconst CloseCallHistoryResponseSchema = listEnvelopeResponseSchema(\n  \"rounds\",\n  CloseCallRoundSchema,\n);\n\nconst CloseCallCandlesResponseSchema = z.object({\n  candles: z.array(CandleSchema),\n  currentOpenPrice: z.number().nullable(),\n  currentMinuteTs: z.number().int().nullable(),\n});\n\nconst currentRoundRoute = createRoute({\n  method: \"get\",\n  path: \"/current-round\",\n  tags: [\"CloseCall\"],\n  summary: \"Get active Close Call round\",\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: envelope(CloseCallCurrentResponseSchema),\n        },\n      },\n      description: \"Active round or null\",\n    },\n  },\n});\n\nconst ccHistoryRoute = createRoute({\n  method: \"get\",\n  path: \"/history\",\n  tags: [\"CloseCall\"],\n  summary: \"Get recent settled/refunded Close Call rounds\",\n  request: {\n    query: LimitQuerySchema,\n  },\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: envelope(CloseCallHistoryResponseSchema),\n        },\n      },\n      description: \"List of settled rounds\",\n    },\n  },\n});\n\nconst ccByIdRoute = createRoute({\n  method: \"get\",\n  path: \"/by-id/{roundId}\",\n  tags: [\"CloseCall\"],\n  summary: \"Lookup Close Call round by ID\",\n  request: {\n    params: RoundIdParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(UnifiedCloseCallRoundResponseSchema) } },\n      description: \"Round found\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid round ID format\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Round not found\",\n    },\n  },\n});\n\nconst candlesRoute = createRoute({\n  method: \"get\",\n  path: \"/candles\",\n  tags: [\"CloseCall\"],\n  summary: \"Get recent minute-boundary candles\",\n  request: {\n    query: LimitQuerySchema,\n  },\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: envelope(CloseCallCandlesResponseSchema),\n        },\n      },\n      description: \"Candle data\",\n    },\n  },\n});\n\nconst betRoute = createRoute({\n  method: \"post\",\n  path: \"/bet\",\n  tags: [\"CloseCall\"],\n  summary: \"Co-sign a Close Call bet transaction\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": { schema: CloseCallBetBodySchema },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(CloseCallBetResponseSchema) } },\n      description: \"Bet transaction built successfully\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid wallet format\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Authentication required\",\n    },\n    403: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Wallet mismatch with authenticated session\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Profile not found\",\n    },\n    422: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid request body\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Transaction build failed\",\n    },\n    503: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"No price data available\",\n    },\n  },\n});\n\n// ── Factory ──────────────────────────────────────────────────────────────\n\nexport function createCloseCallRoutes(deps: CloseCallRoutesDeps) {\n  const { db, connection, serverKeypair, clockWorker } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  app.openapi(currentRoundRoute, async (c) => {\n    // Derive PDAs for current and previous minute — the round may still be\n    // open from the previous minute if not yet settled.\n    const nowMinuteTs = BigInt(Math.floor(Date.now() / 60_000) * 60);\n    const prevMinuteTs = nowMinuteTs - 60n;\n\n    const currentPda = deriveCloseCallRoundPda(nowMinuteTs);\n    const prevPda = deriveCloseCallRoundPda(prevMinuteTs);\n\n    try {\n      const [currentInfo, prevInfo] = await Promise.all([\n        connection.getAccountInfo(currentPda),\n        connection.getAccountInfo(prevPda),\n      ]);\n\n      // Prefer the current minute's round; fall back to previous if it's still open\n      if (currentInfo) {\n        const round = decodeCloseCallRound(Buffer.from(currentInfo.data));\n        return ok(c, { round: formatOnChainRound(round, currentPda) });\n      }\n\n      if (prevInfo) {\n        const round = decodeCloseCallRound(Buffer.from(prevInfo.data));\n        // Only return previous-minute round if it's still open (phase 0)\n        if (round.phase === 0) {\n          return ok(c, { round: formatOnChainRound(round, prevPda) });\n        }\n      }\n\n      return ok(c, { round: null });\n    } catch (fetchError) {\n      logger.error(\"closecall current-round: on-chain lookup failed\", {\n        error: fetchError instanceof Error ? fetchError.message : String(fetchError),\n      });\n      return ok(c, { round: null });\n    }\n  });\n\n  app.openapi(ccHistoryRoute, async (c) => {\n    const { limit: limitParam } = c.req.valid(\"query\");\n    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 100);\n    const rounds = await db.getCloseCallHistory(limit);\n    return ok(c, { rounds: rounds.map(formatCloseCallRound) });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /by-id/:roundId — lookup by round ID (numeric minute timestamp)\n  // -----------------------------------------------------------------------\n\n  app.openapi(ccByIdRoute, async (c) => {\n    const { roundId } = c.req.valid(\"param\");\n    if (!/^[0-9]{1,20}$/.test(roundId)) {\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"roundId must be a numeric timestamp\",\n        { retryable: false },\n      );\n    }\n\n    const round = await db.getCloseCallRound(roundId);\n    if (!round) {\n      return err(c, 404, API_ERROR_CODES.ROUND_NOT_FOUND, \"Round not found\");\n    }\n\n    const totalPool = round.green_pool + round.red_pool;\n    const isSettled = round.phase === \"settled\" || round.phase === \"refunded\";\n\n    const response: CloseCallLookupResponse = {\n      pda: round.pda,\n      game: \"close-call\",\n      phase: round.phase,\n      matchId: round.round_id,\n      openPrice: round.open_price,\n      openPriceExpo: round.open_price_expo,\n      greenPool: round.green_pool,\n      redPool: round.red_pool,\n      totalPool,\n      greenEntries: round.green_entries,\n      redEntries: round.red_entries,\n      greenCount: round.green_entries.length,\n      redCount: round.red_entries.length,\n      createdAt: round.created_at.toISOString(),\n    };\n\n    if (isSettled) {\n      response.closePrice = round.close_price;\n      response.outcome = round.outcome;\n      response.totalFee = round.total_fee;\n      response.settleTx = round.settle_tx;\n      response.settledAt = round.settled_at ? round.settled_at.toISOString() : null;\n      response.verification = {\n        priceSource: \"Pyth Network push oracle\",\n        outcome:\n          round.outcome === \"green\"\n            ? \"close > open\"\n            : round.outcome === \"red\"\n              ? \"close < open\"\n              : \"refund (equal price, one-sided, or single player)\",\n      };\n    }\n\n    return ok(c, response);\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /candles — returns last N minute-boundary candles from DB\n  // -----------------------------------------------------------------------\n\n  app.openapi(candlesRoute, async (c) => {\n    const { limit: limitParam } = c.req.valid(\"query\");\n    const limit = Math.min(Math.max(parseInt(limitParam ?? \"5\", 10) || 5, 1), 60);\n\n    try {\n      // We need limit+1 boundary prices to form `limit` candles.\n      // Each candle = two consecutive boundary prices.\n      const candles_raw = await db.getCloseCallCandles(limit + 1);\n      const rows = candles_raw.map((cc) => ({\n        minute_ts: String(cc.minuteTs),\n        price_human: cc.priceHuman,\n      }));\n\n      if (rows.length < 2) {\n        // Not enough data to form even one candle\n        const bp = clockWorker.getLatestBoundaryPrice();\n        return ok(c, {\n          candles: [],\n          currentOpenPrice: bp ? bp.priceHuman : null,\n          currentMinuteTs: bp ? bp.minuteTs : null,\n        });\n      }\n\n      // Rows come DESC, reverse to ASC for pairing\n      const sorted = rows.reverse();\n\n      // Build candles from consecutive boundary pairs\n      const candles: Array<{\n        openTime: number;\n        closeTime: number;\n        open: number;\n        close: number;\n        high: number;\n        low: number;\n        outcome: \"green\" | \"red\" | null;\n      }> = [];\n\n      for (let i = 0; i < sorted.length - 1; i++) {\n        const openBoundary = sorted[i]!;\n        const closeBoundary = sorted[i + 1]!;\n        const openTs = Number(openBoundary.minute_ts);\n        const closeTs = Number(closeBoundary.minute_ts);\n        const open = openBoundary.price_human;\n        const close = closeBoundary.price_human;\n\n        // Only pair consecutive minute boundaries (60s apart)\n        if (closeTs - openTs !== 60) continue;\n\n        const high = Math.max(open, close);\n        const low = Math.min(open, close);\n\n        // Determine outcome: green if close > open, red if close < open, null if equal\n        let outcome: \"green\" | \"red\" | null = null;\n        if (close > open) outcome = \"green\";\n        else if (close < open) outcome = \"red\";\n\n        candles.push({\n          openTime: openTs * 1000,\n          closeTime: closeTs * 1000,\n          open,\n          close,\n          high,\n          low,\n          outcome,\n        });\n      }\n\n      // Current open price = latest boundary price\n      const bp = clockWorker.getLatestBoundaryPrice();\n\n      return ok(c, {\n        candles,\n        currentOpenPrice: bp ? bp.priceHuman : null,\n        currentMinuteTs: bp ? bp.minuteTs : null,\n      });\n    } catch (queryError) {\n      logger.error(\"closecall candles: query failed\", {\n        error: queryError instanceof Error ? queryError.message : String(queryError),\n      });\n      return ok(c, { candles: [], currentOpenPrice: null, currentMinuteTs: null });\n    }\n  });\n\n  /**\n   * POST /bet — co-sign a bet transaction.\n   *\n   * Uses init_if_needed — creates round on first bet, joins on subsequent.\n   * The server partially signs (pays rent on first call), and returns the\n   * serialized tx for the frontend to add the player signature + submit.\n   */\n  app.openapi(betRoute, async (c) => {\n    // 1. Parse + validate request body (Zod handles shape validation)\n    const body = c.req.valid(\"json\");\n\n    // Additional validation: base58 format\n    if (!isValidBase58(body.playerPubkey)) {\n      logger.warn(\"closecall bet rejected: invalid playerPubkey format\", {\n        playerPubkey: body.playerPubkey,\n      });\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"playerPubkey must be a valid base58 public key\",\n        { retryable: false },\n      );\n    }\n\n    // 2. Validate playerPubkey\n    let playerPubkey: PublicKey;\n    try {\n      playerPubkey = new PublicKey(body.playerPubkey);\n    } catch {\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"playerPubkey is not a valid public key\",\n        { retryable: false },\n      );\n    }\n\n    // 3. Enforce that the authenticated session is bound to the requested wallet\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");\n    }\n\n    if (profile.wallet !== body.playerPubkey) {\n      logger.warn(\"closecall bet rejected: wallet mismatch with profile\", {\n        bodyWallet: body.playerPubkey,\n        profileWallet: profile.wallet,\n      });\n      return err(\n        c,\n        403,\n        API_ERROR_CODES.FORBIDDEN,\n        \"Wallet does not match authenticated session\",\n        { retryable: false },\n      );\n    }\n\n    // 4. Get the latest boundary price from the clock worker (cached)\n    const boundaryPrice = clockWorker.getLatestBoundaryPrice();\n    if (!boundaryPrice) {\n      logger.warn(\"closecall bet: no cached boundary price\");\n      return err(\n        c,\n        503,\n        API_ERROR_CODES.PRICE_UNAVAILABLE,\n        \"No price data available yet. Wait for next minute boundary.\",\n        { retryable: true },\n      );\n    }\n\n    // 5. Compute minuteTs + build partially-signed tx\n    const minuteTs = BigInt(Math.floor(Date.now() / 60_000) * 60);\n    const sideNum = body.side === \"green\" ? 0 : 1;\n\n    try {\n      const { tx, roundPda } = await buildCloseCallBetTx(\n        { connection, serverKeypair },\n        playerPubkey,\n        minuteTs,\n        sideNum,\n        BigInt(body.amountLamports),\n        boundaryPrice.price,\n        boundaryPrice.expo,\n      );\n\n      const serialized = tx.serialize({ requireAllSignatures: false }).toString(\"base64\");\n\n      // Persist round to DB (upsert — idempotent if round already exists)\n      try {\n        await db.insertCloseCallRound({\n          roundId: String(Number(minuteTs)),\n          pda: roundPda.toBase58(),\n          serverKey: serverKeypair.publicKey.toBase58(),\n          openPrice: Number(boundaryPrice.price),\n          openPriceExpo: boundaryPrice.expo,\n        });\n      } catch (dbErr) {\n        logger.warn(\"closecall bet: DB round insert failed (tx still returned)\", {\n          error: dbErr instanceof Error ? dbErr.message : String(dbErr),\n        });\n      }\n\n      // Write participation-time game entry\n      try {\n        await db.upsertGameEntry({\n          userId: profile.user_id,\n          wallet: body.playerPubkey,\n          game: \"closecall\",\n          roundPda: roundPda.toBase58(),\n          matchId: String(Number(minuteTs)),\n          amountLamports: body.amountLamports,\n          side: body.side,\n        });\n      } catch (entryErr) {\n        logger.warn(\"closecall bet: game_entry insert failed\", {\n          error: entryErr instanceof Error ? entryErr.message : String(entryErr),\n        });\n      }\n\n      logger.info(\"closecall bet: tx built\", {\n        minuteTs: Number(minuteTs),\n        roundPda: roundPda.toBase58(),\n        player: body.playerPubkey,\n        side: body.side,\n        amountLamports: body.amountLamports,\n        openPrice: boundaryPrice.priceHuman,\n      });\n\n      return ok(c, {\n        transaction: serialized,\n        minuteTs: Number(minuteTs),\n        roundPda: roundPda.toBase58(),\n      });\n    } catch (buildError) {\n      logger.error(\"closecall bet: tx build failed\", {\n        error: buildError instanceof Error ? buildError.message : String(buildError),\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to build transaction\",\n      );\n    }\n  });\n\n  return app;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1706,"cache_read_input_tokens":124530,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1706},"output_tokens":47,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"a8190fd2-127a-4607-a6d7-99b6b936e439","uuid":"ce0ba88e-f3a3-4661-a09d-546ebc4224f3"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0172sPPJnBfaJ3FddRKMEr5T","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/src/routes/closecall.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"a8190fd2-127a-4607-a6d7-99b6b936e439","uuid":"3c20051d-ea4a-42b8-a863-140dc413540d","timestamp":"2026-04-22T10:26:31.145Z","tool_use_result":{"type":"update","filePath":"/workspaces/rng-utopia/backend/src/routes/closecall.ts","content":"/**\n * Close Call API routes.\n *\n * GET  /closecall/current-round  — active round + pool state\n * GET  /closecall/history        — last N settled/refunded rounds\n * GET  /closecall/by-id/:roundId — lookup by round ID (minute timestamp)\n * GET  /closecall/candles        — last N minute-boundary candles from DB\n * POST /closecall/bet            — co-sign a bet tx (creates round or joins)\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\nimport type { CloseCallRound, Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { buildCloseCallBetTx } from \"../worker/settle-tx.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { decodeCloseCallRound, type DecodedCloseCallRound } from \"../worker/account-decoder.js\";\nimport type { CloseCallClockWorker } from \"../worker/closecall-clock.js\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport {\n  CloseCallBetResponseSchema,\n  CandleSchema,\n  CloseCallRoundSchema,\n  UnifiedCloseCallRoundResponseSchema,\n  listEnvelopeResponseSchema,\n  roundEnvelopeResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface CloseCallRoutesDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  clockWorker: CloseCallClockWorker;\n}\n\n/** Minimum wager in lamports: 0.001 SOL */\nconst MIN_WAGER_LAMPORTS = 1_000_000;\nconst MAX_WAGER_LAMPORTS = 100_000_000_000; // 100 SOL\n\nfunction isValidBase58(s: string): boolean {\n  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n}\n\n/** Convert a minuteTs bigint to an 8-byte LE buffer (for PDA seeds). */\nfunction minuteTsToBuffer(ts: bigint): Buffer {\n  const buf = Buffer.alloc(8);\n  buf.writeBigInt64LE(ts);\n  return buf;\n}\n\n/** Derive the CloseCallRound PDA for a given minute timestamp. */\nfunction deriveCloseCallRoundPda(minuteTs: bigint): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n    CLOSECALL_PROGRAM_ID,\n  );\n  return pda;\n}\n\nconst PHASE_NAMES = [\"open\", \"settled\", \"refunded\"] as const;\nconst OUTCOME_NAMES = [\"pending\", \"green\", \"red\", \"refund\"] as const;\n\ntype CloseCallRoundResponse = z.infer<typeof CloseCallRoundSchema>;\ntype CloseCallLookupResponse = z.infer<typeof UnifiedCloseCallRoundResponseSchema>;\n\n/** Format a decoded on-chain round into the same shape as formatCloseCallRound. */\nfunction formatOnChainRound(\n  round: DecodedCloseCallRound,\n  pda: PublicKey,\n): CloseCallRoundResponse {\n  const greenEntries = round.greenEntries.map((e) => ({\n    player: e.player.toBase58(),\n    amountLamports: Number(e.amountLamports),\n  }));\n  const redEntries = round.redEntries.map((e) => ({\n    player: e.player.toBase58(),\n    amountLamports: Number(e.amountLamports),\n  }));\n  const greenPool = Number(round.greenPool);\n  const redPool = Number(round.redPool);\n  const totalPool = greenPool + redPool;\n\n  return {\n    roundId: Number(round.minuteTs).toString(),\n    pda: pda.toBase58(),\n    phase: PHASE_NAMES[round.phase] ?? \"open\",\n    openPrice: Number(round.openPrice),\n    openPriceExpo: round.openPriceExpo,\n    closePrice: round.phase === 0 ? null : Number(round.closePrice),\n    outcome: OUTCOME_NAMES[round.outcome] ?? \"pending\",\n    greenPool,\n    redPool,\n    totalPool,\n    totalFee: Number(round.totalFee),\n    greenEntries,\n    redEntries,\n    greenCount: greenEntries.length,\n    redCount: redEntries.length,\n    settleTx: null,\n    createdAt: new Date(Number(round.createdAt) * 1000).toISOString(),\n    settledAt: null,\n  };\n}\n\nfunction formatCloseCallRound(round: CloseCallRound): CloseCallRoundResponse {\n  const totalPool = round.green_pool + round.red_pool;\n  return {\n    roundId: round.round_id,\n    pda: round.pda,\n    phase: round.phase,\n    openPrice: round.open_price,\n    openPriceExpo: round.open_price_expo,\n    closePrice: round.close_price,\n    outcome: round.outcome,\n    greenPool: round.green_pool,\n    redPool: round.red_pool,\n    totalPool,\n    totalFee: round.total_fee,\n    greenEntries: round.green_entries,\n    redEntries: round.red_entries,\n    greenCount: round.green_entries.length,\n    redCount: round.red_entries.length,\n    settleTx: round.settle_tx,\n    createdAt: round.created_at.toISOString(),\n    settledAt: round.settled_at ? round.settled_at.toISOString() : null,\n  };\n}\n\n// ── Request schemas ──────────────────────────────────────────────────────\n\nconst LimitQuerySchema = z.object({\n  limit: z.string().optional(),\n});\n\nconst RoundIdParamSchema = z.object({\n  roundId: z.string(),\n});\n\nconst CloseCallBetBodySchema = z.object({\n  playerPubkey: z.string(),\n  side: z.enum([\"green\", \"red\"]),\n  amountLamports: z.number().int().min(MIN_WAGER_LAMPORTS).max(MAX_WAGER_LAMPORTS),\n});\n\n// ── Route definitions ────────────────────────────────────────────────────\n\nconst CloseCallCurrentResponseSchema = roundEnvelopeResponseSchema(\n  \"round\",\n  CloseCallRoundSchema,\n  { nullable: true },\n);\n\nconst CloseCallHistoryResponseSchema = listEnvelopeResponseSchema(\n  \"rounds\",\n  CloseCallRoundSchema,\n);\n\nconst CloseCallCandlesResponseSchema = z.object({\n  candles: z.array(CandleSchema),\n  currentOpenPrice: z.number().nullable(),\n  currentMinuteTs: z.number().int().nullable(),\n});\n\nconst currentRoundRoute = createRoute({\n  method: \"get\",\n  path: \"/current-round\",\n  tags: [\"CloseCall\"],\n  summary: \"Get active Close Call round\",\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: envelope(CloseCallCurrentResponseSchema),\n        },\n      },\n      description: \"Active round or null\",\n    },\n  },\n});\n\nconst ccHistoryRoute = createRoute({\n  method: \"get\",\n  path: \"/history\",\n  tags: [\"CloseCall\"],\n  summary: \"Get recent settled/refunded Close Call rounds\",\n  request: {\n    query: LimitQuerySchema,\n  },\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: envelope(CloseCallHistoryResponseSchema),\n        },\n      },\n      description: \"List of settled rounds\",\n    },\n  },\n});\n\nconst ccByIdRoute = createRoute({\n  method: \"get\",\n  path: \"/by-id/{roundId}\",\n  tags: [\"CloseCall\"],\n  summary: \"Lookup Close Call round by ID\",\n  request: {\n    params: RoundIdParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(UnifiedCloseCallRoundResponseSchema) } },\n      description: \"Round found\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid round ID format\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Round not found\",\n    },\n  },\n});\n\nconst candlesRoute = createRoute({\n  method: \"get\",\n  path: \"/candles\",\n  tags: [\"CloseCall\"],\n  summary: \"Get recent minute-boundary candles\",\n  request: {\n    query: LimitQuerySchema,\n  },\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: envelope(CloseCallCandlesResponseSchema),\n        },\n      },\n      description: \"Candle data\",\n    },\n  },\n});\n\nconst betRoute = createRoute({\n  method: \"post\",\n  path: \"/bet\",\n  tags: [\"CloseCall\"],\n  summary: \"Co-sign a Close Call bet transaction\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": { schema: CloseCallBetBodySchema },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: envelope(CloseCallBetResponseSchema) } },\n      description: \"Bet transaction built successfully\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid wallet format\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Authentication required\",\n    },\n    403: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Wallet mismatch with authenticated session\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Profile not found\",\n    },\n    422: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Invalid request body\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"Transaction build failed\",\n    },\n    503: {\n      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n      description: \"No price data available\",\n    },\n  },\n});\n\n// ── Factory ──────────────────────────────────────────────────────────────\n\nexport function createCloseCallRoutes(deps: CloseCallRoutesDeps) {\n  const { db, connection, serverKeypair, clockWorker } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  app.openapi(currentRoundRoute, async (c) => {\n    // Derive PDAs for current and previous minute — the round may still be\n    // open from the previous minute if not yet settled.\n    const nowMinuteTs = BigInt(Math.floor(Date.now() / 60_000) * 60);\n    const prevMinuteTs = nowMinuteTs - 60n;\n\n    const currentPda = deriveCloseCallRoundPda(nowMinuteTs);\n    const prevPda = deriveCloseCallRoundPda(prevMinuteTs);\n\n    try {\n      const [currentInfo, prevInfo] = await Promise.all([\n        connection.getAccountInfo(currentPda),\n        connection.getAccountInfo(prevPda),\n      ]);\n\n      // Prefer the current minute's round; fall back to previous if it's still open\n      if (currentInfo) {\n        const round = decodeCloseCallRound(Buffer.from(currentInfo.data));\n        return ok(c, { round: formatOnChainRound(round, currentPda) });\n      }\n\n      if (prevInfo) {\n        const round = decodeCloseCallRound(Buffer.from(prevInfo.data));\n        // Only return previous-minute round if it's still open (phase 0)\n        if (round.phase === 0) {\n          return ok(c, { round: formatOnChainRound(round, prevPda) });\n        }\n      }\n\n      return ok(c, { round: null });\n    } catch (fetchError) {\n      logger.error(\"closecall current-round: on-chain lookup failed\", {\n        error: fetchError instanceof Error ? fetchError.message : String(fetchError),\n      });\n      return ok(c, { round: null });\n    }\n  });\n\n  app.openapi(ccHistoryRoute, async (c) => {\n    const { limit: limitParam } = c.req.valid(\"query\");\n    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 100);\n    const rounds = await db.getCloseCallHistory(limit);\n    return ok(c, { rounds: rounds.map(formatCloseCallRound) });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /by-id/:roundId — lookup by round ID (numeric minute timestamp)\n  // -----------------------------------------------------------------------\n\n  app.openapi(ccByIdRoute, async (c) => {\n    const { roundId } = c.req.valid(\"param\");\n    if (!/^[0-9]{1,20}$/.test(roundId)) {\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"roundId must be a numeric timestamp\",\n        { retryable: false },\n      );\n    }\n\n    const round = await db.getCloseCallRound(roundId);\n    if (!round) {\n      return err(c, 404, API_ERROR_CODES.ROUND_NOT_FOUND, \"Round not found\");\n    }\n\n    const totalPool = round.green_pool + round.red_pool;\n    const isSettled = round.phase === \"settled\" || round.phase === \"refunded\";\n\n    const response: CloseCallLookupResponse = {\n      pda: round.pda,\n      game: \"close-call\",\n      phase: round.phase,\n      matchId: round.round_id,\n      openPrice: round.open_price,\n      openPriceExpo: round.open_price_expo,\n      greenPool: round.green_pool,\n      redPool: round.red_pool,\n      totalPool,\n      greenEntries: round.green_entries,\n      redEntries: round.red_entries,\n      greenCount: round.green_entries.length,\n      redCount: round.red_entries.length,\n      createdAt: round.created_at.toISOString(),\n    };\n\n    if (isSettled) {\n      response.closePrice = round.close_price;\n      response.outcome = round.outcome;\n      response.totalFee = round.total_fee;\n      response.settleTx = round.settle_tx;\n      response.settledAt = round.settled_at ? round.settled_at.toISOString() : null;\n      response.verification = {\n        priceSource: \"Pyth Network push oracle\",\n        outcome:\n          round.outcome === \"green\"\n            ? \"close > open\"\n            : round.outcome === \"red\"\n              ? \"close < open\"\n              : \"refund (equal price, one-sided, or single player)\",\n      };\n    }\n\n    return ok(c, response);\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /candles — returns last N minute-boundary candles from DB\n  // -----------------------------------------------------------------------\n\n  app.openapi(candlesRoute, async (c) => {\n    const { limit: limitParam } = c.req.valid(\"query\");\n    const limit = Math.min(Math.max(parseInt(limitParam ?? \"5\", 10) || 5, 1), 60);\n\n    try {\n      // We need limit+1 boundary prices to form `limit` candles.\n      // Each candle = two consecutive boundary prices.\n      const candles_raw = await db.getCloseCallCandles(limit + 1);\n      const rows = candles_raw.map((cc) => ({\n        minute_ts: String(cc.minuteTs),\n        price_human: cc.priceHuman,\n      }));\n\n      if (rows.length < 2) {\n        // Not enough data to form even one candle\n        const bp = clockWorker.getLatestBoundaryPrice();\n        return ok(c, {\n          candles: [],\n          currentOpenPrice: bp ? bp.priceHuman : null,\n          currentMinuteTs: bp ? bp.minuteTs : null,\n        });\n      }\n\n      // Rows come DESC, reverse to ASC for pairing\n      const sorted = rows.reverse();\n\n      // Build candles from consecutive boundary pairs\n      const candles: Array<{\n        openTime: number;\n        closeTime: number;\n        open: number;\n        close: number;\n        high: number;\n        low: number;\n        outcome: \"green\" | \"red\" | null;\n      }> = [];\n\n      for (let i = 0; i < sorted.length - 1; i++) {\n        const openBoundary = sorted[i]!;\n        const closeBoundary = sorted[i + 1]!;\n        const openTs = Number(openBoundary.minute_ts);\n        const closeTs = Number(closeBoundary.minute_ts);\n        const open = openBoundary.price_human;\n        const close = closeBoundary.price_human;\n\n        // Only pair consecutive minute boundaries (60s apart)\n        if (closeTs - openTs !== 60) continue;\n\n        const high = Math.max(open, close);\n        const low = Math.min(open, close);\n\n        // Determine outcome: green if close > open, red if close < open, null if equal\n        let outcome: \"green\" | \"red\" | null = null;\n        if (close > open) outcome = \"green\";\n        else if (close < open) outcome = \"red\";\n\n        candles.push({\n          openTime: openTs * 1000,\n          closeTime: closeTs * 1000,\n          open,\n          close,\n          high,\n          low,\n          outcome,\n        });\n      }\n\n      // Current open price = latest boundary price\n      const bp = clockWorker.getLatestBoundaryPrice();\n\n      return ok(c, {\n        candles,\n        currentOpenPrice: bp ? bp.priceHuman : null,\n        currentMinuteTs: bp ? bp.minuteTs : null,\n      });\n    } catch (queryError) {\n      logger.error(\"closecall candles: query failed\", {\n        error: queryError instanceof Error ? queryError.message : String(queryError),\n      });\n      return ok(c, { candles: [], currentOpenPrice: null, currentMinuteTs: null });\n    }\n  });\n\n  /**\n   * POST /bet — co-sign a bet transaction.\n   *\n   * Uses init_if_needed — creates round on first bet, joins on subsequent.\n   * The server partially signs (pays rent on first call), and returns the\n   * serialized tx for the frontend to add the player signature + submit.\n   */\n  app.openapi(betRoute, async (c) => {\n    // 1. Parse + validate request body (Zod handles shape validation)\n    const body = c.req.valid(\"json\");\n\n    // Additional validation: base58 format\n    if (!isValidBase58(body.playerPubkey)) {\n      logger.warn(\"closecall bet rejected: invalid playerPubkey format\", {\n        playerPubkey: body.playerPubkey,\n      });\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"playerPubkey must be a valid base58 public key\",\n        { retryable: false },\n      );\n    }\n\n    // 2. Validate playerPubkey\n    let playerPubkey: PublicKey;\n    try {\n      playerPubkey = new PublicKey(body.playerPubkey);\n    } catch {\n      return err(\n        c,\n        400,\n        API_ERROR_CODES.INVALID_REQUEST,\n        \"playerPubkey is not a valid public key\",\n        { retryable: false },\n      );\n    }\n\n    // 3. Enforce that the authenticated session is bound to the requested wallet\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");\n    }\n\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");\n    }\n\n    if (profile.wallet !== body.playerPubkey) {\n      logger.warn(\"closecall bet rejected: wallet mismatch with profile\", {\n        bodyWallet: body.playerPubkey,\n        profileWallet: profile.wallet,\n      });\n      return err(\n        c,\n        403,\n        API_ERROR_CODES.FORBIDDEN,\n        \"Wallet does not match authenticated session\",\n        { retryable: false },\n      );\n    }\n\n    // 4. Get the latest boundary price from the clock worker (cached)\n    const boundaryPrice = clockWorker.getLatestBoundaryPrice();\n    if (!boundaryPrice) {\n      logger.warn(\"closecall bet: no cached boundary price\");\n      return err(\n        c,\n        503,\n        API_ERROR_CODES.PRICE_UNAVAILABLE,\n        \"No price data available yet. Wait for next minute boundary.\",\n        { retryable: true },\n      );\n    }\n\n    // 5. Compute minuteTs + build partially-signed tx\n    const minuteTs = BigInt(Math.floor(Date.now() / 60_000) * 60);\n    const sideNum = body.side === \"green\" ? 0 : 1;\n\n    try {\n      const { tx, roundPda } = await buildCloseCallBetTx(\n        { connection, serverKeypair },\n        playerPubkey,\n        minuteTs,\n        sideNum,\n        BigInt(body.amountLamports),\n        boundaryPrice.price,\n        boundaryPrice.expo,\n      );\n\n      const serialized = tx.serialize({ requireAllSignatures: false }).toString(\"base64\");\n\n      // Persist round to DB (upsert — idempotent if round already exists)\n      try {\n        await db.insertCloseCallRound({\n          roundId: String(Number(minuteTs)),\n          pda: roundPda.toBase58(),\n          serverKey: serverKeypair.publicKey.toBase58(),\n          openPrice: Number(boundaryPrice.price),\n          openPriceExpo: boundaryPrice.expo,\n        });\n      } catch (dbErr) {\n        logger.warn(\"closecall bet: DB round insert failed (tx still returned)\", {\n          error: dbErr instanceof Error ? dbErr.message : String(dbErr),\n        });\n      }\n\n      // Write participation-time game entry\n      try {\n        await db.upsertGameEntry({\n          userId: profile.user_id,\n          wallet: body.playerPubkey,\n          game: \"closecall\",\n          roundPda: roundPda.toBase58(),\n          matchId: String(Number(minuteTs)),\n          amountLamports: body.amountLamports,\n          side: body.side,\n        });\n      } catch (entryErr) {\n        logger.warn(\"closecall bet: game_entry insert failed\", {\n          error: entryErr instanceof Error ? entryErr.message : String(entryErr),\n        });\n      }\n\n      logger.info(\"closecall bet: tx built\", {\n        minuteTs: Number(minuteTs),\n        roundPda: roundPda.toBase58(),\n        player: body.playerPubkey,\n        side: body.side,\n        amountLamports: body.amountLamports,\n        openPrice: boundaryPrice.priceHuman,\n      });\n\n      return ok(c, {\n        transaction: serialized,\n        minuteTs: Number(minuteTs),\n        roundPda: roundPda.toBase58(),\n      });\n    } catch (buildError) {\n      logger.error(\"closecall bet: tx build failed\", {\n        error: buildError instanceof Error ? buildError.message : String(buildError),\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to build transaction\",\n      );\n    }\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":18,"oldLines":8,"newStart":18,"newLines":14,"lines":[" import { decodeCloseCallRound, type DecodedCloseCallRound } from \"../worker/account-decoder.js\";"," import type { CloseCallClockWorker } from \"../worker/closecall-clock.js\";"," import type { AppEnv } from \"../hono-env.js\";","+import { API_ERROR_CODES } from \"../contracts/api-errors.js\";"," import {","-  ErrorResponseSchema,","+  envelope,","+  ErrorEnvelopeSchema,","+  ok,","+  err,","+} from \"../contracts/api-envelope.js\";","+import {","   CloseCallBetResponseSchema,","   CandleSchema,","   CloseCallRoundSchema,"]},{"oldStart":158,"oldLines":6,"newStart":164,"newLines":12,"lines":["   CloseCallRoundSchema,"," );"," ","+const CloseCallCandlesResponseSchema = z.object({","+  candles: z.array(CandleSchema),","+  currentOpenPrice: z.number().nullable(),","+  currentMinuteTs: z.number().int().nullable(),","+});","+"," const currentRoundRoute = createRoute({","   method: \"get\",","   path: \"/current-round\","]},{"oldStart":167,"oldLines":7,"newStart":179,"newLines":7,"lines":["     200: {","       content: {","         \"application/json\": {","-          schema: CloseCallCurrentResponseSchema,","+          schema: envelope(CloseCallCurrentResponseSchema),","         },","       },","       description: \"Active round or null\","]},{"oldStart":187,"oldLines":7,"newStart":199,"newLines":7,"lines":["     200: {","       content: {","         \"application/json\": {","-          schema: CloseCallHistoryResponseSchema,","+          schema: envelope(CloseCallHistoryResponseSchema),","         },","       },","       description: \"List of settled rounds\","]},{"oldStart":205,"oldLines":15,"newStart":217,"newLines":15,"lines":["   },","   responses: {","     200: {","-      content: { \"application/json\": { schema: UnifiedCloseCallRoundResponseSchema } },","+      content: { \"application/json\": { schema: envelope(UnifiedCloseCallRoundResponseSchema) } },","       description: \"Round found\",","     },","     400: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Invalid round ID format\",","     },","     404: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Round not found\",","     },","   },"]},{"oldStart":231,"oldLines":11,"newStart":243,"newLines":7,"lines":["     200: {","       content: {","         \"application/json\": {","-          schema: z.object({","-            candles: z.array(CandleSchema),","-            currentOpenPrice: z.number().nullable(),","-            currentMinuteTs: z.number().int().nullable(),","-          }),","+          schema: envelope(CloseCallCandlesResponseSchema),","         },","       },","       description: \"Candle data\","]},{"oldStart":259,"oldLines":31,"newStart":267,"newLines":35,"lines":["   },","   responses: {","     200: {","-      content: { \"application/json\": { schema: CloseCallBetResponseSchema } },","+      content: { \"application/json\": { schema: envelope(CloseCallBetResponseSchema) } },","       description: \"Bet transaction built successfully\",","     },","     400: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","-      description: \"Invalid request\",","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","+      description: \"Invalid wallet format\",","     },","     401: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Authentication required\",","     },","     403: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","-      description: \"Wallet mismatch\",","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","+      description: \"Wallet mismatch with authenticated session\",","     },","     404: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Profile not found\",","     },","+    422: {","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","+      description: \"Invalid request body\",","+    },","     500: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"Transaction build failed\",","     },","     503: {","-      content: { \"application/json\": { schema: ErrorResponseSchema } },","+      content: { \"application/json\": { schema: ErrorEnvelopeSchema } },","       description: \"No price data available\",","     },","   },"]},{"oldStart":313,"oldLines":23,"newStart":325,"newLines":23,"lines":["       // Prefer the current minute's round; fall back to previous if it's still open","       if (currentInfo) {","         const round = decodeCloseCallRound(Buffer.from(currentInfo.data));","-        return c.json({ round: formatOnChainRound(round, currentPda) }, 200);","+        return ok(c, { round: formatOnChainRound(round, currentPda) });","       }"," ","       if (prevInfo) {","         const round = decodeCloseCallRound(Buffer.from(prevInfo.data));","         // Only return previous-minute round if it's still open (phase 0)","         if (round.phase === 0) {","-          return c.json({ round: formatOnChainRound(round, prevPda) }, 200);","+          return ok(c, { round: formatOnChainRound(round, prevPda) });","         }","       }"," ","-      return c.json({ round: null }, 200);","-    } catch (err) {","+      return ok(c, { round: null });","+    } catch (fetchError) {","       logger.error(\"closecall current-round: on-chain lookup failed\", {","-        error: err instanceof Error ? err.message : String(err),","+        error: fetchError instanceof Error ? fetchError.message : String(fetchError),","       });","-      return c.json({ round: null }, 200);","+      return ok(c, { round: null });","     }","   });"," "]},{"oldStart":337,"oldLines":7,"newStart":349,"newLines":7,"lines":["     const { limit: limitParam } = c.req.valid(\"query\");","     const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 100);","     const rounds = await db.getCloseCallHistory(limit);","-    return c.json({ rounds: rounds.map(formatCloseCallRound) }, 200);","+    return ok(c, { rounds: rounds.map(formatCloseCallRound) });","   });"," ","   // -----------------------------------------------------------------------"]},{"oldStart":347,"oldLines":12,"newStart":359,"newLines":18,"lines":["   app.openapi(ccByIdRoute, async (c) => {","     const { roundId } = c.req.valid(\"param\");","     if (!/^[0-9]{1,20}$/.test(roundId)) {","-      return c.json({ error: \"roundId must be a numeric timestamp\" }, 400);","+      return err(","+        c,","+        400,","+        API_ERROR_CODES.INVALID_REQUEST,","+        \"roundId must be a numeric timestamp\",","+        { retryable: false },","+      );","     }"," ","     const round = await db.getCloseCallRound(roundId);","     if (!round) {","-      return c.json({ error: \"Round not found\" }, 404);","+      return err(c, 404, API_ERROR_CODES.ROUND_NOT_FOUND, \"Round not found\");","     }"," ","     const totalPool = round.green_pool + round.red_pool;"]},{"oldStart":392,"oldLines":7,"newStart":410,"newLines":7,"lines":["       };","     }"," ","-    return c.json(response, 200);","+    return ok(c, response);","   });"," ","   // -----------------------------------------------------------------------"]},{"oldStart":415,"oldLines":11,"newStart":433,"newLines":11,"lines":["       if (rows.length < 2) {","         // Not enough data to form even one candle","         const bp = clockWorker.getLatestBoundaryPrice();","-        return c.json({","+        return ok(c, {","           candles: [],","           currentOpenPrice: bp ? bp.priceHuman : null,","           currentMinuteTs: bp ? bp.minuteTs : null,","-        }, 200);","+        });","       }"," ","       // Rows come DESC, reverse to ASC for pairing"]},{"oldStart":469,"oldLines":16,"newStart":487,"newLines":16,"lines":["       // Current open price = latest boundary price","       const bp = clockWorker.getLatestBoundaryPrice();"," ","-      return c.json({","+      return ok(c, {","         candles,","         currentOpenPrice: bp ? bp.priceHuman : null,","         currentMinuteTs: bp ? bp.minuteTs : null,","-      }, 200);","-    } catch (err) {","+      });","+    } catch (queryError) {","       logger.error(\"closecall candles: query failed\", {","-        error: err instanceof Error ? err.message : String(err),","+        error: queryError instanceof Error ? queryError.message : String(queryError),","       });","-      return c.json({ candles: [], currentOpenPrice: null, currentMinuteTs: null }, 200);","+      return ok(c, { candles: [], currentOpenPrice: null, currentMinuteTs: null });","     }","   });"," "]},{"oldStart":498,"oldLines":7,"newStart":516,"newLines":13,"lines":["       logger.warn(\"closecall bet rejected: invalid playerPubkey format\", {","         playerPubkey: body.playerPubkey,","       });","-      return c.json({ error: \"playerPubkey must be a valid base58 public key\" }, 400);","+      return err(","+        c,","+        400,","+        API_ERROR_CODES.INVALID_REQUEST,","+        \"playerPubkey must be a valid base58 public key\",","+        { retryable: false },","+      );","     }"," ","     // 2. Validate playerPubkey"]},{"oldStart":506,"oldLines":18,"newStart":530,"newLines":24,"lines":["     try {","       playerPubkey = new PublicKey(body.playerPubkey);","     } catch {","-      return c.json({ error: \"playerPubkey is not a valid public key\" }, 400);","+      return err(","+        c,","+        400,","+        API_ERROR_CODES.INVALID_REQUEST,","+        \"playerPubkey is not a valid public key\",","+        { retryable: false },","+      );","     }"," ","     // 3. Enforce that the authenticated session is bound to the requested wallet","     const userId = c.get(\"userId\");","     if (!userId) {","-      return c.json({ error: \"Authentication required\" }, 401);","+      return err(c, 401, API_ERROR_CODES.AUTH_REQUIRED, \"Authentication required\");","     }"," ","     const profile = await db.getProfileByUserId(userId);","     if (!profile) {","-      return c.json({ error: \"Profile not found\" }, 404);","+      return err(c, 404, API_ERROR_CODES.PROFILE_NOT_FOUND, \"Profile not found\");","     }"," ","     if (profile.wallet !== body.playerPubkey) {"]},{"oldStart":525,"oldLines":16,"newStart":555,"newLines":25,"lines":["         bodyWallet: body.playerPubkey,","         profileWallet: profile.wallet,","       });","-      return c.json({ error: \"Wallet does not match authenticated session\" }, 403);","+      return err(","+        c,","+        403,","+        API_ERROR_CODES.FORBIDDEN,","+        \"Wallet does not match authenticated session\",","+        { retryable: false },","+      );","     }"," ","     // 4. Get the latest boundary price from the clock worker (cached)","     const boundaryPrice = clockWorker.getLatestBoundaryPrice();","     if (!boundaryPrice) {","       logger.warn(\"closecall bet: no cached boundary price\");","-      return c.json(","-        { error: \"No price data available yet. Wait for next minute boundary.\" },","+      return err(","+        c,","         503,","+        API_ERROR_CODES.PRICE_UNAVAILABLE,","+        \"No price data available yet. Wait for next minute boundary.\",","+        { retryable: true },","       );","     }"," "]},{"oldStart":596,"oldLines":16,"newStart":635,"newLines":21,"lines":["         openPrice: boundaryPrice.priceHuman,","       });"," ","-      return c.json({","+      return ok(c, {","         transaction: serialized,","         minuteTs: Number(minuteTs),","         roundPda: roundPda.toBase58(),","-      }, 200);","-    } catch (err) {","+      });","+    } catch (buildError) {","       logger.error(\"closecall bet: tx build failed\", {","-        error: err instanceof Error ? err.message : String(err),","+        error: buildError instanceof Error ? buildError.message : String(buildError),","       });","-      return c.json({ error: \"Failed to build transaction\" }, 500);","+      return err(","+        c,","+        500,","+        API_ERROR_CODES.PRECONDITION_FAILED,","+        \"Failed to build transaction\",","+      );","     }","   });"," "]}],"originalFile":"/**\n * Close Call API routes.\n *\n * GET  /closecall/current-round  — active round + pool state\n * GET  /closecall/history        — last N settled/refunded rounds\n * GET  /closecall/by-id/:roundId — lookup by round ID (minute timestamp)\n * GET  /closecall/candles        — last N minute-boundary candles from DB\n * POST /closecall/bet            — co-sign a bet tx (creates round or joins)\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\nimport type { CloseCallRound, Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { buildCloseCallBetTx } from \"../worker/settle-tx.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { decodeCloseCallRound, type DecodedCloseCallRound } from \"../worker/account-decoder.js\";\nimport type { CloseCallClockWorker } from \"../worker/closecall-clock.js\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport {\n  ErrorResponseSchema,\n  CloseCallBetResponseSchema,\n  CandleSchema,\n  CloseCallRoundSchema,\n  UnifiedCloseCallRoundResponseSchema,\n  listEnvelopeResponseSchema,\n  roundEnvelopeResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface CloseCallRoutesDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  clockWorker: CloseCallClockWorker;\n}\n\n/** Minimum wager in lamports: 0.001 SOL */\nconst MIN_WAGER_LAMPORTS = 1_000_000;\nconst MAX_WAGER_LAMPORTS = 100_000_000_000; // 100 SOL\n\nfunction isValidBase58(s: string): boolean {\n  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n}\n\n/** Convert a minuteTs bigint to an 8-byte LE buffer (for PDA seeds). */\nfunction minuteTsToBuffer(ts: bigint): Buffer {\n  const buf = Buffer.alloc(8);\n  buf.writeBigInt64LE(ts);\n  return buf;\n}\n\n/** Derive the CloseCallRound PDA for a given minute timestamp. */\nfunction deriveCloseCallRoundPda(minuteTs: bigint): PublicKey {\n  const [pda] = PublicKey.findProgramAddressSync(\n    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n    CLOSECALL_PROGRAM_ID,\n  );\n  return pda;\n}\n\nconst PHASE_NAMES = [\"open\", \"settled\", \"refunded\"] as const;\nconst OUTCOME_NAMES = [\"pending\", \"green\", \"red\", \"refund\"] as const;\n\ntype CloseCallRoundResponse = z.infer<typeof CloseCallRoundSchema>;\ntype CloseCallLookupResponse = z.infer<typeof UnifiedCloseCallRoundResponseSchema>;\n\n/** Format a decoded on-chain round into the same shape as formatCloseCallRound. */\nfunction formatOnChainRound(\n  round: DecodedCloseCallRound,\n  pda: PublicKey,\n): CloseCallRoundResponse {\n  const greenEntries = round.greenEntries.map((e) => ({\n    player: e.player.toBase58(),\n    amountLamports: Number(e.amountLamports),\n  }));\n  const redEntries = round.redEntries.map((e) => ({\n    player: e.player.toBase58(),\n    amountLamports: Number(e.amountLamports),\n  }));\n  const greenPool = Number(round.greenPool);\n  const redPool = Number(round.redPool);\n  const totalPool = greenPool + redPool;\n\n  return {\n    roundId: Number(round.minuteTs).toString(),\n    pda: pda.toBase58(),\n    phase: PHASE_NAMES[round.phase] ?? \"open\",\n    openPrice: Number(round.openPrice),\n    openPriceExpo: round.openPriceExpo,\n    closePrice: round.phase === 0 ? null : Number(round.closePrice),\n    outcome: OUTCOME_NAMES[round.outcome] ?? \"pending\",\n    greenPool,\n    redPool,\n    totalPool,\n    totalFee: Number(round.totalFee),\n    greenEntries,\n    redEntries,\n    greenCount: greenEntries.length,\n    redCount: redEntries.length,\n    settleTx: null,\n    createdAt: new Date(Number(round.createdAt) * 1000).toISOString(),\n    settledAt: null,\n  };\n}\n\nfunction formatCloseCallRound(round: CloseCallRound): CloseCallRoundResponse {\n  const totalPool = round.green_pool + round.red_pool;\n  return {\n    roundId: round.round_id,\n    pda: round.pda,\n    phase: round.phase,\n    openPrice: round.open_price,\n    openPriceExpo: round.open_price_expo,\n    closePrice: round.close_price,\n    outcome: round.outcome,\n    greenPool: round.green_pool,\n    redPool: round.red_pool,\n    totalPool,\n    totalFee: round.total_fee,\n    greenEntries: round.green_entries,\n    redEntries: round.red_entries,\n    greenCount: round.green_entries.length,\n    redCount: round.red_entries.length,\n    settleTx: round.settle_tx,\n    createdAt: round.created_at.toISOString(),\n    settledAt: round.settled_at ? round.settled_at.toISOString() : null,\n  };\n}\n\n// ── Request schemas ──────────────────────────────────────────────────────\n\nconst LimitQuerySchema = z.object({\n  limit: z.string().optional(),\n});\n\nconst RoundIdParamSchema = z.object({\n  roundId: z.string(),\n});\n\nconst CloseCallBetBodySchema = z.object({\n  playerPubkey: z.string(),\n  side: z.enum([\"green\", \"red\"]),\n  amountLamports: z.number().int().min(MIN_WAGER_LAMPORTS).max(MAX_WAGER_LAMPORTS),\n});\n\n// ── Route definitions ────────────────────────────────────────────────────\n\nconst CloseCallCurrentResponseSchema = roundEnvelopeResponseSchema(\n  \"round\",\n  CloseCallRoundSchema,\n  { nullable: true },\n);\n\nconst CloseCallHistoryResponseSchema = listEnvelopeResponseSchema(\n  \"rounds\",\n  CloseCallRoundSchema,\n);\n\nconst currentRoundRoute = createRoute({\n  method: \"get\",\n  path: \"/current-round\",\n  tags: [\"CloseCall\"],\n  summary: \"Get active Close Call round\",\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: CloseCallCurrentResponseSchema,\n        },\n      },\n      description: \"Active round or null\",\n    },\n  },\n});\n\nconst ccHistoryRoute = createRoute({\n  method: \"get\",\n  path: \"/history\",\n  tags: [\"CloseCall\"],\n  summary: \"Get recent settled/refunded Close Call rounds\",\n  request: {\n    query: LimitQuerySchema,\n  },\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: CloseCallHistoryResponseSchema,\n        },\n      },\n      description: \"List of settled rounds\",\n    },\n  },\n});\n\nconst ccByIdRoute = createRoute({\n  method: \"get\",\n  path: \"/by-id/{roundId}\",\n  tags: [\"CloseCall\"],\n  summary: \"Lookup Close Call round by ID\",\n  request: {\n    params: RoundIdParamSchema,\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: UnifiedCloseCallRoundResponseSchema } },\n      description: \"Round found\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Invalid round ID format\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Round not found\",\n    },\n  },\n});\n\nconst candlesRoute = createRoute({\n  method: \"get\",\n  path: \"/candles\",\n  tags: [\"CloseCall\"],\n  summary: \"Get recent minute-boundary candles\",\n  request: {\n    query: LimitQuerySchema,\n  },\n  responses: {\n    200: {\n      content: {\n        \"application/json\": {\n          schema: z.object({\n            candles: z.array(CandleSchema),\n            currentOpenPrice: z.number().nullable(),\n            currentMinuteTs: z.number().int().nullable(),\n          }),\n        },\n      },\n      description: \"Candle data\",\n    },\n  },\n});\n\nconst betRoute = createRoute({\n  method: \"post\",\n  path: \"/bet\",\n  tags: [\"CloseCall\"],\n  summary: \"Co-sign a Close Call bet transaction\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    body: {\n      required: true,\n      content: {\n        \"application/json\": { schema: CloseCallBetBodySchema },\n      },\n    },\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: CloseCallBetResponseSchema } },\n      description: \"Bet transaction built successfully\",\n    },\n    400: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Invalid request\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Authentication required\",\n    },\n    403: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Wallet mismatch\",\n    },\n    404: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Profile not found\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Transaction build failed\",\n    },\n    503: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"No price data available\",\n    },\n  },\n});\n\n// ── Factory ──────────────────────────────────────────────────────────────\n\nexport function createCloseCallRoutes(deps: CloseCallRoutesDeps) {\n  const { db, connection, serverKeypair, clockWorker } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  app.openapi(currentRoundRoute, async (c) => {\n    // Derive PDAs for current and previous minute — the round may still be\n    // open from the previous minute if not yet settled.\n    const nowMinuteTs = BigInt(Math.floor(Date.now() / 60_000) * 60);\n    const prevMinuteTs = nowMinuteTs - 60n;\n\n    const currentPda = deriveCloseCallRoundPda(nowMinuteTs);\n    const prevPda = deriveCloseCallRoundPda(prevMinuteTs);\n\n    try {\n      const [currentInfo, prevInfo] = await Promise.all([\n        connection.getAccountInfo(currentPda),\n        connection.getAccountInfo(prevPda),\n      ]);\n\n      // Prefer the current minute's round; fall back to previous if it's still open\n      if (currentInfo) {\n        const round = decodeCloseCallRound(Buffer.from(currentInfo.data));\n        return c.json({ round: formatOnChainRound(round, currentPda) }, 200);\n      }\n\n      if (prevInfo) {\n        const round = decodeCloseCallRound(Buffer.from(prevInfo.data));\n        // Only return previous-minute round if it's still open (phase 0)\n        if (round.phase === 0) {\n          return c.json({ round: formatOnChainRound(round, prevPda) }, 200);\n        }\n      }\n\n      return c.json({ round: null }, 200);\n    } catch (err) {\n      logger.error(\"closecall current-round: on-chain lookup failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ round: null }, 200);\n    }\n  });\n\n  app.openapi(ccHistoryRoute, async (c) => {\n    const { limit: limitParam } = c.req.valid(\"query\");\n    const limit = Math.min(Math.max(parseInt(limitParam ?? \"20\", 10) || 20, 1), 100);\n    const rounds = await db.getCloseCallHistory(limit);\n    return c.json({ rounds: rounds.map(formatCloseCallRound) }, 200);\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /by-id/:roundId — lookup by round ID (numeric minute timestamp)\n  // -----------------------------------------------------------------------\n\n  app.openapi(ccByIdRoute, async (c) => {\n    const { roundId } = c.req.valid(\"param\");\n    if (!/^[0-9]{1,20}$/.test(roundId)) {\n      return c.json({ error: \"roundId must be a numeric timestamp\" }, 400);\n    }\n\n    const round = await db.getCloseCallRound(roundId);\n    if (!round) {\n      return c.json({ error: \"Round not found\" }, 404);\n    }\n\n    const totalPool = round.green_pool + round.red_pool;\n    const isSettled = round.phase === \"settled\" || round.phase === \"refunded\";\n\n    const response: CloseCallLookupResponse = {\n      pda: round.pda,\n      game: \"close-call\",\n      phase: round.phase,\n      matchId: round.round_id,\n      openPrice: round.open_price,\n      openPriceExpo: round.open_price_expo,\n      greenPool: round.green_pool,\n      redPool: round.red_pool,\n      totalPool,\n      greenEntries: round.green_entries,\n      redEntries: round.red_entries,\n      greenCount: round.green_entries.length,\n      redCount: round.red_entries.length,\n      createdAt: round.created_at.toISOString(),\n    };\n\n    if (isSettled) {\n      response.closePrice = round.close_price;\n      response.outcome = round.outcome;\n      response.totalFee = round.total_fee;\n      response.settleTx = round.settle_tx;\n      response.settledAt = round.settled_at ? round.settled_at.toISOString() : null;\n      response.verification = {\n        priceSource: \"Pyth Network push oracle\",\n        outcome:\n          round.outcome === \"green\"\n            ? \"close > open\"\n            : round.outcome === \"red\"\n              ? \"close < open\"\n              : \"refund (equal price, one-sided, or single player)\",\n      };\n    }\n\n    return c.json(response, 200);\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /candles — returns last N minute-boundary candles from DB\n  // -----------------------------------------------------------------------\n\n  app.openapi(candlesRoute, async (c) => {\n    const { limit: limitParam } = c.req.valid(\"query\");\n    const limit = Math.min(Math.max(parseInt(limitParam ?? \"5\", 10) || 5, 1), 60);\n\n    try {\n      // We need limit+1 boundary prices to form `limit` candles.\n      // Each candle = two consecutive boundary prices.\n      const candles_raw = await db.getCloseCallCandles(limit + 1);\n      const rows = candles_raw.map((cc) => ({\n        minute_ts: String(cc.minuteTs),\n        price_human: cc.priceHuman,\n      }));\n\n      if (rows.length < 2) {\n        // Not enough data to form even one candle\n        const bp = clockWorker.getLatestBoundaryPrice();\n        return c.json({\n          candles: [],\n          currentOpenPrice: bp ? bp.priceHuman : null,\n          currentMinuteTs: bp ? bp.minuteTs : null,\n        }, 200);\n      }\n\n      // Rows come DESC, reverse to ASC for pairing\n      const sorted = rows.reverse();\n\n      // Build candles from consecutive boundary pairs\n      const candles: Array<{\n        openTime: number;\n        closeTime: number;\n        open: number;\n        close: number;\n        high: number;\n        low: number;\n        outcome: \"green\" | \"red\" | null;\n      }> = [];\n\n      for (let i = 0; i < sorted.length - 1; i++) {\n        const openBoundary = sorted[i]!;\n        const closeBoundary = sorted[i + 1]!;\n        const openTs = Number(openBoundary.minute_ts);\n        const closeTs = Number(closeBoundary.minute_ts);\n        const open = openBoundary.price_human;\n        const close = closeBoundary.price_human;\n\n        // Only pair consecutive minute boundaries (60s apart)\n        if (closeTs - openTs !== 60) continue;\n\n        const high = Math.max(open, close);\n        const low = Math.min(open, close);\n\n        // Determine outcome: green if close > open, red if close < open, null if equal\n        let outcome: \"green\" | \"red\" | null = null;\n        if (close > open) outcome = \"green\";\n        else if (close < open) outcome = \"red\";\n\n        candles.push({\n          openTime: openTs * 1000,\n          closeTime: closeTs * 1000,\n          open,\n          close,\n          high,\n          low,\n          outcome,\n        });\n      }\n\n      // Current open price = latest boundary price\n      const bp = clockWorker.getLatestBoundaryPrice();\n\n      return c.json({\n        candles,\n        currentOpenPrice: bp ? bp.priceHuman : null,\n        currentMinuteTs: bp ? bp.minuteTs : null,\n      }, 200);\n    } catch (err) {\n      logger.error(\"closecall candles: query failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ candles: [], currentOpenPrice: null, currentMinuteTs: null }, 200);\n    }\n  });\n\n  /**\n   * POST /bet — co-sign a bet transaction.\n   *\n   * Uses init_if_needed — creates round on first bet, joins on subsequent.\n   * The server partially signs (pays rent on first call), and returns the\n   * serialized tx for the frontend to add the player signature + submit.\n   */\n  app.openapi(betRoute, async (c) => {\n    // 1. Parse + validate request body (Zod handles shape validation)\n    const body = c.req.valid(\"json\");\n\n    // Additional validation: base58 format\n    if (!isValidBase58(body.playerPubkey)) {\n      logger.warn(\"closecall bet rejected: invalid playerPubkey format\", {\n        playerPubkey: body.playerPubkey,\n      });\n      return c.json({ error: \"playerPubkey must be a valid base58 public key\" }, 400);\n    }\n\n    // 2. Validate playerPubkey\n    let playerPubkey: PublicKey;\n    try {\n      playerPubkey = new PublicKey(body.playerPubkey);\n    } catch {\n      return c.json({ error: \"playerPubkey is not a valid public key\" }, 400);\n    }\n\n    // 3. Enforce that the authenticated session is bound to the requested wallet\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    const profile = await db.getProfileByUserId(userId);\n    if (!profile) {\n      return c.json({ error: \"Profile not found\" }, 404);\n    }\n\n    if (profile.wallet !== body.playerPubkey) {\n      logger.warn(\"closecall bet rejected: wallet mismatch with profile\", {\n        bodyWallet: body.playerPubkey,\n        profileWallet: profile.wallet,\n      });\n      return c.json({ error: \"Wallet does not match authenticated session\" }, 403);\n    }\n\n    // 4. Get the latest boundary price from the clock worker (cached)\n    const boundaryPrice = clockWorker.getLatestBoundaryPrice();\n    if (!boundaryPrice) {\n      logger.warn(\"closecall bet: no cached boundary price\");\n      return c.json(\n        { error: \"No price data available yet. Wait for next minute boundary.\" },\n        503,\n      );\n    }\n\n    // 5. Compute minuteTs + build partially-signed tx\n    const minuteTs = BigInt(Math.floor(Date.now() / 60_000) * 60);\n    const sideNum = body.side === \"green\" ? 0 : 1;\n\n    try {\n      const { tx, roundPda } = await buildCloseCallBetTx(\n        { connection, serverKeypair },\n        playerPubkey,\n        minuteTs,\n        sideNum,\n        BigInt(body.amountLamports),\n        boundaryPrice.price,\n        boundaryPrice.expo,\n      );\n\n      const serialized = tx.serialize({ requireAllSignatures: false }).toString(\"base64\");\n\n      // Persist round to DB (upsert — idempotent if round already exists)\n      try {\n        await db.insertCloseCallRound({\n          roundId: String(Number(minuteTs)),\n          pda: roundPda.toBase58(),\n          serverKey: serverKeypair.publicKey.toBase58(),\n          openPrice: Number(boundaryPrice.price),\n          openPriceExpo: boundaryPrice.expo,\n        });\n      } catch (dbErr) {\n        logger.warn(\"closecall bet: DB round insert failed (tx still returned)\", {\n          error: dbErr instanceof Error ? dbErr.message : String(dbErr),\n        });\n      }\n\n      // Write participation-time game entry\n      try {\n        await db.upsertGameEntry({\n          userId: profile.user_id,\n          wallet: body.playerPubkey,\n          game: \"closecall\",\n          roundPda: roundPda.toBase58(),\n          matchId: String(Number(minuteTs)),\n          amountLamports: body.amountLamports,\n          side: body.side,\n        });\n      } catch (entryErr) {\n        logger.warn(\"closecall bet: game_entry insert failed\", {\n          error: entryErr instanceof Error ? entryErr.message : String(entryErr),\n        });\n      }\n\n      logger.info(\"closecall bet: tx built\", {\n        minuteTs: Number(minuteTs),\n        roundPda: roundPda.toBase58(),\n        player: body.playerPubkey,\n        side: body.side,\n        amountLamports: body.amountLamports,\n        openPrice: boundaryPrice.priceHuman,\n      });\n\n      return c.json({\n        transaction: serialized,\n        minuteTs: Number(minuteTs),\n        roundPda: roundPda.toBase58(),\n      }, 200);\n    } catch (err) {\n      logger.error(\"closecall bet: tx build failed\", {\n        error: err instanceof Error ? err.message : String(err),\n      });\n      return c.json({ error: \"Failed to build transaction\" }, 500);\n    }\n  });\n\n  return app;\n}\n","userModified":false}}
