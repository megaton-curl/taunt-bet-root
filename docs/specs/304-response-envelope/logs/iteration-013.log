n    .sign(JWT_SECRET);\n}\n\nfunction buildApp(db: Partial<Db>, clockWorker?: { getLatestBoundaryPrice: () => unknown }) {\n  const app = new Hono();\n\n  app.use(\"/closecall/bet\", createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }));\n  app.route(\n    \"/closecall\",\n    createCloseCallRoutes({\n      db: db as Db,\n      connection: {} as Connection,\n      serverKeypair: Keypair.generate(),\n      clockWorker: (clockWorker ?? {\n        getLatestBoundaryPrice: () => null,\n      }) as never,\n    }),\n  );\n\n  return app;\n}\n\ndescribe(\"createCloseCallRoutes\", () => {\n  it(\"rejects bets when playerPubkey does not match the authenticated profile wallet\", async () => {\n    const profileWallet = Keypair.generate().publicKey.toBase58();\n    const requestWallet = Keypair.generate().publicKey.toBase58();\n    const getProfileByUserId = vi.fn(async () => ({\n      id: 1,\n      user_id: \"usr_session\",\n      wallet: profileWallet,\n      username: \"test\",\n      username_updated_at: null,\n      avatar_url: null,\n      heat_multiplier: 1,\n      points_balance: 0,\n      created_at: new Date(),\n    }));\n    const insertCloseCallRound = vi.fn();\n    const upsertGameEntry = vi.fn();\n    const getLatestBoundaryPrice = vi.fn(() => ({\n      minuteTs: 0,\n      price: 1n,\n      expo: -8,\n      priceHuman: 1,\n    }));\n\n    const app = buildApp(\n      {\n        getProfileByUserId,\n        insertCloseCallRound,\n        upsertGameEntry,\n      },\n      { getLatestBoundaryPrice },\n    );\n\n    const token = await makeJwt(\"usr_session\");\n    const res = await app.request(\"/closecall/bet\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        playerPubkey: requestWallet,\n        side: \"green\",\n        amountLamports: 1_000_000,\n      }),\n    });\n\n    expect(res.status).toBe(403);\n    const body = (await res.json()) as {\n      ok: boolean;\n      error: { code: string; message: string };\n    };\n    expect(body.ok).toBe(false);\n    expect(body.error.code).toBe(\"FORBIDDEN\");\n    expect(body.error.message).toBe(\"Wallet does not match authenticated session\");\n    expect(getProfileByUserId).toHaveBeenCalledWith(\"usr_session\");\n    expect(getLatestBoundaryPrice).not.toHaveBeenCalled();\n    expect(insertCloseCallRound).not.toHaveBeenCalled();\n    expect(upsertGameEntry).not.toHaveBeenCalled();\n  });\n\n  it(\"rejects bets when the authenticated profile does not exist\", async () => {\n    const getProfileByUserId = vi.fn(async () => null);\n    const getLatestBoundaryPrice = vi.fn(() => ({\n      minuteTs: 0,\n      price: 1n,\n      expo: -8,\n      priceHuman: 1,\n    }));\n\n    const app = buildApp(\n      {\n        getProfileByUserId,\n      },\n      { getLatestBoundaryPrice },\n    );\n\n    const token = await makeJwt(\"usr_missing\");\n    const res = await app.request(\"/closecall/bet\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        playerPubkey: Keypair.generate().publicKey.toBase58(),\n        side: \"red\",\n        amountLamports: 1_000_000,\n      }),\n    });\n\n    expect(res.status).toBe(404);\n    expect(await res.json()).toEqual({\n      error: \"Profile not found\",\n    });\n    expect(getProfileByUserId).toHaveBeenCalledWith(\"usr_missing\");\n    expect(getLatestBoundaryPrice).not.toHaveBeenCalled();\n  });\n});\n","structuredPatch":[{"oldStart":130,"oldLines":9,"newStart":130,"newLines":13,"lines":["     });"," ","     expect(res.status).toBe(404);","-    expect(await res.json()).toEqual({","-      error: \"Profile not found\",","-    });","+    const body = (await res.json()) as {","+      ok: boolean;","+      error: { code: string; message: string };","+    };","+    expect(body.ok).toBe(false);","+    expect(body.error.code).toBe(\"PROFILE_NOT_FOUND\");","+    expect(body.error.message).toBe(\"Profile not found\");","     expect(getProfileByUserId).toHaveBeenCalledWith(\"usr_missing\");","     expect(getLatestBoundaryPrice).not.toHaveBeenCalled();","   });"]}],"userModified":false,"replaceAll":false}}
