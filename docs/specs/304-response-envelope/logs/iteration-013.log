{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RopFh6tcrZBd5AA4HaktP4","type":"tool_result","content":"1\t/**\n2\t * OpenAPI contract validation — ensures the auto-generated spec is\n3\t * structurally sound, has expected paths, and every response has a description.\n4\t *\n5\t * Fetches the spec from the app's /openapi.json endpoint (auto-generated\n6\t * by @hono/zod-openapi) rather than importing a static object.\n7\t *\n8\t * Runs without a database — uses the Hono test client.\n9\t */\n10\t\n11\timport { describe, expect, it, beforeAll } from \"vitest\";\n12\timport { OpenAPIHono } from \"@hono/zod-openapi\";\n13\timport { Keypair } from \"@solana/web3.js\";\n14\t\n15\t// Import route factories that DON'T need real deps (we only need the spec)\n16\t// We build a minimal app that generates the same spec as the real one.\n17\t// Instead, we import the real app's index module indirectly by constructing\n18\t// a minimal OpenAPIHono that only has the doc endpoint.\n19\t//\n20\t// Actually, the simplest approach: import the real app and hit /openapi.json.\n21\t// But the real app needs DB, connection, etc. So we build a test app with\n22\t// the same route structure.\n23\t//\n24\t// Simplest viable approach: just import a few route factories and check\n25\t// the spec they generate.\n26\t\n27\ttype AnyRecord = Record<string, unknown>;\n28\t\n29\t/** Recursively collect all \"$ref\" strings from the spec. */\n30\tfunction collectRefs(obj: unknown): string[] {\n31\t  const refs: string[] = [];\n32\t  function walk(value: unknown) {\n33\t    if (Array.isArray(value)) {\n34\t      value.forEach(walk);\n35\t    } else if (value && typeof value === \"object\") {\n36\t      const record = value as AnyRecord;\n37\t      if (typeof record.$ref === \"string\") {\n38\t        refs.push(record.$ref);\n39\t      }\n40\t      Object.values(record).forEach(walk);\n41\t    }\n42\t  }\n43\t  walk(obj);\n44\t  return refs;\n45\t}\n46\t\n47\tconst VALID_METHODS = new Set([\n48\t  \"get\", \"post\", \"put\", \"delete\", \"patch\", \"options\", \"head\",\n49\t]);\n50\t\n51\t// We need to construct a minimal app to generate the spec. Import route\n52\t// factories that don't need heavy deps (health, price, leaderboard).\n53\timport { createHealthRoutes } from \"../routes/health.js\";\n54\timport { createPriceRoutes } from \"../routes/price.js\";\n55\timport { createLeaderboardRoutes } from \"../routes/leaderboard.js\";\n56\timport { createProfileRoutes } from \"../routes/profile.js\";\n57\timport { createFlipYouRoutes } from \"../routes/create.js\";\n58\timport { createPotShotRoutes } from \"../routes/potshot-create.js\";\n59\timport { createCloseCallRoutes } from \"../routes/closecall.js\";\n60\t\n61\tfunction resolveSchema(spec: AnyRecord, schema: unknown): AnyRecord {\n62\t  const record = schema as AnyRecord;\n63\t\n64\t  if (typeof record?.$ref === \"string\") {\n65\t    const path = record.$ref.replace(/^#\\//, \"\").split(\"/\");\n66\t    let current: unknown = spec;\n67\t    for (const segment of path) {\n68\t      current = (current as AnyRecord)?.[segment];\n69\t    }\n70\t    return resolveSchema(spec, current);\n71\t  }\n72\t\n73\t  if (Array.isArray(record?.allOf) && record.allOf.length > 0) {\n74\t    return resolveSchema(spec, record.allOf[0]);\n75\t  }\n76\t\n77\t  if (Array.isArray(record?.anyOf)) {\n78\t    const concrete = record.anyOf.find((item) => {\n79\t      const candidate = item as AnyRecord;\n80\t      return typeof candidate?.$ref === \"string\" || candidate?.type === \"object\";\n81\t    });\n82\t    if (concrete) {\n83\t      return resolveSchema(spec, concrete);\n84\t    }\n85\t  }\n86\t\n87\t  return record;\n88\t}\n89\t\n90\t/**\n91\t * Descend into the success branch of an `ApiEnvelope` (`{ ok: true, data: T }`)\n92\t * within a `oneOf` discriminated union. Returns the resolved schema as-is for\n93\t * legacy non-enveloped responses.\n94\t */\n95\tfunction unwrapEnvelope(spec: AnyRecord, schema: unknown): AnyRecord {\n96\t  const resolved = resolveSchema(spec, schema);\n97\t\n98\t  const oneOf = resolved.oneOf as unknown[] | undefined;\n99\t  if (Array.isArray(oneOf)) {\n100\t    for (const variant of oneOf) {\n101\t      const variantResolved = resolveSchema(spec, variant);\n102\t      const props = variantResolved.properties as AnyRecord | undefined;\n103\t      const okProp = props?.ok as AnyRecord | undefined;\n104\t      const okEnum = okProp?.enum as unknown[] | undefined;\n105\t      if (okEnum && okEnum[0] === true && props && \"data\" in props) {\n106\t        return resolveSchema(spec, props.data);\n107\t      }\n108\t    }\n109\t  }\n110\t\n111\t  const properties = resolved.properties as AnyRecord | undefined;\n112\t  if (properties && \"ok\" in properties && \"data\" in properties) {\n113\t    return resolveSchema(spec, properties.data);\n114\t  }\n115\t\n116\t  return resolved;\n117\t}\n118\t\n119\tfunction getJsonResponseSchema(\n120\t  spec: AnyRecord,\n121\t  path: string,\n122\t  method: string,\n123\t  status: string,\n124\t): AnyRecord {\n125\t  const paths = spec.paths as AnyRecord;\n126\t  const operations = paths[path] as AnyRecord | undefined;\n127\t  const operation = operations?.[method] as AnyRecord | undefined;\n128\t  const responses = operation?.responses as AnyRecord | undefined;\n129\t  const content = (responses?.[status] as AnyRecord | undefined)?.content as AnyRecord | undefined;\n130\t  return unwrapEnvelope(\n131\t    spec,\n132\t    (content?.[\"application/json\"] as AnyRecord | undefined)?.schema,\n133\t  );\n134\t}\n135\t\n136\tfunction buildSpecApp() {\n137\t  const app = new OpenAPIHono();\n138\t  const serverKeypair = Keypair.generate();\n139\t\n140\t  // Stub DB that satisfies the interface minimally — only used for spec generation, never called\n141\t  /* eslint-disable @typescript-eslint/no-explicit-any */\n142\t  const stubDb = new Proxy({} as any, {\n143\t    get: () => async () => ({ count: 0, oldestAgeSeconds: 0 }),\n144\t  });\n145\t  app.route(\"/health\", createHealthRoutes({ isWorkerRunning: () => true }));\n146\t  /* eslint-enable @typescript-eslint/no-explicit-any */\n147\t  app.route(\"/price\", createPriceRoutes());\n148\t  app.route(\"/leaderboard\", createLeaderboardRoutes({ db: stubDb }));\n149\t  app.route(\"/profile\", createProfileRoutes({ db: stubDb }));\n150\t  app.route(\n151\t    \"/flip-you\",\n152\t    createFlipYouRoutes({\n153\t      db: stubDb,\n154\t      connection: {} as never,\n155\t      serverKeypair,\n156\t      pdaWatcher: { watch: () => undefined } as never,\n157\t    }),\n158\t  );\n159\t  app.route(\n160\t    \"/pot-shot\",\n161\t    createPotShotRoutes({\n162\t      db: stubDb,\n163\t      connection: {} as never,\n164\t      serverKeypair,\n165\t      pdaWatcher: { watch: () => undefined } as never,\n166\t    }),\n167\t  );\n168\t  app.route(\n169\t    \"/closecall\",\n170\t    createCloseCallRoutes({\n171\t      db: stubDb,\n172\t      connection: {} as never,\n173\t      serverKeypair,\n174\t      clockWorker: { getLatestBoundaryPrice: () => null } as never,\n175\t    }),\n176\t  );\n177\t\n178\t  app.openAPIRegistry.registerComponent(\"securitySchemes\", \"bearerAuth\", {\n179\t    type: \"http\",\n180\t    scheme: \"bearer\",\n181\t    bearerFormat: \"JWT\",\n182\t  });\n183\t\n184\t  app.doc(\"/openapi.json\", {\n185\t    openapi: \"3.0.3\",\n186\t    info: { title: \"Taunt Bet API\", version: \"0.1.0\" },\n187\t  });\n188\t\n189\t  return app;\n190\t}\n191\t\n192\tdescribe(\"OpenAPI contract (auto-generated)\", () => {\n193\t  let spec: AnyRecord;\n194\t\n195\t  beforeAll(async () => {\n196\t    const app = buildSpecApp();\n197\t    const res = await app.request(\"/openapi.json\");\n198\t    expect(res.status).toBe(200);\n199\t    spec = (await res.json()) as AnyRecord;\n200\t  });\n201\t\n202\t  it(\"is a valid OpenAPI 3.0.3 document\", () => {\n203\t    expect(spec.openapi).toBe(\"3.0.3\");\n204\t    expect(spec.info).toBeDefined();\n205\t    expect((spec.info as AnyRecord).title).toBeTruthy();\n206\t    const paths = spec.paths as AnyRecord;\n207\t    expect(Object.keys(paths).length).toBeGreaterThan(0);\n208\t  });\n209\t\n210\t  it(\"auto-generated spec contains expected paths\", () => {\n211\t    const paths = Object.keys(spec.paths as AnyRecord);\n212\t    // Spot-check a few expected endpoints from the mounted routes\n213\t    expect(paths).toContain(\"/health\");\n214\t    expect(paths).toContain(\"/price/sol-usd\");\n215\t    expect(paths).toContain(\"/leaderboard/weekly\");\n216\t    expect(paths).toContain(\"/profile/me\");\n217\t    expect(paths).toContain(\"/flip-you/verify/{pda}\");\n218\t    expect(paths).toContain(\"/pot-shot/current\");\n219\t    expect(paths).toContain(\"/closecall/by-id/{roundId}\");\n220\t  });\n221\t\n222\t  it(\"does not declare bearer auth globally\", () => {\n223\t    expect(spec.security).toBeUndefined();\n224\t  });\n225\t\n226\t  it(\"keeps public routes public and protected routes protected\", () => {\n227\t    const paths = spec.paths as Record<string, AnyRecord>;\n228\t    expect((paths[\"/health\"]?.get as AnyRecord | undefined)?.security).toBeUndefined();\n229\t    expect((paths[\"/price/sol-usd\"]?.get as AnyRecord | undefined)?.security).toBeUndefined();\n230\t    expect((paths[\"/profile/me\"]?.get as AnyRecord | undefined)?.security).toEqual([\n231\t      { bearerAuth: [] },\n232\t    ]);\n233\t  });\n234\t\n235\t  it(\"documents round endpoints with concrete field schemas\", () => {\n236\t    const flipVerifySchema = getJsonResponseSchema(spec, \"/flip-you/verify/{pda}\", \"get\", \"200\");\n237\t    const flipEntriesSchema = resolveSchema(\n238\t      spec,\n239\t      ((flipVerifySchema.properties as AnyRecord).entries as AnyRecord)?.items,\n240\t    );\n241\t    expect((flipVerifySchema.properties as AnyRecord).matchId).toBeDefined();\n242\t    expect((flipVerifySchema.properties as AnyRecord).verification).toBeDefined();\n243\t    expect((flipEntriesSchema.properties as AnyRecord).player).toBeDefined();\n244\t    expect((flipEntriesSchema.properties as AnyRecord).amountLamports).toBeDefined();\n245\t\n246\t    const potCurrentEnvelope = getJsonResponseSchema(spec, \"/pot-shot/current\", \"get\", \"200\");\n247\t    const potCurrentSchema = resolveSchema(\n248\t      spec,\n249\t      (potCurrentEnvelope.properties as AnyRecord).round,\n250\t    );\n251\t    expect((potCurrentSchema.properties as AnyRecord).entries).toBeDefined();\n252\t    expect((potCurrentSchema.properties as AnyRecord).countdownEndsAt).toBeDefined();\n253\t\n254\t    const closeByIdSchema = getJsonResponseSchema(spec, \"/closecall/by-id/{roundId}\", \"get\", \"200\");\n255\t    const closeEntrySchema = resolveSchema(\n256\t      spec,\n257\t      ((closeByIdSchema.properties as AnyRecord).greenEntries as AnyRecord)?.items,\n258\t    );\n259\t    expect((closeByIdSchema.properties as AnyRecord).game).toBeDefined();\n260\t    expect((closeByIdSchema.properties as AnyRecord).verification).toBeDefined();\n261\t    expect((closeEntrySchema.properties as AnyRecord).player).toBeDefined();\n262\t    expect((closeEntrySchema.properties as AnyRecord).amountLamports).toBeDefined();\n263\t  });\n264\t\n265\t  it(\"all $ref references resolve\", () => {\n266\t    const refs = collectRefs(spec);\n267\t    // Collect all schema names (may be empty if no $refs are used)\n268\t    const schemas = (spec.components as AnyRecord)?.schemas as AnyRecord | undefined;\n269\t    const schemaNames = new Set(schemas ? Object.keys(schemas) : []);\n270\t\n271\t    const unresolved: string[] = [];\n272\t    for (const ref of refs) {\n273\t      const match = ref.match(/^#\\/components\\/schemas\\/(.+)$/);\n274\t      if (match?.[1] && !schemaNames.has(match[1])) {\n275\t        unresolved.push(ref);\n276\t      }\n277\t    }\n278\t\n279\t    expect(unresolved, `Unresolved $ref(s): ${unresolved.join(\", \")}`).toHaveLength(0);\n280\t  });\n281\t\n282\t  it(\"every path uses only valid HTTP methods\", () => {\n283\t    const invalid: string[] = [];\n284\t    for (const [path, methods] of Object.entries(spec.paths as AnyRecord)) {\n285\t      for (const method of Object.keys(methods as AnyRecord)) {\n286\t        if (!VALID_METHODS.has(method)) {\n287\t          invalid.push(`${method.toUpperCase()} ${path}`);\n288\t        }\n289\t      }\n290\t    }\n291\t\n292\t    expect(invalid, `Invalid methods: ${invalid.join(\", \")}`).toHaveLength(0);\n293\t  });\n294\t\n295\t  it(\"every response has a description\", () => {\n296\t    const missing: string[] = [];\n297\t    for (const [path, methods] of Object.entries(spec.paths as AnyRecord)) {\n298\t      for (const [method, operation] of Object.entries(methods as AnyRecord)) {\n299\t        const op = operation as AnyRecord;\n300\t        const responses = op.responses as AnyRecord | undefined;\n301\t        if (!responses) continue;\n302\t        for (const [status, response] of Object.entries(responses)) {\n303\t          const res = response as AnyRecord;\n304\t          if (!res.description) {\n305\t            missing.push(`${method.toUpperCase()} ${path} → ${status}`);\n306\t          }\n307\t        }\n308\t      }\n309\t    }\n310\t\n311\t    expect(missing, `Responses missing description:\\n${missing.join(\"\\n\")}`).toHaveLength(0);\n312\t  });\n313\t});\n314\t"}]},"parent_tool_use_id":null,"session_id":"a8190fd2-127a-4607-a6d7-99b6b936e439","uuid":"b42ce6d2-19d0-40ad-b1c8-6c2f34d248c3","timestamp":"2026-04-22T10:24:41.652Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/openapi-contract.test.ts","content":"/**\n * OpenAPI contract validation — ensures the auto-generated spec is\n * structurally sound, has expected paths, and every response has a description.\n *\n * Fetches the spec from the app's /openapi.json endpoint (auto-generated\n * by @hono/zod-openapi) rather than importing a static object.\n *\n * Runs without a database — uses the Hono test client.\n */\n\nimport { describe, expect, it, beforeAll } from \"vitest\";\nimport { OpenAPIHono } from \"@hono/zod-openapi\";\nimport { Keypair } from \"@solana/web3.js\";\n\n// Import route factories that DON'T need real deps (we only need the spec)\n// We build a minimal app that generates the same spec as the real one.\n// Instead, we import the real app's index module indirectly by constructing\n// a minimal OpenAPIHono that only has the doc endpoint.\n//\n// Actually, the simplest approach: import the real app and hit /openapi.json.\n// But the real app needs DB, connection, etc. So we build a test app with\n// the same route structure.\n//\n// Simplest viable approach: just import a few route factories and check\n// the spec they generate.\n\ntype AnyRecord = Record<string, unknown>;\n\n/** Recursively collect all \"$ref\" strings from the spec. */\nfunction collectRefs(obj: unknown): string[] {\n  const refs: string[] = [];\n  function walk(value: unknown) {\n    if (Array.isArray(value)) {\n      value.forEach(walk);\n    } else if (value && typeof value === \"object\") {\n      const record = value as AnyRecord;\n      if (typeof record.$ref === \"string\") {\n        refs.push(record.$ref);\n      }\n      Object.values(record).forEach(walk);\n    }\n  }\n  walk(obj);\n  return refs;\n}\n\nconst VALID_METHODS = new Set([\n  \"get\", \"post\", \"put\", \"delete\", \"patch\", \"options\", \"head\",\n]);\n\n// We need to construct a minimal app to generate the spec. Import route\n// factories that don't need heavy deps (health, price, leaderboard).\nimport { createHealthRoutes } from \"../routes/health.js\";\nimport { createPriceRoutes } from \"../routes/price.js\";\nimport { createLeaderboardRoutes } from \"../routes/leaderboard.js\";\nimport { createProfileRoutes } from \"../routes/profile.js\";\nimport { createFlipYouRoutes } from \"../routes/create.js\";\nimport { createPotShotRoutes } from \"../routes/potshot-create.js\";\nimport { createCloseCallRoutes } from \"../routes/closecall.js\";\n\nfunction resolveSchema(spec: AnyRecord, schema: unknown): AnyRecord {\n  const record = schema as AnyRecord;\n\n  if (typeof record?.$ref === \"string\") {\n    const path = record.$ref.replace(/^#\\//, \"\").split(\"/\");\n    let current: unknown = spec;\n    for (const segment of path) {\n      current = (current as AnyRecord)?.[segment];\n    }\n    return resolveSchema(spec, current);\n  }\n\n  if (Array.isArray(record?.allOf) && record.allOf.length > 0) {\n    return resolveSchema(spec, record.allOf[0]);\n  }\n\n  if (Array.isArray(record?.anyOf)) {\n    const concrete = record.anyOf.find((item) => {\n      const candidate = item as AnyRecord;\n      return typeof candidate?.$ref === \"string\" || candidate?.type === \"object\";\n    });\n    if (concrete) {\n      return resolveSchema(spec, concrete);\n    }\n  }\n\n  return record;\n}\n\n/**\n * Descend into the success branch of an `ApiEnvelope` (`{ ok: true, data: T }`)\n * within a `oneOf` discriminated union. Returns the resolved schema as-is for\n * legacy non-enveloped responses.\n */\nfunction unwrapEnvelope(spec: AnyRecord, schema: unknown): AnyRecord {\n  const resolved = resolveSchema(spec, schema);\n\n  const oneOf = resolved.oneOf as unknown[] | undefined;\n  if (Array.isArray(oneOf)) {\n    for (const variant of oneOf) {\n      const variantResolved = resolveSchema(spec, variant);\n      const props = variantResolved.properties as AnyRecord | undefined;\n      const okProp = props?.ok as AnyRecord | undefined;\n      const okEnum = okProp?.enum as unknown[] | undefined;\n      if (okEnum && okEnum[0] === true && props && \"data\" in props) {\n        return resolveSchema(spec, props.data);\n      }\n    }\n  }\n\n  const properties = resolved.properties as AnyRecord | undefined;\n  if (properties && \"ok\" in properties && \"data\" in properties) {\n    return resolveSchema(spec, properties.data);\n  }\n\n  return resolved;\n}\n\nfunction getJsonResponseSchema(\n  spec: AnyRecord,\n  path: string,\n  method: string,\n  status: string,\n): AnyRecord {\n  const paths = spec.paths as AnyRecord;\n  const operations = paths[path] as AnyRecord | undefined;\n  const operation = operations?.[method] as AnyRecord | undefined;\n  const responses = operation?.responses as AnyRecord | undefined;\n  const content = (responses?.[status] as AnyRecord | undefined)?.content as AnyRecord | undefined;\n  return unwrapEnvelope(\n    spec,\n    (content?.[\"application/json\"] as AnyRecord | undefined)?.schema,\n  );\n}\n\nfunction buildSpecApp() {\n  const app = new OpenAPIHono();\n  const serverKeypair = Keypair.generate();\n\n  // Stub DB that satisfies the interface minimally — only used for spec generation, never called\n  /* eslint-disable @typescript-eslint/no-explicit-any */\n  const stubDb = new Proxy({} as any, {\n    get: () => async () => ({ count: 0, oldestAgeSeconds: 0 }),\n  });\n  app.route(\"/health\", createHealthRoutes({ isWorkerRunning: () => true }));\n  /* eslint-enable @typescript-eslint/no-explicit-any */\n  app.route(\"/price\", createPriceRoutes());\n  app.route(\"/leaderboard\", createLeaderboardRoutes({ db: stubDb }));\n  app.route(\"/profile\", createProfileRoutes({ db: stubDb }));\n  app.route(\n    \"/flip-you\",\n    createFlipYouRoutes({\n      db: stubDb,\n      connection: {} as never,\n      serverKeypair,\n      pdaWatcher: { watch: () => undefined } as never,\n    }),\n  );\n  app.route(\n    \"/pot-shot\",\n    createPotShotRoutes({\n      db: stubDb,\n      connection: {} as never,\n      serverKeypair,\n      pdaWatcher: { watch: () => undefined } as never,\n    }),\n  );\n  app.route(\n    \"/closecall\",\n    createCloseCallRoutes({\n      db: stubDb,\n      connection: {} as never,\n      serverKeypair,\n      clockWorker: { getLatestBoundaryPrice: () => null } as never,\n    }),\n  );\n\n  app.openAPIRegistry.registerComponent(\"securitySchemes\", \"bearerAuth\", {\n    type: \"http\",\n    scheme: \"bearer\",\n    bearerFormat: \"JWT\",\n  });\n\n  app.doc(\"/openapi.json\", {\n    openapi: \"3.0.3\",\n    info: { title: \"Taunt Bet API\", version: \"0.1.0\" },\n  });\n\n  return app;\n}\n\ndescribe(\"OpenAPI contract (auto-generated)\", () => {\n  let spec: AnyRecord;\n\n  beforeAll(async () => {\n    const app = buildSpecApp();\n    const res = await app.request(\"/openapi.json\");\n    expect(res.status).toBe(200);\n    spec = (await res.json()) as AnyRecord;\n  });\n\n  it(\"is a valid OpenAPI 3.0.3 document\", () => {\n    expect(spec.openapi).toBe(\"3.0.3\");\n    expect(spec.info).toBeDefined();\n    expect((spec.info as AnyRecord).title).toBeTruthy();\n    const paths = spec.paths as AnyRecord;\n    expect(Object.keys(paths).length).toBeGreaterThan(0);\n  });\n\n  it(\"auto-generated spec contains expected paths\", () => {\n    const paths = Object.keys(spec.paths as AnyRecord);\n    // Spot-check a few expected endpoints from the mounted routes\n    expect(paths).toContain(\"/health\");\n    expect(paths).toContain(\"/price/sol-usd\");\n    expect(paths).toContain(\"/leaderboard/weekly\");\n    expect(paths).toContain(\"/profile/me\");\n    expect(paths).toContain(\"/flip-you/verify/{pda}\");\n    expect(paths).toContain(\"/pot-shot/current\");\n    expect(paths).toContain(\"/closecall/by-id/{roundId}\");\n  });\n\n  it(\"does not declare bearer auth globally\", () => {\n    expect(spec.security).toBeUndefined();\n  });\n\n  it(\"keeps public routes public and protected routes protected\", () => {\n    const paths = spec.paths as Record<string, AnyRecord>;\n    expect((paths[\"/health\"]?.get as AnyRecord | undefined)?.security).toBeUndefined();\n    expect((paths[\"/price/sol-usd\"]?.get as AnyRecord | undefined)?.security).toBeUndefined();\n    expect((paths[\"/profile/me\"]?.get as AnyRecord | undefined)?.security).toEqual([\n      { bearerAuth: [] },\n    ]);\n  });\n\n  it(\"documents round endpoints with concrete field schemas\", () => {\n    const flipVerifySchema = getJsonResponseSchema(spec, \"/flip-you/verify/{pda}\", \"get\", \"200\");\n    const flipEntriesSchema = resolveSchema(\n      spec,\n      ((flipVerifySchema.properties as AnyRecord).entries as AnyRecord)?.items,\n    );\n    expect((flipVerifySchema.properties as AnyRecord).matchId).toBeDefined();\n    expect((flipVerifySchema.properties as AnyRecord).verification).toBeDefined();\n    expect((flipEntriesSchema.properties as AnyRecord).player).toBeDefined();\n    expect((flipEntriesSchema.properties as AnyRecord).amountLamports).toBeDefined();\n\n    const potCurrentEnvelope = getJsonResponseSchema(spec, \"/pot-shot/current\", \"get\", \"200\");\n    const potCurrentSchema = resolveSchema(\n      spec,\n      (potCurrentEnvelope.properties as AnyRecord).round,\n    );\n    expect((potCurrentSchema.properties as AnyRecord).entries).toBeDefined();\n    expect((potCurrentSchema.properties as AnyRecord).countdownEndsAt).toBeDefined();\n\n    const closeByIdSchema = getJsonResponseSchema(spec, \"/closecall/by-id/{roundId}\", \"get\", \"200\");\n    const closeEntrySchema = resolveSchema(\n      spec,\n      ((closeByIdSchema.properties as AnyRecord).greenEntries as AnyRecord)?.items,\n    );\n    expect((closeByIdSchema.properties as AnyRecord).game).toBeDefined();\n    expect((closeByIdSchema.properties as AnyRecord).verification).toBeDefined();\n    expect((closeEntrySchema.properties as AnyRecord).player).toBeDefined();\n    expect((closeEntrySchema.properties as AnyRecord).amountLamports).toBeDefined();\n  });\n\n  it(\"all $ref references resolve\", () => {\n    const refs = collectRefs(spec);\n    // Collect all schema names (may be empty if no $refs are used)\n    const schemas = (spec.components as AnyRecord)?.schemas as AnyRecord | undefined;\n    const schemaNames = new Set(schemas ? Object.keys(schemas) : []);\n\n    const unresolved: string[] = [];\n    for (const ref of refs) {\n      const match = ref.match(/^#\\/components\\/schemas\\/(.+)$/);\n      if (match?.[1] && !schemaNames.has(match[1])) {\n        unresolved.push(ref);\n      }\n    }\n\n    expect(unresolved, `Unresolved $ref(s): ${unresolved.join(\", \")}`).toHaveLength(0);\n  });\n\n  it(\"every path uses only valid HTTP methods\", () => {\n    const invalid: string[] = [];\n    for (const [path, methods] of Object.entries(spec.paths as AnyRecord)) {\n      for (const method of Object.keys(methods as AnyRecord)) {\n        if (!VALID_METHODS.has(method)) {\n          invalid.push(`${method.toUpperCase()} ${path}`);\n        }\n      }\n    }\n\n    expect(invalid, `Invalid methods: ${invalid.join(\", \")}`).toHaveLength(0);\n  });\n\n  it(\"every response has a description\", () => {\n    const missing: string[] = [];\n    for (const [path, methods] of Object.entries(spec.paths as AnyRecord)) {\n      for (const [method, operation] of Object.entries(methods as AnyRecord)) {\n        const op = operation as AnyRecord;\n        const responses = op.responses as AnyRecord | undefined;\n        if (!responses) continue;\n        for (const [status, response] of Object.entries(responses)) {\n          const res = response as AnyRecord;\n          if (!res.description) {\n            missing.push(`${method.toUpperCase()} ${path} → ${status}`);\n          }\n        }\n      }\n    }\n\n    expect(missing, `Responses missing description:\\n${missing.join(\"\\n\")}`).toHaveLength(0);\n  });\n});\n","numLines":314,"startLine":1,"totalLines":314}}}
