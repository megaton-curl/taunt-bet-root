{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C3GFizM2Mqb4YcqwaBgQbm","type":"tool_result","content":"80\t      createFlipYouRoutes({\n81\t        db,\n82\t        connection: mockConn as unknown as Connection,\n83\t        serverKeypair,\n84\t      }),\n85\t    );\n86\t  });\n87\t\n88\t  it(\"full lifecycle: create, join, settle, verify\", async () => {\n89\t    const wallet = creatorKeypair.publicKey.toBase58();\n90\t    const token = await makeJwt(wallet);\n91\t\n92\t    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n93\t    const createRes = await app.request(\"/flipyou/create\", {\n94\t      method: \"POST\",\n95\t      headers: {\n96\t        \"Content-Type\": \"application/json\",\n97\t        Authorization: `Bearer ${token}`,\n98\t      },\n99\t      body: JSON.stringify(body),\n100\t    });\n101\t\n102\t    expect(createRes.status).toBe(200);\n103\t    const createJson = (await createRes.json()) as {\n104\t      transaction: string;\n105\t      matchPda: string;\n106\t      matchId: string;\n107\t      commitment: string;\n108\t      lastValidBlockHeight: number;\n109\t    };\n110\t    expect(createJson.transaction).toBeDefined();\n111\t    expect(createJson.matchPda).toBeDefined();\n112\t    expect(createJson.commitment).toBeDefined();\n113\t    expect(createJson.lastValidBlockHeight).toBeDefined();\n114\t\n115\t    const round = await db.getRoundByPda(createJson.matchPda);\n116\t    expect(round).toBeDefined();\n117\t    expect(round!.phase).toBe(\"created\");\n118\t    expect(round!.game).toBe(\"flipyou\");\n119\t    expect(round!.creator).toBe(wallet);\n120\t    expect(round!.amount_lamports).toBe(AMOUNT_LAMPORTS);\n121\t    expect(round!.side).toBe(SIDE_HEADS);\n122\t    expect(round!.commitment.toString(\"hex\")).toBe(createJson.commitment);\n123\t    expect(round!.secret).toBeDefined();\n124\t    expect(round!.secret.length).toBe(32);\n125\t\n126\t    const events =\n127\t      await rawSql`SELECT * FROM operator_events WHERE pda = ${createJson.matchPda} ORDER BY id`;\n128\t    expect(events.length).toBe(1);\n129\t    expect(events[0]!.event_type).toBe(\"secret_generated\");\n130\t\n131\t    const matchPubkey = new PublicKey(createJson.matchPda);\n132\t    const matchAccountData = await buildMatchAccountData({\n133\t      creator: creatorKeypair.publicKey,\n134\t      opponent: opponentKeypair.publicKey,\n135\t      server: serverKeypair.publicKey,\n136\t      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n137\t      creatorSide: SIDE_HEADS,\n138\t      phase: PHASE_LOCKED,\n139\t      commitment: Buffer.from(createJson.commitment, \"hex\"),\n140\t      algorithmVer: 1,\n141\t      targetSlot: 150n,\n142\t      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n143\t      matchId: Buffer.from(createJson.matchId, \"hex\"),\n144\t    });\n145\t\n146\t    mockConn.setAccount(matchPubkey, matchAccountData, {\n147\t      owner: FLIPYOU_PROGRAM_ID,\n148\t    });\n149\t    mockConn.slot = 200;\n150\t\n151\t    let settlePromise: Promise<void> | null = null;\n152\t    const retrySettler = createRetrySettler({\n153\t      db,\n154\t      connection: mockConn as unknown as Connection,\n155\t      settleRound: (pda) =>\n156\t        settleMatch(\n157\t          {\n158\t            db,\n159\t            connection: mockConn as unknown as Connection,\n160\t            serverKeypair,\n161\t            entropyAccount,\n162\t            referralDefaultRateBps: 1000,\n163\t          },\n164\t          pda,\n165\t        ),\n166\t    });\n167\t\n168\t    const worker = createSettlementWorker({\n169\t      db,\n170\t      connection: mockConn as unknown as Connection,\n171\t      serverKey: serverKeypair.publicKey,\n172\t      pollIntervalMs: 60_000,\n173\t      onSettleReady: (pda) => {\n174\t        settlePromise = retrySettler.attemptSettle(pda);\n175\t        return settlePromise;\n176\t      },\n177\t    });\n178\t\n179\t    await worker.poll();\n180\t    if (settlePromise) await settlePromise;\n181\t\n182\t    const settled = await db.getRoundByPda(createJson.matchPda);\n183\t    expect(settled).toBeDefined();\n184\t    expect(settled!.phase).toBe(\"settled\");\n185\t    expect(settled!.settle_tx).toBeDefined();\n186\t    expect(settled!.result_hash).toBeDefined();\n187\t    expect(settled!.result_hash!.length).toBe(32);\n188\t    expect(settled!.result_side).toBeDefined();\n189\t    expect([0, 1]).toContain(settled!.result_side);\n190\t    expect(settled!.winner).toBeDefined();\n191\t    expect([\n192\t      creatorKeypair.publicKey.toBase58(),\n193\t      opponentKeypair.publicKey.toBase58(),\n194\t    ]).toContain(settled!.winner);\n195\t\n196\t    const allEvents =\n197\t      await rawSql`SELECT * FROM operator_events WHERE pda = ${createJson.matchPda} ORDER BY id`;\n198\t    const eventTypes = allEvents.map(\n199\t      (e) => (e as Record<string, any>).event_type,\n200\t    );\n201\t    expect(eventTypes).toContain(\"secret_generated\");\n202\t    expect(eventTypes).toContain(\"match_detected\");\n203\t    expect(eventTypes).toContain(\"settle_submitted\");\n204\t    expect(eventTypes).toContain(\"settle_confirmed\");\n205\t\n206\t    const roundsRes = await app.request(`/flipyou/verify/${createJson.matchPda}`);\n207\t    expect(roundsRes.status).toBe(200);\n208\t\n209\t    const roundsJson = (await roundsRes.json()) as Record<string, any>;\n210\t    expect(roundsJson.pda).toBe(createJson.matchPda);\n211\t    expect(roundsJson.phase).toBe(\"settled\");\n212\t    expect(roundsJson.game).toBe(\"flip-you\");\n213\t    expect(roundsJson.creator).toBe(wallet);\n214\t    expect(roundsJson.commitment).toBe(createJson.commitment);\n215\t    expect(roundsJson.secret).toBeDefined();\n216\t    expect(typeof roundsJson.secret).toBe(\"string\");\n217\t    expect((roundsJson.secret as string).length).toBe(64);\n218\t    expect(roundsJson.resultHash).toBeDefined();\n219\t    expect(roundsJson.resultSide).toBeDefined();\n220\t    expect(roundsJson.winner).toBeDefined();\n221\t    expect(roundsJson.settleTx).toBeDefined();\n222\t\n223\t    const verification = roundsJson.verification as Record<string, string>;\n224\t    expect(verification).toBeDefined();\n225\t    expect(verification.commitmentCheck).toBe(\"sha256(secret) == commitment\");\n226\t    expect(verification.resultFormula).toContain(\"sha256(secret\");\n227\t    expect(verification.entropySource).toContain(\"SlotHashes\");\n228\t  }, 20_000);\n229\t\n230\t  it(\"GET /flipyou/verify/:pda returns 404 for unknown PDA\", async () => {\n231\t    const unknownPda = Keypair.generate().publicKey.toBase58();\n232\t    const res = await app.request(`/flipyou/verify/${unknownPda}`);\n233\t    expect(res.status).toBe(404);\n234\t  });\n235\t\n236\t  it(\"unsettled round does not expose secret\", async () => {\n237\t    const wallet = creatorKeypair.publicKey.toBase58();\n238\t    const token = await makeJwt(wallet);\n239\t\n240\t    const res = await app.request(\"/flipyou/create\", {\n241\t      method: \"POST\",\n242\t      headers: {\n243\t        \"Content-Type\": \"application/json\",\n244\t        Authorization: `Bearer ${token}`,\n245\t      },\n246\t      body: JSON.stringify({\n247\t        wallet,\n248\t        amountLamports: AMOUNT_LAMPORTS,\n249\t        side: SIDE_HEADS,\n250\t      }),\n251\t    });\n252\t    expect(res.status).toBe(200);\n253\t    const json = (await res.json()) as { matchPda: string };\n254\t\n255\t    const roundRes = await app.request(`/flipyou/verify/${json.matchPda}`);\n256\t    expect(roundRes.status).toBe(200);\n257\t    const roundJson = (await roundRes.json()) as Record<string, any>;\n258\t    expect(roundJson.phase).toBe(\"created\");\n259\t    expect(roundJson.secret).toBeUndefined();\n260\t    expect(roundJson.resultHash).toBeUndefined();\n261\t    expect(roundJson.verification).toBeUndefined();\n262\t  });\n263\t\n264\t  it(\"two creates from same wallet succeed with different match IDs\", async () => {\n265\t    const wallet = creatorKeypair.publicKey.toBase58();\n266\t    const token = await makeJwt(wallet);\n267\t\n268\t    const res1 = await app.request(\"/flipyou/create\", {\n269\t      method: \"POST\",\n270\t      headers: {\n271\t        \"Content-Type\": \"application/json\",\n272\t        Authorization: `Bearer ${token}`,\n273\t      },\n274\t      body: JSON.stringify({\n275\t        wallet,\n276\t        amountLamports: AMOUNT_LAMPORTS,\n277\t        side: SIDE_HEADS,\n278\t      }),\n279\t    });\n280\t    expect(res1.status).toBe(200);\n281\t\n282\t    const res2 = await app.request(\"/flipyou/create\", {\n283\t      method: \"POST\",\n284\t      headers: {\n285\t        \"Content-Type\": \"application/json\",\n286\t        Authorization: `Bearer ${token}`,\n287\t      },\n288\t      body: JSON.stringify({\n289\t        wallet,\n290\t        amountLamports: AMOUNT_LAMPORTS,\n291\t        side: SIDE_HEADS,\n292\t      }),\n293\t    });\n294\t    expect(res2.status).toBe(200);\n295\t\n296\t    const json1 = (await res1.json()) as { matchPda: string; matchId: string };\n297\t    const json2 = (await res2.json()) as { matchPda: string; matchId: string };\n298\t    expect(json1.matchPda).not.toBe(json2.matchPda);\n299\t    expect(json1.matchId).not.toBe(json2.matchId);"}]},"parent_tool_use_id":null,"session_id":"8cfcdb07-149c-4b93-978d-588d594a76e6","uuid":"03d201da-041c-47a5-a4a2-10fb89eb8a6a","timestamp":"2026-04-22T11:31:34.209Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/integration-settlement.test.ts","content":"      createFlipYouRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n  });\n\n  it(\"full lifecycle: create, join, settle, verify\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n    const createRes = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify(body),\n    });\n\n    expect(createRes.status).toBe(200);\n    const createJson = (await createRes.json()) as {\n      transaction: string;\n      matchPda: string;\n      matchId: string;\n      commitment: string;\n      lastValidBlockHeight: number;\n    };\n    expect(createJson.transaction).toBeDefined();\n    expect(createJson.matchPda).toBeDefined();\n    expect(createJson.commitment).toBeDefined();\n    expect(createJson.lastValidBlockHeight).toBeDefined();\n\n    const round = await db.getRoundByPda(createJson.matchPda);\n    expect(round).toBeDefined();\n    expect(round!.phase).toBe(\"created\");\n    expect(round!.game).toBe(\"flipyou\");\n    expect(round!.creator).toBe(wallet);\n    expect(round!.amount_lamports).toBe(AMOUNT_LAMPORTS);\n    expect(round!.side).toBe(SIDE_HEADS);\n    expect(round!.commitment.toString(\"hex\")).toBe(createJson.commitment);\n    expect(round!.secret).toBeDefined();\n    expect(round!.secret.length).toBe(32);\n\n    const events =\n      await rawSql`SELECT * FROM operator_events WHERE pda = ${createJson.matchPda} ORDER BY id`;\n    expect(events.length).toBe(1);\n    expect(events[0]!.event_type).toBe(\"secret_generated\");\n\n    const matchPubkey = new PublicKey(createJson.matchPda);\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: Buffer.from(createJson.commitment, \"hex\"),\n      algorithmVer: 1,\n      targetSlot: 150n,\n      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n\n    mockConn.setAccount(matchPubkey, matchAccountData, {\n      owner: FLIPYOU_PROGRAM_ID,\n    });\n    mockConn.slot = 200;\n\n    let settlePromise: Promise<void> | null = null;\n    const retrySettler = createRetrySettler({\n      db,\n      connection: mockConn as unknown as Connection,\n      settleRound: (pda) =>\n        settleMatch(\n          {\n            db,\n            connection: mockConn as unknown as Connection,\n            serverKeypair,\n            entropyAccount,\n            referralDefaultRateBps: 1000,\n          },\n          pda,\n        ),\n    });\n\n    const worker = createSettlementWorker({\n      db,\n      connection: mockConn as unknown as Connection,\n      serverKey: serverKeypair.publicKey,\n      pollIntervalMs: 60_000,\n      onSettleReady: (pda) => {\n        settlePromise = retrySettler.attemptSettle(pda);\n        return settlePromise;\n      },\n    });\n\n    await worker.poll();\n    if (settlePromise) await settlePromise;\n\n    const settled = await db.getRoundByPda(createJson.matchPda);\n    expect(settled).toBeDefined();\n    expect(settled!.phase).toBe(\"settled\");\n    expect(settled!.settle_tx).toBeDefined();\n    expect(settled!.result_hash).toBeDefined();\n    expect(settled!.result_hash!.length).toBe(32);\n    expect(settled!.result_side).toBeDefined();\n    expect([0, 1]).toContain(settled!.result_side);\n    expect(settled!.winner).toBeDefined();\n    expect([\n      creatorKeypair.publicKey.toBase58(),\n      opponentKeypair.publicKey.toBase58(),\n    ]).toContain(settled!.winner);\n\n    const allEvents =\n      await rawSql`SELECT * FROM operator_events WHERE pda = ${createJson.matchPda} ORDER BY id`;\n    const eventTypes = allEvents.map(\n      (e) => (e as Record<string, any>).event_type,\n    );\n    expect(eventTypes).toContain(\"secret_generated\");\n    expect(eventTypes).toContain(\"match_detected\");\n    expect(eventTypes).toContain(\"settle_submitted\");\n    expect(eventTypes).toContain(\"settle_confirmed\");\n\n    const roundsRes = await app.request(`/flipyou/verify/${createJson.matchPda}`);\n    expect(roundsRes.status).toBe(200);\n\n    const roundsJson = (await roundsRes.json()) as Record<string, any>;\n    expect(roundsJson.pda).toBe(createJson.matchPda);\n    expect(roundsJson.phase).toBe(\"settled\");\n    expect(roundsJson.game).toBe(\"flip-you\");\n    expect(roundsJson.creator).toBe(wallet);\n    expect(roundsJson.commitment).toBe(createJson.commitment);\n    expect(roundsJson.secret).toBeDefined();\n    expect(typeof roundsJson.secret).toBe(\"string\");\n    expect((roundsJson.secret as string).length).toBe(64);\n    expect(roundsJson.resultHash).toBeDefined();\n    expect(roundsJson.resultSide).toBeDefined();\n    expect(roundsJson.winner).toBeDefined();\n    expect(roundsJson.settleTx).toBeDefined();\n\n    const verification = roundsJson.verification as Record<string, string>;\n    expect(verification).toBeDefined();\n    expect(verification.commitmentCheck).toBe(\"sha256(secret) == commitment\");\n    expect(verification.resultFormula).toContain(\"sha256(secret\");\n    expect(verification.entropySource).toContain(\"SlotHashes\");\n  }, 20_000);\n\n  it(\"GET /flipyou/verify/:pda returns 404 for unknown PDA\", async () => {\n    const unknownPda = Keypair.generate().publicKey.toBase58();\n    const res = await app.request(`/flipyou/verify/${unknownPda}`);\n    expect(res.status).toBe(404);\n  });\n\n  it(\"unsettled round does not expose secret\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    const res = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(res.status).toBe(200);\n    const json = (await res.json()) as { matchPda: string };\n\n    const roundRes = await app.request(`/flipyou/verify/${json.matchPda}`);\n    expect(roundRes.status).toBe(200);\n    const roundJson = (await roundRes.json()) as Record<string, any>;\n    expect(roundJson.phase).toBe(\"created\");\n    expect(roundJson.secret).toBeUndefined();\n    expect(roundJson.resultHash).toBeUndefined();\n    expect(roundJson.verification).toBeUndefined();\n  });\n\n  it(\"two creates from same wallet succeed with different match IDs\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    const res1 = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(res1.status).toBe(200);\n\n    const res2 = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(res2.status).toBe(200);\n\n    const json1 = (await res1.json()) as { matchPda: string; matchId: string };\n    const json2 = (await res2.json()) as { matchPda: string; matchId: string };\n    expect(json1.matchPda).not.toBe(json2.matchPda);\n    expect(json1.matchId).not.toBe(json2.matchId);","numLines":220,"startLine":80,"totalLines":735}}}
