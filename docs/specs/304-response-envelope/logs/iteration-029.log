{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AiVi5kdBDj8rnJeB7a9mCX","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/src/__tests__/integration-settlement.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"8cfcdb07-149c-4b93-978d-588d594a76e6","uuid":"a3410c97-58ff-4329-a8f8-a844a2894988","timestamp":"2026-04-22T11:32:09.311Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/integration-settlement.test.ts","oldString":"    expect(createRes.status).toBe(200);\n    const createJson = (await createRes.json()) as {\n      transaction: string;\n      matchPda: string;\n      matchId: string;\n      commitment: string;\n      lastValidBlockHeight: number;\n    };\n    expect(createJson.transaction).toBeDefined();","newString":"    expect(createRes.status).toBe(200);\n    const createBody = (await createRes.json()) as {\n      ok: true;\n      data: {\n        transaction: string;\n        matchPda: string;\n        matchId: string;\n        commitment: string;\n        lastValidBlockHeight: number;\n      };\n    };\n    const createJson = createBody.data;\n    expect(createJson.transaction).toBeDefined();","originalFile":"/* eslint-disable @typescript-eslint/no-explicit-any */\nimport { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair, PublicKey } from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport { createFlipYouRoutes } from \"../routes/create.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport { createSettlementWorker } from \"../worker/settlement.js\";\nimport { settleMatch } from \"../worker/settle-tx.js\";\nimport { createRetrySettler } from \"../worker/retry.js\";\nimport { FLIPYOU_PROGRAM_ID } from \"../fairness.js\";\nimport { resetPlatformConfigCache } from \"../platform-config.js\";\nimport { encodeCloseCallRound } from \"../worker/account-decoder.js\";\nimport { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { createCloseCallClockWorker } from \"../worker/closecall-clock.js\";\nimport type { HermesFetcher, HermesPrice } from \"../worker/pyth-poster.js\";\nimport {\n  AMOUNT_LAMPORTS,\n  AMOUNT_LAMPORTS_BIGINT,\n  JWT_SECRET,\n  PHASE_LOCKED,\n  SIDE_HEADS,\n  type IntegrationDbContext,\n  type TestSql,\n  buildMatchAccountData,\n  closeIntegrationDb,\n  makeJwt,\n  MockConnection,\n  openIntegrationDb,\n  resetIntegrationState,\n  seedSettlementProgramAccounts,\n  userIdFromWallet,\n} from \"./integration-test-helpers.js\";\n\ndescribe(\"Settlement integration: create, settle, and emit events\", () => {\n  let ctx: IntegrationDbContext;\n  let rawSql: TestSql;\n  let db: Db;\n  let mockConn: MockConnection;\n  let app: Hono;\n\n  const serverKeypair = Keypair.generate();\n  const creatorKeypair = Keypair.generate();\n  const opponentKeypair = Keypair.generate();\n  const treasuryKeypair = Keypair.generate();\n  const entropyKeypair = Keypair.generate();\n  const entropyAccount = entropyKeypair.publicKey;\n\n  const entropyData = Buffer.alloc(32);\n  entropyData[0] = 0xab;\n  entropyData[1] = 0xcd;\n  entropyData[15] = 0x42;\n\n  beforeAll(async () => {\n    ctx = await openIntegrationDb();\n    rawSql = ctx.rawSql;\n    db = ctx.db;\n  });\n\n  afterAll(async () => {\n    await closeIntegrationDb(ctx);\n  });\n\n  beforeEach(async () => {\n    await resetIntegrationState(rawSql);\n    resetPlatformConfigCache();\n\n    mockConn = new MockConnection();\n    await seedSettlementProgramAccounts(mockConn, {\n      entropyAccount,\n      entropyData,\n      treasury: treasuryKeypair.publicKey,\n    });\n\n    app = new Hono();\n    app.use(\"/flipyou/*\", createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }));\n    app.route(\n      \"/flipyou\",\n      createFlipYouRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n  });\n\n  it(\"full lifecycle: create, join, settle, verify\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n    const createRes = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify(body),\n    });\n\n    expect(createRes.status).toBe(200);\n    const createJson = (await createRes.json()) as {\n      transaction: string;\n      matchPda: string;\n      matchId: string;\n      commitment: string;\n      lastValidBlockHeight: number;\n    };\n    expect(createJson.transaction).toBeDefined();\n    expect(createJson.matchPda).toBeDefined();\n    expect(createJson.commitment).toBeDefined();\n    expect(createJson.lastValidBlockHeight).toBeDefined();\n\n    const round = await db.getRoundByPda(createJson.matchPda);\n    expect(round).toBeDefined();\n    expect(round!.phase).toBe(\"created\");\n    expect(round!.game).toBe(\"flipyou\");\n    expect(round!.creator).toBe(wallet);\n    expect(round!.amount_lamports).toBe(AMOUNT_LAMPORTS);\n    expect(round!.side).toBe(SIDE_HEADS);\n    expect(round!.commitment.toString(\"hex\")).toBe(createJson.commitment);\n    expect(round!.secret).toBeDefined();\n    expect(round!.secret.length).toBe(32);\n\n    const events =\n      await rawSql`SELECT * FROM operator_events WHERE pda = ${createJson.matchPda} ORDER BY id`;\n    expect(events.length).toBe(1);\n    expect(events[0]!.event_type).toBe(\"secret_generated\");\n\n    const matchPubkey = new PublicKey(createJson.matchPda);\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: Buffer.from(createJson.commitment, \"hex\"),\n      algorithmVer: 1,\n      targetSlot: 150n,\n      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n\n    mockConn.setAccount(matchPubkey, matchAccountData, {\n      owner: FLIPYOU_PROGRAM_ID,\n    });\n    mockConn.slot = 200;\n\n    let settlePromise: Promise<void> | null = null;\n    const retrySettler = createRetrySettler({\n      db,\n      connection: mockConn as unknown as Connection,\n      settleRound: (pda) =>\n        settleMatch(\n          {\n            db,\n            connection: mockConn as unknown as Connection,\n            serverKeypair,\n            entropyAccount,\n            referralDefaultRateBps: 1000,\n          },\n          pda,\n        ),\n    });\n\n    const worker = createSettlementWorker({\n      db,\n      connection: mockConn as unknown as Connection,\n      serverKey: serverKeypair.publicKey,\n      pollIntervalMs: 60_000,\n      onSettleReady: (pda) => {\n        settlePromise = retrySettler.attemptSettle(pda);\n        return settlePromise;\n      },\n    });\n\n    await worker.poll();\n    if (settlePromise) await settlePromise;\n\n    const settled = await db.getRoundByPda(createJson.matchPda);\n    expect(settled).toBeDefined();\n    expect(settled!.phase).toBe(\"settled\");\n    expect(settled!.settle_tx).toBeDefined();\n    expect(settled!.result_hash).toBeDefined();\n    expect(settled!.result_hash!.length).toBe(32);\n    expect(settled!.result_side).toBeDefined();\n    expect([0, 1]).toContain(settled!.result_side);\n    expect(settled!.winner).toBeDefined();\n    expect([\n      creatorKeypair.publicKey.toBase58(),\n      opponentKeypair.publicKey.toBase58(),\n    ]).toContain(settled!.winner);\n\n    const allEvents =\n      await rawSql`SELECT * FROM operator_events WHERE pda = ${createJson.matchPda} ORDER BY id`;\n    const eventTypes = allEvents.map(\n      (e) => (e as Record<string, any>).event_type,\n    );\n    expect(eventTypes).toContain(\"secret_generated\");\n    expect(eventTypes).toContain(\"match_detected\");\n    expect(eventTypes).toContain(\"settle_submitted\");\n    expect(eventTypes).toContain(\"settle_confirmed\");\n\n    const roundsRes = await app.request(`/flipyou/verify/${createJson.matchPda}`);\n    expect(roundsRes.status).toBe(200);\n\n    const roundsJson = (await roundsRes.json()) as Record<string, any>;\n    expect(roundsJson.pda).toBe(createJson.matchPda);\n    expect(roundsJson.phase).toBe(\"settled\");\n    expect(roundsJson.game).toBe(\"flip-you\");\n    expect(roundsJson.creator).toBe(wallet);\n    expect(roundsJson.commitment).toBe(createJson.commitment);\n    expect(roundsJson.secret).toBeDefined();\n    expect(typeof roundsJson.secret).toBe(\"string\");\n    expect((roundsJson.secret as string).length).toBe(64);\n    expect(roundsJson.resultHash).toBeDefined();\n    expect(roundsJson.resultSide).toBeDefined();\n    expect(roundsJson.winner).toBeDefined();\n    expect(roundsJson.settleTx).toBeDefined();\n\n    const verification = roundsJson.verification as Record<string, string>;\n    expect(verification).toBeDefined();\n    expect(verification.commitmentCheck).toBe(\"sha256(secret) == commitment\");\n    expect(verification.resultFormula).toContain(\"sha256(secret\");\n    expect(verification.entropySource).toContain(\"SlotHashes\");\n  }, 20_000);\n\n  it(\"GET /flipyou/verify/:pda returns 404 for unknown PDA\", async () => {\n    const unknownPda = Keypair.generate().publicKey.toBase58();\n    const res = await app.request(`/flipyou/verify/${unknownPda}`);\n    expect(res.status).toBe(404);\n  });\n\n  it(\"unsettled round does not expose secret\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    const res = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(res.status).toBe(200);\n    const json = (await res.json()) as { matchPda: string };\n\n    const roundRes = await app.request(`/flipyou/verify/${json.matchPda}`);\n    expect(roundRes.status).toBe(200);\n    const roundJson = (await roundRes.json()) as Record<string, any>;\n    expect(roundJson.phase).toBe(\"created\");\n    expect(roundJson.secret).toBeUndefined();\n    expect(roundJson.resultHash).toBeUndefined();\n    expect(roundJson.verification).toBeUndefined();\n  });\n\n  it(\"two creates from same wallet succeed with different match IDs\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    const res1 = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(res1.status).toBe(200);\n\n    const res2 = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(res2.status).toBe(200);\n\n    const json1 = (await res1.json()) as { matchPda: string; matchId: string };\n    const json2 = (await res2.json()) as { matchPda: string; matchId: string };\n    expect(json1.matchPda).not.toBe(json2.matchPda);\n    expect(json1.matchId).not.toBe(json2.matchId);\n  });\n\n  it(\"settlement records referral earnings for referred players\", async () => {\n    const referrerKeypair = Keypair.generate();\n    const referrerWallet = referrerKeypair.publicKey.toBase58();\n    const opponentWallet = opponentKeypair.publicKey.toBase58();\n    const creatorWallet = creatorKeypair.publicKey.toBase58();\n    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n\n    await db.insertReferralCode(referrerProfile.user_id, referrerWallet, \"test-ref\");\n    await db.insertReferralLink({\n      referrerUserId: referrerProfile.user_id,\n      refereeUserId: opponentProfile.user_id,\n      referrerWallet,\n      refereeWallet: opponentWallet,\n    });\n\n    const token = await makeJwt(creatorWallet, creatorProfile.user_id);\n    const createRes = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet: creatorWallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(createRes.status).toBe(200);\n    const createJson = (await createRes.json()) as {\n      matchPda: string;\n      matchId: string;\n      commitment: string;\n    };\n\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: Buffer.from(createJson.commitment, \"hex\"),\n      algorithmVer: 1,\n      targetSlot: 150n,\n      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n\n    mockConn.setAccount(new PublicKey(createJson.matchPda), matchAccountData, {\n      owner: FLIPYOU_PROGRAM_ID,\n    });\n    mockConn.slot = 200;\n\n    let settlePromise: Promise<void> | null = null;\n    const retrySettler = createRetrySettler({\n      db,\n      connection: mockConn as unknown as Connection,\n      settleRound: (pda) =>\n        settleMatch(\n          {\n            db,\n            connection: mockConn as unknown as Connection,\n            serverKeypair,\n            entropyAccount,\n            referralDefaultRateBps: 1000,\n          },\n          pda,\n        ),\n    });\n    const worker = createSettlementWorker({\n      db,\n      connection: mockConn as unknown as Connection,\n      serverKey: serverKeypair.publicKey,\n      pollIntervalMs: 60_000,\n      onSettleReady: (pda) => {\n        settlePromise = retrySettler.attemptSettle(pda);\n        return settlePromise;\n      },\n    });\n\n    await worker.poll();\n    if (settlePromise) await settlePromise;\n\n    const earnings =\n      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${opponentProfile.user_id}`;\n    expect(earnings.length).toBe(1);\n\n    const earning = earnings[0]!;\n    expect(earning.referrer_user_id).toBe(referrerProfile.user_id);\n    expect(earning.referee_user_id).toBe(opponentProfile.user_id);\n    expect(earning.referrer_wallet).toBe(referrerWallet);\n    expect(earning.referee_wallet).toBe(opponentWallet);\n    expect(earning.round_id).toBe(createJson.matchId);\n    expect(earning.game_type).toBe(\"flipyou\");\n    expect(Number(earning.wager_lamports)).toBe(AMOUNT_LAMPORTS);\n    expect(Number(earning.fee_lamports)).toBe(250_000);\n    expect(Number(earning.referrer_earned_lamports)).toBe(25_000);\n    expect(Number(earning.referrer_rate_bps)).toBe(1000);\n    expect(Number(earning.referee_rebate_lamports)).toBe(25_000);\n    expect(Number(earning.referee_rebate_rate_bps)).toBe(1000);\n\n    const creatorEarnings =\n      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${creatorProfile.user_id}`;\n    expect(creatorEarnings.length).toBe(0);\n  });\n\n  it(\"settlement uses KOL custom rates for referrer earnings\", async () => {\n    const referrerKeypair = Keypair.generate();\n    const referrerWallet = referrerKeypair.publicKey.toBase58();\n    const opponentWallet = opponentKeypair.publicKey.toBase58();\n    const creatorWallet = creatorKeypair.publicKey.toBase58();\n    const referrerProfile = await db.getOrCreateProfile(referrerWallet);\n    const opponentProfile = await db.getOrCreateProfile(opponentWallet);\n    const creatorProfile = await db.getOrCreateProfile(creatorWallet);\n\n    await db.insertReferralCode(referrerProfile.user_id, referrerWallet, \"kol-code\");\n    await db.insertReferralLink({\n      referrerUserId: referrerProfile.user_id,\n      refereeUserId: opponentProfile.user_id,\n      referrerWallet,\n      refereeWallet: opponentWallet,\n    });\n    await rawSql`\n      INSERT INTO referral_kol_rates (user_id, wallet, rate_bps, set_by)\n      VALUES (${referrerProfile.user_id}, ${referrerWallet}, 2000, 'admin')\n    `;\n\n    const token = await makeJwt(creatorWallet, creatorProfile.user_id);\n    const createRes = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet: creatorWallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(createRes.status).toBe(200);\n    const createJson = (await createRes.json()) as {\n      matchPda: string;\n      matchId: string;\n      commitment: string;\n    };\n\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: Buffer.from(createJson.commitment, \"hex\"),\n      algorithmVer: 1,\n      targetSlot: 150n,\n      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n\n    mockConn.setAccount(new PublicKey(createJson.matchPda), matchAccountData, {\n      owner: FLIPYOU_PROGRAM_ID,\n    });\n    mockConn.slot = 200;\n\n    let settlePromise: Promise<void> | null = null;\n    const retrySettler = createRetrySettler({\n      db,\n      connection: mockConn as unknown as Connection,\n      settleRound: (pda) =>\n        settleMatch(\n          {\n            db,\n            connection: mockConn as unknown as Connection,\n            serverKeypair,\n            entropyAccount,\n            referralDefaultRateBps: 1000,\n          },\n          pda,\n        ),\n    });\n    const worker = createSettlementWorker({\n      db,\n      connection: mockConn as unknown as Connection,\n      serverKey: serverKeypair.publicKey,\n      pollIntervalMs: 60_000,\n      onSettleReady: (pda) => {\n        settlePromise = retrySettler.attemptSettle(pda);\n        return settlePromise;\n      },\n    });\n\n    await worker.poll();\n    if (settlePromise) await settlePromise;\n\n    const settled = await db.getRoundByPda(createJson.matchPda);\n    expect(settled!.phase).toBe(\"settled\");\n\n    const earnings =\n      await rawSql`SELECT * FROM referral_earnings WHERE referee_user_id = ${opponentProfile.user_id}`;\n    expect(earnings.length).toBe(1);\n    expect(Number(earnings[0]!.referrer_earned_lamports)).toBe(50_000);\n    expect(Number(earnings[0]!.referrer_rate_bps)).toBe(2000);\n    expect(Number(earnings[0]!.referee_rebate_lamports)).toBe(25_000);\n    expect(Number(earnings[0]!.referee_rebate_rate_bps)).toBe(1000);\n  });\n\n  it(\"settlement emits flipyou game.settled payloads with the expected shape\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n    const creatorUserId = userIdFromWallet(creatorKeypair.publicKey.toBase58());\n    const opponentUserId = userIdFromWallet(opponentKeypair.publicKey.toBase58());\n\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${creatorUserId}, ${creatorKeypair.publicKey.toBase58()}, 'creator')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${opponentUserId}, ${opponentKeypair.publicKey.toBase58()}, 'opponent')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n\n    const createRes = await app.request(\"/flipyou/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        Authorization: `Bearer ${token}`,\n      },\n      body: JSON.stringify({\n        wallet,\n        amountLamports: AMOUNT_LAMPORTS,\n        side: SIDE_HEADS,\n      }),\n    });\n    expect(createRes.status).toBe(200);\n    const createJson = (await createRes.json()) as {\n      matchPda: string;\n      matchId: string;\n      commitment: string;\n    };\n\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: Buffer.from(createJson.commitment, \"hex\"),\n      algorithmVer: 1,\n      targetSlot: 150n,\n      resolveDeadline: BigInt(Math.floor(Date.now() / 1000) + 86400),\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n    mockConn.setAccount(new PublicKey(createJson.matchPda), matchAccountData, {\n      owner: FLIPYOU_PROGRAM_ID,\n    });\n\n    await db.updateRoundPhase(createJson.matchPda, \"locked\");\n    await settleMatch(\n      {\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n        entropyAccount,\n        referralDefaultRateBps: 1000,\n      },\n      createJson.matchPda,\n    );\n\n    const events = await rawSql`\n      SELECT * FROM event_queue WHERE event_type = 'game.settled'\n    `;\n    expect(events.length).toBe(1);\n    expect(events[0]!.status).toBe(\"pending\");\n\n    const payload = events[0]!.payload as Record<string, any>;\n    expect(payload.roundId).toBe(createJson.matchId);\n    expect(payload.roundPda).toBe(createJson.matchPda);\n    expect(payload.game).toBe(\"flipyou\");\n    expect(payload.feeLamports).toBeDefined();\n    expect(payload.settledAt).toBeDefined();\n    expect(payload.players).toHaveLength(2);\n\n    const creator = payload.players.find(\n      (player: Record<string, string>) =>\n        player.wallet === creatorKeypair.publicKey.toBase58(),\n    );\n    const opponent = payload.players.find(\n      (player: Record<string, string>) =>\n        player.wallet === opponentKeypair.publicKey.toBase58(),\n    );\n    expect(creator).toBeDefined();\n    expect(opponent).toBeDefined();\n    expect(creator.isCreator).toBe(true);\n    expect(opponent.isCreator).toBe(false);\n    expect(creator.userId).toBe(creatorUserId);\n    expect(opponent.userId).toBe(opponentUserId);\n    expect(creator.amountLamports).toBe(String(AMOUNT_LAMPORTS));\n    expect(opponent.amountLamports).toBe(String(AMOUNT_LAMPORTS));\n    expect([creator.isWinner, opponent.isWinner].filter(Boolean)).toHaveLength(1);\n\n    const winner = creator.isWinner ? creator : opponent;\n    const loser = creator.isWinner ? opponent : creator;\n    expect(Number(winner.payoutLamports)).toBeGreaterThan(0);\n    expect(loser.payoutLamports).toBe(\"0\");\n    expect(payload.feeLamports).toBe(String(500_000));\n  });\n\n  it(\"closecall settlement emits game.settled payloads with the expected shape\", async () => {\n    const greenPlayer = Keypair.generate();\n    const redPlayer = Keypair.generate();\n    const greenUserId = userIdFromWallet(greenPlayer.publicKey.toBase58());\n    const redUserId = userIdFromWallet(redPlayer.publicKey.toBase58());\n\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${greenUserId}, ${greenPlayer.publicKey.toBase58()}, 'green_player')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES (${redUserId}, ${redPlayer.publicKey.toBase58()}, 'red_player')\n      ON CONFLICT (user_id) DO NOTHING\n    `;\n\n    const nowSec = Math.floor(Date.now() / 1000);\n    const minuteTs = BigInt(Math.floor((nowSec - 120) / 60) * 60);\n    const openPrice = 69500_00n;\n\n    const minuteTsBuf = Buffer.alloc(8);\n    minuteTsBuf.writeBigInt64LE(minuteTs);\n    const [roundPda] = PublicKey.findProgramAddressSync(\n      [Buffer.from(\"round\"), minuteTsBuf, serverKeypair.publicKey.toBuffer()],\n      CLOSECALL_PROGRAM_ID,\n    );\n\n    const roundAccountData = await encodeCloseCallRound({\n      minuteTs,\n      server: serverKeypair.publicKey,\n      phase: 0,\n      greenEntries: [\n        { player: greenPlayer.publicKey, amountLamports: 5_000_000n },\n      ],\n      redEntries: [{ player: redPlayer.publicKey, amountLamports: 5_000_000n }],\n      greenPool: 5_000_000n,\n      redPool: 5_000_000n,\n      openPrice,\n      openPriceExpo: -2,\n      closePrice: 0n,\n      createdAt: minuteTs,\n      bettingEndsAt: minuteTs + 45n,\n      resolveDeadline: minuteTs + 300n,\n      outcome: 0,\n      totalFee: 0n,\n      bump: 0,\n    });\n\n    mockConn.setAccount(roundPda, roundAccountData, {\n      owner: CLOSECALL_PROGRAM_ID,\n    });\n\n    const closePrice = 69600_00n;\n    const mockHermes: HermesFetcher = {\n      fetchLatestBtcPrice: async (): Promise<HermesPrice> => ({\n        price: closePrice,\n        expo: -2,\n        publishTime: Math.floor(Date.now() / 1000),\n        priceHuman: 69600.0,\n        vaaBase64: null,\n      }),\n    };\n\n    const clock = createCloseCallClockWorker({\n      connection: mockConn as unknown as Connection,\n      serverKeypair,\n      db,\n      hermesFetcher: mockHermes,\n    });\n\n    await clock.tick();\n\n    const events = await rawSql<{\n      status: string;\n      payload: Record<string, any>;\n    }[]>`\n      SELECT status, payload FROM event_queue WHERE event_type = 'game.settled'\n    `;\n    const matchingEvents = events.filter(\n      (event) =>\n        (event.payload as Record<string, any>).roundId ===\n        String(Number(minuteTs)),\n    );\n    expect(matchingEvents.length).toBe(1);\n    expect(matchingEvents[0]!.status).toBe(\"pending\");\n\n    const payload = matchingEvents[0]!.payload as Record<string, any>;\n    expect(payload.roundId).toBe(String(Number(minuteTs)));\n    expect(payload.roundPda).toBe(roundPda.toBase58());\n    expect(payload.game).toBe(\"closecall\");\n    expect(payload.feeLamports).toBeDefined();\n    expect(payload.settledAt).toBeDefined();\n    expect(payload.players).toHaveLength(2);\n\n    const green = payload.players.find(\n      (player: Record<string, string>) =>\n        player.wallet === greenPlayer.publicKey.toBase58(),\n    );\n    const red = payload.players.find(\n      (player: Record<string, string>) =>\n        player.wallet === redPlayer.publicKey.toBase58(),\n    );\n    expect(green).toBeDefined();\n    expect(red).toBeDefined();\n    expect(green.userId).toBe(greenUserId);\n    expect(red.userId).toBe(redUserId);\n    expect(green.amountLamports).toBe(String(5_000_000n));\n    expect(red.amountLamports).toBe(String(5_000_000n));\n    expect(green.isWinner).toBe(true);\n    expect(red.isWinner).toBe(false);\n    expect(Number(green.payoutLamports)).toBeGreaterThan(0);\n    expect(red.payoutLamports).toBe(\"0\");\n    expect(payload.feeLamports).toBe(String(500_000));\n    expect(green.isCreator).toBe(true);\n    expect(red.isCreator).toBe(false);\n  });\n});\n","structuredPatch":[{"oldStart":100,"oldLines":13,"newStart":100,"newLines":17,"lines":["     });"," ","     expect(createRes.status).toBe(200);","-    const createJson = (await createRes.json()) as {","-      transaction: string;","-      matchPda: string;","-      matchId: string;","-      commitment: string;","-      lastValidBlockHeight: number;","+    const createBody = (await createRes.json()) as {","+      ok: true;","+      data: {","+        transaction: string;","+        matchPda: string;","+        matchId: string;","+        commitment: string;","+        lastValidBlockHeight: number;","+      };","     };","+    const createJson = createBody.data;","     expect(createJson.transaction).toBeDefined();","     expect(createJson.matchPda).toBeDefined();","     expect(createJson.commitment).toBeDefined();"]}],"userModified":false,"replaceAll":false}}
