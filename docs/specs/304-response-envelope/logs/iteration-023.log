At\",\n      \"referrerCode\",\n      \"referrerUserId\",\n      \"referrerUsername\",\n    ],\n    authRequired: true,\n  },\n  \"GET /referral/stats\": {\n    requestBody: null,\n    response: [\n      \"activeCount\",\n      \"pendingLamports\",\n      \"referredCount\",\n      \"totalEarnedLamports\",\n      \"totalRebateLamports\",\n      \"totalVolumeLamports\",\n    ],\n    authRequired: true,\n  },\n  \"GET /referral/referrals\": {\n    requestBody: null,\n    response: [\"items\"],\n    itemResponse: [\"createdAt\", \"refereeUserId\", \"refereeUsername\"],\n    authRequired: true,\n  },\n} as const;","new_string":"const WAITLIST_CONTRACT = {\n  // ── Auth (public, JSON) ───────────────────────────────────────────────\n  \"POST /auth/challenge\": {\n    requestBody: [\"wallet\"],\n    response: [\"expiresAt\", \"message\", \"nonce\"],\n    successStatus: \"200\",\n    authRequired: false,\n  },\n  \"POST /auth/verify\": {\n    requestBody: [\"nonce\", \"signature\", \"wallet\"],\n    response: [\n      \"accessExpiresAt\",\n      \"accessToken\",\n      \"refreshExpiresAt\",\n      \"refreshToken\",\n    ],\n    successStatus: \"200\",\n    authRequired: false,\n  },\n  \"POST /auth/refresh\": {\n    requestBody: [\"refreshToken\"],\n    response: [\n      \"accessExpiresAt\",\n      \"accessToken\",\n      \"refreshExpiresAt\",\n      \"refreshToken\",\n    ],\n    successStatus: \"200\",\n    authRequired: false,\n  },\n  \"POST /auth/logout\": {\n    requestBody: [\"refreshToken\"], // optional on backend, always sent by waitlist\n    response: null, // 204 no body\n    successStatus: \"204\",\n    authRequired: false,\n  },\n\n  // ── Public referral ──────────────────────────────────────────────────\n  \"GET /public-referral/code/{code}\": {\n    requestBody: null,\n    response: [\"exists\"],\n    successStatus: \"200\",\n    authRequired: false,\n  },\n\n  // ── Authenticated referral ───────────────────────────────────────────\n  \"POST /referral/code\": {\n    requestBody: [\"code\"],\n    response: [\"code\"],\n    successStatus: \"200\",\n    authRequired: true,\n  },\n  \"GET /referral/code\": {\n    requestBody: null,\n    response: [\"code\"],\n    successStatus: \"200\",\n    authRequired: true,\n  },\n  \"POST /referral/apply\": {\n    requestBody: [\"code\"],\n    response: [\"benefit\", \"referrerUserId\"],\n    successStatus: \"200\",\n    authRequired: true,\n  },\n  \"GET /referral/referrer\": {\n    requestBody: null,\n    response: [\n      \"linkedAt\",\n      \"referrerCode\",\n      \"referrerUserId\",\n      \"referrerUsername\",\n    ],\n    successStatus: \"200\",\n    authRequired: true,\n  },\n  \"GET /referral/stats\": {\n    requestBody: null,\n    response: [\n      \"activeCount\",\n      \"pendingLamports\",\n      \"referredCount\",\n      \"totalEarnedLamports\",\n      \"totalRebateLamports\",\n      \"totalVolumeLamports\",\n    ],\n    successStatus: \"200\",\n    authRequired: true,\n  },\n  \"GET /referral/referrals\": {\n    requestBody: null,\n    response: [\"items\"],\n    itemResponse: [\"createdAt\", \"refereeUserId\", \"refereeUsername\"],\n    successStatus: \"200\",\n    authRequired: true,\n  },\n} as const;"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2068,"cache_read_input_tokens":97957,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2068},"output_tokens":54,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"12a29aff-adb0-4463-b149-c5e8c20a0688","uuid":"3ae4c81e-ea70-43b1-b396-71dce2a5f03a"}
