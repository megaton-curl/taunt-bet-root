insert\n      const msg =\n        insertError instanceof Error ? insertError.message : String(insertError);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return err(\n          c,\n          409,\n          API_ERROR_CODES.CODE_TAKEN,\n          \"This referral code is already in use\",\n          { retryable: false },\n        );\n      }\n      logger.error(\"Failed to set referral code\", {\n        err: String(insertError),\n        userId,\n        wallet,\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to set referral code\",\n      );\n    }\n  }, (result, c) => {\n    if (result.success) return;\n    return err(\n      c,\n      422,\n      API_ERROR_CODES.INVALID_CODE,\n      \"Referral code must be 3-16 lowercase letters, numbers, or hyphens.\",\n      { retryable: false, details: result.error.issues },\n    );\n  });\n\n  // ── POST /apply — link the authenticated player to a referrer ──────────\n\n  const applyRoute = createRoute({\n    method: \"post\",\n    path: \"/apply\",\n    tags: [\"Referral\"],\n    summary: \"Apply a referral code (link to referrer)\",\n    security: [{ bearerAuth: [] }],\n    request: {\n      body: {\n        required: true,\n        content: { \"application/json\": { schema: ApplyReferralCodeBodySchema } },\n      },\n    },\n    responses: {\n      200: {\n        content: {\n          \"application/json\": { schema: envelope(ReferralApplyResponseSchema) },\n        },\n        description: \"Linked to referrer\",\n      },\n      401: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Authentication required\",","numLines":135,"startLine":75,"totalLines":852}}}
