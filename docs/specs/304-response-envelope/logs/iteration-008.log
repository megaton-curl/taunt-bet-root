{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01E4fwQ6JqTELdaeJDv7FHbh","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_019JiSmFCTaK4TX9CFZxYpnj","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/src/routes/public-referral.ts","content":"/**\n * Public referral routes — unauthenticated lookup by user_id or username.\n *\n * WAITLIST-CONTRACT: the waitlist calls GET /code/{code} before wallet\n * connection to validate a pending referral. Shape pinned in\n * `__tests__/waitlist-contract.test.ts`; keep\n * `waitlist/src/lib/referral-api.ts` (checkReferralCode) in lockstep.\n */\n\nimport { createRoute, z } from \"@hono/zod-openapi\";\nimport type { Db } from \"../db.js\";\nimport { API_ERROR_CODES } from \"../contracts/api-errors.js\";\nimport {\n  envelope,\n  ErrorEnvelopeSchema,\n  ok,\n  err,\n} from \"../contracts/api-envelope.js\";\nimport {\n  ExistsResponseSchema,\n  PublicReferralLookupResponseSchema,\n  ReferralCodeSchema,\n} from \"../contracts/validators.js\";\nimport { logger } from \"../logger.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface PublicReferralRoutesDeps {\n  db: Db;\n}\n\nexport function createPublicReferralRoutes(deps: PublicReferralRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp();\n\n  /**\n   * Check whether a referral code exists.\n   * Used by the waitlist before wallet connection.\n   */\n  const checkCodeRoute = createRoute({\n    method: \"get\",\n    path: \"/code/{code}\",\n    tags: [\"Referral\"],\n    summary: \"Check whether a referral code exists\",\n    request: {\n      params: z.object({\n        code: z.string().openapi({ description: \"Referral code to check\" }),\n      }),\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: envelope(ExistsResponseSchema) } },\n        description: \"Referral code existence\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to check referral code\",\n      },\n    },\n  });\n\n  app.openapi(checkCodeRoute, async (c) => {\n    const { code: rawCode } = c.req.valid(\"param\");\n    const parsedCode = ReferralCodeSchema.safeParse(rawCode);\n    if (!parsedCode.success) {\n      return ok(c, { exists: false });\n    }\n    const code = parsedCode.data;\n\n    try {\n      const row = await db.getReferralCodeByCode(code);\n      return ok(c, { exists: !!row });\n    } catch (lookupError) {\n      logger.error(\"public-referral code check failed\", {\n        code,\n        error: lookupError instanceof Error ? lookupError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to check referral code\",\n      );\n    }\n  });\n\n  const lookupRoute = createRoute({\n    method: \"get\",\n    path: \"/{identifier}\",\n    tags: [\"Referral\"],\n    summary: \"Get public referral info by user ID or username\",\n    request: {\n      params: z.object({\n        identifier: z.string().openapi({ description: \"User ID (usr_xxxxxxxx) or username\" }),\n      }),\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: envelope(PublicReferralLookupResponseSchema) } },\n        description: \"Public referral lookup result\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Profile not found\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorEnvelopeSchema } },\n        description: \"Failed to fetch referral\",\n      },\n    },\n  });\n\n  app.openapi(lookupRoute, async (c) => {\n    const { identifier } = c.req.valid(\"param\");\n\n    try {\n      const profile = await db.getProfileByIdentifier(identifier);\n      if (!profile) {\n        return err(c, 404, API_ERROR_CODES.NOT_FOUND, \"Profile not found\");\n      }\n\n      const referralCode = await db.getReferralCodeByUserId(profile.user_id);\n      return ok(c, {\n        userId: profile.user_id,\n        username: profile.username,\n        referralCode: referralCode?.code ?? null,\n      });\n    } catch (lookupError) {\n      logger.error(\"public-referral lookup failed\", {\n        identifier,\n        error: lookupError instanceof Error ? lookupError.message : \"Unknown error\",\n      });\n      return err(\n        c,\n        500,\n        API_ERROR_CODES.PRECONDITION_FAILED,\n        \"Failed to fetch referral\",\n      );\n    }\n  });\n\n  return app;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":587,"cache_read_input_tokens":73781,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":587},"output_tokens":47,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"0a766de4-4ba4-4c0e-b963-559cc51990d7","uuid":"cba19244-ebab-41cc-b330-032c730b2574"}
