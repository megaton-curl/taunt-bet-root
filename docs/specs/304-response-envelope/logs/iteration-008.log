{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NSaHWBM1fePvPs7Ej1GeAe","type":"tool_result","content":"1\t/**\n2\t * Public referral routes — unauthenticated lookup by user_id or username.\n3\t *\n4\t * WAITLIST-CONTRACT: the waitlist calls GET /code/{code} before wallet\n5\t * connection to validate a pending referral. Shape pinned in\n6\t * `__tests__/waitlist-contract.test.ts`; keep\n7\t * `waitlist/src/lib/referral-api.ts` (checkReferralCode) in lockstep.\n8\t */\n9\t\n10\timport { createRoute, z } from \"@hono/zod-openapi\";\n11\timport type { Db } from \"../db.js\";\n12\timport { errorMessage } from \"../contracts/api-errors.js\";\n13\timport {\n14\t  ErrorResponseSchema,\n15\t  ExistsResponseSchema,\n16\t  PublicReferralLookupResponseSchema,\n17\t  ReferralCodeSchema,\n18\t} from \"../contracts/validators.js\";\n19\timport { logger } from \"../logger.js\";\n20\timport { createOpenApiApp } from \"../openapi/hono.js\";\n21\t\n22\texport interface PublicReferralRoutesDeps {\n23\t  db: Db;\n24\t}\n25\t\n26\texport function createPublicReferralRoutes(deps: PublicReferralRoutesDeps) {\n27\t  const { db } = deps;\n28\t  const app = createOpenApiApp();\n29\t\n30\t  /**\n31\t   * Check whether a referral code exists.\n32\t   * Used by the waitlist before wallet connection.\n33\t   */\n34\t  const checkCodeRoute = createRoute({\n35\t    method: \"get\",\n36\t    path: \"/code/{code}\",\n37\t    tags: [\"Referral\"],\n38\t    summary: \"Check whether a referral code exists\",\n39\t    request: {\n40\t      params: z.object({\n41\t        code: z.string().openapi({ description: \"Referral code to check\" }),\n42\t      }),\n43\t    },\n44\t    responses: {\n45\t      200: {\n46\t        content: { \"application/json\": { schema: ExistsResponseSchema } },\n47\t        description: \"Referral code existence\",\n48\t      },\n49\t      500: {\n50\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n51\t        description: \"Failed to check referral code\",\n52\t      },\n53\t    },\n54\t  });\n55\t\n56\t  app.openapi(checkCodeRoute, async (c) => {\n57\t    const { code: rawCode } = c.req.valid(\"param\");\n58\t    const parsedCode = ReferralCodeSchema.safeParse(rawCode);\n59\t    if (!parsedCode.success) {\n60\t      return c.json({ exists: false }, 200);\n61\t    }\n62\t    const code = parsedCode.data;\n63\t\n64\t    try {\n65\t      const row = await db.getReferralCodeByCode(code);\n66\t      return c.json({ exists: !!row }, 200);\n67\t    } catch (err) {\n68\t      logger.error(\"public-referral code check failed\", {\n69\t        code,\n70\t        error: err instanceof Error ? err.message : \"Unknown error\",\n71\t      });\n72\t      return c.json(errorMessage(\"Failed to check referral code\"), 500);\n73\t    }\n74\t  });\n75\t\n76\t  const lookupRoute = createRoute({\n77\t    method: \"get\",\n78\t    path: \"/{identifier}\",\n79\t    tags: [\"Referral\"],\n80\t    summary: \"Get public referral info by user ID or username\",\n81\t    request: {\n82\t      params: z.object({\n83\t        identifier: z.string().openapi({ description: \"User ID (usr_xxxxxxxx) or username\" }),\n84\t      }),\n85\t    },\n86\t    responses: {\n87\t      200: {\n88\t        content: { \"application/json\": { schema: PublicReferralLookupResponseSchema } },\n89\t        description: \"Public referral lookup result\",\n90\t      },\n91\t      404: {\n92\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n93\t        description: \"Profile not found\",\n94\t      },\n95\t      500: {\n96\t        content: { \"application/json\": { schema: ErrorResponseSchema } },\n97\t        description: \"Failed to fetch referral\",\n98\t      },\n99\t    },\n100\t  });\n101\t\n102\t  app.openapi(lookupRoute, async (c) => {\n103\t    const { identifier } = c.req.valid(\"param\");\n104\t\n105\t    try {\n106\t      const profile = await db.getProfileByIdentifier(identifier);\n107\t      if (!profile) {\n108\t        return c.json({ error: \"NOT_FOUND\" }, 404);\n109\t      }\n110\t\n111\t      const referralCode = await db.getReferralCodeByUserId(profile.user_id);\n112\t      return c.json(\n113\t        {\n114\t          userId: profile.user_id,\n115\t          username: profile.username,\n116\t          referralCode: referralCode?.code ?? null,\n117\t        },\n118\t        200,\n119\t      );\n120\t    } catch (err) {\n121\t      logger.error(\"public-referral lookup failed\", {\n122\t        identifier,\n123\t        error: err instanceof Error ? err.message : \"Unknown error\",\n124\t      });\n125\t      return c.json(errorMessage(\"Failed to fetch referral\"), 500);\n126\t    }\n127\t  });\n128\t\n129\t  return app;\n130\t}\n131\t"}]},"parent_tool_use_id":null,"session_id":"0a766de4-4ba4-4c0e-b963-559cc51990d7","uuid":"d2e4c6ba-16f7-44db-b6b1-88849e401552","timestamp":"2026-04-22T09:56:48.057Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/public-referral.ts","content":"/**\n * Public referral routes — unauthenticated lookup by user_id or username.\n *\n * WAITLIST-CONTRACT: the waitlist calls GET /code/{code} before wallet\n * connection to validate a pending referral. Shape pinned in\n * `__tests__/waitlist-contract.test.ts`; keep\n * `waitlist/src/lib/referral-api.ts` (checkReferralCode) in lockstep.\n */\n\nimport { createRoute, z } from \"@hono/zod-openapi\";\nimport type { Db } from \"../db.js\";\nimport { errorMessage } from \"../contracts/api-errors.js\";\nimport {\n  ErrorResponseSchema,\n  ExistsResponseSchema,\n  PublicReferralLookupResponseSchema,\n  ReferralCodeSchema,\n} from \"../contracts/validators.js\";\nimport { logger } from \"../logger.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\nexport interface PublicReferralRoutesDeps {\n  db: Db;\n}\n\nexport function createPublicReferralRoutes(deps: PublicReferralRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp();\n\n  /**\n   * Check whether a referral code exists.\n   * Used by the waitlist before wallet connection.\n   */\n  const checkCodeRoute = createRoute({\n    method: \"get\",\n    path: \"/code/{code}\",\n    tags: [\"Referral\"],\n    summary: \"Check whether a referral code exists\",\n    request: {\n      params: z.object({\n        code: z.string().openapi({ description: \"Referral code to check\" }),\n      }),\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: ExistsResponseSchema } },\n        description: \"Referral code existence\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to check referral code\",\n      },\n    },\n  });\n\n  app.openapi(checkCodeRoute, async (c) => {\n    const { code: rawCode } = c.req.valid(\"param\");\n    const parsedCode = ReferralCodeSchema.safeParse(rawCode);\n    if (!parsedCode.success) {\n      return c.json({ exists: false }, 200);\n    }\n    const code = parsedCode.data;\n\n    try {\n      const row = await db.getReferralCodeByCode(code);\n      return c.json({ exists: !!row }, 200);\n    } catch (err) {\n      logger.error(\"public-referral code check failed\", {\n        code,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json(errorMessage(\"Failed to check referral code\"), 500);\n    }\n  });\n\n  const lookupRoute = createRoute({\n    method: \"get\",\n    path: \"/{identifier}\",\n    tags: [\"Referral\"],\n    summary: \"Get public referral info by user ID or username\",\n    request: {\n      params: z.object({\n        identifier: z.string().openapi({ description: \"User ID (usr_xxxxxxxx) or username\" }),\n      }),\n    },\n    responses: {\n      200: {\n        content: { \"application/json\": { schema: PublicReferralLookupResponseSchema } },\n        description: \"Public referral lookup result\",\n      },\n      404: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Profile not found\",\n      },\n      500: {\n        content: { \"application/json\": { schema: ErrorResponseSchema } },\n        description: \"Failed to fetch referral\",\n      },\n    },\n  });\n\n  app.openapi(lookupRoute, async (c) => {\n    const { identifier } = c.req.valid(\"param\");\n\n    try {\n      const profile = await db.getProfileByIdentifier(identifier);\n      if (!profile) {\n        return c.json({ error: \"NOT_FOUND\" }, 404);\n      }\n\n      const referralCode = await db.getReferralCodeByUserId(profile.user_id);\n      return c.json(\n        {\n          userId: profile.user_id,\n          username: profile.username,\n          referralCode: referralCode?.code ?? null,\n        },\n        200,\n      );\n    } catch (err) {\n      logger.error(\"public-referral lookup failed\", {\n        identifier,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json(errorMessage(\"Failed to fetch referral\"), 500);\n    }\n  });\n\n  return app;\n}\n","numLines":131,"startLine":1,"totalLines":131}}}
