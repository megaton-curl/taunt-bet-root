{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01StppPYEYoCZ3BgQqHoiosY","type":"tool_result","content":"1\t/* eslint-disable @typescript-eslint/no-explicit-any */\n2\timport { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";\n3\timport { Hono } from \"hono\";\n4\timport type { Db } from \"../db.js\";\n5\timport { createDogpileRoutes } from \"../routes/dogpile.js\";\n6\timport { createPublicReferralRoutes } from \"../routes/public-referral.js\";\n7\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n8\timport {\n9\t  closeIntegrationDb,\n10\t  JWT_SECRET,\n11\t  openIntegrationDb,\n12\t  resetIntegrationState,\n13\t  type IntegrationDbContext,\n14\t  type TestSql,\n15\t} from \"./integration-test-helpers.js\";\n16\t\n17\tdescribe(\"Public referral routes\", () => {\n18\t  let ctx: IntegrationDbContext;\n19\t  let rawSql: TestSql;\n20\t  let db: Db;\n21\t  let app: Hono;\n22\t\n23\t  beforeAll(async () => {\n24\t    ctx = await openIntegrationDb();\n25\t    rawSql = ctx.rawSql;\n26\t    db = ctx.db;\n27\t  });\n28\t\n29\t  afterAll(async () => {\n30\t    await closeIntegrationDb(ctx);\n31\t  });\n32\t\n33\t  beforeEach(async () => {\n34\t    await resetIntegrationState(rawSql);\n35\t    app = new Hono();\n36\t    app.route(\"/public-referral\", createPublicReferralRoutes({ db }));\n37\t    app.use(\"/dogpile/*\", createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }));\n38\t    app.route(\"/dogpile\", createDogpileRoutes({ db }));\n39\t  });\n40\t\n41\t  it(\"GET /public-referral/:identifier returns the player's referral code when set\", async () => {\n42\t    await rawSql`\n43\t      INSERT INTO player_profiles (user_id, wallet, username)\n44\t      VALUES ('usr_alice', 'wallet_alice', 'alice')\n45\t    `;\n46\t    await rawSql`\n47\t      INSERT INTO referral_codes (user_id, wallet, code)\n48\t      VALUES ('usr_alice', 'wallet_alice', 'alpha')\n49\t    `;\n50\t\n51\t    const response = await app.request(\"/public-referral/alice\");\n52\t    expect(response.status).toBe(200);\n53\t\n54\t    const body = (await response.json()) as Record<string, any>;\n55\t    expect(body.userId).toBe(\"usr_alice\");\n56\t    expect(body.username).toBe(\"alice\");\n57\t    expect(body.referralCode).toBe(\"alpha\");\n58\t  });\n59\t\n60\t  it(\"GET /public-referral/:identifier returns null referralCode when the player has none\", async () => {\n61\t    await rawSql`\n62\t      INSERT INTO player_profiles (user_id, wallet, username)\n63\t      VALUES ('usr_bob', 'wallet_bob', 'bob')\n64\t    `;\n65\t\n66\t    const response = await app.request(\"/public-referral/bob\");\n67\t    expect(response.status).toBe(200);\n68\t\n69\t    const body = (await response.json()) as Record<string, any>;\n70\t    expect(body.userId).toBe(\"usr_bob\");\n71\t    expect(body.username).toBe(\"bob\");\n72\t    expect(body.referralCode).toBeNull();\n73\t  });\n74\t\n75\t  it(\"GET /public-referral/:identifier returns 404 for unknown players\", async () => {\n76\t    const response = await app.request(\"/public-referral/missing\");\n77\t\n78\t    expect(response.status).toBe(404);\n79\t    expect(await response.json()).toEqual({ error: \"NOT_FOUND\" });\n80\t  });\n81\t\n82\t  // ── GET /public-referral/code/:code ──────────────────────────────\n83\t\n84\t  it(\"GET /public-referral/code/:code returns exists:true for a real code\", async () => {\n85\t    await rawSql`\n86\t      INSERT INTO player_profiles (user_id, wallet, username)\n87\t      VALUES ('usr_carol', 'wallet_carol', 'carol')\n88\t    `;\n89\t    await rawSql`\n90\t      INSERT INTO referral_codes (user_id, wallet, code)\n91\t      VALUES ('usr_carol', 'wallet_carol', 'beta')\n92\t    `;\n93\t\n94\t    const response = await app.request(\"/public-referral/code/beta\");\n95\t    expect(response.status).toBe(200);\n96\t    expect(await response.json()).toEqual({ exists: true });\n97\t  });\n98\t\n99\t  it(\"GET /public-referral/code/:code returns exists:false for unknown code\", async () => {\n100\t    const response = await app.request(\"/public-referral/code/nope\");\n101\t    expect(response.status).toBe(200);\n102\t    expect(await response.json()).toEqual({ exists: false });\n103\t  });\n104\t\n105\t  it(\"GET /public-referral/code/:code returns exists:false for invalid format\", async () => {\n106\t    const response = await app.request(\"/public-referral/code/AB!!INVALID\");\n107\t    expect(response.status).toBe(200);\n108\t    expect(await response.json()).toEqual({ exists: false });\n109\t  });\n110\t\n111\t  it(\"GET /dogpile/current remains public when JWT middleware uses default GET passthrough\", async () => {\n112\t    await rawSql`\n113\t      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n114\t      VALUES (now() + interval '20 minutes', now() + interval '80 minutes', 2.0, 'scheduled')\n115\t    `;\n116\t\n117\t    const response = await app.request(\"/dogpile/current\");\n118\t    expect(response.status).toBe(200);\n119\t\n120\t    const body = (await response.json()) as Record<string, any>;\n121\t    expect(body.status).toBe(\"scheduled\");\n122\t    expect(body.multiplier).toBe(2);\n123\t    expect(body.startsIn).toBeGreaterThan(0);\n124\t  });\n125\t});\n126\t"}]},"parent_tool_use_id":null,"session_id":"0a766de4-4ba4-4c0e-b963-559cc51990d7","uuid":"d47f9206-cb6d-40e8-b097-575254be4ee8","timestamp":"2026-04-22T09:56:53.699Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/public-referral-routes.test.ts","content":"/* eslint-disable @typescript-eslint/no-explicit-any */\nimport { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";\nimport { Hono } from \"hono\";\nimport type { Db } from \"../db.js\";\nimport { createDogpileRoutes } from \"../routes/dogpile.js\";\nimport { createPublicReferralRoutes } from \"../routes/public-referral.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport {\n  closeIntegrationDb,\n  JWT_SECRET,\n  openIntegrationDb,\n  resetIntegrationState,\n  type IntegrationDbContext,\n  type TestSql,\n} from \"./integration-test-helpers.js\";\n\ndescribe(\"Public referral routes\", () => {\n  let ctx: IntegrationDbContext;\n  let rawSql: TestSql;\n  let db: Db;\n  let app: Hono;\n\n  beforeAll(async () => {\n    ctx = await openIntegrationDb();\n    rawSql = ctx.rawSql;\n    db = ctx.db;\n  });\n\n  afterAll(async () => {\n    await closeIntegrationDb(ctx);\n  });\n\n  beforeEach(async () => {\n    await resetIntegrationState(rawSql);\n    app = new Hono();\n    app.route(\"/public-referral\", createPublicReferralRoutes({ db }));\n    app.use(\"/dogpile/*\", createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }));\n    app.route(\"/dogpile\", createDogpileRoutes({ db }));\n  });\n\n  it(\"GET /public-referral/:identifier returns the player's referral code when set\", async () => {\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES ('usr_alice', 'wallet_alice', 'alice')\n    `;\n    await rawSql`\n      INSERT INTO referral_codes (user_id, wallet, code)\n      VALUES ('usr_alice', 'wallet_alice', 'alpha')\n    `;\n\n    const response = await app.request(\"/public-referral/alice\");\n    expect(response.status).toBe(200);\n\n    const body = (await response.json()) as Record<string, any>;\n    expect(body.userId).toBe(\"usr_alice\");\n    expect(body.username).toBe(\"alice\");\n    expect(body.referralCode).toBe(\"alpha\");\n  });\n\n  it(\"GET /public-referral/:identifier returns null referralCode when the player has none\", async () => {\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES ('usr_bob', 'wallet_bob', 'bob')\n    `;\n\n    const response = await app.request(\"/public-referral/bob\");\n    expect(response.status).toBe(200);\n\n    const body = (await response.json()) as Record<string, any>;\n    expect(body.userId).toBe(\"usr_bob\");\n    expect(body.username).toBe(\"bob\");\n    expect(body.referralCode).toBeNull();\n  });\n\n  it(\"GET /public-referral/:identifier returns 404 for unknown players\", async () => {\n    const response = await app.request(\"/public-referral/missing\");\n\n    expect(response.status).toBe(404);\n    expect(await response.json()).toEqual({ error: \"NOT_FOUND\" });\n  });\n\n  // ── GET /public-referral/code/:code ──────────────────────────────\n\n  it(\"GET /public-referral/code/:code returns exists:true for a real code\", async () => {\n    await rawSql`\n      INSERT INTO player_profiles (user_id, wallet, username)\n      VALUES ('usr_carol', 'wallet_carol', 'carol')\n    `;\n    await rawSql`\n      INSERT INTO referral_codes (user_id, wallet, code)\n      VALUES ('usr_carol', 'wallet_carol', 'beta')\n    `;\n\n    const response = await app.request(\"/public-referral/code/beta\");\n    expect(response.status).toBe(200);\n    expect(await response.json()).toEqual({ exists: true });\n  });\n\n  it(\"GET /public-referral/code/:code returns exists:false for unknown code\", async () => {\n    const response = await app.request(\"/public-referral/code/nope\");\n    expect(response.status).toBe(200);\n    expect(await response.json()).toEqual({ exists: false });\n  });\n\n  it(\"GET /public-referral/code/:code returns exists:false for invalid format\", async () => {\n    const response = await app.request(\"/public-referral/code/AB!!INVALID\");\n    expect(response.status).toBe(200);\n    expect(await response.json()).toEqual({ exists: false });\n  });\n\n  it(\"GET /dogpile/current remains public when JWT middleware uses default GET passthrough\", async () => {\n    await rawSql`\n      INSERT INTO dogpile_events (starts_at, ends_at, multiplier, status)\n      VALUES (now() + interval '20 minutes', now() + interval '80 minutes', 2.0, 'scheduled')\n    `;\n\n    const response = await app.request(\"/dogpile/current\");\n    expect(response.status).toBe(200);\n\n    const body = (await response.json()) as Record<string, any>;\n    expect(body.status).toBe(\"scheduled\");\n    expect(body.multiplier).toBe(2);\n    expect(body.startsIn).toBeGreaterThan(0);\n  });\n});\n","numLines":126,"startLine":1,"totalLines":126}}}
