{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LH2zf2nJKvn4QkLrwpd3Yq","type":"tool_result","content":"1\texport interface ErrorResponseBody {\n2\t  error: string;\n3\t}\n4\t\n5\texport interface StructuredErrorDetail {\n6\t  code: string;\n7\t  message: string;\n8\t  retryable?: boolean;\n9\t}\n10\t\n11\texport interface StructuredErrorResponseBody {\n12\t  error: StructuredErrorDetail;\n13\t}\n14\t\n15\texport function errorMessage(error: string): ErrorResponseBody {\n16\t  return { error };\n17\t}\n18\t\n19\texport function structuredErrorMessage(\n20\t  code: string,\n21\t  message: string,\n22\t  retryable?: boolean,\n23\t): StructuredErrorResponseBody {\n24\t  return {\n25\t    error: retryable === undefined ? { code, message } : { code, message, retryable },\n26\t  };\n27\t}\n28\t"}]},"parent_tool_use_id":null,"session_id":"1457c4df-37f5-4b88-a9bb-32dd3ea06637","uuid":"9c31449e-a878-453a-8e5c-ab7736dce236","timestamp":"2026-04-22T09:15:43.735Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/contracts/api-errors.ts","content":"export interface ErrorResponseBody {\n  error: string;\n}\n\nexport interface StructuredErrorDetail {\n  code: string;\n  message: string;\n  retryable?: boolean;\n}\n\nexport interface StructuredErrorResponseBody {\n  error: StructuredErrorDetail;\n}\n\nexport function errorMessage(error: string): ErrorResponseBody {\n  return { error };\n}\n\nexport function structuredErrorMessage(\n  code: string,\n  message: string,\n  retryable?: boolean,\n): StructuredErrorResponseBody {\n  return {\n    error: retryable === undefined ? { code, message } : { code, message, retryable },\n  };\n}\n","numLines":28,"startLine":1,"totalLines":28}}}
