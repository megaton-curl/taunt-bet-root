{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0144pJLNxL6SHfNk1VRMWxgy","type":"tool_result","content":"1\t/**\n2\t * Shared response envelope for public JSON routes.\n3\t *\n4\t * Every public JSON response body is either:\n5\t *   { ok: true,  data: <payload> }   — success (200/201/202)\n6\t *   { ok: false, error: ApiError }   — failure (4xx/5xx)\n7\t *\n8\t * Semantic HTTP status is preserved — handled domain failures MUST NOT be\n9\t * flattened into `200`. See `docs/specs/304-response-envelope/spec.md`.\n10\t */\n11\t\n12\timport { z } from \"zod\";\n13\timport type { Context } from \"hono\";\n14\t\n15\t// TEMPORARY: `ApiErrorCode` will be redefined as the union of\n16\t// `API_ERROR_CODES` values once `api-errors.ts` is rewritten in the next\n17\t// iteration. Keeping it as `string` here lets this file ship standalone.\n18\texport type ApiErrorCode = string;\n19\t\n20\texport interface ApiError {\n21\t  code: ApiErrorCode;\n22\t  message: string;\n23\t  retryable?: boolean;\n24\t  details?: unknown;\n25\t}\n26\t\n27\texport interface ApiEnvelopeSuccess<T> {\n28\t  ok: true;\n29\t  data: T;\n30\t}\n31\t\n32\texport interface ApiEnvelopeError {\n33\t  ok: false;\n34\t  error: ApiError;\n35\t}\n36\t\n37\texport type ApiEnvelope<T> = ApiEnvelopeSuccess<T> | ApiEnvelopeError;\n38\t\n39\texport const ApiErrorSchema = z.object({\n40\t  code: z.string(),\n41\t  message: z.string(),\n42\t  retryable: z.boolean().optional(),\n43\t  details: z.unknown().optional(),\n44\t});\n45\t\n46\texport const ErrorEnvelopeSchema = z.object({\n47\t  ok: z.literal(false),\n48\t  error: ApiErrorSchema,\n49\t});\n50\t\n51\texport function envelope<T extends z.ZodTypeAny>(dataSchema: T) {\n52\t  return z.discriminatedUnion(\"ok\", [\n53\t    z.object({\n54\t      ok: z.literal(true),\n55\t      data: dataSchema,\n56\t    }),\n57\t    ErrorEnvelopeSchema,\n58\t  ]);\n59\t}\n60\t\n61\texport type SuccessStatus = 200 | 201 | 202;\n62\texport type ErrorStatus = 400 | 401 | 403 | 404 | 409 | 422 | 429 | 500 | 503;\n63\t\n64\texport function ok<T>(c: Context, data: T, status: SuccessStatus = 200) {\n65\t  const body: ApiEnvelopeSuccess<T> = { ok: true, data };\n66\t  return c.json(body, status);\n67\t}\n68\t\n69\texport function err(\n70\t  c: Context,\n71\t  status: ErrorStatus,\n72\t  code: ApiErrorCode,\n73\t  message: string,\n74\t  opts?: { retryable?: boolean; details?: unknown },\n75\t) {\n76\t  const error: ApiError = { code, message };\n77\t  if (opts?.retryable !== undefined) error.retryable = opts.retryable;\n78\t  if (opts?.details !== undefined) error.details = opts.details;\n79\t  const body: ApiEnvelopeError = { ok: false, error };\n80\t  return c.json(body, status);\n81\t}\n82\t"}]},"parent_tool_use_id":null,"session_id":"1457c4df-37f5-4b88-a9bb-32dd3ea06637","uuid":"93ec8f99-1e9c-4716-8f4c-c6147f7c9c23","timestamp":"2026-04-22T09:15:46.473Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/contracts/api-envelope.ts","content":"/**\n * Shared response envelope for public JSON routes.\n *\n * Every public JSON response body is either:\n *   { ok: true,  data: <payload> }   — success (200/201/202)\n *   { ok: false, error: ApiError }   — failure (4xx/5xx)\n *\n * Semantic HTTP status is preserved — handled domain failures MUST NOT be\n * flattened into `200`. See `docs/specs/304-response-envelope/spec.md`.\n */\n\nimport { z } from \"zod\";\nimport type { Context } from \"hono\";\n\n// TEMPORARY: `ApiErrorCode` will be redefined as the union of\n// `API_ERROR_CODES` values once `api-errors.ts` is rewritten in the next\n// iteration. Keeping it as `string` here lets this file ship standalone.\nexport type ApiErrorCode = string;\n\nexport interface ApiError {\n  code: ApiErrorCode;\n  message: string;\n  retryable?: boolean;\n  details?: unknown;\n}\n\nexport interface ApiEnvelopeSuccess<T> {\n  ok: true;\n  data: T;\n}\n\nexport interface ApiEnvelopeError {\n  ok: false;\n  error: ApiError;\n}\n\nexport type ApiEnvelope<T> = ApiEnvelopeSuccess<T> | ApiEnvelopeError;\n\nexport const ApiErrorSchema = z.object({\n  code: z.string(),\n  message: z.string(),\n  retryable: z.boolean().optional(),\n  details: z.unknown().optional(),\n});\n\nexport const ErrorEnvelopeSchema = z.object({\n  ok: z.literal(false),\n  error: ApiErrorSchema,\n});\n\nexport function envelope<T extends z.ZodTypeAny>(dataSchema: T) {\n  return z.discriminatedUnion(\"ok\", [\n    z.object({\n      ok: z.literal(true),\n      data: dataSchema,\n    }),\n    ErrorEnvelopeSchema,\n  ]);\n}\n\nexport type SuccessStatus = 200 | 201 | 202;\nexport type ErrorStatus = 400 | 401 | 403 | 404 | 409 | 422 | 429 | 500 | 503;\n\nexport function ok<T>(c: Context, data: T, status: SuccessStatus = 200) {\n  const body: ApiEnvelopeSuccess<T> = { ok: true, data };\n  return c.json(body, status);\n}\n\nexport function err(\n  c: Context,\n  status: ErrorStatus,\n  code: ApiErrorCode,\n  message: string,\n  opts?: { retryable?: boolean; details?: unknown },\n) {\n  const error: ApiError = { code, message };\n  if (opts?.retryable !== undefined) error.retryable = opts.retryable;\n  if (opts?.details !== undefined) error.details = opts.details;\n  const body: ApiEnvelopeError = { ok: false, error };\n  return c.json(body, status);\n}\n","numLines":82,"startLine":1,"totalLines":82}}}
