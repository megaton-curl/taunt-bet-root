{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YT7NYjE21F3cjJEPMHi9QQ","type":"tool_result","content":"The file /workspaces/rng-utopia/backend/src/contracts/api-envelope.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"1457c4df-37f5-4b88-a9bb-32dd3ea06637","uuid":"1e9ce32d-667c-4ed4-b939-da7c720da922","timestamp":"2026-04-22T09:16:42.380Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/backend/src/contracts/api-envelope.ts","oldString":"import { z } from \"zod\";\nimport type { Context } from \"hono\";\n\n// TEMPORARY: `ApiErrorCode` will be redefined as the union of\n// `API_ERROR_CODES` values once `api-errors.ts` is rewritten in the next\n// iteration. Keeping it as `string` here lets this file ship standalone.\nexport type ApiErrorCode = string;","newString":"import { z } from \"zod\";\nimport type { Context } from \"hono\";\n\nexport type { ApiErrorCode } from \"./api-errors.js\";\nimport type { ApiErrorCode } from \"./api-errors.js\";","originalFile":"/**\n * Shared response envelope for public JSON routes.\n *\n * Every public JSON response body is either:\n *   { ok: true,  data: <payload> }   — success (200/201/202)\n *   { ok: false, error: ApiError }   — failure (4xx/5xx)\n *\n * Semantic HTTP status is preserved — handled domain failures MUST NOT be\n * flattened into `200`. See `docs/specs/304-response-envelope/spec.md`.\n */\n\nimport { z } from \"zod\";\nimport type { Context } from \"hono\";\n\n// TEMPORARY: `ApiErrorCode` will be redefined as the union of\n// `API_ERROR_CODES` values once `api-errors.ts` is rewritten in the next\n// iteration. Keeping it as `string` here lets this file ship standalone.\nexport type ApiErrorCode = string;\n\nexport interface ApiError {\n  code: ApiErrorCode;\n  message: string;\n  retryable?: boolean;\n  details?: unknown;\n}\n\nexport interface ApiEnvelopeSuccess<T> {\n  ok: true;\n  data: T;\n}\n\nexport interface ApiEnvelopeError {\n  ok: false;\n  error: ApiError;\n}\n\nexport type ApiEnvelope<T> = ApiEnvelopeSuccess<T> | ApiEnvelopeError;\n\nexport const ApiErrorSchema = z.object({\n  code: z.string(),\n  message: z.string(),\n  retryable: z.boolean().optional(),\n  details: z.unknown().optional(),\n});\n\nexport const ErrorEnvelopeSchema = z.object({\n  ok: z.literal(false),\n  error: ApiErrorSchema,\n});\n\nexport function envelope<T extends z.ZodTypeAny>(dataSchema: T) {\n  return z.discriminatedUnion(\"ok\", [\n    z.object({\n      ok: z.literal(true),\n      data: dataSchema,\n    }),\n    ErrorEnvelopeSchema,\n  ]);\n}\n\nexport type SuccessStatus = 200 | 201 | 202;\nexport type ErrorStatus = 400 | 401 | 403 | 404 | 409 | 422 | 429 | 500 | 503;\n\nexport function ok<T>(c: Context, data: T, status: SuccessStatus = 200) {\n  const body: ApiEnvelopeSuccess<T> = { ok: true, data };\n  return c.json(body, status);\n}\n\nexport function err(\n  c: Context,\n  status: ErrorStatus,\n  code: ApiErrorCode,\n  message: string,\n  opts?: { retryable?: boolean; details?: unknown },\n) {\n  const error: ApiError = { code, message };\n  if (opts?.retryable !== undefined) error.retryable = opts.retryable;\n  if (opts?.details !== undefined) error.details = opts.details;\n  const body: ApiEnvelopeError = { ok: false, error };\n  return c.json(body, status);\n}\n","structuredPatch":[{"oldStart":12,"oldLines":10,"newStart":12,"newLines":8,"lines":[" import { z } from \"zod\";"," import type { Context } from \"hono\";"," ","-// TEMPORARY: `ApiErrorCode` will be redefined as the union of","-// `API_ERROR_CODES` values once `api-errors.ts` is rewritten in the next","-// iteration. Keeping it as `string` here lets this file ship standalone.","-export type ApiErrorCode = string;","+export type { ApiErrorCode } from \"./api-errors.js\";","+import type { ApiErrorCode } from \"./api-errors.js\";"," "," export interface ApiError {","   code: ApiErrorCode;"]}],"userModified":false,"replaceAll":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01Y6GnJnrro1ZqobwGRtJYRz","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_018UUUoGBDRXFNBhLu1wNEiX","name":"Write","input":{"file_path":"/workspaces/rng-utopia/backend/src/__tests__/api-errors.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport {\n  API_ERROR_CODES,\n  type ApiErrorCode,\n} from \"../contracts/api-errors.js\";\n\ndescribe(\"API_ERROR_CODES catalog\", () => {\n  it(\"is the single source of truth: every key equals its value\", () => {\n    for (const [key, value] of Object.entries(API_ERROR_CODES)) {\n      expect(value).toBe(key);\n    }\n  });\n\n  it(\"contains only SCREAMING_SNAKE_CASE entries\", () => {\n    for (const value of Object.values(API_ERROR_CODES)) {\n      expect(value).toMatch(/^[A-Z][A-Z0-9_]*$/);\n    }\n  });\n\n  it(\"emits unique code values with no duplicates\", () => {\n    const values = Object.values(API_ERROR_CODES);\n    const unique = new Set(values);\n    expect(unique.size).toBe(values.length);\n  });\n\n  it(\"is frozen-shaped (as const) so keys and values align at the type level\", () => {\n    const probe: ApiErrorCode = API_ERROR_CODES.AUTH_REQUIRED;\n    expect(probe).toBe(\"AUTH_REQUIRED\");\n  });\n\n  it(\"covers every error code declared by FR-2\", () => {\n    const expected = [\n      \"AUTH_REQUIRED\",\n      \"FORBIDDEN\",\n      \"RATE_LIMITED\",\n      \"VALIDATION_FAILED\",\n      \"INVALID_REQUEST\",\n      \"INVALID_PARAMS\",\n      \"INVALID_SIGNATURE\",\n      \"CHALLENGE_EXPIRED\",\n      \"REFRESH_TOKEN_INVALID\",\n      \"CODE_ALREADY_SET\",\n      \"CODE_TAKEN\",\n      \"CODE_NOT_FOUND\",\n      \"INVALID_CODE\",\n      \"SELF_REFERRAL\",\n      \"ALREADY_LINKED\",\n      \"ZERO_BALANCE\",\n      \"BELOW_THRESHOLD\",\n      \"CLAIM_NOT_FOUND\",\n      \"PROFILE_NOT_FOUND\",\n      \"USERNAME_TAKEN\",\n      \"USERNAME_COOLDOWN\",\n      \"INVALID_USERNAME\",\n      \"MATCH_NOT_FOUND\",\n      \"MATCH_PHASE_INVALID\",\n      \"ROUND_NOT_FOUND\",\n      \"BET_TOO_SMALL\",\n      \"BET_TOO_LARGE\",\n      \"TELEGRAM_NOT_LINKED\",\n      \"TELEGRAM_ALREADY_LINKED\",\n      \"TELEGRAM_TOKEN_EXPIRED\",\n      \"PRICE_UNAVAILABLE\",\n      \"NOT_FOUND\",\n      \"CONFLICT\",\n      \"PRECONDITION_FAILED\",\n    ] as const;\n    for (const code of expected) {\n      expect(API_ERROR_CODES).toHaveProperty(code, code);\n    }\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":446,"cache_read_input_tokens":66942,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":446},"output_tokens":62,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"1457c4df-37f5-4b88-a9bb-32dd3ea06637","uuid":"8e46f95a-412f-41ba-9bf0-33824c7cac25"}
