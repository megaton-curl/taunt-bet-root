ed = schema.parse({\n134\t      ok: false,\n135\t      error: { code: \"BAD\", message: \"nope\" },\n136\t    });\n137\t    expect(parsed).toEqual({\n138\t      ok: false,\n139\t      error: { code: \"BAD\", message: \"nope\" },\n140\t    });\n141\t  });\n142\t\n143\t  it(\"parses an error envelope with retryable + details\", () => {\n144\t    const parsed = schema.parse({\n145\t      ok: false,\n146\t      error: {\n147\t        code: \"RATE_LIMITED\",\n148\t        message: \"slow down\",\n149\t        retryable: true,\n150\t        details: { retryAfterMs: 1000 },\n151\t      },\n152\t    });\n153\t    if (parsed.ok) throw new Error(\"expected error envelope\");\n154\t    expect(parsed.error.retryable).toBe(true);\n155\t    expect(parsed.error.details).toEqual({ retryAfterMs: 1000 });\n156\t  });\n157\t\n158\t  it(\"rejects a success envelope when data is wrong shape\", () => {\n159\t    expect(() => schema.parse({ ok: true, data: { id: \"not-a-number\" } })).toThrow();\n160\t  });\n161\t\n162\t  it(\"rejects an envelope with no ok discriminator\", () => {\n163\t    expect(() => schema.parse({ data: { id: 1 } })).toThrow();\n164\t  });\n165\t\n166\t  it(\"narrows via the `ok` discriminator\", () => {\n167\t    const parsed = schema.parse({ ok: true, data: { id: 7 } });\n168\t    if (parsed.ok) {\n169\t      expect(parsed.data.id).toBe(7);\n170\t    } else {\n171\t      throw new Error(\"expected success envelope\");\n172\t    }\n173\t  });\n174\t});\n175\t\n176\tdescribe(\"ApiErrorSchema + ErrorEnvelopeSchema\", () => {\n177\t  it(\"round-trips the minimal error shape\", () => {\n178\t    const input = { code: \"AUTH_REQUIRED\", message: \"sign in\" };\n179\t    expect(ApiErrorSchema.parse(input)).toEqual(input);\n180\t  });\n181\t\n182\t  it(\"round-trips an error with retryable + details\", () => {\n183\t    const input = {\n184\t      code: \"VALIDATION_FAILED\",\n185\t      message: \"Invalid request\",\n186\t      retryable: false,\n187\t      details: [{ pa