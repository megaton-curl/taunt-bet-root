data: { hello: \"world\" } });\n  });\n\n  it(\"preserves 201 for created\", async () => {\n    const app = makeApp();\n    app.post(\"/\", (c) => ok(c, { id: 1 }, 201));\n\n    const res = await app.request(\"/\", { method: \"POST\" });\n    expect(res.status).toBe(201);\n    const body = (await res.json()) as ApiEnvelopeSuccess<{ id: number }>;\n    expect(body).toEqual({ ok: true, data: { id: 1 } });\n  });\n\n  it(\"preserves 202 for accepted\", async () => {\n    const app = makeApp();\n    app.post(\"/\", (c) => ok(c, { queued: true }, 202));\n\n    const res = await app.request(\"/\", { method: \"POST\" });\n    expect(res.status).toBe(202);\n    const body = (await res.json()) as ApiEnvelopeSuccess<{ queued: boolean }>;\n    expect(body).toEqual({ ok: true, data: { queued: true } });\n  });\n\n  it(\"supports nullable/empty data for documented empty-state reads\", async () => {\n    const app = makeApp();\n    app.get(\"/\", (c) => ok(c, { code: null as string | null }));\n\n    const res = await app.request(\"/\");\n    expect(res.status).toBe(200);\n    const body = (await res.json()) as ApiEnvelopeSuccess<{ code: string | null }>;\n    expect(body).toEqual({ ok: true, data: { code: null } });\n  });\n});\n\ndescribe(\"err()\", () => {\n  const errorStatuses = [400, 401, 403, 404, 409, 422, 429, 500, 503] as const;\n\n  for (const status of errorStatuses) {\n    it(`returns ${status} { ok: false, error } with code + message`, async () => {\n      const app = makeApp();\n      app.get(\"/\", (c) => err(c, status, \"SOME_CODE\", \"something went wrong\"));\n\n      const res = await app.request(\"/\");\n      expect(res.status).toBe(status);\n      const body = (await res.json()) as ApiEnvelopeError;\n      expect(body).toEqual({\n        ok: false,\n        error: { code: \"SOME_CODE\", message: \"something went wrong\" },\n      });\n    });\n  }\n\n  it(\"includes retryable when provided\", async () => {\n    const app = makeApp();\n    app.get(\"/\", (c) =>\n      err(c, 429, \"RATE_LIMITED\", \"slow down\", { retryable: true }),\n    );\n\n    const res = await app.request(\"/\");\n    expect(res.status).toBe(429);\n    const body = (await res.json()) as ApiEnvelopeError;\n    expect(body.error.retryable).toBe(true);\n    expect(body.error.code).toBe(\"RATE_LIMITED\");\n  });\n\n  it(\"includes details when provided\", async () => {\n    const app = makeApp();\n    const issues = [{ path: [\"code\"], message: \"required\" }];\n    app.get(\"/\", (c) =>\n      err(c, 422, \"VALIDATION_FAILED\", \"Invalid request\", {\n        retryable: false,\n        details: issues,\n      }),\n    );\n\n    const res = await app.request(\"/\");\n    expect(res.status).toBe(422);\n    const body = (await res.json()) as ApiEnvelopeError;\n    expect(body.error.retryable).toBe(false);\n    expect(body.error.details).toEqual(issues);\n  });\n\n  it(\"omits retryable/details when not provided\", async () => {\n    const app = makeApp();\n    app.get(\"/\", (c) => err(c, 404, \"NOT_FOUND\", \"missing\"));\n\n    const res = await app.request(\"/\");\n    const body = (await res.json()) as ApiEnvelopeError;\n    expect(body).toEqual({\n      ok: false,\n      error: { code: \"NOT_FOUND\", message: \"missing\" },\n    });\n    expect(body.error).not.toHaveProperty(\"retryable\");\n    expect(body.error).not.toHaveProperty(\"details\");\n  });\n});\n\ndescribe(\"envelope()\", () => {\n  const DataSchema = z.object({ id: z.number() });\n  const schema = envelope(DataSchema);\n\n  it(\"parses a success envelope\", () => {\n    const parsed = schema.parse({ ok: true, data: { id: 42 } });\n    expect(parsed).toEqual({ ok: true, data: { id: 42 } });\n  });\n\n  it(\"parses an error envelope\", () => {\n    const parsed = schema.parse({\n      ok: false,\n      error: { code: \"BAD\", message: \"nope\" },\n    });\n    expect(parsed).toEqual({\n      ok: false,\n      error: { code: \"BAD\", message: \"nope\" },\n    });\n  });\n\n  it(\"parses an error envelope with retryable + details\", () => {\n    const parsed = schema.parse({\n      ok: false,\n      error: {\n        code: \"RATE_LIMITED\",\n        message: \"slow down\",\n        retryable: true,\n        details: { retryAfterMs: 1000 },\n      },\n    });\n    if (parsed.ok) throw new Error(\"expected error envelope\");\n    expect(parsed.error.retryable).toBe(true);\n    expect(parsed.error.details).toEqual({ retryAfterMs: 1000 });\n  });\n\n  it(\"rejects a success envelope when data is wrong shape\", () => {\n    expect(() => schema.parse({ ok: true, data: { id: \"not-a-number\" } })).toThrow();\n  });\n\n  it(\"rejects an envelope with no ok discriminator\", () => {\n    expect(() => schema.parse({ data: { id: 1 } })).toThrow();\n  });\n\n  it(\"narrows via the `ok` discriminator\", () => {\n    const parsed = schema.parse({ ok: true, data: { id: 7 } });\n    if (parsed.ok) {\n      expect(parsed.data.id).toBe(7);\n    } else {\n      throw new Error(\"expected success envelope\");\n    }\n  });\n});\n\ndescribe(\"ApiErrorSchema + ErrorEnvelopeSchema\", () => {\n  it(\"round-trips the minimal error shape\", () => {\n    const input = { code: \"AUTH_REQUIRED\", message: \"sign in\" };\n    expect(ApiErrorSchema.parse(input)).toEqual(input);\n  });\n\n  it(\"round-trips an error with retryable + details\", () => {\n    const input = {\n      code: \"VALIDATION_FAILED\",\n      message: \"Invalid request\",\n      retryable: false,\n      details: [{ path: [\"code\"], message: \"required\" }],\n    };\n    expect(ApiErrorSchema.parse(input)).toEqual(input);\n  });\n\n  it(\"round-trips the envelope at the schema level\", () => {\n    const input: ApiEnvelopeError = {\n      ok: false,\n      error: { code: \"NOT_FOUND\", message: \"missing\" },\n    };\n    expect(ErrorEnvelopeSchema.parse(input)).toEqual(input);\n  });\n\n  it(\"rejects an error envelope with ok: true\", () => {\n    expect(() =>\n      ErrorEnvelopeSchema.parse({ ok: true, error: { code: \"X\", message: \"y\" } }),\n    ).toThrow();\n  });\n});\n","structuredPatch":[{"oldStart":63,"oldLines":14,"newStart":63,"newLines":14,"lines":["   for (const status of errorStatuses) {","     it(`returns ${status} { ok: false, error } with code + message`, async () => {","       const app = makeApp();","-      app.get(\"/\", (c) => err(c, status, \"SOME_CODE\", \"something went wrong\"));","+      app.get(\"/\", (c) => err(c, status, \"NOT_FOUND\", \"something went wrong\"));"," ","       const res = await app.request(\"/\");","       expect(res.status).toBe(status);","       const body = (await res.json()) as ApiEnvelopeError;","       expect(body).toEqual({","         ok: false,","-        error: { code: \"SOME_CODE\", message: \"something went wrong\" },","+        error: { code: \"NOT_FOUND\", message: \"something went wrong\" },","       });","     });","   }"]}],"userModified":false,"replaceAll":false}}
