D\",\n  CONFLICT: \"CONFLICT\",\n  PRECONDITION_FAILED: \"PRECONDITION_FAILED\",\n} as const;\n\nexport type ApiErrorCode = (typeof API_ERROR_CODES)[keyof typeof API_ERROR_CODES];\n\n// ---------------------------------------------------------------------------\n// Legacy helpers (to be deleted in the cleanup iteration once all public\n// routes have migrated to the envelope helpers in `api-envelope.ts`).\n// ---------------------------------------------------------------------------\n\nexport interface ErrorResponseBody {\n  error: string;\n}\n\nexport interface StructuredErrorDetail {\n  code: string;\n  message: string;\n  retryable?: boolean;\n}\n\nexport interface StructuredErrorResponseBody {\n  error: StructuredErrorDetail;\n}\n\nexport function errorMessage(error: string): ErrorResponseBody {\n  return { error };\n}\n\nexport function structuredErrorMessage(\n  code: string,\n  message: string,\n  retryable?: boolean,\n): StructuredErrorResponseBody {\n  return {\n    error: retryable === undefined ? { code, message } : { code, message, retryable },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":580,"cache_read_input_tokens":63030,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":580},"output_tokens":42,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"1457c4df-37f5-4b88-a9bb-32dd3ea06637","uuid":"651b118e-3ea5-432c-b7ab-a482de896a5e"}
