{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EqzHN318Xu6bqZ6CHAwq1H","type":"tool_result","content":"1\t/* eslint-disable @typescript-eslint/no-explicit-any */\n2\timport { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";\n3\timport { Hono } from \"hono\";\n4\timport { Keypair } from \"@solana/web3.js\";\n5\timport type { Db } from \"../db.js\";\n6\timport { createPointsRoutes, createCrateRoutes } from \"../routes/points.js\";\n7\timport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n8\timport {\n9\t  closeIntegrationDb,\n10\t  type IntegrationDbContext,\n11\t  JWT_SECRET,\n12\t  makeJwt,\n13\t  openIntegrationDb,\n14\t  resetIntegrationState,\n15\t  type TestSql,\n16\t  userIdFromWallet,\n17\t} from \"./integration-test-helpers.js\";\n18\t\n19\tdescribe(\"Points and crates routes\", () => {\n20\t  let ctx: IntegrationDbContext;\n21\t  let rawSql: TestSql;\n22\t  let db: Db;\n23\t\n24\t  beforeAll(async () => {\n25\t    ctx = await openIntegrationDb();\n26\t    rawSql = ctx.rawSql;\n27\t    db = ctx.db;\n28\t  });\n29\t\n30\t  afterAll(async () => {\n31\t    await closeIntegrationDb(ctx);\n32\t  });\n33\t\n34\t  describe(\"GET /points/mine, /points/mine/history, and /crates/mine\", () => {\n35\t    let pointsApp: Hono;\n36\t    let cratesApp: Hono;\n37\t\n38\t    const testWallet = Keypair.generate().publicKey.toBase58();\n39\t    const testUserId = userIdFromWallet(testWallet);\n40\t\n41\t    beforeEach(async () => {\n42\t      await resetIntegrationState(rawSql);\n43\t\n44\t      pointsApp = new Hono();\n45\t      pointsApp.use(\n46\t        \"/points/*\",\n47\t        createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n48\t      );\n49\t      pointsApp.route(\"/points\", createPointsRoutes({ db }));\n50\t\n51\t      cratesApp = new Hono();\n52\t      cratesApp.use(\n53\t        \"/crates/*\",\n54\t        createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n55\t      );\n56\t      cratesApp.route(\"/crates\", createCrateRoutes({ db }));\n57\t    });\n58\t\n59\t    it(\"GET /points/mine returns zeros when no ledger row exists\", async () => {\n60\t      const token = await makeJwt(testWallet, testUserId);\n61\t      const res = await pointsApp.request(\"/points/mine\", {\n62\t        method: \"GET\",\n63\t        headers: { Authorization: `Bearer ${token}` },\n64\t      });\n65\t      expect(res.status).toBe(200);\n66\t      const body = (await res.json()) as Record<string, any>;\n67\t      expect(body.balance).toBe(0);\n68\t      expect(body.lifetimeEarned).toBe(0);\n69\t    });\n70\t\n71\t    it(\"GET /points/mine returns the stored balance and lifetime earned\", async () => {\n72\t      await rawSql`\n73\t        INSERT INTO player_points (user_id, wallet, balance, lifetime_earned)\n74\t        VALUES (${testUserId}, ${testWallet}, 5000, 12000)\n75\t      `;\n76\t\n77\t      const token = await makeJwt(testWallet, testUserId);\n78\t      const res = await pointsApp.request(\"/points/mine\", {\n79\t        method: \"GET\",\n80\t        headers: { Authorization: `Bearer ${token}` },\n81\t      });\n82\t      expect(res.status).toBe(200);\n83\t      const body = (await res.json()) as Record<string, any>;\n84\t      expect(body.balance).toBe(5000);\n85\t      expect(body.lifetimeEarned).toBe(12000);\n86\t    });\n87\t\n88\t    it(\"GET /points/mine/history paginates point grants by cursor\", async () => {\n89\t      for (let i = 1; i <= 3; i++) {\n90\t        await rawSql`\n91\t          INSERT INTO point_grants (\n92\t            user_id,\n93\t            wallet,\n94\t            source_type,\n95\t            source_id,\n96\t            amount,\n97\t            metadata\n98\t          )\n99\t          VALUES (\n100\t            ${testUserId},\n101\t            ${testWallet},\n102\t            'wager',\n103\t            ${`round_${i}`},\n104\t            ${1000 * i},\n105\t            ${JSON.stringify({ solPrice: 100 })}\n106\t          )\n107\t        `;\n108\t      }\n109\t\n110\t      const token = await makeJwt(testWallet, testUserId);\n111\t\n112\t      const res1 = await pointsApp.request(\"/points/mine/history?limit=2\", {\n113\t        method: \"GET\",\n114\t        headers: { Authorization: `Bearer ${token}` },\n115\t      });\n116\t      expect(res1.status).toBe(200);\n117\t      const body1 = (await res1.json()) as Record<string, any>;\n118\t      expect(body1.items).toHaveLength(2);\n119\t      expect(body1.items[0].sourceType).toBe(\"wager\");\n120\t      expect(body1.items[0].amount).toBe(3000);\n121\t      expect(body1.items[1].amount).toBe(2000);\n122\t      expect(body1.nextCursor).not.toBeNull();\n123\t      expect(body1.items[0]).toHaveProperty(\"id\");\n124\t      expect(body1.items[0]).toHaveProperty(\"sourceId\");\n125\t      expect(body1.items[0]).toHaveProperty(\"metadata\");\n126\t      expect(body1.items[0]).toHaveProperty(\"createdAt\");\n127\t\n128\t      const res2 = await pointsApp.request(\n129\t        `/points/mine/history?limit=2&cursor=${body1.nextCursor}`,\n130\t        {\n131\t          method: \"GET\",\n132\t          headers: { Authorization: `Bearer ${token}` },\n133\t        },\n134\t      );\n135\t      expect(res2.status).toBe(200);\n136\t      const body2 = (await res2.json()) as Record<string, any>;\n137\t      expect(body2.items).toHaveLength(1);\n138\t      expect(body2.items[0].amount).toBe(1000);\n139\t      expect(body2.nextCursor).toBeNull();\n140\t    });\n141\t\n142\t    it(\"GET /points/mine/history returns an empty page when no grants exist\", async () => {\n143\t      const token = await makeJwt(testWallet, testUserId);\n144\t      const res = await pointsApp.request(\"/points/mine/history\", {\n145\t        method: \"GET\",\n146\t        headers: { Authorization: `Bearer ${token}` },\n147\t      });\n148\t      expect(res.status).toBe(200);\n149\t      const body = (await res.json()) as Record<string, any>;\n1