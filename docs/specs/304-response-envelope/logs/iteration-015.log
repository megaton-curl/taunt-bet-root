{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011RmQHXUofKLfqM9iX75hfG","type":"tool_result","content":"80\t}\n81\t\n82\tinterface BonusCompletionRow {\n83\t  id: string;\n84\t}\n85\t\n86\t// ---------------------------------------------------------------------------\n87\t// Period key helpers\n88\t// ---------------------------------------------------------------------------\n89\t\n90\t/** Returns \"daily:YYYY-MM-DD\" for the current UTC date. */\n91\texport function dailyPeriodKey(now?: Date): string {\n92\t  const d = now ?? new Date();\n93\t  return `daily:${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, \"0\")}-${String(d.getUTCDate()).padStart(2, \"0\")}`;\n94\t}\n95\t\n96\t/** Returns \"weekly:YYYY-Www\" for the current ISO week. */\n97\texport function weeklyPeriodKey(now?: Date): string {\n98\t  const d = now ?? new Date();\n99\t  // ISO week calculation\n100\t  const tmp = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()));\n101\t  tmp.setUTCDate(tmp.getUTCDate() + 4 - (tmp.getUTCDay() || 7));\n102\t  const yearStart = new Date(Date.UTC(tmp.getUTCFullYear(), 0, 1));\n103\t  const weekNo = Math.ceil(((tmp.getTime() - yearStart.getTime()) / 86400000 + 1) / 7);\n104\t  return `weekly:${tmp.getUTCFullYear()}-W${String(weekNo).padStart(2, \"0\")}`;\n105\t}\n106\t\n107\t/** Returns midnight UTC of the next day (daily reset). */\n108\texport function dailyResetsAt(now?: Date): string {\n109\t  const d = now ?? new Date();\n110\t  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + 1));\n111\t  return next.toISOString();\n112\t}\n113\t\n114\t/** Returns midnight UTC of next Monday (weekly reset). */\n115\texport function weeklyResetsAt(now?: Date): string {\n116\t  const d = now ?? new Date();\n117\t  const dayOfWeek = d.getUTCDay(); // 0=Sun, 1=Mon, ...\n118\t  const daysUntilMonday = dayOfWeek === 0 ? 1 : 8 - dayOfWeek;\n119\t  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + daysUntilMonday));\n120\t  return next.toISOString();\n121\t}\n122\t\n123\t// ---------------------------------------------------------------------------\n124\t// DB helpers\n125\t// ---------------------------------------------------------------------------\n126\t\n127\t/** Expire stale assignments (expires_at < now AND status='active'). */\n128\tasync function expireStaleAssignments(db: Db, userId: string): Promise<void> {\n129\t  await db.rawSql`\n130\t    UPDATE challenge_assignments\n131\t    SET status = 'expired'\n132\t    WHERE user_id = ${userId}\n133\t      AND status = 'active'\n134\t      AND expires_at IS NOT NULL\n135\t      AND expires_at < now()\n136\t  `;\n137\t}\n138\t\n139\t/** Get assignments for a user in a given period, joined with challenge metadata. */\n140\tasync function getAssignmentsForPeriod(\n141\t  db: Db,\n142\t  userId: string,\n143\t  periodKey: string,\n144\t): Promise<AssignmentRow[]> {\n145\t  return db.rawSql<AssignmentRow[]>`\n146\t    SELECT\n147\t      ca.id,\n148\t      ca.challenge_id,\n149\t      ca.period_key,\n150\t      ca.status,\n151\t      ca.progress,\n152\t      ca.target,\n153\t      ca.expires_at,\n154\t      ca.completed_at,\n155\t      c.title,\n156\t      c.description,\n157\t      c.reward_type,\n158\t      c.reward_amount,\n159\t      camp.campaign_type\n160\t    FROM challenge_assignments ca\n161\t    JOIN challenges c ON c.id = ca.challenge_id\n162\t    JOIN campaigns camp ON camp.id = c.campaign_id\n163\t    WHERE ca.user_id = ${userId}\n164\t      AND ca.period_key = ${periodKey}\n165\t    ORDER BY c.sort_order ASC\n166\t  `;\n167\t}\n168\t\n169\t/** Get top N active challenges for a campaign, ordered by sort_order ASC. */\n170\tasync function getActiveChallengesBySort(\n171\t  db: Db,\n172\t  campaignId: string,\n173\t  limit: number,\n174\t): Promise<ChallengeRow[]> {\n175\t  return db.rawSql<ChallengeRow[]>`\n176\t    SELECT id, campaign_id, title, description, action, scope, condition,\n177\t           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n178\t    FROM challenges\n179\t    WHERE campaign_id = ${campaignId}\n180\t      AND is_active = true\n181\t    ORDER BY sort_order ASC\n182\t    LIMIT ${limit}\n183\t  `;\n184\t}\n185\t\n186\t/** Get the campaign ID for a given campaign type. */\n187\tasync function getCampaignByType(\n188\t  db: Db,\n189\t  campaignType: string,\n190\t): Promise<{ id: string } | null> {\n191\t  const rows = await db.rawSql<{ id: string }[]>`\n192\t    SELECT id FROM campaigns\n193\t    WHERE campaign_type = ${campaignType}\n194\t      AND is_active = true\n195\t    ORDER BY id ASC\n196\t    LIMIT 1\n197\t  `;\n198\t  return rows[0] ?? null;\n199\t}\n200\t\n201\t/** Get all onboarding assignments for a user (any status). */\n202\tasync function getOnboardingAssignments(\n203\t  db: Db,\n204\t  userId: string,\n205\t): Promise<AssignmentRow[]> {\n206\t  return db.rawSql<AssignmentRow[]>`\n207\t    SELECT\n208\t      ca.id,\n209\t      ca.challenge_id,\n210\t      ca.period_key,\n211\t      ca.status,\n212\t      ca.progress,\n213\t      ca.target,\n214\t      ca.expires_at,\n215\t      ca.completed_at,\n216\t      c.title,\n217\t      c.description,\n218\t      c.reward_type,\n219\t      c.reward_amount,\n220\t      camp.campaign_type\n221\t    FROM challenge_assignments ca\n222\t    JOIN challenges c ON c.id = ca.challenge_id\n223\t    JOIN campaigns camp ON camp.id = c.campaign_id\n224\t    WHERE ca.user_id = ${userId}\n225\t      AND ca.period_key = 'onboarding'\n226\t    ORDER BY c.sort_order ASC\n227\t  `;\n228\t}\n229\t\n230\t/** Get all onboarding challenge templates (ordered by chain). */\n231\tasync function getOnboardingChallenges(\n232\t  db: Db,\n233\t  campaignId: string,\n234\t): Promise<ChallengeRow[]> {\n235\t  return db.rawSql<ChallengeRow[]>`\n236\t    SELECT id, campaign_id, title, description, action, scope, condition,\n237\t           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n238\t    FROM challenges\n239\t    WHERE campaign_id = ${campaignId}\n240\t      AND is_active = true\n241\t    ORDER BY sort_order ASC\n242\t  `;\n243\t}\n244\t\n245\t/** Get completion bonuses for a campaign. */\n246\tasync function getCompletionBonusesForCampaign(\n247\t  db: Db,\n248\t  campaignId: string,\n249\t): Promise<CompletionBonusRow[]> {\n250\t  return db.rawSql<CompletionBonusRow[]>`\n251\t    SELECT id, title, required_count, reward_type, reward_amount\n252\t    FROM completion_bonuses\n253\t    WHERE campaign_id = ${campaignId}\n254\t      AND is_active = true\n255\t  `;\n256\t}\n257\t\n258\t/** Check if a bonus was completed for a user in a given period. */\n259\tasync function getBonusCompletion(\n260\t  db: Db,\n261\t  userId: string,\n262\t  bonusId: string,\n263\t  periodKey: string,\n264\t): Promise<BonusCompletionRow | null> {\n265\t  const rows = await db.rawSql<BonusCompletionRow[]>`\n266\t    SELECT id FROM bonus_completions\n267\t    WHERE user_id = ${userId}\n268\t      AND bonus_id = ${bonusId}\n269\t      AND period_key = ${periodKey}\n270\t    LIMIT 1\n271\t  `;\n272\t  return rows[0] ?? null;\n273\t}\n274\t\n275\t/** Count completed assignments for a user in a period+campaign. */\n276\tasync function countCompleted(\n277\t  db: Db,\n278\t  userId: string,\n279\t  periodKey: string,"}]},"parent_tool_use_id":null,"session_id":"2a3b3c5f-a987-45a0-b28a-600ca937b6d5","uuid":"6c1797b2-20ea-4b5f-87a3-b24034d15de4","timestamp":"2026-04-22T10:32:38.493Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/challenges.ts","content":"}\n\ninterface BonusCompletionRow {\n  id: string;\n}\n\n// ---------------------------------------------------------------------------\n// Period key helpers\n// ---------------------------------------------------------------------------\n\n/** Returns \"daily:YYYY-MM-DD\" for the current UTC date. */\nexport function dailyPeriodKey(now?: Date): string {\n  const d = now ?? new Date();\n  return `daily:${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, \"0\")}-${String(d.getUTCDate()).padStart(2, \"0\")}`;\n}\n\n/** Returns \"weekly:YYYY-Www\" for the current ISO week. */\nexport function weeklyPeriodKey(now?: Date): string {\n  const d = now ?? new Date();\n  // ISO week calculation\n  const tmp = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate()));\n  tmp.setUTCDate(tmp.getUTCDate() + 4 - (tmp.getUTCDay() || 7));\n  const yearStart = new Date(Date.UTC(tmp.getUTCFullYear(), 0, 1));\n  const weekNo = Math.ceil(((tmp.getTime() - yearStart.getTime()) / 86400000 + 1) / 7);\n  return `weekly:${tmp.getUTCFullYear()}-W${String(weekNo).padStart(2, \"0\")}`;\n}\n\n/** Returns midnight UTC of the next day (daily reset). */\nexport function dailyResetsAt(now?: Date): string {\n  const d = now ?? new Date();\n  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + 1));\n  return next.toISOString();\n}\n\n/** Returns midnight UTC of next Monday (weekly reset). */\nexport function weeklyResetsAt(now?: Date): string {\n  const d = now ?? new Date();\n  const dayOfWeek = d.getUTCDay(); // 0=Sun, 1=Mon, ...\n  const daysUntilMonday = dayOfWeek === 0 ? 1 : 8 - dayOfWeek;\n  const next = new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate() + daysUntilMonday));\n  return next.toISOString();\n}\n\n// ---------------------------------------------------------------------------\n// DB helpers\n// ---------------------------------------------------------------------------\n\n/** Expire stale assignments (expires_at < now AND status='active'). */\nasync function expireStaleAssignments(db: Db, userId: string): Promise<void> {\n  await db.rawSql`\n    UPDATE challenge_assignments\n    SET status = 'expired'\n    WHERE user_id = ${userId}\n      AND status = 'active'\n      AND expires_at IS NOT NULL\n      AND expires_at < now()\n  `;\n}\n\n/** Get assignments for a user in a given period, joined with challenge metadata. */\nasync function getAssignmentsForPeriod(\n  db: Db,\n  userId: string,\n  periodKey: string,\n): Promise<AssignmentRow[]> {\n  return db.rawSql<AssignmentRow[]>`\n    SELECT\n      ca.id,\n      ca.challenge_id,\n      ca.period_key,\n      ca.status,\n      ca.progress,\n      ca.target,\n      ca.expires_at,\n      ca.completed_at,\n      c.title,\n      c.description,\n      c.reward_type,\n      c.reward_amount,\n      camp.campaign_type\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    JOIN campaigns camp ON camp.id = c.campaign_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = ${periodKey}\n    ORDER BY c.sort_order ASC\n  `;\n}\n\n/** Get top N active challenges for a campaign, ordered by sort_order ASC. */\nasync function getActiveChallengesBySort(\n  db: Db,\n  campaignId: string,\n  limit: number,\n): Promise<ChallengeRow[]> {\n  return db.rawSql<ChallengeRow[]>`\n    SELECT id, campaign_id, title, description, action, scope, condition,\n           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n    FROM challenges\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n    ORDER BY sort_order ASC\n    LIMIT ${limit}\n  `;\n}\n\n/** Get the campaign ID for a given campaign type. */\nasync function getCampaignByType(\n  db: Db,\n  campaignType: string,\n): Promise<{ id: string } | null> {\n  const rows = await db.rawSql<{ id: string }[]>`\n    SELECT id FROM campaigns\n    WHERE campaign_type = ${campaignType}\n      AND is_active = true\n    ORDER BY id ASC\n    LIMIT 1\n  `;\n  return rows[0] ?? null;\n}\n\n/** Get all onboarding assignments for a user (any status). */\nasync function getOnboardingAssignments(\n  db: Db,\n  userId: string,\n): Promise<AssignmentRow[]> {\n  return db.rawSql<AssignmentRow[]>`\n    SELECT\n      ca.id,\n      ca.challenge_id,\n      ca.period_key,\n      ca.status,\n      ca.progress,\n      ca.target,\n      ca.expires_at,\n      ca.completed_at,\n      c.title,\n      c.description,\n      c.reward_type,\n      c.reward_amount,\n      camp.campaign_type\n    FROM challenge_assignments ca\n    JOIN challenges c ON c.id = ca.challenge_id\n    JOIN campaigns camp ON camp.id = c.campaign_id\n    WHERE ca.user_id = ${userId}\n      AND ca.period_key = 'onboarding'\n    ORDER BY c.sort_order ASC\n  `;\n}\n\n/** Get all onboarding challenge templates (ordered by chain). */\nasync function getOnboardingChallenges(\n  db: Db,\n  campaignId: string,\n): Promise<ChallengeRow[]> {\n  return db.rawSql<ChallengeRow[]>`\n    SELECT id, campaign_id, title, description, action, scope, condition,\n           threshold, reward_type, reward_amount, sort_order, prerequisite_id\n    FROM challenges\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n    ORDER BY sort_order ASC\n  `;\n}\n\n/** Get completion bonuses for a campaign. */\nasync function getCompletionBonusesForCampaign(\n  db: Db,\n  campaignId: string,\n): Promise<CompletionBonusRow[]> {\n  return db.rawSql<CompletionBonusRow[]>`\n    SELECT id, title, required_count, reward_type, reward_amount\n    FROM completion_bonuses\n    WHERE campaign_id = ${campaignId}\n      AND is_active = true\n  `;\n}\n\n/** Check if a bonus was completed for a user in a given period. */\nasync function getBonusCompletion(\n  db: Db,\n  userId: string,\n  bonusId: string,\n  periodKey: string,\n): Promise<BonusCompletionRow | null> {\n  const rows = await db.rawSql<BonusCompletionRow[]>`\n    SELECT id FROM bonus_completions\n    WHERE user_id = ${userId}\n      AND bonus_id = ${bonusId}\n      AND period_key = ${periodKey}\n    LIMIT 1\n  `;\n  return rows[0] ?? null;\n}\n\n/** Count completed assignments for a user in a period+campaign. */\nasync function countCompleted(\n  db: Db,\n  userId: string,\n  periodKey: string,","numLines":200,"startLine":80,"totalLines"