{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013Dy4yc5pxvKajfYexUFJPd","type":"tool_result","content":"1\t/**\n2\t * Points & Crate routes — player-facing endpoints for points balance,\n3\t * points history, and crate drop history.\n4\t *\n5\t * GET /mine           — current point balance + lifetime earned\n6\t * GET /mine/history   — paginated point_grants ledger\n7\t * GET /crates/mine    — paginated crate_drops history\n8\t */\n9\t\n10\timport { createRoute } from \"@hono/zod-openapi\";\n11\timport { z } from \"zod\";\n12\timport type { AppEnv } from \"../hono-env.js\";\n13\timport type { Db } from \"../db.js\";\n14\timport { logger } from \"../logger.js\";\n15\timport {\n16\t  PointGrantEntrySchema,\n17\t  CrateDropEntrySchema,\n18\t  ErrorResponseSchema,\n19\t} from \"../contracts/validators.js\";\n20\timport { createOpenApiApp } from \"../openapi/hono.js\";\n21\t\n22\t// ---------------------------------------------------------------------------\n23\t// Types\n24\t// ---------------------------------------------------------------------------\n25\t\n26\texport interface PointsRoutesDeps {\n27\t  db: Db;\n28\t}\n29\t\n30\t// ---------------------------------------------------------------------------\n31\t// Response schemas\n32\t// ---------------------------------------------------------------------------\n33\t\n34\tconst PointBalanceResponseSchema = z.object({\n35\t  balance: z.number(),\n36\t  lifetimeEarned: z.number(),\n37\t});\n38\t\n39\tconst PointHistoryResponseSchema = z.object({\n40\t  items: z.array(PointGrantEntrySchema),\n41\t  nextCursor: z.string().nullable(),\n42\t});\n43\t\n44\tconst CrateHistoryResponseSchema = z.object({\n45\t  items: z.array(CrateDropEntrySchema),\n46\t  nextCursor: z.string().nullable(),\n47\t});\n48\t\n49\t// ---------------------------------------------------------------------------\n50\t// Route definitions — Points\n51\t// ---------------------------------------------------------------------------\n52\t\n53\tconst pointsMineRoute = createRoute({\n54\t  method: \"get\",\n55\t  path: \"/mine\",\n56\t  tags: [\"Points\"],\n57\t  summary: \"Get point balance for the authenticated player\",\n58\t  security: [{ bearerAuth: [] }],\n59\t  responses: {\n60\t    200: {\n61\t      content: { \"application/json\": { schema: PointBalanceResponseSchema } },\n62\t      description: \"Point balance\",\n63\t    },\n64\t    401: {\n65\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n66\t      description: \"Authentication required\",\n67\t    },\n68\t    500: {\n69\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n70\t      description: \"Server error\",\n71\t    },\n72\t  },\n73\t});\n74\t\n75\tconst pointsHistoryRoute = createRoute({\n76\t  method: \"get\",\n77\t  path: \"/mine/history\",\n78\t  tags: [\"Points\"],\n79\t  summary: \"Paginated point grant history\",\n80\t  security: [{ bearerAuth: [] }],\n81\t  request: {\n82\t    query: z.object({\n83\t      cursor: z.string().optional(),\n84\t      limit: z.coerce.number().int().min(1).max(50).optional(),\n85\t    }),\n86\t  },\n87\t  responses: {\n88\t    200: {\n89\t      content: { \"application/json\": { schema: PointHistoryResponseSchema } },\n90\t      description: \"Point grant entries\",\n91\t    },\n92\t    401: {\n93\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n94\t      description: \"Authentication required\",\n95\t    },\n96\t    500: {\n97\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n98\t      description: \"Server error\",\n99\t    },\n100\t  },\n101\t});\n102\t\n103\t// ---------------------------------------------------------------------------\n104\t// Route definitions — Crates\n105\t// ---------------------------------------------------------------------------\n106\t\n107\tconst cratesMineRoute = createRoute({\n108\t  method: \"get\",\n109\t  path: \"/mine\",\n110\t  tags: [\"Points\"],\n111\t  summary: \"Paginated crate drop history\",\n112\t  security: [{ bearerAuth: [] }],\n113\t  request: {\n114\t    query: z.object({\n115\t      cursor: z.string().optional(),\n116\t      limit: z.coerce.number().int().min(1).max(50).optional(),\n117\t    }),\n118\t  },\n119\t  responses: {\n120\t    200: {\n121\t      content: { \"application/json\": { schema: CrateHistoryResponseSchema } },\n122\t      description: \"Crate drop entries\",\n123\t    },\n124\t    401: {\n125\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n126\t      description: \"Authentication required\",\n127\t    },\n128\t    500: {\n129\t      content: { \"application/json\": { schema: ErrorResponseSchema } },\n130\t      description: \"Server error\",\n131\t    },\n132\t  },\n133\t});\n134\t\n135\t// ---------------------------------------------------------------------------\n136\t// Route factory — Points\n137\t// ---------------------------------------------------------------------------\n138\t\n139\texport function createPointsRoutes(deps: PointsRoutesDeps) {\n140\t  const { db } = deps;\n141\t  const app = createOpenApiApp<AppEnv>();\n142\t\n143\t  // GET /mine — point balance\n144\t  app.openapi(pointsMineRoute, async (c) => {\n145\t    const userId = c.get(\"userId\");\n146\t    if (!userId) {\n147\t      return c.json({ error: \"Authentication required\" }, 401);\n148\t    }\n149\t\n150\t    try {\n151\t      const rows = await db.rawSql<{ balance: string; lifetime_earned: string }[]>`\n152\t        SELECT balance, lifetime_earned FROM player_points WHERE user_id = ${userId}\n153\t      `;\n154\t      if (rows.length === 0) {\n155\t        return c.json({ balance: 0, lifetimeEarned: 0 }, 200);\n156\t      }\n157\t      return c.json({\n158\t        balance: Number(rows[0]!.balance),\n159\t        lifetimeEarned: Number(rows[0]!.lifetime_earned),\n160\t      }, 200);\n161\t    } catch (err) {\n162\t      logger.error(\"GET /points/mine failed\", {\n163\t        userId,\n164\t        error: err instanceof Error ? err.message : \"Unknown error\",\n165\t      });\n166\t      return c.json({ error: \"Failed to fetch points\" }, 500);\n167\t    }\n168\t  });\n169\t\n170\t  // GET /mine/history — paginated point_grants\n171\t  app.openapi(pointsHistoryRoute, async (c) => {\n172\t    const userId = c.get(\"userId\");\n173\t    if (!userId) {\n174\t      return c.json({ error: \"Authentication required\" }, 401);\n175\t    }\n176\t\n177\t    const { cursor, limit: rawLimit } = c.req.valid(\"query\");\n178\t    const limit = rawLimit ?? 20;\n179\t\n180\t    try {\n181\t      const cursorFilter = cursor\n182\t        ? db.rawSql`AND id < ${cursor}`\n183\t        : db.rawSql``;\n184\t\n185\t      const rows = await db.rawSql<\n186\t        {\n187\t          id: string;\n188\t          source_type: string;\n189\t          source_id: string;\n190\t          amount: string;\n191\t          metadata: Record<string, unknown>;\n192\t          created_at: Date;\n193\t        }[]\n194\t      >`\n195\t        SELECT id, source_type, source_id, amount, metadata, created_at\n196\t        FROM point_grants\n197\t        WHERE user_id = ${userId} ${cursorFilter}\n198\t        ORDER BY id DESC\n199\t        LIMIT ${limit}\n200\t      `;\n201\t\n202\t      const items = rows.map((r: { id: string; source_type: string; source_id: string; amount: string; metadata: Record<string, unknown>; created_at: Date }) => ({\n203\t        id: Number(r.id),\n204\t        sourceType: r.source_type,\n205\t        sourceId: r.source_id,\n206\t        amount: Number(r.amount),\n207\t        metadata: r.metadata,\n208\t        createdAt: r.created_at.toISOString(),\n209\t      }));\n210\t\n211\t      const nextCursor =\n212\t        items.length === limit ? String(items[items.length - 1]!.id) : null;\n213\t\n214\t      return c.json({ items, nextCursor }, 200);\n215\t    } catch (err) {\n216\t      logger.error(\"GET /points/mine/history failed\", {\n217\t        userId,\n218\t        error: err instanceof Error ? err.message : \"Unknown error\",\n219\t      });\n220\t      return c.json({ error: \"Failed to fetch points history\" }, 500);\n221\t    }\n222\t  });\n223\t\n224\t  return app;\n225\t}\n226\t\n227\t// ---------------------------------------------------------------------------\n228\t// Route factory — Crates\n229\t// ---------------------------------------------------------------------------\n230\t\n231\texport function createCrateRoutes(deps: PointsRoutesDeps) {\n232\t  const { db } = deps;\n233\t  const app = createOpenApiApp<AppEnv>();\n234\t\n235\t  // GET /mine — paginated crate_drops\n236\t  app.openapi(cratesMineRoute, async (c) => {\n237\t    const userId = c.get(\"userId\");\n238\t    if (!userId) {\n239\t      return c.json({ error: \"Authentication required\" }, 401);\n240\t    }\n241\t\n242\t    const { cursor, limit: rawLimit } = c.req.valid(\"query\");\n243\t    const limit = rawLimit ?? 20;\n244\t\n245\t    try {\n246\t      const cursorFilter = cursor\n247\t        ? db.rawSql`AND id < ${cursor}`\n248\t        : db.rawSql``;\n249\t\n250\t      const rows = await db.rawSql<\n251\t        {\n252\t          id: string;\n253\t          crate_type: string;\n254\t          contents_amount: string;\n255\t          status: string;\n256\t          created_at: Date;\n257\t          granted_at: Date | null;\n258\t        }[]\n259\t      >`\n260\t        SELECT id, crate_type, contents_amount, status, created_at, granted_at\n261\t        FROM crate_drops\n262\t        WHERE user_id = ${userId} ${cursorFilter}\n263\t        ORDER BY id DESC\n264\t        LIMIT ${limit}\n265\t      `;\n266\t\n267\t      const items = rows.map((r: { id: string; crate_type: string; contents_amount: string; status: string; created_at: Date; granted_at: Date | null }) => ({\n268\t        id: Number(r.id),\n269\t        crateType: r.crate_type,\n270\t        contentsAmount: r.contents_amount,\n271\t        status: r.status,\n272\t        createdAt: r.created_at.toISOString(),\n273\t        grantedAt: r.granted_at ? r.granted_at.toISOString() : null,\n274\t      }));\n275\t\n276\t      const nextCursor =\n277\t        items.length === limit ? String(items[items.length - 1]!.id) : null;\n278\t\n279\t      return c.json({ items, nextCursor }, 200);\n280\t    } catch (err) {\n281\t      logger.error(\"GET /crates/mine failed\", {\n282\t        userId,\n283\t        error: err instanceof Error ? err.message : \"Unknown error\",\n284\t      });\n285\t      return c.json({ error: \"Failed to fetch crate history\" }, 500);\n286\t    }\n287\t  });\n288\t\n289\t  return app;\n290\t}\n291\t"}]},"parent_tool_use_id":null,"session_id":"2a3b3c5f-a987-45a0-b28a-600ca937b6d5","uuid":"b245c345-a225-4892-9a24-a8b8de3b038f","timestamp":"2026-04-22T10:32:13.151Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/points.ts","content":"/**\n * Points & Crate routes — player-facing endpoints for points balance,\n * points history, and crate drop history.\n *\n * GET /mine           — current point balance + lifetime earned\n * GET /mine/history   — paginated point_grants ledger\n * GET /crates/mine    — paginated crate_drops history\n */\n\nimport { createRoute } from \"@hono/zod-openapi\";\nimport { z } from \"zod\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport {\n  PointGrantEntrySchema,\n  CrateDropEntrySchema,\n  ErrorResponseSchema,\n} from \"../contracts/validators.js\";\nimport { createOpenApiApp } from \"../openapi/hono.js\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface PointsRoutesDeps {\n  db: Db;\n}\n\n// ---------------------------------------------------------------------------\n// Response schemas\n// ---------------------------------------------------------------------------\n\nconst PointBalanceResponseSchema = z.object({\n  balance: z.number(),\n  lifetimeEarned: z.number(),\n});\n\nconst PointHistoryResponseSchema = z.object({\n  items: z.array(PointGrantEntrySchema),\n  nextCursor: z.string().nullable(),\n});\n\nconst CrateHistoryResponseSchema = z.object({\n  items: z.array(CrateDropEntrySchema),\n  nextCursor: z.string().nullable(),\n});\n\n// ---------------------------------------------------------------------------\n// Route definitions — Points\n// ---------------------------------------------------------------------------\n\nconst pointsMineRoute = createRoute({\n  method: \"get\",\n  path: \"/mine\",\n  tags: [\"Points\"],\n  summary: \"Get point balance for the authenticated player\",\n  security: [{ bearerAuth: [] }],\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: PointBalanceResponseSchema } },\n      description: \"Point balance\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\nconst pointsHistoryRoute = createRoute({\n  method: \"get\",\n  path: \"/mine/history\",\n  tags: [\"Points\"],\n  summary: \"Paginated point grant history\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    query: z.object({\n      cursor: z.string().optional(),\n      limit: z.coerce.number().int().min(1).max(50).optional(),\n    }),\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: PointHistoryResponseSchema } },\n      description: \"Point grant entries\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\n// ---------------------------------------------------------------------------\n// Route definitions — Crates\n// ---------------------------------------------------------------------------\n\nconst cratesMineRoute = createRoute({\n  method: \"get\",\n  path: \"/mine\",\n  tags: [\"Points\"],\n  summary: \"Paginated crate drop history\",\n  security: [{ bearerAuth: [] }],\n  request: {\n    query: z.object({\n      cursor: z.string().optional(),\n      limit: z.coerce.number().int().min(1).max(50).optional(),\n    }),\n  },\n  responses: {\n    200: {\n      content: { \"application/json\": { schema: CrateHistoryResponseSchema } },\n      description: \"Crate drop entries\",\n    },\n    401: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Authentication required\",\n    },\n    500: {\n      content: { \"application/json\": { schema: ErrorResponseSchema } },\n      description: \"Server error\",\n    },\n  },\n});\n\n// ---------------------------------------------------------------------------\n// Route factory — Points\n// ---------------------------------------------------------------------------\n\nexport function createPointsRoutes(deps: PointsRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // GET /mine — point balance\n  app.openapi(pointsMineRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    try {\n      const rows = await db.rawSql<{ balance: string; lifetime_earned: string }[]>`\n        SELECT balance, lifetime_earned FROM player_points WHERE user_id = ${userId}\n      `;\n      if (rows.length === 0) {\n        return c.json({ balance: 0, lifetimeEarned: 0 }, 200);\n      }\n      return c.json({\n        balance: Number(rows[0]!.balance),\n        lifetimeEarned: Number(rows[0]!.lifetime_earned),\n      }, 200);\n    } catch (err) {\n      logger.error(\"GET /points/mine failed\", {\n        userId,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch points\" }, 500);\n    }\n  });\n\n  // GET /mine/history — paginated point_grants\n  app.openapi(pointsHistoryRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    const { cursor, limit: rawLimit } = c.req.valid(\"query\");\n    const limit = rawLimit ?? 20;\n\n    try {\n      const cursorFilter = cursor\n        ? db.rawSql`AND id < ${cursor}`\n        : db.rawSql``;\n\n      const rows = await db.rawSql<\n        {\n          id: string;\n          source_type: string;\n          source_id: string;\n          amount: string;\n          metadata: Record<string, unknown>;\n          created_at: Date;\n        }[]\n      >`\n        SELECT id, source_type, source_id, amount, metadata, created_at\n        FROM point_grants\n        WHERE user_id = ${userId} ${cursorFilter}\n        ORDER BY id DESC\n        LIMIT ${limit}\n      `;\n\n      const items = rows.map((r: { id: string; source_type: string; source_id: string; amount: string; metadata: Record<string, unknown>; created_at: Date }) => ({\n        id: Number(r.id),\n        sourceType: r.source_type,\n        sourceId: r.source_id,\n        amount: Number(r.amount),\n        metadata: r.metadata,\n        createdAt: r.created_at.toISOString(),\n      }));\n\n      const nextCursor =\n        items.length === limit ? String(items[items.length - 1]!.id) : null;\n\n      return c.json({ items, nextCursor }, 200);\n    } catch (err) {\n      logger.error(\"GET /points/mine/history failed\", {\n        userId,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch points history\" }, 500);\n    }\n  });\n\n  return app;\n}\n\n// ---------------------------------------------------------------------------\n// Route factory — Crates\n// ---------------------------------------------------------------------------\n\nexport function createCrateRoutes(deps: PointsRoutesDeps) {\n  const { db } = deps;\n  const app = createOpenApiApp<AppEnv>();\n\n  // GET /mine — paginated crate_drops\n  app.openapi(cratesMineRoute, async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    const { cursor, limit: rawLimit } = c.req.valid(\"query\");\n    const limit = rawLimit ?? 20;\n\n    try {\n      const cursorFilter = cursor\n        ? db.rawSql`AND id < ${cursor}`\n        : db.rawSql``;\n\n      const rows = await db.rawSql<\n        {\n          id: string;\n          crate_type: string;\n          contents_amount: string;\n          status: string;\n          created_at: Date;\n          granted_at: Date | null;\n        }[]\n      >`\n        SELECT id, crate_type, contents_amount, status, created_at, granted_at\n        FROM crate_drops\n        WHERE user_id = ${userId} ${cursorFilter}\n        ORDER BY id DESC\n        LIMIT ${limit}\n      `;\n\n      const items = rows.map((r: { id: string; crate_type: string; contents_amount: string; status: string; created_at: Date; granted_at: Date | null }) => ({\n        id: Number(r.id),\n        crateType: r.crate_type,\n        contentsAmount: r.contents_amount,\n        status: r.status,\n        createdAt: r.created_at.toISOString(),\n        grantedAt: r.granted_at ? r.granted_at.toISOString() : null,\n      }));\n\n      const nextCursor =\n        items.length === limit ? String(items[items.length - 1]!.id) : null;\n\n      return c.json({ items, nextCursor }, 200);\n    } catch (err) {\n      logger.error(\"GET /crates/mine failed\", {\n        userId,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch crate history\" }, 500);\n    }\n  });\n\n  return app;\n}\n","numLines":291,"startLine":1,"totalLines":291}}}
