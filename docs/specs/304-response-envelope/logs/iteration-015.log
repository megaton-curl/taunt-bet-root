e when no drops exist\", async () => {\n      const token = await makeJwt(testWallet, testUserId);\n      const res = await cratesApp.request(\"/crates/mine\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as Record<string, any>;\n      expect(body.items).toHaveLength(0);\n      expect(body.nextCursor).toBeNull();\n    });","newString":"      const res1 = await cratesApp.request(\"/crates/mine?limit=2\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n      expect(res1.status).toBe(200);\n      const body1 = (await res1.json()) as Record<string, any>;\n      expect(body1.ok).toBe(true);\n      expect(body1.data.items).toHaveLength(2);\n      expect(body1.data.items[0].crateType).toBe(\"points\");\n      expect(body1.data.items[0].status).toBe(\"pending\");\n      expect(body1.data.items[0].contentsAmount).toBe(\"500\");\n      expect(body1.data.items[0].grantedAt).toBeNull();\n      expect(body1.data.items[1].crateType).toBe(\"sol\");\n      expect(body1.data.items[1].status).toBe(\"granted\");\n      expect(body1.data.items[1].grantedAt).not.toBeNull();\n      expect(body1.data.nextCursor).not.toBeNull();\n      expect(body1.data.items[0]).toHaveProperty(\"id\");\n      expect(body1.data.items[0]).toHaveProperty(\"createdAt\");\n\n      const res2 = await cratesApp.request(\n        `/crates/mine?limit=2&cursor=${body1.data.nextCursor}`,\n        {\n          method: \"GET\",\n          headers: { Authorization: `Bearer ${token}` },\n        },\n      );\n      expect(res2.status).toBe(200);\n      const body2 = (await res2.json()) as Record<string, any>;\n      expect(body2.ok).toBe(true);\n      expect(body2.data.items).toHaveLength(1);\n      expect(body2.data.items[0].crateType).toBe(\"points\");\n      expect(body2.data.items[0].contentsAmount).toBe(\"2500\");\n      expect(body2.data.nextCursor).toBeNull();\n    });\n\n    it(\"GET /crates/mine returns an empty page when no drops exist\", async () => {\n      const token = await makeJwt(testWallet, testUserId);\n      const res = await cratesApp.request(\"/crates/mine\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as Record<string, any>;\n      expect(body.ok).toBe(true);\n      expect(body.data.items).toHaveLength(0);\n      expect(body.data.nextCursor).toBeNull();\n    });","originalFile":"/* eslint-disable @typescript-eslint/no-explicit-any */\nimport { afterAll, beforeAll, beforeEach, describe, expect, it } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport { createPointsRoutes, createCrateRoutes } from \"../routes/points.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport {\n  closeIntegrationDb,\n  type IntegrationDbContext,\n  JWT_SECRET,\n  makeJwt,\n  openIntegrationDb,\n  resetIntegrationState,\n  type TestSql,\n  userIdFromWallet,\n} from \"./integration-test-helpers.js\";\n\ndescribe(\"Points and crates routes\", () => {\n  let ctx: IntegrationDbContext;\n  let rawSql: TestSql;\n  let db: Db;\n\n  beforeAll(async () => {\n    ctx = await openIntegrationDb();\n    rawSql = ctx.rawSql;\n    db = ctx.db;\n  });\n\n  afterAll(async () => {\n    await closeIntegrationDb(ctx);\n  });\n\n  describe(\"GET /points/mine, /points/mine/history, and /crates/mine\", () => {\n    let pointsApp: Hono;\n    let cratesApp: Hono;\n\n    const testWallet = Keypair.generate().publicKey.toBase58();\n    const testUserId = userIdFromWallet(testWallet);\n\n    beforeEach(async () => {\n      await resetIntegrationState(rawSql);\n\n      pointsApp = new Hono();\n      pointsApp.use(\n        \"/points/*\",\n        createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n      );\n      pointsApp.route(\"/points\", createPointsRoutes({ db }));\n\n      cratesApp = new Hono();\n      cratesApp.use(\n        \"/crates/*\",\n        createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n      );\n      cratesApp.route(\"/crates\", createCrateRoutes({ db }));\n    });\n\n    it(\"GET /points/mine returns zeros when no ledger row exists\", async () => {\n      const token = await makeJwt(testWallet, testUserId);\n      const res = await pointsApp.request(\"/points/mine\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as Record<string, any>;\n      expect(body.ok).toBe(true);\n      expect(body.data.balance).toBe(0);\n      expect(body.data.lifetimeEarned).toBe(0);\n    });\n\n    it(\"GET /points/mine returns the stored balance and lifetime earned\", async () => {\n      await rawSql`\n        INSERT INTO player_points (user_id, wallet, balance, lifetime_earned)\n        VALUES (${testUserId}, ${testWallet}, 5000, 12000)\n      `;\n\n      const token = await makeJwt(testWallet, testUserId);\n      const res = await pointsApp.request(\"/points/mine\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as Record<string, any>;\n      expect(body.ok).toBe(true);\n      expect(body.data.balance).toBe(5000);\n      expect(body.data.lifetimeEarned).toBe(12000);\n    });\n\n    it(\"GET /points/mine/history paginates point grants by cursor\", async () => {\n      for (let i = 1; i <= 3; i++) {\n        await rawSql`\n          INSERT INTO point_grants (\n            user_id,\n            wallet,\n            source_type,\n            source_id,\n            amount,\n            metadata\n          )\n          VALUES (\n            ${testUserId},\n            ${testWallet},\n            'wager',\n            ${`round_${i}`},\n            ${1000 * i},\n            ${JSON.stringify({ solPrice: 100 })}\n          )\n        `;\n      }\n\n      const token = await makeJwt(testWallet, testUserId);\n\n      const res1 = await pointsApp.request(\"/points/mine/history?limit=2\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n      expect(res1.status).toBe(200);\n      const body1 = (await res1.json()) as Record<string, any>;\n      expect(body1.ok).toBe(true);\n      expect(body1.data.items).toHaveLength(2);\n      expect(body1.data.items[0].sourceType).toBe(\"wager\");\n      expect(body1.data.items[0].amount).toBe(3000);\n      expect(body1.data.items[1].amount).toBe(2000);\n      expect(body1.data.nextCursor).not.toBeNull();\n      expect(body1.data.items[0]).toHaveProperty(\"id\");\n      expect(body1.data.items[0]).toHaveProperty(\"sourceId\");\n      expect(body1.data.items[0]).toHaveProperty(\"metadata\");\n      expect(body1.data.items[0]).toHaveProperty(\"createdAt\");\n\n      const res2 = await pointsApp.request(\n        `/points/mine/history?limit=2&cursor=${body1.data.nextCursor}`,\n        {\n          method: \"GET\",\n          headers: { Authorization: `Bearer ${token}` },\n        },\n      );\n      expect(res2.status).toBe(200);\n      const body2 = (await res2.json()) as Record<string, any>;\n      expect(body2.ok).toBe(true);\n      expect(body2.data.items).toHaveLength(1);\n      expect(body2.data.items[0].amount).toBe(1000);\n      expect(body2.data.nextCursor).toBeNull();\n    });\n\n    it(\"GET /points/mine/history returns an empty page when no grants exist\", async () => {\n      const token = await makeJwt(testWallet, testUserId);\n      const res = await pointsApp.request(\"/points/mine/history\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as Record<string, any>;\n      expect(body.ok).toBe(true);\n      expect(body.data.items).toHaveLength(0);\n      expect(body.data.nextCursor).toBeNull();\n    });\n\n    it(\"GET /crates/mine paginates crate drops by cursor\", async () => {\n      await rawSql`\n        INSERT INTO crate_drops (\n          user_id,\n          trigger_type,\n          trigger_id,\n          crate_type,\n          contents_amount,\n          status\n        )\n        VALUES (${testUserId}, 'game_settled', 'round_1', 'points', '2500', 'granted')\n      `;\n      await rawSql`\n        INSERT INTO crate_drops (\n          user_id,\n          trigger_type,\n          trigger_id,\n          crate_type,\n          contents_amount,\n          status,\n          granted_at\n        )\n        VALUES (${testUserId}, 'game_settled', 'round_2', 'sol', '10000000', 'granted', now())\n      `;\n      await rawSql`\n        INSERT INTO crate_drops (\n          user_id,\n          trigger_type,\n          trigger_id,\n          crate_type,\n          contents_amount,\n          status\n        )\n        VALUES (${testUserId}, 'game_settled', 'round_3', 'points', '500', 'pending')\n      `;\n\n      const token = await makeJwt(testWallet, testUserId);\n\n      const res1 = await cratesApp.request(\"/crates/mine?limit=2\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n      expect(res1.status).toBe(200);\n      const body1 = (await res1.json()) as Record<string, any>;\n      expect(body1.items).toHaveLength(2);\n      expect(body1.items[0].crateType).toBe(\"points\");\n      expect(body1.items[0].status).toBe(\"pending\");\n      expect(body1.items[0].contentsAmount).toBe(\"500\");\n      expect(body1.items[0].grantedAt).toBeNull();\n      expect(body1.items[1].crateType).toBe(\"sol\");\n      expect(body1.items[1].status).toBe(\"granted\");\n      expect(body1.items[1].grantedAt).not.toBeNull();\n      expect(body1.nextCursor).not.toBeNull();\n      expect(body1.items[0]).toHaveProperty(\"id\");\n      expect(body1.items[0]).toHaveProperty(\"createdAt\");\n\n      const res2 = await cratesApp.request(\n        `/crates/mine?limit=2&cursor=${body1.nextCursor}`,\n        {\n          method: \"GET\",\n          headers: { Authorization: `Bearer ${token}` },\n        },\n      );\n      expect(res2.status).toBe(200);\n      const body2 = (await res2.json()) as Record<string, any>;\n      expect(body2.items).toHaveLength(1);\n      expect(body2.items[0].crateType).toBe(\"points\");\n      expect(body2.items[0].contentsAmount).toBe(\"2500\");\n      expect(body2.nextCursor).toBeNull();\n    });\n\n    it(\"GET /crates/mine returns an empty page when no drops exist\", async () => {\n      const token = await makeJwt(testWallet, testUserId);\n      const res = await cratesApp.request(\"/crates/mine\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as Record<string, any>;\n      expect(body.items).toHaveLength(0);\n      expect(body.nextCursor).toBeNull();\n    });\n  });\n});\n","structuredPatch":[{"oldStart":200,"oldLines":20,"newStart":200,"newLines":21,"lines":["       });","       expect(res1.status).toBe(200);","       const body1 = (await res1.json()) as Record<string, any>;","-      expect(body1.items).toHaveLength(2);","-      expect(body1.items[0].crateType).toBe(\"points\");","-      expect(body1.items[0].status).toBe(\"pending\");","-      expect(body1.items[0].contentsAmount).toBe(\"500\");","-      expect(body1.items[0].grantedAt).toBeNull();","-      expect(body1.items[1].crateType).toBe(\"sol\");","-      expect(body1.items[1].status).toBe(\"granted\");","-      expect(body1.items[1].grantedAt).not.toBeNull();","-      expect(body1.nextCursor).not.toBeNull();","-      expect(body1.items[0]).toHaveProperty(\"id\");","-      expect(body1.items[0]).toHaveProper