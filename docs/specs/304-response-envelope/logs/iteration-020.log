createReferralRoutes({\n      db,\n      sql: {} as any,\n      config: {} as any,\n    }),\n  );\n  app.route(\"/public-referral\", createPublicReferralRoutes({ db }));\n\n  app.openAPIRegistry.registerComponent(\"securitySchemes\", \"bearerAuth\", {\n    type: \"http\",\n    scheme: \"bearer\",\n    bearerFormat: \"JWT\",\n  });\n\n  app.doc(\"/openapi.json\", {\n    openapi: \"3.0.3\",\n    info: { title: \"Taunt Bet API (waitlist contract)\", version: \"0.1.0\" },\n  });\n\n  return app;\n}\n\nfunction resolveSchema(spec: AnyRecord, schema: unknown): AnyRecord {\n  const record = schema as AnyRecord;\n  if (typeof record?.$ref === \"string\") {\n    const parts = record.$ref.replace(/^#\\//, \"\").split(\"/\");\n    let cur: unknown = spec;\n    for (const p of parts) cur = (cur as AnyRecord)?.[p];\n    return resolveSchema(spec, cur);\n  }\n  return record;\n}\n\nfunction requestBodyKeys(\n  spec: AnyRecord,\n  path: string,\n  method: string,\n): string[] {\n  const op = ((spec.paths as AnyRecord)[path] as AnyRecord)?.[method] as\n    | AnyRecord\n    | undefined;\n  const body = op?.requestBody as AnyRecord | undefined;\n  const schema = (\n    (body?.content as AnyRecord | undefined)?.[\"application/json\"] as\n      | AnyRecord\n      | undefined\n  )?.schema;\n  if (!schema) return [];\n  const resolved = resolveSchema(spec, schema);\n  return Object.keys((resolved.properties as AnyRecord | undefined) ?? {}).sort();\n}\n\n/**\n * Unwrap a response schema, descending into the success branch of an envelope\n * (`{ ok: true, data: T }` inside a `oneOf` discriminated union) when present.\n * Falls back to returning the resolved schema as-is for legacy non-enveloped\n * responses.\n */\nfunction unwrapEnvelope(spec: AnyRecord, schema: unknown): AnyRecord {\n  const resolved = resolveSchema(spec, schema);\n\n  const oneOf = resolved.oneOf as unknown[] | undefined;\n  if (Array.isArray(oneOf)) {\n    for (const variant of oneOf) {\n      const variantResolved = resolveSchema(spec, variant);\n      const props = variantResolved.properties as AnyRecord | undefined;\n      const okProp = props?.ok as AnyRecord | undefined;\n      const okEnum = okProp?.enum as unknown[] | undefined;\n      if (okEnum && okEnum[0] === true && props && \"data\" in props) {\n        return resolveSchema(spec, props.data);\n      }\n    }\n  }\n\n  const properties = resolved.properties as AnyRecord | undefined;\n  if (properties && \"ok\" in properties && \"data\" in properties) {\n    return resolveSchema(spec, properties.data);\n  }\n\n  return resolved;\n}\n\nfunction responseKeys(\n  spec: AnyRecord,\n  path: string,\n  method: string,\n  status = \"200\",\n): string[] {\n  const op = ((spec.paths as AnyRecord)[path] as AnyRecord)?.[method] as\n    | AnyRecord\n    | undefined;\n  const responses = op?.responses as AnyRecord | undefined;\n  const entry = responses?.[status] as AnyRecord | undefined;\n  const schema = (\n    (entry?.content as AnyRecord | undefined)?.[\"application/json\"] as\n      | AnyRecord\n      | undefined\n  )?.schema;\n  if (!schema) return [];\n  const unwrapped = unwrapEnvelope(spec, schema);\n  return Object.keys((unwrapped.properties as AnyRecord | undefined) ?? {}).sort();\n}\n\nfunction arrayItemKeys(\n  spec: AnyRecord,\n  path: string,\n  method: string,\n  arrayProperty: string,\n): string[] {\n  const op = ((spec.paths as AnyRecord)[path] as AnyRecord)?.[method] as\n    | AnyRecord\n    | undefined;\n  const responses = op?.responses as AnyRecord | undefined;\n  const entry = responses?.[\"200\"] as AnyRecord | undefined;\n  const schema = (\n    (entry?.content as AnyRecord | undefined)?.[\"application/json\"] as\n      | AnyRecord\n      | undefined\n  )?.schema;\n  const unwrapped = unwrapEnvelope(spec, schema);\n  const prop = (unwrapped.properties as AnyRecord)[arrayProperty] as AnyRecord;\n  const itemResolved = resolveSchema(spec, prop.items);\n  return Object.keys(\n    (itemResolved.properties as AnyRecord | undefined) ?? {},\n  ).sort();\n}\n\nfunction isBearerProtected(\n  spec: AnyRecord,\n  path: string,\n  method: string,\n): boolean {\n  const op = ((spec.paths as AnyRecord)[path] as AnyRecord)?.[method] as\n    | AnyRecord\n    | undefined;\n  const security = op?.security as Array<AnyRecord> | undefined;\n  if (!security) return false;\n  return security.some((entry) => Object.keys(entry).includes(\"bearerAuth\"));\n}\n\n// ---------------------------------------------------------------------------\n// Tests\n// ---------------------------------------------------------------------------\n\ndescribe(\"Waitlist ↔ backend API contract\", () => {\n  let spec: AnyRecord;\n\n  beforeAll(async () => {\n    const app = buildSpecApp();\n    const res = await app.request(\"/openapi.json\");\n    expect(res.status).toBe(200);\n    spec = (await res.json()) as AnyRecord;\n  });\n\n  for (const [key, contract] of Object.entries(WAITLIST_CONTRACT)) {\n    const parts = key.split(\" \");\n    const method = parts[0] as string;\n    const path = parts[1] as string;\n    const methodLower = method.toLowerCase();\n\n    describe(`${key}`, () => {\n      it(\"exists in the generated OpenAPI spec\", () => {\n        const paths = spec.paths as AnyRecord;\n        expect(\n          paths[path],\n          `Waitlist calls ${key} but the OpenAPI spec has no such path.\\n` +\n            \"Available paths: \" +\n            Object.keys(paths).sort().join(\", \"),\n        ).toBeDefined();\n        expect((paths[path] as AnyRecord)[methodLower]).toBeDefined();\n      });\n\n      if (contract.requestBody !== null) {\n        it(\"request body has exactly the keys waitlist sends\", () => {\n          const actual = requestBodyKeys(spec, path, methodLower);\n          expect(\n            actual,\n            `Waitlist sends { ${contract.requestBody.join(\", \")} } to ${key}. ` +\n              `Backend schema has { ${actual.join(\", \")} }. ` +\n              \"Reconcile before merging.\",\n          ).toEqual([...contract.requestBody].sort());\n        });\n      }\n\n      if (contract.response !== null) {\n        it(\"200 response has exactly the keys waitlist consumes\", () => {\n          const actual = responseKeys(spec, path, methodLower);\n          expect(\n            actual,\n            `Waitlist consumes { ${contract.response.join(\", \")} } from ${key}. ` +\n              `Backend returns { ${actual.join(\", \")} }. ` +\n              \"Reconcile before merging.\",\n          ).toEqual([...contract.response].sort());\n        });\n      }\n\n      if (\"itemResponse\" in contract && contract.itemResponse) {\n        it(\"array item shape matches what waitlist renders\", () => {\n          const actual = arrayItemKeys(spec, path, methodLower, \"items\");\n          expect(actual).toEqual([...contract.itemResponse].sort());\n        });\n      }\n\n      it(`auth is ${contract.authRequired ? \"required\" : \"public\"}`, () => {\n        expect(isBearerProtected(spec, path, methodLower)).toBe(\n          contract.authRequired,\n        );\n      });\n    });\n  }\n});\n\n// ---------------------------------------------------------------------------","numLines":270,"startLine":130,"totalLines":456}}}
