{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01V6NvsekPAsCDG4jjFGYFcJ","type":"tool_result","content":"1\t/**\n2\t * Telegram link routes — generate deep-link tokens and redeem them.\n3\t *\n4\t * POST /generate-link — JWT required. Returns a one-time deep-link token.\n5\t * All other endpoints use service-auth via X-Telegram-Webhook-Secret header.\n6\t *\n7\t * WAITLIST-CONTRACT: the waitlist calls POST /generate-link\n8\t * (`waitlist/src/components/TelegramCard.tsx`) and branches on both\n9\t * `alreadyLinked: true` and `deepLink` payloads. This file is plain Hono\n10\t * (no OpenAPI schema), so the response shape is locked by handler invocation\n11\t * in `__tests__/waitlist-contract.test.ts` — updating either response branch\n12\t * requires updating that test AND the waitlist consumer in the same change.\n13\t */\n14\t\n15\timport { randomBytes } from \"node:crypto\";\n16\timport { Hono } from \"hono\";\n17\timport { createMiddleware } from \"hono/factory\";\n18\timport type { AppEnv } from \"../hono-env.js\";\n19\timport type { Db } from \"../db.js\";\n20\timport { logger } from \"../logger.js\";\n21\t\n22\texport interface TelegramLinkRoutesDeps {\n23\t  db: Db;\n24\t  telegramBotUsername: string;\n25\t  telegramWebhookSecret: string;\n26\t  communityInviteUrl: string | undefined;\n27\t  linkTokenTtlSeconds: number;\n28\t}\n29\t\n30\texport function createTelegramLinkRoutes(deps: TelegramLinkRoutesDeps) {\n31\t  const { db, telegramBotUsername, telegramWebhookSecret, communityInviteUrl, linkTokenTtlSeconds } = deps;\n32\t  const app = new Hono<AppEnv>();\n33\t\n34\t  // Service-auth middleware for bot-facing endpoints\n35\t  const serviceAuth = createMiddleware(async (c, next) => {\n36\t    if (c.req.header(\"X-Telegram-Webhook-Secret\") !== telegramWebhookSecret) {\n37\t      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n38\t    }\n39\t    return next();\n40\t  });\n41\t\n42\t  // -------------------------------------------------------------------------\n43\t  // POST /generate-link — JWT required\n44\t  // -------------------------------------------------------------------------\n45\t  app.post(\"/generate-link\", async (c) => {\n46\t    const userId = c.get(\"userId\");\n47\t    if (!userId) {\n48\t      return c.json({ error: \"Authentication required\" }, 401);\n49\t    }\n50\t\n51\t    try {\n52\t      const existing = await db.getActiveLink(userId);\n53\t      if (existing) {\n54\t        return c.json({\n55\t          alreadyLinked: true,\n56\t          telegramUserId: existing.telegram_user_id,\n57\t          telegramUsername: existing.telegram_username,\n58\t          linkedAt: existing.redeemed_at?.toISOString() ?? null,\n59\t          botUrl: `https://t.me/${telegramBotUsername}`,\n60\t          communityUrl: communityInviteUrl ?? null,\n61\t        });\n62\t      }\n63\t\n64\t      const token = randomBytes(32).toString(\"hex\");\n65\t      const expiresAt = new Date(Date.now() + linkTokenTtlSeconds * 1000);\n66\t\n67\t      await db.generateLinkToken(userId, token, expiresAt);\n68\t\n69\t      return c.json({\n70\t        token,\n71\t        deepLink: `https://t.me/${telegramBotUsername}?start=${token}`,\n72\t        expiresAt: expiresAt.toISOString(),\n73\t        botUrl: `https://t.me/${telegramBotUsername}`,\n74\t        communityUrl: communityInviteUrl ?? null,\n75\t      });\n76\t    } catch (err) {\n77\t      logger.error(\"telegram generate-link failed\", {\n78\t        userId,\n79\t        error: err instanceof Error ? err.message : \"Unknown error\",\n80\t      });\n81\t      return c.json({ error: \"Failed to generate link token\" }, 500);\n82\t    }\n83\t  });\n84\t\n85\t  // -------------------------------------------------------------------------\n86\t  // POST /redeem-link — service-auth\n87\t  // -------------------------------------------------------------------------\n88\t  app.post(\"/redeem-link\", serviceAuth, async (c) => {\n89\t    let body: { token?: string; telegramUserId?: string; telegramUsername?: string };\n90\t    try {\n91\t      body = await c.req.json();\n92\t    } catch {\n93\t      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n94\t    }\n95\t\n96\t    const { token, telegramUserId, telegramUsername } = body;\n97\t    if (!token || !telegramUserId) {\n98\t      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n99\t    }\n100\t\n101\t    try {\n102\t      const existingTg = await db.getActiveLinkByTelegramId(telegramUserId);\n103\t      if (existingTg) {\n104\t        return c.json({\n105\t          error: \"TELEGRAM_ALREADY_LINKED\",\n106\t          existingUserId: existingTg.user_id,\n107\t        }, 409);\n108\t      }\n109\t\n110\t      const redeemed = await db.redeemLinkToken(\n111\t        token,\n112\t        telegramUserId,\n113\t        telegramUsername ?? null,\n114\t      );\n115\t\n116\t      if (!redeemed) {\n117\t        return c.json({ error: \"TOKEN_NOT_FOUND\" }, 404);\n118\t      }\n119\t\n120\t      const profile = await db.getProfileByUserId(redeemed.user_id);\n121\t\n122\t      return c.json({\n123\t        userId: redeemed.user_id,\n124\t        username: profile?.username ?? null,\n125\t        alreadyLinked: false,\n126\t      });\n127\t    } catch (err) {\n128\t      logger.error(\"telegram redeem-link failed\", {\n129\t        error: err instanceof Error ? err.message : \"Unknown error\",\n130\t      });\n131\t      return c.json({ error: \"Failed to redeem link token\" }, 500);\n132\t    }\n133\t  });\n134\t\n135\t  // -------------------------------------------------------------------------\n136\t  // GET /linked-user — resolve telegram ID → platform userId\n137\t  // -------------------------------------------------------------------------\n138\t  app.get(\"/linked-user\", serviceAuth, async (c) => {\n139\t    const telegramUserId = c.req.query(\"telegramUserId\");\n140\t    if (!telegramUserId) {\n141\t      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n142\t    }\n143\t\n144\t    try {\n145\t      const link = await db.getActiveLinkByTelegramId(telegramUserId);\n146\t      if (!link) {\n147\t        return c.json({ error: \"NOT_LINKED\" }, 404);\n148\t      }\n149\t\n150\t      return c.json({ userId: link.user_id });\n151\t    } catch (err) {\n152\t      logger.error(\"telegram linked-user lookup failed\", {\n153\t        error: err instanceof Error ? err.message : \"Unknown error\",\n154\t      });\n155\t      return c.json({ error: \"Failed to look up linked user\" }, 500);\n156\t    }\n157\t  });\n158\t\n159\t  // -------------------------------------------------------------------------\n160\t  // GET /referral-info — ref code + count for linked user\n161\t  // -------------------------------------------------------------------------\n162\t  app.get(\"/referral-info\", serviceAuth, async (c) => {\n163\t    const telegramUserId = c.req.query(\"telegramUserId\");\n164\t    if (!telegramUserId) {\n165\t      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n166\t    }\n167\t\n168\t    try {\n169\t      const link = await db.getActiveLinkByTelegramId(telegramUserId);\n170\t      if (!link) {\n171\t        return c.json({ error: \"NOT_LINKED\" }, 404);\n172\t      }\n173\t\n174\t      const userId = link.user_id;\n175\t      const [profile, codeRow, statsRow] = await Promise.all([\n176\t        db.getProfileByUserId(userId),\n177\t        db.getReferralCodeByUserId(userId),\n178\t        db.getReferralStatsByUserId(userId),\n179\t      ]);\n180\t\n181\t      return c.json({\n182\t        userId,\n183\t        username: profile?.username ?? null,\n184\t        referralCode: codeRow?.code ?? null,\n185\t        referredCount: statsRow.referred_count,\n186\t      });\n187\t    } catch (err) {\n188\t      logger.error(\"telegram referral-info failed\", {\n189\t        error: err instanceof Error ? err.message : \"Unknown error\",\n190\t      });\n191\t      return c.json({ error: \"Failed to fetch referral info\" }, 500);\n192\t    }\n193\t  });\n194\t\n195\t  // -------------------------------------------------------------------------\n196\t  // GET /referral-leaderboard — top referrers + user rank\n197\t  // -------------------------------------------------------------------------\n198\t  app.get(\"/referral-leaderboard\", serviceAuth, async (c) => {\n199\t    const telegramUserId = c.req.query(\"telegramUserId\");\n200\t\n201\t    try {\n202\t      // Resolve linked userId (optional — leaderboard works without it)\n203\t      let linkedUserId: string | undefined;\n204\t      if (telegramUserId) {\n205\t        const link = await db.getActiveLinkByTelegramId(telegramUserId);\n206\t        if (link) linkedUserId = link.user_id;\n207\t      }\n208\t\n209\t      const result = await db.getReferralLeaderboard(10, linkedUserId);\n210\t\n211\t      return c.json({\n212\t        entries: result.entries,\n213\t        userRank: result.userRank,\n214\t        userCount: result.userCount,\n215\t      });\n216\t    } catch (err) {\n217\t      logger.error(\"telegram referral-leaderboard failed\", {\n218\t        error: err instanceof Error ? err.message : \"Unknown error\",\n219\t      });\n220\t      return c.json({ error: \"Failed to fetch leaderboard\" }, 500);\n221\t    }\n222\t  });\n223\t\n224\t  return app;\n225\t}\n226\t"}]},"parent_tool_use_id":null,"session_id":"f806a150-eb89-42ec-8486-af5a97db7885","uuid":"bbca8401-2613-4942-855a-9279ec0dabbb","timestamp":"2026-04-22T10:48:41.866Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/telegram-link.ts","content":"/**\n * Telegram link routes — generate deep-link tokens and redeem them.\n *\n * POST /generate-link — JWT required. Returns a one-time deep-link token.\n * All other endpoints use service-auth via X-Telegram-Webhook-Secret header.\n *\n * WAITLIST-CONTRACT: the waitlist calls POST /generate-link\n * (`waitlist/src/components/TelegramCard.tsx`) and branches on both\n * `alreadyLinked: true` and `deepLink` payloads. This file is plain Hono\n * (no OpenAPI schema), so the response shape is locked by handler invocation\n * in `__tests__/waitlist-contract.test.ts` — updating either response branch\n * requires updating that test AND the waitlist consumer in the same change.\n */\n\nimport { randomBytes } from \"node:crypto\";\nimport { Hono } from \"hono\";\nimport { createMiddleware } from \"hono/factory\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\n\nexport interface TelegramLinkRoutesDeps {\n  db: Db;\n  telegramBotUsername: string;\n  telegramWebhookSecret: string;\n  communityInviteUrl: string | undefined;\n  linkTokenTtlSeconds: number;\n}\n\nexport function createTelegramLinkRoutes(deps: TelegramLinkRoutesDeps) {\n  const { db, telegramBotUsername, telegramWebhookSecret, communityInviteUrl, linkTokenTtlSeconds } = deps;\n  const app = new Hono<AppEnv>();\n\n  // Service-auth middleware for bot-facing endpoints\n  const serviceAuth = createMiddleware(async (c, next) => {\n    if (c.req.header(\"X-Telegram-Webhook-Secret\") !== telegramWebhookSecret) {\n      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n    }\n    return next();\n  });\n\n  // -------------------------------------------------------------------------\n  // POST /generate-link — JWT required\n  // -------------------------------------------------------------------------\n  app.post(\"/generate-link\", async (c) => {\n    const userId = c.get(\"userId\");\n    if (!userId) {\n      return c.json({ error: \"Authentication required\" }, 401);\n    }\n\n    try {\n      const existing = await db.getActiveLink(userId);\n      if (existing) {\n        return c.json({\n          alreadyLinked: true,\n          telegramUserId: existing.telegram_user_id,\n          telegramUsername: existing.telegram_username,\n          linkedAt: existing.redeemed_at?.toISOString() ?? null,\n          botUrl: `https://t.me/${telegramBotUsername}`,\n          communityUrl: communityInviteUrl ?? null,\n        });\n      }\n\n      const token = randomBytes(32).toString(\"hex\");\n      const expiresAt = new Date(Date.now() + linkTokenTtlSeconds * 1000);\n\n      await db.generateLinkToken(userId, token, expiresAt);\n\n      return c.json({\n        token,\n        deepLink: `https://t.me/${telegramBotUsername}?start=${token}`,\n        expiresAt: expiresAt.toISOString(),\n        botUrl: `https://t.me/${telegramBotUsername}`,\n        communityUrl: communityInviteUrl ?? null,\n      });\n    } catch (err) {\n      logger.error(\"telegram generate-link failed\", {\n        userId,\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to generate link token\" }, 500);\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // POST /redeem-link — service-auth\n  // -------------------------------------------------------------------------\n  app.post(\"/redeem-link\", serviceAuth, async (c) => {\n    let body: { token?: string; telegramUserId?: string; telegramUsername?: string };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    const { token, telegramUserId, telegramUsername } = body;\n    if (!token || !telegramUserId) {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    try {\n      const existingTg = await db.getActiveLinkByTelegramId(telegramUserId);\n      if (existingTg) {\n        return c.json({\n          error: \"TELEGRAM_ALREADY_LINKED\",\n          existingUserId: existingTg.user_id,\n        }, 409);\n      }\n\n      const redeemed = await db.redeemLinkToken(\n        token,\n        telegramUserId,\n        telegramUsername ?? null,\n      );\n\n      if (!redeemed) {\n        return c.json({ error: \"TOKEN_NOT_FOUND\" }, 404);\n      }\n\n      const profile = await db.getProfileByUserId(redeemed.user_id);\n\n      return c.json({\n        userId: redeemed.user_id,\n        username: profile?.username ?? null,\n        alreadyLinked: false,\n      });\n    } catch (err) {\n      logger.error(\"telegram redeem-link failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to redeem link token\" }, 500);\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // GET /linked-user — resolve telegram ID → platform userId\n  // -------------------------------------------------------------------------\n  app.get(\"/linked-user\", serviceAuth, async (c) => {\n    const telegramUserId = c.req.query(\"telegramUserId\");\n    if (!telegramUserId) {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    try {\n      const link = await db.getActiveLinkByTelegramId(telegramUserId);\n      if (!link) {\n        return c.json({ error: \"NOT_LINKED\" }, 404);\n      }\n\n      return c.json({ userId: link.user_id });\n    } catch (err) {\n      logger.error(\"telegram linked-user lookup failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to look up linked user\" }, 500);\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // GET /referral-info — ref code + count for linked user\n  // -------------------------------------------------------------------------\n  app.get(\"/referral-info\", serviceAuth, async (c) => {\n    const telegramUserId = c.req.query(\"telegramUserId\");\n    if (!telegramUserId) {\n      return c.json({ error: \"INVALID_REQUEST\" }, 400);\n    }\n\n    try {\n      const link = await db.getActiveLinkByTelegramId(telegramUserId);\n      if (!link) {\n        return c.json({ error: \"NOT_LINKED\" }, 404);\n      }\n\n      const userId = link.user_id;\n      const [profile, codeRow, statsRow] = await Promise.all([\n        db.getProfileByUserId(userId),\n        db.getReferralCodeByUserId(userId),\n        db.getReferralStatsByUserId(userId),\n      ]);\n\n      return c.json({\n        userId,\n        username: profile?.username ?? null,\n        referralCode: codeRow?.code ?? null,\n        referredCount: statsRow.referred_count,\n      });\n    } catch (err) {\n      logger.error(\"telegram referral-info failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch referral info\" }, 500);\n    }\n  });\n\n  // -------------------------------------------------------------------------\n  // GET /referral-leaderboard — top referrers + user rank\n  // -------------------------------------------------------------------------\n  app.get(\"/referral-leaderboard\", serviceAuth, async (c) => {\n    const telegramUserId = c.req.query(\"telegramUserId\");\n\n    try {\n      // Resolve linked userId (optional — leaderboard works without it)\n      let linkedUserId: string | undefined;\n      if (telegramUserId) {\n        const link = await db.getActiveLinkByTelegramId(telegramUserId);\n        if (link) linkedUserId = link.user_id;\n      }\n\n      const result = await db.getReferralLeaderboard(10, linkedUserId);\n\n      return c.json({\n        entries: result.entries,\n        userRank: result.userRank,\n        userCount: result.userCount,\n      });\n    } catch (err) {\n      logger.error(\"telegram referral-leaderboard failed\", {\n        error: err instanceof Error ? err.message : \"Unknown error\",\n      });\n      return c.json({ error: \"Failed to fetch leaderboard\" }, 500);\n    }\n  });\n\n  return app;\n}\n","numLines":226,"startLine":1,"totalLines":226}}}
