eads `data.alreadyLinked === true` (was `body.alreadyLinked`).\n- **Verification**:\n  - `pnpm -C backend typecheck:self` → exit 0\n  - `pnpm -C backend lint:self` → exit 0\n  - Targeted: `vitest run --config vitest.unit.config.ts src/__tests__/waitlist-contract.test.ts` → 41/41 passed\n  - Full unit suite (`vitest run --config vitest.unit.config.ts`) → 214/214 passed across 20 files\n\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":330,"cache_read_input_tokens":101177,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":330},"output_tokens":72,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f806a150-eb89-42ec-8486-af5a97db7885","uuid":"5ccd28ac-72a3-42ae-9228-a78817752d78"}
