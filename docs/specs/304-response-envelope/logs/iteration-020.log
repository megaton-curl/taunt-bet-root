{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012KW9AUJbDFeRChYpcipqjP","type":"tool_result","content":"1\t/**\n2\t * Waitlist API contract guard.\n3\t *\n4\t * The waitlist app (separate repo, `waitlist/`) launches first and consumes\n5\t * a fixed subset of backend endpoints. This file pins the EXACT request and\n6\t * response shape for each of those endpoints. If any of these assertions\n7\t * fails, the waitlist is likely to break in production — STOP and think:\n8\t *\n9\t *   1. Is this change intentional?\n10\t *   2. Does the deployed waitlist already tolerate it?\n11\t *   3. Does the waitlist need a coordinated release BEFORE the backend ships?\n12\t *   4. Only then update WAITLIST_CONTRACT below AND update\n13\t *      `waitlist/src/lib/{auth-api,referral-api}.ts` + `TelegramCard.tsx`.\n14\t *\n15\t * Additive changes (new optional response fields) WILL fail this test on\n16\t * purpose — so the author is forced to confirm the waitlist will ignore them.\n17\t *\n18\t * Route files that back this contract carry a `WAITLIST-CONTRACT` banner\n19\t * pointing here.\n20\t */\n21\t\n22\t/* eslint-disable @typescript-eslint/no-explicit-any */\n23\t\n24\timport { describe, it, expect, beforeAll } from \"vitest\";\n25\timport { OpenAPIHono } from \"@hono/zod-openapi\";\n26\timport { Hono } from \"hono\";\n27\timport { createAuthRoutes } from \"../routes/auth.js\";\n28\timport { createReferralRoutes } from \"../routes/referral.js\";\n29\timport { createPublicReferralRoutes } from \"../routes/public-referral.js\";\n30\timport { createTelegramLinkRoutes } from \"../routes/telegram-link.js\";\n31\t\n32\ttype AnyRecord = Record<string, unknown>;\n33\t\n34\t// ---------------------------------------------------------------------------\n35\t// The contract. One entry per endpoint waitlist calls.\n36\t// ---------------------------------------------------------------------------\n37\t//\n38\t// `requestBody` = keys waitlist actually sends.\n39\t// `response`    = keys waitlist actually consumes (or would consume).\n40\t//\n41\t// Keep alphabetized inside each array. If you add, remove, or rename a key\n42\t// here, keep `waitlist/src/lib/*.ts` in lockstep.\n43\t//\n44\t// Source of truth (waitlist side, 2026-04-18):\n45\t//   waitlist/src/lib/auth-api.ts\n46\t//   waitlist/src/lib/referral-api.ts\n47\t//   waitlist/src/components/TelegramCard.tsx\n48\t\n49\tconst WAITLIST_CONTRACT = {\n50\t  // ── Auth (public, JSON) ───────────────────────────────────────────────\n51\t  \"POST /auth/challenge\": {\n52\t    requestBody: [\"wallet\"],\n53\t    response: [\"expiresAt\", \"message\", \"nonce\"],\n54\t    authRequired: false,\n55\t  },\n56\t  \"POST /auth/verify\": {\n57\t    requestBody: [\"nonce\", \"signature\", \"wallet\"],\n58\t    response: [\n59\t      \"accessExpiresAt\",\n60\t      \"accessToken\",\n61\t      \"refreshExpiresAt\",\n62\t      \"refreshToken\",\n63\t    ],\n64\t    authRequired: false,\n65\t  },\n66\t  \"POST /auth/refresh\": {\n67\t    requestBody: [\"refreshToken\"],\n68\t    response: [\n69\t      \"accessExpiresAt\",\n70\t      \"accessToken\",\n71\t      \"refreshExpiresAt\",\n72\t      \"refreshToken\",\n73\t    ],\n74\t    authRequired: false,\n75\t  },\n76\t  \"POST /auth/logout\": {\n77\t    requestBody: [\"refreshToken\"], // optional on backend, always sent by waitlist\n78\t    response: null, // 204 no body\n79\t    authRequired: false,\n80\t  },\n81\t\n82\t  // ── Public referral ──────────────────────────────────────────────────\n83\t  \"GET /public-referral/code/{code}\": {\n84\t    requestBody: null,\n85\t    response: [\"exists\"],\n86\t    authRequired: false,\n87\t  },\n88\t\n89\t  // ── Authenticated referral ───────────────────────────────────────────\n90\t  \"POST /referral/code\": {\n91\t    requestBody: [\"code\"],\n92\t    response: [\"code\"],\n93\t    authRequired: true,\n94\t  },\n95\t  \"GET /referral/code\": {\n96\t    requestBody: null,\n97\t    response: [\"code\"],\n98\t    authRequired: true,\n99\t  },\n100\t  \"POST /referral/apply\": {\n101\t    requestBody: [\"code\"],\n102\t    response: [\"benefit\", \"referrerUserId\"],\n103\t    authRequired: true,\n104\t  },\n105\t  \"GET /referral/referrer\": {\n106\t    requestBody: null,\n107\t    response: [\n108\t      \"linkedAt\",\n109\t      \"referrerCode\",\n110\t      \"referrerUserId\",\n111\t      \"referrerUsername\",\n112\t    ],\n113\t    authRequired: true,\n114\t  },\n115\t  \"GET /referral/stats\": {\n116\t    requestBody: null,\n117\t    response: [\n118\t      \"activeCount\",\n119\t      \"pendingLamports\",\n120\t      \"referredCount\",\n121\t      \"totalEarnedLamports\",\n122\t      \"totalRebateLamports\",\n123\t      \"totalVolumeLamports\",\n124\t    ],\n125\t    authRequired: true,\n126\t  },\n127\t  \"GET /referral/referrals\": {\n128\t    requestBody: null,\n129\t    response: [\"items\"],\n130\t    itemResponse: [\"createdAt\", \"refereeUserId\", \"refereeUsername\"],"}]},"parent_tool_use_id":null,"session_id":"f806a150-eb89-42ec-8486-af5a97db7885","uuid":"92454138-446d-492d-9daf-5ba7e4dc5266","timestamp":"2026-04-22T10:48:52.445Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/__tests__/waitlist-contract.test.ts","content":"/**\n * Waitlist API contract guard.\n *\n * The waitlist app (separate repo, `waitlist/`) launches first and consumes\n * a fixed subset of backend endpoints. This file pins the EXACT request and\n * response shape for each of those endpoints. If any of these assertions\n * fails, the waitlist is likely to break in production — STOP and think:\n *\n *   1. Is this change intentional?\n *   2. Does the deployed waitlist already tolerate it?\n *   3. Does the waitlist need a coordinated release BEFORE the backend ships?\n *   4. Only then update WAITLIST_CONTRACT below AND update\n *      `waitlist/src/lib/{auth-api,referral-api}.ts` + `TelegramCard.tsx`.\n *\n * Additive changes (new optional response fields) WILL fail this test on\n * purpose — so the author is forced to confirm the waitlist will ignore them.\n *\n * Route files that back this contract carry a `WAITLIST-CONTRACT` banner\n * pointing here.\n */\n\n/* eslint-disable @typescript-eslint/no-explicit-any */\n\nimport { describe, it, expect, beforeAll } from \"vitest\";\nimport { OpenAPIHono } from \"@hono/zod-openapi\";\nimport { Hono } from \"hono\";\nimport { createAuthRoutes } from \"../routes/auth.js\";\nimport { createReferralRoutes } from \"../routes/referral.js\";\nimport { createPublicReferralRoutes } from \"../routes/public-referral.js\";\nimport { createTelegramLinkRoutes } from \"../routes/telegram-link.js\";\n\ntype AnyRecord = Record<string, unknown>;\n\n// ---------------------------------------------------------------------------\n// The contract. One entry per endpoint waitlist calls.\n// ---------------------------------------------------------------------------\n//\n// `requestBody` = keys waitlist actually sends.\n// `response`    = keys waitlist actually consumes (or would consume).\n//\n// Keep alphabetized inside each array. If you add, remove, or rename a key\n// here, keep `waitlist/src/lib/*.ts` in lockstep.\n//\n// Source of truth (waitlist side, 2026-04-18):\n//   waitlist/src/lib/auth-api.ts\n//   waitlist/src/lib/referral-api.ts\n//   waitlist/src/components/TelegramCard.tsx\n\nconst WAITLIST_CONTRACT = {\n  // ── Auth (public, JSON) ───────────────────────────────────────────────\n  \"POST /auth/challenge\": {\n    requestBody: [\"wallet\"],\n    response: [\"expiresAt\", \"message\", \"nonce\"],\n    authRequired: false,\n  },\n  \"POST /auth/verify\": {\n    requestBody: [\"nonce\", \"signature\", \"wallet\"],\n    response: [\n      \"accessExpiresAt\",\n      \"accessToken\",\n      \"refreshExpiresAt\",\n      \"refreshToken\",\n    ],\n    authRequired: false,\n  },\n  \"POST /auth/refresh\": {\n    requestBody: [\"refreshToken\"],\n    response: [\n      \"accessExpiresAt\",\n      \"accessToken\",\n      \"refreshExpiresAt\",\n      \"refreshToken\",\n    ],\n    authRequired: false,\n  },\n  \"POST /auth/logout\": {\n    requestBody: [\"refreshToken\"], // optional on backend, always sent by waitlist\n    response: null, // 204 no body\n    authRequired: false,\n  },\n\n  // ── Public referral ──────────────────────────────────────────────────\n  \"GET /public-referral/code/{code}\": {\n    requestBody: null,\n    response: [\"exists\"],\n    authRequired: false,\n  },\n\n  // ── Authenticated referral ───────────────────────────────────────────\n  \"POST /referral/code\": {\n    requestBody: [\"code\"],\n    response: [\"code\"],\n    authRequired: true,\n  },\n  \"GET /referral/code\": {\n    requestBody: null,\n    response: [\"code\"],\n    authRequired: true,\n  },\n  \"POST /referral/apply\": {\n    requestBody: [\"code\"],\n    response: [\"benefit\", \"referrerUserId\"],\n    authRequired: true,\n  },\n  \"GET /referral/referrer\": {\n    requestBody: null,\n    response: [\n      \"linkedAt\",\n      \"referrerCode\",\n      \"referrerUserId\",\n      \"referrerUsername\",\n    ],\n    authRequired: true,\n  },\n  \"GET /referral/stats\": {\n    requestBody: null,\n    response: [\n      \"activeCount\",\n      \"pendingLamports\",\n      \"referredCount\",\n      \"totalEarnedLamports\",\n      \"totalRebateLamports\",\n      \"totalVolumeLamports\",\n    ],\n    authRequired: true,\n  },\n  \"GET /referral/referrals\": {\n    requestBody: null,\n    response: [\"items\"],\n    itemResponse: [\"createdAt\", \"refereeUserId\", \"refereeUsername\"],","numLines":130,"startLine":1,"totalLines":456}}}
