{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BDgJHDvye9tnSnMMNa4w2C","type":"tool_result","content":"     1→/**\n     2→ * Referral routes — code management, linking, stats, earnings, and claims.\n     3→ */\n     4→\n     5→import { Hono } from \"hono\";\n     6→import type { AppEnv } from \"../hono-env.js\";\n     7→import type { Db } from \"../db.js\";\n     8→import { logger } from \"../logger.js\";\n     9→\n    10→export interface ReferralRoutesDeps {\n    11→  db: Db;\n    12→}\n    13→\n    14→/** Referral code validation: 3-16 chars, lowercase alphanumeric + hyphens */\n    15→const CODE_REGEX = /^[a-z0-9-]{3,16}$/;\n    16→\n    17→const REFERRAL_BASE_URL = \"https://taunt.bet/r\";\n    18→\n    19→export function createReferralRoutes(deps: ReferralRoutesDeps) {\n    20→  const { db } = deps;\n    21→  const app = new Hono<AppEnv>();\n    22→\n    23→  // POST /code — set or replace the player's referral code\n    24→  app.post(\"/code\", async (c) => {\n    25→    const wallet = c.get(\"wallet\");\n    26→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n    27→\n    28→    let body: { code?: unknown };\n    29→    try {\n    30→      body = await c.req.json();\n    31→    } catch {\n    32→      return c.json({ error: \"Invalid request body\" }, 400);\n    33→    }\n    34→\n    35→    const code = typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n    36→\n    37→    if (!CODE_REGEX.test(code)) {\n    38→      return c.json(\n    39→        {\n    40→          error: {\n    41→            code: \"INVALID_CODE\",\n    42→            message:\n    43→              \"Code must be 3-16 characters, lowercase letters, numbers, and hyphens only\",\n    44→          },\n    45→        },\n    46→        400,\n    47→      );\n    48→    }\n    49→\n    50→    // Check if this code is already taken by another wallet\n    51→    const existing = await db.getReferralCodeByCode(code);\n    52→    if (existing && existing.wallet !== wallet) {\n    53→      return c.json(\n    54→        {\n    55→          error: {\n    56→            code: \"CODE_TAKEN\",\n    57→            message: \"This referral code is already in use\",\n    58→            retryable: false,\n    59→          },\n    60→        },\n    61→        409,\n    62→      );\n    63→    }\n    64→\n    65→    try {\n    66→      const result = await db.upsertReferralCode(wallet, code);\n    67→      logger.info(\"Referral code set\", { wallet, code: result.code });\n    68→      return c.json({\n    69→        code: result.code,\n    70→        url: `${REFERRAL_BASE_URL}/${result.code}`,\n    71→      });\n    72→    } catch (err) {\n    73→      // Handle race condition: another wallet grabbed the code between check and insert\n    74→      const msg = err instanceof Error ? err.message : String(err);\n    75→      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n    76→        return c.json(\n    77→          {\n    78→            error: {\n    79→              code: \"CODE_TAKEN\",\n    80→              message: \"This referral code is already in use\",\n    81→              retryable: false,\n    82→            },\n    83→          },\n    84→          409,\n    85→        );\n    86→      }\n    87→      logger.error(\"Failed to set referral code\", { err: String(err), wallet });\n    88→      return c.json({ error: \"Failed to set referral code\" }, 500);\n    89→    }\n    90→  });\n    91→\n    92→  return app;\n    93→}\n    94→"}]},"parent_tool_use_id":null,"session_id":"91d95e74-c305-4801-b7f4-b036b613409b","uuid":"b67a4d93-19b5-47cc-b3ec-f82af98286ff","timestamp":"2026-03-25T11:56:10.888Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/referral.ts","content":"/**\n * Referral routes — code management, linking, stats, earnings, and claims.\n */\n\nimport { Hono } from \"hono\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\n\nexport interface ReferralRoutesDeps {\n  db: Db;\n}\n\n/** Referral code validation: 3-16 chars, lowercase alphanumeric + hyphens */\nconst CODE_REGEX = /^[a-z0-9-]{3,16}$/;\n\nconst REFERRAL_BASE_URL = \"https://taunt.bet/r\";\n\nexport function createReferralRoutes(deps: ReferralRoutesDeps) {\n  const { db } = deps;\n  const app = new Hono<AppEnv>();\n\n  // POST /code — set or replace the player's referral code\n  app.post(\"/code\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    let body: { code?: unknown };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json({ error: \"Invalid request body\" }, 400);\n    }\n\n    const code = typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n\n    if (!CODE_REGEX.test(code)) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_CODE\",\n            message:\n              \"Code must be 3-16 characters, lowercase letters, numbers, and hyphens only\",\n          },\n        },\n        400,\n      );\n    }\n\n    // Check if this code is already taken by another wallet\n    const existing = await db.getReferralCodeByCode(code);\n    if (existing && existing.wallet !== wallet) {\n      return c.json(\n        {\n          error: {\n            code: \"CODE_TAKEN\",\n            message: \"This referral code is already in use\",\n            retryable: false,\n          },\n        },\n        409,\n      );\n    }\n\n    try {\n      const result = await db.upsertReferralCode(wallet, code);\n      logger.info(\"Referral code set\", { wallet, code: result.code });\n      return c.json({\n        code: result.code,\n        url: `${REFERRAL_BASE_URL}/${result.code}`,\n      });\n    } catch (err) {\n      // Handle race condition: another wallet grabbed the code between check and insert\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return c.json(\n          {\n            error: {\n              code: \"CODE_TAKEN\",\n              message: \"This referral code is already in use\",\n              retryable: false,\n            },\n          },\n          409,\n        );\n      }\n      logger.error(\"Failed to set referral code\", { err: String(err), wallet });\n      return c.json({ error: \"Failed to set referral code\" }, 500);\n    }\n  });\n\n  return app;\n}\n","numLines":94,"startLine":1,"totalLines":94}}}
