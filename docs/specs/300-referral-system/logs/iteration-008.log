{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Dbi11e6FzUzHrrtYkCRSWp","type":"tool_result","content":"     1→/**\n     2→ * Request authentication middleware.\n     3→ *\n     4→ * Verifies Ed25519 signature over a canonical JSON payload for POST requests.\n     5→ * GET requests pass through without authentication.\n     6→ */\n     7→\n     8→import type { MiddlewareHandler } from \"hono\";\n     9→import nacl from \"tweetnacl\";\n    10→import bs58 from \"bs58\";\n    11→import { logger } from \"../logger.js\";\n    12→\n    13→export interface AuthConfig {\n    14→  /** Maximum allowed clock skew in seconds (default 60). */\n    15→  clockSkewSeconds: number;\n    16→}\n    17→\n    18→/**\n    19→ * Creates a Hono middleware that authenticates POST requests by verifying an\n    20→ * Ed25519 wallet signature over the canonical payload:\n    21→ *   JSON.stringify({ wallet, amountLamports, side, timestamp })\n    22→ *\n    23→ * GET requests are passed through without authentication.\n    24→ */\n    25→export function createAuthMiddleware(config: AuthConfig): MiddlewareHandler {\n    26→  return async (c, next) => {\n    27→    // Skip authentication for GET (and other non-POST) requests\n    28→    if (c.req.method !== \"POST\") {\n    29→      return next();\n    30→    }\n    31→\n    32→    let body: Record<string, unknown>;\n    33→    try {\n    34→      body = await c.req.json();\n    35→    } catch {\n    36→      logger.warn(\"auth rejected: invalid json body\", {\n    37→        path: c.req.path,\n    38→      });\n    39→      return c.json({ error: \"Invalid JSON body\" }, 400);\n    40→    }\n    41→\n    42→    const { wallet, amountLamports, side, timestamp, signature } = body;\n    43→\n    44→    // Require all auth-relevant fields\n    45→    if (\n    46→      typeof wallet !== \"string\" ||\n    47→      typeof signature !== \"string\" ||\n    48→      typeof timestamp !== \"number\"\n    49→    ) {\n    50→      logger.warn(\"auth rejected: missing or invalid fields\", {\n    51→        path: c.req.path,\n    52→        wallet: typeof wallet === \"string\" ? wallet : undefined,\n    53→      });\n    54→      return c.json({ error: \"Missing or invalid authentication fields\" }, 401);\n    55→    }\n    56→\n    57→    // Check timestamp freshness (replay protection)\n    58→    const nowSeconds = Math.floor(Date.now() / 1000);\n    59→    if (Math.abs(nowSeconds - timestamp) > config.clockSkewSeconds) {\n    60→      logger.warn(\"auth rejected: timestamp expired\", {\n    61→        path: c.req.path,\n    62→        wallet,\n    63→        requestTimestamp: timestamp,\n    64→        nowSeconds,\n    65→        allowedClockSkewSeconds: config.clockSkewSeconds,\n    66→      });\n    67→      return c.json({ error: \"Request timestamp expired\" }, 401);\n    68→    }\n    69→\n    70→    // Canonical payload — keys in exact specified order\n    71→    const canonical = JSON.stringify({ wallet, amountLamports, side, timestamp });\n    72→    const messageBytes = new TextEncoder().encode(canonical);\n    73→\n    74→    // Decode signature (base58) and public key (base58)\n    75→    let sigBytes: Uint8Array;\n    76→    let pubkeyBytes: Uint8Array;\n    77→    try {\n    78→      sigBytes = bs58.decode(signature);\n    79→      pubkeyBytes = bs58.decode(wallet);\n    80→    } catch {\n    81→      logger.warn(\"auth rejected: invalid base58 encoding\", {\n    82→        path: c.req.path,\n    83→        wallet,\n    84→      });\n    85→      return c.json({ error: \"Invalid signature or wallet encoding\" }, 401);\n    86→    }\n    87→\n    88→    // Ed25519 signatures are 64 bytes, public keys are 32 bytes\n    89→    if (sigBytes.length !== 64 || pubkeyBytes.length !== 32) {\n    90→      logger.warn(\"auth rejected: invalid signature or wallet length\", {\n    91→        path: c.req.path,\n    92→        wallet,\n    93→        signatureLength: sigBytes.length,\n    94→        walletLength: pubkeyBytes.length,\n    95→      });\n    96→      return c.json({ error: \"Invalid signature or wallet length\" }, 401);\n    97→    }\n    98→\n    99→    // Verify Ed25519 signature\n   100→    const valid = nacl.sign.detached.verify(messageBytes, sigBytes, pubkeyBytes);\n   101→    if (!valid) {\n   102→      logger.warn(\"auth rejected: signature verification failed\", {\n   103→        path: c.req.path,\n   104→        wallet,\n   105→      });\n   106→      return c.json({ error: \"Invalid signature\" }, 401);\n   107→    }\n   108→\n   109→    return next();\n   110→  };\n   111→}\n   112→"}]},"parent_tool_use_id":"toolu_01VCdhEkVHxr9GNyPLZrZRLq","session_id":"91d95e74-c305-4801-b7f4-b036b613409b","uuid":"f417be11-d756-490e-9c9f-0950b322c61c","timestamp":"2026-03-25T11:56:35.484Z"}
