{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0192K16RVmksHTCzd1oziTem","type":"tool_result","content":"     1→/**\n     2→ * JWT Bearer token authentication middleware.\n     3→ *\n     4→ * Verifies HS256 JWT access tokens on POST requests.\n     5→ * Sets c.set(\"wallet\", payload.sub) for downstream handlers.\n     6→ * GET requests pass through without authentication.\n     7→ */\n     8→\n     9→import { createMiddleware } from \"hono/factory\";\n    10→import { jwtVerify } from \"jose\";\n    11→import { logger } from \"../logger.js\";\n    12→import type { AppEnv } from \"../hono-env.js\";\n    13→\n    14→export interface JwtAuthConfig {\n    15→  jwtSecret: Uint8Array;\n    16→  /** When true, require JWT for all HTTP methods (not just POST). Default: false */\n    17→  requireAllMethods?: boolean;\n    18→}\n    19→\n    20→export function createJwtAuthMiddleware(config: JwtAuthConfig) {\n    21→  return createMiddleware<AppEnv>(async (c, next) => {\n    22→    // Skip authentication for non-POST requests (GET, OPTIONS, etc.)\n    23→    // unless requireAllMethods is set (e.g., profile endpoints)\n    24→    if (!config.requireAllMethods && c.req.method !== \"POST\") {\n    25→      return next();\n    26→    }\n    27→\n    28→    const authHeader = c.req.header(\"Authorization\");\n    29→    if (!authHeader || !authHeader.startsWith(\"Bearer \")) {\n    30→      logger.warn(\"jwt auth rejected: missing or invalid Authorization header\", {\n    31→        path: c.req.path,\n    32→      });\n    33→      return c.json({ error: \"Missing or invalid Authorization header\" }, 401);\n    34→    }\n    35→\n    36→    const token = authHeader.slice(7);\n    37→    try {\n    38→      const { payload } = await jwtVerify(token, config.jwtSecret, {\n    39→        algorithms: [\"HS256\"],\n    40→      });\n    41→\n    42→      if (typeof payload.sub !== \"string\") {\n    43→        logger.warn(\"jwt auth rejected: missing sub claim\", {\n    44→          path: c.req.path,\n    45→        });\n    46→        return c.json({ error: \"Invalid token: missing subject\" }, 401);\n    47→      }\n    48→\n    49→      c.set(\"wallet\", payload.sub);\n    50→      return next();\n    51→    } catch (err) {\n    52→      logger.warn(\"jwt auth rejected: token verification failed\", {\n    53→        path: c.req.path,\n    54→        error: err instanceof Error ? err.message : \"Unknown error\",\n    55→      });\n    56→      return c.json({ error: \"Invalid or expired token\" }, 401);\n    57→    }\n    58→  });\n    59→}\n    60→"}]},"parent_tool_use_id":"toolu_01VCdhEkVHxr9GNyPLZrZRLq","session_id":"91d95e74-c305-4801-b7f4-b036b613409b","uuid":"34151f7f-cc1e-4b82-87b4-b36ad0d5b734","timestamp":"2026-03-25T11:56:34.613Z"}
