{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Tzo3atviLGm5aFYRkxYjyk","type":"tool_result","content":"     1→/**\n     2→ * GET /health — operational health endpoint.\n     3→ *\n     4→ * Returns service version, server pubkey, SOL balance, DB connectivity,\n     5→ * worker running status, unsettled round count, and oldest unsettled age.\n     6→ */\n     7→\n     8→import { Hono } from \"hono\";\n     9→import { Connection, type PublicKey } from \"@solana/web3.js\";\n    10→import type postgres from \"postgres\";\n    11→import type { Db } from \"../db.js\";\n    12→import { getQueueDepth } from \"../queue/health.js\";\n    13→import { logger } from \"../logger.js\";\n    14→\n    15→export interface HealthDeps {\n    16→  db: Db;\n    17→  sql: postgres.Sql;\n    18→  connection: Connection;\n    19→  serverKey: PublicKey;\n    20→  isWorkerRunning: () => boolean;\n    21→  minSolBalance: number;\n    22→}\n    23→\n    24→export function createHealthRoutes(deps: HealthDeps): Hono {\n    25→  const { db, sql, connection, serverKey, isWorkerRunning, minSolBalance } = deps;\n    26→  const app = new Hono();\n    27→\n    28→  app.get(\"/\", async (c) => {\n    29→    // Optional flags — extended queries are opt-in so unauthenticated\n    30→    // polling (load balancers, uptime bots) doesn't hit the DB unnecessarily.\n    31→    const verbose = c.req.query(\"verbose\") === \"1\";\n    32→\n    33→    let dbConnected = false;\n    34→    let unsettledCount = 0;\n    35→    let oldestUnsettledAge = 0;\n    36→\n    37→    // Check DB connectivity + query unsettled stats\n    38→    try {\n    39→      const stats = await db.getUnsettledStats();\n    40→      dbConnected = true;\n    41→      unsettledCount = stats.count;\n    42→      oldestUnsettledAge = stats.oldestAgeSeconds;\n    43→    } catch {\n    44→      dbConnected = false;\n    45→    }\n    46→\n    47→    // Get SOL balance of server keypair\n    48→    let solBalance = 0;\n    49→    try {\n    50→      const lamports = await connection.getBalance(serverKey);\n    51→      solBalance = lamports / 1e9;\n    52→    } catch {\n    53→      // If RPC fails, report 0\n    54→    }\n    55→\n    56→    // Warn if SOL balance is below threshold\n    57→    if (solBalance < minSolBalance) {\n    58→      logger.warn(\"Server SOL balance below threshold\", {\n    59→        solBalance,\n    60→        threshold: minSolBalance,\n    61→        serverKey: serverKey.toBase58(),\n    62→      });\n    63→    }\n    64→\n    65→    const response: Record<string, unknown> = {\n    66→      status: \"ok\",\n    67→      version: \"0.1.0\",\n    68→      serverKey: serverKey.toBase58(),\n    69→      solBalance,\n    70→      dbConnected,\n    71→      workerRunning: isWorkerRunning(),\n    72→      unsettledCount,\n    73→      oldestUnsettledAge,\n    74→    };\n    75→\n    76→    // Event queue depth — only when ?verbose=1 (extra DB query)\n    77→    if (verbose) {\n    78→      try {\n    79→        response.eventQueue = await getQueueDepth(sql);\n    80→      } catch {\n    81→        response.eventQueue = { pending: 0, processing: 0, dead: 0, completed: 0 };\n    82→      }\n    83→    }\n    84→\n    85→    return c.json(response);\n    86→  });\n    87→\n    88→  return app;\n    89→}\n    90→"}]},"parent_tool_use_id":"toolu_01VCdhEkVHxr9GNyPLZrZRLq","session_id":"91d95e74-c305-4801-b7f4-b036b613409b","uuid":"1147edf0-1fd5-4e22-bf92-ba8be26b89a6","timestamp":"2026-03-25T11:56:24.377Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SbY2xM6yhnEtJFKhjAK3kV","type":"tool_result","content":"     1→/**\n     2→ * Price routes — cached SOL/USD price from Pyth Hermes.\n     3→ */\n     4→\n     5→import { Hono } from \"hono\";\n     6→import { HermesClient } from \"@pythnetwork/hermes-client\";\n     7→import { logger } from \"../logger.js\";\n     8→\n     9→// SOL/USD Pyth feed ID (same on mainnet + devnet)\n    10→const SOL_USD_FEED_ID =\n    11→  \"0xef0d8b6fda2ceba41da15d4095d1da392a0d2f8ed0c6c7bc0f4cfac8c280b56d\";\n    12→\n    13→const CACHE_TTL_MS = 60_000; // 60 seconds\n    14→\n    15→interface CachedPrice {\n    16→  price: number;\n    17→  expo: number;\n    18→  updatedAt: string;\n    19→  fetchedAt: number; // Date.now() for TTL check\n    20→}\n    21→\n    22→let cached: CachedPrice | null = null;\n    23→\n    24→const client = new HermesClient(\"https://hermes.pyth.network\", {});\n    25→\n    26→async function fetchSolPrice(): Promise<CachedPrice | null> {\n    27→  // Return cached if still fresh\n    28→  if (cached && Date.now() - cached.fetchedAt < CACHE_TTL_MS) {\n    29→    return cached;\n    30→  }\n    31→\n    32→  try {\n    33→    const updates = await client.getLatestPriceUpdates([SOL_USD_FEED_ID], {\n    34→      encoding: \"base64\",\n    35→      parsed: true,\n    36→    });\n    37→    const feed = updates.parsed?.[0];\n    38→    if (!feed?.price) return cached; // stale cache better than nothing\n    39→\n    40→    const price = Number(feed.price.price) * Math.pow(10, feed.price.expo);\n    41→    const expo = feed.price.expo;\n    42→    const updatedAt = new Date(feed.price.publish_time * 1000).toISOString();\n    43→\n    44→    cached = { price, expo, updatedAt, fetchedAt: Date.now() };\n    45→    return cached;\n    46→  } catch (err) {\n    47→    logger.warn(\"hermes: SOL/USD fetch failed\", {\n    48→      error: err instanceof Error ? err.message : String(err),\n    49→    });\n    50→    return cached; // return stale cache on error\n    51→  }\n    52→}\n    53→\n    54→export function createPriceRoutes() {\n    55→  const app = new Hono();\n    56→\n    57→  app.get(\"/sol-usd\", async (c) => {\n    58→    const result = await fetchSolPrice();\n    59→    if (!result) {\n    60→      return c.json({ error: \"Price unavailable\" }, 503);\n    61→    }\n    62→    return c.json({\n    63→      price: result.price,\n    64→      expo: result.expo,\n    65→      updatedAt: result.updatedAt,\n    66→    });\n    67→  });\n    68→\n    69→  return app;\n    70→}\n    71→"}]},"parent_tool_use_id":"toolu_01VCdhEkVHxr9GNyPLZrZRLq","session_id":"91d95e74-c305-4801-b7f4-b036b613409b","uuid":"a8e44b9c-5b0d-4351-8704-eb6f3d4f301f","timestamp":"2026-03-25T11:56:24.399Z"}
