{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QPPfYZGtkLWX5Yqm4zV7zf","type":"tool_result","content":"     1→/**\n     2→ * Database client module — typed query functions for `rounds` and `operator_events`.\n     3→ *\n     4→ * Phase transitions are unidirectional: created → locked → settling → settled,\n     5→ * or created → expired. The application layer rejects backward transitions.\n     6→ */\n     7→\n     8→import postgres from \"postgres\";\n     9→\n    10→// ---------------------------------------------------------------------------\n    11→// Types\n    12→// ---------------------------------------------------------------------------\n    13→\n    14→export type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    15→\n    16→export type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n    17→export type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n    18→\n    19→export interface CloseCallRound {\n    20→  round_id: string;\n    21→  pda: string;\n    22→  server_key: string;\n    23→  phase: CloseCallPhase;\n    24→  open_price: number;\n    25→  open_price_expo: number;\n    26→  close_price: number | null;\n    27→  outcome: CloseCallOutcome;\n    28→  green_pool: number;\n    29→  red_pool: number;\n    30→  total_fee: number;\n    31→  green_entries: Array<{ player: string; amountLamports: number }>;\n    32→  red_entries: Array<{ player: string; amountLamports: number }>;\n    33→  settle_tx: string | null;\n    34→  created_at: Date;\n    35→  settled_at: Date | null;\n    36→}\n    37→\n    38→export interface InsertCloseCallRoundParams {\n    39→  roundId: string;\n    40→  pda: string;\n    41→  serverKey: string;\n    42→  openPrice: number;\n    43→  openPriceExpo: number;\n    44→}\n    45→\n    46→export type OperatorEventType =\n    47→  | \"secret_generated\"\n    48→  | \"tx_built\"\n    49→  | \"match_detected\"\n    50→  | \"settle_submitted\"\n    51→  | \"settle_confirmed\"\n    52→  | \"settle_failed\"\n    53→  | \"settle_retried\"\n    54→  | \"timeout_detected\";\n    55→\n    56→export interface Round {\n    57→  pda: string;\n    58→  game: string;\n    59→  creator: string;\n    60→  server_key: string;\n    61→  secret: Buffer;\n    62→  commitment: Buffer;\n    63→  amount_lamports: number;\n    64→  side: number;\n    65→  match_id: string;\n    66→  phase: RoundPhase;\n    67→  target_slot: string | null;\n    68→  settle_tx: string | null;\n    69→  settle_attempts: number;\n    70→  result_hash: Buffer | null;\n    71→  result_side: number | null;\n    72→  winner: string | null;\n    73→  entries: unknown | null;\n    74→  created_at: Date;\n    75→  updated_at: Date;\n    76→}\n    77→\n    78→export interface InsertRoundParams {\n    79→  pda: string;\n    80→  game: string;\n    81→  creator: string;\n    82→  serverKey: string;\n    83→  secret: Buffer;\n    84→  commitment: Buffer;\n    85→  amountLamports: number;\n    86→  side: number;\n    87→  matchId: string;\n    88→  phase: RoundPhase;\n    89→  entries?: Array<{ player: string; amountLamports: number }>;\n    90→}\n    91→\n    92→export interface OperatorEvent {\n    93→  id: string;\n    94→  pda: string | null;\n    95→  event_type: OperatorEventType;\n    96→  payload: unknown;\n    97→  created_at: Date;\n    98→}\n    99→\n   100→// ---------------------------------------------------------------------------\n   101→// Transaction types\n   102→// ---------------------------------------------------------------------------\n   103→\n   104→export type TransactionType = \"deposit\" | \"payout\" | \"refund\";\n   105→\n   106→export interface Transaction {\n   107→  id: string;\n   108→  wallet: string;\n   109→  game: string;\n   110→  match_id: string;\n   111→  tx_type: TransactionType;\n   112→  amount_lamports: number;\n   113→  tx_sig: string;\n   114→  created_at: Date;\n   115→}\n   116→\n   117→export interface InsertTransactionParams {\n   118→  wallet: string;\n   119→  game: string;\n   120→  matchId: string;\n   121→  txType: TransactionType;\n   122→  amountLamports: number;\n   123→  txSig: string;\n   124→}\n   125→\n   126→// ---------------------------------------------------------------------------\n   127→// Phase transition guard\n   128→// ---------------------------------------------------------------------------\n   129→\n   130→/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n   131→const VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n   132→  created: [\"locked\", \"expired\"],\n   133→  locked: [\"settling\"],\n   134→  settling: [\"settled\"],\n   135→  settled: [],\n   136→  expired: [],\n   137→};\n   138→\n   139→function assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n   140→  const allowed = VALID_TRANSITIONS[from];\n   141→  if (!allowed.includes(to)) {\n   142→    throw new Error(\n   143→      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n   144→    );\n   145→  }\n   146→}\n   147→\n   148→// ---------------------------------------------------------------------------\n   149→// DB client\n   150→// ---------------------------------------------------------------------------\n   151→\n   152→export interface Db {\n   153→  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n   154→  insertRound(params: InsertRoundParams): Promise<Round>;\n   155→\n   156→  /** Delete a round by PDA. Returns true if a row was removed. */\n   157→  deleteRoundByPda(pda: string): Promise<boolean>;\n   158→\n   159→  /** Transition a round's phase. Enforces unidirectional state machine.\n   160→   *  Optional `updates` can set additional columns alongside the phase change. */\n   161→  updateRoundPhase(\n   162→    pda: string,\n   163→    newPhase: RoundPhase,\n   164→    updates?: Partial<\n   165→      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n   166→    >,\n   167→  ): Promise<Round>;\n   168→\n   169→  /** Update the entries JSONB column for a settled round. */\n   170→  updateRoundEntries(\n   171→    pda: string,\n   172→    entries: Array<{ player: string; amountLamports: number }>,\n   173→  ): Promise<Round>;\n   174→\n   175→  /** Get a single round by its PDA. Returns `undefined` if not found. */\n   176→  getRoundByPda(pda: string): Promise<Round | undefined>;\n   177→\n   178→  /** Get all rounds matching a given phase. */\n   179→  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n   180→\n   181→  /** Append an operator event to the audit log. */\n   182→  insertOperatorEvent(\n   183→    pda: string | null,\n   184→    eventType: OperatorEventType,\n   185→    payload?: unknown,\n   186→  ): Promise<OperatorEvent>;\n   187→\n   188→  /** Get the latest operator event for a PDA + type. */\n   189→  getLatestOperatorEvent(\n   190→    pda: string,\n   191→    eventType: OperatorEventType,\n   192→  ): Promise<OperatorEvent | undefined>;\n   193→\n   194→  /** Get a single round by its match_id. Returns `undefined` if not found. */\n   195→  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n   196→\n   197→  /** Batch-fetch the latest operator event per PDA for a given event type. */\n   198→  getLatestOperatorEventsForPdas(\n   199→    pdas: string[],\n   200→    eventType: OperatorEventType,\n   201→  ): Promise<Map<string, OperatorEvent>>;\n   202→\n   203→  /** Get recently settled rounds for a game, ordered newest first. */\n   204→  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n   205→\n   206→  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n   207→  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n   208→\n   209→  // -------------------------------------------------------------------------\n   210→  // Close Call rounds\n   211→  // -------------------------------------------------------------------------\n   212→\n   213→  /** Insert a new Close Call round. */\n   214→  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n   215→\n   216→  /** Get a Close Call round by round_id (16-char hex). */\n   217→  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n   218→\n   219→  /** Get the current active (open) Close Call round. */\n   220→  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n   221→\n   222→  /** Get the most recent settled/refunded Close Call rounds. */\n   223→  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n   224→\n   225→  /** Update a Close Call round after settlement. */\n   226→  settleCloseCallRound(\n   227→    roundId: string,\n   228→    updates: {\n   229→      phase: CloseCallPhase;\n   230→      outcome: CloseCallOutcome;\n   231→      closePrice?: number;\n   232→      greenPool?: number;\n   233→      redPool?: number;\n   234→      totalFee?: number;\n   235→      greenEntries?: Array<{ player: string; amountLamports: number }>;\n   236→      redEntries?: Array<{ player: string; amountLamports: number }>;\n   237→      settleTx?: string;\n   238→    },\n   239→  ): Promise<CloseCallRound>;\n   240→\n   241→  // -------------------------------------------------------------------------\n   242→  // Transactions\n   243→  // -------------------------------------------------------------------------\n   244→\n   245→  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n   246→  insertTransaction(params: InsertTransactionParams): Promise<void>;\n   247→\n   248→  /** Insert multiple transactions in a single batch. */\n   249→  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n   250→\n   251→  /** Get paginated transactions for a wallet, newest first. */\n   252→  getTransactions(\n   253→    wallet: string,\n   254→    cursor?: string,\n   255→    limit?: number,\n   256→    game?: string,\n   257→  ): Promise<Transaction[]>;\n   258→\n   259→  /** Gracefully close the connection pool. */\n   260→  close(): Promise<void>;\n   261→}\n   262→\n   263→function normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n   264→  return {\n   265→    ...row,\n   266→    open_price: Number(row.open_price),\n   267→    open_price_expo: Number(row.open_price_expo),\n   268→    close_price: row.close_price === null ? null : Number(row.close_price),\n   269→    green_pool: Number(row.green_pool),\n   270→    red_pool: Number(row.red_pool),\n   271→    total_fee: Number(row.total_fee),\n   272→    // JSONB comes back as parsed objects from postgres.js\n   273→    green_entries: Array.isArray(row.green_entries)\n   274→      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   275→      : [],\n   276→    red_entries: Array.isArray(row.red_entries)\n   277→      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   278→      : [],\n   279→  };\n   280→}\n   281→\n   282→function normalizeTransaction(row: Transaction): Transaction {\n   283→  return {\n   284→    ...row,\n   285→    amount_lamports: Number(row.amount_lamports),\n   286→  };\n   287→}\n   288→\n   289→function normalizeRound(row: Round): Round {\n   290→  return {\n   291→    ...row,\n   292→    amount_lamports: Number(row.amount_lamports),\n   293→    side: Number(row.side),\n   294→    settle_attempts: Number(row.settle_attempts),\n   295→    result_side: row.result_side === null ? null : Number(row.result_side),\n   296→    // JSONB comes back as parsed objects from postgres.js\n   297→    entries: Array.isArray(row.entries)\n   298→      ? (row.entries as Array<{ player: string; amountLamports: number }>).map((e) => ({\n   299→          player: e.player,\n   300→          amountLamports: Number(e.amountLamports),\n   301→        }))\n   302→      : null,\n   303→  };\n   304→}\n   305→\n   306→export function createDb(databaseUrl: string): Db {\n   307→  const sql = postgres(databaseUrl);\n   308→\n   309→  return {\n   310→    async insertRound(params) {\n   311→      const rows = await sql<Round[]>`\n   312→        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase, entries)\n   313→        VALUES (\n   314→          ${params.pda},\n   315→          ${params.game},\n   316→          ${params.creator},\n   317→          ${params.serverKey},\n   318→          ${params.secret},\n   319→          ${params.commitment},\n   320→          ${params.amountLamports},\n   321→          ${params.side},\n   322→          ${params.matchId},\n   323→          ${params.phase},\n   324→          ${params.entries ? sql.json(params.entries) : null}\n   325→        )\n   326→        RETURNING *\n   327→      `;\n   328→      return normalizeRound(rows[0]!);\n   329→    },\n   330→\n   331→    async deleteRoundByPda(pda) {\n   332→      const rows = await sql<{ pda: string }[]>`\n   333→        DELETE FROM rounds WHERE pda = ${pda}\n   334→        RETURNING pda\n   335→      `;\n   336→      return rows.length > 0;\n   337→    },\n   338→\n   339→    async updateRoundPhase(pda, newPhase, updates) {\n   340→      // Fetch current phase to validate transition\n   341→      const current = await sql<Pick<Round, \"phase\">[]>`\n   342→        SELECT phase FROM rounds WHERE pda = ${pda}\n   343→      `;\n   344→\n   345→      if (current.length === 0) {\n   346→        throw new Error(`Round not found: ${pda}`);\n   347→      }\n   348→\n   349→      const currentPhase = current[0]!.phase as RoundPhase;\n   350→      assertPhaseTransition(currentPhase, newPhase);\n   351→\n   352→      // Build the update — always set phase + updated_at\n   353→      const rows = await sql<Round[]>`\n   354→        UPDATE rounds SET\n   355→          phase = ${newPhase},\n   356→          updated_at = now(),\n   357→          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n   358→          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n   359→          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n   360→          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n   361→          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n   362→          winner = COALESCE(${updates?.winner ?? null}, winner)\n   363→        WHERE pda = ${pda}\n   364→        RETURNING *\n   365→      `;\n   366→\n   367→      return normalizeRound(rows[0]!);\n   368→    },\n   369→\n   370→    async updateRoundEntries(pda, entries) {\n   371→      const rows = await sql<Round[]>`\n   372→        UPDATE rounds SET\n   373→          entries = ${sql.json(entries)},\n   374→          updated_at = now()\n   375→        WHERE pda = ${pda}\n   376→        RETURNING *\n   377→      `;\n   378→      if (rows.length === 0) {\n   379→        throw new Error(`Round not found: ${pda}`);\n   380→      }\n   381→      return normalizeRound(rows[0]!);\n   382→    },\n   383→\n   384→    async getRoundByPda(pda) {\n   385→      const rows = await sql<Round[]>`\n   386→        SELECT * FROM rounds WHERE pda = ${pda}\n   387→      `;\n   388→      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   389→    },\n   390→\n   391→    async getRoundByMatchId(matchId) {\n   392→      const rows = await sql<Round[]>`\n   393→        SELECT * FROM rounds WHERE match_id = ${matchId}\n   394→      `;\n   395→      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   396→    },\n   397→\n   398→    async getRoundsByPhase(phase) {\n   399→      const rows = await sql<Round[]>`\n   400→        SELECT * FROM rounds WHERE phase = ${phase}\n   401→      `;\n   402→      return rows.map(normalizeRound);\n   403→    },\n   404→\n   405→    async insertOperatorEvent(pda, eventType, payload) {\n   406→      const rows = await sql<OperatorEvent[]>`\n   407→        INSERT INTO operator_events (pda, event_type, payload)\n   408→        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n   409→        RETURNING *\n   410→      `;\n   411→      return rows[0]!;\n   412→    },\n   413→\n   414→    async getLatestOperatorEvent(pda, eventType) {\n   415→      const rows = await sql<OperatorEvent[]>`\n   416→        SELECT * FROM operator_events\n   417→        WHERE pda = ${pda} AND event_type = ${eventType}\n   418→        ORDER BY id DESC\n   419→        LIMIT 1\n   420→      `;\n   421→      return rows[0];\n   422→    },\n   423→\n   424→    async getLatestOperatorEventsForPdas(pdas, eventType) {\n   425→      if (pdas.length === 0) return new Map();\n   426→      const rows = await sql<OperatorEvent[]>`\n   427→        SELECT DISTINCT ON (pda) *\n   428→        FROM operator_events\n   429→        WHERE pda = ANY(${pdas}) AND event_type = ${eventType}\n   430→        ORDER BY pda, id DESC\n   431→      `;\n   432→      const map = new Map<string, OperatorEvent>();\n   433→      for (const row of rows) {\n   434→        if (row.pda) map.set(row.pda, row);\n   435→      }\n   436→      return map;\n   437→    },\n   438→\n   439→    async getRecentSettledRounds(game, limit) {\n   440→      const rows = await sql<Round[]>`\n   441→        SELECT * FROM rounds\n   442→        WHERE game = ${game} AND phase = 'settled'\n   443→        ORDER BY updated_at DESC\n   444→        LIMIT ${limit}\n   445→      `;\n   446→      return rows.map(normalizeRound);\n   447→    },\n   448→\n   449→    async getUnsettledStats() {\n   450→      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n   451→        SELECT\n   452→          COUNT(*)::text AS count,\n   453→          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n   454→        FROM rounds\n   455→        WHERE phase NOT IN ('settled', 'expired')\n   456→      `;\n   457→      const row = rows[0]!;\n   458→      return {\n   459→        count: parseInt(row.count, 10),\n   460→        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n   461→      };\n   462→    },\n   463→\n   464→    // -----------------------------------------------------------------------\n   465→    // Close Call rounds\n   466→    // -----------------------------------------------------------------------\n   467→\n   468→    async insertCloseCallRound(params) {\n   469→      const rows = await sql<CloseCallRound[]>`\n   470→        INSERT INTO closecall_rounds (round_id, pda, server_key, open_price, open_price_expo)\n   471→        VALUES (\n   472→          ${params.roundId},\n   473→          ${params.pda},\n   474→          ${params.serverKey},\n   475→          ${params.openPrice},\n   476→          ${params.openPriceExpo}\n   477→        )\n   478→        RETURNING *\n   479→      `;\n   480→      return normalizeCloseCallRound(rows[0]!);\n   481→    },\n   482→\n   483→    async getCloseCallRound(roundId) {\n   484→      const rows = await sql<CloseCallRound[]>`\n   485→        SELECT * FROM closecall_rounds WHERE round_id = ${roundId}\n   486→      `;\n   487→      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n   488→    },\n   489→\n   490→    async getCloseCallCurrentRound() {\n   491→      const rows = await sql<CloseCallRound[]>`\n   492→        SELECT * FROM closecall_rounds\n   493→        WHERE phase = 'open'\n   494→        ORDER BY created_at DESC\n   495→        LIMIT 1\n   496→      `;\n   497→      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n   498→    },\n   499→\n   500→    async getCloseCallHistory(limit) {\n   501→      const rows = await sql<CloseCallRound[]>`\n   502→        SELECT * FROM closecall_rounds\n   503→        WHERE phase IN ('settled', 'refunded')\n   504→        ORDER BY settled_at DESC\n   505→        LIMIT ${limit}\n   506→      `;\n   507→      return rows.map(normalizeCloseCallRound);\n   508→    },\n   509→\n   510→    async settleCloseCallRound(roundId, updates) {\n   511→      const rows = await sql<CloseCallRound[]>`\n   512→        UPDATE closecall_rounds SET\n   513→          phase = ${updates.phase},\n   514→          outcome = ${updates.outcome},\n   515→          close_price = COALESCE(${updates.closePrice ?? null}, close_price),\n   516→          green_pool = COALESCE(${updates.greenPool ?? null}, green_pool),\n   517→          red_pool = COALESCE(${updates.redPool ?? null}, red_pool),\n   518→          total_fee = COALESCE(${updates.totalFee ?? null}, total_fee),\n   519→          green_entries = COALESCE(${updates.greenEntries ? sql.json(updates.greenEntries) : null}, green_entries),\n   520→          red_entries = COALESCE(${updates.redEntries ? sql.json(updates.redEntries) : null}, red_entries),\n   521→          settle_tx = COALESCE(${updates.settleTx ?? null}, settle_tx),\n   522→          settled_at = now()\n   523→        WHERE round_id = ${roundId}\n   524→        RETURNING *\n   525→      `;\n   526→      if (rows.length === 0) {\n   527→        throw new Error(`Close Call round not found: ${roundId}`);\n   528→      }\n   529→      return normalizeCloseCallRound(rows[0]!);\n   530→    },\n   531→\n   532→    // -----------------------------------------------------------------------\n   533→    // Transactions\n   534→    // -----------------------------------------------------------------------\n   535→\n   536→    async insertTransaction(params) {\n   537→      await sql`\n   538→        INSERT INTO transactions (wallet, game, match_id, tx_type, amount_lamports, tx_sig)\n   539→        VALUES (\n   540→          ${params.wallet},\n   541→          ${params.game},\n   542→          ${params.matchId},\n   543→          ${params.txType},\n   544→          ${params.amountLamports},\n   545→          ${params.txSig}\n   546→        )\n   547→        ON CONFLICT DO NOTHING\n   548→      `;\n   549→    },\n   550→\n   551→    async insertTransactions(params) {\n   552→      if (params.length === 0) return;\n   553→      const values = params.map((p) => ({\n   554→        wallet: p.wallet,\n   555→        game: p.game,\n   556→        match_id: p.matchId,\n   557→        tx_type: p.txType,\n   558→        amount_lamports: p.amountLamports,\n   559→        tx_sig: p.txSig,\n   560→      }));\n   561→      await sql`\n   562→        INSERT INTO transactions ${sql(values, \"wallet\", \"game\", \"match_id\", \"tx_type\", \"amount_lamports\", \"tx_sig\")}\n   563→        ON CONFLICT DO NOTHING\n   564→      `;\n   565→    },\n   566→\n   567→    async getTransactions(wallet, cursor, limit = 20, game) {\n   568→      const effectiveLimit = Math.min(limit, 50);\n   569→      if (cursor && game) {\n   570→        const rows = await sql<Transaction[]>`\n   571→          SELECT * FROM transactions\n   572→          WHERE wallet = ${wallet} AND id < ${cursor} AND game = ${game}\n   573→          ORDER BY id DESC\n   574→          LIMIT ${effectiveLimit}\n   575→        `;\n   576→        return rows.map(normalizeTransaction);\n   577→      }\n   578→      if (cursor) {\n   579→        const rows = await sql<Transaction[]>`\n   580→          SELECT * FROM transactions\n   581→          WHERE wallet = ${wallet} AND id < ${cursor}\n   582→          ORDER BY id DESC\n   583→          LIMIT ${effectiveLimit}\n   584→        `;\n   585→        return rows.map(normalizeTransaction);\n   586→      }\n   587→      if (game) {\n   588→        const rows = await sql<Transaction[]>`\n   589→          SELECT * FROM transactions\n   590→          WHERE wallet = ${wallet} AND game = ${game}\n   591→          ORDER BY id DESC\n   592→          LIMIT ${effectiveLimit}\n   593→        `;\n   594→        return rows.map(normalizeTransaction);\n   595→      }\n   596→      const rows = await sql<Transaction[]>`\n   597→        SELECT * FROM transactions\n   598→        WHERE wallet = ${wallet}\n   599→        ORDER BY id DESC\n   600→        LIMIT ${effectiveLimit}\n   601→      `;\n   602→      return rows.map(normalizeTransaction);\n   603→    },\n   604→\n   605→    async close() {\n   606→      await sql.end();\n   607→    },\n   608→  };\n   609→}\n   610→"}]},"parent_tool_use_id":null,"session_id":"743710ba-7b6c-4e0b-9643-b380efda39b4","uuid":"06d60a69-96fd-4eef-9b57-51fb21486e6b","timestamp":"2026-03-25T09:07:51.782Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/db.ts","content":"/**\n * Database client module — typed query functions for `rounds` and `operator_events`.\n *\n * Phase transitions are unidirectional: created → locked → settling → settled,\n * or created → expired. The application layer rejects backward transitions.\n */\n\nimport postgres from \"postgres\";\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n\nexport type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\nexport type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n\nexport interface CloseCallRound {\n  round_id: string;\n  pda: string;\n  server_key: string;\n  phase: CloseCallPhase;\n  open_price: number;\n  open_price_expo: number;\n  close_price: number | null;\n  outcome: CloseCallOutcome;\n  green_pool: number;\n  red_pool: number;\n  total_fee: number;\n  green_entries: Array<{ player: string; amountLamports: number }>;\n  red_entries: Array<{ player: string; amountLamports: number }>;\n  settle_tx: string | null;\n  created_at: Date;\n  settled_at: Date | null;\n}\n\nexport interface InsertCloseCallRoundParams {\n  roundId: string;\n  pda: string;\n  serverKey: string;\n  openPrice: number;\n  openPriceExpo: number;\n}\n\nexport type OperatorEventType =\n  | \"secret_generated\"\n  | \"tx_built\"\n  | \"match_detected\"\n  | \"settle_submitted\"\n  | \"settle_confirmed\"\n  | \"settle_failed\"\n  | \"settle_retried\"\n  | \"timeout_detected\";\n\nexport interface Round {\n  pda: string;\n  game: string;\n  creator: string;\n  server_key: string;\n  secret: Buffer;\n  commitment: Buffer;\n  amount_lamports: number;\n  side: number;\n  match_id: string;\n  phase: RoundPhase;\n  target_slot: string | null;\n  settle_tx: string | null;\n  settle_attempts: number;\n  result_hash: Buffer | null;\n  result_side: number | null;\n  winner: string | null;\n  entries: unknown | null;\n  created_at: Date;\n  updated_at: Date;\n}\n\nexport interface InsertRoundParams {\n  pda: string;\n  game: string;\n  creator: string;\n  serverKey: string;\n  secret: Buffer;\n  commitment: Buffer;\n  amountLamports: number;\n  side: number;\n  matchId: string;\n  phase: RoundPhase;\n  entries?: Array<{ player: string; amountLamports: number }>;\n}\n\nexport interface OperatorEvent {\n  id: string;\n  pda: string | null;\n  event_type: OperatorEventType;\n  payload: unknown;\n  created_at: Date;\n}\n\n// ---------------------------------------------------------------------------\n// Transaction types\n// ---------------------------------------------------------------------------\n\nexport type TransactionType = \"deposit\" | \"payout\" | \"refund\";\n\nexport interface Transaction {\n  id: string;\n  wallet: string;\n  game: string;\n  match_id: string;\n  tx_type: TransactionType;\n  amount_lamports: number;\n  tx_sig: string;\n  created_at: Date;\n}\n\nexport interface InsertTransactionParams {\n  wallet: string;\n  game: string;\n  matchId: string;\n  txType: TransactionType;\n  amountLamports: number;\n  txSig: string;\n}\n\n// ---------------------------------------------------------------------------\n// Phase transition guard\n// ---------------------------------------------------------------------------\n\n/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\nconst VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n  created: [\"locked\", \"expired\"],\n  locked: [\"settling\"],\n  settling: [\"settled\"],\n  settled: [],\n  expired: [],\n};\n\nfunction assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n  const allowed = VALID_TRANSITIONS[from];\n  if (!allowed.includes(to)) {\n    throw new Error(\n      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n    );\n  }\n}\n\n// ---------------------------------------------------------------------------\n// DB client\n// ---------------------------------------------------------------------------\n\nexport interface Db {\n  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n  insertRound(params: InsertRoundParams): Promise<Round>;\n\n  /** Delete a round by PDA. Returns true if a row was removed. */\n  deleteRoundByPda(pda: string): Promise<boolean>;\n\n  /** Transition a round's phase. Enforces unidirectional state machine.\n   *  Optional `updates` can set additional columns alongside the phase change. */\n  updateRoundPhase(\n    pda: string,\n    newPhase: RoundPhase,\n    updates?: Partial<\n      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n    >,\n  ): Promise<Round>;\n\n  /** Update the entries JSONB column for a settled round. */\n  updateRoundEntries(\n    pda: string,\n    entries: Array<{ player: string; amountLamports: number }>,\n  ): Promise<Round>;\n\n  /** Get a single round by its PDA. Returns `undefined` if not found. */\n  getRoundByPda(pda: string): Promise<Round | undefined>;\n\n  /** Get all rounds matching a given phase. */\n  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n\n  /** Append an operator event to the audit log. */\n  insertOperatorEvent(\n    pda: string | null,\n    eventType: OperatorEventType,\n    payload?: unknown,\n  ): Promise<OperatorEvent>;\n\n  /** Get the latest operator event for a PDA + type. */\n  getLatestOperatorEvent(\n    pda: string,\n    eventType: OperatorEventType,\n  ): Promise<OperatorEvent | undefined>;\n\n  /** Get a single round by its match_id. Returns `undefined` if not found. */\n  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n\n  /** Batch-fetch the latest operator event per PDA for a given event type. */\n  getLatestOperatorEventsForPdas(\n    pdas: string[],\n    eventType: OperatorEventType,\n  ): Promise<Map<string, OperatorEvent>>;\n\n  /** Get recently settled rounds for a game, ordered newest first. */\n  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n\n  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n\n  // -------------------------------------------------------------------------\n  // Close Call rounds\n  // -------------------------------------------------------------------------\n\n  /** Insert a new Close Call round. */\n  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n\n  /** Get a Close Call round by round_id (16-char hex). */\n  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n\n  /** Get the current active (open) Close Call round. */\n  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n\n  /** Get the most recent settled/refunded Close Call rounds. */\n  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n\n  /** Update a Close Call round after settlement. */\n  settleCloseCallRound(\n    roundId: string,\n    updates: {\n      phase: CloseCallPhase;\n      outcome: CloseCallOutcome;\n      closePrice?: number;\n      greenPool?: number;\n      redPool?: number;\n      totalFee?: number;\n      greenEntries?: Array<{ player: string; amountLamports: number }>;\n      redEntries?: Array<{ player: string; amountLamports: number }>;\n      settleTx?: string;\n    },\n  ): Promise<CloseCallRound>;\n\n  // -------------------------------------------------------------------------\n  // Transactions\n  // -------------------------------------------------------------------------\n\n  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n  insertTransaction(params: InsertTransactionParams): Promise<void>;\n\n  /** Insert multiple transactions in a single batch. */\n  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n\n  /** Get paginated transactions for a wallet, newest first. */\n  getTransactions(\n    wallet: string,\n    cursor?: string,\n    limit?: number,\n    game?: string,\n  ): Promise<Transaction[]>;\n\n  /** Gracefully close the connection pool. */\n  close(): Promise<void>;\n}\n\nfunction normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n  return {\n    ...row,\n    open_price: Number(row.open_price),\n    open_price_expo: Number(row.open_price_expo),\n    close_price: row.close_price === null ? null : Number(row.close_price),\n    green_pool: Number(row.green_pool),\n    red_pool: Number(row.red_pool),\n    total_fee: Number(row.total_fee),\n    // JSONB comes back as parsed objects from postgres.js\n    green_entries: Array.isArray(row.green_entries)\n      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n      : [],\n    red_entries: Array.isArray(row.red_entries)\n      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n      : [],\n  };\n}\n\nfunction normalizeTransaction(row: Transaction): Transaction {\n  return {\n    ...row,\n    amount_lamports: Number(row.amount_lamports),\n  };\n}\n\nfunction normalizeRound(row: Round): Round {\n  return {\n    ...row,\n    amount_lamports: Number(row.amount_lamports),\n    side: Number(row.side),\n    settle_attempts: Number(row.settle_attempts),\n    result_side: row.result_side === null ? null : Number(row.result_side),\n    // JSONB comes back as parsed objects from postgres.js\n    entries: Array.isArray(row.entries)\n      ? (row.entries as Array<{ player: string; amountLamports: number }>).map((e) => ({\n          player: e.player,\n          amountLamports: Number(e.amountLamports),\n        }))\n      : null,\n  };\n}\n\nexport function createDb(databaseUrl: string): Db {\n  const sql = postgres(databaseUrl);\n\n  return {\n    async insertRound(params) {\n      const rows = await sql<Round[]>`\n        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase, entries)\n        VALUES (\n          ${params.pda},\n          ${params.game},\n          ${params.creator},\n          ${params.serverKey},\n          ${params.secret},\n          ${params.commitment},\n          ${params.amountLamports},\n          ${params.side},\n          ${params.matchId},\n          ${params.phase},\n          ${params.entries ? sql.json(params.entries) : null}\n        )\n        RETURNING *\n      `;\n      return normalizeRound(rows[0]!);\n    },\n\n    async deleteRoundByPda(pda) {\n      const rows = await sql<{ pda: string }[]>`\n        DELETE FROM rounds WHERE pda = ${pda}\n        RETURNING pda\n      `;\n      return rows.length > 0;\n    },\n\n    async updateRoundPhase(pda, newPhase, updates) {\n      // Fetch current phase to validate transition\n      const current = await sql<Pick<Round, \"phase\">[]>`\n        SELECT phase FROM rounds WHERE pda = ${pda}\n      `;\n\n      if (current.length === 0) {\n        throw new Error(`Round not found: ${pda}`);\n      }\n\n      const currentPhase = current[0]!.phase as RoundPhase;\n      assertPhaseTransition(currentPhase, newPhase);\n\n      // Build the update — always set phase + updated_at\n      const rows = await sql<Round[]>`\n        UPDATE rounds SET\n          phase = ${newPhase},\n          updated_at = now(),\n          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n          winner = COALESCE(${updates?.winner ?? null}, winner)\n        WHERE pda = ${pda}\n        RETURNING *\n      `;\n\n      return normalizeRound(rows[0]!);\n    },\n\n    async updateRoundEntries(pda, entries) {\n      const rows = await sql<Round[]>`\n        UPDATE rounds SET\n          entries = ${sql.json(entries)},\n          updated_at = now()\n        WHERE pda = ${pda}\n        RETURNING *\n      `;\n      if (rows.length === 0) {\n        throw new Error(`Round not found: ${pda}`);\n      }\n      return normalizeRound(rows[0]!);\n    },\n\n    async getRoundByPda(pda) {\n      const rows = await sql<Round[]>`\n        SELECT * FROM rounds WHERE pda = ${pda}\n      `;\n      return rows[0] ? normalizeRound(rows[0]) : undefined;\n    },\n\n    async getRoundByMatchId(matchId) {\n      const rows = await sql<Round[]>`\n        SELECT * FROM rounds WHERE match_id = ${matchId}\n      `;\n      return rows[0] ? normalizeRound(rows[0]) : undefined;\n    },\n\n    async getRoundsByPhase(phase) {\n      const rows = await sql<Round[]>`\n        SELECT * FROM rounds WHERE phase = ${phase}\n      `;\n      return rows.map(normalizeRound);\n    },\n\n    async insertOperatorEvent(pda, eventType, payload) {\n      const rows = await sql<OperatorEvent[]>`\n        INSERT INTO operator_events (pda, event_type, payload)\n        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n        RETURNING *\n      `;\n      return rows[0]!;\n    },\n\n    async getLatestOperatorEvent(pda, eventType) {\n      const rows = await sql<OperatorEvent[]>`\n        SELECT * FROM operator_events\n        WHERE pda = ${pda} AND event_type = ${eventType}\n        ORDER BY id DESC\n        LIMIT 1\n      `;\n      return rows[0];\n    },\n\n    async getLatestOperatorEventsForPdas(pdas, eventType) {\n      if (pdas.length === 0) return new Map();\n      const rows = await sql<OperatorEvent[]>`\n        SELECT DISTINCT ON (pda) *\n        FROM operator_events\n        WHERE pda = ANY(${pdas}) AND event_type = ${eventType}\n        ORDER BY pda, id DESC\n      `;\n      const map = new Map<string, OperatorEvent>();\n      for (const row of rows) {\n        if (row.pda) map.set(row.pda, row);\n      }\n      return map;\n    },\n\n    async getRecentSettledRounds(game, limit) {\n      const rows = await sql<Round[]>`\n        SELECT * FROM rounds\n        WHERE game = ${game} AND phase = 'settled'\n        ORDER BY updated_at DESC\n        LIMIT ${limit}\n      `;\n      return rows.map(normalizeRound);\n    },\n\n    async getUnsettledStats() {\n      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n        SELECT\n          COUNT(*)::text AS count,\n          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n        FROM rounds\n        WHERE phase NOT IN ('settled', 'expired')\n      `;\n      const row = rows[0]!;\n      return {\n        count: parseInt(row.count, 10),\n        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n      };\n    },\n\n    // -----------------------------------------------------------------------\n    // Close Call rounds\n    // -----------------------------------------------------------------------\n\n    async insertCloseCallRound(params) {\n      const rows = await sql<CloseCallRound[]>`\n        INSERT INTO closecall_rounds (round_id, pda, server_key, open_price, open_price_expo)\n        VALUES (\n          ${params.roundId},\n          ${params.pda},\n          ${params.serverKey},\n          ${params.openPrice},\n          ${params.openPriceExpo}\n        )\n        RETURNING *\n      `;\n      return normalizeCloseCallRound(rows[0]!);\n    },\n\n    async getCloseCallRound(roundId) {\n      const rows = await sql<CloseCallRound[]>`\n        SELECT * FROM closecall_rounds WHERE round_id = ${roundId}\n      `;\n      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n    },\n\n    async getCloseCallCurrentRound() {\n      const rows = await sql<CloseCallRound[]>`\n        SELECT * FROM closecall_rounds\n        WHERE phase = 'open'\n        ORDER BY created_at DESC\n        LIMIT 1\n      `;\n      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n    },\n\n    async getCloseCallHistory(limit) {\n      const rows = await sql<CloseCallRound[]>`\n        SELECT * FROM closecall_rounds\n        WHERE phase IN ('settled', 'refunded')\n        ORDER BY settled_at DESC\n        LIMIT ${limit}\n      `;\n      return rows.map(normalizeCloseCallRound);\n    },\n\n    async settleCloseCallRound(roundId, updates) {\n      const rows = await sql<CloseCallRound[]>`\n        UPDATE closecall_rounds SET\n          phase = ${updates.phase},\n          outcome = ${updates.outcome},\n          close_price = COALESCE(${updates.closePrice ?? null}, close_price),\n          green_pool = COALESCE(${updates.greenPool ?? null}, green_pool),\n          red_pool = COALESCE(${updates.redPool ?? null}, red_pool),\n          total_fee = COALESCE(${updates.totalFee ?? null}, total_fee),\n          green_entries = COALESCE(${updates.greenEntries ? sql.json(updates.greenEntries) : null}, green_entries),\n          red_entries = COALESCE(${updates.redEntries ? sql.json(updates.redEntries) : null}, red_entries),\n          settle_tx = COALESCE(${updates.settleTx ?? null}, settle_tx),\n          settled_at = now()\n        WHERE round_id = ${roundId}\n        RETURNING *\n      `;\n      if (rows.length === 0) {\n        throw new Error(`Close Call round not found: ${roundId}`);\n      }\n      return normalizeCloseCallRound(rows[0]!);\n    },\n\n    // -----------------------------------------------------------------------\n    // Transactions\n    // -----------------------------------------------------------------------\n\n    async insertTransaction(params) {\n      await sql`\n        INSERT INTO transactions (wallet, game, match_id, tx_type, amount_lamports, tx_sig)\n        VALUES (\n          ${params.wallet},\n          ${params.game},\n          ${params.matchId},\n          ${params.txType},\n          ${params.amountLamports},\n          ${params.txSig}\n        )\n        ON CONFLICT DO NOTHING\n      `;\n    },\n\n    async insertTransactions(params) {\n      if (params.length === 0) return;\n      const values = params.map((p) => ({\n        wallet: p.wallet,\n        game: p.game,\n        match_id: p.matchId,\n        tx_type: p.txType,\n        amount_lamports: p.amountLamports,\n        tx_sig: p.txSig,\n      }));\n      await sql`\n        INSERT INTO transactions ${sql(values, \"wallet\", \"game\", \"match_id\", \"tx_type\", \"amount_lamports\", \"tx_sig\")}\n        ON CONFLICT DO NOTHING\n      `;\n    },\n\n    async getTransactions(wallet, cursor, limit = 20, game) {\n      const effectiveLimit = Math.min(limit, 50);\n      if (cursor && game) {\n        const rows = await sql<Transaction[]>`\n          SELECT * FROM transactions\n          WHERE wallet = ${wallet} AND id < ${cursor} AND game = ${game}\n          ORDER BY id DESC\n          LIMIT ${effectiveLimit}\n        `;\n        return rows.map(normalizeTransaction);\n      }\n      if (cursor) {\n        const rows = await sql<Transaction[]>`\n          SELECT * FROM transactions\n          WHERE wallet = ${wallet} AND id < ${cursor}\n          ORDER BY id DESC\n          LIMIT ${effectiveLimit}\n        `;\n        return rows.map(normalizeTransaction);\n      }\n      if (game) {\n        const rows = await sql<Transaction[]>`\n          SELECT * FROM transactions\n          WHERE wallet = ${wallet} AND game = ${game}\n          ORDER BY id DESC\n          LIMIT ${effectiveLimit}\n        `;\n        return rows.map(normalizeTransaction);\n      }\n      const rows = await sql<Transaction[]>`\n        SELECT * FROM transactions\n        WHERE wallet = ${wallet}\n        ORDER BY id DESC\n        LIMIT ${effectiveLimit}\n      `;\n      return rows.map(normalizeTransaction);\n    },\n\n    async close() {\n      await sql.end();\n    },\n  };\n}\n","numLines":610,"startLine":1,"totalLines":610}}}
