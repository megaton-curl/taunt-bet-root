{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VUM8fcBf98TPmKSiUCEfMH","type":"tool_result","content":"     1→/**\n     2→ * Auth routes: challenge/verify/refresh/logout for JWT session management.\n     3→ */\n     4→\n     5→import { Hono } from \"hono\";\n     6→import { randomBytes, createHash } from \"node:crypto\";\n     7→import nacl from \"tweetnacl\";\n     8→import bs58 from \"bs58\";\n     9→import { SignJWT } from \"jose\";\n    10→import type { AuthDb } from \"../auth-db.js\";\n    11→import { logger } from \"../logger.js\";\n    12→\n    13→export interface AuthRoutesDeps {\n    14→  authDb: AuthDb;\n    15→  jwtSecret: Uint8Array;\n    16→  cluster: string;\n    17→  challengeTtlSeconds: number;\n    18→  accessTokenTtlSeconds: number;\n    19→  refreshTokenTtlDays: number;\n    20→}\n    21→\n    22→function hashToken(token: string): Buffer {\n    23→  return createHash(\"sha256\").update(token).digest();\n    24→}\n    25→\n    26→function buildSignInMessage(\n    27→  wallet: string,\n    28→  cluster: string,\n    29→  nonce: string,\n    30→  issuedAt: string,\n    31→  expiresAt: string,\n    32→): string {\n    33→  return [\n    34→    \"Sign in to RNG Utopia\",\n    35→    `Wallet: ${wallet}`,\n    36→    `Cluster: ${cluster}`,\n    37→    `Nonce: ${nonce}`,\n    38→    `Issued At: ${issuedAt}`,\n    39→    `Expires At: ${expiresAt}`,\n    40→    \"This signature creates a backend session for gameplay actions.\",\n    41→    \"It does not approve a blockchain transaction.\",\n    42→  ].join(\"\\n\");\n    43→}\n    44→\n    45→export function createAuthRoutes(deps: AuthRoutesDeps): Hono {\n    46→  const {\n    47→    authDb,\n    48→    jwtSecret,\n    49→    cluster,\n    50→    challengeTtlSeconds,\n    51→    accessTokenTtlSeconds,\n    52→    refreshTokenTtlDays,\n    53→  } = deps;\n    54→\n    55→  const app = new Hono();\n    56→\n    57→  // POST /challenge — generate nonce + human-readable message\n    58→  app.post(\"/challenge\", async (c) => {\n    59→    let body: { wallet: string };\n    60→    try {\n    61→      body = await c.req.json();\n    62→      if (typeof body.wallet !== \"string\" || body.wallet.length === 0) {\n    63→        return c.json({ error: \"wallet is required\" }, 400);\n    64→      }\n    65→    } catch {\n    66→      return c.json({ error: \"Invalid JSON body\" }, 400);\n    67→    }\n    68→\n    69→    const nonce = randomBytes(32).toString(\"hex\");\n    70→    const now = new Date();\n    71→    const expiresAt = new Date(now.getTime() + challengeTtlSeconds * 1000);\n    72→\n    73→    const message = buildSignInMessage(\n    74→      body.wallet,\n    75→      cluster,\n    76→      nonce,\n    77→      now.toISOString(),\n    78→      expiresAt.toISOString(),\n    79→    );\n    80→\n    81→    await authDb.insertChallenge(nonce, body.wallet, cluster, message, expiresAt);\n    82→\n    83→    logger.info(\"auth challenge issued\", { wallet: body.wallet, nonce });\n    84→\n    85→    return c.json({\n    86→      nonce,\n    87→      message,\n    88→      expiresAt: expiresAt.toISOString(),\n    89→    });\n    90→  });\n    91→\n    92→  // POST /verify — consume challenge, verify signature, issue tokens\n    93→  app.post(\"/verify\", async (c) => {\n    94→    let body: { nonce: string; wallet: string; signature: string };\n    95→    try {\n    96→      body = await c.req.json();\n    97→      if (\n    98→        typeof body.nonce !== \"string\" ||\n    99→        typeof body.wallet !== \"string\" ||\n   100→        typeof body.signature !== \"string\"\n   101→      ) {\n   102→        return c.json({ error: \"nonce, wallet, and signature are required\" }, 400);\n   103→      }\n   104→    } catch {\n   105→      return c.json({ error: \"Invalid JSON body\" }, 400);\n   106→    }\n   107→\n   108→    // Atomically consume the challenge\n   109→    const challenge = await authDb.consumeChallenge(body.nonce);\n   110→    if (!challenge) {\n   111→      logger.warn(\"auth verify rejected: challenge not found or expired\", {\n   112→        nonce: body.nonce,\n   113→        wallet: body.wallet,\n   114→      });\n   115→      return c.json({ error: \"Challenge not found, expired, or already used\" }, 401);\n   116→    }\n   117→\n   118→    // Verify wallet matches challenge\n   119→    if (challenge.wallet !== body.wallet) {\n   120→      logger.warn(\"auth verify rejected: wallet mismatch\", {\n   121→        nonce: body.nonce,\n   122→        challengeWallet: challenge.wallet,\n   123→        requestWallet: body.wallet,\n   124→      });\n   125→      return c.json({ error: \"Wallet does not match challenge\" }, 401);\n   126→    }\n   127→\n   128→    // Verify Ed25519 signature over the challenge message\n   129→    let sigBytes: Uint8Array;\n   130→    let pubkeyBytes: Uint8Array;\n   131→    try {\n   132→      sigBytes = bs58.decode(body.signature);\n   133→      pubkeyBytes = bs58.decode(body.wallet);\n   134→    } catch {\n   135→      return c.json({ error: \"Invalid signature or wallet encoding\" }, 401);\n   136→    }\n   137→\n   138→    if (sigBytes.length !== 64 || pubkeyBytes.length !== 32) {\n   139→      return c.json({ error: \"Invalid signature or wallet length\" }, 401);\n   140→    }\n   141→\n   142→    const messageBytes = new TextEncoder().encode(challenge.message);\n   143→    const valid = nacl.sign.detached.verify(messageBytes, sigBytes, pubkeyBytes);\n   144→    if (!valid) {\n   145→      logger.warn(\"auth verify rejected: signature verification failed\", {\n   146→        wallet: body.wallet,\n   147→      });\n   148→      return c.json({ error: \"Invalid signature\" }, 401);\n   149→    }\n   150→\n   151→    // Issue JWT access token\n   152→    const now = Math.floor(Date.now() / 1000);\n   153→    const accessToken = await new SignJWT({ sub: body.wallet })\n   154→      .setProtectedHeader({ alg: \"HS256\" })\n   155→      .setIssuedAt(now)\n   156→      .setExpirationTime(now + accessTokenTtlSeconds)\n   157→      .sign(jwtSecret);\n   158→\n   159→    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n   160→\n   161→    // Generate opaque refresh token\n   162→    const refreshTokenRaw = randomBytes(48).toString(\"hex\");\n   163→    const refreshTokenHash = hashToken(refreshTokenRaw);\n   164→    const familyId = randomBytes(16).toString(\"hex\");\n   165→    const refreshExpiresAt = new Date(\n   166→      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n   167→    );\n   168→\n   169→    await authDb.insertRefreshToken(\n   170→      body.wallet,\n   171→      refreshTokenHash,\n   172→      familyId,\n   173→      refreshExpiresAt,\n   174→    );\n   175→\n   176→    logger.info(\"auth session created\", { wallet: body.wallet });\n   177→\n   178→    return c.json({\n   179→      accessToken,\n   180→      accessExpiresAt,\n   181→      refreshToken: refreshTokenRaw,\n   182→      refreshExpiresAt: refreshExpiresAt.toISOString(),\n   183→    });\n   184→  });\n   185→\n   186→  // POST /refresh — rotate refresh token, issue new access token\n   187→  app.post(\"/refresh\", async (c) => {\n   188→    let body: { refreshToken: string };\n   189→    try {\n   190→      body = await c.req.json();\n   191→      if (typeof body.refreshToken !== \"string\") {\n   192→        return c.json({ error: \"refreshToken is required\" }, 400);\n   193→      }\n   194→    } catch {\n   195→      return c.json({ error: \"Invalid JSON body\" }, 400);\n   196→    }\n   197→\n   198→    const tokenHash = hashToken(body.refreshToken);\n   199→    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n   200→\n   201→    if (!stored) {\n   202→      logger.warn(\"auth refresh rejected: token not found\");\n   203→      return c.json({ error: \"Invalid refresh token\" }, 401);\n   204→    }\n   205→\n   206→    // Reuse detection: if the token was already revoked, someone replayed it.\n   207→    // Revoke the entire family as a precaution.\n   208→    if (stored.revoked) {\n   209→      logger.warn(\"auth refresh rejected: token reuse detected, revoking family\", {\n   210→        wallet: stored.wallet,\n   211→        familyId: stored.family_id,\n   212→      });\n   213→      await authDb.revokeTokenFamily(stored.family_id);\n   214→      return c.json({ error: \"Token reuse detected. Please sign in again.\" }, 401);\n   215→    }\n   216→\n   217→    // Check expiry\n   218→    if (new Date() > stored.expires_at) {\n   219→      logger.warn(\"auth refresh rejected: token expired\", {\n   220→        wallet: stored.wallet,\n   221→      });\n   222→      await authDb.revokeRefreshToken(stored.id);\n   223→      return c.json({ error: \"Refresh token expired\" }, 401);\n   224→    }\n   225→\n   226→    // Revoke old token\n   227→    await authDb.revokeRefreshToken(stored.id);\n   228→\n   229→    // Issue new access token\n   230→    const now = Math.floor(Date.now() / 1000);\n   231→    const accessToken = await new SignJWT({ sub: stored.wallet })\n   232→      .setProtectedHeader({ alg: \"HS256\" })\n   233→      .setIssuedAt(now)\n   234→      .setExpirationTime(now + accessTokenTtlSeconds)\n   235→      .sign(jwtSecret);\n   236→\n   237→    const accessExpiresAt = new Date((now + accessTokenTtlSeconds) * 1000).toISOString();\n   238→\n   239→    // Issue new refresh token in the same family\n   240→    const newRefreshRaw = randomBytes(48).toString(\"hex\");\n   241→    const newRefreshHash = hashToken(newRefreshRaw);\n   242→    const newRefreshExpiresAt = new Date(\n   243→      Date.now() + refreshTokenTtlDays * 24 * 60 * 60 * 1000,\n   244→    );\n   245→\n   246→    await authDb.insertRefreshToken(\n   247→      stored.wallet,\n   248→      newRefreshHash,\n   249→      stored.family_id,\n   250→      newRefreshExpiresAt,\n   251→    );\n   252→\n   253→    logger.debug(\"auth token refreshed\", { wallet: stored.wallet });\n   254→\n   255→    return c.json({\n   256→      accessToken,\n   257→      accessExpiresAt,\n   258→      refreshToken: newRefreshRaw,\n   259→      refreshExpiresAt: newRefreshExpiresAt.toISOString(),\n   260→    });\n   261→  });\n   262→\n   263→  // POST /logout — revoke refresh token\n   264→  app.post(\"/logout\", async (c) => {\n   265→    let body: { refreshToken: string };\n   266→    try {\n   267→      body = await c.req.json();\n   268→      if (typeof body.refreshToken !== \"string\") {\n   269→        return c.body(null, 204);\n   270→      }\n   271→    } catch {\n   272→      return c.body(null, 204);\n   273→    }\n   274→\n   275→    const tokenHash = hashToken(body.refreshToken);\n   276→    const stored = await authDb.getRefreshTokenByHash(tokenHash);\n   277→    if (stored) {\n   278→      await authDb.revokeRefreshToken(stored.id);\n   279→      logger.info(\"auth logout\", { wallet: stored.wallet });\n   280→    }\n   281→\n   282→    return c.body(null, 204);\n   283→  });\n   284→\n   285→  return app;\n   286→}\n   287→"}]},"parent_tool_use_id":"toolu_01TP2vt2gVQWAytPQvUJrUk6","session_id":"9bf9a501-ff1b-418f-8f9a-7e40ba9d0165","uuid":"41fc0f1a-7e05-42a4-ae0e-3d65e8cbc901","timestamp":"2026-03-25T11:51:29.460Z"}
