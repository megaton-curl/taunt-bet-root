{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01BpbeQUXQjnfKLgW9Rx6ZRk","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015aEYzPSrNPKPbN9PyUbaXs","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/referral.ts","content":"/**\n * Referral routes — code management, linking, stats, earnings, and claims.\n */\n\nimport { Hono } from \"hono\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\n\nexport interface ReferralRoutesDeps {\n  db: Db;\n}\n\n/** Referral code validation: 3-16 chars, lowercase alphanumeric + hyphens */\nconst CODE_REGEX = /^[a-z0-9-]{3,16}$/;\n\nconst REFERRAL_BASE_URL = \"https://taunt.bet/r\";\n\nexport function createReferralRoutes(deps: ReferralRoutesDeps) {\n  const { db } = deps;\n  const app = new Hono<AppEnv>();\n\n  // POST /code — set or replace the player's referral code\n  app.post(\"/code\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    let body: { code?: unknown };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json({ error: \"Invalid request body\" }, 400);\n    }\n\n    const code = typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n\n    if (!CODE_REGEX.test(code)) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_CODE\",\n            message:\n              \"Code must be 3-16 characters, lowercase letters, numbers, and hyphens only\",\n          },\n        },\n        400,\n      );\n    }\n\n    // Check if this code is already taken by another wallet\n    const existing = await db.getReferralCodeByCode(code);\n    if (existing && existing.wallet !== wallet) {\n      return c.json(\n        {\n          error: {\n            code: \"CODE_TAKEN\",\n            message: \"This referral code is already in use\",\n            retryable: false,\n          },\n        },\n        409,\n      );\n    }\n\n    try {\n      const result = await db.upsertReferralCode(wallet, code);\n      logger.info({ wallet, code: result.code }, \"Referral code set\");\n      return c.json({\n        code: result.code,\n        url: `${REFERRAL_BASE_URL}/${result.code}`,\n      });\n    } catch (err) {\n      // Handle race condition: another wallet grabbed the code between check and insert\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return c.json(\n          {\n            error: {\n              code: \"CODE_TAKEN\",\n              message: \"This referral code is already in use\",\n              retryable: false,\n            },\n          },\n          409,\n        );\n      }\n      logger.error({ err, wallet }, \"Failed to set referral code\");\n      return c.json({ error: \"Failed to set referral code\" }, 500);\n    }\n  });\n\n  return app;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":487,"cache_read_input_tokens":58514,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":487},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"9bf9a501-ff1b-418f-8f9a-7e40ba9d0165","uuid":"6d8b947d-5769-4309-944e-78c1ffab90cc"}
