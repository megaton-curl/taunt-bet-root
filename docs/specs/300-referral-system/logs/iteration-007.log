{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WDDdJrbMYykvgfjVz3CdRJ","type":"tool_result","content":"     1→/**\n     2→ * GET /health — operational health endpoint.\n     3→ *\n     4→ * Returns service version, server pubkey, SOL balance, DB connectivity,\n     5→ * worker running status, unsettled round count, and oldest unsettled age.\n     6→ */\n     7→\n     8→import { Hono } from \"hono\";\n     9→import { Connection, type PublicKey } from \"@solana/web3.js\";\n    10→import type postgres from \"postgres\";\n    11→import type { Db } from \"../db.js\";\n    12→import { getQueueDepth } from \"../queue/health.js\";\n    13→import { logger } from \"../logger.js\";\n    14→\n    15→export interface HealthDeps {\n    16→  db: Db;\n    17→  sql: postgres.Sql;\n    18→  connection: Connection;\n    19→  serverKey: PublicKey;\n    20→  isWorkerRunning: () => boolean;\n    21→  minSolBalance: number;\n    22→}\n    23→\n    24→export function createHealthRoutes(deps: HealthDeps): Hono {\n    25→  const { db, sql, connection, serverKey, isWorkerRunning, minSolBalance } = deps;\n    26→  const app = new Hono();\n    27→\n    28→  app.get(\"/\", async (c) => {\n    29→    // Optional flags — extended queries are opt-in so unauthenticated\n    30→    // polling (load balancers, uptime bots) doesn't hit the DB unnecessarily.\n    31→    const verbose = c.req.query(\"verbose\") === \"1\";\n    32→\n    33→    let dbConnected = false;\n    34→    let unsettledCount = 0;\n    35→    let oldestUnsettledAge = 0;\n    36→\n    37→    // Check DB connectivity + query unsettled stats\n    38→    try {\n    39→      const stats = await db.getUnsettledStats();\n    40→      dbConnected = true;\n    41→      unsettledCount = stats.count;\n    42→      oldestUnsettledAge = stats.oldestAgeSeconds;\n    43→    } catch {\n    44→      dbConnected = false;\n    45→    }\n    46→\n    47→    // Get SOL balance of server keypair\n    48→    let solBalance = 0;\n    49→    try {\n    50→      const lamports = await connection.getBalance(serverKey);\n    51→      solBalance = lamports / 1e9;\n    52→    } catch {\n    53→      // If RPC fails, report 0\n    54→    }\n    55→\n    56→    // Warn if SOL balance is below threshold\n    57→    if (solBalance < minSolBalance) {\n    58→      logger.warn(\"Server SOL balance below threshold\", {\n    59→        solBalance,\n    60→        threshold: minSolBalance,\n    61→        serverKey: serverKey.toBase58(),\n    62→      });\n    63→    }\n    64→\n    65→    const response: Record<string, unknown> = {\n    66→      status: \"ok\",\n    67→      version: \"0.1.0\",\n    68→      serverKey: serverKey.toBase58(),\n    69→      solBalance,\n    70→      dbConnected,\n    71→      workerRunning: isWorkerRunning(),\n    72→      unsettledCount,\n    73→      oldestUnsettledAge,\n    74→    };\n    75→\n    76→    // Event queue depth — only when ?verbose=1 (extra DB query)\n    77→    if (verbose) {\n    78→      try {\n    79→        response.eventQueue = await getQueueDepth(sql);\n    80→      } catch {\n    81→        response.eventQueue = { pending: 0, processing: 0, dead: 0, completed: 0 };\n    82→      }\n    83→    }\n    84→\n    85→    return c.json(response);\n    86→  });\n    87→\n    88→  return app;\n    89→}\n    90→"}]},"parent_tool_use_id":"toolu_01TP2vt2gVQWAytPQvUJrUk6","session_id":"9bf9a501-ff1b-418f-8f9a-7e40ba9d0165","uuid":"78d5a1a2-6246-4d5d-94c5-b0230571f88b","timestamp":"2026-03-25T11:51:34.332Z"}
