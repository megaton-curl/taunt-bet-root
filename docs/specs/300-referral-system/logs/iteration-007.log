{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014hawgfPPKcVPr7HbHQhLAa","type":"tool_result","content":"     1→/**\n     2→ * In-memory sliding-window rate limiting middleware.\n     3→ *\n     4→ * Applies per-wallet and global limits to POST requests only.\n     5→ * Counters reset on service restart (acceptable for MVP).\n     6→ */\n     7→\n     8→import type { MiddlewareHandler } from \"hono\";\n     9→import { logger } from \"../logger.js\";\n    10→\n    11→export interface RateLimitConfig {\n    12→  /** Max POST requests per wallet per window (default 10). */\n    13→  perWallet: number;\n    14→  /** Max total POST requests per window (default 100). */\n    15→  global: number;\n    16→  /** Window size in milliseconds (default 60_000 = 1 minute). */\n    17→  windowMs: number;\n    18→}\n    19→\n    20→interface SlidingWindow {\n    21→  timestamps: number[];\n    22→}\n    23→\n    24→/**\n    25→ * Prune timestamps older than the window and return the current count.\n    26→ */\n    27→function countInWindow(window: SlidingWindow, now: number, windowMs: number): number {\n    28→  const cutoff = now - windowMs;\n    29→  // Remove expired entries from the front\n    30→  while (window.timestamps.length > 0 && window.timestamps[0]! <= cutoff) {\n    31→    window.timestamps.shift();\n    32→  }\n    33→  return window.timestamps.length;\n    34→}\n    35→\n    36→/**\n    37→ * Creates a Hono middleware that rate-limits POST requests.\n    38→ *\n    39→ * - Per-wallet: keyed by the `wallet` field in the JSON body.\n    40→ * - Global: all POST requests combined.\n    41→ * - Returns 429 with `Retry-After` header when either limit is exceeded.\n    42→ * - GET requests pass through without rate limiting.\n    43→ */\n    44→export function createRateLimitMiddleware(config: RateLimitConfig): MiddlewareHandler {\n    45→  const walletWindows = new Map<string, SlidingWindow>();\n    46→  const globalWindow: SlidingWindow = { timestamps: [] };\n    47→\n    48→  return async (c, next) => {\n    49→    if (c.req.method !== \"POST\") {\n    50→      return next();\n    51→    }\n    52→\n    53→    const now = Date.now();\n    54→    const retryAfterSeconds = Math.ceil(config.windowMs / 1000);\n    55→\n    56→    // Check global limit first\n    57→    const globalCount = countInWindow(globalWindow, now, config.windowMs);\n    58→    if (globalCount >= config.global) {\n    59→      logger.warn(\"rate limit exceeded: global limit\", {\n    60→        path: c.req.path,\n    61→        currentCount: globalCount,\n    62→        limit: config.global,\n    63→        windowMs: config.windowMs,\n    64→      });\n    65→      c.header(\"Retry-After\", String(retryAfterSeconds));\n    66→      return c.json({ error: \"Too many requests\" }, 429);\n    67→    }\n    68→\n    69→    // Extract wallet: prefer context (set by JWT middleware), fall back to body\n    70→    let wallet: string | undefined;\n    71→    try {\n    72→      wallet = c.get(\"wallet\") as string | undefined;\n    73→    } catch {\n    74→      // Context variable not set — expected for pre-auth routes\n    75→    }\n    76→    if (!wallet) {\n    77→      try {\n    78→        const body = await c.req.json();\n    79→        wallet = typeof body.wallet === \"string\" ? body.wallet : undefined;\n    80→      } catch {\n    81→        // If body is not parseable, fall back to IP-based limiting\n    82→      }\n    83→    }\n    84→    // Final fallback: key on IP for pre-auth routes (e.g., /auth/*)\n    85→    if (!wallet) {\n    86→      wallet = c.req.header(\"x-forwarded-for\")?.split(\",\")[0]?.trim()\n    87→        ?? c.req.header(\"x-real-ip\")\n    88→        ?? \"unknown-ip\";\n    89→    }\n    90→\n    91→    // Check per-wallet limit\n    92→    if (wallet) {\n    93→      let wWindow = walletWindows.get(wallet);\n    94→      if (!wWindow) {\n    95→        wWindow = { timestamps: [] };\n    96→        walletWindows.set(wallet, wWindow);\n    97→      }\n    98→      const walletCount = countInWindow(wWindow, now, config.windowMs);\n    99→      if (walletCount >= config.perWallet) {\n   100→        logger.warn(\"rate limit exceeded: wallet limit\", {\n   101→          path: c.req.path,\n   102→          wallet,\n   103→          currentCount: walletCount,\n   104→          limit: config.perWallet,\n   105→          windowMs: config.windowMs,\n   106→        });\n   107→        c.header(\"Retry-After\", String(retryAfterSeconds));\n   108→        return c.json({ error: \"Too many requests\" }, 429);\n   109→      }\n   110→      wWindow.timestamps.push(now);\n   111→    }\n   112→\n   113→    // Record in global window\n   114→    globalWindow.timestamps.push(now);\n   115→\n   116→    return next();\n   117→  };\n   118→}\n   119→"}]},"parent_tool_use_id":"toolu_01TP2vt2gVQWAytPQvUJrUk6","session_id":"9bf9a501-ff1b-418f-8f9a-7e40ba9d0165","uuid":"9d64b80d-4cd8-4fee-aafe-c28c96f8db79","timestamp":"2026-03-25T11:51:47.521Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01X3wZQnKEKq4mHUep97Mx6i","type":"tool_result","content":"     1→/**\n     2→ * Close Call API routes.\n     3→ *\n     4→ * GET  /closecall/current-round — active round + pool state\n     5→ * GET  /closecall/history       — last N settled/refunded rounds\n     6→ * GET  /closecall/candles       — last N minute-boundary candles from DB\n     7→ * POST /closecall/bet           — co-sign a bet tx (creates round or joins)\n     8→ */\n     9→\n    10→import { Hono } from \"hono\";\n    11→import { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\n    12→import type postgres from \"postgres\";\n    13→import type { CloseCallRound, Db } from \"../db.js\";\n    14→import { logger } from \"../logger.js\";\n    15→import { buildCloseCallBetTx } from \"../worker/settle-tx.js\";\n    16→import { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n    17→import { decodeCloseCallRound, type DecodedCloseCallRound } from \"../worker/account-decoder.js\";\n    18→import type { CloseCallClockWorker } from \"../worker/closecall-clock.js\";\n    19→\n    20→export interface CloseCallRoutesDeps {\n    21→  db: Db;\n    22→  connection: Connection;\n    23→  serverKeypair: Keypair;\n    24→  clockWorker: CloseCallClockWorker;\n    25→  /** Postgres sql instance for candle queries. */\n    26→  sql: postgres.Sql;\n    27→}\n    28→\n    29→/** Minimum wager in lamports: 0.001 SOL */\n    30→const MIN_WAGER_LAMPORTS = 1_000_000;\n    31→const MAX_WAGER_LAMPORTS = 100_000_000_000; // 100 SOL\n    32→\n    33→function isValidBase58(s: string): boolean {\n    34→  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n    35→}\n    36→\n    37→/** Convert a minuteTs bigint to an 8-byte LE buffer (for PDA seeds). */\n    38→function minuteTsToBuffer(ts: bigint): Buffer {\n    39→  const buf = Buffer.alloc(8);\n    40→  buf.writeBigInt64LE(ts);\n    41→  return buf;\n    42→}\n    43→\n    44→/** Derive the CloseCallRound PDA for a given minute timestamp. */\n    45→function deriveCloseCallRoundPda(minuteTs: bigint): PublicKey {\n    46→  const [pda] = PublicKey.findProgramAddressSync(\n    47→    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n    48→    CLOSECALL_PROGRAM_ID,\n    49→  );\n    50→  return pda;\n    51→}\n    52→\n    53→const PHASE_NAMES = [\"open\", \"settled\", \"refunded\"] as const;\n    54→const OUTCOME_NAMES = [\"pending\", \"green\", \"red\", \"refund\"] as const;\n    55→\n    56→/** Format a decoded on-chain round into the same shape as formatCloseCallRound. */\n    57→function formatOnChainRound(round: DecodedCloseCallRound, pda: PublicKey) {\n    58→  const greenEntries = round.greenEntries.map((e) => ({\n    59→    player: e.player.toBase58(),\n    60→    amountLamports: Number(e.amountLamports),\n    61→  }));\n    62→  const redEntries = round.redEntries.map((e) => ({\n    63→    player: e.player.toBase58(),\n    64→    amountLamports: Number(e.amountLamports),\n    65→  }));\n    66→  const greenPool = Number(round.greenPool);\n    67→  const redPool = Number(round.redPool);\n    68→  const totalPool = greenPool + redPool;\n    69→\n    70→  return {\n    71→    roundId: Number(round.minuteTs).toString(),\n    72→    pda: pda.toBase58(),\n    73→    phase: PHASE_NAMES[round.phase] ?? \"open\",\n    74→    openPrice: Number(round.openPrice),\n    75→    openPriceExpo: round.openPriceExpo,\n    76→    closePrice: round.phase === 0 ? null : Number(round.closePrice),\n    77→    outcome: OUTCOME_NAMES[round.outcome] ?? \"pending\",\n    78→    greenPool,\n    79→    redPool,\n    80→    totalPool,\n    81→    totalFee: Number(round.totalFee),\n    82→    greenEntries,\n    83→    redEntries,\n    84→    greenCount: greenEntries.length,\n    85→    redCount: redEntries.length,\n    86→    settleTx: null,\n    87→    createdAt: new Date(Number(round.createdAt) * 1000).toISOString(),\n    88→    settledAt: null,\n    89→  };\n    90→}\n    91→\n    92→function formatCloseCallRound(round: CloseCallRound) {\n    93→  const totalPool = round.green_pool + round.red_pool;\n    94→  return {\n    95→    roundId: round.round_id,\n    96→    pda: round.pda,\n    97→    phase: round.phase,\n    98→    openPrice: round.open_price,\n    99→    openPriceExpo: round.open_price_expo,\n   100→    closePrice: round.close_price,"}]},"parent_tool_use_id":"toolu_01TP2vt2gVQWAytPQvUJrUk6","session_id":"9bf9a501-ff1b-418f-8f9a-7e40ba9d0165","uuid":"cdd306b5-5154-42d7-874c-90d91da98219","timestamp":"2026-03-25T11:51:47.538Z"}
