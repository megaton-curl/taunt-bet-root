{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0172omrY8aiEHsxgvempPRGM","type":"tool_result","content":"     1→import { Hono } from \"hono\";\n     2→import { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\n     3→import { computeCommitment, generateMatchId, generateSecret } from \"../fairness.js\";\n     4→import { buildCreateLordRoundTx, deriveLordRoundPda } from \"../tx-builder.js\";\n     5→import type { Db } from \"../db.js\";\n     6→import { logger } from \"../logger.js\";\n     7→import type { AppEnv } from \"../hono-env.js\";\n     8→import type { PdaWatcher } from \"../worker/pda-watcher.js\";\n     9→import { decodeLordRound, type DecodedJackpotRound } from \"../worker/account-decoder.js\";\n    10→\n    11→export interface LordCreateRoutesDeps {\n    12→  db: Db;\n    13→  connection: Connection;\n    14→  serverKeypair: Keypair;\n    15→  pdaWatcher?: PdaWatcher;\n    16→}\n    17→\n    18→const MIN_WAGER_LAMPORTS = 1_000_000;\n    19→\n    20→interface CreateLordRequestBody {\n    21→  wallet: string;\n    22→  amountLamports: number;\n    23→}\n    24→\n    25→function isValidBase58(s: string): boolean {\n    26→  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n    27→}\n    28→\n    29→function validateBody(body: unknown): CreateLordRequestBody {\n    30→  if (!body || typeof body !== \"object\") {\n    31→    throw new Error(\"Request body must be a JSON object\");\n    32→  }\n    33→\n    34→  const b = body as Record<string, unknown>;\n    35→\n    36→  if (typeof b.wallet !== \"string\" || !isValidBase58(b.wallet)) {\n    37→    throw new Error(\"wallet must be a valid base58 public key\");\n    38→  }\n    39→\n    40→  if (\n    41→    typeof b.amountLamports !== \"number\" ||\n    42→    !Number.isInteger(b.amountLamports) ||\n    43→    b.amountLamports < MIN_WAGER_LAMPORTS\n    44→  ) {\n    45→    throw new Error(`amountLamports must be an integer >= ${MIN_WAGER_LAMPORTS}`);\n    46→  }\n    47→\n    48→  return {\n    49→    wallet: b.wallet,\n    50→    amountLamports: b.amountLamports,\n    51→  };\n    52→}\n    53→\n    54→const PHASE_NAMES = [\"waiting\", \"active\", \"locked\", \"resolving\", \"settled\", \"refunded\"] as const;\n    55→\n    56→function formatLordRound(\n    57→  round: DecodedJackpotRound,\n    58→  pda: PublicKey,\n    59→  dbRound: { match_id: string; commitment: Buffer; phase: string } | undefined,\n    60→) {\n    61→  const entries = round.entries.map((e) => ({\n    62→    player: e.player.toBase58(),\n    63→    amountLamports: Number(e.amountLamports),\n    64→  }));\n    65→\n    66→  return {\n    67→    matchId: dbRound?.match_id ?? Buffer.from(round.matchId).toString(\"hex\"),\n    68→    pda: pda.toBase58(),\n    69→    phase: PHASE_NAMES[round.phase] ?? \"waiting\",\n    70→    creator: round.creator.toBase58(),\n    71→    commitment: dbRound\n    72→      ? dbRound.commitment.toString(\"hex\")\n    73→      : Buffer.from(round.commitment).toString(\"hex\"),\n    74→    entries,\n    75→    totalAmountLamports: Number(round.totalAmountLamports),\n    76→    distinctPlayers: round.distinctPlayers,\n    77→    countdownStartedAt: Number(round.countdownStartedAt) > 0\n    78→      ? Number(round.countdownStartedAt)\n    79→      : null,\n    80→    countdownEndsAt: Number(round.countdownEndsAt) > 0"}]},"parent_tool_use_id":"toolu_01TP2vt2gVQWAytPQvUJrUk6","session_id":"9bf9a501-ff1b-418f-8f9a-7e40ba9d0165","uuid":"bd77e5cf-dca1-4955-a93e-a68e8f3751dc","timestamp":"2026-03-25T11:51:49.455Z"}
