{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016Z4FRBMdrqjixg5FKGJE9u","type":"tool_result","content":"     1→/**\n     2→ * Database client module — typed query functions for `rounds` and `operator_events`.\n     3→ *\n     4→ * Phase transitions are unidirectional: created → locked → settling → settled,\n     5→ * or created → expired. The application layer rejects backward transitions.\n     6→ */\n     7→\n     8→import postgres from \"postgres\";\n     9→\n    10→// ---------------------------------------------------------------------------\n    11→// Types\n    12→// ---------------------------------------------------------------------------\n    13→\n    14→export type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    15→\n    16→export type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n    17→export type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n    18→\n    19→export interface CloseCallRound {\n    20→  round_id: string;\n    21→  pda: string;\n    22→  server_key: string;\n    23→  phase: CloseCallPhase;\n    24→  open_price: number;\n    25→  open_price_expo: number;\n    26→  close_price: number | null;\n    27→  outcome: CloseCallOutcome;\n    28→  green_pool: number;\n    29→  red_pool: number;\n    30→  total_fee: number;\n    31→  green_entries: Array<{ player: string; amountLamports: number }>;\n    32→  red_entries: Array<{ player: string; amountLamports: number }>;\n    33→  settle_tx: string | null;\n    34→  created_at: Date;\n    35→  settled_at: Date | null;\n    36→}\n    37→\n    38→export interface InsertCloseCallRoundParams {\n    39→  roundId: string;\n    40→  pda: string;\n    41→  serverKey: string;\n    42→  openPrice: number;\n    43→  openPriceExpo: number;\n    44→}\n    45→\n    46→export type OperatorEventType =\n    47→  | \"secret_generated\"\n    48→  | \"tx_built\"\n    49→  | \"match_detected\"\n    50→  | \"settle_submitted\"\n    51→  | \"settle_confirmed\"\n    52→  | \"settle_failed\"\n    53→  | \"settle_retried\"\n    54→  | \"timeout_detected\";\n    55→\n    56→export interface Round {\n    57→  pda: string;\n    58→  game: string;\n    59→  creator: string;\n    60→  server_key: string;\n    61→  secret: Buffer;\n    62→  commitment: Buffer;\n    63→  amount_lamports: number;\n    64→  side: number;\n    65→  match_id: string;\n    66→  phase: RoundPhase;\n    67→  target_slot: string | null;\n    68→  settle_tx: string | null;\n    69→  settle_attempts: number;\n    70→  result_hash: Buffer | null;\n    71→  result_side: number | null;\n    72→  winner: string | null;\n    73→  entries: unknown | null;\n    74→  created_at: Date;\n    75→  updated_at: Date;\n    76→}\n    77→\n    78→export interface InsertRoundParams {\n    79→  pda: string;\n    80→  game: string;\n    81→  creator: string;\n    82→  serverKey: string;\n    83→  secret: Buffer;\n    84→  commitment: Buffer;\n    85→  amountLamports: number;\n    86→  side: number;\n    87→  matchId: string;\n    88→  phase: RoundPhase;\n    89→  entries?: Array<{ player: string; amountLamports: number }>;\n    90→}\n    91→\n    92→export interface OperatorEvent {\n    93→  id: string;\n    94→  pda: string | null;\n    95→  event_type: OperatorEventType;\n    96→  payload: unknown;\n    97→  created_at: Date;\n    98→}\n    99→\n   100→// ---------------------------------------------------------------------------\n   101→// Transaction types\n   102→// ---------------------------------------------------------------------------\n   103→\n   104→export type TransactionType = \"deposit\" | \"payout\" | \"refund\";\n   105→\n   106→export interface Transaction {\n   107→  id: string;\n   108→  wallet: string;\n   109→  game: string;\n   110→  match_id: string;\n   111→  tx_type: TransactionType;\n   112→  amount_lamports: number;\n   113→  tx_sig: string;\n   114→  created_at: Date;\n   115→}\n   116→\n   117→export interface InsertTransactionParams {\n   118→  wallet: string;\n   119→  game: string;\n   120→  matchId: string;\n   121→  txType: TransactionType;\n   122→  amountLamports: number;\n   123→  txSig: string;\n   124→}\n   125→\n   126→// ---------------------------------------------------------------------------\n   127→// Referral types\n   128→// ---------------------------------------------------------------------------\n   129→\n   130→export interface ReferralCode {\n   131→  id: number;\n   132→  wallet: string;\n   133→  code: string;\n   134→  created_at: Date;\n   135→  updated_at: Date;\n   136→}\n   137→\n   138→export interface ReferralLink {\n   139→  id: number;\n   140→  referrer_wallet: string;\n   141→  referee_wallet: string;\n   142→  created_at: Date;\n   143→}\n   144→\n   145→export interface ReferralEarning {\n   146→  id: number;\n   147→  referrer_wallet: string;\n   148→  referee_wallet: string;\n   149→  round_id: string;\n   150→  game_type: string;\n   151→  wager_lamports: number;\n   152→  fee_lamports: number;\n   153→  referrer_earned_lamports: number;\n   154→  referrer_rate_bps: number;\n   155→  referee_rebate_lamports: number;\n   156→  referee_rebate_rate_bps: number;\n   157→  created_at: Date;\n   158→}\n   159→\n   160→export interface ReferralStats {\n   161→  referred_count: number;\n   162→  active_count: number;\n   163→  total_volume_lamports: string;\n   164→  total_earned_lamports: string;\n   165→  pending_lamports: string;\n   166→}\n   167→\n   168→export interface ReferralClaim {\n   169→  id: string;\n   170→  wallet: string;\n   171→  amount_lamports: string;\n   172→  status: \"pending\" | \"processing\" | \"completed\" | \"failed\";\n   173→  tx_signature: string | null;\n   174→  error: string | null;\n   175→  requested_at: Date;\n   176→  processed_at: Date | null;\n   177→}\n   178→\n   179→// ---------------------------------------------------------------------------\n   180→// Phase transition guard\n   181→// ---------------------------------------------------------------------------\n   182→\n   183→/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n   184→const VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n   185→  created: [\"locked\", \"expired\"],\n   186→  locked: [\"settling\"],\n   187→  settling: [\"settled\"],\n   188→  settled: [],\n   189→  expired: [],\n   190→};\n   191→\n   192→function assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n   193→  const allowed = VALID_TRANSITIONS[from];\n   194→  if (!allowed.includes(to)) {\n   195→    throw new Error(\n   196→      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n   197→    );\n   198→  }\n   199→}\n   200→\n   201→// ---------------------------------------------------------------------------\n   202→// DB client\n   203→// ---------------------------------------------------------------------------\n   204→\n   205→export interface Db {\n   206→  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n   207→  insertRound(params: InsertRoundParams): Promise<Round>;\n   208→\n   209→  /** Delete a round by PDA. Returns true if a row was removed. */\n   210→  deleteRoundByPda(pda: string): Promise<boolean>;\n   211→\n   212→  /** Transition a round's phase. Enforces unidirectional state machine.\n   213→   *  Optional `updates` can set additional columns alongside the phase change. */\n   214→  updateRoundPhase(\n   215→    pda: string,\n   216→    newPhase: RoundPhase,\n   217→    updates?: Partial<\n   218→      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n   219→    >,\n   220→  ): Promise<Round>;\n   221→\n   222→  /** Update the entries JSONB column for a settled round. */\n   223→  updateRoundEntries(\n   224→    pda: string,\n   225→    entries: Array<{ player: string; amountLamports: number }>,\n   226→  ): Promise<Round>;\n   227→\n   228→  /** Get a single round by its PDA. Returns `undefined` if not found. */\n   229→  getRoundByPda(pda: string): Promise<Round | undefined>;\n   230→\n   231→  /** Get all rounds matching a given phase. */\n   232→  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n   233→\n   234→  /** Append an operator event to the audit log. */\n   235→  insertOperatorEvent(\n   236→    pda: string | null,\n   237→    eventType: OperatorEventType,\n   238→    payload?: unknown,\n   239→  ): Promise<OperatorEvent>;\n   240→\n   241→  /** Get the latest operator event for a PDA + type. */\n   242→  getLatestOperatorEvent(\n   243→    pda: string,\n   244→    eventType: OperatorEventType,\n   245→  ): Promise<OperatorEvent | undefined>;\n   246→\n   247→  /** Get a single round by its match_id. Returns `undefined` if not found. */\n   248→  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n   249→\n   250→  /** Batch-fetch the latest operator event per PDA for a given event type. */\n   251→  getLatestOperatorEventsForPdas(\n   252→    pdas: string[],\n   253→    eventType: OperatorEventType,\n   254→  ): Promise<Map<string, OperatorEvent>>;\n   255→\n   256→  /** Get recently settled rounds for a game, ordered newest first. */\n   257→  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n   258→\n   259→  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n   260→  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n   261→\n   262→  // -------------------------------------------------------------------------\n   263→  // Close Call rounds\n   264→  // -------------------------------------------------------------------------\n   265→\n   266→  /** Insert a new Close Call round. */\n   267→  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n   268→\n   269→  /** Get a Close Call round by round_id (16-char hex). */\n   270→  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n   271→\n   272→  /** Get the current active (open) Close Call round. */\n   273→  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n   274→\n   275→  /** Get the most recent settled/refunded Close Call rounds. */\n   276→  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n   277→\n   278→  /** Update a Close Call round after settlement. */\n   279→  settleCloseCallRound(\n   280→    roundId: string,\n   281→    updates: {\n   282→      phase: CloseCallPhase;\n   283→      outcome: CloseCallOutcome;\n   284→      closePrice?: number;\n   285→      greenPool?: number;\n   286→      redPool?: number;\n   287→      totalFee?: number;\n   288→      greenEntries?: Array<{ player: string; amountLamports: number }>;\n   289→      redEntries?: Array<{ player: string; amountLamports: number }>;\n   290→      settleTx?: string;\n   291→    },\n   292→  ): Promise<CloseCallRound>;\n   293→\n   294→  // -------------------------------------------------------------------------\n   295→  // Transactions\n   296→  // -------------------------------------------------------------------------\n   297→\n   298→  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n   299→  insertTransaction(params: InsertTransactionParams): Promise<void>;\n   300→\n   301→  /** Insert multiple transactions in a single batch. */\n   302→  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n   303→\n   304→  /** Get paginated transactions for a wallet, newest first. */\n   305→  getTransactions(\n   306→    wallet: string,\n   307→    cursor?: string,\n   308→    limit?: number,\n   309→    game?: string,\n   310→  ): Promise<Transaction[]>;\n   311→\n   312→  // -------------------------------------------------------------------------\n   313→  // Referral — codes\n   314→  // -------------------------------------------------------------------------\n   315→\n   316→  /** Insert a new referral code for a wallet. Throws on duplicate wallet or code. */\n   317→  insertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n   318→\n   319→  /** Get a wallet's referral code. Returns `undefined` if none set. */\n   320→  getReferralCodeByWallet(wallet: string): Promise<ReferralCode | undefined>;\n   321→\n   322→  /** Look up a referral code record by code string. Returns `undefined` if not found. */\n   323→  getReferralCodeByCode(code: string): Promise<ReferralCode | undefined>;\n   324→\n   325→  /** Set or replace a wallet's referral code (INSERT … ON CONFLICT UPDATE). */\n   326→  upsertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n   327→\n   328→  // -------------------------------------------------------------------------\n   329→  // Referral — links\n   330→  // -------------------------------------------------------------------------\n   331→\n   332→  /** Create a referral link (referrer → referee). Throws on duplicate referee. */\n   333→  insertReferralLink(referrerWallet: string, refereeWallet: string): Promise<ReferralLink>;\n   334→\n   335→  /** Get the referral link for a referee wallet. Returns `undefined` if not referred. */\n   336→  getReferralLinkByReferee(refereeWallet: string): Promise<ReferralLink | undefined>;\n   337→\n   338→  /** Get all referral links where the given wallet is the referrer. */\n   339→  getReferralLinksByReferrer(referrerWallet: string): Promise<ReferralLink[]>;\n   340→\n   341→  // -------------------------------------------------------------------------\n   342→  // Referral — earnings & stats\n   343→  // -------------------------------------------------------------------------\n   344→\n   345→  /** Insert a referral earning row. Throws on duplicate (referee_wallet, round_id). */\n   346→  insertReferralEarning(params: {\n   347→    referrerWallet: string;\n   348→    refereeWallet: string;\n   349→    roundId: string;\n   350→    gameType: string;\n   351→    wagerLamports: number;\n   352→    feeLamports: number;\n   353→    referrerEarnedLamports: number;\n   354→    referrerRateBps: number;\n   355→    refereeRebateLamports: number;\n   356→    refereeRebateRateBps: number;\n   357→  }): Promise<ReferralEarning>;\n   358→\n   359→  /**\n   360→   * Get the pending (unclaimed) balance for a wallet.\n   361→   * Sum of referrer_earned where wallet=referrer + sum of referee_rebate where\n   362→   * wallet=referee, minus sum of completed claims for the wallet.\n   363→   * Returns a lamport string.\n   364→   */\n   365→  getPendingBalance(wallet: string): Promise<string>;\n   366→\n   367→  /** Get paginated per-game earnings for a wallet (as referrer). Newest first. */\n   368→  getReferralEarnings(\n   369→    wallet: string,\n   370→    page: number,\n   371→    limit: number,\n   372→  ): Promise<{ items: ReferralEarning[]; totalPages: number }>;\n   373→\n   374→  /** Get referral summary stats for a wallet. */\n   375→  getReferralStats(wallet: string): Promise<ReferralStats>;\n   376→\n   377→  // -------------------------------------------------------------------------\n   378→  // Referral — claims & rates\n   379→  // -------------------------------------------------------------------------\n   380→\n   381→  /** Insert a new referral claim row (status defaults to 'pending'). Returns the created claim. */\n   382→  insertReferralClaim(\n   383→    wallet: string,\n   384→    amountLamports: string,\n   385→  ): Promise<ReferralClaim>;\n   386→\n   387→  /** Get a referral claim by its UUID. Returns `undefined` if not found. */\n   388→  getReferralClaim(claimId: string): Promise<ReferralClaim | undefined>;\n   389→\n   390→  /**\n   391→   * Update a claim's status and optional metadata (tx_signature, error, processed_at).\n   392→   * Returns the updated claim.\n   393→   */\n   394→  updateClaimStatus(\n   395→    claimId: string,\n   396→    status: ReferralClaim[\"status\"],\n   397→    meta?: { txSignature?: string; error?: string },\n   398→  ): Promise<ReferralClaim>;\n   399→\n   400→  /**\n   401→   * Get the effective referrer rate for a wallet in bps.\n   402→   * Checks `referral_kol_rates` first; falls back to `defaultRateBps`.\n   403→   */\n   404→  getReferrerRate(\n   405→    wallet: string,\n   406→    defaultRateBps: number,\n   407→  ): Promise<number>;\n   408→\n   409→  /** Gracefully close the connection pool. */\n   410→  close(): Promise<void>;\n   411→}\n   412→\n   413→function normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n   414→  return {\n   415→    ...row,\n   416→    open_price: Number(row.open_price),\n   417→    open_price_expo: Number(row.open_price_expo),\n   418→    close_price: row.close_price === null ? null : Number(row.close_price),\n   419→    green_pool: Number(row.green_pool),\n   420→    red_pool: Number(row.red_pool),\n   421→    total_fee: Number(row.total_fee),\n   422→    // JSONB comes back as parsed objects from postgres.js\n   423→    green_entries: Array.isArray(row.green_entries)\n   424→      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   425→      : [],\n   426→    red_entries: Array.isArray(row.red_entries)\n   427→      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   428→      : [],\n   429→  };\n   430→}\n   431→\n   432→function normalizeTransaction(row: Transaction): Transaction {\n   433→  return {\n   434→    ...row,\n   435→    amount_lamports: Number(row.amount_lamports),\n   436→  };\n   437→}\n   438→\n   439→function normalizeReferralEarning(row: ReferralEarning): ReferralEarning {\n   440→  return {\n   441→    ...row,\n   442→    wager_lamports: Number(row.wager_lamports),\n   443→    fee_lamports: Number(row.fee_lamports),\n   444→    referrer_earned_lamports: Number(row.referrer_earned_lamports),\n   445→    referrer_rate_bps: Number(row.referrer_rate_bps),\n   446→    referee_rebate_lamports: Number(row.referee_rebate_lamports),\n   447→    referee_rebate_rate_bps: Number(row.referee_rebate_rate_bps),\n   448→  };\n   449→}\n   450→\n   451→function normalizeRound(row: Round): Round {\n   452→  return {\n   453→    ...row,\n   454→    amount_lamports: Number(row.amount_lamports),\n   455→    side: Number(row.side),\n   456→    settle_attempts: Number(row.settle_attempts),\n   457→    result_side: row.result_side === null ? null : Number(row.result_side),\n   458→    // JSONB comes back as parsed objects from postgres.js\n   459→    entries: Array.isArray(row.entries)\n   460→      ? (row.entries as Array<{ player: string; amountLamports: number }>).map((e) => ({\n   461→          player: e.player,\n   462→          amountLamports: Number(e.amountLamports),\n   463→        }))\n   464→      : null,\n   465→  };\n   466→}\n   467→\n   468→export function createDb(databaseUrl: string): Db {\n   469→  const sql = postgres(databaseUrl);\n   470→\n   471→  return {\n   472→    async insertRound(params) {\n   473→      const rows = await sql<Round[]>`\n   474→        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase, entries)\n   475→        VALUES (\n   476→          ${params.pda},\n   477→          ${params.game},\n   478→          ${params.creator},\n   479→          ${params.serverKey},\n   480→          ${params.secret},\n   481→          ${params.commitment},\n   482→          ${params.amountLamports},\n   483→          ${params.side},\n   484→          ${params.matchId},\n   485→          ${params.phase},\n   486→          ${params.entries ? sql.json(params.entries) : null}\n   487→        )\n   488→        RETURNING *\n   489→      `;\n   490→      return normalizeRound(rows[0]!);\n   491→    },\n   492→\n   493→    async deleteRoundByPda(pda) {\n   494→      const rows = await sql<{ pda: string }[]>`\n   495→        DELETE FROM rounds WHERE pda = ${pda}\n   496→        RETURNING pda\n   497→      `;\n   498→      return rows.length > 0;\n   499→    },\n   500→\n   501→    async updateRoundPhase(pda, newPhase, updates) {\n   502→      // Fetch current phase to validate transition\n   503→      const current = await sql<Pick<Round, \"phase\">[]>`\n   504→        SELECT phase FROM rounds WHERE pda = ${pda}\n   505→      `;\n   506→\n   507→      if (current.length === 0) {\n   508→        throw new Error(`Round not found: ${pda}`);\n   509→      }\n   510→\n   511→      const currentPhase = current[0]!.phase as RoundPhase;\n   512→      assertPhaseTransition(currentPhase, newPhase);\n   513→\n   514→      // Build the update — always set phase + updated_at\n   515→      const rows = await sql<Round[]>`\n   516→        UPDATE rounds SET\n   517→          phase = ${newPhase},\n   518→          updated_at = now(),\n   519→          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n   520→          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n   521→          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n   522→          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n   523→          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n   524→          winner = COALESCE(${updates?.winner ?? null}, winner)\n   525→        WHERE pda = ${pda}\n   526→        RETURNING *\n   527→      `;\n   528→\n   529→      return normalizeRound(rows[0]!);\n   530→    },\n   531→\n   532→    async updateRoundEntries(pda, entries) {\n   533→      const rows = await sql<Round[]>`\n   534→        UPDATE rounds SET\n   535→          entries = ${sql.json(entries)},\n   536→          updated_at = now()\n   537→        WHERE pda = ${pda}\n   538→        RETURNING *\n   539→      `;\n   540→      if (rows.length === 0) {\n   541→        throw new Error(`Round not found: ${pda}`);\n   542→      }\n   543→      return normalizeRound(rows[0]!);\n   544→    },\n   545→\n   546→    async getRoundByPda(pda) {\n   547→      const rows = await sql<Round[]>`\n   548→        SELECT * FROM rounds WHERE pda = ${pda}\n   549→      `;\n   550→      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   551→    },\n   552→\n   553→    async getRoundByMatchId(matchId) {\n   554→      const rows = await sql<Round[]>`\n   555→        SELECT * FROM rounds WHERE match_id = ${matchId}\n   556→      `;\n   557→      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   558→    },\n   559→\n   560→    async getRoundsByPhase(phase) {\n   561→      const rows = await sql<Round[]>`\n   562→        SELECT * FROM rounds WHERE phase = ${phase}\n   563→      `;\n   564→      return rows.map(normalizeRound);\n   565→    },\n   566→\n   567→    async insertOperatorEvent(pda, eventType, payload) {\n   568→      const rows = await sql<OperatorEvent[]>`\n   569→        INSERT INTO operator_events (pda, event_type, payload)\n   570→        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n   571→        RETURNING *\n   572→      `;\n   573→      return rows[0]!;\n   574→    },\n   575→\n   576→    async getLatestOperatorEvent(pda, eventType) {\n   577→      const rows = await sql<OperatorEvent[]>`\n   578→        SELECT * FROM operator_events\n   579→        WHERE pda = ${pda} AND event_type = ${eventType}\n   580→        ORDER BY id DESC\n   581→        LIMIT 1\n   582→      `;\n   583→      return rows[0];\n   584→    },\n   585→\n   586→    async getLatestOperatorEventsForPdas(pdas, eventType) {\n   587→      if (pdas.length === 0) return new Map();\n   588→      const rows = await sql<OperatorEvent[]>`\n   589→        SELECT DISTINCT ON (pda) *\n   590→        FROM operator_events\n   591→        WHERE pda = ANY(${pdas}) AND event_type = ${eventType}\n   592→        ORDER BY pda, id DESC\n   593→      `;\n   594→      const map = new Map<string, OperatorEvent>();\n   595→      for (const row of rows) {\n   596→        if (row.pda) map.set(row.pda, row);\n   597→      }\n   598→      return map;\n   599→    },\n   600→\n   601→    async getRecentSettledRounds(game, limit) {\n   602→      const rows = await sql<Round[]>`\n   603→        SELECT * FROM rounds\n   604→        WHERE game = ${game} AND phase = 'settled'\n   605→        ORDER BY updated_at DESC\n   606→        LIMIT ${limit}\n   607→      `;\n   608→      return rows.map(normalizeRound);\n   609→    },\n   610→\n   611→    async getUnsettledStats() {\n   612→      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n   613→        SELECT\n   614→          COUNT(*)::text AS count,\n   615→          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n   616→        FROM rounds\n   617→        WHERE phase NOT IN ('settled', 'expired')\n   618→      `;\n   619→      const row = rows[0]!;\n   620→      return {\n   621→        count: parseInt(row.count, 10),\n   622→        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n   623→      };\n   624→    },\n   625→\n   626→    // -----------------------------------------------------------------------\n   627→    // Close Call rounds\n   628→    // -----------------------------------------------------------------------\n   629→\n   630→    async insertCloseCallRound(params) {\n   631→      const rows = await sql<CloseCallRound[]>`\n   632→        INSERT INTO closecall_rounds (round_id, pda, server_key, open_price, open_price_expo)\n   633→        VALUES (\n   634→          ${params.roundId},\n   635→          ${params.pda},\n   636→          ${params.serverKey},\n   637→          ${params.openPrice},\n   638→          ${params.openPriceExpo}\n   639→        )\n   640→        RETURNING *\n   641→      `;\n   642→      return normalizeCloseCallRound(rows[0]!);\n   643→    },\n   644→\n   645→    async getCloseCallRound(roundId) {\n   646→      const rows = await sql<CloseCallRound[]>`\n   647→        SELECT * FROM closecall_rounds WHERE round_id = ${roundId}\n   648→      `;\n   649→      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n   650→    },\n   651→\n   652→    async getCloseCallCurrentRound() {\n   653→      const rows = await sql<CloseCallRound[]>`\n   654→        SELECT * FROM closecall_rounds\n   655→        WHERE phase = 'open'\n   656→        ORDER BY created_at DESC\n   657→        LIMIT 1\n   658→      `;\n   659→      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n   660→    },\n   661→\n   662→    async getCloseCallHistory(limit) {\n   663→      const rows = await sql<CloseCallRound[]>`\n   664→        SELECT * FROM closecall_rounds\n   665→        WHERE phase IN ('settled', 'refunded')\n   666→        ORDER BY settled_at DESC\n   667→        LIMIT ${limit}\n   668→      `;\n   669→      return rows.map(normalizeCloseCallRound);\n   670→    },\n   671→\n   672→    async settleCloseCallRound(roundId, updates) {\n   673→      const rows = await sql<CloseCallRound[]>`\n   674→        UPDATE closecall_rounds SET\n   675→          phase = ${updates.phase},\n   676→          outcome = ${updates.outcome},\n   677→          close_price = COALESCE(${updates.closePrice ?? null}, close_price),\n   678→          green_pool = COALESCE(${updates.greenPool ?? null}, green_pool),\n   679→          red_pool = COALESCE(${updates.redPool ?? null}, red_pool),\n   680→          total_fee = COALESCE(${updates.totalFee ?? null}, total_fee),\n   681→          green_entries = COALESCE(${updates.greenEntries ? sql.json(updates.greenEntries) : null}, green_entries),\n   682→          red_entries = COALESCE(${updates.redEntries ? sql.json(updates.redEntries) : null}, red_entries),\n   683→          settle_tx = COALESCE(${updates.settleTx ?? null}, settle_tx),\n   684→          settled_at = now()\n   685→        WHERE round_id = ${roundId}\n   686→        RETURNING *\n   687→      `;\n   688→      if (rows.length === 0) {\n   689→        throw new Error(`Close Call round not found: ${roundId}`);\n   690→      }\n   691→      return normalizeCloseCallRound(rows[0]!);\n   692→    },\n   693→\n   694→    // -----------------------------------------------------------------------\n   695→    // Transactions\n   696→    // -----------------------------------------------------------------------\n   697→\n   698→    async insertTransaction(params) {\n   699→      await sql`\n   700→        INSERT INTO transactions (wallet, game, match_id, tx_type, amount_lamports, tx_sig)\n   701→        VALUES (\n   702→          ${params.wallet},\n   703→          ${params.game},\n   704→          ${params.matchId},\n   705→          ${params.txType},\n   706→          ${params.amountLamports},\n   707→          ${params.txSig}\n   708→        )\n   709→        ON CONFLICT DO NOTHING\n   710→      `;\n   711→    },\n   712→\n   713→    async insertTransactions(params) {\n   714→      if (params.length === 0) return;\n   715→      const values = params.map((p) => ({\n   716→        wallet: p.wallet,\n   717→        game: p.game,\n   718→        match_id: p.matchId,\n   719→        tx_type: p.txType,\n   720→        amount_lamports: p.amountLamports,\n   721→        tx_sig: p.txSig,\n   722→      }));\n   723→      await sql`\n   724→        INSERT INTO transactions ${sql(values, \"wallet\", \"game\", \"match_id\", \"tx_type\", \"amount_lamports\", \"tx_sig\")}\n   725→        ON CONFLICT DO NOTHING\n   726→      `;\n   727→    },\n   728→\n   729→    async getTransactions(wallet, cursor, limit = 20, game) {\n   730→      const effectiveLimit = Math.min(limit, 50);\n   731→      if (cursor && game) {\n   732→        const rows = await sql<Transaction[]>`\n   733→          SELECT * FROM transactions\n   734→          WHERE wallet = ${wallet} AND id < ${cursor} AND game = ${game}\n   735→          ORDER BY id DESC\n   736→          LIMIT ${effectiveLimit}\n   737→        `;\n   738→        return rows.map(normalizeTransaction);\n   739→      }\n   740→      if (cursor) {\n   741→        const rows = await sql<Transaction[]>`\n   742→          SELECT * FROM transactions\n   743→          WHERE wallet = ${wallet} AND id < ${cursor}\n   744→          ORDER BY id DESC\n   745→          LIMIT ${effectiveLimit}\n   746→        `;\n   747→        return rows.map(normalizeTransaction);\n   748→      }\n   749→      if (game) {\n   750→        const rows = await sql<Transaction[]>`\n   751→          SELECT * FROM transactions\n   752→          WHERE wallet = ${wallet} AND game = ${game}\n   753→          ORDER BY id DESC\n   754→          LIMIT ${effectiveLimit}\n   755→        `;\n   756→        return rows.map(normalizeTransaction);\n   757→      }\n   758→      const rows = await sql<Transaction[]>`\n   759→        SELECT * FROM transactions\n   760→        WHERE wallet = ${wallet}\n   761→        ORDER BY id DESC\n   762→        LIMIT ${effectiveLimit}\n   763→      `;\n   764→      return rows.map(normalizeTransaction);\n   765→    },\n   766→\n   767→    // -----------------------------------------------------------------------\n   768→    // Referral — codes\n   769→    // -----------------------------------------------------------------------\n   770→\n   771→    async insertReferralCode(wallet, code) {\n   772→      const rows = await sql<ReferralCode[]>`\n   773→        INSERT INTO referral_codes (wallet, code)\n   774→        VALUES (${wallet}, ${code})\n   775→        RETURNING *\n   776→      `;\n   777→      return rows[0]!;\n   778→    },\n   779→\n   780→    async getReferralCodeByWallet(wallet) {\n   781→      const rows = await sql<ReferralCode[]>`\n   782→        SELECT * FROM referral_codes WHERE wallet = ${wallet}\n   783→      `;\n   784→      return rows[0];\n   785→    },\n   786→\n   787→    async getReferralCodeByCode(code) {\n   788→      const rows = await sql<ReferralCode[]>`\n   789→        SELECT * FROM referral_codes WHERE code = ${code}\n   790→      `;\n   791→      return rows[0];\n   792→    },\n   793→\n   794→    async upsertReferralCode(wallet, code) {\n   795→      const rows = await sql<ReferralCode[]>`\n   796→        INSERT INTO referral_codes (wallet, code)\n   797→        VALUES (${wallet}, ${code})\n   798→        ON CONFLICT (wallet) DO UPDATE SET\n   799→          code = ${code},\n   800→          updated_at = now()\n   801→        RETURNING *\n   802→      `;\n   803→      return rows[0]!;\n   804→    },\n   805→\n   806→    // -- Referral links -------------------------------------------------------\n   807→\n   808→    async insertReferralLink(referrerWallet, refereeWallet) {\n   809→      const rows = await sql<ReferralLink[]>`\n   810→        INSERT INTO referral_links (referrer_wallet, referee_wallet)\n   811→        VALUES (${referrerWallet}, ${refereeWallet})\n   812→        RETURNING *\n   813→      `;\n   814→      return rows[0]!;\n   815→    },\n   816→\n   817→    async getReferralLinkByReferee(refereeWallet) {\n   818→      const rows = await sql<ReferralLink[]>`\n   819→        SELECT * FROM referral_links WHERE referee_wallet = ${refereeWallet}\n   820→      `;\n   821→      return rows[0];\n   822→    },\n   823→\n   824→    async getReferralLinksByReferrer(referrerWallet) {\n   825→      const rows = await sql<ReferralLink[]>`\n   826→        SELECT * FROM referral_links WHERE referrer_wallet = ${referrerWallet}\n   827→        ORDER BY created_at DESC\n   828→      `;\n   829→      return rows;\n   830→    },\n   831→\n   832→    // -- Referral earnings & stats --------------------------------------------\n   833→\n   834→    async insertReferralEarning(params) {\n   835→      const rows = await sql<ReferralEarning[]>`\n   836→        INSERT INTO referral_earnings (\n   837→          referrer_wallet, referee_wallet, round_id, game_type,\n   838→          wager_lamports, fee_lamports,\n   839→          referrer_earned_lamports, referrer_rate_bps,\n   840→          referee_rebate_lamports, referee_rebate_rate_bps\n   841→        ) VALUES (\n   842→          ${params.referrerWallet}, ${params.refereeWallet}, ${params.roundId}, ${params.gameType},\n   843→          ${params.wagerLamports}, ${params.feeLamports},\n   844→          ${params.referrerEarnedLamports}, ${params.referrerRateBps},\n   845→          ${params.refereeRebateLamports}, ${params.refereeRebateRateBps}\n   846→        )\n   847→        RETURNING *\n   848→      `;\n   849→      return normalizeReferralEarning(rows[0]!);\n   850→    },\n   851→\n   852→    async getPendingBalance(wallet) {\n   853→      const rows = await sql<{ pending: string }[]>`\n   854→        SELECT COALESCE(\n   855→          (\n   856→            SELECT SUM(referrer_earned_lamports)\n   857→            FROM referral_earnings WHERE referrer_wallet = ${wallet}\n   858→          ), 0\n   859→        ) + COALESCE(\n   860→          (\n   861→            SELECT SUM(referee_rebate_lamports)\n   862→            FROM referral_earnings WHERE referee_wallet = ${wallet}\n   863→          ), 0\n   864→        ) - COALESCE(\n   865→          (\n   866→            SELECT SUM(amount_lamports)\n   867→            FROM referral_claims WHERE wallet = ${wallet} AND status IN ('pending', 'processing', 'completed')\n   868→          ), 0\n   869→        ) AS pending\n   870→      `;\n   871→      return rows[0]!.pending;\n   872→    },\n   873→\n   874→    async getReferralEarnings(wallet, page, limit) {\n   875→      const offset = (page - 1) * limit;\n   876→      const [countRows, rows] = await Promise.all([\n   877→        sql<{ count: string }[]>`\n   878→          SELECT COUNT(*)::TEXT AS count FROM referral_earnings\n   879→          WHERE referrer_wallet = ${wallet}\n   880→        `,\n   881→        sql<ReferralEarning[]>`\n   882→          SELECT * FROM referral_earnings\n   883→          WHERE referrer_wallet = ${wallet}\n   884→          ORDER BY created_at DESC\n   885→          LIMIT ${limit} OFFSET ${offset}\n   886→        `,\n   887→      ]);\n   888→      const total = Number(countRows[0]!.count);\n   889→      const totalPages = Math.max(1, Math.ceil(total / limit));\n   890→      return { items: rows.map(normalizeReferralEarning), totalPages };\n   891→    },\n   892→\n   893→    async getReferralStats(wallet) {\n   894→      const rows = await sql<ReferralStats[]>`\n   895→        SELECT\n   896→          (SELECT COUNT(*) FROM referral_links WHERE referrer_wallet = ${wallet})::INT\n   897→            AS referred_count,\n   898→          (\n   899→            SELECT COUNT(DISTINCT re.referee_wallet)\n   900→            FROM referral_earnings re\n   901→            JOIN referral_links rl ON rl.referee_wallet = re.referee_wallet AND rl.referrer_wallet = ${wallet}\n   902→            WHERE re.created_at > now() - INTERVAL '7 days'\n   903→          )::INT AS active_count,\n   904→          COALESCE(\n   905→            (\n   906→              SELECT SUM(re.wager_lamports)::TEXT\n   907→              FROM referral_earnings re\n   908→              JOIN referral_links rl ON rl.referee_wallet = re.referee_wallet AND rl.referrer_wallet = ${wallet}\n   909→            ), '0'\n   910→          ) AS total_volume_lamports,\n   911→          COALESCE(\n   912→            (SELECT SUM(referrer_earned_lamports)::TEXT FROM referral_earnings WHERE referrer_wallet = ${wallet}),\n   913→            '0'\n   914→          ) AS total_earned_lamports,\n   915→          (\n   916→            COALESCE((SELECT SUM(referrer_earned_lamports) FROM referral_earnings WHERE referrer_wallet = ${wallet}), 0)\n   917→            + COALESCE((SELECT SUM(referee_rebate_lamports) FROM referral_earnings WHERE referee_wallet = ${wallet}), 0)\n   918→            - COALESCE((SELECT SUM(amount_lamports) FROM referral_claims WHERE wallet = ${wallet} AND status IN ('pending','processing','completed')), 0)\n   919→          )::TEXT AS pending_lamports\n   920→      `;\n   921→      return rows[0]!;\n   922→    },\n   923→\n   924→    // -----------------------------------------------------------------------\n   925→    // Referral — claims & rates\n   926→    // -----------------------------------------------------------------------\n   927→\n   928→    async insertReferralClaim(wallet, amountLamports) {\n   929→      const rows = await sql<ReferralClaim[]>`\n   930→        INSERT INTO referral_claims (wallet, amount_lamports, status)\n   931→        VALUES (${wallet}, ${amountLamports}, 'pending')\n   932→        RETURNING *\n   933→      `;\n   934→      return rows[0]!;\n   935→    },\n   936→\n   937→    async getReferralClaim(claimId) {\n   938→      const rows = await sql<ReferralClaim[]>`\n   939→        SELECT * FROM referral_claims WHERE id = ${claimId}\n   940→      `;\n   941→      return rows[0];\n   942→    },\n   943→\n   944→    async updateClaimStatus(claimId, status, meta) {\n   945→      const rows = await sql<ReferralClaim[]>`\n   946→        UPDATE referral_claims\n   947→        SET\n   948→          status = ${status},\n   949→          tx_signature = COALESCE(${meta?.txSignature ?? null}, tx_signature),\n   950→          error = COALESCE(${meta?.error ?? null}, error),\n   951→          processed_at = ${status === \"completed\" || status === \"failed\" ? sql`now()` : sql`processed_at`}\n   952→        WHERE id = ${claimId}\n   953→        RETURNING *\n   954→      `;\n   955→      return rows[0]!;\n   956→    },\n   957→\n   958→    async getReferrerRate(wallet, defaultRateBps) {\n   959→      const rows = await sql<{ rate_bps: number }[]>`\n   960→        SELECT rate_bps FROM referral_kol_rates WHERE wallet = ${wallet}\n   961→      `;\n   962→      return rows[0]?.rate_bps ?? defaultRateBps;\n   963→    },\n   964→\n   965→    async close() {\n   966→      await sql.end();\n   967→    },\n   968→  };\n   969→}\n   970→"}]},"parent_tool_use_id":"toolu_011wZc6Yp3wLgud7rNN6S1rN","session_id":"9bf9a501-ff1b-4