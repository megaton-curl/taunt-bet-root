{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XBGLB5ax5NCHhYr7G38wXK","type":"tool_result","content":"     1→/**\n     2→ * Handler registry — maps event type strings to handler functions.\n     3→ *\n     4→ * One handler per event type (no pub/sub fan-out for v1).\n     5→ * Handlers must be idempotent — re-processing is a safe no-op.\n     6→ */\n     7→\n     8→import type { EventType } from \"./event-types.js\";\n     9→\n    10→export type EventHandler = (\n    11→  payload: Record<string, unknown>,\n    12→) => Promise<void>;\n    13→\n    14→const handlers = new Map<string, EventHandler>();\n    15→\n    16→export function registerHandler(\n    17→  eventType: EventType,\n    18→  handler: EventHandler,\n    19→): void {\n    20→  handlers.set(eventType, handler);\n    21→}\n    22→\n    23→export function getHandler(eventType: string): EventHandler | undefined {\n    24→  return handlers.get(eventType);\n    25→}\n    26→\n    27→/** Remove all registered handlers. Used by tests for isolation. */\n    28→export function clearHandlers(): void {\n    29→  handlers.clear();\n    30→}\n    31→"}]},"parent_tool_use_id":"toolu_01EsZ149HxsCGBH7ihZWCDXq","session_id":"22eabd0a-3a3b-489d-bc57-d8e8d222d116","uuid":"afae65d9-8aa5-4c06-9904-6a4ef6572343","timestamp":"2026-03-24T21:24:47.411Z"}
