 backoffSeconds,\n   141→            error: errorMessage,\n   142→            transition: \"processing → pending\",\n   143→          });\n   144→        }\n   145→      }\n   146→    }\n   147→  }\n   148→\n   149→  async function loop(): Promise<void> {\n   150→    if (!running) return;\n   151→    try {\n   152→      inflightPoll = poll();\n   153→      await inflightPoll;\n   154→    } catch (err) {\n   155→      logger.error(\"event queue worker poll error\", {\n   156→        error: err instanceof Error ? err.message : String(err),\n   157→      });\n   158→    } finally {\n   159→      inflightPoll = null;\n   160→    }\n   161→    if (running) {\n   162→      timeoutId = setTimeout(loop, pollIntervalMs);\n   163→    }\n   164→  }\n   165→\n   166→  return {\n   167→    start() {\n   168→      if (running) return;\n   169→      running = true;\n   170→      logger.info(\"event queue worker started\", { pollIntervalMs, batchSize });\n   171→      loop();\n   172→    },\n   173→    async stop() {\n   174→      running = false;\n   175→      if (timeoutId) {\n   176→        clearTimeout(timeoutId);\n   177→        timeoutId = null;\n   178→      }\n   179→      // Wait for in-flight poll to finish so no work is cut short"}]},"parent_tool_use_id":"toolu_01EsZ149HxsCGBH7ihZWCDXq","session_id":"22eabd0a-3a3b-489d-bc57-d8e8d222d116","uuid":"23fe952a-43eb-461b-bdc3-a7f15474f0f4","timestamp":"2026-03-24T21:24:46.243Z"}
