{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xvxvs815ehrjo2eyVfUD9p","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/sources/rng-utopia/services/backend/migrations/011_referral.sql"}]},"parent_tool_use_id":null,"session_id":"22eabd0a-3a3b-489d-bc57-d8e8d222d116","uuid":"e14148dc-a13b-42fb-b0a0-a76f3c25a566","timestamp":"2026-03-24T21:26:14.258Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/migrations/011_referral.sql","content":"-- 011_referral.sql — Referral system tables (spec 300).\n--\n-- Off-chain referral economics: code generation, referral linking,\n-- per-game earnings tracking, claim payouts, and KOL custom rates.\n-- No on-chain program changes — all tables are backend-only.\n\n-- Referral codes: one active code per wallet\nCREATE TABLE IF NOT EXISTS referral_codes (\n  id              SERIAL       PRIMARY KEY,\n  wallet          TEXT         NOT NULL UNIQUE,\n  code            TEXT         NOT NULL UNIQUE,\n  custom          BOOLEAN      NOT NULL DEFAULT false,\n  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n  updated_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n);\n\n-- Referral links: immutable referrer→referee binding (one referrer per player)\nCREATE TABLE IF NOT EXISTS referral_links (\n  id              SERIAL       PRIMARY KEY,\n  referrer_wallet TEXT         NOT NULL,\n  referee_wallet  TEXT         NOT NULL UNIQUE,\n  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n);\n\nCREATE INDEX IF NOT EXISTS idx_referral_links_referrer\n  ON referral_links (referrer_wallet);\n\n-- Referral earnings: one row per referee per round (idempotency guard)\nCREATE TABLE IF NOT EXISTS referral_earnings (\n  id                        SERIAL       PRIMARY KEY,\n  referrer_wallet           TEXT         NOT NULL,\n  referee_wallet            TEXT         NOT NULL,\n  round_id                  TEXT         NOT NULL,\n  game_type                 TEXT         NOT NULL,\n  wager_lamports            BIGINT       NOT NULL,\n  fee_lamports              BIGINT       NOT NULL,\n  referrer_earned_lamports  BIGINT       NOT NULL,\n  referrer_rate_bps         INTEGER      NOT NULL,\n  referee_rebate_lamports   BIGINT       NOT NULL,\n  referee_rebate_rate_bps   INTEGER      NOT NULL,\n  created_at                TIMESTAMPTZ  NOT NULL DEFAULT now(),\n\n  CONSTRAINT uq_referral_earnings_referee_round\n    UNIQUE (referee_wallet, round_id)\n);\n\nCREATE INDEX IF NOT EXISTS idx_referral_earnings_referrer\n  ON referral_earnings (referrer_wallet, created_at);\n\nCREATE INDEX IF NOT EXISTS idx_referral_earnings_referee\n  ON referral_earnings (referee_wallet, created_at);\n\nCREATE INDEX IF NOT EXISTS idx_referral_earnings_round_id\n  ON referral_earnings (round_id);\n\n-- Referral claims: async SOL payout tracking\nCREATE TABLE IF NOT EXISTS referral_claims (\n  id              UUID         PRIMARY KEY DEFAULT gen_random_uuid(),\n  wallet          TEXT         NOT NULL,\n  amount_lamports BIGINT       NOT NULL,\n  status          TEXT         NOT NULL DEFAULT 'pending',\n  tx_signature    TEXT,\n  error           TEXT,\n  requested_at    TIMESTAMPTZ  NOT NULL DEFAULT now(),\n  processed_at    TIMESTAMPTZ,\n\n  CONSTRAINT chk_referral_claims_status\n    CHECK (status IN ('pending', 'processing', 'completed', 'failed'))\n);\n\nCREATE INDEX IF NOT EXISTS idx_referral_claims_wallet\n  ON referral_claims (wallet, requested_at);\n\nCREATE INDEX IF NOT EXISTS idx_referral_claims_status\n  ON referral_claims (status)\n  WHERE status IN ('pending', 'processing');\n\n-- KOL custom referrer rates (overrides default 1000 bps)\nCREATE TABLE IF NOT EXISTS referral_kol_rates (\n  wallet          TEXT         PRIMARY KEY,\n  rate_bps        INTEGER      NOT NULL,\n  set_by          TEXT         NOT NULL,\n  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n  updated_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n);\n","structuredPatch":[],"originalFile":null}}
