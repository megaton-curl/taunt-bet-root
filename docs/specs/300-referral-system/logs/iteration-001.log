{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VHixePeNn3nGMT8it5cQxh","type":"tool_result","content":"     1→-- 010_event_queue.sql — Postgres-backed async event queue.\n     2→--\n     3→-- Decouples settlement hot path from secondary side-effects (reward delivery,\n     4→-- notifications, analytics). Events are committed atomically with their\n     5→-- triggering operation. Worker polls with SKIP LOCKED for safe concurrency.\n     6→\n     7→CREATE TABLE IF NOT EXISTS event_queue (\n     8→  id              BIGSERIAL    PRIMARY KEY,\n     9→  event_type      TEXT         NOT NULL,\n    10→  payload         JSONB        NOT NULL,\n    11→  status          TEXT         NOT NULL DEFAULT 'pending',\n    12→  attempts        INTEGER      NOT NULL DEFAULT 0,\n    13→  max_attempts    INTEGER      NOT NULL DEFAULT 3,\n    14→  scheduled_at    TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    15→  started_at      TIMESTAMPTZ,\n    16→  completed_at    TIMESTAMPTZ,\n    17→  error           TEXT,\n    18→  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    19→\n    20→  CONSTRAINT chk_event_queue_status\n    21→    CHECK (status IN ('pending', 'processing', 'completed', 'failed', 'dead'))\n    22→);\n    23→\n    24→-- Partial index for worker polling — only scans pending events\n    25→CREATE INDEX IF NOT EXISTS idx_event_queue_poll\n    26→  ON event_queue (scheduled_at)\n    27→  WHERE status = 'pending';\n    28→\n    29→-- Index for observability queries (dead events, recent failures)\n    30→CREATE INDEX IF NOT EXISTS idx_event_queue_status\n    31→  ON event_queue (status, created_at);\n    32→"}]},"parent_tool_use_id":"toolu_014cafuVWnUT6aMionBoRWHY","session_id":"22eabd0a-3a3b-489d-bc57-d8e8d222d116","uuid":"fd01e023-e3a2-45e2-8455-f94af6d8395b","timestamp":"2026-03-24T21:24:31.871Z"}
