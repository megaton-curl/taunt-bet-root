{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018LHXn7hYqPiSagev9k3bWd","type":"tool_result","content":"     1→-- 008_user_transactions.sql — Player transaction history ledger.\n     2→--\n     3→-- One row per user-visible game event (join, win, loss, refund).\n     4→-- Used by the profile transactions API. Idempotent writes via\n     5→-- UNIQUE constraint on (wallet, match_id, event).\n     6→\n     7→CREATE TABLE IF NOT EXISTS user_transactions (\n     8→  id              BIGSERIAL    PRIMARY KEY,\n     9→  wallet          TEXT         NOT NULL,\n    10→  game            TEXT         NOT NULL,\n    11→  match_id        TEXT         NOT NULL,\n    12→  event           TEXT         NOT NULL,\n    13→  amount_lamports BIGINT       NOT NULL,\n    14→  tx_sig          TEXT,\n    15→  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n    16→);\n    17→\n    18→-- Paginated history by wallet\n    19→CREATE INDEX IF NOT EXISTS idx_user_tx_wallet_created\n    20→  ON user_transactions (wallet, created_at DESC);\n    21→\n    22→-- Dedup / lookup by match_id\n    23→CREATE INDEX IF NOT EXISTS idx_user_tx_match_id\n    24→  ON user_transactions (match_id);\n    25→\n    26→-- Idempotency guard — ON CONFLICT DO NOTHING target\n    27→ALTER TABLE user_transactions\n    28→  ADD CONSTRAINT uq_user_tx_wallet_match_event\n    29→  UNIQUE (wallet, match_id, event);\n    30→"}]},"parent_tool_use_id":"toolu_014cafuVWnUT6aMionBoRWHY","session_id":"22eabd0a-3a3b-489d-bc57-d8e8d222d116","uuid":"787f1ea3-0e2a-4d75-b47b-9812f62dffe8","timestamp":"2026-03-24T21:24:34.730Z"}
