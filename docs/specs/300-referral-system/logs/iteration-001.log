{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XUoo3qxaVfQ4cqwGQngfUA","type":"tool_result","content":"     1→-- 005_closecall_rounds.sql — Separate table for Close Call pari-mutuel rounds.\n     2→--\n     3→-- Close Call uses oracle-resolved settlement (no secret/commitment), pari-mutuel\n     4→-- pools (multiple players per round), and Pyth price data — a fundamentally\n     5→-- different schema from the commit-reveal `rounds` table.\n     6→\n     7→CREATE TABLE IF NOT EXISTS closecall_rounds (\n     8→  round_id       TEXT PRIMARY KEY,       -- 16-char hex (8-byte random ID)\n     9→  pda            TEXT UNIQUE NOT NULL,    -- Round PDA on-chain\n    10→  server_key     TEXT NOT NULL,           -- Server pubkey that created the round\n    11→  phase          TEXT NOT NULL DEFAULT 'open',  -- open | settled | refunded\n    12→  open_price     BIGINT NOT NULL,        -- Pyth price at round creation\n    13→  open_price_expo INT NOT NULL,          -- Pyth exponent\n    14→  close_price    BIGINT,                 -- Pyth price at settlement (NULL until settled)\n    15→  outcome        TEXT NOT NULL DEFAULT 'pending',  -- pending | green | red | refund\n    16→  green_pool     BIGINT NOT NULL DEFAULT 0,  -- Total lamports on green side\n    17→  red_pool       BIGINT NOT NULL DEFAULT 0,  -- Total lamports on red side\n    18→  total_fee      BIGINT NOT NULL DEFAULT 0,  -- Fee collected (only on decisive rounds)\n    19→  green_entries  JSONB NOT NULL DEFAULT '[]', -- [{player, amountLamports}]\n    20→  red_entries    JSONB NOT NULL DEFAULT '[]', -- [{player, amountLamports}]\n    21→  settle_tx      TEXT,                   -- Settlement transaction signature\n    22→  created_at     TIMESTAMPTZ DEFAULT now(),\n    23→  settled_at     TIMESTAMPTZ             -- NULL until settled/refunded\n    24→);\n    25→\n    26→CREATE INDEX IF NOT EXISTS idx_closecall_rounds_phase ON closecall_rounds(phase);\n    27→CREATE INDEX IF NOT EXISTS idx_closecall_rounds_settled_at ON closecall_rounds(settled_at DESC);\n    28→"}]},"parent_tool_use_id":"toolu_014cafuVWnUT6aMionBoRWHY","session_id":"22eabd0a-3a3b-489d-bc57-d8e8d222d116","uuid":"2b5aabda-f92e-46b3-b66a-b92aada7e940","timestamp":"2026-03-24T21:24:33.999Z"}
