{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019pGCwwyJ4h7xEaEgYL4Euu","type":"tool_result","content":"     1→/**\n     2→ * Queue health — provides event counts by status for observability.\n     3→ */\n     4→\n     5→import type postgres from \"postgres\";\n     6→\n     7→export interface QueueDepth {\n     8→  pending: number;\n     9→  processing: number;\n    10→  dead: number;\n    11→  completed: number;\n    12→}\n    13→\n    14→export async function getQueueDepth(sql: postgres.Sql): Promise<QueueDepth> {\n    15→  const rows = await sql<{ status: string; count: string }[]>`\n    16→    SELECT status, count(*)::text AS count\n    17→    FROM event_queue\n    18→    WHERE status IN ('pending', 'processing', 'dead', 'completed')\n    19→    GROUP BY status\n    20→  `;\n    21→\n    22→  const counts: QueueDepth = { pending: 0, processing: 0, dead: 0, completed: 0 };\n    23→  for (const row of rows) {\n    24→    if (row.status in counts) {\n    25→      counts[row.status as keyof QueueDepth] = parseInt(row.count, 10);\n    26→    }\n    27→  }\n    28→  return counts;\n    29→}\n    30→"}]},"parent_tool_use_id":"toolu_01EsZ149HxsCGBH7ihZWCDXq","session_id":"22eabd0a-3a3b-489d-bc57-d8e8d222d116","uuid":"6846a79b-2c62-496e-bba3-9dc70e2e800a","timestamp":"2026-03-24T21:24:50.742Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PjdYyAJDmmkyf45HrJLzdd","type":"tool_result","content":"     1→/**\n     2→ * Unit tests for the async event queue module.\n     3→ *\n     4→ * Covers:\n     5→ * 1. emitEvent — inserts with correct fields, returns eventId\n     6→ * 2. emitEvent — rolled-back transaction does NOT persist\n     7→ * 3. Handler registry — register/get, unknown returns undefined\n     8→ * 4. Backoff calculation — attempt 1 → 5s, attempt 2 → 30s, attempt 3+ → 300s\n     9→ *\n    10→ * Requires a running Postgres database (same as backend).\n    11→ */\n    12→\n    13→import { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n    14→import postgres from \"postgres\";\n    15→import { emitEvent } from \"../emit-event.js\";\n    16→import { registerHandler, getHandler } from \"../handler-registry.js\";\n    17→import { EventTypes } from \"../event-types.js\";\n    18→import { getBackoffSeconds } from \"../worker.js\";\n    19→\n    20→describe(\"event queue unit tests\", () => {\n    21→  let sql: ReturnType<typeof postgres>;\n    22→\n    23→  beforeAll(async () => {\n    24→    sql = process.env.DATABASE_URL\n    25→      ? postgres(process.env.DATABASE_URL)\n    26→      : postgres({\n    27→          host: \"/var/run/postgresql\",\n    28→          database: \"rng_utopia_dev\",\n    29→          username: \"vscode\",\n    30→        });\n    31→  });\n    32→\n    33→  afterAll(async () => {\n    34→    await sql.end();\n    35→  });\n    36→\n    37→  beforeEach(async () => {\n    38→    await sql`TRUNCATE event_queue RESTART IDENTITY`;\n    39→  });\n    40→\n    41→  // -------------------------------------------------------------------------\n    42→  // emitEvent\n    43→  // -------------------------------------------------------------------------\n    44→\n    45→  describe(\"emitEvent\", () => {\n    46→    it(\"inserts a row with correct fields and returns eventId\", async () => {\n    47→      const payload = { referrerWallet: \"abc\", roundId: \"123\" };\n    48→\n    49→      const result = await sql.begin(async (tx) => {\n    50→        return emitEvent(\n    51→          tx as unknown as postgres.Sql,\n    52→          EventTypes.REFERRAL_GAME_SETTLED,\n    53→          payload,\n    54→        );\n    55→      });\n    56→\n    57→      expect(result.eventId).toBeTypeOf(\"bigint\");\n    58→      expect(result.eventId).toBeGreaterThan(0n);\n    59→\n    60→      // Verify the persisted row\n    61→      const rows = await sql`\n    62→        SELECT * FROM event_queue WHERE id = ${result.eventId.toString()}\n    63→      `;\n    64→      expect(rows).toHaveLength(1);\n    65→\n    66→      const row = rows[0]!;\n    67→      expect(row.event_type).toBe(\"referral.game_settled\");\n    68→      expect(row.payload).toEqual(payload);\n    69→      expect(row.status).toBe(\"pending\");\n    70→      expect(row.attempts).toBe(0);\n    71→      expect(row.max_attempts).toBe(3);\n    72→      expect(row.scheduled_at).toBeInstanceOf(Date);\n    73→      expect(row.created_at).toBeInstanceOf(Date);\n    74→    });\n    75→\n    76→    it(\"does NOT persist when transaction is rolled back\", async () => {\n    77→      let capturedId: bigint | undefined;\n    78→\n    79→      try {\n    80→        await sql.begin(async (tx) => {"}]},"parent_tool_use_id":"toolu_01EsZ149HxsCGBH7ihZWCDXq","session_id":"22eabd0a-3a3b-489d-bc57-d8e8d222d116","uuid":"834ef36d-db23-4a68-8c1c-af0c1eeab18e","timestamp":"2026-03-24T21:24:50.834Z"}
