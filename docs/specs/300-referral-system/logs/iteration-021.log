</button>\n      </div>\n\n      {/* Dogpile Raid indicator */}\n      <div className=\"raid-sidebar\">\n        <HeaderBossRaid />\n        <RNGBuffIndicator />\n      </div>\n\n      <div className=\"sb-body\">\n        {/* The Pit */}\n        <div className=\"nv-sec\">\n          <div className=\"nv-sec-lbl\">The Pit</div>\n\n          <NavLink to=\"/\" end className={({ isActive }) => `nv-item ${isActive ? \"active\" : \"\"}`} style={{ \"--nc\": \"var(--color-pink)\" } as React.CSSProperties}>\n            <div className=\"nv-ico\">\n              <svg viewBox=\"0 0 17 17\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"1.5\" strokeLinecap=\"round\" strokeLinejoin=\"round\">\n                <rect x=\"1\" y=\"1\" width=\"6.5\" height=\"6.5\" rx=\"1\" />\n                <rect x=\"9.5\" y=\"1\" width=\"6.5\" height=\"6.5\" rx=\"1\" />\n                <rect x=\"1\" y=\"9.5\" width=\"6.5\" height=\"6.5\" rx=\"1\" />\n                <rect x=\"9.5\" y=\"9.5\" width=\"6.5\" height=\"6.5\" rx=\"1\" />\n              </svg>\n            </div>\n            <span className=\"nv-lbl\">All Games</span>\n            <span className=\"nv-bdg gr\">5</span>\n          </NavLink>\n\n          <NavLink to=\"/coinflip\" className={({ isActive }) => `nv-item ${isActive ? \"active\" : \"\"}`} style={{ \"--nc\": \"var(--color-yellow)\" } as React.CSSProperties}>\n            <div className=\"nv-ico\">\n              <svg viewBox=\"0 0 17 17\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"1.5\" strokeLinecap=\"round\">\n                <circle cx=\"8.5\" cy=\"8.5\" r=\"7\" />\n                <line x1=\"6\" y1=\"5.5\" x2=\"6\" y2=\"11.5\" />\n                <line x1=\"11\" y1=\"5.5\" x2=\"11\" y2=\"11.5\" />\n                <line x1=\"6\" y1=\"8.5\" x2=\"11\" y2=\"8.5\" />\n              </svg>\n            </div>\n            <span className=\"nv-lbl\">Flip You</span>\n          </NavLink>\n\n          <NavLink to=\"/lord-of-rngs\" className={({ isActive }) => `nv-item ${isActive ? \"active\" : \"\"}`} style={{ \"--nc\": \"var(--color-pink)\" } as React.CSSProperties}>\n            <div className=\"nv-ico\">\n              <svg viewBox=\"0 0 17 17\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"1.4\" strokeLinecap=\"round\">\n                <circle cx=\"8.5\" cy=\"8.5\" r=\"7\" />\n                <circle cx=\"8.5\" cy=\"8.5\" r=\"2.2\" />\n                <line x1=\"8.5\" y1=\"1.5\" x2=\"8.5\" y2=\"6.3\" />\n                <line x1=\"8.5\" y1=\"10.7\" x2=\"8.5\" y2=\"15.5\" />\n                <line x1=\"1.5\" y1=\"8.5\" x2=\"6.3\" y2=\"8.5\" />\n                <line x1=\"10.7\" y1=\"8.5\" x2=\"15.5\" y2=\"8.5\" />\n              </svg>\n            </div>\n            <span className=\"nv-lbl\">Jackpot</span>\n          </NavLink>\n\n          <NavLink to=\"/close-call\" className={({ isActive }) => `nv-item ${isActive ? \"active\" : \"\"}`} style={{ \"--nc\": \"var(--color-green)\" } as React.CSSProperties}>\n            <div className=\"nv-ico\">\n              <svg viewBox=\"0 0 17 17\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"1.5\" strokeLinecap=\"round\">\n                <line x1=\"5\" y1=\"1.5\" x2=\"5\" y2=\"3.5\" />\n                <rect x=\"3\" y=\"3.5\" width=\"4\" height=\"8.5\" rx=\"0.6\" strokeWidth=\"1.4\" />\n                <line x1=\"5\" y1=\"12\" x2=\"5\" y2=\"15.5\" />\n                <line x1=\"12\" y1=\"1\" x2=\"12\" y2=\"3.5\" />\n                <rect x=\"10\" y=\"3.5\" width=\"4\" height=\"6\" rx=\"0.6\" strokeWidth=\"1.4\" />\n                <line x1=\"12\" y1=\"9.5\" x2=\"12\" y2=\"15.5\" />\n              </svg>\n            </div>\n            <span className=\"nv-lbl\">Close Call</span>\n          </NavLink>\n\n          <NavLink to=\"/crash\" className={({ isActive }) => `nv-item ${isActive ? \"active\" : \"\"}`} style={{ \"--nc\": \"var(--color-red)\" } as React.CSSProperties}>\n            <div className=\"nv-ico\">\n              <svg viewBox=\"0 0 17 17\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"1.5\" strokeLinecap=\"round\" strokeLinejoin=\"round\">\n                <polyline points=\"1.5,15 5,10.5 8,12.5 11.5,6.5 15.5,2\" />\n                <polyline points=\"11.5,2 15.5,2 15.5,6\" />\n              </svg>\n            </div>\n            <span className=\"nv-lbl\">Crypto Crash</span>\n          </NavLink>\n\n          <NavLink to=\"/game-of-trades\" className={({ isActive }) => `nv-item ${isActive ? \"active\" : \"\"}`} style={{ \"--nc\": \"var(--color-blue)\" } as React.CSSProperties}>\n            <div className=\"nv-ico\">\n              <svg viewBox=\"0 0 17 17\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"1.5\" strokeLinecap=\"round\">\n                <line x1=\"8.5\" y1=\"8.5\" x2=\"2\" y2=\"2\" />\n                <line x1=\"5.5\" y1=\"5.5\" x2=\"3.5\" y2=\"7.5\" />\n                <circle cx=\"11\" cy=\"11\" r=\"1.5\" />\n                <line x1=\"8.5\" y1=\"8.5\" x2=\"15\" y2=\"2\" />\n                <line x1=\"11.5\" y1=\"5.5\" x2=\"13.5\" y2=\"7.5\" />\n                <circle cx=\"6\" cy=\"11\" r=\"1.5\" />\n              </svg>\n            </div>\n            <span className=\"nv-lbl\">Game of Trades</span>\n          </NavLink>\n        </div>\n\n        {/* Player */}\n        <div className=\"nv-sec\">\n          <div className=\"nv-sec-lbl\">Player</div>\n\n          <NavLink to=\"/profile\" className={({ isActive }) => `nv-item ${isActive ? \"active\" : \"\"}`} style={{ \"--nc\": \"var(--color-blue)\" } as React.CSSProperties}>\n            <div className=\"nv-ico\">\n              <svg viewBox=\"0 0 17 17\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"1.5\" strokeLinecap=\"round\">\n                <circle cx=\"8.5\" cy=\"5.5\" r=\"3.2\" />\n                <path d=\"M2 16C2 12.5 4.7 10 8.5 10C12.3 10 15 12.5 15 16\" />\n              </svg>\n            </div>\n            <span className=\"nv-lbl\">Profile</span>\n          </NavLink>\n\n          <NavLink to=\"/loot\" className={({ isActive }) => `nv-item ${isActive ? \"active\" : \"\"}`} style={{ \"--nc\": \"var(--color-yellow)\" } as React.CSSProperties}>\n            <div className=\"nv-ico\">\n              <svg viewBox=\"0 0 17 17\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"1.5\" strokeLinecap=\"round\" strokeLinejoin=\"round\">\n                <rect x=\"1.5\" y=\"7.5\" width=\"14\" height=\"8\" rx=\"1\" />\n                <path d=\"M1.5 7.5V5.5C1.5 4.7 2.2 4 3.2 4H13.8C14.8 4 15.5 4.7 15.5 5.5V7.5\" />\n                <line x1=\"1.5\" y1=\"7.5\" x2=\"15.5\" y2=\"7.5\" />\n                <path d=\"M6.5 7.5C6.5 5.8 7.2 4 8.5 4C9.8 4 10.5 5.8 10.5 7.5\" />\n                <line x1=\"8.5\" y1=\"7.5\" x2=\"8.5\" y2=\"11\" />\n              </svg>\n            </div>\n            <span className=\"nv-lbl\">Loot Crates</span>\n            {unopenedChestCount > 0 && <span className=\"nv-bdg yl\">{unopenedChestCount}</span>}\n          </NavLink>\n\n          <NavLink to=\"/quests\" className={({ isActive }) => `nv-item ${isActive ? \"active\" : \"\"}`} style={{ \"--nc\": \"var(--color-green)\" } as React.CSSProperties}>\n            <div className=\"nv-ico\">\n              <svg viewBox=\"0 0 17 17\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"1.5\" strokeLinecap=\"round\" strokeLinejoin=\"round\">\n                <circle cx=\"8.5\" cy=\"8.5\" r=\"7\" />\n                <polyline points=\"5.5,8.5 7.2,10.5 11.5,6\" />\n              </svg>\n            </div>\n            <span className=\"nv-lbl\">Quests</span>\n            {claimableQuestCount > 0 && <span className=\"nv-bdg pk\">{claimableQuestCount}</span>}\n          </NavLink>\n        </div>\n\n        {/* Platform */}\n        <div className=\"nv-sec\">\n          <div className=\"nv-sec-lbl\">Platform</div>\n\n          <NavLink to=\"/fairness\" className={({ isActive }) => `nv-item ${isActive ? \"active\" : \"\"}`} style={{ \"--nc\": \"var(--color-muted2)\" } as React.CSSProperties}>\n            <div className=\"nv-ico\">\n              <svg viewBox=\"0 0 17 17\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"1.5\" strokeLinecap=\"round\" strokeLinejoin=\"round\">\n                <path d=\"M8.5 1.5L2 4V9C2 12.5 4.8 15.5 8.5 16C12.2 15.5 15 12.5 15 9V4Z\" />\n                <polyline points=\"5.5,8.5 7.5,10.5 11.5,6.5\" />\n              </svg>\n            </div>\n            <span className=\"nv-lbl\">Provably Fair</span>\n          </NavLink>\n        </div>\n      </div>\n\n      {/* User footer */}\n      {connected && address && (\n        <div className=\"sb-foot\">\n          <div className=\"sf-user\">\n            <div className=\"sf-av\">\n              <svg viewBox=\"0 0 18 18\" fill=\"none\" stroke=\"white\" strokeWidth=\"1.6\" strokeLinecap=\"round\">\n                <circle cx=\"9\" cy=\"6\" r=\"3.5\" />\n                <path d=\"M2 17C2 13.5 5 11 9 11C13 11 16 13.5 16 17\" />\n              </svg>\n            </div>\n            <div className=\"sf-info\">\n              <div className=\"sf-name\">{address.slice(0, 4)}â€¦{address.slice(-4)}</div>\n            </div>\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n","structuredPatch":[{"oldStart":158,"oldLines":6,"newStart":158,"newLines":17,"lines":["             <span className=\"nv-lbl\">Quests</span>","             {claimableQuestCount > 0 && <span className=\"nv-bdg pk\">{claimableQuestCount}</span>}","           </NavLink>","+","+          <NavLink to=\"/referrals\" className={({ isActive }) => `nv-item ${isActive ? \"active\" : \"\"}`} style={{ \"--nc\": \"var(--color-green)\" } as React.CSSProperties}>","+            <div className=\"nv-ico\">","+              <svg viewBox=\"0 0 17 17\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"1.5\" strokeLinecap=\"round\" strokeLinejoin=\"round\">","+                <path d=\"M7 3.5H4C3.2 3.5 2.5 4.2 2.5 5V12C2.5 12.8 3.2 13.5 4 13.5H13C13.8 13.5 14.5 12.8 14.5 12V9.5\" />","+                <path d=\"M10 2L14.5 2L14.5