s, setStats] = useState<ReferralStatsResponse | null>(null);\n\n  useEffect(() => {\n    if (!accessToken) return;\n    let cancelled = false;\n    getReferralStats(accessToken)\n      .then((res) => {\n        if (!cancelled) setStats(res);\n      })\n      .catch(() => {\n        /* stats unavailable — show zeros */\n      })\n      .finally(() => {\n        if (!cancelled) setLoading(false);\n      });\n    return () => {\n      cancelled = true;\n    };\n  }, [accessToken]);\n\n  const items = [\n    { label: \"Referred Players\", value: stats ? String(stats.referredCount) : \"0\" },\n    { label: \"Active (7d)\", value: stats ? String(stats.activeCount) : \"0\" },\n    { label: \"Total Volume\", value: stats ? formatSol(stats.totalVolumeLamports) + \" SOL\" : \"0 SOL\" },\n    { label: \"Total Earned\", value: stats ? formatSol(stats.totalEarnedLamports) + \" SOL\" : \"0 SOL\" },\n  ];\n\n  return (\n    <div className=\"ref-stats-card\">\n      <h3 className=\"ref-stats-card__title\">Stats</h3>\n      <div className=\"ref-stats-card__grid\">\n        {items.map((item) => (\n          <div key={item.label} className=\"ref-stats-card__stat\">\n            {loading ? (\n              <div className=\"ref-stats-card__skeleton\" />\n            ) : (\n              <div className=\"ref-stats-card__value\">{item.value}</div>\n            )}\n            <div className=\"ref-stats-card__label\">{item.label}</div>\n          </div>\n        ))}\n      </div>\n    </div>\n  );\n}\n```\n\n## 3. ReferralLinkCard.tsx\n\n```typescript\nimport { useCallback, useEffect, useState } from \"react\";\nimport { useSession } from \"../../context/SessionContext\";\nimport {\n  getReferralCode,\n  setReferralCode,\n  type ReferralCodeResponse,\n} from \"../../lib/referral-api\";\n\nconst CODE_RE = /^[a-z0-9-]{3,16}$/;\n\nexport function ReferralLinkCard() {\n  const { accessToken } = useSession();\n\n  const [loading, setLoading] = useState(true);\n  const [saving, setSaving] = useState(false);\n  const [existing, setExisting] = useState<ReferralCodeResponse | null>(null);\n  const [editing, setEditing] = useState(false);\n  const [input, setInput] = useState(\"\");\n  const [error, setError] = useState(\"\");\n  const [copied, setCopied] = useState(false);\n\n  // Fetch existing code on mount\n  useEffect(() => {\n    if (!accessToken) return;\n    let cancelled = false;\n    getReferralCode(accessToken)\n      .then((res) => {\n        if (!cancelled) setExisting(res);\n      })\n      .catch(() => {\n        /* 404 = no code yet, ignore */\n      })\n      .finally(() => {\n        if (!cancelled) setLoading(false);\n      });\n    return () => {\n      cancelled = true;\n    };\n  }, [accessToken]);\n\n  const validate = (code: string): string => {\n    if (code.length < 3) return \"Code must be at least 3 characters\";\n    if (code.length > 16) return \"Code must be at most 16 characters\";\n    if (!CODE_RE.test(code)) return \"Only lowercase letters, numbers, and hyphens\";\n    return \"\";\n  };\n\n  const handleInputChange = (val: string) => {\n    const lower = val.toLowerCase();\n    setInput(lower);\n    setError(lower ? validate(lower) : \"\");\n  };\n\n  const handleSubmit = useCallback(async () => {\n    if (!accessToken) return;\n    const err = validate(input);\n    if (err) {\n      setError(err);\n      return;\n    }\n    setSaving(true);\n    setError(\"\");\n    try {\n      const res = await setReferralCode(accessToken, input);\n      setExisting(res);\n      setEditing(false);\n      setInput(\"\");\n    } catch (e) {\n      setError(e instanceof Error ? e.message : \"Failed to set code\");\n    } finally {\n      setSaving(false);\n    }\n  }, [accessToken, input]);\n\n  const handleCopy = useCallback(() => {\n    if (!existing) return;\n    navigator.clipboard.writeText(existing.url).then(() => {\n      setCopied(true);\n      setTimeout(() => setCopied(false), 2000);\n    });\n  }, [existing]);\n\n  if (loading) {\n    return (\n      <div className=\"ref-link-card\">\n        <h3 className=\"ref-link-card__title\">Your Referral Link</h3>\n        <div className=\"ref-link-card__skeleton\" />\n      </div>\n    );\n  }\n\n  // No code yet, or user is editing/changing\n  if (!existing || editing) {\n    return (\n      <div className=\"ref-link-card\">\n        <h3 className=\"ref-link-card__title\">\n          {existing ? \"Change Referral Code\" : \"Your Referral Link\"}\n        </h3>\n        {!existing && (\n          <p className=\"ref-link-card__desc\">\n            Choose a custom code to create your referral link.\n          </p>\n        )}\n        <div className=\"ref-link-card__form\">\n          <div className=\"ref-link-card__input-row\">\n            <span className=\"ref-link-card__prefix\">taunt.bet/r/</span>\n            <input\n              type=\"text\"\n              className=\"ref-link-card__input\"\n              placeholder=\"my-code\"\n              value={input}\n              onChange={(e) => handleInputChange(e.target.value)}\n              onKeyDown={(e) => {\n                if (e.key === \"Enter\" && !saving) handleSubmit();\n              }}\n              maxLength={16}\n              disabled={saving}\n              autoFocus\n            />\n          </div>\n          {error && <p className=\"ref-link-card__error\">{error}</p>}\n          <div className=\"ref-link-card__actions\">\n            <button\n              type=\"button\"\n              className=\"ref-link-card__btn ref-link-card__btn--primary\"\n              onClick={handleSubmit}\n              disabled={saving || !input || !!error}\n            >\n              {saving ? \"Saving...\" : existing ? \"Update Code\" : \"Set Code\"}\n            </button>\n            {existing && (\n              <button\n                type=\"button\"\n                className=\"ref-link-card__btn ref-link-card__btn--secondary\"\n                onClick={() => {\n                  setEditing(false);\n                  setInput(\"\");\n                  setError(\"\");\n                }}\n              >\n                Cancel\n              </button>\n            )}\n          </div>\n        </div>\n      </div>\n    );\n  }\n\n  // Code exists — show display mode\n  return (\n    <div className=\"ref-link-card\">\n      <h3 className=\"ref-link-card__title\">Your Referral Link</h3>\n      <div className=\"ref-link-card__display\">\n        <div className=\"ref-link-card__url-row\">\n          <input\n            type=\"text\"\n            className=\"ref-link-card__url\"\n            value={existing.url}\n            readOnly\n          />\n          <button\n            type=\"button\"\n            className=\"ref-link-card__btn ref-link-card__btn--copy\"\n            onClick={handleCopy}\n          >\n            {copied ? \"Copied!\" : \"Copy Link\"}\n          </button>\n        </div>\n        <button\n          type=\"button\"\n          className=\"ref-link-card__change\"\n          onClick={() => {\n            setEditing(true);\n            setInput(existing.code);\n          }}\n        >\n          Change code\n        </button>\n      </div>\n    </div>\n  );\n}\n```\n\n## 4. referral-api.ts\n\n```typescript\n/**\n * Thin fetch wrappers for the /referral/* backend endpoints.\n * All calls require JWT Bearer auth from useSession().accessToken.\n */\n\nconst BACKEND_URL = (\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n).replace(/\\/$/, \"\");\n\n/* ── Response types ─────────────────────────────────────────────── */\n\nexport interface ReferralCodeResponse {\n  code: string;\n  url: string;\n}\n\nexport interface ApplyReferralResponse {\n  referrer: string;\n  benefit: string;\n}\n\nexport interface ReferralStatsResponse {\n  referredCount: number;\n  activeCount: number;\n  totalVolumeLamports: string;\n  totalEarnedLamports: string;\n  pendingLamports: string;\n}\n\nexport interface ReferralEarningItem {\n  roundId: string;\n  gameType: string;\n  refereeWallet: string;\n  wagerLamports: string;\n  earnedLamports: string;\n  createdAt: string;\n}\n\nexport interface ReferralEarningsResponse {\n  items: ReferralEarningItem[];\n  pagination: { page: number; totalPages: number };\n}\n\nexport interface ClaimResponse {\n  claimId: string;\n  amountLamports: string;\n  status: \"pending\" | \"completed\" | \"failed\";\n  txSignature?: string;\n}\n\n/* ── Helpers ────────────────────────────────────────────────────── */\n\nasync function parseResponse<T>(res: Response): Promise<T> {\n  const json = await res.json();\n  if (!res.ok) {\n    const err = json?.error;\n    const msg =\n      typeof err === \"string\"\n        ? err\n        : typeof err?.message === \"string\"\n          ? err.message\n          : `Referral request failed (${res.status})`;\n    throw new Error(msg);\n  }\n  return json as T;\n}\n\nfunction authHeaders(token: string): Record<string, string> {\n  return {\n    \"Content-Type\": \"application/json\",\n    Authorization: `Bearer ${token}`,\n  };\n}\n\n/* ── API functions ──────────────────────────────────────────────── */\n\n/** Set (or replace) the authenticated player's referral code. */\nexport async function setReferralCode(\n  token: string,\n  code: string,\n): Promise<ReferralCodeResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    method: \"POST\",\n    headers: authHeaders(token),\n    body: JSON.stringify({ code }),\n  });\n  return parseResponse<ReferralCodeResponse>(res);\n}\n\n/** Get the authenticated player's current referral code, or throw on 404. */\nexport async function getReferralCode(\n  token: string,\n): Promise<ReferralCodeResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ReferralCodeResponse>(res);\n}\n\n/** Apply a referral code to the authenticated player (link to referrer). */\nexport async function applyReferralCode(\n  token: string,\n  code: string,\n): Promise<ApplyReferralResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/apply`, {\n    method: \"POST\",\n    headers: authHeaders(token),\n    body: JSON.stringify({ code }),\n  });\n  return parseResponse<ApplyReferralResponse>(res);\n}\n\n/** Get referral summary stats for the authenticated player. */\nexport async function getReferralStats(\n  token: string,\n): Promise<ReferralStatsResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/stats`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ReferralStatsResponse>(res);\n}\n\n/** Get paginated per-game referral earnings log. */\nexport async function getReferralEarnings(\n  token: string,\n  page?: number,\n  limit?: number,\n): Promise<ReferralEarningsResponse> {\n  const parts: string[] = [];\n  if (page != null) parts.push(`page=${page}`);\n  if (limit != null) parts.push(`limit=${limit}`);\n  const qs = parts.length ? `?${parts.join(\"&\")}` : \"\";\n  const res = await fetch(`${BACKEND_URL}/referral/earnings${qs}`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ReferralEarningsResponse>(res);\n}\n\n/** Request an async claim of all pending referral earnings. Returns 202. */\nexport async function requestReferralClaim(\n  token: string,\n): Promise<ClaimResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/claim`, {\n    method: \"POST\",\n    headers: authHeaders(token),\n  });\n  return parseResponse<ClaimResponse>(res);\n}\n\n/** Poll the status of an existing claim by ID. */\nexport async function pollClaimStatus(\n  token: string,\n  claimId: string,\n): Promise<ClaimResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/claim/${claimId}`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ClaimResponse>(res);\n}\n```\n\n## 5. index.ts\n\n```typescript\nexport { useReferralApply } from \"./hooks/useReferralApply\";\nexport { ReferralPage } from \"./ReferralPage\";\n```"}],"totalDurationMs":28238,"totalTokens":45884,"totalToolUseCount":5,"usage":{"input_tokens":7,"cache_creation_input_tokens":11528,"cache_read_input_tokens":30137,"output_tokens":4212,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":11528},"inference_geo":"","iterations":[],"speed":"standard"}}}
