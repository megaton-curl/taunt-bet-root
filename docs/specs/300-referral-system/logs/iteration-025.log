{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QUNUYJKrgzkpaEeBrc9uc4","type":"tool_result","content":"     1→/**\n     2→ * ChestDropNotification - Toast notification when a chest drops\n     3→ *\n     4→ * Shows a brief notification when the player earns a treasure chest\n     5→ * from the RNG Buff while wagering.\n     6→ */\n     7→\n     8→import { useQuests } from \"../context/QuestsContext\";\n     9→\n    10→export function ChestDropNotification() {\n    11→  const { chestDropNotification } = useQuests();\n    12→\n    13→  if (!chestDropNotification.visible) {\n    14→    return null;\n    15→  }\n    16→\n    17→  return (\n    18→    <div className=\"chest-drop-notification\">\n    19→      <div className=\"chest-drop-notification__content\">\n    20→        <div className=\"chest-drop-notification__icon\">\n    21→          <svg viewBox=\"0 0 24 24\" width=\"28\" height=\"28\" fill=\"none\">\n    22→            {/* Treasure chest icon */}\n    23→            <rect x=\"3\" y=\"10\" width=\"18\" height=\"10\" rx=\"2\" fill=\"#8B4513\" stroke=\"#5D3A1A\" strokeWidth=\"1.5\" />\n    24→            <rect x=\"3\" y=\"8\" width=\"18\" height=\"4\" rx=\"1\" fill=\"#A0522D\" stroke=\"#5D3A1A\" strokeWidth=\"1.5\" />\n    25→            <rect x=\"10\" y=\"12\" width=\"4\" height=\"4\" rx=\"1\" fill=\"#FFD700\" stroke=\"#B8860B\" strokeWidth=\"1\" />\n    26→            <circle cx=\"12\" cy=\"14\" r=\"1\" fill=\"#B8860B\" />\n    27→          </svg>\n    28→        </div>\n    29→        <div className=\"chest-drop-notification__text\">\n    30→          <span className=\"chest-drop-notification__title\">Crate Drop!</span>\n    31→          <span className=\"chest-drop-notification__subtitle\">\n    32→            {chestDropNotification.source === \"rng_buff\"\n    33→              ? \"Heater Drop!\"\n    34→              : \"Quest reward!\"}\n    35→          </span>\n    36→        </div>\n    37→      </div>\n    38→    </div>\n    39→  );\n    40→}\n    41→"}]},"parent_tool_use_id":"toolu_01Ew1UwqLQQVnAjBH54kbdMX","session_id":"e1866399-0612-4b5c-bae9-0fe08bc8e43b","uuid":"b7c064b8-608a-4cab-b154-08416069fb60","timestamp":"2026-03-25T13:27:42.066Z"}
