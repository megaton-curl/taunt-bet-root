{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012S8irJb25C5wpjyD8EucWJ","type":"tool_result","content":"     1→import { useEffect, useRef } from \"react\";\n     2→import { useSession } from \"../../../context/SessionContext\";\n     3→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n     4→import { applyReferralCode } from \"../../../lib/referral-api\";\n     5→\n     6→const STORAGE_KEY = \"referral_code\";\n     7→\n     8→/**\n     9→ * On authentication, if a referral code is stored in localStorage (from /r/:code),\n    10→ * auto-apply it via POST /referral/apply. Clears storage on success or permanent\n    11→ * failure (invalid code, already linked, self-referral). Keeps on transient failure\n    12→ * (network error) so it retries next auth.\n    13→ */\n    14→export function useReferralApply() {\n    15→  const { isAuthenticated, accessToken } = useSession();\n    16→  const { address } = useWallet();\n    17→  const appliedRef = useRef(false);\n    18→\n    19→  useEffect(() => {\n    20→    if (!isAuthenticated || !accessToken || !address) {\n    21→      appliedRef.current = false;\n    22→      return;\n    23→    }\n    24→\n    25→    // Prevent duplicate calls within the same auth session\n    26→    if (appliedRef.current) return;\n    27→\n    28→    let stored: string | null = null;\n    29→    try {\n    30→      stored = localStorage.getItem(STORAGE_KEY);\n    31→    } catch {\n    32→      // localStorage unavailable\n    33→      return;\n    34→    }\n    35→\n    36→    if (!stored) return;\n    37→\n    38→    let code: string;\n    39→    try {\n    40→      const parsed = JSON.parse(stored);\n    41→      code = parsed?.code;\n    42→    } catch {\n    43→      // Corrupt data — remove it\n    44→      try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n    45→      return;\n    46→    }\n    47→\n    48→    if (!code || typeof code !== \"string\") {\n    49→      try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n    50→      return;\n    51→    }\n    52→\n    53→    appliedRef.current = true;\n    54→\n    55→    applyReferralCode(accessToken, code)\n    56→      .then(() => {\n    57→        try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n    58→        // TODO: replace with toast notification when toast system is implemented\n    59→        console.warn(\"[referral] Referral code applied successfully\");\n    60→      })\n    61→      .catch((err: Error) => {\n    62→        const msg = err.message ?? \"\";\n    63→        // Permanent failures — code invalid, already linked, self-referral\n    64→        const isPermanent =\n    65→          msg.includes(\"ALREADY_LINKED\") ||\n    66→          msg.includes(\"SELF_REFERRAL\") ||\n    67→          msg.includes(\"NOT_FOUND\") ||\n    68→          msg.includes(\"INVALID\") ||\n    69→          msg.includes(\"already linked\") ||\n    70→          msg.includes(\"not found\") ||\n    71→          msg.includes(\"Cannot refer yourself\");\n    72→\n    73→        if (isPermanent) {\n    74→          try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n    75→        }\n    76→        // Transient failures (network, 500): keep localStorage for retry on next auth\n    77→      });\n    78→  }, [isAuthenticated, accessToken, address]);\n    79→}\n    80→"}]},"parent_tool_use_id":"toolu_01Ew1UwqLQQVnAjBH54kbdMX","session_id":"e1866399-0612-4b5c-bae9-0fe08bc8e43b","uuid":"945cfe62-f419-491b-baa9-9e537d72d4e4","timestamp":"2026-03-25T13:27:31.958Z"}
