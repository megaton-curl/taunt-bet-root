{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EVb8nxSPK85dQhEpoo6fuP","type":"tool_result","content":"     1→/**\n     2→ * ProfileTransactions - Transaction history tab content\n     3→ *\n     4→ * Fetches real transaction data from the backend API and displays\n     5→ * a paginated table with tx types, amounts, and explorer links.\n     6→ */\n     7→\n     8→import { GAME_NAMES } from \"../types\";\n     9→import type { GameId, TransactionType } from \"../types\";\n    10→import { useTransactions } from \"../hooks/useTransactions\";\n    11→import { useSolPrice } from \"../hooks/useSolPrice\";\n    12→import { explorerTxUrl } from \"../../../lib/solana-env\";\n    13→\n    14→/** Format lamports as SOL string with +/- prefix and optional USD estimate */\n    15→function formatAmount(\n    16→  lamports: string,\n    17→  txType: TransactionType,\n    18→  solUsdPrice: number | null,\n    19→): string {\n    20→  const sol = Number(lamports) / 1e9;\n    21→  const prefix = txType === \"deposit\" ? \"-\" : \"+\";\n    22→  const solStr =\n    23→    prefix +\n    24→    sol.toLocaleString(\"en-US\", {\n    25→      minimumFractionDigits: 2,\n    26→      maximumFractionDigits: 4,\n    27→    }) +\n    28→    \" SOL\";\n    29→  if (solUsdPrice == null) return solStr;\n    30→  const usd = sol * solUsdPrice;\n    31→  return `${solStr} (~$${usd.toLocaleString(\"en-US\", { minimumFractionDigits: 2, maximumFractionDigits: 2 })})`;\n    32→}\n    33→\n    34→/** Format ISO date as relative time */\n    35→function formatTime(iso: string): string {\n    36→  const date = new Date(iso);\n    37→  const diffMs = Date.now() - date.getTime();\n    38→  const diffMins = Math.floor(diffMs / 60000);\n    39→  const diffHours = Math.floor(diffMs / 3600000);\n    40→  const diffDays = Math.floor(diffMs / 86400000);\n    41→\n    42→  if (diffMins < 1) return \"Just now\";\n    43→  if (diffMins < 60) return `${diffMins}m ago`;\n    44→  if (diffHours < 24) return `${diffHours}h ago`;\n    45→  if (diffDays < 7) return `${diffDays}d ago`;\n    46→  return date.toLocaleDateString();\n    47→}\n    48→\n    49→/** Build the deep-link path for a match */\n    50→function matchPath(gameId: GameId, matchId: string): string {\n    51→  return `/${gameId}/${matchId}`;\n    52→}\n    53→\n    54→/** Transaction type display label */\n    55→const TX_TYPE_LABELS: Record<string, string> = {\n    56→  deposit: \"DEPOSIT\",\n    57→  payout: \"PAYOUT\",\n    58→  refund: \"REFUND\",\n    59→};\n    60→\n    61→export function ProfileTransactions() {\n    62→  const { transactions, loading, loadingMore, nextCursor, loadMore } =\n    63→    useTransactions();\n    64→  const solPrice = useSolPrice();\n    65→\n    66→  if (loading) {\n    67→    return (\n    68→      <div className=\"profile-transactions\">\n    69→        <div className=\"profile-transactions__skeleton\">\n    70→          {Array.from({ length: 5 }, (_, i) => (\n    71→            <div key={i} className=\"profile-transactions__skeleton-row\" />\n    72→          ))}\n    73→        </div>\n    74→      </div>\n    75→    );\n    76→  }\n    77→\n    78→  if (transactions.length === 0) {\n    79→    return (\n    80→      <div className=\"profile-transactions\">\n    81→        <div className=\"profile-transactions__empty\">\n    82→          <p>No transactions yet.</p>\n    83→          <p>Start playing to build your history!</p>\n    84→        </div>\n    85→      </div>\n    86→    );\n    87→  }\n    88→\n    89→  return (\n    90→    <div className=\"profile-transactions\">\n    91→      <table className=\"profile-transactions__table\">\n    92→        <thead>\n    93→          <tr>\n    94→            <th>Time</th>\n    95→            <th>Game</th>\n    96→            <th>Type</th>\n    97→            <th>Amount</th>\n    98→            <th></th>\n    99→          </tr>\n   100→        </thead>\n   101→        <tbody>\n   102→          {transactions.map((tx) => (\n   103→            <tr key={tx.id}>\n   104→              <td>{formatTime(tx.createdAt)}</td>\n   105→              <td>\n   106→                <a\n   107→                  href={matchPath(tx.gameId, tx.matchId)}\n   108→                  className=\"profile-transactions__match-link\"\n   109→                >\n   110→                  {GAME_NAMES[tx.gameId] ?? tx.gameId}\n   111→                </a>\n   112→              </td>\n   113→              <td\n   114→                className={`profile-transactions__tx-type profile-transactions__tx-type--${tx.txType}`}\n   115→              >\n   116→                {TX_TYPE_LABELS[tx.txType] ?? tx.txType}\n   117→              </td>\n   118→              <td\n   119→                className={`profile-transactions__amount profile-transactions__amount--${tx.txType}`}\n   120→              >\n   121→                {formatAmount(tx.amountLamports, tx.txType, solPrice)}\n   122→              </td>\n   123→              <td>\n   124→                <a\n   125→                  href={explorerTxUrl(tx.txSig)}\n   126→                  target=\"_blank\"\n   127→                  rel=\"noopener noreferrer\"\n   128→                  className=\"profile-transactions__explorer-link\"\n   129→                  title=\"View on Solana Explorer\"\n   130→                >\n   131→                  &#x2197;\n   132→                </a>\n   133→              </td>\n   134→            </tr>\n   135→          ))}\n   136→        </tbody>\n   137→      </table>\n   138→\n   139→      {nextCursor && (\n   140→        <div className=\"profile-transactions__load-more\">\n   141→          <button\n   142→            type=\"button\"\n   143→            className=\"profile-transactions__load-more-btn\"\n   144→            onClick={loadMore}\n   145→            disabled={loadingMore}\n   146→          >\n   147→            {loadingMore ? \"Loading...\" : \"Load more\"}\n   148→          </button>\n   149→        </div>\n   150→      )}"}]},"parent_tool_use_id":"toolu_01Ew1UwqLQQVnAjBH54kbdMX","session_id":"e1866399-0612-4b5c-bae9-0fe08bc8e43b","uuid":"54fbc7e7-995f-45e5-a303-406b3ef43635","timestamp":"2026-03-25T13:27:38.930Z"}
