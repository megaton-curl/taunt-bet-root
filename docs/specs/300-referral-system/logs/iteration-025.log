{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01D8wYjY4o9WAtixXNxv4gkB","type":"message","role":"assistant","content":[{"type":"text","text":"Now create the `ReferralClaimCard` component."}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":184,"cache_read_input_tokens":69380,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":184},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e1866399-0612-4b5c-bae9-0fe08bc8e43b","uuid":"8fa19c19-19e5-4012-b2f3-3e40859753a2"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01D8wYjY4o9WAtixXNxv4gkB","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Ux5SL4H8Ysk9jZQVfG2iQ6","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/referral/ReferralClaimCard.tsx","content":"import { useCallback, useEffect, useRef, useState } from \"react\";\nimport { useSession } from \"../../context/SessionContext\";\nimport {\n  getReferralStats,\n  requestReferralClaim,\n  pollClaimStatus,\n  type ReferralStatsResponse,\n  type ClaimResponse,\n} from \"../../lib/referral-api\";\nimport { explorerTxUrl } from \"../../lib/solana-env\";\n\nconst LAMPORTS_PER_SOL = 1_000_000_000;\nconst MIN_CLAIM_LAMPORTS = 10_000_000; // 0.01 SOL\n\nfunction formatSol(lamportsStr: string): string {\n  const sol = Number(lamportsStr) / LAMPORTS_PER_SOL;\n  if (sol >= 1_000_000) return `${(sol / 1_000_000).toFixed(1)}M`;\n  if (sol >= 1000) return `${(sol / 1000).toFixed(1)}k`;\n  if (sol >= 1) return sol.toFixed(2);\n  if (sol >= 0.01) return sol.toFixed(3);\n  return sol.toFixed(4);\n}\n\nexport function ReferralClaimCard() {\n  const { accessToken } = useSession();\n  const [loading, setLoading] = useState(true);\n  const [stats, setStats] = useState<ReferralStatsResponse | null>(null);\n  const [claiming, setClaiming] = useState(false);\n  const [claimResult, setClaimResult] = useState<ClaimResponse | null>(null);\n  const [error, setError] = useState(\"\");\n  const pollRef = useRef<ReturnType<typeof setTimeout> | null>(null);\n\n  const fetchStats = useCallback(async () => {\n    if (!accessToken) return;\n    try {\n      const res = await getReferralStats(accessToken);\n      setStats(res);\n    } catch {\n      /* unavailable — show zeros */\n    } finally {\n      setLoading(false);\n    }\n  }, [accessToken]);\n\n  useEffect(() => {\n    fetchStats();\n  }, [fetchStats]);\n\n  // Poll claim status until terminal\n  useEffect(() => {\n    if (!claimResult || !accessToken) return;\n    if (claimResult.status === \"completed\" || claimResult.status === \"failed\") {\n      return;\n    }\n    const poll = async () => {\n      try {\n        const updated = await pollClaimStatus(accessToken, claimResult.claimId);\n        setClaimResult(updated);\n        if (updated.status === \"completed\") {\n          fetchStats(); // refresh pending balance\n        } else if (updated.status !== \"failed\") {\n          pollRef.current = setTimeout(poll, 3000);\n        }\n      } catch {\n        pollRef.current = setTimeout(poll, 5000);\n      }\n    };\n    pollRef.current = setTimeout(poll, 2000);\n    return () => {\n      if (pollRef.current) clearTimeout(pollRef.current);\n    };\n  }, [claimResult, accessToken, fetchStats]);\n\n  const handleClaim = useCallback(async () => {\n    if (!accessToken) return;\n    setClaiming(true);\n    setError(\"\");\n    setClaimResult(null);\n    try {\n      const res = await requestReferralClaim(accessToken);\n      setClaimResult(res);\n    } catch (e) {\n      setError(e instanceof Error ? e.message : \"Claim failed\");\n    } finally {\n      setClaiming(false);\n    }\n  }, [accessToken]);\n\n  const pendingLamports = Number(stats?.pendingLamports ?? \"0\");\n  const earnedLamports = stats?.totalEarnedLamports ?? \"0\";\n  const rebateLamports = stats?.totalRebateLamports ?? \"0\";\n  const canClaim = pendingLamports >= MIN_CLAIM_LAMPORTS;\n\n  return (\n    <div className=\"ref-claim-card\">\n      <h3 className=\"ref-claim-card__title\">Pending Earnings</h3>\n\n      {loading ? (\n        <div className=\"ref-claim-card__skeleton\" />\n      ) : (\n        <>\n          <div className=\"ref-claim-card__balance\">\n            {formatSol(String(pendingLamports))} <span className=\"ref-claim-card__sol\">SOL</span>\n          </div>\n\n          <div className=\"ref-claim-card__breakdown\">\n            <div className=\"ref-claim-card__breakdown-row\">\n              <span>From referrals</span>\n              <span>{formatSol(earnedLamports)} SOL</span>\n            </div>\n            <div className=\"ref-claim-card__breakdown-row\">\n              <span>From fee rebates</span>\n              <span>{formatSol(rebateLamports)} SOL</span>\n            </div>\n          </div>\n\n          {claimResult?.status === \"completed\" && claimResult.txSignature ? (\n            <div className=\"ref-claim-card__success\">\n              Claimed {formatSol(claimResult.amountLamports)} SOL{\" \"}\n              <a\n                href={explorerTxUrl(claimResult.txSignature)}\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n                className=\"ref-claim-card__tx-link\"\n              >\n                View transaction &#x2197;\n              </a>\n            </div>\n          ) : claimResult?.status === \"failed\" ? (\n            <div className=\"ref-claim-card__error\">\n              Claim failed. Please try again.\n            </div>\n          ) : null}\n\n          {error && <div className=\"ref-claim-card__error\">{error}</div>}\n\n          <button\n            type=\"button\"\n            className=\"ref-claim-card__btn\"\n            onClick={handleClaim}\n            disabled={!canClaim || claiming || (claimResult?.status === \"pending\")}\n          >\n            {claiming\n              ? \"Claiming...\"\n              : claimResult?.status === \"pending\"\n                ? \"Processing...\"\n                : canClaim\n                  ? \"Claim Earnings\"\n                  : pendingLamports > 0\n                    ? \"Below minimum (0.01 SOL)\"\n                    : \"No pending earnings\"}\n          </button>\n        </>\n      )}\n    </div>\n  );\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":184,"cache_read_input_tokens":69380,"cache_creation":{"ephemeral_5m_input_tokens"