e;\n  text-underline-offset: 2px;\n}\n.ref-claim-card__tx-link:hover {\n  opacity: 0.8;\n}\n.ref-claim-card__error {\n  padding: 8px 12px;\n  background: rgba(255, 82, 82, 0.1);\n  border: 1px solid rgba(255, 82, 82, 0.3);\n  border-radius: 6px;\n  font-size: 0.85rem;\n  color: var(--color-error);\n  margin-bottom: 12px;\n}\n.ref-claim-card__btn {\n  width: 100%;\n  padding: 10px 16px;\n  border: none;\n  border-radius: 6px;\n  background: var(--color-green);\n  color: #000;\n  font-weight: 600;\n  font-size: 0.9rem;\n  cursor: pointer;\n  transition: opacity 0.15s;\n}\n.ref-claim-card__btn:hover:not(:disabled) {\n  opacity: 0.9;\n}\n.ref-claim-card__btn:disabled {\n  opacity: 0.4;\n  cursor: not-allowed;\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":210,"cache_read_input_tokens":71437,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":210},"output_tokens":58,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e1866399-0612-4b5c-bae9-0fe08bc8e43b","uuid":"250ac93c-90ee-4e83-b850-0d9dcc03cbf5"}
