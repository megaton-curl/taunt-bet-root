{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01V74SsxFCPZ5UjMH4V2ScmL","type":"tool_result","content":"     1→import { useSession } from \"../../context/SessionContext\";\n     2→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n     3→import { ReferralLinkCard } from \"./ReferralLinkCard\";\n     4→import { ReferralStatsCard } from \"./ReferralStatsCard\";\n     5→\n     6→export function ReferralPage() {\n     7→  const { isAuthenticated } = useSession();\n     8→  const { connected } = useWallet();\n     9→\n    10→  if (!connected || !isAuthenticated) {\n    11→    return (\n    12→      <div className=\"referral-page\">\n    13→        <div className=\"referral-page__connect\">\n    14→          <h2>Referral Program</h2>\n    15→          <p>\n    16→            Earn <strong>10% of the platform fee</strong> from every game your\n    17→            referred players complete — forever. Your referees get a{\" \"}\n    18→            <strong>10% fee rebate</strong> on all their games too.\n    19→          </p>\n    20→          <p>Connect your wallet to get started.</p>\n    21→        </div>\n    22→      </div>\n    23→    );\n    24→  }\n    25→\n    26→  return (\n    27→    <div className=\"referral-page\">\n    28→      <div className=\"referral-page__header\">\n    29→        <h1 className=\"referral-page__title\">Referrals</h1>\n    30→        <p className=\"referral-page__subtitle\">\n    31→          Share your link, earn from every game your friends play\n    32→        </p>\n    33→      </div>\n    34→\n    35→      <div className=\"referral-page__content\">\n    36→        <ReferralLinkCard />\n    37→        <ReferralStatsCard />\n    38→        {/* §3: Pending balance + Claim card — implemented in next iteration */}\n    39→        {/* §4: Earnings history table — implemented in next iteration */}\n    40→      </div>\n    41→    </div>\n    42→  );\n    43→}\n    44→"}]},"parent_tool_use_id":"toolu_01LbTaLEZHECiJbkEGPR4Ve3","session_id":"e1866399-0612-4b5c-bae9-0fe08bc8e43b","uuid":"4b876177-5386-4646-b871-c5fd58b2b733","timestamp":"2026-03-25T13:27:26.816Z"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01HLAXefEVbL5tgM3bFZsVuH","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011s99Hg8feqfNMTBFVREgLV","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/referral/ReferralStatsCard.tsx"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":6050,"cache_read_input_tokens":24087,"cache_creation":{"ephemeral_5m_input_tokens":6050,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01LbTaLEZHECiJbkEGPR4Ve3","session_id":"e1866399-0612-4b5c-bae9-0fe08bc8e43b","uuid":"c53443cb-5372-4c9b-9c09-41514d9a74d4"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011s99Hg8feqfNMTBFVREgLV","type":"tool_result","content":"     1→import { useEffect, useState } from \"react\";\n     2→import { useSession } from \"../../context/SessionContext\";\n     3→import { getReferralStats, type ReferralStatsResponse } from \"../../lib/referral-api\";\n     4→\n     5→const LAMPORTS_PER_SOL = 1_000_000_000;\n     6→\n     7→function formatSol(lamportsStr: string): string {\n     8→  const sol = Number(lamportsStr) / LAMPORTS_PER_SOL;\n     9→  if (sol >= 1_000_000) return `${(sol / 1_000_000).toFixed(1)}M`;\n    10→  if (sol >= 1000) return `${(sol / 1000).toFixed(1)}k`;\n    11→  if (sol >= 1) return sol.toFixed(2);\n    12→  if (sol >= 0.01) return sol.toFixed(3);\n    13→  return sol.toFixed(4);\n    14→}\n    15→\n    16→export function ReferralStatsCard() {\n    17→  const { accessToken } = useSession();\n    18→  const [loading, setLoading] = useState(true);\n    19→  const [stats, setStats] = useState<ReferralStatsResponse | null>(null);\n    20→\n    21→  useEffect(() => {\n    22→    if (!accessToken) return;\n    23→    let cancelled = false;\n    24→    getReferralStats(accessToken)\n    25→      .then((res) => {\n    26→        if (!cancelled) setStats(res);\n    27→      })\n    28→      .catch(() => {\n    29→        /* stats unavailable — show zeros */\n    30→      })\n    31→      .finally(() => {\n    32→        if (!cancelled) setLoading(false);\n    33→      });\n    34→    return () => {\n    35→      cancelled = true;\n    36→    };\n    37→  }, [accessToken]);\n    38→\n    39→  const items = [\n    40→    { label: \"Referred Players\", value: stats ? String(stats.referredCount) : \"0\" },\n    41→    { label: \"Active (7d)\", value: stats ? String(stats.activeCount) : \"0\" },\n    42→    { label: \"Total Volume\", value: stats ? formatSol(stats.totalVolumeLamports) + \" SOL\" : \"0 SOL\" },\n    43→    { label: \"Total Earned\", value: stats ? formatSol(stats.totalEarnedLamports) + \" SOL\" : \"0 SOL\" },\n    44→  ];\n    45→\n    46→  return (\n    47→    <div className=\"ref-stats-card\">\n    48→      <h3 className=\"ref-stats-card__title\">Stats</h3>\n    49→      <div className=\"ref-stats-card__grid\">\n    50→        {items.map((item) => (\n    51→          <div key={item.label} className=\"ref-stats-card__stat\">\n    52→            {loading ? (\n    53→              <div className=\"ref-stats-card__skeleton\" />\n    54→            ) : (\n    55→              <div className=\"ref-stats-card__value\">{item.value}</div>\n    56→            )}\n    57→            <div className=\"ref-stats-card__label\">{item.label}</div>\n    58→          </div>\n    59→        ))}\n    60→      </div>\n    61→    </div>\n    62→  );\n    63→}\n    64→"}]},"parent_tool_use_id":"toolu_01LbTaLEZHECiJbkEGPR4Ve3","session_id":"e1866399-0612-4b5c-bae9-0fe08bc8e43b","uuid":"c51839c7-a38e-4fdd-97a2-6163d14c8e35","timestamp":"2026-03-25T13:27:26.917Z"}
{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01HLAXefEVbL5tgM3bFZsVuH","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01MQoq8ZKeTQrZPdDfUbPBSA","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/referral/ReferralLinkCard.tsx"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":6050,"cache_read_input_tokens":24087,"cache_creation":{"ephemeral_5m_input_tokens":6050,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01LbTaLEZHECiJbkEGPR4Ve3","session_id":"e1866399-0612-4b5c-bae9-0fe08bc8e43b","uuid":"f245716d-6986-4857-b4f2-6597f4b9493f"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MQoq8ZKeTQrZPdDfUbPBSA","type":"tool_result","content":"     1→import { useCallback, useEffect, useState } from \"react\";\n     2→import { useSession } from \"../../context/SessionContext\";\n     3→import {\n     4→  getReferralCode,\n     5→  setReferralCode,\n     6→  type ReferralCodeResponse,\n     7→} from \"../../lib/referral-api\";\n     8→\n     9→const CODE_RE = /^[a-z0-9-]{3,16}$/;\n    10→\n    11→export function ReferralLinkCard() {\n    12→  const { accessToken } = useSession();\n    13→\n    14→  const [loading, setLoading] = useState(true);\n    15→  const [saving, setSaving] = useState(false);\n    16→  const [existing, setExisting] = useState<ReferralCodeResponse | null>(null);\n    17→  const [editing, setEditing] = useState(false);\n    18→  const [input, setInput] = useState(\"\");\n    19→  const [error, setError] = useState(\"\");\n    20→  const [copied, setCopied] = useState(false);\n    21→\n    22→  // Fetch existing code on mount\n    23→  useEffect(() => {\n    24→    if (!accessToken) return;\n    25→    let cancelled = false;\n    26→    getReferralCode(accessToken)\n    27→      .then((res) => {\n    28→        if (!cancelled) setExisting(res);\n    29→      })\n    30→      .catch(() => {\n    31→        /* 404 = no code yet, ignore */\n    32→      })\n    33→      .finally(() => {\n    34→        if (!cancelled) setLoading(false);\n    35→      });\n    36→    return () => {\n    37→      cancelled = true;\n    38→    };\n    39→  }, [accessToken]);\n    40→\n    41→  const validate = (code: string): string => {\n    42→    if (code.length < 3) return \"Code must be at least 3 characters\";\n    43→    if (code.length > 16) return \"Code must be at most 16 characters\";\n    44→    if (!CODE_RE.test(code)) return \"Only lowercase letters, numbers, and hyphens\";\n    45→    return \"\";\n    46→  };\n    47→\n    48→  const handleInputChange = (val: string) => {\n    49→    const lower = val.toLowerCase();\n    50→    setInput(lower);\n    51→    setError(lower ? validate(lower) : \"\");\n    52→  };\n    53→\n    54→  const handleSubmit = useCallback(async () => {\n    55→    if (!accessToken) return;\n    56→    const err = validate(input);\n    57→    if (err) {\n    58→      setError(err);\n    59→      return;\n    60→    }\n    61→    setSaving(true);\n    62→    setError(\"\");\n    63→    try {\n    64→      const res = await setReferralCode(accessToken, input);\n    65→      setExisting(res);\n    66→      setEditing(false);\n    67→      setInput(\"\");\n    68→    } catch (e) {\n    69→      setError(e instanceof Error ? e.message : \"Failed to set code\");\n    70→    } finally {\n    71→      setSaving(false);\n    72→    }\n    73→  }, [accessToken, input]);\n    74→\n    75→  const handleCopy = useCallback(() => {\n    76→    if (!existing) return;\n    77→    navigator.clipboard.writeText(existing.url).then(() => {\n    78→      setCopied(true);\n    79→      setTimeout(() => setCopied(false), 2000);\n    80→    });\n    81→  }, [existing]);\n    82→\n    83→  if (loading) {\n    84→    return (\n    85→      <div className=\"ref-link-card\">\n    86→        <h3 className=\"ref-link-card__title\">Your Referral Link</h3>\n    87→        <div className=\"ref-link-card__skeleton\" />\n    88→      </div>\n    89→    );\n    90→  }\n    91→\n    92→  // No code yet, or user is editing/changing\n    93→  if (!existing || editing) {\n    94→    return (\n    95→      <div className=\"ref-link-card\">\n    96→        <h3 className=\"ref-link-card__title\">\n    97→          {existing ? \"Change Referral Code\" : \"Your Referral Link\"}\n    98→        </h3>\n    99→        {!existing && (\n   100→          <p className=\"ref-link-card__desc\">\n   101→            Choose a custom code to create your referral link.\n   102→          </p>\n   103→        )}\n   104→        <div className=\"ref-link-card__form\">\n   105→          <div className=\"ref-link-card__input-row\">\n   106→            <span className=\"ref-link-card__prefix\">taunt.bet/r/</span>\n   107→            <input\n   108→              type=\"text\"\n   109→              className=\"ref-link-card__input\"\n   110→              placeholder=\"my-code\"\n   111→              value={input}\n   112→              onChange={(e) => handleInputChange(e.target.value)}\n   113→              onKeyDown={(e) => {\n   114→                if (e.key === \"Enter\" && !saving) handleSubmit();\n   115→              }}\n   116→              maxLength={16}\n   117→              disabled={saving}\n   118→              autoFocus\n   119→            />\n   120→          </div>\n   121→          {error && <p className=\"ref-link-card__error\">{error}</p>}\n   122→          <div className=\"ref-link-card__actions\">\n   123→            <button\n   124→              type=\"button\"\n   125→              className=\"ref-link-card__btn ref-link-card__btn--primary\"\n   126→              onClick={handleSubmit}\n   127→              disabled={saving || !input || !!error}\n   128→            >\n   129→              {saving ? \"Saving...\" : existing ? \"Update Code\" : \"Set Code\"}\n   130→            </button>\n   131→            {existing && (\n   132→              <button\n   133→                type=\"button\"\n   134→                className=\"ref-link-card__btn ref-link-card__btn--secondary\"\n   135→                onClick={() => {\n   136→                  setEditing(false);\n   137→                  setInput(\"\");\n   138→                  setError(\"\");\n   139→                }}\n   140→              >\n   141→                Cancel\n   142→              </button>\n   143→            )}\n   144→          </div>\n   145→        </div>\n   146→      </div>\n   147→    );\n   148→  }\n   149→\n   150→  // Code exists — show display mode\n   151→  return (\n   152→    <div className=\"ref-link-card\">\n   153→      <h3 className=\"ref-link-card__title\">Your Referral Link</h3>\n   154→      <div className=\"ref-link-card__display\">\n   155→        <div className=\"ref-link-card__url-row\">\n   156→          <input\n   157→            type=\"text\"\n   158→            className=\"ref-link-card__url\"\n   159→            value={existing.url}\n   160→            readOnly\n   161→          />\n   162→          <button\n   163→            type=\"button\"\n   164→            className=\"ref-link-card__btn ref-link-card__btn--copy\"\n   165→            onClick={handleCopy}\n   166→          >\n   167→            {copied ? \"Copied!\" : \"Copy Link\"}\n   168→          </button>\n   169→        </div>\n   170→        <button\n   171→          type=\"button\"\n   172→          className=\"ref-link-card__change\"\n   173→          onClick={() => {\n   174→            setEditing(true);\n   175→            setInput(existing.code);\n   176→          }}\n   177→        >\n   178→          Change code\n   179→        </button>\n   180→      </div>\n   181→    </div>\n   182→  );\n   183→}\n   184→"}]},"parent_tool_use_id":"toolu_01LbTaLEZHECiJbkEGPR4Ve3","session_id":"e1866399-0612-4b5c-bae9-0fe08bc8e43b","uuid":"33a28221-a187-473b-abaa-7e4fde57562a","timestamp":"2026-03-25T13:27:27.138Z"}
