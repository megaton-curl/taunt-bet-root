{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013tzWbAyXUcLFAVJds8sDao","type":"tool_result","content":"     1→/**\n     2→ * Centralized Solana network configuration.\n     3→ *\n     4→ * Reads VITE_SOLANA_NETWORK once at startup. Every part of the platform\n     5→ * that needs to know the cluster (explorer links, session storage,\n     6→ * wallet adapter, etc.) should import from here instead of hardcoding.\n     7→ */\n     8→\n     9→export type SolanaCluster = \"devnet\" | \"testnet\" | \"mainnet-beta\";\n    10→\n    11→const raw = (import.meta.env.VITE_SOLANA_NETWORK as string) ?? \"devnet\";\n    12→\n    13→function parseCluster(value: string): SolanaCluster {\n    14→  const v = value.trim().toLowerCase();\n    15→  if (v === \"mainnet-beta\" || v === \"mainnet\") return \"mainnet-beta\";\n    16→  if (v === \"testnet\") return \"testnet\";\n    17→  return \"devnet\";\n    18→}\n    19→\n    20→/** The active Solana cluster, derived from VITE_SOLANA_NETWORK. */\n    21→export const SOLANA_CLUSTER: SolanaCluster = parseCluster(raw);\n    22→\n    23→/**\n    24→ * Build a Solana Explorer URL for a transaction signature.\n    25→ * On mainnet-beta the `?cluster=` param is omitted (Explorer default).\n    26→ */\n    27→export function explorerTxUrl(signature: string): string {\n    28→  const base = `https://explorer.solana.com/tx/${signature}`;\n    29→  return SOLANA_CLUSTER === \"mainnet-beta\"\n    30→    ? base\n    31→    : `${base}?cluster=${SOLANA_CLUSTER}`;\n    32→}\n    33→\n    34→/**\n    35→ * Build a Solana Explorer URL for an account/address.\n    36→ */\n    37→export function explorerAddressUrl(address: string): string {\n    38→  const base = `https://explorer.solana.com/address/${address}`;\n    39→  return SOLANA_CLUSTER === \"mainnet-beta\"\n    40→    ? base\n    41→    : `${base}?cluster=${SOLANA_CLUSTER}`;\n    42→}\n    43→"}]},"parent_tool_use_id":"toolu_01Ew1UwqLQQVnAjBH54kbdMX","session_id":"e1866399-0612-4b5c-bae9-0fe08bc8e43b","uuid":"b6a8893a-45b1-44d0-8c91-586d74cde00e","timestamp":"2026-03-25T13:27:38.546Z"}
