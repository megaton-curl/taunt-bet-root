s);\n    } catch {\n      /* unavailable — show zeros */\n    } finally {\n      setLoading(false);\n    }\n  }, [accessToken]);\n\n  useEffect(() => {\n    fetchStats();\n  }, [fetchStats]);\n\n  // Poll claim status until terminal\n  useEffect(() => {\n    if (!claimResult || !accessToken) return;\n    if (claimResult.status === \"completed\" || claimResult.status === \"failed\") {\n      return;\n    }\n    const poll = async () => {\n      try {\n        const updated = await pollClaimStatus(accessToken, claimResult.claimId);\n        setClaimResult(updated);\n        if (updated.status === \"completed\") {\n          fetchStats(); // refresh pending balance\n        } else if (updated.status !== \"failed\") {\n          pollRef.current = setTimeout(poll, 3000);\n        }\n      } catch {\n        pollRef.current = setTimeout(poll, 5000);\n      }\n    };\n    pollRef.current = setTimeout(poll, 2000);\n    return () => {\n      if (pollRef.current) clearTimeout(pollRef.current);\n    };\n  }, [claimResult, accessToken, fetchStats]);\n\n  const handleClaim = useCallback(async () => {\n    if (!accessToken) return;\n    setClaiming(true);\n    setError(\"\");\n    setClaimResult(null);\n    try {\n      const res = await requestReferralClaim(accessToken);\n      setClaimResult(res);\n    } catch (e) {\n      setError(e instanceof Error ? e.message : \"Claim failed\");\n    } finally {\n      setClaiming(false);\n    }\n  }, [accessToken]);\n\n  const pendingLamports = Number(stats?.pendingLamports ?? \"0\");\n  const earnedLamports = stats?.totalEarnedLamports ?? \"0\";\n  const rebateLamports = stats?.totalRebateLamports ?? \"0\";\n  const canClaim = pendingLamports >= MIN_CLAIM_LAMPORTS;\n\n  return (\n    <div className=\"ref-claim-card\">\n      <h3 className=\"ref-claim-card__title\">Pending Earnings</h3>\n\n      {loading ? (\n        <div className=\"ref-claim-card__skeleton\" />\n      ) : (\n        <>\n          <div className=\"ref-claim-card__balance\">\n            {formatSol(String(pendingLamports))} <span className=\"ref-claim-card__sol\">SOL</span>\n          </div>\n\n          <div className=\"ref-claim-card__breakdown\">\n            <div className=\"ref-claim-card__breakdown-row\">\n              <span>From referrals</span>\n              <span>{formatSol(earnedLamports)} SOL</span>\n            </div>\n            <div className=\"ref-claim-card__breakdown-row\">\n              <span>From fee rebates</span>\n              <span>{formatSol(rebateLamports)} SOL</span>\n            </div>\n          </div>\n\n          {claimResult?.status === \"completed\" && claimResult.txSignature ? (\n            <div className=\"ref-claim-card__success\">\n              Claimed {formatSol(claimResult.amountLamports)} SOL{\" \"}\n              <a\n                href={explorerTxUrl(claimResult.txSignature)}\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n                className=\"ref-claim-card__tx-link\"\n              >\n                View transaction &#x2197;\n              </a>\n            </div>\n          ) : claimResult?.status === \"failed\" ? (\n            <div className=\"ref-claim-card__error\">\n              Claim failed. Please try again.\n            </div>\n          ) : null}\n\n          {error && <div className=\"ref-claim-card__error\">{error}</div>}\n\n          <button\n            type=\"button\"\n            className=\"ref-claim-card__btn\"\n            onClick={handleClaim}\n            disabled={!canClaim || claiming || (claimResult?.status === \"pending\")}\n          >\n            {claiming\n              ? \"Claiming...\"\n              : claimResult?.status === \"pending\"\n                ? \"Processing...\"\n                : canClaim\n                  ? \"Claim Earnings\"\n                  : pendingLamports > 0\n                    ? \"Below minimum (0.01 SOL)\"\n                    : \"No pending earnings\"}\n          </button>\n        </>\n      )}\n    </div>\n  );\n}\n","structuredPatch":[],"originalFile":null}}
