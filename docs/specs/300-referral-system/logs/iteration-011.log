{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01FAsfrJHkGfxnezsBpHP81J","type":"message","role":"assistant","content":[{"type":"text","text":"Good. I have all the context I need. The API contract from FR-7 specifies:\n\n```\nGET /referral/earnings\n  Query: { page?: number, limit?: number }\n  Response: {\n    items: [{ roundId, gameType, refereeWallet, wagerLamports, earnedLamports, createdAt }],\n    pagination: { page, totalPages }\n  }\n```\n\nNow let me add the `GET /earnings` endpoint to `routes/referral.ts`."}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":397,"cache_read_input_tokens":52707,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":397},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"92db3e41-1856-4eac-bac8-e2a98fa62710","uuid":"1727267f-6782-4b66-9718-fde570f7b7f8"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01FAsfrJHkGfxnezsBpHP81J","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01AfxrnE81E6Yrf64Ush3Qbv","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/referral.ts","old_string":"  return app;\n}","new_string":"  // GET /earnings — paginated per-game earnings log\n  app.get(\"/earnings\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    const pageParam = c.req.query(\"page\");\n    const limitParam = c.req.query(\"limit\");\n    const page = pageParam ? Math.max(1, Math.floor(Number(pageParam))) : 1;\n    const limit = limitParam\n      ? Math.min(100, Math.max(1, Math.floor(Number(limitParam))))\n      : 20;\n\n    if (Number.isNaN(page) || Number.isNaN(limit)) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_PARAMS\",\n            message: \"page and limit must be positive integers\",\n          },\n        },\n        400,\n      );\n    }\n\n    try {\n      const result = await db.getReferralEarnings(wallet, page, limit);\n      return c.json({\n        items: result.items.map((e) => ({\n          roundId: e.round_id,\n          gameType: e.game_type,\n          refereeWallet: e.referee_wallet,\n          wagerLamports: String(e.wager_lamports),\n          earnedLamports: String(e.referrer_earned_lamports),\n          createdAt: e.created_at.toISOString(),\n        })),\n        pagination: {\n          page,\n          totalPages: result.totalPages,\n        },\n      });\n    } catch (err) {\n      logger.error(\"Failed to fetch referral earnings\", {\n        err: String(err),\n        wallet,\n      });\n      return c.json({ error: \"Failed to fetch referral earnings\" }, 500);\n    }\n  });\n\n  return app;\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":397,"cache_read_input_tokens":52707,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":397},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"92db3e41-1856-4eac-bac8-e2a98fa62710","uuid":"869b1860-7e89-44e8-ade0-74e7bc8d579b"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AfxrnE81E6Yrf64Ush3Qbv","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/referral.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"92db3e41-1856-4eac-bac8-e2a98fa62710","uuid":"f19a198a-4522-4e56-b00e-0d3bc4dc58a3","timestamp":"2026-03-25T12:04:39.872Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/referral.ts","oldString":"  return app;\n}","newString":"  // GET /earnings — paginated per-game earnings log\n  app.get(\"/earnings\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    const pageParam = c.req.query(\"page\");\n    const limitParam = c.req.query(\"limit\");\n    const page = pageParam ? Math.max(1, Math.floor(Number(pageParam))) : 1;\n    const limit = limitParam\n      ? Math.min(100, Math.max(1, Math.floor(Number(limitParam))))\n      : 20;\n\n    if (Number.isNaN(page) || Number.isNaN(limit)) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_PARAMS\",\n            message: \"page and limit must be positive integers\",\n          },\n        },\n        400,\n      );\n    }\n\n    try {\n      const result = await db.getReferralEarnings(wallet, page, limit);\n      return c.json({\n        items: result.items.map((e) => ({\n          roundId: e.round_id,\n          gameType: e.game_type,\n          refereeWallet: e.referee_wallet,\n          wagerLamports: String(e.wager_lamports),\n          earnedLamports: String(e.referrer_earned_lamports),\n          createdAt: e.created_at.toISOString(),\n        })),\n        pagination: {\n          page,\n          totalPages: result.totalPages,\n        },\n      });\n    } catch (err) {\n      logger.error(\"Failed to fetch referral earnings\", {\n        err: String(err),\n        wallet,\n      });\n      return c.json({ error: \"Failed to fetch referral earnings\" }, 500);\n    }\n  });\n\n  return app;\n}","originalFile":"/**\n * Referral routes — code management, linking, stats, earnings, and claims.\n */\n\nimport { Hono } from \"hono\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\n\nexport interface ReferralRoutesDeps {\n  db: Db;\n}\n\n/** Referral code validation: 3-16 chars, lowercase alphanumeric + hyphens */\nconst CODE_REGEX = /^[a-z0-9-]{3,16}$/;\n\nconst REFERRAL_BASE_URL = \"https://taunt.bet/r\";\n\nexport function createReferralRoutes(deps: ReferralRoutesDeps) {\n  const { db } = deps;\n  const app = new Hono<AppEnv>();\n\n  // POST /code — set or replace the player's referral code\n  app.post(\"/code\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    let body: { code?: unknown };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json({ error: \"Invalid request body\" }, 400);\n    }\n\n    const code = typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n\n    if (!CODE_REGEX.test(code)) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_CODE\",\n            message:\n              \"Code must be 3-16 characters, lowercase letters, numbers, and hyphens only\",\n          },\n        },\n        400,\n      );\n    }\n\n    // Check if this code is already taken by another wallet\n    const existing = await db.getReferralCodeByCode(code);\n    if (existing && existing.wallet !== wallet) {\n      return c.json(\n        {\n          error: {\n            code: \"CODE_TAKEN\",\n            message: \"This referral code is already in use\",\n            retryable: false,\n          },\n        },\n        409,\n      );\n    }\n\n    try {\n      const result = await db.upsertReferralCode(wallet, code);\n      logger.info(\"Referral code set\", { wallet, code: result.code });\n      return c.json({\n        code: result.code,\n        url: `${REFERRAL_BASE_URL}/${result.code}`,\n      });\n    } catch (err) {\n      // Handle race condition: another wallet grabbed the code between check and insert\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return c.json(\n          {\n            error: {\n              code: \"CODE_TAKEN\",\n              message: \"This referral code is already in use\",\n              retryable: false,\n            },\n          },\n          409,\n        );\n      }\n      logger.error(\"Failed to set referral code\", { err: String(err), wallet });\n      return c.json({ error: \"Failed to set referral code\" }, 500);\n    }\n  });\n\n  // POST /apply — link the authenticated player to a referrer via their code\n  app.post(\"/apply\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    let body: { code?: unknown };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_BODY\",\n            message: \"Invalid request body\",\n          },\n        },\n        400,\n      );\n    }\n\n    const code =\n      typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n\n    if (!code) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_CODE\",\n            message: \"Referral code is required\",\n          },\n        },\n        400,\n      );\n    }\n\n    // Look up the referral code to find the referrer\n    const codeRow = await db.getReferralCodeByCode(code);\n    if (!codeRow) {\n      return c.json(\n        {\n          error: {\n            code: \"CODE_NOT_FOUND\",\n            message: \"Referral code does not exist\",\n            retryable: false,\n          },\n        },\n        404,\n      );\n    }\n\n    // Self-referral check\n    if (codeRow.wallet === wallet) {\n      return c.json(\n        {\n          error: {\n            code: \"SELF_REFERRAL\",\n            message: \"You cannot use your own referral code\",\n            retryable: false,\n          },\n        },\n        400,\n      );\n    }\n\n    // Check if the player already has a referrer\n    const existingLink = await db.getReferralLinkByReferee(wallet);\n    if (existingLink) {\n      return c.json(\n        {\n          error: {\n            code: \"ALREADY_LINKED\",\n            message: \"You are already linked to a referrer\",\n            retryable: false,\n          },\n        },\n        409,\n      );\n    }\n\n    try {\n      await db.insertReferralLink(codeRow.wallet, wallet);\n      logger.info(\"Referral link created\", {\n        referrer: codeRow.wallet,\n        referee: wallet,\n        code,\n      });\n      return c.json({\n        referrer: codeRow.wallet,\n        benefit: \"10% fee rebate on all games\",\n      });\n    } catch (err) {\n      // Handle race condition: another request linked this referee between check and insert\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return c.json(\n          {\n            error: {\n              code: \"ALREADY_LINKED\",\n              message: \"You are already linked to a referrer\",\n              retryable: false,\n            },\n          },\n          409,\n        );\n      }\n      logger.error(\"Failed to create referral link\", {\n        err: String(err),\n        wallet,\n        code,\n      });\n      return c.json({ error: \"Failed to apply referral code\" }, 500);\n    }\n  });\n\n  // GET /code — return the authenticated player's current referral code\n  app.get(\"/code\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    const row = await db.getReferralCodeByWallet(wallet);\n    if (!row) {\n      return c.json(\n        {\n          error: {\n            code: \"NO_CODE\",\n            message: \"No referral code set for this wallet\",\n          },\n        },\n        404,\n      );\n    }\n\n    return c.json({\n      code: row.code,\n      url: `${REFERRAL_BASE_URL}/${row.code}`,\n    });\n  });\n\n  // GET /stats — referral summary stats for authenticated wallet\n  app.get(\"/stats\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    try {\n      const stats = await db.getReferralStats(wallet);\n      return c.json({\n        referredCount: stats.referred_count,\n        activeCount: stats.active_count,\n        totalVolumeLamports: stats.total_volume_lamports,\n        totalEarnedLamports: stats.total_earned_lamports,\n        pendingLamports: stats.pending_lamports,\n      });\n    } catch (err) {\n      logger.error(\"Failed to fetch referral stats\", {\n        err: String(err),\n        wallet,\n      });\n      return c.json({ error: \"Failed to fetch referral stats\" }, 500);\n    }\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":250,"oldLines":5,"newStart":250,"newLines":54,"lines":["     }","   });"," ","+  // GET /earnings — paginated per-game earnings log","+  app.get(\"/earnings\", async (c) => {","+    const wallet = c.get(\"wallet\");","+    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);","+","+    const pageParam = c.req.query(\"page\");","+    const limitParam = c.req.query(\"limit\");","+    const page = pageParam ? Math.max(1, Math.floor(Number(pageParam))) : 1;","+    const limit = limitParam","+      ? Math.min(100, Math.max(1, Math.floor(Number(limitParam))))","+      : 20;","+","+    if (Number.isNaN(page) || Number.isNaN(limit)) {","+      return c.json(","+        {","+          error: {","+            code: \"INVALID_PARAMS\",","+            message: \"page and limit must be positive integers\",","+          },","+        },","+        400,","+      );","+    }","+","+    try {","+      const result = await db.getReferralEarnings(wallet, page, limit);","+      return c.json({","+        items: result.items.map((e) => ({","+          roundId: e.round_id,","+          gameType: e.game_type,","+          refereeWallet: e.referee_wallet,","+          wagerLamports: String(e.wager_lamports),","+          earnedLamports: String(e.referrer_earned_lamports),","+          createdAt: e.created_at.toISOString(),","+        })),","+        pagination: {","+          page,","+          totalPages: result.totalPages,","+        },","+      });","+    } catch (err) {","+      logger.error(\"Failed to fetch referral earnings\", {","+        err: String(err),","+        wallet,","+      });","+      return c.json({ error: \"Failed to fetch referral earnings\" }, 500);","+    }","+  });","+","   return app;"," }"]}],"userModified":false,"replaceAll":false}}
