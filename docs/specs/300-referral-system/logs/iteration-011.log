llet = ${wallet}\n   902→            WHERE re.created_at > now() - INTERVAL '7 days'\n   903→          )::INT AS active_count,\n   904→          COALESCE(\n   905→            (\n   906→              SELECT SUM(re.wager_lamports)::TEXT\n   907→              FROM referral_earnings re\n   908→              JOIN referral_links rl ON rl.referee_wallet = re.referee_wallet AND rl.referrer_wallet = ${wallet}\n   909→            ), '0'"}]},"parent_tool_use_id":null,"session_id":"92db3e41-1856-4eac-bac8-e2a98fa62710","uuid":"72979a37-5839-452e-8444-a358fb56578d","timestamp":"2026-03-25T12:04:21.752Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/db.ts","content":"          (\n            SELECT SUM(referee_rebate_lamports)\n            FROM referral_earnings WHERE referee_wallet = ${wallet}\n          ), 0\n        ) - COALESCE(\n          (\n            SELECT SUM(amount_lamports)\n            FROM referral_claims WHERE wallet = ${wallet} AND status IN ('pending', 'processing', 'completed')\n          ), 0\n        ) AS pending\n      `;\n      return rows[0]!.pending;\n    },\n\n    async getReferralEarnings(wallet, page, limit) {\n      const offset = (page - 1) * limit;\n      const [countRows, rows] = await Promise.all([\n        sql<{ count: string }[]>`\n          SELECT COUNT(*)::TEXT AS count FROM referral_earnings\n          WHERE referrer_wallet = ${wallet}\n        `,\n        sql<ReferralEarning[]>`\n          SELECT * FROM referral_earnings\n          WHERE referrer_wallet = ${wallet}\n          ORDER BY created_at DESC\n          LIMIT ${limit} OFFSET ${offset}\n        `,\n      ]);\n      const total = Number(countRows[0]!.count);\n      const totalPages = Math.max(1, Math.ceil(total / limit));\n      return { items: rows.map(normalizeReferralEarning), totalPages };\n    },\n\n    async getReferralStats(wallet) {\n      const rows = await sql<ReferralStats[]>`\n        SELECT\n          (SELECT COUNT(*) FROM referral_links WHERE referrer_wallet = ${wallet})::INT\n            AS referred_count,\n          (\n            SELECT COUNT(DISTINCT re.referee_wallet)\n            FROM referral_earnings re\n            JOIN referral_links rl ON rl.referee_wallet = re.referee_wallet AND rl.referrer_wallet = ${wallet}\n            WHERE re.created_at > now() - INTERVAL '7 days'\n          )::INT AS active_count,\n          COALESCE(\n            (\n              SELECT SUM(re.wager_lamports)::TEXT\n              FROM referral_earnings re\n              JOIN referral_links rl ON rl.referee_wallet = re.referee_wallet AND rl.referrer_wallet = ${wallet}\n            ), '0'","numLines":50,"startLine":860,"totalLines":970}}}
