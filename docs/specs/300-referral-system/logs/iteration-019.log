{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019D91CMvDysdEPuoNmLwGm8","type":"tool_result","content":"     1→import { useState, useEffect, useRef } from \"react\";\n     2→import { BrowserRouter, Routes, Route, Link } from \"react-router-dom\";\n     3→import { Header } from \"./components/Header\";\n     4→import { Sidebar } from \"./components/Sidebar\";\n     5→import { Ticker } from \"./components/Ticker\";\n     6→import { BackgroundEffects } from \"./components/BackgroundEffects\";\n     7→import { CoinflipPage } from \"./pages/CoinflipPage\";\n     8→import { LordOfRngsPage } from \"./pages/LordOfRngsPage\";\n     9→import { CloseCallPage } from \"./pages/CloseCallPage\";\n    10→import { CryptoCrashPage } from \"./pages/CryptoCrashPage\";\n    11→import { GameOfTradesPage } from \"./pages/GameOfTradesPage\";\n    12→import { BossRaidProvider } from \"./features/boss-raid\";\n    13→import { PlayerProfileProvider, ProfilePage, MiniProfileModal, PlayerAvatarCompact } from \"./features/player-profile\";\n    14→import { QuestsProvider, ChestDropNotification } from \"./features/quests\";\n    15→import { QuestsPage } from \"./pages/QuestsPage\";\n    16→import { LootPage } from \"./pages/LootPage\";\n    17→import { CoinflipRoundPage } from \"./pages/CoinflipRoundPage\";\n    18→import { LordRoundPage } from \"./pages/LordRoundPage\";\n    19→import { CloseCallRoundPage } from \"./pages/CloseCallRoundPage\";\n    20→import { FairnessPage } from \"./pages/FairnessPage\";\n    21→import { BuildBadge } from \"./components/BuildBadge\";\n    22→import { RouteErrorBoundary } from \"./components/RouteErrorBoundary\";\n    23→import { PriceFeedProvider } from \"@rng-utopia/price-feeds\";\n    24→\n    25→\n    26→export function App() {\n    27→  return (\n    28→    <BrowserRouter>\n    29→      <PriceFeedProvider>\n    30→        <PlayerProfileProvider>\n    31→          <QuestsProvider>\n    32→            <BossRaidProvider>\n    33→              <AppContent />\n    34→            </BossRaidProvider>\n    35→          </QuestsProvider>\n    36→        </PlayerProfileProvider>\n    37→      </PriceFeedProvider>\n    38→    </BrowserRouter>\n    39→  );\n    40→}\n    41→\n    42→\n    43→// Chat icon SVG\n    44→const ChatIcon = () => (\n    45→  <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" width=\"20\" height=\"20\">\n    46→    <path d=\"M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z\"/>\n    47→    <circle cx=\"8\" cy=\"10\" r=\"1.5\"/>\n    48→    <circle cx=\"12\" cy=\"10\" r=\"1.5\"/>\n    49→    <circle cx=\"16\" cy=\"10\" r=\"1.5\"/>\n    50→  </svg>\n    51→);\n    52→\n    53→// Footer component with terms and FAQ modals\n    54→function Footer() {\n    55→  const [showTerms, setShowTerms] = useState(false);\n    56→  const [showFAQ, setShowFAQ] = useState(false);\n    57→  const [expandedFAQ, setExpandedFAQ] = useState<string | null>(null);\n    58→  const termsModalRef = useRef<HTMLDivElement>(null);\n    59→  const faqModalRef = useRef<HTMLDivElement>(null);\n    60→\n    61→  // Close modal on outside click\n    62→  useEffect(() => {\n    63→    if (!showTerms && !showFAQ) return;\n    64→\n    65→    const handleClickOutside = (e: MouseEvent) => {\n    66→      if (showTerms && termsModalRef.current && !termsModalRef.current.contains(e.target as Node)) {\n    67→        setShowTerms(false);\n    68→      }\n    69→      if (showFAQ && faqModalRef.current && !faqModalRef.current.contains(e.target as Node)) {\n    70→        setShowFAQ(false);\n    71→      }\n    72→    };\n    73→\n    74→    document.addEventListener(\"mousedown\", handleClickOutside);\n    75→    return () => document.removeEventListener(\"mousedown\", handleClickOutside);\n    76→  }, [showTerms, showFAQ]);\n    77→\n    78→  // Close on escape\n    79→  useEffect(() => {\n    80→    if (!showTerms && !showFAQ) return;\n    81→\n    82→    const handleEscape = (e: KeyboardEvent) => {\n    83→      if (e.key === \"Escape\") {\n    84→        setShowTerms(false);\n    85→        setShowFAQ(false);\n    86→      }\n    87→    };\n    88→\n    89→    document.addEventListener(\"keydown\", handleEscape);\n    90→    return () => document.removeEventListener(\"keydown\", handleEscape);\n    91→  }, [showTerms, showFAQ]);\n    92→\n    93→  const toggleFAQSection = (section: string) => {\n    94→    setExpandedFAQ(expandedFAQ === section ? null : section);\n    95→  };\n    96→\n    97→  const faqSections = [\n    98→    {\n    99→      id: \"fees\",\n   100→      title: \"Platform Fees\",\n   101→      content: `TAUNT charges a 5% platform fee on all games. This means 95% of all wagered funds go directly to winners.\n   102→\n   103→Fee breakdown:\n   104→• 5% total platform fee on every settled pot\n   105→• Funds cover player incentives (Dogpile Raid reward pool, future promotions) and platform treasury (server costs, development, operations)\n   106→\n   107→What you get:\n   108→• Winners receive: 95% of the pot\n   109→• No hidden fees or withdrawal charges\n   110→• Part of your wagers fund rewards you can win back through Dogpile Raid`\n   111→    },\n   112→    {\n   113→      id: \"raid-boss\",\n   114→      title: \"What is Dogpile Raid?\",\n   115→      content: `Dogpile Raid is a community reward mechanic where players collectively take down a Mark by playing games.\n   116→\n   117→How it works:\n   118→• A new Mark spawns every hour with a 50-minute active phase\n   119→• Every wager you make in any game lands \"hits\" on the Mark\n   120→• The Mark's Armor drains over time - it's always dropped when the timer ends\n   121→• When dropped, the reward pool is distributed to all participants\n   122→\n   123→Rewards:\n   124→• Your share is proportional to your hit contribution\n   125→• The reward pool grows from 1% of all wagers during the raid\n   126→• Higher total community hits = better loot tier = bigger multipliers\n   127→• Bonus loot is occasionally added for extra rewards\n   128→\n   129→Loot Tiers (based on total hits):\n   130→• Bronze: 0-10 SOL in hits\n   131→• Silver: 10-50 SOL in hits\n   132→• Gold: 50-150 SOL in hits\n   133→• Platinum: 150-500 SOL in hits\n   134→• Diamond: 500+ SOL in hits`\n   135→    },\n   136→    {\n   137→      id: \"pvp\",\n   138→      title: \"Why PvP Games?\",\n   139→      content: `Unlike traditional house-edge gambling where you play against the casino, TAUNT is 100% player-vs-player. This creates a fundamentally fairer system:\n   140→\n   141→• No house edge exploiting players\n   142→• Prize pools come entirely from player wagers\n   143→• The platform only takes a small facilitation fee\n   144→• Better odds than any traditional casino\n   145→• Transparent, skill-independent wagering`\n   146→    },\n   147→    {\n   148→      id: \"wagers\",\n   149→      title: \"Custom Wagers\",\n   150→      content: `TAUNT lets you choose your own wager amount for every game."}]},"parent_tool_use_id":"toolu_011AcsGVUbbSU9Yvp6f64T82","session_id":"1c981b50-fe84-48cc-8274-9e2683b7ad2f","uuid":"d081186d-f4dd-4782-a663-4532a513ea18","timestamp":"2026-03-25T12:53:54.672Z"}
