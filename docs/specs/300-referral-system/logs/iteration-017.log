{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DZoPej8FiQ1nHm7gVV8NHn","type":"tool_result","content":"     1→/**\n     2→ * Unit tests for the async event queue module.\n     3→ *\n     4→ * Covers:\n     5→ * 1. emitEvent — inserts with correct fields, returns eventId\n     6→ * 2. emitEvent — rolled-back transaction does NOT persist\n     7→ * 3. Handler registry — register/get, unknown returns undefined\n     8→ * 4. Backoff calculation — attempt 1 → 5s, attempt 2 → 30s, attempt 3+ → 300s\n     9→ *\n    10→ * Requires a running Postgres database (same as backend).\n    11→ */\n    12→\n    13→import { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n    14→import postgres from \"postgres\";\n    15→import { emitEvent } from \"../emit-event.js\";\n    16→import { registerHandler, getHandler } from \"../handler-registry.js\";\n    17→import { EventTypes } from \"../event-types.js\";\n    18→import { getBackoffSeconds } from \"../worker.js\";\n    19→\n    20→describe(\"event queue unit tests\", () => {\n    21→  let sql: ReturnType<typeof postgres>;\n    22→\n    23→  beforeAll(async () => {\n    24→    sql = process.env.DATABASE_URL\n    25→      ? postgres(process.env.DATABASE_URL)\n    26→      : postgres({\n    27→          host: \"/var/run/postgresql\",\n    28→          database: \"rng_utopia_dev\",\n    29→          username: \"vscode\",\n    30→        });\n    31→  });\n    32→\n    33→  afterAll(async () => {\n    34→    await sql.end();\n    35→  });\n    36→\n    37→  beforeEach(async () => {\n    38→    await sql`TRUNCATE event_queue RESTART IDENTITY`;\n    39→  });\n    40→\n    41→  // -------------------------------------------------------------------------\n    42→  // emitEvent\n    43→  // -------------------------------------------------------------------------\n    44→\n    45→  describe(\"emitEvent\", () => {\n    46→    it(\"inserts a row with correct fields and returns eventId\", async () => {\n    47→      const payload = { referrerWallet: \"abc\", roundId: \"123\" };\n    48→\n    49→      const result = await sql.begin(async (tx) => {\n    50→        return emitEvent(\n    51→          tx as unknown as postgres.Sql,\n    52→          EventTypes.REFERRAL_GAME_SETTLED,\n    53→          payload,\n    54→        );\n    55→      });\n    56→\n    57→      expect(result.eventId).toBeTypeOf(\"bigint\");\n    58→      expect(result.eventId).toBeGreaterThan(0n);\n    59→\n    60→      // Verify the persisted row\n    61→      const rows = await sql`\n    62→        SELECT * FROM event_queue WHERE id = ${result.eventId.toString()}\n    63→      `;\n    64→      expect(rows).toHaveLength(1);\n    65→\n    66→      const row = rows[0]!;\n    67→      expect(row.event_type).toBe(\"referral.game_settled\");\n    68→      expect(row.payload).toEqual(payload);\n    69→      expect(row.status).toBe(\"pending\");\n    70→      expect(row.attempts).toBe(0);\n    71→      expect(row.max_attempts).toBe(3);\n    72→      expect(row.scheduled_at).toBeInstanceOf(Date);\n    73→      expect(row.created_at).toBeInstanceOf(Date);\n    74→    });\n    75→\n    76→    it(\"does NOT persist when transaction is rolled back\", async () => {\n    77→      let capturedId: bigint | undefined;\n    78→\n    79→      try {\n    80→        await sql.begin(async (tx) => {\n    81→          const result = await emitEvent(\n    82→            tx as unknown as postgres.Sql,\n    83→            EventTypes.REFERRAL_CODE_APPLIED,\n    84→            { test: true },\n    85→          );\n    86→          capturedId = result.eventId;\n    87→          throw new Error(\"intentional rollback\");\n    88→        });\n    89→      } catch {\n    90→        // Expected — begin() re-throws after rollback\n    91→      }\n    92→\n    93→      expect(capturedId).toBeDefined();\n    94→      const rows = await sql`\n    95→        SELECT * FROM event_queue WHERE id = ${capturedId!.toString()}\n    96→      `;\n    97→      expect(rows).toHaveLength(0);\n    98→    });\n    99→\n   100→    it(\"respects custom maxAttempts and scheduledAt\", async () => {\n   101→      const future = new Date(Date.now() + 60_000);\n   102→\n   103→      const result = await sql.begin(async (tx) => {\n   104→        return emitEvent(\n   105→          tx as unknown as postgres.Sql,\n   106→          EventTypes.REFERRAL_CLAIM_REQUESTED,\n   107→          { foo: \"bar\" },\n   108→          { maxAttempts: 5, scheduledAt: future },\n   109→        );\n   110→      });\n   111→\n   112→      const rows = await sql`\n   113→        SELECT * FROM event_queue WHERE id = ${result.eventId.toString()}\n   114→      `;\n   115→      expect(rows[0]!.max_attempts).toBe(5);\n   116→      // scheduled_at should be close to the future date (within 1s tolerance)\n   117→      const diff = Math.abs(rows[0]!.scheduled_at.getTime() - future.getTime());\n   118→      expect(diff).toBeLessThan(1000);\n   119→    });\n   120→  });\n   121→\n   122→  // -------------------------------------------------------------------------\n   123→  // Handler registry\n   124→  // -------------------------------------------------------------------------\n   125→\n   126→  describe(\"handler registry\", () => {\n   127→    it(\"register → get returns the handler\", () => {\n   128→      const handler = async () => {};\n   129→      registerHandler(EventTypes.REFERRAL_GAME_SETTLED, handler);\n   130→      expect(getHandler(\"referral.game_settled\")).toBe(handler);\n   131→    });\n   132→\n   133→    it(\"get for unknown type returns undefined\", () => {\n   134→      expect(getHandler(\"unknown.event.type\")).toBeUndefined();\n   135→    });\n   136→  });\n   137→\n   138→  // -------------------------------------------------------------------------\n   139→  // Backoff calculation\n   140→  // -------------------------------------------------------------------------\n   141→\n   142→  describe(\"getBackoffSeconds\", () => {\n   143→    it(\"attempt 1 → 5 seconds\", () => {\n   144→      expect(getBackoffSeconds(1)).toBe(5);\n   145→    });\n   146→\n   147→    it(\"attempt 2 → 30 seconds\", () => {\n   148→      expect(getBackoffSeconds(2)).toBe(30);\n   149→    });\n   150→\n   151→    it(\"attempt 3+ → 300 seconds\", () => {\n   152→      expect(getBackoffSeconds(3)).toBe(300);\n   153→      expect(getBackoffSeconds(4)).toBe(300);\n   154→    });\n   155→  });\n   156→});\n   157→"}]},"parent_tool_use_id":"toolu_01RpXW83QJq24abqs9Aj7G3q","session_id":"666b10e8-ff74-42a6-8a85-f241f06f2d89","uuid":"ab09b38a-8ae4-4c95-9c49-a722728e9575","timestamp":"2026-03-25T12:38:56.977Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vmr4V8bX3UzJTsbrbtqim3","type":"tool_result","content":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/queue/emit-event.ts:/** The transaction/sql handle accepted by emitEvent — works with both sql and tx from sql.begin(). */\n/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/queue/emit-event.ts:export async function emitEvent(\n/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/queue/handler-registry.ts:export function registerHandler(\n/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/queue/index.ts:export { emitEvent } from \"./emit-event.js\";\n/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/queue/index.ts:export { registerHandler, getHandler, clearHandlers } from \"./handler-registry.js\";\n/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/referral.ts:import { emitEvent } from \"../queue/emit-event.js\";\n/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/referral.ts:        await emitEvent(","is_error":false}]},"parent_tool_use_id":"toolu_01RpXW83QJq24abqs9Aj7G3q","session_id":"666b10e8-ff74-42a6-8a85-f241f06f2d89","uuid":"87782b43-0259-4f28-a9b5-b349276d6980","timestamp":"2026-03-25T12:38:59.135Z"}
