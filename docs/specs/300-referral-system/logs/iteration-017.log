3→const authDb = createAuthDb(sql);\n    34→\n    35→const connection = new Connection(config.rpcUrl, {\n    36→  commitment: \"confirmed\",\n    37→  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n    38→});\n    39→\n    40→const app = new Hono();\n    41→\n    42→app.use(\n    43→  \"*\",\n    44→  cors({\n    45→    origin: \"*\",\n    46→    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n    47→    allowHeaders: [\"Content-Type\", \"Authorization\"],\n    48→  }),\n    49→);\n    50→\n    51→// Request logging — correlate frontend fetch timing with server-side processing\n    52→app.use(\"*\", async (c, next) => {\n    53→  const start = Date.now();\n    54→  await next();\n    55→  const ms = Date.now() - start;\n    56→  const method = c.req.method;\n    57→  const path = c.req.path;\n    58→  // Skip noisy health checks and OPTIONS preflight\n    59→  if (path === \"/health\" || method === \"OPTIONS\") return;\n    60→  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n    61→});\n    62→\n    63→// Auth routes — no JWT middleware (these are the login endpoints)\n    64→// Lighter rate limiting by IP for auth endpoints\n    65→app.use(\n    66→  \"/auth/*\",\n    67→  createRateLimitMiddleware({\n    68→    perWallet: 20,\n    69→    global: config.rateLimitGlobal,\n    70→    windowMs: 60_000,\n    71→  }),\n    72→);\n    73→\n    74→app.route(\n    75→  \"/auth\",\n    76→  createAuthRoutes({\n    77→    authDb,\n    78→    jwtSecret: config.jwtSecret,\n    79→    cluster: config.cluster,\n    80→    challengeTtlSeconds: config.challengeTtlSeconds,\n    81→    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    82→    refreshTokenTtlDays: config.refreshTokenTtlDays,\n    83→  }),\n    84→);\n    85→\n    86→// Profile routes — authenticated GET endpoints (require JWT on all methods)\n    87→app.use(\n    88→  \"/profile/*\",\n    89→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n    90→);\n    91→app.route(\"/profile\", createProfileRoutes({ db }));\n    92→\n    93→// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n    94→app.use(\n    95→  \"/referral/*\",\n    96→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n    97→);\n    98→app.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n    99→\n   100→// JWT auth middleware for fairness endpoints\n   101→app.use(\n   102→  \"/fairness/*\",\n   103→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n   104→);\n   105→\n   106→// Rate limiting — per-wallet and global limits on POST requests\n   107→app.use(\n   108→  \"/fairness/*\",\n   109→  createRateLimitMiddleware({\n   110→    perWallet: config.rateLimitPerWallet,\n   111→    global: config.rateLimitGlobal,\n   112→    windowMs: 60_000,\n   113→  }),\n   114→);\n   115→\n   116→// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n   117→const entropyAccount = new PublicKey(config.entropyAccount);\n   118→const retrySettler = createRetrySettler({\n   119→  db,\n   120→  connection,\n   121→  settleRound: (pda) =>\n   122→    settleRound(\n   123→      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n   124→      pda,\n   125→    ),\n   126→});\n   127→\n   128→// PDA watcher — WebSocket-based instant join detection\n   129→const pdaWatcher = createPdaWatcher({\n   130→  connection,\n   131→  serverKey: config.serverKeypair.publicKey,\n   132→  db,\n   133→  onJoinDetected: async (pda, targetSlot) => {\n   134→    // Update DB phase if still in 'created'\n   135→    const round = await db.getRoundByPda(pda);\n   136→    if (round && round.phase === \"created\") {\n   137→      await db.updateRoundPhase(pda, \"locked\", {\n   138→        target_slot: targetSlot.toString(),\n   139→      });\n   140→      await db.insertOperator