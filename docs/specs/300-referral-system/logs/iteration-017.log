{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015wWXXYVeKnDBkv9WZC3SXh","type":"tool_result","content":"     1→import { Keypair } from \"@solana/web3.js\";\n     2→import { applyDbSchemaToUrl, loadDbSchemaFromEnv } from \"./db-config.js\";\n     3→\n     4→export interface Config {\n     5→  port: number;\n     6→  databaseUrl: string;\n     7→  dbSchema: string;\n     8→  rpcUrl: string;\n     9→  wsRpcUrl: string | undefined;\n    10→  serverKeypair: Keypair;\n    11→  jwtSecret: Uint8Array;\n    12→  cluster: string;\n    13→  challengeTtlSeconds: number;\n    14→  accessTokenTtlSeconds: number;\n    15→  refreshTokenTtlDays: number;\n    16→  rateLimitPerWallet: number;\n    17→  rateLimitGlobal: number;\n    18→  workerPollIntervalMs: number;\n    19→  entropyAccount: string;\n    20→  pythBtcUsdAccount: string;\n    21→  minSolBalance: number;\n    22→  eventQueuePollMs: number;\n    23→  referralDefaultRateBps: number;\n    24→  referralMinClaimLamports: number;\n    25→}\n    26→\n    27→function requireEnv(name: string): string {\n    28→  const value = process.env[name];\n    29→  if (!value) {\n    30→    throw new Error(`Missing required environment variable: ${name}`);\n    31→  }\n    32→  return value;\n    33→}\n    34→\n    35→function parseKeypair(raw: string): Keypair {\n    36→  try {\n    37→    const bytes = JSON.parse(raw) as number[];\n    38→    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n    39→  } catch {\n    40→    throw new Error(\n    41→      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    42→    );\n    43→  }\n    44→}\n    45→\n    46→export function loadConfig(): Config {\n    47→  const dbSchema = loadDbSchemaFromEnv();\n    48→\n    49→  return {\n    50→    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    51→    databaseUrl: applyDbSchemaToUrl(requireEnv(\"DATABASE_URL\"), dbSchema),\n    52→    dbSchema,\n    53→    rpcUrl: requireEnv(\"RPC_URL\"),\n    54→    wsRpcUrl: process.env.WS_RPC_URL || undefined,\n    55→    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    56→    jwtSecret: (() => {\n    57→      const explicit = process.env.JWT_SECRET;\n    58→      if (explicit) return new TextEncoder().encode(explicit);\n    59→      // Derive from first 32 bytes of server keypair secret key\n    60→      const kp = parseKeypair(requireEnv(\"SERVER_KEYPAIR\"));\n    61→      return kp.secretKey.slice(0, 32);\n    62→    })(),\n    63→    cluster: process.env.SOLANA_CLUSTER ?? \"devnet\",\n    64→    challengeTtlSeconds: parseInt(\n    65→      process.env.CHALLENGE_TTL_SECONDS ?? \"300\",\n    66→      10,\n    67→    ),\n    68→    accessTokenTtlSeconds: parseInt(\n    69→      process.env.ACCESS_TOKEN_TTL_SECONDS ?? \"86400\",\n    70→      10,\n    71→    ),\n    72→    refreshTokenTtlDays: parseInt(\n    73→      process.env.REFRESH_TOKEN_TTL_DAYS ?? \"14\",\n    74→      10,\n    75→    ),\n    76→    rateLimitPerWallet: parseInt(\n    77→      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n    78→      10,\n    79→    ),\n    80→    rateLimitGlobal: parseInt(\n    81→      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n    82→      10,\n    83→    ),\n    84→    workerPollIntervalMs: parseInt(\n    85→      process.env.WORKER_POLL_INTERVAL_MS ?? \"1000\",\n    86→      10,\n    87→    ),\n    88→    entropyAccount: process.env.ENTROPY_ACCOUNT ?? \"SysvarS1otHashes111111111111111111111111111\",\n    89→    pythBtcUsdAccount: process.env.PYTH_BTC_USD_ACCOUNT ?? \"4cSM2e6rvbGQUFiJbqytoVMi5GgghSMr8LwVrT9VPSPo\",\n    90→    minSolBalance: parseFloat(process.env.MIN_SOL_BALANCE ?? \"0.1\"),\n    91→    eventQueuePollMs: parseInt(\n    92→      process.env.EVENT_QUEUE_POLL_MS ?? \"1500\",\n    93→      10,\n    94→    ),\n    95→    referralDefaultRateBps: parseInt(\n    96→      process.env.REFERRAL_DEFAULT_RATE_BPS ?? \"1000\",\n    97→      10,\n    98→    ),\n    99→    referralMinClaimLamports: parseInt(\n   100→      process.env.REFERRAL_MIN_CLAIM_LAMPORTS ?? \"10000000\",\n   101→      10,\n   102→    ),\n   103→  };\n   104→}\n   105→"}]},"parent_tool_use_id":"toolu_01SudYo6eB5Lw6yTao4p7t2j","session_id":"666b10e8-ff74-42a6-8a85-f241f06f2d89","uuid":"81f5eff5-8319-481f-99c5-e7ee0625067f","timestamp":"2026-03-25T12:39:06.799Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FDV8zcAVqo99ewXppjoes5","type":"tool_result","content":"     1→import { Hono } from \"hono\";\n     2→import { cors } from \"hono/cors\";\n     3→import { serve } from \"@hono/node-server\";\n     4→import { Connection, PublicKey } from \"@solana/web3.js\";\n     5→import postgres from \"postgres\";\n     6→import { loadConfig } from \"./config.js\";\n     7→import { createDb } from \"./db.js\";\n     8→import { createAuthDb } from \"./auth-db.js\";\n     9→import { createCoinflipRoutes } from \"./routes/create.js\";\n    10→import { createLordRoutes } from \"./routes/lord-create.js\";\n    11→import { createRoundsRoutes } from \"./routes/rounds.js\";\n    12→import { createCloseCallRoutes } from \"./routes/closecall.js\";\n    13→import { createHealthRoutes } from \"./routes/health.js\";\n    14→import { createProfileRoutes } from \"./routes/profile.js\";\n    15→import { createPriceRoutes } from \"./routes/price.js\";\n    16→import { createAuthRoutes } from \"./routes/auth.js\";\n    17→import { createReferralRoutes } from \"./routes/referral.js\";\n    18→import { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n    19→import { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n    20→import { createSettlementWorker } from \"./worker/settlement.js\";\n    21→import { settleRound } from \"./worker/settle-tx.js\";\n    22→import { createRetrySettler } from \"./worker/retry.js\";\n    23→import { createPdaWatcher } from \"./worker/pda-watcher.js\";\n    24→import { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n    25→import { createEventWorker } from \"./queue/index.js\";\n    26→import { logger } from \"./logger.js\";\n    27→\n    28→const config = loadConfig();\n    29→\n    30→// Shared postgres connection for both game DB and auth DB\n    31→const sql = postgres(config.databaseUrl);\n    32→const db = createDb(config.databaseUrl);\n    33→const authDb = createAuthDb(sql);\n    34→\n    35→const connection = new Connection(config.rpcUrl, {\n    36→  commitment: \"confirmed\",\n    37→  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n    38→});\n    39→\n    40→const app = new Hono();\n    41→\n    42→app.use(\n    43→  \"*\",\n    44→  cors({\n    45→    origin: \"*\",\n    46→    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n    47→    allowHeaders: [\"Content-Type\", \"Authorization\"],\n    48→  }),\n    49→);\n    50→\n    51→// Request logging — correlate frontend fetch timing with server-side processing\n    52→app.use(\"*\", async (c, next) => {\n    53→  const start = Date.now();\n    54→  await next();\n    55→  const ms = Date.now() - start;\n    56→  const method = c.req.method;\n    57→  const path = c.req.path;\n    58→  // Skip noisy health checks and OPTIONS preflight\n    59→  if (path === \"/health\" || method === \"OPTIONS\") return;\n    60→  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n    61→});\n    62→\n    63→// Auth routes — no JWT middleware (these are the login endpoints)\n    64→// Lighter rate limiting by IP for auth endpoints\n    65→app.use(\n    66→  \"/auth/*\",\n    67→  createRateLimitMiddleware({\n    68→    perWallet: 20,\n    69→    global: config.rateLimitGlobal,\n    70→    windowMs: 60_000,\n    71→  }),\n    72→);\n    73→\n    74→app.route(\n    75→  \"/auth\",\n    76→  createAuthRoutes({\n    77→    authDb,\n    78→    jwtSecret: config.jwtSecret,\n    79→    cluster: config.cluster,\n    80→    challengeTtlSeconds: config.challengeTtlSeconds,\n    81→    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    82→    refreshTokenTtlDays: config.refreshTokenTtlDays,\n    83→  }),\n    84→);\n    85→\n    86→// Profile routes — authenticated GET endpoints (require JWT on all methods)\n    87→app.use(\n    88→  \"/profile/*\",\n    89→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n    90→);\n    91→app.route(\"/profile\", createProfileRoutes({ db }));\n    92→\n    93→// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n    94→app.use(\n    95→  \"/referral/*\",\n    96→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n    97→);\n    98→app.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n    99→\n   100→// JWT auth middleware for fairness endpoints\n   101→app.use(\n   102→  \"/fairness/*\",\n   103→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n   104→);\n   105→\n   106→// Rate limiting — per-wallet and global limits on POST requests\n   107→app.use(\n   108→  \"/fairness/*\",\n   109→  createRateLimitMiddleware({\n   110→    perWallet: config.rateLimitPerWallet,\n   111→    global: config.rateLimitGlobal,\n   112→    windowMs: 60_000,\n   113→  }),\n   114→);\n   115→\n   116→// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n   117→const entropyAccount = new PublicKey(config.entropyAccount);\n   118→const retrySettler = createRetrySettler({\n   119→  db,\n   120→  connection,\n   121→  settleRound: (pda) =>\n   122→    settleRound(\n   123→      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n   124→      pda,\n   125→    ),\n   126→});\n   127→\n   128→// PDA watcher — WebSocket-based instant join detection\n   129→const pdaWatcher = createPdaWatcher({\n   130→  connection,\n   131→  serverKey: config.serverKeypair.publicKey,\n   132→  db,\n   133→  onJoinDetected: async (pda, targetSlot) => {\n   134→    // Update DB phase if still in 'created'\n   135→    const round = await db.getRoundByPda(pda);\n   136→    if (round && round.phase === \"created\") {\n   137→      await db.updateRoundPhase(pda, \"locked\", {\n   138→        target_slot: targetSlot.toString(),\n   139→      });\n   140→      await db.insertOperatorEvent(pda, \"match_detected\", {\n   141→        targetSlot: targetSlot.toString(),\n   142→        source: \"pda-watcher\",\n   143→        game: round.game,\n   144→      });\n   145→    }\n   146→\n   147→    // Check if target slot already passed — settle immediately if so\n   148→    const currentSlot = await connection.getSlot();\n   149→    if (BigInt(currentSlot) >= targetSlot) {\n   150→      await retrySettler.attemptSettle(pda);\n   151→      pdaWatcher.unwatch(pda);\n   152→    }\n   153→    // If target slot not reached yet, poll worker will pick it up next cycle\n   154→  },\n   155→});\n   156→\n   157→const worker = createSettlementWorker({\n   158→  db,\n   159→  connection,\n   160→  serverKey: config.serverKeypair.publicKey,\n   161→  pollIntervalMs: config.workerPollIntervalMs,\n   162→  onSettleReady: async (pda) => {\n   163→    await retrySettler.attemptSettle(pda);\n   164→    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n   165→  },\n   166→  isFinalized: (pda) => retrySettler.isFinalized(pda),\n   167→});\n   168→worker.start();\n   169→\n   170→// Close Call clock worker — fetches boundary prices + settles open rounds\n   171→// Rounds are created on-demand by players via /closecall/bet\n   172→const closeCallClock = createCloseCallClockWorker({\n   173→  connection,\n   174→  serverKeypair: config.serverKeypair,\n   175→  db: sql,\n   176→});\n   177→closeCallClock.start();\n   178→\n   179→// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n   180→const eventWorker = createEventWorker(sql, {\n   181→  pollIntervalMs: config.eventQueuePollMs,\n   182→});\n   183→eventWorker.start();\n   184→logger.info(\"Event queue worker started\", {\n   185→  pollIntervalMs: config.eventQueuePollMs,\n   186→});\n   187→\n   188→// Coinflip fairness routes\n   189→app.route(\n   190→  \"/fairness/coinflip\",\n   191→  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n   192→);\n   193→app.route(\n   194→  \"/fairness/lord\",\n   195→  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n   196→);\n   197→\n   198→// Close Call routes (create-round co-signing + candle history + read queries)\n   199→app.route(\"/closecall\", createCloseCallRoutes({\n   200→  db,\n   201→  connection,\n   202→  serverKeypair: config.serverKeypair,\n   203→  clockWorker: closeCallClock,\n   204→  sql,\n   205→}));\n   206→\n   207→// Price routes — public, no auth\n   208→app.route(\"/price\", createPriceRoutes());\n   209→\n   210→// Round verification routes\n   211→app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n   212→\n   213→// Health endpoint — wired after worker exists so we can query its status\n   214→app.route(\n   215→  \"/health\",\n   216→  createHealthRoutes({\n   217→    db,\n   218→    sql,\n   219→    connection,\n   220→    serverKey: config.serverKeypair.publicKey,\n   221→    isWorkerRunning: () => worker.isRunning,\n   222→    minSolBalance: config.minSolBalance,\n   223→  }),\n   224→);\n   225→\n   226→const port = config.port;\n   227→logger.info(\"fairness-backend started\", { port });\n   228→\n   229→serve({\n   230→  fetch: app.fetch,\n   231→  port,\n   232→});\n   233→\n   234→export default {\n   235→  port,\n   236→  fetch: app.fetch,\n   237→};\n   238→"}]},"parent_tool_use_id":"toolu_01SudYo6eB5Lw6yTao4p7t2j","session_id":"666b10e8-ff74-42a6-8a85-f241f06f2d89","uuid":"cfa87ef6-61b4-4739-a434-c7c88da4e0d8","timestamp":"2026-03-25T12:39:06.889Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ucsbr8fQTjBcBK1eQuMGDi","type":"tool_result","content":"     1→/**\n     2→ * Database client module — typed query functions for `rounds` and `operator_events`.\n     3→ *\n     4→ * Phase transitions are unidirectional: created → locked → settling → settled,\n     5→ * or created → expired. The application layer rejects backward transitions.\n     6→ */\n     7→\n     8→import postgres from \"postgres\";\n     9→\n    10→// ---------------------------------------------------------------------------\n    11→// Types\n    12→// ---------------------------------------------------------------------------\n    13→\n    14→export type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    15→\n    16→export type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n    17→export type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n    18→\n    19→export interface CloseCallRound {\n    20→  round_id: string;\n    21→  pda: string;\n    22→  server_key: string;\n    23→  phase: CloseCallPhase;\n    24→  open_price: number;\n    25→  open_price_expo: number;\n    26→  close_price: number | null;\n    27→  outcome: CloseCallOutcome;\n    28→  green_pool: number;\n    29→  red_pool: number;\n    30→  total_fee: number;\n    31→  green_entries: Array<{ player: string; amountLamports: number }>;\n    32→  red_entries: Array<{ player: string; amountLamports: number }>;\n    33→  settle_tx: string | null;\n    34→  created_at: Date;\n    35→  settled_at: Date | null;\n    36→}\n    37→\n    38→export interface InsertCloseCallRoundParams {\n    39→  roundId: string;\n    40→  pda: string;\n    41→  serverKey: string;\n    42→  openPrice: number;\n    43→  openPriceExpo: number;\n    44→}\n    45→\n    46→export type OperatorEventType =\n    47→  | \"secret_generated\"\n    48→  | \"tx_built\"\n    49→  | \"match_detected\"\n    50→  | \"settle_submitted\"\n    51→  | \"settle_confirmed\"\n    52→  | \"settle_failed\"\n    53→  | \"settle_retried\"\n    54→  | \"timeout_detected\";\n    55→\n    56→export interface Round {\n    57→  pda: string;\n    58→  game: string;\n    59→  creator: string;\n    60→  server_key: string;\n    61→  secret: Buffer;\n    62→  commitment: Buffer;\n    63→  amount_lamports: number;\n    64→  side: number;\n    65→  match_id: string;\n    66→  phase: RoundPhase;\n    67→  target_slot: string | null;\n    68→  settle_tx: string | null;\n    69→  settle_attempts: number;\n    70→  result_hash: Buffer | null;\n    71→  result_side: number | null;\n    72→  winner: string | null;\n    73→  entries: unknown | null;\n    74→  created_at: Date;\n    75→  updated_at: Date;\n    76→}\n    77→\n    78→export interface InsertRoundParams {\n    79→  pda: string;\n    80→  game: string;\n    81→  creator: string;\n    82→  serverKey: string;\n    83→  secret: Buffer;\n    84→  commitment: Buffer;\n    85→  amountLamports: number;\n    86→  side: number;\n    87→  matchId: string;\n    88→  phase: RoundPhase;\n    89→  entries?: Array<{ player: string; amountLamports: number }>;\n    90→}\n    91→\n    92→export interface OperatorEvent {\n    93→  id: string;\n    94→  pda: string | null;\n    95→  event_type: OperatorEventType;\n    96→  payload: unknown;\n    97→  created_at: Date;\n    98→}\n    99→\n   100→// ---------------------------------------------------------------------------\n   101→// Transaction types\n   102→// ---------------------------------------------------------------------------\n   103→\n   104→export type TransactionType = \"deposit\" | \"payout\" | \"refund\";\n   105→\n   106→export interface Transaction {\n   107→  id: string;\n   108→  wallet: string;\n   109→  game: string;\n   110→  match_id: string;\n   111→  tx_type: TransactionType;\n   112→  amount_lamports: number;\n   113→  tx_sig: string;\n   114→  created_at: Date;\n   115→}\n   116→\n   117→export interface InsertTransactionParams {\n   118→  wallet: string;\n   119→  game: string;\n   120→  matchId: string;\n   121→  txType: TransactionType;\n   122→  amountLamports: number;\n   123→  txSig: string;\n   124→}\n   125→\n   126→// ---------------------------------------------------------------------------\n   127→// Referral types\n   128→// ---------------------------------------------------------------------------\n   129→\n   130→export interface ReferralCode {\n   131→  id: number;\n   132→  wallet: string;\n   133→  code: string;\n   134→  created_at: Date;\n   135→  updated_at: Date;\n   136→}\n   137→\n   138→export interface ReferralLink {\n   139→  id: number;\n   140→  referrer_wallet: string;\n   141→  referee_wallet: string;\n   142→  created_at: Date;\n   143→}\n   144→\n   145→export interface ReferralEarning {\n   146→  id: number;\n   147→  referrer_wallet: string;\n   148→  referee_wallet: string;\n   149→  round_id: string;\n   150→  game_type: string;\n   151→  wager_lamports: number;\n   152→  fee_lamports: number;\n   153→  referrer_earned_lamports: number;\n   154→  referrer_rate_bps: number;\n   155→  referee_rebate_lamports: number;\n   156→  referee_rebate_rate_bps: number;\n   157→  created_at: Date;\n   158→}\n   159→\n   160→export interface ReferralStats {\n   161→  referred_count: number;\n   162→  active_count: number;\n   163→  total_volume_lamports: string;\n   164→  total_earned_lamports: string;\n   165→  pending_lamports: string;\n   166→}\n   167→\n   168→export interface ReferralClaim {\n   169→  id: string;\n   170→  wallet: string;\n   171→  amount_lamports: string;\n   172→  status: \"pending\" | \"processing\" | \"completed\" | \"failed\";\n   173→  tx_signature: string | null;\n   174→  error: string | null;\n   175→  requested_at: Date;\n   176→  processed_at: Date | null;\n   177→}\n   178→\n   179→// ---------------------------------------------------------------------------\n   180→// Phase transition guard\n   181→// ---------------------------------------------------------------------------\n   182→\n   183→/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n   184→const VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n   185→  created: [\"locked\", \"expired\"],\n   186→  locked: [\"settling\"],\n   187→  settling: [\"settled\"],\n   188→  settled: [],\n   189→  expired: [],\n   190→};\n   191→\n   192→function assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n   193→  const allowed = VALID_TRANSITIONS[from];\n   194→  if (!allowed.includes(to)) {\n   195→    throw new Error(\n   196→      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n   197→    );\n   198→  }\n   199→}\n   200→\n   201→// ---------------------------------------------------------------------------\n   202→// DB client\n   203→// ---------------------------------------------------------------------------\n   204→\n   205→export interface Db {\n   206→  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n   207→  insertRound(params: InsertRoundParams): Promise<Round>;\n   208→\n   209→  /** Delete a round by PDA. Returns true if a row was removed. */\n   210→  deleteRoundByPda(pda: string): Promise<boolean>;\n   211→\n   212→  /** Transition a round's phase. Enforces unidirectional state machine.\n   213→   *  Optional `updates` can set additional columns alongside the phase change. */\n   214→  updateRoundPhase(\n   215→    pda: string,\n   216→    newPhase: RoundPhase,\n   217→    updates?: Partial<\n   218→      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n   219→    >,\n   220→  ): Promise<Round>;\n   221→\n   222→  /** Update the entries JSONB column for a settled round. */\n   223→  updateRoundEntries(\n   224→    pda: string,\n   225→    entries: Array<{ player: string; amountLamports: number }>,\n   226→  ): Promise<Round>;\n   227→\n   228→  /** Get a single round by its PDA. Returns `undefined` if not found. */\n   229→  getRoundByPda(pda: string): Promise<Round | undefined>;\n   230→\n   231→  /** Get all rounds matching a given phase. */\n   232→  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n   233→\n   234→  /** Append an operator event to the audit log. */\n   235→  insertOperatorEvent(\n   236→    pda: string | null,\n   237→    eventType: OperatorEventType,\n   238→    payload?: unknown,\n   239→  ): Promise<OperatorEvent>;\n   240→\n   241→  /** Get the latest operator event for a PDA + type. */\n   242→  getLatestOperatorEvent(\n   243→    pda: string,\n   244→    eventType: OperatorEventType,\n   245→  ): Promise<OperatorEvent | undefined>;\n   246→\n   247→  /** Get a single round by its match_id. Returns `undefined` if not found. */\n   248→  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n   249→\n   250→  /** Batch-fetch the latest operator event per PDA for a given event type. */\n   251→  getLatestOperatorEventsForPdas(\n   252→    pdas: string[],\n   253→    eventType: OperatorEventType,\n   254→  ): Promise<Map<string, OperatorEvent>>;\n   255→\n   256→  /** Get recently settled rounds for a game, ordered newest first. */\n   257→  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n   258→\n   259→  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n   260→  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n   261→\n   262→  // -------------------------------------------------------------------------\n   263→  // Close Call rounds\n   264→  // -------------------------------------------------------------------------\n   265→\n   266→  /** Insert a new Close Call round. */\n   267→  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n   268→\n   269→  /** Get a Close Call round by round_id (16-char hex). */\n   270→  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n   271→\n   272→  /** Get the current active (open) Close Call round. */\n   273→  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n   274→\n   275→  /** Get the most recent settled/refunded Close Call rounds. */\n   276→  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n   277→\n   278→  /** Update a Close Call round after settlement. */\n   279→  settleCloseCallRound(\n   280→    roundId: string,\n   281→    updates: {\n   282→      phase: CloseCallPhase;\n   283→      outcome: CloseCallOutcome;\n   284→      closePrice?: number;\n   285→      greenPool?: number;\n   286→      redPool?: number;\n   287→      totalFee?: number;\n   288→      greenEntries?: Array<{ player: string; amountLamports: number }>;\n   289→      redEntries?: Array<{ player: string; amountLamports: number }>;\n   290→      settleTx?: string;\n   291→    },\n   292→  ): Promise<CloseCallRound>;\n   293→\n   294→  // -------------------------------------------------------------------------\n   295→  // Transactions\n   296→  // -------------------------------------------------------------------------\n   297→\n   298→  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n   299→  insertTransaction(params: InsertTransactionParams): Promise<void>;\n   300→\n   301→  /** Insert multiple transactions in a single batch. */\n   302→  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n   303→\n   304→  /** Get paginated transactions for a wallet, newest first. */\n   305→  getTransactions(\n   306→    wallet: string,\n   307→    cursor?: string,\n   308→    limit?: number,\n   309→    game?: string,\n   310→  ): Promise<Transaction[]>;\n   311→\n   312→  // -------------------------------------------------------------------------\n   313→  // Referral — codes\n   314→  // -------------------------------------------------------------------------\n   315→\n   316→  /** Insert a new referral code for a wallet. Throws on duplicate wallet or code. */\n   317→  insertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n   318→\n   319→  /** Get a wallet's referral code. Returns `undefined` if none set. */\n   320→  getReferralCodeByWallet(wallet: string): Promise<ReferralCode | undefined>;\n   321→\n   322→  /** Look up a referral code record by code string. Returns `undefined` if not found. */\n   323→  getReferralCodeByCode(code: string): Promise<ReferralCode | undefined>;\n   324→\n   325→  /** Set or replace a wallet's referral code (INSERT … ON CONFLICT UPDATE). */\n   326→  upsertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n   327→\n   328→  // -------------------------------------------------------------------------\n   329→  // Referral — links\n   330→  // -------------------------------------------------------------------------\n   331→\n   332→  /** Create a referral link (referrer → referee). Throws on duplicate referee. */\n   333→  insertReferralLink(referrerWallet: string, refereeWallet: string): Promise<ReferralLink>;\n   334→\n   335→  /** Get the referral link for a referee wallet. Returns `undefined` if not referred. */\n   336→  getReferralLinkByReferee(refereeWallet: string): Promise<ReferralLink | undefined>;\n   337→\n   338→  /** Get all referral links where the given wallet is the referrer. */\n   339→  getReferralLinksByReferrer(referrerWallet: string): Promise<ReferralLink[]>;\n   340→\n   341→  // -------------------------------------------------------------------------\n   342→  // Referral — earnings & stats\n   343→  // -------------------------------------------------------------------------\n   344→\n   345→  /** Insert a referral earning row. Throws on duplicate (referee_wallet, round_id). */\n   346→  insertReferralEarning(params: {\n   347→    referrerWallet: string;\n   348→    refereeWallet: string;\n   349→    roundId: string;\n   350→    gameType: string;\n   351→    wagerLamports: number;\n   352→    feeLamports: number;\n   353→    referrerEarnedLamports: number;\n   354→    referrerRateBps: number;\n   355→    refereeRebateLamports: number;\n   356→    refereeRebateRateBps: number;\n   357→  }): Promise<ReferralEarning>;\n   358→\n   359→  /**\n   360→   * Get the pending (unclaimed) balance for a wallet.\n   361→   * Sum of referrer_earned where wallet=referrer + sum of referee_rebate where\n   362→   * wallet=referee, minus sum of completed claims for the wallet.\n   363→   * Returns a lamport string.\n   364→   */\n   365→  getPendingBalance(wallet: string): Promise<string>;\n   366→\n   367→  /** Get paginated per-game earnings for a wallet (as referrer). Newest first. */\n   368→  getReferralEarnings(\n   369→    wallet: string,\n   370→    page: number,\n   371→    limit: number,\n   372→  ): Promise<{ items: ReferralEarning[]; totalPages: number }>;\n   373→\n   374→  /** Get referral summary stats for a wallet. */\n   375→  getReferralStats(wallet: string): Promise<ReferralStats>;\n   376→\n   377→  // -------------------------------------------------------------------------\n   378→  // Referral — claims & rates\n   379→  // -------------------------------------------------------------------------\n   380→\n   381→  /** Insert a new referral claim row (status defaults to 'pending'). Returns the created claim. */\n   382→  insertReferralClaim(\n   383→    wallet: string,\n   384→    amountLamports: string,\n   385→  ): Promise<ReferralClaim>;\n   386→\n   387→  /** Get a referral claim by its UUID. Returns `undefined` if not found. */\n   388→  getReferralClaim(claimId: string): Promise<ReferralClaim | undefined>;\n   389→\n   390→  /**\n   391→   * Update a claim's status and optional metadata (tx_signature, error, processed_at).\n   392→   * Returns the updated claim.\n   393→   */\n   394→  updateClaimStatus(\n   395→    claimId: string,\n   396→    status: ReferralClaim[\"status\"],\n   397→    meta?: { txSignature?: string; error?: string },\n   398→  ): Promise<ReferralClaim>;\n   399→\n   400→  /**\n   401→   * Get the effective referrer rate for a wallet in bps.\n   402→   * Checks `referral_kol_rates` first; falls back to `defaultRateBps`.\n   403→   */\n   404→  getReferrerRate(\n   405→    wallet: string,\n   406→    defaultRateBps: number,\n   407→  ): Promise<number>;\n   408→\n   409→  /**\n   410→   * Execute a function within a database transaction.\n   411→   * All db methods called on the transactional Db share the same transaction.\n   412→   * Rolls back on error, commits on success.\n   413→   */\n   414→  withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T>;\n   415→\n   416→  /** Gracefully close the connection pool. */\n   417→  close(): Promise<void>;\n   418→}\n   419→\n   420→function normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n   421→  return {\n   422→    ...row,\n   423→    open_price: Number(row.open_price),\n   424→    open_price_expo: Number(row.open_price_expo),\n   425→    close_price: row.close_price === null ? null : Number(row.close_price),\n   426→    green_pool: Number(row.green_pool),\n   427→    red_pool: Number(row.red_pool),\n   428→    total_fee: Number(row.total_fee),\n   429→    // JSONB comes back as parsed objects from postgres.js\n   430→    green_entries: Array.isArray(row.green_entries)\n   431→      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   432→      : [],\n   433→    red_entries: Array.isArray(row.red_entries)\n   434→      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   435→      : [],\n   436→  };\n   437→}\n   438→\n   439→function normalizeTransaction(row: Transaction): Transaction {\n   440→  return {\n   441→    ...row,\n   442→    amount_lamports: Number(row.amount_lamports),\n   443→  };\n   444→}\n   445→\n   446→function normalizeReferralEarning(row: ReferralEarning): ReferralEarning {\n   447→  return {\n   448→    ...row,\n   449→    wager_lamports: Number(row.wager_lamports),\n   450→    fee_lamports: Number(row.fee_lamports),\n   451→    referrer_earned_lamports: Number(row.referrer_earned_lamports),\n   452→    referrer_rate_bps: Number(row.referrer_rate_bps),\n   453→    referee_rebate_lamports: Number(row.referee_rebate_lamports),\n   454→    referee_rebate_rate_bps: Number(row.referee_rebate_rate_bps),\n   455→  };\n   456→}\n   457→\n   458→function normalizeRound(row: Round): Round {\n   459→  return {\n   460→    ...row,\n   461→    amount_lamports: Number(row.amount_lamports),\n   462→    side: Number(row.side),\n   463→    settle_attempts: Number(row.settle_attempts),\n   464→    result_side: row.result_side === null ? null : Number(row.result_side),\n   465→    // JSONB comes back as parsed objects from postgres.js\n   466→    entries: Array.isArray(row.entries)\n   467→      ? (row.entries as Array<{ player: string; amountLamports: number }>).map((e) => ({\n   468→          player: e.player,\n   469→          amountLamports: Number(e.amountLamports),\n   470→        }))\n   471→      : null,\n   472→  };\n   473→}\n   474→\n   475→// eslint-disable-next-line @typescript-eslint/no-explicit-any\n   476→export function createDb(databaseUrl: string, _txSql?: any): Db {\n   477→  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n   478→  const sql: any = _txSql ?? postgres(databaseUrl);\n   479→  const _isOwner = !_txSql;\n   480→\n   481→  return {\n   482→    async insertRound(params) {\n   483→      const rows = await sql<Round[]>`\n   484→        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase, entries)\n   485→        VALUES (\n   486→          ${params.pda},\n   487→          ${params.game},\n   488→          ${params.creator},\n   489→          ${params.serverKey},\n   490→          ${params.secret},\n   491→          ${params.commitment},\n   492→          ${params.amountLamports},\n   493→          ${params.side},\n   494→          ${params.matchId},\n   495→          ${params.phase},\n   496→          ${params.entries ? sql.json(params.entries) : null}\n   497→        )\n   498→        RETURNING *\n   499→      `;\n   500→      return normalizeRound(rows[0]!);\n   501→    },\n   502→\n   503→    async deleteRoundByPda(pda) {\n   504→      const rows = await sql<{ pda: string }[]>`\n   505→        DELETE FROM rounds WHERE pda = ${pda}\n   506→        RETURNING pda\n   507→      `;\n   508→      return rows.length > 0;\n   509→    },\n   510→\n   511→    async updateRoundPhase(pda, newPhase, updates) {\n   512→      // Fetch current phase to validate transition\n   513→      const current = await sql<Pick<Round, \"phase\">[]>`\n   514→        SELECT phase FROM rounds WHERE pda = ${pda}\n   515→      `;\n   516→\n   517→      if (current.length === 0) {\n   518→        throw new Error(`Round not found: ${pda}`);\n   519→      }\n   520→\n   521→      const currentPhase = current[0]!.phase as RoundPhase;\n   522→      assertPhaseTransition(currentPhase, newPhase);\n   523→\n   524→      // Build the update — always set phase + updated_at\n   525→      const rows = await sql<Round[]>`\n   526→        UPDATE rounds SET\n   527→          phase = ${newPhase},\n   528→          updated_at = now(),\n   529→          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n   530→          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n   531→          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n   532→          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n   533→          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n   534→          winner = COALESCE(${updates?.winner ?? null}, winner)\n   535→        WHERE pda = ${pda}\n   536→        RETURNING *\n   537→      `;\n   538