{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013hiWqNLsGxNSLa8Zgavuhs","type":"tool_result","content":"   340→   */\n   341→  async function settleRound(\n   342→    roundPda: PublicKey,\n   343→    minuteTs: bigint,\n   344→    round: ReturnType<typeof decodeCloseCallRound>,\n   345→  ): Promise<boolean> {\n   346→    try {\n   347→      const nowSec = Math.floor(Date.now() / 1000);\n   348→      const candleCloseTime = Number(minuteTs) + 60;\n   349→\n   350→      if (nowSec < candleCloseTime) {\n   351→        logger.debug(\"closecall clock: candle not closed yet\", {\n   352→          pda: roundPda.toBase58(),\n   353→          secondsRemaining: candleCloseTime - nowSec,\n   354→        });\n   355→        return false;\n   356→      }\n   357→\n   358→      const greenCount = round.greenEntries.length;\n   359→      const redCount = round.redEntries.length;\n   360→      const totalCount = greenCount + redCount;\n   361→\n   362→      // Fetch platform config (treasury + feeBps) + close price\n   363→      const [platformConfig, hermesPrice] = await Promise.all([\n   364→        readPlatformConfig(),\n   365→        hermes.fetchLatestBtcPrice(),\n   366→      ]);\n   367→\n   368→      if (!platformConfig) {\n   369→        logger.error(\"closecall clock: cannot read platform config treasury\");\n   370→        return false;\n   371→      }\n   372→      const { treasury, feeBps } = platformConfig;\n   373→      if (!hermesPrice) {\n   374→        logger.error(\"closecall clock: cannot fetch Hermes price for settlement\");\n   375→        return false;\n   376→      }\n   377→\n   378→      if (totalCount === 0) {\n   379→        logger.info(\"closecall clock: settling empty round\", {\n   380→          pda: roundPda.toBase58(),\n   381→        });\n   382→      }\n   383→\n   384→      // Pre-determine outcome\n   385→      const hasBothSides = greenCount > 0 && redCount > 0;\n   386→      const isRefund =\n   387→        totalCount === 0 ||\n   388→        !hasBothSides ||\n   389→        totalCount === 1 ||\n   390→        hermesPrice.price === round.openPrice;\n   391→\n   392→      let remainingAccounts: PublicKey[];\n   393→      if (isRefund) {\n   394→        remainingAccounts = [\n   395→          ...round.greenEntries.map((e) => e.player),\n   396→          ...round.redEntries.map((e) => e.player),\n   397→        ];\n   398→      } else if (hermesPrice.price > round.openPrice) {\n   399→        remainingAccounts = round.greenEntries.map((e) => e.player);\n   400→      } else {\n   401→        remainingAccounts = round.redEntries.map((e) => e.player);\n   402→      }\n   403→\n   404→      const ix = buildCloseCallSettleRoundIx(\n   405→        serverKeypair.publicKey,\n   406→        minuteTs,\n   407→        hermesPrice.price,\n   408→        hermesPrice.expo,\n   409→        treasury,\n   410→        remainingAccounts,\n   411→      );\n   412→\n   413→      const { blockhash, lastValidBlockHeight } =\n   414→        await connection.getLatestBlockhash();\n   415→      const tx = new Transaction({\n   416→        feePayer: serverKeypair.publicKey,\n   417→        blockhash,\n   418→        lastValidBlockHeight,\n   419→      });\n   420→      tx.add(ix);\n   421→      tx.sign(serverKeypair);\n   422→\n   423→      const sig = await sendAndConfirm(tx, \"settle\");\n   424→\n   425→      const outcomeStr = isRefund\n   426→        ? \"refund\"\n   427→        : hermesPrice.price > round.openPrice\n   428→          ? \"green\"\n   429→          : \"red\";\n   430→\n   431→      logger.info(\"closecall clock: round settled\", {\n   432→        pda: roundPda.toBase58(),\n   433→        tx: sig,\n   434→        totalEntries: totalCount,\n   435→        outcome: outcomeStr,\n   436→      });\n   437→\n   438→      // Persist settlement to DB\n   439→      try {"}]},"parent_tool_use_id":"toolu_01Uwj6aJcpNBERkrvU3gMqdx","session_id":"666b10e8-ff74-42a6-8a85-f241f06f2d89","uuid":"0780d176-16