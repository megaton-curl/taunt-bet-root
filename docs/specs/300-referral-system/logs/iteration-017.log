{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CgY7Zpbq9Qg7mEKaYmcLi5","type":"tool_result","content":"     1→/**\n     2→ * Settle transaction builder + submission.\n     3→ *\n     4→ * Retrieves the stored secret, reads on-chain match + config data to resolve\n     5→ * all accounts, builds the `settle` instruction, submits it, and updates the\n     6→ * DB on confirmation.\n     7→ */\n     8→\n     9→import { createHash } from \"node:crypto\";\n    10→import { performance } from \"node:perf_hooks\";\n    11→import {\n    12→  Connection,\n    13→  Keypair,\n    14→  PublicKey,\n    15→  SystemProgram,\n    16→  Transaction,\n    17→  TransactionInstruction,\n    18→} from \"@solana/web3.js\";\n    19→import type { Db } from \"../db.js\";\n    20→import { logger } from \"../logger.js\";\n    21→import { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n    22→import { derivePlatformConfigPda, getPlatformConfig } from \"../platform-config.js\";\n    23→import { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@rng-utopia/anchor-client\";\n    24→import {\n    25→  decodeCoinflipMatch,\n    26→  decodeLordRound,\n    27→  type DecodedJackpotRound,\n    28→} from \"./account-decoder.js\";\n    29→\n    30→// ---------------------------------------------------------------------------\n    31→// Instruction discriminators (from IDL — no hardcoded byte arrays)\n    32→// ---------------------------------------------------------------------------\n    33→\n    34→function getInstructionDiscriminator(\n    35→  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n    36→  instructionName: string,\n    37→): Buffer {\n    38→  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n    39→  if (!instruction) {\n    40→    throw new Error(`Instruction ${instructionName} not found in IDL`);\n    41→  }\n    42→  return Buffer.from(instruction.discriminator);\n    43→}\n    44→\n    45→const SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\n    46→const CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n    47→  lordIdl,\n    48→  \"claim_payout\",\n    49→);\n    50→const CC_BET_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"bet\");\n    51→const CC_SETTLE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"settle_round\");\n    52→const CC_TIMEOUT_REFUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"timeout_refund\");\n    53→\n    54→// ---------------------------------------------------------------------------\n    55→// Types\n    56→// ---------------------------------------------------------------------------\n    57→\n    58→export interface SettleTxDeps {\n    59→  db: Db;\n    60→  connection: Connection;\n    61→  serverKeypair: Keypair;\n    62→  entropyAccount: PublicKey;\n    63→  referralDefaultRateBps: number;\n    64→}\n    65→\n    66→export interface SettleResult {\n    67→  txSignature: string;\n    68→  resultHash: Buffer;\n    69→  resultSide?: number;\n    70→  winningEntryIndex?: number;\n    71→  winner: string;\n    72→}\n    73→\n    74→// ---------------------------------------------------------------------------\n    75→// Instruction encoding\n    76→// ---------------------------------------------------------------------------\n    77→\n    78→/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\n    79→function encodeSettleData(secret: Buffer): Buffer {\n    80→  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n    81→}\n    82→\n    83→function encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n    84→  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n    85→}\n    86→\n    87→// ---------------------------------------------------------------------------\n    88→// Result derivation (mirrors on-chain derive_result)\n    89→// ---------------------------------------------------------------------------\n    90→\n    91→/**\n    92→ * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n    93→ * Must match shared/src/fairness.rs `derive_result()`.\n    94→ */\n    95→function deriveResult(\n    96→  secret: Buffer,\n    97→  entropy: Buffer,\n    98→  matchPdaBytes: Buffer,\n    99→  algoVer: number,\n   100→): Buffer {\n   101→  return createHash(\"sha256\")\n   102→    .update(secret)\n   103→    .update(entropy)\n   104→    .update(matchPdaBytes)\n   105→    .update(Buffer.from([algoVer]))\n   106→    .digest();\n   107→}\n   108→\n   109→// ---------------------------------------------------------------------------\n   110→// Referral earnings hook\n   111→// ---------------------------------------------------------------------------\n   112→\n   113→/**\n   114→ * After a game settles, check each player for a referrer and record\n   115→ * referral earnings if applicable.\n   116→ *\n   117→ * For each unique player: look up referral link → if referrer exists,\n   118→ * calculate referrer earning + referee rebate → insert into referral_earnings.\n   119→ *\n   120→ * Errors are logged but never bubble — referral recording must not fail settlement.\n   121→ * The UNIQUE(referee_wallet, round_id) constraint provides idempotency on retries.\n   122→ */\n   123→async function recordReferralEarnings(\n   124→  db: Db,\n   125→  params: {\n   126→    roundId: string;\n   127→    gameType: string;\n   128→    feeBps: number;\n   129→    referralDefaultRateBps: number;\n   130→    players: Array<{ wallet: string; wagerLamports: number }>;\n   131→  },\n   132→): Promise<void> {\n   133→  const { roundId, gameType, feeBps, referralDefaultRateBps, players } = params;\n   134→\n   135→  // Deduplicate players (Lord of RNGs can have multiple entries per player)\n   136→  const playerWagers = new Map<string, number>();\n   137→  for (const p of players) {\n   138→    playerWagers.set(p.wallet, (playerWagers.get(p.wallet) ?? 0) + p.wagerLamports);\n   139→  }\n   140→\n   141→  for (const [wallet, wagerLamports] of playerWagers) {\n   142→    try {\n   143→      const link = await db.getReferralLinkByReferee(wallet);\n   144→      if (!link) continue;\n   145→\n   146→      const referrerWallet = link.referrer_wallet;\n   147→      const referrerRateBps = await db.getReferrerRate(\n   148→        referrerWallet,\n   149→        referralDefaultRateBps,\n   150→      );\n   151→\n   152→      const feeLamports = Math.floor((wagerLamports * feeBps) / 10_000);\n   153→      const referrerEarnedLamports = Math.floor(\n   154→        (feeLamports * referrerRateBps) / 10_000,\n   155→      );\n   156→      const refereeRebateLamports = Math.floor((feeLamports * 1000) / 10_000);\n   157→\n   158→      await db.insertReferralEarning({\n   159→        referrerWallet,\n   160→        refereeWallet: wallet,\n   161→        roundId,\n   162→        gameType,\n   163→        wagerLamports,\n   164→        feeLamports,\n   165→        referrerEarnedLamports,\n   166→        referrerRateBps,\n   167→        refereeRebateLamports,\n   168→        refereeRebateRateBps: 1000, // fixed 10% for v1\n   169→      });\n   170→\n   171→      logger.info(\"referral earning recorded\", {\n   172→        roundId,\n   173→        gameType,\n   174→        referrer: referrerWallet,\n   175→        referee: wallet,\n   176→        referrerEarnedLamports,\n   177→        refereeRebateLamports,\n   178→      });\n   179→    } catch (err: unknown) {\n   180→      const msg = err instanceof Error ? err.message : String(err);\n   181→      if (msg.includes(\"duplicate key\") || msg.includes(\"unique constraint\")) {\n   182→        logger.info(\"referral earning already recorded (idempotent skip)\", {\n   183→          roundId,\n   184→          wallet,\n   185→        });\n   186→      } else {\n   187→        logger.error(\"failed to record referral earning\", {\n   188→          roundId,\n   189→          wallet,\n   190→          error: msg,\n   191→        });\n   192→      }\n   193→    }\n   194→  }\n   195→}\n   196→\n   197→// ---------------------------------------------------------------------------\n   198→// Core settle function\n   199→// ---------------------------------------------------------------------------\n   200→\n   201→/**\n   202→ * Build, submit, and confirm a settle transaction for a locked match.\n   203→ *\n   204→ * Steps:\n   205→ * 1. Retrieve secret from DB\n   206→ * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n   207→ * 3. Fetch config account data (treasury)\n   208→ * 4. Read entropy from the entropy account\n   209→ * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n   210→ * 6. Build + submit settle tx\n   211→ * 7. Update DB on confirmation\n   212→ */\n   213→export async function settleMatch(\n   214→  deps: SettleTxDeps,\n   215→  pda: string,\n   216→): Promise<SettleResult> {\n   217→  const t0 = performance.now();\n   218→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   219→  const matchPubkey = new PublicKey(pda);\n   220→\n   221→  // 1. Retrieve secret from DB\n   222→  const round = await db.getRoundByPda(pda);\n   223→  const tDb = performance.now();\n   224→  if (!round) {\n   225→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   226→  }\n   227→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   228→    throw new PermanentSettleError(\n   229→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   230→    );\n   231→  }\n   232→\n   233→  const secret = Buffer.from(round.secret);\n   234→\n   235→  // Transition to settling (locked → settling)\n   236→  if (round.phase === \"locked\") {\n   237→    await db.updateRoundPhase(pda, \"settling\");\n   238→  }\n   239→\n   240→  // Log settle_submitted\n   241→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   242→    attempt: round.settle_attempts + 1,\n   243→  });\n   244→\n   245→  // 2-4. Fetch match, platform config, entropy, and blockhash in parallel\n   246→  const [platformConfigPda] = derivePlatformConfigPda();\n   247→  const [matchAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n   248→    await Promise.all([\n   249→      connection.getAccountInfo(matchPubkey),\n   250→      getPlatformConfig(connection),\n   251→      connection.getAccountInfo(entropyAccount),\n   252→      connection.getLatestBlockhash(),\n   253→    ]);\n   254→  const tFetch = performance.now();\n   255→\n   256→  if (!matchAccountInfo) {\n   257→    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n   258→  }\n   259→  if (!entropyInfo) {\n   260→    throw new TransientSettleError(\"Entropy account not available yet\");\n   261→  }\n   262→\n   263→  // IDL-driven decode — no manual byte offsets\n   264→  const match = decodeCoinflipMatch(Buffer.from(matchAccountInfo.data));\n   265→  const { feeBps, treasury } = platformConfig;\n   266→\n   267→  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer } = match;\n   268→\n   269→  const pool = entryAmount * 2n;\n   270→  const feeAmount = Number((pool * BigInt(feeBps)) / 10_000n);\n   271→  const payoutAmount = Number(pool) - feeAmount;\n   272→\n   273→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   274→\n   275→  // 5. Pre-compute result\n   276→  const matchPdaBytes = matchPubkey.toBuffer();\n   277→  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n   278→  const resultSide = resultHash[0]! % 2;\n   279→  const winner = resultSide === creatorSide ? creator : opponent;\n   280→\n   281→  // 6. Build settle instruction (8 accounts, no profile CPI)\n   282→  const data = encodeSettleData(secret);\n   283→\n   284→  const instruction = new TransactionInstruction({\n   285→    keys: [\n   286→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n   287→      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // coinflip_match\n   288→      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n   289→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   290→      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n   291→      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n   292→      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n   293→      {\n   294→        pubkey: SystemProgram.programId,\n   295→        isSigner: false,\n   296→        isWritable: false,\n   297→      }, // system_program\n   298→    ],\n   299→    programId: COINFLIP_PROGRAM_ID,\n   300→    data,\n   301→  });\n   302→\n   303→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   304→\n   305→  const tx = new Transaction({\n   306→    feePayer: serverKeypair.publicKey,\n   307→    blockhash,\n   308→    lastValidBlockHeight,\n   309→  });\n   310→  tx.add(instruction);\n   311→  tx.sign(serverKeypair);\n   312→\n   313→  // 7. Submit and confirm\n   314→  const rawTx = tx.serialize();\n   315→  const tBuild = performance.now();\n   316→  const txSignature = await connection.sendRawTransaction(rawTx, {\n   317→    skipPreflight: false,\n   318→  });\n   319→  const tSend = performance.now();\n   320→\n   321→  logger.info(\"settlement transaction submitted\", {\n   322→    pda,\n   323→    txSignature,\n   324→    attempt: round.settle_attempts + 1,\n   325→    dbMs: Math.round(tDb - t0),\n   326→    fetchMs: Math.round(tFetch - tDb),\n   327→    buildMs: Math.round(tBuild - tFetch),\n   328→    sendMs: Math.round(tSend - tBuild),\n   329→  });\n   330→\n   331→  const confirmation = await connection.confirmTransaction(\n   332→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   333→    \"confirmed\",\n   334→  );\n   335→  const tConfirm = performance.now();\n   336→  if (confirmation.value.err) {\n   337→    throw new TransientSettleError(\n   338→      `Coinflip settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   339→    );\n   340→  }\n   341→\n   342→  // 8. Update DB — phase settling → settled (atomic transaction)\n   343→  const coinflipEntries = [\n   344→    { player: creator.toBase58(), amountLamports: Number(entryAmount) },\n   345→    { player: opponent.toBase58(), amountLamports: Number(entryAmount) },\n   346→  ];\n   347→\n   348→  await db.withTransaction(async (txDb) => {\n   349→    await txDb.updateRoundPhase(pda, \"settled\", {\n   350→      settle_tx: txSignature,\n   351→      result_hash: resultHash,\n   352→      result_side: resultSide,\n   353→      winner: winner.toBase58(),\n   354→      settle_attempts: round.settle_attempts + 1,\n   355→    });\n   356→\n   357→    // Persist entries in dedicated JSONB column for direct access\n   358→    await txDb.updateRoundEntries(pda, coinflipEntries);\n   359→\n   360→    // Log settle_confirmed\n   361→    await txDb.insertOperatorEvent(pda, \"settle_confirmed\", {\n   362→      txSignature,\n   363→      resultSide,\n   364→      winner: winner.toBase58(),\n   365→      entropy: entropy.toString(\"hex\"),\n   366→      payoutAmount,\n   367→      feeAmount,\n   368→      entries: coinflipEntries,\n   369→    });\n   370→\n   371→    // Write payout transaction for the winner\n   372→    await txDb.insertTransaction({\n   373→      wallet: winner.toBase58(),\n   374→      game: \"coinflip\",\n   375→      matchId: round.match_id,\n   376→      txType: \"payout\",\n   377→      amountLamports: payoutAmount,\n   378→      txSig: txSignature,\n   379→    });\n   380→\n   381→    // Referral earnings hook — in same transaction for atomicity (System Invariant 4)\n   382→    await recordReferralEarnings(txDb, {\n   383→      roundId: round.match_id,\n   384→      gameType: \"coinflip\",\n   385→      feeBps,\n   386→      referralDefaultRateBps: deps.referralDefaultRateBps,\n   387→      players: [\n   388→        { wallet: creator.toBase58(), wagerLamports: Number(entryAmount) },\n   389→        { wallet: opponent.toBase58(), wagerLamports: Number(entryAmount) },\n   390→      ],\n   391→    });\n   392→  });\n   393→\n   394→  const tDone = performance.now();\n   395→  logger.info(\"settlement transaction confirmed\", {\n   396→    pda,\n   397→    txSignature,\n   398→    resultSide,\n   399→    winner: winner.toBase58(),\n   400→    timing: {\n   401→      dbMs: Math.round(tDb - t0),\n   402→      fetchMs: Math.round(tFetch - tDb),\n   403→      buildMs: Math.round(tBuild - tFetch),\n   404→      sendMs: Math.round(tSend - tBuild),\n   405→      confirmMs: Math.round(tConfirm - tSend),\n   406→      dbWriteMs: Math.round(tDone - tConfirm),\n   407→      totalMs: Math.round(tDone - t0),\n   408→    },\n   409→  });\n   410→\n   411→  return {\n   412→    txSignature,\n   413→    resultHash,\n   414→    resultSide,\n   415→    winner: winner.toBase58(),\n   416→  };\n   417→}\n   418→\n   419→export async function settleLordRound(\n   420→  deps: SettleTxDeps,\n   421→  pda: string,\n   422→): Promise<SettleResult> {\n   423→  const t0 = performance.now();\n   424→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   425→  const roundPubkey = new PublicKey(pda);\n   426→\n   427→  const round = await db.getRoundByPda(pda);\n   428→  const tDb = performance.now();\n   429→  if (!round) {\n   430→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   431→  }\n   432→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   433→    throw new PermanentSettleError(\n   434→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   435→    );\n   436→  }\n   437→\n   438→  const secret = Buffer.from(round.secret);\n   439→\n   440→  if (round.phase === \"locked\") {\n   441→    await db.updateRoundPhase(pda, \"settling\");\n   442→  }\n   443→\n   444→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   445→    attempt: round.settle_attempts + 1,\n   446→    game: \"lord\",\n   447→  });\n   448→\n   449→  const [platformConfigPda] = derivePlatformConfigPda();\n   450→  const [roundAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n   451→    await Promise.all([\n   452→      connection.getAccountInfo(roundPubkey),\n   453→      getPlatformConfig(connection),\n   454→      connection.getAccountInfo(entropyAccount),\n   455→      connection.getLatestBlockhash(),\n   456→    ]);\n   457→\n   458→  const tFetch = performance.now();\n   459→\n   460→  if (!roundAccountInfo) {\n   461→    throw new PermanentSettleError(`Lord round account not found on-chain: ${pda}`);\n   462→  }\n   463→  if (!entropyInfo) {\n   464→    throw new TransientSettleError(\"Entropy account not available yet\");\n   465→  }\n   466→\n   467→  // IDL-driven decode — no manual byte offsets or parseLordRound()\n   468→  const roundData: DecodedJackpotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n   469→  const { feeBps, treasury } = platformConfig;\n   470→\n   471→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   472→  const resultHash = deriveResult(\n   473→    secret,\n   474→    entropy,\n   475→    roundPubkey.toBuffer(),\n   476→    roundData.algorithmVer,\n   477→  );\n   478→  const feeAmount = Number((roundData.totalAmountLamports * BigInt(feeBps)) / 10_000n);\n   479→  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n   480→  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n   481→\n   482→  const raw = resultHash.readBigUInt64LE(0);\n   483→  const winningOffset = raw % roundData.totalAmountLamports;\n   484→\n   485→  let cumulative = 0n;\n   486→  let winnerEntryIndex = -1;\n   487→  let winner = roundData.entries[0]?.player;\n   488→  for (const [index, entry] of roundData.entries.entries()) {\n   489→    cumulative += entry.amountLamports;\n   490→    if (winningOffset < cumulative) {\n   491→      winnerEntryIndex = index;\n   492→      winner = entry.player;\n   493→      break;\n   494→    }\n   495→  }\n   496→\n   497→  if (!winner || winnerEntryIndex < 0) {\n   498→    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n   499→  }\n   500→\n   501→  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n   502→  const instruction = new TransactionInstruction({\n   503→    keys: [\n   504→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n   505→      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n   506→      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n   507→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   508→      { pubkey: treasury, isSigner: false, isWritable: true },\n   509→      { pubkey: winner, isSigner: false, isWritable: true },\n   510→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   511→    ],\n   512→    programId: LORDOFRNGS_PROGRAM_ID,\n   513→    data: encodeClaimPayoutData(matchIdBuf, secret),\n   514→  });\n   515→\n   516→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   517→  const tx = new Transaction({\n   518→    feePayer: serverKeypair.publicKey,\n   519→    blockhash,\n   520→    lastValidBlockHeight,\n   521→  });\n   522→  tx.add(instruction);\n   523→  tx.sign(serverKeypair);\n   524→\n   525→  const tBuild = performance.now();\n   526→  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n   527→    skipPreflight: false,\n   528→  });\n   529→  const tSend = performance.now();\n   530→\n   531→  logger.info(\"lord settlement transaction submitted\", {\n   532→    pda,\n   533→    txSignature,\n   534→    attempt: round.settle_attempts + 1,\n   535→    winningEntryIndex: winnerEntryIndex,\n   536→    dbMs: Math.round(tDb - t0),\n   537→    fetchMs: Math.round(tFetch - tDb),\n   538→    buildMs: Math.round(tBuild - tFetch),\n   539→    sendMs: Math.round(tSend - tBuild),\n   540→  });\n   541→\n   542→  const confirmation = await connection.confirmTransaction(\n   543→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   544→    \"confirmed\",\n   545→  );\n   546→  const tConfirm = performance.now();\n   547→  if (confirmation.value.err) {\n   548→    throw new TransientSettleError(\n   549→      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   550→    );\n   551→  }\n   552→\n   553→  const serializedEntries = roundData.entries.map((e) => ({\n   554→    player: e.player.toBase58(),\n   555→    amountLamports: Number(e.amountLamports),\n   556→  }));\n   557→\n   558→  await db.withTransaction(async (txDb) => {\n   559→    await txDb.updateRoundPhase(pda, \"settled\", {\n   560→      settle_tx: txSignature,\n   561→      result_hash: resultHash,\n   562→      result_side: winnerEntryIndex,\n   563→      winner: winner.toBase58(),\n   564→      settle_attempts: round.settle_attempts + 1,\n   565→    });\n   566→\n   567→    // Persist entries in dedicated JSONB column for direct access\n   568→    await txDb.updateRoundEntries(pda, serializedEntries);\n   569→\n   570→    await txDb.insertOperatorEvent(pda, \"settle_confirmed\", {\n   571→      txSignature,\n   572→      winner: winner.toBase58(),\n   573→      winningEntryIndex: winnerEntryIndex,\n   574→      game: \"lord\",\n   575→      entropy: entropy.toString(\"hex\"),\n   576→      winningOffset: winningOffset.toString(),\n   577→      totalAmountLamports: Number(roundData.totalAmountLamports),\n   578→      payoutAmount,\n   579→      feeAmount,\n   580→      rentRefund,\n   581→      entries: serializedEntries,\n   582→    });\n   583→\n   584→    // Write payout transaction for the winner\n   585→    await txDb.insertTransaction({\n   586→      wallet: winner.toBase58(),\n   587→      game: \"lord\",\n   588→      matchId: round.match_id,\n   589→      txType: \"payout\",\n   590→      amountLamports: payoutAmount,\n   591→      txSig: txSignature,\n   592→    });\n   593→\n   594→    // Referral earnings hook — in same transaction for atomicity (System Invariant 4)\n   595→    await recordReferralEarnings(txDb, {\n   596→      roundId: round.match_id,\n   597→      gameType: \"lord\",\n   598→      feeBps,\n   599→      referralDefaultRateBps: deps.referralDefaultRateBps,\n   600→      players: serializedEntries.map((e) => ({\n   601→        wallet: e.player,\n   602→        wagerLamports: e.amountLamports,\n   603→      })),\n   604→    });\n   605→  });\n   606→\n   607→  const tDone = performance.now();\n   608→  logger.info(\"lord settlement transaction confirmed\", {\n   609→    pda,\n   610→    txSignature,\n   611→    winner: winner.toBase58(),\n   612→    winningEntryIndex: winnerEntryIndex,\n   613→    timing: {\n   614→      dbMs: Math.round(tDb - t0),\n   615→      fetchMs: Math.round(tFetch - tDb),\n   616→      buildMs: Math.round(tBuild - tFetch),\n   617→      sendMs: Math.round(tSend - tBuild),\n   618→      confirmMs: Math.round(tConfirm - tSend),\n   619→      dbWriteMs: Math.round(tDone - tConfirm),\n   620→      totalMs: Math.round(tDone - t0),\n   621→    },\n   622→  });\n   623→\n   624→  return {\n   625→    txSignature,\n   626→    resultHash,\n   627→    winningEntryIndex: winnerEntryIndex,\n   628→    winner: winner.toBase58(),\n   629→  };\n   630→}\n   631→\n   632→export async function settleRound(\n   633→  deps: SettleTxDeps,\n   634→  pda: string,\n   635→): Promise<SettleResult> {\n   636→  const round = await deps.db.getRoundByPda(pda);\n   637→  if (!round) {\n   638→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   639→  }\n   640→\n   641→  if (round.game === \"lord\") {\n   642→    return settleLordRound(deps, pda);\n   643→  }\n   644→\n   645→  return settleMatch(deps, pda);\n   646→}\n   647→\n   648→// ---------------------------------------------------------------------------\n   649→// Close Call — transaction builders\n   650→// ---------------------------------------------------------------------------\n   651→\n   652→function deriveCloseCallConfigPda(): [PublicKey, number] {\n   653→  return PublicKey.findProgramAddressSync(\n   654→    [Buffer.from(\"closecall_config\")],\n   655→    CLOSECALL_PROGRAM_ID,\n   656→  );\n   657→}\n   658→\n   659→\n   660→function minuteTsToBuffer(ts: bigint): Buffer {\n   661→  const buf = Buffer.alloc(8);\n   662→  buf.writeBigInt64LE(ts);\n   663→  return buf;\n   664→}\n   665→\n   666→function deriveCloseCallRoundPda(minuteTs: bigint): [PublicKey, number] {\n   667→  return PublicKey.findProgramAddressSync(\n   668→    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n   669→    CLOSECALL_PROGRAM_ID,\n   670→  );\n   671→}\n   672→\n   673→/** Encode closecall instruction data: discriminator(8) + minute_ts(i64 LE, 8) = 16 bytes */\n   674→function encodeCcMinuteTsData(discriminator: Buffer, minuteTs: bigint): Buffer {\n   675→  const buf = Buffer.alloc(16);\n   676→  discriminator.copy(buf, 0);\n   677→  buf.writeBigInt64LE(minuteTs, 8);\n   678→  return buf;\n   679→}\n   680→\n   681→/** Encode closecall settle_round data: disc(8) + minute_ts(i64 LE, 8) + close_price(i64 LE, 8) + close_price_expo(i32 LE, 4) = 28 bytes */\n   682→function encodeCcSettleData(discriminator: Buffer, minuteTs: bigint, price: bigint, expo: number): Buffer {\n   683→  const buf = Buffer.alloc(28);\n   684→  discriminator.copy(buf, 0);\n   685→  buf.writeBigInt64LE(minuteTs, 8);\n   686→  buf.writeBigInt64LE(price, 16);\n   687→  buf.writeInt32LE(expo, 24);\n   688→  return buf;\n   689→}\n   690→\n   691→/**\n   692→ * Encode closecall bet data:\n   693→ * disc(8) + minute_ts(i64 LE, 8) + side(1) + amount(u64 LE, 8) + open_price(i64 LE, 8) + open_price_expo(i32 LE, 4) = 37 bytes\n   694→ */\n   695→function encodeCcBetData(\n   696→  discriminator: Buffer,\n   697→  minuteTs: bigint,\n   698→  side: number,\n   699→  amount: bigint,\n   700→  openPrice: bigint,\n   701→  openPriceExpo: number,\n   702→): Buffer {\n   703→  const buf = Buffer.alloc(37);\n   704→  discriminator.copy(buf, 0);\n   705→  buf.writeBigInt64LE(minuteTs, 8);\n   706→  buf.writeUInt8(side, 16);\n   707→  buf.writeBigUInt64LE(amount, 17);\n   708→  buf.writeBigInt64LE(openPrice, 25);\n   709→  buf.writeInt32LE(openPriceExpo, 33);\n   710→  return buf;\n   711→}\n   712→\n   713→export interface CloseCallTxDeps {\n   714→  connection: Connection;\n   715→  serverKeypair: Keypair;\n   716→}\n   717→\n   718→/**\n   719→ * Build a `bet` instruction (no transaction wrapping).\n   720→ *\n   721→ * Two signers: player (pays bet) + server (pays rent on first call).\n   722→ * Price + bet info passed as instruction args.\n   723→ * Uses init_if_needed — works for both round creation and joining.\n   724→ */\n   725→export function buildCloseCallBetIx(\n   726→  serverPubkey: PublicKey,\n   727→  playerPubkey: PublicKey,\n   728→  minuteTs: bigint,\n   729→  side: number,\n   730→  amountLamports: bigint,\n   731→  openPrice: bigint,\n   732→  openPriceExpo: number,\n   733→): TransactionInstruction {\n   734→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   735→  const [configPda] = deriveCloseCallConfigPda();\n   736→  const data = encodeCcBetData(\n   737→    CC_BET_DISCRIMINATOR,\n   738→    minuteTs,\n   739→    side,\n   740→    amountLamports,\n   741→    openPrice,\n   742→    openPriceExpo,\n   743→  );\n   744→\n   745→  return new TransactionInstruction({\n   746→    keys: [\n   747→      { pubkey: playerPubkey, isSigner: true, isWritable: true },  // player (pays bet)\n   748→      { pubkey: serverPubkey, isSigner: true, isWritable: true },  // server (pays rent on first call)\n   749→      { pubkey: configPda, isSigner: false, isWritable: false },   // config\n   750→      { pubkey: roundPda, isSigner: false, isWritable: true },     // round\n   751→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   752→    ],\n   753→    programId: CLOSECALL_PROGRAM_ID,\n   754→    data,\n   755→  });\n   756→}\n   757→\n   758→/**\n   759→ * Build a `settle_round` instruction (no transaction wrapping).\n   760→ * Price is passed as instruction args (no on-chain Pyth account).\n   761→ */\n   762→export function buildCloseCallSettleRoundIx(\n   763→  serverPubkey: PublicKey,\n   764→  minuteTs: bigint,\n   765→  closePrice: bigint,\n   766→  closePriceExpo: number,\n   767→  treasury: PublicKey,\n   768→  winnerAccounts: PublicKey[],\n   769→): TransactionInstruction {\n   770→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   771→  const [platformConfigPda] = derivePlatformConfigPda();\n   772→  const data = encodeCcSettleData(CC_SETTLE_ROUND_DISCRIMINATOR, minuteTs, closePrice, closePriceExpo);\n   773→\n   774→  return new TransactionInstruction({\n   775→    keys: [\n   776→      { pubkey: serverPubkey, isSigner: true, isWritable: true },\n   777→      { pubkey: roundPda, isSigner: false, isWritable: true },\n   778→      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n   779→      { pubkey: treasury, isSigner: false, isWritable: true },\n   780→      { pubkey: serverPubkey, isSigner: false, isWritable: true },\n   781→      ...winnerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n   782→    ],\n   783→    programId: CLOSECALL_PROGRAM_ID,\n   784→    data,\n   785→  });\n   786→}\n   787→\n   788→/**\n   789→ * Build a partially-signed `bet` transaction for the Close Call program.\n   790→ *\n   791→ * Two signers: player (pays bet) + server (pays rent on first call via init_if_needed).\n   792→ * Server signs immediately; the frontend must add the player signature before submitting.\n   793→ * Works for both round creation (first bet) and joining (subsequent bets).\n   794→ */\n   795→export async function buildCloseCallBetTx(\n   796→  deps: CloseCallTxDeps,\n   797→  playerPubkey: PublicKey,\n   798→  minuteTs: bigint,\n   799→  side: number,\n   800→  amountLamports: bigint,\n   801→  openPrice: bigint,\n   802→  openPriceExpo: number,\n   803→): Promise<{ tx: Transaction; roundPda: PublicKey }> {\n   804→  const { connection, serverKeypair } = deps;\n   805→\n   806→  const instruction = buildCloseCallBetIx(\n   807→    serverKeypair.publicKey,\n   808→    playerPubkey,\n   809→    minuteTs,\n   810→    side,\n   811→    amountLamports,\n   812→    openPrice,\n   813→    openPriceExpo,\n   814→  );\n   815→\n   816→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   817→\n   818→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   819→  const tx = new Transaction({ feePayer: playerPubkey, blockhash, lastValidBlockHeight });\n   820→  tx.add(instruction);\n   821→  tx.partialSign(serverKeypair);\n   822→\n   823→  return { tx, roundPda };\n   824→}\n   825→\n   826→/**\n   827→ * Build a signed `settle_round` transaction for the Close Call program.\n   828→ *\n   829→ * Price is passed as instruction args. Winners (or all players for refund)\n   830→ * are passed as remaining accounts for auto-payout.\n   831→ */\n   832→export async function buildCloseCallSettleRoundTx(\n   833→  deps: CloseCallTxDeps,\n   834→  minuteTs: bigint,\n   835→  closePrice: bigint,\n   836→  closePriceExpo: number,\n   837→  treasury: PublicKey,\n   838→  winnerAccounts: PublicKey[],\n   839→): Promise<Transaction> {\n   840→  const { connection, serverKeypair } = deps;\n   841→\n   842→  const instruction = buildCloseCallSettleRoundIx(\n   843→    serverKeypair.publicKey,\n   844→    minuteTs,\n   845→    closePrice,\n   846→    closePriceExpo,\n   847→    treasury,\n   848→    winnerAccounts,\n   849→  );\n   850→\n   851→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   852→  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n   853→  tx.add(instruction);\n   854→  tx.sign(serverKeypair);\n   855→\n   856→  return tx;\n   857→}\n   858→\n   859→/**\n   860→ * Build a signed `timeout_refund` transaction for the Close Call program.\n   861→ *\n   862→ * Permissionless after the resolve deadline. Refunds all players their exact\n   863→ * deposit via remaining accounts.\n   864→ */\n   865→export async function buildCloseCallTimeoutRefundTx(\n   866→  deps: CloseCallTxDeps,\n   867→  minuteTs: bigint,\n   868→  playerAccounts: PublicKey[],\n   869→): Promise<Transaction> {\n   870→  const { connection, serverKeypair } = deps;\n   871→\n   872→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   873→  const [configPda] = deriveCloseCallConfigPda();\n   874→  const data = encodeCcMinuteTsData(CC_TIMEOUT_REFUND_DISCRIMINATOR, minuteTs);\n   875→\n   876→  const keys = [\n   877→    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller\n   878→    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round\n   879→    { pubkey: configPda, isSigner: false, isWritable: false },               // closecall_config\n   880→    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)\n   881→    ...playerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n   882→  ];\n   883→\n   884→  const instruction = new TransactionInstruction({\n   885→    keys,\n   886→    programId: CLOSECALL_PROGRAM_ID,\n   887→    data,\n   888→  });\n   889→\n   890→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   891→  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n   892→  tx.add(instruction);\n   893→  tx.sign(serverKeypair);\n   894→\n   895→  return tx;\n   896→}\n   897→\n   898→// ---------------------------------------------------------------------------\n   899→// Error types\n   900→// ---------------------------------------------------------------------------\n   901→\n   902→/** Permanent failure — should not be retried. */\n   903→export class PermanentSettleError extends Error {\n   904→  readonly permanent = true;\n   905→  constructor(message: string) {\n   906→    super(message);\n   907→    this.name = \"PermanentSettleError\";\n   908→  }\n   909→}\n   910→\n   911→/** Transient failure — safe to retry. */\n   912→export class TransientSettleError extends Error {\n   913→  readonly permanent = false;\n   914→  constructor(message: string) {\n   915→    super(message);\n   916→    this.name = \"TransientSettleError\";\n   917→  }\n   918→}\n   919→"}]},"parent_tool_use_id":"toolu_01Uwj6aJcpNBERkrvU3gMqdx","session_id":"666b10e8-ff74-42a6-8a85-f241f06f2d89","uuid":"c172db5a-3558-40b8-ad30-03df5dbb88a7","timestamp":"2026-03-25T12:42:29.430Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NbYFGSq5KdJtKxMi1PWk34","type":"tool_result","content":"     1→import { Hono } from \"hono\";\n     2→import { cors } from \"hono/cors\";\n     3→import { serve } from \"@hono/node-server\";\n     4→import { Connection, PublicKey } from \"@solana/web3.js\";\n     5→import postgres from \"postgres\";\n     6→import { loadConfig } from \"./config.js\";\n     7→import { createDb } from \"./db.js\";\n     8→import { createAuthDb } from \"./auth-db.js\";\n     9→import { createCoinflipRoutes } from \"./routes/create.js\";\n    10→import { createLordRoutes } from \"./routes/lord-create.js\";\n    11→import { createRoundsRoutes } from \"./routes/rounds.js\";\n    12→import { createCloseCallRoutes } from \"./routes/closecall.js\";\n    13→import { createHealthRoutes } from \"./routes/health.js\";\n    14→import { createProfileRoutes } from \"./routes/profile.js\";\n    15→import { createPriceRoutes } from \"./routes/price.js\";\n    16→import { createAuthRoutes } from \"./routes/auth.js\";\n    17→import { createReferralRoutes } from \"./routes/referral.js\";\n    18→import { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n    19→import { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n    20→import { createSettlementWorker } from \"./worker/settlement.js\";\n    21→import { settleRound } from \"./worker/settle-tx.js\";\n    22→import { createRetrySettler } from \"./worker/retry.js\";\n    23→import { createPdaWatcher } from \"./worker/pda-watcher.js\";\n    24→import { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n    25→import { createEventWorker } from \"./queue/index.js\";\n    26→import { logger } from \"./logger.js\";\n    27→\n    28→const config = loadConfig();\n    29→\n    30→// Shared postgres connection for both game DB and auth DB\n    31→const sql = postgres(config.databaseUrl);\n    32→const db = createDb(config.databaseUrl);\n    33→const authDb = createAuthDb(sql);\n    34→\n    35→const connection = new Connection(config.rpcUrl, {\n    36→  commitment: \"confirmed\",\n    37→  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n    38→});\n    39→\n    40→const app = new Hono();\n    41→\n    42→app.use(\n    43→  \"*\",\n    44→  cors({\n    45→    origin: \"*\",\n    46→    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n    47→    allowHeaders: [\"Content-Type\", \"Authorization\"],\n    48→  }),\n    49→);\n    50→\n    51→// Request logging — correlate frontend fetch timing with server-side processing\n    52→app.use(\"*\", async (c, next) => {\n    53→  const start = Date.now();\n    54→  await next();\n    55→  const ms = Date.now() - start;\n    56→  const method = c.req.method;\n    57→  const path = c.req.path;\n    58→  // Skip noisy health checks and OPTIONS preflight\n    59→  if (path === \"/health\" || method === \"OPTIONS\") return;\n    60→  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n    61→});\n    62→\n    63→// Auth routes — no JWT middleware (these are the login endpoints)\n    64→// Lighter rate limiting by IP for auth endpoints\n    65→app.use(\n    66→  \"/auth/*\",\n    67→  createRateLimitMiddleware({\n    68→    perWallet: 20,\n    69→    global: config.rateLimitGlobal,\n    70→    windowMs: 60_000,\n    71→  }),\n    72→);\n    73→\n    74→app.route(\n    75→  \"/auth\",\n    76→  createAuthRoutes({\n    77→    authDb,\n    78→    jwtSecret: config.jwtSecret,\n    79→    cluster: config.cluster,\n    80→    challengeTtlSeconds: config.challengeTtlSeconds,\n    81→    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    82→    refreshTokenTtlDays: config.refreshTokenTtlDays,\n    83→  }),\n    84→);\n    85→\n    86→// Profile routes — authenticated GET endpoints (require JWT on all methods)\n    87→app.use(\n    88→  \"/profile/*\",\n    89→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n    90→);\n    91→app.route(\"/profile\", createProfileRoutes({ db }));\n    92→\n    93→// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n    94→app.use(\n    95→  \"/referral/*\",\n    96→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n    97→);\n    98→app.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n    99→\n   100→// JWT auth middleware for fairness endpoints\n   101→app.use(\n   102→  \"/fairness/*\",\n   103→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n   104→);\n   105→\n   106→// Rate limiting — per-wallet and global limits on POST requests\n   107→app.use(\n   108→  \"/fairness/*\",\n   109→  createRateLimitMiddleware({\n   110→    perWallet: config.rateLimitPerWallet,\n   111→    global: config.rateLimitGlobal,\n   112→    windowMs: 60_000,\n   113→  }),\n   114→);\n   115→\n   116→// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n   117→const entropyAccount = new PublicKey(config.entropyAccount);\n   118→const retrySettler = createRetrySettler({\n   119→  db,\n   120→  connection,\n   121→  settleRound: (pda) =>\n   122→    settleRound(\n   123→      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n   124→      pda,\n   125→    ),\n   126→});\n   127→\n   128→// PDA watcher — WebSocket-based instant join detection\n   129→const pdaWatcher = createPdaWatcher({\n   130→  connection,\n   131→  serverKey: config.serverKeypair.publicKey,\n   132→  db,\n   133→  onJoinDetected: async (pda, targetSlot) => {\n   134→    // Update DB phase if still in 'created'\n   135→    const round = await db.getRoundByPda(pda);\n   136→    if (round && round.phase === \"created\") {\n   137→      await db.updateRoundPhase(pda, \"locked\", {\n   138→        target_slot: targetSlot.toString(),\n   139→      });\n   140→      await db.insertOperatorEvent(pda, \"match_detected\", {\n   141→        targetSlot: targetSlot.toString(),\n   142→        source: \"pda-watcher\",\n   143→        game: round.game,\n   144→      });\n   145→    }\n   146→\n   147→    // Check if target slot already passed — settle immediately if so\n   148→    const currentSlot = await connection.getSlot();\n   149→    if (BigInt(currentSlot) >= targetSlot) {\n   150→      await retrySettler.attemptSettle(pda);\n   151→      pdaWatcher.unwatch(pda);\n   152→    }\n   153→    // If target slot not reached yet, poll worker will pick it up next cycle\n   154→  },\n   155→});\n   156→\n   157→const worker = createSettlementWorker({\n   158→  db,\n   159→  connection,\n   160→  serverKey: config.serverKeypair.publicKey,\n   161→  pollIntervalMs: config.workerPollIntervalMs,\n   162→  onSettleReady: async (pda) => {\n   163→    await retrySettler.attemptSettle(pda);\n   164→    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n   165→  },\n   166→  isFinalized: (pda) => retrySettler.isFinalized(pda),\n   167→});\n   168→worker.start();\n   169→\n   170→// Close Call clock worker — fetches boundary prices + settles open rounds\n   171→// Rounds are created on-demand by players via /closecall/bet\n   172→const closeCallClock = createCloseCallClockWorker({\n   173→  connection,\n   174→  serverKeypair: config.serverKeypair,\n   175→  db: sql,\n   176→});\n   177→closeCallClock.start();\n   178→\n   179→// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n   180→const eventWorker = createEventWorker(sql, {\n   181→  pollIntervalMs: config.eventQueuePollMs,\n   182→});\n   183→eventWorker.start();\n   184→logger.info(\"Event queue worker started\", {\n   185→  pollIntervalMs: config.eventQueuePollMs,\n   186→});\n   187→\n   188→// Coinflip fairness routes\n   189→app.route(\n   190→  \"/fairness/coinflip\",\n   191→  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n   192→);\n   193→app.route(\n   194→  \"/fairness/lord\",\n   195→  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n   196→);\n   197→\n   198→// Close Call routes (create-round co-signing + candle history + read queries)\n   199→app.route(\"/closecall\", createCloseCallRoutes({\n   200→  db,\n   201→  connection,\n   202→  serverKeypair: config.serverKeypair,\n   203→  clockWorker: closeCallClock,\n   204→  sql,\n   205→}));\n   206→\n   207→// Price routes — public, no auth\n   208→app.route(\"/price\", createPriceRoutes());\n   209→\n   210→// Round verification routes\n   211→app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n   212→\n   213→// Health endpoint — wired after worker exists so we can query its status\n   214→app.route(\n   215→  \"/health\",\n   216→  createHealthRoutes({\n   217→    db,\n   218→    sql,\n   219→    connection,\n   220→    serverKey: config.serverKeypair.publicKey,\n   221→    isWorkerRunning: () => worker.isRunning,\n   222→    minSolBalance: config.minSolBalance,\n   223→  }),\n   224→);\n   225→\n   226→const port = config.port;\n   227→logger.info(\"fairness-backend started\", { port });\n   228→\n   229→serve({\n   230→  fetch: app.fetch,\n   231→  port,\n   232→});\n   233→\n   234→export default {\n   235→  port,\n   236→  fetch: app.fetch,\n   237→};\n   238→"}]},"parent_tool_use_id":"toolu_01Uwj6aJcpNBERkrvU3gMqdx","session_id":"666b10e8-ff74-42a6-8a85-f241f06f2d89","uuid":"06f11599-fdbc-4916-a67f-a2c1c7609722","timestamp":"2026-03-25T12:42:29.382Z"}
