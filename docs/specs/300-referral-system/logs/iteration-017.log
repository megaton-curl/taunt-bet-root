{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NF2tmnTuXziL3XKhcsgHnW","type":"tool_result","content":"     1→-- 010_event_queue.sql — Postgres-backed async event queue.\n     2→--\n     3→-- Decouples settlement hot path from secondary side-effects (reward delivery,\n     4→-- notifications, analytics). Events are committed atomically with their\n     5→-- triggering operation. Worker polls with SKIP LOCKED for safe concurrency.\n     6→\n     7→CREATE TABLE IF NOT EXISTS event_queue (\n     8→  id              BIGSERIAL    PRIMARY KEY,\n     9→  event_type      TEXT         NOT NULL,\n    10→  payload         JSONB        NOT NULL,\n    11→  status          TEXT         NOT NULL DEFAULT 'pending',\n    12→  attempts        INTEGER      NOT NULL DEFAULT 0,\n    13→  max_attempts    INTEGER      NOT NULL DEFAULT 3,\n    14→  scheduled_at    TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    15→  started_at      TIMESTAMPTZ,\n    16→  completed_at    TIMESTAMPTZ,\n    17→  error           TEXT,\n    18→  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    19→\n    20→  CONSTRAINT chk_event_queue_status\n    21→    CHECK (status IN ('pending', 'processing', 'completed', 'failed', 'dead'))\n    22→);\n    23→\n    24→-- Partial index for worker polling — only scans pending events\n    25→CREATE INDEX IF NOT EXISTS idx_event_queue_poll\n    26→  ON event_queue (scheduled_at)\n    27→  WHERE status = 'pending';\n    28→\n    29→-- Index for observability queries (dead events, recent failures)\n    30→CREATE INDEX IF NOT EXISTS idx_event_queue_status\n    31→  ON event_queue (status, created_at);\n    32→"}]},"parent_tool_use_id":"toolu_01SudYo6eB5Lw6yTao4p7t2j","session_id":"666b10e8-ff74-42a6-8a85-f241f06f2d89","uuid":"e8a5a97b-b773-4cd0-8d68-3e9f5cbad250","timestamp":"2026-03-25T12:41:00.775Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BZCdYzDbXFm9hxRAjBD3bW","type":"tool_result","content":"     1→-- 011_referral.sql — Referral system tables (spec 300).\n     2→--\n     3→-- Off-chain referral economics: player-chosen codes, referral linking,\n     4→-- per-game earnings tracking, claim payouts, and KOL custom rates.\n     5→-- No on-chain program changes — all tables are backend-only.\n     6→\n     7→-- Referral codes: one active code per wallet\n     8→CREATE TABLE IF NOT EXISTS referral_codes (\n     9→  id              SERIAL       PRIMARY KEY,\n    10→  wallet          TEXT         NOT NULL UNIQUE,\n    11→  code            TEXT         NOT NULL UNIQUE,  -- player-chosen, 3-16 chars [a-z0-9-]\n    12→  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    13→  updated_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n    14→);\n    15→\n    16→-- Referral links: immutable referrer→referee binding (one referrer per player)\n    17→CREATE TABLE IF NOT EXISTS referral_links (\n    18→  id              SERIAL       PRIMARY KEY,\n    19→  referrer_wallet TEXT         NOT NULL,\n    20→  referee_wallet  TEXT         NOT NULL UNIQUE,\n    21→  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n    22→);\n    23→\n    24→CREATE INDEX IF NOT EXISTS idx_referral_links_referrer\n    25→  ON referral_links (referrer_wallet);\n    26→\n    27→-- Referral earnings: one row per referee per round (idempotency guard)\n    28→CREATE TABLE IF NOT EXISTS referral_earnings (\n    29→  id                        SERIAL       PRIMARY KEY,\n    30→  referrer_wallet           TEXT         NOT NULL,\n    31→  referee_wallet            TEXT         NOT NULL,\n    32→  round_id                  TEXT         NOT NULL,\n    33→  game_type                 TEXT         NOT NULL,\n    34→  wager_lamports            BIGINT       NOT NULL,\n    35→  fee_lamports              BIGINT       NOT NULL,\n    36→  referrer_earned_lamports  BIGINT       NOT NULL,\n    37→  referrer_rate_bps         INTEGER      NOT NULL,\n    38→  referee_rebate_lamports   BIGINT       NOT NULL,\n    39→  referee_rebate_rate_bps   INTEGER      NOT NULL,\n    40→  created_at                TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    41→\n    42→  CONSTRAINT uq_referral_earnings_referee_round\n    43→    UNIQUE (referee_wallet, round_id)\n    44→);\n    45→\n    46→CREATE INDEX IF NOT EXISTS idx_referral_earnings_referrer\n    47→  ON referral_earnings (referrer_wallet, created_at);\n    48→\n    49→CREATE INDEX IF NOT EXISTS idx_referral_earnings_referee\n    50→  ON referral_earnings (referee_wallet, created_at);\n    51→\n    52→CREATE INDEX IF NOT EXISTS idx_referral_earnings_round_id\n    53→  ON referral_earnings (round_id);\n    54→\n    55→-- Referral claims: async SOL payout tracking\n    56→CREATE TABLE IF NOT EXISTS referral_claims (\n    57→  id              UUID         PRIMARY KEY DEFAULT gen_random_uuid(),\n    58→  wallet          TEXT         NOT NULL,\n    59→  amount_lamports BIGINT       NOT NULL,\n    60→  status          TEXT         NOT NULL DEFAULT 'pending',\n    61→  tx_signature    TEXT,\n    62→  error           TEXT,\n    63→  requested_at    TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    64→  processed_at    TIMESTAMPTZ,\n    65→\n    66→  CONSTRAINT chk_referral_claims_status\n    67→    CHECK (status IN ('pending', 'processing', 'completed', 'failed'))\n    68→);\n    69→\n    70→CREATE INDEX IF NOT EXISTS idx_referral_claims_wallet\n    71→  ON referral_claims (wallet, requested_at);\n    72→\n    73→CREATE INDEX IF NOT EXISTS idx_referral_claims_status\n    74→  ON referral_claims (status)\n    75→  WHERE status IN ('pending', 'processing');\n    76→\n    77→-- KOL custom referrer rates (overrides default 1000 bps)\n    78→CREATE TABLE IF NOT EXISTS referral_kol_rates (\n    79→  wallet          TEXT         PRIMARY KEY,\n    80→  rate_bps        INTEGER      NOT NULL,\n    81→  set_by          TEXT         NOT NULL,\n    82→  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    83→  updated_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n    84→);\n    85→"}]},"parent_tool_use_id":"toolu_01SudYo6eB5Lw6yTao4p7t2j","session_id":"666b10e8-ff74-42a6-8a85-f241f06f2d89","uuid":"bbfcb15b-14a2-41e0-8afe-5692c92e7b24","timestamp":"2026-03-25T12:41:00.799Z"}
