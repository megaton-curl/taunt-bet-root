n    49→        claimId,\n    50→      });\n    51→      return;\n    52→    }\n    53→\n    54→    if (claim.status === \"failed\") {\n    55→      logger.info(\"referral claim handler: already failed, skipping\", {"}]},"parent_tool_use_id":null,"session_id":"8cdd94d4-4d50-4151-8136-428429db5806","uuid":"66bba692-a0ac-40b9-b7de-37c856540799","timestamp":"2026-03-25T15:30:30.326Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/queue/handlers/referral-claim.ts","content":"/**\n * Handler for `referral.claim_requested` events.\n *\n * Flow: load claim → verify pending → update to processing → re-verify balance\n * → SOL transfer from server keypair → record tx_signature → completed.\n *\n * Idempotent: skips if claim is already completed or failed.\n */\n\nimport {\n  Connection,\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n} from \"@solana/web3.js\";\nimport type { Db } from \"../../db.js\";\nimport { logger } from \"../../logger.js\";\n\nexport interface ClaimHandlerDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n}\n\nexport function createClaimHandler(deps: ClaimHandlerDeps) {\n  const { db, connection, serverKeypair } = deps;\n\n  return async (payload: Record<string, unknown>): Promise<void> => {\n    const claimId = payload.claimId as string;\n    const wallet = payload.wallet as string;\n    const amountLamports = payload.amountLamports as string;\n\n    if (!claimId || !wallet || !amountLamports) {\n      throw new Error(\n        `referral.claim_requested: malformed payload — missing claimId, wallet, or amountLamports`,\n      );\n    }\n\n    // 1. Load claim and check idempotency\n    const claim = await db.getReferralClaim(claimId);\n    if (!claim) {\n      logger.warn(\"referral claim handler: claim not found\", { claimId });\n      return; // no-op — event may reference a deleted/invalid claim\n    }\n\n    if (claim.status === \"completed\") {\n      logger.info(\"referral claim handler: already completed, skipping\", {\n        claimId,\n      });\n      return;\n    }\n\n    if (claim.status === \"failed\") {\n      logger.info(\"referral claim handler: already failed, skipping\", {","numLines":55,"startLine":1,"totalLines":146}}}
