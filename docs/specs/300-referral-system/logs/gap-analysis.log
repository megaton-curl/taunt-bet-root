{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vetu5ZYnYQcRyn42dhdkWj","type":"tool_result","content":"     1→/**\n     2→ * ProfileSettings - Settings tab content\n     3→ *\n     4→ * Shows connected wallet, referral code input, and social connections.\n     5→ * Avatar selection is handled via modal from the profile header.\n     6→ * Username editing is handled inline in the profile header.\n     7→ */\n     8→\n     9→import { useState, useEffect } from \"react\";\n    10→import type { PlayerProfile } from \"../types\";\n    11→import { usePlayerProfile } from \"../context/PlayerProfileContext\";\n    12→import { truncateAddress } from \"../utils/mock-simulation\";\n    13→import { useSession } from \"../../../context/SessionContext\";\n    14→import { getReferrer, applyReferralCode } from \"../../../lib/referral-api\";\n    15→\n    16→interface ProfileSettingsProps {\n    17→  profile: PlayerProfile;\n    18→}\n    19→\n    20→export function ProfileSettings({ profile }: ProfileSettingsProps) {\n    21→  const {\n    22→    connectDiscord,\n    23→    disconnectDiscord,\n    24→    connectTwitter,\n    25→    disconnectTwitter,\n    26→  } = usePlayerProfile();\n    27→  const { accessToken } = useSession();\n    28→\n    29→  const [connectingDiscord, setConnectingDiscord] = useState(false);\n    30→  const [connectingTwitter, setConnectingTwitter] = useState(false);\n    31→\n    32→  // Referral code section state\n    33→  const [referrerWallet, setReferrerWallet] = useState<string | null>(null);\n    34→  const [referrerLoading, setReferrerLoading] = useState(true);\n    35→  const [referralCode, setReferralCode] = useState(\"\");\n    36→  const [referralApplying, setReferralApplying] = useState(false);\n    37→  const [referralError, setReferralError] = useState<string | null>(null);\n    38→  const [referralSuccess, setReferralSuccess] = useState(false);\n    39→\n    40→  // Fetch referrer status on mount\n    41→  useEffect(() => {\n    42→    if (!accessToken) {\n    43→      setReferrerLoading(false);\n    44→      return;\n    45→    }\n    46→    let cancelled = false;\n    47→    getReferrer(accessToken)\n    48→      .then((data) => {\n    49→        if (!cancelled) setReferrerWallet(data.referrerWallet);\n    50→      })\n    51→      .catch(() => {\n    52→        // 404 = no referrer, which is fine\n    53→        if (!cancelled) setReferrerWallet(null);\n    54→      })\n    55→      .finally(() => {\n    56→        if (!cancelled) setReferrerLoading(false);\n    57→      });\n    58→    return () => { cancelled = true; };\n    59→  }, [accessToken]);\n    60→\n    61→  const handleApplyReferral = async () => {\n    62→    if (!accessToken) return;\n    63→    const code = referralCode.toLowerCase().trim();\n    64→    if (!code) {\n    65→      setReferralError(\"Please enter a referral code\");\n    66→      return;\n    67→    }\n    68→    setReferralError(null);\n    69→    setReferralApplying(true);\n    70→    try {\n    71→      const result = await applyReferralCode(accessToken, code);\n    72→      setReferrerWallet(result.referrer);\n    73→      setReferralSuccess(true);\n    74→      setReferralCode(\"\");\n    75→    } catch (err) {\n    76→      const msg = err instanceof Error ? err.message : \"Failed to apply referral code\";\n    77→      if (msg.includes(\"Cannot refer yourself\") || msg.includes(\"SELF_REFERRAL\")) {\n    78→        setReferralError(\"You cannot use your own referral code\");\n    79→      } else if (msg.includes(\"already linked\") || msg.includes(\"ALREADY_LINKED\")) {\n    80→        setReferralError(\"You are already linked to a referrer\");\n    81→      } else if (msg.includes(\"not found\") || msg.includes(\"NOT_FOUND\") || msg.includes(\"does not exist\")) {\n    82→        setReferralError(\"Referral code not found\");\n    83→      } else {\n    84→        setReferralError(msg);\n    85→      }\n    86→    } finally {\n    87→      setReferralApplying(false);\n    88→    }\n    89→  };\n    90→\n    91→  const handleConnectDiscord = async () => {\n    92→    setConnectingDiscord(true);\n    93→    try {\n    94→      await connectDiscord();\n    95→    } catch (error) {\n    96→      console.error(\"Failed to connect Discord:\", error);\n    97→    } finally {\n    98→      setConnectingDiscord(false);\n    99→    }\n   100→  };\n   101→\n   102→  const handleDisconnectDiscord = async () => {\n   103→    setConnectingDiscord(true);\n   104→    try {\n   105→      await disconnectDiscord();\n   106→    } catch (error) {\n   107→      console.error(\"Failed to disconnect Discord:\", error);\n   108→    } finally {\n   109→      setConnectingDiscord(false);\n   110→    }\n   111→  };\n   112→\n   113→  const handleConnectTwitter = async () => {\n   114→    setConnectingTwitter(true);\n   115→    try {\n   116→      await connectTwitter();\n   117→    } catch (error) {\n   118→      console.error(\"Failed to connect Twitter:\", error);\n   119→    } finally {\n   120→      setConnectingTwitter(false);\n   121→    }\n   122→  };\n   123→\n   124→  const handleDisconnectTwitter = async () => {\n   125→    setConnectingTwitter(true);\n   126→    try {\n   127→      await disconnectTwitter();\n   128→    } catch (error) {\n   129→      console.error(\"Failed to disconnect Twitter:\", error);\n   130→    } finally {\n   131→      setConnectingTwitter(false);\n   132→    }\n   133→  };\n   134→\n   135→  return (\n   136→    <div className=\"profile-settings\">\n   137→      {/* Connected Wallet */}\n   138→      <div className=\"profile-settings__section\">\n   139→        <h3 className=\"profile-settings__section-title\">Connected Wallet</h3>\n   140→        <div className=\"profile-settings__wallet\">\n   141→          <div className=\"profile-settings__wallet-icon\">\n   142→            <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n   143→              <path d=\"M21 18v1c0 1.1-.9 2-2 2H5c-1.11 0-2-.9-2-2V5c0-1.1.89-2 2-2h14c1.1 0 2 .9 2 2v1h-9c-1.11 0-2 .9-2 2v8c0 1.1.89 2 2 2h9zm-9-2h10V8H12v8zm4-2.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z\"/>\n   144→            </svg>\n   145→          </div>\n   146→          <div className=\"profile-settings__wallet-info\">\n   147→            <div className=\"profile-settings__wallet-address\">{truncateAddress(profile.address)}</div>\n   148→            <div className=\"profile-settings__wallet-full\" title={profile.address}>\n   149→              {profile.address}\n   150→            </div>\n   151→          </div>\n   152→        </div>\n   153→      </div>\n   154→\n   155→      {/* Referral Code */}\n   156→      <div className=\"profile-settings__section\">\n   157→        <h3 className=\"profile-settings__section-title\">Referral Code</h3>\n   158→        {referrerLoading ? (\n   159→          <div className=\"profile-settings__referral-skeleton\" />\n   160→        ) : referrerWallet ? (\n   161→          <div className=\"profile-settings__referral-linked\">\n   162→            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--color-green)\" strokeWidth=\"2\">\n   163→              <path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\" />\n   164→              <path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\" />\n   165→            </svg>\n   166→            <span>\n   167→              Referred by: <strong title={referrerWallet}>{truncateAddress(referrerWallet)}</strong>\n   168→            </span>\n   169→          </div>\n   170→        ) : referralSuccess ? (\n   171→          <div className=\"profile-settings__referral-success\">\n   172→            Referral code applied! You now receive a 10% fee rebate on all games.\n   173→          </div>\n   174→        ) : (\n   175→          <>\n   176→            <p className=\"profile-settings__referral-hint\">\n   177→              Enter a referral code to receive a 10% fee rebate on all games.\n   178→            </p>\n   179→            <div className=\"profile-settings__input-group\">\n   180→              <input\n   181→                type=\"text\"\n   182→                className=\"profile-settings__input\"\n   183→                placeholder=\"Enter referral code\"\n   184→                value={referralCode}\n   185→                onChange={(e) => {\n   186→                  setReferralCode(e.target.value);\n   187→                  setReferralError(null);\n   188→                }}\n   189→                onKeyDown={(e) => { if (e.key === \"Enter\") handleApplyReferral(); }}\n   190→                disabled={referralApplying}\n   191→                maxLength={16}\n   192→              />\n   193→              <button\n   194→                type=\"button\"\n   195→                className=\"profile-settings__save-btn\"\n   196→                onClick={handleApplyReferral}\n   197→                disabled={referralApplying || !referralCode.trim()}\n   198→              >\n   199→                {referralApplying ? \"Applying...\" : \"Apply\"}\n   200→              </button>\n   201→            </div>\n   202→            {referralError && (\n   203→              <div className=\"profile-settings__referral-error\">{referralError}</div>\n   204→            )}\n   205→          </>\n   206→        )}\n   207→      </div>\n   208→\n   209→      {/* Social Connections */}\n   210→      <div className=\"profile-settings__section\">\n   211→        <h3 className=\"profile-settings__section-title\">Connected Socials</h3>\n   212→        <div className=\"profile-socials__list\">\n   213→          {/* Discord */}\n   214→          <div className=\"profile-socials__item\">\n   215→            <div className=\"profile-socials__icon\">\n   216→              <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n   217→                <path d=\"M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z\"/>\n   218→              </svg>\n   219→            </div>\n   220→            <div className=\"profile-socials__info\">\n   221→              <div className=\"profile-socials__name\">Discord</div>\n   222→              {profile.discordUsername && (\n   223→                <div className=\"profile-socials__username\">{profile.discordUsername}</div>\n   224→              )}\n   225→            </div>\n   226→            {profile.discordUsername ? (\n   227→              <button\n   228→                type=\"button\"\n   229→                className=\"profile-socials__btn profile-socials__btn--disconnect\"\n   230→                onClick={handleDisconnectDiscord}\n   231→                disabled={connectingDiscord}\n   232→              >\n   233→                {connectingDiscord ? \"...\" : \"Disconnect\"}\n   234→              </button>\n   235→            ) : (\n   236→              <button\n   237→                type=\"button\"\n   238→                className=\"profile-socials__btn profile-socials__btn--connect\"\n   239→                onClick={handleConnectDiscord}\n   240→                disabled={connectingDiscord}\n   241→              >\n   242→                {connectingDiscord ? \"...\" : \"Connect\"}\n   243→              </button>\n   244→            )}\n   245→          </div>\n   246→\n   247→          {/* Twitter/X */}\n   248→          <div className=\"profile-socials__item\">\n   249→            <div className=\"profile-socials__icon\">\n   250→              <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n   251→                <path d=\"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z\"/>\n   252→              </svg>\n   253→            </div>\n   254→            <div className=\"profile-socials__info\">\n   255→              <div className=\"profile-socials__name\">X (Twitter)</div>\n   256→              {profile.twitterHandle && (\n   257→                <div className=\"profile-socials__username\">{profile.twitterHandle}</div>\n   258→              )}\n   259→            </div>\n   260→            {profile.twitterHandle ? (\n   261→              <button\n   262→                type=\"button\"\n   263→                className=\"profile-socials__btn profile-socials__btn--disconnect\"\n   264→                onClick={handleDisconnectTwitter}\n   265→                disabled={connectingTwitter}\n   266→              >\n   267→                {connectingTwitter ? \"...\" : \"Disconnect\"}\n   268→              </button>\n   269→            ) : (\n   270→              <button\n   271→                type=\"button\"\n   272→                className=\"profile-socials__btn profile-socials__btn--connect\"\n   273→                onClick={handleConnectTwitter}\n   274→                disabled={connectingTwitter}\n   275→              >\n   276→                {connectingTwitter ? \"...\" : \"Connect\"}\n   277→              </button>\n   278→            )}\n   279→          </div>\n   280→        </div>\n   281→      </div>\n   282→    </div>\n   283→  );\n   284→}\n   285→"}]},"parent_tool_use_id":"toolu_017uqN3x7jw6bV395y2Y8DmC","session_id":"8cdd94d4-4d50-4151-8136-428429db5806","uuid":"2b1d0084-8437-468d-9c7a-f97b57da0d40","timestamp":"2026-03-25T15:27:06.677Z"}
