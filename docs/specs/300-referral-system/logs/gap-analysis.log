{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014mBTeSynpPE5tVnGh8ZdSf","type":"tool_result","content":"   450→  { player: \"anon_8821\", game: \"JACKPOT\", amount: \"+$146.55\", positive: true, taunt: \"the RNG chose me\", color: \"#FF1F8E\" },\n   451→  { player: \"0x3b…81a2\", game: \"CLOSE CALL\", amount: \"+$18.40\", positive: true, taunt: null, color: \"#00E676\" },\n   452→  { player: \"moon_maxi_99\", game: \"CRYPTO CRASH\", amount: \"+$82.10\", positive: true, taunt: \"rekt. bye.\", color: \"#FF2D55\" },\n   453→];\n   454→\n   455→/** Captures referral code from /r/:code URL, stores in localStorage, redirects to / */\n   456→function ReferralCapture() {\n   457→  const { code } = useParams<{ code: string }>();\n   458→  if (code) {\n   459→    try {\n   460→      localStorage.setItem(\"referral_code\", JSON.stringify({ code, capturedAt: new Date().toISOString() }));\n   461→    } catch {\n   462→      // localStorage may be unavailable (private browsing, storage full) — proceed with redirect\n   463→    }\n   464→  }\n   465→  return <Navigate to=\"/\" replace />;\n   466→}\n   467→\n   468→function HomePage() {\n   469→  return (\n   470→    <>\n   471→      {/* Page header */}\n   472→      <div className=\"page-hd\">\n   473→        <div>\n   474→          <div className=\"pg-title\">The <span className=\"pk\">Pit.</span></div>\n   475→          <div className=\"pg-sub\">Five ways to ruin someone's day</div>\n   476→        </div>\n   477→        <div className=\"pg-tags\">\n   478→          <div className=\"ptag on\">Floor Open · 24/7</div>\n   479→          <div className=\"ptag\">5% Flat Fee · Zero House Edge</div>"}]},"parent_tool_use_id":"toolu_017uqN3x7jw6bV395y2Y8DmC","session_id":"8cdd94d4-4d50-4151-8136-428429db5806","uuid":"a8764ed8-2639-4fed-9560-0c88d2aa4090","timestamp":"2026-03-25T15:27:06.717Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RWV2ZP15RzJwHWP4B4oH1t","type":"tool_result","content":"294:    // Ensure referral + event_queue tables exist (idempotent)\n299:      new URL(\"../../migrations/011_referral.sql\", import.meta.url).pathname,\n310:    await rawSql`TRUNCATE rounds, operator_events, referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates RESTART IDENTITY CASCADE`;\n457:            referralDefaultRateBps: 1000,\n605:  it(\"settlement records referral earnings for referred player\", async () => {\n612:    // Set up referral link: referrer → opponent (opponent is the referee)\n675:            referralDefaultRateBps: 1000,\n700:    // 5. Verify referral earnings recorded for the opponent (the referee)\n705:      await rawSql`SELECT * FROM referral_earnings WHERE referee_wallet = ${opponentWallet}`;\n722:      await rawSql`SELECT * FROM referral_earnings WHERE referee_wallet = ${creatorWallet}`;\n733:    // Set up referral link + KOL rate override\n736:    await rawSql`INSERT INTO referral_kol_rates (wallet, rate_bps, set_by) VALUES (${referrerWallet}, 2000, 'admin')`;\n793:            referralDefaultRateBps: 1000,\n822:      await rawSql`SELECT * FROM referral_earnings WHERE referee_wallet = ${opponentWallet}`;","is_error":false}]},"parent_tool_use_id":"toolu_01UouSjWLoexuEH21J3HZK7R","session_id":"8cdd94d4-4d50-4151-8136-428429db5806","uuid":"e1ae4854-9027-468b-adf8-794812473985","timestamp":"2026-03-25T15:27:07.457Z"}
