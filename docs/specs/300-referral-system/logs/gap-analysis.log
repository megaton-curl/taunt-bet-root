{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WeNoHuq89WWTWvNGG57LWB","type":"tool_result","content":"     1→import { useEffect, useRef } from \"react\";\n     2→import { useSession } from \"../../../context/SessionContext\";\n     3→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n     4→import { applyReferralCode } from \"../../../lib/referral-api\";\n     5→\n     6→const STORAGE_KEY = \"referral_code\";\n     7→\n     8→/**\n     9→ * On authentication, if a referral code is stored in localStorage (from /r/:code),\n    10→ * auto-apply it via POST /referral/apply. Clears storage on success or permanent\n    11→ * failure (invalid code, already linked, self-referral). Keeps on transient failure\n    12→ * (network error) so it retries next auth.\n    13→ */\n    14→export function useReferralApply() {\n    15→  const { isAuthenticated, accessToken } = useSession();\n    16→  const { address } = useWallet();\n    17→  const appliedRef = useRef(false);\n    18→\n    19→  useEffect(() => {\n    20→    if (!isAuthenticated || !accessToken || !address) {\n    21→      appliedRef.current = false;\n    22→      return;\n    23→    }\n    24→\n    25→    // Prevent duplicate calls within the same auth session\n    26→    if (appliedRef.current) return;\n    27→\n    28→    let stored: string | null = null;\n    29→    try {\n    30→      stored = localStorage.getItem(STORAGE_KEY);\n    31→    } catch {\n    32→      // localStorage unavailable\n    33→      return;\n    34→    }\n    35→\n    36→    if (!stored) return;\n    37→\n    38→    let code: string;\n    39→    try {\n    40→      const parsed = JSON.parse(stored);\n    41→      code = parsed?.code;\n    42→    } catch {\n    43→      // Corrupt data — remove it\n    44→      try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n    45→      return;\n    46→    }\n    47→\n    48→    if (!code || typeof code !== \"string\") {\n    49→      try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n    50→      return;\n    51→    }\n    52→\n    53→    appliedRef.current = true;\n    54→\n    55→    applyReferralCode(accessToken, code)\n    56→      .then(() => {\n    57→        try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n    58→        // TODO: replace with toast notification when toast system is implemented\n    59→        console.warn(\"[referral] Referral code applied successfully\");\n    60→      })\n    61→      .catch((err: Error) => {\n    62→        const msg = err.message ?? \"\";\n    63→        // Permanent failures — code invalid, already linked, self-referral\n    64→        const isPermanent =\n    65→          msg.includes(\"ALREADY_LINKED\") ||\n    66→          msg.includes(\"SELF_REFERRAL\") ||\n    67→          msg.includes(\"NOT_FOUND\") ||\n    68→          msg.includes(\"INVALID\") ||\n    69→          msg.includes(\"already linked\") ||\n    70→          msg.includes(\"not found\") ||\n    71→          msg.includes(\"Cannot refer yourself\");\n    72→\n    73→        if (isPermanent) {\n    74→          try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n    75→        }\n    76→        // Transient failures (network, 500): keep localStorage for retry on next auth\n    77→      });\n    78→  }, [isAuthenticated, accessToken, address]);\n    79→}\n    80→"}]},"parent_tool_use_id":null,"session_id":"8cdd94d4-4d50-4151-8136-428429db5806","uuid":"0fbcf095-41f3-4166-a911-ea8baf7a2d48","timestamp":"2026-03-25T15:28:25.950Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/referral/hooks/useReferralApply.ts","content":"import { useEffect, useRef } from \"react\";\nimport { useSession } from \"../../../context/SessionContext\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\nimport { applyReferralCode } from \"../../../lib/referral-api\";\n\nconst STORAGE_KEY = \"referral_code\";\n\n/**\n * On authentication, if a referral code is stored in localStorage (from /r/:code),\n * auto-apply it via POST /referral/apply. Clears storage on success or permanent\n * failure (invalid code, already linked, self-referral). Keeps on transient failure\n * (network error) so it retries next auth.\n */\nexport function useReferralApply() {\n  const { isAuthenticated, accessToken } = useSession();\n  const { address } = useWallet();\n  const appliedRef = useRef(false);\n\n  useEffect(() => {\n    if (!isAuthenticated || !accessToken || !address) {\n      appliedRef.current = false;\n      return;\n    }\n\n    // Prevent duplicate calls within the same auth session\n    if (appliedRef.current) return;\n\n    let stored: string | null = null;\n    try {\n      stored = localStorage.getItem(STORAGE_KEY);\n    } catch {\n      // localStorage unavailable\n      return;\n    }\n\n    if (!stored) return;\n\n    let code: string;\n    try {\n      const parsed = JSON.parse(stored);\n      code = parsed?.code;\n    } catch {\n      // Corrupt data — remove it\n      try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n      return;\n    }\n\n    if (!code || typeof code !== \"string\") {\n      try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n      return;\n    }\n\n    appliedRef.current = true;\n\n    applyReferralCode(accessToken, code)\n      .then(() => {\n        try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n        // TODO: replace with toast notification when toast system is implemented\n        console.warn(\"[referral] Referral code applied successfully\");\n      })\n      .catch((err: Error) => {\n        const msg = err.message ?? \"\";\n        // Permanent failures — code invalid, already linked, self-referral\n        const isPermanent =\n          msg.includes(\"ALREADY_LINKED\") ||\n          msg.includes(\"SELF_REFERRAL\") ||\n          msg.includes(\"NOT_FOUND\") ||\n          msg.includes(\"INVALID\") ||\n          msg.includes(\"already linked\") ||\n          msg.includes(\"not found\") ||\n          msg.includes(\"Cannot refer yourself\");\n\n        if (isPermanent) {\n          try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n        }\n        // Transient failures (network, 500): keep localStorage for retry on next auth\n      });\n  }, [isAuthenticated, accessToken, address]);\n}\n","numLines":80,"startLine":1,"totalLines":80}}}
