{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EX1aHaux3wYYYxvEr9K8Q7","type":"tool_result","content":"     1→/**\n     2→ * Referral route tests — set code, apply, stats, earnings, claim flows.\n     3→ *\n     4→ * Uses real Postgres (same pattern as auth-routes.test.ts) with TRUNCATE\n     5→ * between tests for isolation.\n     6→ */\n     7→\n     8→import { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n     9→import { Hono } from \"hono\";\n    10→import { Keypair } from \"@solana/web3.js\";\n    11→import { SignJWT } from \"jose\";\n    12→import postgres from \"postgres\";\n    13→import { createDb, type Db } from \"../db.js\";\n    14→import { createReferralRoutes } from \"../routes/referral.js\";\n    15→import { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n    16→import type { Config } from \"../config.js\";\n    17→\n    18→// ---------------------------------------------------------------------------\n    19→// Constants\n    20→// ---------------------------------------------------------------------------\n    21→\n    22→const DATABASE_URL =\n    23→  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n    24→const JWT_SECRET = new TextEncoder().encode(\"test-secret-for-referral-tests\");\n    25→\n    26→/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n    27→function makeSql() {\n    28→  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n    29→  // Dev container: postgres listens on Unix socket only\n    30→  return postgres({\n    31→    host: \"/var/run/postgresql\",\n    32→    user: \"vscode\",\n    33→    database: \"rng_utopia_dev\",\n    34→  });\n    35→}\n    36→\n    37→// ---------------------------------------------------------------------------\n    38→// Helpers\n    39→// ---------------------------------------------------------------------------\n    40→\n    41→async function makeJwt(wallet: string): Promise<string> {\n    42→  const now = Math.floor(Date.now() / 1000);\n    43→  return new SignJWT({ sub: wallet })\n    44→    .setProtectedHeader({ alg: \"HS256\" })\n    45→    .setIssuedAt(now)\n    46→    .setExpirationTime(now + 3600)\n    47→    .sign(JWT_SECRET);\n    48→}\n    49→\n    50→function json(body: Record<string, unknown>) {\n    51→  return {\n    52→    headers: { \"Content-Type\": \"application/json\" },\n    53→    body: JSON.stringify(body),\n    54→  };\n    55→}\n    56→\n    57→// ---------------------------------------------------------------------------\n    58→// Test suite\n    59→// ---------------------------------------------------------------------------\n    60→\n    61→describe(\"Referral routes\", () => {\n    62→  let rawSql: ReturnType<typeof postgres>;\n    63→  let db: Db;\n    64→  let app: Hono;\n    65→\n    66→  const referrerKp = Keypair.generate();\n    67→  const refereeKp = Keypair.generate();\n    68→  const referrer = referrerKp.publicKey.toBase58();\n    69→  const referee = refereeKp.publicKey.toBase58();\n    70→\n    71→  const testConfig = {\n    72→    referralDefaultRateBps: 1000,\n    73→    referralMinClaimLamports: 10_000_000, // 0.01 SOL\n    74→  } as Config;\n    75→\n    76→  beforeAll(async () => {\n    77→    rawSql = makeSql();\n    78→\n    79→    // Ensure referral + event_queue tables exist (idempotent)\n    80→    await rawSql.file(\n    81→      new URL(\"../../migrations/010_event_queue.sql\", import.meta.url).pathname,\n    82→    );\n    83→    await rawSql.file(\n    84→      new URL(\"../../migrations/011_referral.sql\", import.meta.url).pathname,\n    85→    );\n    86→  });\n    87→\n    88→  afterAll(async () => {\n    89→    if (db) await db.close();\n    90→    await rawSql.end();\n    91→  });\n    92→\n    93→  beforeEach(async () => {\n    94→    await rawSql`TRUNCATE referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, event_queue RESTART IDENTITY CASCADE`;\n    95→\n    96→    db = createDb(DATABASE_URL, rawSql);\n    97→\n    98→    app = new Hono();\n    99→    app.use(\n   100→      \"/referral/*\","}]},"parent_tool_use_id":"toolu_01UouSjWLoexuEH21J3HZK7R","session_id":"8cdd94d4-4d50-4151-8136-428429db5806","uuid":"bfcf28ea-0193-4a3a-b488-dd47d2e255e1","timestamp":"2026-03-25T15:26:58.143Z"}
