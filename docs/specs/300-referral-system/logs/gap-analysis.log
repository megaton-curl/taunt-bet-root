l code\",\n   155→            retryable: false,\n   156→          },\n   157→        },\n   158→        400,\n   159→      );\n   160→    }\n   161→\n   162→    // Check if the player already has a referrer\n   163→    const existingLink = await db.getReferralLinkByReferee(wallet);\n   164→    if (existingLink) {\n   165→      return c.json(\n   166→        {\n   167→          error: {\n   168→            code: \"ALREADY_LINKED\",\n   169→            message: \"You are already linked to a referrer\","}]},"parent_tool_use_id":null,"session_id":"8cdd94d4-4d50-4151-8136-428429db5806","uuid":"bd16afe9-a2c7-4513-a5c6-46435bef2983","timestamp":"2026-03-25T15:28:24.725Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/referral.ts","content":"    }\n  });\n\n  // POST /apply — link the authenticated player to a referrer via their code\n  app.post(\"/apply\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    let body: { code?: unknown };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_BODY\",\n            message: \"Invalid request body\",\n          },\n        },\n        400,\n      );\n    }\n\n    const code =\n      typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n\n    if (!code) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_CODE\",\n            message: \"Referral code is required\",\n          },\n        },\n        400,\n      );\n    }\n\n    // Look up the referral code to find the referrer\n    const codeRow = await db.getReferralCodeByCode(code);\n    if (!codeRow) {\n      return c.json(\n        {\n          error: {\n            code: \"CODE_NOT_FOUND\",\n            message: \"Referral code does not exist\",\n            retryable: false,\n          },\n        },\n        404,\n      );\n    }\n\n    // Self-referral check\n    if (codeRow.wallet === wallet) {\n      return c.json(\n        {\n          error: {\n            code: \"SELF_REFERRAL\",\n            message: \"You cannot use your own referral code\",\n            retryable: false,\n          },\n        },\n        400,\n      );\n    }\n\n    // Check if the player already has a referrer\n    const existingLink = await db.getReferralLinkByReferee(wallet);\n    if (existingLink) {\n      return c.json(\n        {\n          error: {\n            code: \"ALREADY_LINKED\",\n            message: \"You are already linked to a referrer\",","numLines":75,"startLine":95,"totalLines":482}}}
