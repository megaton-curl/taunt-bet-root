84→            status: string;\n   385→          }[]\n   386→        >`\n   387→          INSERT INTO referral_claims (wallet, amount_lamports, status)\n   388→          VALUES (${wallet}, ${pendingStr}, 'pending')\n   389→          RETURNING id, wallet, amount_lamports, status\n   390→        `;\n   391→        const row = rows[0]!;\n   392→\n   393→        await emitEvent(\n   394→          tx as unknown as postgres.Sql,\n   395→          EventTypes.REFERRAL_CLAIM_REQUESTED,\n   396→          {\n   397→            claimId: row.id,\n   398→            wallet: row.wallet,\n   399→            amountLamports: row.amount_lamports,\n   400→            requestedAt: new Date().toISOString(),\n   401→          },\n   402→        );\n   403→\n   404→        return row;\n   405→      });\n   406→\n   407→      logger.info(\"Referral claim requested\", {\n   408→        wallet,\n   409→        claimId: claim.id,\n   410→        amountLamports: claim.amount_lamports,\n   411→      });\n   412→\n   413→      return c.json(\n   414→        {\n   415→          claimId: claim.id,\n   416→          amountLamports: claim.amount_lamports,\n   417→          status: \"pending\",\n   418→        },\n   419→        202,\n   420→      );\n   421→    } catch (err) {\n   422→      logger.error(\"Failed to create referral claim\", {\n   423→        err: String(err),\n   424→        wallet,\n   425→      });\n   426→      return c.json({ error: \"Failed to create referral claim\" }, 500);\n   427→    }\n   428→  });\n   429→\n   430→  // GET /claim/:claimId — poll claim status\n   431→  app.get(\"/claim/:claimId\", async (c) => {\n   432→    const wallet = c.get(\"wallet\");\n   433→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   434→\n   435→    const claimId = c.req.param(\"claimId\");\n   436→\n   437→    try {\n   438→      const claim = await db.getReferralClaim(claimId);\n   439→      if (!claim) {\n   440→        return c.json(\n   441→          {\n   442→            error: {\n   443→              code: \"CLAIM_NOT_FOUND\",\n   444→              message: \"Claim not found\","}]},"parent_tool_use_id":null,"session_id":"8cdd94d4-4d50-4151-8136-428429db5806","uuid":"2240b9fa-8886-4f3f-aad6-811a8159647b","timestamp":"2026-03-25T15:28:26.769Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/referral.ts","content":"        wallet,\n      });\n      return c.json({ error: \"Failed to fetch referral earnings\" }, 500);\n    }\n  });\n\n  // POST /claim — request payout of pending referral earnings (async via queue)\n  app.post(\"/claim\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    try {\n      // Snapshot pending balance\n      const pendingStr = await db.getPendingBalance(wallet);\n      const pendingLamports = BigInt(pendingStr);\n\n      if (pendingLamports <= 0n) {\n        return c.json(\n          {\n            error: {\n              code: \"ZERO_BALANCE\",\n              message: \"No pending earnings to claim\",\n              retryable: false,\n            },\n          },\n          400,\n        );\n      }\n\n      if (pendingLamports < BigInt(config.referralMinClaimLamports)) {\n        return c.json(\n          {\n            error: {\n              code: \"BELOW_THRESHOLD\",\n              message: `Minimum claim amount is ${config.referralMinClaimLamports} lamports (${(config.referralMinClaimLamports / 1e9).toFixed(2)} SOL)`,\n              retryable: false,\n            },\n          },\n          400,\n        );\n      }\n\n      // Atomically insert claim row + emit queue event\n      const claim = await sql.begin(async (tx) => {\n        const rows = await (tx as unknown as postgres.Sql)<\n          {\n            id: string;\n            wallet: string;\n            amount_lamports: string;\n            status: string;\n          }[]\n        >`\n          INSERT INTO referral_claims (wallet, amount_lamports, status)\n          VALUES (${wallet}, ${pendingStr}, 'pending')\n          RETURNING id, wallet, amount_lamports, status\n        `;\n        const row = rows[0]!;\n\n        await emitEvent(\n          tx as unknown as postgres.Sql,\n          EventTypes.REFERRAL_CLAIM_REQUESTED,\n          {\n            claimId: row.id,\n            wallet: row.wallet,\n            amountLamports: row.amount_lamports,\n            requestedAt: new Date().toISOString(),\n          },\n        );\n\n        return row;\n      });\n\n      logger.info(\"Referral claim requested\", {\n        wallet,\n        claimId: claim.id,\n        amountLamports: claim.amount_lamports,\n      });\n\n      return c.json(\n        {\n          claimId: claim.id,\n          amountLamports: claim.amount_lamports,\n          status: \"pending\",\n        },\n        202,\n      );\n    } catch (err) {\n      logger.error(\"Failed to create referral claim\", {\n        err: String(err),\n        wallet,\n      });\n      return c.json({ error: \"Failed to create referral claim\" }, 500);\n    }\n  });\n\n  // GET /claim/:claimId — poll claim status\n  app.get(\"/claim/:claimId\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    const claimId = c.req.param(\"claimId\");\n\n    try {\n      const claim = await db.getReferralClaim(claimId);\n      if (!claim) {\n        return c.json(\n          {\n            error: {\n              code: \"CLAIM_NOT_FOUND\",\n              message: \"Claim not found\",","numLines":110,"startLine":335,"totalLines":482}}}
