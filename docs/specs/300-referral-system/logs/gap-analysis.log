{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01VvEy6Dvcm5izWgri5PJJkt","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Ltziy2zNNVj2bhcrtJ5RWJ","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/referral/ReferralClaimCard.tsx"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3766,"cache_creation_input_tokens":635,"cache_read_input_tokens":44874,"cache_creation":{"ephemeral_5m_input_tokens":635,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_017uqN3x7jw6bV395y2Y8DmC","session_id":"8cdd94d4-4d50-4151-8136-428429db5806","uuid":"f2ee95b5-d624-4701-9872-a723ff3d4c8e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ltziy2zNNVj2bhcrtJ5RWJ","type":"tool_result","content":"     1→import { useCallback, useEffect, useRef, useState } from \"react\";\n     2→import { useSession } from \"../../context/SessionContext\";\n     3→import {\n     4→  getReferralStats,\n     5→  requestReferralClaim,\n     6→  pollClaimStatus,\n     7→  type ReferralStatsResponse,\n     8→  type ClaimResponse,\n     9→} from \"../../lib/referral-api\";\n    10→import { explorerTxUrl } from \"../../lib/solana-env\";\n    11→\n    12→const LAMPORTS_PER_SOL = 1_000_000_000;\n    13→const MIN_CLAIM_LAMPORTS = 10_000_000; // 0.01 SOL\n    14→\n    15→function formatSol(lamportsStr: string): string {\n    16→  const sol = Number(lamportsStr) / LAMPORTS_PER_SOL;\n    17→  if (sol >= 1_000_000) return `${(sol / 1_000_000).toFixed(1)}M`;\n    18→  if (sol >= 1000) return `${(sol / 1000).toFixed(1)}k`;\n    19→  if (sol >= 1) return sol.toFixed(2);\n    20→  if (sol >= 0.01) return sol.toFixed(3);\n    21→  return sol.toFixed(4);\n    22→}\n    23→\n    24→export function ReferralClaimCard() {\n    25→  const { accessToken } = useSession();\n    26→  const [loading, setLoading] = useState(true);\n    27→  const [stats, setStats] = useState<ReferralStatsResponse | null>(null);\n    28→  const [claiming, setClaiming] = useState(false);\n    29→  const [claimResult, setClaimResult] = useState<ClaimResponse | null>(null);\n    30→  const [error, setError] = useState(\"\");\n    31→  const pollRef = useRef<ReturnType<typeof setTimeout> | null>(null);\n    32→\n    33→  const fetchStats = useCallback(async () => {\n    34→    if (!accessToken) return;\n    35→    try {\n    36→      const res = await getReferralStats(accessToken);\n    37→      setStats(res);\n    38→    } catch {\n    39→      /* unavailable — show zeros */\n    40→    } finally {\n    41→      setLoading(false);\n    42→    }\n    43→  }, [accessToken]);\n    44→\n    45→  useEffect(() => {\n    46→    fetchStats();\n    47→  }, [fetchStats]);\n    48→\n    49→  // Poll claim status until terminal\n    50→  useEffect(() => {\n    51→    if (!claimResult || !accessToken) return;\n    52→    if (claimResult.status === \"completed\" || claimResult.status === \"failed\") {\n    53→      return;\n    54→    }\n    55→    const poll = async () => {\n    56→      try {\n    57→        const updated = await pollClaimStatus(accessToken, claimResult.claimId);\n    58→        setClaimResult(updated);\n    59→        if (updated.status === \"completed\") {\n    60→          fetchStats(); // refresh pending balance\n    61→        } else if (updated.status !== \"failed\") {\n    62→          pollRef.current = setTimeout(poll, 3000);\n    63→        }\n    64→      } catch {\n    65→        pollRef.current = setTimeout(poll, 5000);\n    66→      }\n    67→    };\n    68→    pollRef.current = setTimeout(poll, 2000);\n    69→    return () => {\n    70→      if (pollRef.current) clearTimeout(pollRef.current);\n    71→    };\n    72→  }, [claimResult, accessToken, fetchStats]);\n    73→\n    74→  const handleClaim = useCallback(async () => {\n    75→    if (!accessToken) return;\n    76→    setClaiming(true);\n    77→    setError(\"\");\n    78→    setClaimResult(null);\n    79→    try {\n    80→      const res = await requestReferralClaim(accessToken);\n    81→      setClaimResult(res);\n    82→    } catch (e) {\n    83→      setError(e instanceof Error ? e.message : \"Claim failed\");\n    84→    } finally {\n    85→      setClaiming(false);\n    86→    }\n    87→  }, [accessToken]);\n    88→\n    89→  const pendingLamports = Number(stats?.pendingLamports ?? \"0\");\n    90→  const earnedLamports = stats?.totalEarnedLamports ?? \"0\";\n    91→  const rebateLamports = stats?.totalRebateLamports ?? \"0\";\n    92→  const canClaim = pendingLamports >= MIN_CLAIM_LAMPORTS;\n    93→\n    94→  return (\n    95→    <div className=\"ref-claim-card\">\n    96→      <h3 className=\"ref-claim-card__title\">Pending Earnings</h3>\n    97→\n    98→      {loading ? (\n    99→        <div className=\"ref-claim-card__skeleton\" />\n   100→      ) : (\n   101→        <>\n   102→          <div className=\"ref-claim-card__balance\">\n   103→            {formatSol(String(pendingLamports))} <span className=\"ref-claim-card__sol\">SOL</span>\n   104→          </div>\n   105→\n   106→          <div className=\"ref-claim-card__breakdown\">\n   107→            <div className=\"ref-claim-card__breakdown-row\">\n   108→              <span>From referrals</span>\n   109→              <span>{formatSol(earnedLamports)} SOL</span>\n   110→            </div>\n   111→            <div className=\"ref-claim-card__breakdown-row\">\n   112→              <span>From fee rebates</span>\n   113→              <span>{formatSol(rebateLamports)} SOL</span>\n   114→            </div>\n   115→          </div>\n   116→\n   117→          {claimResult?.status === \"completed\" && claimResult.txSignature ? (\n   118→            <div className=\"ref-claim-card__success\">\n   119→              Claimed {formatSol(claimResult.amountLamports)} SOL{\" \"}\n   120→              <a\n   121→                href={explorerTxUrl(claimResult.txSignature)}\n   122→                target=\"_blank\"\n   123→                rel=\"noopener noreferrer\"\n   124→                className=\"ref-claim-card__tx-link\"\n   125→              >\n   126→                View transaction &#x2197;\n   127→              </a>\n   128→            </div>\n   129→          ) : claimResult?.status === \"failed\" ? (\n   130→            <div className=\"ref-claim-card__error\">\n   131→              Claim failed. Please try again.\n   132→            </div>\n   133→          ) : null}\n   134→\n   135→          {error && <div className=\"ref-claim-card__error\">{error}</div>}\n   136→\n   137→          <button\n   138→            type=\"button\"\n   139→            className=\"ref-claim-card__btn\"\n   140→            onClick={handleClaim}\n   141→            disabled={!canClaim || claiming || (claimResult?.status === \"pending\")}\n   142→          >\n   143→            {claiming\n   144→              ? \"Claiming...\"\n   145→              : claimResult?.status === \"pending\"\n   146→                ? \"Processing...\"\n   147→                : canClaim\n   148→                  ? \"Claim Earnings\"\n   149→                  : pendingLamports > 0\n   150→                    ? \"Below minimum (0.01 SOL)\"\n   151→                    : \"No pending earnings\"}\n   152→          </button>\n   153→        </>\n   154→      )}\n   155→    </div>\n   156→  );\n   157→}\n   158→"}]},"parent_tool_use_id":"toolu_017uqN3x7jw6bV395y2Y8DmC","session_id":"8cdd94d4-4d50-4151-8136-428429db5806","uuid":"cfa2c123-4b34-49c9-9b53-6b64573131f1","timestamp":"2026-03-25T15:26:51.154Z"}
