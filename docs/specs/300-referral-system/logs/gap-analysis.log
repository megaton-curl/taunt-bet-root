{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NnLSdjbroQVMaZZfYhuXa1","type":"tool_result","content":"     1→/**\n     2→ * Handler for `referral.claim_requested` events.\n     3→ *\n     4→ * Flow: load claim → verify pending → update to processing → re-verify balance\n     5→ * → SOL transfer from server keypair → record tx_signature → completed.\n     6→ *\n     7→ * Idempotent: skips if claim is already completed or failed.\n     8→ */\n     9→\n    10→import {\n    11→  Connection,\n    12→  Keypair,\n    13→  PublicKey,\n    14→  SystemProgram,\n    15→  Transaction,\n    16→} from \"@solana/web3.js\";\n    17→import type { Db } from \"../../db.js\";\n    18→import { logger } from \"../../logger.js\";\n    19→\n    20→export interface ClaimHandlerDeps {\n    21→  db: Db;\n    22→  connection: Connection;\n    23→  serverKeypair: Keypair;\n    24→}\n    25→\n    26→export function createClaimHandler(deps: ClaimHandlerDeps) {\n    27→  const { db, connection, serverKeypair } = deps;\n    28→\n    29→  return async (payload: Record<string, unknown>): Promise<void> => {\n    30→    const claimId = payload.claimId as string;\n    31→    const wallet = payload.wallet as string;\n    32→    const amountLamports = payload.amountLamports as string;\n    33→\n    34→    if (!claimId || !wallet || !amountLamports) {\n    35→      throw new Error(\n    36→        `referral.claim_requested: malformed payload — missing claimId, wallet, or amountLamports`,\n    37→      );\n    38→    }\n    39→\n    40→    // 1. Load claim and check idempotency\n    41→    const claim = await db.getReferralClaim(claimId);\n    42→    if (!claim) {\n    43→      logger.warn(\"referral claim handler: claim not found\", { claimId });\n    44→      return; // no-op — event may reference a deleted/invalid claim\n    45→    }\n    46→\n    47→    if (claim.status === \"completed\") {\n    48→      logger.info(\"referral claim handler: already completed, skipping\", {\n    49→        claimId,\n    50→      });\n    51→      return;\n    52→    }\n    53→\n    54→    if (claim.status === \"failed\") {\n    55→      logger.info(\"referral claim handler: already failed, skipping\", {\n    56→        claimId,\n    57→      });\n    58→      return;\n    59→    }\n    60→\n    61→    // 2. Update status to processing\n    62→    await db.updateClaimStatus(claimId, \"processing\");\n    63→\n    64→    try {\n    65→      // 3. Re-verify available balance >= claim amount (prevents overpay on concurrent claims)\n    66→      const pendingStr = await db.getPendingBalance(wallet);\n    67→      const pending = BigInt(pendingStr);\n    68→      const amount = BigInt(amountLamports);\n    69→\n    70→      if (pending < amount) {\n    71→        await db.updateClaimStatus(claimId, \"failed\", {\n    72→          error: `Insufficient balance: pending=${pendingStr}, claim=${amountLamports}`,\n    73→        });\n    74→        logger.warn(\"referral claim handler: insufficient balance\", {\n    75→          claimId,\n    76→          wallet,\n    77→          pending: pendingStr,\n    78→          amount: amountLamports,\n    79→        });\n    80→        return;\n    81→      }\n    82→\n    83→      // 4. Execute SOL transfer from server keypair to player wallet\n    84→      const recipient = new PublicKey(wallet);\n    85→      const lamports = Number(amount);\n    86→\n    87→      const { blockhash, lastValidBlockHeight } =\n    88→        await connection.getLatestBlockhash(\"confirmed\");\n    89→\n    90→      const tx = new Transaction({\n    91→        feePayer: serverKeypair.publicKey,\n    92→        blockhash,\n    93→        lastValidBlockHeight,\n    94→      });\n    95→\n    96→      tx.add(\n    97→        SystemProgram.transfer({\n    98→          fromPubkey: serverKeypair.publicKey,\n    99→          toPubkey: recipient,\n   100→          lamports,\n   101→        }),\n   102→      );\n   103→\n   104→      tx.sign(serverKeypair);\n   105→\n   106→      const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n   107→        skipPreflight: false,\n   108→      });\n   109→\n   110→      // Wait for confirmation\n   111→      const confirmation = await connection.confirmTransaction(\n   112→        { signature: txSignature, blockhash, lastValidBlockHeight },\n   113→        \"confirmed\",\n   114→      );\n   115→\n   116→      if (confirmation.value.err) {\n   117→        throw new Error(\n   118→          `Transaction confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   119→        );\n   120→      }\n   121→\n   122→      // 5. Record success\n   123→      await db.updateClaimStatus(claimId, \"completed\", { txSignature });\n   124→      logger.info(\"referral claim handler: transfer completed\", {\n   125→        claimId,\n   126→        wallet,\n   127→        amountLamports,\n   128→        txSignature,\n   129→      });\n   130→    } catch (err) {\n   131→      // 6. Record failure\n   132→      const errorMsg =\n   133→        err instanceof Error ? err.message : \"Unknown transfer error\";\n   134→      await db.updateClaimStatus(claimId, \"failed\", { error: errorMsg });\n   135→      logger.error(\"referral claim handler: transfer failed\", {\n   136→        claimId,\n   137→        wallet,\n   138→        amountLamports,\n   139→        error: errorMsg,\n   140→      });\n   141→      // Re-throw so the queue worker retries (exponential backoff)\n   142→      throw err;\n   143→    }\n   144→  };\n   145→}\n   146→"}]},"parent_tool_use_id":"toolu_01UouSjWLoexuEH21J3HZK7R","session_id":"8cdd94d4-4d50-4151-8136-428429db5806","uuid":"4f4b66ca-718a-4eb6-8b3f-0a4ca2b9870f","timestamp":"2026-03-25T15:26:48.971Z"}
