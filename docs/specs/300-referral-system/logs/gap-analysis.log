{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016sT3GSgZu2mmveGgbCWC1b","type":"tool_result","content":"     1→-- 011_referral.sql — Referral system tables (spec 300).\n     2→--\n     3→-- Off-chain referral economics: player-chosen codes, referral linking,\n     4→-- per-game earnings tracking, claim payouts, and KOL custom rates.\n     5→-- No on-chain program changes — all tables are backend-only.\n     6→\n     7→-- Referral codes: one active code per wallet\n     8→CREATE TABLE IF NOT EXISTS referral_codes (\n     9→  id              SERIAL       PRIMARY KEY,\n    10→  wallet          TEXT         NOT NULL UNIQUE,\n    11→  code            TEXT         NOT NULL UNIQUE,  -- player-chosen, 3-16 chars [a-z0-9-]\n    12→  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    13→  updated_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n    14→);\n    15→\n    16→-- Referral links: immutable referrer→referee binding (one referrer per player)\n    17→CREATE TABLE IF NOT EXISTS referral_links (\n    18→  id              SERIAL       PRIMARY KEY,\n    19→  referrer_wallet TEXT         NOT NULL,\n    20→  referee_wallet  TEXT         NOT NULL UNIQUE,\n    21→  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n    22→);\n    23→\n    24→CREATE INDEX IF NOT EXISTS idx_referral_links_referrer\n    25→  ON referral_links (referrer_wallet);\n    26→\n    27→-- Referral earnings: one row per referee per round (idempotency guard)\n    28→CREATE TABLE IF NOT EXISTS referral_earnings (\n    29→  id                        SERIAL       PRIMARY KEY,\n    30→  referrer_wallet           TEXT         NOT NULL,\n    31→  referee_wallet            TEXT         NOT NULL,\n    32→  round_id                  TEXT         NOT NULL,\n    33→  game_type                 TEXT         NOT NULL,\n    34→  wager_lamports            BIGINT       NOT NULL,\n    35→  fee_lamports              BIGINT       NOT NULL,\n    36→  referrer_earned_lamports  BIGINT       NOT NULL,\n    37→  referrer_rate_bps         INTEGER      NOT NULL,\n    38→  referee_rebate_lamports   BIGINT       NOT NULL,\n    39→  referee_rebate_rate_bps   INTEGER      NOT NULL,\n    40→  created_at                TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    41→\n    42→  CONSTRAINT uq_referral_earnings_referee_round\n    43→    UNIQUE (referee_wallet, round_id)\n    44→);\n    45→\n    46→CREATE INDEX IF NOT EXISTS idx_referral_earnings_referrer\n    47→  ON referral_earnings (referrer_wallet, created_at);\n    48→\n    49→CREATE INDEX IF NOT EXISTS idx_referral_earnings_referee\n    50→  ON referral_earnings (referee_wallet, created_at);\n    51→\n    52→CREATE INDEX IF NOT EXISTS idx_referral_earnings_round_id\n    53→  ON referral_earnings (round_id);\n    54→\n    55→-- Referral claims: async SOL payout tracking\n    56→CREATE TABLE IF NOT EXISTS referral_claims (\n    57→  id              UUID         PRIMARY KEY DEFAULT gen_random_uuid(),\n    58→  wallet          TEXT         NOT NULL,\n    59→  amount_lamports BIGINT       NOT NULL,\n    60→  status          TEXT         NOT NULL DEFAULT 'pending',\n    61→  tx_signature    TEXT,\n    62→  error           TEXT,\n    63→  requested_at    TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    64→  processed_at    TIMESTAMPTZ,\n    65→\n    66→  CONSTRAINT chk_referral_claims_status\n    67→    CHECK (status IN ('pending', 'processing', 'completed', 'failed'))\n    68→);\n    69→\n    70→CREATE INDEX IF NOT EXISTS idx_referral_claims_wallet\n    71→  ON referral_claims (wallet, requested_at);\n    72→\n    73→CREATE INDEX IF NOT EXISTS idx_referral_claims_status\n    74→  ON referral_claims (status)\n    75→  WHERE status IN ('pending', 'processing');\n    76→\n    77→-- KOL custom referrer rates (overrides default 1000 bps)\n    78→CREATE TABLE IF NOT EXISTS referral_kol_rates (\n    79→  wallet          TEXT         PRIMARY KEY,\n    80→  rate_bps        INTEGER      NOT NULL,\n    81→  set_by          TEXT         NOT NULL,\n    82→  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    83→  updated_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n    84→);\n    85→"}]},"parent_tool_use_id":"toolu_01UouSjWLoexuEH21J3HZK7R","session_id":"8cdd94d4-4d50-4151-8136-428429db5806","uuid":"51fefd39-bf97-4b07-b0e3-aac30d946d5a","timestamp":"2026-03-25T15:26:15.636Z"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_014fKiPXctfoupC4ojtvTES3","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_017uqN3x7jw6bV395y2Y8DmC","name":"Agent","input":{"description":"Inventory frontend referral implementation","subagent_type":"Explore","prompt":"Thoroughly inventory the referral system frontend implementation in the codebase. I need precise file:line evidence for each component. Search in `sources/rng-utopia/apps/platform/`.\n\n1. **API client**: Find `lib/referral-api.ts` — list all exported functions with line numbers. Verify it has: setReferralCode, getReferralCode, applyReferralCode, getReferralStats, getReferralEarnings, requestReferralClaim, pollClaimStatus, getReferrer. Check for typed interfaces (ReferralCodeResponse, etc.)\n2. **App.tsx routes**: Find route registrations for `/r/:code` and `/referrals` — exact lines\n3. **ReferralCapture component**: Find where the /r/:code route component is defined — does it store to localStorage and redirect?\n4. **useReferralApply hook**: Find in `features/referral/hooks/` — verify it reads localStorage, calls applyReferralCode, clears on success/permanent failure, keeps on transient failure. Where is it mounted in App.tsx?\n5. **Sidebar.tsx**: Find the \"Referrals\" NavLink — exact line, verify href=\"/referrals\", icon, color\n6. **ReferralPage.tsx**: Find in `features/referral/` — what sections does it render? List child components\n7. **ReferralLinkCard.tsx**: Find and verify it has code input, validation, set/change code, copy link\n8. **ReferralStatsCard.tsx**: Find and verify 4 stat boxes\n9. **ReferralClaimCard.tsx**: Find and verify pending balance display, claim button, polling, success/error states\n10. **ReferralEarningsTable.tsx**: Find and verify paginated table with correct columns\n11. **ProfileSettings.tsx**: Find the referral code section — verify input for no-referrer state, read-only for linked state\n12. **CSS**: Find referral-related styles in index.css or similar\n13. **E2E tests**: Find `30-referral.spec.ts` in e2e/local/ and any visual tests in e2e/visual/\n14. **Barrel export**: Check `features/referral/index.ts`\n\nFor each item, give the EXACT file path and line number. If something doesn't exist, say \"NOT FOUND\"."},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":19589,"cache_read_input_tokens":45953,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":19589},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8cdd94d4-4d50-4151-8136-428429db5806","uuid":"79384eb6-c7a2-4e67-8503-072bf67e009a"}
