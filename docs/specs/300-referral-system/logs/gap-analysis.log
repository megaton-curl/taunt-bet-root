{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013bEgRYUkRQvPc3XVyU79fu","type":"tool_result","content":"     1→/**\n     2→ * Async event queue — Postgres-backed infrastructure for decoupling\n     3→ * side-effects from the game settlement hot path.\n     4→ */\n     5→\n     6→export { emitEvent } from \"./emit-event.js\";\n     7→export type { EmitEventOptions, SqlOrTransaction } from \"./emit-event.js\";\n     8→\n     9→export { EventTypes } from \"./event-types.js\";\n    10→export type { EventType } from \"./event-types.js\";\n    11→\n    12→export { registerHandler, getHandler, clearHandlers } from \"./handler-registry.js\";\n    13→export type { EventHandler } from \"./handler-registry.js\";\n    14→\n    15→export { createEventWorker, getBackoffSeconds } from \"./worker.js\";\n    16→export type { EventWorker, EventWorkerOptions } from \"./worker.js\";\n    17→\n    18→export { getQueueDepth } from \"./health.js\";\n    19→export type { QueueDepth } from \"./health.js\";\n    20→"}]},"parent_tool_use_id":"toolu_01UouSjWLoexuEH21J3HZK7R","session_id":"8cdd94d4-4d50-4151-8136-428429db5806","uuid":"8e79478a-b3f7-42de-9bd0-c6fb4e7cc1ee","timestamp":"2026-03-25T15:26:51.472Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DMfPGCoCYrFFcYBSEu9bCq","type":"tool_result","content":"     1→import { Hono } from \"hono\";\n     2→import { cors } from \"hono/cors\";\n     3→import { serve } from \"@hono/node-server\";\n     4→import { Connection, PublicKey } from \"@solana/web3.js\";\n     5→import postgres from \"postgres\";\n     6→import { loadConfig } from \"./config.js\";\n     7→import { createDb } from \"./db.js\";\n     8→import { createAuthDb } from \"./auth-db.js\";\n     9→import { createCoinflipRoutes } from \"./routes/create.js\";\n    10→import { createLordRoutes } from \"./routes/lord-create.js\";\n    11→import { createRoundsRoutes } from \"./routes/rounds.js\";\n    12→import { createCloseCallRoutes } from \"./routes/closecall.js\";\n    13→import { createHealthRoutes } from \"./routes/health.js\";\n    14→import { createProfileRoutes } from \"./routes/profile.js\";\n    15→import { createPriceRoutes } from \"./routes/price.js\";\n    16→import { createAuthRoutes } from \"./routes/auth.js\";\n    17→import { createReferralRoutes } from \"./routes/referral.js\";\n    18→import { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n    19→import { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n    20→import { createSettlementWorker } from \"./worker/settlement.js\";\n    21→import { settleRound } from \"./worker/settle-tx.js\";\n    22→import { createRetrySettler } from \"./worker/retry.js\";\n    23→import { createPdaWatcher } from \"./worker/pda-watcher.js\";\n    24→import { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n    25→import { createEventWorker, registerHandler, EventTypes } from \"./queue/index.js\";\n    26→import { createClaimHandler } from \"./queue/handlers/referral-claim.js\";\n    27→import { logger } from \"./logger.js\";\n    28→\n    29→const config = loadConfig();\n    30→\n    31→// Shared postgres connection for both game DB and auth DB\n    32→const sql = postgres(config.databaseUrl);\n    33→const db = createDb(config.databaseUrl);\n    34→const authDb = createAuthDb(sql);\n    35→\n    36→const connection = new Connection(config.rpcUrl, {\n    37→  commitment: \"confirmed\",\n    38→  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n    39→});\n    40→\n    41→const app = new Hono();\n    42→\n    43→app.use(\n    44→  \"*\",\n    45→  cors({\n    46→    origin: \"*\",\n    47→    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n    48→    allowHeaders: [\"Content-Type\", \"Authorization\"],\n    49→  }),\n    50→);\n    51→\n    52→// Request logging — correlate frontend fetch timing with server-side processing\n    53→app.use(\"*\", async (c, next) => {\n    54→  const start = Date.now();\n    55→  await next();\n    56→  const ms = Date.now() - start;\n    57→  const method = c.req.method;\n    58→  const path = c.req.path;\n    59→  // Skip noisy health checks and OPTIONS preflight\n    60→  if (path === \"/health\" || method === \"OPTIONS\") return;\n    61→  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n    62→});\n    63→\n    64→// Auth routes — no JWT middleware (these are the login endpoints)\n    65→// Lighter rate limiting by IP for auth endpoints\n    66→app.use(\n    67→  \"/auth/*\",\n    68→  createRateLimitMiddleware({\n    69→    perWallet: 20,\n    70→    global: config.rateLimitGlobal,\n    71→    windowMs: 60_000,\n    72→  }),\n    73→);\n    74→\n    75→app.route(\n    76→  \"/auth\",\n    77→  createAuthRoutes({\n    78→    authDb,\n    79→    jwtSecret: config.jwtSecret,\n    80→    cluster: config.cluster,\n    81→    challengeTtlSeconds: config.challengeTtlSeconds,\n    82→    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    83→    refreshTokenTtlDays: config.refreshTokenTtlDays,\n    84→  }),\n    85→);\n    86→\n    87→// Profile routes — authenticated GET endpoints (require JWT on all methods)\n    88→app.use(\n    89→  \"/profile/*\",\n    90→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n    91→);\n    92→app.route(\"/profile\", createProfileRoutes({ db }));\n    93→\n    94→// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n    95→app.use(\n    96→  \"/referral/*\",\n    97→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n    98→);\n    99→app.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n   100→\n   101→// JWT auth middleware for fairness endpoints\n   102→app.use(\n   103→  \"/fairness/*\",\n   104→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n   105→);\n   106→\n   107→// Rate limiting — per-wallet and global limits on POST requests\n   108→app.use(\n   109→  \"/fairness/*\",\n   110→  createRateLimitMiddleware({\n   111→    perWallet: config.rateLimitPerWallet,\n   112→    global: config.rateLimitGlobal,\n   113→    windowMs: 60_000,\n   114→  }),\n   115→);\n   116→\n   117→// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n   118→const entropyAccount = new PublicKey(config.entropyAccount);\n   119→const retrySettler = createRetrySettler({\n   120→  db,\n   121→  connection,\n   122→  settleRound: (pda) =>\n   123→    settleRound(\n   124→      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n   125→      pda,\n   126→    ),\n   127→});\n   128→\n   129→// PDA watcher — WebSocket-based instant join detection\n   130→const pdaWatcher = createPdaWatcher({\n   131→  connection,\n   132→  serverKey: config.serverKeypair.publicKey,\n   133→  db,\n   134→  onJoinDetected: async (pda, targetSlot) => {\n   135→    // Update DB phase if still in 'created'\n   136→    const round = await db.getRoundByPda(pda);\n   137→    if (round && round.phase === \"created\") {\n   138→      await db.updateRoundPhase(pda, \"locked\", {\n   139→        target_slot: targetSlot.toString(),\n   140→      });\n   141→      await db.insertOperatorEvent(pda, \"match_detected\", {\n   142→        targetSlot: targetSlot.toString(),\n   143→        source: \"pda-watcher\",\n   144→        game: round.game,\n   145→      });\n   146→    }\n   147→\n   148→    // Check if target slot already passed — settle immediately if so\n   149→    const currentSlot = await connection.getSlot();\n   150→    if (BigInt(currentSlot) >= targetSlot) {\n   151→      await retrySettler.attemptSettle(pda);\n   152→      pdaWatcher.unwatch(pda);\n   153→    }\n   154→    // If target slot not reached yet, poll worker will pick it up next cycle\n   155→  },\n   156→});\n   157→\n   158→const worker = createSettlementWorker({\n   159→  db,\n   160→  connection,\n   161→  serverKey: config.serverKeypair.publicKey,\n   162→  pollIntervalMs: config.workerPollIntervalMs,\n   163→  onSettleReady: async (pda) => {\n   164→    await retrySettler.attemptSettle(pda);\n   165→    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n   166→  },\n   167→  isFinalized: (pda) => retrySettler.isFinalized(pda),\n   168→});\n   169→worker.start();\n   170→\n   171→// Close Call clock worker — fetches boundary prices + settles open rounds\n   172→// Rounds are created on-demand by players via /closecall/bet\n   173→const closeCallClock = createCloseCallClockWorker({\n   174→  connection,\n   175→  serverKeypair: config.serverKeypair,\n   176→  db: sql,\n   177→});\n   178→closeCallClock.start();\n   179→\n   180→// Register event handlers before starting the worker\n   181→registerHandler(\n   182→  EventTypes.REFERRAL_CLAIM_REQUESTED,\n   183→  createClaimHandler({ db, connection, serverKeypair: config.serverKeypair }),\n   184→);\n   185→\n   186→// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n   187→const eventWorker = createEventWorker(sql, {\n   188→  pollIntervalMs: config.eventQueuePollMs,\n   189→});\n   190→eventWorker.start();\n   191→logger.info(\"Event queue worker started\", {\n   192→  pollIntervalMs: config.eventQueuePollMs,\n   193→});\n   194→\n   195→// Coinflip fairness routes\n   196→app.route(\n   197→  \"/fairness/coinflip\",\n   198→  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n   199→);\n   200→app.route(\n   201→  \"/fairness/lord\",\n   202→  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n   203→);\n   204→\n   205→// Close Call routes (create-round co-signing + candle history + read queries)\n   206→app.route(\"/closecall\", createCloseCallRoutes({\n   207→  db,\n   208→  connection,\n   209→  serverKeypair: config.serverKeypair,\n   210→  clockWorker: closeCallClock,\n   211→  sql,\n   212→}));\n   213→\n   214→// Price routes — public, no auth\n   215→app.route(\"/price\", createPriceRoutes());\n   216→\n   217→// Round verification routes\n   218→app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n   219→\n   220→// Health endpoint — wired after worker exists so we can query its status\n   221→app.route(\n   222→  \"/health\",\n   223→  createHealthRoutes({\n   224→    db,\n   225→    sql,\n   226→    connection,\n   227→    serverKey: config.serverKeypair.publicKey,\n   228→    isWorkerRunning: () => worker.isRunning,\n   229→    minSolBalance: config.minSolBalance,\n   230→  }),\n   231→);\n   232→\n   233→const port = config.port;\n   234→logger.info(\"fairness-backend started\", { port });\n   235→\n   236→serve({\n   237→  fetch: app.fetch,\n   238→  port,\n   239→});\n   240→\n   241→export default {\n   242→  port,\n   243→  fetch: app.fetch,\n   244→};\n   245→"}]},"parent_tool_use_id":"toolu_01UouSjWLoexuEH21J3HZK7R","session_id":"8cdd94d4-4d50-4151-8136-428429db5806","uuid":"7e03fd7e-c798-408f-a199-a041ede1db4e","timestamp":"2026-03-25T15:26:51.478Z"}
