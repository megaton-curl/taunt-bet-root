uests</span>\n   159→            {claimableQuestCount > 0 && <span className=\"nv-bdg pk\">{claimableQuestCount}</span>}\n   160→          </NavLink>\n   161→\n   162→          <NavLink to=\"/referrals\" className={({ isActive }) => `nv-item ${isActive ? \"active\" : \"\"}`} style={{ \"--nc\": \"var(--color-green)\" } as React.CSSProperties}>\n   163→            <div className=\"nv-ico\">\n   164→              <svg viewBox=\"0 0 17 17\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"1.5\" strokeLinecap=\"round\" strokeLinejoin=\"round\">\n   165→                <path d=\"M7 3.5H4C3.2 3.5 2.5 4.2 2.5 5V12C2.5 12.8 3.2 13.5 4 13.5H13C13.8 13.5 14.5 12.8 14.5 12V9.5\" />\n   166→                <path d=\"M10 2L14.5 2L14.5 6.5\" />\n   167→                <line x1=\"14.5\" y1=\"2\" x2=\"8\" y2=\"8.5\" />\n   168→              </svg>\n   169→            </div>\n   170→            <span className=\"nv-lbl\">Referrals</span>\n   171→          </NavLink>\n   172→        </div>\n   173→\n   174→        {/* Platform */}\n   175→        <div className=\"nv-sec\">\n   176→          <div className=\"nv-sec-lbl\">Platform</div>\n   177→\n   178→          <NavLink to=\"/fairness\" className={({ isActive }) => `nv-item ${isActive ? \"active\" : \"\"}`} style={{ \"--nc\": \"var(--color-muted2)\" } as React.CSSProperties}>\n   179→            <div className=\"nv-ico\">\n   180→              <svg viewBox=\"0 0 17 17\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"1.5\" strokeLinecap=\"round\" strokeLinejoin=\"round\">\n   181→                <path d=\"M8.5 1.5L2 4V9C2 12.5 4.8 15.5 8.5 16C12.2 15.5 15 12.5 15 9V4Z\" />\n   182→                <polyline points=\"5.5,8.5 7.5,10.5 11.5,6.5\" />\n   183→              </svg>\n   184→            </div>\n   185→            <span className=\"nv-lbl\">Provably Fair</span>\n   186→          </NavLink>\n   187→        </div>\n   188→      </div>\n   189→\n   190→      {/* User footer */}\n   191→      {connected && address && (\n   192→        <div className=\"sb-foot\">\n   193→          <div className=\"sf-user\">\n   194→            <div className=\"sf-av\">\n   195→              <svg viewBox=\"0 0 18 18\" fill=\"none\" stroke=\"white\" strokeWidth=\"1.6\" strokeLinecap=\"round\">\n   196→                <circle cx=\"9\" cy=\"6\" r=\"3.5\" />\n   197→                <path d=\"M2 17C2 13.5 5 11 9 11C13 11 16 13.5 16 17\" />\n   198→              </svg>\n   199→            </div>\n   200→            <div className=\"sf-info\">\n   201→              <div className=\"sf-name\">{address.slice(0, 4)}…{address.slice(-4)}</div>\n   202→            </div>\n   203→          </div>\n   204→        </div>\n   205→      )}\n   206→    </div>\n   207→  );\n   208→}\n   209→"}]},"parent_tool_use_id":"toolu_017uqN3x7jw6bV395y2Y8DmC","session_id":"8cdd94d4-4d50-4151-8136-428429db5806","uuid":"992d1542-a70c-420d-9b78-4d300c86cd9d","timestamp":"2026-03-25T15:26:43.513Z"}
