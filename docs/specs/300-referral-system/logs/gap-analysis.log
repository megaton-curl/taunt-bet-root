{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ns6TeoRr4X6a7ZoDiC4tu9","type":"tool_result","content":"     1→/**\n     2→ * Database client module — typed query functions for `rounds` and `operator_events`.\n     3→ *\n     4→ * Phase transitions are unidirectional: created → locked → settling → settled,\n     5→ * or created → expired. The application layer rejects backward transitions.\n     6→ */\n     7→\n     8→import postgres from \"postgres\";\n     9→\n    10→// ---------------------------------------------------------------------------\n    11→// Types\n    12→// ---------------------------------------------------------------------------\n    13→\n    14→export type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    15→\n    16→export type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n    17→export type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n    18→\n    19→export interface CloseCallRound {\n    20→  round_id: string;\n    21→  pda: string;\n    22→  server_key: string;\n    23→  phase: CloseCallPhase;\n    24→  open_price: number;\n    25→  open_price_expo: number;\n    26→  close_price: number | null;\n    27→  outcome: CloseCallOutcome;\n    28→  green_pool: number;\n    29→  red_pool: number;\n    30→  total_fee: number;\n    31→  green_entries: Array<{ player: string; amountLamports: number }>;\n    32→  red_entries: Array<{ player: string; amountLamports: number }>;\n    33→  settle_tx: string | null;\n    34→  created_at: Date;\n    35→  settled_at: Date | null;\n    36→}\n    37→\n    38→export interface InsertCloseCallRoundParams {\n    39→  roundId: string;\n    40→  pda: string;\n    41→  serverKey: string;\n    42→  openPrice: number;\n    43→  openPriceExpo: number;\n    44→}\n    45→\n    46→export type OperatorEventType =\n    47→  | \"secret_generated\"\n    48→  | \"tx_built\"\n    49→  | \"match_detected\"\n    50→  | \"settle_submitted\"\n    51→  | \"settle_confirmed\"\n    52→  | \"settle_failed\"\n    53→  | \"settle_retried\"\n    54→  | \"timeout_detected\";\n    55→\n    56→export interface Round {\n    57→  pda: string;\n    58→  game: string;\n    59→  creator: string;\n    60→  server_key: string;\n    61→  secret: Buffer;\n    62→  commitment: Buffer;\n    63→  amount_lamports: number;\n    64→  side: number;\n    65→  match_id: string;\n    66→  phase: RoundPhase;\n    67→  target_slot: string | null;\n    68→  settle_tx: string | null;\n    69→  settle_attempts: number;\n    70→  result_hash: Buffer | null;\n    71→  result_side: number | null;\n    72→  winner: string | null;\n    73→  entries: unknown | null;\n    74→  created_at: Date;\n    75→  updated_at: Date;\n    76→}\n    77→\n    78→export interface InsertRoundParams {\n    79→  pda: string;\n    80→  game: string;\n    81→  creator: string;\n    82→  serverKey: string;\n    83→  secret: Buffer;\n    84→  commitment: Buffer;\n    85→  amountLamports: number;\n    86→  side: number;\n    87→  matchId: string;\n    88→  phase: RoundPhase;\n    89→  entries?: Array<{ player: string; amountLamports: number }>;\n    90→}\n    91→\n    92→export interface OperatorEvent {\n    93→  id: string;\n    94→  pda: string | null;\n    95→  event_type: OperatorEventType;\n    96→  payload: unknown;\n    97→  created_at: Date;\n    98→}\n    99→\n   100→// ---------------------------------------------------------------------------\n   101→// Transaction types\n   102→// ---------------------------------------------------------------------------\n   103→\n   104→export type TransactionType = \"deposit\" | \"payout\" | \"refund\";\n   105→\n   106→export interface Transaction {\n   107→  id: string;\n   108→  wallet: string;\n   109→  game: string;\n   110→  match_id: string;\n   111→  tx_type: TransactionType;\n   112→  amount_lamports: number;\n   113→  tx_sig: string;\n   114→  created_at: Date;\n   115→}\n   116→\n   117→export interface InsertTransactionParams {\n   118→  wallet: string;\n   119→  game: string;\n   120→  matchId: string;\n   121→  txType: TransactionType;\n   122→  amountLamports: number;\n   123→  txSig: string;\n   124→}\n   125→\n   126→// ---------------------------------------------------------------------------\n   127→// Referral types\n   128→// ---------------------------------------------------------------------------\n   129→\n   130→export interface ReferralCode {\n   131→  id: number;\n   132→  wallet: string;\n   133→  code: string;\n   134→  created_at: Date;\n   135→  updated_at: Date;\n   136→}\n   137→\n   138→export interface ReferralLink {\n   139→  id: number;\n   140→  referrer_wallet: string;\n   141→  referee_wallet: string;\n   142→  created_at: Date;\n   143→}\n   144→\n   145→export interface ReferralEarning {\n   146→  id: number;\n   147→  referrer_wallet: string;\n   148→  referee_wallet: string;\n   149→  round_id: string;\n   150→  game_type: string;\n   151→  wager_lamports: number;\n   152→  fee_lamports: number;\n   153→  referrer_earned_lamports: number;\n   154→  referrer_rate_bps: number;\n   155→  referee_rebate_lamports: number;\n   156→  referee_rebate_rate_bps: number;\n   157→  created_at: Date;\n   158→}\n   159→\n   160→export interface ReferralStats {\n   161→  referred_count: number;\n   162→  active_count: number;\n   163→  total_volume_lamports: string;\n   164→  total_earned_lamports: string;\n   165→  total_rebate_lamports: string;\n   166→  pending_lamports: string;\n   167→}\n   168→\n   169→export interface ReferralClaim {\n   170→  id: string;\n   171→  wallet: string;\n   172→  amount_lamports: string;\n   173→  status: \"pending\" | \"processing\" | \"completed\" | \"failed\";\n   174→  tx_signature: string | null;\n   175→  error: string | null;\n   176→  requested_at: Date;\n   177→  processed_at: Date | null;\n   178→}\n   179→\n   180→// ---------------------------------------------------------------------------\n   181→// Phase transition guard\n   182→// ---------------------------------------------------------------------------\n   183→\n   184→/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n   185→const VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n   186→  created: [\"locked\", \"expired\"],\n   187→  locked: [\"settling\"],\n   188→  settling: [\"settled\"],\n   189→  settled: [],\n   190→  expired: [],\n   191→};\n   192→\n   193→function assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n   194→  const allowed = VALID_TRANSITIONS[from];\n   195→  if (!allowed.includes(to)) {\n   196→    throw new Error(\n   197→      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n   198→    );\n   199→  }\n   200→}\n   201→\n   202→// ---------------------------------------------------------------------------\n   203→// DB client\n   204→// ---------------------------------------------------------------------------\n   205→\n   206→export interface Db {\n   207→  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n   208→  insertRound(params: InsertRoundParams): Promise<Round>;\n   209→\n   210→  /** Delete a round by PDA. Returns true if a row was removed. */\n   211→  deleteRoundByPda(pda: string): Promise<boolean>;\n   212→\n   213→  /** Transition a round's phase. Enforces unidirectional state machine.\n   214→   *  Optional `updates` can set additional columns alongside the phase change. */\n   215→  updateRoundPhase(\n   216→    pda: string,\n   217→    newPhase: RoundPhase,\n   218→    updates?: Partial<\n   219→      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n   220→    >,\n   221→  ): Promise<Round>;\n   222→\n   223→  /** Update the entries JSONB column for a settled round. */\n   224→  updateRoundEntries(\n   225→    pda: string,\n   226→    entries: Array<{ player: string; amountLamports: number }>,\n   227→  ): Promise<Round>;\n   228→\n   229→  /** Get a single round by its PDA. Returns `undefined` if not found. */\n   230→  getRoundByPda(pda: string): Promise<Round | undefined>;\n   231→\n   232→  /** Get all rounds matching a given phase. */\n   233→  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n   234→\n   235→  /** Append an operator event to the audit log. */\n   236→  insertOperatorEvent(\n   237→    pda: string | null,\n   238→    eventType: OperatorEventType,\n   239→    payload?: unknown,\n   240→  ): Promise<OperatorEvent>;\n   241→\n   242→  /** Get the latest operator event for a PDA + type. */\n   243→  getLatestOperatorEvent(\n   244→    pda: string,\n   245→    eventType: OperatorEventType,\n   246→  ): Promise<OperatorEvent | undefined>;\n   247→\n   248→  /** Get a single round by its match_id. Returns `undefined` if not found. */\n   249→  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n   250→\n   251→  /** Batch-fetch the latest operator event per PDA for a given event type. */\n   252→  getLatestOperatorEventsForPdas(\n   253→    pdas: string[],\n   254→    eventType: OperatorEventType,\n   255→  ): Promise<Map<string, OperatorEvent>>;\n   256→\n   257→  /** Get recently settled rounds for a game, ordered newest first. */\n   258→  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n   259→\n   260→  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n   261→  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n   262→\n   263→  // -------------------------------------------------------------------------\n   264→  // Close Call rounds\n   265→  // -------------------------------------------------------------------------\n   266→\n   267→  /** Insert a new Close Call round. */\n   268→  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n   269→\n   270→  /** Get a Close Call round by round_id (16-char hex). */\n   271→  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n   272→\n   273→  /** Get the current active (open) Close Call round. */\n   274→  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n   275→\n   276→  /** Get the most recent settled/refunded Close Call rounds. */\n   277→  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n   278→\n   279→  /** Update a Close Call round after settlement. */\n   280→  settleCloseCallRound(\n   281→    roundId: string,\n   282→    updates: {\n   283→      phase: CloseCallPhase;\n   284→      outcome: CloseCallOutcome;\n   285→      closePrice?: number;\n   286→      greenPool?: number;\n   287→      redPool?: number;\n   288→      totalFee?: number;\n   289→      greenEntries?: Array<{ player: string; amountLamports: number }>;\n   290→      redEntries?: Array<{ player: string; amountLamports: number }>;\n   291→      settleTx?: string;\n   292→    },\n   293→  ): Promise<CloseCallRound>;\n   294→\n   295→  // -------------------------------------------------------------------------\n   296→  // Transactions\n   297→  // -------------------------------------------------------------------------\n   298→\n   299→  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n   300→  insertTransaction(params: InsertTransactionParams): Promise<void>;\n   301→\n   302→  /** Insert multiple transactions in a single batch. */\n   303→  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n   304→\n   305→  /** Get paginated transactions for a wallet, newest first. */\n   306→  getTransactions(\n   307→    wallet: string,\n   308→    cursor?: string,\n   309→    limit?: number,\n   310→    game?: string,\n   311→  ): Promise<Transaction[]>;\n   312→\n   313→  // -------------------------------------------------------------------------\n   314→  // Referral — codes\n   315→  // -------------------------------------------------------------------------\n   316→\n   317→  /** Insert a new referral code for a wallet. Throws on duplicate wallet or code. */\n   318→  insertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n   319→\n   320→  /** Get a wallet's referral code. Returns `undefined` if none set. */\n   321→  getReferralCodeByWallet(wallet: string): Promise<ReferralCode | undefined>;\n   322→\n   323→  /** Look up a referral code record by code string. Returns `undefined` if not found. */\n   324→  getReferralCodeByCode(code: string): Promise<ReferralCode | undefined>;\n   325→\n   326→  /** Set or replace a wallet's referral code (INSERT … ON CONFLICT UPDATE). */\n   327→  upsertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n   328→\n   329→  // -------------------------------------------------------------------------\n   330→  // Referral — links\n   331→  // -------------------------------------------------------------------------\n   332→\n   333→  /** Create a referral link (referrer → referee). Throws on duplicate referee. */\n   334→  insertReferralLink(referrerWallet: string, refereeWallet: string): Promise<ReferralLink>;\n   335→\n   336→  /** Get the referral link for a referee wallet. Returns `undefined` if not referred. */\n   337→  getReferralLinkByReferee(refereeWallet: string): Promise<ReferralLink | undefined>;\n   338→\n   339→  /** Get all referral links where the given wallet is the referrer. */\n   340→  getReferralLinksByReferrer(referrerWallet: string): Promise<ReferralLink[]>;\n   341→\n   342→  // -------------------------------------------------------------------------\n   343→  // Referral — earnings & stats\n   344→  // -------------------------------------------------------------------------\n   345→\n   346→  /** Insert a referral earning row. Throws on duplicate (referee_wallet, round_id). */\n   347→  insertReferralEarning(params: {\n   348→    referrerWallet: string;\n   349→    refereeWallet: string;\n   350→    roundId: string;\n   351→    gameType: string;\n   352→    wagerLamports: number;\n   353→    feeLamports: number;\n   354→    referrerEarnedLamports: number;\n   355→    referrerRateBps: number;\n   356→    refereeRebateLamports: number;\n   357→    refereeRebateRateBps: number;\n   358→  }): Promise<ReferralEarning>;\n   359→\n   360→  /**\n   361→   * Get the pending (unclaimed) balance for a wallet.\n   362→   * Sum of referrer_earned where wallet=referrer + sum of referee_rebate where\n   363→   * wallet=referee, minus sum of completed claims for the wallet.\n   364→   * Returns a lamport string.\n   365→   */\n   366→  getPendingBalance(wallet: string): Promise<string>;\n   367→\n   368→  /** Get paginated per-game earnings for a wallet (as referrer). Newest first. */\n   369→  getReferralEarnings(\n   370→    wallet: string,\n   371→    page: number,\n   372→    limit: number,\n   373→  ): Promise<{ items: ReferralEarning[]; totalPages: number }>;\n   374→\n   375→  /** Get referral summary stats for a wallet. */\n   376→  getReferralStats(wallet: string): Promise<ReferralStats>;\n   377→\n   378→  // -------------------------------------------------------------------------\n   379→  // Referral — claims & rates\n   380→  // -------------------------------------------------------------------------\n   381→\n   382→  /** Insert a new referral claim row (status defaults to 'pending'). Returns the created claim. */\n   383→  insertReferralClaim(\n   384→    wallet: string,\n   385→    amountLamports: string,\n   386→  ): Promise<ReferralClaim>;\n   387→\n   388→  /** Get a referral claim by its UUID. Returns `undefined` if not found. */\n   389→  getReferralClaim(claimId: string): Promise<ReferralClaim | undefined>;\n   390→\n   391→  /**\n   392→   * Update a claim's status and optional metadata (tx_signature, error, processed_at).\n   393→   * Returns the updated claim.\n   394→   */\n   395→  updateClaimStatus(\n   396→    claimId: string,\n   397→    status: ReferralClaim[\"status\"],\n   398→    meta?: { txSignature?: string; error?: string },\n   399→  ): Promise<ReferralClaim>;\n   400→\n   401→  /**\n   402→   * Get the effective referrer rate for a wallet in bps.\n   403→   * Checks `referral_kol_rates` first; falls back to `defaultRateBps`.\n   404→   */\n   405→  getReferrerRate(\n   406→    wallet: string,\n   407→    defaultRateBps: number,\n   408→  ): Promise<number>;\n   409→\n   410→  /**\n   411→   * Execute a function within a database transaction.\n   412→   * All db methods called on the transactional Db share the same transaction.\n   413→   * Rolls back on error, commits on success.\n   414→   */\n   415→  withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T>;\n   416→\n   417→  /** Gracefully close the connection pool. */\n   418→  close(): Promise<void>;\n   419→}\n   420→\n   421→function normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n   422→  return {\n   423→    ...row,\n   424→    open_price: Number(row.open_price),\n   425→    open_price_expo: Number(row.open_price_expo),\n   426→    close_price: row.close_price === null ? null : Number(row.close_price),\n   427→    green_pool: Number(row.green_pool),\n   428→    red_pool: Number(row.red_pool),\n   429→    total_fee: Number(row.total_fee),\n   430→    // JSONB comes back as parsed objects from postgres.js\n   431→    green_entries: Array.isArray(row.green_entries)\n   432→      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   433→      : [],\n   434→    red_entries: Array.isArray(row.red_entries)\n   435→      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   436→      : [],\n   437→  };\n   438→}\n   439→\n   440→function normalizeTransaction(row: Transaction): Transaction {\n   441→  return {\n   442→    ...row,\n   443→    amount_lamports: Number(row.amount_lamports),\n   444→  };\n   445→}\n   446→\n   447→function normalizeReferralEarning(row: ReferralEarning): ReferralEarning {\n   448→  return {\n   449→    ...row,\n   450→    wager_lamports: Number(row.wager_lamports),\n   451→    fee_lamports: Number(row.fee_lamports),\n   452→    referrer_earned_lamports: Number(row.referrer_earned_lamports),\n   453→    referrer_rate_bps: Number(row.referrer_rate_bps),\n   454→    referee_rebate_lamports: Number(row.referee_rebate_lamports),\n   455→    referee_rebate_rate_bps: Number(row.referee_rebate_rate_bps),\n   456→  };\n   457→}\n   458→\n   459→function normalizeRound(row: Round): Round {\n   460→  return {\n   461→    ...row,\n   462→    amount_lamports: Number(row.amount_lamports),\n   463→    side: Number(row.side),\n   464→    settle_attempts: Number(row.settle_attempts),\n   465→    result_side: row.result_side === null ? null : Number(row.result_side),\n   466→    // JSONB comes back as parsed objects from postgres.js\n   467→    entries: Array.isArray(row.entries)\n   468→      ? (row.entries as Array<{ player: string; amountLamports: number }>).map((e) => ({\n   469→          player: e.player,\n   470→          amountLamports: Number(e.amountLamports),\n   471→        }))\n   472→      : null,\n   473→  };\n   474→}\n   475→\n   476→// eslint-disable-next-line @typescript-eslint/no-explicit-any\n   477→export function createDb(databaseUrl: string, _txSql?: any): Db {\n   478→  // eslint-disable-next-line @typescript-eslint/no-explicit-any\n   479→  const sql: any = _txSql ?? postgres(databaseUrl);\n   480→  const _isOwner = !_txSql;\n   481→\n   482→  return {\n   483→    async insertRound(params) {\n   484→      const rows = await sql<Round[]>`\n   485→        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase, entries)\n   486→        VALUES (\n   487→          ${params.pda},\n   488→          ${params.game},\n   489→          ${params.creator},\n   490→          ${params.serverKey},\n   491→          ${params.secret},\n   492→          ${params.commitment},\n   493→          ${params.amountLamports},\n   494→          ${params.side},\n   495→          ${params.matchId},\n   496→          ${params.phase},\n   497→          ${params.entries ? sql.json(params.entries) : null}\n   498→        )\n   499→        RETURNING *\n   500→      `;\n   501→      return normalizeRound(rows[0]!);\n   502→    },\n   503→\n   504→    async deleteRoundByPda(pda) {\n   505→      const rows = await sql<{ pda: string }[]>`\n   506→        DELETE FROM rounds WHERE pda = ${pda}\n   507→        RETURNING pda\n   508→      `;\n   509→      return rows.length > 0;\n   510→    },\n   511→\n   512→    async updateRoundPhase(pda, newPhase, updates) {\n   513→      // Fetch current phase to validate transition\n   514→      const current = await sql<Pick<Round, \"phase\">[]>`\n   515→        SELECT phase FROM rounds WHERE pda = ${pda}\n   516→      `;\n   517→\n   518→      if (current.length === 0) {\n   519→        throw new Error(`Round not found: ${pda}`);\n   520→      }\n   521→\n   522→      const currentPhase = current[0]!.phase as RoundPhase;\n   523→      assertPhaseTransition(currentPhase, newPhase);\n   524→\n   525→      // Build the update — always set phase + updated_at\n   526→      const rows = await sql<Round[]>`\n   527→        UPDATE rounds SET\n   528→          phase = ${newPhase},\n   529→          updated_at = now(),\n   530→          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n   531→          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n   532→          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n   533→          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n   534→          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n   535→          winner = COALESCE(${updates?.winner ?? null}, winner)\n   536→        WHERE pda = ${pda}\n   537→        RETURNING *\n   538→      `;\n   539→\n   540→      return normalizeRound(rows[0]!);\n   541→    },\n   542→\n   543→    async updateRoundEntries(pda, entries) {\n   544→      const rows = await sql<Round[]>`\n   545→        UPDATE rounds SET\n   546→          entries = ${sql.json(entries)},\n   547→          updated_at = now()\n   548→        WHERE pda = ${pda}\n   549→        RETURNING *\n   550→      `;\n   551→      if (rows.length === 0) {\n   552→        throw new Error(`Round not found: ${pda}`);\n   553→      }\n   554→      return normalizeRound(rows[0]!);\n   555→    },\n   556→\n   557→    async getRoundByPda(pda) {\n   558→      const rows = await sql<Round[]>`\n   559→        SELECT * FROM rounds WHERE pda = ${pda}\n   560→      `;\n   561→      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   562→    },\n   563→\n   564→    async getRoundByMatchId(matchId) {\n   565→      const rows = await sql<Round[]>`\n   566→        SELECT * FROM rounds WHERE match_id = ${matchId}\n   567→      `;\n   568→      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   569→    },\n   570→\n   571→    async getRoundsByPhase(phase) {\n   572→      const rows = await sql<Round[]>`\n   573→        SELECT * FROM rounds WHERE phase = ${phase}\n   574→      `;\n   575→      return rows.map(normalizeRound);\n   576→    },\n   577→\n   578→    async insertOperatorEvent(pda, eventType, payload) {\n   579→      const rows = await sql<OperatorEvent[]>`\n   580→        INSERT INTO operator_events (pda, event_type, payload)\n   581→        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n   582→        RETURNING *\n   583→      `;\n   584→      return rows[0]!;\n   585→    },\n   586→\n   587→    async getLatestOperatorEvent(pda, eventType) {\n   588→      const rows = await sql<OperatorEvent[]>`\n   589→        SELECT * FROM operator_events\n   590→        WHERE pda = ${pda} AND event_type = ${eventType}\n   591→        ORDER BY id DESC\n   592→        LIMIT 1\n   593→      `;\n   594→      return rows[0];\n   595→    },\n   596→\n   597→    async getLatestOperatorEventsForPdas(pdas, eventType) {\n   598→      if (pdas.length === 0) return new Map();\n   599→      const rows = await sql<OperatorEvent[]>`\n   600→        SELECT DISTINCT ON (pda) *\n   601→        FROM operator_events\n   602→        WHERE pda = ANY(${pdas}) AND event_type = ${eventType}\n   603→        ORDER BY pda, id DESC\n   604→      `;\n   605→      const map = new Map<string, OperatorEvent>();\n   606→      for (const row of rows) {\n   607→        if (row.pda) map.set(row.pda, row);\n   608→      }\n   609→      return map;\n   610→    },\n   611→\n   612→    async getRecentSettledRounds(game, limit) {\n   613→      const rows = await sql<Round[]>`\n   614→        SELECT * FROM rounds\n   615→        WHERE game = ${game} AND phase = 'settled'\n   616→        ORDER BY updated_at DESC\n   617→        LIMIT ${limit}\n   618→      `;\n   619→      return rows.map(normalizeRound);\n   620→    },\n   621→\n   622→    async getUnsettledStats() {\n   623→      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n   624→        SELECT\n   625→          COUNT(*)::text AS count,\n   626→          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n   627→        FROM rounds\n   628→        WHERE phase NOT IN ('settled', 'expired')\n   629→      `;\n   630→      const row = rows[0]!;\n   631→      return {\n   632→        count: parseInt(row.count, 10),\n   633→        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n   634→      };\n   635→    },\n   636→\n   637→    // -----------------------------------------------------------------------\n   638→    // Close Call rounds\n   639→    // -----------------------------------------------------------------------\n   640→\n   641→    async insertCloseCallRound(params) {\n   642→      const rows = await sql<CloseCallRound[]>`\n   643→        INSERT INTO closecall_rounds (round_id, pda, server_key, open_price, open_price_expo)\n   644→        VALUES (\n   645→          ${params.roundId},\n   646→          ${params.pda},\n   647→          ${params.serverKey},\n   648→          ${params.openPrice},\n   649→          ${params.openPriceExpo}\n   650→        )\n   651→        RETURNING *\n   652→      `;\n   653→      return normalizeCloseCallRound(rows[0]!);\n   654→    },\n   655→\n   656→    async getCloseCallRound(roundId) {\n   657→      const rows = await sql<CloseCallRound[]>`\n   658→        SELECT * FROM closecall_rounds WHERE round_id = ${roundId}\n   659→      `;\n   660→      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n   661→    },\n   662→\n   663→    async getCloseCallCurrentRound() {\n   664→      const rows = await sql<CloseCallRound[]>`\n   665→        SELECT * FROM closecall_rounds\n   666→        WHERE phase = 'open'\n   667→        ORDER BY created_at DESC\n   668→        LIMIT 1\n   669→      `;\n   670→      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n   671→    },\n   672→\n   673→    async getCloseCallHistory(limit) {\n   674→      const rows = await sql<CloseCallRound[]>`\n   675→        SELECT * FROM closecall_rounds\n   676→        WHERE phase IN ('settled', 'refunded')\n   677→        ORDER BY settled_at DESC\n   678→        LIMIT ${limit}\n   679→      `;\n   680→      return rows.map(normalizeCloseCallRound);\n   681→    },\n   682→\n   683→    async settleCloseCallRound(roundId, updates) {\n   684→      const rows = await sql<CloseCallRound[]>`\n   685→        UPDATE closecall_rounds SET\n   686→          phase = ${updates.phase},\n   687→          outcome = ${updates.outcome},\n   688→          close_price = COALESCE(${updates.closePrice ?? null}, close_price),\n   689→          green_pool = COALESCE(${updates.greenPool ?? null}, green_pool),\n   690→          red_pool = COALESCE(${updates.redPool ?? null}, red_pool),\n   691→          total_fee = COALESCE(${updates.totalFee ?? null}, total_fee),\n   692→          green_entries = COALESCE(${updates.greenEntries ? sql.json(updates.greenEntries) : null}, green_entries),\n   693→          red_entries = COALESCE(${updates.redEntries ? sql.json(updates.redEntries) : null}, red_entries),\n   694→          settle_tx = COALESCE(${updates.settleTx ?? null}, settle_tx),\n   695→          settled_at = now()\n   696→        WHERE round_id = ${roundId}\n   697→        RETURNING *\n   698→      `;\n   699→      if (rows.length === 0) {\n   700→        throw new Error(`Close Call round not found: ${roundId}`);\n   701→      }\n   702→      return normalizeCloseCallRound(rows[0]!);\n   703→    },\n   704→\n   705→    // -----------------------------------------------------------------------\n   706→    // Transactions\n   707→    // -----------------------------------------------------------------------\n   708→\n   709→    async insertTransaction(params) {\n   710→      await sql`\n   711→        INSERT INTO transactions (wallet, game, match_id, tx_type, amount_lamports, tx_sig)\n   712→        VALUES (\n   713→          ${params.wallet},\n   714→          ${params.game},\n   715→          ${params.matchId},\n   716→          ${params.txType},\n   717→          ${params.amountLamports},\n   718→          ${params.txSig}\n   719→        )\n   720→        ON CONFLICT DO NOTHING\n   721→      `;\n   722→    },\n   723→\n   724→    async insertTransactions(params) {\n   725→      if (params.length === 0) return;\n   726→      const values = params.map((p) => ({\n   727→        wallet: p.wallet,\n   728→        game: p.game,\n   729→        match_id: p.matchId,\n   730→        tx_type: p.txType,\n   731→        amount_lamports: p.amountLamports,\n   732→        tx_sig: p.txSig,\n   733→      }));\n   734→      await sql`\n   735→        INSERT INTO transactions ${sql(values, \"wallet\", \"game\", \"match_id\", \"tx_type\", \"amount_lamports\", \"tx_sig\")}\n   736→        ON CONFLICT DO NOTHING\n   737→      `;\n   738→    },\n   739→\n   740→    async getTransactions(wallet, cursor, limit = 20, game) {\n   741→      const effectiveLimit = Math.min(limit, 50);\n   742→      if (cursor && game) {\n   743→        const rows = await sql<Transaction[]>`\n   744→          SELECT * FROM transactions\n   745→          WHERE wallet = ${wallet} AND id < ${cursor} AND game = ${game}\n   746→          ORDER BY id DESC\n   747→          LIMIT ${effectiveLimit}\n   748→        `;\n   749→        return rows.map(normalizeTransaction);\n   750→      }\n   751→      if (cursor) {\n   752→        const rows = await sql<Transaction[]>`\n   753→          SELECT * FROM transactions\n   754→          WHERE wallet = ${wallet} AND id < ${cursor}\n   755→          ORDER BY id DESC\n   756→          LIMIT ${effectiveLimit}\n   757→        `;\n   758→        return rows.map(normalizeTransaction);\n   759→      }\n   760→      if (game) {\n   761→        const rows = await sql<Transaction[]>`\n   762→          SELECT * FROM transactions\n   763→          WHERE wallet = ${wallet} AND game = ${game}\n   764→          ORDER BY id DESC\n   765→          LIMIT ${effectiveLimit}\n   766→        `;\n   767→        return rows.map(normalizeTransaction);\n   768→      }\n   769→      const rows = await sql<Transaction[]>`\n   770→        SELECT * FROM transactions\n   771→        WHERE wallet = ${wallet}\n   772→        ORDER BY id DESC\n   773→        LIMIT ${effectiveLimit}\n   774→      `;\n   775→      return rows.map(normalizeTransaction);\n   776→    },\n   777→\n   778→    // -----------------------------------------------------------------------\n   779→    // Referral — codes\n   780→    // -----------------------------------------------------------------------\n   781→\n   782→    async insertReferralCode(wallet, code) {\n   783→      const rows = await sql<ReferralCode[]>`\n   784→        INSERT INTO referral_codes (wallet, code)\n   785→        VALUES (${wallet}, ${code})\n   786→        RETURNING *\n   787→      `;\n   788→      return rows[0]!;\n   789→    },\n   790→\n   791→    async getReferralCodeByWallet(wallet) {\n   792→      const rows = await sql<ReferralCode[]>`\n   793→        SELECT * FROM referral_codes WHERE wallet = ${wallet}\n   794→      `;\n   795→      return rows[0];\n   796→    },\n   797→\n   798→    async getReferralCodeByCode(code) {\n   799→      const rows = await sql<ReferralCode[]>`\n   800→        SELECT * FROM referral_codes WHERE code = ${code}\n   801→      `;\n   802→      return rows[0];\n   803→    },\n   804→\n   805→    async upsertReferralCode(wallet, code) {\n   806→      const rows = await sql<ReferralCode[]>`\n   807→        INSERT INTO referral_codes (wallet, code)\n   808→        VALUES (${wallet}, ${code})\n   809→        ON CONFLICT (wallet) DO UPDATE SET\n   810→          code = ${code},\n   811→          updated_at = now()\n   812→        RETURNING *\n   813→      `;\n   814→      return rows[0]!;\n   815→    },\n   816→\n   817→    // -- Referral links -------------------------------------------------------\n   818→\n   819→    async insertReferralLink(referrerWallet, refereeWallet) {\n   820→      const rows = await sql<ReferralLink[]>`\n   821→        INSERT INTO referral_links (referrer_wallet, referee_wallet)\n   822→        VALUES (${referrerWallet}, ${refereeWallet})\n   823→        RETURNING *\n   824→      `;\n   825→      return rows[0]!;\n   826→    },\n   827→\n   828→    async getReferralLinkByReferee(refereeWallet) {\n   829→      const rows = await sql<ReferralLink[]>`\n   830→        SELECT * FROM referral_links WHERE referee_wallet = ${refereeWallet}\n   831→      `;\n   832→      return rows[0];\n   833→    },\n   834→\n   835→    async getReferralLinksByReferrer(referrerWallet) {\n   836→      const rows = await sql<ReferralLink[]>`\n   837→        SELECT * FROM referral_links WHERE referrer_wallet = ${referrerWallet}\n   838→        ORDER BY created_at DESC\n   839→      `;\n   840→      return rows;\n   841→    },\n   842→\n   843→    // -- Referral earnings & stats --------------------------------------------\n   844→\n   845→    async insertReferralEarning(params) {\n   846→      const rows = await sql<ReferralEarning[]>`\n   847→        INSERT INTO referral_earnings (\n   848→          referrer_wallet, referee_wallet, round_id, game_type,\n   849→          wager_lamports, fee_lamports,\n   850→          referrer_earned_lamports, referrer_rate_bps,\n   851→          referee_rebate_lamports, referee_rebate_rate_bps\n   852→        ) VALUES (\n   853→          ${params.referrerWallet}, ${params.refereeWallet}, ${params.roundId}, ${params.gameType},\n   854→          ${params.wagerLamports}, ${params.feeLamports},\n   855→          ${params.referrerEarnedLamports}, ${params.referrerRateBps},\n   856→          ${params.refereeRebateLamports}, ${params.refereeRebateRateBps}\n   857→        )\n   858→        RETURNING *\n   859→      `;\n   860→      return normalizeReferralEarning(rows[0]!);\n   861→    },\n   862→\n   863→    async getPendingBalance(wallet) {\n   864→      const rows = await sql<{ pending: string }[]>`\n   865→        SELECT COALESCE(\n   866→          (\n   867→            SELECT SUM(referrer_earned_lamports)\n   868→            FROM referral_earnings WHERE referrer_wallet = ${wallet}\n   869→          ), 0\n   870→        ) + COALESCE(\n   871→          (\n   872→            SELECT SUM(referee_rebate_lamports)\n   873→            FROM referral_earnings WHERE referee_wallet = ${wallet}\n   874→          ), 0\n   875→        ) - COALESCE(\n   876→          (\n   877→            SELECT SUM(amount_lamports)\n   878→            FROM referral_claims WHERE wallet = ${wallet} AND status IN ('pending', 'processing', 'completed')\n   879→          ), 0\n   880→        ) AS pending\n   881→      `;\n   882→      return rows[0]!.pending;\n   883→    },\n   884→\n   885→    async getReferralEarnings(wallet, page, limit) {\n   886→      const offset = (page - 1) * limit;\n   887→      const [countRows, rows] = await Promise.all([\n   888→        sql<{ count: string }[]>`\n   889→          SELECT COUNT(*)::TEXT AS count FROM referral_earnings\n   890→          WHERE referrer_wallet = ${wallet}\n   891→        `,\n   892→        sql<ReferralEarning[]>`\n   893→          SELECT * FROM referral_earnings\n   894→          WHERE referrer_wallet = ${wallet}\n   895→          ORDER BY created_at DESC\n   896→          LIMIT ${limit} OFFSET ${offset}\n   897→        `,\n   898→      ]);\n   899→      const total = Number(countRows[0]!.count);\n   900→      const totalPages = Math.max(1, Math.ceil(total / limit));\n   901→      return { items: rows.map(normalizeReferralEarning), totalPages };\n   902→    },\n   903→\n   904→    async getReferralStats(wallet) {\n   905→      const rows = await sql<ReferralStats[]>`\n   906→        SELECT\n   907→          (SELECT COUNT(*) FROM referral_links WHERE referrer_wallet = ${wallet})::INT\n   908→            AS referred_count,\n   909→          (\n   910→            SELECT COUNT(DISTINCT re.referee_wallet)\n   911→            FROM referral_earnings re\n   912→            JOIN referral_links rl ON rl.referee_wallet = re.referee_wallet AND rl.referrer_wallet = ${wallet}\n   913→            WHERE re.created_at > now() - INTERVAL '7 days'\n   914→          )::INT AS active_count,\n   915→          COALESCE(\n   916→            (\n   917→              SELECT SUM(re.wager_lamports)::TEXT\n   918→              FROM referral_earnings re\n   919→              JOIN referral_links rl ON rl.referee_wallet = re.referee_wallet AND rl.referrer_wallet = ${wallet}\n   920→            ), '0'\n   921→          ) AS total_volume_lamports,\n   922→          COALESCE(\n   923→            (SELECT SUM(referrer_earned_lamports)::TEXT FROM referral_earnings WHERE referrer_wallet = ${wallet}),\n   924→            '0'\n   925→          ) AS total_earned_lamports,\n   926→          COALESCE(\n   927→            (SELECT SUM(referee_rebate_lamports)::TEXT FROM referral_earnings WHERE referee_wallet = ${wallet}),\n   928→            '0'\n   929→          ) AS total_rebate_lamports,\n   930→          (\n   931→            COALESCE((SELECT SUM(referrer_earned_lamports) FROM referral_earnings WHERE referrer_wallet = ${wallet}), 0)\n   932→            + COALESCE((SELECT SUM(referee_rebate_lamports) FROM referral_earnings WHERE referee_wallet = ${wallet}), 0)\n   933→            - COALESCE((SELECT SUM(amount_lamports) FROM referral_claims WHERE wallet = ${wallet} AND status IN ('pending','processing','completed')), 0)\n   934→          )::TEXT AS pending_lamports\n   935→      `;\n   936→      return rows[0]!;\n   937→    },\n   938→\n   939→    // -----------------------------------------------------------------------\n   940→    // Referral — claims & rates\n   941→    // -----------------------------------------------------------------------\n   942→\n   943→    async insertReferralClaim(wallet, amountLamports) {\n   944→      const rows = await sql<ReferralClaim[]>`\n   945→        INSERT INTO referral_claims (wallet, amount_lamports, status)\n   946→        VALUES (${wallet}, ${amountLamports}, 'pending')\n   947→        RETURNING *\n   948→      `;\n   949→      return rows[0]!;\n   950→    },\n   951→\n   952→    async getReferralClaim(claimId) {\n   953→      const rows = await sql<ReferralClaim[]>`\n   954→        SELECT * FROM referral_claims WHERE id = ${claimId}\n   955→      `;\n   956→      return rows[0];\n   957→    },\n   958→\n   959→    async updateClaimStatus(claimId, status, meta) {\n   960→      const rows = await sql<ReferralClaim[]>`\n   961→        UPDATE referral_claims\n   962→        SET\n   963→          status = ${status},\n   964→          tx_signature = COALESCE(${meta?.txSignature ?? null}, tx_signature),\n   965→          error = COALESCE(${meta?.error ?? null}, error),\n   966→          processed_at = ${status === \"completed\" || status === \"failed\" ? sql`now()` : sql`processed_at`}\n   967→        WHERE id = ${claimId}\n   968→        RETURNING *\n   969→      `;\n   970→      return rows[0]!;\n   971→    },\n   972→\n   973→    async getReferrerRate(wallet, defaultRateBps) {\n   974→      const rows = await sql<{ rate_bps: number }[]>`\n   975→        SELECT rate_bps FROM referral_kol_rates WHERE wallet = ${wallet}\n   976→      `;\n   977→      return rows[0]?.rate_bps ?? defaultRateBps;\n   978→    },\n   979→\n   980→    async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {\n   981→      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n   982→      return sql.begin(async (txSql: any) => fn(createDb(databaseUrl, txSql)));\n   983→    },\n   984→\n   985→    async close() {\n   986→      if (_isOwner) await sql.end();\n   987→    },\n   988→  };\n   989→}\n   990→"}]},"parent_tool_use_id":"toolu_01UouSjWLoexuEH21J3HZK7R","session_id":"8cdd94d4-4d50-4151-8136-428429db5806","uuid":"13d0c1e6-5bd5-4e4d-af6a-3b48cef4b8c8","timestamp":"2026-03-25T15:26:40.012Z"}
