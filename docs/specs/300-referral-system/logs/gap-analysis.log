{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WSXCx7PJ4KdgT3jGxetHcL","type":"tool_result","content":"     1→import { Keypair } from \"@solana/web3.js\";\n     2→import { applyDbSchemaToUrl, loadDbSchemaFromEnv } from \"./db-config.js\";\n     3→\n     4→export interface Config {\n     5→  port: number;\n     6→  databaseUrl: string;\n     7→  dbSchema: string;\n     8→  rpcUrl: string;\n     9→  wsRpcUrl: string | undefined;\n    10→  serverKeypair: Keypair;\n    11→  jwtSecret: Uint8Array;\n    12→  cluster: string;\n    13→  challengeTtlSeconds: number;\n    14→  accessTokenTtlSeconds: number;\n    15→  refreshTokenTtlDays: number;\n    16→  rateLimitPerWallet: number;\n    17→  rateLimitGlobal: number;\n    18→  workerPollIntervalMs: number;\n    19→  entropyAccount: string;\n    20→  pythBtcUsdAccount: string;\n    21→  minSolBalance: number;\n    22→  eventQueuePollMs: number;\n    23→  referralDefaultRateBps: number;\n    24→  referralMinClaimLamports: number;\n    25→}\n    26→\n    27→function requireEnv(name: string): string {\n    28→  const value = process.env[name];\n    29→  if (!value) {\n    30→    throw new Error(`Missing required environment variable: ${name}`);\n    31→  }\n    32→  return value;\n    33→}\n    34→\n    35→function parseKeypair(raw: string): Keypair {\n    36→  try {\n    37→    const bytes = JSON.parse(raw) as number[];\n    38→    return Keypair.fromSecretKey(Uint8Array.from(bytes));\n    39→  } catch {\n    40→    throw new Error(\n    41→      \"SERVER_KEYPAIR must be a JSON array of secret key bytes (e.g. from solana-keygen)\"\n    42→    );\n    43→  }\n    44→}\n    45→\n    46→export function loadConfig(): Config {\n    47→  const dbSchema = loadDbSchemaFromEnv();\n    48→\n    49→  return {\n    50→    port: parseInt(process.env.PORT ?? \"3100\", 10),\n    51→    databaseUrl: applyDbSchemaToUrl(requireEnv(\"DATABASE_URL\"), dbSchema),\n    52→    dbSchema,\n    53→    rpcUrl: requireEnv(\"RPC_URL\"),\n    54→    wsRpcUrl: process.env.WS_RPC_URL || undefined,\n    55→    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    56→    jwtSecret: (() => {\n    57→      const explicit = process.env.JWT_SECRET;\n    58→      if (explicit) return new TextEncoder().encode(explicit);\n    59→      // Derive from first 32 bytes of server keypair secret key\n    60→      const kp = parseKeypair(requireEnv(\"SERVER_KEYPAIR\"));\n    61→      return kp.secretKey.slice(0, 32);\n    62→    })(),\n    63→    cluster: process.env.SOLANA_CLUSTER ?? \"devnet\",\n    64→    challengeTtlSeconds: parseInt(\n    65→      process.env.CHALLENGE_TTL_SECONDS ?? \"300\",\n    66→      10,\n    67→    ),\n    68→    accessTokenTtlSeconds: parseInt(\n    69→      process.env.ACCESS_TOKEN_TTL_SECONDS ?? \"86400\",\n    70→      10,\n    71→    ),\n    72→    refreshTokenTtlDays: parseInt(\n    73→      process.env.REFRESH_TOKEN_TTL_DAYS ?? \"14\",\n    74→      10,\n    75→    ),\n    76→    rateLimitPerWallet: parseInt(\n    77→      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n    78→      10,\n    79→    ),\n    80→    rateLimitGlobal: parseInt(\n    81→      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n    82→      10,\n    83→    ),\n    84→    workerPollIntervalMs: parseInt(\n    85→      process.env.WORKER_POLL_INTERVAL_MS ?? \"1000\",\n    86→      10,\n    87→    ),\n    88→    entropyAccount: process.env.ENTROPY_ACCOUNT ?? \"SysvarS1otHashes111111111111111111111111111\",\n    89→    pythBtcUsdAccount: process.env.PYTH_BTC_USD_ACCOUNT ?? \"4cSM2e6rvbGQUFiJbqytoVMi5GgghSMr8LwVrT9VPSPo\",\n    90→    minSolBalance: parseFloat(process.env.MIN_SOL_BALANCE ?? \"0.1\"),\n    91→    eventQueuePollMs: parseInt(\n    92→      process.env.EVENT_QUEUE_POLL_MS ?? \"1500\",\n    93→      10,\n    94→    ),\n    95→    referralDefaultRateBps: parseInt(\n    96→      process.env.REFERRAL_DEFAULT_RATE_BPS ?? \"1000\",\n    97→      10,\n    98→    ),\n    99→    referralMinClaimLamports: parseInt(\n   100→      process.env.REFERRAL_MIN_CLAIM_LAMPORTS ?? \"10000000\",\n   101→      10,\n   102→    ),\n   103→  };\n   104→}\n   105→"}]},"parent_tool_use_id":"toolu_01UouSjWLoexuEH21J3HZK7R","session_id":"8cdd94d4-4d50-4151-8136-428429db5806","uuid":"c52416fa-2fa7-49ae-a358-a7c7dd21d048","timestamp":"2026-03-25T15:26:48.842Z"}
