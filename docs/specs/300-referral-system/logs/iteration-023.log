{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TuBKduAPJUzkKK3CZc8k6g","type":"tool_result","content":"     1→import { useSession } from \"../../context/SessionContext\";\n     2→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n     3→\n     4→export function ReferralPage() {\n     5→  const { isAuthenticated } = useSession();\n     6→  const { connected } = useWallet();\n     7→\n     8→  if (!connected || !isAuthenticated) {\n     9→    return (\n    10→      <div className=\"referral-page\">\n    11→        <div className=\"referral-page__connect\">\n    12→          <h2>Referral Program</h2>\n    13→          <p>\n    14→            Earn <strong>10% of the platform fee</strong> from every game your\n    15→            referred players complete — forever. Your referees get a{\" \"}\n    16→            <strong>10% fee rebate</strong> on all their games too.\n    17→          </p>\n    18→          <p>Connect your wallet to get started.</p>\n    19→        </div>\n    20→      </div>\n    21→    );\n    22→  }\n    23→\n    24→  return (\n    25→    <div className=\"referral-page\">\n    26→      <div className=\"referral-page__header\">\n    27→        <h1 className=\"referral-page__title\">Referrals</h1>\n    28→        <p className=\"referral-page__subtitle\">\n    29→          Share your link, earn from every game your friends play\n    30→        </p>\n    31→      </div>\n    32→\n    33→      <div className=\"referral-page__content\">\n    34→        {/* §1: Your Referral Link card — implemented in next iteration */}\n    35→        {/* §2: Stats summary card — implemented in next iteration */}\n    36→        {/* §3: Pending balance + Claim card — implemented in next iteration */}\n    37→        {/* §4: Earnings history table — implemented in next iteration */}\n    38→      </div>\n    39→    </div>\n    40→  );\n    41→}\n    42→"}]},"parent_tool_use_id":"toolu_01HJYyPVmgRqEZ5vMykm41zt","session_id":"f0103f33-7014-49be