{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LxGqt3tQL5TAttv8KhK4Ey","type":"tool_result","content":"     1→/**\n     2→ * Integration test: full create → join → settle lifecycle.\n     3→ *\n     4→ * Uses a mock Solana Connection to simulate on-chain state while exercising\n     5→ * the real HTTP endpoints, database, settlement worker, and retry logic\n     6→ * end-to-end. Auth uses JWT Bearer tokens (HS256).\n     7→ */\n     8→\n     9→import { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n    10→import { Hono } from \"hono\";\n    11→import {\n    12→  Keypair,\n    13→  PublicKey,\n    14→  SystemProgram,\n    15→  LAMPORTS_PER_SOL,\n    16→} from \"@solana/web3.js\";\n    17→import type { Connection } from \"@solana/web3.js\";\n    18→import bs58 from \"bs58\";\n    19→import { SignJWT } from \"jose\";\n    20→import postgres from \"postgres\";\n    21→import { createDb, type Db } from \"../db.js\";\n    22→import { createCoinflipRoutes } from \"../routes/create.js\";\n    23→import { createRoundsRoutes } from \"../routes/rounds.js\";\n    24→import { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n    25→import { createSettlementWorker } from \"../worker/settlement.js\";\n    26→import { settleMatch } from \"../worker/settle-tx.js\";\n    27→import { createRetrySettler } from \"../worker/retry.js\";\n    28→import { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n    29→import { encodeCoinflipMatch, encodeCoinflipConfig } from \"../worker/account-decoder.js\";\n    30→\n    31→// ---------------------------------------------------------------------------\n    32→// Constants\n    33→// ---------------------------------------------------------------------------\n    34→\n    35→const DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n    36→const AMOUNT_LAMPORTS = 5_000_000;\n    37→const AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\n    38→const SIDE_HEADS = 0;\n    39→const PHASE_LOCKED = 1;\n    40→const JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n    41→\n    42→// ---------------------------------------------------------------------------\n    43→// JWT helper\n    44→// ---------------------------------------------------------------------------\n    45→\n    46→async function makeJwt(wallet: string) {\n    47→  const now = Math.floor(Date.now() / 1000);\n    48→  return new SignJWT({ sub: wallet })\n    49→    .setProtectedHeader({ alg: \"HS256\" })\n    50→    .setIssuedAt(now)\n    51→    .setExpirationTime(now + 3600)\n    52→    .sign(JWT_SECRET);\n    53→}\n    54→\n    55→// ---------------------------------------------------------------------------\n    56→// Mock Connection\n    57→// ---------------------------------------------------------------------------\n    58→\n    59→/**\n    60→ * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n    61→ * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n    62→ * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n    63→ */\n    64→class MockConnection {\n    65→  private _slot = 200;\n    66→  private _accounts = new Map<\n    67→    string,\n    68→    {\n    69→      data: Buffer;\n    70→      lamports: number;\n    71→      owner: PublicKey;\n    72→      executable: boolean;\n    73→    }\n    74→  >();\n    75→  lastRawTx: Buffer | null = null;\n    76→\n    77→  set slot(s: number) {\n    78→    this._slot = s;\n    79→  }\n    80→  get slot() {\n    81→    return this._slot;\n    82→  }\n    83→\n    84→  setAccount(\n    85→    pubkey: PublicKey,\n    86→    data: Buffer,\n    87→    opts?: { lamports?: number; owner?: PublicKey },\n    88→  ) {\n    89→    this._accounts.set(pubkey.toBase58(), {\n    90→      data,\n    91→      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n    92→      owner: opts?.owner ?? SystemProgram.programId,\n    93→      executable: false,\n    94→    });\n    95→  }\n    96→\n    97→  removeAccount(pubkey: PublicKey) {\n    98→    this._accounts.delete(pubkey.toBase58());\n    99→  }\n   100→"}]},"parent_tool_use_id":null,"session_id":"773e2b1e-9c3d-4d53-809d-a95c06988ae7","uuid":"aeb09a90-8968-4ca7-81cc-92f7153c625e","timestamp":"2026-03-25T13:57:11.400Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/integration.test.ts","content":"/**\n * Integration test: full create → join → settle lifecycle.\n *\n * Uses a mock Solana Connection to simulate on-chain state while exercising\n * the real HTTP endpoints, database, settlement worker, and retry logic\n * end-to-end. Auth uses JWT Bearer tokens (HS256).\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport {\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  LAMPORTS_PER_SOL,\n} from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport bs58 from \"bs58\";\nimport { SignJWT } from \"jose\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createCoinflipRoutes } from \"../routes/create.js\";\nimport { createRoundsRoutes } from \"../routes/rounds.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport { createSettlementWorker } from \"../worker/settlement.js\";\nimport { settleMatch } from \"../worker/settle-tx.js\";\nimport { createRetrySettler } from \"../worker/retry.js\";\nimport { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\nimport { encodeCoinflipMatch, encodeCoinflipConfig } from \"../worker/account-decoder.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\nconst AMOUNT_LAMPORTS = 5_000_000;\nconst AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\nconst SIDE_HEADS = 0;\nconst PHASE_LOCKED = 1;\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n\n// ---------------------------------------------------------------------------\n// JWT helper\n// ---------------------------------------------------------------------------\n\nasync function makeJwt(wallet: string) {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({ sub: wallet })\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setIssuedAt(now)\n    .setExpirationTime(now + 3600)\n    .sign(JWT_SECRET);\n}\n\n// ---------------------------------------------------------------------------\n// Mock Connection\n// ---------------------------------------------------------------------------\n\n/**\n * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n */\nclass MockConnection {\n  private _slot = 200;\n  private _accounts = new Map<\n    string,\n    {\n      data: Buffer;\n      lamports: number;\n      owner: PublicKey;\n      executable: boolean;\n    }\n  >();\n  lastRawTx: Buffer | null = null;\n\n  set slot(s: number) {\n    this._slot = s;\n  }\n  get slot() {\n    return this._slot;\n  }\n\n  setAccount(\n    pubkey: PublicKey,\n    data: Buffer,\n    opts?: { lamports?: number; owner?: PublicKey },\n  ) {\n    this._accounts.set(pubkey.toBase58(), {\n      data,\n      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n      owner: opts?.owner ?? SystemProgram.programId,\n      executable: false,\n    });\n  }\n\n  removeAccount(pubkey: PublicKey) {\n    this._accounts.delete(pubkey.toBase58());\n  }\n","numLines":100,"startLine":1,"totalLines":557}}}
