{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MfqVS6ufoDkEnBggtSy4o1","type":"tool_result","content":"     1→/**\n     2→ * Settle transaction builder + submission.\n     3→ *\n     4→ * Retrieves the stored secret, reads on-chain match + config data to resolve\n     5→ * all accounts, builds the `settle` instruction, submits it, and updates the\n     6→ * DB on confirmation.\n     7→ */\n     8→\n     9→import { createHash } from \"node:crypto\";\n    10→import { performance } from \"node:perf_hooks\";\n    11→import {\n    12→  Connection,\n    13→  Keypair,\n    14→  PublicKey,\n    15→  SystemProgram,\n    16→  Transaction,\n    17→  TransactionInstruction,\n    18→} from \"@solana/web3.js\";\n    19→import type { Db } from \"../db.js\";\n    20→import { logger } from \"../logger.js\";\n    21→import { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n    22→import { derivePlatformConfigPda, getPlatformConfig } from \"../platform-config.js\";\n    23→import { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@rng-utopia/anchor-client\";\n    24→import {\n    25→  decodeCoinflipMatch,\n    26→  decodeLordRound,\n    27→  type DecodedJackpotRound,\n    28→} from \"./account-decoder.js\";\n    29→\n    30→// ---------------------------------------------------------------------------\n    31→// Instruction discriminators (from IDL — no hardcoded byte arrays)\n    32→// ---------------------------------------------------------------------------\n    33→\n    34→function getInstructionDiscriminator(\n    35→  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n    36→  instructionName: string,\n    37→): Buffer {\n    38→  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n    39→  if (!instruction) {\n    40→    throw new Error(`Instruction ${instructionName} not found in IDL`);\n    41→  }\n    42→  return Buffer.from(instruction.discriminator);\n    43→}\n    44→\n    45→const SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\n    46→const CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n    47→  lordIdl,\n    48→  \"claim_payout\",\n    49→);\n    50→const CC_BET_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"bet\");\n    51→const CC_SETTLE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"settle_round\");\n    52→const CC_TIMEOUT_REFUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"timeout_refund\");\n    53→\n    54→// ---------------------------------------------------------------------------\n    55→// Types\n    56→// ---------------------------------------------------------------------------\n    57→\n    58→export interface SettleTxDeps {\n    59→  db: Db;\n    60→  connection: Connection;\n    61→  serverKeypair: Keypair;\n    62→  entropyAccount: PublicKey;\n    63→  referralDefaultRateBps: number;\n    64→}\n    65→\n    66→export interface SettleResult {\n    67→  txSignature: string;\n    68→  resultHash: Buffer;\n    69→  resultSide?: number;\n    70→  winningEntryIndex?: number;\n    71→  winner: string;\n    72→}\n    73→\n    74→// ---------------------------------------------------------------------------\n    75→// Instruction encoding\n    76→// ---------------------------------------------------------------------------\n    77→\n    78→/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\n    79→function encodeSettleData(secret: Buffer): Buffer {\n    80→  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n    81→}\n    82→\n    83→function encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n    84→  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n    85→}\n    86→\n    87→// ---------------------------------------------------------------------------\n    88→// Result derivation (mirrors on-chain derive_result)\n    89→// ---------------------------------------------------------------------------\n    90→\n    91→/**\n    92→ * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n    93→ * Must match shared/src/fairness.rs `derive_result()`.\n    94→ */\n    95→function deriveResult(\n    96→  secret: Buffer,\n    97→  entropy: Buffer,\n    98→  matchPdaBytes: Buffer,\n    99→  algoVer: number,\n   100→): Buffer {\n   101→  return createHash(\"sha256\")\n   102→    .update(secret)\n   103→    .update(entropy)\n   104→    .update(matchPdaBytes)\n   105→    .update(Buffer.from([algoVer]))\n   106→    .digest();\n   107→}\n   108→\n   109→// ---------------------------------------------------------------------------\n   110→// Referral earnings hook\n   111→// ---------------------------------------------------------------------------\n   112→\n   113→/**\n   114→ * After a game settles, check each player for a referrer and record\n   115→ * referral earnings if applicable.\n   116→ *\n   117→ * For each unique player: look up referral link → if referrer exists,\n   118→ * calculate referrer earning + referee rebate → insert into referral_earnings.\n   119→ *\n   120→ * Errors are logged but never bubble — referral recording must not fail settlement.\n   121→ * The UNIQUE(referee_wallet, round_id) constraint provides idempotency on retries.\n   122→ */\n   123→async function recordReferralEarnings(\n   124→  db: Db,\n   125→  params: {\n   126→    roundId: string;\n   127→    gameType: string;\n   128→    feeBps: number;\n   129→    referralDefaultRateBps: number;\n   130→    players: Array<{ wallet: string; wagerLamports: number }>;\n   131→  },\n   132→): Promise<void> {\n   133→  const { roundId, gameType, feeBps, referralDefaultRateBps, players } = params;\n   134→\n   135→  // Deduplicate players (Lord of RNGs can have multiple entries per player)\n   136→  const playerWagers = new Map<string, number>();\n   137→  for (const p of players) {\n   138→    playerWagers.set(p.wallet, (playerWagers.get(p.wallet) ?? 0) + p.wagerLamports);\n   139→  }\n   140→\n   141→  for (const [wallet, wagerLamports] of playerWagers) {\n   142→    try {\n   143→      const link = await db.getReferralLinkByReferee(wallet);\n   144→      if (!link) continue;\n   145→\n   146→      const referrerWallet = link.referrer_wallet;\n   147→      const referrerRateBps = await db.getReferrerRate(\n   148→        referrerWallet,\n   149→        referralDefaultRateBps,\n   150→      );\n   151→\n   152→      const feeLamports = Math.floor((wagerLamports * feeBps) / 10_000);\n   153→      const referrerEarnedLamports = Math.floor(\n   154→        (feeLamports * referrerRateBps) / 10_000,\n   155→      );\n   156→      const refereeRebateLamports = Math.floor((feeLamports * 1000) / 10_000);\n   157→\n   158→      await db.insertReferralEarning({\n   159→        referrerWallet,\n   160→        refereeWallet: wallet,\n   161→        roundId,\n   162→        gameType,\n   163→        wagerLamports,\n   164→        feeLamports,\n   165→        referrerEarnedLamports,\n   166→        referrerRateBps,\n   167→        refereeRebateLamports,\n   168→        refereeRebateRateBps: 1000, // fixed 10% for v1\n   169→      });\n   170→\n   171→      logger.info(\"referral earning recorded\", {\n   172→        roundId,\n   173→        gameType,\n   174→        referrer: referrerWallet,\n   175→        referee: wallet,\n   176→        referrerEarnedLamports,\n   177→        refereeRebateLamports,\n   178→      });\n   179→    } catch (err: unknown) {\n   180→      const msg = err instanceof Error ? err.message : String(err);\n   181→      if (msg.includes(\"duplicate key\") || msg.includes(\"unique constraint\")) {\n   182→        logger.info(\"referral earning already recorded (idempotent skip)\", {\n   183→          roundId,\n   184→          wallet,\n   185→        });\n   186→      } else {\n   187→        logger.error(\"failed to record referral earning\", {\n   188→          roundId,\n   189→          wallet,\n   190→          error: msg,\n   191→        });\n   192→      }\n   193→    }\n   194→  }\n   195→}\n   196→\n   197→// ---------------------------------------------------------------------------\n   198→// Core settle function\n   199→// ---------------------------------------------------------------------------\n   200→\n   201→/**\n   202→ * Build, submit, and confirm a settle transaction for a locked match.\n   203→ *\n   204→ * Steps:\n   205→ * 1. Retrieve secret from DB\n   206→ * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n   207→ * 3. Fetch config account data (treasury)\n   208→ * 4. Read entropy from the entropy account\n   209→ * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n   210→ * 6. Build + submit settle tx\n   211→ * 7. Update DB on confirmation\n   212→ */\n   213→export async function settleMatch(\n   214→  deps: SettleTxDeps,\n   215→  pda: string,\n   216→): Promise<SettleResult> {\n   217→  const t0 = performance.now();\n   218→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   219→  const matchPubkey = new PublicKey(pda);\n   220→\n   221→  // 1. Retrieve secret from DB\n   222→  const round = await db.getRoundByPda(pda);\n   223→  const tDb = performance.now();\n   224→  if (!round) {\n   225→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   226→  }\n   227→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   228→    throw new PermanentSettleError(\n   229→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   230→    );\n   231→  }\n   232→\n   233→  const secret = Buffer.from(round.secret);\n   234→\n   235→  // Transition to settling (locked → settling)\n   236→  if (round.phase === \"locked\") {\n   237→    await db.updateRoundPhase(pda, \"settling\");\n   238→  }\n   239→\n   240→  // Log settle_submitted\n   241→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   242→    attempt: round.settle_attempts + 1,\n   243→  });\n   244→\n   245→  // 2-4. Fetch match, platform config, entropy, and blockhash in parallel\n   246→  const [platformConfigPda] = derivePlatformConfigPda();\n   247→  const [matchAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n   248→    await Promise.all([\n   249→      connection.getAccountInfo(matchPubkey),\n   250→      getPlatformConfig(connection),\n   251→      connection.getAccountInfo(entropyAccount),\n   252→      connection.getLatestBlockhash(),\n   253→    ]);\n   254→  const tFetch = performance.now();\n   255→\n   256→  if (!matchAccountInfo) {\n   257→    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n   258→  }\n   259→  if (!entropyInfo) {\n   260→    throw new TransientSettleError(\"Entropy account not available yet\");\n   261→  }\n   262→\n   263→  // IDL-driven decode — no manual byte offsets\n   264→  const match = decodeCoinflipMatch(Buffer.from(matchAccountInfo.data));\n   265→  const { feeBps, treasury } = platformConfig;\n   266→\n   267→  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer } = match;\n   268→\n   269→  const pool = entryAmount * 2n;\n   270→  const feeAmount = Number((pool * BigInt(feeBps)) / 10_000n);\n   271→  const payoutAmount = Number(pool) - feeAmount;\n   272→\n   273→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   274→\n   275→  // 5. Pre-compute result\n   276→  const matchPdaBytes = matchPubkey.toBuffer();\n   277→  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n   278→  const resultSide = resultHash[0]! % 2;\n   279→  const winner = resultSide === creatorSide ? creator : opponent;\n   280→\n   281→  // 6. Build settle instruction (8 accounts, no profile CPI)\n   282→  const data = encodeSettleData(secret);\n   283→\n   284→  const instruction = new TransactionInstruction({\n   285→    keys: [\n   286→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n   287→      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // coinflip_match\n   288→      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n   289→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   290→      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n   291→      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n   292→      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n   293→      {\n   294→        pubkey: SystemProgram.programId,\n   295→        isSigner: false,\n   296→        isWritable: false,\n   297→      }, // system_program\n   298→    ],\n   299→    programId: COINFLIP_PROGRAM_ID,\n   300→    data,\n   301→  });\n   302→\n   303→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   304→\n   305→  const tx = new Transaction({\n   306→    feePayer: serverKeypair.publicKey,\n   307→    blockhash,\n   308→    lastValidBlockHeight,\n   309→  });\n   310→  tx.add(instruction);\n   311→  tx.sign(serverKeypair);\n   312→\n   313→  // 7. Submit and confirm\n   314→  const rawTx = tx.serialize();\n   315→  const tBuild = performance.now();\n   316→  const txSignature = await connection.sendRawTransaction(rawTx, {\n   317→    skipPreflight: false,\n   318→  });\n   319→  const tSend = performance.now();\n   320→\n   321→  logger.info(\"settlement transaction submitted\", {\n   322→    pda,\n   323→    txSignature,\n   324→    attempt: round.settle_attempts + 1,\n   325→    dbMs: Math.round(tDb - t0),\n   326→    fetchMs: Math.round(tFetch - tDb),\n   327→    buildMs: Math.round(tBuild - tFetch),\n   328→    sendMs: Math.round(tSend - tBuild),\n   329→  });\n   330→\n   331→  const confirmation = await connection.confirmTransaction(\n   332→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   333→    \"confirmed\",\n   334→  );\n   335→  const tConfirm = performance.now();\n   336→  if (confirmation.value.err) {\n   337→    throw new TransientSettleError(\n   338→      `Coinflip settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   339→    );\n   340→  }\n   341→\n   342→  // 8. Update DB — phase settling → settled (atomic transaction)\n   343→  const coinflipEntries = [\n   344→    { player: creator.toBase58(), amountLamports: Number(entryAmount) },\n   345→    { player: opponent.toBase58(), amountLamports: Number(entryAmount) },\n   346→  ];\n   347→\n   348→  await db.withTransaction(async (txDb) => {\n   349→    await txDb.updateRoundPhase(pda, \"settled\", {\n   350→      settle_tx: txSignature,\n   351→      result_hash: resultHash,\n   352→      result_side: resultSide,\n   353→      winner: winner.toBase58(),\n   354→      settle_attempts: round.settle_attempts + 1,\n   355→    });\n   356→\n   357→    // Persist entries in dedicated JSONB column for direct access\n   358→    await txDb.updateRoundEntries(pda, coinflipEntries);\n   359→\n   360→    // Log settle_confirmed\n   361→    await txDb.insertOperatorEvent(pda, \"settle_confirmed\", {\n   362→      txSignature,\n   363→      resultSide,\n   364→      winner: winner.toBase58(),\n   365→      entropy: entropy.toString(\"hex\"),\n   366→      payoutAmount,\n   367→      feeAmount,\n   368→      entries: coinflipEntries,\n   369→    });\n   370→\n   371→    // Write payout transaction for the winner\n   372→    await txDb.insertTransaction({\n   373→      wallet: winner.toBase58(),\n   374→      game: \"coinflip\",\n   375→      matchId: round.match_id,\n   376→      txType: \"payout\",\n   377→      amountLamports: payoutAmount,\n   378→      txSig: txSignature,\n   379→    });\n   380→\n   381→    // Referral earnings hook — in same transaction for atomicity (System Invariant 4)\n   382→    await recordReferralEarnings(txDb, {\n   383→      roundId: round.match_id,\n   384→      gameType: \"coinflip\",\n   385→      feeBps,\n   386→      referralDefaultRateBps: deps.referralDefaultRateBps,\n   387→      players: [\n   388→        { wallet: creator.toBase58(), wagerLamports: Number(entryAmount) },\n   389→        { wallet: opponent.toBase58(), wagerLamports: Number(entryAmount) },\n   390→      ],\n   391→    });\n   392→  });\n   393→\n   394→  const tDone = performance.now();\n   395→  logger.info(\"settlement transaction confirmed\", {\n   396→    pda,\n   397→    txSignature,\n   398→    resultSide,\n   399→    winner: winner.toBase58(),\n   400→    timing: {\n   401→      dbMs: Math.round(tDb - t0),\n   402→      fetchMs: Math.round(tFetch - tDb),\n   403→      buildMs: Math.round(tBuild - tFetch),\n   404→      sendMs: Math.round(tSend - tBuild),\n   405→      confirmMs: Math.round(tConfirm - tSend),\n   406→      dbWriteMs: Math.round(tDone - tConfirm),\n   407→      totalMs: Math.round(tDone - t0),\n   408→    },\n   409→  });\n   410→\n   411→  return {\n   412→    txSignature,\n   413→    resultHash,\n   414→    resultSide,\n   415→    winner: winner.toBase58(),\n   416→  };\n   417→}\n   418→\n   419→export async function settleLordRound(\n   420→  deps: SettleTxDeps,\n   421→  pda: string,\n   422→): Promise<SettleResult> {\n   423→  const t0 = performance.now();\n   424→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   425→  const roundPubkey = new PublicKey(pda);\n   426→\n   427→  const round = await db.getRoundByPda(pda);\n   428→  const tDb = performance.now();\n   429→  if (!round) {\n   430→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   431→  }\n   432→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   433→    throw new PermanentSettleError(\n   434→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   435→    );\n   436→  }\n   437→\n   438→  const secret = Buffer.from(round.secret);\n   439→\n   440→  if (round.phase === \"locked\") {\n   441→    await db.updateRoundPhase(pda, \"settling\");\n   442→  }\n   443→\n   444→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   445→    attempt: round.settle_attempts + 1,\n   446→    game: \"lord\",\n   447→  });\n   448→\n   449→  const [platformConfigPda] = derivePlatformConfigPda();\n   450→  const [roundAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n   451→    await Promise.all([\n   452→      connection.getAccountInfo(roundPubkey),\n   453→      getPlatformConfig(connection),\n   454→      connection.getAccountInfo(entropyAccount),\n   455→      connection.getLatestBlockhash(),\n   456→    ]);\n   457→\n   458→  const tFetch = performance.now();\n   459→\n   460→  if (!roundAccountInfo) {\n   461→    throw new PermanentSettleError(`Lord round account not found on-chain: ${pda}`);\n   462→  }\n   463→  if (!entropyInfo) {\n   464→    throw new TransientSettleError(\"Entropy account not available yet\");\n   465→  }\n   466→\n   467→  // IDL-driven decode — no manual byte offsets or parseLordRound()\n   468→  const roundData: DecodedJackpotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n   469→  const { feeBps, treasury } = platformConfig;\n   470→\n   471→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   472→  const resultHash = deriveResult(\n   473→    secret,\n   474→    entropy,\n   475→    roundPubkey.toBuffer(),\n   476→    roundData.algorithmVer,\n   477→  );\n   478→  const feeAmount = Number((roundData.totalAmountLamports * BigInt(feeBps)) / 10_000n);\n   479→  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n   480→  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n   481→\n   482→  const raw = resultHash.readBigUInt64LE(0);\n   483→  const winningOffset = raw % roundData.totalAmountLamports;\n   484→\n   485→  let cumulative = 0n;\n   486→  let winnerEntryIndex = -1;\n   487→  let winner = roundData.entries[0]?.player;\n   488→  for (const [index, entry] of roundData.entries.entries()) {\n   489→    cumulative += entry.amountLamports;\n   490→    if (winningOffset < cumulative) {\n   491→      winnerEntryIndex = index;\n   492→      winner = entry.player;\n   493→      break;\n   494→    }\n   495→  }\n   496→\n   497→  if (!winner || winnerEntryIndex < 0) {\n   498→    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n   499→  }\n   500→\n   501→  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n   502→  const instruction = new TransactionInstruction({\n   503→    keys: [\n   504→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n   505→      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n   506→      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n   507→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   508→      { pubkey: treasury, isSigner: false, isWritable: true },\n   509→      { pubkey: winner, isSigner: false, isWritable: true },\n   510→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   511→    ],\n   512→    programId: LORDOFRNGS_PROGRAM_ID,\n   513→    data: encodeClaimPayoutData(matchIdBuf, secret),\n   514→  });\n   515→\n   516→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   517→  const tx = new Transaction({\n   518→    feePayer: serverKeypair.publicKey,\n   519→    blockhash,\n   520→    lastValidBlockHeight,\n   521→  });\n   522→  tx.add(instruction);\n   523→  tx.sign(serverKeypair);\n   524→\n   525→  const tBuild = performance.now();\n   526→  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n   527→    skipPreflight: false,\n   528→  });\n   529→  const tSend = performance.now();\n   530→\n   531→  logger.info(\"lord settlement transaction submitted\", {\n   532→    pda,\n   533→    txSignature,\n   534→    attempt: round.settle_attempts + 1,\n   535→    winningEntryIndex: winnerEntryIndex,\n   536→    dbMs: Math.round(tDb - t0),\n   537→    fetchMs: Math.round(tFetch - tDb),\n   538→    buildMs: Math.round(tBuild - tFetch),\n   539→    sendMs: Math.round(tSend - tBuild),\n   540→  });\n   541→\n   542→  const confirmation = await connection.confirmTransaction(\n   543→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   544→    \"confirmed\",\n   545→  );\n   546→  const tConfirm = performance.now();\n   547→  if (confirmation.value.err) {\n   548→    throw new TransientSettleError(\n   549→      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   550→    );\n   551→  }\n   552→\n   553→  const serializedEntries = roundData.entries.map((e) => ({\n   554→    player: e.player.toBase58(),\n   555→    amountLamports: Number(e.amountLamports),\n   556→  }));\n   557→\n   558→  await db.withTransaction(async (txDb) => {\n   559→    await txDb.updateRoundPhase(pda, \"settled\", {\n   560→      settle_tx: txSignature,\n   561→      result_hash: resultHash,\n   562→      result_side: winnerEntryIndex,\n   563→      winner: winner.toBase58(),\n   564→      settle_attempts: round.settle_attempts + 1,\n   565→    });\n   566→\n   567→    // Persist entries in dedicated JSONB column for direct access\n   568→    await txDb.updateRoundEntries(pda, serializedEntries);\n   569→\n   570→    await txDb.insertOperatorEvent(pda, \"settle_confirmed\", {\n   571→      txSignature,\n   572→      winner: winner.toBase58(),\n   573→      winningEntryIndex: winnerEntryIndex,\n   574→      game: \"lord\",\n   575→      entropy: entropy.toString(\"hex\"),\n   576→      winningOffset: winningOffset.toString(),\n   577→      totalAmountLamports: Number(roundData.totalAmountLamports),\n   578→      payoutAmount,\n   579→      feeAmount,\n   580→      rentRefund,\n   581→      entries: serializedEntries,\n   582→    });\n   583→\n   584→    // Write payout transaction for the winner\n   585→    await txDb.insertTransaction({\n   586→      wallet: winner.toBase58(),\n   587→      game: \"lord\",\n   588→      matchId: round.match_id,\n   589→      txType: \"payout\",\n   590→      amountLamports: payoutAmount,\n   591→      txSig: txSignature,\n   592→    });\n   593→\n   594→    // Referral earnings hook — in same transaction for atomicity (System Invariant 4)\n   595→    await recordReferralEarnings(txDb, {\n   596→      roundId: round.match_id,\n   597→      gameType: \"lord\",\n   598→      feeBps,\n   599→      referralDefaultRateBps: deps.referralDefaultRateBps,\n   600→      players: serializedEntries.map((e) => ({\n   601→        wallet: e.player,\n   602→        wagerLamports: e.amountLamports,\n   603→      })),\n   604→    });\n   605→  });\n   606→\n   607→  const tDone = performance.now();\n   608→  logger.info(\"lord settlement transaction confirmed\", {\n   609→    pda,\n   610→    txSignature,\n   611→    winner: winner.toBase58(),\n   612→    winningEntryIndex: winnerEntryIndex,\n   613→    timing: {\n   614→      dbMs: Math.round(tDb - t0),\n   615→      fetchMs: Math.round(tFetch - tDb),\n   616→      buildMs: Math.round(tBuild - tFetch),\n   617→      sendMs: Math.round(tSend - tBuild),\n   618→      confirmMs: Math.round(tConfirm - tSend),\n   619→      dbWriteMs: Math.round(tDone - tConfirm),\n   620→      totalMs: Math.round(tDone - t0),\n   621→    },\n   622→  });\n   623→\n   624→  return {\n   625→    txSignature,\n   626→    resultHash,\n   627→    winningEntryIndex: winnerEntryIndex,\n   628→    winner: winner.toBase58(),\n   629→  };\n   630→}\n   631→\n   632→export async function settleRound(\n   633→  deps: SettleTxDeps,\n   634→  pda: string,\n   635→): Promise<SettleResult> {\n   636→  const round = await deps.db.getRoundByPda(pda);\n   637→  if (!round) {\n   638→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   639→  }\n   640→\n   641→  if (round.game === \"lord\") {\n   642→    return settleLordRound(deps, pda);\n   643→  }\n   644→\n   645→  return settleMatch(deps, pda);\n   646→}\n   647→\n   648→// ---------------------------------------------------------------------------\n   649→// Close Call — transaction builders\n   650→// ---------------------------------------------------------------------------\n   651→\n   652→function deriveCloseCallConfigPda(): [PublicKey, number] {\n   653→  return PublicKey.findProgramAddressSync(\n   654→    [Buffer.from(\"closecall_config\")],\n   655→    CLOSECALL_PROGRAM_ID,\n   656→  );\n   657→}\n   658→\n   659→\n   660→function minuteTsToBuffer(ts: bigint): Buffer {\n   661→  const buf = Buffer.alloc(8);\n   662→  buf.writeBigInt64LE(ts);\n   663→  return buf;\n   664→}\n   665→\n   666→function deriveCloseCallRoundPda(minuteTs: bigint): [PublicKey, number] {\n   667→  return PublicKey.findProgramAddressSync(\n   668→    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n   669→    CLOSECALL_PROGRAM_ID,\n   670→  );\n   671→}\n   672→\n   673→/** Encode closecall instruction data: discriminator(8) + minute_ts(i64 LE, 8) = 16 bytes */\n   674→function encodeCcMinuteTsData(discriminator: Buffer, minuteTs: bigint): Buffer {\n   675→  const buf = Buffer.alloc(16);\n   676→  discriminator.copy(buf, 0);\n   677→  buf.writeBigInt64LE(minuteTs, 8);\n   678→  return buf;\n   679→}\n   680→\n   681→/** Encode closecall settle_round data: disc(8) + minute_ts(i64 LE, 8) + close_price(i64 LE, 8) + close_price_expo(i32 LE, 4) = 28 bytes */\n   682→function encodeCcSettleData(discriminator: Buffer, minuteTs: bigint, price: bigint, expo: number): Buffer {\n   683→  const buf = Buffer.alloc(28);\n   684→  discriminator.copy(buf, 0);\n   685→  buf.writeBigInt64LE(minuteTs, 8);\n   686→  buf.writeBigInt64LE(price, 16);\n   687→  buf.writeInt32LE(expo, 24);\n   688→  return buf;\n   689→}\n   690→\n   691→/**\n   692→ * Encode closecall bet data:\n   693→ * disc(8) + minute_ts(i64 LE, 8) + side(1) + amount(u64 LE, 8) + open_price(i64 LE, 8) + open_price_expo(i32 LE, 4) = 37 bytes\n   694→ */\n   695→function encodeCcBetData(\n   696→  discriminator: Buffer,\n   697→  minuteTs: bigint,\n   698→  side: number,\n   699→  amount: bigint,\n   700→  openPrice: bigint,\n   701→  openPriceExpo: number,\n   702→): Buffer {\n   703→  const buf = Buffer.alloc(37);\n   704→  discriminator.copy(buf, 0);\n   705→  buf.writeBigInt64LE(minuteTs, 8);\n   706→  buf.writeUInt8(side, 16);\n   707→  buf.writeBigUInt64LE(amount, 17);\n   708→  buf.writeBigInt64LE(openPrice, 25);\n   709→  buf.writeInt32LE(openPriceExpo, 33);\n   710→  return buf;\n   711→}\n   712→\n   713→export interface CloseCallTxDeps {\n   714→  connection: Connection;\n   715→  serverKeypair: Keypair;\n   716→}\n   717→\n   718→/**\n   719→ * Build a `bet` instruction (no transaction wrapping).\n   720→ *\n   721→ * Two signers: player (pays bet) + server (pays rent on first call).\n   722→ * Price + bet info passed as instruction args.\n   723→ * Uses init_if_needed — works for both round creation and joining.\n   724→ */\n   725→export function buildCloseCallBetIx(\n   726→  serverPubkey: PublicKey,\n   727→  playerPubkey: PublicKey,\n   728→  minuteTs: bigint,\n   729→  side: number,\n   730→  amountLamports: bigint,\n   731→  openPrice: bigint,\n   732→  openPriceExpo: number,\n   733→): TransactionInstruction {\n   734→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   735→  const [configPda] = deriveCloseCallConfigPda();\n   736→  const data = encodeCcBetData(\n   737→    CC_BET_DISCRIMINATOR,\n   738→    minuteTs,\n   739→    side,\n   740→    amountLamports,\n   741→    openPrice,\n   742→    openPriceExpo,\n   743→  );\n   744→\n   745→  return new TransactionInstruction({\n   746→    keys: [\n   747→      { pubkey: playerPubkey, isSigner: true, isWritable: true },  // player (pays bet)\n   748→      { pubkey: serverPubkey, isSigner: true, isWritable: true },  // server (pays rent on first call)\n   749→      { pubkey: configPda, isSigner: false, isWritable: false },   // config\n   750→      { pubkey: roundPda, isSigner: false, isWritable: true },     // round\n   751→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   752→    ],\n   753→    programId: CLOSECALL_PROGRAM_ID,\n   754→    data,\n   755→  });\n   756→}\n   757→\n   758→/**\n   759→ * Build a `settle_round` instruction (no transaction wrapping).\n   760→ * Price is passed as instruction args (no on-chain Pyth account).\n   761→ */\n   762→export function buildCloseCallSettleRoundIx(\n   763→  serverPubkey: PublicKey,\n   764→  minuteTs: bigint,\n   765→  closePrice: bigint,\n   766→  closePriceExpo: number,\n   767→  treasury: PublicKey,\n   768→  winnerAccounts: PublicKey[],\n   769→): TransactionInstruction {\n   770→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   771→  const [platformConfigPda] = derivePlatformConfigPda();\n   772→  const data = encodeCcSettleData(CC_SETTLE_ROUND_DISCRIMINATOR, minuteTs, closePrice, closePriceExpo);\n   773→\n   774→  return new TransactionInstruction({\n   775→    keys: [\n   776→      { pubkey: serverPubkey, isSigner: true, isWritable: true },\n   777→      { pubkey: roundPda, isSigner: false, isWritable: true },\n   778→      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n   779→      { pubkey: treasury, isSigner: false, isWritable: true },\n   780→      { pubkey: serverPubkey, isSigner: false, isWritable: true },\n   781→      ...winnerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n   782→    ],\n   783→    programId: CLOSECALL_PROGRAM_ID,\n   784→    data,\n   785→  });\n   786→}\n   787→\n   788→/**\n   789→ * Build a partially-signed `bet` transaction for the Close Call program.\n   790→ *\n   791→ * Two signers: player (pays bet) + server (pays rent on first call via init_if_needed).\n   792→ * Server signs immediately; the frontend must add the player signature before submitting.\n   793→ * Works for both round creation (first bet) and joining (subsequent bets).\n   794→ */\n   795→export async function buildCloseCallBetTx(\n   796→  deps: CloseCallTxDeps,\n   797→  playerPubkey: PublicKey,\n   798→  minuteTs: bigint,\n   799→  side: number,\n   800→  amountLamports: bigint,\n   801→  openPrice: bigint,\n   802→  openPriceExpo: number,\n   803→): Promise<{ tx: Transaction; roundPda: PublicKey }> {\n   804→  const { connection, serverKeypair } = deps;\n   805→\n   806→  const instruction = buildCloseCallBetIx(\n   807→    serverKeypair.publicKey,\n   808→    playerPubkey,\n   809→    minuteTs,\n   810→    side,\n   811→    amountLamports,\n   812→    openPrice,\n   813→    openPriceExpo,\n   814→  );\n   815→\n   816→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   817→\n   818→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   819→  const tx = new Transaction({ feePayer: playerPubkey, blockhash, lastValidBlockHeight });\n   820→  tx.add(instruction);\n   821→  tx.partialSign(serverKeypair);\n   822→\n   823→  return { tx, roundPda };\n   824→}\n   825→\n   826→/**\n   827→ * Build a signed `settle_round` transaction for the Close Call program.\n   828→ *\n   829→ * Price is passed as instruction args. Winners (or all players for refund)\n   830→ * are passed as remaining accounts for auto-payout.\n   831→ */\n   832→export async function buildCloseCallSettleRoundTx(\n   833→  deps: CloseCallTxDeps,\n   834→  minuteTs: bigint,\n   835→  closePrice: bigint,\n   836→  closePriceExpo: number,\n   837→  treasury: PublicKey,\n   838→  winnerAccounts: PublicKey[],\n   839→): Promise<Transaction> {\n   840→  const { connection, serverKeypair } = deps;\n   841→\n   842→  const instruction = buildCloseCallSettleRoundIx(\n   843→    serverKeypair.publicKey,\n   844→    minuteTs,\n   845→    closePrice,\n   846→    closePriceExpo,\n   847→    treasury,\n   848→    winnerAccounts,\n   849→  );\n   850→\n   851→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   852→  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n   853→  tx.add(instruction);\n   854→  tx.sign(serverKeypair);\n   855→\n   856→  return tx;\n   857→}\n   858→\n   859→/**\n   860→ * Build a signed `timeout_refund` transaction for the Close Call program.\n   861→ *\n   862→ * Permissionless after the resolve deadline. Refunds all players their exact\n   863→ * deposit via remaining accounts.\n   864→ */\n   865→export async function buildCloseCallTimeoutRefundTx(\n   866→  deps: CloseCallTxDeps,\n   867→  minuteTs: bigint,\n   868→  playerAccounts: PublicKey[],\n   869→): Promise<Transaction> {\n   870→  const { connection, serverKeypair } = deps;\n   871→\n   872→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   873→  const [configPda] = deriveCloseCallConfigPda();\n   874→  const data = encodeCcMinuteTsData(CC_TIMEOUT_REFUND_DISCRIMINATOR, minuteTs);\n   875→\n   876→  const keys = [\n   877→    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller\n   878→    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round\n   879→    { pubkey: configPda, isSigner: false, isWritable: false },               // closecall_config\n   880→    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)\n   881→    ...playerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n   882→  ];\n   883→\n   884→  const instruction = new TransactionInstruction({\n   885→    keys,\n   886→    programId: CLOSECALL_PROGRAM_ID,\n   887→    data,\n   888→  });\n   889→\n   890→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   891→  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n   892→  tx.add(instruction);\n   893→  tx.sign(serverKeypair);\n   894→\n   895→  return tx;\n   896→}\n   897→\n   898→// ---------------------------------------------------------------------------\n   899→// Error types\n   900→// ---------------------------------------------------------------------------\n   901→\n   902→/** Permanent failure — should not be retried. */\n   903→export class PermanentSettleError extends Error {\n   904→  readonly permanent = true;\n   905→  constructor(message: string) {\n   906→    super(message);\n   907→    this.name = \"PermanentSettleError\";\n   908→  }\n   909→}\n   910→\n   911→/** Transient failure — safe to retry. */\n   912→export class TransientSettleError extends Error {\n   913→  readonly permanent = false;\n   914→  constructor(message: string) {\n   915→    super(message);\n   916→    this.name = \"TransientSettleError\";\n   917→  }\n   918→}\n   919→"}]},"parent_tool_use_id":"toolu_01K6S9FTWc4Mt7jLihK2J2QP","session_id":"773e2b1e-9c3d-4d53-809d-a95c06988ae7","uuid":"7fe7b2de-24e1-4f03-84f8-f6e03c600f56","timestamp":"2026-03-25T13:56:00.960Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QJv95PEQRQyqU2UT68V6eT","type":"tool_result","content":"     1→/**\n     2→ * Integration test: full create → join → settle lifecycle.\n     3→ *\n     4→ * Uses a mock Solana Connection to simulate on-chain state while exercising\n     5→ * the real HTTP endpoints, database, settlement worker, and retry logic\n     6→ * end-to-end. Auth uses JWT Bearer tokens (HS256).\n     7→ */\n     8→\n     9→import { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n    10→import { Hono } from \"hono\";\n    11→import {\n    12→  Keypair,\n    13→  PublicKey,\n    14→  SystemProgram,\n    15→  LAMPORTS_PER_SOL,\n    16→} from \"@solana/web3.js\";\n    17→import type { Connection } from \"@solana/web3.js\";\n    18→import bs58 from \"bs58\";\n    19→import { SignJWT } from \"jose\";\n    20→import postgres from \"postgres\";\n    21→import { createDb, type Db } from \"../db.js\";\n    22→import { createCoinflipRoutes } from \"../routes/create.js\";\n    23→import { createRoundsRoutes } from \"../routes/rounds.js\";\n    24→import { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n    25→import { createSettlementWorker } from \"../worker/settlement.js\";\n    26→import { settleMatch } from \"../worker/settle-tx.js\";\n    27→import { createRetrySettler } from \"../worker/retry.js\";\n    28→import { COINFLIP_PROGRAM_ID } from \"../fairness.js\";\n    29→import { encodeCoinflipMatch, encodeCoinflipConfig } from \"../worker/account-decoder.js\";\n    30→\n    31→// ---------------------------------------------------------------------------\n    32→// Constants\n    33→// ---------------------------------------------------------------------------\n    34→\n    35→const DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n    36→const AMOUNT_LAMPORTS = 5_000_000;\n    37→const AMOUNT_LAMPORTS_BIGINT = 5_000_000n;\n    38→const SIDE_HEADS = 0;\n    39→const PHASE_LOCKED = 1;\n    40→const JWT_SECRET = new TextEncoder().encode(\"test-secret-for-integration-tests\");\n    41→\n    42→// ---------------------------------------------------------------------------\n    43→// JWT helper\n    44→// ---------------------------------------------------------------------------\n    45→\n    46→async function makeJwt(wallet: string) {\n    47→  const now = Math.floor(Date.now() / 1000);\n    48→  return new SignJWT({ sub: wallet })\n    49→    .setProtectedHeader({ alg: \"HS256\" })\n    50→    .setIssuedAt(now)\n    51→    .setExpirationTime(now + 3600)\n    52→    .sign(JWT_SECRET);\n    53→}\n    54→\n    55→// ---------------------------------------------------------------------------\n    56→// Mock Connection\n    57→// ---------------------------------------------------------------------------\n    58→\n    59→/**\n    60→ * Minimal mock of `@solana/web3.js` Connection that the backend modules need.\n    61→ * Stores accounts in-memory and provides getAccountInfo, getProgramAccounts,\n    62→ * getSlot, getLatestBlockhash, sendRawTransaction, confirmTransaction, getBalance.\n    63→ */\n    64→class MockConnection {\n    65→  private _slot = 200;\n    66→  private _accounts = new Map<\n    67→    string,\n    68→    {\n    69→      data: Buffer;\n    70→      lamports: number;\n    71→      owner: PublicKey;\n    72→      executable: boolean;\n    73→    }\n    74→  >();\n    75→  lastRawTx: Buffer | null = null;\n    76→\n    77→  set slot(s: number) {\n    78→    this._slot = s;\n    79→  }\n    80→  get slot() {\n    81→    return this._slot;\n    82→  }\n    83→\n    84→  setAccount(\n    85→    pubkey: PublicKey,\n    86→    data: Buffer,\n    87→    opts?: { lamports?: number; owner?: PublicKey },\n    88→  ) {\n    89→    this._accounts.set(pubkey.toBase58(), {\n    90→      data,\n    91→      lamports: opts?.lamports ?? LAMPORTS_PER_SOL,\n    92→      owner: opts?.owner ?? SystemProgram.programId,\n    93→      executable: false,\n    94→    });\n    95→  }\n    96→\n    97→  removeAccount(pubkey: PublicKey) {\n    98→    this._accounts.delete(pubkey.toBase58());\n    99→  }\n   100→\n   101→  async getLatestBlockhash() {\n   102→    return {\n   103→      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n   104→      lastValidBlockHeight: 999_999,\n   105→    };\n   106→  }\n   107→\n   108→  async getSlot() {\n   109→    return this._slot;\n   110→  }\n   111→\n   112→  async getAccountInfo(pubkey: PublicKey) {\n   113→    const acc = this._accounts.get(pubkey.toBase58());\n   114→    if (!acc) return null;\n   115→    return { ...acc, rentEpoch: 0 };\n   116→  }\n   117→\n   118→  async getProgramAccounts(\n   119→    programId: PublicKey,\n   120→    config?: {\n   121→      filters?: Array<\n   122→        | { dataSize: number }\n   123→        | { memcmp: { offset: number; bytes: string } }\n   124→      >;\n   125→    },\n   126→  ) {\n   127→    const results: Array<{\n   128→      pubkey: PublicKey;\n   129→      account: {\n   130→        data: Buffer;\n   131→        lamports: number;\n   132→        owner: PublicKey;\n   133→        executable: boolean;\n   134→        rentEpoch: number;\n   135→      };\n   136→    }> = [];\n   137→\n   138→    for (const [key, acc] of this._accounts) {\n   139→      if (!acc.owner.equals(programId)) continue;\n   140→\n   141→      let matches = true;\n   142→      if (config?.filters) {\n   143→        for (const filter of config.filters) {\n   144→          if (\"dataSize\" in filter) {\n   145→            if (acc.data.length !== filter.dataSize) {\n   146→              matches = false;\n   147→              break;\n   148→            }\n   149→          }\n   150→          if (\"memcmp\" in filter) {\n   151→            const expected = Buffer.from(bs58.decode(filter.memcmp.bytes));\n   152→            const actual = acc.data.subarray(\n   153→              filter.memcmp.offset,\n   154→              filter.memcmp.offset + expected.length,\n   155→            );\n   156→            if (Buffer.compare(actual, expected) !== 0) {\n   157→              matches = false;\n   158→              break;\n   159→            }\n   160→          }\n   161→        }\n   162→      }\n   163→\n   164→      if (matches) {\n   165→        results.push({\n   166→          pubkey: new PublicKey(key),\n   167→          account: { ...acc, rentEpoch: 0 },\n   168→        });\n   169→      }\n   170→    }\n   171→    return results;\n   172→  }\n   173→\n   174→  async sendRawTransaction(rawTx: Buffer | Uint8Array) {\n   175→    this.lastRawTx = Buffer.from(rawTx);\n   176→    // Return a deterministic fake signature\n   177→    return bs58.encode(Buffer.alloc(64, 0x01));\n   178→  }\n   179→\n   180→  async confirmTransaction() {\n   181→    return { value: { err: null }, context: { slot: this._slot } };\n   182→  }\n   183→\n   184→  async getBlockTime(_slot: number) {\n   185→    return Math.floor(Date.now() / 1000);\n   186→  }\n   187→\n   188→  async getBalance() {\n   189→    return 2 * LAMPORTS_PER_SOL;\n   190→  }\n   191→}\n   192→\n   193→// ---------------------------------------------------------------------------\n   194→// Account data builders\n   195→// ---------------------------------------------------------------------------\n   196→\n   197→async function buildMatchAccountData(params: {\n   198→  creator: PublicKey;\n   199→  opponent: PublicKey;\n   200→  server: PublicKey;\n   201→  entryAmount: bigint;\n   202→  creatorSide: number;\n   203→  phase: number;\n   204→  commitment: Buffer;\n   205→  algorithmVer: number;\n   206→  targetSlot: bigint;\n   207→  resolveDeadline: bigint;\n   208→  matchId: Buffer;\n   209→}): Promise<Buffer> {\n   210→  return encodeCoinflipMatch({\n   211→    creator: params.creator,\n   212→    opponent: params.opponent,\n   213→    server: params.server,\n   214→    entryAmount: params.entryAmount,\n   215→    creatorSide: params.creatorSide,\n   216→    phase: params.phase,\n   217→    commitment: [...params.commitment],\n   218→    algorithmVer: params.algorithmVer,\n   219→    targetSlot: params.targetSlot,\n   220→    resolveDeadline: params.resolveDeadline,\n   221→    resultHash: new Array(32).fill(0),\n   222→    result: 0,\n   223→    winner: PublicKey.default,\n   224→    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n   225→    matchId: [...params.matchId],\n   226→    bump: 0,\n   227→  });\n   228→}\n   229→\n   230→async function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n   231→  return encodeCoinflipConfig({\n   232→    authority: PublicKey.default,\n   233→    treasury,\n   234→    paused: false,\n   235→    bump: 0,\n   236→  });\n   237→}\n   238→\n   239→// ---------------------------------------------------------------------------\n   240→// Test suite\n   241→// ---------------------------------------------------------------------------\n   242→\n   243→describe(\"Integration: create → join → settle lifecycle\", () => {\n   244→  let db: Db;\n   245→  let rawSql: ReturnType<typeof postgres>;\n   246→  let mockConn: MockConnection;\n   247→  let app: Hono;\n   248→\n   249→  const serverKeypair = Keypair.generate();\n   250→  const creatorKeypair = Keypair.generate();\n   251→  const opponentKeypair = Keypair.generate();\n   252→  const treasuryKeypair = Keypair.generate();\n   253→  const entropyKeypair = Keypair.generate();\n   254→  const entropyAccount = entropyKeypair.publicKey;\n   255→\n   256→  const entropyData = Buffer.alloc(32);\n   257→  entropyData[0] = 0xab;\n   258→  entropyData[1] = 0xcd;\n   259→  entropyData[15] = 0x42;\n   260→\n   261→  beforeAll(async () => {\n   262→    db = createDb(DATABASE_URL);\n   263→    rawSql = postgres(DATABASE_URL);\n   264→  });\n   265→\n   266→  afterAll(async () => {\n   267→    await db.close();\n   268→    await rawSql.end();\n   269→  });\n   270→\n   271→  beforeEach(async () => {\n   272→    // Clean tables for isolation\n   273→    await rawSql`TRUNCATE rounds, operator_events RESTART IDENTITY`;\n   274→\n   275→    // Fresh mock Connection\n   276→    mockConn = new MockConnection();\n   277→\n   278→    // Pre-populate mock with entropy and config accounts\n   279→    mockConn.setAccount(entropyAccount, entropyData);\n   280→\n   281→    const [configPda] = PublicKey.findProgramAddressSync(\n   282→      [Buffer.from(\"coinflip_config\")],\n   283→      COINFLIP_PROGRAM_ID,\n   284→    );\n   285→    mockConn.setAccount(\n   286→      configPda,\n   287→      await buildConfigAccountData(treasuryKeypair.publicKey),\n   288→      { owner: COINFLIP_PROGRAM_ID },\n   289→    );\n   290→\n   291→    // Build the Hono app (no rate limiting for tests)\n   292→    app = new Hono();\n   293→\n   294→    app.use(\n   295→      \"/fairness/*\",\n   296→      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n   297→    );\n   298→\n   299→    app.route(\n   300→      \"/fairness/coinflip\",\n   301→      createCoinflipRoutes({\n   302→        db,\n   303→        connection: mockConn as unknown as Connection,\n   304→        serverKeypair,\n   305→      }),\n   306→    );\n   307→\n   308→    app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n   309→  });\n   310→\n   311→  it(\"full lifecycle: create → join (mock) → settle → verify\", async () => {\n   312→    const wallet = creatorKeypair.publicKey.toBase58();\n   313→    const token = await makeJwt(wallet);\n   314→\n   315→    // ------------------------------------------------------------------\n   316→    // 1. POST /fairness/coinflip/create\n   317→    // ------------------------------------------------------------------\n   318→    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n   319→\n   320→    const createRes = await app.request(\"/fairness/coinflip/create\", {\n   321→      method: \"POST\",\n   322→      headers: {\n   323→        \"Content-Type\": \"application/json\",\n   324→        \"Authorization\": `Bearer ${token}`,\n   325→      },\n   326→      body: JSON.stringify(body),\n   327→    });\n   328→\n   329→    expect(createRes.status).toBe(200);\n   330→    const createJson = (await createRes.json()) as {\n   331→      transaction: string;\n   332→      matchPda: string;\n   333→      matchId: string;\n   334→      commitment: string;\n   335→      lastValidBlockHeight: number;\n   336→    };\n   337→    expect(createJson.transaction).toBeDefined();\n   338→    expect(createJson.matchPda).toBeDefined();\n   339→    expect(createJson.commitment).toBeDefined();\n   340→    expect(createJson.lastValidBlockHeight).toBeDefined();\n   341→\n   342→    const matchPda = createJson.matchPda;\n   343→    const commitmentHex = createJson.commitment;\n   344→    const commitmentBuf = Buffer.from(commitmentHex, \"hex\");\n   345→\n   346→    // ------------------------------------------------------------------\n   347→    // 2. Verify DB state — round in \"created\" phase\n   348→    // ------------------------------------------------------------------\n   349→    const round = await db.getRoundByPda(matchPda);\n   350→    expect(round).toBeDefined();\n   351→    expect(round!.phase).toBe(\"created\");\n   352→    expect(round!.game).toBe(\"coinflip\");\n   353→    expect(round!.creator).toBe(wallet);\n   354→    expect(round!.amount_lamports).toBe(AMOUNT_LAMPORTS);\n   355→    expect(round!.side).toBe(SIDE_HEADS);\n   356→    expect(round!.commitment.toString(\"hex\")).toBe(commitmentHex);\n   357→    expect(round!.secret).toBeDefined();\n   358→    expect(round!.secret.length).toBe(32);\n   359→\n   360→    // Verify operator event was logged\n   361→    const events =\n   362→      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n   363→    expect(events.length).toBe(1);\n   364→    expect(events[0]!.event_type).toBe(\"secret_generated\");\n   365→\n   366→    // ------------------------------------------------------------------\n   367→    // 3. Simulate on-chain join — add LOCKED match to mock Connection\n   368→    // ------------------------------------------------------------------\n   369→    const matchPubkey = new PublicKey(matchPda);\n   370→    const targetSlot = 150n;\n   371→    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n   372→\n   373→    const matchAccountData = await buildMatchAccountData({\n   374→      creator: creatorKeypair.publicKey,\n   375→      opponent: opponentKeypair.publicKey,\n   376→      server: serverKeypair.publicKey,\n   377→      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n   378→      creatorSide: SIDE_HEADS,\n   379→      phase: PHASE_LOCKED,\n   380→      commitment: commitmentBuf,\n   381→      algorithmVer: 1,\n   382→      targetSlot,\n   383→      resolveDeadline,\n   384→      matchId: Buffer.from(createJson.matchId, \"hex\"),\n   385→    });\n   386→\n   387→    mockConn.setAccount(matchPubkey, matchAccountData, {\n   388→      owner: COINFLIP_PROGRAM_ID,\n   389→    });\n   390→\n   391→    // Set current slot past target_slot so settlement triggers immediately\n   392→    mockConn.slot = 200;\n   393→\n   394→    // ------------------------------------------------------------------\n   395→    // 4. Create worker + retry settler, trigger poll\n   396→    // ------------------------------------------------------------------\n   397→    let settlePromise: Promise<void> | null = null;\n   398→\n   399→    const retrySettler = createRetrySettler({\n   400→      db,\n   401→      connection: mockConn as unknown as Connection,\n   402→      settleRound: (pda) =>\n   403→        settleMatch(\n   404→          {\n   405→            db,\n   406→            connection: mockConn as unknown as Connection,\n   407→            serverKeypair,\n   408→            entropyAccount,\n   409→            referralDefaultRateBps: 1000,\n   410→          },\n   411→          pda,\n   412→        ),\n   413→    });\n   414→\n   415→    const worker = createSettlementWorker({\n   416→      db,\n   417→      connection: mockConn as unknown as Connection,\n   418→      serverKey: serverKeypair.publicKey,\n   419→      pollIntervalMs: 60_000, // won't auto-poll\n   420→      onSettleReady: (pda) => {\n   421→        settlePromise = retrySettler.attemptSettle(pda);\n   422→        return settlePromise;\n   423→      },\n   424→    });\n   425→\n   426→    // Single poll cycle — should discover locked match and settle it\n   427→    await worker.poll();\n   428→    if (settlePromise) await settlePromise;\n   429→\n   430→    // ------------------------------------------------------------------\n   431→    // 5. Verify DB updated to \"settled\" with result data\n   432→    // ------------------------------------------------------------------\n   433→    const settled = await db.getRoundByPda(matchPda);\n   434→    expect(settled).toBeDefined();\n   435→    expect(settled!.phase).toBe(\"settled\");\n   436→    expect(settled!.settle_tx).toBeDefined();\n   437→    expect(settled!.result_hash).toBeDefined();\n   438→    expect(settled!.result_hash!.length).toBe(32);\n   439→    expect(settled!.result_side).toBeDefined();\n   440→    expect([0, 1]).toContain(settled!.result_side);\n   441→    expect(settled!.winner).toBeDefined();\n   442→\n   443→    // Winner should be one of the two players\n   444→    expect([\n   445→      creatorKeypair.publicKey.toBase58(),\n   446→      opponentKeypair.publicKey.toBase58(),\n   447→    ]).toContain(settled!.winner);\n   448→\n   449→    // Verify operator events trail\n   450→    const allEvents =\n   451→      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n   452→    const eventTypes = allEvents.map(\n   453→      (e) => (e as Record<string, unknown>).event_type,\n   454→    );\n   455→    expect(eventTypes).toContain(\"secret_generated\");\n   456→    expect(eventTypes).toContain(\"match_detected\");\n   457→    expect(eventTypes).toContain(\"settle_submitted\");\n   458→    expect(eventTypes).toContain(\"settle_confirmed\");\n   459→\n   460→    // ------------------------------------------------------------------\n   461→    // 6. GET /fairness/rounds/:pda — verify response includes secret\n   462→    // ------------------------------------------------------------------\n   463→    const roundsRes = await app.request(`/fairness/rounds/${matchPda}`);\n   464→    expect(roundsRes.status).toBe(200);\n   465→\n   466→    const roundsJson = (await roundsRes.json()) as Record<string, unknown>;\n   467→    expect(roundsJson.pda).toBe(matchPda);\n   468→    expect(roundsJson.phase).toBe(\"settled\");\n   469→    expect(roundsJson.game).toBe(\"coinflip\");\n   470→    expect(roundsJson.creator).toBe(wallet);\n   471→    expect(roundsJson.commitment).toBe(commitmentHex);\n   472→\n   473→    // Settled round should include secret + verification payload\n   474→    expect(roundsJson.secret).toBeDefined();\n   475→    expect(typeof roundsJson.secret).toBe(\"string\");\n   476→    expect((roundsJson.secret as string).length).toBe(64); // 32 bytes hex\n   477→    expect(roundsJson.resultHash).toBeDefined();\n   478→    expect(roundsJson.resultSide).toBeDefined();\n   479→    expect(roundsJson.winner).toBeDefined();\n   480→    expect(roundsJson.settleTx).toBeDefined();\n   481→\n   482→    // Verification object\n   483→    const verification = roundsJson.verification as Record<string, string>;\n   484→    expect(verification).toBeDefined();\n   485→    expect(verification.commitmentCheck).toBe(\"sha256(secret) == commitment\");\n   486→    expect(verification.resultFormula).toContain(\"sha256(secret\");\n   487→    expect(verification.entropySource).toContain(\"SlotHashes\");\n   488→  });\n   489→\n   490→  it(\"GET /rounds/:pda returns 404 for unknown PDA\", async () => {\n   491→    const unknownPda = Keypair.generate().publicKey.toBase58();\n   492→    const res = await app.request(`/fairness/rounds/${unknownPda}`);\n   493→    expect(res.status).toBe(404);\n   494→  });\n   495→\n   496→  it(\"unsettled round does not expose secret\", async () => {\n   497→    const wallet = creatorKeypair.publicKey.toBase58();\n   498→    const token = await makeJwt(wallet);\n   499→\n   500→    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n   501→\n   502→    const res = await app.request(\"/fairness/coinflip/create\", {\n   503→      method: \"POST\",\n   504→      headers: {\n   505→        \"Content-Type\": \"application/json\",\n   506→        \"Authorization\": `Bearer ${token}`,\n   507→      },\n   508→      body: JSON.stringify(body),\n   509→    });\n   510→    expect(res.status).toBe(200);\n   511→    const json = (await res.json()) as { matchPda: string };\n   512→\n   513→    // GET the unsettled round\n   514→    const roundRes = await app.request(`/fairness/rounds/${json.matchPda}`);\n   515→    expect(roundRes.status).toBe(200);\n   516→    const roundJson = (await roundRes.json()) as Record<string, unknown>;\n   517→    expect(roundJson.phase).toBe(\"created\");\n   518→    expect(roundJson.secret).toBeUndefined();\n   519→    expect(roundJson.resultHash).toBeUndefined();\n   520→    expect(roundJson.verification).toBeUndefined();\n   521→  });\n   522→\n   523→  it(\"two creates from same wallet succeed (different match IDs)\", async () => {\n   524→    const wallet = creatorKeypair.publicKey.toBase58();\n   525→    const token = await makeJwt(wallet);\n   526→\n   527→    const body1 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n   528→    const res1 = await app.request(\"/fairness/coinflip/create\", {\n   529→      method: \"POST\",\n   530→      headers: {\n   531→        \"Content-Type\": \"application/json\",\n   532→        \"Authorization\": `Bearer ${token}`,\n   533→      },\n   534→      body: JSON.stringify(body1),\n   535→    });\n   536→    expect(res1.status).toBe(200);\n   537→\n   538→    // Second request — different random matchId generated server-side\n   539→    const body2 = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n   540→    const res2 = await app.request(\"/fairness/coinflip/create\", {\n   541→      method: \"POST\",\n   542→      headers: {\n   543→        \"Content-Type\": \"application/json\",\n   544→        \"Authorization\": `Bearer ${token}`,\n   545→      },\n   546→      body: JSON.stringify(body2),\n   547→    });\n   548→    expect(res2.status).toBe(200);\n   549→\n   550→    // Both should have different matchIds and PDAs\n   551→    const json1 = (await res1.json()) as { matchPda: string; matchId: string };\n   552→    const json2 = (await res2.json()) as { matchPda: string; matchId: string };\n   553→    expect(json1.matchPda).not.toBe(json2.matchPda);\n   554→    expect(json1.matchId).not.toBe(json2.matchId);\n   555→  });\n   556→});\n   557→"}]},"parent_tool_use_id":"toolu_01K6S9FTWc4Mt7jLihK2J2QP","session_id":"773e2b1e-9c3d-4d53-809d-a95c06988ae7","uuid":"41861650-5bc4-425e-8a8a-2cde11e2c7b1","timestamp":"2026-03-25T13:56:01.299Z"}
