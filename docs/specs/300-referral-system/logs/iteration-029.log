{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RMxwU7xkVdmiFhisBn9ZRi","type":"tool_result","content":"     1→/**\n     2→ * Referral route tests — set code, apply, stats, earnings, claim flows.\n     3→ *\n     4→ * Uses real Postgres (same pattern as auth-routes.test.ts) with TRUNCATE\n     5→ * between tests for isolation.\n     6→ */\n     7→\n     8→import { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n     9→import { Hono } from \"hono\";\n    10→import { Keypair } from \"@solana/web3.js\";\n    11→import { SignJWT } from \"jose\";\n    12→import postgres from \"postgres\";\n    13→import { createDb, type Db } from \"../db.js\";\n    14→import { createReferralRoutes } from \"../routes/referral.js\";\n    15→import { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n    16→import type { Config } from \"../config.js\";\n    17→\n    18→// ---------------------------------------------------------------------------\n    19→// Constants\n    20→// ---------------------------------------------------------------------------\n    21→\n    22→const DATABASE_URL =\n    23→  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n    24→const JWT_SECRET = new TextEncoder().encode(\"test-secret-for-referral-tests\");\n    25→\n    26→/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n    27→function makeSql() {\n    28→  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n    29→  // Dev container: postgres listens on Unix socket only\n    30→  return postgres({\n    31→    host: \"/var/run/postgresql\",\n    32→    user: \"vscode\",\n    33→    database: \"rng_utopia_dev\",\n    34→  });\n    35→}\n    36→\n    37→// ---------------------------------------------------------------------------\n    38→// Helpers\n    39→// ---------------------------------------------------------------------------\n    40→\n    41→async function makeJwt(wallet: string): Promise<string> {\n    42→  const now = Math.floor(Date.now() / 1000);\n    43→  return new SignJWT({ sub: wallet })\n    44→    .setProtectedHeader({ alg: \"HS256\" })\n    45→    .setIssuedAt(now)\n    46→    .setExpirationTime(now + 3600)\n    47→    .sign(JWT_SECRET);\n    48→}\n    49→\n    50→function json(body: Record<string, unknown>) {\n    51→  return {\n    52→    headers: { \"Content-Type\": \"application/json\" },\n    53→    body: JSON.stringify(body),\n    54→  };\n    55→}\n    56→\n    57→// ---------------------------------------------------------------------------\n    58→// Test suite\n    59→// ---------------------------------------------------------------------------\n    60→"}]},"parent_tool_use_id":null,"session_id":"773e2b1e-9c3d-4d53-809d-a95c06988ae7","uuid":"223d1469-8280-4726-b4c0-5b1d51dd9e0d","timestamp":"2026-03-25T13:59:30.218Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/referral-routes.test.ts","content":"/**\n * Referral route tests — set code, apply, stats, earnings, claim flows.\n *\n * Uses real Postgres (same pattern as auth-routes.test.ts) with TRUNCATE\n * between tests for isolation.\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport { SignJWT } from \"jose\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createReferralRoutes } from \"../routes/referral.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport type { Config } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-referral-tests\");\n\n/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\nfunction makeSql() {\n  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n  // Dev container: postgres listens on Unix socket only\n  return postgres({\n    host: \"/var/run/postgresql\",\n    user: \"vscode\",\n    database: \"rng_utopia_dev\",\n  });\n}\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\nasync function makeJwt(wallet: string): Promise<string> {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({ sub: wallet })\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setIssuedAt(now)\n    .setExpirationTime(now + 3600)\n    .sign(JWT_SECRET);\n}\n\nfunction json(body: Record<string, unknown>) {\n  return {\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify(body),\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n","numLines":60,"startLine":1,"totalLines":783}}}
