pe<typeof postgres>;\n  let db: Db;\n  let app: Hono;\n\n  const referrerKp = Keypair.generate();\n  const refereeKp = Keypair.generate();\n  const referrer = referrerKp.publicKey.toBase58();\n  const referee = refereeKp.publicKey.toBase58();\n\n  const testConfig = {\n    referralDefaultRateBps: 1000,\n    referralMinClaimLamports: 10_000_000, // 0.01 SOL\n  } as Config;\n\n  beforeAll(async () => {\n    rawSql = makeSql();\n\n    // Ensure referral + event_queue tables exist (idempotent)\n    await rawSql.file(\n      new URL(\"../../migrations/010_event_queue.sql\", import.meta.url).pathname,\n    );\n    await rawSql.file(\n      new URL(\"../../migrations/011_referral.sql\", import.meta.url).pathname,\n    );\n  });\n\n  afterAll(async () => {\n    if (db) await db.close();\n    await rawSql.end();","numLines":35,"startLine":56,"totalLines":783}}}
