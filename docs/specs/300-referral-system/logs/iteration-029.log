{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0197gZn5rD9fxNg5e7p942Fm","type":"tool_result","content":"   343→  // Referral — earnings & stats\n   344→  // -------------------------------------------------------------------------\n   345→\n   346→  /** Insert a referral earning row. Throws on duplicate (referee_wallet, round_id). */\n   347→  insertReferralEarning(params: {\n   348→    referrerWallet: string;\n   349→    refereeWallet: string;\n   350→    roundId: string;\n   351→    gameType: string;\n   352→    wagerLamports: number;\n   353→    feeLamports: number;\n   354→    referrerEarnedLamports: number;\n   355→    referrerRateBps: number;\n   356→    refereeRebateLamports: number;\n   357→    refereeRebateRateBps: number;\n   358→  }): Promise<ReferralEarning>;\n   359→\n   360→  /**\n   361→   * Get the pending (unclaimed) balance for a wallet.\n   362→   * Sum of referrer_earned where wallet=referrer + sum of referee_rebate where\n   363→   * wallet=referee, minus sum of completed claims for the wallet.\n   364→   * Returns a lamport string.\n   365→   */\n   366→  getPendingBalance(wallet: string): Promise<string>;\n   367→\n   368→  /** Get paginated per-game earnings for a wallet (as referrer). Newest first. */\n   369→  getReferralEarnings(\n   370→    wallet: string,\n   371→    page: number,\n   372→    limit: number,\n   373→  ): Promise<{ items: ReferralEarning[]; totalPages: number }>;\n   374→\n   375→  /** Get referral summary stats for a wallet. */\n   376→  getReferralStats(wallet: string): Promise<ReferralStats>;\n   377→\n   378→  // -------------------------------------------------------------------------\n   379→  // Referral — claims & rates\n   380→  // -------------------------------------------------------------------------\n   381→\n   382→  /** Insert a new referral claim row (status defaults to 'pending'). Returns the created claim. */\n   383→  insertReferralClaim(\n   384→    wallet: string,\n   385→    amountLamports: string,\n   386→  ): Promise<ReferralClaim>;\n   387→\n   388→  /** Get a referral claim by its UUID. Returns `undefined` if not found. */\n   389→  getReferralClaim(claimId: string): Promise<ReferralClaim | undefined>;\n   390→\n   391→  /**\n   392→   * Update a claim's status and optional metadata (tx_signature, error, processed_at).\n   393→   * Returns the updated claim.\n   394→   */\n   395→  updateClaimStatus(\n   396→    claimId: string,\n   397→    status: ReferralClaim[\"status\"],\n   398→    meta?: { txSignature?: string; error?: string },\n   399→  ): Promise<ReferralClaim>;\n   400→\n   401→  /**\n   402→   * Get the effective referrer rate for a wallet in bps.\n   403→   * Checks `referral_kol_rates` first; falls back to `defaultRateBps`.\n   404→   */\n   405→  getReferrerRate(\n   406→    wallet: string,\n   407→    defaultRateBps: number,\n   408→  ): Promise<number>;\n   409→\n   410→  /**\n   411→   * Execute a function within a database transaction.\n   412→   * All db methods called on the transactional Db share the same transaction.\n   413→   * Rolls back on error, commits on success.\n   414→   */\n   415→  withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T>;\n   416→\n   417→  /** Gracefully close the connection pool. */\n   418→  close(): Promise<void>;\n   419→}\n   420→\n   421→function normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n   422→  return {\n   423→    ...row,\n   424→    open_price: Number(row.open_price),\n   425→    open_price_expo: Number(row.open_price_expo),\n   426→    close_price: row.close_price === null ? null : Number(row.close_price),\n   427→    green_pool: Number(row.green_pool),\n   428→    red_pool: Number(row.red_pool),\n   429→    total_fee: Number(row.total_fee),\n   430→    // JSONB comes back as parsed objects from postgres.js\n   431→    green_entries: Array.isArray(row.green_entries)\n   432→      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   433→      : [],\n   434→    red_entries: Array.isArray(row.red_entries)\n   435→      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   436→      : [],\n   437→  };\n   438→}\n   439→\n   440→function normalizeTransaction(row: Transaction): Transaction {\n   441→  return {\n   442→    ...row,"}]},"parent_tool_use_id":"toolu_01FBkbFoVYBbtV21JBz2b79G","session_id":"773e2b1e-9c3d-4d53-809d-a95c06988ae7","uuid":"c2264d54-295f-4b25-bf9f-17d20b8d471e","timestamp":"2026-03-25T13:56:26.991Z"}
