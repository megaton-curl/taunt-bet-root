{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018tkXzJxm4GfGEcdV53PsaV","type":"tool_result","content":"   150→      return c.json(\n   151→        {\n   152→          error: {\n   153→            code: \"SELF_REFERRAL\",\n   154→            message: \"You cannot use your own referral code\",\n   155→            retryable: false,\n   156→          },\n   157→        },\n   158→        400,\n   159→      );\n   160→    }\n   161→\n   162→    // Check if the player already has a referrer\n   163→    const existingLink = await db.getReferralLinkByReferee(wallet);\n   164→    if (existingLink) {\n   165→      return c.json(\n   166→        {\n   167→          error: {\n   168→            code: \"ALREADY_LINKED\",\n   169→            message: \"You are already linked to a referrer\",\n   170→            retryable: false,\n   171→          },\n   172→        },\n   173→        409,\n   174→      );\n   175→    }\n   176→\n   177→    try {\n   178→      await db.insertReferralLink(codeRow.wallet, wallet);\n   179→      logger.info(\"Referral link created\", {\n   180→        referrer: codeRow.wallet,\n   181→        referee: wallet,\n   182→        code,\n   183→      });\n   184→      return c.json({\n   185→        referrer: codeRow.wallet,\n   186→        benefit: \"10% fee rebate on all games\",\n   187→      });\n   188→    } catch (err) {\n   189→      // Handle race condition: another request linked this referee between check and insert\n   190→      const msg = err instanceof Error ? err.message : String(err);\n   191→      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n   192→        return c.json(\n   193→          {\n   194→            error: {\n   195→              code: \"ALREADY_LINKED\",\n   196→              message: \"You are already linked to a referrer\",\n   197→              retryable: false,\n   198→            },\n   199→          },\n   200→          409,\n   201→        );\n   202→      }\n   203→      logger.error(\"Failed to create referral link\", {\n   204→        err: String(err),\n   205→        wallet,\n   206→        code,\n   207→      });\n   208→      return c.json({ error: \"Failed to apply referral code\" }, 500);\n   209→    }\n   210→  });\n   211→\n   212→  // GET /code — return the authenticated player's current referral code\n   213→  app.get(\"/code\", async (c) => {\n   214→    const wallet = c.get(\"wallet\");\n   215→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   216→\n   217→    const row = await db.getReferralCodeByWallet(wallet);\n   218→    if (!row) {\n   219→      return c.json(\n   220→        {\n   221→          error: {\n   222→            code: \"NO_CODE\",\n   223→            message: \"No referral code set for this wallet\",\n   224→          },\n   225→        },\n   226→        404,\n   227→      );\n   228→    }\n   229→\n   230→    return c.json({\n   231→      code: row.code,\n   232→      url: `${REFERRAL_BASE_URL}/${row.code}`,\n   233→    });\n   234→  });\n   235→\n   236→  // GET /referrer — check if the authenticated player has a referrer\n   237→  app.get(\"/referrer\", async (c) => {\n   238→    const wallet = c.get(\"wallet\");\n   239→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   240→\n   241→    try {\n   242→      const link = await db.getReferralLinkByReferee(wallet);\n   243→      if (!link) {\n   244→        return c.json(\n   245→          {\n   246→            error: {\n   247→              code: \"NO_REFERRER\",\n   248→              message: \"You are not linked to a referrer\",\n   249→            },\n   250→          },\n   251→          404,\n   252→        );\n   253→      }\n   254→\n   255→      return c.json({\n   256→        referrerWallet: link.referrer_wallet,\n   257→        linkedAt: link.created_at.toISOString(),\n   258→      });\n   259→    } catch (err) {\n   260→      logger.error(\"Failed to fetch referrer\", {\n   261→        err: String(err),\n   262→        wallet,\n   263→      });\n   264→      return c.json({ error: \"Failed to fetch referrer\" }, 500);\n   265→    }\n   266→  });\n   267→\n   268→  // GET /stats — referral summary stats for authenticated wallet\n   269→  app.get(\"/stats\", async (c) => {\n   270→    const wallet = c.get(\"wallet\");\n   271→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   272→\n   273→    try {\n   274→      const stats = await db.getReferralStats(wallet);\n   275→      return c.json({\n   276→        referredCount: stats.referred_count,\n   277→        activeCount: stats.active_count,\n   278→        totalVolumeLamports: stats.total_volume_lamports,\n   279→        totalEarnedLamports: stats.total_earned_lamports,\n   280→        totalRebateLamports: stats.total_rebate_lamports,\n   281→        pendingLamports: stats.pending_lamports,\n   282→      });\n   283→    } catch (err) {\n   284→      logger.error(\"Failed to fetch referral stats\", {\n   285→        err: String(err),\n   286→        wallet,\n   287→      });\n   288→      return c.json({ error: \"Failed to fetch referral stats\" }, 500);\n   289→    }\n   290→  });\n   291→\n   292→  // GET /earnings — paginated per-game earnings log\n   293→  app.get(\"/earnings\", async (c) => {\n   294→    const wallet = c.get(\"wallet\");\n   295→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   296→\n   297→    const pageParam = c.req.query(\"page\");\n   298→    const limitParam = c.req.query(\"limit\");\n   299→    const page = pageParam ? Math.max(1, Math.floor(Number(pageParam))) : 1;\n   300→    const limit = limitParam\n   301→      ? Math.min(100, Math.max(1, Math.floor(Number(limitParam))))\n   302→      : 20;\n   303→\n   304→    if (Number.isNaN(page) || Number.isNaN(limit)) {\n   305→      return c.json(\n   306→        {\n   307→          error: {\n   308→            code: \"INVALID_PARAMS\",\n   309→            message: \"page and limit must be positive integers\",\n   310→          },\n   311→        },\n   312→        400,\n   313→      );\n   314→    }\n   315→\n   316→    try {\n   317→      const result = await db.getReferralEarnings(wallet, page, limit);\n   318→      return c.json({\n   319→        items: result.items.map((e) => ({\n   320→          roundId: e.round_id,\n   321→          gameType: e.game_type,\n   322→          refereeWallet: e.referee_wallet,\n   323→          wagerLamports: String(e.wager_lamports),\n   324→          earnedLamports: String(e.referrer_earned_lamports),\n   325→          createdAt: e.created_at.toISOString(),\n   326→        })),\n   327→        pagination: {\n   328→          page,\n   329→          totalPages: result.totalPages,\n   330→        },\n   331→      });\n   332→    } catch (err) {\n   333→      logger.error(\"Failed to fetch referral earnings\", {\n   334→        err: String(err),\n   335→        wallet,\n   336→      });\n   337→      return c.json({ error: \"Failed to fetch referral earnings\" }, 500);\n   338→    }\n   339→  });\n   340→\n   341→  // POST /claim — request payout of pending referral earnings (async via queue)\n   342→  app.post(\"/claim\", async (c) => {\n   343→    const wallet = c.get(\"wallet\");\n   344→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   345→\n   346→    try {\n   347→      // Snapshot pending balance\n   348→      const pendingStr = await db.getPendingBalance(wallet);\n   349→      const pendingLamports = BigInt(pendingStr);\n   350→\n   351→      if (pendingLamports <= 0n) {\n   352→        return c.json(\n   353→          {\n   354→            error: {\n   355→              code: \"ZERO_BALANCE\",\n   356→              message: \"No pending earnings to claim\",\n   357→              retryable: false,\n   358→            },\n   359→          },\n   360→          400,\n   361→        );\n   362→      }\n   363→\n   364→      if (pendingLamports < BigInt(config.referralMinClaimLamports)) {\n   365→        return c.json(\n   366→          {\n   367→            error: {\n   368→              code: \"BELOW_THRESHOLD\",\n   369→              message: `Minimum claim amount is ${config.referralMinClaimLamports} lamports (${(config.referralMinClaimLamports / 1e9).toFixed(2)} SOL)`,\n   370→              retryable: false,\n   371→            },\n   372→          },\n   373→          400,\n   374→        );\n   375→      }\n   376→\n   377→      // Atomically insert claim row + emit queue event\n   378→      const claim = await sql.begin(async (tx) => {\n   379→        const rows = await (tx as unknown as postgres.Sql)<\n   380→          {\n   381→            id: string;\n   382→            wallet: string;\n   383→            amount_lamports: string;\n   384→            status: string;\n   385→          }[]\n   386→        >`\n   387→          INSERT INTO referral_claims (wallet, amount_lamports, status)\n   388→          VALUES (${wallet}, ${pendingStr}, 'pending')\n   389→          RETURNING id, wallet, amount_lamports, status\n   390→        `;\n   391→        const row = rows[0]!;\n   392→\n   393→        await emitEvent(\n   394→          tx as unknown as postgres.Sql,\n   395→          EventTypes.REFERRAL_CLAIM_REQUESTED,\n   396→          {\n   397→            claimId: row.id,\n   398→            wallet: row.wallet,\n   399→            amountLamports: row.amount_lamports,\n   400→            requestedAt: new Date().toISOString(),\n   401→          },\n   402→        );\n   403→\n   404→        return row;\n   405→      });\n   406→\n   407→      logger.info(\"Referral claim requested\", {\n   408→        wallet,\n   409→        claimId: claim.id,\n   410→        amountLamports: claim.amount_lamports,\n   411→      });\n   412→\n   413→      return c.json(\n   414→        {\n   415→          claimId: claim.id,\n   416→          amountLamports: claim.amount_lamports,\n   417→          status: \"pending\",\n   418→        },\n   419→        202,\n   420→      );\n   421→    } catch (err) {\n   422→      logger.error(\"Failed to create referral claim\", {\n   423→        err: String(err),\n   424→        wallet,\n   425→      });\n   426→      return c.json({ error: \"Failed to create referral claim\" }, 500);\n   427→    }\n   428→  });\n   429→\n   430→  // GET /claim/:claimId — poll claim status\n   431→  app.get(\"/claim/:claimId\", async (c) => {\n   432→    const wallet = c.get(\"wallet\");\n   433→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   434→\n   435→    const claimId = c.req.param(\"claimId\");\n   436→\n   437→    try {\n   438→      const claim = await db.getReferralClaim(claimId);\n   439→      if (!claim) {\n   440→        return c.json(\n   441→          {\n   442→            error: {\n   443→              code: \"CLAIM_NOT_FOUND\",\n   444→              message: \"Claim not found\",\n   445→            },\n   446→          },\n   447→          404,\n   448→        );\n   449→      }"}]},"parent_tool_use_id":"toolu_01FBkbFoVYBbtV21JBz2b79G","session_id":"773e2b1e-9c3d-4d53-809d-a95c06988ae7","uuid":"9fb2b620-0cc7-4852-b4fc-15cdf96f3058","timestamp":"2026-03-25T13:56:15.388Z"}
