{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VmcqXidhb1zKHiFGvyj5Wm","type":"tool_result","content":"     1→/**\n     2→ * Referral routes — code management, linking, stats, earnings, and claims.\n     3→ */\n     4→\n     5→import { Hono } from \"hono\";\n     6→import type postgres from \"postgres\";\n     7→import type { AppEnv } from \"../hono-env.js\";\n     8→import type { Db } from \"../db.js\";\n     9→import type { Config } from \"../config.js\";\n    10→import { logger } from \"../logger.js\";\n    11→import { emitEvent } from \"../queue/emit-event.js\";\n    12→import { EventTypes } from \"../queue/event-types.js\";\n    13→\n    14→export interface ReferralRoutesDeps {\n    15→  db: Db;\n    16→  sql: postgres.Sql;\n    17→  config: Config;\n    18→}\n    19→\n    20→/** Referral code validation: 3-16 chars, lowercase alphanumeric + hyphens */\n    21→const CODE_REGEX = /^[a-z0-9-]{3,16}$/;\n    22→\n    23→const REFERRAL_BASE_URL = \"https://taunt.bet/r\";\n    24→\n    25→export function createReferralRoutes(deps: ReferralRoutesDeps) {\n    26→  const { db, sql, config } = deps;\n    27→  const app = new Hono<AppEnv>();\n    28→\n    29→  // POST /code — set or replace the player's referral code\n    30→  app.post(\"/code\", async (c) => {\n    31→    const wallet = c.get(\"wallet\");\n    32→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n    33→\n    34→    let body: { code?: unknown };\n    35→    try {\n    36→      body = await c.req.json();\n    37→    } catch {\n    38→      return c.json({ error: \"Invalid request body\" }, 400);\n    39→    }\n    40→\n    41→    const code = typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n    42→\n    43→    if (!CODE_REGEX.test(code)) {\n    44→      return c.json(\n    45→        {\n    46→          error: {\n    47→            code: \"INVALID_CODE\",\n    48→            message:\n    49→              \"Code must be 3-16 characters, lowercase letters, numbers, and hyphens only\",\n    50→          },\n    51→        },\n    52→        400,\n    53→      );\n    54→    }\n    55→\n    56→    // Check if this code is already taken by another wallet\n    57→    const existing = await db.getReferralCodeByCode(code);\n    58→    if (existing && existing.wallet !== wallet) {\n    59→      return c.json(\n    60→        {\n    61→          error: {\n    62→            code: \"CODE_TAKEN\",\n    63→            message: \"This referral code is already in use\",\n    64→            retryable: false,\n    65→          },\n    66→        },\n    67→        409,\n    68→      );\n    69→    }\n    70→\n    71→    try {\n    72→      const result = await db.upsertReferralCode(wallet, code);\n    73→      logger.info(\"Referral code set\", { wallet, code: result.code });\n    74→      return c.json({\n    75→        code: result.code,\n    76→        url: `${REFERRAL_BASE_URL}/${result.code}`,\n    77→      });\n    78→    } catch (err) {\n    79→      // Handle race condition: another wallet grabbed the code between check and insert\n    80→      const msg = err instanceof Error ? err.message : String(err);\n    81→      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n    82→        return c.json(\n    83→          {\n    84→            error: {\n    85→              code: \"CODE_TAKEN\",\n    86→              message: \"This referral code is already in use\",\n    87→              retryable: false,\n    88→            },\n    89→          },\n    90→          409,\n    91→        );\n    92→      }\n    93→      logger.error(\"Failed to set referral code\", { err: String(err), wallet });\n    94→      return c.json({ error: \"Failed to set referral code\" }, 500);\n    95→    }\n    96→  });\n    97→\n    98→  // POST /apply — link the authenticated player to a referrer via their code\n    99→  app.post(\"/apply\", async (c) => {\n   100→    const wallet = c.get(\"wallet\");\n   101→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   102→\n   103→    let body: { code?: unknown };\n   104→    try {\n   105→      body = await c.req.json();\n   106→    } catch {\n   107→      return c.json(\n   108→        {\n   109→          error: {\n   110→            code: \"INVALID_BODY\",\n   111→            message: \"Invalid request body\",\n   112→          },\n   113→        },\n   114→        400,\n   115→      );\n   116→    }\n   117→\n   118→    const code =\n   119→      typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n   120→\n   121→    if (!code) {\n   122→      return c.json(\n   123→        {\n   124→          error: {\n   125→            code: \"INVALID_CODE\",\n   126→            message: \"Referral code is required\",\n   127→          },\n   128→        },\n   129→        400,\n   130→      );\n   131→    }\n   132→\n   133→    // Look up the referral code to find the referrer\n   134→    const codeRow = await db.getReferralCodeByCode(code);\n   135→    if (!codeRow) {\n   136→      return c.json(\n   137→        {\n   138→          error: {\n   139→            code: \"CODE_NOT_FOUND\",\n   140→            message: \"Referral code does not exist\",\n   141→            retryable: false,\n   142→          },\n   143→        },\n   144→        404,\n   145→      );\n   146→    }\n   147→\n   148→    // Self-referral check\n   149→    if (codeRow.wallet === wallet) {\n   150→      return c.json("}]},"parent_tool_use_id":"toolu_01FBkbFoVYBbtV21JBz2b79G","session_id":"773e2b1e-9c3d-4d53-809d-a95c06988ae7","uuid":"84df14ae-1d53-4380-b619-df863606ef89","timestamp":"2026-03-25T13:56:13.554Z"}
