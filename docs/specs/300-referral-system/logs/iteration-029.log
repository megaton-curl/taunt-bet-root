{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WdYYdv6yn2FVU2TTwjsMo4","type":"tool_result","content":"   145→export interface ReferralEarning {\n   146→  id: number;\n   147→  referrer_wallet: string;\n   148→  referee_wallet: string;\n   149→  round_id: string;\n   150→  game_type: string;\n   151→  wager_lamports: number;\n   152→  fee_lamports: number;\n   153→  referrer_earned_lamports: number;\n   154→  referrer_rate_bps: number;\n   155→  referee_rebate_lamports: number;\n   156→  referee_rebate_rate_bps: number;\n   157→  created_at: Date;\n   158→}\n   159→\n   160→export interface ReferralStats {\n   161→  referred_count: number;\n   162→  active_count: number;\n   163→  total_volume_lamports: string;\n   164→  total_earned_lamports: string;\n   165→  total_rebate_lamports: string;\n   166→  pending_lamports: string;\n   167→}\n   168→\n   169→export interface ReferralClaim {\n   170→  id: string;\n   171→  wallet: string;\n   172→  amount_lamports: string;\n   173→  status: \"pending\" | \"processing\" | \"completed\" | \"failed\";\n   174→  tx_signature: string | null;\n   175→  error: string | null;\n   176→  requested_at: Date;\n   177→  processed_at: Date | null;\n   178→}\n   179→\n   180→// ---------------------------------------------------------------------------\n   181→// Phase transition guard\n   182→// ---------------------------------------------------------------------------\n   183→\n   184→/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n   185→const VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n   186→  created: [\"locked\", \"expired\"],\n   187→  locked: [\"settling\"],\n   188→  settling: [\"settled\"],\n   189→  settled: [],\n   190→  expired: [],\n   191→};\n   192→\n   193→function assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n   194→  const allowed = VALID_TRANSITIONS[from];\n   195→  if (!allowed.includes(to)) {\n   196→    throw new Error(\n   197→      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n   198→    );\n   199→  }\n   200→}\n   201→\n   202→// ---------------------------------------------------------------------------\n   203→// DB client\n   204→// ---------------------------------------------------------------------------\n   205→\n   206→export interface Db {\n   207→  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n   208→  insertRound(params: InsertRoundParams): Promise<Round>;\n   209→\n   210→  /** Delete a round by PDA. Returns true if a row was removed. */\n   211→  deleteRoundByPda(pda: string): Promise<boolean>;\n   212→\n   213→  /** Transition a round's phase. Enforces unidirectional state machine.\n   214→   *  Optional `updates` can set additional columns alongside the phase change. */\n   215→  updateRoundPhase(\n   216→    pda: string,\n   217→    newPhase: RoundPhase,\n   218→    updates?: Partial<\n   219→      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n   220→    >,\n   221→  ): Promise<Round>;\n   222→\n   223→  /** Update the entries JSONB column for a settled round. */\n   224→  updateRoundEntries(\n   225→    pda: string,\n   226→    entries: Array<{ player: string; amountLamports: number }>,\n   227→  ): Promise<Round>;\n   228→\n   229→  /** Get a single round by its PDA. Returns `undefined` if not found. */\n   230→  getRoundByPda(pda: string): Promise<Round | undefined>;\n   231→\n   232→  /** Get all rounds matching a given phase. */\n   233→  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n   234→\n   235→  /** Append an operator event to the audit log. */\n   236→  insertOperatorEvent(\n   237→    pda: string | null,\n   238→    eventType: OperatorEventType,\n   239→    payload?: unknown,\n   240→  ): Promise<OperatorEvent>;\n   241→\n   242→  /** Get the latest operator event for a PDA + type. */\n   243→  getLatestOperatorEvent(\n   244→    pda: string,\n   245→    eventType: OperatorEventType,\n   246→  ): Promise<OperatorEvent | undefined>;\n   247→\n   248→  /** Get a single round by its match_id. Returns `undefined` if not found. */\n   249→  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n   250→\n   251→  /** Batch-fetch the latest operator event per PDA for a given event type. */\n   252→  getLatestOperatorEventsForPdas(\n   253→    pdas: string[],\n   254→    eventType: OperatorEventType,\n   255→  ): Promise<Map<string, OperatorEvent>>;\n   256→\n   257→  /** Get recently settled rounds for a game, ordered newest first. */\n   258→  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n   259→\n   260→  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n   261→  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n   262→\n   263→  // -------------------------------------------------------------------------\n   264→  // Close Call rounds\n   265→  // -------------------------------------------------------------------------\n   266→\n   267→  /** Insert a new Close Call round. */\n   268→  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n   269→\n   270→  /** Get a Close Call round by round_id (16-char hex). */\n   271→  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n   272→\n   273→  /** Get the current active (open) Close Call round. */\n   274→  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n   275→\n   276→  /** Get the most recent settled/refunded Close Call rounds. */\n   277→  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n   278→\n   279→  /** Update a Close Call round after settlement. */\n   280→  settleCloseCallRound(\n   281→    roundId: string,\n   282→    updates: {\n   283→      phase: CloseCallPhase;\n   284→      outcome: CloseCallOutcome;\n   285→      closePrice?: number;\n   286→      greenPool?: number;\n   287→      redPool?: number;\n   288→      totalFee?: number;\n   289→      greenEntries?: Array<{ player: string; amountLamports: number }>;\n   290→      redEntries?: Array<{ player: string; amountLamports: number }>;\n   291→      settleTx?: string;\n   292→    },\n   293→  ): Promise<CloseCallRound>;\n   294→\n   295→  // -------------------------------------------------------------------------\n   296→  // Transactions\n   297→  // -------------------------------------------------------------------------\n   298→\n   299→  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n   300→  insertTransaction(params: InsertTransactionParams): Promise<void>;\n   301→\n   302→  /** Insert multiple transactions in a single batch. */\n   303→  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n   304→\n   305→  /** Get paginated transactions for a wallet, newest first. */\n   306→  getTransactions(\n   307→    wallet: string,\n   308→    cursor?: string,\n   309→    limit?: number,\n   310→    game?: string,\n   311→  ): Promise<Transaction[]>;\n   312→\n   313→  // -------------------------------------------------------------------------\n   314→  // Referral — codes\n   315→  // -------------------------------------------------------------------------\n   316→\n   317→  /** Insert a new referral code for a wallet. Throws on duplicate wallet or code. */\n   318→  insertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n   319→\n   320→  /** Get a wallet's referral code. Returns `undefined` if none set. */\n   321→  getReferralCodeByWallet(wallet: string): Promise<ReferralCode | undefined>;\n   322→\n   323→  /** Look up a referral code record by code string. Returns `undefined` if not found. */\n   324→  getReferralCodeByCode(code: string): Promise<ReferralCode | undefined>;\n   325→\n   326→  /** Set or replace a wallet's referral code (INSERT … ON CONFLICT UPDATE). */\n   327→  upsertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n   328→\n   329→  // -------------------------------------------------------------------------\n   330→  // Referral — links\n   331→  // -------------------------------------------------------------------------\n   332→\n   333→  /** Create a referral link (referrer → referee). Throws on duplicate referee. */\n   334→  insertReferralLink(referrerWallet: string, refereeWallet: string): Promise<ReferralLink>;\n   335→\n   336→  /** Get the referral link for a referee wallet. Returns `undefined` if not referred. */\n   337→  getReferralLinkByReferee(refereeWallet: string): Promise<ReferralLink | undefined>;\n   338→\n   339→  /** Get all referral links where the given wallet is the referrer. */\n   340→  getReferralLinksByReferrer(referrerWallet: string): Promise<ReferralLink[]>;\n   341→\n   342→  // -------------------------------------------------------------------------\n   343→  // Referral — earnings & stats\n   344→  // -------------------------------------------------------------------------"}]},"parent_tool_use_id":"toolu_01FBkbFoVYBbtV21JBz2b79G","session_id":"773e2b1e-9c3d-4d53-809d-a95c06988ae7","uuid":"7de5ef59-19bd-4776-8d80-abef936b3ae9","timestamp":"2026-03-25T13:56:25.198Z"}
