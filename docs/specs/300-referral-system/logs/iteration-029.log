{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SMB7QdUTaH2AhAuzHPYhTW","type":"tool_result","content":"     1→/**\n     2→ * Settlement worker — polls the chain for server-owned rounds that are ready\n     3→ * for backend settlement across supported games.\n     4→ */\n     5→\n     6→import { performance } from \"node:perf_hooks\";\n     7→import { Connection, PublicKey } from \"@solana/web3.js\";\n     8→import { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID } from \"../tx-builder.js\";\n     9→import type { Db } from \"../db.js\";\n    10→import { logger } from \"../logger.js\";\n    11→import {\n    12→  coinflipMatchSize,\n    13→  decodeCoinflipMatch,\n    14→  decodeLordRound,\n    15→  lordRoundDiscriminatorFilter,\n    16→} from \"./account-decoder.js\";\n    17→\n    18→const PHASE_LOCKED_VALUE = 1;\n    19→const LORD_PHASE_ACTIVE_VALUE = 1;\n    20→\n    21→export interface SettlementWorkerDeps {\n    22→  db: Db;\n    23→  connection: Connection;\n    24→  serverKey: PublicKey;\n    25→  pollIntervalMs: number;\n    26→  /** Called when a match is detected as ready for settlement (target_slot reached). */\n    27→  onSettleReady?: (pda: string) => Promise<void>;\n    28→  /** Called to check if a PDA is finalized (settled or permanently failed). */\n    29→  isFinalized?: (pda: string) => boolean;\n    30→}\n    31→\n    32→export interface SettlementWorker {\n    33→  start(): void;\n    34→  stop(): void;\n    35→  readonly isRunning: boolean;\n    36→  /** Run a single poll cycle (exposed for testing). */\n    37→  poll(): Promise<void>;\n    38→}\n    39→\n    40→export function createSettlementWorker(\n    41→  deps: SettlementWorkerDeps,\n    42→): SettlementWorker {\n    43→  const { db, connection, serverKey, pollIntervalMs } = deps;\n    44→  const discoveredPdas = new Set<string>();\n    45→  const readyPdas = new Set<string>();\n    46→  /** PDAs that failed decode — stale accounts from previous deploys. Logged once, then skipped. */\n    47→  const undecodeablePdas = new Set<string>();\n    48→  let running = false;\n    49→  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n    50→\n    51→  async function handleDiscoveredRound(\n    52→    pda: string,\n    53→    targetSlot: bigint,\n    54→    currentSlot: number,\n    55→    slotTime: string | null,\n    56→  ): Promise<void> {\n    57→    const round = await db.getRoundByPda(pda);\n    58→    if (!round) {\n    59→      return;\n    60→    }\n    61→\n    62→    if (!discoveredPdas.has(pda)) {\n    63→      discoveredPdas.add(pda);\n    64→      if (round.phase === \"created\") {\n    65→        await db.updateRoundPhase(pda, \"locked\", {\n    66→          target_slot: targetSlot.toString(),\n    67→        });\n    68→        await db.insertOperatorEvent(pda, \"match_detected\", {\n    69→          targetSlot: targetSlot.toString(),\n    70→          currentSlot,\n    71→          game: round.game,\n    72→        });\n    73→        logger.info(\"settlement worker detected locked round\", {\n    74→          pda,\n    75→          creator: round.creator,\n    76→          targetSlot: targetSlot.toString(),\n    77→          currentSlot,\n    78→          slotTime,\n    79→          game: round.game,\n    80→        });\n    81→      }\n    82→    }\n    83→\n    84→    if (BigInt(currentSlot) >= targetSlot && deps.onSettleReady) {\n    85→      if (deps.isFinalized?.(pda)) {\n    86→        // Clean up tracking sets for finalized PDAs to prevent unbounded growth\n    87→        discoveredPdas.delete(pda);\n    88→        readyPdas.delete(pda);\n    89→        return;\n    90→      }\n    91→\n    92→      const slotsAhead = currentSlot - Number(targetSlot);\n    93→      if (!readyPdas.has(pda)) {\n    94→        readyPdas.add(pda);\n    95→        logger.info(\"settlement worker found round ready\", {\n    96→          pda,\n    97→          targetSlot: targetSlot.toString(),\n    98→          currentSlot,\n    99→          slotsAhead,\n   100→          estimatedDelayMs: slotsAhead * 400,\n   101→          slotTime,\n   102→        });\n   103→      }\n   104→      const tSettle0 = performance.now();\n   105→      await deps.onSettleReady(pda);\n   106→      const tSettle1 = performance.now();\n   107→      logger.debug(\"settlement worker onSettleReady completed\", {\n   108→        pda: pda.slice(0, 12),\n   109→        settleMs: Math.round(tSettle1 - tSettle0),\n   110→      });\n   111→    }\n   112→  }\n   113→\n   114→  async function poll(): Promise<void> {\n   115→    const t0 = performance.now();\n   116→    const currentSlot = await connection.getSlot();\n   117→    const blockTime = await connection.getBlockTime(currentSlot).catch(() => null);\n   118→    const slotTime = blockTime ? new Date(blockTime * 1000).toISOString() : null;\n   119→    const tSlot = performance.now();\n   120→\n   121→    // Coinflip: fetch by dataSize (distinguishes Match from Config), decode + filter\n   122→    const coinflipAccounts = await connection.getProgramAccounts(COINFLIP_PROGRAM_ID, {\n   123→      filters: [{ dataSize: coinflipMatchSize() }],\n   124→    });\n   125→    const tCoinflip = performance.now();\n   126→\n   127→    for (const { pubkey, account } of coinflipAccounts) {\n   128→      const key = pubkey.toBase58();\n   129→      if (undecodeablePdas.has(key)) continue;\n   130→      try {\n   131→        const match = decodeCoinflipMatch(Buffer.from(account.data));\n   132→        if (match.phase !== PHASE_LOCKED_VALUE || !match.server.equals(serverKey)) continue;\n   133→        await handleDiscoveredRound(key, match.targetSlot, currentSlot, slotTime);\n   134→      } catch {\n   135→        undecodeablePdas.add(key);\n   136→        logger.warn(\"skipping undecodeable coinflip account\", { pda: key });\n   137→      }\n   138→    }\n   139→\n   140→    // Lord: fetch by discriminator (variable-size accounts), decode + filter\n   141→    const lordAccounts = await connection.getProgramAccounts(LORDOFRNGS_PROGRAM_ID, {\n   142→      filters: [lordRoundDiscriminatorFilter()],\n   143→    });\n   144→    const tLord = performance.now();\n   145→\n   146→    for (const { pubkey, account } of lordAccounts) {\n   147→      const key = pubkey.toBase58();\n   148→      if (undecodeablePdas.has(key)) continue;\n   149→      try {\n   150→        const round = decodeLordRound(Buffer.from(account.data));\n   151→        if (round.phase !== LORD_PHASE_ACTIVE_VALUE || !round.server.equals(serverKey)) continue;\n   152→        if (round.targetEntropySlot <= 0n) continue;\n   153→        await handleDiscoveredRound(key, round.targetEntropySlot, currentSlot, slotTime);\n   154→      } catch {\n   155→        undecodeablePdas.add(key);\n   156→        logger.warn(\"skipping undecodeable lord account\", { pda: key });\n   157→      }\n   158→    }\n   159→    const tEnd = performance.now();\n   160→\n   161→    logger.debug(\"settlement poll cycle\", {\n   162→      slotMs: Math.round(tSlot - t0),\n   163→      coinflipFetchMs: Math.round(tCoinflip - tSlot),\n   164→      lordFetchMs: Math.round(tLord - tCoinflip),\n   165→      totalMs: Math.round(tEnd - t0),\n   166→      coinflipAccounts: coinflipAccounts.length,\n   167→      lordAccounts: lordAccounts.length,\n   168→      currentSlot,\n   169→      slotTime,\n   170→    });\n   171→  }\n   172→\n   173→  async function loop(): Promise<void> {\n   174→    if (!running) return;\n   175→    try {\n   176→      await poll();\n   177→    } catch (err) {\n   178→      // Log but don't crash — transient RPC errors are expected\n   179→      logger.error(\"settlement worker poll error\", {\n   180→        error: err instanceof Error ? err.message : String(err),\n   181→      });\n   182→    }\n   183→    if (running) {\n   184→      timeoutId = setTimeout(loop, pollIntervalMs);\n   185→    }\n   186→  }\n   187→\n   188→  return {\n   189→    start() {\n   190→      if (running) return;\n   191→      running = true;\n   192→      const rpcUrl = connection.rpcEndpoint;\n   193→      const trimmedRpc = (() => {\n   194→        try {\n   195→          const u = new URL(rpcUrl);\n   196→          return `${u.host}${u.pathname}`;\n   197→        } catch {\n   198→          return rpcUrl.slice(0, 40) + \"…\";\n   199→        }\n   200→      })();\n   201→      logger.info(\"settlement worker started\", {\n   202→        serverKey: serverKey.toBase58(),\n   203→        pollIntervalMs,\n   204→        rpc: trimmedRpc,\n   205→      });\n   206→      loop();\n   207→    },\n   208→    stop() {\n   209→      running = false;\n   210→      if (timeoutId) {\n   211→        clearTimeout(timeoutId);\n   212→        timeoutId = null;\n   213→      }\n   214→      logger.info(\"settlement worker stopped\", {\n   215→        serverKey: serverKey.toBase58(),\n   216→      });\n   217→    },\n   218→    get isRunning() {\n   219→      return running;\n   220→    },\n   221→    poll,\n   222→  };\n   223→}\n   224→"}]},"parent_tool_use_id":"toolu_01K6S9FTWc4Mt7jLihK2J2QP","session_id":"773e2b1e-9c3d-4d53-809d-a95c06988ae7","uuid":"2d6b7470-05d1-488d-9ae7-38545bb1e8b2","timestamp":"2026-03-25T13:56:03.684Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016ErVG2HRg1oPjzsHdPH5AG","type":"tool_result","content":"     1→/**\n     2→ * Referral route tests — set code, apply, stats, earnings, claim flows.\n     3→ *\n     4→ * Uses real Postgres (same pattern as auth-routes.test.ts) with TRUNCATE\n     5→ * between tests for isolation.\n     6→ */\n     7→\n     8→import { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n     9→import { Hono } from \"hono\";\n    10→import { Keypair } from \"@solana/web3.js\";\n    11→import { SignJWT } from \"jose\";\n    12→import postgres from \"postgres\";\n    13→import { createDb, type Db } from \"../db.js\";\n    14→import { createReferralRoutes } from \"../routes/referral.js\";\n    15→import { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\n    16→import type { Config } from \"../config.js\";\n    17→\n    18→// ---------------------------------------------------------------------------\n    19→// Constants\n    20→// ---------------------------------------------------------------------------\n    21→\n    22→const DATABASE_URL =\n    23→  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n    24→const JWT_SECRET = new TextEncoder().encode(\"test-secret-for-referral-tests\");\n    25→\n    26→/** Build postgres connection — prefers DATABASE_URL, falls back to Unix socket. */\n    27→function makeSql() {\n    28→  if (process.env.DATABASE_URL) return postgres(process.env.DATABASE_URL);\n    29→  // Dev container: postgres listens on Unix socket only\n    30→  return postgres({\n    31→    host: \"/var/run/postgresql\",\n    32→    user: \"vscode\",\n    33→    database: \"rng_utopia_dev\",\n    34→  });\n    35→}\n    36→\n    37→// ---------------------------------------------------------------------------\n    38→// Helpers\n    39→// ---------------------------------------------------------------------------\n    40→\n    41→async function makeJwt(wallet: string): Promise<string> {\n    42→  const now = Math.floor(Date.now() / 1000);\n    43→  return new SignJWT({ sub: wallet })\n    44→    .setProtectedHeader({ alg: \"HS256\" })\n    45→    .setIssuedAt(now)\n    46→    .setExpirationTime(now + 3600)\n    47→    .sign(JWT_SECRET);\n    48→}\n    49→\n    50→function json(body: Record<string, unknown>) {\n    51→  return {\n    52→    headers: { \"Content-Type\": \"application/json\" },\n    53→    body: JSON.stringify(body),\n    54→  };\n    55→}\n    56→\n    57→// ---------------------------------------------------------------------------\n    58→// Test suite\n    59→// ---------------------------------------------------------------------------\n    60→\n    61→describe(\"Referral routes\", () => {\n    62→  let rawSql: ReturnType<typeof postgres>;\n    63→  let db: Db;\n    64→  let app: Hono;\n    65→\n    66→  const referrerKp = Keypair.generate();\n    67→  const refereeKp = Keypair.generate();\n    68→  const referrer = referrerKp.publicKey.toBase58();\n    69→  const referee = refereeKp.publicKey.toBase58();\n    70→\n    71→  const testConfig = {\n    72→    referralDefaultRateBps: 1000,\n    73→    referralMinClaimLamports: 10_000_000, // 0.01 SOL\n    74→  } as Config;\n    75→\n    76→  beforeAll(async () => {\n    77→    rawSql = makeSql();\n    78→\n    79→    // Ensure referral + event_queue tables exist (idempotent)\n    80→    await rawSql.file(\n    81→      new URL(\"../../migrations/010_event_queue.sql\", import.meta.url).pathname,\n    82→    );\n    83→    await rawSql.file(\n    84→      new URL(\"../../migrations/011_referral.sql\", import.meta.url).pathname,\n    85→    );\n    86→  });\n    87→\n    88→  afterAll(async () => {\n    89→    if (db) await db.close();\n    90→    await rawSql.end();\n    91→  });\n    92→\n    93→  beforeEach(async () => {\n    94→    await rawSql`TRUNCATE referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, event_queue RESTART IDENTITY CASCADE`;\n    95→\n    96→    db = createDb(DATABASE_URL, rawSql);\n    97→\n    98→    app = new Hono();\n    99→    app.use(\n   100→      \"/referral/*\",\n   101→      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n   102→    );\n   103→    app.route(\n   104→      \"/referral\",\n   105→      createReferralRoutes({ db, sql: rawSql, config: testConfig }),\n   106→    );\n   107→  });\n   108→\n   109→  // -----------------------------------------------------------------------\n   110→  // POST /referral/code — set custom code\n   111→  // -----------------------------------------------------------------------\n   112→\n   113→  describe(\"POST /referral/code\", () => {\n   114→    it(\"sets a valid custom code and returns code + url\", async () => {\n   115→      const token = await makeJwt(referrer);\n   116→      const res = await app.request(\"/referral/code\", {\n   117→        method: \"POST\",\n   118→        ...json({ code: \"my-code-123\" }),\n   119→        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n   120→      });\n   121→\n   122→      expect(res.status).toBe(200);\n   123→      const body = (await res.json()) as { code: string; url: string };\n   124→      expect(body.code).toBe(\"my-code-123\");\n   125→      expect(body.url).toBe(\"https://taunt.bet/r/my-code-123\");\n   126→    });\n   127→\n   128→    it(\"rejects code shorter than 3 chars\", async () => {\n   129→      const token = await makeJwt(referrer);\n   130→      const res = await app.request(\"/referral/code\", {\n   131→        method: \"POST\",\n   132→        ...json({ code: \"ab\" }),\n   133→        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n   134→      });\n   135→\n   136→      expect(res.status).toBe(400);\n   137→      const body = (await res.json()) as { error: { code: string } };\n   138→      expect(body.error.code).toBe(\"INVALID_CODE\");\n   139→    });\n   140→\n   141→    it(\"rejects code longer than 16 chars\", async () => {\n   142→      const token = await makeJwt(referrer);\n   143→      const res = await app.request(\"/referral/code\", {\n   144→        method: \"POST\",\n   145→        ...json({ code: \"abcdefghijklmnopq\" }), // 17 chars\n   146→        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n   147→      });\n   148→\n   149→      expect(res.status).toBe(400);\n   150→    });\n   151→\n   152→    it(\"rejects code with uppercase or special chars\", async () => {\n   153→      const token = await makeJwt(referrer);\n   154→      const res = await app.request(\"/referral/code\", {\n   155→        method: \"POST\",\n   156→        ...json({ code: \"My_Code!\" }),\n   157→        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n   158→      });\n   159→\n   160→      expect(res.status).toBe(400);\n   161→    });\n   162→\n   163→    it(\"returns 409 when code is taken by another wallet\", async () => {\n   164→      // First wallet takes the code\n   165→      const token1 = await makeJwt(referrer);\n   166→      await app.request(\"/referral/code\", {\n   167→        method: \"POST\",\n   168→        ...json({ code: \"taken-code\" }),\n   169→        headers: { ...json({}).headers, Authorization: `Bearer ${token1}` },\n   170→      });\n   171→\n   172→      // Second wallet tries the same code\n   173→      const token2 = await makeJwt(referee);\n   174→      const res = await app.request(\"/referral/code\", {\n   175→        method: \"POST\",\n   176→        ...json({ code: \"taken-code\" }),\n   177→        headers: { ...json({}).headers, Authorization: `Bearer ${token2}` },\n   178→      });\n   179→\n   180→      expect(res.status).toBe(409);\n   181→      const body = (await res.json()) as { error: { code: string } };\n   182→      expect(body.error.code).toBe(\"CODE_TAKEN\");\n   183→    });\n   184→\n   185→    it(\"allows the same wallet to update their own code\", async () => {\n   186→      const token = await makeJwt(referrer);\n   187→\n   188→      // Set initial code\n   189→      await app.request(\"/referral/code\", {\n   190→        method: \"POST\",\n   191→        ...json({ code: \"first-code\" }),\n   192→        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n   193→      });\n   194→\n   195→      // Update to new code\n   196→      const res = await app.request(\"/referral/code\", {\n   197→        method: \"POST\",\n   198→        ...json({ code: \"second-code\" }),\n   199→        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n   200→      });\n   201→\n   202→      expect(res.status).toBe(200);\n   203→      const body = (await res.json()) as { code: string };\n   204→      expect(body.code).toBe(\"second-code\");\n   205→    });\n   206→\n   207→    it(\"rejects missing body\", async () => {\n   208→      const token = await makeJwt(referrer);\n   209→      const res = await app.request(\"/referral/code\", {\n   210→        method: \"POST\",\n   211→        headers: { Authorization: `Bearer ${token}` },\n   212→      });\n   213→\n   214→      expect(res.status).toBe(400);\n   215→    });\n   216→  });\n   217→\n   218→  // -----------------------------------------------------------------------\n   219→  // GET /referral/code — retrieve current code\n   220→  // -----------------------------------------------------------------------\n   221→\n   222→  describe(\"GET /referral/code\", () => {\n   223→    it(\"returns existing code for wallet\", async () => {\n   224→      const token = await makeJwt(referrer);\n   225→\n   226→      // Set code first\n   227→      await app.request(\"/referral/code\", {\n   228→        method: \"POST\",\n   229→        ...json({ code: \"get-test\" }),\n   230→        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n   231→      });\n   232→\n   233→      const res = await app.request(\"/referral/code\", {\n   234→        method: \"GET\",\n   235→        headers: { Authorization: `Bearer ${token}` },\n   236→      });\n   237→\n   238→      expect(res.status).toBe(200);\n   239→      const body = (await res.json()) as { code: string; url: string };\n   240→      expect(body.code).toBe(\"get-test\");\n   241→      expect(body.url).toBe(\"https://taunt.bet/r/get-test\");\n   242→    });\n   243→\n   244→    it(\"returns 404 if no code set\", async () => {\n   245→      const token = await makeJwt(referrer);\n   246→      const res = await app.request(\"/referral/code\", {\n   247→        method: \"GET\",\n   248→        headers: { Authorization: `Bearer ${token}` },\n   249→      });\n   250→\n   251→      expect(res.status).toBe(404);\n   252→      const body = (await res.json()) as { error: { code: string } };\n   253→      expect(body.error.code).toBe(\"NO_CODE\");\n   254→    });\n   255→  });\n   256→\n   257→  // -----------------------------------------------------------------------\n   258→  // POST /referral/apply — link referee to referrer\n   259→  // -----------------------------------------------------------------------\n   260→\n   261→  describe(\"POST /referral/apply\", () => {\n   262→    beforeEach(async () => {\n   263→      // Set up a referral code for the referrer\n   264→      const token = await makeJwt(referrer);\n   265→      await app.request(\"/referral/code\", {\n   266→        method: \"POST\",\n   267→        ...json({ code: \"apply-test\" }),\n   268→        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n   269→      });\n   270→    });\n   271→\n   272→    it(\"links referee to referrer via code\", async () => {\n   273→      const token = await makeJwt(referee);\n   274→      const res = await app.request(\"/referral/apply\", {\n   275→        method: \"POST\",\n   276→        ...json({ code: \"apply-test\" }),\n   277→        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n   278→      });\n   279→\n   280→      expect(res.status).toBe(200);\n   281→      const body = (await res.json()) as { referrer: string; benefit: string };\n   282→      expect(body.referrer).toBe(referrer);\n   283→      expect(body.benefit).toContain(\"10%\");\n   284→    });\n   285→\n   286→    it(\"rejects self-referral\", async () => {\n   287→      const token = await makeJwt(referrer); // referrer applying their own code\n   288→      const res = await app.request(\"/referral/apply\", {\n   289→        method: \"POST\",\n   290→        ...json({ code: \"apply-test\" }),\n   291→        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n   292→      });\n   293→\n   294→      expect(res.status).toBe(400);\n   295→      const body = (await res.json()) as { error: { code: string } };\n   296→      expect(body.error.code).toBe(\"SELF_REFERRAL\");\n   297→    });\n   298→\n   299→    it(\"returns 409 when already linked to a referrer\", async () => {\n   300→      const token = await makeJwt(referee);\n   301→\n   302→      // First apply succeeds\n   303→      await app.request(\"/referral/apply\", {\n   304→        method: \"POST\",\n   305→        ...json({ code: \"apply-test\" }),\n   306→        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n   307→      });\n   308→\n   309→      // Set up a second referrer code\n   310→      const other = Keypair.generate().publicKey.toBase58();\n   311→      const otherToken = await makeJwt(other);\n   312→      await app.request(\"/referral/code\", {\n   313→        method: \"POST\",\n   314→        ...json({ code: \"other-code\" }),\n   315→        headers: { ...json({}).headers, Authorization: `Bearer ${otherToken}` },\n   316→      });\n   317→\n   318→      // Second apply fails\n   319→      const res = await app.request(\"/referral/apply\", {\n   320→        method: \"POST\",\n   321→        ...json({ code: \"other-code\" }),\n   322→        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n   323→      });\n   324→\n   325→      expect(res.status).toBe(409);\n   326→      const body = (await res.json()) as { error: { code: string } };\n   327→      expect(body.error.code).toBe(\"ALREADY_LINKED\");\n   328→    });\n   329→\n   330→    it(\"returns 404 for non-existent code\", async () => {\n   331→      const token = await makeJwt(referee);\n   332→      const res = await app.request(\"/referral/apply\", {\n   333→        method: \"POST\",\n   334→        ...json({ code: \"nonexistent\" }),\n   335→        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n   336→      });\n   337→\n   338→      expect(res.status).toBe(404);\n   339→      const body = (await res.json()) as { error: { code: string } };\n   340→      expect(body.error.code).toBe(\"CODE_NOT_FOUND\");\n   341→    });\n   342→\n   343→    it(\"rejects empty code\", async () => {\n   344→      const token = await makeJwt(referee);\n   345→      const res = await app.request(\"/referral/apply\", {\n   346→        method: \"POST\",\n   347→        ...json({ code: \"\" }),\n   348→        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n   349→      });\n   350→\n   351→      expect(res.status).toBe(400);\n   352→    });\n   353→  });\n   354→\n   355→  // -----------------------------------------------------------------------\n   356→  // GET /referral/stats — summary stats\n   357→  // -----------------------------------------------------------------------\n   358→\n   359→  describe(\"GET /referral/stats\", () => {\n   360→    it(\"returns zeroed stats for wallet with no referrals\", async () => {\n   361→      const token = await makeJwt(referrer);\n   362→      const res = await app.request(\"/referral/stats\", {\n   363→        method: \"GET\",\n   364→        headers: { Authorization: `Bearer ${token}` },\n   365→      });\n   366→\n   367→      expect(res.status).toBe(200);\n   368→      const body = (await res.json()) as Record<string, unknown>;\n   369→      expect(body.referredCount).toBe(0);\n   370→      expect(body.activeCount).toBe(0);\n   371→      expect(body.totalVolumeLamports).toBe(\"0\");\n   372→      expect(body.totalEarnedLamports).toBe(\"0\");\n   373→      expect(body.pendingLamports).toBe(\"0\");\n   374→    });\n   375→\n   376→    it(\"reflects referred count after linking\", async () => {\n   377→      // Set up referrer code + link a referee\n   378→      const referrerToken = await makeJwt(referrer);\n   379→      await app.request(\"/referral/code\", {\n   380→        method: \"POST\",\n   381→        ...json({ code: \"stats-test\" }),\n   382→        headers: { ...json({}).headers, Authorization: `Bearer ${referrerToken}` },\n   383→      });\n   384→\n   385→      const refereeToken = await makeJwt(referee);\n   386→      await app.request(\"/referral/apply\", {\n   387→        method: \"POST\",\n   388→        ...json({ code: \"stats-test\" }),\n   389→        headers: { ...json({}).headers, Authorization: `Bearer ${refereeToken}` },\n   390→      });\n   391→\n   392→      const res = await app.request(\"/referral/stats\", {\n   393→        method: \"GET\",\n   394→        headers: { Authorization: `Bearer ${referrerToken}` },\n   395→      });\n   396→\n   397→      expect(res.status).toBe(200);\n   398→      const body = (await res.json()) as { referredCount: number };\n   399→      expect(body.referredCount).toBe(1);\n   400→    });\n   401→  });\n   402→\n   403→  // -----------------------------------------------------------------------\n   404→  // GET /referral/earnings — paginated earnings\n   405→  // -----------------------------------------------------------------------\n   406→\n   407→  describe(\"GET /referral/earnings\", () => {\n   408→    it(\"returns empty items when no earnings exist\", async () => {\n   409→      const token = await makeJwt(referrer);\n   410→      const res = await app.request(\"/referral/earnings\", {\n   411→        method: \"GET\",\n   412→        headers: { Authorization: `Bearer ${token}` },\n   413→      });\n   414→\n   415→      expect(res.status).toBe(200);\n   416→      const body = (await res.json()) as {\n   417→        items: unknown[];\n   418→        pagination: { page: number; totalPages: number };\n   419→      };\n   420→      expect(body.items).toHaveLength(0);\n   421→      expect(body.pagination.page).toBe(1);\n   422→      expect(body.pagination.totalPages).toBe(1); // min 1 page even when empty\n   423→    });\n   424→\n   425→    it(\"returns earnings after inserting one\", async () => {\n   426→      // Insert an earning directly via DB\n   427→      await db.insertReferralEarning({\n   428→        referrerWallet: referrer,\n   429→        refereeWallet: referee,\n   430→        roundId: \"test-round-001\",\n   431→        gameType: \"coinflip\",\n   432→        wagerLamports: 1_000_000_000,\n   433→        feeLamports: 50_000_000,\n   434→        referrerEarnedLamports: 5_000_000,\n   435→        referrerRateBps: 1000,\n   436→        refereeRebateLamports: 5_000_000,\n   437→        refereeRebateRateBps: 1000,\n   438→      });\n   439→\n   440→      const token = await makeJwt(referrer);\n   441→      const res = await app.request(\"/referral/earnings\", {\n   442→        method: \"GET\",\n   443→        headers: { Authorization: `Bearer ${token}` },\n   444→      });\n   445→\n   446→      expect(res.status).toBe(200);\n   447→      const body = (await res.json()) as {\n   448→        items: Array<{\n   449→          roundId: string;\n   450→          gameType: string;\n   451→          refereeWallet: string;\n   452→          wagerLamports: string;\n   453→          earnedLamports: string;\n   454→          createdAt: string;\n   455→        }>;\n   456→        pagination: { page: number; totalPages: number };\n   457→      };\n   458→      expect(body.items).toHaveLength(1);\n   459→      expect(body.items[0]!.roundId).toBe(\"test-round-001\");\n   460→      expect(body.items[0]!.gameType).toBe(\"coinflip\");\n   461→      expect(body.items[0]!.wagerLamports).toBe(\"1000000000\");\n   462→      expect(body.items[0]!.earnedLamports).toBe(\"5000000\");\n   463→      expect(body.pagination.totalPages).toBe(1);\n   464→    });\n   465→\n   466→    it(\"respects page and limit query params\", async () => {\n   467→      // Insert 3 earnings\n   468→      for (let i = 1; i <= 3; i++) {\n   469→        await db.insertReferralEarning({\n   470→          referrerWallet: referrer,\n   471→          refereeWallet: referee,\n   472→          roundId: `round-${i}`,\n   473→          gameType: \"coinflip\",\n   474→          wagerLamports: 1_000_000_000,\n   475→          feeLamports: 50_000_000,\n   476→          referrerEarnedLamports: 5_000_000,\n   477→          referrerRateBps: 1000,\n   478→          refereeRebateLamports: 5_000_000,\n   479→          refereeRebateRateBps: 1000,\n   480→        });\n   481→      }\n   482→\n   483→      const token = await makeJwt(referrer);\n   484→      const res = await app.request(\"/referral/earnings?page=1&limit=2\", {\n   485→        method: \"GET\",\n   486→        headers: { Authorization: `Bearer ${token}` },\n   487→      });\n   488→\n   489→      expect(res.status).toBe(200);\n   490→      const body = (await res.json()) as {\n   491→        items: unknown[];\n   492→        pagination: { page: number; totalPages: number };\n   493→      };\n   494→      expect(body.items).toHaveLength(2);\n   495→      expect(body.pagination.totalPages).toBe(2);\n   496→    });\n   497→  });\n   498→\n   499→  // -----------------------------------------------------------------------\n   500→  // POST /referral/claim — claim flow\n   501→  // -----------------------------------------------------------------------\n   502→\n   503→  describe(\"POST /referral/claim\", () => {\n   504→    it(\"rejects claim with zero balance\", async () => {\n   505→      const token = await makeJwt(referrer);\n   506→      const res = await app.request(\"/referral/claim\", {\n   507→        method: \"POST\",\n   508→        headers: {\n   509→          \"Content-Type\": \"application/json\",\n   510→          Authorization: `Bearer ${token}`,\n   511→        },\n   512→      });\n   513→\n   514→      expect(res.status).toBe(400);\n   515→      const body = (await res.json()) as { error: { code: string } };\n   516→      expect(body.error.code).toBe(\"ZERO_BALANCE\");\n   517→    });\n   518→\n   519→    it(\"rejects claim below minimum threshold\", async () => {\n   520→      // Insert a small earning (below 0.01 SOL threshold)\n   521→      await db.insertReferralEarning({\n   522→        referrerWallet: referrer,\n   523→        refereeWallet: referee,\n   524→        roundId: \"small-round\",\n   525→        gameType: \"coinflip\",\n   526→        wagerLamports: 100_000_000, // 0.1 SOL\n   527→        feeLamports: 5_000_000, // 0.005 SOL\n   528→        referrerEarnedLamports: 500_000, // 0.0005 SOL — below 0.01 threshold\n   529→        referrerRateBps: 1000,\n   530→        refereeRebateLamports: 500_000,\n   531→        refereeRebateRateBps: 1000,\n   532→      });\n   533→\n   534→      const token = await makeJwt(referrer);\n   535→      const res = await app.request(\"/referral/claim\", {\n   536→        method: \"POST\",\n   537→        headers: {\n   538→          \"Content-Type\": \"application/json\",\n   539→          Authorization: `Bearer ${token}`,\n   540→        },\n   541→      });\n   542→\n   543→      expect(res.status).toBe(400);\n   544→      const body = (await res.json()) as { error: { code: string } };\n   545→      expect(body.error.code).toBe(\"BELOW_THRESHOLD\");\n   546→    });\n   547→\n   548→    it(\"creates a pending claim for valid balance\", async () => {\n   549→      // Insert a large enough earning\n   550→      await db.insertReferralEarning({\n   551→        referrerWallet: referrer,\n   552→        refereeWallet: referee,\n   553→        roundId: \"big-round\",\n   554→        gameType: \"coinflip\",\n   555→        wagerLamports: 10_000_000_000, // 10 SOL\n   556→        feeLamports: 500_000_000, // 0.5 SOL\n   557→        referrerEarnedLamports: 50_000_000, // 0.05 SOL — above threshold\n   558→        referrerRateBps: 1000,\n   559→        refereeRebateLamports: 50_000_000,\n   560→        refereeRebateRateBps: 1000,\n   561→      });\n   562→\n   563→      const token = await makeJwt(referrer);\n   564→      const res = await app.request(\"/referral/claim\", {\n   565→        method: \"POST\",\n   566→        headers: {\n   567→          \"Content-Type\": \"application/json\",\n   568→          Authorization: `Bearer ${token}`,\n   569→        },\n   570→      });\n   571→\n   572→      expect(res.status).toBe(202);\n   573→      const body = (await res.json()) as {\n   574→        claimId: string;\n   575→        amountLamports: string;\n   576→        status: string;\n   577→      };\n   578→      expect(body.claimId).toBeDefined();\n   579→      expect(body.amountLamports).toBe(\"50000000\");\n   580→      expect(body.status).toBe(\"pending\");\n   581→\n   582→      // Verify event was emitted\n   583→      const events =\n   584→        await rawSql`SELECT * FROM event_queue WHERE event_type = 'referral.claim_requested'`;\n   585→      expect(events.length).toBe(1);\n   586→    });\n   587→\n   588→    it(\"prevents double-claim by deducting pending balance\", async () => {\n   589→      // Insert earning\n   590→      await db.insertReferralEarning({\n   591→        referrerWallet: referrer,\n   592→        refereeWallet: referee,\n   593→        roundId: \"double-round\",\n   594→        gameType: \"coinflip\",\n   595→        wagerLamports: 10_000_000_000,\n   596→        feeLamports: 500_000_000,\n   597→        referrerEarnedLamports: 50_000_000,\n   598→        referrerRateBps: 1000,\n   599→        refereeRebateLamports: 50_000_000,\n   600→        refereeRebateRateBps: 1000,\n   601→      });\n   602→\n   603→      const token = await makeJwt(referrer);\n   604→\n   605→      // First claim succeeds\n   606→      const res1 = await app.request(\"/referral/claim\", {\n   607→        method: \"POST\",\n   608→        headers: {\n   609→          \"Content-Type\": \"application/json\",\n   610→          Authorization: `Bearer ${token}`,\n   611→        },\n   612→      });\n   613→      expect(res1.status).toBe(202);\n   614→\n   615→      // Second claim fails — balance consumed by pending claim\n   616→      const res2 = await app.request(\"/referral/claim\", {\n   617→        method: \"POST\",\n   618→        headers: {\n   619→          \"Content-Type\": \"application/json\",\n   620→          Authorization: `Bearer ${token}`,\n   621→        },\n   622→      });\n   623→      expect(res2.status).toBe(400);\n   624→      const body = (await res2.json()) as { error: { code: string } };\n   625→      expect(body.error.code).toBe(\"ZERO_BALANCE\");\n   626→    });\n   627→  });\n   628→\n   629→  // -----------------------------------------------------------------------\n   630→  // GET /referral/claim/:claimId — poll claim status\n   631→  // -----------------------------------------------------------------------\n   632→\n   633→  describe(\"GET /referral/claim/:claimId\", () => {\n   634→    it(\"returns claim status for the owner\", async () => {\n   635→      // Insert earning + create claim\n   636→      await db.insertReferralEarning({\n   637→        referrerWallet: referrer,\n   638→        refereeWallet: referee,\n   639→        roundId: \"poll-round\",\n   640→        gameType: \"coinflip\",\n   641→        wagerLamports: 10_000_000_000,\n   642→        feeLamports: 500_000_000,\n   643→        referrerEarnedLamports: 50_000_000,\n   644→        referrerRateBps: 1000,\n   645→        refereeRebateLamports: 50_000_000,\n   646→        refereeRebateRateBps: 1000,\n   647→      });\n   648→\n   649→      const token = await makeJwt(referrer);\n   650→      const claimRes = await app.request(\"/referral/claim\", {\n   651→        method: \"POST\",\n   652→        headers: {\n   653→          \"Content-Type\": \"application/json\",\n   654→          Authorization: `Bearer ${token}`,\n   655→        },\n   656→      });\n   657→      const claim = (await claimRes.json()) as { claimId: string };\n   658→\n   659→      // Poll status\n   660→      const res = await app.request(`/referral/claim/${claim.claimId}`, {\n   661→        method: \"GET\",\n   662→        headers: { Authorization: `Bearer ${token}` },\n   663→      });\n   664→\n   665→      expect(res.status).toBe(200);\n   666→      const body = (await res.json()) as {\n   667→        claimId: string;\n   668→        amountLamports: string;\n   669→        status: string;\n   670→      };\n   671→      expect(body.claimId).toBe(claim.claimId);\n   672→      expect(body.status).toBe(\"pending\");\n   673→    });\n   674→\n   675→    it(\"returns 404 for non-existent claim\", async () => {\n   676→      const token = await makeJwt(referrer);\n   677→      const res = await app.request(\n   678→        \"/referral/claim/00000000-0000-0000-0000-000000000000\",\n   679→        {\n   680→          method: \"GET\",\n   681→          headers: { Authorization: `Bearer ${token}` },\n   682→        },\n   683→      );\n   684→\n   685→      expect(res.status).toBe(404);\n   686→    });\n   687→\n   688→    it(\"returns 404 when another wallet tries to view a claim\", async () => {\n   689→      // Create earning + claim as referrer\n   690→      await db.insertReferralEarning({\n   691→        referrerWallet: referrer,\n   692→        refereeWallet: referee,\n   693→        roundId: \"auth-round\",\n   694→        gameType: \"coinflip\",\n   695→        wagerLamports: 10_000_000_000,\n   696→        feeLamports: 500_000_000,\n   697→        referrerEarnedLamports: 50_000_000,\n   698→        referrerRateBps: 1000,\n   699→        refereeRebateLamports: 50_000_000,\n   700→        refereeRebateRateBps: 1000,\n   701→      });\n   702→\n   703→      const referrerToken = await makeJwt(referrer);\n   704→      const claimRes = await app.request(\"/referral/claim\", {\n   705→        method: \"POST\",\n   706→        headers: {\n   707→          \"Content-Type\": \"application/json\",\n   708→          Authorization: `Bearer ${referrerToken}`,\n   709→        },\n   710→      });\n   711→      const claim = (await claimRes.json()) as { claimId: string };\n   712→\n   713→      // Try to view as referee (different wallet)\n   714→      const refereeToken = await makeJwt(referee);\n   715→      const res = await app.request(`/referral/claim/${claim.claimId}`, {\n   716→        method: \"GET\",\n   717→        headers: { Authorization: `Bearer ${refereeToken}` },\n   718→      });\n   719→\n   720→      expect(res.status).toBe(404);\n   721→    });\n   722→  });\n   723→\n   724→  // -----------------------------------------------------------------------\n   725→  // GET /referral/referrer — check referrer status\n   726→  // -----------------------------------------------------------------------\n   727→\n   728→  describe(\"GET /referral/referrer\", () => {\n   729→    it(\"returns 404 when not referred\", async () => {\n   730→      const token = await makeJwt(referee);\n   731→      const res = await app.request(\"/referral/referrer\", {\n   732→        method: \"GET\",\n   733→        headers: { Authorization: `Bearer ${token}` },\n   734→      });\n   735→\n   736→      expect(res.status).toBe(404);\n   737→      const body = (await res.json()) as { error: { code: string } };\n   738→      expect(body.error.code).toBe(\"NO_REFERRER\");\n   739→    });\n   740→\n   741→    it(\"returns referrer wallet after linking\", async () => {\n   742→      // Set up code + apply\n   743→      const referrerToken = await makeJwt(referrer);\n   744→      await app.request(\"/referral/code\", {\n   745→        method: \"POST\",\n   746→        ...json({ code: \"referrer-test\" }),\n   747→        headers: { ...json({}).headers, Authorization: `Bearer ${referrerToken}` },\n   748→      });\n   749→\n   750→      const refereeToken = await makeJwt(referee);\n   751→      await app.request(\"/referral/apply\", {\n   752→        method: \"POST\",\n   753→        ...json({ code: \"referrer-test\" }),\n   754→        headers: { ...json({}).headers, Authorization: `Bearer ${refereeToken}` },\n   755→      });\n   756→\n   757→      const res = await app.request(\"/referral/referrer\", {\n   758→        method: \"GET\",\n   759→        headers: { Authorization: `Bearer ${refereeToken}` },\n   760→      });\n   761→\n   762→      expect(res.status).toBe(200);\n   763→      const body = (await res.json()) as {\n   764→        referrerWallet: string;\n   765→        linkedAt: string;\n   766→      };\n   767→      expect(body.referrerWallet).toBe(referrer);\n   768→      expect(body.linkedAt).toBeDefined();\n   769→    });\n   770→  });\n   771→\n   772→  // -----------------------------------------------------------------------\n   773→  // Auth — missing JWT\n   774→  // -----------------------------------------------------------------------\n   775→\n   776→  describe(\"Authentication\", () => {\n   777→    it(\"returns 401 for requests without JWT\", async () => {\n   778→      const res = await app.request(\"/referral/stats\", { method: \"GET\" });\n   779→      expect(res.status).toBe(401);\n   780→    });\n   781→  });\n   782→});\n   783→"}]},"parent_tool_use_id":"toolu_01K6S9FTWc4Mt7jLihK2J2QP","session_id":"773e2b1e-9c3d-4d53-809d-a95c06988ae7","uuid":"a95bbe30-5ec2-4ee1-b708-c0cdc97c0525","timestamp":"2026-03-25T13:56:04.638Z"}
