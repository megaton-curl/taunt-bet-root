 670→    const earning = earnings[0]!;\n   671→    expect(earning.referrer_wallet).toBe(referrerWallet);\n   672→    expect(earning.referee_wallet).toBe(opponentWallet);\n   673→    expect(earning.round_id).toBe(createJson.matchId);\n   674→    expect(earning.game_type).toBe(\"coinflip\");\n   675→    expect(Number(earning.wager_lamports)).toBe(AMOUNT_LAMPORTS); // 5_000_000\n   676→    expect(Number(earning.fee_lamports)).toBe(250_000); // 5_000_000 * 500 / 10_000\n   677→    expect(Number(earning.referrer_earned_lamports)).toBe(25_000); // 250_000 * 1000 / 10_000\n   678→    expect(Number(earning.referrer_rate_bps)).toBe(1000);\n   679→    expect(Number(earning.referee_rebate_lamports)).toBe(25_000); // 250_000 * 1000 / 10_000"}]},"parent_tool_use_id":null,"session_id":"773e2b1e-9c3d-4d53-809d-a95c06988ae7","uuid":"de3afddb-c3a2-4b2d-9cb0-f7725af841e1","timestamp":"2026-03-25T14:01:22.346Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/integration.test.ts","content":"    });\n\n    mockConn.setAccount(matchPubkey, matchAccountData, {\n      owner: COINFLIP_PROGRAM_ID,\n    });\n    mockConn.slot = 200;\n\n    // 3. Settle the match\n    const retrySettler = createRetrySettler({\n      db,\n      connection: mockConn as unknown as Connection,\n      settleRound: (pda) =>\n        settleMatch(\n          {\n            db,\n            connection: mockConn as unknown as Connection,\n            serverKeypair,\n            entropyAccount,\n            referralDefaultRateBps: 1000,\n          },\n          pda,\n        ),\n    });\n\n    const worker = createSettlementWorker({\n      db,\n      connection: mockConn as unknown as Connection,\n      serverKey: serverKeypair.publicKey,\n      pollIntervalMs: 60_000,\n      onSettleReady: (pda) => {\n        const p = retrySettler.attemptSettle(pda);\n        return p;\n      },\n    });\n\n    await worker.poll();\n\n    // 4. Verify match settled\n    const settled = await db.getRoundByPda(createJson.matchPda);\n    expect(settled).toBeDefined();\n    expect(settled!.phase).toBe(\"settled\");\n\n    // 5. Verify referral earnings recorded for the opponent (the referee)\n    // Expected: wager=5_000_000, fee=5_000_000*500/10_000=250_000\n    //           referrer_earned=250_000*1000/10_000=25_000\n    //           referee_rebate=250_000*1000/10_000=25_000\n    const earnings =\n      await rawSql`SELECT * FROM referral_earnings WHERE referee_wallet = ${opponentWallet}`;\n    expect(earnings.length).toBe(1);\n\n    const earning = earnings[0]!;\n    expect(earning.referrer_wallet).toBe(referrerWallet);\n    expect(earning.referee_wallet).toBe(opponentWallet);\n    expect(earning.round_id).toBe(createJson.matchId);\n    expect(earning.game_type).toBe(\"coinflip\");\n    expect(Number(earning.wager_lamports)).toBe(AMOUNT_LAMPORTS); // 5_000_000\n    expect(Number(earning.fee_lamports)).toBe(250_000); // 5_000_000 * 500 / 10_000\n    expect(Number(earning.referrer_earned_lamports)).toBe(25_000); // 250_000 * 1000 / 10_000\n    expect(Number(earning.referrer_rate_bps)).toBe(1000);\n    expect(Number(earning.referee_rebate_lamports)).toBe(25_000); // 250_000 * 1000 / 10_000","numLines":60,"startLine":620,"totalLines":788}}}
