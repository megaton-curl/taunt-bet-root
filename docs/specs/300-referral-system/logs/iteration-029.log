{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AewPQkquKh7jzk8NMNphTz","type":"tool_result","content":"     1→/**\n     2→ * Platform config reader — fetches fee_bps and treasury from the on-chain\n     3→ * PlatformConfig account (owned by the platform program).\n     4→ *\n     5→ * Used by all settlement paths (coinflip, lord, closecall) so fee calculation\n     6→ * and treasury routing come from a single authoritative source.\n     7→ */\n     8→\n     9→import { Connection, PublicKey } from \"@solana/web3.js\";\n    10→import { PlatformIDL } from \"@rng-utopia/anchor-client\";\n    11→\n    12→export const PLATFORM_PROGRAM_ID = new PublicKey(PlatformIDL.address);\n    13→\n    14→/**\n    15→ * Derive the PlatformConfig PDA.\n    16→ * Seeds: [\"platform_config\"]\n    17→ */\n    18→export function derivePlatformConfigPda(): [PublicKey, number] {\n    19→  return PublicKey.findProgramAddressSync(\n    20→    [Buffer.from(\"platform_config\")],\n    21→    PLATFORM_PROGRAM_ID,\n    22→  );\n    23→}\n    24→\n    25→/**\n    26→ * Fetch PlatformConfig directly from on-chain account data.\n    27→ *\n    28→ * Account layout (after 8-byte Anchor discriminator):\n    29→ *   offset  0..8   discriminator\n    30→ *   offset  8..40  authority (Pubkey, 32 bytes)\n    31→ *   offset 40..72  treasury  (Pubkey, 32 bytes)\n    32→ *   offset 72..74  fee_bps   (u16 LE)\n    33→ */\n    34→export async function fetchPlatformConfig(\n    35→  connection: Connection,\n    36→): Promise<{ feeBps: number; treasury: PublicKey }> {\n    37→  const [pda] = derivePlatformConfigPda();\n    38→  const info = await connection.getAccountInfo(pda);\n    39→  if (!info) {\n    40→    throw new Error(\n    41→      `PlatformConfig account not found at ${pda.toBase58()}`,\n    42→    );\n    43→  }\n    44→\n    45→  const data = info.data;\n    46→  const treasury = new PublicKey(data.subarray(40, 72));\n    47→  const feeBps = data.readUInt16LE(72);\n    48→\n    49→  return { feeBps, treasury };\n    50→}\n    51→\n    52→// ---------------------------------------------------------------------------\n    53→// Cached accessor — avoids repeated RPC calls within the same process\n    54→// ---------------------------------------------------------------------------\n    55→\n    56→let _cache: { feeBps: number; treasury: PublicKey } | null = null;\n    57→\n    58→/**\n    59→ * Return the cached PlatformConfig, fetching from RPC on first call.\n    60→ * Cache lives for the process lifetime — restart the backend to pick up\n    61→ * on-chain config changes.\n    62→ */\n    63→export async function getPlatformConfig(\n    64→  connection: Connection,\n    65→): Promise<{ feeBps: number; treasury: PublicKey }> {\n    66→  if (_cache) return _cache;\n    67→  _cache = await fetchPlatformConfig(connection);\n    68→  return _cache;\n    69→}\n    70→"}]},"parent_tool_use_id":null,"session_id":"773e2b1e-9c3d-4d53-809d-a95c06988ae7","uuid":"87864200-84c4-4c85-8854-75abd9ea47b8","timestamp":"2026-03-25T14:05:10.963Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/platform-config.ts","content":"/**\n * Platform config reader — fetches fee_bps and treasury from the on-chain\n * PlatformConfig account (owned by the platform program).\n *\n * Used by all settlement paths (coinflip, lord, closecall) so fee calculation\n * and treasury routing come from a single authoritative source.\n */\n\nimport { Connection, PublicKey } from \"@solana/web3.js\";\nimport { PlatformIDL } from \"@rng-utopia/anchor-client\";\n\nexport const PLATFORM_PROGRAM_ID = new PublicKey(PlatformIDL.address);\n\n/**\n * Derive the PlatformConfig PDA.\n * Seeds: [\"platform_config\"]\n */\nexport function derivePlatformConfigPda(): [PublicKey, number] {\n  return PublicKey.findProgramAddressSync(\n    [Buffer.from(\"platform_config\")],\n    PLATFORM_PROGRAM_ID,\n  );\n}\n\n/**\n * Fetch PlatformConfig directly from on-chain account data.\n *\n * Account layout (after 8-byte Anchor discriminator):\n *   offset  0..8   discriminator\n *   offset  8..40  authority (Pubkey, 32 bytes)\n *   offset 40..72  treasury  (Pubkey, 32 bytes)\n *   offset 72..74  fee_bps   (u16 LE)\n */\nexport async function fetchPlatformConfig(\n  connection: Connection,\n): Promise<{ feeBps: number; treasury: PublicKey }> {\n  const [pda] = derivePlatformConfigPda();\n  const info = await connection.getAccountInfo(pda);\n  if (!info) {\n    throw new Error(\n      `PlatformConfig account not found at ${pda.toBase58()}`,\n    );\n  }\n\n  const data = info.data;\n  const treasury = new PublicKey(data.subarray(40, 72));\n  const feeBps = data.readUInt16LE(72);\n\n  return { feeBps, treasury };\n}\n\n// ---------------------------------------------------------------------------\n// Cached accessor — avoids repeated RPC calls within the same process\n// ---------------------------------------------------------------------------\n\nlet _cache: { feeBps: number; treasury: PublicKey } | null = null;\n\n/**\n * Return the cached PlatformConfig, fetching from RPC on first call.\n * Cache lives for the process lifetime — restart the backend to pick up\n * on-chain config changes.\n */\nexport async function getPlatformConfig(\n  connection: Connection,\n): Promise<{ feeBps: number; treasury: PublicKey }> {\n  if (_cache) return _cache;\n  _cache = await fetchPlatformConfig(connection);\n  return _cache;\n}\n","numLines":70,"startLine":1,"totalLines":70}}}
