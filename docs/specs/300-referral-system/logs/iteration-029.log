{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L72wk81J2dC8UH3M73GaP7","type":"tool_result","content":"   220→    resolveDeadline: params.resolveDeadline,\n   221→    resultHash: new Array(32).fill(0),\n   222→    result: 0,\n   223→    winner: PublicKey.default,\n   224→    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n   225→    matchId: [...params.matchId],\n   226→    bump: 0,\n   227→  });\n   228→}\n   229→\n   230→async function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n   231→  return encodeCoinflipConfig({\n   232→    authority: PublicKey.default,\n   233→    treasury,\n   234→    paused: false,\n   235→    bump: 0,\n   236→  });\n   237→}\n   238→\n   239→// ---------------------------------------------------------------------------\n   240→// Test suite\n   241→// ---------------------------------------------------------------------------\n   242→\n   243→describe(\"Integration: create → join → settle lifecycle\", () => {\n   244→  let db: Db;\n   245→  let rawSql: ReturnType<typeof postgres>;\n   246→  let mockConn: MockConnection;\n   247→  let app: Hono;\n   248→\n   249→  const serverKeypair = Keypair.generate();\n   250→  const creatorKeypair = Keypair.generate();\n   251→  const opponentKeypair = Keypair.generate();\n   252→  const treasuryKeypair = Keypair.generate();\n   253→  const entropyKeypair = Keypair.generate();\n   254→  const entropyAccount = entropyKeypair.publicKey;\n   255→\n   256→  const entropyData = Buffer.alloc(32);\n   257→  entropyData[0] = 0xab;\n   258→  entropyData[1] = 0xcd;\n   259→  entropyData[15] = 0x42;\n   260→\n   261→  beforeAll(async () => {\n   262→    db = createDb(DATABASE_URL);\n   263→    rawSql = postgres(DATABASE_URL);\n   264→  });\n   265→\n   266→  afterAll(async () => {\n   267→    await db.close();\n   268→    await rawSql.end();\n   269→  });\n   270→\n   271→  beforeEach(async () => {\n   272→    // Clean tables for isolation\n   273→    await rawSql`TRUNCATE rounds, operator_events RESTART IDENTITY`;\n   274→\n   275→    // Fresh mock Connection\n   276→    mockConn = new MockConnection();\n   277→\n   278→    // Pre-populate mock with entropy and config accounts\n   279→    mockConn.setAccount(entropyAccount, entropyData);\n   280→\n   281→    const [configPda] = PublicKey.findProgramAddressSync(\n   282→      [Buffer.from(\"coinflip_config\")],\n   283→      COINFLIP_PROGRAM_ID,\n   284→    );\n   285→    mockConn.setAccount(\n   286→      configPda,\n   287→      await buildConfigAccountData(treasuryKeypair.publicKey),\n   288→      { owner: COINFLIP_PROGRAM_ID },\n   289→    );\n   290→\n   291→    // Build the Hono app (no rate limiting for tests)\n   292→    app = new Hono();\n   293→\n   294→    app.use(\n   295→      \"/fairness/*\",\n   296→      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n   297→    );\n   298→\n   299→    app.route(\n   300→      \"/fairness/coinflip\",\n   301→      createCoinflipRoutes({\n   302→        db,\n   303→        connection: mockConn as unknown as Connection,\n   304→        serverKeypair,\n   305→      }),\n   306→    );\n   307→\n   308→    app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n   309→  });\n   310→\n   311→  it(\"full lifecycle: create → join (mock) → settle → verify\", async () => {\n   312→    const wallet = creatorKeypair.publicKey.toBase58();\n   313→    const token = await makeJwt(wallet);\n   314→\n   315→    // ------------------------------------------------------------------\n   316→    // 1. POST /fairness/coinflip/create\n   317→    // ------------------------------------------------------------------\n   318→    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n   319→\n   320→    const createRes = await app.request(\"/fairness/coinflip/create\", {\n   321→      method: \"POST\",\n   322→      headers: {\n   323→        \"Content-Type\": \"application/json\",\n   324→        \"Authorization\": `Bearer ${token}`,\n   325→      },\n   326→      body: JSON.stringify(body),\n   327→    });\n   328→\n   329→    expect(createRes.status).toBe(200);\n   330→    const createJson = (await createRes.json()) as {\n   331→      transaction: string;\n   332→      matchPda: string;\n   333→      matchId: string;\n   334→      commitment: string;\n   335→      lastValidBlockHeight: number;\n   336→    };\n   337→    expect(createJson.transaction).toBeDefined();\n   338→    expect(createJson.matchPda).toBeDefined();\n   339→    expect(createJson.commitment).toBeDefined();\n   340→    expect(createJson.lastValidBlockHeight).toBeDefined();\n   341→\n   342→    const matchPda = createJson.matchPda;\n   343→    const commitmentHex = createJson.commitment;\n   344→    const commitmentBuf = Buffer.from(commitmentHex, \"hex\");\n   345→\n   346→    // ------------------------------------------------------------------\n   347→    // 2. Verify DB state — round in \"created\" phase\n   348→    // ------------------------------------------------------------------\n   349→    const round = await db.getRoundByPda(matchPda);\n   350→    expect(round).toBeDefined();\n   351→    expect(round!.phase).toBe(\"created\");\n   352→    expect(round!.game).toBe(\"coinflip\");\n   353→    expect(round!.creator).toBe(wallet);\n   354→    expect(round!.amount_lamports).toBe(AMOUNT_LAMPORTS);\n   355→    expect(round!.side).toBe(SIDE_HEADS);\n   356→    expect(round!.commitment.toString(\"hex\")).toBe(commitmentHex);\n   357→    expect(round!.secret).toBeDefined();\n   358→    expect(round!.secret.length).toBe(32);\n   359→\n   360→    // Verify operator event was logged\n   361→    const events =\n   362→      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n   363→    expect(events.length).toBe(1);\n   364→    expect(events[0]!.event_type).toBe(\"secret_generated\");\n   365→\n   366→    // ------------------------------------------------------------------\n   367→    // 3. Simulate on-chain join — add LOCKED match to mock Connection\n   368→    // ------------------------------------------------------------------\n   369→    const matchPubkey = new PublicKey(matchPda);\n   370→    const targetSlot = 150n;\n   371→    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n   372→\n   373→    const matchAccountData = await buildMatchAccountData({\n   374→      creator: creatorKeypair.publicKey,\n   375→      opponent: opponentKeypair.publicKey,\n   376→      server: serverKeypair.publicKey,\n   377→      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n   378→      creatorSide: SIDE_HEADS,\n   379→      phase: PHASE_LOCKED,\n   380→      commitment: commitmentBuf,\n   381→      algorithmVer: 1,\n   382→      targetSlot,\n   383→      resolveDeadline,\n   384→      matchId: Buffer.from(createJson.matchId, \"hex\"),\n   385→    });\n   386→\n   387→    mockConn.setAccount(matchPubkey, matchAccountData, {\n   388→      owner: COINFLIP_PROGRAM_ID,\n   389→    });\n   390→\n   391→    // Set current slot past target_slot so settlement triggers immediately\n   392→    mockConn.slot = 200;\n   393→\n   394→    // ------------------------------------------------------------------\n   395→    // 4. Create worker + retry settler, trigger poll\n   396→    // ------------------------------------------------------------------\n   397→    let settlePromise: Promise<void> | null = null;\n   398→\n   399→    const retrySettler = createRetrySettler({\n   400→      db,\n   401→      connection: mockConn as unknown as Connection,\n   402→      settleRound: (pda) =>\n   403→        settleMatch(\n   404→          {\n   405→            db,\n   406→            connection: mockConn as unknown as Connection,\n   407→            serverKeypair,\n   408→            entropyAccount,\n   409→            referralDefaultRateBps: 1000,\n   410→          },\n   411→          pda,\n   412→        ),\n   413→    });\n   414→\n   415→    const worker = createSettlementWorker({\n   416→      db,\n   417→      connection: mockConn as unknown as Connection,\n   418→      serverKey: serverKeypair.publicKey,\n   419→      pollIntervalMs: 60_000, // won't auto-poll\n   420→      onSettleReady: (pda) => {\n   421→        settlePromise = retrySettler.attemptSettle(pda);\n   422→        return settlePromise;\n   423→      },\n   424→    });\n   425→\n   426→    // Single poll cycle — should discover locked match and settle it\n   427→    await worker.poll();\n   428→    if (settlePromise) await settlePromise;\n   429→\n   430→    // ------------------------------------------------------------------\n   431→    // 5. Verify DB updated to \"settled\" with result data\n   432→    // ------------------------------------------------------------------\n   433→    const settled = await db.getRoundByPda(matchPda);\n   434→    expect(settled).toBeDefined();\n   435→    expect(settled!.phase).toBe(\"settled\");\n   436→    expect(settled!.settle_tx).toBeDefined();\n   437→    expect(settled!.result_hash).toBeDefined();\n   438→    expect(settled!.result_hash!.length).toBe(32);\n   439→    expect(settled!.result_side).toBeDefined();\n   440→    expect([0, 1]).toContain(settled!.result_side);\n   441→    expect(settled!.winner).toBeDefined();\n   442→\n   443→    // Winner should be one of the two players\n   444→    expect([\n   445→      creatorKeypair.publicKey.toBase58(),\n   446→      opponentKeypair.publicKey.toBase58(),\n   447→    ]).toContain(settled!.winner);\n   448→\n   449→    // Verify operator events trail\n   450→    const allEvents =\n   451→      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n   452→    const eventTypes = allEvents.map(\n   453→      (e) => (e as Record<string, unknown>).event_type,\n   454→    );\n   455→    expect(eventTypes).toContain(\"secret_generated\");\n   456→    expect(eventTypes).toContain(\"match_detected\");\n   457→    expect(eventTypes).toContain(\"settle_submitted\");\n   458→    expect(eventTypes).toContain(\"settle_confirmed\");\n   459→\n   460→    // ------------------------------------------------------------------\n   461→    // 6. GET /fairness/rounds/:pda — verify response includes secret\n   462→    // ------------------------------------------------------------------\n   463→    const roundsRes = await app.request(`/fairness/rounds/${matchPda}`);\n   464→    expect(roundsRes.status).toBe(200);\n   465→\n   466→    const roundsJson = (await roundsRes.json()) as Record<string, unknown>;\n   467→    expect(roundsJson.pda).toBe(matchPda);\n   468→    expect(roundsJson.phase).toBe(\"settled\");\n   469→    expect(roundsJson.game).toBe(\"coinflip\");"}]},"parent_tool_use_id":null,"session_id":"773e2b1e-9c3d-4d53-809d-a95c06988ae7","uuid":"9f4966be-3d96-48c0-8017-1c6e96053ffa","timestamp":"2026-03-25T13:57:18.839Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/integration.test.ts","content":"    resolveDeadline: params.resolveDeadline,\n    resultHash: new Array(32).fill(0),\n    result: 0,\n    winner: PublicKey.default,\n    createdAt: BigInt(Math.floor(Date.now() / 1000)),\n    matchId: [...params.matchId],\n    bump: 0,\n  });\n}\n\nasync function buildConfigAccountData(treasury: PublicKey): Promise<Buffer> {\n  return encodeCoinflipConfig({\n    authority: PublicKey.default,\n    treasury,\n    paused: false,\n    bump: 0,\n  });\n}\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"Integration: create → join → settle lifecycle\", () => {\n  let db: Db;\n  let rawSql: ReturnType<typeof postgres>;\n  let mockConn: MockConnection;\n  let app: Hono;\n\n  const serverKeypair = Keypair.generate();\n  const creatorKeypair = Keypair.generate();\n  const opponentKeypair = Keypair.generate();\n  const treasuryKeypair = Keypair.generate();\n  const entropyKeypair = Keypair.generate();\n  const entropyAccount = entropyKeypair.publicKey;\n\n  const entropyData = Buffer.alloc(32);\n  entropyData[0] = 0xab;\n  entropyData[1] = 0xcd;\n  entropyData[15] = 0x42;\n\n  beforeAll(async () => {\n    db = createDb(DATABASE_URL);\n    rawSql = postgres(DATABASE_URL);\n  });\n\n  afterAll(async () => {\n    await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    // Clean tables for isolation\n    await rawSql`TRUNCATE rounds, operator_events RESTART IDENTITY`;\n\n    // Fresh mock Connection\n    mockConn = new MockConnection();\n\n    // Pre-populate mock with entropy and config accounts\n    mockConn.setAccount(entropyAccount, entropyData);\n\n    const [configPda] = PublicKey.findProgramAddressSync(\n      [Buffer.from(\"coinflip_config\")],\n      COINFLIP_PROGRAM_ID,\n    );\n    mockConn.setAccount(\n      configPda,\n      await buildConfigAccountData(treasuryKeypair.publicKey),\n      { owner: COINFLIP_PROGRAM_ID },\n    );\n\n    // Build the Hono app (no rate limiting for tests)\n    app = new Hono();\n\n    app.use(\n      \"/fairness/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n    );\n\n    app.route(\n      \"/fairness/coinflip\",\n      createCoinflipRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n\n    app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n  });\n\n  it(\"full lifecycle: create → join (mock) → settle → verify\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const token = await makeJwt(wallet);\n\n    // ------------------------------------------------------------------\n    // 1. POST /fairness/coinflip/create\n    // ------------------------------------------------------------------\n    const body = { wallet, amountLamports: AMOUNT_LAMPORTS, side: SIDE_HEADS };\n\n    const createRes = await app.request(\"/fairness/coinflip/create\", {\n      method: \"POST\",\n      headers: {\n        \"Content-Type\": \"application/json\",\n        \"Authorization\": `Bearer ${token}`,\n      },\n      body: JSON.stringify(body),\n    });\n\n    expect(createRes.status).toBe(200);\n    const createJson = (await createRes.json()) as {\n      transaction: string;\n      matchPda: string;\n      matchId: string;\n      commitment: string;\n      lastValidBlockHeight: number;\n    };\n    expect(createJson.transaction).toBeDefined();\n    expect(createJson.matchPda).toBeDefined();\n    expect(createJson.commitment).toBeDefined();\n    expect(createJson.lastValidBlockHeight).toBeDefined();\n\n    const matchPda = createJson.matchPda;\n    const commitmentHex = createJson.commitment;\n    const commitmentBuf = Buffer.from(commitmentHex, \"hex\");\n\n    // ------------------------------------------------------------------\n    // 2. Verify DB state — round in \"created\" phase\n    // ------------------------------------------------------------------\n    const round = await db.getRoundByPda(matchPda);\n    expect(round).toBeDefined();\n    expect(round!.phase).toBe(\"created\");\n    expect(round!.game).toBe(\"coinflip\");\n    expect(round!.creator).toBe(wallet);\n    expect(round!.amount_lamports).toBe(AMOUNT_LAMPORTS);\n    expect(round!.side).toBe(SIDE_HEADS);\n    expect(round!.commitment.toString(\"hex\")).toBe(commitmentHex);\n    expect(round!.secret).toBeDefined();\n    expect(round!.secret.length).toBe(32);\n\n    // Verify operator event was logged\n    const events =\n      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n    expect(events.length).toBe(1);\n    expect(events[0]!.event_type).toBe(\"secret_generated\");\n\n    // ------------------------------------------------------------------\n    // 3. Simulate on-chain join — add LOCKED match to mock Connection\n    // ------------------------------------------------------------------\n    const matchPubkey = new PublicKey(matchPda);\n    const targetSlot = 150n;\n    const resolveDeadline = BigInt(Math.floor(Date.now() / 1000) + 86400);\n\n    const matchAccountData = await buildMatchAccountData({\n      creator: creatorKeypair.publicKey,\n      opponent: opponentKeypair.publicKey,\n      server: serverKeypair.publicKey,\n      entryAmount: AMOUNT_LAMPORTS_BIGINT,\n      creatorSide: SIDE_HEADS,\n      phase: PHASE_LOCKED,\n      commitment: commitmentBuf,\n      algorithmVer: 1,\n      targetSlot,\n      resolveDeadline,\n      matchId: Buffer.from(createJson.matchId, \"hex\"),\n    });\n\n    mockConn.setAccount(matchPubkey, matchAccountData, {\n      owner: COINFLIP_PROGRAM_ID,\n    });\n\n    // Set current slot past target_slot so settlement triggers immediately\n    mockConn.slot = 200;\n\n    // ------------------------------------------------------------------\n    // 4. Create worker + retry settler, trigger poll\n    // ------------------------------------------------------------------\n    let settlePromise: Promise<void> | null = null;\n\n    const retrySettler = createRetrySettler({\n      db,\n      connection: mockConn as unknown as Connection,\n      settleRound: (pda) =>\n        settleMatch(\n          {\n            db,\n            connection: mockConn as unknown as Connection,\n            serverKeypair,\n            entropyAccount,\n            referralDefaultRateBps: 1000,\n          },\n          pda,\n        ),\n    });\n\n    const worker = createSettlementWorker({\n      db,\n      connection: mockConn as unknown as Connection,\n      serverKey: serverKeypair.publicKey,\n      pollIntervalMs: 60_000, // won't auto-poll\n      onSettleReady: (pda) => {\n        settlePromise = retrySettler.attemptSettle(pda);\n        return settlePromise;\n      },\n    });\n\n    // Single poll cycle — should discover locked match and settle it\n    await worker.poll();\n    if (settlePromise) await settlePromise;\n\n    // ------------------------------------------------------------------\n    // 5. Verify DB updated to \"settled\" with result data\n    // ------------------------------------------------------------------\n    const settled = await db.getRoundByPda(matchPda);\n    expect(settled).toBeDefined();\n    expect(settled!.phase).toBe(\"settled\");\n    expect(settled!.settle_tx).toBeDefined();\n    expect(settled!.result_hash).toBeDefined();\n    expect(settled!.result_hash!.length).toBe(32);\n    expect(settled!.result_side).toBeDefined();\n    expect([0, 1]).toContain(settled!.result_side);\n    expect(settled!.winner).toBeDefined();\n\n    // Winner should be one of the two players\n    expect([\n      creatorKeypair.publicKey.toBase58(),\n      opponentKeypair.publicKey.toBase58(),\n    ]).toContain(settled!.winner);\n\n    // Verify operator events trail\n    const allEvents =\n      await rawSql`SELECT * FROM operator_events WHERE pda = ${matchPda} ORDER BY id`;\n    const eventTypes = allEvents.map(\n      (e) => (e as Record<string, unknown>).event_type,\n    );\n    expect(eventTypes).toContain(\"secret_generated\");\n    expect(eventTypes).toContain(\"match_detected\");\n    expect(eventTypes).toContain(\"settle_submitted\");\n    expect(eventTypes).toContain(\"settle_confirmed\");\n\n    // ------------------------------------------------------------------\n    // 6. GET /fairness/rounds/:pda — verify response includes secret\n    // ------------------------------------------------------------------\n    const roundsRes = await app.request(`/fairness/rounds/${matchPda}`);\n    expect(roundsRes.status).toBe(200);\n\n    const roundsJson = (await roundsRes.json()) as Record<string, unknown>;\n    expect(roundsJson.pda).toBe(matchPda);\n    expect(roundsJson.phase).toBe(\"settled\");\n    expect(roundsJson.game).toBe(\"coinflip\");","numLines":250,"startLine":220,"totalLines":557}}}
