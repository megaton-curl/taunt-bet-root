 rows = await sql<ReferralCode[]>`\n   800→        SELECT * FROM referral_codes WHERE code = ${code}\n   801→      `;\n   802→      return rows[0];\n   803→    },\n   804→\n   805→    async upsertReferralCode(wallet, code) {\n   806→      const rows = await sql<ReferralCode[]>`\n   807→        INSERT INTO referral_codes (wallet, code)\n   808→        VALUES (${wallet}, ${code})\n   809→        ON CONFLICT (wallet) DO UPDATE SET\n   810→          code = ${code},\n   811→          updated_at = now()\n   812→        RETURNING *\n   813→      `;\n   814→      return rows[0]!;\n   815→    },\n   816→\n   817→    // -- Referral links -------------------------------------------------------\n   818→\n   819→    async insertReferralLink(referrerWallet, refereeWallet) {\n   820→      const rows = await sql<ReferralLink[]>`\n   821→        INSERT INTO referral_links (referrer_wallet, referee_wallet)\n   822→        VALUES (${referrerWallet}, ${refereeWallet})\n   823→        RETURNING *\n   824→      `;\n   825→      return rows[0]!;\n   826→    },\n   827→\n   828→    async getReferralLinkByReferee(refereeWallet) {\n   829→      const rows = await sql<ReferralLink[]>`\n   830→        SELECT * FROM referral_links WHERE referee_wallet = ${refereeWallet}\n   831→      `;\n   832→      return rows[0];\n   833→    },\n   834→\n   835→    async getReferralLinksByReferrer(referrerWallet) {\n   836→      const rows = await sql<ReferralLink[]>`\n   837→        SELECT * FROM referral_links WHERE referrer_wallet = ${referrerWallet}\n   838→        ORDER BY created_at DESC\n   839→      `;\n   840→      return rows;\n   841→    },\n   842→\n   843→    // -- Referral earnings & stats --------------------------------------------\n   844→\n   845→    async insertReferralEarning(params) {\n   846→      const rows = await sql<ReferralEarning[]>`\n   847→        INSERT INTO referral_earnings (\n   848→          referrer_wallet, referee_wallet, round_id, game_type,\n   849→          wager_lamports, fee_lamports,\n   850→          referrer_earned_lamports, referrer_rate_bps,\n   851→          referee_rebate_lamports, referee_rebate_rate_bps\n   852→        ) VALUES (\n   853→          ${params.referrerWallet}, ${params.refereeWallet}, ${params.roundId}, ${params.gameType},\n   854→          ${params.wagerLamports}, ${params.feeLamports},\n   855→          ${params.referrerEarnedLamports}, ${params.referrerRateBps},\n   856→          ${params.refereeRebateLamports}, ${params.refereeRebateRateBps}\n   857→        )\n   858→        RETURNING *\n   859→      `;\n   860→      return normalizeReferralEarning(rows[0]!);\n   861→    },\n   862→\n   863→    async getPendingBalance(wallet) {\n   864→      const rows = await sql<{ pending: string }[]>`\n   865→        SELECT COALESCE(\n   866→          (\n   867→            SELECT SUM(referrer_earned_lamports)\n   868→            FROM referral_earnings WHERE referrer_wallet = ${wallet}\n   869→          ), 0\n   870→        ) + COALESCE(\n   871→          (\n   872→            SELECT SUM(referee_rebate_lamports)\n   873→            FROM referral_earnings WHERE referee_wallet = ${wallet}\n   874→          ), 0\n   875→        ) - COALESCE(\n   876→          (\n   877→            SELECT SUM(amount_lamports)\n   878→            FROM referral_claims WHERE wallet = ${wallet} AND status IN ('pending', 'processing', 'completed')\n   879→          ), 0\n   880→        ) AS pending\n   881→      `;\n   882→      return rows[0]!.pending;\n   883→    },\n   884→\n   885→    async getReferralEarnings(wallet, page, limit) {\n   886→      const offset = (page - 1) * limit;\n   887→      const [countRows, rows] = await Promise.all([\n   888→        sql<{ count: string }[]>`\n   889→          SELECT COUNT(*)::TEXT AS count FROM referral_earnings\n   890→          WHERE referrer_wallet = ${wallet}\n   891→        `,\n   892→        sql<ReferralEarning[]>`\n   893→          SELECT * FROM referral_earnings\n   894→          WHERE referrer_wallet = ${wallet}\n   895→          ORDER BY created_at DESC\n   896→          LIMIT ${limit} OFFSET ${offset}\n   897→        `,\n   898→      ]);\n   899→      const total = Number(countRows[0]!.count);\n   900→      const totalPages = Math.max(1, Math.ceil(total / limit));\n   901→      return { items: rows.map(normalizeReferralEarning), totalPages };\n   902→    },\n   903→\n   904→    async getReferralStats(wallet) {\n   905→      const rows = await sql<ReferralStats[]>`\n   906→        SELECT\n   907→          (SELECT COUNT(*) FROM referral_links WHERE referrer_wallet = ${wallet})::INT\n   908→            AS referred_count,\n   909→          (\n   910→            SELECT COUNT(DISTINCT re.referee_wallet)\n   911→            FROM referral_earnings re\n   912→            JOIN referral_links rl ON rl.referee_wallet = re.referee_wallet AND rl.referrer_wallet = ${wallet}\n   913→            WHERE re.created_at > now() - INTERVAL '7 days'\n   914→          )::INT AS active_count,\n   915→          COALESCE(\n   916→            (\n   917→              SELECT SUM(re.wager_lamports)::TEXT\n   918→              FROM referral_earnings re\n   919→              JOIN referral_links rl ON rl.referee_wallet = re.referee_wallet AND rl.referrer_wallet = ${wallet}\n   920→            ), '0'\n   921→          ) AS total_volume_lamports,\n   922→          COALESCE(\n   923→            (SELECT SUM(referrer_earned_lamports)::TEXT FROM referral_earnings WHERE referrer_wallet = ${wallet}),\n   924→            '0'\n   925→          ) AS total_earned_lamports,\n   926→          COALESCE(\n   927→            (SELECT SUM(referee_rebate_lamports)::TEXT FROM referral_earnings WHERE referee_wallet = ${wallet}),\n   928→            '0'\n   929→          ) AS total_rebate_lamports,\n   930→          (\n   931→            COALESCE((SELECT SUM(referrer_earned_lamports) FROM referral_earnings WHERE referrer_wallet = ${wallet}), 0)\n   932→            + COALESCE((SELECT SUM(referee_rebate_lamports) FROM referral_earnings WHERE referee_wallet = ${wallet}), 0)\n   933→            - COALESCE((SELECT SUM(amount_lamports) FROM referral_claims WHERE wallet = ${wallet} AND status IN ('pending','processing','completed')), 0)\n   934→          )::TEXT AS pending_lamports\n   935→      `;\n   936→      return rows[0]!;\n   937→    },\n   938→\n   939→    // -----------------------------------------------------------------------\n   940→    // Referral — claims & rates\n   941→    // -----------------------------------------------------------------------\n   942→\n   943→    async insertReferralClaim(wallet, amountLamports) {\n   944→      const rows = await sql<ReferralClaim[]>`\n   945→        INSERT INTO referral_claims (wallet, amount_lamports, status)\n   946→        VALUES (${wallet}, ${amountLamports}, 'pending')\n   947→        RETURNING *\n   948→      `;\n   949→      return rows[0]!;\n   950→    },\n   951→\n   952→    async getReferralClaim(claimId) {\n   953→      const rows = await sql<ReferralClaim[]>`\n   954→        SELECT * FROM referral_claims WHERE id = ${claimId}\n   955→      `;\n   956→      return rows[0];\n   957→    },\n   958→\n   959→    async updateClaimStatus(claimId, status, meta) {\n   960→      const rows = await sql<ReferralClaim[]>`\n   961→        UPDATE referral_claims\n   962→        SET\n   963→          status = ${status},\n   964→          tx_signature = COALESCE(${meta?.txSignature ?? null}, tx_signature),\n   965→          error = COALESCE(${meta?.error ?? null}, error),\n   966→          processed_at = ${status === \"completed\" || status === \"failed\" ? sql`now()` : sql`processed_at`}\n   967→        WHERE id = ${claimId}\n   968→        RETURNING *\n   969→      `;\n   970→      return rows[0]!;\n   971→    },\n   972→\n   973→    async getReferrerRate(wallet, defaultRateBps) {\n   974→      const rows = await sql<{ rate_bps: number }[]>`\n   975→        SELECT rate_bps FROM referral_kol_rates WHERE wallet = ${wallet}\n   976→      `;\n   977→      return rows[0]?.rate_bps ?? defaultRateBps;\n   978→    },\n   979→\n   980→    async withTransaction<T>(fn: (db: Db) => Promise<T>): Promise<T> {\n   981→      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n   982→      return sql.begin(async (txSql: any) => fn(createDb(databaseUrl, txSql)));\n   983→    },\n   984→\n   985→    async close() {\n   986→      if (_isOwner) await sql.end();\n   987→    },\n   988→  };\n   989→}\n   990→"}]},"parent_tool_use_id":"toolu_01FBkbFoVYBbtV21JBz2b79G","session_id":"773e2b1e-9c3d-4d53-809d-a95c06988ae7","uuid":"2542d269-cfdb-4bb1-aeec-1d4d5cdccb1b","timestamp":"2026-03-25T13:56:19.131Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013tfFdd3i9GX2nC9e5mRxBA","type":"tool_result","content":"     1→/**\n     2→ * Settlement retry logic — wraps settlement with exponential backoff\n     3→ * for transient failures and proper handling of permanent failures.\n     4→ *\n     5→ * Called by the settlement worker's onSettleReady callback on each poll\n     6→ * cycle for every locked match whose target_slot has been reached.\n     7→ */\n     8→\n     9→import { Connection, PublicKey } from \"@solana/web3.js\";\n    10→import type { Db } from \"../db.js\";\n    11→import type { SettleResult } from \"./settle-tx.js\";\n    12→import { PermanentSettleError } from \"./settle-tx.js\";\n    13→import { logger } from \"../logger.js\";\n    14→import { decodeCoinflipMatch, decodeLordRound } from \"./account-decoder.js\";\n    15→\n    16→// ---------------------------------------------------------------------------\n    17→// Constants\n    18→// ---------------------------------------------------------------------------\n    19→\n    20→const MAX_RETRIES = 5;\n    21→const BASE_DELAY_MS = 2_000;\n    22→const MAX_DELAY_MS = 30_000;\n    23→\n    24→// ---------------------------------------------------------------------------\n    25→// Types\n    26→// ---------------------------------------------------------------------------\n    27→\n    28→export interface RetrySettlerDeps {\n    29→  db: Db;\n    30→  connection: Connection;\n    31→  settleRound: (pda: string) => Promise<SettleResult>;\n    32→}\n    33→\n    34→interface RetryState {\n    35→  attempts: number;\n    36→  /** Timestamp (ms) at which next retry is allowed. */\n    37→  nextRetryAt: number;\n    38→}\n    39→\n    40→export interface RetrySettler {\n    41→  /**\n    42→   * Attempt settlement for a PDA. Handles retry scheduling, permanent\n    43→   * failure tracking, and resolve_deadline timeout detection.\n    44→   *\n    45→   * Safe to call repeatedly — skips if a retry is scheduled but not yet due,\n    46→   * or if the PDA has already been marked as permanently failed / timed out.\n    47→   */\n    48→  attemptSettle(pda: string): Promise<void>;\n    49→  /** Returns true if this PDA is done (settled, failed, or timed out). */\n    50→  isFinalized(pda: string): boolean;\n    51→}\n    52→\n    53→// ---------------------------------------------------------------------------\n    54→// Factory\n    55→// ---------------------------------------------------------------------------\n    56→\n    57→export function createRetrySettler(deps: RetrySettlerDeps): RetrySettler {\n    58→  const { db, connection, settleRound } = deps;\n    59→\n    60→  /** Per-PDA retry tracking (in-memory, resets on service restart). */\n    61→  const retryStates = new Map<string, RetryState>();\n    62→\n    63→  /** PDAs that hit a permanent (non-retryable) error. */\n    64→  const failedPdas = new Set<string>();\n    65→\n    66→  /** PDAs whose resolve_deadline has passed. */\n    67→  const timeoutPdas = new Set<string>();\n    68→\n    69→  /** PDAs that settled successfully. */\n    70→  const settledPdas = new Set<string>();\n    71→\n    72→  /** Compute exponential backoff delay: base * 2^attempt, capped at max. */\n    73→  function getDelay(attempt: number): number {\n    74→    return Math.min(BASE_DELAY_MS * Math.pow(2, attempt), MAX_DELAY_MS);\n    75→  }\n    76→\n    77→  /**\n    78→   * Check whether the on-chain resolve_deadline has passed for a round.\n    79→   * Returns true if the deadline is in the past (timeout refund eligible).\n    80→   */\n    81→  async function isResolveDeadlinePassed(pda: string): Promise<boolean> {\n    82→    try {\n    83→      const round = await db.getRoundByPda(pda);\n    84→      if (!round) return true;\n    85→      const accountInfo = await connection.getAccountInfo(new PublicKey(pda));\n    86→      if (!accountInfo) return true; // account gone — treat as expired\n    87→      const data = Buffer.from(accountInfo.data);\n    88→      let resolveDeadline = 0;\n    89→      if (round.game === \"lord\") {\n    90→        const decoded = decodeLordRound(data);\n    91→        resolveDeadline = Number(decoded.resolveDeadline);\n    92→      } else {\n    93→        const decoded = decodeCoinflipMatch(data);\n    94→        resolveDeadline = Number(decoded.resolveDeadline);\n    95→      }\n    96→      if (resolveDeadline <= 0) return false; // not set yet\n    97→      const nowUnix = Math.floor(Date.now() / 1000);\n    98→      return nowUnix >= resolveDeadline;\n    99→    } catch {\n   100→      return false; // can't read — don't assume timeout"}]},"parent_tool_use_id":"toolu_01K6S9FTWc4Mt7jLihK2J2QP","session_id":"773e2b1e-9c3d-4d53-809d-a95c06988ae7","uuid":"13d9b322-e88a-45bd-bd1b-94c61946dee2","timestamp":"2026-03-25T13:56:18.922Z"}
