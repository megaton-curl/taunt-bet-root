t data.\n *\n * Account layout (after 8-byte Anchor discriminator):\n *   offset  0..8   discriminator\n *   offset  8..40  authority (Pubkey, 32 bytes)\n *   offset 40..72  treasury  (Pubkey, 32 bytes)\n *   offset 72..74  fee_bps   (u16 LE)\n */\nexport async function fetchPlatformConfig(\n  connection: Connection,\n): Promise<{ feeBps: number; treasury: PublicKey }> {\n  const [pda] = derivePlatformConfigPda();\n  const info = await connection.getAccountInfo(pda);\n  if (!info) {\n    throw new Error(\n      `PlatformConfig account not found at ${pda.toBase58()}`,\n    );\n  }\n\n  const data = info.data;\n  const treasury = new PublicKey(data.subarray(40, 72));\n  const feeBps = data.readUInt16LE(72);\n\n  return { feeBps, treasury };\n}\n\n// ---------------------------------------------------------------------------\n// Cached accessor — avoids repeated RPC calls within the same process\n// ---------------------------------------------------------------------------\n\nlet _cache: { feeBps: number; treasury: PublicKey } | null = null;\n\n/**\n * Return the cached PlatformConfig, fetching from RPC on first call.\n * Cache lives for the process lifetime — restart the backend to pick up\n * on-chain config changes.\n */\nexport async function getPlatformConfig(\n  connection: Connection,\n): Promise<{ feeBps: number; treasury: PublicKey }> {\n  if (_cache) return _cache;\n  _cache = await fetchPlatformConfig(connection);\n  return _cache;\n}\n","structuredPatch":[{"oldStart":67,"oldLines":3,"newStart":67,"newLines":8,"lines":["   _cache = await fetchPlatformConfig(connection);","   return _cache;"," }","+","+/** Clear the cached PlatformConfig — used in tests to reset between runs. */","+export function resetPlatformConfigCache(): void {","+  _cache = null;","+}"]}],"userModified":false,"replaceAll":false}}
