{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NxZMx9iPUYKLrJHz8wGiFb","type":"tool_result","content":"     1→/**\n     2→ * Integration tests for the event queue worker.\n     3→ *\n     4→ * Tests the full lifecycle: emit → worker poll → handler dispatch → status transitions.\n     5→ * Requires a running Postgres database (same as backend).\n     6→ *\n     7→ * Covers:\n     8→ * 1. Happy path — handler called, event status = completed\n     9→ * 2. Failure → retry → dead — attempts increment, backoff applied, final status = dead\n    10→ * 3. Concurrent safety — two workers, SKIP LOCKED, each event processed exactly once\n    11→ */\n    12→\n    13→import {\n    14→  describe,\n    15→  it,\n    16→  beforeAll,\n    17→  afterAll,\n    18→  beforeEach,\n    19→  expect,\n    20→} from \"vitest\";\n    21→import postgres from \"postgres\";\n    22→import { emitEvent } from \"../emit-event.js\";\n    23→import {\n    24→  registerHandler,\n    25→  clearHandlers,\n    26→} from \"../handler-registry.js\";\n    27→import { EventTypes } from \"../event-types.js\";\n    28→import { createEventWorker } from \"../worker.js\";\n    29→\n    30→/** Poll until condition is true or timeout. */\n    31→async function waitFor(\n    32→  condition: () => boolean,\n    33→  timeoutMs: number,\n    34→): Promise<void> {\n    35→  const start = Date.now();\n    36→  while (!condition()) {\n    37→    if (Date.now() - start > timeoutMs) {\n    38→      throw new Error(`waitFor timed out after ${timeoutMs}ms`);\n    39→    }\n    40→    await new Promise((r) => setTimeout(r, 50));\n    41→  }\n    42→}\n    43→\n    44→describe(\"event queue integration tests\", () => {\n    45→  let sql: ReturnType<typeof postgres>;\n    46→\n    47→  beforeAll(async () => {\n    48→    sql = process.env.DATABASE_URL\n    49→      ? postgres(process.env.DATABASE_URL)\n    50→      : postgres({\n    51→          host: \"/var/run/postgresql\",\n    52→          database: \"rng_utopia_dev\",\n    53→          username: \"vscode\",\n    54→        });\n    55→  });\n    56→\n    57→  afterAll(async () => {\n    58→    await sql.end();\n    59→  });\n    60→\n    61→  beforeEach(async () => {\n    62→    await sql`TRUNCATE event_queue RESTART IDENTITY`;\n    63→    clearHandlers();\n    64→  });\n    65→\n    66→  // -------------------------------------------------------------------------\n    67→  // 1. Happy path\n    68→  // -------------------------------------------------------------------------\n    69→\n    70→  it(\"happy path: handler called and event status = completed\", async () => {\n    71→    let handlerCalled = false;\n    72→    let capturedPayload: Record<string, unknown> | null = null;\n    73→\n    74→    registerHandler(EventTypes.REFERRAL_GAME_SETTLED, async (payload) => {\n    75→      handlerCalled = true;\n    76→      capturedPayload = payload;\n    77→    });\n    78→\n    79→    const payload = { referrerWallet: \"abc\", roundId: \"test-round\" };\n    80→    await sql.begin(async (tx) => {\n    81→      await emitEvent(\n    82→        tx as unknown as postgres.Sql,\n    83→        EventTypes.REFERRAL_GAME_SETTLED,\n    84→        payload,\n    85→      );\n    86→    });\n    87→\n    88→    const worker = createEventWorker(sql, { pollIntervalMs: 100 });\n    89→    worker.start();\n    90→\n    91→    // Wait for handler to be called (up to 3s)\n    92→    await waitFor(() => handlerCalled, 3000);\n    93→    worker.stop();\n    94→\n    95→    expect(handlerCalled).toBe(true);\n    96→    expect(capturedPayload).toEqual(payload);\n    97→\n    98→    // Verify DB status\n    99→    const rows = await sql`SELECT * FROM event_queue WHERE status = 'completed'`;\n   100→    expect(rows).toHaveLength(1);\n   101→    expect(rows[0]!.event_type).toBe(\"referral.game_settled\");\n   102→    expect(rows[0]!.completed_at).toBeInstanceOf(Date);\n   103→  });\n   104→\n   105→  // -------------------------------------------------------------------------\n   106→  // 2. Failure → retry → dead\n   107→  // -------------------------------------------------------------------------\n   108→\n   109→  it(\"failure → retry → dead after max_attempts\", async () => {\n   110→    let callCount = 0;\n   111→\n   112→    registerHandler(EventTypes.REFERRAL_CODE_APPLIED, async () => {\n   113→      callCount++;\n   114→      throw new Error(\"simulated failure\");\n   115→    });\n   116→\n   117→    await sql.begin(async (tx) => {\n   118→      await emitEvent(\n   119→        tx as unknown as postgres.Sql,\n   120→        EventTypes.REFERRAL_CODE_APPLIED,\n   121→        { test: true },\n   122→        { maxAttempts: 3 },\n   123→      );\n   124→    });\n   125→\n   126→    const worker = createEventWorker(sql);\n   127→\n   128→    // Attempt 1 — fails → pending with backoff\n   129→    await worker.poll();\n   130→    expect(callCount).toBe(1);\n   131→    let rows = await sql`SELECT * FROM event_queue`;\n   132→    expect(rows[0]!.status).toBe(\"pending\");\n   133→    expect(rows[0]!.attempts).toBe(1);\n   134→    expect(rows[0]!.error).toBe(\"simulated failure\");\n   135→\n   136→    // Reset scheduled_at so next poll picks it up immediately\n   137→    await sql`UPDATE event_queue SET scheduled_at = now()`;\n   138→\n   139→    // Attempt 2 — fails → pending with backoff\n   140→    await worker.poll();\n   141→    expect(callCount).toBe(2);\n   142→    rows = await sql`SELECT * FROM event_queue`;\n   143→    expect(rows[0]!.status).toBe(\"pending\");\n   144→    expect(rows[0]!.attempts).toBe(2);\n   145→\n   146→    // Reset scheduled_at for final attempt\n   147→    await sql`UPDATE event_queue SET scheduled_at = now()`;\n   148→\n   149→    // Attempt 3 — fails → dead (max_attempts reached)\n   150→    await worker.poll();"}]},"parent_tool_use_id":"toolu_01K6S9FTWc4Mt7jLihK2J2QP","session_id":"773e2b1e-9c3d-4d53-809d-a95c06988ae7","uuid":"419f4d04-529a-4277-a9e7-624d5d010ce4","timestamp":"2026-03-25T13:56:25.887Z"}
