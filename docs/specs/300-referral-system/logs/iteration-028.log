{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017JFuCPneNpgzc9Ti3HX8pA","type":"tool_result","content":"     1→/**\n     2→ * Unit tests for the async event queue module.\n     3→ *\n     4→ * Covers:\n     5→ * 1. emitEvent — inserts with correct fields, returns eventId\n     6→ * 2. emitEvent — rolled-back transaction does NOT persist\n     7→ * 3. Handler registry — register/get, unknown returns undefined\n     8→ * 4. Backoff calculation — attempt 1 → 5s, attempt 2 → 30s, attempt 3+ → 300s\n     9→ *\n    10→ * Requires a running Postgres database (same as backend).\n    11→ */\n    12→\n    13→import { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n    14→import postgres from \"postgres\";\n    15→import { emitEvent } from \"../emit-event.js\";\n    16→import { registerHandler, getHandler } from \"../handler-registry.js\";\n    17→import { EventTypes } from \"../event-types.js\";\n    18→import { getBackoffSeconds } from \"../worker.js\";\n    19→\n    20→describe(\"event queue unit tests\", () => {\n    21→  let sql: ReturnType<typeof postgres>;\n    22→\n    23→  beforeAll(async () => {\n    24→    sql = process.env.DATABASE_URL\n    25→      ? postgres(process.env.DATABASE_URL)\n    26→      : postgres({\n    27→          host: \"/var/run/postgresql\",\n    28→          database: \"rng_utopia_dev\",\n    29→          username: \"vscode\",\n    30→        });\n    31→  });\n    32→\n    33→  afterAll(async () => {\n    34→    await sql.end();\n    35→  });\n    36→\n    37→  beforeEach(async () => {\n    38→    await sql`TRUNCATE event_queue RESTART IDENTITY`;\n    39→  });\n    40→\n    41→  // -------------------------------------------------------------------------\n    42→  // emitEvent\n    43→  // -------------------------------------------------------------------------\n    44→\n    45→  describe(\"emitEvent\", () => {\n    46→    it(\"inserts a row with correct fields and returns eventId\", async () => {\n    47→      const payload = { referrerWallet: \"abc\", roundId: \"123\" };\n    48→\n    49→      const result = await sql.begin(async (tx) => {\n    50→        return emitEvent(\n    51→          tx as unknown as postgres.Sql,\n    52→          EventTypes.REFERRAL_GAME_SETTLED,\n    53→          payload,\n    54→        );\n    55→      });\n    56→\n    57→      expect(result.eventId).toBeTypeOf(\"bigint\");\n    58→      expect(result.eventId).toBeGreaterThan(0n);\n    59→\n    60→      // Verify the persisted row\n    61→      const rows = await sql`\n    62→        SELECT * FROM event_queue WHERE id = ${result.eventId.toString()}\n    63→      `;\n    64→      expect(rows).toHaveLength(1);\n    65→\n    66→      const row = rows[0]!;\n    67→      expect(row.event_type).toBe(\"referral.game_settled\");\n    68→      expect(row.payload).toEqual(payload);\n    69→      expect(row.status).toBe(\"pending\");\n    70→      expect(row.attempts).toBe(0);\n    71→      expect(row.max_attempts).toBe(3);\n    72→      expect(row.scheduled_at).toBeInstanceOf(Date);\n    73→      expect(row.created_at).toBeInstanceOf(Date);\n    74→    });\n    75→\n    76→    it(\"does NOT persist when transaction is rolled back\", async () => {\n    77→      let capturedId: bigint | undefined;\n    78→\n    79→      try {\n    80→        await sql.begin(async (tx) => {\n    81→          const result = await emitEvent(\n    82→            tx as unknown as postgres.Sql,\n    83→            EventTypes.REFERRAL_CODE_APPLIED,\n    84→            { test: true },\n    85→          );\n    86→          capturedId = result.eventId;\n    87→          throw new Error(\"intentional rollback\");\n    88→        });\n    89→      } catch {\n    90→        // Expected — begin() re-throws after rollback\n    91→      }\n    92→\n    93→      expect(capturedId).toBeDefined();\n    94→      const rows = await sql`\n    95→        SELECT * FROM event_queue WHERE id = ${capturedId!.toString()}\n    96→      `;\n    97→      expect(rows).toHaveLength(0);\n    98→    });\n    99→\n   100→    it(\"respects custom maxAttempts and scheduledAt\", async () => {\n   101→      const future = new Date(Date.now() + 60_000);\n   102→\n   103→      const result = await sql.begin(async (tx) => {\n   104→        return emitEvent(\n   105→          tx as unknown as postgres.Sql,\n   106→          EventTypes.REFERRAL_CLAIM_REQUESTED,\n   107→          { foo: \"bar\" },\n   108→          { maxAttempts: 5, scheduledAt: future },\n   109→        );\n   110→      });\n   111→\n   112→      const rows = await sql`\n   113→        SELECT * FROM event_queue WHERE id = ${result.eventId.toString()}\n   114→      `;\n   115→      expect(rows[0]!.max_attempts).toBe(5);\n   116→      // scheduled_at should be close to the future date (within 1s tolerance)\n   117→      const diff = Math.abs(rows[0]!.scheduled_at.getTime() - future.getTime());\n   118→      expect(diff).toBeLessThan(1000);\n   119→    });\n   120→  });\n   121→\n   122→  // -------------------------------------------------------------------------\n   123→  // Handler registry\n   124→  // -------------------------------------------------------------------------\n   125→\n   126→  describe(\"handler registry\", () => {\n   127→    it(\"register → get returns the handler\", () => {\n   128→      const handler = async () => {};\n   129→      registerHandler(EventTypes.REFERRAL_GAME_SETTLED, handler);\n   130→      expect(getHandler(\"referral.game_settled\")).toBe(handler);\n   131→    });\n   132→\n   133→    it(\"get for unknown type returns undefined\", () => {\n   134→      expect(getHandler(\"unknown.event.type\")).toBeUndefined();\n   135→    });\n   136→  });\n   137→\n   138→  // -------------------------------------------------------------------------\n   139→  // Backoff calculation\n   140→  // -------------------------------------------------------------------------\n   141→\n   142→  describe(\"getBackoffSeconds\", () => {\n   143→    it(\"attempt 1 → 5 seconds\", () => {\n   144→      expect(getBackoffSeconds(1)).toBe(5);\n   145→    });\n   146→\n   147→    it(\"attempt 2 → 30 seconds\", () => {\n   148→      expect(getBackoffSeconds(2)).toBe(30);\n   149→    });\n   150→\n   151→    it(\"attempt 3+ → 300 seconds\", () => {\n   152→      expect(getBackoffSeconds(3)).toBe(300);\n   153→      expect(getBackoffSeconds(4)).toBe(300);\n   154→    });\n   155→  });\n   156→});\n   157→"}]},"parent_tool_use_id":"toolu_01FUmw22Gty3DEJ8iw5RHp6J","session_id":"aa0285d4-bc35-4024-8afc-77d99fd4e541","uuid":"448e9f66-1696-4ae8-b584-6b68a7a989c9","timestamp":"2026-03-25T13:44:36.538Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013Po6Dvtpm4wsW9RBWB5gZA","type":"tool_result","content":"     1→/**\n     2→ * Auth routes tests: challenge → verify → refresh → logout flows.\n     3→ */\n     4→\n     5→import { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n     6→import { Hono } from \"hono\";\n     7→import { Keypair } from \"@solana/web3.js\";\n     8→import nacl from \"tweetnacl\";\n     9→import bs58 from \"bs58\";\n    10→import { jwtVerify } from \"jose\";\n    11→import postgres from \"postgres\";\n    12→import { createAuthDb, type AuthDb } from \"../auth-db.js\";\n    13→import { createAuthRoutes } from \"../routes/auth.js\";\n    14→\n    15→// ---------------------------------------------------------------------------\n    16→// Constants\n    17→// ---------------------------------------------------------------------------\n    18→\n    19→const DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n    20→const JWT_SECRET = new TextEncoder().encode(\"test-secret-for-auth-route-tests\");\n    21→\n    22→// ---------------------------------------------------------------------------\n    23→// Test suite\n    24→// ---------------------------------------------------------------------------\n    25→\n    26→describe(\"Auth routes: challenge → verify → refresh → logout\", () => {\n    27→  let rawSql: ReturnType<typeof postgres>;\n    28→  let authDb: AuthDb;\n    29→  let app: Hono;\n    30→\n    31→  const creatorKeypair = Keypair.generate();\n    32→\n    33→  beforeAll(async () => {\n    34→    rawSql = postgres(DATABASE_URL);\n    35→    // Ensure auth tables exist\n    36→    await rawSql`\n    37→      CREATE TABLE IF NOT EXISTS auth_challenges (\n    38→        nonce TEXT PRIMARY KEY,\n    39→        wallet TEXT NOT NULL,\n    40→        cluster TEXT NOT NULL DEFAULT 'devnet',\n    41→        message TEXT NOT NULL,\n    42→        expires_at TIMESTAMPTZ NOT NULL,\n    43→        used BOOLEAN DEFAULT FALSE,\n    44→        created_at TIMESTAMPTZ DEFAULT now()\n    45→      )\n    46→    `;\n    47→    await rawSql`\n    48→      CREATE TABLE IF NOT EXISTS refresh_tokens (\n    49→        id BIGSERIAL PRIMARY KEY,\n    50→        wallet TEXT NOT NULL,\n    51→        token_hash BYTEA NOT NULL UNIQUE,\n    52→        family_id TEXT NOT NULL,\n    53→        expires_at TIMESTAMPTZ NOT NULL,\n    54→        revoked BOOLEAN DEFAULT FALSE,\n    55→        created_at TIMESTAMPTZ DEFAULT now()\n    56→      )\n    57→    `;\n    58→  });\n    59→\n    60→  afterAll(async () => {\n    61→    await rawSql.end();\n    62→  });\n    63→\n    64→  beforeEach(async () => {\n    65→    await rawSql`TRUNCATE auth_challenges, refresh_tokens RESTART IDENTITY`;\n    66→    authDb = createAuthDb(rawSql);\n    67→    app = new Hono();\n    68→    app.route(\n    69→      \"/auth\",\n    70→      createAuthRoutes({\n    71→        authDb,\n    72→        jwtSecret: JWT_SECRET,\n    73→        cluster: \"devnet\",\n    74→        challengeTtlSeconds: 300,\n    75→        accessTokenTtlSeconds: 3600,\n    76→        refreshTokenTtlDays: 14,\n    77→      }),\n    78→    );\n    79→  });\n    80→\n    81→  // -----------------------------------------------------------------------\n    82→  // POST /auth/challenge\n    83→  // -----------------------------------------------------------------------\n    84→\n    85→  it(\"returns a challenge with nonce and message\", async () => {\n    86→    const wallet = creatorKeypair.publicKey.toBase58();\n    87→    const res = await app.request(\"/auth/challenge\", {\n    88→      method: \"POST\",\n    89→      headers: { \"Content-Type\": \"application/json\" },\n    90→      body: JSON.stringify({ wallet }),\n    91→    });\n    92→\n    93→    expect(res.status).toBe(200);\n    94→    const json = (await res.json()) as { nonce: string; message: string; expiresAt: string };\n    95→    expect(json.nonce).toBeDefined();\n    96→    expect(json.nonce.length).toBe(64); // 32 bytes hex\n    97→    expect(json.message).toContain(\"Sign in to RNG Utopia\");\n    98→    expect(json.message).toContain(wallet);\n    99→    expect(json.message).toContain(\"devnet\");\n   100→    expect(json.expiresAt).toBeDefined();\n   101→  });\n   102→\n   103→  it(\"rejects challenge with missing wallet\", async () => {\n   104→    const res = await app.request(\"/auth/challenge\", {\n   105→      method: \"POST\",\n   106→      headers: { \"Content-Type\": \"application/json\" },\n   107→      body: JSON.stringify({}),\n   108→    });\n   109→    expect(res.status).toBe(400);\n   110→  });\n   111→\n   112→  // -----------------------------------------------------------------------\n   113→  // Full flow: challenge → verify → refresh → logout\n   114→  // -----------------------------------------------------------------------\n   115→\n   116→  it(\"full auth flow: challenge → verify → refresh → logout\", async () => {\n   117→    const wallet = creatorKeypair.publicKey.toBase58();\n   118→\n   119→    // 1. Request challenge\n   120→    const challengeRes = await app.request(\"/auth/challenge\", {\n   121→      method: \"POST\",\n   122→      headers: { \"Content-Type\": \"application/json\" },\n   123→      body: JSON.stringify({ wallet }),\n   124→    });\n   125→    expect(challengeRes.status).toBe(200);\n   126→    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n   127→\n   128→    // 2. Sign the message\n   129→    const messageBytes = new TextEncoder().encode(challenge.message);\n   130→    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n   131→    const signature = bs58.encode(signatureBytes);\n   132→\n   133→    // 3. Verify\n   134→    const verifyRes = await app.request(\"/auth/verify\", {\n   135→      method: \"POST\",\n   136→      headers: { \"Content-Type\": \"application/j