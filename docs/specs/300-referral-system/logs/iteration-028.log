{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0151kfnRHCsRYDBnW4YSNdoG","type":"tool_result","content":"     1→/**\n     2→ * Auth routes tests: challenge → verify → refresh → logout flows.\n     3→ */\n     4→\n     5→import { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n     6→import { Hono } from \"hono\";\n     7→import { Keypair } from \"@solana/web3.js\";\n     8→import nacl from \"tweetnacl\";\n     9→import bs58 from \"bs58\";\n    10→import { jwtVerify } from \"jose\";\n    11→import postgres from \"postgres\";\n    12→import { createAuthDb, type AuthDb } from \"../auth-db.js\";\n    13→import { createAuthRoutes } from \"../routes/auth.js\";\n    14→\n    15→// ---------------------------------------------------------------------------\n    16→// Constants\n    17→// ---------------------------------------------------------------------------\n    18→\n    19→const DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\n    20→const JWT_SECRET = new TextEncoder().encode(\"test-secret-for-auth-route-tests\");\n    21→\n    22→// ---------------------------------------------------------------------------\n    23→// Test suite\n    24→// ---------------------------------------------------------------------------\n    25→\n    26→describe(\"Auth routes: challenge → verify → refresh → logout\", () => {\n    27→  let rawSql: ReturnType<typeof postgres>;\n    28→  let authDb: AuthDb;\n    29→  let app: Hono;\n    30→\n    31→  const creatorKeypair = Keypair.generate();\n    32→\n    33→  beforeAll(async () => {\n    34→    rawSql = postgres(DATABASE_URL);\n    35→    // Ensure auth tables exist\n    36→    await rawSql`\n    37→      CREATE TABLE IF NOT EXISTS auth_challenges (\n    38→        nonce TEXT PRIMARY KEY,\n    39→        wallet TEXT NOT NULL,\n    40→        cluster TEXT NOT NULL DEFAULT 'devnet',\n    41→        message TEXT NOT NULL,\n    42→        expires_at TIMESTAMPTZ NOT NULL,\n    43→        used BOOLEAN DEFAULT FALSE,\n    44→        created_at TIMESTAMPTZ DEFAULT now()\n    45→      )\n    46→    `;\n    47→    await rawSql`\n    48→      CREATE TABLE IF NOT EXISTS refresh_tokens (\n    49→        id BIGSERIAL PRIMARY KEY,\n    50→        wallet TEXT NOT NULL,\n    51→        token_hash BYTEA NOT NULL UNIQUE,\n    52→        family_id TEXT NOT NULL,\n    53→        expires_at TIMESTAMPTZ NOT NULL,\n    54→        revoked BOOLEAN DEFAULT FALSE,\n    55→        created_at TIMESTAMPTZ DEFAULT now()\n    56→      )\n    57→    `;\n    58→  });\n    59→\n    60→  afterAll(async () => {\n    61→    await rawSql.end();\n    62→  });\n    63→\n    64→  beforeEach(async () => {\n    65→    await rawSql`TRUNCATE auth_challenges, refresh_tokens RESTART IDENTITY`;\n    66→    authDb = createAuthDb(rawSql);\n    67→    app = new Hono();\n    68→    app.route(\n    69→      \"/auth\",\n    70→      createAuthRoutes({\n    71→        authDb,\n    72→        jwtSecret: JWT_SECRET,\n    73→        cluster: \"devnet\",\n    74→        challengeTtlSeconds: 300,\n    75→        accessTokenTtlSeconds: 3600,\n    76→        refreshTokenTtlDays: 14,\n    77→      }),\n    78→    );\n    79→  });\n    80→\n    81→  // -----------------------------------------------------------------------\n    82→  // POST /auth/challenge\n    83→  // -----------------------------------------------------------------------\n    84→\n    85→  it(\"returns a challenge with nonce and message\", async () => {\n    86→    const wallet = creatorKeypair.publicKey.toBase58();\n    87→    const res = await app.request(\"/auth/challenge\", {\n    88→      method: \"POST\",\n    89→      headers: { \"Content-Type\": \"application/json\" },\n    90→      body: JSON.stringify({ wallet }),\n    91→    });\n    92→\n    93→    expect(res.status).toBe(200);\n    94→    const json = (await res.json()) as { nonce: string; message: string; expiresAt: string };\n    95→    expect(json.nonce).toBeDefined();\n    96→    expect(json.nonce.length).toBe(64); // 32 bytes hex\n    97→    expect(json.message).toContain(\"Sign in to RNG Utopia\");\n    98→    expect(json.message).toContain(wallet);\n    99→    expect(json.message).toContain(\"devnet\");\n   100→    expect(json.expiresAt).toBeDefined();\n   101→  });\n   102→\n   103→  it(\"rejects challenge with missing wallet\", async () => {\n   104→    const res = await app.request(\"/auth/challenge\", {\n   105→      method: \"POST\",\n   106→      headers: { \"Content-Type\": \"application/json\" },\n   107→      body: JSON.stringify({}),\n   108→    });\n   109→    expect(res.status).toBe(400);\n   110→  });\n   111→\n   112→  // -----------------------------------------------------------------------\n   113→  // Full flow: challenge → verify → refresh → logout\n   114→  // -----------------------------------------------------------------------\n   115→\n   116→  it(\"full auth flow: challenge → verify → refresh → logout\", async () => {\n   117→    const wallet = creatorKeypair.publicKey.toBase58();\n   118→\n   119→    // 1. Request challenge\n   120→    const challengeRes = await app.request(\"/auth/challenge\", {\n   121→      method: \"POST\",\n   122→      headers: { \"Content-Type\": \"application/json\" },\n   123→      body: JSON.stringify({ wallet }),\n   124→    });\n   125→    expect(challengeRes.status).toBe(200);\n   126→    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n   127→\n   128→    // 2. Sign the message\n   129→    const messageBytes = new TextEncoder().encode(challenge.message);\n   130→    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n   131→    const signature = bs58.encode(signatureBytes);\n   132→\n   133→    // 3. Verify\n   134→    const verifyRes = await app.request(\"/auth/verify\", {\n   135→      method: \"POST\",\n   136→      headers: { \"Content-Type\": \"application/json\" },\n   137→      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n   138→    });\n   139→    expect(verifyRes.status).toBe(200);\n   140→    const tokens = (await verifyRes.json()) as {\n   141→      accessToken: string;\n   142→      accessExpiresAt: string;\n   143→      refreshToken: string;\n   144→      refreshExpiresAt: string;\n   145→    };\n   146→    expect(tokens.accessToken).toBeDefined();\n   147→    expect(tokens.refreshToken).toBeDefined();\n   148→    expect(tokens.accessExpiresAt).toBeDefined();\n   149→    expect(tokens.refreshExpiresAt).toBeDefined();\n   150→\n   151→    // Verify JWT is valid and contains the correct wallet\n   152→    const { payload } = await jwtVerify(tokens.accessToken, JWT_SECRET, {\n   153→      algorithms: [\"HS256\"],\n   154→    });\n   155→    expect(payload.sub).toBe(wallet);\n   156→\n   157→    // 4. Refresh\n   158→    const refreshRes = await app.request(\"/auth/refresh\", {\n   159→      method: \"POST\",\n   160→      headers: { \"Content-Type\": \"application/json\" },\n   161→      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n   162→    });\n   163→    expect(refreshRes.status).toBe(200);\n   164→    const newTokens = (await refreshRes.json()) as {\n   165→      accessToken: string;\n   166→      refreshToken: string;\n   167→    };\n   168→    expect(newTokens.accessToken).toBeDefined();\n   169→    expect(newTokens.refreshToken).toBeDefined();\n   170→    // New refresh token should be different from the old one\n   171→    expect(newTokens.refreshToken).not.toBe(tokens.refreshToken);\n   172→\n   173→    // 5. Old refresh token should no longer work (it was rotated)\n   174→    const replayRes = await app.request(\"/auth/refresh\", {\n   175→      method: \"POST\",\n   176→      headers: { \"Content-Type\": \"application/json\" },\n   177→      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n   178→    });\n   179→    expect(replayRes.status).toBe(401);\n   180→    const replayJson = (await replayRes.json()) as { error: string };\n   181→    expect(replayJson.error).toContain(\"reuse\");\n   182→\n   183→    // 6. Logout with new token\n   184→    const logoutRes = await app.request(\"/auth/logout\", {\n   185→      method: \"POST\",\n   186→      headers: { \"Content-Type\": \"application/json\" },\n   187→      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n   188→    });\n   189→    expect(logoutRes.status).toBe(204);\n   190→\n   191→    // 7. Refresh after logout should fail\n   192→    const postLogoutRefresh = await app.request(\"/auth/refresh\", {\n   193→      method: \"POST\",\n   194→      headers: { \"Content-Type\": \"application/json\" },\n   195→      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n   196→    });\n   197→    expect(postLogoutRefresh.status).toBe(401);\n   198→  });\n   199→\n   200→  // -----------------------------------------------------------------------\n   201→  // Edge cases\n   202→  // -----------------------------------------------------------------------\n   203→\n   204→  it(\"rejects verify with wrong wallet\", async () => {\n   205→    const wallet = creatorKeypair.publicKey.toBase58();\n   206→    const otherKeypair = Keypair.generate();\n   207→\n   208→    // Get challenge for the correct wallet\n   209→    const challengeRes = await app.request(\"/auth/challenge\", {\n   210→      method: \"POST\",\n   211→      headers: { \"Content-Type\": \"application/json\" },\n   212→      body: JSON.stringify({ wallet }),\n   213→    });\n   214→    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n   215→\n   216→    // Sign with the correct keypair\n   217→    const messageBytes = new TextEncoder().encode(challenge.message);\n   218→    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n   219→    const signature = bs58.encode(signatureBytes);\n   220→\n   221→    // But claim to be a different wallet\n   222→    const verifyRes = await app.request(\"/auth/verify\", {\n   223→      method: \"POST\",\n   224→      headers: { \"Content-Type\": \"application/json\" },\n   225→      body: JSON.stringify({\n   226→        nonce: challenge.nonce,\n   227→        wallet: otherKeypair.publicKey.toBase58(),\n   228→        signature,\n   229→      }),\n   230→    });\n   231→    expect(verifyRes.status).toBe(401);\n   232→  });\n   233→\n   234→  it(\"rejects verify with wrong signature\", async () => {\n   235→    const wallet = creatorKeypair.publicKey.toBase58();\n   236→    const otherKeypair = Keypair.generate();\n   237→\n   238→    const challengeRes = await app.request(\"/auth/challenge\", {\n   239→      method: \"POST\",\n   240→      headers: { \"Content-Type\": \"application/json\" },\n   241→      body: JSON.stringify({ wallet }),\n   242→    });\n   243→    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n   244→\n   245→    // Sign with wrong keypair\n   246→    const messageBytes = new TextEncoder().encode(challenge.message);\n   247→    const signatureBytes = nacl.sign.detached(messageBytes, otherKeypair.secretKey);\n   248→    const signature = bs58.encode(signatureBytes);\n   249→\n   250→    const verifyRes = await app.request(\"/auth/verify\", {\n   251→      method: \"POST\",\n   252→      headers: { \"Content-Type\": \"application/json\" },\n   253→      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n   254→    });\n   255→    expect(verifyRes.status).toBe(401);\n   256→  });\n   257→\n   258→  it(\"rejects verify with already-used nonce\", async () => {\n   259→    const wallet = creatorKeypair.publicKey.toBase58();\n   260→\n   261→    // Get and consume a challenge\n   262→    const challengeRes = await app.request(\"/auth/challenge\", {\n   263→      method: \"POST\",\n   264→      headers: { \"Content-Type\": \"application/json\" },\n   265→      body: JSON.stringify({ wallet }),\n   266→    });\n   267→    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n   268→    const messageBytes = new TextEncoder().encode(challenge.message);\n   269→    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n   270→    const signature = bs58.encode(signatureBytes);\n   271→\n   272→    // First verify — should succeed\n   273→    const res1 = await app.request(\"/auth/verify\", {\n   274→      method: \"POST\",\n   275→      headers: { \"Content-Type\": \"application/json\" },\n   276→      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n   277→    });\n   278→    expect(res1.status).toBe(200);\n   279→\n   280→    // Second verify with same nonce — should fail\n   281→    const res2 = await app.request(\"/auth/verify\", {\n   282→      method: \"POST\",\n   283→      headers: { \"Content-Type\": \"application/json\" },\n   284→      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n   285→    });\n   286→    expect(res2.status).toBe(401);\n   287→  });\n   288→\n   289→  it(\"rejects refresh with invalid token\", async () => {\n   290→    const res = await app.request(\"/auth/refresh\", {\n   291→      method: \"POST\",\n   292→      headers: { \"Content-Type\": \"application/json\" },\n   293→      body: JSON.stringify({ refreshToken: \"not-a-real-token\" }),\n   294→    });\n   295→    expect(res.status).toBe(401);\n   296→  });\n   297→});\n   298→"}]},"parent_tool_use_id":null,"session_id":"aa0285d4-bc35-4024-8afc-77d99fd4e541","uuid":"779ef04d-be2f-44d5-8c63-80b6163d670e","timestamp":"2026-03-25T13:45:54.019Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/auth-routes.test.ts","content":"/**\n * Auth routes tests: challenge → verify → refresh → logout flows.\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport nacl from \"tweetnacl\";\nimport bs58 from \"bs58\";\nimport { jwtVerify } from \"jose\";\nimport postgres from \"postgres\";\nimport { createAuthDb, type AuthDb } from \"../auth-db.js\";\nimport { createAuthRoutes } from \"../routes/auth.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-auth-route-tests\");\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"Auth routes: challenge → verify → refresh → logout\", () => {\n  let rawSql: ReturnType<typeof postgres>;\n  let authDb: AuthDb;\n  let app: Hono;\n\n  const creatorKeypair = Keypair.generate();\n\n  beforeAll(async () => {\n    rawSql = postgres(DATABASE_URL);\n    // Ensure auth tables exist\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS auth_challenges (\n        nonce TEXT PRIMARY KEY,\n        wallet TEXT NOT NULL,\n        cluster TEXT NOT NULL DEFAULT 'devnet',\n        message TEXT NOT NULL,\n        expires_at TIMESTAMPTZ NOT NULL,\n        used BOOLEAN DEFAULT FALSE,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n    await rawSql`\n      CREATE TABLE IF NOT EXISTS refresh_tokens (\n        id BIGSERIAL PRIMARY KEY,\n        wallet TEXT NOT NULL,\n        token_hash BYTEA NOT NULL UNIQUE,\n        family_id TEXT NOT NULL,\n        expires_at TIMESTAMPTZ NOT NULL,\n        revoked BOOLEAN DEFAULT FALSE,\n        created_at TIMESTAMPTZ DEFAULT now()\n      )\n    `;\n  });\n\n  afterAll(async () => {\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE auth_challenges, refresh_tokens RESTART IDENTITY`;\n    authDb = createAuthDb(rawSql);\n    app = new Hono();\n    app.route(\n      \"/auth\",\n      createAuthRoutes({\n        authDb,\n        jwtSecret: JWT_SECRET,\n        cluster: \"devnet\",\n        challengeTtlSeconds: 300,\n        accessTokenTtlSeconds: 3600,\n        refreshTokenTtlDays: 14,\n      }),\n    );\n  });\n\n  // -----------------------------------------------------------------------\n  // POST /auth/challenge\n  // -----------------------------------------------------------------------\n\n  it(\"returns a challenge with nonce and message\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const res = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n\n    expect(res.status).toBe(200);\n    const json = (await res.json()) as { nonce: string; message: string; expiresAt: string };\n    expect(json.nonce).toBeDefined();\n    expect(json.nonce.length).toBe(64); // 32 bytes hex\n    expect(json.message).toContain(\"Sign in to RNG Utopia\");\n    expect(json.message).toContain(wallet);\n    expect(json.message).toContain(\"devnet\");\n    expect(json.expiresAt).toBeDefined();\n  });\n\n  it(\"rejects challenge with missing wallet\", async () => {\n    const res = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({}),\n    });\n    expect(res.status).toBe(400);\n  });\n\n  // -----------------------------------------------------------------------\n  // Full flow: challenge → verify → refresh → logout\n  // -----------------------------------------------------------------------\n\n  it(\"full auth flow: challenge → verify → refresh → logout\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n\n    // 1. Request challenge\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    expect(challengeRes.status).toBe(200);\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n\n    // 2. Sign the message\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    // 3. Verify\n    const verifyRes = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(verifyRes.status).toBe(200);\n    const tokens = (await verifyRes.json()) as {\n      accessToken: string;\n      accessExpiresAt: string;\n      refreshToken: string;\n      refreshExpiresAt: string;\n    };\n    expect(tokens.accessToken).toBeDefined();\n    expect(tokens.refreshToken).toBeDefined();\n    expect(tokens.accessExpiresAt).toBeDefined();\n    expect(tokens.refreshExpiresAt).toBeDefined();\n\n    // Verify JWT is valid and contains the correct wallet\n    const { payload } = await jwtVerify(tokens.accessToken, JWT_SECRET, {\n      algorithms: [\"HS256\"],\n    });\n    expect(payload.sub).toBe(wallet);\n\n    // 4. Refresh\n    const refreshRes = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n    });\n    expect(refreshRes.status).toBe(200);\n    const newTokens = (await refreshRes.json()) as {\n      accessToken: string;\n      refreshToken: string;\n    };\n    expect(newTokens.accessToken).toBeDefined();\n    expect(newTokens.refreshToken).toBeDefined();\n    // New refresh token should be different from the old one\n    expect(newTokens.refreshToken).not.toBe(tokens.refreshToken);\n\n    // 5. Old refresh token should no longer work (it was rotated)\n    const replayRes = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: tokens.refreshToken }),\n    });\n    expect(replayRes.status).toBe(401);\n    const replayJson = (await replayRes.json()) as { error: string };\n    expect(replayJson.error).toContain(\"reuse\");\n\n    // 6. Logout with new token\n    const logoutRes = await app.request(\"/auth/logout\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n    });\n    expect(logoutRes.status).toBe(204);\n\n    // 7. Refresh after logout should fail\n    const postLogoutRefresh = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n    });\n    expect(postLogoutRefresh.status).toBe(401);\n  });\n\n  // -----------------------------------------------------------------------\n  // Edge cases\n  // -----------------------------------------------------------------------\n\n  it(\"rejects verify with wrong wallet\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const otherKeypair = Keypair.generate();\n\n    // Get challenge for the correct wallet\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n\n    // Sign with the correct keypair\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    // But claim to be a different wallet\n    const verifyRes = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({\n        nonce: challenge.nonce,\n        wallet: otherKeypair.publicKey.toBase58(),\n        signature,\n      }),\n    });\n    expect(verifyRes.status).toBe(401);\n  });\n\n  it(\"rejects verify with wrong signature\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n    const otherKeypair = Keypair.generate();\n\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n\n    // Sign with wrong keypair\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, otherKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    const verifyRes = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(verifyRes.status).toBe(401);\n  });\n\n  it(\"rejects verify with already-used nonce\", async () => {\n    const wallet = creatorKeypair.publicKey.toBase58();\n\n    // Get and consume a challenge\n    const challengeRes = await app.request(\"/auth/challenge\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ wallet }),\n    });\n    const challenge = (await challengeRes.json()) as { nonce: string; message: string };\n    const messageBytes = new TextEncoder().encode(challenge.message);\n    const signatureBytes = nacl.sign.detached(messageBytes, creatorKeypair.secretKey);\n    const signature = bs58.encode(signatureBytes);\n\n    // First verify — should succeed\n    const res1 = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(res1.status).toBe(200);\n\n    // Second verify with same nonce — should fail\n    const res2 = await app.request(\"/auth/verify\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ nonce: challenge.nonce, wallet, signature }),\n    });\n    expect(res2.status).toBe(401);\n  });\n\n  it(\"rejects refresh with invalid token\", async () => {\n    const res = await app.request(\"/auth/refresh\", {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: \"not-a-real-token\" }),\n    });\n    expect(res.status).toBe(401);\n  });\n});\n","numLines":298,"startLine":1,"totalLines":298}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011Rbz2TYahNryGu3sLhFCrd","type":"tool_result","content":"     1→/**\n     2→ * Referral routes — code management, linking, stats, earnings, and claims.\n     3→ */\n     4→\n     5→import { Hono } from \"hono\";\n     6→import type postgres from \"postgres\";\n     7→import type { AppEnv } from \"../hono-env.js\";\n     8→import type { Db } from \"../db.js\";\n     9→import type { Config } from \"../config.js\";\n    10→import { logger } from \"../logger.js\";\n    11→import { emitEvent } from \"../queue/emit-event.js\";\n    12→import { EventTypes } from \"../queue/event-types.js\";\n    13→\n    14→export interface ReferralRoutesDeps {\n    15→  db: Db;\n    16→  sql: postgres.Sql;\n    17→  config: Config;\n    18→}\n    19→\n    20→/** Referral code validation: 3-16 chars, lowercase alphanumeric + hyphens */\n    21→const CODE_REGEX = /^[a-z0-9-]{3,16}$/;\n    22→\n    23→const REFERRAL_BASE_URL = \"https://taunt.bet/r\";\n    24→\n    25→export function createReferralRoutes(deps: ReferralRoutesDeps) {\n    26→  const { db, sql, config } = deps;\n    27→  const app = new Hono<AppEnv>();\n    28→\n    29→  // POST /code — set or replace the player's referral code\n    30→  app.post(\"/code\", async (c) => {\n    31→    const wallet = c.get(\"wallet\");\n    32→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n    33→\n    34→    let body: { code?: unknown };\n    35→    try {\n    36→      body = await c.req.json();\n    37→    } catch {\n    38→      return c.json({ error: \"Invalid request body\" }, 400);\n    39→    }\n    40→\n    41→    const code = typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n    42→\n    43→    if (!CODE_REGEX.test(code)) {\n    44→      return c.json(\n    45→        {\n    46→          error: {\n    47→            code: \"INVALID_CODE\",\n    48→            message:\n    49→              \"Code must be 3-16 characters, lowercase letters, numbers, and hyphens only\",\n    50→          },\n    51→        },\n    52→        400,\n    53→      );\n    54→    }\n    55→\n    56→    // Check if this code is already taken by another wallet\n    57→    const existing = await db.getReferralCodeByCode(code);\n    58→    if (existing && existing.wallet !== wallet) {\n    59→      return c.json(\n    60→        {\n    61→          error: {\n    62→            code: \"CODE_TAKEN\",\n    63→            message: \"This referral code is already in use\",\n    64→            retryable: false,\n    65→          },\n    66→        },\n    67→        409,\n    68→      );\n    69→    }\n    70→\n    71→    try {\n    72→      const result = await db.upsertReferralCode(wallet, code);\n    73→      logger.info(\"Referral code set\", { wallet, code: result.code });\n    74→      return c.json({\n    75→        code: result.code,\n    76→        url: `${REFERRAL_BASE_URL}/${result.code}`,\n    77→      });\n    78→    } catch (err) {\n    79→      // Handle race condition: another wallet grabbed the code between check and insert\n    80→      const msg = err instanceof Error ? err.message : String(err);\n    81→      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n    82→        return c.json(\n    83→          {\n    84→            error: {\n    85→              code: \"CODE_TAKEN\",\n    86→              message: \"This referral code is already in use\",\n    87→              retryable: false,\n    88→            },\n    89→          },\n    90→          409,\n    91→        );\n    92→      }\n    93→      logger.error(\"Failed to set referral code\", { err: String(err), wallet });\n    94→      return c.json({ error: \"Failed to set referral code\" }, 500);\n    95→    }\n    96→  });\n    97→\n    98→  // POST /apply — link the authenticated player to a referrer via their code\n    99→  app.post(\"/apply\", async (c) => {\n   100→    const wallet = c.get(\"wallet\");\n   101→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   102→\n   103→    let body: { code?: unknown };\n   104→    try {\n   105→      body = await c.req.json();\n   106→    } catch {\n   107→      return c.json(\n   108→        {\n   109→          error: {\n   110→            code: \"INVALID_BODY\",\n   111→            message: \"Invalid request body\",\n   112→          },\n   113→        },\n   114→        400,\n   115→      );\n   116→    }\n   117→\n   118→    const code =\n   119→      typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n   120→\n   121→    if (!code) {\n   122→      return c.json(\n   123→        {\n   124→          error: {\n   125→            code: \"INVALID_CODE\",\n   126→            message: \"Referral code is required\",\n   127→          },\n   128→        },\n   129→        400,\n   130→      );\n   131→    }\n   132→\n   133→    // Look up the referral code to find the referrer\n   134→    const codeRow = await db.getReferralCodeByCode(code);\n   135→    if (!codeRow) {\n   136→      return c.json(\n   137→        {\n   138→          error: {\n   139→            code: \"CODE_NOT_FOUND\",\n   140→            message: \"Referral code does not exist\",\n   141→            retryable: false,\n   142→          },\n   143→        },\n   144→        404,\n   145→      );\n   146→    }\n   147→\n   148→    // Self-referral check\n   149→    if (codeRow.wallet === wallet) {\n   150→      return c.json(\n   151→        {\n   152→          error: {\n   153→            code: \"SELF_REFERRAL\",\n   154→            message: \"You cannot use your own referral code\",\n   155→            retryable: false,\n   156→          },\n   157→        },\n   158→        400,\n   159→      );\n   160→    }\n   161→\n   162→    // Check if the player already has a referrer\n   163→    const existingLink = await db.getReferralLinkByReferee(wallet);\n   164→    if (existingLink) {\n   165→      return c.json(\n   166→        {\n   167→          error: {\n   168→            code: \"ALREADY_LINKED\",\n   169→            message: \"You are already linked to a referrer\",\n   170→            retryable: false,\n   171→          },\n   172→        },\n   173→        409,\n   174→      );\n   175→    }\n   176→\n   177→    try {\n   178→      await db.insertReferralLink(codeRow.wallet, wallet);\n   179→      logger.info(\"Referral link created\", {\n   180→        referrer: codeRow.wallet,\n   181→        referee: wallet,\n   182→        code,\n   183→      });\n   184→      return c.json({\n   185→        referrer: codeRow.wallet,\n   186→        benefit: \"10% fee rebate on all games\",\n   187→      });\n   188→    } catch (err) {\n   189→      // Handle race condition: another request linked this referee between check and insert\n   190→      const msg = err instanceof Error ? err.message : String(err);\n   191→      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n   192→        return c.json(\n   193→          {\n   194→            error: {\n   195→              code: \"ALREADY_LINKED\",\n   196→              message: \"You are already linked to a referrer\",\n   197→              retryable: false,\n   198→            },\n   199→          },\n   200→          409,\n   201→        );\n   202→      }\n   203→      logger.error(\"Failed to create referral link\", {\n   204→        err: String(err),\n   205→        wallet,\n   206→        code,\n   207→      });\n   208→      return c.json({ error: \"Failed to apply referral code\" }, 500);\n   209→    }\n   210→  });\n   211→\n   212→  // GET /code — return the authenticated player's current referral code\n   213→  app.get(\"/code\", async (c) => {\n   214→    const wallet = c.get(\"wallet\");\n   215→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   216→\n   217→    const row = await db.getReferralCodeByWallet(wallet);\n   218→    if (!row) {\n   219→      return c.json(\n   220→        {\n   221→          error: {\n   222→            code: \"NO_CODE\",\n   223→            message: \"No referral code set for this wallet\",\n   224→          },\n   225→        },\n   226→        404,\n   227→      );\n   228→    }\n   229→\n   230→    return c.json({\n   231→      code: row.code,\n   232→      url: `${REFERRAL_BASE_URL}/${row.code}`,\n   233→    });\n   234→  });\n   235→\n   236→  // GET /referrer — check if the authenticated player has a referrer\n   237→  app.get(\"/referrer\", async (c) => {\n   238→    const wallet = c.get(\"wallet\");\n   239→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   240→\n   241→    try {\n   242→      const link = await db.getReferralLinkByReferee(wallet);\n   243→      if (!link) {\n   244→        return c.json(\n   245→          {\n   246→            error: {\n   247→              code: \"NO_REFERRER\",\n   248→              message: \"You are not linked to a referrer\",\n   249→            },\n   250→          },\n   251→          404,\n   252→        );\n   253→      }\n   254→\n   255→      return c.json({\n   256→        referrerWallet: link.referrer_wallet,\n   257→        linkedAt: link.created_at.toISOString(),\n   258→      });\n   259→    } catch (err) {\n   260→      logger.error(\"Failed to fetch referrer\", {\n   261→        err: String(err),\n   262→        wallet,\n   263→      });\n   264→      return c.json({ error: \"Failed to fetch referrer\" }, 500);\n   265→    }\n   266→  });\n   267→\n   268→  // GET /stats — referral summary stats for authenticated wallet\n   269→  app.get(\"/stats\", async (c) => {\n   270→    const wallet = c.get(\"wallet\");\n   271→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   272→\n   273→    try {\n   274→      const stats = await db.getReferralStats(wallet);\n   275→      return c.json({\n   276→        referredCount: stats.referred_count,\n   277→        activeCount: stats.active_count,\n   278→        totalVolumeLamports: stats.total_volume_lamports,\n   279→        totalEarnedLamports: stats.total_earned_lamports,\n   280→        totalRebateLamports: stats.total_rebate_lamports,\n   281→        pendingLamports: stats.pending_lamports,\n   282→      });\n   283→    } catch (err) {\n   284→      logger.error(\"Failed to fetch referral stats\", {\n   285→        err: String(err),\n   286→        wallet,\n   287→      });\n   288→      return c.json({ error: \"Failed to fetch referral stats\" }, 500);\n   289→    }\n   290→  });\n   291→\n   292→  // GET /earnings — paginated per-game earnings log\n   293→  app.get(\"/earnings\", async (c) => {\n   294→    const wallet = c.get(\"wallet\");\n   295→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   296→\n   297→    const pageParam = c.req.query(\"page\");\n   298→    const limitParam = c.req.query(\"limit\");\n   299→    const page = pageParam ? Math.max(1, Math.floor(Number(pageParam))) : 1;\n   300→    const limit = limitParam\n   301→      ? Math.min(100, Math.max(1, Math.floor(Number(limitParam))))\n   302→      : 20;\n   303→\n   304→    if (Number.isNaN(page) || Number.isNaN(limit)) {\n   305→      return c.json(\n   306→        {\n   307→          error: {\n   308→            code: \"INVALID_PARAMS\",\n   309→            message: \"page and limit must be positive integers\",\n   310→          },\n   311→        },\n   312→        400,\n   313→      );\n   314→    }\n   315→\n   316→    try {\n   317→      const result = await db.getReferralEarnings(wallet, page, limit);\n   318→      return c.json({\n   319→        items: result.items.map((e) => ({\n   320→          roundId: e.round_id,\n   321→          gameType: e.game_type,\n   322→          refereeWallet: e.referee_wallet,\n   323→          wagerLamports: String(e.wager_lamports),\n   324→          earnedLamports: String(e.referrer_earned_lamports),\n   325→          createdAt: e.created_at.toISOString(),\n   326→        })),\n   327→        pagination: {\n   328→          page,\n   329→          totalPages: result.totalPages,\n   330→        },\n   331→      });\n   332→    } catch (err) {\n   333→      logger.error(\"Failed to fetch referral earnings\", {\n   334→        err: String(err),\n   335→        wallet,\n   336→      });\n   337→      return c.json({ error: \"Failed to fetch referral earnings\" }, 500);\n   338→    }\n   339→  });\n   340→\n   341→  // POST /claim — request payout of pending referral earnings (async via queue)\n   342→  app.post(\"/claim\", async (c) => {\n   343→    const wallet = c.get(\"wallet\");\n   344→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   345→\n   346→    try {\n   347→      // Snapshot pending balance\n   348→      const pendingStr = await db.getPendingBalance(wallet);\n   349→      const pendingLamports = BigInt(pendingStr);\n   350→\n   351→      if (pendingLamports <= 0n) {\n   352→        return c.json(\n   353→          {\n   354→            error: {\n   355→              code: \"ZERO_BALANCE\",\n   356→              message: \"No pending earnings to claim\",\n   357→              retryable: false,\n   358→            },\n   359→          },\n   360→          400,\n   361→        );\n   362→      }\n   363→\n   364→      if (pendingLamports < BigInt(config.referralMinClaimLamports)) {\n   365→        return c.json(\n   366→          {\n   367→            error: {\n   368→              code: \"BELOW_THRESHOLD\",\n   369→              message: `Minimum claim amount is ${config.referralMinClaimLamports} lamports (${(config.referralMinClaimLamports / 1e9).toFixed(2)} SOL)`,\n   370→              retryable: false,\n   371→            },\n   372→          },\n   373→          400,\n   374→        );\n   375→      }\n   376→\n   377→      // Atomically insert claim row + emit queue event\n   378→      const claim = await sql.begin(async (tx) => {\n   379→        const rows = await (tx as unknown as postgres.Sql)<\n   380→          {\n   381→            id: string;\n   382→            wallet: string;\n   383→            amount_lamports: string;\n   384→            status: string;\n   385→          }[]\n   386→        >`\n   387→          INSERT INTO referral_claims (wallet, amount_lamports, status)\n   388→          VALUES (${wallet}, ${pendingStr}, 'pending')\n   389→          RETURNING id, wallet, amount_lamports, status\n   390→        `;\n   391→        const row = rows[0]!;\n   392→\n   393→        await emitEvent(\n   394→          tx as unknown as postgres.Sql,\n   395→          EventTypes.REFERRAL_CLAIM_REQUESTED,\n   396→          {\n   397→            claimId: row.id,\n   398→            wallet: row.wallet,\n   399→            amountLamports: row.amount_lamports,\n   400→            requestedAt: new Date().toISOString(),\n   401→          },\n   402→        );\n   403→\n   404→        return row;\n   405→      });\n   406→\n   407→      logger.info(\"Referral claim requested\", {\n   408→        wallet,\n   409→        claimId: claim.id,\n   410→        amountLamports: claim.amount_lamports,\n   411→      });\n   412→\n   413→      return c.json(\n   414→        {\n   415→          claimId: claim.id,\n   416→          amountLamports: claim.amount_lamports,\n   417→          status: \"pending\",\n   418→        },\n   419→        202,\n   420→      );\n   421→    } catch (err) {\n   422→      logger.error(\"Failed to create referral claim\", {\n   423→        err: String(err),\n   424→        wallet,\n   425→      });\n   426→      return c.json({ error: \"Failed to create referral claim\" }, 500);\n   427→    }\n   428→  });\n   429→\n   430→  // GET /claim/:claimId — poll claim status\n   431→  app.get(\"/claim/:claimId\", async (c) => {\n   432→    const wallet = c.get(\"wallet\");\n   433→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   434→\n   435→    const claimId = c.req.param(\"claimId\");\n   436→\n   437→    try {\n   438→      const claim = await db.getReferralClaim(claimId);\n   439→      if (!claim) {\n   440→        return c.json(\n   441→          {\n   442→            error: {\n   443→              code: \"CLAIM_NOT_FOUND\",\n   444→              message: \"Claim not found\",\n   445→            },\n   446→          },\n   447→          404,\n   448→        );\n   449→      }\n   450→\n   451→      // Only allow the claim owner to view their claim\n   452→      if (claim.wallet !== wallet) {\n   453→        return c.json(\n   454→          {\n   455→            error: {\n   456→              code: \"CLAIM_NOT_FOUND\",\n   457→              message: \"Claim not found\",\n   458→            },\n   459→          },\n   460→          404,\n   461→        );\n   462→      }\n   463→\n   464→      return c.json({\n   465→        claimId: claim.id,\n   466→        amountLamports: String(claim.amount_lamports),\n   467→        status: claim.status,\n   468→        ...(claim.tx_signature ? { txSignature: claim.tx_signature } : {}),\n   469→      });\n   470→    } catch (err) {\n   471→      logger.error(\"Failed to fetch referral claim\", {\n   472→        err: String(err),\n   473→        wallet,\n   474→        claimId,\n   475→      });\n   476→      return c.json({ error: \"Failed to fetch referral claim\" }, 500);\n   477→    }\n   478→  });\n   479→\n   480→  return app;\n   481→}\n   482→"}]},"parent_tool_use_id":null,"session_id":"aa0285d4-bc35-4024-8afc-77d99fd4e541","uuid":"9e54b9fe-77b3-4f0d-84c0-6edfbf7b9458","timestamp":"2026-03-25T13:45:54.219Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/referral.ts","content":"/**\n * Referral routes — code management, linking, stats, earnings, and claims.\n */\n\nimport { Hono } from \"hono\";\nimport type postgres from \"postgres\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport type { Config } from \"../config.js\";\nimport { logger } from \"../logger.js\";\nimport { emitEvent } from \"../queue/emit-event.js\";\nimport { EventTypes } from \"../queue/event-types.js\";\n\nexport interface ReferralRoutesDeps {\n  db: Db;\n  sql: postgres.Sql;\n  config: Config;\n}\n\n/** Referral code validation: 3-16 chars, lowercase alphanumeric + hyphens */\nconst CODE_REGEX = /^[a-z0-9-]{3,16}$/;\n\nconst REFERRAL_BASE_URL = \"https://taunt.bet/r\";\n\nexport function createReferralRoutes(deps: ReferralRoutesDeps) {\n  const { db, sql, config } = deps;\n  const app = new Hono<AppEnv>();\n\n  // POST /code — set or replace the player's referral code\n  app.post(\"/code\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    let body: { code?: unknown };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json({ error: \"Invalid request body\" }, 400);\n    }\n\n    const code = typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n\n    if (!CODE_REGEX.test(code)) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_CODE\",\n            message:\n              \"Code must be 3-16 characters, lowercase letters, numbers, and hyphens only\",\n          },\n        },\n        400,\n      );\n    }\n\n    // Check if this code is already taken by another wallet\n    const existing = await db.getReferralCodeByCode(code);\n    if (existing && existing.wallet !== wallet) {\n      return c.json(\n        {\n          error: {\n            code: \"CODE_TAKEN\",\n            message: \"This referral code is already in use\",\n            retryable: false,\n          },\n        },\n        409,\n      );\n    }\n\n    try {\n      const result = await db.upsertReferralCode(wallet, code);\n      logger.info(\"Referral code set\", { wallet, code: result.code });\n      return c.json({\n        code: result.code,\n        url: `${REFERRAL_BASE_URL}/${result.code}`,\n      });\n    } catch (err) {\n      // Handle race condition: another wallet grabbed the code between check and insert\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return c.json(\n          {\n            error: {\n              code: \"CODE_TAKEN\",\n              message: \"This referral code is already in use\",\n              retryable: false,\n            },\n          },\n          409,\n        );\n      }\n      logger.error(\"Failed to set referral code\", { err: String(err), wallet });\n      return c.json({ error: \"Failed to set referral code\" }, 500);\n    }\n  });\n\n  // POST /apply — link the authenticated player to a referrer via their code\n  app.post(\"/apply\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    let body: { code?: unknown };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_BODY\",\n            message: \"Invalid request body\",\n          },\n        },\n        400,\n      );\n    }\n\n    const code =\n      typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n\n    if (!code) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_CODE\",\n            message: \"Referral code is required\",\n          },\n        },\n        400,\n      );\n    }\n\n    // Look up the referral code to find the referrer\n    const codeRow = await db.getReferralCodeByCode(code);\n    if (!codeRow) {\n      return c.json(\n        {\n          error: {\n            code: \"CODE_NOT_FOUND\",\n            message: \"Referral code does not exist\",\n            retryable: false,\n          },\n        },\n        404,\n      );\n    }\n\n    // Self-referral check\n    if (codeRow.wallet === wallet) {\n      return c.json(\n        {\n          error: {\n            code: \"SELF_REFERRAL\",\n            message: \"You cannot use your own referral code\",\n            retryable: false,\n          },\n        },\n        400,\n      );\n    }\n\n    // Check if the player already has a referrer\n    const existingLink = await db.getReferralLinkByReferee(wallet);\n    if (existingLink) {\n      return c.json(\n        {\n          error: {\n            code: \"ALREADY_LINKED\",\n            message: \"You are already linked to a referrer\",\n            retryable: false,\n          },\n        },\n        409,\n      );\n    }\n\n    try {\n      await db.insertReferralLink(codeRow.wallet, wallet);\n      logger.info(\"Referral link created\", {\n        referrer: codeRow.wallet,\n        referee: wallet,\n        code,\n      });\n      return c.json({\n        referrer: codeRow.wallet,\n        benefit: \"10% fee rebate on all games\",\n      });\n    } catch (err) {\n      // Handle race condition: another request linked this referee between check and insert\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return c.json(\n          {\n            error: {\n              code: \"ALREADY_LINKED\",\n              message: \"You are already linked to a referrer\",\n              retryable: false,\n            },\n          },\n          409,\n        );\n      }\n      logger.error(\"Failed to create referral link\", {\n        err: String(err),\n        wallet,\n        code,\n      });\n      return c.json({ error: \"Failed to apply referral code\" }, 500);\n    }\n  });\n\n  // GET /code — return the authenticated player's current referral code\n  app.get(\"/code\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    const row = await db.getReferralCodeByWallet(wallet);\n    if (!row) {\n      return c.json(\n        {\n          error: {\n            code: \"NO_CODE\",\n            message: \"No referral code set for this wallet\",\n          },\n        },\n        404,\n      );\n    }\n\n    return c.json({\n      code: row.code,\n      url: `${REFERRAL_BASE_URL}/${row.code}`,\n    });\n  });\n\n  // GET /referrer — check if the authenticated player has a referrer\n  app.get(\"/referrer\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    try {\n      const link = await db.getReferralLinkByReferee(wallet);\n      if (!link) {\n        return c.json(\n          {\n            error: {\n              code: \"NO_REFERRER\",\n              message: \"You are not linked to a referrer\",\n            },\n          },\n          404,\n        );\n      }\n\n      return c.json({\n        referrerWallet: link.referrer_wallet,\n        linkedAt: link.created_at.toISOString(),\n      });\n    } catch (err) {\n      logger.error(\"Failed to fetch referrer\", {\n        err: String(err),\n        wallet,\n      });\n      return c.json({ error: \"Failed to fetch referrer\" }, 500);\n    }\n  });\n\n  // GET /stats — referral summary stats for authenticated wallet\n  app.get(\"/stats\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    try {\n      const stats = await db.getReferralStats(wallet);\n      return c.json({\n        referredCount: stats.referred_count,\n        activeCount: stats.active_count,\n        totalVolumeLamports: stats.total_volume_lamports,\n        totalEarnedLamports: stats.total_earned_lamports,\n        totalRebateLamports: stats.total_rebate_lamports,\n        pendingLamports: stats.pending_lamports,\n      });\n    } catch (err) {\n      logger.error(\"Failed to fetch referral stats\", {\n        err: String(err),\n        wallet,\n      });\n      return c.json({ error: \"Failed to fetch referral stats\" }, 500);\n    }\n  });\n\n  // GET /earnings — paginated per-game earnings log\n  app.get(\"/earnings\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    const pageParam = c.req.query(\"page\");\n    const limitParam = c.req.query(\"limit\");\n    const page = pageParam ? Math.max(1, Math.floor(Number(pageParam))) : 1;\n    const limit = limitParam\n      ? Math.min(100, Math.max(1, Math.floor(Number(limitParam))))\n      : 20;\n\n    if (Number.isNaN(page) || Number.isNaN(limit)) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_PARAMS\",\n            message: \"page and limit must be positive integers\",\n          },\n        },\n        400,\n      );\n    }\n\n    try {\n      const result = await db.getReferralEarnings(wallet, page, limit);\n      return c.json({\n        items: result.items.map((e) => ({\n          roundId: e.round_id,\n          gameType: e.game_type,\n          refereeWallet: e.referee_wallet,\n          wagerLamports: String(e.wager_lamports),\n          earnedLamports: String(e.referrer_earned_lamports),\n          createdAt: e.created_at.toISOString(),\n        })),\n        pagination: {\n          page,\n          totalPages: result.totalPages,\n        },\n      });\n    } catch (err) {\n      logger.error(\"Failed to fetch referral earnings\", {\n        err: String(err),\n        wallet,\n      });\n      return c.json({ error: \"Failed to fetch referral earnings\" }, 500);\n    }\n  });\n\n  // POST /claim — request payout of pending referral earnings (async via queue)\n  app.post(\"/claim\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    try {\n      // Snapshot pending balance\n      const pendingStr = await db.getPendingBalance(wallet);\n      const pendingLamports = BigInt(pendingStr);\n\n      if (pendingLamports <= 0n) {\n        return c.json(\n          {\n            error: {\n              code: \"ZERO_BALANCE\",\n              message: \"No pending earnings to claim\",\n              retryable: false,\n            },\n          },\n          400,\n        );\n      }\n\n      if (pendingLamports < BigInt(config.referralMinClaimLamports)) {\n        return c.json(\n          {\n            error: {\n              code: \"BELOW_THRESHOLD\",\n              message: `Minimum claim amount is ${config.referralMinClaimLamports} lamports (${(config.referralMinClaimLamports / 1e9).toFixed(2)} SOL)`,\n              retryable: false,\n            },\n          },\n          400,\n        );\n      }\n\n      // Atomically insert claim row + emit queue event\n      const claim = await sql.begin(async (tx) => {\n        const rows = await (tx as unknown as postgres.Sql)<\n          {\n            id: string;\n            wallet: string;\n            amount_lamports: string;\n            status: string;\n          }[]\n        >`\n          INSERT INTO referral_claims (wallet, amount_lamports, status)\n          VALUES (${wallet}, ${pendingStr}, 'pending')\n          RETURNING id, wallet, amount_lamports, status\n        `;\n        const row = rows[0]!;\n\n        await emitEvent(\n          tx as unknown as postgres.Sql,\n          EventTypes.REFERRAL_CLAIM_REQUESTED,\n          {\n            claimId: row.id,\n            wallet: row.wallet,\n            amountLamports: row.amount_lamports,\n            requestedAt: new Date().toISOString(),\n          },\n        );\n\n        return row;\n      });\n\n      logger.info(\"Referral claim requested\", {\n        wallet,\n        claimId: claim.id,\n        amountLamports: claim.amount_lamports,\n      });\n\n      return c.json(\n        {\n          claimId: claim.id,\n          amountLamports: claim.amount_lamports,\n          status: \"pending\",\n        },\n        202,\n      );\n    } catch (err) {\n      logger.error(\"Failed to create referral claim\", {\n        err: String(err),\n        wallet,\n      });\n      return c.json({ error: \"Failed to create referral claim\" }, 500);\n    }\n  });\n\n  // GET /claim/:claimId — poll claim status\n  app.get(\"/claim/:claimId\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    const claimId = c.req.param(\"claimId\");\n\n    try {\n      const claim = await db.getReferralClaim(claimId);\n      if (!claim) {\n        return c.json(\n          {\n            error: {\n              code: \"CLAIM_NOT_FOUND\",\n              message: \"Claim not found\",\n            },\n          },\n          404,\n        );\n      }\n\n      // Only allow the claim owner to view their claim\n      if (claim.wallet !== wallet) {\n        return c.json(\n          {\n            error: {\n              code: \"CLAIM_NOT_FOUND\",\n              message: \"Claim not found\",\n            },\n          },\n          404,\n        );\n      }\n\n      return c.json({\n        claimId: claim.id,\n        amountLamports: String(claim.amount_lamports),\n        status: claim.status,\n        ...(claim.tx_signature ? { txSignature: claim.tx_signature } : {}),\n      });\n    } catch (err) {\n      logger.error(\"Failed to fetch referral claim\", {\n        err: String(err),\n        wallet,\n        claimId,\n      });\n      return c.json({ error: \"Failed to fetch referral claim\" }, 500);\n    }\n  });\n\n  return app;\n}\n","numLines":482,"startLine":1,"totalLines":482}}}
