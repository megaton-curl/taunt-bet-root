[a-z0-9-]\n   241→  created_at    TIMESTAMPTZ DEFAULT now(),\n   242→  updated_at    TIMESTAMPTZ DEFAULT now()\n   243→)\n   244→\n   245→referral_links (\n   246→  id              SERIAL PRIMARY KEY,\n   247→  referrer_wallet TEXT NOT NULL,\n   248→  referee_wallet  TEXT NOT NULL UNIQUE,  -- one referrer per player\n   249→  created_at      TIMESTAMPTZ DEFAULT now()\n   250→)\n   251→\n   252→referral_earnings (\n   253→  id                        SERIAL PRIMARY KEY,\n   254→  referrer_wallet           TEXT NOT NULL,\n   255→  referee_wallet            TEXT NOT NULL,\n   256→  round_id                  TEXT NOT NULL,\n   257→  game_type                 TEXT NOT NULL,\n   258→  wager_lamports            BIGINT NOT NULL,\n   259→  fee_lamports              BIGINT NOT NULL,\n   260→  referrer_earned_lamports  BIGINT NOT NULL,\n   261→  referrer_rate_bps         INTEGER NOT NULL,\n   262→  referee_rebate_lamports   BIGINT NOT NULL,\n   263→  referee_rebate_rate_bps   INTEGER NOT NULL,  -- always 1000 for v1\n   264→  created_at                TIMESTAMPTZ DEFAULT now(),\n   265→  UNIQUE (referee_wallet, round_id)  -- idempotency: one earning per player per round\n   266→)\n   267→\n   268→referral_claims (\n   269→  id                UUID PRIMARY KEY DEFAULT gen_random_uuid(),\n   270→  wallet            TEXT NOT NULL,\n   271→  amount_lamports   BIGINT NOT NULL,\n   272→  status            TEXT NOT NULL CHECK (status IN ('pending','processing','completed','failed')),\n   273→  tx_signature      TEXT,\n   274→  error             TEXT,\n   275→  requested_at      TIMESTAMPTZ DEFAULT now(),\n   276→  processed_at      TIMESTAMPTZ\n   277→)\n   278→\n   279→-- KOL custom referrer rates (overrides default 1000 bps)\n   280→referral_kol_rates (\n   281→  wallet          TEXT PRIMARY KEY,\n   282→  rate_bps        INTEGER NOT NULL,  -- e.g., 2000 = 20% of total fee (= 100 bps of wager)\n   283→  set_by          TEXT NOT NULL,     -- admin wallet\n   284→  created_at      TIME