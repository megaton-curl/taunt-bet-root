{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_0173uopVGjBLVq8uJuM65QMz","type":"message","role":"assistant","content":[{"type":"text","text":"The `createDb()` takes a string URL. I need to handle the socket-based connection. Let me update the test to construct the postgres connection with the socket host, then pass the raw sql to the routes directly while using `createDb` with a proper URL format.\n\nActually, a simpler approach: just configure the DATABASE_URL with the `host` query parameter properly for postgres.js, or create the raw sql with options object and pass it to `createDb` via the `_txSql` parameter.\n\nLet me update the test to use the options-based postgres connection."}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":422,"cache_read_input_tokens":93808,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":422},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"aa0285d4-bc35-4024-8afc-77d99fd4e541","uuid":"2d7b33f3-749d-48a9-afc2-a6926351a1de"}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_0173uopVGjBLVq8uJuM65QMz","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01PY14oUC8vr5nKkmRQnhUfp","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/referral-routes.test.ts","old_string":"const DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-referral-tests\");","new_string":"const DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-referral-tests\");\n\n/** Build postgres connection — handles both TCP and Unix socket. */\nfunction makeSql() {\n  try {\n    // Try URL-based connection first (works in CI with TCP)\n    const sql = postgres(DATABASE_URL);\n    return sql;\n  } catch {\n    // Fallback to Unix socket (dev container)\n    return postgres({\n      host: \"/var/run/postgresql\",\n      user: \"vscode\",\n      database: \"rng_utopia_dev\",\n    });\n  }\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":422,"cache_read_input_tokens":93808,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":422},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"aa0285d4-bc35-4024-8afc-77d99fd4e541","uuid":"88cdc763-e335-4c06-80c0-f388268c502b"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PY14oUC8vr5nKkmRQnhUfp","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/referral-routes.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"aa0285d4-bc35-4024-8afc-77d99fd4e541","uuid":"c1991f99-b7d5-496f-a133-35223323032a","timestamp":"2026-03-25T13:49:42.621Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/referral-routes.test.ts","oldString":"const DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-referral-tests\");","newString":"const DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-referral-tests\");\n\n/** Build postgres connection — handles both TCP and Unix socket. */\nfunction makeSql() {\n  try {\n    // Try URL-based connection first (works in CI with TCP)\n    const sql = postgres(DATABASE_URL);\n    return sql;\n  } catch {\n    // Fallback to Unix socket (dev container)\n    return postgres({\n      host: \"/var/run/postgresql\",\n      user: \"vscode\",\n      database: \"rng_utopia_dev\",\n    });\n  }\n}","originalFile":"/**\n * Referral route tests — set code, apply, stats, earnings, claim flows.\n *\n * Uses real Postgres (same pattern as auth-routes.test.ts) with TRUNCATE\n * between tests for isolation.\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair } from \"@solana/web3.js\";\nimport { SignJWT } from \"jose\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createReferralRoutes } from \"../routes/referral.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport type { Config } from \"../config.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL =\n  process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-referral-tests\");\n\n// ---------------------------------------------------------------------------\n// Helpers\n// ---------------------------------------------------------------------------\n\nasync function makeJwt(wallet: string): Promise<string> {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({ sub: wallet })\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setIssuedAt(now)\n    .setExpirationTime(now + 3600)\n    .sign(JWT_SECRET);\n}\n\nfunction json(body: Record<string, unknown>) {\n  return {\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify(body),\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"Referral routes\", () => {\n  let rawSql: ReturnType<typeof postgres>;\n  let db: Db;\n  let app: Hono;\n\n  const referrerKp = Keypair.generate();\n  const refereeKp = Keypair.generate();\n  const referrer = referrerKp.publicKey.toBase58();\n  const referee = refereeKp.publicKey.toBase58();\n\n  const testConfig = {\n    referralDefaultRateBps: 1000,\n    referralMinClaimLamports: 10_000_000, // 0.01 SOL\n  } as Config;\n\n  beforeAll(async () => {\n    rawSql = postgres(DATABASE_URL);\n\n    // Ensure referral + event_queue tables exist (idempotent)\n    await rawSql.file(\n      new URL(\"../../migrations/011_referral.sql\", import.meta.url).pathname,\n    );\n    await rawSql.file(\n      new URL(\"../../migrations/010_event_queue.sql\", import.meta.url).pathname,\n    );\n  });\n\n  afterAll(async () => {\n    if (db) await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE referral_codes, referral_links, referral_earnings, referral_claims, referral_kol_rates, event_queue RESTART IDENTITY CASCADE`;\n\n    db = createDb(DATABASE_URL);\n\n    app = new Hono();\n    app.use(\n      \"/referral/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET, requireAllMethods: true }),\n    );\n    app.route(\n      \"/referral\",\n      createReferralRoutes({ db, sql: rawSql, config: testConfig }),\n    );\n  });\n\n  // -----------------------------------------------------------------------\n  // POST /referral/code — set custom code\n  // -----------------------------------------------------------------------\n\n  describe(\"POST /referral/code\", () => {\n    it(\"sets a valid custom code and returns code + url\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"my-code-123\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as { code: string; url: string };\n      expect(body.code).toBe(\"my-code-123\");\n      expect(body.url).toBe(\"https://taunt.bet/r/my-code-123\");\n    });\n\n    it(\"rejects code shorter than 3 chars\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"ab\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(400);\n      const body = (await res.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"INVALID_CODE\");\n    });\n\n    it(\"rejects code longer than 16 chars\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"abcdefghijklmnopq\" }), // 17 chars\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(400);\n    });\n\n    it(\"rejects code with uppercase or special chars\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"My_Code!\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(400);\n    });\n\n    it(\"returns 409 when code is taken by another wallet\", async () => {\n      // First wallet takes the code\n      const token1 = await makeJwt(referrer);\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"taken-code\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token1}` },\n      });\n\n      // Second wallet tries the same code\n      const token2 = await makeJwt(referee);\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"taken-code\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token2}` },\n      });\n\n      expect(res.status).toBe(409);\n      const body = (await res.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"CODE_TAKEN\");\n    });\n\n    it(\"allows the same wallet to update their own code\", async () => {\n      const token = await makeJwt(referrer);\n\n      // Set initial code\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"first-code\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      // Update to new code\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"second-code\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as { code: string };\n      expect(body.code).toBe(\"second-code\");\n    });\n\n    it(\"rejects missing body\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/code\", {\n        method: \"POST\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(400);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /referral/code — retrieve current code\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /referral/code\", () => {\n    it(\"returns existing code for wallet\", async () => {\n      const token = await makeJwt(referrer);\n\n      // Set code first\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"get-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      const res = await app.request(\"/referral/code\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as { code: string; url: string };\n      expect(body.code).toBe(\"get-test\");\n      expect(body.url).toBe(\"https://taunt.bet/r/get-test\");\n    });\n\n    it(\"returns 404 if no code set\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/code\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(404);\n      const body = (await res.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"NO_CODE\");\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // POST /referral/apply — link referee to referrer\n  // -----------------------------------------------------------------------\n\n  describe(\"POST /referral/apply\", () => {\n    beforeEach(async () => {\n      // Set up a referral code for the referrer\n      const token = await makeJwt(referrer);\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"apply-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n    });\n\n    it(\"links referee to referrer via code\", async () => {\n      const token = await makeJwt(referee);\n      const res = await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"apply-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as { referrer: string; benefit: string };\n      expect(body.referrer).toBe(referrer);\n      expect(body.benefit).toContain(\"10%\");\n    });\n\n    it(\"rejects self-referral\", async () => {\n      const token = await makeJwt(referrer); // referrer applying their own code\n      const res = await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"apply-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(400);\n      const body = (await res.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"SELF_REFERRAL\");\n    });\n\n    it(\"returns 409 when already linked to a referrer\", async () => {\n      const token = await makeJwt(referee);\n\n      // First apply succeeds\n      await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"apply-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      // Set up a second referrer code\n      const other = Keypair.generate().publicKey.toBase58();\n      const otherToken = await makeJwt(other);\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"other-code\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${otherToken}` },\n      });\n\n      // Second apply fails\n      const res = await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"other-code\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(409);\n      const body = (await res.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"ALREADY_LINKED\");\n    });\n\n    it(\"returns 404 for non-existent code\", async () => {\n      const token = await makeJwt(referee);\n      const res = await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"nonexistent\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(404);\n      const body = (await res.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"CODE_NOT_FOUND\");\n    });\n\n    it(\"rejects empty code\", async () => {\n      const token = await makeJwt(referee);\n      const res = await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(400);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /referral/stats — summary stats\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /referral/stats\", () => {\n    it(\"returns zeroed stats for wallet with no referrals\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/stats\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as Record<string, unknown>;\n      expect(body.referredCount).toBe(0);\n      expect(body.activeCount).toBe(0);\n      expect(body.totalVolumeLamports).toBe(\"0\");\n      expect(body.totalEarnedLamports).toBe(\"0\");\n      expect(body.pendingLamports).toBe(\"0\");\n    });\n\n    it(\"reflects referred count after linking\", async () => {\n      // Set up referrer code + link a referee\n      const referrerToken = await makeJwt(referrer);\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"stats-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${referrerToken}` },\n      });\n\n      const refereeToken = await makeJwt(referee);\n      await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"stats-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${refereeToken}` },\n      });\n\n      const res = await app.request(\"/referral/stats\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${referrerToken}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as { referredCount: number };\n      expect(body.referredCount).toBe(1);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /referral/earnings — paginated earnings\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /referral/earnings\", () => {\n    it(\"returns empty items when no earnings exist\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/earnings\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        items: unknown[];\n        pagination: { page: number; totalPages: number };\n      };\n      expect(body.items).toHaveLength(0);\n      expect(body.pagination.page).toBe(1);\n      expect(body.pagination.totalPages).toBe(0);\n    });\n\n    it(\"returns earnings after inserting one\", async () => {\n      // Insert an earning directly via DB\n      await db.insertReferralEarning({\n        referrer_wallet: referrer,\n        referee_wallet: referee,\n        round_id: \"test-round-001\",\n        game_type: \"coinflip\",\n        wager_lamports: 1_000_000_000,\n        fee_lamports: 50_000_000,\n        referrer_earned_lamports: 5_000_000,\n        referrer_rate_bps: 1000,\n        referee_rebate_lamports: 5_000_000,\n        referee_rebate_rate_bps: 1000,\n      });\n\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/earnings\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        items: Array<{\n          roundId: string;\n          gameType: string;\n          refereeWallet: string;\n          wagerLamports: string;\n          earnedLamports: string;\n          createdAt: string;\n        }>;\n        pagination: { page: number; totalPages: number };\n      };\n      expect(body.items).toHaveLength(1);\n      expect(body.items[0]!.roundId).toBe(\"test-round-001\");\n      expect(body.items[0]!.gameType).toBe(\"coinflip\");\n      expect(body.items[0]!.wagerLamports).toBe(\"1000000000\");\n      expect(body.items[0]!.earnedLamports).toBe(\"5000000\");\n      expect(body.pagination.totalPages).toBe(1);\n    });\n\n    it(\"respects page and limit query params\", async () => {\n      // Insert 3 earnings\n      for (let i = 1; i <= 3; i++) {\n        await db.insertReferralEarning({\n          referrer_wallet: referrer,\n          referee_wallet: referee,\n          round_id: `round-${i}`,\n          game_type: \"coinflip\",\n          wager_lamports: 1_000_000_000,\n          fee_lamports: 50_000_000,\n          referrer_earned_lamports: 5_000_000,\n          referrer_rate_bps: 1000,\n          referee_rebate_lamports: 5_000_000,\n          referee_rebate_rate_bps: 1000,\n        });\n      }\n\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/earnings?page=1&limit=2\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        items: unknown[];\n        pagination: { page: number; totalPages: number };\n      };\n      expect(body.items).toHaveLength(2);\n      expect(body.pagination.totalPages).toBe(2);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // POST /referral/claim — claim flow\n  // -----------------------------------------------------------------------\n\n  describe(\"POST /referral/claim\", () => {\n    it(\"rejects claim with zero balance\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n\n      expect(res.status).toBe(400);\n      const body = (await res.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"ZERO_BALANCE\");\n    });\n\n    it(\"rejects claim below minimum threshold\", async () => {\n      // Insert a small earning (below 0.01 SOL threshold)\n      await db.insertReferralEarning({\n        referrer_wallet: referrer,\n        referee_wallet: referee,\n        round_id: \"small-round\",\n        game_type: \"coinflip\",\n        wager_lamports: 100_000_000, // 0.1 SOL\n        fee_lamports: 5_000_000, // 0.005 SOL\n        referrer_earned_lamports: 500_000, // 0.0005 SOL — below 0.01 threshold\n        referrer_rate_bps: 1000,\n        referee_rebate_lamports: 500_000,\n        referee_rebate_rate_bps: 1000,\n      });\n\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n\n      expect(res.status).toBe(400);\n      const body = (await res.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"BELOW_THRESHOLD\");\n    });\n\n    it(\"creates a pending claim for valid balance\", async () => {\n      // Insert a large enough earning\n      await db.insertReferralEarning({\n        referrer_wallet: referrer,\n        referee_wallet: referee,\n        round_id: \"big-round\",\n        game_type: \"coinflip\",\n        wager_lamports: 10_000_000_000, // 10 SOL\n        fee_lamports: 500_000_000, // 0.5 SOL\n        referrer_earned_lamports: 50_000_000, // 0.05 SOL — above threshold\n        referrer_rate_bps: 1000,\n        referee_rebate_lamports: 50_000_000,\n        referee_rebate_rate_bps: 1000,\n      });\n\n      const token = await makeJwt(referrer);\n      const res = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n\n      expect(res.status).toBe(202);\n      const body = (await res.json()) as {\n        claimId: string;\n        amountLamports: string;\n        status: string;\n      };\n      expect(body.claimId).toBeDefined();\n      expect(body.amountLamports).toBe(\"50000000\");\n      expect(body.status).toBe(\"pending\");\n\n      // Verify event was emitted\n      const events =\n        await rawSql`SELECT * FROM event_queue WHERE event_type = 'referral.claim_requested'`;\n      expect(events.length).toBe(1);\n    });\n\n    it(\"prevents double-claim by deducting pending balance\", async () => {\n      // Insert earning\n      await db.insertReferralEarning({\n        referrer_wallet: referrer,\n        referee_wallet: referee,\n        round_id: \"double-round\",\n        game_type: \"coinflip\",\n        wager_lamports: 10_000_000_000,\n        fee_lamports: 500_000_000,\n        referrer_earned_lamports: 50_000_000,\n        referrer_rate_bps: 1000,\n        referee_rebate_lamports: 50_000_000,\n        referee_rebate_rate_bps: 1000,\n      });\n\n      const token = await makeJwt(referrer);\n\n      // First claim succeeds\n      const res1 = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n      expect(res1.status).toBe(202);\n\n      // Second claim fails — balance consumed by pending claim\n      const res2 = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n      expect(res2.status).toBe(400);\n      const body = (await res2.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"ZERO_BALANCE\");\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /referral/claim/:claimId — poll claim status\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /referral/claim/:claimId\", () => {\n    it(\"returns claim status for the owner\", async () => {\n      // Insert earning + create claim\n      await db.insertReferralEarning({\n        referrer_wallet: referrer,\n        referee_wallet: referee,\n        round_id: \"poll-round\",\n        game_type: \"coinflip\",\n        wager_lamports: 10_000_000_000,\n        fee_lamports: 500_000_000,\n        referrer_earned_lamports: 50_000_000,\n        referrer_rate_bps: 1000,\n        referee_rebate_lamports: 50_000_000,\n        referee_rebate_rate_bps: 1000,\n      });\n\n      const token = await makeJwt(referrer);\n      const claimRes = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n      });\n      const claim = (await claimRes.json()) as { claimId: string };\n\n      // Poll status\n      const res = await app.request(`/referral/claim/${claim.claimId}`, {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        claimId: string;\n        amountLamports: string;\n        status: string;\n      };\n      expect(body.claimId).toBe(claim.claimId);\n      expect(body.status).toBe(\"pending\");\n    });\n\n    it(\"returns 404 for non-existent claim\", async () => {\n      const token = await makeJwt(referrer);\n      const res = await app.request(\n        \"/referral/claim/00000000-0000-0000-0000-000000000000\",\n        {\n          method: \"GET\",\n          headers: { Authorization: `Bearer ${token}` },\n        },\n      );\n\n      expect(res.status).toBe(404);\n    });\n\n    it(\"returns 404 when another wallet tries to view a claim\", async () => {\n      // Create earning + claim as referrer\n      await db.insertReferralEarning({\n        referrer_wallet: referrer,\n        referee_wallet: referee,\n        round_id: \"auth-round\",\n        game_type: \"coinflip\",\n        wager_lamports: 10_000_000_000,\n        fee_lamports: 500_000_000,\n        referrer_earned_lamports: 50_000_000,\n        referrer_rate_bps: 1000,\n        referee_rebate_lamports: 50_000_000,\n        referee_rebate_rate_bps: 1000,\n      });\n\n      const referrerToken = await makeJwt(referrer);\n      const claimRes = await app.request(\"/referral/claim\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${referrerToken}`,\n        },\n      });\n      const claim = (await claimRes.json()) as { claimId: string };\n\n      // Try to view as referee (different wallet)\n      const refereeToken = await makeJwt(referee);\n      const res = await app.request(`/referral/claim/${claim.claimId}`, {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${refereeToken}` },\n      });\n\n      expect(res.status).toBe(404);\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /referral/referrer — check referrer status\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /referral/referrer\", () => {\n    it(\"returns 404 when not referred\", async () => {\n      const token = await makeJwt(referee);\n      const res = await app.request(\"/referral/referrer\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${token}` },\n      });\n\n      expect(res.status).toBe(404);\n      const body = (await res.json()) as { error: { code: string } };\n      expect(body.error.code).toBe(\"NO_REFERRER\");\n    });\n\n    it(\"returns referrer wallet after linking\", async () => {\n      // Set up code + apply\n      const referrerToken = await makeJwt(referrer);\n      await app.request(\"/referral/code\", {\n        method: \"POST\",\n        ...json({ code: \"referrer-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${referrerToken}` },\n      });\n\n      const refereeToken = await makeJwt(referee);\n      await app.request(\"/referral/apply\", {\n        method: \"POST\",\n        ...json({ code: \"referrer-test\" }),\n        headers: { ...json({}).headers, Authorization: `Bearer ${refereeToken}` },\n      });\n\n      const res = await app.request(\"/referral/referrer\", {\n        method: \"GET\",\n        headers: { Authorization: `Bearer ${refereeToken}` },\n      });\n\n      expect(res.status).toBe(200);\n      const body = (await res.json()) as {\n        referrerWallet: string;\n        linkedAt: string;\n      };\n      expect(body.referrerWallet).toBe(referrer);\n      expect(body.linkedAt).toBeDefined();\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // Auth — missing JWT\n  // -----------------------------------------------------------------------\n\n  describe(\"Authentication\", () => {\n    it(\"returns 401 for requests without JWT\", async () => {\n      const res = await app.request(\"/referral/stats\", { method: \"GET\" });\n      expect(res.status).toBe(401);\n    });\n  });\n});\n","structuredPatch":[{"oldStart":23,"oldLines":6,"newStart":23,"newLines":22,"lines":["   process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";"," const JWT_SECRET = new TextEncoder().encode(\"test-secret-for-referral-tests\");"," ","+/** Build postgres connection — handles both TCP and Unix socket. */","+function makeSql() {","+  try {","+    // Try URL-based connection first (works in CI with TCP)","+    const sql = postgres(DATABASE_URL);","+    return sql;","+  } catch {","+    // Fallback to Unix socket (dev container)","+    return postgres({","+      host: \"/var/run/postgresql\",","+      user: \"vscode\",","+      database: \"rng_utopia_dev\",","+    });","+  }","+}","+"," // ---------------------------------------------------------------------------"," // Helpers"," // ---------------------------------------------------------------------------"]}],"userModified":false,"replaceAll":false}