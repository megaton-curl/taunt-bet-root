{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L9yAKyjo32cnvGBxU7LE4f","type":"tool_result","content":"     1→/**\n     2→ * In-memory sliding-window rate limiting middleware.\n     3→ *\n     4→ * Applies per-wallet and global limits to POST requests only.\n     5→ * Counters reset on service restart (acceptable for MVP).\n     6→ */\n     7→\n     8→import type { MiddlewareHandler } from \"hono\";\n     9→import { logger } from \"../logger.js\";\n    10→\n    11→export interface RateLimitConfig {\n    12→  /** Max POST requests per wallet per window (default 10). */\n    13→  perWallet: number;\n    14→  /** Max total POST requests per window (default 100). */\n    15→  global: number;\n    16→  /** Window size in milliseconds (default 60_000 = 1 minute). */\n    17→  windowMs: number;\n    18→}\n    19→\n    20→interface SlidingWindow {\n    21→  timestamps: number[];\n    22→}\n    23→\n    24→/**\n    25→ * Prune timestamps older than the window and return the current count.\n    26→ */\n    27→function countInWindow(window: SlidingWindow, now: number, windowMs: number): number {\n    28→  const cutoff = now - windowMs;\n    29→  // Remove expired entries from the front\n    30→  while (window.timestamps.length > 0 && window.timestamps[0]! <= cutoff) {\n    31→    window.timestamps.shift();\n    32→  }\n    33→  return window.timestamps.length;\n    34→}\n    35→\n    36→/**\n    37→ * Creates a Hono middleware that rate-limits POST requests.\n    38→ *\n    39→ * - Per-wallet: keyed by the `wallet` field in the JSON body.\n    40→ * - Global: all POST requests combined.\n    41→ * - Returns 429 with `Retry-After` header when either limit is exceeded.\n    42→ * - GET requests pass through without rate limiting.\n    43→ */\n    44→export function createRateLimitMiddleware(config: RateLimitConfig): MiddlewareHandler {\n    45→  const walletWindows = new Map<string, SlidingWindow>();\n    46→  const globalWindow: SlidingWindow = { timestamps: [] };\n    47→\n    48→  return async (c, next) => {\n    49→    if (c.req.method !== \"POST\") {\n    50→      return next();\n    51→    }\n    52→\n    53→    const now = Date.now();\n    54→    const retryAfterSeconds = Math.ceil(config.windowMs / 1000);\n    55→\n    56→    // Check global limit first\n    57→    const globalCount = countInWindow(globalWindow, now, config.windowMs);\n    58→    if (globalCount >= config.global) {\n    59→      logger.warn(\"rate limit exceeded: global limit\", {\n    60→        path: c.req.path,\n    61→        currentCount: globalCount,\n    62→        limit: config.global,\n    63→        windowMs: config.windowMs,\n    64→      });\n    65→      c.header(\"Retry-After\", String(retryAfterSeconds));\n    66→      return c.json({ error: \"Too many requests\" }, 429);\n    67→    }\n    68→\n    69→    // Extract wallet: prefer context (set by JWT middleware), fall back to body\n    70→    let wallet: string | undefined;\n    71→    try {\n    72→      wallet = c.get(\"wallet\") as string | undefined;\n    73→    } catch {\n    74→      // Context variable not set — expected for pre-auth routes\n    75→    }\n    76→    if (!wallet) {\n    77→      try {\n    78→        const body = await c.req.json();\n    79→        wallet = typeof body.wallet === \"string\" ? body.wallet : undefined;\n    80→      } catch {\n    81→        // If body is not parseable, fall back to IP-based limiting\n    82→      }\n    83→    }\n    84→    // Final fallback: key on IP for pre-auth routes (e.g., /auth/*)\n    85→    if (!wallet) {\n    86→      wallet = c.req.header(\"x-forwarded-for\")?.split(\",\")[0]?.trim()\n    87→        ?? c.req.header(\"x-real-ip\")\n    88→        ?? \"unknown-ip\";\n    89→    }\n    90→\n    91→    // Check per-wallet limit\n    92→    if (wallet) {\n    93→      let wWindow = walletWindows.get(wallet);\n    94→      if (!wWindow) {\n    95→        wWindow = { timestamps: [] };\n    96→        walletWindows.set(wallet, wWindow);\n    97→      }\n    98→      const walletCount = countInWindow(wWindow, now, config.windowMs);\n    99→      if (walletCount >= config.perWallet) {\n   100→        logger.warn(\"rate limit exceeded: wallet limit\", {\n   101→          path: c.req.path,\n   102→          wallet,\n   103→          currentCount: walletCount,\n   104→          limit: config.perWallet,\n   105→          windowMs: config.windowMs,\n   106→        });\n   107→        c.header(\"Retry-After\", String(retryAfterSeconds));\n   108→        return c.json({ error: \"Too many requests\" }, 429);\n   109→      }\n   110→      wWindow.timestamps.push(now);\n   111→    }\n   112→\n   113→    // Record in global window\n   114→    globalWindow.timestamps.push(now);\n   115→\n   116→    return next();\n   117→  };\n   118→}\n   119→"}]},"parent_tool_use_id":"toolu_01FUmw22Gty3DEJ8iw5RHp6J","session_id":"aa0285d4-bc35-4024-8afc-77d99fd4e541","uuid":"2bedc3bf-1a5f-435e-b983-94a4d1f11377","timestamp":"2026-03-25T13:44:52.550Z"}
