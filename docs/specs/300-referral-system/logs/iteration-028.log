/rng-utopia/services/backend/migrations/010_event_queue.sql-18-  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n/workspaces/rng-utopia/sources/rng-utopia/services/backend/migrations/010_event_queue.sql-19-\n/workspaces/rng-utopia/sources/rng-utopia/services/backend/migrations/010_event_queue.sql-20-  CONSTRAINT chk_event_queue_status\n/workspaces/rng-utopia/sources/rng-utopia/services/backend/migrations/010_event_queue.sql-21-    CHECK (status IN ('pending', 'processing', 'completed', 'failed', 'dead'))\n/workspaces/rng-utopia/sources/rng-utopia/services/backend/migrations/010_event_queue.sql-22-);","numLines":16}}
