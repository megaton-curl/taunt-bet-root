{code})\n    RETURNING *\n  `;\n  return rows[0]!;\n},\n```\n\n**getReferralCodeByWallet (lines 646–651):**\n```typescript\nasync getReferralCodeByWallet(wallet) {\n  const rows = await sql<ReferralCode[]>`\n    SELECT * FROM referral_codes WHERE wallet = ${wallet}\n  `;\n  return rows[0];\n},\n```\n\n**getReferralCodeByCode (lines 653–658):**\n```typescript\nasync getReferralCodeByCode(code) {\n  const rows = await sql<ReferralCode[]>`\n    SELECT * FROM referral_codes WHERE code = ${code}\n  `;\n  return rows[0];\n},\n```\n\n**upsertReferralCode (lines 660–670):**\n```typescript\nasync upsertReferralCode(wallet, code) {\n  const rows = await sql<ReferralCode[]>`\n    INSERT INTO referral_codes (wallet, code)\n    VALUES (${wallet}, ${code})\n    ON CONFLICT (wallet) DO UPDATE SET\n      code = ${code},\n      updated_at = now()\n    RETURNING *\n  `;\n  return rows[0]!;\n},\n```\n\n---\n\n### 4. SQL Template Literal Patterns\n\nThe code uses **postgres.js** (imported as `postgres` at line 8) with typed template literals:\n\n- **Syntax**: `` sql<TypeArray[]>`query with ${param}` ``\n- **Type annotation**: `sql<ReferralCode[]>` specifies the return type\n- **Parameter binding**: `${variable}` automatically escapes and binds parameters (no SQL injection risk)\n- **JSON handling**: `sql.json(object)` for JSONB columns (e.g., entries, green_entries, red_entries)\n- **Return pattern**: Query returns an array; destructure with `[0]` and use `!` (non-null assertion) when guaranteed to exist\n- **Optional returns**: Return `rows[0]` directly (which is `undefined` if empty) when the result is optional\n\n---\n\n### 5. Migration File — Table Schemas\n**Full path**: `/workspaces/rng-utopia/sources/rng-utopia/services/backend/migrations/011_referral.sql`\n\n**referral_codes table (lines 8–14):**\n```sql\nCREATE TABLE IF NOT EXISTS referral_codes (\n  id              SERIAL       PRIMARY KEY,\n  wallet          TEXT         NOT NULL UNIQUE,\n  code            TEXT         NOT NULL UNIQUE,  -- player-chosen, 3-16 chars [a-z0-9-]\n  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n  updated_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n);\n```\n\n**Other tables in same migration** (for context):\n- `referral_links` (lines 17–25): immutable referrer→referee binding\n- `referral_earnings` (lines 28–44): one row per referee per round\n- `referral_claims` (lines 56–68): async SOL payout tracking\n- `referral_kol_rates` (lines 78–84): KOL custom referrer rates\n\n---\n\n### Key Patterns for Future Methods\n\n1. **Parameter passing**: Use camelCase in TypeScript interfaces (e.g., `amountLamports`), convert to snake_case in SQL queries (e.g., `amount_lamports`)\n2. **Return types**: Always use `Promise<T>` for async methods\n3. **Nullable results**: Use `| undefined` for methods that may not find a record\n4. **Array returns**: Type as `TypeName[]` and map with normalization functions if needed\n5. **Error handling**: Throw `Error` for missing records in required operations; let postgres.js handle constraint violations\n6. **SQL patterns**:\n   - `RETURNING *` to get inserted/updated rows\n   - `ON CONFLICT` for upsert operations\n   - `ORDER BY` with `LIMIT` for pagination\n   - `sql.json()` for JSONB data"}],"totalDurationMs":19848,"totalTokens":47514,"totalToolUseCount":5,"usage":{"input_tokens":5,"cache_creation_input_tokens":304,"cache_read_input_tokens":45785,"output_tokens":1420,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":304},"inference_geo":"","iterations":[],"speed":"standard"}}}
