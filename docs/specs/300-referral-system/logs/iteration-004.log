{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019Vk7GKSdN1pKHb5xX7C7oL","type":"tool_result","content":"     1→/**\n     2→ * Database client module — typed query functions for `rounds` and `operator_events`.\n     3→ *\n     4→ * Phase transitions are unidirectional: created → locked → settling → settled,\n     5→ * or created → expired. The application layer rejects backward transitions.\n     6→ */\n     7→\n     8→import postgres from \"postgres\";\n     9→\n    10→// ---------------------------------------------------------------------------\n    11→// Types\n    12→// ---------------------------------------------------------------------------\n    13→\n    14→export type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    15→\n    16→export type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n    17→export type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n    18→\n    19→export interface CloseCallRound {\n    20→  round_id: string;\n    21→  pda: string;\n    22→  server_key: string;\n    23→  phase: CloseCallPhase;\n    24→  open_price: number;\n    25→  open_price_expo: number;\n    26→  close_price: number | null;\n    27→  outcome: CloseCallOutcome;\n    28→  green_pool: number;\n    29→  red_pool: number;\n    30→  total_fee: number;\n    31→  green_entries: Array<{ player: string; amountLamports: number }>;\n    32→  red_entries: Array<{ player: string; amountLamports: number }>;\n    33→  settle_tx: string | null;\n    34→  created_at: Date;\n    35→  settled_at: Date | null;\n    36→}\n    37→\n    38→export interface InsertCloseCallRoundParams {\n    39→  roundId: string;\n    40→  pda: string;\n    41→  serverKey: string;\n    42→  openPrice: number;\n    43→  openPriceExpo: number;\n    44→}\n    45→\n    46→export type OperatorEventType =\n    47→  | \"secret_generated\"\n    48→  | \"tx_built\"\n    49→  | \"match_detected\"\n    50→  | \"settle_submitted\"\n    51→  | \"settle_confirmed\"\n    52→  | \"settle_failed\"\n    53→  | \"settle_retried\"\n    54→  | \"timeout_detected\";\n    55→\n    56→export interface Round {\n    57→  pda: string;\n    58→  game: string;\n    59→  creator: string;\n    60→  server_key: string;\n    61→  secret: Buffer;\n    62→  commitment: Buffer;\n    63→  amount_lamports: number;\n    64→  side: number;\n    65→  match_id: string;\n    66→  phase: RoundPhase;\n    67→  target_slot: string | null;\n    68→  settle_tx: string | null;\n    69→  settle_attempts: number;\n    70→  result_hash: Buffer | null;\n    71→  result_side: number | null;\n    72→  winner: string | null;\n    73→  entries: unknown | null;\n    74→  created_at: Date;\n    75→  updated_at: Date;\n    76→}\n    77→\n    78→export interface InsertRoundParams {\n    79→  pda: string;\n    80→  game: string;\n    81→  creator: string;\n    82→  serverKey: string;\n    83→  secret: Buffer;\n    84→  commitment: Buffer;\n    85→  amountLamports: number;\n    86→  side: number;\n    87→  matchId: string;\n    88→  phase: RoundPhase;\n    89→  entries?: Array<{ player: string; amountLamports: number }>;\n    90→}\n    91→\n    92→export interface OperatorEvent {\n    93→  id: string;\n    94→  pda: string | null;\n    95→  event_type: OperatorEventType;\n    96→  payload: unknown;\n    97→  created_at: Date;\n    98→}\n    99→\n   100→// ---------------------------------------------------------------------------\n   101→// Transaction types\n   102→// ---------------------------------------------------------------------------\n   103→\n   104→export type TransactionType = \"deposit\" | \"payout\" | \"refund\";\n   105→\n   106→export interface Transaction {\n   107→  id: string;\n   108→  wallet: string;\n   109→  game: string;\n   110→  match_id: string;\n   111→  tx_type: TransactionType;\n   112→  amount_lamports: number;\n   113→  tx_sig: string;\n   114→  created_at: Date;\n   115→}\n   116→\n   117→export interface InsertTransactionParams {\n   118→  wallet: string;\n   119→  game: string;\n   120→  matchId: string;\n   121→  txType: TransactionType;\n   122→  amountLamports: number;\n   123→  txSig: string;\n   124→}\n   125→\n   126→// ---------------------------------------------------------------------------\n   127→// Referral types\n   128→// ---------------------------------------------------------------------------\n   129→\n   130→export interface ReferralCode {\n   131→  id: number;\n   132→  wallet: string;\n   133→  code: string;\n   134→  created_at: Date;\n   135→  updated_at: Date;\n   136→}\n   137→\n   138→// ---------------------------------------------------------------------------\n   139→// Phase transition guard\n   140→// ---------------------------------------------------------------------------\n   141→\n   142→/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n   143→const VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n   144→  created: [\"locked\", \"expired\"],\n   145→  locked: [\"settling\"],\n   146→  settling: [\"settled\"],\n   147→  settled: [],\n   148→  expired: [],\n   149→};\n   150→\n   151→function assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n   152→  const allowed = VALID_TRANSITIONS[from];\n   153→  if (!allowed.includes(to)) {\n   154→    throw new Error(\n   155→      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n   156→    );\n   157→  }\n   158→}\n   159→\n   160→// ---------------------------------------------------------------------------\n   161→// DB client\n   162→// ---------------------------------------------------------------------------\n   163→\n   164→export interface Db {\n   165→  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n   166→  insertRound(params: InsertRoundParams): Promise<Round>;\n   167→\n   168→  /** Delete a round by PDA. Returns true if a row was removed. */\n   169→  deleteRoundByPda(pda: string): Promise<boolean>;\n   170→\n   171→  /** Transition a round's phase. Enforces unidirectional state machine.\n   172→   *  Optional `updates` can set additional columns alongside the phase change. */\n   173→  updateRoundPhase(\n   174→    pda: string,\n   175→    newPhase: RoundPhase,\n   176→    updates?: Partial<\n   177→      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n   178→    >,\n   179→  ): Promise<Round>;\n   180→\n   181→  /** Update the entries JSONB column for a settled round. */\n   182→  updateRoundEntries(\n   183→    pda: string,\n   184→    entries: Array<{ player: string; amountLamports: number }>,\n   185→  ): Promise<Round>;\n   186→\n   187→  /** Get a single round by its PDA. Returns `undefined` if not found. */\n   188→  getRoundByPda(pda: string): Promise<Round | undefined>;\n   189→\n   190→  /** Get all rounds matching a given phase. */\n   191→  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n   192→\n   193→  /** Append an operator event to the audit log. */\n   194→  insertOperatorEvent(\n   195→    pda: string | null,\n   196→    eventType: OperatorEventType,\n   197→    payload?: unknown,\n   198→  ): Promise<OperatorEvent>;\n   199→\n   200→  /** Get the latest operator event for a PDA + type. */\n   201→  getLatestOperatorEvent(\n   202→    pda: string,\n   203→    eventType: OperatorEventType,\n   204→  ): Promise<OperatorEvent | undefined>;\n   205→\n   206→  /** Get a single round by its match_id. Returns `undefined` if not found. */\n   207→  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n   208→\n   209→  /** Batch-fetch the latest operator event per PDA for a given event type. */\n   210→  getLatestOperatorEventsForPdas(\n   211→    pdas: string[],\n   212→    eventType: OperatorEventType,\n   213→  ): Promise<Map<string, OperatorEvent>>;\n   214→\n   215→  /** Get recently settled rounds for a game, ordered newest first. */\n   216→  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n   217→\n   218→  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n   219→  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n   220→\n   221→  // -------------------------------------------------------------------------\n   222→  // Close Call rounds\n   223→  // -------------------------------------------------------------------------\n   224→\n   225→  /** Insert a new Close Call round. */\n   226→  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n   227→\n   228→  /** Get a Close Call round by round_id (16-char hex). */\n   229→  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n   230→\n   231→  /** Get the current active (open) Close Call round. */\n   232→  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n   233→\n   234→  /** Get the most recent settled/refunded Close Call rounds. */\n   235→  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n   236→\n   237→  /** Update a Close Call round after settlement. */\n   238→  settleCloseCallRound(\n   239→    roundId: string,\n   240→    updates: {\n   241→      phase: CloseCallPhase;\n   242→      outcome: CloseCallOutcome;\n   243→      closePrice?: number;\n   244→      greenPool?: number;\n   245→      redPool?: number;\n   246→      totalFee?: number;\n   247→      greenEntries?: Array<{ player: string; amountLamports: number }>;\n   248→      redEntries?: Array<{ player: string; amountLamports: number }>;\n   249→      settleTx?: string;\n   250→    },\n   251→  ): Promise<CloseCallRound>;\n   252→\n   253→  // -------------------------------------------------------------------------\n   254→  // Transactions\n   255→  // -------------------------------------------------------------------------\n   256→\n   257→  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n   258→  insertTransaction(params: InsertTransactionParams): Promise<void>;\n   259→\n   260→  /** Insert multiple transactions in a single batch. */\n   261→  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n   262→\n   263→  /** Get paginated transactions for a wallet, newest first. */\n   264→  getTransactions(\n   265→    wallet: string,\n   266→    cursor?: string,\n   267→    limit?: number,\n   268→    game?: string,\n   269→  ): Promise<Transaction[]>;\n   270→\n   271→  // -------------------------------------------------------------------------\n   272→  // Referral — codes\n   273→  // -------------------------------------------------------------------------\n   274→\n   275→  /** Insert a new referral code for a wallet. Throws on duplicate wallet or code. */\n   276→  insertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n   277→\n   278→  /** Get a wallet's referral code. Returns `undefined` if none set. */\n   279→  getReferralCodeByWallet(wallet: string): Promise<ReferralCode | undefined>;\n   280→\n   281→  /** Look up a referral code record by code string. Returns `undefined` if not found. */\n   282→  getReferralCodeByCode(code: string): Promise<ReferralCode | undefined>;\n   283→\n   284→  /** Set or replace a wallet's referral code (INSERT … ON CONFLICT UPDATE). */\n   285→  upsertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n   286→\n   287→  /** Gracefully close the connection pool. */\n   288→  close(): Promise<void>;\n   289→}\n   290→\n   291→function normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n   292→  return {\n   293→    ...row,\n   294→    open_price: Number(row.open_price),\n   295→    open_price_expo: Number(row.open_price_expo),\n   296→    close_price: row.close_price === null ? null : Number(row.close_price),\n   297→    green_pool: Number(row.green_pool),\n   298→    red_pool: Number(row.red_pool),\n   299→    total_fee: Number(row.total_fee),\n   300→    // JSONB comes back as parsed objects from postgres.js\n   301→    green_entries: Array.isArray(row.green_entries)\n   302→      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   303→      : [],\n   304→    red_entries: Array.isArray(row.red_entries)\n   305→      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   306→      : [],\n   307→  };\n   308→}\n   309→\n   310→function normalizeTransaction(row: Transaction): Transaction {\n   311→  return {\n   312→    ...row,\n   313→    amount_lamports: Number(row.amount_lamports),\n   314→  };\n   315→}\n   316→\n   317→function normalizeRound(row: Round): Round {\n   318→  return {\n   319→    ...row,\n   320→    amount_lamports: Number(row.amount_lamports),\n   321→    side: Number(row.side),\n   322→    settle_attempts: Number(row.settle_attempts),\n   323→    result_side: row.result_side === null ? null : Number(row.result_side),\n   324→    // JSONB comes back as parsed objects from postgres.js\n   325→    entries: Array.isArray(row.entries)\n   326→      ? (row.entries as Array<{ player: string; amountLamports: number }>).map((e) => ({\n   327→          player: e.player,\n   328→          amountLamports: Number(e.amountLamports),\n   329→        }))\n   330→      : null,\n   331→  };\n   332→}\n   333→\n   334→export function createDb(databaseUrl: string): Db {\n   335→  const sql = postgres(databaseUrl);\n   336→\n   337→  return {\n   338→    async insertRound(params) {\n   339→      const rows = await sql<Round[]>`\n   340→        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase, entries)\n   341→        VALUES (\n   342→          ${params.pda},\n   343→          ${params.game},\n   344→          ${params.creator},\n   345→          ${params.serverKey},\n   346→          ${params.secret},\n   347→          ${params.commitment},\n   348→          ${params.amountLamports},\n   349→          ${params.side},\n   350→          ${params.matchId},\n   351→          ${params.phase},\n   352→          ${params.entries ? sql.json(params.entries) : null}\n   353→        )\n   354→        RETURNING *\n   355→      `;\n   356→      return normalizeRound(rows[0]!);\n   357→    },\n   358→\n   359→    async deleteRoundByPda(pda) {\n   360→      const rows = await sql<{ pda: string }[]>`\n   361→        DELETE FROM rounds WHERE pda = ${pda}\n   362→        RETURNING pda\n   363→      `;\n   364→      return rows.length > 0;\n   365→    },\n   366→\n   367→    async updateRoundPhase(pda, newPhase, updates) {\n   368→      // Fetch current phase to validate transition\n   369→      const current = await sql<Pick<Round, \"phase\">[]>`\n   370→        SELECT phase FROM rounds WHERE pda = ${pda}\n   371→      `;\n   372→\n   373→      if (current.length === 0) {\n   374→        throw new Error(`Round not found: ${pda}`);\n   375→      }\n   376→\n   377→      const currentPhase = current[0]!.phase as RoundPhase;\n   378→      assertPhaseTransition(currentPhase, newPhase);\n   379→\n   380→      // Build the update — always set phase + updated_at\n   381→      const rows = await sql<Round[]>`\n   382→        UPDATE rounds SET\n   383→          phase = ${newPhase},\n   384→          updated_at = now(),\n   385→          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n   386→          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n   387→          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n   388→          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n   389→          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n   390→          winner = COALESCE(${updates?.winner ?? null}, winner)\n   391→        WHERE pda = ${pda}\n   392→        RETURNING *\n   393→      `;\n   394→\n   395→      return normalizeRound(rows[0]!);\n   396→    },\n   397→\n   398→    async updateRoundEntries(pda, entries) {\n   399→      const rows = await sql<Round[]>`\n   400→        UPDATE rounds SET\n   401→          entries = ${sql.json(entries)},\n   402→          updated_at = now()\n   403→        WHERE pda = ${pda}\n   404→        RETURNING *\n   405→      `;\n   406→      if (rows.length === 0) {\n   407→        throw new Error(`Round not found: ${pda}`);\n   408→      }\n   409→      return normalizeRound(rows[0]!);\n   410→    },\n   411→\n   412→    async getRoundByPda(pda) {\n   413→      const rows = await sql<Round[]>`\n   414→        SELECT * FROM rounds WHERE pda = ${pda}\n   415→      `;\n   416→      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   417→    },\n   418→\n   419→    async getRoundByMatchId(matchId) {\n   420→      const rows = await sql<Round[]>`\n   421→        SELECT * FROM rounds WHERE match_id = ${matchId}\n   422→      `;\n   423→      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   424→    },\n   425→\n   426→    async getRoundsByPhase(phase) {\n   427→      const rows = await sql<Round[]>`\n   428→        SELECT * FROM rounds WHERE phase = ${phase}\n   429→      `;\n   430→      return rows.map(normalizeRound);\n   431→    },\n   432→\n   433→    async insertOperatorEvent(pda, eventType, payload) {\n   434→      const rows = await sql<OperatorEvent[]>`\n   435→        INSERT INTO operator_events (pda, event_type, payload)\n   436→        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n   437→        RETURNING *\n   438→      `;\n   439→      return rows[0]!;\n   440→    },\n   441→\n   442→    async getLatestOperatorEvent(pda, eventType) {\n   443→      const rows = await sql<OperatorEvent[]>`\n   444→        SELECT * FROM operator_events\n   445→        WHERE pda = ${pda} AND event_type = ${eventType}\n   446→        ORDER BY id DESC\n   447→        LIMIT 1\n   448→      `;\n   449→      return rows[0];\n   450→    },\n   451→\n   452→    async getLatestOperatorEventsForPdas(pdas, eventType) {\n   453→      if (pdas.length === 0) return new Map();\n   454→      const rows = await sql<OperatorEvent[]>`\n   455→        SELECT DISTINCT ON (pda) *\n   456→        FROM operator_events\n   457→        WHERE pda = ANY(${pdas}) AND event_type = ${eventType}\n   458→        ORDER BY pda, id DESC\n   459→      `;\n   460→      const map = new Map<string, OperatorEvent>();\n   461→      for (const row of rows) {\n   462→        if (row.pda) map.set(row.pda, row);\n   463→      }\n   464→      return map;\n   465→    },\n   466→\n   467→    async getRecentSettledRounds(game, limit) {\n   468→      const rows = await sql<Round[]>`\n   469→        SELECT * FROM rounds\n   470→        WHERE game = ${game} AND phase = 'settled'\n   471→        ORDER BY updated_at DESC\n   472→        LIMIT ${limit}\n   473→      `;\n   474→      return rows.map(normalizeRound);\n   475→    },\n   476→\n   477→    async getUnsettledStats() {\n   478→      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n   479→        SELECT\n   480→          COUNT(*)::text AS count,\n   481→          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n   482→        FROM rounds\n   483→        WHERE phase NOT IN ('settled', 'expired')\n   484→      `;\n   485→      const row = rows[0]!;\n   486→      return {\n   487→        count: parseInt(row.count, 10),\n   488→        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n   489→      };\n   490→    },\n   491→\n   492→    // -----------------------------------------------------------------------\n   493→    // Close Call rounds\n   494→    // -----------------------------------------------------------------------\n   495→\n   496→    async insertCloseCallRound(params) {\n   497→      const rows = await sql<CloseCallRound[]>`\n   498→        INSERT INTO closecall_rounds (round_id, pda, server_key, open_price, open_price_expo)\n   499→        VALUES (\n   500→          ${params.roundId},\n   501→          ${params.pda},\n   502→          ${params.serverKey},\n   503→          ${params.openPrice},\n   504→          ${params.openPriceExpo}\n   505→        )\n   506→        RETURNING *\n   507→      `;\n   508→      return normalizeCloseCallRound(rows[0]!);\n   509→    },\n   510→\n   511→    async getCloseCallRound(roundId) {\n   512→      const rows = await sql<CloseCallRound[]>`\n   513→        SELECT * FROM closecall_rounds WHERE round_id = ${roundId}\n   514→      `;\n   515→      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n   516→    },\n   517→\n   518→    async getCloseCallCurrentRound() {\n   519→      const rows = await sql<CloseCallRound[]>`\n   520→        SELECT * FROM closecall_rounds\n   521→        WHERE phase = 'open'\n   522→        ORDER BY created_at DESC\n   523→        LIMIT 1\n   524→      `;\n   525→      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n   526→    },\n   527→\n   528→    async getCloseCallHistory(limit) {\n   529→      const rows = await sql<CloseCallRound[]>`\n   530→        SELECT * FROM closecall_rounds\n   531→        WHERE phase IN ('settled', 'refunded')\n   532→        ORDER BY settled_at DESC\n   533→        LIMIT ${limit}\n   534→      `;\n   535→      return rows.map(normalizeCloseCallRound);\n   536→    },\n   537→\n   538→    async settleCloseCallRound(roundId, updates) {\n   539→      const rows = await sql<CloseCallRound[]>`\n   540→        UPDATE closecall_rounds SET\n   541→          phase = ${updates.phase},\n   542→          outcome = ${updates.outcome},\n   543→          close_price = COALESCE(${updates.closePrice ?? null}, close_price),\n   544→          green_pool = COALESCE(${updates.greenPool ?? null}, green_pool),\n   545→          red_pool = COALESCE(${updates.redPool ?? null}, red_pool),\n   546→          total_fee = COALESCE(${updates.totalFee ?? null}, total_fee),\n   547→          green_entries = COALESCE(${updates.greenEntries ? sql.json(updates.greenEntries) : null}, green_entries),\n   548→          red_entries = COALESCE(${updates.redEntries ? sql.json(updates.redEntries) : null}, red_entries),\n   549→          settle_tx = COALESCE(${updates.settleTx ?? null}, settle_tx),\n   550→          settled_at = now()\n   551→        WHERE round_id = ${roundId}\n   552→        RETURNING *\n   553→      `;\n   554→      if (rows.length === 0) {\n   555→        throw new Error(`Close Call round not found: ${roundId}`);\n   556→      }\n   557→      return normalizeCloseCallRound(rows[0]!);\n   558→    },\n   559→\n   560→    // -----------------------------------------------------------------------\n   561→    // Transactions\n   562→    // -----------------------------------------------------------------------\n   563→\n   564→    async insertTransaction(params) {\n   565→      await sql`\n   566→        INSERT INTO transactions (wallet, game, match_id, tx_type, amount_lamports, tx_sig)\n   567→        VALUES (\n   568→          ${params.wallet},\n   569→          ${params.game},\n   570→          ${params.matchId},\n   571→          ${params.txType},\n   572→          ${params.amountLamports},\n   573→          ${params.txSig}\n   574→        )\n   575→        ON CONFLICT DO NOTHING\n   576→      `;\n   577→    },\n   578→\n   579→    async insertTransactions(params) {\n   580→      if (params.length === 0) return;\n   581→      const values = params.map((p) => ({\n   582→        wallet: p.wallet,\n   583→        game: p.game,\n   584→        match_id: p.matchId,\n   585→        tx_type: p.txType,\n   586→        amount_lamports: p.amountLamports,\n   587→        tx_sig: p.txSig,\n   588→      }));\n   589→      await sql`\n   590→        INSERT INTO transactions ${sql(values, \"wallet\", \"game\", \"match_id\", \"tx_type\", \"amount_lamports\", \"tx_sig\")}\n   591→        ON CONFLICT DO NOTHING\n   592→      `;\n   593→    },\n   594→\n   595→    async getTransactions(wallet, cursor, limit = 20, game) {\n   596→      const effectiveLimit = Math.min(limit, 50);\n   597→      if (cursor && game) {\n   598→        const rows = await sql<Transaction[]>`\n   599→          SELECT * FROM transactions\n   600→          WHERE wallet = ${wallet} AND id < ${cursor} AND game = ${game}\n   601→          ORDER BY id DESC\n   602→          LIMIT ${effectiveLimit}\n   603→        `;\n   604→        return rows.map(normalizeTransaction);\n   605→      }\n   606→      if (cursor) {\n   607→        const rows = await sql<Transaction[]>`\n   608→          SELECT * FROM transactions\n   609→          WHERE wallet = ${wallet} AND id < ${cursor}\n   610→          ORDER BY id DESC\n   611→          LIMIT ${effectiveLimit}\n   612→        `;\n   613→        return rows.map(normalizeTransaction);\n   614→      }\n   615→      if (game) {\n   616→        const rows = await sql<Transaction[]>`\n   617→          SELECT * FROM transactions\n   618→          WHERE wallet = ${wallet} AND game = ${game}\n   619→          ORDER BY id DESC\n   620→          LIMIT ${effectiveLimit}\n   621→        `;\n   622→        return rows.map(normalizeTransaction);\n   623→      }\n   624→      const rows = await sql<Transaction[]>`\n   625→        SELECT * FROM transactions\n   626→        WHERE wallet = ${wallet}\n   627→        ORDER BY id DESC\n   628→        LIMIT ${effectiveLimit}\n   629→      `;\n   630→      return rows.map(normalizeTransaction);\n   631→    },\n   632→\n   633→    // -----------------------------------------------------------------------\n   634→    // Referral — codes\n   635→    // -----------------------------------------------------------------------\n   636→\n   637→    async insertReferralCode(wallet, code) {\n   638→      const rows = await sql<ReferralCode[]>`\n   639→        INSERT INTO referral_codes (wallet, code)\n   640→        VALUES (${wallet}, ${code})\n   641→        RETURNING *\n   642→      `;\n   643→      return rows[0]!;\n   644→    },\n   645→\n   646→    async getReferralCodeByWallet(wallet) {\n   647→      const rows = await sql<ReferralCode[]>`\n   648→        SELECT * FROM referral_codes WHERE wallet = ${wallet}\n   649→      `;\n   650→      return rows[0];\n   651→    },\n   652→\n   653→    async getReferralCodeByCode(code) {\n   654→      const rows = await sql<ReferralCode[]>`\n   655→        SELECT * FROM referral_codes WHERE code = ${code}\n   656→      `;\n   657→      return rows[0];\n   658→    },\n   659→\n   660→    async upsertReferralCode(wallet, code) {\n   661→      const rows = await sql<ReferralCode[]>`\n   662→        INSERT INTO referral_codes (wallet, code)\n   663→        VALUES (${wallet}, ${code})\n   664→        ON CONFLICT (wallet) DO UPDATE SET\n   665→          code = ${code},\n   666→          updated_at = now()\n   667→        RETURNING *\n   668→      `;\n   669→      return rows[0]!;\n   670→    },\n   671→\n   672→    async close() {\n   673→      await sql.end();\n   674→    },\n   675→  };\n   676→}\n   677→"}]},"parent_tool_use_id":"toolu_018ZJ6GocB8KERc3aGCnSCER","session_id":"c89a03cc-8748-4b08-a745-25648f76e1cb","uuid":"57f47be9-0417-493c-a433-0e6746f7e0cb","timestamp":"2026-03-25T10:20:09.114Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J5WThPaZoKqPWBZ7vRuion","type":"tool_result","content":"     1→-- 011_referral.sql — Referral system tables (spec 300).\n     2→--\n     3→-- Off-chain referral economics: player-chosen codes, referral linking,\n     4→-- per-game earnings tracking, claim payouts, and KOL custom rates.\n     5→-- No on-chain program changes — all tables are backend-only.\n     6→\n     7→-- Referral codes: one active code per wallet\n     8→CREATE TABLE IF NOT EXISTS referral_codes (\n     9→  id              SERIAL       PRIMARY KEY,\n    10→  wallet          TEXT         NOT NULL UNIQUE,\n    11→  code            TEXT         NOT NULL UNIQUE,  -- player-chosen, 3-16 chars [a-z0-9-]\n    12→  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    13→  updated_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n    14→);\n    15→\n    16→-- Referral links: immutable referrer→referee binding (one referrer per player)\n    17→CREATE TABLE IF NOT EXISTS referral_links (\n    18→  id              SERIAL       PRIMARY KEY,\n    19→  referrer_wallet TEXT         NOT NULL,\n    20→  referee_wallet  TEXT         NOT NULL UNIQUE,\n    21→  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n    22→);\n    23→\n    24→CREATE INDEX IF NOT EXISTS idx_referral_links_referrer\n    25→  ON referral_links (referrer_wallet);\n    26→\n    27→-- Referral earnings: one row per referee per round (idempotency guard)\n    28→CREATE TABLE IF NOT EXISTS referral_earnings (\n    29→  id                        SERIAL       PRIMARY KEY,\n    30→  referrer_wallet           TEXT         NOT NULL,\n    31→  referee_wallet            TEXT         NOT NULL,\n    32→  round_id                  TEXT         NOT NULL,\n    33→  game_type                 TEXT         NOT NULL,\n    34→  wager_lamports            BIGINT       NOT NULL,\n    35→  fee_lamports              BIGINT       NOT NULL,\n    36→  referrer_earned_lamports  BIGINT       NOT NULL,\n    37→  referrer_rate_bps         INTEGER      NOT NULL,\n    38→  referee_rebate_lamports   BIGINT       NOT NULL,\n    39→  referee_rebate_rate_bps   INTEGER      NOT NULL,\n    40→  created_at                TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    41→\n    42→  CONSTRAINT uq_referral_earnings_referee_round\n    43→    UNIQUE (referee_wallet, round_id)\n    44→);\n    45→\n    46→CREATE INDEX IF NOT EXISTS idx_referral_earnings_referrer\n    47→  ON referral_earnings (referrer_wallet, created_at);\n    48→\n    49→CREATE INDEX IF NOT EXISTS idx_referral_earnings_referee\n    50→  ON referral_earnings (referee_wallet, created_at);\n    51→\n    52→CREATE INDEX IF NOT EXISTS idx_referral_earnings_round_id\n    53→  ON referral_earnings (round_id);\n    54→\n    55→-- Referral claims: async SOL payout tracking\n    56→CREATE TABLE IF NOT EXISTS referral_claims (\n    57→  id              UUID         PRIMARY KEY DEFAULT gen_random_uuid(),\n    58→  wallet          TEXT         NOT NULL,\n    59→  amount_lamports BIGINT       NOT NULL,\n    60→  status          TEXT         NOT NULL DEFAULT 'pending',\n    61→  tx_signature    TEXT,\n    62→  error           TEXT,\n    63→  requested_at    TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    64→  processed_at    TIMESTAMPTZ,\n    65→\n    66→  CONSTRAINT chk_referral_claims_status\n    67→    CHECK (status IN ('pending', 'processing', 'completed', 'failed'))\n    68→);\n    69→\n    70→CREATE INDEX IF NOT EXISTS idx_referral_claims_wallet\n    71→  ON referral_claims (wallet, requested_at);\n    72→\n    73→CREATE INDEX IF NOT EXISTS idx_referral_claims_status\n    74→  ON referral_claims (status)\n    75→  WHERE status IN ('pending', 'processing');\n    76→\n    77→-- KOL custom referrer rates (overrides default 1000 bps)\n    78→CREATE TABLE IF NOT EXISTS referral_kol_rates (\n    79→  wallet          TEXT         PRIMARY KEY,\n    80→  rate_bps        INTEGER      NOT NULL,\n    81→  set_by          TEXT         NOT NULL,\n    82→  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    83→  updated_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n    84→);\n    85→"}]},"parent_tool_use_id":"toolu_018ZJ6GocB8KERc3aGCnSCER","session_id":"c89a03cc-8748-4b08-a745-25648f76e1cb","uuid":"fdc7e99e-439d-4210-a31e-38d473342d78","timestamp":"2026-03-25T10:20:09.201Z"}
