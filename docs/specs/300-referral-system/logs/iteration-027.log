.then((data) => {\n        if (!cancelled) setReferrerWallet(data.referrerWallet);\n      })\n      .catch(() => {\n        // 404 = no referrer, which is fine\n        if (!cancelled) setReferrerWallet(null);\n      })\n      .finally(() => {\n        if (!cancelled) setReferrerLoading(false);\n      });\n    return () => { cancelled = true; };\n  }, [accessToken]);\n\n  const handleApplyReferral = async () => {\n    if (!accessToken) return;\n    const code = referralCode.toLowerCase().trim();\n    if (!code) {\n      setReferralError(\"Please enter a referral code\");\n      return;\n    }\n    setReferralError(null);\n    setReferralApplying(true);\n    try {\n      const result = await applyReferralCode(accessToken, code);\n      setReferrerWallet(result.referrer);\n      setReferralSuccess(true);\n      setReferralCode(\"\");\n    } catch (err) {\n      const msg = err instanceof Error ? err.message : \"Failed to apply referral code\";\n      if (msg.includes(\"Cannot refer yourself\") || msg.includes(\"SELF_REFERRAL\")) {\n        setReferralError(\"You cannot use your own referral code\");\n      } else if (msg.includes(\"already linked\") || msg.includes(\"ALREADY_LINKED\")) {\n        setReferralError(\"You are already linked to a referrer\");\n      } else if (msg.includes(\"not found\") || msg.includes(\"NOT_FOUND\") || msg.includes(\"does not exist\")) {\n        setReferralError(\"Referral code not found\");\n      } else {\n        setReferralError(msg);\n      }\n    } finally {\n      setReferralApplying(false);\n    }\n  };","originalFile":"/**\n * ProfileSettings - Settings tab content\n *\n * Shows connected wallet, referral code input, and social connections.\n * Avatar selection is handled via modal from the profile header.\n * Username editing is handled inline in the profile header.\n */\n\nimport { useState, useEffect } from \"react\";\nimport type { PlayerProfile } from \"../types\";\nimport { usePlayerProfile } from \"../context/PlayerProfileContext\";\nimport { truncateAddress } from \"../utils/mock-simulation\";\nimport { useSession } from \"../../../context/SessionContext\";\nimport { getReferrer, applyReferralCode } from \"../../../lib/referral-api\";\n\ninterface ProfileSettingsProps {\n  profile: PlayerProfile;\n}\n\nexport function ProfileSettings({ profile }: ProfileSettingsProps) {\n  const {\n    connectDiscord,\n    disconnectDiscord,\n    connectTwitter,\n    disconnectTwitter,\n  } = usePlayerProfile();\n\n  const [connectingDiscord, setConnectingDiscord] = useState(false);\n  const [connectingTwitter, setConnectingTwitter] = useState(false);\n\n  const handleConnectDiscord = async () => {\n    setConnectingDiscord(true);\n    try {\n      await connectDiscord();\n    } catch (error) {\n      console.error(\"Failed to connect Discord:\", error);\n    } finally {\n      setConnectingDiscord(false);\n    }\n  };\n\n  const handleDisconnectDiscord = async () => {\n    setConnectingDiscord(true);\n    try {\n      await disconnectDiscord();\n    } catch (error) {\n      console.error(\"Failed to disconnect Discord:\", error);\n    } finally {\n      setConnectingDiscord(false);\n    }\n  };\n\n  const handleConnectTwitter = async () => {\n    setConnectingTwitter(true);\n    try {\n      await connectTwitter();\n    } catch (error) {\n      console.error(\"Failed to connect Twitter:\", error);\n    } finally {\n      setConnectingTwitter(false);\n    }\n  };\n\n  const handleDisconnectTwitter = async () => {\n    setConnectingTwitter(true);\n    try {\n      await disconnectTwitter();\n    } catch (error) {\n      console.error(\"Failed to disconnect Twitter:\", error);\n    } finally {\n      setConnectingTwitter(false);\n    }\n  };\n\n  return (\n    <div className=\"profile-settings\">\n      {/* Connected Wallet */}\n      <div className=\"profile-settings__section\">\n        <h3 className=\"profile-settings__section-title\">Connected Wallet</h3>\n        <div className=\"profile-settings__wallet\">\n          <div className=\"profile-settings__wallet-icon\">\n            <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n              <path d=\"M21 18v1c0 1.1-.9 2-2 2H5c-1.11 0-2-.9-2-2V5c0-1.1.89-2 2-2h14c1.1 0 2 .9 2 2v1h-9c-1.11 0-2 .9-2 2v8c0 1.1.89 2 2 2h9zm-9-2h10V8H12v8zm4-2.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z\"/>\n            </svg>\n          </div>\n          <div className=\"profile-settings__wallet-info\">\n            <div className=\"profile-settings__wallet-address\">{truncateAddress(profile.address)}</div>\n            <div className=\"profile-settings__wallet-full\" title={profile.address}>\n              {profile.address}\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* Social Connections */}\n      <div className=\"profile-settings__section\">\n        <h3 className=\"profile-settings__section-title\">Connected Socials</h3>\n        <div className=\"profile-socials__list\">\n          {/* Discord */}\n          <div className=\"profile-socials__item\">\n            <div className=\"profile-socials__icon\">\n              <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                <path d=\"M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6