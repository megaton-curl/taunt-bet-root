{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GnGL1fett6NDTZAErmHUrA","type":"tool_result","content":"     1→/**\n     2→ * Thin fetch wrappers for the /referral/* backend endpoints.\n     3→ * All calls require JWT Bearer auth from useSession().accessToken.\n     4→ */\n     5→\n     6→const BACKEND_URL = (\n     7→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n     8→    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n     9→).replace(/\\/$/, \"\");\n    10→\n    11→/* ── Response types ─────────────────────────────────────────────── */\n    12→\n    13→export interface ReferralCodeResponse {\n    14→  code: string;\n    15→  url: string;\n    16→}\n    17→\n    18→export interface ApplyReferralResponse {\n    19→  referrer: string;\n    20→  benefit: string;\n    21→}\n    22→\n    23→export interface ReferralStatsResponse {\n    24→  referredCount: number;\n    25→  activeCount: number;\n    26→  totalVolumeLamports: string;\n    27→  totalEarnedLamports: string;\n    28→  totalRebateLamports: string;\n    29→  pendingLamports: string;\n    30→}\n    31→\n    32→export interface ReferralEarningItem {\n    33→  roundId: string;\n    34→  gameType: string;\n    35→  refereeWallet: string;\n    36→  wagerLamports: string;\n    37→  earnedLamports: string;\n    38→  createdAt: string;\n    39→}\n    40→\n    41→export interface ReferralEarningsResponse {\n    42→  items: ReferralEarningItem[];\n    43→  pagination: { page: number; totalPages: number };\n    44→}\n    45→\n    46→export interface ClaimResponse {\n    47→  claimId: string;\n    48→  amountLamports: string;\n    49→  status: \"pending\" | \"completed\" | \"failed\";\n    50→  txSignature?: string;\n    51→}\n    52→\n    53→/* ── Helpers ────────────────────────────────────────────────────── */\n    54→\n    55→async function parseResponse<T>(res: Response): Promise<T> {\n    56→  const json = await res.json();\n    57→  if (!res.ok) {\n    58→    const err = json?.error;\n    59→    const msg =\n    60→      typeof err === \"string\"\n    61→        ? err\n    62→        : typeof err?.message === \"string\"\n    63→          ? err.message\n    64→          : `Referral request failed (${res.status})`;\n    65→    throw new Error(msg);\n    66→  }\n    67→  return json as T;\n    68→}\n    69→\n    70→function authHeaders(token: string): Record<string, string> {\n    71→  return {\n    72→    \"Content-Type\": \"application/json\",\n    73→    Authorization: `Bearer ${token}`,\n    74→  };\n    75→}\n    76→\n    77→/* ── API functions ──────────────────────────────────────────────── */\n    78→\n    79→/** Set (or replace) the authenticated player's referral code. */\n    80→export async function setReferralCode(\n    81→  token: string,\n    82→  code: string,\n    83→): Promise<ReferralCodeResponse> {\n    84→  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    85→    method: \"POST\",\n    86→    headers: authHeaders(token),\n    87→    body: JSON.stringify({ code }),\n    88→  });\n    89→  return parseResponse<ReferralCodeResponse>(res);\n    90→}\n    91→\n    92→/** Get the authenticated player's current referral code, or throw on 404. */\n    93→export async function getReferralCode(\n    94→  token: string,\n    95→): Promise<ReferralCodeResponse> {\n    96→  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    97→    headers: authHeaders(token),\n    98→  });\n    99→  return parseResponse<ReferralCodeResponse>(res);\n   100→}\n   101→\n   102→/** Apply a referral code to the authenticated player (link to referrer). */\n   103→export async function applyReferralCode(\n   104→  token: string,\n   105→  code: string,\n   106→): Promise<ApplyReferralResponse> {\n   107→  const res = await fetch(`${BACKEND_URL}/referral/apply`, {\n   108→    method: \"POST\",\n   109→    headers: authHeaders(token),\n   110→    body: JSON.stringify({ code }),\n   111→  });\n   112→  return parseResponse<ApplyReferralResponse>(res);\n   113→}\n   114→\n   115→/** Get referral summary stats for the authenticated player. */\n   116→export async function getReferralStats(\n   117→  token: string,\n   118→): Promise<ReferralStatsResponse> {\n   119→  const res = await fetch(`${BACKEND_URL}/referral/stats`, {\n   120→    headers: authHeaders(token),\n   121→  });\n   122→  return parseResponse<ReferralStatsResponse>(res);\n   123→}\n   124→\n   125→/** Get paginated per-game referral earnings log. */\n   126→export async function getReferralEarnings(\n   127→  token: string,\n   128→  page?: number,\n   129→  limit?: number,\n   130→): Promise<ReferralEarningsResponse> {\n   131→  const parts: string[] = [];\n   132→  if (page != null) parts.push(`page=${page}`);\n   133→  if (limit != null) parts.push(`limit=${limit}`);\n   134→  const qs = parts.length ? `?${parts.join(\"&\")}` : \"\";\n   135→  const res = await fetch(`${BACKEND_URL}/referral/earnings${qs}`, {\n   136→    headers: authHeaders(token),\n   137→  });\n   138→  return parseResponse<ReferralEarningsResponse>(res);\n   139→}\n   140→\n   141→/** Request an async claim of all pending referral earnings. Returns 202. */\n   142→export async function requestReferralClaim(\n   143→  token: string,\n   144→): Promise<ClaimResponse> {\n   145→  const res = await fetch(`${BACKEND_URL}/referral/claim`, {\n   146→    method: \"POST\",\n   147→    headers: authHeaders(token),\n   148→  });\n   149→  return parseResponse<ClaimResponse>(res);\n   150→}\n   151→\n   152→/** Poll the status of an existing claim by ID. */\n   153→export async function pollClaimStatus(\n   154→  token: string,\n   155→  claimId: string,\n   156→): Promise<ClaimResponse> {\n   157→  const res = await fetch(`${BACKEND_URL}/referral/claim/${claimId}`, {\n   158→    headers: authHeaders(token),\n   159→  });\n   160→  return parseResponse<ClaimResponse>(res);\n   161→}\n   162→"}]},"parent_tool_use_id":null,"session_id":"eb5de170-2e49-4887-a19e-0983dec4d654","uuid":"5cbf1bfa-b1cd-44b1-85b9-99a88c037655","timestamp":"2026-03-25T13:39:13.388Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/lib/referral-api.ts","content":"/**\n * Thin fetch wrappers for the /referral/* backend endpoints.\n * All calls require JWT Bearer auth from useSession().accessToken.\n */\n\nconst BACKEND_URL = (\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n).replace(/\\/$/, \"\");\n\n/* ── Response types ─────────────────────────────────────────────── */\n\nexport interface ReferralCodeResponse {\n  code: string;\n  url: string;\n}\n\nexport interface ApplyReferralResponse {\n  referrer: string;\n  benefit: string;\n}\n\nexport interface ReferralStatsResponse {\n  referredCount: number;\n  activeCount: number;\n  totalVolumeLamports: string;\n  totalEarnedLamports: string;\n  totalRebateLamports: string;\n  pendingLamports: string;\n}\n\nexport interface ReferralEarningItem {\n  roundId: string;\n  gameType: string;\n  refereeWallet: string;\n  wagerLamports: string;\n  earnedLamports: string;\n  createdAt: string;\n}\n\nexport interface ReferralEarningsResponse {\n  items: ReferralEarningItem[];\n  pagination: { page: number; totalPages: number };\n}\n\nexport interface ClaimResponse {\n  claimId: string;\n  amountLamports: string;\n  status: \"pending\" | \"completed\" | \"failed\";\n  txSignature?: string;\n}\n\n/* ── Helpers ────────────────────────────────────────────────────── */\n\nasync function parseResponse<T>(res: Response): Promise<T> {\n  const json = await res.json();\n  if (!res.ok) {\n    const err = json?.error;\n    const msg =\n      typeof err === \"string\"\n        ? err\n        : typeof err?.message === \"string\"\n          ? err.message\n          : `Referral request failed (${res.status})`;\n    throw new Error(msg);\n  }\n  return json as T;\n}\n\nfunction authHeaders(token: string): Record<string, string> {\n  return {\n    \"Content-Type\": \"application/json\",\n    Authorization: `Bearer ${token}`,\n  };\n}\n\n/* ── API functions ──────────────────────────────────────────────── */\n\n/** Set (or replace) the authenticated player's referral code. */\nexport async function setReferralCode(\n  token: string,\n  code: string,\n): Promise<ReferralCodeResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    method: \"POST\",\n    headers: authHeaders(token),\n    body: JSON.stringify({ code }),\n  });\n  return parseResponse<ReferralCodeResponse>(res);\n}\n\n/** Get the authenticated player's current referral code, or throw on 404. */\nexport async function getReferralCode(\n  token: string,\n): Promise<ReferralCodeResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ReferralCodeResponse>(res);\n}\n\n/** Apply a referral code to the authenticated player (link to referrer). */\nexport async function applyReferralCode(\n  token: string,\n  code: string,\n): Promise<ApplyReferralResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/apply`, {\n    method: \"POST\",\n    headers: authHeaders(token),\n    body: JSON.stringify({ code }),\n  });\n  return parseResponse<ApplyReferralResponse>(res);\n}\n\n/** Get referral summary stats for the authenticated player. */\nexport async function getReferralStats(\n  token: string,\n): Promise<ReferralStatsResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/stats`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ReferralStatsResponse>(res);\n}\n\n/** Get paginated per-game referral earnings log. */\nexport async function getReferralEarnings(\n  token: string,\n  page?: number,\n  limit?: number,\n): Promise<ReferralEarningsResponse> {\n  const parts: string[] = [];\n  if (page != null) parts.push(`page=${page}`);\n  if (limit != null) parts.push(`limit=${limit}`);\n  const qs = parts.length ? `?${parts.join(\"&\")}` : \"\";\n  const res = await fetch(`${BACKEND_URL}/referral/earnings${qs}`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ReferralEarningsResponse>(res);\n}\n\n/** Request an async claim of all pending referral earnings. Returns 202. */\nexport async function requestReferralClaim(\n  token: string,\n): Promise<ClaimResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/claim`, {\n    method: \"POST\",\n    headers: authHeaders(token),\n  });\n  return parseResponse<ClaimResponse>(res);\n}\n\n/** Poll the status of an existing claim by ID. */\nexport async function pollClaimStatus(\n  token: string,\n  claimId: string,\n): Promise<ClaimResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/claim/${claimId}`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ClaimResponse>(res);\n}\n","numLines":162,"startLine":1,"totalLines":162}}}
