{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DbUaznJJAUACM6kkhuAZYZ","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/lib/referral-api.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"eb5de170-2e49-4887-a19e-0983dec4d654","uuid":"0388d4a8-d9d0-44d4-a14f-cd413c78918e","timestamp":"2026-03-25T13:40:13.931Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/lib/referral-api.ts","oldString":"export interface ReferralStatsResponse {","newString":"export interface ReferrerResponse {\n  referrerWallet: string;\n  linkedAt: string;\n}\n\nexport interface ReferralStatsResponse {","originalFile":"/**\n * Thin fetch wrappers for the /referral/* backend endpoints.\n * All calls require JWT Bearer auth from useSession().accessToken.\n */\n\nconst BACKEND_URL = (\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n).replace(/\\/$/, \"\");\n\n/* ── Response types ─────────────────────────────────────────────── */\n\nexport interface ReferralCodeResponse {\n  code: string;\n  url: string;\n}\n\nexport interface ApplyReferralResponse {\n  referrer: string;\n  benefit: string;\n}\n\nexport interface ReferralStatsResponse {\n  referredCount: number;\n  activeCount: number;\n  totalVolumeLamports: string;\n  totalEarnedLamports: string;\n  totalRebateLamports: string;\n  pendingLamports: string;\n}\n\nexport interface ReferralEarningItem {\n  roundId: string;\n  gameType: string;\n  refereeWallet: string;\n  wagerLamports: string;\n  earnedLamports: string;\n  createdAt: string;\n}\n\nexport interface ReferralEarningsResponse {\n  items: ReferralEarningItem[];\n  pagination: { page: number; totalPages: number };\n}\n\nexport interface ClaimResponse {\n  claimId: string;\n  amountLamports: string;\n  status: \"pending\" | \"completed\" | \"failed\";\n  txSignature?: string;\n}\n\n/* ── Helpers ────────────────────────────────────────────────────── */\n\nasync function parseResponse<T>(res: Response): Promise<T> {\n  const json = await res.json();\n  if (!res.ok) {\n    const err = json?.error;\n    const msg =\n      typeof err === \"string\"\n        ? err\n        : typeof err?.message === \"string\"\n          ? err.message\n          : `Referral request failed (${res.status})`;\n    throw new Error(msg);\n  }\n  return json as T;\n}\n\nfunction authHeaders(token: string): Record<string, string> {\n  return {\n    \"Content-Type\": \"application/json\",\n    Authorization: `Bearer ${token}`,\n  };\n}\n\n/* ── API functions ──────────────────────────────────────────────── */\n\n/** Set (or replace) the authenticated player's referral code. */\nexport async function setReferralCode(\n  token: string,\n  code: string,\n): Promise<ReferralCodeResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    method: \"POST\",\n    headers: authHeaders(token),\n    body: JSON.stringify({ code }),\n  });\n  return parseResponse<ReferralCodeResponse>(res);\n}\n\n/** Get the authenticated player's current referral code, or throw on 404. */\nexport async function getReferralCode(\n  token: string,\n): Promise<ReferralCodeResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ReferralCodeResponse>(res);\n}\n\n/** Apply a referral code to the authenticated player (link to referrer). */\nexport async function applyReferralCode(\n  token: string,\n  code: string,\n): Promise<ApplyReferralResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/apply`, {\n    method: \"POST\",\n    headers: authHeaders(token),\n    body: JSON.stringify({ code }),\n  });\n  return parseResponse<ApplyReferralResponse>(res);\n}\n\n/** Get referral summary stats for the authenticated player. */\nexport async function getReferralStats(\n  token: string,\n): Promise<ReferralStatsResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/stats`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ReferralStatsResponse>(res);\n}\n\n/** Get paginated per-game referral earnings log. */\nexport async function getReferralEarnings(\n  token: string,\n  page?: number,\n  limit?: number,\n): Promise<ReferralEarningsResponse> {\n  const parts: string[] = [];\n  if (page != null) parts.push(`page=${page}`);\n  if (limit != null) parts.push(`limit=${limit}`);\n  const qs = parts.length ? `?${parts.join(\"&\")}` : \"\";\n  const res = await fetch(`${BACKEND_URL}/referral/earnings${qs}`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ReferralEarningsResponse>(res);\n}\n\n/** Request an async claim of all pending referral earnings. Returns 202. */\nexport async function requestReferralClaim(\n  token: string,\n): Promise<ClaimResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/claim`, {\n    method: \"POST\",\n    headers: authHeaders(token),\n  });\n  return parseResponse<ClaimResponse>(res);\n}\n\n/** Poll the status of an existing claim by ID. */\nexport async function pollClaimStatus(\n  token: string,\n  claimId: string,\n): Promise<ClaimResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/claim/${claimId}`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ClaimResponse>(res);\n}\n","structuredPatch":[{"oldStart":20,"oldLines":6,"newStart":20,"newLines":11,"lines":["   benefit: string;"," }"," ","+export interface ReferrerResponse {","+  referrerWallet: string;","+  linkedAt: string;","+}","+"," export interface ReferralStatsResponse {","   referredCount: number;","   activeCount: number;"]}],"userModified":false,"replaceAll":false}}
