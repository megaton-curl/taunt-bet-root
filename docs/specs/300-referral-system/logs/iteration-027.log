{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019EXeYaUYim9EoXZtLNTbuy","type":"tool_result","content":"     1→import { useSession } from \"../../context/SessionContext\";\n     2→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n     3→import { ReferralLinkCard } from \"./ReferralLinkCard\";\n     4→import { ReferralStatsCard } from \"./ReferralStatsCard\";\n     5→import { ReferralClaimCard } from \"./ReferralClaimCard\";\n     6→import { ReferralEarningsTable } from \"./ReferralEarningsTable\";\n     7→\n     8→export function ReferralPage() {\n     9→  const { isAuthenticated } = useSession();\n    10→  const { connected } = useWallet();\n    11→\n    12→  if (!connected || !isAuthenticated) {\n    13→    return (\n    14→      <div className=\"referral-page\">\n    15→        <div className=\"referral-page__connect\">\n    16→          <h2>Referral Program</h2>\n    17→          <p>\n    18→            Earn <strong>10% of the platform fee</strong> from every game your\n    19→            referred players complete — forever. Your referees get a{\" \"}\n    20→            <strong>10% fee rebate</strong> on all their games too.\n    21→          </p>\n    22→          <p>Connect your wallet to get started.</p>\n    23→        </div>\n    24→      </div>\n    25→    );\n    26→  }\n    27→\n    28→  return (\n    29→    <div className=\"referral-page\">\n    30→      <div className=\"referral-page__header\">\n    31→        <h1 className=\"referral-page__title\">Referrals</h1>\n    32→        <p className=\"referral-page__subtitle\">\n    33→          Share your link, earn from every game your friends play\n    34→        </p>\n    35→      </div>\n    36→\n    37→      <div className=\"referral-page__content\">\n    38→        <ReferralLinkCard />\n    39→        <ReferralStatsCard />\n    40→        <ReferralClaimCard />\n    41→        <ReferralEarningsTable />\n    42→      </div>\n    43→    </div>\n    44→  );\n    45→}\n    46→"}]},"parent_tool_use_id":"toolu_01Y23uHuJLb188RP28MGNAiH","session_id":"eb5de170-2e49-4887-a19e-0983dec4d654","uuid":"ad4dead8-bad1-4a59-a9c8-0bf3c8bf0baf","timestamp":"2026-03-25T13:38:14.130Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012UeWLvFV3PtyNnHfwFPFuA","type":"tool_result","content":"     1→export { useReferralApply } from \"./hooks/useReferralApply\";\n     2→export { ReferralPage } from \"./ReferralPage\";\n     3→"}]},"parent_tool_use_id":"toolu_01Y23uHuJLb188RP28MGNAiH","session_id":"eb5de170-2e49-4887-a19e-0983dec4d654","uuid":"9a860d23-29ed-49c6-888b-8d8ca0cbff27","timestamp":"2026-03-25T13:38:14.163Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CfZBNyuCte3pbJZLQzvgEf","type":"tool_result","content":"     1→import { useEffect, useRef } from \"react\";\n     2→import { useSession } from \"../../../context/SessionContext\";\n     3→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n     4→import { applyReferralCode } from \"../../../lib/referral-api\";\n     5→\n     6→const STORAGE_KEY = \"referral_code\";\n     7→\n     8→/**\n     9→ * On authentication, if a referral code is stored in localStorage (from /r/:code),\n    10→ * auto-apply it via POST /referral/apply. Clears storage on success or permanent\n    11→ * failure (invalid code, already linked, self-referral). Keeps on transient failure\n    12→ * (network error) so it retries next auth.\n    13→ */\n    14→export function useReferralApply() {\n    15→  const { isAuthenticated, accessToken } = useSession();\n    16→  const { address } = useWallet();\n    17→  const appliedRef = useRef(false);\n    18→\n    19→  useEffect(() => {\n    20→    if (!isAuthenticated || !accessToken || !address) {\n    21→      appliedRef.current = false;\n    22→      return;\n    23→    }\n    24→\n    25→    // Prevent duplicate calls within the same auth session\n    26→    if (appliedRef.current) return;\n    27→\n    28→    let stored: string | null = null;\n    29→    try {\n    30→      stored = localStorage.getItem(STORAGE_KEY);\n    31→    } catch {\n    32→      // localStorage unavailable\n    33→      return;\n    34→    }\n    35→\n    36→    if (!stored) return;\n    37→\n    38→    let code: string;\n    39→    try {\n    40→      const parsed = JSON.parse(stored);\n    41→      code = parsed?.code;\n    42→    } catch {\n    43→      // Corrupt data — remove it\n    44→      try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n    45→      return;\n    46→    }\n    47→\n    48→    if (!code || typeof code !== \"string\") {\n    49→      try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n    50→      return;\n    51→    }\n    52→\n    53→    appliedRef.current = true;\n    54→\n    55→    applyReferralCode(accessToken, code)\n    56→      .then(() => {\n    57→        try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n    58→        // TODO: replace with toast notification when toast system is implemented\n    59→        console.warn(\"[referral] Referral code applied successfully\");\n    60→      })\n    61→      .catch((err: Error) => {\n    62→        const msg = err.message ?? \"\";\n    63→        // Permanent failures — code invalid, already linked, self-referral\n    64→        const isPermanent =\n    65→          msg.includes(\"ALREADY_LINKED\") ||\n    66→          msg.includes(\"SELF_REFERRAL\") ||\n    67→          msg.includes(\"NOT_FOUND\") ||\n    68→          msg.includes(\"INVALID\") ||\n    69→          msg.includes(\"already linked\") ||\n    70→          msg.includes(\"not found\") ||\n    71→          msg.includes(\"Cannot refer yourself\");\n    72→\n    73→        if (isPermanent) {\n    74→          try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n    75→        }\n    76→        // Transient failures (network, 500): keep localStorage for retry on next auth\n    77→      });\n    78→  }, [isAuthenticated, accessToken, address]);\n    79→}\n    80→"}]},"parent_tool_use_id":"toolu_01Y23uHuJLb188RP28MGNAiH","session_id":"eb5de170-2e49-4887-a19e-0983dec4d654","uuid":"aa1cbe2f-9c42-4c33-aed7-1ea4d5dd9502","timestamp":"2026-03-25T13:38:14.179Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016VXeUWjrbmsNhzTzepK3HZ","type":"tool_result","content":"     1→/**\n     2→ * Thin fetch wrappers for the /referral/* backend endpoints.\n     3→ * All calls require JWT Bearer auth from useSession().accessToken.\n     4→ */\n     5→\n     6→const BACKEND_URL = (\n     7→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n     8→    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n     9→).replace(/\\/$/, \"\");\n    10→\n    11→/* ── Response types ─────────────────────────────────────────────── */\n    12→\n    13→export interface ReferralCodeResponse {\n    14→  code: string;\n    15→  url: string;\n    16→}\n    17→\n    18→export interface ApplyReferralResponse {\n    19→  referrer: string;\n    20→  benefit: string;\n    21→}\n    22→\n    23→export interface ReferralStatsResponse {\n    24→  referredCount: number;\n    25→  activeCount: number;\n    26→  totalVolumeLamports: string;\n    27→  totalEarnedLamports: string;\n    28→  totalRebateLamports: string;\n    29→  pendingLamports: string;\n    30→}\n    31→\n    32→export interface ReferralEarningItem {\n    33→  roundId: string;\n    34→  gameType: string;\n    35→  refereeWallet: string;\n    36→  wagerLamports: string;\n    37→  earnedLamports: string;\n    38→  createdAt: string;\n    39→}\n    40→\n    41→export interface ReferralEarningsResponse {\n    42→  items: ReferralEarningItem[];\n    43→  pagination: { page: number; totalPages: number };\n    44→}\n    45→\n    46→export interface ClaimResponse {\n    47→  claimId: string;\n    48→  amountLamports: string;\n    49→  status: \"pending\" | \"completed\" | \"failed\";\n    50→  txSignature?: string;\n    51→}\n    52→\n    53→/* ── Helpers ────────────────────────────────────────────────────── */\n    54→\n    55→async function parseResponse<T>(res: Response): Promise<T> {\n    56→  const json = await res.json();\n    57→  if (!res.ok) {\n    58→    const err = json?.error;\n    59→    const msg =\n    60→      typeof err === \"string\"\n    61→        ? err\n    62→        : typeof err?.message === \"string\"\n    63→          ? err.message\n    64→          : `Referral request failed (${res.status})`;\n    65→    throw new Error(msg);\n    66→  }\n    67→  return json as T;\n    68→}\n    69→\n    70→function authHeaders(token: string): Record<string, string> {\n    71→  return {\n    72→    \"Content-Type\": \"application/json\",\n    73→    Authorization: `Bearer ${token}`,\n    74→  };\n    75→}\n    76→\n    77→/* ── API functions ──────────────────────────────────────────────── */\n    78→\n    79→/** Set (or replace) the authenticated player's referral code. */\n    80→export async function setReferralCode(\n    81→  token: string,\n    82→  code: string,\n    83→): Promise<ReferralCodeResponse> {\n    84→  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    85→    method: \"POST\",\n    86→    headers: authHeaders(token),\n    87→    body: JSON.stringify({ code }),\n    88→  });\n    89→  return parseResponse<ReferralCodeResponse>(res);\n    90→}\n    91→\n    92→/** Get the authenticated player's current referral code, or throw on 404. */\n    93→export async function getReferralCode(\n    94→  token: string,\n    95→): Promise<ReferralCodeResponse> {\n    96→  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    97→    headers: authHeaders(token),\n    98→  });\n    99→  return parseResponse<ReferralCodeResponse>(res);\n   100→}\n   101→\n   102→/** Apply a referral code to the authenticated player (link to referrer). */\n   103→export async function applyReferralCode(\n   104→  token: string,\n   105→  code: string,\n   106→): Promise<ApplyReferralResponse> {\n   107→  const res = await fetch(`${BACKEND_URL}/referral/apply`, {\n   108→    method: \"POST\",\n   109→    headers: authHeaders(token),\n   110→    body: JSON.stringify({ code }),\n   111→  });\n   112→  return parseResponse<ApplyReferralResponse>(res);\n   113→}\n   114→\n   115→/** Get referral summary stats for the authenticated player. */\n   116→export async function getReferralStats(\n   117→  token: string,\n   118→): Promise<ReferralStatsResponse> {\n   119→  const res = await fetch(`${BACKEND_URL}/referral/stats`, {\n   120→    headers: authHeaders(token),\n   121→  });\n   122→  return parseResponse<ReferralStatsResponse>(res);\n   123→}\n   124→\n   125→/** Get paginated per-game referral earnings log. */\n   126→export async function getReferralEarnings(\n   127→  token: string,\n   128→  page?: number,\n   129→  limit?: number,\n   130→): Promise<ReferralEarningsResponse> {\n   131→  const parts: string[] = [];\n   132→  if (page != null) parts.push(`page=${page}`);\n   133→  if (limit != null) parts.push(`limit=${limit}`);\n   134→  const qs = parts.length ? `?${parts.join(\"&\")}` : \"\";\n   135→  const res = await fetch(`${BACKEND_URL}/referral/earnings${qs}`, {\n   136→    headers: authHeaders(token),\n   137→  });\n   138→  return parseResponse<ReferralEarningsResponse>(res);\n   139→}\n   140→\n   141→/** Request an async claim of all pending referral earnings. Returns 202. */\n   142→export async function requestReferralClaim(\n   143→  token: string,\n   144→): Promise<ClaimResponse> {\n   145→  const res = await fetch(`${BACKEND_URL}/referral/claim`, {\n   146→    method: \"POST\",\n   147→    headers: authHeaders(token),\n   148→  });\n   149→  return parseResponse<ClaimResponse>(res);\n   150→}\n   151→\n   152→/** Poll the status of an existing claim by ID. */\n   153→export async function pollClaimStatus(\n   154→  token: string,\n   155→  claimId: string,\n   156→): Promise<ClaimResponse> {\n   157→  const res = await fetch(`${BACKEND_URL}/referral/claim/${claimId}`, {\n   158→    headers: authHeaders(token),\n   159→  });\n   160→  return parseResponse<ClaimResponse>(res);\n   161→}\n   162→"}]},"parent_tool_use_id":"toolu_01Y23uHuJLb188RP28MGNAiH","session_id":"eb5de170-2e49-4887-a19e-0983dec4d654","uuid":"71fae4d1-ff02-49b4-bd0b-c73c0b935778","timestamp":"2026-03-25T13:38:14.228Z"}
