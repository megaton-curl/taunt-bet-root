{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DgUe2iyGF6PftTw2QZ17kf","type":"tool_result","content":"     1→/**\n     2→ * Player Profile Feature - Public API\n     3→ *\n     4→ * Exports the provider, hooks, components, and types needed\n     5→ * for integrating player profiles throughout the app.\n     6→ */\n     7→\n     8→// Provider and hook\n     9→export { PlayerProfileProvider, usePlayerProfile, truncateAddress } from \"./context/PlayerProfileContext\";\n    10→\n    11→// Components\n    12→export { PlayerAvatar } from \"./components/PlayerAvatar\";\n    13→export { PlayerAvatarCompact } from \"./components/PlayerAvatarCompact\";\n    14→export { LevelProgressBar } from \"./components/LevelProgressBar\";\n    15→export { MiniProfileModal } from \"./components/MiniProfileModal\";\n    16→export { ProfilePage } from \"./components/ProfilePage\";\n    17→export { AvatarSelector } from \"./components/AvatarSelector\";\n    18→\n    19→// Types\n    20→export type {\n    21→  AvatarId,\n    22→  AvatarSize,\n    23→  AvatarTier,\n    24→  AvatarConfig,\n    25→  BorderStyle,\n    26→  BorderConfig,\n    27→  GameId,\n    28→  PlayerProfile,\n    29→  PlayerStats,\n    30→  GameSpecificStats,\n    31→  LootItem,\n    32→  LootSource,\n    33→  ProfileTransaction,\n    34→  TransactionType,\n    35→  GameResultEvent,\n    36→  PlayerProfileContextValue,\n    37→} from \"./types\";\n    38→\n    39→export {\n    40→  AVATAR_CONFIGS,\n    41→  AVATAR_SIZES,\n    42→  AVATAR_TIER_COLORS,\n    43→  LEVEL_BORDERS,\n    44→  GAME_NAMES,\n    45→  DEFAULT_AVATAR_ID,\n    46→  MAX_USERNAME_LENGTH,\n    47→  MIN_USERNAME_LENGTH,\n    48→  USERNAME_REGEX,\n    49→  createEmptyStats,\n    50→  getHighestUnlockedAvatar,\n    51→} from \"./types\";\n    52→\n    53→// XP Calculator utilities\n    54→export {\n    55→  getXPForLevel,\n    56→  getLevelFromXP,\n    57→  getXPProgress,\n    58→  calculateWagerXP,\n    59→  calculateWinBonusXP,\n    60→  calculateGameXP,\n    61→  getBorderStyleFromLevel,\n    62→  getLevelMilestones,\n    63→  formatXP,\n    64→  formatLevel,\n    65→  type XPProgress,\n    66→} from \"./utils/xp-calculator\";\n    67→\n    68→// Event bus for game integrations\n    69→export {\n    70→  profileEventBus,\n    71→  emitGameResult,\n    72→  emitCoinflipResults,\n    73→  emitLordOfRngsResults,\n    74→  emitCryptoCrashResults,\n    75→  emitCloseCallResults,\n    76→  createGameResultEvent,\n    77→} from \"./utils/profile-event-bus\";\n    78→\n    79→// Mock simulation utilities (for testing/development)\n    80→export {\n    81→  getProfile,\n    82→  getOrCreateProfile,\n    83→  getTransactions,\n    84→  getDisplayName,\n    85→  getAvatarId,\n    86→  getLevel,\n    87→  addLoot,\n    88→} from \"./utils/mock-simulation\";\n    89→"}]},"parent_tool_use_id":"toolu_01Bgy74XGuVegTWEABLEacP1","session_id":"eb5de170-2e49-4887-a19e-0983dec4d654","uuid":"6dcda31e-af66-4f98-b0d3-747176cc16be","timestamp":"2026-03-25T13:38:43.269Z"}
