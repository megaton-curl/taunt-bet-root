{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K2tPdH5XKDSu7o5i6Q6GT6","type":"tool_result","content":"     1→/**\n     2→ * ProfileSettings - Settings tab content\n     3→ *\n     4→ * Shows connected wallet and allows connecting socials.\n     5→ * Avatar selection is handled via modal from the profile header.\n     6→ * Username editing is handled inline in the profile header.\n     7→ */\n     8→\n     9→import { useState } from \"react\";\n    10→import type { PlayerProfile } from \"../types\";\n    11→import { usePlayerProfile } from \"../context/PlayerProfileContext\";\n    12→import { truncateAddress } from \"../utils/mock-simulation\";\n    13→\n    14→interface ProfileSettingsProps {\n    15→  profile: PlayerProfile;\n    16→}\n    17→\n    18→export function ProfileSettings({ profile }: ProfileSettingsProps) {\n    19→  const {\n    20→    connectDiscord,\n    21→    disconnectDiscord,\n    22→    connectTwitter,\n    23→    disconnectTwitter,\n    24→  } = usePlayerProfile();\n    25→\n    26→  const [connectingDiscord, setConnectingDiscord] = useState(false);\n    27→  const [connectingTwitter, setConnectingTwitter] = useState(false);\n    28→\n    29→  const handleConnectDiscord = async () => {\n    30→    setConnectingDiscord(true);\n    31→    try {\n    32→      await connectDiscord();\n    33→    } catch (error) {\n    34→      console.error(\"Failed to connect Discord:\", error);\n    35→    } finally {\n    36→      setConnectingDiscord(false);\n    37→    }\n    38→  };\n    39→\n    40→  const handleDisconnectDiscord = async () => {\n    41→    setConnectingDiscord(true);\n    42→    try {\n    43→      await disconnectDiscord();\n    44→    } catch (error) {\n    45→      console.error(\"Failed to disconnect Discord:\", error);\n    46→    } finally {\n    47→      setConnectingDiscord(false);\n    48→    }\n    49→  };\n    50→\n    51→  const handleConnectTwitter = async () => {\n    52→    setConnectingTwitter(true);\n    53→    try {\n    54→      await connectTwitter();\n    55→    } catch (error) {\n    56→      console.error(\"Failed to connect Twitter:\", error);\n    57→    } finally {\n    58→      setConnectingTwitter(false);\n    59→    }\n    60→  };\n    61→\n    62→  const handleDisconnectTwitter = async () => {\n    63→    setConnectingTwitter(true);\n    64→    try {\n    65→      await disconnectTwitter();\n    66→    } catch (error) {\n    67→      console.error(\"Failed to disconnect Twitter:\", error);\n    68→    } finally {\n    69→      setConnectingTwitter(false);\n    70→    }\n    71→  };\n    72→\n    73→  return (\n    74→    <div className=\"profile-settings\">\n    75→      {/* Connected Wallet */}\n    76→      <div className=\"profile-settings__section\">\n    77→        <h3 className=\"profile-settings__section-title\">Connected Wallet</h3>\n    78→        <div className=\"profile-settings__wallet\">\n    79→          <div className=\"profile-settings__wallet-icon\">\n    80→            <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n    81→              <path d=\"M21 18v1c0 1.1-.9 2-2 2H5c-1.11 0-2-.9-2-2V5c0-1.1.89-2 2-2h14c1.1 0 2 .9 2 2v1h-9c-1.11 0-2 .9-2 2v8c0 1.1.89 2 2 2h9zm-9-2h10V8H12v8zm4-2.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z\"/>\n    82→            </svg>\n    83→          </div>\n    84→          <div className=\"profile-settings__wallet-info\">\n    85→            <div className=\"profile-settings__wallet-address\">{truncateAddress(profile.address)}</div>\n    86→            <div className=\"profile-settings__wallet-full\" title={profile.address}>\n    87→              {profile.address}\n    88→            </div>\n    89→          </div>\n    90→        </div>\n    91→      </div>\n    92→\n    93→      {/* Social Connections */}\n    94→      <div className=\"profile-settings__section\">\n    95→        <h3 className=\"profile-settings__section-title\">Connected Socials</h3>\n    96→        <div className=\"profile-socials__list\">\n    97→          {/* Discord */}\n    98→          <div className=\"profile-socials__item\">\n    99→            <div className=\"profile-socials__icon\">\n   100→              <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n   101→                <path d=\"M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z\"/>\n   102→              </svg>\n   103→            </div>\n   104→            <div className=\"profile-socials__info\">\n   105→              <div className=\"profile-socials__name\">Discord</div>\n   106→              {profile.discordUsername && (\n   107→                <div className=\"profile-socials__username\">{profile.discordUsername}</div>\n   108→              )}\n   109→            </div>\n   110→            {profile.discordUsername ? (\n   111→              <button\n   112→                type=\"button\"\n   113→                className=\"profile-socials__btn profile-socials__btn--disconnect\"\n   114→                onClick={handleDisconnectDiscord}\n   115→                disabled={connectingDiscord}\n   116→              >\n   117→                {connectingDiscord ? \"...\" : \"Disconnect\"}\n   118→              </button>\n   119→            ) : (\n   120→              <button\n   121→                type=\"button\"\n   122→                className=\"profile-socials__btn profile-socials__btn--connect\"\n   123→                onClick={handleConnectDiscord}\n   124→                disabled={connectingDiscord}\n   125→              >\n   126→                {connectingDiscord ? \"...\" : \"Connect\"}\n   127→              </button>\n   128→            )}\n   129→          </div>\n   130→\n   131→          {/* Twitter/X */}\n   132→          <div className=\"profile-socials__item\">\n   133→            <div className=\"profile-socials__icon\">\n   134→              <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n   135→                <path d=\"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z\"/>\n   136→              </svg>\n   137→            </div>\n   138→            <div className=\"profile-socials__info\">\n   139→              <div className=\"profile-socials__name\">X (Twitter)</div>\n   140→              {profile.twitterHandle && (\n   141→                <div className=\"profile-socials__username\">{profile.twitterHandle}</div>\n   142→              )}\n   143→            </div>\n   144→            {profile.twitterHandle ? (\n   145→              <button\n   146→                type=\"button\"\n   147→                className=\"profile-socials__btn profile-socials__btn--disconnect\"\n   148→                onClick={handleDisconnectTwitter}\n   149→                disabled={connectingTwitter}\n   150→              >\n   151→                {connectingTwitter ? \"...\" : \"Disconnect\"}\n   152→              </button>\n   153→            ) : (\n   154→              <button\n   155→                type=\"button\"\n   156→                className=\"profile-socials__btn profile-socials__btn--connect\"\n   157→                onClick={handleConnectTwitter}\n   158→                disabled={connectingTwitter}\n   159→              >\n   160→                {connectingTwitter ? \"...\" : \"Connect\"}\n   161→              </button>\n   162→            )}\n   163→          </div>\n   164→        </div>\n   165→      </div>\n   166→    </div>\n   167→  );\n   168→}\n   169→"}]},"parent_tool_use_id":"toolu_01Bgy74XGuVegTWEABLEacP1","session_id":"eb5de170-2e49-4887-a19e-0983dec4d654","uuid":"d58e9f80-9cc7-4012-8a6a-3971d33d91b9","timestamp":"2026-03-25T13:38:29.540Z"}
