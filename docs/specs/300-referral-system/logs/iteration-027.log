e.target.value);\n                  setReferralError(null);\n                }}\n                onKeyDown={(e) => { if (e.key === \"Enter\") handleApplyReferral(); }}\n                disabled={referralApplying}\n                maxLength={16}\n              />\n              <button\n                type=\"button\"\n                className=\"profile-settings__save-btn\"\n                onClick={handleApplyReferral}\n                disabled={referralApplying || !referralCode.trim()}\n              >\n                {referralApplying ? \"Applying...\" : \"Apply\"}\n              </button>\n            </div>\n            {referralError && (\n              <div className=\"profile-settings__referral-error\">{referralError}</div>\n            )}\n          </>\n        )}\n      </div>\n\n      {/* Social Connections */}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1068,"cache_read_input_tokens":75450,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1068},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"eb5de170-2e49-4887-a19e-0983dec4d654","uuid":"b871bf60-397b-406f-a13e-81c8553b2f27"}
