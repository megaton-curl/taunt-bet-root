{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WZRKVoFPwsScMr4qRrFfbM","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/referral.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"eb5de170-2e49-4887-a19e-0983dec4d654","uuid":"64a9e613-67e4-45a0-a17a-e96fa2e559d3","timestamp":"2026-03-25T13:40:09.544Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/referral.ts","oldString":"  // GET /stats — referral summary stats for authenticated wallet","newString":"  // GET /referrer — check if the authenticated player has a referrer\n  app.get(\"/referrer\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    try {\n      const link = await db.getReferralLinkByReferee(wallet);\n      if (!link) {\n        return c.json(\n          {\n            error: {\n              code: \"NO_REFERRER\",\n              message: \"You are not linked to a referrer\",\n            },\n          },\n          404,\n        );\n      }\n\n      return c.json({\n        referrerWallet: link.referrer_wallet,\n        linkedAt: link.created_at.toISOString(),\n      });\n    } catch (err) {\n      logger.error(\"Failed to fetch referrer\", {\n        err: String(err),\n        wallet,\n      });\n      return c.json({ error: \"Failed to fetch referrer\" }, 500);\n    }\n  });\n\n  // GET /stats — referral summary stats for authenticated wallet","originalFile":"/**\n * Referral routes — code management, linking, stats, earnings, and claims.\n */\n\nimport { Hono } from \"hono\";\nimport type postgres from \"postgres\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport type { Config } from \"../config.js\";\nimport { logger } from \"../logger.js\";\nimport { emitEvent } from \"../queue/emit-event.js\";\nimport { EventTypes } from \"../queue/event-types.js\";\n\nexport interface ReferralRoutesDeps {\n  db: Db;\n  sql: postgres.Sql;\n  config: Config;\n}\n\n/** Referral code validation: 3-16 chars, lowercase alphanumeric + hyphens */\nconst CODE_REGEX = /^[a-z0-9-]{3,16}$/;\n\nconst REFERRAL_BASE_URL = \"https://taunt.bet/r\";\n\nexport function createReferralRoutes(deps: ReferralRoutesDeps) {\n  const { db, sql, config } = deps;\n  const app = new Hono<AppEnv>();\n\n  // POST /code — set or replace the player's referral code\n  app.post(\"/code\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    let body: { code?: unknown };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json({ error: \"Invalid request body\" }, 400);\n    }\n\n    const code = typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n\n    if (!CODE_REGEX.test(code)) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_CODE\",\n            message:\n              \"Code must be 3-16 characters, lowercase letters, numbers, and hyphens only\",\n          },\n        },\n        400,\n      );\n    }\n\n    // Check if this code is already taken by another wallet\n    const existing = await db.getReferralCodeByCode(code);\n    if (existing && existing.wallet !== wallet) {\n      return c.json(\n        {\n          error: {\n            code: \"CODE_TAKEN\",\n            message: \"This referral code is already in use\",\n            retryable: false,\n          },\n        },\n        409,\n      );\n    }\n\n    try {\n      const result = await db.upsertReferralCode(wallet, code);\n      logger.info(\"Referral code set\", { wallet, code: result.code });\n      return c.json({\n        code: result.code,\n        url: `${REFERRAL_BASE_URL}/${result.code}`,\n      });\n    } catch (err) {\n      // Handle race condition: another wallet grabbed the code between check and insert\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return c.json(\n          {\n            error: {\n              code: \"CODE_TAKEN\",\n              message: \"This referral code is already in use\",\n              retryable: false,\n            },\n          },\n          409,\n        );\n      }\n      logger.error(\"Failed to set referral code\", { err: String(err), wallet });\n      return c.json({ error: \"Failed to set referral code\" }, 500);\n    }\n  });\n\n  // POST /apply — link the authenticated player to a referrer via their code\n  app.post(\"/apply\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    let body: { code?: unknown };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_BODY\",\n            message: \"Invalid request body\",\n          },\n        },\n        400,\n      );\n    }\n\n    const code =\n      typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n\n    if (!code) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_CODE\",\n            message: \"Referral code is required\",\n          },\n        },\n        400,\n      );\n    }\n\n    // Look up the referral code to find the referrer\n    const codeRow = await db.getReferralCodeByCode(code);\n    if (!codeRow) {\n      return c.json(\n        {\n          error: {\n            code: \"CODE_NOT_FOUND\",\n            message: \"Referral code does not exist\",\n            retryable: false,\n          },\n        },\n        404,\n      );\n    }\n\n    // Self-referral check\n    if (codeRow.wallet === wallet) {\n      return c.json(\n        {\n          error: {\n            code: \"SELF_REFERRAL\",\n            message: \"You cannot use your own referral code\",\n            retryable: false,\n          },\n        },\n        400,\n      );\n    }\n\n    // Check if the player already has a referrer\n    const existingLink = await db.getReferralLinkByReferee(wallet);\n    if (existingLink) {\n      return c.json(\n        {\n          error: {\n            code: \"ALREADY_LINKED\",\n            message: \"You are already linked to a referrer\",\n            retryable: false,\n          },\n        },\n        409,\n      );\n    }\n\n    try {\n      await db.insertReferralLink(codeRow.wallet, wallet);\n      logger.info(\"Referral link created\", {\n        referrer: codeRow.wallet,\n        referee: wallet,\n        code,\n      });\n      return c.json({\n        referrer: codeRow.wallet,\n        benefit: \"10% fee rebate on all games\",\n      });\n    } catch (err) {\n      // Handle race condition: another request linked this referee between check and insert\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return c.json(\n          {\n            error: {\n              code: \"ALREADY_LINKED\",\n              message: \"You are already linked to a referrer\",\n              retryable: false,\n            },\n          },\n          409,\n        );\n      }\n      logger.error(\"Failed to create referral link\", {\n        err: String(err),\n        wallet,\n        code,\n      });\n      return c.json({ error: \"Failed to apply referral code\" }, 500);\n    }\n  });\n\n  // GET /code — return the authenticated player's current referral code\n  app.get(\"/code\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    const row = await db.getReferralCodeByWallet(wallet);\n    if (!row) {\n      return c.json(\n        {\n          error: {\n            code: \"NO_CODE\",\n            message: \"No referral code set for this wallet\",\n          },\n        },\n        404,\n      );\n    }\n\n    return c.json({\n      code: row.code,\n      url: `${REFERRAL_BASE_URL}/${row.code}`,\n    });\n  });\n\n  // GET /stats — referral summary stats for authenticated wallet\n  app.get(\"/stats\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    try {\n      const stats = await db.getReferralStats(wallet);\n      return c.json({\n        referredCount: stats.referred_count,\n        activeCount: stats.active_count,\n        totalVolumeLamports: stats.total_volume_lamports,\n        totalEarnedLamports: stats.total_earned_lamports,\n        totalRebateLamports: stats.total_rebate_lamports,\n        pendingLamports: stats.pending_lamports,\n      });\n    } catch (err) {\n      logger.error(\"Failed to fetch referral stats\", {\n        err: String(err),\n        wallet,\n      });\n      return c.json({ error: \"Failed to fetch referral stats\" }, 500);\n    }\n  });\n\n  // GET /earnings — paginated per-game earnings log\n  app.get(\"/earnings\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    const pageParam = c.req.query(\"page\");\n    const limitParam = c.req.query(\"limit\");\n    const page = pageParam ? Math.max(1, Math.floor(Number(pageParam))) : 1;\n    const limit = limitParam\n      ? Math.min(100, Math.max(1, Math.floor(Number(limitParam))))\n      : 20;\n\n    if (Number.isNaN(page) || Number.isNaN(limit)) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_PARAMS\",\n            message: \"page and limit must be positive integers\",\n          },\n        },\n        400,\n      );\n    }\n\n    try {\n      const result = await db.getReferralEarnings(wallet, page, limit);\n      return c.json({\n        items: result.items.map((e) => ({\n          roundId: e.round_id,\n          gameType: e.game_type,\n          refereeWallet: e.referee_wallet,\n          wagerLamports: String(e.wager_lamports),\n          earnedLamports: String(e.referrer_earned_lamports),\n          createdAt: e.created_at.toISOString(),\n        })),\n        pagination: {\n          page,\n          totalPages: result.totalPages,\n        },\n      });\n    } catch (err) {\n      logger.error(\"Failed to fetch referral earnings\", {\n        err: String(err),\n        wallet,\n      });\n      return c.json({ error: \"Failed to fetch referral earnings\" }, 500);\n    }\n  });\n\n  // POST /claim — request payout of pending referral earnings (async via queue)\n  app.post(\"/claim\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    try {\n      // Snapshot pending balance\n      const pendingStr = await db.getPendingBalance(wallet);\n      const pendingLamports = BigInt(pendingStr);\n\n      if (pendingLamports <= 0n) {\n        return c.json(\n          {\n            error: {\n              code: \"ZERO_BALANCE\",\n              message: \"No pending earnings to claim\",\n              retryable: false,\n            },\n          },\n          400,\n        );\n      }\n\n      if (pendingLamports < BigInt(config.referralMinClaimLamports)) {\n        return c.json(\n          {\n            error: {\n              code: \"BELOW_THRESHOLD\",\n              message: `Minimum claim amount is ${config.referralMinClaimLamports} lamports (${(config.referralMinClaimLamports / 1e9).toFixed(2)} SOL)`,\n              retryable: false,\n            },\n          },\n          400,\n        );\n      }\n\n      // Atomically insert claim row + emit queue event\n      const claim = await sql.begin(async (tx) => {\n        const rows = await (tx as unknown as postgres.Sql)<\n          {\n            id: string;\n            wallet: string;\n            amount_lamports: string;\n            status: string;\n          }[]\n        >`\n          INSERT INTO referral_claims (wallet, amount_lamports, status)\n          VALUES (${wallet}, ${pendingStr}, 'pending')\n          RETURNING id, wallet, amount_lamports, status\n        `;\n        const row = rows[0]!;\n\n        await emitEvent(\n          tx as unknown as postgres.Sql,\n          EventTypes.REFERRAL_CLAIM_REQUESTED,\n          {\n            claimId: row.id,\n            wallet: row.wallet,\n            amountLamports: row.amount_lamports,\n            requestedAt: new Date().toISOString(),\n          },\n        );\n\n        return row;\n      });\n\n      logger.info(\"Referral claim requested\", {\n        wallet,\n        claimId: claim.id,\n        amountLamports: claim.amount_lamports,\n      });\n\n      return c.json(\n        {\n          claimId: claim.id,\n          amountLamports: claim.amount_lamports,\n          status: \"pending\",\n        },\n        202,\n      );\n    } catch (err) {\n      logger.error(\"Failed to create referral claim\", {\n        err: String(err),\n        wallet,\n      });\n      return c.json({ error: \"Failed to create referral claim\" }, 500);\n    }\n  });\n\n  // GET /claim/:claimId — poll claim status\n  app.get(\"/claim/:claimId\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    const claimId = c.req.param(\"claimId\");\n\n    try {\n      const claim = await db.getReferralClaim(claimId);\n      if (!claim) {\n        return c.json(\n          {\n            error: {\n              code: \"CLAIM_NOT_FOUND\",\n              message: \"Claim not found\",\n            },\n          },\n          404,\n        );\n      }\n\n      // Only allow the claim owner to view their claim\n      if (claim.wallet !== wallet) {\n        return c.json(\n          {\n            error: {\n              code: \"CLAIM_NOT_FOUND\",\n              message: \"Claim not found\",\n            },\n          },\n          404,\n        );\n      }\n\n      return c.json({\n        claimId: claim.id,\n        amountLamports: String(claim.amount_lamports),\n        status: claim.status,\n        ...(claim.tx_signature ? { txSignature: claim.tx_signature } : {}),\n      });\n    } catch (err) {\n      logger.error(\"Failed to fetch referral claim\", {\n        err: String(err),\n        wallet,\n        claimId,\n      });\n      return c.json({ error: \"Failed to fetch referral claim\" }, 500);\n    }\n  });\n\n  return app;\n}\n","structuredPatch":[{"oldStart":233,"oldLines":6,"newStart":233,"newLines":38,"lines":["     });","   });"," ","+  // GET /referrer — check if the authenticated player has a referrer","+  app.get(\"/referrer\", async (c) => {","+    const wallet = c.get(\"wallet\");","+    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);","+","+    try {","+      const link = await db.getReferralLinkByReferee(wallet);","+      if (!link) {","+        return c.json(","+          {","+            error: {","+              code: \"NO_REFERRER\",","+              message: \"You are not linked to a referrer\",","+            },","+          },","+          404,","+        );","+      }","+","+      return c.json({","+        referrerWallet: link.referrer_wallet,","+        linkedAt: link.created_at.toISOString(),","+      });","+    } catch (err) {","+      logger.error(\"Failed to fetch referrer\", {","+        err: String(err),","+        wallet,","+      });","+      return c.json({ error: \"Failed to fetch referrer\" }, 500);","+    }","+  });","+","   // GET /stats — referral summary stats for authenticated wallet","   app.get(\"/stats\", async (c) => {","     const wallet = c.get(\"wallet\");"]}],"userModified":false,"replaceAll":false}}
