Twitter ? \"...\" : \"Disconnect\"}\n   152→              </button>\n   153→            ) : (\n   154→              <button\n   155→                type=\"button\"\n   156→                className=\"profile-socials__btn profile-socials__btn--connect\"\n   157→                onClick={handleConnectTwitter}\n   158→                disabled={connectingTwitter}\n   159→              >\n   160→                {connectingTwitter ? \"...\" : \"Connect\"}\n   161→              </button>\n   162→            )}\n   163→          </div>\n   164→        </div>\n   165→      </div>\n   166→    </div>\n   167→  );\n   168→}\n   169→"}]},"parent_tool_use_id":null,"session_id":"eb5de170-2e49-4887-a19e-0983dec4d654","uuid":"7028ea53-4599-42ac-9963-c0d90528e212","timestamp":"2026-03-25T13:39:13.125Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/player-profile/components/ProfileSettings.tsx","content":"/**\n * ProfileSettings - Settings tab content\n *\n * Shows connected wallet and allows connecting socials.\n * Avatar selection is handled via modal from the profile header.\n * Username editing is handled inline in the profile header.\n */\n\nimport { useState } from \"react\";\nimport type { PlayerProfile } from \"../types\";\nimport { usePlayerProfile } from \"../context/PlayerProfileContext\";\nimport { truncateAddress } from \"../utils/mock-simulation\";\n\ninterface ProfileSettingsProps {\n  profile: PlayerProfile;\n}\n\nexport function ProfileSettings({ profile }: ProfileSettingsProps) {\n  const {\n    connectDiscord,\n    disconnectDiscord,\n    connectTwitter,\n    disconnectTwitter,\n  } = usePlayerProfile();\n\n  const [connectingDiscord, setConnectingDiscord] = useState(false);\n  const [connectingTwitter, setConnectingTwitter] = useState(false);\n\n  const handleConnectDiscord = async () => {\n    setConnectingDiscord(true);\n    try {\n      await connectDiscord();\n    } catch (error) {\n      console.error(\"Failed to connect Discord:\", error);\n    } finally {\n      setConnectingDiscord(false);\n    }\n  };\n\n  const handleDisconnectDiscord = async () => {\n    setConnectingDiscord(true);\n    try {\n      await disconnectDiscord();\n    } catch (error) {\n      console.error(\"Failed to disconnect Discord:\", error);\n    } finally {\n      setConnectingDiscord(false);\n    }\n  };\n\n  const handleConnectTwitter = async () => {\n    setConnectingTwitter(true);\n    try {\n      await connectTwitter();\n    } catch (error) {\n      console.error(\"Failed to connect Twitter:\", error);\n    } finally {\n      setConnectingTwitter(false);\n    }\n  };\n\n  const handleDisconnectTwitter = async () => {\n    setConnectingTwitter(true);\n    try {\n      await disconnectTwitter();\n    } catch (error) {\n      console.error(\"Failed to disconnect Twitter:\", error);\n    } finally {\n      setConnectingTwitter(false);\n    }\n  };\n\n  return (\n    <div className=\"profile-settings\">\n      {/* Connected Wallet */}\n      <div className=\"profile-settings__section\">\n        <h3 className=\"profile-settings__section-title\">Connected Wallet</h3>\n        <div className=\"profile-settings__wallet\">\n          <div className=\"profile-settings__wallet-icon\">\n            <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n              <path d=\"M21 18v1c0 1.1-.9 2-2 2H5c-1.11 0-2-.9-2-2V5c0-1.1.89-2 2-2h14c1.1 0 2 .9 2 2v1h-9c-1.11 0-2 .9-2 2v8c0 1.1.89 2 2 2h9zm-9-2h10V8H12v8zm4-2.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z\"/>\n            </svg>\n          </div>\n          <div className=\"profile-settings__wallet-info\">\n            <div className=\"profile-settings__wallet-address\">{truncateAddress(profile.address)}</div>\n            <div className=\"profile-settings__wallet-full\" title={profile.address}>\n              {profile.address}\n            </div>\n          </div>\n        </div>\n      </div>\n\n      {/* Social Connections */}\n      <div className=\"profile-settings__section\">\n        <h3 className=\"profile-settings__section-title\">Connected Socials</h3>\n        <div className=\"profile-socials__list\">\n          {/* Discord */}\n          <div className=\"profile-socials__item\">\n            <div className=\"profile-socials__icon\">\n              <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                <path d=\"M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z\"/>\n              </svg>\n            </div>\n            <div className=\"profile-socials__info\">\n              <div className=\"profile-socials__name\">Discord</div>\n              {profile.discordUsername && (\n                <div className=\"profile-socials__username\">{profile.discordUsername}</div>\n              )}\n            </div>\n            {profile.discordUsername ? (\n              <button\n                type=\"button\"\n                className=\"profile-socials__btn profile-socials__btn--disconnect\"\n                onClick={handleDisconnectDiscord}\n                disabled={connectingDiscord}\n              >\n                {connectingDiscord ? \"...\" : \"Disconnect\"}\n              </button>\n            ) : (\n              <button\n                type=\"button\"\n                className=\"profile-socials__btn profile-socials__btn--connect\"\n                onClick={handleConnectDiscord}\n                disabled={connectingDiscord}\n              >\n                {connectingDiscord ? \"...\" : \"Connect\"}\n              </button>\n            )}\n          </div>\n\n          {/* Twitter/X */}\n          <div className=\"profile-socials__item\">\n            <div className=\"profile-socials__icon\">\n              <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                <path d=\"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z\"/>\n              </svg>\n            </div>\n            <div className=\"profile-socials__info\">\n              <div className=\"profile-socials__name\">X (Twitter)</div>\n              {profile.twitterHandle && (\n                <div className=\"profile-socials__username\">{profile.twitterHandle}</div>\n              )}\n            </div>\n            {profile.twitterHandle ? (\n              <button\n                type=\"button\"\n                className=\"profile-socials__btn profile-socials__btn--disconnect\"\n                onClick={handleDisconnectTwitter}\n                disabled={connectingTwitter}\n              >\n                {connectingTwitter ? \"...\" : \"Disconnect\"}\n              </button>\n            ) : (\n              <button\n                type=\"button\"\n                className=\"profile-socials__btn profile-socials__btn--connect\"\n                onClick={handleConnectTwitter}\n                disabled={connectingTwitter}\n              >\n                {connectingTwitter ? \"...\" : \"Connect\"}\n              </button>\n            )}\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n","numLines":169,"startLine":1,"totalLines":169}}}
