{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J5Ftrggi9y7FX9yjZcUggQ","type":"tool_result","content":"     1→/**\n     2→ * Referral routes — code management, linking, stats, earnings, and claims.\n     3→ */\n     4→\n     5→import { Hono } from \"hono\";\n     6→import type postgres from \"postgres\";\n     7→import type { AppEnv } from \"../hono-env.js\";\n     8→import type { Db } from \"../db.js\";\n     9→import type { Config } from \"../config.js\";\n    10→import { logger } from \"../logger.js\";\n    11→import { emitEvent } from \"../queue/emit-event.js\";\n    12→import { EventTypes } from \"../queue/event-types.js\";\n    13→\n    14→export interface ReferralRoutesDeps {\n    15→  db: Db;\n    16→  sql: postgres.Sql;\n    17→  config: Config;\n    18→}\n    19→\n    20→/** Referral code validation: 3-16 chars, lowercase alphanumeric + hyphens */\n    21→const CODE_REGEX = /^[a-z0-9-]{3,16}$/;\n    22→\n    23→const REFERRAL_BASE_URL = \"https://taunt.bet/r\";\n    24→\n    25→export function createReferralRoutes(deps: ReferralRoutesDeps) {\n    26→  const { db, sql, config } = deps;\n    27→  const app = new Hono<AppEnv>();\n    28→\n    29→  // POST /code — set or replace the player's referral code\n    30→  app.post(\"/code\", async (c) => {\n    31→    const wallet = c.get(\"wallet\");\n    32→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n    33→\n    34→    let body: { code?: unknown };\n    35→    try {\n    36→      body = await c.req.json();\n    37→    } catch {\n    38→      return c.json({ error: \"Invalid request body\" }, 400);\n    39→    }\n    40→\n    41→    const code = typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n    42→\n    43→    if (!CODE_REGEX.test(code)) {\n    44→      return c.json(\n    45→        {\n    46→          error: {\n    47→            code: \"INVALID_CODE\",\n    48→            message:\n    49→              \"Code must be 3-16 characters, lowercase letters, numbers, and hyphens only\",\n    50→          },\n    51→        },\n    52→        400,\n    53→      );\n    54→    }\n    55→\n    56→    // Check if this code is already taken by another wallet\n    57→    const existing = await db.getReferralCodeByCode(code);\n    58→    if (existing && existing.wallet !== wallet) {\n    59→      return c.json(\n    60→        {\n    61→          error: {\n    62→            code: \"CODE_TAKEN\",\n    63→            message: \"This referral code is already in use\",\n    64→            retryable: false,\n    65→          },\n    66→        },\n    67→        409,\n    68→      );\n    69→    }\n    70→\n    71→    try {\n    72→      const result = await db.upsertReferralCode(wallet, code);\n    73→      logger.info(\"Referral code set\", { wallet, code: result.code });\n    74→      return c.json({\n    75→        code: result.code,\n    76→        url: `${REFERRAL_BASE_URL}/${result.code}`,\n    77→      });\n    78→    } catch (err) {\n    79→      // Handle race condition: another wallet grabbed the code between check and insert\n    80→      const msg = err instanceof Error ? err.message : String(err);\n    81→      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n    82→        return c.json(\n    83→          {\n    84→            error: {\n    85→              code: \"CODE_TAKEN\",\n    86→              message: \"This referral code is already in use\",\n    87→              retryable: false,\n    88→            },\n    89→          },\n    90→          409,\n    91→        );\n    92→      }\n    93→      logger.error(\"Failed to set referral code\", { err: String(err), wallet });\n    94→      return c.json({ error: \"Failed to set referral code\" }, 500);\n    95→    }\n    96→  });\n    97→\n    98→  // POST /apply — link the authenticated player to a referrer via their code\n    99→  app.post(\"/apply\", async (c) => {\n   100→    const wallet = c.get(\"wallet\");\n   101→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   102→\n   103→    let body: { code?: unknown };\n   104→    try {\n   105→      body = await c.req.json();\n   106→    } catch {\n   107→      return c.json(\n   108→        {\n   109→          error: {\n   110→            code: \"INVALID_BODY\",\n   111→            message: \"Invalid request body\",\n   112→          },\n   113→        },\n   114→        400,\n   115→      );\n   116→    }\n   117→\n   118→    const code =\n   119→      typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n   120→\n   121→    if (!code) {\n   122→      return c.json(\n   123→        {\n   124→          error: {\n   125→            code: \"INVALID_CODE\",\n   126→            message: \"Referral code is required\",\n   127→          },\n   128→        },\n   129→        400,\n   130→      );\n   131→    }\n   132→\n   133→    // Look up the referral code to find the referrer\n   134→    const codeRow = await db.getReferralCodeByCode(code);\n   135→    if (!codeRow) {\n   136→      return c.json(\n   137→        {\n   138→          error: {\n   139→            code: \"CODE_NOT_FOUND\",\n   140→            message: \"Referral code does not exist\",\n   141→            retryable: false,\n   142→          },\n   143→        },\n   144→        404,\n   145→      );\n   146→    }\n   147→\n   148→    // Self-referral check\n   149→    if (codeRow.wallet === wallet) {\n   150→      return c.json(\n   151→        {\n   152→          error: {\n   153→            code: \"SELF_REFERRAL\",\n   154→            message: \"You cannot use your own referral code\",\n   155→            retryable: false,\n   156→          },\n   157→        },\n   158→        400,\n   159→      );\n   160→    }\n   161→\n   162→    // Check if the player already has a referrer\n   163→    const existingLink = await db.getReferralLinkByReferee(wallet);\n   164→    if (existingLink) {\n   165→      return c.json(\n   166→        {\n   167→          error: {\n   168→            code: \"ALREADY_LINKED\",\n   169→            message: \"You are already linked to a referrer\",\n   170→            retryable: false,\n   171→          },\n   172→        },\n   173→        409,\n   174→      );\n   175→    }\n   176→\n   177→    try {\n   178→      await db.insertReferralLink(codeRow.wallet, wallet);\n   179→      logger.info(\"Referral link created\", {\n   180→        referrer: codeRow.wallet,\n   181→        referee: wallet,\n   182→        code,\n   183→      });\n   184→      return c.json({\n   185→        referrer: codeRow.wallet,\n   186→        benefit: \"10% fee rebate on all games\",\n   187→      });\n   188→    } catch (err) {\n   189→      // Handle race condition: another request linked this referee between check and insert\n   190→      const msg = err instanceof Error ? err.message : String(err);\n   191→      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n   192→        return c.json(\n   193→          {\n   194→            error: {\n   195→              code: \"ALREADY_LINKED\",\n   196→              message: \"You are already linked to a referrer\",\n   197→              retryable: false,\n   198→            },\n   199→          },\n   200→          409,\n   201→        );\n   202→      }\n   203→      logger.error(\"Failed to create referral link\", {\n   204→        err: String(err),\n   205→        wallet,\n   206→        code,\n   207→      });\n   208→      return c.json({ error: \"Failed to apply referral code\" }, 500);\n   209→    }\n   210→  });\n   211→\n   212→  // GET /code — return the authenticated player's current referral code\n   213→  app.get(\"/code\", async (c) => {\n   214→    const wallet = c.get(\"wallet\");\n   215→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   216→\n   217→    const row = await db.getReferralCodeByWallet(wallet);\n   218→    if (!row) {\n   219→      return c.json(\n   220→        {\n   221→          error: {\n   222→            code: \"NO_CODE\",\n   223→            message: \"No referral code set for this wallet\",\n   224→          },\n   225→        },\n   226→        404,\n   227→      );\n   228→    }\n   229→\n   230→    return c.json({\n   231→      code: row.code,\n   232→      url: `${REFERRAL_BASE_URL}/${row.code}`,\n   233→    });\n   234→  });\n   235→\n   236→  // GET /stats — referral summary stats for authenticated wallet\n   237→  app.get(\"/stats\", async (c) => {\n   238→    const wallet = c.get(\"wallet\");\n   239→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   240→\n   241→    try {\n   242→      const stats = await db.getReferralStats(wallet);\n   243→      return c.json({\n   244→        referredCount: stats.referred_count,\n   245→        activeCount: stats.active_count,\n   246→        totalVolumeLamports: stats.total_volume_lamports,\n   247→        totalEarnedLamports: stats.total_earned_lamports,\n   248→        totalRebateLamports: stats.total_rebate_lamports,\n   249→        pendingLamports: stats.pending_lamports,\n   250→      });\n   251→    } catch (err) {\n   252→      logger.error(\"Failed to fetch referral stats\", {\n   253→        err: String(err),\n   254→        wallet,\n   255→      });\n   256→      return c.json({ error: \"Failed to fetch referral stats\" }, 500);\n   257→    }\n   258→  });\n   259→\n   260→  // GET /earnings — paginated per-game earnings log\n   261→  app.get(\"/earnings\", async (c) => {\n   262→    const wallet = c.get(\"wallet\");\n   263→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   264→\n   265→    const pageParam = c.req.query(\"page\");\n   266→    const limitParam = c.req.query(\"limit\");\n   267→    const page = pageParam ? Math.max(1, Math.floor(Number(pageParam))) : 1;\n   268→    const limit = limitParam\n   269→      ? Math.min(100, Math.max(1, Math.floor(Number(limitParam))))\n   270→      : 20;\n   271→\n   272→    if (Number.isNaN(page) || Number.isNaN(limit)) {\n   273→      return c.json(\n   274→        {\n   275→          error: {\n   276→            code: \"INVALID_PARAMS\",\n   277→            message: \"page and limit must be positive integers\",\n   278→          },\n   279→        },\n   280→        400,\n   281→      );\n   282→    }\n   283→\n   284→    try {\n   285→      const result = await db.getReferralEarnings(wallet, page, limit);\n   286→      return c.json({\n   287→        items: result.items.map((e) => ({\n   288→          roundId: e.round_id,\n   289→          gameType: e.game_type,\n   290→          refereeWallet: e.referee_wallet,\n   291→          wagerLamports: String(e.wager_lamports),\n   292→          earnedLamports: String(e.referrer_earned_lamports),\n   293→          createdAt: e.created_at.toISOString(),\n   294→        })),\n   295→        pagination: {\n   296→          page,\n   297→          totalPages: result.totalPages,\n   298→        },\n   299→      });\n   300→    } catch (err) {\n   301→      logger.error(\"Failed to fetch referral earnings\", {\n   302→        err: String(err),\n   303→        wallet,\n   304→      });\n   305→      return c.json({ error: \"Failed to fetch referral earnings\" }, 500);\n   306→    }\n   307→  });\n   308→\n   309→  // POST /claim — request payout of pending referral earnings (async via queue)\n   310→  app.post(\"/claim\", async (c) => {\n   311→    const wallet = c.get(\"wallet\");\n   312→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   313→\n   314→    try {\n   315→      // Snapshot pending balance\n   316→      const pendingStr = await db.getPendingBalance(wallet);\n   317→      const pendingLamports = BigInt(pendingStr);\n   318→\n   319→      if (pendingLamports <= 0n) {\n   320→        return c.json(\n   321→          {\n   322→            error: {\n   323→              code: \"ZERO_BALANCE\",\n   324→              message: \"No pending earnings to claim\",\n   325→              retryable: false,\n   326→            },\n   327→          },\n   328→          400,\n   329→        );\n   330→      }\n   331→\n   332→      if (pendingLamports < BigInt(config.referralMinClaimLamports)) {\n   333→        return c.json(\n   334→          {\n   335→            error: {\n   336→              code: \"BELOW_THRESHOLD\",\n   337→              message: `Minimum claim amount is ${config.referralMinClaimLamports} lamports (${(config.referralMinClaimLamports / 1e9).toFixed(2)} SOL)`,\n   338→              retryable: false,\n   339→            },\n   340→          },\n   341→          400,\n   342→        );\n   343→      }\n   344→\n   345→      // Atomically insert claim row + emit queue event\n   346→      const claim = await sql.begin(async (tx) => {\n   347→        const rows = await (tx as unknown as postgres.Sql)<\n   348→          {\n   349→            id: string;\n   350→            wallet: string;\n   351→            amount_lamports: string;\n   352→            status: string;\n   353→          }[]\n   354→        >`\n   355→          INSERT INTO referral_claims (wallet, amount_lamports, status)\n   356→          VALUES (${wallet}, ${pendingStr}, 'pending')\n   357→          RETURNING id, wallet, amount_lamports, status\n   358→        `;\n   359→        const row = rows[0]!;\n   360→\n   361→        await emitEvent(\n   362→          tx as unknown as postgres.Sql,\n   363→          EventTypes.REFERRAL_CLAIM_REQUESTED,\n   364→          {\n   365→            claimId: row.id,\n   366→            wallet: row.wallet,\n   367→            amountLamports: row.amount_lamports,\n   368→            requestedAt: new Date().toISOString(),\n   369→          },\n   370→        );\n   371→\n   372→        return row;\n   373→      });\n   374→\n   375→      logger.info(\"Referral claim requested\", {\n   376→        wallet,\n   377→        claimId: claim.id,\n   378→        amountLamports: claim.amount_lamports,\n   379→      });\n   380→\n   381→      return c.json(\n   382→        {\n   383→          claimId: claim.id,\n   384→          amountLamports: claim.amount_lamports,\n   385→          status: \"pending\",\n   386→        },\n   387→        202,\n   388→      );\n   389→    } catch (err) {\n   390→      logger.error(\"Failed to create referral claim\", {\n   391→        err: String(err),\n   392→        wallet,\n   393→      });\n   394→      return c.json({ error: \"Failed to create referral claim\" }, 500);\n   395→    }\n   396→  });\n   397→\n   398→  // GET /claim/:claimId — poll claim status\n   399→  app.get(\"/claim/:claimId\", async (c) => {\n   400→    const wallet = c.get(\"wallet\");\n   401→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   402→\n   403→    const claimId = c.req.param(\"claimId\");\n   404→\n   405→    try {\n   406→      const claim = await db.getReferralClaim(claimId);\n   407→      if (!claim) {\n   408→        return c.json(\n   409→          {\n   410→            error: {\n   411→              code: \"CLAIM_NOT_FOUND\",\n   412→              message: \"Claim not found\",\n   413→            },\n   414→          },\n   415→          404,\n   416→        );\n   417→      }\n   418→\n   419→      // Only allow the claim owner to view their claim\n   420→      if (claim.wallet !== wallet) {\n   421→        return c.json(\n   422→          {\n   423→            error: {\n   424→              code: \"CLAIM_NOT_FOUND\",\n   425→              message: \"Claim not found\",\n   426→            },\n   427→          },\n   428→          404,\n   429→        );\n   430→      }\n   431→\n   432→      return c.json({\n   433→        claimId: claim.id,\n   434→        amountLamports: String(claim.amount_lamports),\n   435→        status: claim.status,\n   436→        ...(claim.tx_signature ? { txSignature: claim.tx_signature } : {}),\n   437→      });\n   438→    } catch (err) {\n   439→      logger.error(\"Failed to fetch referral claim\", {\n   440→        err: String(err),\n   441→        wallet,\n   442→        claimId,\n   443→      });\n   444→      return c.json({ error: \"Failed to fetch referral claim\" }, 500);\n   445→    }\n   446→  });\n   447→\n   448→  return app;\n   449→}\n   450→"}]},"parent_tool_use_id":null,"session_id":"eb5de170-2e49-4887-a19e-0983dec4d654","uuid":"76326a32-c18a-4f58-82c0-7a0246403c2d","timestamp":"2026-03-25T13:39:55.968Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/referral.ts","content":"/**\n * Referral routes — code management, linking, stats, earnings, and claims.\n */\n\nimport { Hono } from \"hono\";\nimport type postgres from \"postgres\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport type { Config } from \"../config.js\";\nimport { logger } from \"../logger.js\";\nimport { emitEvent } from \"../queue/emit-event.js\";\nimport { EventTypes } from \"../queue/event-types.js\";\n\nexport interface ReferralRoutesDeps {\n  db: Db;\n  sql: postgres.Sql;\n  config: Config;\n}\n\n/** Referral code validation: 3-16 chars, lowercase alphanumeric + hyphens */\nconst CODE_REGEX = /^[a-z0-9-]{3,16}$/;\n\nconst REFERRAL_BASE_URL = \"https://taunt.bet/r\";\n\nexport function createReferralRoutes(deps: ReferralRoutesDeps) {\n  const { db, sql, config } = deps;\n  const app = new Hono<AppEnv>();\n\n  // POST /code — set or replace the player's referral code\n  app.post(\"/code\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    let body: { code?: unknown };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json({ error: \"Invalid request body\" }, 400);\n    }\n\n    const code = typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n\n    if (!CODE_REGEX.test(code)) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_CODE\",\n            message:\n              \"Code must be 3-16 characters, lowercase letters, numbers, and hyphens only\",\n          },\n        },\n        400,\n      );\n    }\n\n    // Check if this code is already taken by another wallet\n    const existing = await db.getReferralCodeByCode(code);\n    if (existing && existing.wallet !== wallet) {\n      return c.json(\n        {\n          error: {\n            code: \"CODE_TAKEN\",\n            message: \"This referral code is already in use\",\n            retryable: false,\n          },\n        },\n        409,\n      );\n    }\n\n    try {\n      const result = await db.upsertReferralCode(wallet, code);\n      logger.info(\"Referral code set\", { wallet, code: result.code });\n      return c.json({\n        code: result.code,\n        url: `${REFERRAL_BASE_URL}/${result.code}`,\n      });\n    } catch (err) {\n      // Handle race condition: another wallet grabbed the code between check and insert\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return c.json(\n          {\n            error: {\n              code: \"CODE_TAKEN\",\n              message: \"This referral code is already in use\",\n              retryable: false,\n            },\n          },\n          409,\n        );\n      }\n      logger.error(\"Failed to set referral code\", { err: String(err), wallet });\n      return c.json({ error: \"Failed to set referral code\" }, 500);\n    }\n  });\n\n  // POST /apply — link the authenticated player to a referrer via their code\n  app.post(\"/apply\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    let body: { code?: unknown };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_BODY\",\n            message: \"Invalid request body\",\n          },\n        },\n        400,\n      );\n    }\n\n    const code =\n      typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n\n    if (!code) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_CODE\",\n            message: \"Referral code is required\",\n          },\n        },\n        400,\n      );\n    }\n\n    // Look up the referral code to find the referrer\n    const codeRow = await db.getReferralCodeByCode(code);\n    if (!codeRow) {\n      return c.json(\n        {\n          error: {\n            code: \"CODE_NOT_FOUND\",\n            message: \"Referral code does not exist\",\n            retryable: false,\n          },\n        },\n        404,\n      );\n    }\n\n    // Self-referral check\n    if (codeRow.wallet === wallet) {\n      return c.json(\n        {\n          error: {\n            code: \"SELF_REFERRAL\",\n            message: \"You cannot use your own referral code\",\n            retryable: false,\n          },\n        },\n        400,\n      );\n    }\n\n    // Check if the player already has a referrer\n    const existingLink = await db.getReferralLinkByReferee(wallet);\n    if (existingLink) {\n      return c.json(\n        {\n          error: {\n            code: \"ALREADY_LINKED\",\n            message: \"You are already linked to a referrer\",\n            retryable: false,\n          },\n        },\n        409,\n      );\n    }\n\n    try {\n      await db.insertReferralLink(codeRow.wallet, wallet);\n      logger.info(\"Referral link created\", {\n        referrer: codeRow.wallet,\n        referee: wallet,\n        code,\n      });\n      return c.json({\n        referrer: codeRow.wallet,\n        benefit: \"10% fee rebate on all games\",\n      });\n    } catch (err) {\n      // Handle race condition: another request linked this referee between check and insert\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return c.json(\n          {\n            error: {\n              code: \"ALREADY_LINKED\",\n              message: \"You are already linked to a referrer\",\n              retryable: false,\n            },\n          },\n          409,\n        );\n      }\n      logger.error(\"Failed to create referral link\", {\n        err: String(err),\n        wallet,\n        code,\n      });\n      return c.json({ error: \"Failed to apply referral code\" }, 500);\n    }\n  });\n\n  // GET /code — return the authenticated player's current referral code\n  app.get(\"/code\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    const row = await db.getReferralCodeByWallet(wallet);\n    if (!row) {\n      return c.json(\n        {\n          error: {\n            code: \"NO_CODE\",\n            message: \"No referral code set for this wallet\",\n          },\n        },\n        404,\n      );\n    }\n\n    return c.json({\n      code: row.code,\n      url: `${REFERRAL_BASE_URL}/${row.code}`,\n    });\n  });\n\n  // GET /stats — referral summary stats for authenticated wallet\n  app.get(\"/stats\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    try {\n      const stats = await db.getReferralStats(wallet);\n      return c.json({\n        referredCount: stats.referred_count,\n        activeCount: stats.active_count,\n        totalVolumeLamports: stats.total_volume_lamports,\n        totalEarnedLamports: stats.total_earned_lamports,\n        totalRebateLamports: stats.total_rebate_lamports,\n        pendingLamports: stats.pending_lamports,\n      });\n    } catch (err) {\n      logger.error(\"Failed to fetch referral stats\", {\n        err: String(err),\n        wallet,\n      });\n      return c.json({ error: \"Failed to fetch referral stats\" }, 500);\n    }\n  });\n\n  // GET /earnings — paginated per-game earnings log\n  app.get(\"/earnings\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    const pageParam = c.req.query(\"page\");\n    const limitParam = c.req.query(\"limit\");\n    const page = pageParam ? Math.max(1, Math.floor(Number(pageParam))) : 1;\n    const limit = limitParam\n      ? Math.min(100, Math.max(1, Math.floor(Number(limitParam))))\n      : 20;\n\n    if (Number.isNaN(page) || Number.isNaN(limit)) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_PARAMS\",\n            message: \"page and limit must be positive integers\",\n          },\n        },\n        400,\n      );\n    }\n\n    try {\n      const result = await db.getReferralEarnings(wallet, page, limit);\n      return c.json({\n        items: result.items.map((e) => ({\n          roundId: e.round_id,\n          gameType: e.game_type,\n          refereeWallet: e.referee_wallet,\n          wagerLamports: String(e.wager_lamports),\n          earnedLamports: String(e.referrer_earned_lamports),\n          createdAt: e.created_at.toISOString(),\n        })),\n        pagination: {\n          page,\n          totalPages: result.totalPages,\n        },\n      });\n    } catch (err) {\n      logger.error(\"Failed to fetch referral earnings\", {\n        err: String(err),\n        wallet,\n      });\n      return c.json({ error: \"Failed to fetch referral earnings\" }, 500);\n    }\n  });\n\n  // POST /claim — request payout of pending referral earnings (async via queue)\n  app.post(\"/claim\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    try {\n      // Snapshot pending balance\n      const pendingStr = await db.getPendingBalance(wallet);\n      const pendingLamports = BigInt(pendingStr);\n\n      if (pendingLamports <= 0n) {\n        return c.json(\n          {\n            error: {\n              code: \"ZERO_BALANCE\",\n              message: \"No pending earnings to claim\",\n              retryable: false,\n            },\n          },\n          400,\n        );\n      }\n\n      if (pendingLamports < BigInt(config.referralMinClaimLamports)) {\n        return c.json(\n          {\n            error: {\n              code: \"BELOW_THRESHOLD\",\n              message: `Minimum claim amount is ${config.referralMinClaimLamports} lamports (${(config.referralMinClaimLamports / 1e9).toFixed(2)} SOL)`,\n              retryable: false,\n            },\n          },\n          400,\n        );\n      }\n\n      // Atomically insert claim row + emit queue event\n      const claim = await sql.begin(async (tx) => {\n        const rows = await (tx as unknown as postgres.Sql)<\n          {\n            id: string;\n            wallet: string;\n            amount_lamports: string;\n            status: string;\n          }[]\n        >`\n          INSERT INTO referral_claims (wallet, amount_lamports, status)\n          VALUES (${wallet}, ${pendingStr}, 'pending')\n          RETURNING id, wallet, amount_lamports, status\n        `;\n        const row = rows[0]!;\n\n        await emitEvent(\n          tx as unknown as postgres.Sql,\n          EventTypes.REFERRAL_CLAIM_REQUESTED,\n          {\n            claimId: row.id,\n            wallet: row.wallet,\n            amountLamports: row.amount_lamports,\n            requestedAt: new Date().toISOString(),\n          },\n        );\n\n        return row;\n      });\n\n      logger.info(\"Referral claim requested\", {\n        wallet,\n        claimId: claim.id,\n        amountLamports: claim.amount_lamports,\n      });\n\n      return c.json(\n        {\n          claimId: claim.id,\n          amountLamports: claim.amount_lamports,\n          status: \"pending\",\n        },\n        202,\n      );\n    } catch (err) {\n      logger.error(\"Failed to create referral claim\", {\n        err: String(err),\n        wallet,\n      });\n      return c.json({ error: \"Failed to create referral claim\" }, 500);\n    }\n  });\n\n  // GET /claim/:claimId — poll claim status\n  app.get(\"/claim/:claimId\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    const claimId = c.req.param(\"claimId\");\n\n    try {\n      const claim = await db.getReferralClaim(claimId);\n      if (!claim) {\n        return c.json(\n          {\n            error: {\n              code: \"CLAIM_NOT_FOUND\",\n              message: \"Claim not found\",\n            },\n          },\n          404,\n        );\n      }\n\n      // Only allow the claim owner to view their claim\n      if (claim.wallet !== wallet) {\n        return c.json(\n          {\n            error: {\n              code: \"CLAIM_NOT_FOUND\",\n              message: \"Claim not found\",\n            },\n          },\n          404,\n        );\n      }\n\n      return c.json({\n        claimId: claim.id,\n        amountLamports: String(claim.amount_lamports),\n        status: claim.status,\n        ...(claim.tx_signature ? { txSignature: claim.tx_signature } : {}),\n      });\n    } catch (err) {\n      logger.error(\"Failed to fetch referral claim\", {\n        err: String(err),\n        wallet,\n        claimId,\n      });\n      return c.json({ error: \"Failed to fetch referral claim\" }, 500);\n    }\n  });\n\n  return app;\n}\n","numLines":450,"startLine":1,"totalLines":450}}}
