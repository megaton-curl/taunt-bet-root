{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0175eTwHvfqN8ituhjHMpFTt","type":"tool_result","content":"     1→/**\n     2→ * Close Call API routes.\n     3→ *\n     4→ * GET  /closecall/current-round — active round + pool state\n     5→ * GET  /closecall/history       — last N settled/refunded rounds\n     6→ * GET  /closecall/candles       — last N minute-boundary candles from DB\n     7→ * POST /closecall/bet           — co-sign a bet tx (creates round or joins)\n     8→ */\n     9→\n    10→import { Hono } from \"hono\";\n    11→import { Connection, Keypair, PublicKey } from \"@solana/web3.js\";\n    12→import type postgres from \"postgres\";\n    13→import type { CloseCallRound, Db } from \"../db.js\";\n    14→import { logger } from \"../logger.js\";\n    15→import { buildCloseCallBetTx } from \"../worker/settle-tx.js\";\n    16→import { CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n    17→import { decodeCloseCallRound, type DecodedCloseCallRound } from \"../worker/account-decoder.js\";\n    18→import type { CloseCallClockWorker } from \"../worker/closecall-clock.js\";\n    19→\n    20→export interface CloseCallRoutesDeps {\n    21→  db: Db;\n    22→  connection: Connection;\n    23→  serverKeypair: Keypair;\n    24→  clockWorker: CloseCallClockWorker;\n    25→  /** Postgres sql instance for candle queries. */\n    26→  sql: postgres.Sql;\n    27→}\n    28→\n    29→/** Minimum wager in lamports: 0.001 SOL */\n    30→const MIN_WAGER_LAMPORTS = 1_000_000;\n    31→const MAX_WAGER_LAMPORTS = 100_000_000_000; // 100 SOL\n    32→\n    33→function isValidBase58(s: string): boolean {\n    34→  return /^[1-9A-HJ-NP-Za-km-z]+$/.test(s);\n    35→}\n    36→\n    37→/** Convert a minuteTs bigint to an 8-byte LE buffer (for PDA seeds). */\n    38→function minuteTsToBuffer(ts: bigint): Buffer {\n    39→  const buf = Buffer.alloc(8);\n    40→  buf.writeBigInt64LE(ts);\n    41→  return buf;\n    42→}\n    43→\n    44→/** Derive the CloseCallRound PDA for a given minute timestamp. */\n    45→function deriveCloseCallRoundPda(minuteTs: bigint): PublicKey {\n    46→  const [pda] = PublicKey.findProgramAddressSync(\n    47→    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n    48→    CLOSECALL_PROGRAM_ID,\n    49→  );\n    50→  return pda;\n    51→}\n    52→\n    53→const PHASE_NAMES = [\"open\", \"settled\", \"refunded\"] as const;\n    54→const OUTCOME_NAMES = [\"pending\", \"green\", \"red\", \"refund\"] as const;\n    55→\n    56→/** Format a decoded on-chain round into the same shape as formatCloseCallRound. */\n    57→function formatOnChainRound(round: DecodedCloseCallRound, pda: PublicKey) {\n    58→  const greenEntries = round.greenEntries.map((e) => ({\n    59→    player: e.player.toBase58(),\n    60→    amountLamports: Number(e.amountLamports),\n    61→  }));\n    62→  const redEntries = round.redEntries.map((e) => ({\n    63→    player: e.player.toBase58(),\n    64→    amountLamports: Number(e.amountLamports),\n    65→  }));\n    66→  const greenPool = Number(round.greenPool);\n    67→  const redPool = Number(round.redPool);\n    68→  const totalPool = greenPool + redPool;\n    69→\n    70→  return {\n    71→    roundId: Number(round.minuteTs).toString(),\n    72→    pda: pda.toBase58(),\n    73→    phase: PHASE_NAMES[round.phase] ?? \"open\",\n    74→    openPrice: Number(round.openPrice),\n    75→    openPriceExpo: round.openPriceExpo,\n    76→    closePrice: round.phase === 0 ? null : Number(round.closePrice),\n    77→    outcome: OUTCOME_NAMES[round.outcome] ?? \"pending\",\n    78→    greenPool,\n    79→    redPool,\n    80→    totalPool,\n    81→    totalFee: Number(round.totalFee),\n    82→    greenEntries,\n    83→    redEntries,\n    84→    greenCount: greenEntries.length,\n    85→    redCount: redEntries.length,\n    86→    settleTx: null,\n    87→    createdAt: new Date(Number(round.createdAt) * 1000).toISOString(),\n    88→    settledAt: null,\n    89→  };\n    90→}\n    91→\n    92→function formatCloseCallRound(round: CloseCallRound) {\n    93→  const totalPool = round.green_pool + round.red_pool;\n    94→  return {\n    95→    roundId: round.round_id,\n    96→    pda: round.pda,\n    97→    phase: round.phase,\n    98→    openPrice: round.open_price,\n    99→    openPriceExpo: round.open_price_expo,\n   100→    closePrice: round.close_price,"}]},"parent_tool_use_id":"toolu_01ThcUuhBAqVohewpCgnJpcA","session_id":"193b62af-6140-4f02-b928-a21cc0840192","uuid":"46c667eb-cc7e-4a9c-8103-95bf673008dc","timestamp":"2026-03-25T12:15:28.805Z"}
