{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015vyAtD9RZhbZehSH6T5Hf5","type":"tool_result","content":"     1→import { Hono } from \"hono\";\n     2→import { cors } from \"hono/cors\";\n     3→import { serve } from \"@hono/node-server\";\n     4→import { Connection, PublicKey } from \"@solana/web3.js\";\n     5→import postgres from \"postgres\";\n     6→import { loadConfig } from \"./config.js\";\n     7→import { createDb } from \"./db.js\";\n     8→import { createAuthDb } from \"./auth-db.js\";\n     9→import { createCoinflipRoutes } from \"./routes/create.js\";\n    10→import { createLordRoutes } from \"./routes/lord-create.js\";\n    11→import { createRoundsRoutes } from \"./routes/rounds.js\";\n    12→import { createCloseCallRoutes } from \"./routes/closecall.js\";\n    13→import { createHealthRoutes } from \"./routes/health.js\";\n    14→import { createProfileRoutes } from \"./routes/profile.js\";\n    15→import { createPriceRoutes } from \"./routes/price.js\";\n    16→import { createAuthRoutes } from \"./routes/auth.js\";\n    17→import { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n    18→import { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n    19→import { createSettlementWorker } from \"./worker/settlement.js\";\n    20→import { settleRound } from \"./worker/settle-tx.js\";\n    21→import { createRetrySettler } from \"./worker/retry.js\";\n    22→import { createPdaWatcher } from \"./worker/pda-watcher.js\";\n    23→import { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n    24→import { createEventWorker } from \"./queue/index.js\";\n    25→import { logger } from \"./logger.js\";\n    26→\n    27→const config = loadConfig();\n    28→\n    29→// Shared postgres connection for both game DB and auth DB\n    30→const sql = postgres(config.databaseUrl);\n    31→const db = createDb(config.databaseUrl);\n    32→const authDb = createAuthDb(sql);\n    33→\n    34→const connection = new Connection(config.rpcUrl, {\n    35→  commitment: \"confirmed\",\n    36→  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n    37→});\n    38→\n    39→const app = new Hono();\n    40→\n    41→app.use(\n    42→  \"*\",\n    43→  cors({\n    44→    origin: \"*\",\n    45→    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n    46→    allowHeaders: [\"Content-Type\", \"Authorization\"],\n    47→  }),\n    48→);\n    49→\n    50→// Request logging — correlate frontend fetch timing with server-side processing\n    51→app.use(\"*\", async (c, next) => {\n    52→  const start = Date.now();\n    53→  await next();\n    54→  const ms = Date.now() - start;\n    55→  const method = c.req.method;\n    56→  const path = c.req.path;\n    57→  // Skip noisy health checks and OPTIONS preflight\n    58→  if (path === \"/health\" || method === \"OPTIONS\") return;\n    59→  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n    60→});\n    61→\n    62→// Auth routes — no JWT middleware (these are the login endpoints)\n    63→// Lighter rate limiting by IP for auth endpoints\n    64→app.use(\n    65→  \"/auth/*\",\n    66→  createRateLimitMiddleware({\n    67→    perWallet: 20,\n    68→    global: config.rateLimitGlobal,\n    69→    windowMs: 60_000,\n    70→  }),\n    71→);\n    72→\n    73→app.route(\n    74→  \"/auth\",\n    75→  createAuthRoutes({\n    76→    authDb,\n    77→    jwtSecret: config.jwtSecret,\n    78→    cluster: config.cluster,\n    79→    challengeTtlSeconds: config.challengeTtlSeconds,\n    80→    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    81→    refreshTokenTtlDays: config.refreshTokenTtlDays,\n    82→  }),\n    83→);\n    84→\n    85→// Profile routes — authenticated GET endpoints (require JWT on all methods)\n    86→app.use(\n    87→  \"/profile/*\",\n    88→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n    89→);\n    90→app.route(\"/profile\", createProfileRoutes({ db }));\n    91→\n    92→// JWT auth middleware for fairness endpoints\n    93→app.use(\n    94→  \"/fairness/*\",\n    95→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n    96→);\n    97→\n    98→// Rate limiting — per-wallet and global limits on POST requests\n    99→app.use(\n   100→  \"/fairness/*\",\n   101→  createRateLimitMiddleware({\n   102→    perWallet: config.rateLimitPerWallet,\n   103→    global: config.rateLimitGlobal,\n   104→    windowMs: 60_000,\n   105→  }),\n   106→);\n   107→\n   108→// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n   109→const entropyAccount = new PublicKey(config.entropyAccount);\n   110→const retrySettler = createRetrySettler({\n   111→  db,\n   112→  connection,\n   113→  settleRound: (pda) =>\n   114→    settleRound(\n   115→      { db, connection, serverKeypair: config.serverKeypair, entropyAccount },\n   116→      pda,\n   117→    ),\n   118→});\n   119→\n   120→// PDA watcher — WebSocket-based instant join detection\n   121→const pdaWatcher = createPdaWatcher({\n   122→  connection,\n   123→  serverKey: config.serverKeypair.publicKey,\n   124→  db,\n   125→  onJoinDetected: async (pda, targetSlot) => {\n   126→    // Update DB phase if still in 'created'\n   127→    const round = await db.getRoundByPda(pda);\n   128→    if (round && round.phase === \"created\") {\n   129→      await db.updateRoundPhase(pda, \"locked\", {\n   130→        target_slot: targetSlot.toString(),\n   131→      });\n   132→      await db.insertOperatorEvent(pda, \"match_detected\", {\n   133→        targetSlot: targetSlot.toString(),\n   134→        source: \"pda-watcher\",\n   135→        game: round.game,\n   136→      });\n   137→    }\n   138→\n   139→    // Check if target slot already passed — settle immediately if so\n   140→    const currentSlot = await connection.getSlot();\n   141→    if (BigInt(currentSlot) >= targetSlot) {\n   142→      await retrySettler.attemptSettle(pda);\n   143→      pdaWatcher.unwatch(pda);\n   144→    }\n   145→    // If target slot not reached yet, poll worker will pick it up next cycle\n   146→  },\n   147→});\n   148→\n   149→const worker = createSettlementWorker({\n   150→  db,\n   151→  connection,\n   152→  serverKey: config.serverKeypair.publicKey,\n   153→  pollIntervalMs: config.workerPollIntervalMs,\n   154→  onSettleReady: async (pda) => {\n   155→    await retrySettler.attemptSettle(pda);\n   156→    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n   157→  },\n   158→  isFinalized: (pda) => retrySettler.isFinalized(pda),\n   159→});\n   160→worker.start();\n   161→\n   162→// Close Call clock worker — fetches boundary prices + settles open rounds\n   163→// Rounds are created on-demand by players via /closecall/bet\n   164→const closeCallClock = createCloseCallClockWorker({\n   165→  connection,\n   166→  serverKeypair: config.serverKeypair,\n   167→  db: sql,\n   168→});\n   169→closeCallClock.start();\n   170→\n   171→// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n   172→const eventWorker = createEventWorker(sql, {\n   173→  pollIntervalMs: config.eventQueuePollMs,\n   174→});\n   175→eventWorker.start();\n   176→logger.info(\"Event queue worker started\", {\n   177→  pollIntervalMs: config.eventQueuePollMs,\n   178→});\n   179→\n   180→// Coinflip fairness routes\n   181→app.route(\n   182→  \"/fairness/coinflip\",\n   183→  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n   184→);\n   185→app.route(\n   186→  \"/fairness/lord\",\n   187→  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n   188→);\n   189→\n   190→// Close Call routes (create-round co-signing + candle history + read queries)\n   191→app.route(\"/closecall\", createCloseCallRoutes({\n   192→  db,\n   193→  connection,\n   194→  serverKeypair: config.serverKeypair,\n   195→  clockWorker: closeCallClock,\n   196→  sql,\n   197→}));\n   198→\n   199→// Price routes — public, no auth\n   200→app.route(\"/price\", createPriceRoutes());\n   201→\n   202→// Round verification routes\n   203→app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n   204→\n   205→// Health endpoint — wired after worker exists so we can query its status\n   206→app.route(\n   207→  \"/health\",\n   208→  createHealthRoutes({\n   209→    db,\n   210→    sql,\n   211→    connection,\n   212→    serverKey: config.serverKeypair.publicKey,\n   213→    isWorkerRunning: () => worker.isRunning,\n   214→    minSolBalance: config.minSolBalance,\n   215→  }),\n   216→);\n   217→\n   218→const port = config.port;\n   219→logger.info(\"fairness-backend started\", { port });\n   220→\n   221→serve({\n   222→  fetch: app.fetch,\n   223→  port,\n   224→});\n   225→\n   226→export default {\n   227→  port,\n   228→  fetch: app.fetch,\n   229→};\n   230→"}]},"parent_tool_use_id":"toolu_01ThcUuhBAqVohewpCgnJpcA","session_id":"193b62af-6140-4f02-b928-a21cc0840192","uuid":"9953932e-9f01-41fd-a10f-7aee4778bf2f","timestamp":"2026-03-25T12:15:09.526Z"}
