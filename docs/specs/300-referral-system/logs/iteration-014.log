{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Lzq5KNd2s97bN9AtuVsB92","type":"tool_result","content":"     1→/**\n     2→ * Referral routes — code management, linking, stats, earnings, and claims.\n     3→ */\n     4→\n     5→import { Hono } from \"hono\";\n     6→import type postgres from \"postgres\";\n     7→import type { AppEnv } from \"../hono-env.js\";\n     8→import type { Db } from \"../db.js\";\n     9→import type { Config } from \"../config.js\";\n    10→import { logger } from \"../logger.js\";\n    11→import { emitEvent } from \"../queue/emit-event.js\";\n    12→import { EventTypes } from \"../queue/event-types.js\";\n    13→\n    14→export interface ReferralRoutesDeps {\n    15→  db: Db;\n    16→  sql: postgres.Sql;\n    17→  config: Config;\n    18→}\n    19→\n    20→/** Referral code validation: 3-16 chars, lowercase alphanumeric + hyphens */\n    21→const CODE_REGEX = /^[a-z0-9-]{3,16}$/;\n    22→\n    23→const REFERRAL_BASE_URL = \"https://taunt.bet/r\";\n    24→\n    25→export function createReferralRoutes(deps: ReferralRoutesDeps) {\n    26→  const { db, sql, config } = deps;\n    27→  const app = new Hono<AppEnv>();\n    28→\n    29→  // POST /code — set or replace the player's referral code\n    30→  app.post(\"/code\", async (c) => {\n    31→    const wallet = c.get(\"wallet\");\n    32→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n    33→\n    34→    let body: { code?: unknown };\n    35→    try {\n    36→      body = await c.req.json();\n    37→    } catch {\n    38→      return c.json({ error: \"Invalid request body\" }, 400);\n    39→    }\n    40→\n    41→    const code = typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n    42→\n    43→    if (!CODE_REGEX.test(code)) {\n    44→      return c.json(\n    45→        {\n    46→          error: {\n    47→            code: \"INVALID_CODE\",\n    48→            message:\n    49→              \"Code must be 3-16 characters, lowercase letters, numbers, and hyphens only\",\n    50→          },\n    51→        },\n    52→        400,\n    53→      );\n    54→    }\n    55→\n    56→    // Check if this code is already taken by another wallet\n    57→    const existing = await db.getReferralCodeByCode(code);\n    58→    if (existing && existing.wallet !== wallet) {\n    59→      return c.json(\n    60→        {\n    61→          error: {\n    62→            code: \"CODE_TAKEN\",\n    63→            message: \"This referral code is already in use\",\n    64→            retryable: false,\n    65→          },\n    66→        },\n    67→        409,\n    68→      );\n    69→    }\n    70→\n    71→    try {\n    72→      const result = await db.upsertReferralCode(wallet, code);\n    73→      logger.info(\"Referral code set\", { wallet, code: result.code });\n    74→      return c.json({\n    75→        code: result.code,\n    76→        url: `${REFERRAL_BASE_URL}/${result.code}`,\n    77→      });\n    78→    } catch (err) {\n    79→      // Handle race condition: another wallet grabbed the code between check and insert\n    80→      const msg = err instanceof Error ? err.message : String(err);\n    81→      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n    82→        return c.json(\n    83→          {\n    84→            error: {\n    85→              code: \"CODE_TAKEN\",\n    86→              message: \"This referral code is already in use\",\n    87→              retryable: false,\n    88→            },\n    89→          },\n    90→          409,\n    91→        );\n    92→      }\n    93→      logger.error(\"Failed to set referral code\", { err: String(err), wallet });\n    94→      return c.json({ error: \"Failed to set referral code\" }, 500);\n    95→    }\n    96→  });\n    97→\n    98→  // POST /apply — link the authenticated player to a referrer via their code\n    99→  app.post(\"/apply\", async (c) => {\n   100→    const wallet = c.get(\"wallet\");\n   101→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   102→\n   103→    let body: { code?: unknown };\n   104→    try {\n   105→      body = await c.req.json();\n   106→    } catch {\n   107→      return c.json(\n   108→        {\n   109→          error: {\n   110→            code: \"INVALID_BODY\",\n   111→            message: \"Invalid request body\",\n   112→          },\n   113→        },\n   114→        400,\n   115→      );\n   116→    }\n   117→\n   118→    const code =\n   119→      typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n   120→\n   121→    if (!code) {\n   122→      return c.json(\n   123→        {\n   124→          error: {\n   125→            code: \"INVALID_CODE\",\n   126→            message: \"Referral code is required\",\n   127→          },\n   128→        },\n   129→        400,\n   130→      );\n   131→    }\n   132→\n   133→    // Look up the referral code to find the referrer\n   134→    const codeRow = await db.getReferralCodeByCode(code);\n   135→    if (!codeRow) {\n   136→      return c.json(\n   137→        {\n   138→          error: {\n   139→            code: \"CODE_NOT_FOUND\",\n   140→            message: \"Referral code does not exist\",\n   141→            retryable: false,\n   142→          },\n   143→        },\n   144→        404,\n   145→      );\n   146→    }\n   147→\n   148→    // Self-referral check\n   149→    if (codeRow.wallet === wallet) {\n   150→      return c.json(\n   151→        {\n   152→          error: {\n   153→            code: \"SELF_REFERRAL\",\n   154→            message: \"You cannot use your own referral code\",\n   155→            retryable: false,\n   156→          },\n   157→        },\n   158→        400,\n   159→      );\n   160→    }\n   161→\n   162→    // Check if the player already has a referrer\n   163→    const existingLink = await db.getReferralLinkByReferee(wallet);\n   164→    if (existingLink) {\n   165→      return c.json(\n   166→        {\n   167→          error: {\n   168→            code: \"ALREADY_LINKED\",\n   169→            message: \"You are already linked to a referrer\",\n   170→            retryable: false,\n   171→          },\n   172→        },\n   173→        409,\n   174→      );\n   175→    }\n   176→\n   177→    try {\n   178→      await db.insertReferralLink(codeRow.wallet, wallet);\n   179→      logger.info(\"Referral link created\", {\n   180→        referrer: codeRow.wallet,\n   181→        referee: wallet,\n   182→        code,\n   183→      });\n   184→      return c.json({\n   185→        referrer: codeRow.wallet,\n   186→        benefit: \"10% fee rebate on all games\",\n   187→      });\n   188→    } catch (err) {\n   189→      // Handle race condition: another request linked this referee between check and insert\n   190→      const msg = err instanceof Error ? err.message : String(err);\n   191→      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n   192→        return c.json(\n   193→          {\n   194→            error: {\n   195→              code: \"ALREADY_LINKED\",\n   196→              message: \"You are already linked to a referrer\",\n   197→              retryable: false,\n   198→            },\n   199→          },\n   200→          409,\n   201→        );\n   202→      }\n   203→      logger.error(\"Failed to create referral link\", {\n   204→        err: String(err),\n   205→        wallet,\n   206→        code,\n   207→      });\n   208→      return c.json({ error: \"Failed to apply referral code\" }, 500);\n   209→    }\n   210→  });\n   211→\n   212→  // GET /code — return the authenticated player's current referral code\n   213→  app.get(\"/code\", async (c) => {\n   214→    const wallet = c.get(\"wallet\");\n   215→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   216→\n   217→    const row = await db.getReferralCodeByWallet(wallet);\n   218→    if (!row) {\n   219→      return c.json(\n   220→        {\n   221→          error: {\n   222→            code: \"NO_CODE\",\n   223→            message: \"No referral code set for this wallet\",\n   224→          },\n   225→        },\n   226→        404,\n   227→      );\n   228→    }\n   229→\n   230→    return c.json({\n   231→      code: row.code,\n   232→      url: `${REFERRAL_BASE_URL}/${row.code}`,\n   233→    });\n   234→  });\n   235→\n   236→  // GET /stats — referral summary stats for authenticated wallet\n   237→  app.get(\"/stats\", async (c) => {\n   238→    const wallet = c.get(\"wallet\");\n   239→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   240→\n   241→    try {\n   242→      const stats = await db.getReferralStats(wallet);\n   243→      return c.json({\n   244→        referredCount: stats.referred_count,\n   245→        activeCount: stats.active_count,\n   246→        totalVolumeLamports: stats.total_volume_lamports,\n   247→        totalEarnedLamports: stats.total_earned_lamports,\n   248→        pendingLamports: stats.pending_lamports,\n   249→      });\n   250→    } catch (err) {\n   251→      logger.error(\"Failed to fetch referral stats\", {\n   252→        err: String(err),\n   253→        wallet,\n   254→      });\n   255→      return c.json({ error: \"Failed to fetch referral stats\" }, 500);\n   256→    }\n   257→  });\n   258→\n   259→  // GET /earnings — paginated per-game earnings log\n   260→  app.get(\"/earnings\", async (c) => {\n   261→    const wallet = c.get(\"wallet\");\n   262→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   263→\n   264→    const pageParam = c.req.query(\"page\");\n   265→    const limitParam = c.req.query(\"limit\");\n   266→    const page = pageParam ? Math.max(1, Math.floor(Number(pageParam))) : 1;\n   267→    const limit = limitParam\n   268→      ? Math.min(100, Math.max(1, Math.floor(Number(limitParam))))\n   269→      : 20;\n   270→\n   271→    if (Number.isNaN(page) || Number.isNaN(limit)) {\n   272→      return c.json(\n   273→        {\n   274→          error: {\n   275→            code: \"INVALID_PARAMS\",\n   276→            message: \"page and limit must be positive integers\",\n   277→          },\n   278→        },\n   279→        400,\n   280→      );\n   281→    }\n   282→\n   283→    try {\n   284→      const result = await db.getReferralEarnings(wallet, page, limit);\n   285→      return c.json({\n   286→        items: result.items.map((e) => ({\n   287→          roundId: e.round_id,\n   288→          gameType: e.game_type,\n   289→          refereeWallet: e.referee_wallet,\n   290→          wagerLamports: String(e.wager_lamports),\n   291→          earnedLamports: String(e.referrer_earned_lamports),\n   292→          createdAt: e.created_at.toISOString(),\n   293→        })),\n   294→        pagination: {\n   295→          page,\n   296→          totalPages: result.totalPages,\n   297→        },\n   298→      });\n   299→    } catch (err) {\n   300→      logger.error(\"Failed to fetch referral earnings\", {\n   301→        err: String(err),\n   302→        wallet,\n   303→      });\n   304→      return c.json({ error: \"Failed to fetch referral earnings\" }, 500);\n   305→    }\n   306→  });\n   307→\n   308→  // POST /claim — request payout of pending referral earnings (async via queue)\n   309→  app.post(\"/claim\", async (c) => {\n   310→    const wallet = c.get(\"wallet\");\n   311→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   312→\n   313→    try {\n   314→      // Snapshot pending balance\n   315→      const pendingStr = await db.getPendingBalance(wallet);\n   316→      const pendingLamports = BigInt(pendingStr);\n   317→\n   318→      if (pendingLamports <= 0n) {\n   319→        return c.json(\n   320→          {\n   321→            error: {\n   322→              code: \"ZERO_BALANCE\",\n   323→              message: \"No pending earnings to claim\",\n   324→              retryable: false,\n   325→            },\n   326→          },\n   327→          400,\n   328→        );\n   329→      }\n   330→\n   331→      if (pendingLamports < BigInt(config.referralMinClaimLamports)) {\n   332→        return c.json(\n   333→          {\n   334→            error: {\n   335→              code: \"BELOW_THRESHOLD\",\n   336→              message: `Minimum claim amount is ${config.referralMinClaimLamports} lamports (${(config.referralMinClaimLamports / 1e9).toFixed(2)} SOL)`,\n   337→              retryable: false,\n   338→            },\n   339→          },\n   340→          400,\n   341→        );\n   342→      }\n   343→\n   344→      // Atomically insert claim row + emit queue event\n   345→      const claim = await sql.begin(async (tx) => {\n   346→        const rows = await (tx as unknown as postgres.Sql)<\n   347→          {\n   348→            id: string;\n   349→            wallet: string;\n   350→            amount_lamports: string;\n   351→            status: string;\n   352→          }[]\n   353→        >`\n   354→          INSERT INTO referral_claims (wallet, amount_lamports, status)\n   355→          VALUES (${wallet}, ${pendingStr}, 'pending')\n   356→          RETURNING id, wallet, amount_lamports, status\n   357→        `;\n   358→        const row = rows[0]!;\n   359→\n   360→        await emitEvent(\n   361→          tx as unknown as postgres.Sql,\n   362→          EventTypes.REFERRAL_CLAIM_REQUESTED,\n   363→          {\n   364→            claimId: row.id,\n   365→            wallet: row.wallet,\n   366→            amountLamports: row.amount_lamports,\n   367→            requestedAt: new Date().toISOString(),\n   368→          },\n   369→        );\n   370→\n   371→        return row;\n   372→      });\n   373→\n   374→      logger.info(\"Referral claim requested\", {\n   375→        wallet,\n   376→        claimId: claim.id,\n   377→        amountLamports: claim.amount_lamports,\n   378→      });\n   379→\n   380→      return c.json(\n   381→        {\n   382→          claimId: claim.id,\n   383→          amountLamports: claim.amount_lamports,\n   384→          status: \"pending\",\n   385→        },\n   386→        202,\n   387→      );\n   388→    } catch (err) {\n   389→      logger.error(\"Failed to create referral claim\", {\n   390→        err: String(err),\n   391→        wallet,\n   392→      });\n   393→      return c.json({ error: \"Failed to create referral claim\" }, 500);\n   394→    }\n   395→  });\n   396→\n   397→  // GET /claim/:claimId — poll claim status\n   398→  app.get(\"/claim/:claimId\", async (c) => {\n   399→    const wallet = c.get(\"wallet\");\n   400→    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   401→\n   402→    const claimId = c.req.param(\"claimId\");\n   403→\n   404→    try {\n   405→      const claim = await db.getReferralClaim(claimId);\n   406→      if (!claim) {\n   407→        return c.json(\n   408→          {\n   409→            error: {\n   410→              code: \"CLAIM_NOT_FOUND\",\n   411→              message: \"Claim not found\",\n   412→            },\n   413→          },\n   414→          404,\n   415→        );\n   416→      }\n   417→\n   418→      // Only allow the claim owner to view their claim\n   419→      if (claim.wallet !== wallet) {\n   420→        return c.json(\n   421→          {\n   422→            error: {\n   423→              code: \"CLAIM_NOT_FOUND\",\n   424→              message: \"Claim not found\",\n   425→            },\n   426→          },\n   427→          404,\n   428→        );\n   429→      }\n   430→\n   431→      return c.json({\n   432→        claimId: claim.id,\n   433→        amountLamports: String(claim.amount_lamports),\n   434→        status: claim.status,\n   435→        ...(claim.tx_signature ? { txSignature: claim.tx_signature } : {}),\n   436→      });\n   437→    } catch (err) {\n   438→      logger.error(\"Failed to fetch referral claim\", {\n   439→        err: String(err),\n   440→        wallet,\n   441→        claimId,\n   442→      });\n   443→      return c.json({ error: \"Failed to fetch referral claim\" }, 500);\n   444→    }\n   445→  });\n   446→\n   447→  return app;\n   448→}\n   449→"}]},"parent_tool_use_id":"toolu_01BoceKhw4EJDGMKPbt5sFxY","session_id":"193b62af-6140-4f02-b928-a21cc0840192","uuid":"87622485-510f-43d2-b607-e7a0f17060b3","timestamp":"2026-03-25T12:15:11.537Z"}
