{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01YZpD3E2jBKxRL86wMwvYWK","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FTuBBVbJyZNyo6soKqVQTn","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/referral/hooks/useReferralApply.ts","content":"import { useEffect, useRef } from \"react\";\nimport { useSession } from \"../../../context/SessionContext\";\nimport { useWallet } from \"@rng-utopia/wallet/hooks\";\nimport { applyReferralCode } from \"../../../lib/referral-api\";\n\nconst STORAGE_KEY = \"referral_code\";\n\n/**\n * On authentication, if a referral code is stored in localStorage (from /r/:code),\n * auto-apply it via POST /referral/apply. Clears storage on success or permanent\n * failure (invalid code, already linked, self-referral). Keeps on transient failure\n * (network error) so it retries next auth.\n */\nexport function useReferralApply() {\n  const { isAuthenticated, accessToken } = useSession();\n  const { address } = useWallet();\n  const appliedRef = useRef(false);\n\n  useEffect(() => {\n    if (!isAuthenticated || !accessToken || !address) {\n      appliedRef.current = false;\n      return;\n    }\n\n    // Prevent duplicate calls within the same auth session\n    if (appliedRef.current) return;\n\n    let stored: string | null = null;\n    try {\n      stored = localStorage.getItem(STORAGE_KEY);\n    } catch {\n      // localStorage unavailable\n      return;\n    }\n\n    if (!stored) return;\n\n    let code: string;\n    try {\n      const parsed = JSON.parse(stored);\n      code = parsed?.code;\n    } catch {\n      // Corrupt data — remove it\n      try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n      return;\n    }\n\n    if (!code || typeof code !== \"string\") {\n      try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n      return;\n    }\n\n    appliedRef.current = true;\n\n    applyReferralCode(accessToken, code)\n      .then(() => {\n        try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n        // Success toast — use console for now; will be replaced when toast system exists\n        console.info(\"[referral] Referral code applied successfully\");\n      })\n      .catch((err: Error) => {\n        const msg = err.message ?? \"\";\n        // Permanent failures — code invalid, already linked, self-referral\n        const isPermanent =\n          msg.includes(\"ALREADY_LINKED\") ||\n          msg.includes(\"SELF_REFERRAL\") ||\n          msg.includes(\"NOT_FOUND\") ||\n          msg.includes(\"INVALID\") ||\n          msg.includes(\"already linked\") ||\n          msg.includes(\"not found\") ||\n          msg.includes(\"Cannot refer yourself\");\n\n        if (isPermanent) {\n          try { localStorage.removeItem(STORAGE_KEY); } catch { /* noop */ }\n        }\n        // Transient failures (network, 500): keep localStorage for retry on next auth\n      });\n  }, [isAuthenticated, accessToken, address]);\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":113,"cache_read_input_tokens":63489,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":113},"output_tokens":67,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"6e340fd0-3e08-4923-9328-61b8592b2652","uuid":"feb256ff-6f21-42fa-8035-a85edc28f01b"}
