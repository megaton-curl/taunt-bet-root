\n    58→    const msg =\n    59→      typeof err === \"string\"\n    60→        ? err\n    61→        : typeof err?.message === \"string\"\n    62→          ? err.message\n    63→          : `Referral request failed (${res.status})`;\n    64→    throw new Error(msg);\n    65→  }\n    66→  return json as T;\n    67→}\n    68→\n    69→function authHeaders(token: string): Record<string, string> {\n    70→  return {\n    71→    \"Content-Type\": \"application/json\",\n    72→    Authorization: `Bearer ${token}`,\n    73→  };\n    74→}\n    75→\n    76→/* ── API functions ──────────────────────────────────────────────── */\n    77→\n    78→/** Set (or replace) the authenticated player's referral code. */\n    79→export async function setReferralCode(\n    80→  token: string,\n    81→  code: string,\n    82→): Promise<ReferralCodeResponse> {\n    83→  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    84→    method: \"POST\",\n    85→    headers: authHeaders(token),\n    86→    body: JSON.stringify({ code }),\n    87→  });\n    88→  return parseResponse<ReferralCodeResponse>(res);\n    89→}\n    90→\n    91→/** Get the authenticated player's current referral code, or throw on 404. */\n    92→export async function getReferralCode(\n    93→  token: string,\n    94→): Promise<ReferralCodeResponse> {\n    95→  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    96→    headers: authHeaders(token),\n    97→  });\n    98→  return parseResponse<ReferralCodeResponse>(res);\n    99→}\n   100→\n   101→/** Apply a referral code to the authenticated player (link to referrer). */\n   102→export async function applyReferralCode(\n   103→  token: string,\n   104→  code: string,\n   105→): Promise<ApplyReferralResponse> {\n   106→  const res = await fetch(`${BACKEND_URL}/referral/apply`, {\n   107→    method: \"POST\",\n   108→    headers: authHeaders(token),\n   109→    body: JSON.stringify({ code }),\n   110→  });\n   111→  return parseResponse<ApplyReferralResponse>(res);\n   112→}\n   113→\n   114→/** Get referral summary stats for the authenticated player. */\n   115→export async function getReferralStats(\n   116→  token: string,\n   117→): Promise<ReferralStatsResponse> {\n   118→  const res = await fetch(`${BACKEND_URL}/referral/stats`, {\n   119→    headers: authHeaders(token),\n   120→  });\n   121→  return parseResponse<ReferralStatsResponse>(res);\n   122→}\n   123→\n   124→/** Get paginated per-game referral earnings log. */\n   125→export async function getReferralEarnings(\n   126→  token: string,\n   127→  page?: number,\n   128→  limit?: number,\n   129→): Promise<ReferralEarningsResponse> {\n   130→  const parts: string[] = [];\n   131→  if (page != null) parts.push(`page=${page}`);\n   132→  if (limit != null) parts.push(`limit=${limit}`);\n   133→  const qs = parts.length ? `?${parts.join(\"&\")}` : \"\";\n   134→  const res = await fetch(`${BACKEND_URL}/referral/earnings${qs}`, {\n   135→    headers: authHeaders(token),\n   136→  });\n   137→  return parseResponse<ReferralEarningsResponse>(res);\n   138→}\n   139→\n   140→/** Request an async claim of all pending referral earnings. Returns 202. */\n   141→export async function requestReferralClaim(\n   142→  token: string,\n   143→): Promise<ClaimResponse> {\n   144→  const res = await fetch(`${BACKEND_URL}/referral/claim`, {\n   145→    method: \"POST\",\n   146→    headers: authHeaders(token),\n   147→  });\n   148→  return parseResponse<ClaimResponse>(res);\n   149→}\n   150→\n   151→/** Poll the status of an existing claim by ID. */\n   152→export async function pollClaimStatus(\n   153→  token: string,\n   154→  claimId: string,\n   155→): Promise<ClaimResponse> {\n   156→  const res = await fetch(`${BACKEND_URL}/referral/claim/${claimId}`, {\n   157→    headers: authHeaders(token),\n   158→  });\n   159→  return parseResponse<ClaimResponse>(res);\n   160→}\n   161→"}]},"parent_tool_use_id":null,"session_id":"6e340fd0-3e08-4923-9328-61b8592b2652","uuid":"100f8509-3c23-4192-9c88-4fe0f868ca9d","timestamp":"2026-03-25T13:02:09.794Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/lib/referral-api.ts","content":"/**\n * Thin fetch wrappers for the /referral/* backend endpoints.\n * All calls require JWT Bearer auth from useSession().accessToken.\n */\n\nconst BACKEND_URL = (\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n).replace(/\\/$/, \"\");\n\n/* ── Response types ─────────────────────────────────────────────── */\n\nexport interface ReferralCodeResponse {\n  code: string;\n  url: string;\n}\n\nexport interface ApplyReferralResponse {\n  referrer: string;\n  benefit: string;\n}\n\nexport interface ReferralStatsResponse {\n  referredCount: number;\n  activeCount: number;\n  totalVolumeLamports: string;\n  totalEarnedLamports: string;\n  pendingLamports: string;\n}\n\nexport interface ReferralEarningItem {\n  roundId: string;\n  gameType: string;\n  refereeWallet: string;\n  wagerLamports: string;\n  earnedLamports: string;\n  createdAt: string;\n}\n\nexport interface ReferralEarningsResponse {\n  items: ReferralEarningItem[];\n  pagination: { page: number; totalPages: number };\n}\n\nexport interface ClaimResponse {\n  claimId: string;\n  amountLamports: string;\n  status: \"pending\" | \"completed\" | \"failed\";\n  txSignature?: string;\n}\n\n/* ── Helpers ────────────────────────────────────────────────────── */\n\nasync function parseResponse<T>(res: Response): Promise<T> {\n  const json = await res.json();\n  if (!res.ok) {\n    const err = json?.error;\n    const msg =\n      typeof err === \"string\"\n        ? err\n        : typeof err?.message === \"string\"\n          ? err.message\n          : `Referral request failed (${res.status})`;\n    throw new Error(msg);\n  }\n  return json as T;\n}\n\nfunction authHeaders(token: string): Record<string, string> {\n  return {\n    \"Content-Type\": \"application/json\",\n    Authorization: `Bearer ${token}`,\n  };\n}\n\n/* ── API functions ──────────────────────────────────────────────── */\n\n/** Set (or replace) the authenticated player's referral code. */\nexport async function setReferralCode(\n  token: string,\n  code: string,\n): Promise<ReferralCodeResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    method: \"POST\",\n    headers: authHeaders(token),\n    body: JSON.stringify({ code }),\n  });\n  return parseResponse<ReferralCodeResponse>(res);\n}\n\n/** Get the authenticated player's current referral code, or throw on 404. */\nexport async function getReferralCode(\n  token: string,\n): Promise<ReferralCodeResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ReferralCodeResponse>(res);\n}\n\n/** Apply a referral code to the authenticated player (link to referrer). */\nexport async function applyReferralCode(\n  token: string,\n  code: string,\n): Promise<ApplyReferralResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/apply`, {\n    method: \"POST\",\n    headers: authHeaders(token),\n    body: JSON.stringify({ code }),\n  });\n  return parseResponse<ApplyReferralResponse>(res);\n}\n\n/** Get referral summary stats for the authenticated player. */\nexport async function getReferralStats(\n  token: string,\n): Promise<ReferralStatsResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/stats`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ReferralStatsResponse>(res);\n}\n\n/** Get paginated per-game referral earnings log. */\nexport async function getReferralEarnings(\n  token: string,\n  page?: number,\n  limit?: number,\n): Promise<ReferralEarningsResponse> {\n  const parts: string[] = [];\n  if (page != null) parts.push(`page=${page}`);\n  if (limit != null) parts.push(`limit=${limit}`);\n  const qs = parts.length ? `?${parts.join(\"&\")}` : \"\";\n  const res = await fetch(`${BACKEND_URL}/referral/earnings${qs}`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ReferralEarningsResponse>(res);\n}\n\n/** Request an async claim of all pending referral earnings. Returns 202. */\nexport async function requestReferralClaim(\n  token: string,\n): Promise<ClaimResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/claim`, {\n    method: \"POST\",\n    headers: authHeaders(token),\n  });\n  return parseResponse<ClaimResponse>(res);\n}\n\n/** Poll the status of an existing claim by ID. */\nexport async function pollClaimStatus(\n  token: string,\n  claimId: string,\n): Promise<ClaimResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/claim/${claimId}`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ClaimResponse>(res);\n}\n","numLines":161,"startLine":1,"totalLines":161}}}
