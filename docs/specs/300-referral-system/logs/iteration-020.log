rovider>\n    33→              <AppContent />\n    34→            </BossRaidProvider>\n    35→          </QuestsProvider>\n    36→        </PlayerProfileProvider>\n    37→      </PriceFeedProvider>\n    38→    </BrowserRouter>\n    39→  );\n    40→}\n    41→\n    42→\n    43→// Chat icon SVG\n    44→const ChatIcon = () => (\n    45→  <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" width=\"20\" height=\"20\">\n    46→    <path d=\"M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z\"/>\n    47→    <circle cx=\"8\" cy=\"10\" r=\"1.5\"/>\n    48→    <circle cx=\"12\" cy=\"10\" r=\"1.5\"/>\n    49→    <circle cx=\"16\" cy=\"10\" r=\"1.5\"/>\n    50→  </svg>\n    51→);\n    52→\n    53→// Footer component with terms and FAQ modals\n    54→function Footer() {\n    55→  const [showTerms, setShowTerms] = useState(false);\n    56→  const [showFAQ, setShowFAQ] = useState(false);\n    57→  const [expandedFAQ, setExpandedFAQ] = useState<string | null>(null);\n    58→  const termsModalRef = useRef<HTMLDivElement>(null);\n    59→  const faqModalRef = useRef<HTMLDivElement>(null);\n    60→\n    61→  // Close modal on outside click\n    62→  useEffect(() => {\n    63→    if (!showTerms && !showFAQ) return;\n    64→\n    65→    const handleClickOutside = (e: MouseEvent) => {\n    66→      if (showTerms && termsModalRef.current && !termsModalRef.current.contains(e.target as Node)) {\n    67→        setShowTerms(false);\n    68→      }\n    69→      if (showFAQ && faqModalRef.current && !faqModalRef.current.contains(e.target as Node)) {\n    70→        setShowFAQ(false);\n    71→      }\n    72→    };\n    73→\n    74→    document.addEventListener(\"mousedown\", handleClickOutside);\n    75→    return () => document.removeEventListener(\"mousedown\", handleClickOutside);\n    76→  }, [showTerms, showFAQ]);\n    77→\n    78→  // Close on escape\n    79→  useEffect(() => {\n    80→    if (!showTerms && !showFAQ) return;\n    81→\n    82→    const handleEscape = (e: KeyboardEvent) => {\n    83→      if (e.key === \"Escape\") {\n    84→        setShowTerms(false);\n    85→        setShowFAQ(false);\n    86→      }\n    87→    };\n    88→\n    89→    document.addEventListener(\"keydown\", handleEscape);\n    90→    return () => document.removeEventListener(\"keydown\", handleEscape);\n    91→  }, [showTerms, showFAQ]);\n    92→\n    93→  const toggleFAQSection = (section: string) => {\n    94→    setExpandedFAQ(expandedFAQ === section ? null : section);\n    95→  };\n    96→\n    97→  const faqSections = [\n    98→    {\n    99→      id: \"fees\",\n   100→      title: \"Platform Fees\","}]},"parent_tool_use_id":"toolu_01VR6nJBUdGJdFfgxRHSBf3G","session_id":"6e340fd0-3e08-4923-9328-61b8592b2652","uuid":"1e4b08d7-b91a-44d6-8cfd-70710462eba7","timestamp":"2026-03-25T13:00:54.497Z"}
