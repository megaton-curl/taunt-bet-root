       <line x1=\"70\" y1=\"64\" x2=\"22\" y2=\"16\" stroke=\"#3D7FFF\" strokeWidth=\"3\" strokeLinecap=\"round\" />\n            <line x1=\"56\" y1=\"50\" x2=\"47\" y2=\"59\" stroke=\"#3D7FFF\" strokeWidth=\"5\" strokeLinecap=\"round\" opacity=\"0.55\" />\n            <circle cx=\"80\" cy=\"74\" r=\"4.5\" fill=\"rgba(61,127,255,0.45)\" stroke=\"#3D7FFF\" strokeWidth=\"1\" />\n          </g>\n          <g className=\"sw-r\">\n            <line x1=\"65\" y1=\"64\" x2=\"113\" y2=\"16\" stroke=\"#3D7FFF\" strokeWidth=\"3\" strokeLinecap=\"round\" />\n            <line x1=\"79\" y1=\"50\" x2=\"88\" y2=\"59\" stroke=\"#3D7FFF\" strokeWidth=\"5\" strokeLinecap=\"round\" opacity=\"0.55\" />\n            <circle cx=\"55\" cy=\"74\" r=\"4.5\" fill=\"rgba(61,127,255,0.45)\" stroke=\"#3D7FFF\" strokeWidth=\"1\" />\n          </g>\n          <circle cx=\"67.5\" cy=\"63\" r=\"5.5\" fill=\"rgba(255,184,0,0.55)\" className=\"spark-p\" />\n          <line x1=\"67.5\" y1=\"54\" x2=\"67.5\" y2=\"46\" stroke=\"#FFB800\" strokeWidth=\"1.5\" strokeLinecap=\"round\" opacity=\"0.55\" />\n          <line x1=\"73\" y1=\"57\" x2=\"79\" y2=\"51\" stroke=\"#FFB800\" strokeWidth=\"1.5\" strokeLinecap=\"round\" opacity=\"0.55\" />\n          <line x1=\"62\" y1=\"57\" x2=\"56\" y2=\"51\" stroke=\"#FFB800\" strokeWidth=\"1.5\" strokeLinecap=\"round\" opacity=\"0.55\" />\n          <rect x=\"12\" y=\"113\" width=\"48\" height=\"15\" rx=\"1.5\" fill=\"rgba(0,230,118,0.08)\" stroke=\"rgba(0,230,118,0.25)\" strokeWidth=\"1\" />\n          <text x=\"36\" y=\"124\" textAnchor=\"middle\" fontFamily=\"'Bebas Neue', sans-serif\" fontSize=\"11\" fill=\"#00E676\" letterSpacing=\"1\">+28.4%</text>\n          <rect x=\"75\" y=\"113\" width=\"48\" height=\"15\" rx=\"1.5\" fill=\"rgba(255,45,85,0.08)\" stroke=\"rgba(255,45,85,0.25)\" strokeWidth=\"1\" />\n          <text x=\"99\" y=\"124\" textAnchor=\"middle\" fontFamily=\"'Bebas Neue', sans-serif\" fontSize=\"11\" fill=\"#FF2D55\" letterSpacing=\"1\">REKT</tex