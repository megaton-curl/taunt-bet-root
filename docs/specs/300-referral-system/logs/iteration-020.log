{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0159DxKrL23AgGxMcDGoF2ci","type":"tool_result","content":"     1→/**\n     2→ * useTransactions — fetches transaction history from the real API.\n     3→ *\n     4→ * Uses JWT auth (from auth-store) and cursor-based pagination.\n     5→ */\n     6→\n     7→import { useState, useCallback, useEffect, useRef } from \"react\";\n     8→import { getAccessToken } from \"../../../lib/auth-store\";\n     9→import type { GameId, TransactionType } from \"../types\";\n    10→\n    11→const BACKEND_URL = (\n    12→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    13→    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n    14→).replace(/\\/$/, \"\");\n    15→\n    16→interface ApiTransaction {\n    17→  id: string;\n    18→  game: string;\n    19→  matchId: string;\n    20→  txType: TransactionType;\n    21→  amountLamports: string;\n    22→  txSig: string;\n    23→  createdAt: string;\n    24→}\n    25→\n    26→interface ApiResponse {\n    27→  transactions: ApiTransaction[];\n    28→  nextCursor: string | null;\n    29→}\n    30→\n    31→export interface Transaction {\n    32→  id: string;\n    33→  gameId: GameId;\n    34→  matchId: string;\n    35→  txType: TransactionType;\n    36→  amountLamports: string;\n    37→  txSig: string;\n    38→  createdAt: string;\n    39→}\n    40→\n    41→export function useTransactions(game?: string) {\n    42→  const [transactions, setTransactions] = useState<Transaction[]>([]);\n    43→  const [nextCursor, setNextCursor] = useState<string | null>(null);\n    44→  const [loading, setLoading] = useState(true);\n    45→  const [loadingMore, setLoadingMore] = useState(false);\n    46→  const [error, setError] = useState<string | null>(null);\n    47→  const abortRef = useRef<AbortController | null>(null);\n    48→\n    49→  const fetchPage = useCallback(\n    50→    async (cursor?: string) => {\n    51→      const token = getAccessToken();\n    52→      if (!token) {\n    53→        setTransactions([]);\n    54→        setLoading(false);\n    55→        return;\n    56→      }\n    57→\n    58→      // Build query string\n    59→      const parts = [\"limit=20\"];\n    60→      if (cursor) parts.push(`cursor=${encodeURIComponent(cursor)}`);\n    61→      if (game) parts.push(`game=${encodeURIComponent(game)}`);\n    62→      const qs = parts.join(\"&\");\n    63→\n    64→      // Abort any in-flight request\n    65→      abortRef.current?.abort();\n    66→      const controller = new AbortController();\n    67→      abortRef.current = controller;\n    68→\n    69→      try {\n    70→        const res = await fetch(\n    71→          `${BACKEND_URL}/profile/transactions?${qs}`,\n    72→          {\n    73→            headers: { Authorization: `Bearer ${token}` },\n    74→            signal: controller.signal,\n    75→          },\n    76→        );\n    77→        if (!res.ok) throw new Error(`HTTP ${res.status}`);\n    78→        const data: ApiResponse = await res.json();\n    79→\n    80→        const mapped: Transaction[] = data.transactions.map((tx) => ({\n    81→          id: tx.id,\n    82→          gameId: tx.game as GameId,\n    83→          matchId: tx.matchId,\n    84→          txType: tx.txType,\n    85→          amountLamports: tx.amountLamports,\n    86→          txSig: tx.txSig,\n    87→          createdAt: tx.createdAt,\n    88→        }));\n    89→\n    90→        if (cursor) {\n    91→          setTransactions((prev) => [...prev, ...mapped]);\n    92→        } else {\n    93→          setTransactions(mapped);\n    94→        }\n    95→        setNextCursor(data.nextCursor);\n    96→        setError(null);\n    97→      } catch (err) {\n    98→        if (err instanceof Error && err.name === \"AbortError\") return;\n    99→        setError(err instanceof Error ? err.message : \"Failed to fetch\");\n   100→      } finally {\n   101→        setLoading(false);\n   102→        setLoadingMore(false);\n   103→      }\n   104→    },\n   105→    [game],\n   106→  );\n   107→\n   108→  useEffect(() => {\n   109→    setLoading(true);\n   110→    setTransactions([]);\n   111→    setNextCursor(null);\n   112→    fetchPage();\n   113→    return () => abortRef.current?.abort();\n   114→  }, [fetchPage]);\n   115→\n   116→  const loadMore = useCallback(() => {\n   117→    if (!nextCursor || loadingMore) return;\n   118→    setLoadingMore(true);\n   119→    fetchPage(nextCursor);\n   120→  }, [nextCursor, loadingMore, fetchPage]);\n   121→\n   122→  return { transactions, loading, loadingMore, error, nextCursor, loadMore };\n   123→}\n   124→"}]},"parent_tool_use_id":"toolu_01VR6nJBUdGJdFfgxRHSBf3G","session_id":"6e340fd0-3e08-4923-9328-61b8592b2652","uuid":"56915db7-acc3-46d1-9d03-16a92c4d8602","timestamp":"2026-03-25T13:00:47.718Z"}
