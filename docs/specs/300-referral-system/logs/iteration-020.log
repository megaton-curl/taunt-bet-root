{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015rAGqLF8kYq7QL3whUug8X","type":"tool_result","content":"     1→/**\n     2→ * useSolPrice — fetches cached SOL/USD price from the backend.\n     3→ *\n     4→ * Refreshes every 60s. Returns null when price is unavailable.\n     5→ */\n     6→\n     7→import { useState, useEffect, useRef } from \"react\";\n     8→\n     9→const BACKEND_URL = (\n    10→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    11→    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n    12→).replace(/\\/$/, \"\");\n    13→\n    14→const REFRESH_INTERVAL_MS = 60_000;\n    15→\n    16→export function useSolPrice(): number | null {\n    17→  const [price, setPrice] = useState<number | null>(null);\n    18→  const intervalRef = useRef<ReturnType<typeof setInterval> | null>(null);\n    19→\n    20→  useEffect(() => {\n    21→    let cancelled = false;\n    22→\n    23→    async function fetchPrice() {\n    24→      try {\n    25→        const res = await fetch(`${BACKEND_URL}/price/sol-usd`);\n    26→        if (!res.ok) return;\n    27→        const data: { price: number } = await res.json();\n    28→        if (!cancelled) setPrice(data.price);\n    29→      } catch {\n    30→        // Graceful degradation — keep previous price or null\n    31→      }\n    32→    }\n    33→\n    34→    fetchPrice();\n    35→    intervalRef.current = setInterval(fetchPrice, REFRESH_INTERVAL_MS);\n    36→\n    37→    return () => {\n    38→      cancelled = true;\n    39→      if (intervalRef.current) clearInterval(intervalRef.current);\n    40→    };\n    41→  }, []);\n    42→\n    43→  return price;\n    44→}\n    45→"}]},"parent_tool_use_id":"toolu_01VR6nJBUdGJdFfgxRHSBf3G","session_id":"6e340fd0-3e08-4923-9328-61b8592b2652","uuid":"477704d3-2152-49f8-9508-a98fd561f2a0","timestamp":"2026-03-25T13:00:48.462Z"}
