{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WUgoVozLRnCiJuoBbiL9WU","type":"tool_result","content":"     1→/**\n     2→ * Quests Context\n     3→ *\n     4→ * Provides quest state and actions to the app.\n     5→ * Listens to the profile event bus to track game activity.\n     6→ */\n     7→\n     8→import {\n     9→  createContext,\n    10→  useContext,\n    11→  useState,\n    12→  useEffect,\n    13→  useCallback,\n    14→  type ReactNode,\n    15→} from \"react\";\n    16→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n    17→import { profileEventBus } from \"../../player-profile/utils/profile-event-bus\";\n    18→import { awardXP } from \"../../player-profile/utils/mock-simulation\";\n    19→import {\n    20→  type QuestProgress,\n    21→  type TreasureChest,\n    22→  type ChestContents,\n    23→  type ChestDropNotification,\n    24→  type QuestsContextValue,\n    25→  ALL_QUESTS,\n    26→  getNextDailyReset,\n    27→  getNextWeeklyReset,\n    28→} from \"../types\";\n    29→import {\n    30→  getOrCreateChests,\n    31→  getUnopenedChestCount,\n    32→  recordGamePlayed,\n    33→  claimQuestReward as claimReward,\n    34→  openChest as openChestMock,\n    35→  openAllChests as openAllChestsMock,\n    36→  subscribeToQuestState,\n    37→  subscribeToChests,\n    38→} from \"../utils/mock-simulation\";\n    39→\n    40→const QuestsContext = createContext<QuestsContextValue | null>(null);\n    41→\n    42→export function QuestsProvider({ children }: { children: ReactNode }) {\n    43→  const { address } = useWallet();\n    44→\n    45→  // Quest state\n    46→  const [dailyQuests, setDailyQuests] = useState<QuestProgress[]>([]);\n    47→  const [weeklyQuests, setWeeklyQuests] = useState<QuestProgress[]>([]);\n    48→  const [dailyResetAt, setDailyResetAt] = useState(getNextDailyReset());\n    49→  const [weeklyResetAt, setWeeklyResetAt] = useState(getNextWeeklyReset());\n    50→  const [loading, setLoading] = useState(true);\n    51→\n    52→  // Treasure chests\n    53→  const [treasureChests, setTreasureChests] = useState<TreasureChest[]>([]);\n    54→  const [unopenedChestCount, setUnopenedChestCount] = useState(0);\n    55→\n    56→  // Chest drop notification\n    57→  const [chestDropNotification, setChestDropNotification] = useState<ChestDropNotification>({\n    58→    visible: false,\n    59→    source: null,\n    60→    rarity: null,\n    61→  });\n    62→\n    63→  // Load quest state when address changes\n    64→  useEffect(() => {\n    65→    if (!address) {\n    66→      setDailyQuests([]);\n    67→      setWeeklyQuests([]);\n    68→      setTreasureChests([]);\n    69→      setUnopenedChestCount(0);\n    70→      setLoading(false);\n    71→      return;\n    72→    }\n    73→\n    74→    setLoading(true);\n    75→\n    76→    // Subscribe to quest state updates\n    77→    const unsubscribe = subscribeToQuestState(address, (state) => {\n    78→      setDailyQuests([...state.dailyQuests]);\n    79→      setWeeklyQuests([...state.weeklyQuests]);\n    80→      setDailyResetAt(state.dailyResetAt);\n    81→      setWeeklyResetAt(state.weeklyResetAt);\n    82→\n    83→      // Update chests\n    84→      const chests = getOrCreateChests(address);\n    85→      setTreasureChests([...chests]);\n    86→      setUnopenedChestCount(getUnopenedChestCount(address));\n    87→\n    88→      setLoading(false);\n    89→    });\n    90→\n    91→    return unsubscribe;\n    92→  }, [address]);\n    93→\n    94→  // Subscribe to chest updates (for RNG Buff drops)\n    95→  useEffect(() => {\n    96→    if (!address) return;\n    97→\n    98→    let prevChestCount = 0;\n    99→    let isFirstLoad = true;\n   100→\n   101→    const unsubscribe = subscribeToChests(address, (chests) => {\n   102→      const newUnopenedCount = chests.filter((c) => !c.opened).length;\n   103→\n   104→      // Check if a new chest was added (not on initial load)\n   105→      if (!isFirstLoad && newUnopenedCount > prevChestCount) {\n   106→        // Find the newest RNG Buff chest by earnedAt\n   107→        const newestChest = chests\n   108→          .filter((c) => !c.opened && c.source === \"rng_buff\")\n   109→          .sort((a, b) => b.earnedAt - a.earnedAt)[0];\n   110→        if (newestChest) {\n   111→          setChestDropNotification({\n   112→            visible: true,\n   113→            source: \"rng_buff\",\n   114→            rarity: newestChest.rarity ?? \"common\",\n   115→          });\n   116→          setTimeout(() => {\n   117→            setChestDropNotification({ visible: false, source: null, rarity: null });\n   118→          }, 3000);\n   119→        }\n   120→      }\n   121→\n   122→      prevChestCount = newUnopenedCount;\n   123→      isFirstLoad = false;\n   124→\n   125→      setTreasureChests([...chests]);\n   126→      setUnopenedChestCount(newUnopenedCount);\n   127→    });\n   128→\n   129→    return unsubscribe;\n   130→  }, [address]);\n   131→\n   132→  // Listen to game results from the profile event bus\n   133→  useEffect(() => {\n   134→    if (!address) return;\n   135→\n   136→    const unsubscribe = profileEventBus.subscribe((event) => {\n   137→      // Only track events for this user\n   138→      if (event.playerAddress !== address) return;\n   139→\n   140→      // Record the game played\n   141→      const won = event.outcome === \"win\";\n   142→      recordGamePlayed(address, event.gameId, won);\n   143→\n   144→      // Update chest count in case quests were auto-completed\n   145→      setUnopenedChestCount(getUnopenedChestCount(address));\n   146→    });\n   147→\n   148→    return unsubscribe;\n   149→  }, [address]);\n   150→\n   151→  // Claim quest reward\n   152→  const claimQuestReward = useCallback(\n   153→    async (questId: string): Promise<{ xp: number; chests: number }> => {\n   154→      if (!address) {\n   155→        throw new Error(\"Wallet not connected\");\n   156→      }\n   157→\n   158→      // Simulate network delay\n   159→      await new Promise((resolve) => setTimeout(resolve, 300));\n   160→\n   161→      const result = claimReward(address, questId);\n   162→      if (!result.success) {\n   163→        throw new Error(result.error || \"Failed to claim reward\");\n   164→      }\n   165→\n   166→      // Award XP to player profile\n   167→      if (result.xp > 0) {\n   168→        awardXP(address, result.xp);\n   169→      }\n   170→\n   171→      // Update chests\n   172→      const chests = getOrCreateChests(address);\n   173→      setTreasureChests([...chests]);\n   174→      setUnopenedChestCount(getUnopenedChestCount(address));\n   175→\n   176→      return { xp: result.xp, chests: result.chests };\n   177→    },\n   178→    [address]\n   179→  );\n   180→\n   181→  // Open a single chest\n   182→  const openChest = useCallback(\n   183→    async (chestId: string): Promise<ChestContents> => {\n   184→      if (!address) {\n   185→        throw new Error(\"Wallet not connected\");\n   186→      }\n   187→\n   188→      // Simulate network delay\n   189→      await new Promise((resolve) => setTimeout(resolve, 500));\n   190→\n   191→      const result = openChestMock(address, chestId);\n   192→      if (!result.success || !result.contents) {\n   193→        throw new Error(result.error || \"Failed to open chest\");\n   194→      }\n   195→\n   196→      // Award XP from chest\n   197→      if (result.contents.xp > 0) {\n   198→        awardXP(address, result.contents.xp);\n   199→      }\n   200→\n   201→      // Update chests\n   202→      const chests = getOrCreateChests(address);\n   203→      setTreasureChests([...chests]);\n   204→      setUnopenedChestCount(getUnopenedChestCount(address));\n   205→\n   206→      return result.contents;\n   207→    },\n   208→    [address]\n   209→  );\n   210→\n   211→  // Open all chests\n   212→  const openAllChests = useCallback(async (): Promise<ChestContents> => {\n   213→    if (!address) {\n   214→      throw new Error(\"Wallet not connected\");\n   215→    }\n   216→\n   217→    // Simulate network delay\n   218→    await new Promise((resolve) => setTimeout(resolve, 800));\n   219→\n   220→    const result = openAllChestsMock(address);\n   221→    if (!result.success) {\n   222→      throw new Error(\"Failed to open chests\");\n   223→    }\n   224→\n   225→    // Award XP from all chests\n   226→    if (result.totalXp > 0) {\n   227→      awardXP(address, result.totalXp);\n   228→    }\n   229→\n   230→    // Update chests\n   231→    const chests = getOrCreateChests(address);\n   232→    setTreasureChests([...chests]);\n   233→    setUnopenedChestCount(getUnopenedChestCount(address));\n   234→\n   235→    return { xp: result.totalXp, amount: result.totalAmount };\n   236→  }, [address]);\n   237→\n   238→  // Helper functions\n   239→  const getQuestDefinition = useCallback((questId: string) => {\n   240→    return ALL_QUESTS.find((q) => q.id === questId);\n   241→  }, []);\n   242→\n   243→  const isQuestComplete = useCallback(\n   244→    (questId: string): boolean => {\n   245→      const quest =\n   246→        dailyQuests.find((q) => q.questId === questId) ||\n   247→        weeklyQuests.find((q) => q.questId === questId);\n   248→      return quest?.completed ?? false;\n   249→    },\n   250→    [dailyQuests, weeklyQuests]\n   251→  );\n   252→\n   253→  const isQuestClaimed = useCallback(\n   254→    (questId: string): boolean => {\n   255→      const quest =\n   256→        dailyQuests.find((q) => q.questId === questId) ||\n   257→        weeklyQuests.find((q) => q.questId === questId);\n   258→      return quest?.claimed ?? false;\n   259→    },\n   260→    [dailyQuests, weeklyQuests]\n   261→  );\n   262→\n   263→  // Compute claimable quest count (completed but not claimed)\n   264→  const claimableQuestCount =\n   265→    dailyQuests.filter((q) => q.completed && !q.claimed).length +\n   266→    weeklyQuests.filter((q) => q.completed && !q.claimed).length;\n   267→\n   268→  const value: QuestsContextValue = {\n   269→    dailyQuests,\n   270→    weeklyQuests,\n   271→    loading,\n   272→    dailyResetAt,\n   273→    weeklyResetAt,\n   274→    treasureChests,\n   275→    unopenedChestCount,\n   276→    claimableQuestCount,\n   277→    chestDropNotification,\n   278→    claimQuestReward,\n   279→    openChest,\n   280→    openAllChests,\n   281→    getQuestDefinition,\n   282→    isQuestComplete,\n   283→    isQuestClaimed,\n   284→  };\n   285→\n   286→  return (\n   287→    <QuestsContext.Provider value={value}>{children}</QuestsContext.Provider>\n   288→  );\n   289→}\n   290→\n   291→export function useQuests(): QuestsContextValue {\n   292→  const context = useContext(QuestsContext);\n   293→  if (!context) {\n   294→    throw new Error(\"useQuests must be used within a QuestsProvider\");\n   295→  }\n   296→  return context;\n   297→}\n   298→"}]},"parent_tool_use_id":"toolu_01VR6nJBUdGJdFfgxRHSBf3G","session_id":"6e340fd0-3e08-4923-9328-61b8592b2652","uuid":"2436bee7-78f9-4c6d-bd95-8bdc9d38c6e5","timestamp":"2026-03-25T13:00:14.457Z"}
