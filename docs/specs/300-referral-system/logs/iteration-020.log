u acknowledge and accept these terms.\n   283→              </p>\n   284→            </div>\n   285→            <button\n   286→              type=\"button\"\n   287→              className=\"footer-terms-accept\"\n   288→              onClick={() => setShowTerms(false)}\n   289→            >\n   290→              I Understand\n   291→            </button>\n   292→          </div>\n   293→        </div>\n   294→      )}\n   295→\n   296→      {/* FAQ Modal */}\n   297→      {showFAQ && (\n   298→        <div className=\"footer-faq-overlay\">\n   299→          <div className=\"footer-faq-modal\" ref={faqModalRef}>\n   300→            <button\n   301→              type=\"button\"\n   302→              className=\"footer-faq-close\"\n   303→              onClick={() => setShowFAQ(false)}\n   304→            >\n   305→              ×\n   306→            </button>\n   307→            <h3 className=\"footer-faq-title\">Frequently Asked Questions</h3>\n   308→            <div className=\"footer-faq-content\">\n   309→              {faqSections.map((section) => (\n   310→                <div key={section.id} className=\"faq-section\">\n   311→                  <button\n   312→                    type=\"button\"\n   313→                    className={`faq-section-header ${expandedFAQ === section.id ? \"expanded\" : \"\"}`}\n   314→                    onClick={() => toggleFAQSection(section.id)}\n   315→                  >\n   316→                    <span className=\"faq-section-title\">{section.title}</span>\n   317→                    <span className=\"faq-section-arrow\">{expandedFAQ === section.id ? \"−\" : \"+\"}</span>\n   318→                  </button>\n   319→                  {expandedFAQ === section.id && (\n   320→                    <div className=\"faq-section-content\">\n   321→                      {section.content.split(\"\\n\\n\").map((paragraph, idx) => (\n   322→                        <p key={idx}>{paragraph}</p>\n   323→                      ))}\n   324