{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PTtP8vywzrtSpYSyB3fa1N","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/App.tsx has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"6e340fd0-3e08-4923-9328-61b8592b2652","uuid":"3f0dc4bc-ad28-4759-9076-3a9feff9f867","timestamp":"2026-03-25T13:03:35.933Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/App.tsx","oldString":"function AppContent() {\n  const [chatExpanded, setChatExpanded] = useState(false);\n  const [sidebarCollapsed, setSidebarCollapsed] = useState(false);","newString":"function AppContent() {\n  const [chatExpanded, setChatExpanded] = useState(false);\n  const [sidebarCollapsed, setSidebarCollapsed] = useState(false);\n\n  // Auto-apply referral code from localStorage after authentication\n  useReferralApply();","originalFile":"import { useState, useEffect, useRef } from \"react\";\nimport { BrowserRouter, Routes, Route, Link, Navigate, useParams } from \"react-router-dom\";\nimport { Header } from \"./components/Header\";\nimport { Sidebar } from \"./components/Sidebar\";\nimport { Ticker } from \"./components/Ticker\";\nimport { BackgroundEffects } from \"./components/BackgroundEffects\";\nimport { CoinflipPage } from \"./pages/CoinflipPage\";\nimport { LordOfRngsPage } from \"./pages/LordOfRngsPage\";\nimport { CloseCallPage } from \"./pages/CloseCallPage\";\nimport { CryptoCrashPage } from \"./pages/CryptoCrashPage\";\nimport { GameOfTradesPage } from \"./pages/GameOfTradesPage\";\nimport { BossRaidProvider } from \"./features/boss-raid\";\nimport { PlayerProfileProvider, ProfilePage, MiniProfileModal, PlayerAvatarCompact } from \"./features/player-profile\";\nimport { QuestsProvider, ChestDropNotification } from \"./features/quests\";\nimport { QuestsPage } from \"./pages/QuestsPage\";\nimport { LootPage } from \"./pages/LootPage\";\nimport { CoinflipRoundPage } from \"./pages/CoinflipRoundPage\";\nimport { LordRoundPage } from \"./pages/LordRoundPage\";\nimport { CloseCallRoundPage } from \"./pages/CloseCallRoundPage\";\nimport { FairnessPage } from \"./pages/FairnessPage\";\nimport { BuildBadge } from \"./components/BuildBadge\";\nimport { RouteErrorBoundary } from \"./components/RouteErrorBoundary\";\nimport { PriceFeedProvider } from \"@rng-utopia/price-feeds\";\nimport { useReferralApply } from \"./features/referral\";\n\n\nexport function App() {\n  return (\n    <BrowserRouter>\n      <PriceFeedProvider>\n        <PlayerProfileProvider>\n          <QuestsProvider>\n            <BossRaidProvider>\n              <AppContent />\n            </BossRaidProvider>\n          </QuestsProvider>\n        </PlayerProfileProvider>\n      </PriceFeedProvider>\n    </BrowserRouter>\n  );\n}\n\n\n// Chat icon SVG\nconst ChatIcon = () => (\n  <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" width=\"20\" height=\"20\">\n    <path d=\"M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z\"/>\n    <circle cx=\"8\" cy=\"10\" r=\"1.5\"/>\n    <circle cx=\"12\" cy=\"10\" r=\"1.5\"/>\n    <circle cx=\"16\" cy=\"10\" r=\"1.5\"/>\n  </svg>\n);\n\n// Footer component with terms and FAQ modals\nfunction Footer() {\n  const [showTerms, setShowTerms] = useState(false);\n  const [showFAQ, setShowFAQ] = useState(false);\n  const [expandedFAQ, setExpandedFAQ] = useState<string | null>(null);\n  const termsModalRef = useRef<HTMLDivElement>(null);\n  const faqModalRef = useRef<HTMLDivElement>(null);\n\n  // Close modal on outside click\n  useEffect(() => {\n    if (!showTerms && !showFAQ) return;\n\n    const handleClickOutside = (e: MouseEvent) => {\n      if (showTerms && termsModalRef.current && !termsModalRef.current.contains(e.target as Node)) {\n        setShowTerms(false);\n      }\n      if (showFAQ && faqModalRef.current && !faqModalRef.current.contains(e.target as Node)) {\n        setShowFAQ(false);\n      }\n    };\n\n    document.addEventListener(\"mousedown\", handleClickOutside);\n    return () => document.removeEventListener(\"mousedown\", handleClickOutside);\n  }, [showTerms, showFAQ]);\n\n  // Close on escape\n  useEffect(() => {\n    if (!showTerms && !showFAQ) return;\n\n    const handleEscape = (e: KeyboardEvent) => {\n      if (e.key === \"Escape\") {\n        setShowTerms(false);\n        setShowFAQ(false);\n      }\n    };\n\n    document.addEventListener(\"keydown\", handleEscape);\n    return () => document.removeEventListener(\"keydown\", handleEscape);\n  }, [showTerms, showFAQ]);\n\n  const toggleFAQSection = (section: string) => {\n    setExpandedFAQ(expandedFAQ === section ? null : section);\n  };\n\n  const faqSections = [\n    {\n      id: \"fees\",\n      title: \"Platform Fees\",\n      content: `TAUNT charges a 5% platform fee on all games. This means 95% of all wagered funds go directly to winners.\n\nFee breakdown:\n• 5% total platform fee on every settled pot\n• Funds cover player incentives (Dogpile Raid reward pool, future promotions) and platform treasury (server costs, development, operations)\n\nWhat you get:\n• Winners receive: 95% of the pot\n• No hidden fees or withdrawal charges\n• Part of your wagers fund rewards you can win back through Dogpile Raid`\n    },\n    {\n      id: \"raid-boss\",\n      title: \"What is Dogpile Raid?\",\n      content: `Dogpile Raid is a community reward mechanic where players collectively take down a Mark by playing games.\n\nHow it works:\n• A new Mark spawns every hour with a 50-minute active phase\n• Every wager you make in any game lands \"hits\" on the Mark\n• The Mark's Armor drains over time - it's always dropped when the timer ends\n• When dropped, the reward pool is distributed to all participants\n\nRewards:\n• Your share is proportional to your hit contribution\n• The reward pool grows from 1% of all wagers during the raid\n• Higher total community hits = better loot tier = bigger multipliers\n• Bonus loot is occasionally added for extra rewards\n\nLoot Tiers (based on total hits):\n• Bronze: 0-10 SOL in hits\n• Silver: 10-50 SOL in hits\n• Gold: 50-150 SOL in hits\n• Platinum: 150-500 SOL in hits\n• Diamond: 500+ SOL in hits`\n    },\n    {\n      id: \"pvp\",\n      title: \"Why PvP Games?\",\n      content: `Unlike traditional house-edge gambling where you play against the casino, TAUNT is 100% player-vs-player. This creates a fundamentally fairer system:\n\n• No house edge exploiting players\n• Prize pools come entirely from player wagers\n• The platform only takes a small facilitation fee\n• Better odds than any traditional casino\n• Transparent, skill-independent wagering`\n    },\n    {\n      id: \"wagers\",\n      title: \"Custom Wagers\",\n      content: `TAUNT lets you choose your own wager amount for every game.\n\nWager limits:\n• Minimum: 0.001 SOL\n• Maximum: 100 SOL\n\nHow it works:\n• Enter any amount within the limits before joining a game\n• In head-to-head games (Flip You), both players wager the same amount\n• In pool games (Lord of RNGs, Close Call), your share of the pool scales with your wager\n\nBenefits:\n• Play at exactly the stake you're comfortable with\n• No fixed tiers — full flexibility\n• Preset buttons for quick common amounts`\n    },\n    {\n      id: \"leaderboard\",\n      title: \"Leaderboard System\",\n      content: `Leaderboard system details coming soon.\n\nWe're working on implementing competitive leaderboards to track and reward top players. Stay tuned for updates!`\n    },\n    {\n      id: \"fairness\",\n      title: \"On-Chain Fairness\",\n      content: `All game outcomes are provably fair using cryptographic verification:\n\nCommit-Reveal Pattern (Crash, Close Call):\n1. Server publishes a hash of its seed before betting\n2. Solana blockhash becomes the public seed\n3. After the round, server reveals its seed\n4. Anyone can verify the outcome matches\n\nOn-Chain VRF (Jackpot, Flip You):\n1. Game requests randomness from VRF provider\n2. VRF generates verifiable random bytes\n3. Result and proof stored on Solana blockchain\n4. Anyone can verify using blockchain explorer\n\nVisit the Fairness page in the header for verification tools.`\n    },\n    {\n      id: \"rng-buff\",\n      title: \"Heater\",\n      content: `The Heater is a powerful temporary bonus granted to players who help drop the Mark before the timer expires.\n\nHow to get the Heater:\n1. Participate in the hourly Dogpile Raid by wagering in any game\n2. Your wagers land \"hits\" on the Mark\n3. If the Mark is dropped before time runs out, ALL participants receive the Heater\n4. The Heater lasts for 1 hour (until the next raid starts)\n\nHeater Benefits:\n• Golden glowing border on your avatar (visible to all players)\n• Chance to drop crates when wagering\n• Drop chance scales with wager amount (1% base + 5% per SOL, max 25%)\n\nVisual Indicators:\n• Golden pulsing border around your avatar everywhere in the app\n• Heater icon with countdown timer in your profile header\n• Star icon with timer in the main header\n\nThe Heater expires when the next raid begins, so make the most of it!`\n    },\n    {\n      id: \"treasure-chests\",\n      title: \"Crates\",\n      content: `Crates are mystery rewards that contain XP and SOL prizes. Open them in the Loot page.\n\nHow to earn crates:\n• Heater drops: Random chance when wagering with active Heater\n• Complete ALL daily quests: 1 crate\n• Complete weekly quests: 1 crate per quest (3 total)\n• Complete ALL weekly quests: +2 bonus crates (5 total)\n\nHeater crate drop rates:\n• Base chance: 1% per wager\n• Bonus: +5% per 1 SOL wagered\n• Maximum: 25% chance per wager\n\nCrate rarity (determined when opened):\n• Common (50%): 50-100 XP, 0.001-0.005 SOL\n• Uncommon (30%): 100-250 XP, 0.005-0.01 SOL\n• Rare (15%): 250-500 XP, 0.01-0.025 SOL\n• Epic (4%): 500-1000 XP, 0.025-0.05 SOL\n• Legendary (1%): 1000-2500 XP, 0.05-0.1 SOL\n\nSOL rewards are paid from the platform treasury. May the RNG gods smile upon you!`\n    },\n  ];\n\n  return (\n    <>\n      <footer className=\"footer-v2\">\n        <div className=\"ft-logo\">TAUNT<em>.</em></div>\n        <div className=\"ft-links\">\n          <button type=\"button\" className=\"ft-lnk\" onClick={() => setShowFAQ(true)}>FAQ</button>\n          <button type=\"button\" className=\"ft-lnk\" onClick={() => setShowTerms(true)}>Terms</button>\n          <a href=\"https://x.com/rngutopia\" target=\"_blank\" rel=\"noopener noreferrer\" className=\"ft-lnk\">Twitter</a>\n          <a href=\"https://t.me/rngutopia\" target=\"_blank\" rel=\"noopener noreferrer\" className=\"ft-lnk\">Telegram</a>\n        </div>\n        <div className=\"ft-tag\">taunt.bet &middot; Provably Fair &middot; Solana</div>\n      </footer>\n\n      {/* Terms Modal */}\n      {showTerms && (\n        <div className=\"footer-terms-overlay\">\n          <div className=\"footer-terms-modal\" ref={termsModalRef}>\n            <button\n              type=\"button\"\n              className=\"footer-terms-close\"\n              onClick={() => setShowTerms(false)}\n            >\n              ×\n            </button>\n            <h3 className=\"footer-terms-title\">Terms of Use</h3>\n            <div className=\"footer-terms-content\">\n              <p>\n                By accessing and using TAUNT, you confirm that you are not a citizen,\n                resident, or located within any jurisdiction where online gambling is prohibited\n                or restricted by law, including but not limited to: the United States,\n                United Kingdom, France, Germany, Spain, the Netherlands, or any other\n                jurisdiction with similar regulations.\n              </p>\n              <p>\n                You are solely responsible for determining whether your use of this platform\n                is lawful in your country or region of residence. TAUNT does not provide\n                legal advice and assumes no liability for users who access the platform in\n                violation of applicable laws.\n              </p>\n              <p>\n                By continuing to use this service, you acknowledge and accept these terms.\n              </p>\n            </div>\n            <button\n              type=\"button\"\n              className=\"footer-terms-accept\"\n              onClick={() => setShowTerms(false)}\n            >\n              I Understand\n            </button>\n          </div>\n        </div>\n      )}\n\n      {/* FAQ Modal */}\n      {showFAQ && (\n        <div className=\"footer-faq-overlay\">\n          <div className=\"footer-faq-modal\" ref={faqModalRef}>\n            <button\n              type=\"button\"\n              className=\"footer-faq-close\"\n              onClick={() => setShowFAQ(false)}\n            >\n              ×\n            </button>\n            <h3 className=\"footer-faq-title\">Frequently Asked Questions</h3>\n            <div className=\"footer-faq-content\">\n              {faqSections.map((section) => (\n                <div key={section.id} className=\"faq-section\">\n                  <button\n                    type=\"button\"\n                    className={`faq-section-header ${expandedFAQ === section.id ? \"expanded\" : \"\"}`}\n                    onClick={() => toggleFAQSection(section.id)}\n                  >\n                    <span className=\"faq-section-title\">{section.title}</span>\n                    <span className=\"faq-section-arrow\">{expandedFAQ === section.id ? \"−\" : \"+\"}</span>\n                  </button>\n                  {expandedFAQ === section.id && (\n                    <div className=\"faq-section-content\">\n                      {section.content.split(\"\\n\\n\").map((paragraph, idx) => (\n                        <p key={idx}>{paragraph}</p>\n                      ))}\n                    </div>\n                  )}\n                </div>\n              ))}\n            </div>\n            <button\n              type=\"button\"\n              className=\"footer-faq-close-btn\"\n              onClick={() => setShowFAQ(false)}\n            >\n              Close\n            </button>\n          </div>\n        </div>\n      )}\n    </>\n  );\n}\n\nfunction AppContent() {\n  const [chatExpanded, setChatExpanded] = useState(false);\n  const [sidebarCollapsed, setSidebarCollapsed] = useState(false);\n\n  const toggleSidebar = () => {\n    setSidebarCollapsed(!sidebarCollapsed);\n    document.body.classList.toggle(\"nc\", !sidebarCollapsed);\n  };\n\n  return (\n    <div className=\"app\">\n      <BackgroundEffects />\n\n      {/* Fixed top bar */}\n      <div className=\"top-bar\">\n        <Header />\n        <Ticker />\n      </div>\n\n      {/* Fixed sidebar */}\n      <Sidebar collapsed={sidebarCollapsed} onToggle={toggleSidebar} />\n\n      <main className=\"main\">\n        <Routes>\n          <Route path=\"/\" element={<HomePage />} />\n          <Route path=\"/coinflip\" element={<RouteErrorBoundary label=\"Coinflip\"><CoinflipPage /></RouteErrorBoundary>} />\n          <Route path=\"/coinflip/:matchId\" element={<RouteErrorBoundary label=\"Coinflip\"><CoinflipPage /></RouteErrorBoundary>} />\n          <Route path=\"/lord-of-rngs\" element={<RouteErrorBoundary label=\"Lord of RNGs\"><LordOfRngsPage /></RouteErrorBoundary>} />\n          <Route path=\"/lord-of-rngs/:matchId\" element={<RouteErrorBoundary label=\"Lord of RNGs\"><LordOfRngsPage /></RouteErrorBoundary>} />\n          <Route path=\"/close-call\" element={<RouteErrorBoundary label=\"Close Call\"><CloseCallPage /></RouteErrorBoundary>} />\n          <Route path=\"/crash\" element={<RouteErrorBoundary label=\"Crash\"><CryptoCrashPage /></RouteErrorBoundary>} />\n          <Route path=\"/game-of-trades\" element={<RouteErrorBoundary label=\"Game of Trades\"><GameOfTradesPage /></RouteErrorBoundary>} />\n          <Route path=\"/profile\" element={<RouteErrorBoundary label=\"Profile\"><ProfilePage /></RouteErrorBoundary>} />\n          <Route path=\"/loot\" element={<RouteErrorBoundary label=\"Loot\"><LootPage /></RouteErrorBoundary>} />\n          <Route path=\"/quests\" element={<RouteErrorBoundary label=\"Quests\"><QuestsPage /></RouteErrorBoundary>} />\n          <Route path=\"/fairness\" element={<RouteErrorBoundary label=\"Fairness\"><FairnessPage /></RouteErrorBoundary>} />\n          <Route path=\"/coinflip/:matchId/proof\" element={<RouteErrorBoundary label=\"Coinflip Proof\"><CoinflipRoundPage /></RouteErrorBoundary>} />\n          <Route path=\"/lord-of-rngs/:matchId/proof\" element={<RouteErrorBoundary label=\"Lord of RNGs Proof\"><LordRoundPage /></RouteErrorBoundary>} />\n          <Route path=\"/close-call/:roundId\" element={<RouteErrorBoundary label=\"Close Call Round\"><CloseCallRoundPage /></RouteErrorBoundary>} />\n          <Route path=\"/r/:code\" element={<ReferralCapture />} />\n          <Route path=\"*\" element={<NotFoundPage />} />\n        </Routes>\n        <Footer />\n      </main>\n\n      <BuildBadge />\n\n      {/* Floating chat button */}\n      <div className=\"chat-float\">\n        <button type=\"button\" className=\"chat-float__btn\" onClick={() => setChatExpanded(!chatExpanded)}>\n          <ChatIcon />\n          <span className=\"chat-float__dot\" />\n        </button>\n        {chatExpanded && (\n          <div className=\"chat-float__panel\">\n            <div className=\"chat-panel-header\">\n              <h4>Global Chat</h4>\n              <button className=\"chat-close\" onClick={() => setChatExpanded(false)}>×</button>\n            </div>\n            <div className=\"chat-messages\">\n              <div className=\"chat-message\">\n                <PlayerAvatarCompact address=\"DemoPlayer1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n                <span className=\"text\">gg nice flip!</span>\n              </div>\n              <div className=\"chat-message\">\n                <PlayerAvatarCompact address=\"DemoPlayer2xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n                <span className=\"text\">who's ready for crash?</span>\n              </div>\n              <div className=\"chat-message\">\n                <PlayerAvatarCompact address=\"DemoPlayer3xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n                <span className=\"text\">close call is rigged lol jk</span>\n              </div>\n              <div className=\"chat-message\">\n                <PlayerAvatarCompact address=\"DemoPlayer4xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n                <span className=\"text\">just hit 5x on crash!</span>\n              </div>\n              <div className=\"chat-message\">\n                <PlayerAvatarCompact address=\"DemoPlayer5xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx\" />\n                <span className=\"text\">coinflip is where it's at</span>\n              </div>\n            </div>\n            <div className=\"chat-input-container\">\n              <input type=\"text\" className=\"chat-input\" placeholder=\"Type a message...\" />\n              <button className=\"chat-send-btn\">Send</button>\n            </div>\n          </div>\n        )}\n      </div>\n\n      <MiniProfileModal />\n      <ChestDropNotification />\n    </div>\n  );\n}\n\n// Mock recent winners data\nconst RECENT_WINNERS = [\n  { player: \"CryptoSavage.eth\", game: \"FLIP YOU\", amount: \"+$194.00\", positive: true, taunt: \"later, bitch\", color: \"#FFB800\" },\n  { player: \"degen_whale_99\", game: \"MOON OR REKT\", amount: \"+$407.40\", positive: true, taunt: \"gg ez lmao\", color: \"#FF2D55\" },\n  { player: \"0x9f…22b1\", game: \"JACKPOT\", amount: \"+$38.80\", positive: true, taunt: null, color: \"#FF1F8E\" },\n  { player: \"paper_hands_pete\", game: \"FLIP YOU\", amount: \"-$10.00\", positive: false, taunt: \"skill issue ngl\", color: \"#FFB800\" },\n  { player: \"sol_degen_88\", game: \"GAME OF TRADES\", amount: \"+$30.00\", positive: true, taunt: null, color: \"#3D7FFF\" },\n  { player: \"anon_8821\", game: \"JACKPOT\", amount: \"+$146.55\", positive: true, taunt: \"the RNG chose me\", color: \"#FF1F8E\" },\n  { player: \"0x3b…81a2\", game: \"CLOSE CALL\", amount: \"+$18.40\", positive: true, taunt: null, color: \"#00E676\" },\n  { player: \"moon_maxi_99\", game: \"CRYPTO CRASH\", amount: \"+$82.10\", positive: true, taunt: \"rekt. bye.\", color: \"#FF2D55\" },\n];\n\n/** Captures referral code from /r/:code URL, stores in localStorage, redirects to / */\nfunction ReferralCapture() {\n  const { code } = useParams<{ code: string }>();\n  if (code) {\n    try {\n      localStorage.setItem(\"referral_code\", JSON.stringify({ code, capturedAt: new Date().toISOString() }));\n    } catch {\n      // localStorage may be unavailable (private browsing, storage full) — proceed with redirect\n    }\n  }\n  return <Navigate to=\"/\" replace />;\n}\n\nfunction HomePage() {\n  return (\n    <>\n      {/* Page header */}\n      <div className=\"page-hd\">\n        <div>\n          <div className=\"pg-title\">The <span className=\"pk\">Pit.</span></div>\n          <div className=\"pg-sub\">Five ways to ruin someone's day</div>\n        </div>\n        <div className=\"pg-tags\">\n          <div className=\"ptag on\">Floor Open · 24/7</div>\n          <div className=\"ptag\">5% Flat Fee · Zero House Edge</div>\n          <div className=\"ptag\">Provably Fair · Solana</div>\n        </div>\n      </div>\n\n      {/* Game grid */}\n      <div className=\"game-grid\">\n        <GameCardV2\n          name=\"Flip You\"\n          subtitle=\"$0.50 — $100 · P2P · 1v1\"\n          description=\"Pure 50/50. One winner takes the pot. Your opponent sees your taunt the moment they lose.\"\n          path=\"/coinflip\"\n          visual=\"coinflip\"\n          mode=\"VRF · On-chain\"\n          colorClass=\"y\"\n          stats={[\n            { value: \"18\", label: \"Open Games\" },\n            { value: \"6\", label: \"Tiers\" },\n            { value: \"95%\", label: \"Payout\" },\n          ]}\n        />\n        <GameCardV2\n          name=\"Jackpot\"\n          subtitle=\"$0.50 — $100 · P2P · Lottery\"\n          description=\"Buy tickets, buy odds. One spin decides everything. The wheel doesn't care how many you own.\"\n          path=\"/lord-of-rngs\"\n          visual=\"lotr\"\n          mode=\"VRF · On-chain\"\n          colorClass=\"pk\"\n          stats={[\n            { value: \"$146\", label: \"Top Jackpot\" },\n            { value: \"6\", label: \"Active\" },\n            { value: \"VRF\", label: \"Randomness\" },\n          ]}\n        />\n        <GameCardV2\n          name=\"Close Call\"\n          subtitle=\"$0.50 — $100 · P2P · Binary\"\n          description=\"Green or red. Lock in before the round closes. Winners split the losers' side pro-rata.\"\n          path=\"/close-call\"\n          visual=\"close-call\"\n          mode=\"Commit-Reveal\"\n          colorClass=\"g\"\n          stats={[\n            { value: \"$892\", label: \"Active Pool\" },\n            { value: \"1.46×\", label: \"Green Odds\" },\n            { value: \"43s\", label: \"Time Left\" },\n          ]}\n        />\n        <GameCardV2\n          name=\"Crypto Crash\"\n          subtitle=\"$0.50 — $100 · P2P · Crash\"\n          description=\"Multiplier climbs. Cash out before it crashes. The last player in wins the Diamond pot.\"\n          path=\"/crash\"\n          visual=\"crash\"\n          mode=\"Commit-Reveal\"\n          colorClass=\"r\"\n          stats={[\n            { value: \"1.84×\", label: \"Live Multi\" },\n            { value: \"$1,842\", label: \"Diamond Pot\" },\n            { value: \"CR\", label: \"Provably Fair\" },\n          ]}\n        />\n        <GameCardV2\n          name=\"Game of Trades\"\n          subtitle=\"$0.50 — $100 · P2P · Sim\"\n          description=\"$10k paper balance. 100× leverage. 60 seconds on a live chart. Best PnL takes the pot.\"\n          path=\"/game-of-trades\"\n          visual=\"trades\"\n          mode=\"100× Leverage\"\n          colorClass=\"b\"\n          stats={[\n            { value: \"$600\", label: \"Largest Pot\" },\n            { value: \"32\", label: \"In Lobbies\" },\n            { value: \"60s\", label: \"Round Time\" },\n          ]}\n        />\n      </div>\n\n      {/* Recent winners strip */}\n      <div className=\"wins-strip\">\n        <div className=\"wins-hd\"><div className=\"pdot\" />Recent Winners</div>\n        <div className=\"wins-in\">\n          {RECENT_WINNERS.map((w, i) => (\n            <div key={i} className=\"wchip\" style={{ \"--wc\": w.color } as React.CSSProperties}>\n              <div>\n                <div className=\"wchip-player\">{w.player}</div>\n                <div className=\"wchip-game\">{w.game}</div>\n                {w.taunt && <div className=\"wchip-taunt\">\"{w.taunt}\"</div>}\n              </div>\n              <div className={`wchip-amt ${w.positive ? \"p\" : \"n\"}`}>{w.amount}</div>\n            </div>\n          ))}\n        </div>\n      </div>\n    </>\n  );\n}\n\ninterface GameCardV2Props {\n  name: string;\n  subtitle: string;\n  description: string;\n  path: string;\n  visual: string;\n  mode: string;\n  colorClass: string;\n  stats: { value: string; label: string }[];\n}\n\nfunction GameCardV2({ name, subtitle, description, path, visual, mode, colorClass, stats }: GameCardV2Props) {\n  return (\n    <Link to={path} className={`gcard gc-${colorClass}`}>\n      <div className=\"gcard-accent\" />\n      <div className=\"gcard-vis\">\n        <div className=\"gcard-bg\" />\n        <GameVisualV2 type={visual} />\n      </div>\n      <div className=\"gcard-info\">\n        <div className=\"gcard-hd\">\n          <div>\n            <div className=\"gcard-name\">{name}</div>\n            <div className=\"gcard-sub2\">{subtitle}</div>\n          </div>\n          <div className=\"gcard-mode\">{mode}</div>\n        </div>\n        <div className=\"gcard-line\">{description}</div>\n        <div className=\"gcard-stats\">\n          {stats.map((s, i) => (\n            <div key={i} className=\"gstat\">\n              <div className=\"gstat-n\">{s.value}</div>\n              <div className=\"gstat-l\">{s.label}</div>\n            </div>\n          ))}\n        </div>\n        <button type=\"button\" className=\"gcard-btn\" onClick={(e) => e.preventDefault()}>\n          <div className=\"gcard-bf\" />\n          <span className=\"gcard-btxt\">Enter Game</span>\n          <span className=\"gcard-arr\">&rarr;</span>\n        </button>\n      </div>\n    </Link>\n  );\n}\n\nfunction GameVisualV2({ type }: { type: string }) {\n  switch (type) {\n    case \"coinflip\":\n      return (\n        <svg className=\"gcard-ico coin-flip\" viewBox=\"0 0 135 135\" fill=\"none\">\n          <circle cx=\"67.5\" cy=\"67.5\" r=\"60\" fill=\"#111118\" stroke=\"#FFB800\" strokeWidth=\"2.5\" />\n          <circle cx=\"67.5\" cy=\"67.5\" r=\"52\" fill=\"none\" stroke=\"rgba(255,184,0,0.12)\" strokeWidth=\"1\" />\n          <circle cx=\"67.5\" cy=\"67.5\" r=\"43\" fill=\"none\" stroke=\"rgba(255,184,0,0.07)\" strokeWidth=\"1\" strokeDasharray=\"5 5\" />\n          <path d=\"M22 44 A60 60 0 0 1 113 44\" stroke=\"rgba(255,184,0,0.28)\" strokeWidth=\"3.5\" strokeLinecap=\"round\" fill=\"none\" />\n          <text x=\"67.5\" y=\"86\" textAnchor=\"middle\" fontFamily=\"'Bebas Neue', sans-serif\" fontSize=\"46\" fill=\"#FFB800\" letterSpacing=\"2\">H</text>\n          <circle cx=\"67.5\" cy=\"11\" r=\"2.5\" fill=\"#FFB800\" opacity=\"0.5\" />\n          <circle cx=\"67.5\" cy=\"124\" r=\"2.5\" fill=\"#FFB800\" opacity=\"0.5\" />\n          <circle cx=\"11\" cy=\"67.5\" r=\"2.5\" fill=\"#FFB800\" opacity=\"0.5\" />\n          <circle cx=\"124\" cy=\"67.5\" r=\"2.5\" fill=\"#FFB800\" opacity=\"0.5\" />\n        </svg>\n      );\n\n    case \"lotr\":\n      return (\n        <svg className=\"gcard-ico\" viewBox=\"0 0 135 135\" fill=\"none\">\n          <circle cx=\"67.5\" cy=\"67.5\" r=\"62\" fill=\"#111118\" stroke=\"#FF1F8E\" strokeWidth=\"2\" />\n          <g className=\"spin-slow\">\n            <path d=\"M67.5 67.5L67.5 7.5A60 60 0 0 1 119.5 37.5Z\" fill=\"rgba(255,31,142,0.2)\" stroke=\"rgba(255,31,142,0.3)\" strokeWidth=\"0.8\" />\n            <path d=\"M67.5 67.5L119.5 37.5A60 60 0 0 1 127.5 67.5Z\" fill=\"rgba(255,31,142,0.08)\" stroke=\"rgba(255,31,142,0.2)\" strokeWidth=\"0.8\" />\n            <path d=\"M67.5 67.5L127.5 67.5A60 60 0 0 1 119.5 97.5Z\" fill=\"rgba(255,31,142,0.2)\" stroke=\"rgba(255,31,142,0.3)\" strokeWidth=\"0.8\" />\n            <path d=\"M67.5 67.5L119.5 97.5A60 60 0 0 1 67.5 127.5Z\" fill=\"rgba(255,31,142,0.08)\" stroke=\"rgba(255,31,142,0.2)\" strokeWidth=\"0.8\" />\n            <path d=\"M67.5 67.5L67.5 127.5A60 60 0 0 1 15.5 97.5Z\" fill=\"rgba(255,31,142,0.2)\" stroke=\"rgba(255,31,142,0.3)\" strokeWidth=\"0.8\" />\n            <path d=\"M67.5 67.5L15.5 97.5A60 60 0 0 1 7.5 67.5Z\" fill=\"rgba(255,31,142,0.08)\" stroke=\"rgba(255,31,142,0.2)\" strokeWidth=\"0.8\" />\n            <path d=\"M67.5 67.5L7.5 67.5A60 60 0 0 1 15.5 37.5Z\" fill=\"rgba(255,31,142,0.2)\" stroke=\"rgba(255,31,142,0.3)\" strokeWidth=\"0.8\" />\n            <path d=\"M67.5 67.5L15.5 37.5A60 60 0 0 1 67.5 7.5Z\" fill=\"rgba(255,31,142,0.08)\" stroke=\"rgba(255,31,142,0.2)\" strokeWidth=\"0.8\" />\n            <circle cx=\"67.5\" cy=\"67.5\" r=\"22\" fill=\"#111118\" stroke=\"#FF1F8E\" strokeWidth=\"1.5\" />\n            <circle cx=\"67.5\" cy=\"67.5\" r=\"7\" fill=\"#FF1F8E\" opacity=\"0.6\" />\n          </g>\n          <polygon points=\"67.5,2 74,15 61,15\" fill=\"#FFB800\" />\n          <circle cx=\"67.5\" cy=\"67.5\" r=\"10\" fill=\"#0E0E1A\" stroke=\"#FF1F8E\" strokeWidth=\"1.5\" />\n          <circle cx=\"67.5\" cy=\"67.5\" r=\"3.5\" fill=\"#FF1F8E\" />\n        </svg>\n      );\n\n    case \"close-call\":\n      return (\n        <svg className=\"gcard-ico\" viewBox=\"0 0 135 135\" fill=\"none\">\n          <line x1=\"16\" y1=\"36\" x2=\"119\" y2=\"36\" stroke=\"rgba(255,255,255,0.04)\" strokeWidth=\"1\" />\n          <line x1=\"16\" y1=\"62\" x2=\"119\" y2=\"62\" stroke=\"rgba(255,255,255,0.04)\" strokeWidth=\"1\" />\n          <line x1=\"16\" y1=\"88\" x2=\"119\" y2=\"88\" stroke=\"rgba(255,255,255,0.04)\" strokeWidth=\"1\" />\n          <line x1=\"16\" y1=\"114\" x2=\"119\" y2=\"114\" stroke=\"rgba(255,255,255,0.04)\" strokeWidth=\"1\" />\n          <g className=\"cand-up\">\n            <line x1=\"43\" y1=\"18\" x2=\"43\" y2=\"40\" stroke=\"#00E676\" strokeWidth=\"2\" strokeLinecap=\"round\" />\n            <rect x=\"27\" y=\"40\" width=\"32\" height=\"64\" rx=\"1.5\" fill=\"#00E676\" opacity=\"0.82\" />\n            <rect x=\"29\" y=\"42\" width=\"10\" height=\"20\" rx=\"1\" fill=\"rgba(255,255,255,0.18)\" />\n            <line x1=\"43\" y1=\"104\" x2=\"43\" y2=\"120\" stroke=\"#00E676\" strokeWidth=\"2\" strokeLinecap=\"round\" />\n          </g>\n          <text x=\"67.5\" y=\"74\" textAnchor=\"middle\" fontFamily=\"'Bebas Neue', sans-serif\" fontSize=\"16\" fill=\"rgba(255,255,255,0.18)\" letterSpacing=\"1\">VS</text>\n          <g className=\"cand-dn\">\n            <line x1=\"92\" y1=\"14\" x2=\"92\" y2=\"44\" stroke=\"#FF2D55\" strokeWidth=\"2\" strokeLinecap=\"round\" />\n            <rect x=\"76\" y=\"44\" width=\"32\" height=\"48\" rx=\"1.5\" fill=\"#FF2D55\" opacity=\"0.82\" />\n            <rect x=\"78\" y=\"46\" width=\"10\" height=\"14\" rx=\"1\" fill=\"rgba(255,255,255,0.14)\" />\n            <line x1=\"92\" y1=\"92\" x2=\"92\" y2=\"120\" stroke=\"#FF2D55\" strokeWidth=\"2\" strokeLinecap=\"round\" />\n          </g>\n        </svg>\n      );\n\n    case \"crash\":\n      return (\n        <svg className=\"gcard-ico\" viewBox=\"0 0 135 135\" fill=\"none\">\n          <line x1=\"16\" y1=\"118\" x2=\"16\" y2=\"12\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1\" />\n          <line x1=\"16\" y1=\"118\" x2=\"122\" y2=\"118\" stroke=\"rgba(255,25