nimation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      // Settle time for UI to stabilize\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\"referrals-connected.png\", { fullPage: true });\n    });\n  });\n\n  test.describe(\"Coinflip page\", () => {","originalFile":"import { test, expect } from \"../fixtures\";\n\ntest.describe(\"State variants\", () => {\n  test.describe(\"Home page\", () => {\n    test(\"wallet disconnected\", async ({ stablePage }) => {\n      // Clear any persisted wallet state to ensure disconnected\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/\");\n      await expect(stablePage).toHaveScreenshot(\"home-disconnected.png\", { fullPage: true });\n    });\n\n    test(\"wallet connected\", async ({ stablePage }) => {\n      // Clear persisted state first so connect generates fresh from seeded PRNG\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/\");\n\n      // Click the wallet connect button\n      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n\n      // Wait for connected state\n      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n        timeout: 5000,\n      });\n\n      // Re-inject animation freeze CSS (connect flow may have triggered transitions)\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      // Settle time for UI to stabilize\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\"home-connected.png\", { fullPage: true });\n    });\n  });\n\n  test.describe(\"Profile page\", () => {\n    test(\"wallet connected\", async ({ stablePage }) => {\n      // Clear persisted state first so connect generates fresh from seeded PRNG\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/profile\");\n\n      // Click the wallet connect button\n      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n\n      // Wait for connected state\n      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n        timeout: 5000,\n      });\n\n      // Re-inject animation freeze CSS (connect flow may have triggered transitions)\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      // Settle time for UI to stabilize\n      await stablePage.waitForTimeout(300);\n\n      // Avatar SVG has sub-pixel rendering variance; allow slightly higher threshold\n      await expect(stablePage).toHaveScreenshot(\"profile-connected.png\", {\n        fullPage: true,\n        maxDiffPixelRatio: 0.03,\n      });\n    });\n\n    test(\"transactions tab — empty state\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/profile\");\n\n      // Connect wallet\n      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n        timeout: 5000,\n      });\n\n      // Click the Transactions tab\n      await stablePage\n        .locator(\".profile-page__tab\", { hasText: \"Transactions\" })\n        .click();\n\n      // Wait for the transactions empty state to render\n      await stablePage.waitForSelector(\".profile-transactions__empty\", {\n        timeout: 5000,\n      });\n\n      // Re-inject animation freeze CSS\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\n        \"profile-transactions-empty.png\",\n        {\n          fullPage: true,\n          maxDiffPixelRatio: 0.03,\n        },\n      );\n    });\n  });\n\n  test.describe(\"Lord of the RNGs page\", () => {\n    test(\"round lobby — wallet disconnected\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/lord-of-rngs\");\n\n      // Wait for lobby to render (round cards or \"No open rounds\" message)\n      await stablePage.waitForSelector(\".lotr-tier-lobby\", { timeout: 10_000 });\n\n      await expect(stablePage).toHaveScreenshot(\"lotr-lobby-disconnected.png\", { fullPage: true });\n    });\n\n    test(\"round selected — shows sidebar and 