{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N8dtqGGRmeccNn8GGdeFRH","type":"tool_result","content":"     1→import { useSession } from \"../../context/SessionContext\";\n     2→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n     3→import { ReferralLinkCard } from \"./ReferralLinkCard\";\n     4→import { ReferralStatsCard } from \"./ReferralStatsCard\";\n     5→import { ReferralClaimCard } from \"./ReferralClaimCard\";\n     6→import { ReferralEarningsTable } from \"./ReferralEarningsTable\";\n     7→\n     8→export function ReferralPage() {\n     9→  const { isAuthenticated } = useSession();\n    10→  const { connected } = useWallet();\n    11→\n    12→  if (!connected || !isAuthenticated) {\n    13→    return (\n    14→      <div className=\"referral-page\">\n    15→        <div className=\"referral-page__connect\">\n    16→          <h2>Referral Program</h2>\n    17→          <p>\n    18→            Earn <strong>10% of the platform fee</strong> from every game your\n    19→            referred players complete — forever. Your referees get a{\" \"}\n    20→            <strong>10% fee rebate</strong> on all their games too.\n    21→          </p>\n    22→          <p>Connect your wallet to get started.</p>\n    23→        </div>\n    24→      </div>\n    25→    );\n    26→  }\n    27→\n    28→  return (\n    29→    <div className=\"referral-page\">\n    30→      <div className=\"referral-page__header\">\n    31→        <h1 className=\"referral-page__title\">Referrals</h1>\n    32→        <p className=\"referral-page__subtitle\">\n    33→          Share your link, earn from every game your friends play\n    34→        </p>\n    35→      </div>\n    36→\n    37→      <div className=\"referral-page__content\">\n    38→        <ReferralLinkCard />\n    39→        <ReferralStatsCard />\n    40→        <ReferralClaimCard />\n    41→        <ReferralEarningsTable />\n    42→      </div>\n    43→    </div>\n    44→  );\n    45→}\n    46→"}]},"parent_tool_use_id":"toolu_01JnskMXfhvse64yJnfkiyD7","session_id":"90f4afdf-f404-4516-a077-3e53d0f561c2","uuid":"d55aedfb-d395-47b0-9cad-30b53cdf8cad","timestamp":"2026-03-25T14:20:44.870Z"}
