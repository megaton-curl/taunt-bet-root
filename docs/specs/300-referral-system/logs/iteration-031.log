{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Nzfn5PTSajCdjtsiW9Svhp","type":"tool_result","content":"    \"test:visual\": \"turbo run test:visual --env-mode=loose\",\n    \"clean\": \"turbo run clean && rm -rf node_modules\",\n    \"dev:platform\": \"pnpm --filter @rng-utopia/platform dev\",\n    \"build:platform\": \"pnpm --filter @rng-utopia/platform build\",\n    \"dev:programs\": \"cd solana && anchor build\",\n    \"test:programs\": \"cd solana && anchor test --skip-local-validator --skip-deploy\",\n    \"test:e2e\": \"pnpm --filter @rng-utopia/platform test:e2e\",\n    \"test:e2e:devnet\": \"pnpm --filter @rng-utopia/platform test:e2e:devnet\",\n    \"format\": \"prettier --write \\\"**/*.{ts,tsx,js,jsx,json,md}\\\"\",\n    \"format:check\": \"prettier --check \\\"**/*.{ts,tsx,js,jsx,json,md}\\\"\"\n  },\n  \"devDependencies\": {\n    \"prettier\": \"^3.2.5\",\n    \"turbo\": \"^2.3.0\"\n  },\n  \"keywords\": [\n    \"solana\",\n    \"casino\",\n    \"p2p\",\n    \"gaming\",\n    \"vrf\",","is_error":false}]},"parent_tool_use_id":"toolu_01Cn9ndhQNcfEd7xGaMQRh3e","session_id":"90f4afdf-f404-4516-a077-3e53d0f561c2","uuid":"35e2e698-8263-45bd-bcc2-cfdaca715bef","timestamp":"2026-03-25T14:21:53.188Z"}
