imeout: 10_000 });\n   181→\n   182→      // Connect wallet\n   183→      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n   184→      await stablePage.waitForSelector(\".rng-wallet-button--connected\", { timeout: 5_000 });\n   185→\n   186→      // Click first round card if available\n   187→      const card = stablePage.locator(\".lotr-tier-card\").first();\n   188→      if (await card.isVisible({ timeout: 3_000 }).catch(() => false)) {\n   189→        await card.click();\n   190→        await stablePage.waitForSelector(\".lotr-sidebar\", { timeout: 5_000 });\n   191→      }\n   192→\n   193→      // Re-inject animation freeze CSS after interactions\n   194→      await stablePage.addStyleTag({\n   195→        content: `\n   196→          *, *::before, *::after {\n   197→            animation-duration: 0s !important;\n   198→            animation-delay: 0s !important;\n   199→            transition-duration: 0s !important;\n   200→            transition-delay: 0s !important;\n   201→            scroll-behavior: auto !important;\n   202→          }\n   203→          svg { animation-play-state: paused !important; }\n   204→        `,\n   205→      });\n   206→\n   207→      // Settle UI\n   208→      await stablePage.waitForTimeout(300);\n   209→\n   210→      await expect(stablePage).toHaveScreenshot(\"lotr-tier-connected.png\", { fullPage: true });\n   211→    });\n   212→\n   213→    test(\"back to lobby — human navigates back from round view\", async ({ stablePage }) => {\n   214→      await stablePage.addInitScript(() => {\n   215→        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n   216→      });\n   217→      await stablePage.goto(\"/lord-of-rngs\");\n   218→\n   219→      // Wait for lobby\n   220→      await stablePage.waitForSelector(\".lotr-tier-lobby\", { timeout: 10_000 });\n   221→\n   222→      // Select a round if available\n   223→      const card = stablePage.locator(\".lotr-tier-card\").first();\n   224→      if (await card.isVisible({ timeout: 3_000 }).catch(() => false)) {\n   225→        await card.click();\n   226→        await stablePage.waitForSelector(\".lotr-sidebar\", { timeout: 5_000 });\n   227→\n   228→        // Click back button to return to lobby\n   229→        const backBtn = stablePage.getByRole(\"button\", { name: /back to lobby/i });\n   230→        if (await backBtn.isVisible({ timeout: 3_000 }).catch(() => false)) {\n   231→          await backBtn.click();\n   232→        }\n   233→      }\n   234→\n   235→      // Wait for lobby to reappear\n   236→      await stablePage.waitForSelector(\".lotr-tier-lobby\", { timeout: 5_000 });\n   237→\n   238→      // Settle\n   239→      await stablePage.waitForTimeout(300);\n   240→\n   241→      await expect(stablePage).toHaveScreenshot(\"lotr-back-to-lobby.png\", { fullPage: true });\n   242→    });\n   243→  });\n   244→\n   245→  test.describe(\"Close Call page\", () => {\n   246→    test(\"wallet disconnected\", async ({ stablePage }) => {\n   247→      await stablePage.addInitScript(() => {\n   248→        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n   249→      });\n   250→      await stablePage.goto(\"/close-call\");\n   251→      await expect(stablePage).toHaveScreenshot(\"closecall-disconnected.png\", { fullPage: true });\n   252→    });\n   253→\n   254→    test(\"wallet connected\", async ({ stablePage }) => {\n   255→      await stablePage.addInitScript(() => {\n   256→        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n   257→      });\n   258→      await stablePage.goto(\"/close-call\");\n   259→\n   260→      // Click the wallet connect button\n   261→      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n   262→\n   263→      // Wait for connected state\n   264→      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n   265→        timeout: 5000,\n   266→      });\n   267→\n   268→      // Re-inject animation freeze CSS (connect flow