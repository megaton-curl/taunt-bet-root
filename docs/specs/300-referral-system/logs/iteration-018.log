{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WfQBv9vyVs8ogfKh6iewKi","type":"tool_result","content":"==> /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/lib/auth-api.ts <==\n/**\n * Thin fetch wrappers for the /auth/* backend endpoints.\n */\n\nconst BACKEND_URL = (\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n).replace(/\\/$/, \"\");\n\nexport interface ChallengeResponse {\n  nonce: string;\n  message: string;\n  expiresAt: string;\n}\n\n\n==> /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/lib/auth-store.ts <==\n/**\n * Pure storage logic for auth session tokens.\n * No React — just localStorage + module-level in-memory access token.\n */\n\nconst STORAGE_KEY = \"rng-utopia:session\";\n\nexport interface PersistedWalletSession {\n  wallet: string;\n  cluster: string;\n  refreshToken: string;\n  refreshExpiresAt: string;\n}\n\n// In-memory only — never stored in localStorage\n\n==> /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/lib/colors.ts <==\n/** Shared outcome colors used across game pages */\n\n/** Neon green — win/won result text */\nexport const WIN_COLOR = \"#39ff14\";\n\n/** Muted red — loss/lost result text */\nexport const LOSS_COLOR = \"#d45d5d\";\n\n/** Green — positive profit amount */\nexport const PROFIT_COLOR = \"#22c55e\";\n\n/** Red — negative loss amount and error text */\nexport const ERROR_COLOR = \"#ef4444\";\n\n==> /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/lib/confirm-deposit.ts <==\n/**\n * confirm-tx — reports a confirmed on-chain transaction to the backend.\n *\n * Called by each game context after sendAndConfirm succeeds. The backend\n * records the transaction row with the real tx_sig. Fire-and-forget —\n * failures are logged but don't block gameplay.\n */\n\nimport { getAccessToken } from \"./auth-store\";\n\nconst BACKEND_URL = (\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n).replace(/\\/$/, \"\");\n\n\n==> /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/lib/parse-transaction-error.ts <==\n/**\n * Shared transaction error parser.\n *\n * Each game calls `createTransactionErrorParser` with its own game-specific\n * checks and a log label. The returned function runs game overrides first,\n * then falls through to the shared checks that are common across all games.\n */\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\n/** A single error check: test the raw message, return a user-friendly string. */\nexport type ErrorCheck = (msg: string) => string | null;\n\n\n==> /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/lib/solana-env.ts <==\n/**\n * Centralized Solana network configuration.\n *\n * Reads VITE_SOLANA_NETWORK once at startup. Every part of the platform\n * that needs to know the cluster (explorer links, session storage,\n * wallet adapter, etc.) should import from here instead of hardcoding.\n */\n\nexport type SolanaCluster = \"devnet\" | \"testnet\" | \"mainnet-beta\";\n\nconst raw = (import.meta.env.VITE_SOLANA_NETWORK as string) ?? \"devnet\";\n\nfunction parseCluster(value: string): SolanaCluster {\n  const v = value.trim().toLowerCase();\n  if (v === \"mainnet-beta\" || v === \"mainnet\") return \"mainnet-beta\";\n\n==> /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/lib/useSendAndConfirm.ts <==\nimport { useCallback } from \"react\";\nimport type { Connection, Transaction } from \"@solana/web3.js\";\n\n/**\n * Shared hook that wraps send + confirm + retry logic for Solana transactions.\n *\n * Features:\n * - Preserves external (backend) signatures — skips blockhash overwrite\n * - Pre-flight simulation with InstructionError early-abort\n * - Retry loop with fresh blockhash on expiry (skipped for preserved-signature txs)\n * - 30s abort controller timeout per attempt\n * - Fallback getSignatureStatus check before retrying (catches devnet WS drops)\n * - refreshBalance() call on success\n */\nexport function useSendAndConfirm(\n\n==> /workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/lib/useSettlementEvent.ts <==\n/**\n * Shared hook for detecting on-chain settlement via WebSocket.\n *\n * Uses `connection.onAccountChange(matchPda, ...)` to detect when the match\n * account is closed (lamports → 0) by the settle instruction. This is the\n * most reliable subscription method because:\n * - Subscribes to a specific account address (not program-wide)\n * - Fires on any lamports/data change, including closure\n * - Works on all RPC providers (dRPC, Helius, public devnet)\n *\n * When closure is detected, fetches the settle tx from the backend to get\n * the full event data (winner, result, secret, etc.).\n *\n * This provides ~1-3s settlement detection vs ~15s with getAccountInfo polling.\n * Polling remains as a fallback in case the WebSocket drops.","is_error":false}]},"parent_tool_use_id":"toolu_019qSVyWcmbSmZ1QD7cP6hiJ","session_id":"38b63b0d-f98b-4e0f-a8c4-3b64d5b6e37d","uuid":"d677a63c-ee94-475a-bc3c-f024d6dd2884","timestamp":"2026-03-25T12:49:24.165Z"}
