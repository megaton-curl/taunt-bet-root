{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J2WR2txotx5cHAVj16zqmU","type":"tool_result","content":"     1→/**\n     2→ * Pure storage logic for auth session tokens.\n     3→ * No React — just localStorage + module-level in-memory access token.\n     4→ */\n     5→\n     6→const STORAGE_KEY = \"rng-utopia:session\";\n     7→\n     8→export interface PersistedWalletSession {\n     9→  wallet: string;\n    10→  cluster: string;\n    11→  refreshToken: string;\n    12→  refreshExpiresAt: string;\n    13→}\n    14→\n    15→// In-memory only — never stored in localStorage\n    16→let accessToken: string | null = null;\n    17→let accessExpiresAt: string | null = null;\n    18→\n    19→export function getAccessToken(): string | null {\n    20→  if (!accessToken || !accessExpiresAt) return null;\n    21→  // Check if expired (with 30s buffer)\n    22→  if (new Date(accessExpiresAt).getTime() - 30_000 < Date.now()) return null;\n    23→  return accessToken;\n    24→}\n    25→\n    26→export function setAccessToken(token: string, expiresAt: string): void {\n    27→  accessToken = token;\n    28→  accessExpiresAt = expiresAt;\n    29→}\n    30→\n    31→export function clearAccessToken(): void {\n    32→  accessToken = null;\n    33→  accessExpiresAt = null;\n    34→}\n    35→\n    36→export function getAccessExpiresAt(): string | null {\n    37→  return accessExpiresAt;\n    38→}\n    39→\n    40→export function getPersistedSession(): PersistedWalletSession | null {\n    41→  try {\n    42→    const raw = localStorage.getItem(STORAGE_KEY);\n    43→    if (!raw) return null;\n    44→    const parsed = JSON.parse(raw) as PersistedWalletSession;\n    45→    // Check refresh token expiry\n    46→    if (new Date(parsed.refreshExpiresAt).getTime() < Date.now()) {\n    47→      localStorage.removeItem(STORAGE_KEY);\n    48→      return null;\n    49→    }\n    50→    return parsed;\n    51→  } catch {\n    52→    return null;\n    53→  }\n    54→}\n    55→\n    56→export function setPersistedSession(session: PersistedWalletSession): void {\n    57→  localStorage.setItem(STORAGE_KEY, JSON.stringify(session));\n    58→}\n    59→\n    60→export function clearPersistedSession(): void {\n    61→  localStorage.removeItem(STORAGE_KEY);\n    62→  clearAccessToken();\n    63→}\n    64→"}]},"parent_tool_use_id":"toolu_019qSVyWcmbSmZ1QD7cP6hiJ","session_id":"38b63b0d-f98b-4e0f-a8c4-3b64d5b6e37d","uuid":"317bd10b-643a-44c7-b38a-dc5ed1ce7e22","timestamp":"2026-03-25T12:49:15.373Z"}
