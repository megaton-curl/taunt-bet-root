typeof json?.error === \"string\" ? json.error : `Auth request failed (${res.status})`;\n    throw new Error(msg);\n  }\n  return json as T;\n}\n\nexport async function requestChallenge(wallet: string): Promise<ChallengeResponse> {\n  const res = await fetch(`${BACKEND_URL}/auth/challenge`, {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ wallet }),\n  });\n  return parseResponse<ChallengeResponse>(res);\n}\n\nexport async function verifyChallenge(\n  nonce: string,\n  wallet: string,\n  signature: string,\n): Promise<VerifyResponse> {\n  const res = await fetch(`${BACKEND_URL}/auth/verify`, {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ nonce, wallet, signature }),\n  });\n  return parseResponse<VerifyResponse>(res);\n}\n\nexport async function refreshSession(refreshToken: string): Promise<RefreshResponse> {\n  const res = await fetch(`${BACKEND_URL}/auth/refresh`, {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ refreshToken }),\n  });\n  return parseResponse<RefreshResponse>(res);\n}\n\nexport async function logout(refreshToken: string): Promise<void> {\n  await fetch(`${BACKEND_URL}/auth/logout`, {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ refreshToken }),\n  });\n}\n","numLines":77,"startLine":1,"totalLines":77}}}
