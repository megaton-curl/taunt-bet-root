{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019oRWunbcfRDr53sNhJz34a","type":"tool_result","content":"     1ŌåÆ/**\n     2ŌåÆ * Settlement worker ŌĆö polls the chain for server-owned rounds that are ready\n     3ŌåÆ * for backend settlement across supported games.\n     4ŌåÆ */\n     5ŌåÆ\n     6ŌåÆimport { performance } from \"node:perf_hooks\";\n     7ŌåÆimport { Connection, PublicKey } from \"@solana/web3.js\";\n     8ŌåÆimport { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID } from \"../tx-builder.js\";\n     9ŌåÆimport type { Db } from \"../db.js\";\n    10ŌåÆimport { logger } from \"../logger.js\";\n    11ŌåÆimport {\n    12ŌåÆ  coinflipMatchSize,\n    13ŌåÆ  decodeCoinflipMatch,\n    14ŌåÆ  decodeLordRound,\n    15ŌåÆ  lordRoundDiscriminatorFilter,\n    16ŌåÆ} from \"./account-decoder.js\";\n    17ŌåÆ\n    18ŌåÆconst PHASE_LOCKED_VALUE = 1;\n    19ŌåÆconst LORD_PHASE_ACTIVE_VALUE = 1;\n    20ŌåÆ\n    21ŌåÆexport interface SettlementWorkerDeps {\n    22ŌåÆ  db: Db;\n    23ŌåÆ  connection: Connection;\n    24ŌåÆ  serverKey: PublicKey;\n    25ŌåÆ  pollIntervalMs: number;\n    26ŌåÆ  /** Called when a match is detected as ready for settlement (target_slot reached). */\n    27ŌåÆ  onSettleReady?: (pda: string) => Promise<void>;\n    28ŌåÆ  /** Called to check if a PDA is finalized (settled or permanently failed). */\n    29ŌåÆ  isFinalized?: (pda: string) => boolean;\n    30ŌåÆ}\n    31ŌåÆ\n    32ŌåÆexport interface SettlementWorker {\n    33ŌåÆ  start(): void;\n    34ŌåÆ  stop(): void;\n    35ŌåÆ  readonly isRunning: boolean;\n    36ŌåÆ  /** Run a single poll cycle (exposed for testing). */\n    37ŌåÆ  poll(): Promise<void>;\n    38ŌåÆ}\n    39ŌåÆ\n    40ŌåÆexport function createSettlementWorker(\n    41ŌåÆ  deps: SettlementWorkerDeps,\n    42ŌåÆ): SettlementWorker {\n    43ŌåÆ  const { db, connection, serverKey, pollIntervalMs } = deps;\n    44ŌåÆ  const discoveredPdas = new Set<string>();\n    45ŌåÆ  const readyPdas = new Set<string>();\n    46ŌåÆ  /** PDAs that failed decode ŌĆö stale accounts from previous deploys. Logged once, then skipped. */\n    47ŌåÆ  const undecodeablePdas = new Set<string>();\n    48ŌåÆ  let running = false;\n    49ŌåÆ  let timeoutId: ReturnType<typeof setTimeout> | null = null;\n    50ŌåÆ\n    51ŌåÆ  async function handleDiscoveredRound(\n    52ŌåÆ    pda: string,\n    53ŌåÆ    targetSlot: bigint,\n    54ŌåÆ    currentSlot: number,\n    55ŌåÆ    slotTime: string | null,\n    56ŌåÆ  ): Promise<void> {\n    57ŌåÆ    const round = await db.getRoundByPda(pda);\n    58ŌåÆ    if (!round) {\n    59ŌåÆ      return;\n    60ŌåÆ    }\n    61ŌåÆ\n    62ŌåÆ    if (!discoveredPdas.has(pda)) {\n    63ŌåÆ      discoveredPdas.add(pda);\n    64ŌåÆ      if (round.phase === \"created\") {\n    65ŌåÆ        await db.updateRoundPhase(pda, \"locked\", {\n    66ŌåÆ          target_slot: targetSlot.toString(),\n    67ŌåÆ        });\n    68ŌåÆ        await db.insertOperatorEvent(pda, \"match_detected\", {\n    69ŌåÆ          targetSlot: targetSlot.toString(),\n    70ŌåÆ          currentSlot,\n    71ŌåÆ          game: round.game,\n    72ŌåÆ        });\n    73ŌåÆ        logger.info(\"settlement worker detected locked round\", {\n    74ŌåÆ          pda,\n    75ŌåÆ          creator: round.creator,\n    76ŌåÆ          targetSlot: targetSlot.toString(),\n    77ŌåÆ          currentSlot,\n    78ŌåÆ          slotTime,\n    79ŌåÆ          game: round.game,\n    80ŌåÆ        });\n    81ŌåÆ      }\n    82ŌåÆ    }\n    83ŌåÆ\n    84ŌåÆ    if (BigInt(currentSlot) >= targetSlot && deps.onSettleReady) {\n    85ŌåÆ      if (deps.isFinalized?.(pda)) {\n    86ŌåÆ        // Clean up tracking sets for finalized PDAs to prevent unbounded growth\n    87ŌåÆ        discoveredPdas.delete(pda);\n    88ŌåÆ        readyPdas.delete(pda);\n    89ŌåÆ        return;\n    90ŌåÆ      }\n    91ŌåÆ\n    92ŌåÆ      const slotsAhead = currentSlot - Number(targetSlot);\n    93ŌåÆ      if (!readyPdas.has(pda)) {\n    94ŌåÆ        readyPdas.add(pda);\n    95ŌåÆ        logger.info(\"settlement worker found round ready\", {\n    96ŌåÆ          pda,\n    97ŌåÆ          targetSlot: targetSlot.toString(),\n    98ŌåÆ          currentSlot,\n    99ŌåÆ          slotsAhead,\n   100ŌåÆ          estimatedDelayMs: slotsAhead * 400,\n   101ŌåÆ          slotTime,\n   102ŌåÆ        });\n   103ŌåÆ      }\n   104ŌåÆ      const tSettle0 = performance.now();\n   105ŌåÆ      await deps.onSettleReady(pda);\n   106ŌåÆ      const tSettle1 = performance.now();\n   107ŌåÆ      logger.debug(\"settlement worker onSettleReady completed\", {\n   108ŌåÆ        pda: pda.slice(0, 12),\n   109ŌåÆ        settleMs: Math.round(tSettle1 - tSettle0),\n   110ŌåÆ      });\n   111ŌåÆ    }\n   112ŌåÆ  }\n   113ŌåÆ\n   114ŌåÆ  async function poll(): Promise<void> {\n   115ŌåÆ    const t0 = performance.now();\n   116ŌåÆ    const currentSlot = await connection.getSlot();\n   117ŌåÆ    const blockTime = await connection.getBlockTime(currentSlot).catch(() => null);\n   118ŌåÆ    const slotTime = blockTime ? new Date(blockTime * 1000).toISOString() : null;\n   119ŌåÆ    const tSlot = performance.now();\n   120ŌåÆ\n   121ŌåÆ    // Coinflip: fetch by dataSize (distinguishes Match from Config), decode + filter\n   122ŌåÆ    const coinflipAccounts = await connection.getProgramAccounts(COINFLIP_PROGRAM_ID, {\n   123ŌåÆ      filters: [{ dataSize: coinflipMatchSize() }],\n   124ŌåÆ    });\n   125ŌåÆ    const tCoinflip = performance.now();\n   126ŌåÆ\n   127ŌåÆ    for (const { pubkey, account } of coinflipAccounts) {\n   128ŌåÆ      const key = pubkey.toBase58();\n   129ŌåÆ      if (undecodeablePdas.has(key)) continue;\n   130ŌåÆ      try {\n   131ŌåÆ        const match = decodeCoinflipMatch(Buffer.from(account.data));\n   132ŌåÆ        if (match.phase !== PHASE_LOCKED_VALUE || !match.server.equals(serverKey)) continue;\n   133ŌåÆ        await handleDiscoveredRound(key, match.targetSlot, currentSlot, slotTime);\n   134ŌåÆ      } catch {\n   135ŌåÆ        undecodeablePdas.add(key);\n   136ŌåÆ        logger.warn(\"skipping undecodeable coinflip account\", { pda: key });\n   137ŌåÆ      }\n   138ŌåÆ    }\n   139ŌåÆ\n   140ŌåÆ    // Lord: fetch by discriminator (variable-size accounts), decode + filter\n   141ŌåÆ    const lordAccounts = await connection.getProgramAccounts(LORDOFRNGS_PROGRAM_ID, {\n   142ŌåÆ      filters: [lordRoundDiscriminatorFilter()],\n   143ŌåÆ    });\n   144ŌåÆ    const tLord = performance.now();\n   145ŌåÆ\n   146ŌåÆ    for (const { pubkey, account } of lordAccounts) {\n   147ŌåÆ      const key = pubkey.toBase58();\n   148ŌåÆ      if (undecodeablePdas.has(key)) continue;\n   149ŌåÆ      try {\n   150ŌåÆ        const round = decodeLordRound(Buffer.from(account.data));\n   151ŌåÆ        if (round.phase !== LORD_PHASE_ACTIVE_VALUE || !round.server.equals(serverKey)) continue;\n   152ŌåÆ        if (round.targetEntropySlot <= 0n) continue;\n   153ŌåÆ        await handleDiscoveredRound(key, round.targetEntropySlot, currentSlot, slotTime);\n   154ŌåÆ      } catch {\n   155ŌåÆ        undecodeablePdas.add(key);\n   156ŌåÆ        logger.warn(\"skipping undecodeable lord account\", { pda: key });\n   157ŌåÆ      }\n   158ŌåÆ    }\n   159ŌåÆ    const tEnd = performance.now();\n   160ŌåÆ\n   161ŌåÆ    logger.debug(\"settlement poll cycle\", {\n   162ŌåÆ      slotMs: Math.round(tSlot - t0),\n   163ŌåÆ      coinflipFetchMs: Math.round(tCoinflip - tSlot),\n   164ŌåÆ      lordFetchMs: Math.round(tLord - tCoinflip),\n   165ŌåÆ      totalMs: Math.round(tEnd - t0),\n   166ŌåÆ      coinflipAccounts: coinflipAccounts.length,\n   167ŌåÆ      lordAccounts: lordAccounts.length,\n   168ŌåÆ      currentSlot,\n   169ŌåÆ      slotTime,\n   170ŌåÆ    });\n   171ŌåÆ  }\n   172ŌåÆ\n   173ŌåÆ  async function loop(): Promise<void> {\n   174ŌåÆ    if (!running) return;\n   175ŌåÆ    try {\n   176ŌåÆ      await poll();\n   177ŌåÆ    } catch (err) {\n   178ŌåÆ      // Log but don't crash ŌĆö transient RPC errors are expected\n   179ŌåÆ      logger.error(\"settlement worker poll error\", {\n   180ŌåÆ        error: err instanceof Error ? err.message : String(err),\n   181ŌåÆ      });\n   182ŌåÆ    }\n   183ŌåÆ    if (running) {\n   184ŌåÆ      timeoutId = setTimeout(loop, pollIntervalMs);\n   185ŌåÆ    }\n   186ŌåÆ  }\n   187ŌåÆ\n   188ŌåÆ  return {\n   189ŌåÆ    start() {\n   190ŌåÆ      if (running) return;\n   191ŌåÆ      running = true;\n   192ŌåÆ      const rpcUrl = connection.rpcEndpoint;\n   193ŌåÆ      const trimmedRpc = (() => {\n   194ŌåÆ        try {\n   195ŌåÆ          const u = new URL(rpcUrl);\n   196ŌåÆ          return `${u.host}${u.pathname}`;\n   197ŌåÆ        } catch {\n   198ŌåÆ          return rpcUrl.slice(0, 40) + \"ŌĆ”\";\n   199ŌåÆ        }\n   200ŌåÆ      })();\n   201ŌåÆ      logger.info(\"settlement worker started\", {\n   202ŌåÆ        serverKey: serverKey.toBase58(),\n   203ŌåÆ        pollIntervalMs,\n   204ŌåÆ        rpc: trimmedRpc,\n   205ŌåÆ      });\n   206ŌåÆ      loop();\n   207ŌåÆ    },\n   208ŌåÆ    stop() {\n   209ŌåÆ      running = false;\n   210ŌåÆ      if (timeoutId) {\n   211ŌåÆ        clearTimeout(timeoutId);\n   212ŌåÆ        timeoutId = null;\n   213ŌåÆ      }\n   214ŌåÆ      logger.info(\"settlement worker stopped\", {\n   215ŌåÆ        serverKey: serverKey.toBase58(),\n   216ŌåÆ      });\n   217ŌåÆ    },\n   218ŌåÆ    get isRunning() {\n   219ŌåÆ      return running;\n   220ŌåÆ    },\n   221ŌåÆ    poll,\n   222ŌåÆ  };\n   223ŌåÆ}\n   224ŌåÆ"}]},"parent_tool_use_id":"toolu_01GsAXUbdQhh9DYX1RdbJUxG","session_id":"e3b67986-fd78-4b1a-b5f8-3ba5e0f9fe3d","uuid":"478b73f6-437a-4e6c-809a-8714cd7a3a34","timestamp":"2026-03-25T12:19:26.413Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013PqeNguUbxVre8hyaEhrVA","type":"tool_result","content":"     1ŌåÆ/**\n     2ŌåÆ * Settle transaction builder + submission.\n     3ŌåÆ *\n     4ŌåÆ * Retrieves the stored secret, reads on-chain match + config data to resolve\n     5ŌåÆ * all accounts, builds the `settle` instruction, submits it, and updates the\n     6ŌåÆ * DB on confirmation.\n     7ŌåÆ */\n     8ŌåÆ\n     9ŌåÆimport { createHash } from \"node:crypto\";\n    10ŌåÆimport { performance } from \"node:perf_hooks\";\n    11ŌåÆimport {\n    12ŌåÆ  Connection,\n    13ŌåÆ  Keypair,\n    14ŌåÆ  PublicKey,\n    15ŌåÆ  SystemProgram,\n    16ŌåÆ  Transaction,\n    17ŌåÆ  TransactionInstruction,\n    18ŌåÆ} from \"@solana/web3.js\";\n    19ŌåÆimport type { Db } from \"../db.js\";\n    20ŌåÆimport { logger } from \"../logger.js\";\n    21ŌåÆimport { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n    22ŌåÆimport { derivePlatformConfigPda, getPlatformConfig } from \"../platform-config.js\";\n    23ŌåÆimport { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@rng-utopia/anchor-client\";\n    24ŌåÆimport {\n    25ŌåÆ  decodeCoinflipMatch,\n    26ŌåÆ  decodeLordRound,\n    27ŌåÆ  type DecodedJackpotRound,\n    28ŌåÆ} from \"./account-decoder.js\";\n    29ŌåÆ\n    30ŌåÆ// ---------------------------------------------------------------------------\n    31ŌåÆ// Instruction discriminators (from IDL ŌĆö no hardcoded byte arrays)\n    32ŌåÆ// ---------------------------------------------------------------------------\n    33ŌåÆ\n    34ŌåÆfunction getInstructionDiscriminator(\n    35ŌåÆ  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n    36ŌåÆ  instructionName: string,\n    37ŌåÆ): Buffer {\n    38ŌåÆ  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n    39ŌåÆ  if (!instruction) {\n    40ŌåÆ    throw new Error(`Instruction ${instructionName} not found in IDL`);\n    41ŌåÆ  }\n    42ŌåÆ  return Buffer.from(instruction.discriminator);\n    43ŌåÆ}\n    44ŌåÆ\n    45ŌåÆconst SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\n    46ŌåÆconst CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n    47ŌåÆ  lordIdl,\n    48ŌåÆ  \"claim_payout\",\n    49ŌåÆ);\n    50ŌåÆconst CC_BET_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"bet\");\n    51ŌåÆconst CC_SETTLE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"settle_round\");\n    52ŌåÆconst CC_TIMEOUT_REFUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"timeout_refund\");\n    53ŌåÆ\n    54ŌåÆ// ---------------------------------------------------------------------------\n    55ŌåÆ// Types\n    56ŌåÆ// ---------------------------------------------------------------------------\n    57ŌåÆ\n    58ŌåÆexport interface SettleTxDeps {\n    59ŌåÆ  db: Db;\n    60ŌåÆ  connection: Connection;\n    61ŌåÆ  serverKeypair: Keypair;\n    62ŌåÆ  entropyAccount: PublicKey;\n    63ŌåÆ}\n    64ŌåÆ\n    65ŌåÆexport interface SettleResult {\n    66ŌåÆ  txSignature: string;\n    67ŌåÆ  resultHash: Buffer;\n    68ŌåÆ  resultSide?: number;\n    69ŌåÆ  winningEntryIndex?: number;\n    70ŌåÆ  winner: string;\n    71ŌåÆ}\n    72ŌåÆ\n    73ŌåÆ// ---------------------------------------------------------------------------\n    74ŌåÆ// Instruction encoding\n    75ŌåÆ// ---------------------------------------------------------------------------\n    76ŌåÆ\n    77ŌåÆ/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\n    78ŌåÆfunction encodeSettleData(secret: Buffer): Buffer {\n    79ŌåÆ  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n    80ŌåÆ}\n    81ŌåÆ\n    82ŌåÆfunction encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n    83ŌåÆ  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n    84ŌåÆ}\n    85ŌåÆ\n    86ŌåÆ// ---------------------------------------------------------------------------\n    87ŌåÆ// Result derivation (mirrors on-chain derive_result)\n    88ŌåÆ// ---------------------------------------------------------------------------\n    89ŌåÆ\n    90ŌåÆ/**\n    91ŌåÆ * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n    92ŌåÆ * Must match shared/src/fairness.rs `derive_result()`.\n    93ŌåÆ */\n    94ŌåÆfunction deriveResult(\n    95ŌåÆ  secret: Buffer,\n    96ŌåÆ  entropy: Buffer,\n    97ŌåÆ  matchPdaBytes: Buffer,\n    98ŌåÆ  algoVer: number,\n    99ŌåÆ): Buffer {\n   100ŌåÆ  return createHash(\"sha256\")\n   101ŌåÆ    .update(secret)\n   102ŌåÆ    .update(entropy)\n   103ŌåÆ    .update(matchPdaBytes)\n   104ŌåÆ    .update(Buffer.from([algoVer]))\n   105ŌåÆ    .digest();\n   106ŌåÆ}\n   107ŌåÆ\n   108ŌåÆ// ---------------------------------------------------------------------------\n   109ŌåÆ// Core settle function\n   110ŌåÆ// ---------------------------------------------------------------------------\n   111ŌåÆ\n   112ŌåÆ/**\n   113ŌåÆ * Build, submit, and confirm a settle transaction for a locked match.\n   114ŌåÆ *\n   115ŌåÆ * Steps:\n   116ŌåÆ * 1. Retrieve secret from DB\n   117ŌåÆ * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n   118ŌåÆ * 3. Fetch config account data (treasury)\n   119ŌåÆ * 4. Read entropy from the entropy account\n   120ŌåÆ * 5. Pre-compute result (for DB storage ŌĆö account is zeroed after settle)\n   121ŌåÆ * 6. Build + submit settle tx\n   122ŌåÆ * 7. Update DB on confirmation\n   123ŌåÆ */\n   124ŌåÆexport async function settleMatch(\n   125ŌåÆ  deps: SettleTxDeps,\n   126ŌåÆ  pda: string,\n   127ŌåÆ): Promise<SettleResult> {\n   128ŌåÆ  const t0 = performance.now();\n   129ŌåÆ  const { db, connection, serverKeypair, entropyAccount } = deps;\n   130ŌåÆ  const matchPubkey = new PublicKey(pda);\n   131ŌåÆ\n   132ŌåÆ  // 1. Retrieve secret from DB\n   133ŌåÆ  const round = await db.getRoundByPda(pda);\n   134ŌåÆ  const tDb = performance.now();\n   135ŌåÆ  if (!round) {\n   136ŌåÆ    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   137ŌåÆ  }\n   138ŌåÆ  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   139ŌåÆ    throw new PermanentSettleError(\n   140ŌåÆ      `Round ${pda} in unexpected phase: ${round.phase}`,\n   141ŌåÆ    );\n   142ŌåÆ  }\n   143ŌåÆ\n   144ŌåÆ  const secret = Buffer.from(round.secret);\n   145ŌåÆ\n   146ŌåÆ  // Transition to settling (locked ŌåÆ settling)\n   147ŌåÆ  if (round.phase === \"locked\") {\n   148ŌåÆ    await db.updateRoundPhase(pda, \"settling\");\n   149ŌåÆ  }\n   150ŌåÆ\n   151ŌåÆ  // Log settle_submitted\n   152ŌåÆ  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   153ŌåÆ    attempt: round.settle_attempts + 1,\n   154ŌåÆ  });\n   155ŌåÆ\n   156ŌåÆ  // 2-4. Fetch match, platform config, entropy, and blockhash in parallel\n   157ŌåÆ  const [platformConfigPda] = derivePlatformConfigPda();\n   158ŌåÆ  const [matchAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n   159ŌåÆ    await Promise.all([\n   160ŌåÆ      connection.getAccountInfo(matchPubkey),\n   161ŌåÆ      getPlatformConfig(connection),\n   162ŌåÆ      connection.getAccountInfo(entropyAccount),\n   163ŌåÆ      connection.getLatestBlockhash(),\n   164ŌåÆ    ]);\n   165ŌåÆ  const tFetch = performance.now();\n   166ŌåÆ\n   167ŌåÆ  if (!matchAccountInfo) {\n   168ŌåÆ    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n   169ŌåÆ  }\n   170ŌåÆ  if (!entropyInfo) {\n   171ŌåÆ    throw new TransientSettleError(\"Entropy account not available yet\");\n   172ŌåÆ  }\n   173ŌåÆ\n   174ŌåÆ  // IDL-driven decode ŌĆö no manual byte offsets\n   175ŌåÆ  const match = decodeCoinflipMatch(Buffer.from(matchAccountInfo.data));\n   176ŌåÆ  const { feeBps, treasury } = platformConfig;\n   177ŌåÆ\n   178ŌåÆ  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer } = match;\n   179ŌåÆ\n   180ŌåÆ  const pool = entryAmount * 2n;\n   181ŌåÆ  const feeAmount = Number((pool * BigInt(feeBps)) / 10_000n);\n   182ŌåÆ  const payoutAmount = Number(pool) - feeAmount;\n   183ŌåÆ\n   184ŌåÆ  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   185ŌåÆ\n   186ŌåÆ  // 5. Pre-compute result\n   187ŌåÆ  const matchPdaBytes = matchPubkey.toBuffer();\n   188ŌåÆ  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n   189ŌåÆ  const resultSide = resultHash[0]! % 2;\n   190ŌåÆ  const winner = resultSide === creatorSide ? creator : opponent;\n   191ŌåÆ\n   192ŌåÆ  // 6. Build settle instruction (8 accounts, no profile CPI)\n   193ŌåÆ  const data = encodeSettleData(secret);\n   194ŌåÆ\n   195ŌåÆ  const instruction = new TransactionInstruction({\n   196ŌåÆ    keys: [\n   197ŌåÆ      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n   198ŌåÆ      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // coinflip_match\n   199ŌåÆ      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n   200ŌåÆ      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   201ŌåÆ      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n   202ŌåÆ      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n   203ŌåÆ      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n   204ŌåÆ      {\n   205ŌåÆ        pubkey: SystemProgram.programId,\n   206ŌåÆ        isSigner: false,\n   207ŌåÆ        isWritable: false,\n   208ŌåÆ      }, // system_program\n   209ŌåÆ    ],\n   210ŌåÆ    programId: COINFLIP_PROGRAM_ID,\n   211ŌåÆ    data,\n   212ŌåÆ  });\n   213ŌåÆ\n   214ŌåÆ  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   215ŌåÆ\n   216ŌåÆ  const tx = new Transaction({\n   217ŌåÆ    feePayer: serverKeypair.publicKey,\n   218ŌåÆ    blockhash,\n   219ŌåÆ    lastValidBlockHeight,\n   220ŌåÆ  });\n   221ŌåÆ  tx.add(instruction);\n   222ŌåÆ  tx.sign(serverKeypair);\n   223ŌåÆ\n   224ŌåÆ  // 7. Submit and confirm\n   225ŌåÆ  const rawTx = tx.serialize();\n   226ŌåÆ  const tBuild = performance.now();\n   227ŌåÆ  const txSignature = await connection.sendRawTransaction(rawTx, {\n   228ŌåÆ    skipPreflight: false,\n   229ŌåÆ  });\n   230ŌåÆ  const tSend = performance.now();\n   231ŌåÆ\n   232ŌåÆ  logger.info(\"settlement transaction submitted\", {\n   233ŌåÆ    pda,\n   234ŌåÆ    txSignature,\n   235ŌåÆ    attempt: round.settle_attempts + 1,\n   236ŌåÆ    dbMs: Math.round(tDb - t0),\n   237ŌåÆ    fetchMs: Math.round(tFetch - tDb),\n   238ŌåÆ    buildMs: Math.round(tBuild - tFetch),\n   239ŌåÆ    sendMs: Math.round(tSend - tBuild),\n   240ŌåÆ  });\n   241ŌåÆ\n   242ŌåÆ  const confirmation = await connection.confirmTransaction(\n   243ŌåÆ    { signature: txSignature, blockhash, lastValidBlockHeight },\n   244ŌåÆ    \"confirmed\",\n   245ŌåÆ  );\n   246ŌåÆ  const tConfirm = performance.now();\n   247ŌåÆ  if (confirmation.value.err) {\n   248ŌåÆ    throw new TransientSettleError(\n   249ŌåÆ      `Coinflip settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   250ŌåÆ    );\n   251ŌåÆ  }\n   252ŌåÆ\n   253ŌåÆ  // 8. Update DB ŌĆö phase settling ŌåÆ settled\n   254ŌåÆ  const coinflipEntries = [\n   255ŌåÆ    { player: creator.toBase58(), amountLamports: Number(entryAmount) },\n   256ŌåÆ    { player: opponent.toBase58(), amountLamports: Number(entryAmount) },\n   257ŌåÆ  ];\n   258ŌåÆ\n   259ŌåÆ  await db.updateRoundPhase(pda, \"settled\", {\n   260ŌåÆ    settle_tx: txSignature,\n   261ŌåÆ    result_hash: resultHash,\n   262ŌåÆ    result_side: resultSide,\n   263ŌåÆ    winner: winner.toBase58(),\n   264ŌåÆ    settle_attempts: round.settle_attempts + 1,\n   265ŌåÆ  });\n   266ŌåÆ\n   267ŌåÆ  // Persist entries in dedicated JSONB column for direct access\n   268ŌåÆ  await db.updateRoundEntries(pda, coinflipEntries);\n   269ŌåÆ\n   270ŌåÆ  // Log settle_confirmed\n   271ŌåÆ  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   272ŌåÆ    txSignature,\n   273ŌåÆ    resultSide,\n   274ŌåÆ    winner: winner.toBase58(),\n   275ŌåÆ    entropy: entropy.toString(\"hex\"),\n   276ŌåÆ    payoutAmount,\n   277ŌåÆ    feeAmount,\n   278ŌåÆ    entries: coinflipEntries,\n   279ŌåÆ  });\n   280ŌåÆ\n   281ŌåÆ  // Write payout transaction for the winner\n   282ŌåÆ  await db.insertTransaction({\n   283ŌåÆ    wallet: winner.toBase58(),\n   284ŌåÆ    game: \"coinflip\",\n   285ŌåÆ    matchId: round.match_id,\n   286ŌåÆ    txType: \"payout\",\n   287ŌåÆ    amountLamports: payoutAmount,\n   288ŌåÆ    txSig: txSignature,\n   289ŌåÆ  });\n   290ŌåÆ\n   291ŌåÆ  const tDone = performance.now();\n   292ŌåÆ  logger.info(\"settlement transaction confirmed\", {\n   293ŌåÆ    pda,\n   294ŌåÆ    txSignature,\n   295ŌåÆ    resultSide,\n   296ŌåÆ    winner: winner.toBase58(),\n   297ŌåÆ    timing: {\n   298ŌåÆ      dbMs: Math.round(tDb - t0),\n   299ŌåÆ      fetchMs: Math.round(tFetch - tDb),\n   300ŌåÆ      buildMs: Math.round(tBuild - tFetch),\n   301ŌåÆ      sendMs: Math.round(tSend - tBuild),\n   302ŌåÆ      confirmMs: Math.round(tConfirm - tSend),\n   303ŌåÆ      dbWriteMs: Math.round(tDone - tConfirm),\n   304ŌåÆ      totalMs: Math.round(tDone - t0),\n   305ŌåÆ    },\n   306ŌåÆ  });\n   307ŌåÆ\n   308ŌåÆ  return {\n   309ŌåÆ    txSignature,\n   310ŌåÆ    resultHash,\n   311ŌåÆ    resultSide,\n   312ŌåÆ    winner: winner.toBase58(),\n   313ŌåÆ  };\n   314ŌåÆ}\n   315ŌåÆ\n   316ŌåÆexport async function settleLordRound(\n   317ŌåÆ  deps: SettleTxDeps,\n   318ŌåÆ  pda: string,\n   319ŌåÆ): Promise<SettleResult> {\n   320ŌåÆ  const t0 = performance.now();\n   321ŌåÆ  const { db, connection, serverKeypair, entropyAccount } = deps;\n   322ŌåÆ  const roundPubkey = new PublicKey(pda);\n   323ŌåÆ\n   324ŌåÆ  const round = await db.getRoundByPda(pda);\n   325ŌåÆ  const tDb = performance.now();\n   326ŌåÆ  if (!round) {\n   327ŌåÆ    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   328ŌåÆ  }\n   329ŌåÆ  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   330ŌåÆ    throw new PermanentSettleError(\n   331ŌåÆ      `Round ${pda} in unexpected phase: ${round.phase}`,\n   332ŌåÆ    );\n   333ŌåÆ  }\n   334ŌåÆ\n   335ŌåÆ  const secret = Buffer.from(round.secret);\n   336ŌåÆ\n   337ŌåÆ  if (round.phase === \"locked\") {\n   338ŌåÆ    await db.updateRoundPhase(pda, \"settling\");\n   339ŌåÆ  }\n   340ŌåÆ\n   341ŌåÆ  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   342ŌåÆ    attempt: round.settle_attempts + 1,\n   343ŌåÆ    game: \"lord\",\n   344ŌåÆ  });\n   345ŌåÆ\n   346ŌåÆ  const [platformConfigPda] = derivePlatformConfigPda();\n   347ŌåÆ  const [roundAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n   348ŌåÆ    await Promise.all([\n   349ŌåÆ      connection.getAccountInfo(roundPubkey),\n   350ŌåÆ      getPlatformConfig(connection),\n   351ŌåÆ      connection.getAccountInfo(entropyAccount),\n   352ŌåÆ      connection.getLatestBlockhash(),\n   353ŌåÆ    ]);\n   354ŌåÆ\n   355ŌåÆ  const tFetch = performance.now();\n   356ŌåÆ\n   357ŌåÆ  if (!roundAccountInfo) {\n   358ŌåÆ    throw new PermanentSettleError(`Lord round account not found on-chain: ${pda}`);\n   359ŌåÆ  }\n   360ŌåÆ  if (!entropyInfo) {\n   361ŌåÆ    throw new TransientSettleError(\"Entropy account not available yet\");\n   362ŌåÆ  }\n   363ŌåÆ\n   364ŌåÆ  // IDL-driven decode ŌĆö no manual byte offsets or parseLordRound()\n   365ŌåÆ  const roundData: DecodedJackpotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n   366ŌåÆ  const { feeBps, treasury } = platformConfig;\n   367ŌåÆ\n   368ŌåÆ  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   369ŌåÆ  const resultHash = deriveResult(\n   370ŌåÆ    secret,\n   371ŌåÆ    entropy,\n   372ŌåÆ    roundPubkey.toBuffer(),\n   373ŌåÆ    roundData.algorithmVer,\n   374ŌåÆ  );\n   375ŌåÆ  const feeAmount = Number((roundData.totalAmountLamports * BigInt(feeBps)) / 10_000n);\n   376ŌåÆ  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n   377ŌåÆ  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n   378ŌåÆ\n   379ŌåÆ  const raw = resultHash.readBigUInt64LE(0);\n   380ŌåÆ  const winningOffset = raw % roundData.totalAmountLamports;\n   381ŌåÆ\n   382ŌåÆ  let cumulative = 0n;\n   383ŌåÆ  let winnerEntryIndex = -1;\n   384ŌåÆ  let winner = roundData.entries[0]?.player;\n   385ŌåÆ  for (const [index, entry] of roundData.entries.entries()) {\n   386ŌåÆ    cumulative += entry.amountLamports;\n   387ŌåÆ    if (winningOffset < cumulative) {\n   388ŌåÆ      winnerEntryIndex = index;\n   389ŌåÆ      winner = entry.player;\n   390ŌåÆ      break;\n   391ŌåÆ    }\n   392ŌåÆ  }\n   393ŌåÆ\n   394ŌåÆ  if (!winner || winnerEntryIndex < 0) {\n   395ŌåÆ    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n   396ŌåÆ  }\n   397ŌåÆ\n   398ŌåÆ  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n   399ŌåÆ  const instruction = new TransactionInstruction({\n   400ŌåÆ    keys: [\n   401ŌåÆ      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n   402ŌåÆ      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n   403ŌåÆ      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n   404ŌåÆ      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   405ŌåÆ      { pubkey: treasury, isSigner: false, isWritable: true },\n   406ŌåÆ      { pubkey: winner, isSigner: false, isWritable: true },\n   407ŌåÆ      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   408ŌåÆ    ],\n   409ŌåÆ    programId: LORDOFRNGS_PROGRAM_ID,\n   410ŌåÆ    data: encodeClaimPayoutData(matchIdBuf, secret),\n   411ŌåÆ  });\n   412ŌåÆ\n   413ŌåÆ  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   414ŌåÆ  const tx = new Transaction({\n   415ŌåÆ    feePayer: serverKeypair.publicKey,\n   416ŌåÆ    blockhash,\n   417ŌåÆ    lastValidBlockHeight,\n   418ŌåÆ  });\n   419ŌåÆ  tx.add(instruction);\n   420ŌåÆ  tx.sign(serverKeypair);\n   421ŌåÆ\n   422ŌåÆ  const tBuild = performance.now();\n   423ŌåÆ  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n   424ŌåÆ    skipPreflight: false,\n   425ŌåÆ  });\n   426ŌåÆ  const tSend = performance.now();\n   427ŌåÆ\n   428ŌåÆ  logger.info(\"lord settlement transaction submitted\", {\n   429ŌåÆ    pda,\n   430ŌåÆ    txSignature,\n   431ŌåÆ    attempt: round.settle_attempts + 1,\n   432ŌåÆ    winningEntryIndex: winnerEntryIndex,\n   433ŌåÆ    dbMs: Math.round(tDb - t0),\n   434ŌåÆ    fetchMs: Math.round(tFetch - tDb),\n   435ŌåÆ    buildMs: Math.round(tBuild - tFetch),\n   436ŌåÆ    sendMs: Math.round(tSend - tBuild),\n   437ŌåÆ  });\n   438ŌåÆ\n   439ŌåÆ  const confirmation = await connection.confirmTransaction(\n   440ŌåÆ    { signature: txSignature, blockhash, lastValidBlockHeight },\n   441ŌåÆ    \"confirmed\",\n   442ŌåÆ  );\n   443ŌåÆ  const tConfirm = performance.now();\n   444ŌåÆ  if (confirmation.value.err) {\n   445ŌåÆ    throw new TransientSettleError(\n   446ŌåÆ      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   447ŌåÆ    );\n   448ŌåÆ  }\n   449ŌåÆ\n   450ŌåÆ  const serializedEntries = roundData.entries.map((e) => ({\n   451ŌåÆ    player: e.player.toBase58(),\n   452ŌåÆ    amountLamports: Number(e.amountLamports),\n   453ŌåÆ  }));\n   454ŌåÆ\n   455ŌåÆ  await db.updateRoundPhase(pda, \"settled\", {\n   456ŌåÆ    settle_tx: txSignature,\n   457ŌåÆ    result_hash: resultHash,\n   458ŌåÆ    result_side: winnerEntryIndex,\n   459ŌåÆ    winner: winner.toBase58(),\n   460ŌåÆ    settle_attempts: round.settle_attempts + 1,\n   461ŌåÆ  });\n   462ŌåÆ\n   463ŌåÆ  // Persist entries in dedicated JSONB column for direct access\n   464ŌåÆ  await db.updateRoundEntries(pda, serializedEntries);\n   465ŌåÆ\n   466ŌåÆ  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   467ŌåÆ    txSignature,\n   468ŌåÆ    winner: winner.toBase58(),\n   469ŌåÆ    winningEntryIndex: winnerEntryIndex,\n   470ŌåÆ    game: \"lord\",\n   471ŌåÆ    entropy: entropy.toString(\"hex\"),\n   472ŌåÆ    winningOffset: winningOffset.toString(),\n   473ŌåÆ    totalAmountLamports: Number(roundData.totalAmountLamports),\n   474ŌåÆ    payoutAmount,\n   475ŌåÆ    feeAmount,\n   476ŌåÆ    rentRefund,\n   477ŌåÆ    entries: serializedEntries,\n   478ŌåÆ  });\n   479ŌåÆ\n   480ŌåÆ  // Write payout transaction for the winner\n   481ŌåÆ  await db.insertTransaction({\n   482ŌåÆ    wallet: winner.toBase58(),\n   483ŌåÆ    game: \"lord\",\n   484ŌåÆ    matchId: round.match_id,\n   485ŌåÆ    txType: \"payout\",\n   486ŌåÆ    amountLamports: payoutAmount,\n   487ŌåÆ    txSig: txSignature,\n   488ŌåÆ  });\n   489ŌåÆ\n   490ŌåÆ  const tDone = performance.now();\n   491ŌåÆ  logger.info(\"lord settlement transaction confirmed\", {\n   492ŌåÆ    pda,\n   493ŌåÆ    txSignature,\n   494ŌåÆ    winner: winner.toBase58(),\n   495ŌåÆ    winningEntryIndex: winnerEntryIndex,\n   496ŌåÆ    timing: {\n   497ŌåÆ      dbMs: Math.round(tDb - t0),\n   498ŌåÆ      fetchMs: Math.round(tFetch - tDb),\n   499ŌåÆ      buildMs: Math.round(tBuild - tFetch),\n   500ŌåÆ      sendMs: Math.round(tSend - tBuild),\n   501ŌåÆ      confirmMs: Math.round(tConfirm - tSend),\n   502ŌåÆ      dbWriteMs: Math.round(tDone - tConfirm),\n   503ŌåÆ      totalMs: Math.round(tDone - t0),\n   504ŌåÆ    },\n   505ŌåÆ  });\n   506ŌåÆ\n   507ŌåÆ  return {\n   508ŌåÆ    txSignature,\n   509ŌåÆ    resultHash,\n   510ŌåÆ    winningEntryIndex: winnerEntryIndex,\n   511ŌåÆ    winner: winner.toBase58(),\n   512ŌåÆ  };\n   513ŌåÆ}\n   514ŌåÆ\n   515ŌåÆexport async function settleRound(\n   516ŌåÆ  deps: SettleTxDeps,\n   517ŌåÆ  pda: string,\n   518ŌåÆ): Promise<SettleResult> {\n   519ŌåÆ  const round = await deps.db.getRoundByPda(pda);\n   520ŌåÆ  if (!round) {\n   521ŌåÆ    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   522ŌåÆ  }\n   523ŌåÆ\n   524ŌåÆ  if (round.game === \"lord\") {\n   525ŌåÆ    return settleLordRound(deps, pda);\n   526ŌåÆ  }\n   527ŌåÆ\n   528ŌåÆ  return settleMatch(deps, pda);\n   529ŌåÆ}\n   530ŌåÆ\n   531ŌåÆ// ---------------------------------------------------------------------------\n   532ŌåÆ// Close Call ŌĆö transaction builders\n   533ŌåÆ// ---------------------------------------------------------------------------\n   534ŌåÆ\n   535ŌåÆfunction deriveCloseCallConfigPda(): [PublicKey, number] {\n   536ŌåÆ  return PublicKey.findProgramAddressSync(\n   537ŌåÆ    [Buffer.from(\"closecall_config\")],\n   538ŌåÆ    CLOSECALL_PROGRAM_ID,\n   539ŌåÆ  );\n   540ŌåÆ}\n   541ŌåÆ\n   542ŌåÆ\n   543ŌåÆfunction minuteTsToBuffer(ts: bigint): Buffer {\n   544ŌåÆ  const buf = Buffer.alloc(8);\n   545ŌåÆ  buf.writeBigInt64LE(ts);\n   546ŌåÆ  return buf;\n   547ŌåÆ}\n   548ŌåÆ\n   549ŌåÆfunction deriveCloseCallRoundPda(minuteTs: bigint): [PublicKey, number] {\n   550ŌåÆ  return PublicKey.findProgramAddressSync(\n   551ŌåÆ    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n   552ŌåÆ    CLOSECALL_PROGRAM_ID,\n   553ŌåÆ  );\n   554ŌåÆ}\n   555ŌåÆ\n   556ŌåÆ/** Encode closecall instruction data: discriminator(8) + minute_ts(i64 LE, 8) = 16 bytes */\n   557ŌåÆfunction encodeCcMinuteTsData(discriminator: Buffer, minuteTs: bigint): Buffer {\n   558ŌåÆ  const buf = Buffer.alloc(16);\n   559ŌåÆ  discriminator.copy(buf, 0);\n   560ŌåÆ  buf.writeBigInt64LE(minuteTs, 8);\n   561ŌåÆ  return buf;\n   562ŌåÆ}\n   563ŌåÆ\n   564ŌåÆ/** Encode closecall settle_round data: disc(8) + minute_ts(i64 LE, 8) + close_price(i64 LE, 8) + close_price_expo(i32 LE, 4) = 28 bytes */\n   565ŌåÆfunction encodeCcSettleData(discriminator: Buffer, minuteTs: bigint, price: bigint, expo: number): Buffer {\n   566ŌåÆ  const buf = Buffer.alloc(28);\n   567ŌåÆ  discriminator.copy(buf, 0);\n   568ŌåÆ  buf.writeBigInt64LE(minuteTs, 8);\n   569ŌåÆ  buf.writeBigInt64LE(price, 16);\n   570ŌåÆ  buf.writeInt32LE(expo, 24);\n   571ŌåÆ  return buf;\n   572ŌåÆ}\n   573ŌåÆ\n   574ŌåÆ/**\n   575ŌåÆ * Encode closecall bet data:\n   576ŌåÆ * disc(8) + minute_ts(i64 LE, 8) + side(1) + amount(u64 LE, 8) + open_price(i64 LE, 8) + open_price_expo(i32 LE, 4) = 37 bytes\n   577ŌåÆ */\n   578ŌåÆfunction encodeCcBetData(\n   579ŌåÆ  discriminator: Buffer,\n   580ŌåÆ  minuteTs: bigint,\n   581ŌåÆ  side: number,\n   582ŌåÆ  amount: bigint,\n   583ŌåÆ  openPrice: bigint,\n   584ŌåÆ  openPriceExpo: number,\n   585ŌåÆ): Buffer {\n   586ŌåÆ  const buf = Buffer.alloc(37);\n   587ŌåÆ  discriminator.copy(buf, 0);\n   588ŌåÆ  buf.writeBigInt64LE(minuteTs, 8);\n   589ŌåÆ  buf.writeUInt8(side, 16);\n   590ŌåÆ  buf.writeBigUInt64LE(amount, 17);\n   591ŌåÆ  buf.writeBigInt64LE(openPrice, 25);\n   592ŌåÆ  buf.writeInt32LE(openPriceExpo, 33);\n   593ŌåÆ  return buf;\n   594ŌåÆ}\n   595ŌåÆ\n   596ŌåÆexport interface CloseCallTxDeps {\n   597ŌåÆ  connection: Connection;\n   598ŌåÆ  serverKeypair: Keypair;\n   599ŌåÆ}\n   600ŌåÆ\n   601ŌåÆ/**\n   602ŌåÆ * Build a `bet` instruction (no transaction wrapping).\n   603ŌåÆ *\n   604ŌåÆ * Two signers: player (pays bet) + server (pays rent on first call).\n   605ŌåÆ * Price + bet info passed as instruction args.\n   606ŌåÆ * Uses init_if_needed ŌĆö works for both round creation and joining.\n   607ŌåÆ */\n   608ŌåÆexport function buildCloseCallBetIx(\n   609ŌåÆ  serverPubkey: PublicKey,\n   610ŌåÆ  playerPubkey: PublicKey,\n   611ŌåÆ  minuteTs: bigint,\n   612ŌåÆ  side: number,\n   613ŌåÆ  amountLamports: bigint,\n   614ŌåÆ  openPrice: bigint,\n   615ŌåÆ  openPriceExpo: number,\n   616ŌåÆ): TransactionInstruction {\n   617ŌåÆ  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   618ŌåÆ  const [configPda] = deriveCloseCallConfigPda();\n   619ŌåÆ  const data = encodeCcBetData(\n   620ŌåÆ    CC_BET_DISCRIMINATOR,\n   621ŌåÆ    minuteTs,\n   622ŌåÆ    side,\n   623ŌåÆ    amountLamports,\n   624ŌåÆ    openPrice,\n   625ŌåÆ    openPriceExpo,\n   626ŌåÆ  );\n   627ŌåÆ\n   628ŌåÆ  return new TransactionInstruction({\n   629ŌåÆ    keys: [\n   630ŌåÆ      { pubkey: playerPubkey, isSigner: true, isWritable: true },  // player (pays bet)\n   631ŌåÆ      { pubkey: serverPubkey, isSigner: true, isWritable: true },  // server (pays rent on first call)\n   632ŌåÆ      { pubkey: configPda, isSigner: false, isWritable: false },   // config\n   633ŌåÆ      { pubkey: roundPda, isSigner: false, isWritable: true },     // round\n   634ŌåÆ      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   635ŌåÆ    ],\n   636ŌåÆ    programId: CLOSECALL_PROGRAM_ID,\n   637ŌåÆ    data,\n   638ŌåÆ  });\n   639ŌåÆ}\n   640ŌåÆ\n   641ŌåÆ/**\n   642ŌåÆ * Build a `settle_round` instruction (no transaction wrapping).\n   643ŌåÆ * Price is passed as instruction args (no on-chain Pyth account).\n   644ŌåÆ */\n   645ŌåÆexport function buildCloseCallSettleRoundIx(\n   646ŌåÆ  serverPubkey: PublicKey,\n   647ŌåÆ  minuteTs: bigint,\n   648ŌåÆ  closePrice: bigint,\n   649ŌåÆ  closePriceExpo: number,\n   650ŌåÆ  treasury: PublicKey,\n   651ŌåÆ  winnerAccounts: PublicKey[],\n   652ŌåÆ): TransactionInstruction {\n   653ŌåÆ  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   654ŌåÆ  const [platformConfigPda] = derivePlatformConfigPda();\n   655ŌåÆ  const data = encodeCcSettleData(CC_SETTLE_ROUND_DISCRIMINATOR, minuteTs, closePrice, closePriceExpo);\n   656ŌåÆ\n   657ŌåÆ  return new TransactionInstruction({\n   658ŌåÆ    keys: [\n   659ŌåÆ      { pubkey: serverPubkey, isSigner: true, isWritable: true },\n   660ŌåÆ      { pubkey: roundPda, isSigner: false, isWritable: true },\n   661ŌåÆ      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n   662ŌåÆ      { pubkey: treasury, isSigner: false, isWritable: true },\n   663ŌåÆ      { pubkey: serverPubkey, isSigner: false, isWritable: true },\n   664ŌåÆ      ...winnerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n   665ŌåÆ    ],\n   666ŌåÆ    programId: CLOSECALL_PROGRAM_ID,\n   667ŌåÆ    data,\n   668ŌåÆ  });\n   669ŌåÆ}\n   670ŌåÆ\n   671ŌåÆ/**\n   672ŌåÆ * Build a partially-signed `bet` transaction for the Close Call program.\n   673ŌåÆ *\n   674ŌåÆ * Two signers: player (pays bet) + server (pays rent on first call via init_if_needed).\n   675ŌåÆ * Server signs immediately; the frontend must add the player signature before submitting.\n   676ŌåÆ * Works for both round creation (first bet) and joining (subsequent bets).\n   677ŌåÆ */\n   678ŌåÆexport async function buildCloseCallBetTx(\n   679ŌåÆ  deps: CloseCallTxDeps,\n   680ŌåÆ  playerPubkey: PublicKey,\n   681ŌåÆ  minuteTs: bigint,\n   682ŌåÆ  side: number,\n   683ŌåÆ  amountLamports: bigint,\n   684ŌåÆ  openPrice: bigint,\n   685ŌåÆ  openPriceExpo: number,\n   686ŌåÆ): Promise<{ tx: Transaction; roundPda: PublicKey }> {\n   687ŌåÆ  const { connection, serverKeypair } = deps;\n   688ŌåÆ\n   689ŌåÆ  const instruction = buildCloseCallBetIx(\n   690ŌåÆ    serverKeypair.publicKey,\n   691ŌåÆ    playerPubkey,\n   692ŌåÆ    minuteTs,\n   693ŌåÆ    side,\n   694ŌåÆ    amountLamports,\n   695ŌåÆ    openPrice,\n   696ŌåÆ    openPriceExpo,\n   697ŌåÆ  );\n   698ŌåÆ\n   699ŌåÆ  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   700ŌåÆ\n   701ŌåÆ  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   702ŌåÆ  const tx = new Transaction({ feePayer: playerPubkey, blockhash, lastValidBlockHeight });\n   703ŌåÆ  tx.add(instruction);\n   704ŌåÆ  tx.partialSign(serverKeypair);\n   705ŌåÆ\n   706ŌåÆ  return { tx, roundPda };\n   707ŌåÆ}\n   708ŌåÆ\n   709ŌåÆ/**\n   710ŌåÆ * Build a signed `settle_round` transaction for the Close Call program.\n   711ŌåÆ *\n   712ŌåÆ * Price is passed as instruction args. Winners (or all players for refund)\n   713ŌåÆ * are passed as remaining accounts for auto-payout.\n   714ŌåÆ */\n   715ŌåÆexport async function buildCloseCallSettleRoundTx(\n   716ŌåÆ  deps: CloseCallTxDeps,\n   717ŌåÆ  minuteTs: bigint,\n   718ŌåÆ  closePrice: bigint,\n   719ŌåÆ  closePriceExpo: number,\n   720ŌåÆ  treasury: PublicKey,\n   721ŌåÆ  winnerAccounts: PublicKey[],\n   722ŌåÆ): Promise<Transaction> {\n   723ŌåÆ  const { connection, serverKeypair } = deps;\n   724ŌåÆ\n   725ŌåÆ  const instruction = buildCloseCallSettleRoundIx(\n   726ŌåÆ    serverKeypair.publicKey,\n   727ŌåÆ    minuteTs,\n   728ŌåÆ    closePrice,\n   729ŌåÆ    closePriceExpo,\n   730ŌåÆ    treasury,\n   731ŌåÆ    winnerAccounts,\n   732ŌåÆ  );\n   733ŌåÆ\n   734ŌåÆ  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   735ŌåÆ  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n   736ŌåÆ  tx.add(instruction);\n   737ŌåÆ  tx.sign(serverKeypair);\n   738ŌåÆ\n   739ŌåÆ  return tx;\n   740ŌåÆ}\n   741ŌåÆ\n   742ŌåÆ/**\n   743ŌåÆ * Build a signed `timeout_refund` transaction for the Close Call program.\n   744ŌåÆ *\n   745ŌåÆ * Permissionless after the resolve deadline. Refunds all players their exact\n   746ŌåÆ * deposit via remaining accounts.\n   747ŌåÆ */\n   748ŌåÆexport async function buildCloseCallTimeoutRefundTx(\n   749ŌåÆ  deps: CloseCallTxDeps,\n   750ŌåÆ  minuteTs: bigint,\n   751ŌåÆ  playerAccounts: PublicKey[],\n   752ŌåÆ): Promise<Transaction> {\n   753ŌåÆ  const { connection, serverKeypair } = deps;\n   754ŌåÆ\n   755ŌåÆ  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   756ŌåÆ  const [configPda] = deriveCloseCallConfigPda();\n   757ŌåÆ  const data = encodeCcMinuteTsData(CC_TIMEOUT_REFUND_DISCRIMINATOR, minuteTs);\n   758ŌåÆ\n   759ŌåÆ  const keys = [\n   760ŌåÆ    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller\n   761ŌåÆ    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round\n   762ŌåÆ    { pubkey: configPda, isSigner: false, isWritable: false },               // closecall_config\n   763ŌåÆ    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)\n   764ŌåÆ    ...playerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n   765ŌåÆ  ];\n   766ŌåÆ\n   767ŌåÆ  const instruction = new TransactionInstruction({\n   768ŌåÆ    keys,\n   769ŌåÆ    programId: CLOSECALL_PROGRAM_ID,\n   770ŌåÆ    data,\n   771ŌåÆ  });\n   772ŌåÆ\n   773ŌåÆ  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   774ŌåÆ  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n   775ŌåÆ  tx.add(instruction);\n   776ŌåÆ  tx.sign(serverKeypair);\n   777ŌåÆ\n   778ŌåÆ  return tx;\n   779ŌåÆ}\n   780ŌåÆ\n   781ŌåÆ// ---------------------------------------------------------------------------\n   782ŌåÆ// Error types\n   783ŌåÆ// ---------------------------------------------------------------------------\n   784ŌåÆ\n   785ŌåÆ/** Permanent failure ŌĆö should not be retried. */\n   786ŌåÆexport class PermanentSettleError extends Error {\n   787ŌåÆ  readonly permanent = true;\n   788ŌåÆ  constructor(message: string) {\n   789ŌåÆ    super(message);\n   790ŌåÆ    this.name = \"PermanentSettleError\";\n   791ŌåÆ  }\n   792ŌåÆ}\n   793ŌåÆ\n   794ŌåÆ/** Transient failure ŌĆö safe to retry. */\n   795ŌåÆexport class TransientSettleError extends Error {\n   796ŌåÆ  readonly permanent = false;\n   797ŌåÆ  constructor(message: string) {\n   798ŌåÆ    super(message);\n   799ŌåÆ    this.name = \"TransientSettleError\";\n   800ŌåÆ  }\n   801ŌåÆ}\n   802ŌåÆ"}]},"parent_tool_use_id":"toolu_01GsAXUbdQhh9DYX1RdbJUxG","session_id":"e3b67986-fd78-4b1a-b5f8-3ba5e0f9fe3d","uuid":"ff3da2e6-c44f-4e29-9971-6edbf11fb5a5","timestamp":"2026-03-25T12:19:26.820Z"}
