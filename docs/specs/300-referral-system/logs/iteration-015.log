{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016cgkv98VWZ9Mh59JfaU6Hh","type":"tool_result","content":"     1ŌåÆ/**\n     2ŌåÆ * Settle transaction builder + submission.\n     3ŌåÆ *\n     4ŌåÆ * Retrieves the stored secret, reads on-chain match + config data to resolve\n     5ŌåÆ * all accounts, builds the `settle` instruction, submits it, and updates the\n     6ŌåÆ * DB on confirmation.\n     7ŌåÆ */\n     8ŌåÆ\n     9ŌåÆimport { createHash } from \"node:crypto\";\n    10ŌåÆimport { performance } from \"node:perf_hooks\";\n    11ŌåÆimport {\n    12ŌåÆ  Connection,\n    13ŌåÆ  Keypair,\n    14ŌåÆ  PublicKey,\n    15ŌåÆ  SystemProgram,\n    16ŌåÆ  Transaction,\n    17ŌåÆ  TransactionInstruction,\n    18ŌåÆ} from \"@solana/web3.js\";\n    19ŌåÆimport type { Db } from \"../db.js\";\n    20ŌåÆimport { logger } from \"../logger.js\";\n    21ŌåÆimport { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n    22ŌåÆimport { derivePlatformConfigPda, getPlatformConfig } from \"../platform-config.js\";\n    23ŌåÆimport { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@rng-utopia/anchor-client\";\n    24ŌåÆimport {\n    25ŌåÆ  decodeCoinflipMatch,\n    26ŌåÆ  decodeLordRound,\n    27ŌåÆ  type DecodedJackpotRound,\n    28ŌåÆ} from \"./account-decoder.js\";\n    29ŌåÆ\n    30ŌåÆ// ---------------------------------------------------------------------------\n    31ŌåÆ// Instruction discriminators (from IDL ŌĆö no hardcoded byte arrays)\n    32ŌåÆ// ---------------------------------------------------------------------------\n    33ŌåÆ\n    34ŌåÆfunction getInstructionDiscriminator(\n    35ŌåÆ  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n    36ŌåÆ  instructionName: string,\n    37ŌåÆ): Buffer {\n    38ŌåÆ  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n    39ŌåÆ  if (!instruction) {\n    40ŌåÆ    throw new Error(`Instruction ${instructionName} not found in IDL`);\n    41ŌåÆ  }\n    42ŌåÆ  return Buffer.from(instruction.discriminator);\n    43ŌåÆ}\n    44ŌåÆ\n    45ŌåÆconst SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\n    46ŌåÆconst CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n    47ŌåÆ  lordIdl,\n    48ŌåÆ  \"claim_payout\",\n    49ŌåÆ);\n    50ŌåÆconst CC_BET_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"bet\");\n    51ŌåÆconst CC_SETTLE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"settle_round\");\n    52ŌåÆconst CC_TIMEOUT_REFUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"timeout_refund\");\n    53ŌåÆ\n    54ŌåÆ// ---------------------------------------------------------------------------\n    55ŌåÆ// Types\n    56ŌåÆ// ---------------------------------------------------------------------------\n    57ŌåÆ\n    58ŌåÆexport interface SettleTxDeps {\n    59ŌåÆ  db: Db;\n    60ŌåÆ  connection: Connection;\n    61ŌåÆ  serverKeypair: Keypair;\n    62ŌåÆ  entropyAccount: PublicKey;\n    63ŌåÆ}\n    64ŌåÆ\n    65ŌåÆexport interface SettleResult {\n    66ŌåÆ  txSignature: string;\n    67ŌåÆ  resultHash: Buffer;\n    68ŌåÆ  resultSide?: number;\n    69ŌåÆ  winningEntryIndex?: number;\n    70ŌåÆ  winner: string;\n    71ŌåÆ}\n    72ŌåÆ\n    73ŌåÆ// ---------------------------------------------------------------------------\n    74ŌåÆ// Instruction encoding\n    75ŌåÆ// ---------------------------------------------------------------------------\n    76ŌåÆ\n    77ŌåÆ/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\n    78ŌåÆfunction encodeSettleData(secret: Buffer): Buffer {\n    79ŌåÆ  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n    80ŌåÆ}\n    81ŌåÆ\n    82ŌåÆfunction encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n    83ŌåÆ  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n    84ŌåÆ}\n    85ŌåÆ\n    86ŌåÆ// ---------------------------------------------------------------------------\n    87ŌåÆ// Result derivation (mirrors on-chain derive_result)\n    88ŌåÆ// ---------------------------------------------------------------------------\n    89ŌåÆ\n    90ŌåÆ/**\n    91ŌåÆ * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n    92ŌåÆ * Must match shared/src/fairness.rs `derive_result()`.\n    93ŌåÆ */\n    94ŌåÆfunction deriveResult(\n    95ŌåÆ  secret: Buffer,\n    96ŌåÆ  entropy: Buffer,\n    97ŌåÆ  matchPdaBytes: Buffer,\n    98ŌåÆ  algoVer: number,\n    99ŌåÆ): Buffer {\n   100ŌåÆ  return createHash(\"sha256\")"}]},"parent_tool_use_id":null,"session_id":"e3b67986-fd78-4b1a-b5f8-3ba5e0f9fe3d","uuid":"21735f85-0d6b-46c5-8bdf-99d4688a6256","timestamp":"2026-03-25T12:21:20.889Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/worker/settle-tx.ts","content":"/**\n * Settle transaction builder + submission.\n *\n * Retrieves the stored secret, reads on-chain match + config data to resolve\n * all accounts, builds the `settle` instruction, submits it, and updates the\n * DB on confirmation.\n */\n\nimport { createHash } from \"node:crypto\";\nimport { performance } from \"node:perf_hooks\";\nimport {\n  Connection,\n  Keypair,\n  PublicKey,\n  SystemProgram,\n  Transaction,\n  TransactionInstruction,\n} from \"@solana/web3.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\nimport { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\nimport { derivePlatformConfigPda, getPlatformConfig } from \"../platform-config.js\";\nimport { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@rng-utopia/anchor-client\";\nimport {\n  decodeCoinflipMatch,\n  decodeLordRound,\n  type DecodedJackpotRound,\n} from \"./account-decoder.js\";\n\n// ---------------------------------------------------------------------------\n// Instruction discriminators (from IDL ŌĆö no hardcoded byte arrays)\n// ---------------------------------------------------------------------------\n\nfunction getInstructionDiscriminator(\n  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n  instructionName: string,\n): Buffer {\n  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n  if (!instruction) {\n    throw new Error(`Instruction ${instructionName} not found in IDL`);\n  }\n  return Buffer.from(instruction.discriminator);\n}\n\nconst SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\nconst CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n  lordIdl,\n  \"claim_payout\",\n);\nconst CC_BET_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"bet\");\nconst CC_SETTLE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"settle_round\");\nconst CC_TIMEOUT_REFUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"timeout_refund\");\n\n// ---------------------------------------------------------------------------\n// Types\n// ---------------------------------------------------------------------------\n\nexport interface SettleTxDeps {\n  db: Db;\n  connection: Connection;\n  serverKeypair: Keypair;\n  entropyAccount: PublicKey;\n}\n\nexport interface SettleResult {\n  txSignature: string;\n  resultHash: Buffer;\n  resultSide?: number;\n  winningEntryIndex?: number;\n  winner: string;\n}\n\n// ---------------------------------------------------------------------------\n// Instruction encoding\n// ---------------------------------------------------------------------------\n\n/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\nfunction encodeSettleData(secret: Buffer): Buffer {\n  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n}\n\nfunction encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n}\n\n// ---------------------------------------------------------------------------\n// Result derivation (mirrors on-chain derive_result)\n// ---------------------------------------------------------------------------\n\n/**\n * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n * Must match shared/src/fairness.rs `derive_result()`.\n */\nfunction deriveResult(\n  secret: Buffer,\n  entropy: Buffer,\n  matchPdaBytes: Buffer,\n  algoVer: number,\n): Buffer {\n  return createHash(\"sha256\")","numLines":100,"startLine":1,"totalLines":802}}}
