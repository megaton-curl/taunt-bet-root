{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0157hHiaJeca74444CVqVNw8","type":"tool_result","content":"     1ŌåÆ/**\n     2ŌåÆ * Settlement retry logic ŌĆö wraps settlement with exponential backoff\n     3ŌåÆ * for transient failures and proper handling of permanent failures.\n     4ŌåÆ *\n     5ŌåÆ * Called by the settlement worker's onSettleReady callback on each poll\n     6ŌåÆ * cycle for every locked match whose target_slot has been reached.\n     7ŌåÆ */\n     8ŌåÆ\n     9ŌåÆimport { Connection, PublicKey } from \"@solana/web3.js\";\n    10ŌåÆimport type { Db } from \"../db.js\";\n    11ŌåÆimport type { SettleResult } from \"./settle-tx.js\";\n    12ŌåÆimport { PermanentSettleError } from \"./settle-tx.js\";\n    13ŌåÆimport { logger } from \"../logger.js\";\n    14ŌåÆimport { decodeCoinflipMatch, decodeLordRound } from \"./account-decoder.js\";\n    15ŌåÆ\n    16ŌåÆ// ---------------------------------------------------------------------------\n    17ŌåÆ// Constants\n    18ŌåÆ// ---------------------------------------------------------------------------\n    19ŌåÆ\n    20ŌåÆconst MAX_RETRIES = 5;\n    21ŌåÆconst BASE_DELAY_MS = 2_000;\n    22ŌåÆconst MAX_DELAY_MS = 30_000;\n    23ŌåÆ\n    24ŌåÆ// ---------------------------------------------------------------------------\n    25ŌåÆ// Types\n    26ŌåÆ// ---------------------------------------------------------------------------\n    27ŌåÆ\n    28ŌåÆexport interface RetrySettlerDeps {\n    29ŌåÆ  db: Db;\n    30ŌåÆ  connection: Connection;\n    31ŌåÆ  settleRound: (pda: string) => Promise<SettleResult>;\n    32ŌåÆ}\n    33ŌåÆ\n    34ŌåÆinterface RetryState {\n    35ŌåÆ  attempts: number;\n    36ŌåÆ  /** Timestamp (ms) at which next retry is allowed. */\n    37ŌåÆ  nextRetryAt: number;\n    38ŌåÆ}\n    39ŌåÆ\n    40ŌåÆexport interface RetrySettler {\n    41ŌåÆ  /**\n    42ŌåÆ   * Attempt settlement for a PDA. Handles retry scheduling, permanent\n    43ŌåÆ   * failure tracking, and resolve_deadline timeout detection.\n    44ŌåÆ   *\n    45ŌåÆ   * Safe to call repeatedly ŌĆö skips if a retry is scheduled but not yet due,\n    46ŌåÆ   * or if the PDA has already been marked as permanently failed / timed out.\n    47ŌåÆ   */\n    48ŌåÆ  attemptSettle(pda: string): Promise<void>;\n    49ŌåÆ  /** Returns true if this PDA is done (settled, failed, or timed out). */\n    50ŌåÆ  isFinalized(pda: string): boolean;\n    51ŌåÆ}\n    52ŌåÆ\n    53ŌåÆ// ---------------------------------------------------------------------------\n    54ŌåÆ// Factory\n    55ŌåÆ// ---------------------------------------------------------------------------\n    56ŌåÆ\n    57ŌåÆexport function createRetrySettler(deps: RetrySettlerDeps): RetrySettler {\n    58ŌåÆ  const { db, connection, settleRound } = deps;\n    59ŌåÆ\n    60ŌåÆ  /** Per-PDA retry tracking (in-memory, resets on service restart). */\n    61ŌåÆ  const retryStates = new Map<string, RetryState>();\n    62ŌåÆ\n    63ŌåÆ  /** PDAs that hit a permanent (non-retryable) error. */\n    64ŌåÆ  const failedPdas = new Set<string>();\n    65ŌåÆ\n    66ŌåÆ  /** PDAs whose resolve_deadline has passed. */\n    67ŌåÆ  const timeoutPdas = new Set<string>();\n    68ŌåÆ\n    69ŌåÆ  /** PDAs that settled successfully. */\n    70ŌåÆ  const settledPdas = new Set<string>();\n    71ŌåÆ\n    72ŌåÆ  /** Compute exponential backoff delay: base * 2^attempt, capped at max. */\n    73ŌåÆ  function getDelay(attempt: number): number {\n    74ŌåÆ    return Math.min(BASE_DELAY_MS * Math.pow(2, attempt), MAX_DELAY_MS);\n    75ŌåÆ  }\n    76ŌåÆ\n    77ŌåÆ  /**\n    78ŌåÆ   * Check whether the on-chain resolve_deadline has passed for a round.\n    79ŌåÆ   * Returns true if the deadline is in the past (timeout refund eligible).\n    80ŌåÆ   */\n    81ŌåÆ  async function isResolveDeadlinePassed(pda: string): Promise<boolean> {\n    82ŌåÆ    try {\n    83ŌåÆ      const round = await db.getRoundByPda(pda);\n    84ŌåÆ      if (!round) return true;\n    85ŌåÆ      const accountInfo = await connection.getAccountInfo(new PublicKey(pda));\n    86ŌåÆ      if (!accountInfo) return true; // account gone ŌĆö treat as expired\n    87ŌåÆ      const data = Buffer.from(accountInfo.data);\n    88ŌåÆ      let resolveDeadline = 0;\n    89ŌåÆ      if (round.game === \"lord\") {\n    90ŌåÆ        const decoded = decodeLordRound(data);\n    91ŌåÆ        resolveDeadline = Number(decoded.resolveDeadline);\n    92ŌåÆ      } else {\n    93ŌåÆ        const decoded = decodeCoinflipMatch(data);\n    94ŌåÆ        resolveDeadline = Number(decoded.resolveDeadline);\n    95ŌåÆ      }\n    96ŌåÆ      if (resolveDeadline <= 0) return false; // not set yet\n    97ŌåÆ      const nowUnix = Math.floor(Date.now() / 1000);\n    98ŌåÆ      return nowUnix >= resolveDeadline;\n    99ŌåÆ    } catch {\n   100ŌåÆ      return false; // can't read ŌĆö don't assume timeout\n   101ŌåÆ    }\n   102ŌåÆ  }\n   103ŌåÆ\n   104ŌåÆ  async function attemptSettle(pda: string): Promise<void> {\n   105ŌåÆ    // Skip finalized PDAs (settled, failed, or timed out)\n   106ŌåÆ    if (settledPdas.has(pda) || failedPdas.has(pda) || timeoutPdas.has(pda)) return;\n   107ŌåÆ\n   108ŌåÆ    const state = retryStates.get(pda);\n   109ŌåÆ\n   110ŌåÆ    // If a retry is scheduled but not yet due, skip\n   111ŌåÆ    if (state && Date.now() < state.nextRetryAt) return;\n   112ŌåÆ\n   113ŌåÆ    // If max retries exceeded, mark as failed\n   114ŌåÆ    if (state && state.attempts >= MAX_RETRIES) {\n   115ŌåÆ      failedPdas.add(pda);\n   116ŌåÆ      retryStates.delete(pda);\n   117ŌåÆ      await db.insertOperatorEvent(pda, \"settle_failed\", {\n   118ŌåÆ        reason: \"max retries exceeded\",\n   119ŌåÆ        attempts: state.attempts,\n   120ŌåÆ      });\n   121ŌåÆ      logger.error(\"settle failed ŌĆö max retries exceeded\", {\n   122ŌåÆ        pda,\n   123ŌåÆ        attempts: state.attempts,\n   124ŌåÆ      });\n   125ŌåÆ      return;\n   126ŌåÆ    }\n   127ŌåÆ\n   128ŌåÆ    // Check resolve_deadline before attempting\n   129ŌåÆ    if (await isResolveDeadlinePassed(pda)) {\n   130ŌåÆ      timeoutPdas.add(pda);\n   131ŌåÆ      retryStates.delete(pda);\n   132ŌåÆ      await db.insertOperatorEvent(pda, \"timeout_detected\", {\n   133ŌåÆ        reason: \"resolve_deadline passed without successful settlement\",\n   134ŌåÆ        attempts: state?.attempts ?? 0,\n   135ŌåÆ      });\n   136ŌåÆ      logger.warn(\"resolve deadline passed, stopping settlement attempts\", {\n   137ŌåÆ        pda,\n   138ŌåÆ      });\n   139ŌåÆ      return;\n   140ŌåÆ    }\n   141ŌåÆ\n   142ŌåÆ    try {\n   143ŌåÆ      const result = await settleRound(pda);\n   144ŌåÆ\n   145ŌåÆ      // Success ŌĆö mark finalized, clear retry state\n   146ŌåÆ      settledPdas.add(pda);\n   147ŌåÆ      retryStates.delete(pda);\n   148ŌåÆ      logger.info(\"round settled\", {\n   149ŌåÆ        pda,\n   150ŌåÆ        tx: result.txSignature,\n   151ŌåÆ        resultSide: result.resultSide,\n   152ŌåÆ        winningEntryIndex: result.winningEntryIndex,\n   153ŌåÆ        winner: result.winner,\n   154ŌåÆ      });\n   155ŌåÆ    } catch (err) {\n   156ŌåÆ      if (err instanceof PermanentSettleError) {\n   157ŌåÆ        // Permanent failure ŌĆö do not retry\n   158ŌåÆ        failedPdas.add(pda);\n   159ŌåÆ        retryStates.delete(pda);\n   160ŌåÆ        await db.insertOperatorEvent(pda, \"settle_failed\", {\n   161ŌåÆ          reason: err.message,\n   162ŌåÆ          permanent: true,\n   163ŌåÆ        });\n   164ŌåÆ        logger.error(\"settle permanently failed\", {\n   165ŌåÆ          pda,\n   166ŌåÆ          error: err.message,\n   167ŌåÆ        });\n   168ŌåÆ      } else {\n   169ŌåÆ        // Transient failure ŌĆö schedule retry with exponential backoff\n   170ŌåÆ        const attempts = (state?.attempts ?? 0) + 1;\n   171ŌåÆ        const delay = getDelay(attempts - 1);\n   172ŌåÆ\n   173ŌåÆ        retryStates.set(pda, {\n   174ŌåÆ          attempts,\n   175ŌåÆ          nextRetryAt: Date.now() + delay,\n   176ŌåÆ        });\n   177ŌåÆ\n   178ŌåÆ        await db.insertOperatorEvent(pda, \"settle_retried\", {\n   179ŌåÆ          attempt: attempts,\n   180ŌåÆ          nextRetryInMs: delay,\n   181ŌåÆ          error: err instanceof Error ? err.message : String(err),\n   182ŌåÆ        });\n   183ŌåÆ        logger.warn(\"settle transient failure, scheduling retry\", {\n   184ŌåÆ          pda,\n   185ŌåÆ          attempt: attempts,\n   186ŌåÆ          nextRetryInMs: delay,\n   187ŌåÆ          error: err instanceof Error ? err.message : String(err),\n   188ŌåÆ        });\n   189ŌåÆ      }\n   190ŌåÆ    }\n   191ŌåÆ  }\n   192ŌåÆ\n   193ŌåÆ  function isFinalized(pda: string): boolean {\n   194ŌåÆ    return settledPdas.has(pda) || failedPdas.has(pda) || timeoutPdas.has(pda);\n   195ŌåÆ  }\n   196ŌåÆ\n   197ŌåÆ  return { attemptSettle, isFinalized };\n   198ŌåÆ}\n   199ŌåÆ"}]},"parent_tool_use_id":"toolu_01GsAXUbdQhh9DYX1RdbJUxG","session_id":"e3b67986-fd78-4b1a-b5f8-3ba5e0f9fe3d","uuid":"72fc35a8-1899-4062-8a4c-25c15cf90048","timestamp":"2026-03-25T12:19:55.798Z"}
