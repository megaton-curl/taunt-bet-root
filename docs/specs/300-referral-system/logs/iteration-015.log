l(requireEnv(\"DATABASE_URL\"), dbSchema),\n    52ŌåÆ    dbSchema,\n    53ŌåÆ    rpcUrl: requireEnv(\"RPC_URL\"),\n    54ŌåÆ    wsRpcUrl: process.env.WS_RPC_URL || undefined,\n    55ŌåÆ    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    56ŌåÆ    jwtSecret: (() => {\n    57ŌåÆ      const explicit = process.env.JWT_SECRET;\n    58ŌåÆ      if (explicit) return new TextEncoder().encode(explicit);\n    59ŌåÆ      // Derive from first 32 bytes of server keypair secret key\n    60ŌåÆ      const kp = parseKeypair(requireEnv(\"SERVER_KEYPAIR\"));\n    61ŌåÆ      return kp.secretKey.slice(0, 32);\n    62ŌåÆ    })(),\n    63ŌåÆ    cluster: process.env.SOLANA_CLUSTER ?? \"devnet\",\n    64ŌåÆ    challengeTtlSeconds: parseInt(\n    65ŌåÆ      process.env.CHALLENGE_TTL_SECONDS ?? \"300\",\n    66ŌåÆ      10,\n    67ŌåÆ    ),\n    68ŌåÆ    accessTokenTtlSeconds: parseInt(\n    69ŌåÆ      process.env.ACCESS_TOKEN_TTL_SECONDS ?? \"86400\",\n    70ŌåÆ      10,\n    71ŌåÆ    ),\n    72ŌåÆ    refreshTokenTtlDays: parseInt(\n    73ŌåÆ      process.env.REFRESH_TOKEN_TTL_DAYS ?? \"14\",\n    74ŌåÆ      10,\n    75ŌåÆ    ),\n    76ŌåÆ    rateLimitPerWallet: parseInt(\n    77ŌåÆ      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n    78ŌåÆ      10,\n    79ŌåÆ    ),\n    80ŌåÆ    rateLimitGlobal: parseInt(\n    81ŌåÆ      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n    82ŌåÆ      10,\n    83ŌåÆ    ),\n    84ŌåÆ    workerPollIntervalMs: parseInt(\n    85ŌåÆ      process.env.WORKER_POLL_INTERVAL_MS ?? \"1000\",\n    86ŌåÆ      10,\n    87ŌåÆ    ),\n    88ŌåÆ    entropyAccount: process.env.ENTROPY_ACCOUNT ?? \"SysvarS1otHashes111111111111111111111111111\",\n    89ŌåÆ    pythBtcUsdAccount: process.env.PYTH_BTC_USD_ACCOUNT ?? \"4cSM2e6rvbGQUFiJbqytoVMi5GgghSMr8LwVrT9VPSPo\",\n    90ŌåÆ    minSolBalance: parseFloat(process.env.MIN_SOL_BALANCE ?? \"0.1\"),\n    91ŌåÆ    eventQueuePollMs: parseInt(\n    92ŌåÆ      process.env.EVENT_QUEUE_POLL_MS ?? \"1500\",\n    93ŌåÆ      10,\n    