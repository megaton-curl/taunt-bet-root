   844ŌåÆ          ${params.referrerEarnedLamports}, ${params.referrerRateBps},\n   845ŌåÆ          ${params.refereeRebateLamports}, ${params.refereeRebateRateBps}\n   846ŌåÆ        )\n   847ŌåÆ        RETURNING *\n   848ŌåÆ      `;\n   849ŌåÆ      return normalizeReferralEarning(rows[0]!);\n   850ŌåÆ    },\n   851ŌåÆ\n   852ŌåÆ    async getPendingBalance(wallet) {\n   853ŌåÆ      const rows = await sql<{ pending: string }[]>`\n   854ŌåÆ        SELECT COALESCE(\n   855ŌåÆ          (\n   856ŌåÆ            SELECT SUM(referrer_earned_lamports)\n   857ŌåÆ            FROM referral_earnings WHERE referrer_wallet = ${wallet}\n   858ŌåÆ          ), 0\n   859ŌåÆ        ) + COALESCE(\n   860ŌåÆ          (\n   861ŌåÆ            SELECT SUM(referee_rebate_lamports)\n   862ŌåÆ            FROM referral_earnings WHERE referee_wallet = ${wallet}\n   863ŌåÆ          ), 0\n   864ŌåÆ        ) - COALESCE(\n   865ŌåÆ          (\n   866ŌåÆ            SELECT SUM(amount_lamports)\n   867ŌåÆ            FROM referral_claims WHERE wallet = ${wallet} AND status IN ('pending', 'processing', 'completed')\n   868ŌåÆ          ), 0\n   869ŌåÆ        ) AS pending\n   870ŌåÆ      `;\n   871ŌåÆ      return rows[0]!.pending;\n   872ŌåÆ    },\n   873ŌåÆ\n   874ŌåÆ    async getReferralEarnings(wallet, page, limit) {\n   875ŌåÆ      const offset = (page - 1) * limit;\n   876ŌåÆ      const [countRows, rows] = await Promise.all([\n   877ŌåÆ        sql<{ count: string }[]>`\n   878ŌåÆ          SELECT COUNT(*)::TEXT AS count FROM referral_earnings\n   879ŌåÆ          WHERE referrer_wallet = ${wallet}\n   880ŌåÆ        `,\n   881ŌåÆ        sql<ReferralEarning[]>`\n   882ŌåÆ          SELECT * FROM referral_earnings\n   883ŌåÆ          WHERE referrer_wallet = ${wallet}\n   884ŌåÆ          ORDER BY created_at DESC\n   885ŌåÆ          LIMIT ${limit} OFFSET ${offset}\n   886ŌåÆ        `,\n   887ŌåÆ      ]);\n   888ŌåÆ      const total = Number(countRows[0]!.count);\n   889ŌåÆ      const totalPages = Math.max(1, Math.ceil(total / limit));\n   890ŌåÆ      return { items: rows.map(normalizeReferralEarning), totalPages };\n   891ŌåÆ    },\n   892ŌåÆ\n   893ŌåÆ    async getReferralStats(wallet) {\n   894ŌåÆ      const rows = await sql<ReferralStats[]>`\n   895ŌåÆ        SELECT\n   896ŌåÆ          (SELECT COUNT(*) FROM referral_links WHERE referrer_wallet = ${wallet})::INT\n   897ŌåÆ            AS referred_count,\n   898ŌåÆ          (\n   899ŌåÆ            SELECT COUNT(DISTINCT re.referee_wallet)\n   900ŌåÆ            FROM referral_earnings re\n   901ŌåÆ            JOIN referral_links rl ON rl.referee_wallet = re.referee_wallet AND rl.referrer_wallet = ${wallet}\n   902ŌåÆ            WHERE re.created_at > now() - INTERVAL '7 days'\n   903ŌåÆ          )::INT AS active_count,\n   904ŌåÆ          COALESCE(\n   905ŌåÆ            (\n   906ŌåÆ              SELECT SUM(re.wager_lamports)::TEXT\n   907ŌåÆ              FROM referral_earnings re\n   908ŌåÆ              JOIN referral_links rl ON rl.referee_wallet = re.referee_wallet AND rl.referrer_wallet = ${wallet}\n   909ŌåÆ            ), '0'\n   910ŌåÆ          ) AS total_volume_lamports,\n   911ŌåÆ          COALESCE(\n   912ŌåÆ            (SELECT SUM(referrer_earned_lamports)::TEXT FROM referral_earnings WHERE referrer_wallet = ${wallet}),\n   913ŌåÆ            '0'\n   914ŌåÆ          ) AS total_earned_lamports,\n   915ŌåÆ          (\n   916ŌåÆ            COALESCE((SELECT SUM(referrer_earned_lamports) FROM referral_earnings WHERE referrer_wallet = ${wallet}), 0)\n   917ŌåÆ            + COALESCE((SELECT SUM(referee_rebate_lamports) FROM referral_earnings WHERE referee_wallet = ${wallet}), 0)\n   918ŌåÆ            - COALESCE((SELECT SUM(amount_lamports) FROM referral_claims WHERE wallet = ${wallet} AND status IN ('pending','processing','completed')), 0)\n   919ŌåÆ          )::TEXT AS pending_lamports\n   920ŌåÆ      `;\n   921ŌåÆ      return rows[0]!;\n   922ŌåÆ    },\n   923ŌåÆ\n   924ŌåÆ    // -----------------------------------------------------------------------\n   925ŌåÆ    // Referral ŌĆö claims & rates\n   926ŌåÆ    // -----------------------------------------------------------------------\n   927ŌåÆ\n   928ŌåÆ    async insertReferralClaim(wallet, amountLamports) {\n   929ŌåÆ      const rows = await sql<ReferralClaim[]>`\n   930ŌåÆ        INSERT INTO referral_claims (wallet, amount_lamports, status)\n   931ŌåÆ        VALUES (${wallet}, ${amountLamports}, 'pending')\n   932ŌåÆ        RETURNING *\n   933ŌåÆ      `;\n   934ŌåÆ      return rows[0]!;\n   935ŌåÆ    },\n   936ŌåÆ\n   937ŌåÆ    async getReferralClaim(claimId) {\n   938ŌåÆ      const rows = await sql<ReferralClaim[]>`\n   939ŌåÆ        SELECT * FROM referral_claims WHERE id = ${claimId}\n   940ŌåÆ      `;\n   941ŌåÆ      return rows[0];\n   942ŌåÆ    },\n   943ŌåÆ\n   944ŌåÆ    async updateClaimStatus(claimId, status, meta) {\n   945ŌåÆ      const rows = await sql<ReferralClaim[]>`\n   946ŌåÆ        UPDATE referral_claims\n   947ŌåÆ        SET\n   948ŌåÆ          status = ${status},\n   949ŌåÆ          tx_signature = COALESCE(${meta?.txSignature ?? null}, tx_signature),\n   950ŌåÆ          error = COALESCE(${meta?.error ?? null}, error),\n   951ŌåÆ          processed_at = ${status === \"completed\" || status === \"failed\" ? sql`now()` : sql`processed_at`}\n   952ŌåÆ        WHERE id = ${claimId}\n   953ŌåÆ        RETURNING *\n   954ŌåÆ      `;\n   955ŌåÆ      return rows[0]!;\n   956ŌåÆ    },\n   957ŌåÆ\n   958ŌåÆ    async getReferrerRate(wallet, defaultRateBps) {\n   959ŌåÆ      const rows = await sql<{ rate_bps: number }[]>`\n   960ŌåÆ        SELECT rate_bps FROM referral_kol_rates WHERE wallet = ${wallet}\n   961ŌåÆ      `;\n   962ŌåÆ      return rows[0]?.rate_bps ?? defaultRateBps;\n   963ŌåÆ    },\n   964ŌåÆ\n   965ŌåÆ    async close() {\n   966ŌåÆ      await sql.end();\n   967ŌåÆ    },\n   968ŌåÆ  };\n   969ŌåÆ}\n   970ŌåÆ"}]},"parent_tool_use_id":"toolu_01VrdDqAhMuAGPDL8ByWc5Nc","session_id":"a51b6cb4-cdb0-4e97-8a06-1ab74eb394f9"