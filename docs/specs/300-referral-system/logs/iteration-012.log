{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VJU5AX4yqPRWdNhVQ1JhNB","type":"tool_result","content":"     1ŌåÆimport { Hono } from \"hono\";\n     2ŌåÆimport { cors } from \"hono/cors\";\n     3ŌåÆimport { serve } from \"@hono/node-server\";\n     4ŌåÆimport { Connection, PublicKey } from \"@solana/web3.js\";\n     5ŌåÆimport postgres from \"postgres\";\n     6ŌåÆimport { loadConfig } from \"./config.js\";\n     7ŌåÆimport { createDb } from \"./db.js\";\n     8ŌåÆimport { createAuthDb } from \"./auth-db.js\";\n     9ŌåÆimport { createCoinflipRoutes } from \"./routes/create.js\";\n    10ŌåÆimport { createLordRoutes } from \"./routes/lord-create.js\";\n    11ŌåÆimport { createRoundsRoutes } from \"./routes/rounds.js\";\n    12ŌåÆimport { createCloseCallRoutes } from \"./routes/closecall.js\";\n    13ŌåÆimport { createHealthRoutes } from \"./routes/health.js\";\n    14ŌåÆimport { createProfileRoutes } from \"./routes/profile.js\";\n    15ŌåÆimport { createPriceRoutes } from \"./routes/price.js\";\n    16ŌåÆimport { createAuthRoutes } from \"./routes/auth.js\";\n    17ŌåÆimport { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n    18ŌåÆimport { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n    19ŌåÆimport { createSettlementWorker } from \"./worker/settlement.js\";\n    20ŌåÆimport { settleRound } from \"./worker/settle-tx.js\";\n    21ŌåÆimport { createRetrySettler } from \"./worker/retry.js\";\n    22ŌåÆimport { createPdaWatcher } from \"./worker/pda-watcher.js\";\n    23ŌåÆimport { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n    24ŌåÆimport { createEventWorker } from \"./queue/index.js\";\n    25ŌåÆimport { logger } from \"./logger.js\";\n    26ŌåÆ\n    27ŌåÆconst config = loadConfig();\n    28ŌåÆ\n    29ŌåÆ// Shared postgres connection for both game DB and auth DB\n    30ŌåÆconst sql = postgres(config.databaseUrl);\n    31ŌåÆconst db = createDb(config.databaseUrl);\n    32ŌåÆconst authDb = createAuthDb(sql);\n    33ŌåÆ\n    34ŌåÆconst connection = new Connection(config.rpcUrl, {\n    35ŌåÆ  commitment: \"confirmed\",\n    36ŌåÆ  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n    37ŌåÆ});\n    38ŌåÆ\n    39ŌåÆconst app = new Hono();\n    40ŌåÆ\n    41ŌåÆapp.use(\n    42ŌåÆ  \"*\",\n    43ŌåÆ  cors({\n    44ŌåÆ    origin: \"*\",\n    45ŌåÆ    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n    46ŌåÆ    allowHeaders: [\"Content-Type\", \"Authorization\"],\n    47ŌåÆ  }),\n    48ŌåÆ);\n    49ŌåÆ\n    50ŌåÆ// Request logging ŌĆö correlate frontend fetch timing with server-side processing\n    51ŌåÆapp.use(\"*\", async (c, next) => {\n    52ŌåÆ  const start = Date.now();\n    53ŌåÆ  await next();\n    54ŌåÆ  const ms = Date.now() - start;\n    55ŌåÆ  const method = c.req.method;\n    56ŌåÆ  const path = c.req.path;\n    57ŌåÆ  // Skip noisy health checks and OPTIONS preflight\n    58ŌåÆ  if (path === \"/health\" || method === \"OPTIONS\") return;\n    59ŌåÆ  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n    60ŌåÆ});\n    61ŌåÆ\n    62ŌåÆ// Auth routes ŌĆö no JWT middleware (these are the login endpoints)\n    63ŌåÆ// Lighter rate limiting by IP for auth endpoints\n    64ŌåÆapp.use(\n    65ŌåÆ  \"/auth/*\",\n    66ŌåÆ  createRateLimitMiddleware({\n    67ŌåÆ    perWallet: 20,\n    68ŌåÆ    global: config.rateLimitGlobal,\n    69ŌåÆ    windowMs: 60_000,\n    70ŌåÆ  }),\n    71ŌåÆ);\n    72ŌåÆ\n    73ŌåÆapp.route(\n    74ŌåÆ  \"/auth\",\n    75ŌåÆ  createAuthRoutes({\n    76ŌåÆ    authDb,\n    77ŌåÆ    jwtSecret: config.jwtSecret,\n    78ŌåÆ    cluster: config.cluster,\n    79ŌåÆ    challengeTtlSeconds: config.challengeTtlSeconds,\n    80ŌåÆ    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    81ŌåÆ    refreshTokenTtlDays: config.refreshTokenTtlDays,\n    82ŌåÆ  }),\n    83ŌåÆ);\n    84ŌåÆ\n    85ŌåÆ// Profile routes ŌĆö authenticated GET endpoints (require JWT on all methods)\n    86ŌåÆapp.use(\n    87ŌåÆ  \"/profile/*\",\n    88ŌåÆ  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n    89ŌåÆ);\n    90ŌåÆapp.route(\"/profile\", createProfileRoutes({ db }));\n    91ŌåÆ\n    92ŌåÆ// JWT auth middleware for fairness endpoints\n    93ŌåÆapp.use(\n    94ŌåÆ  \"/fairness/*\",\n    95ŌåÆ  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n    96ŌåÆ);\n    97ŌåÆ\n    98ŌåÆ// Rate limiting ŌĆö per-wallet and global limits on POST requests\n    99ŌåÆapp.use(\n   100ŌåÆ  \"/fairness/*\",\n   101ŌåÆ  createRateLimitMiddleware({\n   102ŌåÆ    perWallet: config.rateLimitPerWallet,\n   103ŌåÆ    global: config.rateLimitGlobal,\n   104ŌåÆ    windowMs: 60_000,\n   105ŌåÆ  }),\n   106ŌåÆ);\n   107ŌåÆ\n   108ŌåÆ// Settlement infrastructure ŌĆö must be created before routes (routes use pdaWatcher)\n   109ŌåÆconst entropyAccount = new PublicKey(config.entropyAccount);\n   110ŌåÆconst retrySettler = createRetrySettler({\n   111ŌåÆ  db,\n   112ŌåÆ  connection,\n   113ŌåÆ  settleRound: (pda) =>\n   114ŌåÆ    settleRound(\n   115ŌåÆ      { db, connection, serverKeypair: config.serverKeypair, entropyAccount },\n   116ŌåÆ      pda,\n   117ŌåÆ    ),\n   118ŌåÆ});\n   119ŌåÆ\n   120ŌåÆ// PDA watcher ŌĆö WebSocket-based instant join detection\n   121ŌåÆconst pdaWatcher = createPdaWatcher({\n   122ŌåÆ  connection,\n   123ŌåÆ  serverKey: config.serverKeypair.publicKey,\n   124ŌåÆ  db,\n   125ŌåÆ  onJoinDetected: async (pda, targetSlot) => {\n   126ŌåÆ    // Update DB phase if still in 'created'\n   127ŌåÆ    const round = await db.getRoundByPda(pda);\n   128ŌåÆ    if (round && round.phase === \"created\") {\n   129ŌåÆ      await db.updateRoundPhase(pda, \"locked\", {\n   130ŌåÆ        target_slot: targetSlot.toString(),\n   131ŌåÆ      });\n   132ŌåÆ      await db.insertOperatorEvent(pda, \"match_detected\", {\n   133ŌåÆ        targetSlot: targetSlot.toString(),\n   134ŌåÆ        source: \"pda-watcher\",\n   135ŌåÆ        game: round.game,\n   136ŌåÆ      });\n   137ŌåÆ    }\n   138ŌåÆ\n   139ŌåÆ    // Check if target slot already passed ŌĆö settle immediately if so\n   140ŌåÆ    const currentSlot = await connection.getSlot();\n   141ŌåÆ    if (BigInt(currentSlot) >= targetSlot) {\n   142ŌåÆ      await retrySettler.attemptSettle(pda);\n   143ŌåÆ      pdaWatcher.unwatch(pda);\n   144ŌåÆ    }\n   145ŌåÆ    // If target slot not reached yet, poll worker will pick it up next cycle\n   146ŌåÆ  },\n   147ŌåÆ});\n   148ŌåÆ\n   149ŌåÆconst worker = createSettlementWorker({\n   150ŌåÆ  db,"}]},"parent_tool_use_id":"toolu_01TV6oB4zFLLycoW2yHnJ2sr","session_id":"a51b6cb4-cdb0-4e97-8a06-1ab74eb394f9","uuid":"8b434ded-cf40-49b2-be7c-fea4d4efc616","timestamp":"2026-03-25T12:07:32.056Z"}
