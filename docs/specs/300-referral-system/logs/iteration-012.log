{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012QVUVNh1TnBwTFxCm8hQFm","type":"tool_result","content":"     1ŌåÆ-- 010_event_queue.sql ŌĆö Postgres-backed async event queue.\n     2ŌåÆ--\n     3ŌåÆ-- Decouples settlement hot path from secondary side-effects (reward delivery,\n     4ŌåÆ-- notifications, analytics). Events are committed atomically with their\n     5ŌåÆ-- triggering operation. Worker polls with SKIP LOCKED for safe concurrency.\n     6ŌåÆ\n     7ŌåÆCREATE TABLE IF NOT EXISTS event_queue (\n     8ŌåÆ  id              BIGSERIAL    PRIMARY KEY,\n     9ŌåÆ  event_type      TEXT         NOT NULL,\n    10ŌåÆ  payload         JSONB        NOT NULL,\n    11ŌåÆ  status          TEXT         NOT NULL DEFAULT 'pending',\n    12ŌåÆ  attempts        INTEGER      NOT NULL DEFAULT 0,\n    13ŌåÆ  max_attempts    INTEGER      NOT NULL DEFAULT 3,\n    14ŌåÆ  scheduled_at    TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    15ŌåÆ  started_at      TIMESTAMPTZ,\n    16ŌåÆ  completed_at    TIMESTAMPTZ,\n    17ŌåÆ  error           TEXT,\n    18ŌåÆ  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n    19ŌåÆ\n    20ŌåÆ  CONSTRAINT chk_event_queue_status\n    21ŌåÆ    CHECK (status IN ('pending', 'processing', 'completed', 'failed', 'dead'))\n    22ŌåÆ);\n    23ŌåÆ\n    24ŌåÆ-- Partial index for worker polling ŌĆö only scans pending events\n    25ŌåÆCREATE INDEX IF NOT EXISTS idx_event_queue_poll\n    26ŌåÆ  ON event_queue (scheduled_at)\n    27ŌåÆ  WHERE status = 'pending';\n    28ŌåÆ\n    29ŌåÆ-- Index for observability queries (dead events, recent failures)\n    30ŌåÆCREATE INDEX IF NOT EXISTS idx_event_queue_status\n    31ŌåÆ  ON event_queue (status, created_at);\n    32ŌåÆ"}]},"parent_tool_use_id":"toolu_01TV6oB4zFLLycoW2yHnJ2sr","session_id":"a51b6cb4-cdb0-4e97-8a06-1ab74eb394f9","uuid":"76ffbf53-904e-4038-9090-32c85e2c9b96","timestamp":"2026-03-25T12:06:53.636Z"}
