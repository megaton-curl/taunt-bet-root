{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TLgtNZhGzRMxtCXDALFaWf","type":"tool_result","content":"     1ŌåÆ/**\n     2ŌåÆ * Referral routes ŌĆö code management, linking, stats, earnings, and claims.\n     3ŌåÆ */\n     4ŌåÆ\n     5ŌåÆimport { Hono } from \"hono\";\n     6ŌåÆimport type { AppEnv } from \"../hono-env.js\";\n     7ŌåÆimport type { Db } from \"../db.js\";\n     8ŌåÆimport { logger } from \"../logger.js\";\n     9ŌåÆ\n    10ŌåÆexport interface ReferralRoutesDeps {\n    11ŌåÆ  db: Db;\n    12ŌåÆ}\n    13ŌåÆ\n    14ŌåÆ/** Referral code validation: 3-16 chars, lowercase alphanumeric + hyphens */\n    15ŌåÆconst CODE_REGEX = /^[a-z0-9-]{3,16}$/;\n    16ŌåÆ\n    17ŌåÆconst REFERRAL_BASE_URL = \"https://taunt.bet/r\";\n    18ŌåÆ\n    19ŌåÆexport function createReferralRoutes(deps: ReferralRoutesDeps) {\n    20ŌåÆ  const { db } = deps;\n    21ŌåÆ  const app = new Hono<AppEnv>();\n    22ŌåÆ\n    23ŌåÆ  // POST /code ŌĆö set or replace the player's referral code\n    24ŌåÆ  app.post(\"/code\", async (c) => {\n    25ŌåÆ    const wallet = c.get(\"wallet\");\n    26ŌåÆ    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n    27ŌåÆ\n    28ŌåÆ    let body: { code?: unknown };\n    29ŌåÆ    try {\n    30ŌåÆ      body = await c.req.json();\n    31ŌåÆ    } catch {\n    32ŌåÆ      return c.json({ error: \"Invalid request body\" }, 400);\n    33ŌåÆ    }\n    34ŌåÆ\n    35ŌåÆ    const code = typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n    36ŌåÆ\n    37ŌåÆ    if (!CODE_REGEX.test(code)) {\n    38ŌåÆ      return c.json(\n    39ŌåÆ        {\n    40ŌåÆ          error: {\n    41ŌåÆ            code: \"INVALID_CODE\",\n    42ŌåÆ            message:\n    43ŌåÆ              \"Code must be 3-16 characters, lowercase letters, numbers, and hyphens only\",\n    44ŌåÆ          },\n    45ŌåÆ        },\n    46ŌåÆ        400,\n    47ŌåÆ      );\n    48ŌåÆ    }\n    49ŌåÆ\n    50ŌåÆ    // Check if this code is already taken by another wallet\n    51ŌåÆ    const existing = await db.getReferralCodeByCode(code);\n    52ŌåÆ    if (existing && existing.wallet !== wallet) {\n    53ŌåÆ      return c.json(\n    54ŌåÆ        {\n    55ŌåÆ          error: {\n    56ŌåÆ            code: \"CODE_TAKEN\",\n    57ŌåÆ            message: \"This referral code is already in use\",\n    58ŌåÆ            retryable: false,\n    59ŌåÆ          },\n    60ŌåÆ        },\n    61ŌåÆ        409,\n    62ŌåÆ      );\n    63ŌåÆ    }\n    64ŌåÆ\n    65ŌåÆ    try {\n    66ŌåÆ      const result = await db.upsertReferralCode(wallet, code);\n    67ŌåÆ      logger.info(\"Referral code set\", { wallet, code: result.code });\n    68ŌåÆ      return c.json({\n    69ŌåÆ        code: result.code,\n    70ŌåÆ        url: `${REFERRAL_BASE_URL}/${result.code}`,\n    71ŌåÆ      });\n    72ŌåÆ    } catch (err) {\n    73ŌåÆ      // Handle race condition: another wallet grabbed the code between check and insert\n    74ŌåÆ      const msg = err instanceof Error ? err.message : String(err);\n    75ŌåÆ      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n    76ŌåÆ        return c.json(\n    77ŌåÆ          {\n    78ŌåÆ            error: {\n    79ŌåÆ              code: \"CODE_TAKEN\",\n    80ŌåÆ              message: \"This referral code is already in use\",\n    81ŌåÆ              retryable: false,\n    82ŌåÆ            },\n    83ŌåÆ          },\n    84ŌåÆ          409,\n    85ŌåÆ        );\n    86ŌåÆ      }\n    87ŌåÆ      logger.error(\"Failed to set referral code\", { err: String(err), wallet });\n    88ŌåÆ      return c.json({ error: \"Failed to set referral code\" }, 500);\n    89ŌåÆ    }\n    90ŌåÆ  });\n    91ŌåÆ\n    92ŌåÆ  // POST /apply ŌĆö link the authenticated player to a referrer via their code\n    93ŌåÆ  app.post(\"/apply\", async (c) => {\n    94ŌåÆ    const wallet = c.get(\"wallet\");\n    95ŌåÆ    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n    96ŌåÆ\n    97ŌåÆ    let body: { code?: unknown };\n    98ŌåÆ    try {\n    99ŌåÆ      body = await c.req.json();\n   100ŌåÆ    } catch {\n   101ŌåÆ      return c.json(\n   102ŌåÆ        {\n   103ŌåÆ          error: {\n   104ŌåÆ            code: \"INVALID_BODY\",\n   105ŌåÆ            message: \"Invalid request body\",\n   106ŌåÆ          },\n   107ŌåÆ        },\n   108ŌåÆ        400,\n   109ŌåÆ      );\n   110ŌåÆ    }\n   111ŌåÆ\n   112ŌåÆ    const code =\n   113ŌåÆ      typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n   114ŌåÆ\n   115ŌåÆ    if (!code) {\n   116ŌåÆ      return c.json(\n   117ŌåÆ        {\n   118ŌåÆ          error: {\n   119ŌåÆ            code: \"INVALID_CODE\",\n   120ŌåÆ            message: \"Referral code is required\",\n   121ŌåÆ          },\n   122ŌåÆ        },\n   123ŌåÆ        400,\n   124ŌåÆ      );\n   125ŌåÆ    }\n   126ŌåÆ\n   127ŌåÆ    // Look up the referral code to find the referrer\n   128ŌåÆ    const codeRow = await db.getReferralCodeByCode(code);\n   129ŌåÆ    if (!codeRow) {\n   130ŌåÆ      return c.json(\n   131ŌåÆ        {\n   132ŌåÆ          error: {\n   133ŌåÆ            code: \"CODE_NOT_FOUND\",\n   134ŌåÆ            message: \"Referral code does not exist\",\n   135ŌåÆ            retryable: false,\n   136ŌåÆ          },\n   137ŌåÆ        },\n   138ŌåÆ        404,\n   139ŌåÆ      );\n   140ŌåÆ    }\n   141ŌåÆ\n   142ŌåÆ    // Self-referral check\n   143ŌåÆ    if (codeRow.wallet === wallet) {\n   144ŌåÆ      return c.json(\n   145ŌåÆ        {\n   146ŌåÆ          error: {\n   147ŌåÆ            code: \"SELF_REFERRAL\",\n   148ŌåÆ            message: \"You cannot use your own referral code\",\n   149ŌåÆ            retryable: false,\n   150ŌåÆ          },\n   151ŌåÆ        },\n   152ŌåÆ        400,\n   153ŌåÆ      );\n   154ŌåÆ    }\n   155ŌåÆ\n   156ŌåÆ    // Check if the player already has a referrer\n   157ŌåÆ    const existingLink = await db.getReferralLinkByReferee(wallet);\n   158ŌåÆ    if (existingLink) {\n   159ŌåÆ      return c.json(\n   160ŌåÆ        {\n   161ŌåÆ          error: {\n   162ŌåÆ            code: \"ALREADY_LINKED\",\n   163ŌåÆ            message: \"You are already linked to a referrer\",\n   164ŌåÆ            retryable: false,\n   165ŌåÆ          },\n   166ŌåÆ        },\n   167ŌåÆ        409,\n   168ŌåÆ      );\n   169ŌåÆ    }\n   170ŌåÆ\n   171ŌåÆ    try {\n   172ŌåÆ      await db.insertReferralLink(codeRow.wallet, wallet);\n   173ŌåÆ      logger.info(\"Referral link created\", {\n   174ŌåÆ        referrer: codeRow.wallet,\n   175ŌåÆ        referee: wallet,\n   176ŌåÆ        code,\n   177ŌåÆ      });\n   178ŌåÆ      return c.json({\n   179ŌåÆ        referrer: codeRow.wallet,\n   180ŌåÆ        benefit: \"10% fee rebate on all games\",\n   181ŌåÆ      });\n   182ŌåÆ    } catch (err) {\n   183ŌåÆ      // Handle race condition: another request linked this referee between check and insert\n   184ŌåÆ      const msg = err instanceof Error ? err.message : String(err);\n   185ŌåÆ      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n   186ŌåÆ        return c.json(\n   187ŌåÆ          {\n   188ŌåÆ            error: {\n   189ŌåÆ              code: \"ALREADY_LINKED\",\n   190ŌåÆ              message: \"You are already linked to a referrer\",\n   191ŌåÆ              retryable: false,\n   192ŌåÆ            },\n   193ŌåÆ          },\n   194ŌåÆ          409,\n   195ŌåÆ        );\n   196ŌåÆ      }\n   197ŌåÆ      logger.error(\"Failed to create referral link\", {\n   198ŌåÆ        err: String(err),\n   199ŌåÆ        wallet,\n   200ŌåÆ        code,\n   201ŌåÆ      });\n   202ŌåÆ      return c.json({ error: \"Failed to apply referral code\" }, 500);\n   203ŌåÆ    }\n   204ŌåÆ  });\n   205ŌåÆ\n   206ŌåÆ  // GET /code ŌĆö return the authenticated player's current referral code\n   207ŌåÆ  app.get(\"/code\", async (c) => {\n   208ŌåÆ    const wallet = c.get(\"wallet\");\n   209ŌåÆ    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   210ŌåÆ\n   211ŌåÆ    const row = await db.getReferralCodeByWallet(wallet);\n   212ŌåÆ    if (!row) {\n   213ŌåÆ      return c.json(\n   214ŌåÆ        {\n   215ŌåÆ          error: {\n   216ŌåÆ            code: \"NO_CODE\",\n   217ŌåÆ            message: \"No referral code set for this wallet\",\n   218ŌåÆ          },\n   219ŌåÆ        },\n   220ŌåÆ        404,\n   221ŌåÆ      );\n   222ŌåÆ    }\n   223ŌåÆ\n   224ŌåÆ    return c.json({\n   225ŌåÆ      code: row.code,\n   226ŌåÆ      url: `${REFERRAL_BASE_URL}/${row.code}`,\n   227ŌåÆ    });\n   228ŌåÆ  });\n   229ŌåÆ\n   230ŌåÆ  // GET /stats ŌĆö referral summary stats for authenticated wallet\n   231ŌåÆ  app.get(\"/stats\", async (c) => {\n   232ŌåÆ    const wallet = c.get(\"wallet\");\n   233ŌåÆ    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   234ŌåÆ\n   235ŌåÆ    try {\n   236ŌåÆ      const stats = await db.getReferralStats(wallet);\n   237ŌåÆ      return c.json({\n   238ŌåÆ        referredCount: stats.referred_count,\n   239ŌåÆ        activeCount: stats.active_count,\n   240ŌåÆ        totalVolumeLamports: stats.total_volume_lamports,\n   241ŌåÆ        totalEarnedLamports: stats.total_earned_lamports,\n   242ŌåÆ        pendingLamports: stats.pending_lamports,\n   243ŌåÆ      });\n   244ŌåÆ    } catch (err) {\n   245ŌåÆ      logger.error(\"Failed to fetch referral stats\", {\n   246ŌåÆ        err: String(err),\n   247ŌåÆ        wallet,\n   248ŌåÆ      });\n   249ŌåÆ      return c.json({ error: \"Failed to fetch referral stats\" }, 500);\n   250ŌåÆ    }\n   251ŌåÆ  });\n   252ŌåÆ\n   253ŌåÆ  // GET /earnings ŌĆö paginated per-game earnings log\n   254ŌåÆ  app.get(\"/earnings\", async (c) => {\n   255ŌåÆ    const wallet = c.get(\"wallet\");\n   256ŌåÆ    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n   257ŌåÆ\n   258ŌåÆ    const pageParam = c.req.query(\"page\");\n   259ŌåÆ    const limitParam = c.req.query(\"limit\");\n   260ŌåÆ    const page = pageParam ? Math.max(1, Math.floor(Number(pageParam))) : 1;\n   261ŌåÆ    const limit = limitParam\n   262ŌåÆ      ? Math.min(100, Math.max(1, Math.floor(Number(limitParam))))\n   263ŌåÆ      : 20;\n   264ŌåÆ\n   265ŌåÆ    if (Number.isNaN(page) || Number.isNaN(limit)) {\n   266ŌåÆ      return c.json(\n   267ŌåÆ        {\n   268ŌåÆ          error: {\n   269ŌåÆ            code: \"INVALID_PARAMS\",\n   270ŌåÆ            message: \"page and limit must be positive integers\",\n   271ŌåÆ          },\n   272ŌåÆ        },\n   273ŌåÆ        400,\n   274ŌåÆ      );\n   275ŌåÆ    }\n   276ŌåÆ\n   277ŌåÆ    try {\n   278ŌåÆ      const result = await db.getReferralEarnings(wallet, page, limit);\n   279ŌåÆ      return c.json({\n   280ŌåÆ        items: result.items.map((e) => ({\n   281ŌåÆ          roundId: e.round_id,\n   282ŌåÆ          gameType: e.game_type,\n   283ŌåÆ          refereeWallet: e.referee_wallet,\n   284ŌåÆ          wagerLamports: String(e.wager_lamports),\n   285ŌåÆ          earnedLamports: String(e.referrer_earned_lamports),\n   286ŌåÆ          createdAt: e.created_at.toISOString(),\n   287ŌåÆ        })),\n   288ŌåÆ        pagination: {\n   289ŌåÆ          page,\n   290ŌåÆ          totalPages: result.totalPages,\n   291ŌåÆ        },\n   292ŌåÆ      });\n   293ŌåÆ    } catch (err) {\n   294ŌåÆ      logger.error(\"Failed to fetch referral earnings\", {\n   295ŌåÆ        err: String(err),\n   296ŌåÆ        wallet,\n   297ŌåÆ      });\n   298ŌåÆ      return c.json({ error: \"Failed to fetch referral earnings\" }, 500);\n   299ŌåÆ    }\n   300ŌåÆ  });\n   301ŌåÆ\n   302ŌåÆ  return app;\n   303ŌåÆ}\n   304ŌåÆ"}]},"parent_tool_use_id":null,"session_id":"a51b6cb4-cdb0-4e97-8a06-1ab74eb394f9","uuid":"7417b7a2-8461-44c6-a742-3f365b4f2650","timestamp":"2026-03-25T12:08:03.229Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/referral.ts","content":"/**\n * Referral routes ŌĆö code management, linking, stats, earnings, and claims.\n */\n\nimport { Hono } from \"hono\";\nimport type { AppEnv } from \"../hono-env.js\";\nimport type { Db } from \"../db.js\";\nimport { logger } from \"../logger.js\";\n\nexport interface ReferralRoutesDeps {\n  db: Db;\n}\n\n/** Referral code validation: 3-16 chars, lowercase alphanumeric + hyphens */\nconst CODE_REGEX = /^[a-z0-9-]{3,16}$/;\n\nconst REFERRAL_BASE_URL = \"https://taunt.bet/r\";\n\nexport function createReferralRoutes(deps: ReferralRoutesDeps) {\n  const { db } = deps;\n  const app = new Hono<AppEnv>();\n\n  // POST /code ŌĆö set or replace the player's referral code\n  app.post(\"/code\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    let body: { code?: unknown };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json({ error: \"Invalid request body\" }, 400);\n    }\n\n    const code = typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n\n    if (!CODE_REGEX.test(code)) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_CODE\",\n            message:\n              \"Code must be 3-16 characters, lowercase letters, numbers, and hyphens only\",\n          },\n        },\n        400,\n      );\n    }\n\n    // Check if this code is already taken by another wallet\n    const existing = await db.getReferralCodeByCode(code);\n    if (existing && existing.wallet !== wallet) {\n      return c.json(\n        {\n          error: {\n            code: \"CODE_TAKEN\",\n            message: \"This referral code is already in use\",\n            retryable: false,\n          },\n        },\n        409,\n      );\n    }\n\n    try {\n      const result = await db.upsertReferralCode(wallet, code);\n      logger.info(\"Referral code set\", { wallet, code: result.code });\n      return c.json({\n        code: result.code,\n        url: `${REFERRAL_BASE_URL}/${result.code}`,\n      });\n    } catch (err) {\n      // Handle race condition: another wallet grabbed the code between check and insert\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return c.json(\n          {\n            error: {\n              code: \"CODE_TAKEN\",\n              message: \"This referral code is already in use\",\n              retryable: false,\n            },\n          },\n          409,\n        );\n      }\n      logger.error(\"Failed to set referral code\", { err: String(err), wallet });\n      return c.json({ error: \"Failed to set referral code\" }, 500);\n    }\n  });\n\n  // POST /apply ŌĆö link the authenticated player to a referrer via their code\n  app.post(\"/apply\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    let body: { code?: unknown };\n    try {\n      body = await c.req.json();\n    } catch {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_BODY\",\n            message: \"Invalid request body\",\n          },\n        },\n        400,\n      );\n    }\n\n    const code =\n      typeof body.code === \"string\" ? body.code.toLowerCase().trim() : \"\";\n\n    if (!code) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_CODE\",\n            message: \"Referral code is required\",\n          },\n        },\n        400,\n      );\n    }\n\n    // Look up the referral code to find the referrer\n    const codeRow = await db.getReferralCodeByCode(code);\n    if (!codeRow) {\n      return c.json(\n        {\n          error: {\n            code: \"CODE_NOT_FOUND\",\n            message: \"Referral code does not exist\",\n            retryable: false,\n          },\n        },\n        404,\n      );\n    }\n\n    // Self-referral check\n    if (codeRow.wallet === wallet) {\n      return c.json(\n        {\n          error: {\n            code: \"SELF_REFERRAL\",\n            message: \"You cannot use your own referral code\",\n            retryable: false,\n          },\n        },\n        400,\n      );\n    }\n\n    // Check if the player already has a referrer\n    const existingLink = await db.getReferralLinkByReferee(wallet);\n    if (existingLink) {\n      return c.json(\n        {\n          error: {\n            code: \"ALREADY_LINKED\",\n            message: \"You are already linked to a referrer\",\n            retryable: false,\n          },\n        },\n        409,\n      );\n    }\n\n    try {\n      await db.insertReferralLink(codeRow.wallet, wallet);\n      logger.info(\"Referral link created\", {\n        referrer: codeRow.wallet,\n        referee: wallet,\n        code,\n      });\n      return c.json({\n        referrer: codeRow.wallet,\n        benefit: \"10% fee rebate on all games\",\n      });\n    } catch (err) {\n      // Handle race condition: another request linked this referee between check and insert\n      const msg = err instanceof Error ? err.message : String(err);\n      if (msg.includes(\"unique\") || msg.includes(\"duplicate\")) {\n        return c.json(\n          {\n            error: {\n              code: \"ALREADY_LINKED\",\n              message: \"You are already linked to a referrer\",\n              retryable: false,\n            },\n          },\n          409,\n        );\n      }\n      logger.error(\"Failed to create referral link\", {\n        err: String(err),\n        wallet,\n        code,\n      });\n      return c.json({ error: \"Failed to apply referral code\" }, 500);\n    }\n  });\n\n  // GET /code ŌĆö return the authenticated player's current referral code\n  app.get(\"/code\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    const row = await db.getReferralCodeByWallet(wallet);\n    if (!row) {\n      return c.json(\n        {\n          error: {\n            code: \"NO_CODE\",\n            message: \"No referral code set for this wallet\",\n          },\n        },\n        404,\n      );\n    }\n\n    return c.json({\n      code: row.code,\n      url: `${REFERRAL_BASE_URL}/${row.code}`,\n    });\n  });\n\n  // GET /stats ŌĆö referral summary stats for authenticated wallet\n  app.get(\"/stats\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    try {\n      const stats = await db.getReferralStats(wallet);\n      return c.json({\n        referredCount: stats.referred_count,\n        activeCount: stats.active_count,\n        totalVolumeLamports: stats.total_volume_lamports,\n        totalEarnedLamports: stats.total_earned_lamports,\n        pendingLamports: stats.pending_lamports,\n      });\n    } catch (err) {\n      logger.error(\"Failed to fetch referral stats\", {\n        err: String(err),\n        wallet,\n      });\n      return c.json({ error: \"Failed to fetch referral stats\" }, 500);\n    }\n  });\n\n  // GET /earnings ŌĆö paginated per-game earnings log\n  app.get(\"/earnings\", async (c) => {\n    const wallet = c.get(\"wallet\");\n    if (!wallet) return c.json({ error: \"Authentication required\" }, 401);\n\n    const pageParam = c.req.query(\"page\");\n    const limitParam = c.req.query(\"limit\");\n    const page = pageParam ? Math.max(1, Math.floor(Number(pageParam))) : 1;\n    const limit = limitParam\n      ? Math.min(100, Math.max(1, Math.floor(Number(limitParam))))\n      : 20;\n\n    if (Number.isNaN(page) || Number.isNaN(limit)) {\n      return c.json(\n        {\n          error: {\n            code: \"INVALID_PARAMS\",\n            message: \"page and limit must be positive integers\",\n          },\n        },\n        400,\n      );\n    }\n\n    try {\n      const result = await db.getReferralEarnings(wallet, page, limit);\n      return c.json({\n        items: result.items.map((e) => ({\n          roundId: e.round_id,\n          gameType: e.game_type,\n          refereeWallet: e.referee_wallet,\n          wagerLamports: String(e.wager_lamports),\n          earnedLamports: String(e.referrer_earned_lamports),\n          createdAt: e.created_at.toISOString(),\n        })),\n        pagination: {\n          page,\n          totalPages: result.totalPages,\n        },\n      });\n    } catch (err) {\n      logger.error(\"Failed to fetch referral earnings\", {\n        err: String(err),\n        wallet,\n      });\n      return c.json({ error: \"Failed to fetch referral earnings\" }, 500);\n    }\n  });\n\n  return app;\n}\n","numLines":304,"startLine":1,"totalLines":304}}}
