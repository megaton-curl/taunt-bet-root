{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015u244C7a7fHP8icTKMT1Rf","type":"tool_result","content":"     1ŌåÆ/**\n     2ŌåÆ * Integration tests for the event queue worker.\n     3ŌåÆ *\n     4ŌåÆ * Tests the full lifecycle: emit ŌåÆ worker poll ŌåÆ handler dispatch ŌåÆ status transitions.\n     5ŌåÆ * Requires a running Postgres database (same as backend).\n     6ŌåÆ *\n     7ŌåÆ * Covers:\n     8ŌåÆ * 1. Happy path ŌĆö handler called, event status = completed\n     9ŌåÆ * 2. Failure ŌåÆ retry ŌåÆ dead ŌĆö attempts increment, backoff applied, final status = dead\n    10ŌåÆ * 3. Concurrent safety ŌĆö two workers, SKIP LOCKED, each event processed exactly once\n    11ŌåÆ */\n    12ŌåÆ\n    13ŌåÆimport {\n    14ŌåÆ  describe,\n    15ŌåÆ  it,\n    16ŌåÆ  beforeAll,\n    17ŌåÆ  afterAll,\n    18ŌåÆ  beforeEach,\n    19ŌåÆ  expect,\n    20ŌåÆ} from \"vitest\";\n    21ŌåÆimport postgres from \"postgres\";\n    22ŌåÆimport { emitEvent } from \"../emit-event.js\";\n    23ŌåÆimport {\n    24ŌåÆ  registerHandler,\n    25ŌåÆ  clearHandlers,\n    26ŌåÆ} from \"../handler-registry.js\";\n    27ŌåÆimport { EventTypes } from \"../event-types.js\";\n    28ŌåÆimport { createEventWorker } from \"../worker.js\";\n    29ŌåÆ\n    30ŌåÆ/** Poll until condition is true or timeout. */\n    31ŌåÆasync function waitFor(\n    32ŌåÆ  condition: () => boolean,\n    33ŌåÆ  timeoutMs: number,\n    34ŌåÆ): Promise<void> {\n    35ŌåÆ  const start = Date.now();\n    36ŌåÆ  while (!condition()) {\n    37ŌåÆ    if (Date.now() - start > timeoutMs) {\n    38ŌåÆ      throw new Error(`waitFor timed out after ${timeoutMs}ms`);\n    39ŌåÆ    }\n    40ŌåÆ    await new Promise((r) => setTimeout(r, 50));\n    41ŌåÆ  }\n    42ŌåÆ}\n    43ŌåÆ\n    44ŌåÆdescribe(\"event queue integration tests\", () => {\n    45ŌåÆ  let sql: ReturnType<typeof postgres>;\n    46ŌåÆ\n    47ŌåÆ  beforeAll(async () => {\n    48ŌåÆ    sql = process.env.DATABASE_URL\n    49ŌåÆ      ? postgres(process.env.DATABASE_URL)\n    50ŌåÆ      : postgres({\n    51ŌåÆ          host: \"/var/run/postgresql\",\n    52ŌåÆ          database: \"rng_utopia_dev\",\n    53ŌåÆ          username: \"vscode\",\n    54ŌåÆ        });\n    55ŌåÆ  });\n    56ŌåÆ\n    57ŌåÆ  afterAll(async () => {\n    58ŌåÆ    await sql.end();\n    59ŌåÆ  });\n    60ŌåÆ\n    61ŌåÆ  beforeEach(async () => {\n    62ŌåÆ    await sql`TRUNCATE event_queue RESTART IDENTITY`;\n    63ŌåÆ    clearHandlers();\n    64ŌåÆ  });\n    65ŌåÆ\n    66ŌåÆ  // -------------------------------------------------------------------------\n    67ŌåÆ  // 1. Happy path\n    68ŌåÆ  // -------------------------------------------------------------------------\n    69ŌåÆ\n    70ŌåÆ  it(\"happy path: handler called and event status = completed\", async () => {\n    71ŌåÆ    let handlerCalled = false;\n    72ŌåÆ    let capturedPayload: Record<string, unknown> | null = null;\n    73ŌåÆ\n    74ŌåÆ    registerHandler(EventTypes.REFERRAL_GAME_SETTLED, async (payload) => {\n    75ŌåÆ      handlerCalled = true;\n    76ŌåÆ      capturedPayload = payload;\n    77ŌåÆ    });\n    78ŌåÆ\n    79ŌåÆ    const payload = { referrerWallet: \"abc\", roundId: \"test-round\" };\n    80ŌåÆ    await sql.begin(async (tx) => {\n    81ŌåÆ      await emitEvent(\n    82ŌåÆ        tx as unknown as postgres.Sql,\n    83ŌåÆ        EventTypes.REFERRAL_GAME_SETTLED,\n    84ŌåÆ        payload,\n    85ŌåÆ      );\n    86ŌåÆ    });\n    87ŌåÆ\n    88ŌåÆ    const worker = createEventWorker(sql, { pollIntervalMs: 100 });\n    89ŌåÆ    worker.start();\n    90ŌåÆ\n    91ŌåÆ    // Wait for handler to be called (up to 3s)\n    92ŌåÆ    await waitFor(() => handlerCalled, 3000);\n    93ŌåÆ    worker.stop();\n    94ŌåÆ\n    95ŌåÆ    expect(handlerCalled).toBe(true);\n    96ŌåÆ    expect(capturedPayload).toEqual(payload);\n    97ŌåÆ\n    98ŌåÆ    // Verify DB status\n    99ŌåÆ    const rows = await sql`SELECT * FROM event_queue WHERE status = 'completed'`;\n   100ŌåÆ    expect(rows).toHaveLength(1);\n   101ŌåÆ    expect(rows[0]!.event_type).toBe(\"referral.game_settled\");\n   102ŌåÆ    expect(rows[0]!.completed_at).toBeInstanceOf(Date);\n   103ŌåÆ  });\n   104ŌåÆ\n   105ŌåÆ  // -------------------------------------------------------------------------\n   106ŌåÆ  // 2. Failure ŌåÆ retry ŌåÆ dead\n   107ŌåÆ  // -------------------------------------------------------------------------\n   108ŌåÆ\n   109ŌåÆ  it(\"failure ŌåÆ retry ŌåÆ dead after max_attempts\", async () => {\n   110ŌåÆ    let callCount = 0;\n   111ŌåÆ\n   112ŌåÆ    registerHandler(EventTypes.REFERRAL_CODE_APPLIED, async () => {\n   113ŌåÆ      callCount++;\n   114ŌåÆ      throw new Error(\"simulated failure\");\n   115ŌåÆ    });\n   116ŌåÆ\n   117ŌåÆ    await sql.begin(async (tx) => {\n   118ŌåÆ      await emitEvent(\n   119ŌåÆ        tx as unknown as postgres.Sql,\n   120ŌåÆ        EventTypes.REFERRAL_CODE_APPLIED,\n   121ŌåÆ        { test: true },\n   122ŌåÆ        { maxAttempts: 3 },\n   123ŌåÆ      );\n   124ŌåÆ    });\n   125ŌåÆ\n   126ŌåÆ    const worker = createEventWorker(sql);\n   127ŌåÆ\n   128ŌåÆ    // Attempt 1 ŌĆö fails ŌåÆ pending with backoff\n   129ŌåÆ    await worker.poll();\n   130ŌåÆ    expect(callCount).toBe(1);\n   131ŌåÆ    let rows = await sql`SELECT * FROM event_queue`;\n   132ŌåÆ    expect(rows[0]!.status).toBe(\"pending\");\n   133ŌåÆ    expect(rows[0]!.attempts).toBe(1);\n   134ŌåÆ    expect(rows[0]!.error).toBe(\"simulated failure\");\n   135ŌåÆ\n   136ŌåÆ    // Reset scheduled_at so next poll picks it up immediately\n   137ŌåÆ    await sql`UPDATE event_queue SET scheduled_at = now()`;\n   138ŌåÆ\n   139ŌåÆ    // Attempt 2 ŌĆö fails ŌåÆ pending with backoff\n   140ŌåÆ    await worker.poll();\n   141ŌåÆ    expect(callCount).toBe(2);\n   142ŌåÆ    rows = await sql`SELECT * FROM event_queue`;\n   143ŌåÆ    expect(rows[0]!.status).toBe(\"pending\");\n   144ŌåÆ    expect(rows[0]!.attempts).toBe(2);\n   145ŌåÆ\n   146ŌåÆ    // Reset scheduled_at for final attempt\n   147ŌåÆ    await sql`UPDATE event_queue SET scheduled_at = now()`;\n   148ŌåÆ\n   149ŌåÆ    // Attempt 3 ŌĆö fails ŌåÆ dead (max_attempts reached)\n   150ŌåÆ    await worker.poll();\n   151ŌåÆ    expect(callCount).toBe(3);\n   152ŌåÆ    rows = await sql`SELECT * FROM event_queue`;\n   153ŌåÆ    expect(rows[0]!.status).toBe(\"dead\");\n   154ŌåÆ    expect(rows[0]!.attempts).toBe(3);\n   155ŌåÆ    expect(rows[0]!.error).toBe(\"simulated failure\");\n   156ŌåÆ    expect(rows[0]!.completed_at).toBeInstanceOf(Date);\n   157ŌåÆ  });\n   158ŌåÆ\n   159ŌåÆ  // -------------------------------------------------------------------------\n   160ŌåÆ  // 3. Concurrent safety ŌĆö SKIP LOCKED\n   161ŌåÆ  // -------------------------------------------------------------------------\n   162ŌåÆ\n   163ŌåÆ  it(\"concurrent safety: two workers, each event processed exactly once\", async () => {\n   164ŌåÆ    let callCount = 0;\n   165ŌåÆ\n   166ŌåÆ    registerHandler(EventTypes.REFERRAL_CLAIM_REQUESTED, async () => {\n   167ŌåÆ      // Small delay to simulate real work and increase overlap window\n   168ŌåÆ      await new Promise((r) => setTimeout(r, 50));\n   169ŌåÆ      callCount++;\n   170ŌåÆ    });\n   171ŌåÆ\n   172ŌåÆ    // Emit 5 events\n   173ŌåÆ    for (let i = 0; i < 5; i++) {\n   174ŌåÆ      await sql.begin(async (tx) => {\n   175ŌåÆ        await emitEvent(\n   176ŌåÆ          tx as unknown as postgres.Sql,\n   177ŌåÆ          EventTypes.REFERRAL_CLAIM_REQUESTED,\n   178ŌåÆ          { index: i },\n   179ŌåÆ        );\n   180ŌåÆ      });\n   181ŌåÆ    }\n   182ŌåÆ\n   183ŌåÆ    const worker1 = createEventWorker(sql, { batchSize: 5 });\n   184ŌåÆ    const worker2 = createEventWorker(sql, { batchSize: 5 });\n   185ŌåÆ\n   186ŌåÆ    // Both poll simultaneously ŌĆö SKIP LOCKED ensures no double-processing\n   187ŌåÆ    await Promise.all([worker1.poll(), worker2.poll()]);\n   188ŌåÆ\n   189ŌåÆ    expect(callCount).toBe(5);\n   190ŌåÆ\n   191ŌåÆ    const completed = await sql`SELECT * FROM event_queue WHERE status = 'completed'`;\n   192ŌåÆ    expect(completed).toHaveLength(5);\n   193ŌåÆ  });\n   194ŌåÆ});\n   195ŌåÆ"}]},"parent_tool_use_id":"toolu_01TV6oB4zFLLycoW2yHnJ2sr","session_id":"a51b6cb4-cdb0-4e97-8a06-1ab74eb394f9","uuid":"6d8a968e-91be-46ee-9f3a-301f1afede25","timestamp":"2026-03-25T12:07:20.686Z"}
