{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HyFSQMX1LbjJdjpyDvkpNT","type":"tool_result","content":"     1ŌåÆ/**\n     2ŌåÆ * Unit tests for the async event queue module.\n     3ŌåÆ *\n     4ŌåÆ * Covers:\n     5ŌåÆ * 1. emitEvent ŌĆö inserts with correct fields, returns eventId\n     6ŌåÆ * 2. emitEvent ŌĆö rolled-back transaction does NOT persist\n     7ŌåÆ * 3. Handler registry ŌĆö register/get, unknown returns undefined\n     8ŌåÆ * 4. Backoff calculation ŌĆö attempt 1 ŌåÆ 5s, attempt 2 ŌåÆ 30s, attempt 3+ ŌåÆ 300s\n     9ŌåÆ *\n    10ŌåÆ * Requires a running Postgres database (same as backend).\n    11ŌåÆ */\n    12ŌåÆ\n    13ŌåÆimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\n    14ŌåÆimport postgres from \"postgres\";\n    15ŌåÆimport { emitEvent } from \"../emit-event.js\";\n    16ŌåÆimport { registerHandler, getHandler } from \"../handler-registry.js\";\n    17ŌåÆimport { EventTypes } from \"../event-types.js\";\n    18ŌåÆimport { getBackoffSeconds } from \"../worker.js\";\n    19ŌåÆ\n    20ŌåÆdescribe(\"event queue unit tests\", () => {\n    21ŌåÆ  let sql: ReturnType<typeof postgres>;\n    22ŌåÆ\n    23ŌåÆ  beforeAll(async () => {\n    24ŌåÆ    sql = process.env.DATABASE_URL\n    25ŌåÆ      ? postgres(process.env.DATABASE_URL)\n    26ŌåÆ      : postgres({\n    27ŌåÆ          host: \"/var/run/postgresql\",\n    28ŌåÆ          database: \"rng_utopia_dev\",\n    29ŌåÆ          username: \"vscode\",\n    30ŌåÆ        });\n    31ŌåÆ  });\n    32ŌåÆ\n    33ŌåÆ  afterAll(async () => {\n    34ŌåÆ    await sql.end();\n    35ŌåÆ  });\n    36ŌåÆ\n    37ŌåÆ  beforeEach(async () => {\n    38ŌåÆ    await sql`TRUNCATE event_queue RESTART IDENTITY`;\n    39ŌåÆ  });\n    40ŌåÆ\n    41ŌåÆ  // -------------------------------------------------------------------------\n    42ŌåÆ  // emitEvent\n    43ŌåÆ  // -------------------------------------------------------------------------\n    44ŌåÆ\n    45ŌåÆ  describe(\"emitEvent\", () => {\n    46ŌåÆ    it(\"inserts a row with correct fields and returns eventId\", async () => {\n    47ŌåÆ      const payload = { referrerWallet: \"abc\", roundId: \"123\" };\n    48ŌåÆ\n    49ŌåÆ      const result = await sql.begin(async (tx) => {\n    50ŌåÆ        return emitEvent(\n    51ŌåÆ          tx as unknown as postgres.Sql,\n    52ŌåÆ          EventTypes.REFERRAL_GAME_SETTLED,\n    53ŌåÆ          payload,\n    54ŌåÆ        );\n    55ŌåÆ      });\n    56ŌåÆ\n    57ŌåÆ      expect(result.eventId).toBeTypeOf(\"bigint\");\n    58ŌåÆ      expect(result.eventId).toBeGreaterThan(0n);\n    59ŌåÆ\n    60ŌåÆ      // Verify the persisted row\n    61ŌåÆ      const rows = await sql`\n    62ŌåÆ        SELECT * FROM event_queue WHERE id = ${result.eventId.toString()}\n    63ŌåÆ      `;\n    64ŌåÆ      expect(rows).toHaveLength(1);\n    65ŌåÆ\n    66ŌåÆ      const row = rows[0]!;\n    67ŌåÆ      expect(row.event_type).toBe(\"referral.game_settled\");\n    68ŌåÆ      expect(row.payload).toEqual(payload);\n    69ŌåÆ      expect(row.status).toBe(\"pending\");\n    70ŌåÆ      expect(row.attempts).toBe(0);\n    71ŌåÆ      expect(row.max_attempts).toBe(3);\n    72ŌåÆ      expect(row.scheduled_at).toBeInstanceOf(Date);\n    73ŌåÆ      expect(row.created_at).toBeInstanceOf(Date);\n    74ŌåÆ    });\n    75ŌåÆ\n    76ŌåÆ    it(\"does NOT persist when transaction is rolled back\", async () => {\n    77ŌåÆ      let capturedId: bigint | undefined;\n    78ŌåÆ\n    79ŌåÆ      try {\n    80ŌåÆ        await sql.begin(async (tx) => {\n    81ŌåÆ          const result = await emitEvent(\n    82ŌåÆ            tx as unknown as postgres.Sql,\n    83ŌåÆ            EventTypes.REFERRAL_CODE_APPLIED,\n    84ŌåÆ            { test: true },\n    85ŌåÆ          );\n    86ŌåÆ          capturedId = result.eventId;\n    87ŌåÆ          throw new Error(\"intentional rollback\");\n    88ŌåÆ        });\n    89ŌåÆ      } catch {\n    90ŌåÆ        // Expected ŌĆö begin() re-throws after rollback\n    91ŌåÆ      }\n    92ŌåÆ\n    93ŌåÆ      expect(capturedId).toBeDefined();\n    94ŌåÆ      const rows = await sql`\n    95ŌåÆ        SELECT * FROM event_queue WHERE id = ${capturedId!.toString()}\n    96ŌåÆ      `;\n    97ŌåÆ      expect(rows).toHaveLength(0);\n    98ŌåÆ    });\n    99ŌåÆ\n   100ŌåÆ    it(\"respects custom maxAttempts and scheduledAt\", async () => {\n   101ŌåÆ      const future = new Date(Date.now() + 60_000);\n   102ŌåÆ\n   103ŌåÆ      const result = await sql.begin(async (tx) => {\n   104ŌåÆ        return emitEvent(\n   105ŌåÆ          tx as unknown as postgres.Sql,\n   106ŌåÆ          EventTypes.REFERRAL_CLAIM_REQUESTED,\n   107ŌåÆ          { foo: \"bar\" },\n   108ŌåÆ          { maxAttempts: 5, scheduledAt: future },\n   109ŌåÆ        );\n   110ŌåÆ      });\n   111ŌåÆ\n   112ŌåÆ      const rows = await sql`\n   113ŌåÆ        SELECT * FROM event_queue WHERE id = ${result.eventId.toString()}\n   114ŌåÆ      `;\n   115ŌåÆ      expect(rows[0]!.max_attempts).toBe(5);\n   116ŌåÆ      // scheduled_at should be close to the future date (within 1s tolerance)\n   117ŌåÆ      const diff = Math.abs(rows[0]!.scheduled_at.getTime() - future.getTime());\n   118ŌåÆ      expect(diff).toBeLessThan(1000);\n   119ŌåÆ    });\n   120ŌåÆ  });\n   121ŌåÆ\n   122ŌåÆ  // -------------------------------------------------------------------------\n   123ŌåÆ  // Handler registry\n   124ŌåÆ  // -------------------------------------------------------------------------\n   125ŌåÆ\n   126ŌåÆ  describe(\"handler registry\", () => {\n   127ŌåÆ    it(\"register ŌåÆ get returns the handler\", () => {\n   128ŌåÆ      const handler = async () => {};\n   129ŌåÆ      registerHandler(EventTypes.REFERRAL_GAME_SETTLED, handler);\n   130ŌåÆ      expect(getHandler(\"referral.game_settled\")).toBe(handler);\n   131ŌåÆ    });\n   132ŌåÆ\n   133ŌåÆ    it(\"get for unknown type returns undefined\", () => {\n   134ŌåÆ      expect(getHandler(\"unknown.event.type\")).toBeUndefined();\n   135ŌåÆ    });\n   136ŌåÆ  });\n   137ŌåÆ\n   138ŌåÆ  // -------------------------------------------------------------------------\n   139ŌåÆ  // Backoff calculation\n   140ŌåÆ  // -------------------------------------------------------------------------\n   141ŌåÆ\n   142ŌåÆ  describe(\"getBackoffSeconds\", () => {\n   143ŌåÆ    it(\"attempt 1 ŌåÆ 5 seconds\", () => {\n   144ŌåÆ      expect(getBackoffSeconds(1)).toBe(5);\n   145ŌåÆ    });\n   146ŌåÆ\n   147ŌåÆ    it(\"attempt 2 ŌåÆ 30 seconds\", () => {\n   148ŌåÆ      expect(getBackoffSeconds(2)).toBe(30);\n   149ŌåÆ    });\n   150ŌåÆ\n   151ŌåÆ    it(\"attempt 3+ ŌåÆ 300 seconds\", () => {\n   152ŌåÆ      expect(getBackoffSeconds(3)).toBe(300);\n   153ŌåÆ      expect(getBackoffSeconds(4)).toBe(300);\n   154ŌåÆ    });\n   155ŌåÆ  });\n   156ŌåÆ});\n   157ŌåÆ"}]},"parent_tool_use_id":"toolu_01TV6oB4zFLLycoW2yHnJ2sr","session_id":"a51b6cb4-cdb0-4e97-8a06-1ab74eb394f9","uuid":"39e186a2-1036-4878-ab39-fd045578fc7f","timestamp":"2026-03-25T12:07:20.534Z"}
