{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LoZL8c5a5YRh6DtunFERPe","type":"tool_result","content":"     1ŌåÆ/**\n     2ŌåÆ * Handler registry ŌĆö maps event type strings to handler functions.\n     3ŌåÆ *\n     4ŌåÆ * One handler per event type (no pub/sub fan-out for v1).\n     5ŌåÆ * Handlers must be idempotent ŌĆö re-processing is a safe no-op.\n     6ŌåÆ */\n     7ŌåÆ\n     8ŌåÆimport type { EventType } from \"./event-types.js\";\n     9ŌåÆ\n    10ŌåÆexport type EventHandler = (\n    11ŌåÆ  payload: Record<string, unknown>,\n    12ŌåÆ) => Promise<void>;\n    13ŌåÆ\n    14ŌåÆconst handlers = new Map<string, EventHandler>();\n    15ŌåÆ\n    16ŌåÆexport function registerHandler(\n    17ŌåÆ  eventType: EventType,\n    18ŌåÆ  handler: EventHandler,\n    19ŌåÆ): void {\n    20ŌåÆ  handlers.set(eventType, handler);\n    21ŌåÆ}\n    22ŌåÆ\n    23ŌåÆexport function getHandler(eventType: string): EventHandler | undefined {\n    24ŌåÆ  return handlers.get(eventType);\n    25ŌåÆ}\n    26ŌåÆ\n    27ŌåÆ/** Remove all registered handlers. Used by tests for isolation. */\n    28ŌåÆexport function clearHandlers(): void {\n    29ŌåÆ  handlers.clear();\n    30ŌåÆ}\n    31ŌåÆ"}]},"parent_tool_use_id":"toolu_01TV6oB4zFLLycoW2yHnJ2sr","session_id":"a51b6cb4-cdb0-4e97-8a06-1ab74eb394f9","uuid":"dec3c0bb-c61f-4a71-adcb-7e344efed250","timestamp":"2026-03-25T12:07:17.000Z"}
