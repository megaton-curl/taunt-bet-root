{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017VKEinCLhef7csjPmnxoAs","type":"tool_result","content":"     1ŌåÆ/**\n     2ŌåÆ * Queue health ŌĆö provides event counts by status for observability.\n     3ŌåÆ */\n     4ŌåÆ\n     5ŌåÆimport type postgres from \"postgres\";\n     6ŌåÆ\n     7ŌåÆexport interface QueueDepth {\n     8ŌåÆ  pending: number;\n     9ŌåÆ  processing: number;\n    10ŌåÆ  dead: number;\n    11ŌåÆ  completed: number;\n    12ŌåÆ}\n    13ŌåÆ\n    14ŌåÆexport async function getQueueDepth(sql: postgres.Sql): Promise<QueueDepth> {\n    15ŌåÆ  const rows = await sql<{ status: string; count: string }[]>`\n    16ŌåÆ    SELECT status, count(*)::text AS count\n    17ŌåÆ    FROM event_queue\n    18ŌåÆ    WHERE status IN ('pending', 'processing', 'dead', 'completed')\n    19ŌåÆ    GROUP BY status\n    20ŌåÆ  `;\n    21ŌåÆ\n    22ŌåÆ  const counts: QueueDepth = { pending: 0, processing: 0, dead: 0, completed: 0 };\n    23ŌåÆ  for (const row of rows) {\n    24ŌåÆ    if (row.status in counts) {\n    25ŌåÆ      counts[row.status as keyof QueueDepth] = parseInt(row.count, 10);\n    26ŌåÆ    }\n    27ŌåÆ  }\n    28ŌåÆ  return counts;\n    29ŌåÆ}\n    30ŌåÆ"}]},"parent_tool_use_id":"toolu_01TV6oB4zFLLycoW2yHnJ2sr","session_id":"a51b6cb4-cdb0-4e97-8a06-1ab74eb394f9","uuid":"f8da89e8-3126-4d92-ad17-8e729cd0411f","timestamp":"2026-03-25T12:07:27.837Z"}
