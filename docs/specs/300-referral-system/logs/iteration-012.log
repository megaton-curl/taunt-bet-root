{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R3J798VRrmprbLzqH4SiBs","type":"tool_result","content":"     1ŌåÆ/**\n     2ŌåÆ * Database client module ŌĆö typed query functions for `rounds` and `operator_events`.\n     3ŌåÆ *\n     4ŌåÆ * Phase transitions are unidirectional: created ŌåÆ locked ŌåÆ settling ŌåÆ settled,\n     5ŌåÆ * or created ŌåÆ expired. The application layer rejects backward transitions.\n     6ŌåÆ */\n     7ŌåÆ\n     8ŌåÆimport postgres from \"postgres\";\n     9ŌåÆ\n    10ŌåÆ// ---------------------------------------------------------------------------\n    11ŌåÆ// Types\n    12ŌåÆ// ---------------------------------------------------------------------------\n    13ŌåÆ\n    14ŌåÆexport type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    15ŌåÆ\n    16ŌåÆexport type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n    17ŌåÆexport type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n    18ŌåÆ\n    19ŌåÆexport interface CloseCallRound {\n    20ŌåÆ  round_id: string;\n    21ŌåÆ  pda: string;\n    22ŌåÆ  server_key: string;\n    23ŌåÆ  phase: CloseCallPhase;\n    24ŌåÆ  open_price: number;\n    25ŌåÆ  open_price_expo: number;\n    26ŌåÆ  close_price: number | null;\n    27ŌåÆ  outcome: CloseCallOutcome;\n    28ŌåÆ  green_pool: number;\n    29ŌåÆ  red_pool: number;\n    30ŌåÆ  total_fee: number;\n    31ŌåÆ  green_entries: Array<{ player: string; amountLamports: number }>;\n    32ŌåÆ  red_entries: Array<{ player: string; amountLamports: number }>;\n    33ŌåÆ  settle_tx: string | null;\n    34ŌåÆ  created_at: Date;\n    35ŌåÆ  settled_at: Date | null;\n    36ŌåÆ}\n    37ŌåÆ\n    38ŌåÆexport interface InsertCloseCallRoundParams {\n    39ŌåÆ  roundId: string;\n    40ŌåÆ  pda: string;\n    41ŌåÆ  serverKey: string;\n    42ŌåÆ  openPrice: number;\n    43ŌåÆ  openPriceExpo: number;\n    44ŌåÆ}\n    45ŌåÆ\n    46ŌåÆexport type OperatorEventType =\n    47ŌåÆ  | \"secret_generated\"\n    48ŌåÆ  | \"tx_built\"\n    49ŌåÆ  | \"match_detected\"\n    50ŌåÆ  | \"settle_submitted\"\n    51ŌåÆ  | \"settle_confirmed\"\n    52ŌåÆ  | \"settle_failed\"\n    53ŌåÆ  | \"settle_retried\"\n    54ŌåÆ  | \"timeout_detected\";\n    55ŌåÆ\n    56ŌåÆexport interface Round {\n    57ŌåÆ  pda: string;\n    58ŌåÆ  game: string;\n    59ŌåÆ  creator: string;\n    60ŌåÆ  server_key: string;\n    61ŌåÆ  secret: Buffer;\n    62ŌåÆ  commitment: Buffer;\n    63ŌåÆ  amount_lamports: number;\n    64ŌåÆ  side: number;\n    65ŌåÆ  match_id: string;\n    66ŌåÆ  phase: RoundPhase;\n    67ŌåÆ  target_slot: string | null;\n    68ŌåÆ  settle_tx: string | null;\n    69ŌåÆ  settle_attempts: number;\n    70ŌåÆ  result_hash: Buffer | null;\n    71ŌåÆ  result_side: number | null;\n    72ŌåÆ  winner: string | null;\n    73ŌåÆ  entries: unknown | null;\n    74ŌåÆ  created_at: Date;\n    75ŌåÆ  updated_at: Date;\n    76ŌåÆ}\n    77ŌåÆ\n    78ŌåÆexport interface InsertRoundParams {\n    79ŌåÆ  pda: string;\n    80ŌåÆ  game: string;\n    81ŌåÆ  creator: string;\n    82ŌåÆ  serverKey: string;\n    83ŌåÆ  secret: Buffer;\n    84ŌåÆ  commitment: Buffer;\n    85ŌåÆ  amountLamports: number;\n    86ŌåÆ  side: number;\n    87ŌåÆ  matchId: string;\n    88ŌåÆ  phase: RoundPhase;\n    89ŌåÆ  entries?: Array<{ player: string; amountLamports: number }>;\n    90ŌåÆ}\n    91ŌåÆ\n    92ŌåÆexport interface OperatorEvent {\n    93ŌåÆ  id: string;\n    94ŌåÆ  pda: string | null;\n    95ŌåÆ  event_type: OperatorEventType;\n    96ŌåÆ  payload: unknown;\n    97ŌåÆ  created_at: Date;\n    98ŌåÆ}\n    99ŌåÆ\n   100ŌåÆ// ---------------------------------------------------------------------------\n   101ŌåÆ// Transaction types\n   102ŌåÆ// ---------------------------------------------------------------------------\n   103ŌåÆ\n   104ŌåÆexport type TransactionType = \"deposit\" | \"payout\" | \"refund\";\n   105ŌåÆ\n   106ŌåÆexport interface Transaction {\n   107ŌåÆ  id: string;\n   108ŌåÆ  wallet: string;\n   109ŌåÆ  game: string;\n   110ŌåÆ  match_id: string;\n   111ŌåÆ  tx_type: TransactionType;\n   112ŌåÆ  amount_lamports: number;\n   113ŌåÆ  tx_sig: string;\n   114ŌåÆ  created_at: Date;\n   115ŌåÆ}\n   116ŌåÆ\n   117ŌåÆexport interface InsertTransactionParams {\n   118ŌåÆ  wallet: string;\n   119ŌåÆ  game: string;\n   120ŌåÆ  matchId: string;\n   121ŌåÆ  txType: TransactionType;\n   122ŌåÆ  amountLamports: number;\n   123ŌåÆ  txSig: string;\n   124ŌåÆ}\n   125ŌåÆ\n   126ŌåÆ// ---------------------------------------------------------------------------\n   127ŌåÆ// Referral types\n   128ŌåÆ// ---------------------------------------------------------------------------\n   129ŌåÆ\n   130ŌåÆexport interface ReferralCode {\n   131ŌåÆ  id: number;\n   132ŌåÆ  wallet: string;\n   133ŌåÆ  code: string;\n   134ŌåÆ  created_at: Date;\n   135ŌåÆ  updated_at: Date;\n   136ŌåÆ}\n   137ŌåÆ\n   138ŌåÆexport interface ReferralLink {\n   139ŌåÆ  id: number;\n   140ŌåÆ  referrer_wallet: string;\n   141ŌåÆ  referee_wallet: string;\n   142ŌåÆ  created_at: Date;\n   143ŌåÆ}\n   144ŌåÆ\n   145ŌåÆexport interface ReferralEarning {\n   146ŌåÆ  id: number;\n   147ŌåÆ  referrer_wallet: string;\n   148ŌåÆ  referee_wallet: string;\n   149ŌåÆ  round_id: string;\n   150ŌåÆ  game_type: string;\n   151ŌåÆ  wager_lamports: number;\n   152ŌåÆ  fee_lamports: number;\n   153ŌåÆ  referrer_earned_lamports: number;\n   154ŌåÆ  referrer_rate_bps: number;\n   155ŌåÆ  referee_rebate_lamports: number;\n   156ŌåÆ  referee_rebate_rate_bps: number;\n   157ŌåÆ  created_at: Date;\n   158ŌåÆ}\n   159ŌåÆ\n   160ŌåÆexport interface ReferralStats {\n   161ŌåÆ  referred_count: number;\n   162ŌåÆ  active_count: number;\n   163ŌåÆ  total_volume_lamports: string;\n   164ŌåÆ  total_earned_lamports: string;\n   165ŌåÆ  pending_lamports: string;\n   166ŌåÆ}\n   167ŌåÆ\n   168ŌåÆexport interface ReferralClaim {\n   169ŌåÆ  id: string;\n   170ŌåÆ  wallet: string;\n   171ŌåÆ  amount_lamports: string;\n   172ŌåÆ  status: \"pending\" | \"processing\" | \"completed\" | \"failed\";\n   173ŌåÆ  tx_signature: string | null;\n   174ŌåÆ  error: string | null;\n   175ŌåÆ  requested_at: Date;\n   176ŌåÆ  processed_at: Date | null;\n   177ŌåÆ}\n   178ŌåÆ\n   179ŌåÆ// ---------------------------------------------------------------------------\n   180ŌåÆ// Phase transition guard\n   181ŌåÆ// ---------------------------------------------------------------------------\n   182ŌåÆ\n   183ŌåÆ/** Valid transitions: createdŌåÆlocked, lockedŌåÆsettling, settlingŌåÆsettled, createdŌåÆexpired */\n   184ŌåÆconst VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n   185ŌåÆ  created: [\"locked\", \"expired\"],\n   186ŌåÆ  locked: [\"settling\"],\n   187ŌåÆ  settling: [\"settled\"],\n   188ŌåÆ  settled: [],\n   189ŌåÆ  expired: [],\n   190ŌåÆ};\n   191ŌåÆ\n   192ŌåÆfunction assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n   193ŌåÆ  const allowed = VALID_TRANSITIONS[from];\n   194ŌåÆ  if (!allowed.includes(to)) {\n   195ŌåÆ    throw new Error(\n   196ŌåÆ      `Invalid phase transition: ${from} ŌåÆ ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n   197ŌåÆ    );\n   198ŌåÆ  }\n   199ŌåÆ}\n   200ŌåÆ\n   201ŌåÆ// ---------------------------------------------------------------------------\n   202ŌåÆ// DB client\n   203ŌåÆ// ---------------------------------------------------------------------------\n   204ŌåÆ\n   205ŌåÆexport interface Db {\n   206ŌåÆ  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n   207ŌåÆ  insertRound(params: InsertRoundParams): Promise<Round>;\n   208ŌåÆ\n   209ŌåÆ  /** Delete a round by PDA. Returns true if a row was removed. */\n   210ŌåÆ  deleteRoundByPda(pda: string): Promise<boolean>;\n   211ŌåÆ\n   212ŌåÆ  /** Transition a round's phase. Enforces unidirectional state machine.\n   213ŌåÆ   *  Optional `updates` can set additional columns alongside the phase change. */\n   214ŌåÆ  updateRoundPhase(\n   215ŌåÆ    pda: string,\n   216ŌåÆ    newPhase: RoundPhase,\n   217ŌåÆ    updates?: Partial<\n   218ŌåÆ      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n   219ŌåÆ    >,\n   220ŌåÆ  ): Promise<Round>;\n   221ŌåÆ\n   222ŌåÆ  /** Update the entries JSONB column for a settled round. */\n   223ŌåÆ  updateRoundEntries(\n   224ŌåÆ    pda: string,\n   225ŌåÆ    entries: Array<{ player: string; amountLamports: number }>,\n   226ŌåÆ  ): Promise<Round>;\n   227ŌåÆ\n   228ŌåÆ  /** Get a single round by its PDA. Returns `undefined` if not found. */\n   229ŌåÆ  getRoundByPda(pda: string): Promise<Round | undefined>;\n   230ŌåÆ\n   231ŌåÆ  /** Get all rounds matching a given phase. */\n   232ŌåÆ  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n   233ŌåÆ\n   234ŌåÆ  /** Append an operator event to the audit log. */\n   235ŌåÆ  insertOperatorEvent(\n   236ŌåÆ    pda: string | null,\n   237ŌåÆ    eventType: OperatorEventType,\n   238ŌåÆ    payload?: unknown,\n   239ŌåÆ  ): Promise<OperatorEvent>;\n   240ŌåÆ\n   241ŌåÆ  /** Get the latest operator event for a PDA + type. */\n   242ŌåÆ  getLatestOperatorEvent(\n   243ŌåÆ    pda: string,\n   244ŌåÆ    eventType: OperatorEventType,\n   245ŌåÆ  ): Promise<OperatorEvent | undefined>;\n   246ŌåÆ\n   247ŌåÆ  /** Get a single round by its match_id. Returns `undefined` if not found. */\n   248ŌåÆ  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n   249ŌåÆ\n   250ŌåÆ  /** Batch-fetch the latest operator event per PDA for a given event type. */\n   251ŌåÆ  getLatestOperatorEventsForPdas(\n   252ŌåÆ    pdas: string[],\n   253ŌåÆ    eventType: OperatorEventType,\n   254ŌåÆ  ): Promise<Map<string, OperatorEvent>>;\n   255ŌåÆ\n   256ŌåÆ  /** Get recently settled rounds for a game, ordered newest first. */\n   257ŌåÆ  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n   258ŌåÆ\n   259ŌåÆ  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n   260ŌåÆ  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n   261ŌåÆ\n   262ŌåÆ  // -------------------------------------------------------------------------\n   263ŌåÆ  // Close Call rounds\n   264ŌåÆ  // -------------------------------------------------------------------------\n   265ŌåÆ\n   266ŌåÆ  /** Insert a new Close Call round. */\n   267ŌåÆ  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n   268ŌåÆ\n   269ŌåÆ  /** Get a Close Call round by round_id (16-char hex). */\n   270ŌåÆ  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n   271ŌåÆ\n   272ŌåÆ  /** Get the current active (open) Close Call round. */\n   273ŌåÆ  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n   274ŌåÆ\n   275ŌåÆ  /** Get the most recent settled/refunded Close Call rounds. */\n   276ŌåÆ  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n   277ŌåÆ\n   278ŌåÆ  /** Update a Close Call round after settlement. */\n   279ŌåÆ  settleCloseCallRound(\n   280ŌåÆ    roundId: string,\n   281ŌåÆ    updates: {\n   282ŌåÆ      phase: CloseCallPhase;\n   283ŌåÆ      outcome: CloseCallOutcome;\n   284ŌåÆ      closePrice?: number;\n   285ŌåÆ      greenPool?: number;\n   286ŌåÆ      redPool?: number;\n   287ŌåÆ      totalFee?: number;\n   288ŌåÆ      greenEntries?: Array<{ player: string; amountLamports: number }>;\n   289ŌåÆ      redEntries?: Array<{ player: string; amountLamports: number }>;\n   290ŌåÆ      settleTx?: string;\n   291ŌåÆ    },\n   292ŌåÆ  ): Promise<CloseCallRound>;\n   293ŌåÆ\n   294ŌåÆ  // -------------------------------------------------------------------------\n   295ŌåÆ  // Transactions\n   296ŌåÆ  // -------------------------------------------------------------------------\n   297ŌåÆ\n   298ŌåÆ  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n   299ŌåÆ  insertTransaction(params: InsertTransactionParams): Promise<void>;\n   300ŌåÆ\n   301ŌåÆ  /** Insert multiple transactions in a single batch. */\n   302ŌåÆ  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n   303ŌåÆ\n   304ŌåÆ  /** Get paginated transactions for a wallet, newest first. */\n   305ŌåÆ  getTransactions(\n   306ŌåÆ    wallet: string,\n   307ŌåÆ    cursor?: string,\n   308ŌåÆ    limit?: number,\n   309ŌåÆ    game?: string,\n   310ŌåÆ  ): Promise<Transaction[]>;\n   311ŌåÆ\n   312ŌåÆ  // -------------------------------------------------------------------------\n   313ŌåÆ  // Referral ŌĆö codes\n   314ŌåÆ  // -------------------------------------------------------------------------\n   315ŌåÆ\n   316ŌåÆ  /** Insert a new referral code for a wallet. Throws on duplicate wallet or code. */\n   317ŌåÆ  insertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n   318ŌåÆ\n   319ŌåÆ  /** Get a wallet's referral code. Returns `undefined` if none set. */\n   320ŌåÆ  getReferralCodeByWallet(wallet: string): Promise<ReferralCode | undefined>;\n   321ŌåÆ\n   322ŌåÆ  /** Look up a referral code record by code string. Returns `undefined` if not found. */\n   323ŌåÆ  getReferralCodeByCode(code: string): Promise<ReferralCode | undefined>;\n   324ŌåÆ\n   325ŌåÆ  /** Set or replace a wallet's referral code (INSERT ŌĆ” ON CONFLICT UPDATE). */\n   326ŌåÆ  upsertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n   327ŌåÆ\n   328ŌåÆ  // -------------------------------------------------------------------------\n   329ŌåÆ  // Referral ŌĆö links\n   330ŌåÆ  // -------------------------------------------------------------------------\n   331ŌåÆ\n   332ŌåÆ  /** Create a referral link (referrer ŌåÆ referee). Throws on duplicate referee. */\n   333ŌåÆ  insertReferralLink(referrerWallet: string, refereeWallet: string): Promise<ReferralLink>;\n   334ŌåÆ\n   335ŌåÆ  /** Get the referral link for a referee wallet. Returns `undefined` if not referred. */\n   336ŌåÆ  getReferralLinkByReferee(refereeWallet: string): Promise<ReferralLink | undefined>;\n   337ŌåÆ\n   338ŌåÆ  /** Get all referral links where the given wallet is the referrer. */\n   339ŌåÆ  getReferralLinksByReferrer(referrerWallet: string): Promise<ReferralLink[]>;\n   340ŌåÆ\n   341ŌåÆ  // -------------------------------------------------------------------------\n   342ŌåÆ  // Referral ŌĆö earnings & stats\n   343ŌåÆ  // -------------------------------------------------------------------------\n   344ŌåÆ\n   345ŌåÆ  /** Insert a referral earning row. Throws on duplicate (referee_wallet, round_id). */\n   346ŌåÆ  insertReferralEarning(params: {\n   347ŌåÆ    referrerWallet: string;\n   348ŌåÆ    refereeWallet: string;\n   349ŌåÆ    roundId: string;\n   350ŌåÆ    gameType: string;\n   351ŌåÆ    wagerLamports: number;\n   352ŌåÆ    feeLamports: number;\n   353ŌåÆ    referrerEarnedLamports: number;\n   354ŌåÆ    referrerRateBps: number;\n   355ŌåÆ    refereeRebateLamports: number;\n   356ŌåÆ    refereeRebateRateBps: number;\n   357ŌåÆ  }): Promise<ReferralEarning>;\n   358ŌåÆ\n   359ŌåÆ  /**\n   360ŌåÆ   * Get the pending (unclaimed) balance for a wallet.\n   361ŌåÆ   * Sum of referrer_earned where wallet=referrer + sum of referee_rebate where\n   362ŌåÆ   * wallet=referee, minus sum of completed claims for the wallet.\n   363ŌåÆ   * Returns a lamport string.\n   364ŌåÆ   */\n   365ŌåÆ  getPendingBalance(wallet: string): Promise<string>;\n   366ŌåÆ\n   367ŌåÆ  /** Get paginated per-game earnings for a wallet (as referrer). Newest first. */\n   368ŌåÆ  getReferralEarnings(\n   369ŌåÆ    wallet: string,\n   370ŌåÆ    page: number,\n   371ŌåÆ    limit: number,\n   372ŌåÆ  ): Promise<{ items: ReferralEarning[]; totalPages: number }>;\n   373ŌåÆ\n   374ŌåÆ  /** Get referral summary stats for a wallet. */\n   375ŌåÆ  getReferralStats(wallet: string): Promise<ReferralStats>;\n   376ŌåÆ\n   377ŌåÆ  // -------------------------------------------------------------------------\n   378ŌåÆ  // Referral ŌĆö claims & rates\n   379ŌåÆ  // -------------------------------------------------------------------------\n   380ŌåÆ\n   381ŌåÆ  /** Insert a new referral claim row (status defaults to 'pending'). Returns the created claim. */\n   382ŌåÆ  insertReferralClaim(\n   383ŌåÆ    wallet: string,\n   384ŌåÆ    amountLamports: string,\n   385ŌåÆ  ): Promise<ReferralClaim>;\n   386ŌåÆ\n   387ŌåÆ  /** Get a referral claim by its UUID. Returns `undefined` if not found. */\n   388ŌåÆ  getReferralClaim(claimId: string): Promise<ReferralClaim | undefined>;\n   389ŌåÆ\n   390ŌåÆ  /**\n   391ŌåÆ   * Update a claim's status and optional metadata (tx_signature, error, processed_at).\n   392ŌåÆ   * Returns the updated claim.\n   393ŌåÆ   */\n   394ŌåÆ  updateClaimStatus(\n   395ŌåÆ    claimId: string,\n   396ŌåÆ    status: ReferralClaim[\"status\"],\n   397ŌåÆ    meta?: { txSignature?: string; error?: string },\n   398ŌåÆ  ): Promise<ReferralClaim>;\n   399ŌåÆ\n   400ŌåÆ  /**\n   401ŌåÆ   * Get the effective referrer rate for a wallet in bps.\n   402ŌåÆ   * Checks `referral_kol_rates` first; falls back to `defaultRateBps`.\n   403ŌåÆ   */\n   404ŌåÆ  getReferrerRate(\n   405ŌåÆ    wallet: string,\n   406ŌåÆ    defaultRateBps: number,\n   407ŌåÆ  ): Promise<number>;\n   408ŌåÆ\n   409ŌåÆ  /** Gracefully close the connection pool. */\n   410ŌåÆ  close(): Promise<void>;\n   411ŌåÆ}\n   412ŌåÆ\n   413ŌåÆfunction normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n   414ŌåÆ  return {\n   415ŌåÆ    ...row,\n   416ŌåÆ    open_price: Number(row.open_price),\n   417ŌåÆ    open_price_expo: Number(row.open_price_expo),\n   418ŌåÆ    close_price: row.close_price === null ? null : Number(row.close_price),\n   419ŌåÆ    green_pool: Number(row.green_pool),\n   420ŌåÆ    red_pool: Number(row.red_pool),\n   421ŌåÆ    total_fee: Number(row.total_fee),\n   422ŌåÆ    // JSONB comes back as parsed objects from postgres.js\n   423ŌåÆ    green_entries: Array.isArray(row.green_entries)\n   424ŌåÆ      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   425ŌåÆ      : [],\n   426ŌåÆ    red_entries: Array.isArray(row.red_entries)\n   427ŌåÆ      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   428ŌåÆ      : [],\n   429ŌåÆ  };\n   430ŌåÆ}\n   431ŌåÆ\n   432ŌåÆfunction normalizeTransaction(row: Transaction): Transaction {\n   433ŌåÆ  return {\n   434ŌåÆ    ...row,\n   435ŌåÆ    amount_lamports: Number(row.amount_lamports),\n   436ŌåÆ  };\n   437ŌåÆ}\n   438ŌåÆ\n   439ŌåÆfunction normalizeReferralEarning(row: ReferralEarning): ReferralEarning {\n   440ŌåÆ  return {\n   441ŌåÆ    ...row,\n   442ŌåÆ    wager_lamports: Number(row.wager_lamports),\n   443ŌåÆ    fee_lamports: Number(row.fee_lamports),\n   444ŌåÆ    referrer_earned_lamports: Number(row.referrer_earned_lamports),\n   445ŌåÆ    referrer_rate_bps: Number(row.referrer_rate_bps),\n   446ŌåÆ    referee_rebate_lamports: Number(row.referee_rebate_lamports),\n   447ŌåÆ    referee_rebate_rate_bps: Number(row.referee_rebate_rate_bps),\n   448ŌåÆ  };\n   449ŌåÆ}\n   450ŌåÆ\n   451ŌåÆfunction normalizeRound(row: Round): Round {\n   452ŌåÆ  return {\n   453ŌåÆ    ...row,\n   454ŌåÆ    amount_lamports: Number(row.amount_lamports),\n   455ŌåÆ    side: Number(row.side),\n   456ŌåÆ    settle_attempts: Number(row.settle_attempts),\n   457ŌåÆ    result_side: row.result_side === null ? null : Number(row.result_side),\n   458ŌåÆ    // JSONB comes back as parsed objects from postgres.js\n   459ŌåÆ    entries: Array.isArray(row.entries)\n   460ŌåÆ      ? (row.entries as Array<{ player: string; amountLamports: number }>).map((e) => ({\n   461ŌåÆ          player: e.player,\n   462ŌåÆ          amountLamports: Number(e.amountLamports),\n   463ŌåÆ        }))\n   464ŌåÆ      : null,\n   465ŌåÆ  };\n   466ŌåÆ}\n   467ŌåÆ\n   468ŌåÆexport function createDb(databaseUrl: string): Db {\n   469ŌåÆ  const sql = postgres(databaseUrl);\n   470ŌåÆ\n   471ŌåÆ  return {\n   472ŌåÆ    async insertRound(params) {\n   473ŌåÆ      const rows = await sql<Round[]>`\n   474ŌåÆ        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase, entries)\n   475ŌåÆ        VALUES (\n   476ŌåÆ          ${params.pda},\n   477ŌåÆ          ${params.game},\n   478ŌåÆ          ${params.creator},\n   479ŌåÆ          ${params.serverKey},\n   480ŌåÆ          ${params.secret},\n   481ŌåÆ          ${params.commitment},\n   482ŌåÆ          ${params.amountLamports},\n   483ŌåÆ          ${params.side},\n   484ŌåÆ          ${params.matchId},\n   485ŌåÆ          ${params.phase},\n   486ŌåÆ          ${params.entries ? sql.json(params.entries) : null}\n   487ŌåÆ        )\n   488ŌåÆ        RETURNING *\n   489ŌåÆ      `;\n   490ŌåÆ      return normalizeRound(rows[0]!);\n   491ŌåÆ    },\n   492ŌåÆ\n   493ŌåÆ    async deleteRoundByPda(pda) {\n   494ŌåÆ      const rows = await sql<{ pda: string }[]>`\n   495ŌåÆ        DELETE FROM rounds WHERE pda = ${pda}\n   496ŌåÆ        RETURNING pda\n   497ŌåÆ      `;\n   498ŌåÆ      return rows.length > 0;\n   499ŌåÆ    },\n   500ŌåÆ\n   501ŌåÆ    async updateRoundPhase(pda, newPhase, updates) {\n   502ŌåÆ      // Fetch current phase to validate transition\n   503ŌåÆ      const current = await sql<Pick<Round, \"phase\">[]>`\n   504ŌåÆ        SELECT phase FROM rounds WHERE pda = ${pda}\n   505ŌåÆ      `;\n   506ŌåÆ\n   507ŌåÆ      if (current.length === 0) {\n   508ŌåÆ        throw new Error(`Round not found: ${pda}`);\n   509ŌåÆ      }\n   510ŌåÆ\n   511ŌåÆ      const currentPhase = current[0]!.phase as RoundPhase;\n   512ŌåÆ      assertPhaseTransition(currentPhase, newPhase);\n   513ŌåÆ\n   514ŌåÆ      // Build the update ŌĆö always set phase + updated_at\n   515ŌåÆ      const rows = await sql<Round[]>`\n   516ŌåÆ        UPDATE rounds SET\n   517ŌåÆ          phase = ${newPhase},\n   518ŌåÆ          updated_at = now(),\n   519ŌåÆ          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n   520ŌåÆ          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n   521ŌåÆ          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n   522ŌåÆ          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n   523ŌåÆ          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n   524ŌåÆ          winner = COALESCE(${updates?.winner ?? null}, winner)\n   525ŌåÆ        WHERE pda = ${pda}\n   526ŌåÆ        RETURNING *\n   527ŌåÆ      `;\n   528ŌåÆ\n   529ŌåÆ      return normalizeRound(rows[0]!);\n   530ŌåÆ    },\n   531ŌåÆ\n   532ŌåÆ    async updateRoundEntries(pda, entries) {\n   533ŌåÆ      const rows = await sql<Round[]>`\n   534ŌåÆ        UPDATE rounds SET\n   535ŌåÆ          entries = ${sql.json(entries)},\n   536ŌåÆ          updated_at = now()\n   537ŌåÆ        WHERE pda = ${pda}\n   538ŌåÆ        RETURNING *\n   539ŌåÆ      `;\n   540ŌåÆ      if (rows.length === 0) {\n   541ŌåÆ        throw new Error(`Round not found: ${pda}`);\n   542ŌåÆ      }\n   543ŌåÆ      return normalizeRound(rows[0]!);\n   544ŌåÆ    },\n   545ŌåÆ\n   546ŌåÆ    async getRoundByPda(pda) {\n   547ŌåÆ      const rows = await sql<Round[]>`\n   548ŌåÆ        SELECT * FROM rounds WHERE pda = ${pda}\n   549ŌåÆ      `;\n   550ŌåÆ      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   551ŌåÆ    },\n   552ŌåÆ\n   553ŌåÆ    async getRoundByMatchId(matchId) {\n   554ŌåÆ      const rows = await sql<Round[]>`\n   555ŌåÆ        SELECT * FROM rounds WHERE match_id = ${matchId}\n   556ŌåÆ      `;\n   557ŌåÆ      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   558ŌåÆ    },\n   559ŌåÆ\n   560ŌåÆ    async getRoundsByPhase(phase) {\n   561ŌåÆ      const rows = await sql<Round[]>`\n   562ŌåÆ        SELECT * FROM rounds WHERE phase = ${phase}\n   563ŌåÆ      `;\n   564ŌåÆ      return rows.map(normalizeRound);\n   565ŌåÆ    },\n   566ŌåÆ\n   567ŌåÆ    async insertOperatorEvent(pda, eventType, payload) {\n   568ŌåÆ      const rows = await sql<OperatorEvent[]>`\n   569ŌåÆ        INSERT INTO operator_events (pda, event_type, payload)\n   570ŌåÆ        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n   571ŌåÆ        RETURNING *\n   572ŌåÆ      `;\n   573ŌåÆ      return rows[0]!;\n   574ŌåÆ    },\n   575ŌåÆ\n   576ŌåÆ    async getLatestOperatorEvent(pda, eventType) {\n   577ŌåÆ      const rows = await sql<OperatorEvent[]>`\n   578ŌåÆ        SELECT * FROM operator_events\n   579ŌåÆ        WHERE pda = ${pda} AND event_type = ${eventType}\n   580ŌåÆ        ORDER BY id DESC\n   581ŌåÆ        LIMIT 1\n   582ŌåÆ      `;\n   583ŌåÆ      return rows[0];\n   584ŌåÆ    },\n   585ŌåÆ\n   586ŌåÆ    async getLatestOperatorEventsForPdas(pdas, eventType) {\n   587ŌåÆ      if (pdas.length === 0) return new Map();\n   588ŌåÆ      const rows = await sql<OperatorEvent[]>`\n   589ŌåÆ        SELECT DISTINCT ON (pda) *\n   590ŌåÆ        FROM operator_events\n   591ŌåÆ        WHERE pda = ANY(${pdas}) AND event_type = ${eventType}\n   592ŌåÆ        ORDER BY pda, id DESC\n   593ŌåÆ      `;\n   594ŌåÆ      const map = new Map<string, OperatorEvent>();\n   595ŌåÆ      for (const row of rows) {\n   596ŌåÆ        if (row.pda) map.set(row.pda, row);\n   597ŌåÆ      }\n   598ŌåÆ      return map;\n   599ŌåÆ    },\n   600ŌåÆ\n   601ŌåÆ    async getRecentSettledRounds(game, limit) {\n   602ŌåÆ      const rows = await sql<Round[]>`\n   603ŌåÆ        SELECT * FROM rounds\n   604ŌåÆ        WHERE game = ${game} AND phase = 'settled'\n   605ŌåÆ        ORDER BY updated_at DESC\n   606ŌåÆ        LIMIT ${limit}\n   607ŌåÆ      `;\n   608ŌåÆ      return rows.map(normalizeRound);\n   609ŌåÆ    },\n   610ŌåÆ\n   611ŌåÆ    async getUnsettledStats() {\n   612ŌåÆ      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n   613ŌåÆ        SELECT\n   614ŌåÆ          COUNT(*)::text AS count,\n   615ŌåÆ          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n   616ŌåÆ        FROM rounds\n   617ŌåÆ        WHERE phase NOT IN ('settled', 'expired')\n   618ŌåÆ      `;\n   619ŌåÆ      const row = rows[0]!;\n   620ŌåÆ      return {\n   621ŌåÆ        count: parseInt(row.count, 10),\n   622ŌåÆ        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n   623ŌåÆ      };\n   624ŌåÆ    },\n   625ŌåÆ\n   626ŌåÆ    // -----------------------------------------------------------------------\n   627ŌåÆ    // Close Call rounds\n   628ŌåÆ    // -----------------------------------------------------------------------\n   629ŌåÆ\n   630ŌåÆ    async insertCloseCallRound(params) {\n   631ŌåÆ      const rows = await sql<CloseCallRound[]>`\n   632ŌåÆ        INSERT INTO closecall_rounds (round_id, pda, server_key, open_price, open_price_expo)\n   633ŌåÆ        VALUES (\n   634ŌåÆ          ${params.roundId},\n   635ŌåÆ          ${params.pda},\n   636ŌåÆ          ${params.serverKey},\n   637ŌåÆ          ${params.openPrice},\n   638ŌåÆ          ${params.openPriceExpo}\n   639ŌåÆ        )\n   640ŌåÆ        RETURNING *\n   641ŌåÆ      `;\n   642ŌåÆ      return normalizeCloseCallRound(rows[0]!);\n   643ŌåÆ    },\n   644ŌåÆ\n   645ŌåÆ    async getCloseCallRound(roundId) {\n   646ŌåÆ      const rows = await sql<CloseCallRound[]>`\n   647ŌåÆ        SELECT * FROM closecall_rounds WHERE round_id = ${roundId}\n   648ŌåÆ      `;\n   649ŌåÆ      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n   650ŌåÆ    },\n   651ŌåÆ\n   652ŌåÆ    async getCloseCallCurrentRound() {\n   653ŌåÆ      const rows = await sql<CloseCallRound[]>`\n   654ŌåÆ        SELECT * FROM closecall_rounds\n   655ŌåÆ        WHERE phase = 'open'\n   656ŌåÆ        ORDER BY created_at DESC\n   657ŌåÆ        LIMIT 1\n   658ŌåÆ      `;\n   659ŌåÆ      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n   660ŌåÆ    },\n   661ŌåÆ\n   662ŌåÆ    async getCloseCallHistory(limit) {\n   663ŌåÆ      const rows = await sql<CloseCallRound[]>`\n   664ŌåÆ        SELECT * FROM closecall_rounds\n   665ŌåÆ        WHERE phase IN ('settled', 'refunded')\n   666ŌåÆ        ORDER BY settled_at DESC\n   667ŌåÆ        LIMIT ${limit}\n   668ŌåÆ      `;\n   669ŌåÆ      return rows.map(normalizeCloseCallRound);\n   670ŌåÆ    },\n   671ŌåÆ\n   672ŌåÆ    async settleCloseCallRound(roundId, updates) {\n   673ŌåÆ      const rows = await sql<CloseCallRound[]>`\n   674ŌåÆ        UPDATE closecall_rounds SET\n   675ŌåÆ          phase = ${updates.phase},\n   676ŌåÆ          outcome = ${updates.outcome},\n   677ŌåÆ          close_price = COALESCE(${updates.closePrice ?? null}, close_price),\n   678ŌåÆ          green_pool = COALESCE(${updates.greenPool ?? null}, green_pool),\n   679ŌåÆ          red_pool = COALESCE(${updates.redPool ?? null}, red_pool),\n   680ŌåÆ          total_fee = COALESCE(${updates.totalFee ?? null}, total_fee),\n   681ŌåÆ          green_entries = COALESCE(${updates.greenEntries ? sql.json(updates.greenEntries) : null}, green_entries),\n   682ŌåÆ          red_entries = COALESCE(${updates.redEntries ? sql.json(updates.redEntries) : null}, red_entries),\n   683ŌåÆ          settle_tx = COALESCE(${updates.settleTx ?? null}, settle_tx),\n   684ŌåÆ          settled_at = now()\n   685ŌåÆ        WHERE round_id = ${roundId}\n   686ŌåÆ        RETURNING *\n   687ŌåÆ      `;\n   688ŌåÆ      if (rows.length === 0) {\n   689ŌåÆ        throw new Error(`Close Call round not found: ${roundId}`);\n   690ŌåÆ      }\n   691ŌåÆ      return normalizeCloseCallRound(rows[0]!);\n   692ŌåÆ    },\n   693ŌåÆ\n   694ŌåÆ    // -----------------------------------------------------------------------\n   695ŌåÆ    // Transactions\n   696ŌåÆ    // -----------------------------------------------------------------------\n   697ŌåÆ\n   698ŌåÆ    async insertTransaction(params) {\n   699ŌåÆ      await sql`\n   700ŌåÆ        INSERT INTO transactions (wallet, game, match_id, tx_type, amount_lamports, tx_sig)\n   701ŌåÆ        VALUES (\n   702ŌåÆ          ${params.wallet},\n   703ŌåÆ          ${params.game},\n   704ŌåÆ          ${params.matchId},\n   705ŌåÆ          ${params.txType},\n   706ŌåÆ          ${params.amountLamports},\n   707ŌåÆ          ${params.txSig}\n   708ŌåÆ        )\n   709ŌåÆ        ON CONFLICT DO NOTHING\n   710ŌåÆ      `;\n   711ŌåÆ    },\n   712ŌåÆ\n   713ŌåÆ    async insertTransactions(params) {\n   714ŌåÆ      if (params.length === 0) return;\n   715ŌåÆ      const values = params.map((p) => ({\n   716ŌåÆ        wallet: p.wallet,\n   717ŌåÆ        game: p.game,\n   718ŌåÆ        match_id: p.matchId,\n   719ŌåÆ        tx_type: p.txType,\n   720ŌåÆ        amount_lamports: p.amountLamports,\n   721ŌåÆ        tx_sig: p.txSig,\n   722ŌåÆ      }));\n   723ŌåÆ      await sql`\n   724ŌåÆ        INSERT INTO transactions ${sql(values, \"wallet\", \"game\", \"match_id\", \"tx_type\", \"amount_lamports\", \"tx_sig\")}\n   725ŌåÆ        ON CONFLICT DO NOTHING\n   726ŌåÆ      `;\n   727ŌåÆ    },\n   728ŌåÆ\n   729ŌåÆ    async getTransactions(wallet, cursor, limit = 20, game) {\n   730ŌåÆ      const effectiveLimit = Math.min(limit, 50);\n   731ŌåÆ      if (cursor && game) {\n   732ŌåÆ        const rows = await sql<Transaction[]>`\n   733ŌåÆ          SELECT * FROM transactions\n   734ŌåÆ          WHERE wallet = ${wallet} AND id < ${cursor} AND game = ${game}\n   735ŌåÆ          ORDER BY id DESC\n   736ŌåÆ          LIMIT ${effectiveLimit}\n   737ŌåÆ        `;\n   738ŌåÆ        return rows.map(normalizeTransaction);\n   739ŌåÆ      }\n   740ŌåÆ      if (cursor) {\n   741ŌåÆ        const rows = await sql<Transaction[]>`\n   742ŌåÆ          SELECT * FROM transactions\n   743ŌåÆ          WHERE wallet = ${wallet} AND id < ${cursor}\n   744ŌåÆ          ORDER BY id DESC\n   745ŌåÆ          LIMIT ${effectiveLimit}\n   746ŌåÆ        `;\n   747ŌåÆ        return rows.map(normalizeTransaction);\n   748ŌåÆ      }\n   749ŌåÆ      if (game) {\n   750ŌåÆ        const rows = await sql<Transaction[]>`\n   751ŌåÆ          SELECT * FROM transactions\n   752ŌåÆ          WHERE wallet = ${wallet} AND game = ${game}\n   753ŌåÆ          ORDER BY id DESC\n   754ŌåÆ          LIMIT ${effectiveLimit}\n   755ŌåÆ        `;\n   756ŌåÆ        return rows.map(normalizeTransaction);\n   757ŌåÆ      }\n   758ŌåÆ      const rows = await sql<Transaction[]>`\n   759ŌåÆ        SELECT * FROM transactions\n   760ŌåÆ        WHERE wallet = ${wallet}\n   761ŌåÆ        ORDER BY id DESC\n   762ŌåÆ        LIMIT ${effectiveLimit}\n   763ŌåÆ      `;\n   764ŌåÆ      return rows.map(normalizeTransaction);\n   765ŌåÆ    },\n   766ŌåÆ\n   767ŌåÆ    // -----------------------------------------------------------------------\n   768ŌåÆ    // Referral ŌĆö codes\n   769ŌåÆ    // -----------------------------------------------------------------------\n   770ŌåÆ\n   771ŌåÆ    async insertReferralCode(wallet, code) {\n   772ŌåÆ      const rows = await sql<ReferralCode[]>`\n   773ŌåÆ        INSERT INTO referral_codes (wallet, code)\n   774ŌåÆ        VALUES (${wallet}, ${code})\n   775ŌåÆ        RETURNING *\n   776ŌåÆ      `;\n   777ŌåÆ      return rows[0]!;\n   778ŌåÆ    },\n   779ŌåÆ\n   780ŌåÆ    async getReferralCodeByWallet(wallet) {\n   781ŌåÆ      const rows = await sql<ReferralCode[]>`\n   782ŌåÆ        SELECT * FROM referral_codes WHERE wallet = ${wallet}\n   783ŌåÆ      `;\n   784ŌåÆ      return rows[0];\n   785ŌåÆ    },\n   786ŌåÆ\n   787ŌåÆ    async getReferralCodeByCode(code) {\n   788ŌåÆ      const rows = await sql<ReferralCode[]>`\n   789ŌåÆ        SELECT * FROM referral_codes WHERE code = ${code}\n   790ŌåÆ      `;\n   791ŌåÆ      return rows[0];\n   792ŌåÆ    },\n   793ŌåÆ\n   794ŌåÆ    async upsertReferralCode(wallet, code) {\n   795ŌåÆ      const rows = await sql<ReferralCode[]>`\n   796ŌåÆ        INSERT INTO referral_codes (wallet, code)\n   797ŌåÆ        VALUES (${wallet}, ${code})\n   798ŌåÆ        ON CONFLICT (wallet) DO UPDATE SET\n   799Ōå