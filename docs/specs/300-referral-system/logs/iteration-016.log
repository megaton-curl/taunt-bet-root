{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QFmvspMpq55LBzFDUcPFAD","type":"tool_result","content":"     1→import { Hono } from \"hono\";\n     2→import { cors } from \"hono/cors\";\n     3→import { serve } from \"@hono/node-server\";\n     4→import { Connection, PublicKey } from \"@solana/web3.js\";\n     5→import postgres from \"postgres\";\n     6→import { loadConfig } from \"./config.js\";\n     7→import { createDb } from \"./db.js\";\n     8→import { createAuthDb } from \"./auth-db.js\";\n     9→import { createCoinflipRoutes } from \"./routes/create.js\";\n    10→import { createLordRoutes } from \"./routes/lord-create.js\";\n    11→import { createRoundsRoutes } from \"./routes/rounds.js\";\n    12→import { createCloseCallRoutes } from \"./routes/closecall.js\";\n    13→import { createHealthRoutes } from \"./routes/health.js\";\n    14→import { createProfileRoutes } from \"./routes/profile.js\";\n    15→import { createPriceRoutes } from \"./routes/price.js\";\n    16→import { createAuthRoutes } from \"./routes/auth.js\";\n    17→import { createReferralRoutes } from \"./routes/referral.js\";\n    18→import { createJwtAuthMiddleware } from \"./middleware/jwt-auth.js\";\n    19→import { createRateLimitMiddleware } from \"./middleware/rate-limit.js\";\n    20→import { createSettlementWorker } from \"./worker/settlement.js\";\n    21→import { settleRound } from \"./worker/settle-tx.js\";\n    22→import { createRetrySettler } from \"./worker/retry.js\";\n    23→import { createPdaWatcher } from \"./worker/pda-watcher.js\";\n    24→import { createCloseCallClockWorker } from \"./worker/closecall-clock.js\";\n    25→import { createEventWorker } from \"./queue/index.js\";\n    26→import { logger } from \"./logger.js\";\n    27→\n    28→const config = loadConfig();\n    29→\n    30→// Shared postgres connection for both game DB and auth DB\n    31→const sql = postgres(config.databaseUrl);\n    32→const db = createDb(config.databaseUrl);\n    33→const authDb = createAuthDb(sql);\n    34→\n    35→const connection = new Connection(config.rpcUrl, {\n    36→  commitment: \"confirmed\",\n    37→  ...(config.wsRpcUrl ? { wsEndpoint: config.wsRpcUrl } : {}),\n    38→});\n    39→\n    40→const app = new Hono();\n    41→\n    42→app.use(\n    43→  \"*\",\n    44→  cors({\n    45→    origin: \"*\",\n    46→    allowMethods: [\"GET\", \"POST\", \"OPTIONS\"],\n    47→    allowHeaders: [\"Content-Type\", \"Authorization\"],\n    48→  }),\n    49→);\n    50→\n    51→// Request logging — correlate frontend fetch timing with server-side processing\n    52→app.use(\"*\", async (c, next) => {\n    53→  const start = Date.now();\n    54→  await next();\n    55→  const ms = Date.now() - start;\n    56→  const method = c.req.method;\n    57→  const path = c.req.path;\n    58→  // Skip noisy health checks and OPTIONS preflight\n    59→  if (path === \"/health\" || method === \"OPTIONS\") return;\n    60→  logger.debug(\"request\", { method, path, status: c.res.status, ms });\n    61→});\n    62→\n    63→// Auth routes — no JWT middleware (these are the login endpoints)\n    64→// Lighter rate limiting by IP for auth endpoints\n    65→app.use(\n    66→  \"/auth/*\",\n    67→  createRateLimitMiddleware({\n    68→    perWallet: 20,\n    69→    global: config.rateLimitGlobal,\n    70→    windowMs: 60_000,\n    71→  }),\n    72→);\n    73→\n    74→app.route(\n    75→  \"/auth\",\n    76→  createAuthRoutes({\n    77→    authDb,\n    78→    jwtSecret: config.jwtSecret,\n    79→    cluster: config.cluster,\n    80→    challengeTtlSeconds: config.challengeTtlSeconds,\n    81→    accessTokenTtlSeconds: config.accessTokenTtlSeconds,\n    82→    refreshTokenTtlDays: config.refreshTokenTtlDays,\n    83→  }),\n    84→);\n    85→\n    86→// Profile routes — authenticated GET endpoints (require JWT on all methods)\n    87→app.use(\n    88→  \"/profile/*\",\n    89→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n    90→);\n    91→app.route(\"/profile\", createProfileRoutes({ db }));\n    92→\n    93→// Referral routes — authenticated GET + POST endpoints (require JWT on all methods)\n    94→app.use(\n    95→  \"/referral/*\",\n    96→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret, requireAllMethods: true }),\n    97→);\n    98→app.route(\"/referral\", createReferralRoutes({ db, sql, config }));\n    99→\n   100→// JWT auth middleware for fairness endpoints\n   101→app.use(\n   102→  \"/fairness/*\",\n   103→  createJwtAuthMiddleware({ jwtSecret: config.jwtSecret }),\n   104→);\n   105→\n   106→// Rate limiting — per-wallet and global limits on POST requests\n   107→app.use(\n   108→  \"/fairness/*\",\n   109→  createRateLimitMiddleware({\n   110→    perWallet: config.rateLimitPerWallet,\n   111→    global: config.rateLimitGlobal,\n   112→    windowMs: 60_000,\n   113→  }),\n   114→);\n   115→\n   116→// Settlement infrastructure — must be created before routes (routes use pdaWatcher)\n   117→const entropyAccount = new PublicKey(config.entropyAccount);\n   118→const retrySettler = createRetrySettler({\n   119→  db,\n   120→  connection,\n   121→  settleRound: (pda) =>\n   122→    settleRound(\n   123→      { db, connection, serverKeypair: config.serverKeypair, entropyAccount, referralDefaultRateBps: config.referralDefaultRateBps },\n   124→      pda,\n   125→    ),\n   126→});\n   127→\n   128→// PDA watcher — WebSocket-based instant join detection\n   129→const pdaWatcher = createPdaWatcher({\n   130→  connection,\n   131→  serverKey: config.serverKeypair.publicKey,\n   132→  db,\n   133→  onJoinDetected: async (pda, targetSlot) => {\n   134→    // Update DB phase if still in 'created'\n   135→    const round = await db.getRoundByPda(pda);\n   136→    if (round && round.phase === \"created\") {\n   137→      await db.updateRoundPhase(pda, \"locked\", {\n   138→        target_slot: targetSlot.toString(),\n   139→      });\n   140→      await db.insertOperatorEvent(pda, \"match_detected\", {\n   141→        targetSlot: targetSlot.toString(),\n   142→        source: \"pda-watcher\",\n   143→        game: round.game,\n   144→      });\n   145→    }\n   146→\n   147→    // Check if target slot already passed — settle immediately if so\n   148→    const currentSlot = await connection.getSlot();\n   149→    if (BigInt(currentSlot) >= targetSlot) {\n   150→      await retrySettler.attemptSettle(pda);\n   151→      pdaWatcher.unwatch(pda);\n   152→    }\n   153→    // If target slot not reached yet, poll worker will pick it up next cycle\n   154→  },\n   155→});\n   156→\n   157→const worker = createSettlementWorker({\n   158→  db,\n   159→  connection,\n   160→  serverKey: config.serverKeypair.publicKey,\n   161→  pollIntervalMs: config.workerPollIntervalMs,\n   162→  onSettleReady: async (pda) => {\n   163→    await retrySettler.attemptSettle(pda);\n   164→    pdaWatcher.unwatch(pda); // clean up subscription after settlement\n   165→  },\n   166→  isFinalized: (pda) => retrySettler.isFinalized(pda),\n   167→});\n   168→worker.start();\n   169→\n   170→// Close Call clock worker — fetches boundary prices + settles open rounds\n   171→// Rounds are created on-demand by players via /closecall/bet\n   172→const closeCallClock = createCloseCallClockWorker({\n   173→  connection,\n   174→  serverKeypair: config.serverKeypair,\n   175→  db: sql,\n   176→});\n   177→closeCallClock.start();\n   178→\n   179→// Event queue worker — processes async side-effects (rewards, notifications, etc.)\n   180→const eventWorker = createEventWorker(sql, {\n   181→  pollIntervalMs: config.eventQueuePollMs,\n   182→});\n   183→eventWorker.start();\n   184→logger.info(\"Event queue worker started\", {\n   185→  pollIntervalMs: config.eventQueuePollMs,\n   186→});\n   187→\n   188→// Coinflip fairness routes\n   189→app.route(\n   190→  \"/fairness/coinflip\",\n   191→  createCoinflipRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n   192→);\n   193→app.route(\n   194→  \"/fairness/lord\",\n   195→  createLordRoutes({ db, connection, serverKeypair: config.serverKeypair, pdaWatcher }),\n   196→);\n   197→\n   198→// Close Call routes (create-round co-signing + candle history + read queries)\n   199→app.route(\"/closecall\", createCloseCallRoutes({\n   200→  db,\n   201→  connection,\n   202→  serverKeypair: config.serverKeypair,\n   203→  clockWorker: closeCallClock,\n   204→  sql,\n   205→}));\n   206→\n   207→// Price routes — public, no auth\n   208→app.route(\"/price\", createPriceRoutes());\n   209→\n   210→// Round verification routes\n   211→app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n   212→\n   213→// Health endpoint — wired after worker exists so we can query its status\n   214→app.route(\n   215→  \"/health\",\n   216→  createHealthRoutes({\n   217→    db,\n   218→    sql,\n   219→    connection,\n   220→    serverKey: config.serverKeypair.publicKey,\n   221→    isWorkerRunning: () => worker.isRunning,\n   222→    minSolBalance: config.minSolBalance,\n   223→  }),\n   224→);\n   225→\n   226→const port = config.port;\n   227→logger.info(\"fairness-backend started\", { port });\n   228→\n   229→serve({\n   230→  fetch: app.fetch,\n   231→  port,\n   232→});\n   233→\n   234→export default {\n   235→  port,\n   236→  fetch: app.fetch,\n   237→};\n   238→"}]},"parent_tool_use_id":"toolu_01XiRZ79WmcAciE6msWuHCFL","session_id":"b75d7aec-4dd6-4c16-a100-27ad57796fa9","uuid":"12729ed6-b0d7-4456-a36a-a162f62afd99","timestamp":"2026-03-25T12:27:10.357Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VC3T6BZLdornqiEd56y4Lt","type":"tool_result","content":"     1→/**\n     2→ * Settle transaction builder + submission.\n     3→ *\n     4→ * Retrieves the stored secret, reads on-chain match + config data to resolve\n     5→ * all accounts, builds the `settle` instruction, submits it, and updates the\n     6→ * DB on confirmation.\n     7→ */\n     8→\n     9→import { createHash } from \"node:crypto\";\n    10→import { performance } from \"node:perf_hooks\";\n    11→import {\n    12→  Connection,\n    13→  Keypair,\n    14→  PublicKey,\n    15→  SystemProgram,\n    16→  Transaction,\n    17→  TransactionInstruction,\n    18→} from \"@solana/web3.js\";\n    19→import type { Db } from \"../db.js\";\n    20→import { logger } from \"../logger.js\";\n    21→import { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n    22→import { derivePlatformConfigPda, getPlatformConfig } from \"../platform-config.js\";\n    23→import { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@rng-utopia/anchor-client\";\n    24→import {\n    25→  decodeCoinflipMatch,\n    26→  decodeLordRound,\n    27→  type DecodedJackpotRound,\n    28→} from \"./account-decoder.js\";\n    29→\n    30→// ---------------------------------------------------------------------------\n    31→// Instruction discriminators (from IDL — no hardcoded byte arrays)\n    32→// ---------------------------------------------------------------------------\n    33→\n    34→function getInstructionDiscriminator(\n    35→  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n    36→  instructionName: string,\n    37→): Buffer {\n    38→  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n    39→  if (!instruction) {\n    40→    throw new Error(`Instruction ${instructionName} not found in IDL`);\n    41→  }\n    42→  return Buffer.from(instruction.discriminator);\n    43→}\n    44→\n    45→const SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\n    46→const CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n    47→  lordIdl,\n    48→  \"claim_payout\",\n    49→);\n    50→const CC_BET_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"bet\");\n    51→const CC_SETTLE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"settle_round\");\n    52→const CC_TIMEOUT_REFUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"timeout_refund\");\n    53→\n    54→// ---------------------------------------------------------------------------\n    55→// Types\n    56→// ---------------------------------------------------------------------------\n    57→\n    58→export interface SettleTxDeps {\n    59→  db: Db;\n    60→  connection: Connection;\n    61→  serverKeypair: Keypair;\n    62→  entropyAccount: PublicKey;\n    63→  referralDefaultRateBps: number;\n    64→}\n    65→\n    66→export interface SettleResult {\n    67→  txSignature: string;\n    68→  resultHash: Buffer;\n    69→  resultSide?: number;\n    70→  winningEntryIndex?: number;\n    71→  winner: string;\n    72→}\n    73→\n    74→// ---------------------------------------------------------------------------\n    75→// Instruction encoding\n    76→// ---------------------------------------------------------------------------\n    77→\n    78→/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\n    79→function encodeSettleData(secret: Buffer): Buffer {\n    80→  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n    81→}\n    82→\n    83→function encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n    84→  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n    85→}\n    86→\n    87→// ---------------------------------------------------------------------------\n    88→// Result derivation (mirrors on-chain derive_result)\n    89→// ---------------------------------------------------------------------------\n    90→\n    91→/**\n    92→ * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n    93→ * Must match shared/src/fairness.rs `derive_result()`.\n    94→ */\n    95→function deriveResult(\n    96→  secret: Buffer,\n    97→  entropy: Buffer,\n    98→  matchPdaBytes: Buffer,\n    99→  algoVer: number,\n   100→): Buffer {\n   101→  return createHash(\"sha256\")\n   102→    .update(secret)\n   103→    .update(entropy)\n   104→    .update(matchPdaBytes)\n   105→    .update(Buffer.from([algoVer]))\n   106→    .digest();\n   107→}\n   108→\n   109→// ---------------------------------------------------------------------------\n   110→// Referral earnings hook\n   111→// ---------------------------------------------------------------------------\n   112→\n   113→/**\n   114→ * After a game settles, check each player for a referrer and record\n   115→ * referral earnings if applicable.\n   116→ *\n   117→ * For each unique player: look up referral link → if referrer exists,\n   118→ * calculate referrer earning + referee rebate → insert into referral_earnings.\n   119→ *\n   120→ * Errors are logged but never bubble — referral recording must not fail settlement.\n   121→ * The UNIQUE(referee_wallet, round_id) constraint provides idempotency on retries.\n   122→ */\n   123→async function recordReferralEarnings(\n   124→  db: Db,\n   125→  params: {\n   126→    roundId: string;\n   127→    gameType: string;\n   128→    feeBps: number;\n   129→    referralDefaultRateBps: number;\n   130→    players: Array<{ wallet: string; wagerLamports: number }>;\n   131→  },\n   132→): Promise<void> {\n   133→  const { roundId, gameType, feeBps, referralDefaultRateBps, players } = params;\n   134→\n   135→  // Deduplicate players (Lord of RNGs can have multiple entries per player)\n   136→  const playerWagers = new Map<string, number>();\n   137→  for (const p of players) {\n   138→    playerWagers.set(p.wallet, (playerWagers.get(p.wallet) ?? 0) + p.wagerLamports);\n   139→  }\n   140→\n   141→  for (const [wallet, wagerLamports] of playerWagers) {\n   142→    try {\n   143→      const link = await db.getReferralLinkByReferee(wallet);\n   144→      if (!link) continue;\n   145→\n   146→      const referrerWallet = link.referrer_wallet;\n   147→      const referrerRateBps = await db.getReferrerRate(\n   148→        referrerWallet,\n   149→        referralDefaultRateBps,\n   150→      );\n   151→\n   152→      const feeLamports = Math.floor((wagerLamports * feeBps) / 10_000);\n   153→      const referrerEarnedLamports = Math.floor(\n   154→        (feeLamports * referrerRateBps) / 10_000,\n   155→      );\n   156→      const refereeRebateLamports = Math.floor((feeLamports * 1000) / 10_000);\n   157→\n   158→      await db.insertReferralEarning({\n   159→        referrerWallet,\n   160→        refereeWallet: wallet,\n   161→        roundId,\n   162→        gameType,\n   163→        wagerLamports,\n   164→        feeLamports,\n   165→        referrerEarnedLamports,\n   166→        referrerRateBps,\n   167→        refereeRebateLamports,\n   168→        refereeRebateRateBps: 1000, // fixed 10% for v1\n   169→      });\n   170→\n   171→      logger.info(\"referral earning recorded\", {\n   172→        roundId,\n   173→        gameType,\n   174→        referrer: referrerWallet,\n   175→        referee: wallet,\n   176→        referrerEarnedLamports,\n   177→        refereeRebateLamports,\n   178→      });\n   179→    } catch (err: unknown) {\n   180→      const msg = err instanceof Error ? err.message : String(err);\n   181→      if (msg.includes(\"duplicate key\") || msg.includes(\"unique constraint\")) {\n   182→        logger.info(\"referral earning already recorded (idempotent skip)\", {\n   183→          roundId,\n   184→          wallet,\n   185→        });\n   186→      } else {\n   187→        logger.error(\"failed to record referral earning\", {\n   188→          roundId,\n   189→          wallet,\n   190→          error: msg,\n   191→        });\n   192→      }\n   193→    }\n   194→  }\n   195→}\n   196→\n   197→// ---------------------------------------------------------------------------\n   198→// Core settle function\n   199→// ---------------------------------------------------------------------------\n   200→\n   201→/**\n   202→ * Build, submit, and confirm a settle transaction for a locked match.\n   203→ *\n   204→ * Steps:\n   205→ * 1. Retrieve secret from DB\n   206→ * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n   207→ * 3. Fetch config account data (treasury)\n   208→ * 4. Read entropy from the entropy account\n   209→ * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n   210→ * 6. Build + submit settle tx\n   211→ * 7. Update DB on confirmation\n   212→ */\n   213→export async function settleMatch(\n   214→  deps: SettleTxDeps,\n   215→  pda: string,\n   216→): Promise<SettleResult> {\n   217→  const t0 = performance.now();\n   218→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   219→  const matchPubkey = new PublicKey(pda);\n   220→\n   221→  // 1. Retrieve secret from DB\n   222→  const round = await db.getRoundByPda(pda);\n   223→  const tDb = performance.now();\n   224→  if (!round) {\n   225→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   226→  }\n   227→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   228→    throw new PermanentSettleError(\n   229→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   230→    );\n   231→  }\n   232→\n   233→  const secret = Buffer.from(round.secret);\n   234→\n   235→  // Transition to settling (locked → settling)\n   236→  if (round.phase === \"locked\") {\n   237→    await db.updateRoundPhase(pda, \"settling\");\n   238→  }\n   239→\n   240→  // Log settle_submitted\n   241→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   242→    attempt: round.settle_attempts + 1,\n   243→  });\n   244→\n   245→  // 2-4. Fetch match, platform config, entropy, and blockhash in parallel\n   246→  const [platformConfigPda] = derivePlatformConfigPda();\n   247→  const [matchAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n   248→    await Promise.all([\n   249→      connection.getAccountInfo(matchPubkey),\n   250→      getPlatformConfig(connection),\n   251→      connection.getAccountInfo(entropyAccount),\n   252→      connection.getLatestBlockhash(),\n   253→    ]);\n   254→  const tFetch = performance.now();\n   255→\n   256→  if (!matchAccountInfo) {\n   257→    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n   258→  }\n   259→  if (!entropyInfo) {\n   260→    throw new TransientSettleError(\"Entropy account not available yet\");\n   261→  }\n   262→\n   263→  // IDL-driven decode — no manual byte offsets\n   264→  const match = decodeCoinflipMatch(Buffer.from(matchAccountInfo.data));\n   265→  const { feeBps, treasury } = platformConfig;\n   266→\n   267→  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer } = match;\n   268→\n   269→  const pool = entryAmount * 2n;\n   270→  const feeAmount = Number((pool * BigInt(feeBps)) / 10_000n);\n   271→  const payoutAmount = Number(pool) - feeAmount;\n   272→\n   273→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   274→\n   275→  // 5. Pre-compute result\n   276→  const matchPdaBytes = matchPubkey.toBuffer();\n   277→  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n   278→  const resultSide = resultHash[0]! % 2;\n   279→  const winner = resultSide === creatorSide ? creator : opponent;\n   280→\n   281→  // 6. Build settle instruction (8 accounts, no profile CPI)\n   282→  const data = encodeSettleData(secret);\n   283→\n   284→  const instruction = new TransactionInstruction({\n   285→    keys: [\n   286→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n   287→      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // coinflip_match\n   288→      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n   289→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   290→      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n   291→      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n   292→      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n   293→      {\n   294→        pubkey: SystemProgram.programId,\n   295→        isSigner: false,\n   296→        isWritable: false,\n   297→      }, // system_program\n   298→    ],\n   299→    programId: COINFLIP_PROGRAM_ID,\n   300→    data,\n   301→  });\n   302→\n   303→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   304→\n   305→  const tx = new Transaction({\n   306→    feePayer: serverKeypair.publicKey,\n   307→    blockhash,\n   308→    lastValidBlockHeight,\n   309→  });\n   310→  tx.add(instruction);\n   311→  tx.sign(serverKeypair);\n   312→\n   313→  // 7. Submit and confirm\n   314→  const rawTx = tx.serialize();\n   315→  const tBuild = performance.now();\n   316→  const txSignature = await connection.sendRawTransaction(rawTx, {\n   317→    skipPreflight: false,\n   318→  });\n   319→  const tSend = performance.now();\n   320→\n   321→  logger.info(\"settlement transaction submitted\", {\n   322→    pda,\n   323→    txSignature,\n   324→    attempt: round.settle_attempts + 1,\n   325→    dbMs: Math.round(tDb - t0),\n   326→    fetchMs: Math.round(tFetch - tDb),\n   327→    buildMs: Math.round(tBuild - tFetch),\n   328→    sendMs: Math.round(tSend - tBuild),\n   329→  });\n   330→\n   331→  const confirmation = await connection.confirmTransaction(\n   332→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   333→    \"confirmed\",\n   334→  );\n   335→  const tConfirm = performance.now();\n   336→  if (confirmation.value.err) {\n   337→    throw new TransientSettleError(\n   338→      `Coinflip settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   339→    );\n   340→  }\n   341→\n   342→  // 8. Update DB — phase settling → settled\n   343→  const coinflipEntries = [\n   344→    { player: creator.toBase58(), amountLamports: Number(entryAmount) },\n   345→    { player: opponent.toBase58(), amountLamports: Number(entryAmount) },\n   346→  ];\n   347→\n   348→  await db.updateRoundPhase(pda, \"settled\", {\n   349→    settle_tx: txSignature,\n   350→    result_hash: resultHash,\n   351→    result_side: resultSide,\n   352→    winner: winner.toBase58(),\n   353→    settle_attempts: round.settle_attempts + 1,\n   354→  });\n   355→\n   356→  // Persist entries in dedicated JSONB column for direct access\n   357→  await db.updateRoundEntries(pda, coinflipEntries);\n   358→\n   359→  // Log settle_confirmed\n   360→  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   361→    txSignature,\n   362→    resultSide,\n   363→    winner: winner.toBase58(),\n   364→    entropy: entropy.toString(\"hex\"),\n   365→    payoutAmount,\n   366→    feeAmount,\n   367→    entries: coinflipEntries,\n   368→  });\n   369→\n   370→  // Write payout transaction for the winner\n   371→  await db.insertTransaction({\n   372→    wallet: winner.toBase58(),\n   373→    game: \"coinflip\",\n   374→    matchId: round.match_id,\n   375→    txType: \"payout\",\n   376→    amountLamports: payoutAmount,\n   377→    txSig: txSignature,\n   378→  });\n   379→\n   380→  // Referral earnings hook — check both players for referrers\n   381→  await recordReferralEarnings(db, {\n   382→    roundId: round.match_id,\n   383→    gameType: \"coinflip\",\n   384→    feeBps,\n   385→    referralDefaultRateBps: deps.referralDefaultRateBps,\n   386→    players: [\n   387→      { wallet: creator.toBase58(), wagerLamports: Number(entryAmount) },\n   388→      { wallet: opponent.toBase58(), wagerLamports: Number(entryAmount) },\n   389→    ],\n   390→  });\n   391→\n   392→  const tDone = performance.now();\n   393→  logger.info(\"settlement transaction confirmed\", {\n   394→    pda,\n   395→    txSignature,\n   396→    resultSide,\n   397→    winner: winner.toBase58(),\n   398→    timing: {\n   399→      dbMs: Math.round(tDb - t0),\n   400→      fetchMs: Math.round(tFetch - tDb),\n   401→      buildMs: Math.round(tBuild - tFetch),\n   402→      sendMs: Math.round(tSend - tBuild),\n   403→      confirmMs: Math.round(tConfirm - tSend),\n   404→      dbWriteMs: Math.round(tDone - tConfirm),\n   405→      totalMs: Math.round(tDone - t0),\n   406→    },\n   407→  });\n   408→\n   409→  return {\n   410→    txSignature,\n   411→    resultHash,\n   412→    resultSide,\n   413→    winner: winner.toBase58(),\n   414→  };\n   415→}\n   416→\n   417→export async function settleLordRound(\n   418→  deps: SettleTxDeps,\n   419→  pda: string,\n   420→): Promise<SettleResult> {\n   421→  const t0 = performance.now();\n   422→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   423→  const roundPubkey = new PublicKey(pda);\n   424→\n   425→  const round = await db.getRoundByPda(pda);\n   426→  const tDb = performance.now();\n   427→  if (!round) {\n   428→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   429→  }\n   430→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   431→    throw new PermanentSettleError(\n   432→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   433→    );\n   434→  }\n   435→\n   436→  const secret = Buffer.from(round.secret);\n   437→\n   438→  if (round.phase === \"locked\") {\n   439→    await db.updateRoundPhase(pda, \"settling\");\n   440→  }\n   441→\n   442→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   443→    attempt: round.settle_attempts + 1,\n   444→    game: \"lord\",\n   445→  });\n   446→\n   447→  const [platformConfigPda] = derivePlatformConfigPda();\n   448→  const [roundAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n   449→    await Promise.all([\n   450→      connection.getAccountInfo(roundPubkey),\n   451→      getPlatformConfig(connection),\n   452→      connection.getAccountInfo(entropyAccount),\n   453→      connection.getLatestBlockhash(),\n   454→    ]);\n   455→\n   456→  const tFetch = performance.now();\n   457→\n   458→  if (!roundAccountInfo) {\n   459→    throw new PermanentSettleError(`Lord round account not found on-chain: ${pda}`);\n   460→  }\n   461→  if (!entropyInfo) {\n   462→    throw new TransientSettleError(\"Entropy account not available yet\");\n   463→  }\n   464→\n   465→  // IDL-driven decode — no manual byte offsets or parseLordRound()\n   466→  const roundData: DecodedJackpotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n   467→  const { feeBps, treasury } = platformConfig;\n   468→\n   469→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   470→  const resultHash = deriveResult(\n   471→    secret,\n   472→    entropy,\n   473→    roundPubkey.toBuffer(),\n   474→    roundData.algorithmVer,\n   475→  );\n   476→  const feeAmount = Number((roundData.totalAmountLamports * BigInt(feeBps)) / 10_000n);\n   477→  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n   478→  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n   479→\n   480→  const raw = resultHash.readBigUInt64LE(0);\n   481→  const winningOffset = raw % roundData.totalAmountLamports;\n   482→\n   483→  let cumulative = 0n;\n   484→  let winnerEntryIndex = -1;\n   485→  let winner = roundData.entries[0]?.player;\n   486→  for (const [index, entry] of roundData.entries.entries()) {\n   487→    cumulative += entry.amountLamports;\n   488→    if (winningOffset < cumulative) {\n   489→      winnerEntryIndex = index;\n   490→      winner = entry.player;\n   491→      break;\n   492→    }\n   493→  }\n   494→\n   495→  if (!winner || winnerEntryIndex < 0) {\n   496→    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n   497→  }\n   498→\n   499→  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n   500→  const instruction = new TransactionInstruction({\n   501→    keys: [\n   502→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n   503→      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n   504→      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n   505→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   506→      { pubkey: treasury, isSigner: false, isWritable: true },\n   507→      { pubkey: winner, isSigner: false, isWritable: true },\n   508→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   509→    ],\n   510→    programId: LORDOFRNGS_PROGRAM_ID,\n   511→    data: encodeClaimPayoutData(matchIdBuf, secret),\n   512→  });\n   513→\n   514→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   515→  const tx = new Transaction({\n   516→    feePayer: serverKeypair.publicKey,\n   517→    blockhash,\n   518→    lastValidBlockHeight,\n   519→  });\n   520→  tx.add(instruction);\n   521→  tx.sign(serverKeypair);\n   522→\n   523→  const tBuild = performance.now();\n   524→  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n   525→    skipPreflight: false,\n   526→  });\n   527→  const tSend = performance.now();\n   528→\n   529→  logger.info(\"lord settlement transaction submitted\", {\n   530→    pda,\n   531→    txSignature,\n   532→    attempt: round.settle_attempts + 1,\n   533→    winningEntryIndex: winnerEntryIndex,\n   534→    dbMs: Math.round(tDb - t0),\n   535→    fetchMs: Math.round(tFetch - tDb),\n   536→    buildMs: Math.round(tBuild - tFetch),\n   537→    sendMs: Math.round(tSend - tBuild),\n   538→  });\n   539→\n   540→  const confirmation = await connection.confirmTransaction(\n   541→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   542→    \"confirmed\",\n   543→  );\n   544→  const tConfirm = performance.now();\n   545→  if (confirmation.value.err) {\n   546→    throw new TransientSettleError(\n   547→      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   548→    );\n   549→  }\n   550→\n   551→  const serializedEntries = roundData.entries.map((e) => ({\n   552→    player: e.player.toBase58(),\n   553→    amountLamports: Number(e.amountLamports),\n   554→  }));\n   555→\n   556→  await db.updateRoundPhase(pda, \"settled\", {\n   557→    settle_tx: txSignature,\n   558→    result_hash: resultHash,\n   559→    result_side: winnerEntryIndex,\n   560→    winner: winner.toBase58(),\n   561→    settle_attempts: round.settle_attempts + 1,\n   562→  });\n   563→\n   564→  // Persist entries in dedicated JSONB column for direct access\n   565→  await db.updateRoundEntries(pda, serializedEntries);\n   566→\n   567→  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   568→    txSignature,\n   569→    winner: winner.toBase58(),\n   570→    winningEntryIndex: winnerEntryIndex,\n   571→    game: \"lord\",\n   572→    entropy: entropy.toString(\"hex\"),\n   573→    winningOffset: winningOffset.toString(),\n   574→    totalAmountLamports: Number(roundData.totalAmountLamports),\n   575→    payoutAmount,\n   576→    feeAmount,\n   577→    rentRefund,\n   578→    entries: serializedEntries,\n   579→  });\n   580→\n   581→  // Write payout transaction for the winner\n   582→  await db.insertTransaction({\n   583→    wallet: winner.toBase58(),\n   584→    game: \"lord\",\n   585→    matchId: round.match_id,\n   586→    txType: \"payout\",\n   587→    amountLamports: payoutAmount,\n   588→    txSig: txSignature,\n   589→  });\n   590→\n   591→  // Referral earnings hook — check all players for referrers\n   592→  await recordReferralEarnings(db, {\n   593→    roundId: round.match_id,\n   594→    gameType: \"lord\",\n   595→    feeBps,\n   596→    referralDefaultRateBps: deps.referralDefaultRateBps,\n   597→    players: serializedEntries.map((e) => ({\n   598→      wallet: e.player,\n   599→      wagerLamports: e.amountLamports,\n   600→    })),\n   601→  });\n   602→\n   603→  const tDone = performance.now();\n   604→  logger.info(\"lord settlement transaction confirmed\", {\n   605→    pda,\n   606→    txSignature,\n   607→    winner: winner.toBase58(),\n   608→    winningEntryIndex: winnerEntryIndex,\n   609→    timing: {\n   610→      dbMs: Math.round(tDb - t0),\n   611→      fetchMs: Math.round(tFetch - tDb),\n   612→      buildMs: Math.round(tBuild - tFetch),\n   613→      sendMs: Math.round(tSend - tBuild),\n   614→      confirmMs: Math.round(tConfirm - tSend),\n   615→      dbWriteMs: Math.round(tDone - tConfirm),\n   616→      totalMs: Math.round(tDone - t0),\n   617→    },\n   618→  });\n   619→\n   620→  return {\n   621→    txSignature,\n   622→    resultHash,\n   623→    winningEntryIndex: winnerEntryIndex,\n   624→    winner: winner.toBase58(),\n   625→  };\n   626→}\n   627→\n   628→export async function settleRound(\n   629→  deps: SettleTxDeps,\n   630→  pda: string,\n   631→): Promise<SettleResult> {\n   632→  const round = await deps.db.getRoundByPda(pda);\n   633→  if (!round) {\n   634→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   635→  }\n   636→\n   637→  if (round.game === \"lord\") {\n   638→    return settleLordRound(deps, pda);\n   639→  }\n   640→\n   641→  return settleMatch(deps, pda);\n   642→}\n   643→\n   644→// ---------------------------------------------------------------------------\n   645→// Close Call — transaction builders\n   646→// ---------------------------------------------------------------------------\n   647→\n   648→function deriveCloseCallConfigPda(): [PublicKey, number] {\n   649→  return PublicKey.findProgramAddressSync(\n   650→    [Buffer.from(\"closecall_config\")],\n   651→    CLOSECALL_PROGRAM_ID,\n   652→  );\n   653→}\n   654→\n   655→\n   656→function minuteTsToBuffer(ts: bigint): Buffer {\n   657→  const buf = Buffer.alloc(8);\n   658→  buf.writeBigInt64LE(ts);\n   659→  return buf;\n   660→}\n   661→\n   662→function deriveCloseCallRoundPda(minuteTs: bigint): [PublicKey, number] {\n   663→  return PublicKey.findProgramAddressSync(\n   664→    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n   665→    CLOSECALL_PROGRAM_ID,\n   666→  );\n   667→}\n   668→\n   669→/** Encode closecall instruction data: discriminator(8) + minute_ts(i64 LE, 8) = 16 bytes */\n   670→function encodeCcMinuteTsData(discriminator: Buffer, minuteTs: bigint): Buffer {\n   671→  const buf = Buffer.alloc(16);\n   672→  discriminator.copy(buf, 0);\n   673→  buf.writeBigInt64LE(minuteTs, 8);\n   674→  return buf;\n   675→}\n   676→\n   677→/** Encode closecall settle_round data: disc(8) + minute_ts(i64 LE, 8) + close_price(i64 LE, 8) + close_price_expo(i32 LE, 4) = 28 bytes */\n   678→function encodeCcSettleData(discriminator: Buffer, minuteTs: bigint, price: bigint, expo: number): Buffer {\n   679→  const buf = Buffer.alloc(28);\n   680→  discriminator.copy(buf, 0);\n   681→  buf.writeBigInt64LE(minuteTs, 8);\n   682→  buf.writeBigInt64LE(price, 16);\n   683→  buf.writeInt32LE(expo, 24);\n   684→  return buf;\n   685→}\n   686→\n   687→/**\n   688→ * Encode closecall bet data:\n   689→ * disc(8) + minute_ts(i64 LE, 8) + side(1) + amount(u64 LE, 8) + open_price(i64 LE, 8) + open_price_expo(i32 LE, 4) = 37 bytes\n   690→ */\n   691→function encodeCcBetData(\n   692→  discriminator: Buffer,\n   693→  minuteTs: bigint,\n   694→  side: number,\n   695→  amount: bigint,\n   696→  openPrice: bigint,\n   697→  openPriceExpo: number,\n   698→): Buffer {\n   699→  const buf = Buffer.alloc(37);\n   700→  discriminator.copy(buf, 0);\n   701→  buf.writeBigInt64LE(minuteTs, 8);\n   702→  buf.writeUInt8(side, 16);\n   703→  buf.writeBigUInt64LE(amount, 17);\n   704→  buf.writeBigInt64LE(openPrice, 25);\n   705→  buf.writeInt32LE(openPriceExpo, 33);\n   706→  return buf;\n   707→}\n   708→\n   709→export interface CloseCallTxDeps {\n   710→  connection: Connection;\n   711→  serverKeypair: Keypair;\n   712→}\n   713→\n   714→/**\n   715→ * Build a `bet` instruction (no transaction wrapping).\n   716→ *\n   717→ * Two signers: player (pays bet) + server (pays rent on first call).\n   718→ * Price + bet info passed as instruction args.\n   719→ * Uses init_if_needed — works for both round creation and joining.\n   720→ */\n   721→export function buildCloseCallBetIx(\n   722→  serverPubkey: PublicKey,\n   723→  playerPubkey: PublicKey,\n   724→  minuteTs: bigint,\n   725→  side: number,\n   726→  amountLamports: bigint,\n   727→  openPrice: bigint,\n   728→  openPriceExpo: number,\n   729→): TransactionInstruction {\n   730→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   731→  const [configPda] = deriveCloseCallConfigPda();\n   732→  const data = encodeCcBetData(\n   733→    CC_BET_DISCRIMINATOR,\n   734→    minuteTs,\n   735→    side,\n   736→    amountLamports,\n   737→    openPrice,\n   738→    openPriceExpo,\n   739→  );\n   740→\n   741→  return new TransactionInstruction({\n   742→    keys: [\n   743→      { pubkey: playerPubkey, isSigner: true, isWritable: true },  // player (pays bet)\n   744→      { pubkey: serverPubkey, isSigner: true, isWritable: true },  // server (pays rent on first call)\n   745→      { pubkey: configPda, isSigner: false, isWritable: false },   // config\n   746→      { pubkey: roundPda, isSigner: false, isWritable: true },     // round\n   747→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   748→    ],\n   749→    programId: CLOSECALL_PROGRAM_ID,\n   750→    data,\n   751→  });\n   752→}\n   753→\n   754→/**\n   755→ * Build a `settle_round` instruction (no transaction wrapping).\n   756→ * Price is passed as instruction args (no on-chain Pyth account).\n   757→ */\n   758→export function buildCloseCallSettleRoundIx(\n   759→  serverPubkey: PublicKey,\n   760→  minuteTs: bigint,\n   761→  closePrice: bigint,\n   762→  closePriceExpo: number,\n   763→  treasury: PublicKey,\n   764→  winnerAccounts: PublicKey[],\n   765→): TransactionInstruction {\n   766→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   767→  const [platformConfigPda] = derivePlatformConfigPda();\n   768→  const data = encodeCcSettleData(CC_SETTLE_ROUND_DISCRIMINATOR, minuteTs, closePrice, closePriceExpo);\n   769→\n   770→  return new TransactionInstruction({\n   771→    keys: [\n   772→      { pubkey: serverPubkey, isSigner: true, isWritable: true },\n   773→      { pubkey: roundPda, isSigner: false, isWritable: true },\n   774→      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n   775→      { pubkey: treasury, isSigner: false, isWritable: true },\n   776→      { pubkey: serverPubkey, isSigner: false, isWritable: true },\n   777→      ...winnerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n   778→    ],\n   779→    programId: CLOSECALL_PROGRAM_ID,\n   780→    data,\n   781→  });\n   782→}\n   783→\n   784→/**\n   785→ * Build a partially-signed `bet` transaction for the Close Call program.\n   786→ *\n   787→ * Two signers: player (pays bet) + server (pays rent on first call via init_if_needed).\n   788→ * Server signs immediately; the frontend must add the player signature before submitting.\n   789→ * Works for both round creation (first bet) and joining (subsequent bets).\n   790→ */\n   791→export async function buildCloseCallBetTx(\n   792→  deps: CloseCallTxDeps,\n   793→  playerPubkey: PublicKey,\n   794→  minuteTs: bigint,\n   795→  side: number,\n   796→  amountLamports: bigint,\n   797→  openPrice: bigint,\n   798→  openPriceExpo: number,\n   799→): Promise<{ tx: Transaction; roundPda: PublicKey }> {\n   800→  const { connection, serverKeypair } = deps;\n   801→\n   802→  const instruction = buildCloseCallBetIx(\n   803→    serverKeypair.publicKey,\n   804→    playerPubkey,\n   805→    minuteTs,\n   806→    side,\n   807→    amountLamports,\n   808→    openPrice,\n   809→    openPriceExpo,\n   810→  );\n   811→\n   812→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   813→\n   814→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   815→  const tx = new Transaction({ feePayer: playerPubkey, blockhash, lastValidBlockHeight });\n   816→  tx.add(instruction);\n   817→  tx.partialSign(serverKeypair);\n   818→\n   819→  return { tx, roundPda };\n   820→}\n   821→\n   822→/**\n   823→ * Build a signed `settle_round` transaction for the Close Call program.\n   824→ *\n   825→ * Price is passed as instruction args. Winners (or all players for refund)\n   826→ * are passed as remaining accounts for auto-payout.\n   827→ */\n   828→export async function buildCloseCallSettleRoundTx(\n   829→  deps: CloseCallTxDeps,\n   830→  minuteTs: bigint,\n   831→  closePrice: bigint,\n   832→  closePriceExpo: number,\n   833→  treasury: PublicKey,\n   834→  winnerAccounts: PublicKey[],\n   835→): Promise<Transaction> {\n   836→  const { connection, serverKeypair } = deps;\n   837→\n   838→  const instruction = buildCloseCallSettleRoundIx(\n   839→    serverKeypair.publicKey,\n   840→    minuteTs,\n   841→    closePrice,\n   842→    closePriceExpo,\n   843→    treasury,\n   844→    winnerAccounts,\n   845→  );\n   846→\n   847→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   848→  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n   849→  tx.add(instruction);\n   850→  tx.sign(serverKeypair);\n   851→\n   852→  return tx;\n   853→}\n   854→\n   855→/**\n   856→ * Build a signed `timeout_refund` transaction for the Close Call program.\n   857→ *\n   858→ * Permissionless after the resolve deadline. Refunds all players their exact\n   859→ * deposit via remaining accounts.\n   860→ */\n   861→export async function buildCloseCallTimeoutRefundTx(\n   862→  deps: CloseCallTxDeps,\n   863→  minuteTs: bigint,\n   864→  playerAccounts: PublicKey[],\n   865→): Promise<Transaction> {\n   866→  const { connection, serverKeypair } = deps;\n   867→\n   868→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   869→  const [configPda] = deriveCloseCallConfigPda();\n   870→  const data = encodeCcMinuteTsData(CC_TIMEOUT_REFUND_DISCRIMINATOR, minuteTs);\n   871→\n   872→  const keys = [\n   873→    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller\n   874→    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round\n   875→    { pubkey: configPda, isSigner: false, isWritable: false },               // closecall_config\n   876→    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)\n   877→    ...playerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n   878→  ];\n   879→\n   880→  const instruction = new TransactionInstruction({\n   881→    keys,\n   882→    programId: CLOSECALL_PROGRAM_ID,\n   883→    data,\n   884→  });\n   885→\n   886→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   887→  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n   888→  tx.add(instruction);\n   889→  tx.sign(serverKeypair);\n   890→\n   891→  return tx;\n   892→}\n   893→\n   894→// ---------------------------------------------------------------------------\n   895→// Error types\n   896→// ---------------------------------------------------------------------------\n   897→\n   898→/** Permanent failure — should not be retried. */\n   899→export class PermanentSettleError extends Error {\n   900→  readonly permanent = true;\n   901→  constructor(message: string) {\n   902→    super(message);\n   903→    this.name = \"PermanentSettleError\";\n   904→  }\n   905→}\n   906→\n   907→/** Transient failure — safe to retry. */\n   908→export class TransientSettleError extends Error {\n   909→  readonly permanent = false;\n   910→  constructor(message: string) {\n   911→    super(message);\n   912→    this.name = \"TransientSettleError\";\n   913→  }\n   914→}\n   915→"}]},"parent_tool_use_id":"toolu_01XiRZ79WmcAciE6msWuHCFL","session_id":"b75d7aec-4dd6-4c16-a100-27ad57796fa9","uuid":"33167564-889e-4a54-af34-a59d48171720","timestamp":"2026-03-25T12:27:10.541Z"}
