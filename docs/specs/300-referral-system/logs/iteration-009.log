 c.json(","+          {","+            error: {","+              code: \"ALREADY_LINKED\",","+              message: \"You are already linked to a referrer\",","+              retryable: false,","+            },","+          },","+          409,","+        );","+      }","+      logger.error(\"Failed to create referral link\", {","+        err: String(err),","+        wallet,","+        code,","+      });","+      return c.json({ error: \"Failed to apply referral code\" }, 500);","+    }","+  });","+","   // GET /code — return the authenticated player's current referral code","   app.get(\"/code\", async (c) => {","     const wallet = c.get(\"wallet\");"]}],"userModified":false,"replaceAll":false}}
