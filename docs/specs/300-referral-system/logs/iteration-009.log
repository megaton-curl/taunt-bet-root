{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_018sw1hGx2qdTJvQSFiwMYQC","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_014XruYmeMMzCCNcUoHs5P3H","name":"Read","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/routes/profile.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":7,"cache_creation_input_tokens":14862,"cache_read_input_tokens":34969,"cache_creation":{"ephemeral_5m_input_tokens":14862,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_011BAH9Yk1HJbAWRUnFawaL4","session_id":"3d179094-b1ae-4405-8e43-449089b7a949","uuid":"13afeb24-bff2-49b6-bd4e-71159af2376e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014XruYmeMMzCCNcUoHs5P3H","type":"tool_result","content":"     1→/**\n     2→ * Profile routes — transaction history for the authenticated player.\n     3→ */\n     4→\n     5→import { Hono } from \"hono\";\n     6→import type { AppEnv } from \"../hono-env.js\";\n     7→import type { Db } from \"../db.js\";\n     8→import { logger } from \"../logger.js\";\n     9→\n    10→export interface ProfileRoutesDeps {\n    11→  db: Db;\n    12→}\n    13→\n    14→/** Map DB game names to frontend game IDs */\n    15→const GAME_TO_FRONTEND: Record<string, string> = {\n    16→  coinflip: \"coinflip\",\n    17→  lord: \"lord-of-rngs\",\n    18→  closecall: \"close-call\",\n    19→};\n    20→\n    21→/** Map frontend/DB game names to canonical DB names */\n    22→const TO_DB_GAME: Record<string, string> = {\n    23→  coinflip: \"coinflip\",\n    24→  lord: \"lord\",\n    25→  closecall: \"closecall\",\n    26→  \"lord-of-rngs\": \"lord\",\n    27→  \"close-call\": \"closecall\",\n    28→};\n    29→\n    30→export function createProfileRoutes(deps: ProfileRoutesDeps) {\n    31→  const { db } = deps;\n    32→  const app = new Hono<AppEnv>();\n    33→\n    34→  app.get(\"/transactions\", async (c) => {\n    35→    const wallet = c.get(\"wallet\");\n    36→    if (!wallet) {\n    37→      return c.json({ error: \"Authentication required\" }, 401);\n    38→    }\n    39→\n    40→    // Parse query params\n    41→    const cursor = c.req.query(\"cursor\") || undefined;\n    42→    const limitParam = c.req.query(\"limit\");\n    43→    const gameParam = c.req.query(\"game\") || undefined;\n    44→\n    45→    // Validate & clamp limit\n    46→    let limit = 20;\n    47→    if (limitParam) {\n    48→      const parsed = parseInt(limitParam, 10);\n    49→      if (!isNaN(parsed) && parsed > 0) {\n    50→        limit = Math.min(parsed, 50);\n    51→      }\n    52→    }\n    53→\n    54→    // Map game filter to DB name (accept both DB and frontend names)\n    55→    let dbGame: string | undefined;\n    56→    if (gameParam) {\n    57→      dbGame = TO_DB_GAME[gameParam];\n    58→      if (!dbGame) {\n    59→        return c.json({ error: `Invalid game filter: ${gameParam}` }, 400);\n    60→      }\n    61→    }\n    62→\n    63→    try {\n    64→      const rows = await db.getTransactions(wallet, cursor, limit, dbGame);\n    65→\n    66→      const transactions = rows.map((row) => ({\n    67→        id: row.id,\n    68→        game: GAME_TO_FRONTEND[row.game] ?? row.game,\n    69→        matchId: row.match_id,\n    70→        txType: row.tx_type,\n    71→        amountLamports: String(row.amount_lamports),\n    72→        txSig: row.tx_sig,\n    73→        createdAt: row.created_at.toISOString(),\n    74→      }));\n    75→\n    76→      const nextCursor =\n    77→        transactions.length === limit\n    78→          ? String(transactions[transactions.length - 1]!.id)\n    79→          : null;\n    80→\n    81→      return c.json({ transactions, nextCursor });\n    82→    } catch (err) {\n    83→      logger.error(\"profile transactions query failed\", {\n    84→        wallet,\n    85→        error: err instanceof Error ? err.message : \"Unknown error\",\n    86→      });\n    87→      return c.json({ error: \"Failed to fetch transactions\" }, 500);\n    88→    }\n    89→  });\n    90→\n    91→  // POST /confirm-tx — frontend reports a confirmed on-chain transaction\n    92→  app.post(\"/confirm-tx\", async (c) => {\n    93→    const wallet = c.get(\"wallet\");\n    94→    if (!wallet) {\n    95→      return c.json({ error: \"Authentication required\" }, 401);\n    96→    }\n    97→\n    98→    const body = await c.req.json<{\n    99→      game?: string;\n   100→      matchId?: string;\n   101→      txType?: string;\n   102→      txSig?: string;\n   103→      amountLamports?: number;\n   104→    }>();\n   105→\n   106→    if (!body.game || !body.matchId || !body.txType || !body.txSig || !body.amountLamports) {\n   107→      return c.json({ error: \"Missing required fields: game, matchId, txType, txSig, amountLamports\" }, 400);\n   108→    }\n   109→\n   110→    const validTypes = [\"deposit\", \"refund\"];\n   111→    if (!validTypes.includes(body.txType)) {\n   112→      return c.json({ error: `Invalid txType: ${body.txType}. Must be one of: ${validTypes.join(\", \")}` }, 400);\n   113→    }\n   114→\n   115→    // Map to DB game name\n   116→    const dbGame = TO_DB_GAME[body.game];\n   117→    if (!dbGame) {\n   118→      return c.json({ error: `Invalid game: ${body.game}` }, 400);\n   119→    }\n   120→\n   121→    try {\n   122→      await db.insertTransaction({\n   123→        wallet,\n   124→        game: dbGame,\n   125→        matchId: body.matchId,\n   126→        txType: body.txType as \"deposit\" | \"refund\",\n   127→        amountLamports: body.amountLamports,\n   128→        txSig: body.txSig,\n   129→      });\n   130→      return c.json({ ok: true });\n   131→    } catch (err) {\n   132→      logger.error(\"confirm-tx failed\", {\n   133→        wallet,\n   134→        txType: body.txType,\n   135→        error: err instanceof Error ? err.message : \"Unknown error\",\n   136→      });\n   137→      return c.json({ error: \"Failed to record transaction\" }, 500);\n   138→    }\n   139→  });\n   140→\n   141→  return app;\n   142→}\n   143→"}]},"parent_tool_use_id":"toolu_011BAH9Yk1HJbAWRUnFawaL4","session_id":"3d179094-b1ae-4405-8e43-449089b7a949","uuid":"1a0f2da4-3357-4546-9753-530f286e6717","timestamp":"2026-03-25T11:59:20.403Z"}
