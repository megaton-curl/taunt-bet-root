{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L4wf5DuRT67YzHkCusd5zm","type":"tool_result","content":"     1→/**\n     2→ * Thin fetch wrappers for the /referral/* backend endpoints.\n     3→ * All calls require JWT Bearer auth from useSession().accessToken.\n     4→ */\n     5→\n     6→const BACKEND_URL = (\n     7→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n     8→    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n     9→).replace(/\\/$/, \"\");\n    10→\n    11→/* ── Response types ─────────────────────────────────────────────── */\n    12→\n    13→export interface ReferralCodeResponse {\n    14→  code: string;\n    15→  url: string;\n    16→}\n    17→\n    18→export interface ApplyReferralResponse {\n    19→  referrer: string;\n    20→  benefit: string;\n    21→}\n    22→\n    23→export interface ReferralStatsResponse {\n    24→  referredCount: number;\n    25→  activeCount: number;\n    26→  totalVolumeLamports: string;\n    27→  totalEarnedLamports: string;\n    28→  pendingLamports: string;\n    29→}\n    30→\n    31→export interface ReferralEarningItem {\n    32→  roundId: string;\n    33→  gameType: string;\n    34→  refereeWallet: string;\n    35→  wagerLamports: string;\n    36→  earnedLamports: string;\n    37→  createdAt: string;\n    38→}\n    39→\n    40→export interface ReferralEarningsResponse {\n    41→  items: ReferralEarningItem[];\n    42→  pagination: { page: number; totalPages: number };\n    43→}\n    44→\n    45→export interface ClaimResponse {\n    46→  claimId: string;\n    47→  amountLamports: string;\n    48→  status: \"pending\" | \"completed\" | \"failed\";\n    49→  txSignature?: string;\n    50→}\n    51→\n    52→/* ── Helpers ────────────────────────────────────────────────────── */\n    53→\n    54→async function parseResponse<T>(res: Response): Promise<T> {\n    55→  const json = await res.json();\n    56→  if (!res.ok) {\n    57→    const err = json?.error;\n    58→    const msg =\n    59→      typeof err === \"string\"\n    60→        ? err\n    61→        : typeof err?.message === \"string\"\n    62→          ? err.message\n    63→          : `Referral request failed (${res.status})`;\n    64→    throw new Error(msg);\n    65→  }\n    66→  return json as T;\n    67→}\n    68→\n    69→function authHeaders(token: string): Record<string, string> {\n    70→  return {\n    71→    \"Content-Type\": \"application/json\",\n    72→    Authorization: `Bearer ${token}`,\n    73→  };\n    74→}\n    75→\n    76→/* ── API functions ──────────────────────────────────────────────── */\n    77→\n    78→/** Set (or replace) the authenticated player's referral code. */\n    79→export async function setReferralCode(\n    80→  token: string,\n    81→  code: string,\n    82→): Promise<ReferralCodeResponse> {\n    83→  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    84→    method: \"POST\",\n    85→    headers: authHeaders(token),\n    86→    body: JSON.stringify({ code }),\n    87→  });\n    88→  return parseResponse<ReferralCodeResponse>(res);\n    89→}\n    90→\n    91→/** Get the authenticated player's current referral code, or throw on 404. */\n    92→export async function getReferralCode(\n    93→  token: string,\n    94→): Promise<ReferralCodeResponse> {\n    95→  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    96→    headers: authHeaders(token),\n    97→  });\n    98→  return parseResponse<ReferralCodeResponse>(res);\n    99→}\n   100→\n   101→/** Apply a referral code to the authenticated player (link to referrer). */\n   102→export async function applyReferralCode(\n   103→  token: string,\n   104→  code: string,\n   105→): Promise<ApplyReferralResponse> {\n   106→  const res = await fetch(`${BACKEND_URL}/referral/apply`, {\n   107→    method: \"POST\",\n   108→    headers: authHeaders(token),\n   109→    body: JSON.stringify({ code }),\n   110→  });\n   111→  return parseResponse<ApplyReferralResponse>(res);\n   112→}\n   113→\n   114→/** Get referral summary stats for the authenticated player. */\n   115→export async function getReferralStats(\n   116→  token: string,\n   117→): Promise<ReferralStatsResponse> {\n   118→  const res = await fetch(`${BACKEND_URL}/referral/stats`, {\n   119→    headers: authHeaders(token),\n   120→  });\n   121→  return parseResponse<ReferralStatsResponse>(res);\n   122→}\n   123→\n   124→/** Get paginated per-game referral earnings log. */\n   125→export async function getReferralEarnings(\n   126→  token: string,\n   127→  page?: number,\n   128→  limit?: number,\n   129→): Promise<ReferralEarningsResponse> {\n   130→  const parts: string[] = [];\n   131→  if (page != null) parts.push(`page=${page}`);\n   132→  if (limit != null) parts.push(`limit=${limit}`);\n   133→  const qs = parts.length ? `?${parts.join(\"&\")}` : \"\";\n   134→  const res = await fetch(`${BACKEND_URL}/referral/earnings${qs}`, {\n   135→    headers: authHeaders(token),\n   136→  });\n   137→  return parseResponse<ReferralEarningsResponse>(res);\n   138→}\n   139→\n   140→/** Request an async claim of all pending referral earnings. Returns 202. */\n   141→export async function requestReferralClaim(\n   142→  token: string,\n   143→): Promise<ClaimResponse> {\n   144→  const res = await fetch(`${BACKEND_URL}/referral/claim`, {\n   145→    method: \"POST\",\n   146→    headers: authHeaders(token),\n   147→  });\n   148→  return parseResponse<ClaimResponse>(res);\n   149→}\n   150→\n   151→/** Poll the status of an existing claim by ID. */\n   152→export async function pollClaimStatus(\n   153→  token: string,\n   154→  claimId: string,\n   155→): Promise<ClaimResponse> {\n   156→  const res = await fetch(`${BACKEND_URL}/referral/claim/${claimId}`, {\n   157→    headers: authHeaders(token),\n   158→  });\n   159→  return parseResponse<ClaimResponse>(res);\n   160→}\n   161→"}]},"parent_tool_use_id":"toolu_01W9CLkr9HqaEarze5DeMrDQ","session_id":"cad61997-ae30-4665-891e-0380cf7cb6d1","uuid":"5c415d57-3167-4c04-8be2-cd29840e4d9a","timestamp":"2026-03-25T13:11:38.511Z"}
