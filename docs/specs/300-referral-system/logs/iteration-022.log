h=\"1\" />\n          <line x1=\"16\" y1=\"118\" x2=\"122\" y2=\"118\" stroke=\"rgba(255,255,255,0.08)\" strokeWidth=\"1\" />\n          <line x1=\"16\" y1=\"84\" x2=\"122\" y2=\"84\" stroke=\"rgba(255,255,255,0.04)\" strokeWidth=\"1\" strokeDasharray=\"3 3\" />\n          <line x1=\"16\" y1=\"52\" x2=\"122\" y2=\"52\" stroke=\"rgba(255,255,255,0.04)\" strokeWidth=\"1\" strokeDasharray=\"3 3\" />\n          <path d=\"M16 118Q34 113 52 96Q70 76 84 54Q94 35 100 18L100 118Z\" fill=\"rgba(255,45,85,0.07)\" />\n          <path className=\"crash-ln\" d=\"M16 118Q34 113 52 96Q70 76 84 54Q94 35 100 18\" stroke=\"#FF2D55\" strokeWidth=\"2.8\" strokeLinecap=\"round\" fill=\"none\" />\n          <circle cx=\"52\" cy=\"96\" r=\"3.5\" fill=\"#00E676\" stroke=\"#0E0E1A\" strokeWidth=\"1.5\" opacity=\"0.9\" />\n          <circle cx=\"70\" cy=\"76\" r=\"3.5\" fill=\"#00E676\" stroke=\"#0E0E1A\" strokeWidth=\"1.5\" opacity=\"0.7\" />\n          <circle cx=\"84\" cy=\"54\" r=\"3\" fill=\"#FFB800\" stroke=\"#0E0E1A\" strokeWidth=\"1.5\" opacity=\"0.8\" />\n          <line x1=\"100\" y1=\"18\" x2=\"107\" y2=\"11\" stroke=\"#FF2D55\" strokeWidth=\"1.5\" strokeLinecap=\"round\" />\n          <line x1=\"100\" y1=\"18\" x2=\"108\" y2=\"20\" stroke=\"#FF2D55\" strokeWidth=\"1.5\" strokeLinecap=\"round\" />\n          <line x1=\"100\" y1=\"18\" x2=\"104\" y2=\"26\" stroke=\"#FF2D55\" strokeWidth=\"1.5\" strokeLinecap=\"round\" />\n          <circle cx=\"116\" cy=\"19\" r=\"11\" fill=\"rgba(255,255,255,0.03)\" stroke=\"rgba(255,255,255,0.1)\" strokeWidth=\"1\" />\n          <path d=\"M116 10C110 10 106 14 106 19C106 24 110 28 116 28C113 26 111 23 111 19C111 15 113 12 116 10Z\" fill=\"rgba(255,255,255,0.12)\" />\n        </svg>\n      );\n\n    case \"trades\":\n      return (\n        <svg className=\"gcard-ico\" viewBox=\"0 0 135 135\" fill=\"none\">\n          <polyline points=\"14,110 32,90 52,98 70,67 88,74 106,42 121,48\" stroke=\"rgba(61,127,255,0.18)\" strokeWidth=\"2\" strokeLinecap=\