{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TBowiFLC5HE6V5FSxQ5zKi","type":"tool_result","content":"     1→/**\n     2→ * SessionContext — JWT session management for wallet authentication.\n     3→ *\n     4→ * Provides sign-once authentication: wallet signs a human-readable challenge\n     5→ * on connect, backend issues JWT access + refresh tokens, and all subsequent\n     6→ * requests use Bearer tokens.\n     7→ */\n     8→\n     9→import {\n    10→  createContext,\n    11→  useContext,\n    12→  useState,\n    13→  useCallback,\n    14→  useEffect,\n    15→  useRef,\n    16→  type ReactNode,\n    17→} from \"react\";\n    18→import bs58 from \"bs58\";\n    19→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n    20→import { SOLANA_CLUSTER } from \"../lib/solana-env\";\n    21→import {\n    22→  requestChallenge,\n    23→  verifyChallenge,\n    24→  refreshSession,\n    25→  logout,\n    26→} from \"../lib/auth-api\";\n    27→import {\n    28→  getAccessToken,\n    29→  setAccessToken,\n    30→  getPersistedSession,\n    31→  setPersistedSession,\n    32→  clearPersistedSession,\n    33→  getAccessExpiresAt,\n    34→} from \"../lib/auth-store\";\n    35→\n    36→interface SessionContextValue {\n    37→  isAuthenticated: boolean;\n    38→  isAuthenticating: boolean;\n    39→  accessToken: string | null;\n    40→  authenticate: () => Promise<string>;\n    41→  clearSession: () => void;\n    42→}\n    43→\n    44→const SessionContext = createContext<SessionContextValue | null>(null);\n    45→\n    46→export function SessionProvider({ children }: { children: ReactNode }) {\n    47→  const { connected, publicKey, signMessage } = useWallet();\n    48→\n    49→  const [isAuthenticated, setIsAuthenticated] = useState(false);\n    50→  const [isAuthenticating, setIsAuthenticating] = useState(false);\n    51→\n    52→  // Mutex for refresh — only one in-flight refresh at a time\n    53→  const refreshPromiseRef = useRef<Promise<boolean> | null>(null);\n    54→  const refreshTimerRef = useRef<number | null>(null);\n    55→  const prevWalletRef = useRef<string | null>(null);\n    56→\n    57→  const clearSession = useCallback(() => {\n    58→    const session = getPersistedSession();\n    59→    if (session) {\n    60→      // Best-effort logout on backend\n    61→      logout(session.refreshToken).catch(() => {});\n    62→    }\n    63→    clearPersistedSession();\n    64→    setIsAuthenticated(false);\n    65→    if (refreshTimerRef.current !== null) {\n    66→      clearTimeout(refreshTimerRef.current);\n    67→      refreshTimerRef.current = null;\n    68→    }\n    69→  }, []);\n    70→\n    71→  // Schedule proactive refresh ~5 min before access token expiry\n    72→  const scheduleRefresh = useCallback(() => {\n    73→    if (refreshTimerRef.current !== null) {\n    74→      clearTimeout(refreshTimerRef.current);\n    75→    }\n    76→\n    77→    const expiresAt = getAccessExpiresAt();\n    78→    if (!expiresAt) return;\n    79→\n    80→    const msUntilExpiry = new Date(expiresAt).getTime() - Date.now();"}]},"parent_tool_use_id":"toolu_01W9CLkr9HqaEarze5DeMrDQ","session_id":"cad61997-ae30-4665-891e-0380cf7cb6d1","uuid":"83c63f8d-98dc-4af6-ac57-ba674236f512","timestamp":"2026-03-25T13:11:38.389Z"}
