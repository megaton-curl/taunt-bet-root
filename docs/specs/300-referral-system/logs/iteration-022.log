{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NRBRcEZEZ3BXTsmrNNqK9G","type":"tool_result","content":"     1→/**\n     2→ * LootPage - Dedicated page for viewing treasure chests and loot rewards\n     3→ */\n     4→\n     5→import { usePlayerProfile } from \"../features/player-profile\";\n     6→import { ProfileLoot } from \"../features/player-profile/components/ProfileLoot\";\n     7→\n     8→export function LootPage() {\n     9→  const { myProfile, loading } = usePlayerProfile();\n    10→\n    11→  if (loading) {\n    12→    return (\n    13→      <div className=\"loot-page\">\n    14→        <div className=\"loot-page__loading\">Loading...</div>\n    15→      </div>\n    16→    );\n    17→  }\n    18→\n    19→  if (!myProfile) {\n    20→    return (\n    21→      <div className=\"loot-page\">\n    22→        <div className=\"loot-page__connect\">\n    23→          <h2>Connect Wallet</h2>\n    24→          <p>Connect your wallet to view your loot.</p>\n    25→        </div>\n    26→      </div>\n    27→    );\n    28→  }\n    29→\n    30→  return (\n    31→    <div className=\"loot-page\">\n    32→      <div className=\"loot-page__header\">\n    33→        <h1 className=\"loot-page__title\">Loot</h1>\n    34→        <p className=\"loot-page__subtitle\">\n    35→          Open crates and claim your rewards\n    36→        </p>\n    37→      </div>\n    38→\n    39→      <div className=\"loot-page__content\">\n    40→        <ProfileLoot profile={myProfile} />\n    41→      </div>\n    42→    </div>\n    43→  );\n    44→}\n    45→"}]},"parent_tool_use_id":"toolu_01W9CLkr9HqaEarze5DeMrDQ","session_id":"cad61997-ae30-4665-891e-0380cf7cb6d1","uuid":"9bf3e219-1d4e-48f4-8aa2-69c4686036dc","timestamp":"2026-03-25T13:11:15.045Z"}
