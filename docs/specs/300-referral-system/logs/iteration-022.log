{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013eHKnpmwz15wjtuxBCt7Uj","type":"tool_result","content":"     1→import { useState, useEffect, useRef } from \"react\";\n     2→import { BrowserRouter, Routes, Route, Link, Navigate, useParams } from \"react-router-dom\";\n     3→import { Header } from \"./components/Header\";\n     4→import { Sidebar } from \"./components/Sidebar\";\n     5→import { Ticker } from \"./components/Ticker\";\n     6→import { BackgroundEffects } from \"./components/BackgroundEffects\";\n     7→import { CoinflipPage } from \"./pages/CoinflipPage\";\n     8→import { LordOfRngsPage } from \"./pages/LordOfRngsPage\";\n     9→import { CloseCallPage } from \"./pages/CloseCallPage\";\n    10→import { CryptoCrashPage } from \"./pages/CryptoCrashPage\";\n    11→import { GameOfTradesPage } from \"./pages/GameOfTradesPage\";\n    12→import { BossRaidProvider } from \"./features/boss-raid\";\n    13→import { PlayerProfileProvider, ProfilePage, MiniProfileModal, PlayerAvatarCompact } from \"./features/player-profile\";\n    14→import { QuestsProvider, ChestDropNotification } from \"./features/quests\";\n    15→import { QuestsPage } from \"./pages/QuestsPage\";\n    16→import { LootPage } from \"./pages/LootPage\";\n    17→import { CoinflipRoundPage } from \"./pages/CoinflipRoundPage\";\n    18→import { LordRoundPage } from \"./pages/LordRoundPage\";\n    19→import { CloseCallRoundPage } from \"./pages/CloseCallRoundPage\";\n    20→import { FairnessPage } from \"./pages/FairnessPage\";\n    21→import { BuildBadge } from \"./components/BuildBadge\";\n    22→import { RouteErrorBoundary } from \"./components/RouteErrorBoundary\";\n    23→import { PriceFeedProvider } from \"@rng-utopia/price-feeds\";\n    24→import { useReferralApply } from \"./features/referral\";\n    25→\n    26→\n    27→export function App() {\n    28→  return (\n    29→    <BrowserRouter>\n    30→      <PriceFeedProvider>\n    31→        <PlayerProfileProvider>\n    32→          <QuestsProvider>\n    33→            <BossRaidProvider>\n    34→              <AppContent />\n    35→            </BossRaidProvider>\n    36→          </QuestsProvider>\n    37→        </PlayerProfileProvider>\n    38→      </PriceFeedProvider>\n    39→    </BrowserRouter>\n    40→  );\n    41→}\n    42→\n    43→\n    44→// Chat icon SVG\n    45→const ChatIcon = () => (\n    46→  <svg viewBox=\"0 0 24 24\" fill=\"currentColor\" width=\"20\" height=\"20\">\n    47→    <path d=\"M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z\"/>\n    48→    <circle cx=\"8\" cy=\"10\" r=\"1.5\"/>\n    49→    <circle cx=\"12\" cy=\"10\" r=\"1.5\"/>\n    50→    <circle cx=\"16\" cy=\"10\" r=\"1.5\"/>\n    51→  </svg>\n    52→);\n    53→\n    54→// Footer component with terms and FAQ modals\n    55→function Footer() {\n    56→  const [showTerms, setShowTerms] = useState(false);\n    57→  const [showFAQ, setShowFAQ] = useState(false);\n    58→  const [expandedFAQ, setExpandedFAQ] = useState<string | null>(null);\n    59→  const termsModalRef = useRef<HTMLDivElement>(null);\n    60→  const faqModalRef = useRef<HTMLDivElement>(null);\n    61→\n    62→  // Close modal on outside click\n    63→  useEffect(() => {\n    64→    if (!showTerms && !showFAQ) return;\n    65→\n    66→    const handleClickOutside = (e: MouseEvent) => {\n    67→      if (showTerms && termsModalRef.current && !termsModalRef.current.contains(e.target as Node)) {\n    68→        setShowTerms(false);\n    69→      }\n    70→      if (showFAQ && faqModalRef.current && !faqModalRef.current.contains(e.target as Node)) {\n    71→        setShowFAQ(false);\n    72→      }\n    73→    };\n    74→\n    75→    document.addEventListener(\"mousedown\", handleClickOutside);\n    76→    return () => document.removeEventListener(\"mousedown\", handleClickOutside);\n    77→  }, [showTerms, showFAQ]);\n    78→\n    79→  // Close on escape\n    80→  useEffect(() => {\n    81→    if (!showTerms && !showFAQ) return;\n    82→\n    83→    const handleEscape = (e: KeyboardEvent) => {\n    84→      if (e.key === \"Escape\") {\n    85→        setShowTerms(false);\n    86→        setShowFAQ(false);\n    87→      }\n    88→    };\n    89→\n    90→    document.addEventListener(\"keydown\", handleEscape);\n    91→    return () => document.removeEventListener(\"keydown\", handleEscape);\n    92→  }, [showTerms, showFAQ]);\n    93→\n    94→  const toggleFAQSection = (section: string) => {\n    95→    setExpandedFAQ(expandedFAQ === section ? null : section);\n    96→  };\n    97→\n    98→  const faqSections = [\n    99→    {\n   100→      id: \"fees\",\n   101→      title: \"Platform Fees\",\n   102→      content: `TAUNT charges a 5% platform fee on all games. This means 95% of all wagered funds go directly to winners.\n   103→\n   104→Fee breakdown:\n   105→• 5% total platform fee on every settled pot\n   106→• Funds cover player incentives (Dogpile Raid reward pool, future promotions) and platform treasury (server costs, development, operations)\n   107→\n   108→What you get:\n   109→• Winners receive: 95% of the pot\n   110→• No hidden fees or withdrawal charges\n   111→• Part of your wagers fund rewards you can win back through Dogpile Raid`\n   112→    },\n   113→    {\n   114→      id: \"raid-boss\",\n   115→      title: \"What is Dogpile Raid?\",\n   116→      content: `Dogpile Raid is a community reward mechanic where players collectively take down a Mark by playing games.\n   117→\n   118→How it works:\n   119→• A new Mark spawns every hour with a 50-minute active phase\n   120→• Every wager you make in any game lands \"hits\" on the Mark\n   121→• The Mark's Armor drains over time - it's always dropped when the timer ends\n   122→• When dropped, the reward pool is distributed to all participants\n   123→\n   124→Rewards:\n   125→• Your share is proportional to your hit contribution\n   126→• The reward pool grows from 1% of all wagers during the raid\n   127→• Higher total community hits = better loot tier = bigger multipliers\n   128→• Bonus loot is occasionally added for extra rewards\n   129→\n   130→Loot Tiers (based on total hits):\n   131→• Bronze: 0-10 SOL in hits\n   132→• Silver: 10-50 SOL in hits\n   133→• Gold: 50-150 SOL in hits\n   134→• Platinum: 150-500 SOL in hits\n   135→• Diamond: 500+ SOL in hits`\n   136→    },\n   137→    {\n   138→      id: \"pvp\",\n   139→      title: \"Why PvP Games?\",\n   140→      content: `Unlike traditional house-edge gambling where you play against the casino, TAUNT is 100% player-vs-player. This creates a fundamentally fairer system:\n   141→\n   142→• No house edge exploiting players\n   143→• Prize pools come entirely from player wagers\n   144→• The platform only takes a small facilitation fee\n   145→• Better odds than any traditional casino\n   146→• Transparent, skill-independent wagering`\n   147→    },\n   148→    {\n   149→      id: \"wagers\",\n   150→      title: \"Custom Wagers\","}]},"parent_tool_use_id":"toolu_01W9CLkr9HqaEarze5DeMrDQ","session_id":"cad61997-ae30-4665-891e-0380cf7cb6d1","uuid":"a7b1a3f3-30dc-4437-ae81-e8836970d94f","timestamp":"2026-03-25T13:11:14.479Z"}
