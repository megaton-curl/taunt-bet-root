{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LsisxiMc5NRfHDpK9N6PUC","type":"tool_result","content":"     1→import { Component, type ReactNode, type ErrorInfo } from \"react\";\n     2→\n     3→interface Props {\n     4→  children: ReactNode;\n     5→  /** Shown in the error UI so the player knows which area broke. */\n     6→  label?: string;\n     7→}\n     8→\n     9→interface State {\n    10→  hasError: boolean;\n    11→  error: Error | null;\n    12→}\n    13→\n    14→/**\n    15→ * Per-route error boundary — catches render crashes in a single feature\n    16→ * without tearing down the whole app (sidebar, header, other games stay alive).\n    17→ */\n    18→export class RouteErrorBoundary extends Component<Props, State> {\n    19→  constructor(props: Props) {\n    20→    super(props);\n    21→    this.state = { hasError: false, error: null };\n    22→  }\n    23→\n    24→  static getDerivedStateFromError(error: Error): Partial<State> {\n    25→    return { hasError: true, error };\n    26→  }\n    27→\n    28→  componentDidCatch(error: Error, info: ErrorInfo): void {\n    29→    console.error(`[RouteErrorBoundary${this.props.label ? ` — ${this.props.label}` : \"\"}]`, error, info);\n    30→  }\n    31→\n    32→  render() {\n    33→    if (!this.state.hasError) return this.props.children;\n    34→\n    35→    return (\n    36→      <div className=\"route-error\">\n    37→        <h2 className=\"route-error__title\">Something went wrong</h2>\n    38→        {this.props.label && (\n    39→          <p className=\"route-error__label\">{this.props.label} hit an error.</p>\n    40→        )}\n    41→        <pre className=\"route-error__detail\">{this.state.error?.message}</pre>\n    42→        <button\n    43→          type=\"button\"\n    44→          className=\"route-error__retry\"\n    45→          onClick={() => this.setState({ hasError: false, error: null })}\n    46→        >\n    47→          Try Again\n    48→        </button>\n    49→      </div>\n    50→    );\n    51→  }\n    52→}\n    53→"}]},"parent_tool_use_id":"toolu_01W9CLkr9HqaEarze5DeMrDQ","session_id":"cad61997-ae30-4665-891e-0380cf7cb6d1","uuid":"dbe5f56a-34ba-406b-a6bd-a6197fb44cb9","timestamp":"2026-03-25T13:11:24.522Z"}
