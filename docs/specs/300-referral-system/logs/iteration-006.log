{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KaUKoEBotky4hoZmugMj9Z","type":"tool_result","content":"     1→/**\n     2→ * Database client module — typed query functions for `rounds` and `operator_events`.\n     3→ *\n     4→ * Phase transitions are unidirectional: created → locked → settling → settled,\n     5→ * or created → expired. The application layer rejects backward transitions.\n     6→ */\n     7→\n     8→import postgres from \"postgres\";\n     9→\n    10→// ---------------------------------------------------------------------------\n    11→// Types\n    12→// ---------------------------------------------------------------------------\n    13→\n    14→export type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    15→\n    16→export type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n    17→export type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n    18→\n    19→export interface CloseCallRound {\n    20→  round_id: string;\n    21→  pda: string;\n    22→  server_key: string;\n    23→  phase: CloseCallPhase;\n    24→  open_price: number;\n    25→  open_price_expo: number;\n    26→  close_price: number | null;\n    27→  outcome: CloseCallOutcome;\n    28→  green_pool: number;\n    29→  red_pool: number;\n    30→  total_fee: number;\n    31→  green_entries: Array<{ player: string; amountLamports: number }>;\n    32→  red_entries: Array<{ player: string; amountLamports: number }>;\n    33→  settle_tx: string | null;\n    34→  created_at: Date;\n    35→  settled_at: Date | null;\n    36→}\n    37→\n    38→export interface InsertCloseCallRoundParams {\n    39→  roundId: string;\n    40→  pda: string;\n    41→  serverKey: string;\n    42→  openPrice: number;\n    43→  openPriceExpo: number;\n    44→}\n    45→\n    46→export type OperatorEventType =\n    47→  | \"secret_generated\"\n    48→  | \"tx_built\"\n    49→  | \"match_detected\"\n    50→  | \"settle_submitted\"\n    51→  | \"settle_confirmed\"\n    52→  | \"settle_failed\"\n    53→  | \"settle_retried\"\n    54→  | \"timeout_detected\";\n    55→\n    56→export interface Round {\n    57→  pda: string;\n    58→  game: string;\n    59→  creator: string;\n    60→  server_key: string;\n    61→  secret: Buffer;\n    62→  commitment: Buffer;\n    63→  amount_lamports: number;\n    64→  side: number;\n    65→  match_id: string;\n    66→  phase: RoundPhase;\n    67→  target_slot: string | null;\n    68→  settle_tx: string | null;\n    69→  settle_attempts: number;\n    70→  result_hash: Buffer | null;\n    71→  result_side: number | null;\n    72→  winner: string | null;\n    73→  entries: unknown | null;\n    74→  created_at: Date;\n    75→  updated_at: Date;\n    76→}\n    77→\n    78→export interface InsertRoundParams {\n    79→  pda: string;\n    80→  game: string;\n    81→  creator: string;\n    82→  serverKey: string;\n    83→  secret: Buffer;\n    84→  commitment: Buffer;\n    85→  amountLamports: number;\n    86→  side: number;\n    87→  matchId: string;\n    88→  phase: RoundPhase;\n    89→  entries?: Array<{ player: string; amountLamports: number }>;\n    90→}\n    91→\n    92→export interface OperatorEvent {\n    93→  id: string;\n    94→  pda: string | null;\n    95→  event_type: OperatorEventType;\n    96→  payload: unknown;\n    97→  created_at: Date;\n    98→}\n    99→\n   100→// ---------------------------------------------------------------------------\n   101→// Transaction types\n   102→// ---------------------------------------------------------------------------\n   103→\n   104→export type TransactionType = \"deposit\" | \"payout\" | \"refund\";\n   105→\n   106→export interface Transaction {\n   107→  id: string;\n   108→  wallet: string;\n   109→  game: string;\n   110→  match_id: string;\n   111→  tx_type: TransactionType;\n   112→  amount_lamports: number;\n   113→  tx_sig: string;\n   114→  created_at: Date;\n   115→}\n   116→\n   117→export interface InsertTransactionParams {\n   118→  wallet: string;\n   119→  game: string;\n   120→  matchId: string;\n   121→  txType: TransactionType;\n   122→  amountLamports: number;\n   123→  txSig: string;\n   124→}\n   125→\n   126→// ---------------------------------------------------------------------------\n   127→// Referral types\n   128→// ---------------------------------------------------------------------------\n   129→\n   130→export interface ReferralCode {\n   131→  id: number;\n   132→  wallet: string;\n   133→  code: string;\n   134→  created_at: Date;\n   135→  updated_at: Date;\n   136→}\n   137→\n   138→export interface ReferralLink {\n   139→  id: number;\n   140→  referrer_wallet: string;\n   141→  referee_wallet: string;\n   142→  created_at: Date;\n   143→}\n   144→\n   145→export interface ReferralEarning {\n   146→  id: number;\n   147→  referrer_wallet: string;\n   148→  referee_wallet: string;\n   149→  round_id: string;\n   150→  game_type: string;\n   151→  wager_lamports: number;\n   152→  fee_lamports: number;\n   153→  referrer_earned_lamports: number;\n   154→  referrer_rate_bps: number;\n   155→  referee_rebate_lamports: number;\n   156→  referee_rebate_rate_bps: number;\n   157→  created_at: Date;\n   158→}\n   159→\n   160→export interface ReferralStats {\n   161→  referred_count: number;\n   162→  active_count: number;\n   163→  total_volume_lamports: string;\n   164→  total_earned_lamports: string;\n   165→  pending_lamports: string;\n   166→}\n   167→\n   168→// ---------------------------------------------------------------------------\n   169→// Phase transition guard\n   170→// ---------------------------------------------------------------------------\n   171→\n   172→/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n   173→const VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n   174→  created: [\"locked\", \"expired\"],\n   175→  locked: [\"settling\"],\n   176→  settling: [\"settled\"],\n   177→  settled: [],\n   178→  expired: [],\n   179→};\n   180→\n   181→function assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n   182→  const allowed = VALID_TRANSITIONS[from];\n   183→  if (!allowed.includes(to)) {\n   184→    throw new Error(\n   185→      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n   186→    );\n   187→  }\n   188→}\n   189→\n   190→// ---------------------------------------------------------------------------\n   191→// DB client\n   192→// ---------------------------------------------------------------------------\n   193→\n   194→export interface Db {\n   195→  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n   196→  insertRound(params: InsertRoundParams): Promise<Round>;\n   197→\n   198→  /** Delete a round by PDA. Returns true if a row was removed. */\n   199→  deleteRoundByPda(pda: string): Promise<boolean>;\n   200→\n   201→  /** Transition a round's phase. Enforces unidirectional state machine.\n   202→   *  Optional `updates` can set additional columns alongside the phase change. */\n   203→  updateRoundPhase(\n   204→    pda: string,\n   205→    newPhase: RoundPhase,\n   206→    updates?: Partial<\n   207→      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n   208→    >,\n   209→  ): Promise<Round>;\n   210→\n   211→  /** Update the entries JSONB column for a settled round. */\n   212→  updateRoundEntries(\n   213→    pda: string,\n   214→    entries: Array<{ player: string; amountLamports: number }>,\n   215→  ): Promise<Round>;\n   216→\n   217→  /** Get a single round by its PDA. Returns `undefined` if not found. */\n   218→  getRoundByPda(pda: string): Promise<Round | undefined>;\n   219→\n   220→  /** Get all rounds matching a given phase. */\n   221→  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n   222→\n   223→  /** Append an operator event to the audit log. */\n   224→  insertOperatorEvent(\n   225→    pda: string | null,\n   226→    eventType: OperatorEventType,\n   227→    payload?: unknown,\n   228→  ): Promise<OperatorEvent>;\n   229→\n   230→  /** Get the latest operator event for a PDA + type. */\n   231→  getLatestOperatorEvent(\n   232→    pda: string,\n   233→    eventType: OperatorEventType,\n   234→  ): Promise<OperatorEvent | undefined>;\n   235→\n   236→  /** Get a single round by its match_id. Returns `undefined` if not found. */\n   237→  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n   238→\n   239→  /** Batch-fetch the latest operator event per PDA for a given event type. */\n   240→  getLatestOperatorEventsForPdas(\n   241→    pdas: string[],\n   242→    eventType: OperatorEventType,\n   243→  ): Promise<Map<string, OperatorEvent>>;\n   244→\n   245→  /** Get recently settled rounds for a game, ordered newest first. */\n   246→  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n   247→\n   248→  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n   249→  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n   250→\n   251→  // -------------------------------------------------------------------------\n   252→  // Close Call rounds\n   253→  // -------------------------------------------------------------------------\n   254→\n   255→  /** Insert a new Close Call round. */\n   256→  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n   257→\n   258→  /** Get a Close Call round by round_id (16-char hex). */\n   259→  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n   260→\n   261→  /** Get the current active (open) Close Call round. */\n   262→  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n   263→\n   264→  /** Get the most recent settled/refunded Close Call rounds. */\n   265→  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n   266→\n   267→  /** Update a Close Call round after settlement. */\n   268→  settleCloseCallRound(\n   269→    roundId: string,\n   270→    updates: {\n   271→      phase: CloseCallPhase;\n   272→      outcome: CloseCallOutcome;\n   273→      closePrice?: number;\n   274→      greenPool?: number;\n   275→      redPool?: number;\n   276→      totalFee?: number;\n   277→      greenEntries?: Array<{ player: string; amountLamports: number }>;\n   278→      redEntries?: Array<{ player: string; amountLamports: number }>;\n   279→      settleTx?: string;\n   280→    },\n   281→  ): Promise<CloseCallRound>;\n   282→\n   283→  // -------------------------------------------------------------------------\n   284→  // Transactions\n   285→  // -------------------------------------------------------------------------\n   286→\n   287→  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n   288→  insertTransaction(params: InsertTransactionParams): Promise<void>;\n   289→\n   290→  /** Insert multiple transactions in a single batch. */\n   291→  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n   292→\n   293→  /** Get paginated transactions for a wallet, newest first. */\n   294→  getTransactions(\n   295→    wallet: string,\n   296→    cursor?: string,\n   297→    limit?: number,\n   298→    game?: string,\n   299→  ): Promise<Transaction[]>;\n   300→\n   301→  // -------------------------------------------------------------------------\n   302→  // Referral — codes\n   303→  // -------------------------------------------------------------------------\n   304→\n   305→  /** Insert a new referral code for a wallet. Throws on duplicate wallet or code. */\n   306→  insertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n   307→\n   308→  /** Get a wallet's referral code. Returns `undefined` if none set. */\n   309→  getReferralCodeByWallet(wallet: string): Promise<ReferralCode | undefined>;\n   310→\n   311→  /** Look up a referral code record by code string. Returns `undefined` if not found. */\n   312→  getReferralCodeByCode(code: string): Promise<ReferralCode | undefined>;\n   313→\n   314→  /** Set or replace a wallet's referral code (INSERT … ON CONFLICT UPDATE). */\n   315→  upsertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n   316→\n   317→  // -------------------------------------------------------------------------\n   318→  // Referral — links\n   319→  // -------------------------------------------------------------------------\n   320→\n   321→  /** Create a referral link (referrer → referee). Throws on duplicate referee. */\n   322→  insertReferralLink(referrerWallet: string, refereeWallet: string): Promise<ReferralLink>;\n   323→\n   324→  /** Get the referral link for a referee wallet. Returns `undefined` if not referred. */\n   325→  getReferralLinkByReferee(refereeWallet: string): Promise<ReferralLink | undefined>;\n   326→\n   327→  /** Get all referral links where the given wallet is the referrer. */\n   328→  getReferralLinksByReferrer(referrerWallet: string): Promise<ReferralLink[]>;\n   329→\n   330→  // -------------------------------------------------------------------------\n   331→  // Referral — earnings & stats\n   332→  // -------------------------------------------------------------------------\n   333→\n   334→  /** Insert a referral earning row. Throws on duplicate (referee_wallet, round_id). */\n   335→  insertReferralEarning(params: {\n   336→    referrerWallet: string;\n   337→    refereeWallet: string;\n   338→    roundId: string;\n   339→    gameType: string;\n   340→    wagerLamports: number;\n   341→    feeLamports: number;\n   342→    referrerEarnedLamports: number;\n   343→    referrerRateBps: number;\n   344→    refereeRebateLamports: number;\n   345→    refereeRebateRateBps: number;\n   346→  }): Promise<ReferralEarning>;\n   347→\n   348→  /**\n   349→   * Get the pending (unclaimed) balance for a wallet.\n   350→   * Sum of referrer_earned where wallet=referrer + sum of referee_rebate where\n   351→   * wallet=referee, minus sum of completed claims for the wallet.\n   352→   * Returns a lamport string.\n   353→   */\n   354→  getPendingBalance(wallet: string): Promise<string>;\n   355→\n   356→  /** Get paginated per-game earnings for a wallet (as referrer). Newest first. */\n   357→  getReferralEarnings(\n   358→    wallet: string,\n   359→    page: number,\n   360→    limit: number,\n   361→  ): Promise<{ items: ReferralEarning[]; totalPages: number }>;\n   362→\n   363→  /** Get referral summary stats for a wallet. */\n   364→  getReferralStats(wallet: string): Promise<ReferralStats>;\n   365→\n   366→  /** Gracefully close the connection pool. */\n   367→  close(): Promise<void>;\n   368→}\n   369→\n   370→function normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n   371→  return {\n   372→    ...row,\n   373→    open_price: Number(row.open_price),\n   374→    open_price_expo: Number(row.open_price_expo),\n   375→    close_price: row.close_price === null ? null : Number(row.close_price),\n   376→    green_pool: Number(row.green_pool),\n   377→    red_pool: Number(row.red_pool),\n   378→    total_fee: Number(row.total_fee),\n   379→    // JSONB comes back as parsed objects from postgres.js\n   380→    green_entries: Array.isArray(row.green_entries)\n   381→      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   382→      : [],\n   383→    red_entries: Array.isArray(row.red_entries)\n   384→      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   385→      : [],\n   386→  };\n   387→}\n   388→\n   389→function normalizeTransaction(row: Transaction): Transaction {\n   390→  return {\n   391→    ...row,\n   392→    amount_lamports: Number(row.amount_lamports),\n   393→  };\n   394→}\n   395→\n   396→function normalizeReferralEarning(row: ReferralEarning): ReferralEarning {\n   397→  return {\n   398→    ...row,\n   399→    wager_lamports: Number(row.wager_lamports),\n   400→    fee_lamports: Number(row.fee_lamports),\n   401→    referrer_earned_lamports: Number(row.referrer_earned_lamports),\n   402→    referrer_rate_bps: Number(row.referrer_rate_bps),\n   403→    referee_rebate_lamports: Number(row.referee_rebate_lamports),\n   404→    referee_rebate_rate_bps: Number(row.referee_rebate_rate_bps),\n   405→  };\n   406→}\n   407→\n   408→function normalizeRound(row: Round): Round {\n   409→  return {\n   410→    ...row,\n   411→    amount_lamports: Number(row.amount_lamports),\n   412→    side: Number(row.side),\n   413→    settle_attempts: Number(row.settle_attempts),\n   414→    result_side: row.result_side === null ? null : Number(row.result_side),\n   415→    // JSONB comes back as parsed objects from postgres.js\n   416→    entries: Array.isArray(row.entries)\n   417→      ? (row.entries as Array<{ player: string; amountLamports: number }>).map((e) => ({\n   418→          player: e.player,\n   419→          amountLamports: Number(e.amountLamports),\n   420→        }))\n   421→      : null,\n   422→  };\n   423→}\n   424→\n   425→export function createDb(databaseUrl: string): Db {\n   426→  const sql = postgres(databaseUrl);\n   427→\n   428→  return {\n   429→    async insertRound(params) {\n   430→      const rows = await sql<Round[]>`\n   431→        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase, entries)\n   432→        VALUES (\n   433→          ${params.pda},\n   434→          ${params.game},\n   435→          ${params.creator},\n   436→          ${params.serverKey},\n   437→          ${params.secret},\n   438→          ${params.commitment},\n   439→          ${params.amountLamports},\n   440→          ${params.side},\n   441→          ${params.matchId},\n   442→          ${params.phase},\n   443→          ${params.entries ? sql.json(params.entries) : null}\n   444→        )\n   445→        RETURNING *\n   446→      `;\n   447→      return normalizeRound(rows[0]!);\n   448→    },\n   449→\n   450→    async deleteRoundByPda(pda) {\n   451→      const rows = await sql<{ pda: string }[]>`\n   452→        DELETE FROM rounds WHERE pda = ${pda}\n   453→        RETURNING pda\n   454→      `;\n   455→      return rows.length > 0;\n   456→    },\n   457→\n   458→    async updateRoundPhase(pda, newPhase, updates) {\n   459→      // Fetch current phase to validate transition\n   460→      const current = await sql<Pick<Round, \"phase\">[]>`\n   461→        SELECT phase FROM rounds WHERE pda = ${pda}\n   462→      `;\n   463→\n   464→      if (current.length === 0) {\n   465→        throw new Error(`Round not found: ${pda}`);\n   466→      }\n   467→\n   468→      const currentPhase = current[0]!.phase as RoundPhase;\n   469→      assertPhaseTransition(currentPhase, newPhase);\n   470→\n   471→      // Build the update — always set phase + updated_at\n   472→      const rows = await sql<Round[]>`\n   473→        UPDATE rounds SET\n   474→          phase = ${newPhase},\n   475→          updated_at = now(),\n   476→          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n   477→          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n   478→          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n   479→          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n   480→          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n   481→          winner = COALESCE(${updates?.winner ?? null}, winner)\n   482→        WHERE pda = ${pda}\n   483→        RETURNING *\n   484→      `;\n   485→\n   486→      return normalizeRound(rows[0]!);\n   487→    },\n   488→\n   489→    async updateRoundEntries(pda, entries) {\n   490→      const rows = await sql<Round[]>`\n   491→        UPDATE rounds SET\n   492→          entries = ${sql.json(entries)},\n   493→          updated_at = now()\n   494→        WHERE pda = ${pda}\n   495→        RETURNING *\n   496→      `;\n   497→      if (rows.length === 0) {\n   498→        throw new Error(`Round not found: ${pda}`);\n   499→      }\n   500→      return normalizeRound(rows[0]!);\n   501→    },\n   502→\n   503→    async getRoundByPda(pda) {\n   504→      const rows = await sql<Round[]>`\n   505→        SELECT * FROM rounds WHERE pda = ${pda}\n   506→      `;\n   507→      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   508→    },\n   509→\n   510→    async getRoundByMatchId(matchId) {\n   511→      const rows = await sql<Round[]>`\n   512→        SELECT * FROM rounds WHERE match_id = ${matchId}\n   513→      `;\n   514→      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   515→    },\n   516→\n   517→    async getRoundsByPhase(phase) {\n   518→      const rows = await sql<Round[]>`\n   519→        SELECT * FROM rounds WHERE phase = ${phase}\n   520→      `;\n   521→      return rows.map(normalizeRound);\n   522→    },\n   523→\n   524→    async insertOperatorEvent(pda, eventType, payload) {\n   525→      const rows = await sql<OperatorEvent[]>`\n   526→        INSERT INTO operator_events (pda, event_type, payload)\n   527→        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n   528→        RETURNING *\n   529→      `;\n   530→      return rows[0]!;\n   531→    },\n   532→\n   533→    async getLatestOperatorEvent(pda, eventType) {\n   534→      const rows = await sql<OperatorEvent[]>`\n   535→        SELECT * FROM operator_events\n   536→        WHERE pda = ${pda} AND event_type = ${eventType}\n   537→        ORDER BY id DESC\n   538→        LIMIT 1\n   539→      `;\n   540→      return rows[0];\n   541→    },\n   542→\n   543→    async getLatestOperatorEventsForPdas(pdas, eventType) {\n   544→      if (pdas.length === 0) return new Map();\n   545→      const rows = await sql<OperatorEvent[]>`\n   546→        SELECT DISTINCT ON (pda) *\n   547→        FROM operator_events\n   548→        WHERE pda = ANY(${pdas}) AND event_type = ${eventType}\n   549→        ORDER BY pda, id DESC\n   550→      `;\n   551→      const map = new Map<string, OperatorEvent>();\n   552→      for (const row of rows) {\n   553→        if (row.pda) map.set(row.pda, row);\n   554→      }\n   555→      return map;\n   556→    },\n   557→\n   558→    async getRecentSettledRounds(game, limit) {\n   559→      const rows = await sql<Round[]>`\n   560→        SELECT * FROM rounds\n   561→        WHERE game = ${game} AND phase = 'settled'\n   562→        ORDER BY updated_at DESC\n   563→        LIMIT ${limit}\n   564→      `;\n   565→      return rows.map(normalizeRound);\n   566→    },\n   567→\n   568→    async getUnsettledStats() {\n   569→      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n   570→        SELECT\n   571→          COUNT(*)::text AS count,\n   572→          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n   573→        FROM rounds\n   574→        WHERE phase NOT IN ('settled', 'expired')\n   575→      `;\n   576→      const row = rows[0]!;\n   577→      return {\n   578→        count: parseInt(row.count, 10),\n   579→        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n   580→      };\n   581→    },\n   582→\n   583→    // -----------------------------------------------------------------------\n   584→    // Close Call rounds\n   585→    // -----------------------------------------------------------------------\n   586→\n   587→    async insertCloseCallRound(params) {\n   588→      const rows = await sql<CloseCallRound[]>`\n   589→        INSERT INTO closecall_rounds (round_id, pda, server_key, open_price, open_price_expo)\n   590→        VALUES (\n   591→          ${params.roundId},\n   592→          ${params.pda},\n   593→          ${params.serverKey},\n   594→          ${params.openPrice},\n   595→          ${params.openPriceExpo}\n   596→        )\n   597→        RETURNING *\n   598→      `;\n   599→      return normalizeCloseCallRound(rows[0]!);\n   600→    },\n   601→\n   602→    async getCloseCallRound(roundId) {\n   603→      const rows = await sql<CloseCallRound[]>`\n   604→        SELECT * FROM closecall_rounds WHERE round_id = ${roundId}\n   605→      `;\n   606→      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n   607→    },\n   608→\n   609→    async getCloseCallCurrentRound() {\n   610→      const rows = await sql<CloseCallRound[]>`\n   611→        SELECT * FROM closecall_rounds\n   612→        WHERE phase = 'open'\n   613→        ORDER BY created_at DESC\n   614→        LIMIT 1\n   615→      `;\n   616→      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n   617→    },\n   618→\n   619→    async getCloseCallHistory(limit) {\n   620→      const rows = await sql<CloseCallRound[]>`\n   621→        SELECT * FROM closecall_rounds\n   622→        WHERE phase IN ('settled', 'refunded')\n   623→        ORDER BY settled_at DESC\n   624→        LIMIT ${limit}\n   625→      `;\n   626→      return rows.map(normalizeCloseCallRound);\n   627→    },\n   628→\n   629→    async settleCloseCallRound(roundId, updates) {\n   630→      const rows = await sql<CloseCallRound[]>`\n   631→        UPDATE closecall_rounds SET\n   632→          phase = ${updates.phase},\n   633→          outcome = ${updates.outcome},\n   634→          close_price = COALESCE(${updates.closePrice ?? null}, close_price),\n   635→          green_pool = COALESCE(${updates.greenPool ?? null}, green_pool),\n   636→          red_pool = COALESCE(${updates.redPool ?? null}, red_pool),\n   637→          total_fee = COALESCE(${updates.totalFee ?? null}, total_fee),\n   638→          green_entries = COALESCE(${updates.greenEntries ? sql.json(updates.greenEntries) : null}, green_entries),\n   639→          red_entries = COALESCE(${updates.redEntries ? sql.json(updates.redEntries) : null}, red_entries),\n   640→          settle_tx = COALESCE(${updates.settleTx ?? null}, settle_tx),\n   641→          settled_at = now()\n   642→        WHERE round_id = ${roundId}\n   643→        RETURNING *\n   644→      `;\n   645→      if (rows.length === 0) {\n   646→        throw new Error(`Close Call round not found: ${roundId}`);\n   647→      }\n   648→      return normalizeCloseCallRound(rows[0]!);\n   649→    },\n   650→\n   651→    // -----------------------------------------------------------------------\n   652→    // Transactions\n   653→    // -----------------------------------------------------------------------\n   654→\n   655→    async insertTransaction(params) {\n   656→      await sql`\n   657→        INSERT INTO transactions (wallet, game, match_id, tx_type, amount_lamports, tx_sig)\n   658→        VALUES (\n   659→          ${params.wallet},\n   660→          ${params.game},\n   661→          ${params.matchId},\n   662→          ${params.txType},\n   663→          ${params.amountLamports},\n   664→          ${params.txSig}\n   665→        )\n   666→        ON CONFLICT DO NOTHING\n   667→      `;\n   668→    },\n   669→\n   670→    async insertTransactions(params) {\n   671→      if (params.length === 0) return;\n   672→      const values = params.map((p) => ({\n   673→        wallet: p.wallet,\n   674→        game: p.game,\n   675→        match_id: p.matchId,\n   676→        tx_type: p.txType,\n   677→        amount_lamports: p.amountLamports,\n   678→        tx_sig: p.txSig,\n   679→      }));\n   680→      await sql`\n   681→        INSERT INTO transactions ${sql(values, \"wallet\", \"game\", \"match_id\", \"tx_type\", \"amount_lamports\", \"tx_sig\")}\n   682→        ON CONFLICT DO NOTHING\n   683→      `;\n   684→    },\n   685→\n   686→    async getTransactions(wallet, cursor, limit = 20, game) {\n   687→      const effectiveLimit = Math.min(limit, 50);\n   688→      if (cursor && game) {\n   689→        const rows = await sql<Transaction[]>`\n   690→          SELECT * FROM transactions\n   691→          WHERE wallet = ${wallet} AND id < ${cursor} AND game = ${game}\n   692→          ORDER BY id DESC\n   693→          LIMIT ${effectiveLimit}\n   694→        `;\n   695→        return rows.map(normalizeTransaction);\n   696→      }\n   697→      if (cursor) {\n   698→        const rows = await sql<Transaction[]>`\n   699→          SELECT * FROM transactions\n   700→          WHERE wallet = ${wallet} AND id < ${cursor}\n   701→          ORDER BY id DESC\n   702→          LIMIT ${effectiveLimit}\n   703→        `;\n   704→        return rows.map(normalizeTransaction);\n   705→      }\n   706→      if (game) {\n   707→        const rows = await sql<Transaction[]>`\n   708→          SELECT * FROM transactions\n   709→          WHERE wallet = ${wallet} AND game = ${game}\n   710→          ORDER BY id DESC\n   711→          LIMIT ${effectiveLimit}\n   712→        `;\n   713→        return rows.map(normalizeTransaction);\n   714→      }\n   715→      const rows = await sql<Transaction[]>`\n   716→        SELECT * FROM transactions\n   717→        WHERE wallet = ${wallet}\n   718→        ORDER BY id DESC\n   719→        LIMIT ${effectiveLimit}\n   720→      `;\n   721→      return rows.map(normalizeTransaction);\n   722→    },\n   723→\n   724→    // -----------------------------------------------------------------------\n   725→    // Referral — codes\n   726→    // -----------------------------------------------------------------------\n   727→\n   728→    async insertReferralCode(wallet, code) {\n   729→      const rows = await sql<ReferralCode[]>`\n   730→        INSERT INTO referral_codes (wallet, code)\n   731→        VALUES (${wallet}, ${code})\n   732→        RETURNING *\n   733→      `;\n   734→      return rows[0]!;\n   735→    },\n   736→\n   737→    async getReferralCodeByWallet(wallet) {\n   738→      const rows = await sql<ReferralCode[]>`\n   739→        SELECT * FROM referral_codes WHERE wallet = ${wallet}\n   740→      `;\n   741→      return rows[0];\n   742→    },\n   743→\n   744→    async getReferralCodeByCode(code) {\n   745→      const rows = await sql<ReferralCode[]>`\n   746→        SELECT * FROM referral_codes WHERE code = ${code}\n   747→      `;\n   748→      return rows[0];\n   749→    },\n   750→\n   751→    async upsertReferralCode(wallet, code) {\n   752→      const rows = await sql<ReferralCode[]>`\n   753→        INSERT INTO referral_codes (wallet, code)\n   754→        VALUES (${wallet}, ${code})\n   755→        ON CONFLICT (wallet) DO UPDATE SET\n   756→          code = ${code},\n   757→          updated_at = now()\n   758→        RETURNING *\n   759→      `;\n   760→      return rows[0]!;\n   761→    },\n   762→\n   763→    // -- Referral links -------------------------------------------------------\n   764→\n   765→    async insertReferralLink(referrerWallet, refereeWallet) {\n   766→      const rows = await sql<ReferralLink[]>`\n   767→        INSERT INTO referral_links (referrer_wallet, referee_wallet)\n   768→        VALUES (${referrerWallet}, ${refereeWallet})\n   769→        RETURNING *\n   770→      `;\n   771→      return rows[0]!;\n   772→    },\n   773→\n   774→    async getReferralLinkByReferee(refereeWallet) {\n   775→      const rows = await sql<ReferralLink[]>`\n   776→        SELECT * FROM referral_links WHERE referee_wallet = ${refereeWallet}\n   777→      `;\n   778→      return rows[0];\n   779→    },\n   780→\n   781→    async getReferralLinksByReferrer(referrerWallet) {\n   782→      const rows = await sql<ReferralLink[]>`\n   783→        SELECT * FROM referral_links WHERE referrer_wallet = ${referrerWallet}\n   784→        ORDER BY created_at DESC\n   785→      `;\n   786→      return rows;\n   787→    },\n   788→\n   789→    // -- Referral earnings & stats --------------------------------------------\n   790→\n   791→    async insertReferralEarning(params) {\n   792→      const rows = await sql<ReferralEarning[]>`\n   793→        INSERT INTO referral_earnings (\n   794→          referrer_wallet, referee_wallet, round_id, game_type,\n   795→          wager_lamports, fee_lamports,\n   796→          referrer_earned_lamports, referrer_rate_bps,\n   797→          referee_rebate_lamports, referee_rebate_rate_bps\n   798→        ) VALUES (\n   799→          ${params.referrerWallet}, ${params.refereeWallet}, ${params.roundId}, ${params.gameType},\n   800→          ${params.wagerLamports}, ${params.feeLamports},\n   801→          ${params.referrerEarnedLamports}, ${params.referrerRateBps},\n   802→          ${params.refereeRebateLamports}, ${params.refereeRebateRateBps}\n   803→        )\n   804→        RETURNING *\n   805→      `;\n   806→      return normalizeReferralEarning(rows[0]!);\n   807→    },\n   808→\n   809→    async getPendingBalance(wallet) {\n   810→      const rows = await sql<{ pending: string }[]>`\n   811→        SELECT COALESCE(\n   812→          (\n   813→            SELECT SUM(referrer_earned_lamports)\n   814→            FROM referral_earnings WHERE referrer_wallet = ${wallet}\n   815→          ), 0\n   816→        ) + COALESCE(\n   817→          (\n   818→            SELECT SUM(referee_rebate_lamports)\n   819→            FROM referral_earnings WHERE referee_wallet = ${wallet}\n   820→          ), 0\n   821→        ) - COALESCE(\n   822→          (\n   823→            SELECT SUM(amount_lamports)\n   824→            FROM referral_claims WHERE wallet = ${wallet} AND status IN ('pending', 'processing', 'completed')\n   825→          ), 0\n   826→        ) AS pending\n   827→      `;\n   828→      return rows[0]!.pending;\n   829→    },\n   830→\n   831→    async getReferralEarnings(wallet, page, limit) {\n   832→      const offset = (page - 1) * limit;\n   833→      const [countRows, rows] = await Promise.all([\n   834→        sql<{ count: string }[]>`\n   835→          SELECT COUNT(*)::TEXT AS count FROM referral_earnings\n   836→          WHERE referrer_wallet = ${wallet}\n   837→        `,\n   838→        sql<ReferralEarning[]>`\n   839→          SELECT * FROM referral_earnings\n   840→          WHERE referrer_wallet = ${wallet}\n   841→          ORDER BY created_at DESC\n   842→          LIMIT ${limit} OFFSET ${offset}\n   843→        `,\n   844→      ]);\n   845→      const total = Number(countRows[0]!.count);\n   846→      const totalPages = Math.max(1, Math.ceil(total / limit));\n   847→      return { items: rows.map(normalizeReferralEarning), totalPages };\n   848→    },\n   849→\n   850→    async getReferralStats(wallet) {\n   851→      const rows = await sql<ReferralStats[]>`\n   852→        SELECT\n   853→          (SELECT COUNT(*) FROM referral_links WHERE referrer_wallet = ${wallet})::INT\n   854→            AS referred_count,\n   855→          (\n   856→            SELECT COUNT(DISTINCT re.referee_wallet)\n   857→            FROM referral_earnings re\n   858→            JOIN referral_links rl ON rl.referee_wallet = re.referee_wallet AND rl.referrer_wallet = ${wallet}\n   859→            WHERE re.created_at > now() - INTERVAL '7 days'\n   860→          )::INT AS active_count,\n   861→          COALESCE(\n   862→            (\n   863→              SELECT SUM(re.wager_lamports)::TEXT\n   864→              FROM referral_earnings re\n   865→              JOIN referral_links rl ON rl.referee_wallet = re.referee_wallet AND rl.referrer_wallet = ${wallet}\n   866→            ), '0'\n   867→          ) AS total_volume_lamports,\n   868→          COALESCE(\n   869→            (SELECT SUM(referrer_earned_lamports)::TEXT FROM referral_earnings WHERE referrer_wallet = ${wallet}),\n   870→            '0'\n   871→          ) AS total_earned_lamports,\n   872→          (\n   873→            COALESCE((SELECT SUM(referrer_earned_lamports) FROM referral_earnings WHERE referrer_wallet = ${wallet}), 0)\n   874→            + COALESCE((SELECT SUM(referee_rebate_lamports) FROM referral_earnings WHERE referee_wallet = ${wallet}), 0)\n   875→            - COALESCE((SELECT SUM(amount_lamports) FROM referral_claims WHERE wallet = ${wallet} AND status IN ('pending','processing','completed')), 0)\n   876→          )::TEXT AS pending_lamports\n   877→      `;\n   878→      return rows[0]!;\n   879→    },\n   880→\n   881→    async close() {\n   882→      await sql.end();\n   883→    },\n   884→  };\n   885→}\n   886→"}]},"parent_tool_use_id":"toolu_01Rsj1pkNpZEEJ25n9iN64ZV","session_id":"3e0bba06-3e2a-40d1-8fc4-6fd6659fa3ce","uuid":"a0709791-8685-47ab-ab67-dee6edc98483","timestamp":"2026-03-25T11:45:22.614Z"}
