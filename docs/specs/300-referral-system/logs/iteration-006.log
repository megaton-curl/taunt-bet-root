{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ArJCaBnVsH9r1rBYh3ycPn","type":"tool_result","content":"     1→/**\n     2→ * Integration tests for the event queue worker.\n     3→ *\n     4→ * Tests the full lifecycle: emit → worker poll → handler dispatch → status transitions.\n     5→ * Requires a running Postgres database (same as backend).\n     6→ *\n     7→ * Covers:\n     8→ * 1. Happy path — handler called, event status = completed\n     9→ * 2. Failure → retry → dead — attempts increment, backoff applied, final status = dead\n    10→ * 3. Concurrent safety — two workers, SKIP LOCKED, each event processed exactly once\n    11→ */\n    12→\n    13→import {\n    14→  describe,\n    15→  it,\n    16→  beforeAll,\n    17→  afterAll,\n    18→  beforeEach,\n    19→  expect,\n    20→} from \"vitest\";\n    21→import postgres from \"postgres\";\n    22→import { emitEvent } from \"../emit-event.js\";\n    23→import {\n    24→  registerHandler,\n    25→  clearHandlers,\n    26→} from \"../handler-registry.js\";\n    27→import { EventTypes } from \"../event-types.js\";\n    28→import { createEventWorker } from \"../worker.js\";\n    29→\n    30→/** Poll until condition is true or timeout. */\n    31→async function waitFor(\n    32→  condition: () => boolean,\n    33→  timeoutMs: number,\n    34→): Promise<void> {\n    35→  const start = Date.now();\n    36→  while (!condition()) {\n    37→    if (Date.now() - start > timeoutMs) {\n    38→      throw new Error(`waitFor timed out after ${timeoutMs}ms`);\n    39→    }\n    40→    await new Promise((r) => setTimeout(r, 50));\n    41→  }\n    42→}\n    43→\n    44→describe(\"event queue integration tests\", () => {\n    45→  let sql: ReturnType<typeof postgres>;\n    46→\n    47→  beforeAll(async () => {\n    48→    sql = process.env.DATABASE_URL\n    49→      ? postgres(process.env.DATABASE_URL)\n    50→      : postgres({\n    51→          host: \"/var/run/postgresql\",\n    52→          database: \"rng_utopia_dev\",\n    53→          username: \"vscode\",\n    54→        });\n    55→  });\n    56→\n    57→  afterAll(async () => {\n    58→    await sql.end();\n    59→  });\n    60→\n    61→  beforeEach(async () => {\n    62→    await sql`TRUNCATE event_queue RESTART IDENTITY`;\n    63→    clearHandlers();\n    64→  });\n    65→\n    66→  // -------------------------------------------------------------------------\n    67→  // 1. Happy path\n    68→  // -------------------------------------------------------------------------\n    69→\n    70→  it(\"happy path: handler called and event status = completed\", async () => {\n    71→    let handlerCalled = false;\n    72→    let capturedPayload: Record<string, unknown> | null = null;\n    73→\n    74→    registerHandler(EventTypes.REFERRAL_GAME_SETTLED, async (payload) => {\n    75→      handlerCalled = true;\n    76→      capturedPayload = payload;\n    77→    });\n    78→\n    79→    const payload = { referrerWallet: \"abc\", roundId: \"test-round\" };\n    80→    await sql.begin(async (tx) => {\n    81→      await emitEvent(\n    82→        tx as unknown as postgres.Sql,\n    83→        EventTypes.REFERRAL_GAME_SETTLED,\n    84→        payload,\n    85→      );\n    86→    });\n    87→\n    88→    const worker = createEventWorker(sql, { pollIntervalMs: 100 });\n    89→    worker.start();\n    90→\n    91→    // Wait for handler to be called (up to 3s)\n    92→    await waitFor(() => handlerCalled, 3000);\n    93→    worker.stop();\n    94→\n    95→    expect(handlerCalled).toBe(true);\n    96→    expect(capturedPayload).toEqual(payload);\n    97→\n    98→    // Verify DB status\n    99→    const rows = await sql`SELECT * FROM event_queue WHERE status = 'completed'`;\n   100→    expect(rows).toHaveLength(1);"}]},"parent_tool_use_id":"toolu_01RV1VboAcMDf4MT4RSfBWWe","session_id":"3e0bba06-3e2a-40d1-8fc4-6fd6659fa3ce","uuid":"577ac6d7-e8d4-4ce2-b7d8-508c0c5a8b7f","timestamp":"2026-03-25T11:46:53.922Z"}
