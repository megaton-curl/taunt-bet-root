{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RkXjmK3m7kpfsAv7UbzWNR","type":"tool_result","content":"   330→  // -------------------------------------------------------------------------\n   331→  // Referral — earnings & stats\n   332→  // -------------------------------------------------------------------------\n   333→\n   334→  /** Insert a referral earning row. Throws on duplicate (referee_wallet, round_id). */\n   335→  insertReferralEarning(params: {\n   336→    referrerWallet: string;\n   337→    refereeWallet: string;\n   338→    roundId: string;\n   339→    gameType: string;\n   340→    wagerLamports: number;\n   341→    feeLamports: number;\n   342→    referrerEarnedLamports: number;\n   343→    referrerRateBps: number;\n   344→    refereeRebateLamports: number;\n   345→    refereeRebateRateBps: number;\n   346→  }): Promise<ReferralEarning>;\n   347→\n   348→  /**\n   349→   * Get the pending (unclaimed) balance for a wallet.\n   350→   * Sum of referrer_earned where wallet=referrer + sum of referee_rebate where\n   351→   * wallet=referee, minus sum of completed claims for the wallet.\n   352→   * Returns a lamport string.\n   353→   */\n   354→  getPendingBalance(wallet: string): Promise<string>;\n   355→\n   356→  /** Get paginated per-game earnings for a wallet (as referrer). Newest first. */\n   357→  getReferralEarnings(\n   358→    wallet: string,\n   359→    page: number,\n   360→    limit: number,\n   361→  ): Promise<{ items: ReferralEarning[]; totalPages: number }>;\n   362→\n   363→  /** Get referral summary stats for a wallet. */\n   364→  getReferralStats(wallet: string): Promise<ReferralStats>;\n   365→\n   366→  /** Gracefully close the connection pool. */\n   367→  close(): Promise<void>;\n   368→}\n   369→\n   370→function normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n   371→  return {\n   372→    ...row,\n   373→    open_price: Number(row.open_price),\n   374→    open_price_expo: Number(row.open_price_expo),\n   375→    close_price: row.close_price === null ? null : Number(row.close_price),\n   376→    green_pool: Number(row.green_pool),\n   377→    red_pool: Number(row.red_pool),\n   378→    total_fee: Number(row.total_fee),\n   379→    // JSONB comes back as parsed objects from postgres.js\n   380→    green_entries: Array.isArray(row.green_entries)\n   381→      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   382→      : [],\n   383→    red_entries: Array.isArray(row.red_entries)\n   384→      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   385→      : [],\n   386→  };\n   387→}\n   388→\n   389→function normalizeTransaction(row: Transaction): Transaction {\n   390→  return {\n   391→    ...row,\n   392→    amount_lamports: Number(row.amount_lamports),\n   393→  };\n   394→}\n   395→\n   396→function normalizeReferralEarning(row: ReferralEarning): ReferralEarning {\n   397→  return {\n   398→    ...row,\n   399→    wager_lamports: Number(row.wager_lamports),\n   400→    fee_lamports: Number(row.fee_lamports),\n   401→    referrer_earned_lamports: Number(row.referrer_earned_lamports),\n   402→    referrer_rate_bps: Number(row.referrer_rate_bps),\n   403→    referee_rebate_lamports: Number(row.referee_rebate_lamports),\n   404→    referee_rebate_rate_bps: Number(row.referee_rebate_rate_bps),\n   405→  };\n   406→}\n   407→\n   408→function normalizeRound(row: Round): Round {\n   409→  return {\n   410→    ...row,\n   411→    amount_lamports: Number(row.amount_lamports),\n   412→    side: Number(row.side),\n   413→    settle_attempts: Number(row.settle_attempts),\n   414→    result_side: row.result_side === null ? null : Number(row.result_side),\n   415→    // JSONB comes back as parsed objects from postgres.js\n   416→    entries: Array.isArray(row.entries)\n   417→      ? (row.entries as Array<{ player: string; amountLamports: number }>).map((e) => ({\n   418→          player: e.player,\n   419→          amountLamports: Number(e.amountLamports),\n   420→        }))\n   421→      : null,\n   422→  };\n   423→}\n   424→\n   425→export function createDb(databaseUrl: string): Db {\n   426→  const sql = postgres(databaseUrl);\n   427→\n   428→  return {\n   429→    async insertRound(params) {\n   430→      const rows = await sql<Round[]>`\n   431→        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase, entries)\n   432→        VALUES (\n   433→          ${params.pda},\n   434→          ${params.game},\n   435→          ${params.creator},\n   436→          ${params.serverKey},\n   437→          ${params.secret},\n   438→          ${params.commitment},\n   439→          ${params.amountLamports},\n   440→          ${params.side},\n   441→          ${params.matchId},\n   442→          ${params.phase},\n   443→          ${params.entries ? sql.json(params.entries) : null}\n   444→        )\n   445→        RETURNING *\n   446→      `;\n   447→      return normalizeRound(rows[0]!);\n   448→    },\n   449→\n   450→    async deleteRoundByPda(pda) {\n   451→      const rows = await sql<{ pda: string }[]>`\n   452→        DELETE FROM rounds WHERE pda = ${pda}\n   453→        RETURNING pda\n   454→      `;\n   455→      return rows.length > 0;\n   456→    },\n   457→\n   458→    async updateRoundPhase(pda, newPhase, updates) {\n   459→      // Fetch current phase to validate transition\n   460→      const current = await sql<Pick<Round, \"phase\">[]>`\n   461→        SELECT phase FROM rounds WHERE pda = ${pda}\n   462→      `;\n   463→\n   464→      if (current.length === 0) {\n   465→        throw new Error(`Round not found: ${pda}`);\n   466→      }\n   467→\n   468→      const currentPhase = current[0]!.phase as RoundPhase;\n   469→      assertPhaseTransition(currentPhase, newPhase);\n   470→\n   471→      // Build the update — always set phase + updated_at\n   472→      const rows = await sql<Round[]>`\n   473→        UPDATE rounds SET\n   474→          phase = ${newPhase},\n   475→          updated_at = now(),\n   476→          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n   477→          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n   478→          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n   479→          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),"}]},"parent_tool_use_id":"toolu_01RV1VboAcMDf4MT4RSfBWWe","session_id":"3e0bba06-3e2a-40d1-8fc4-6fd6659fa3ce","uuid":"17e929c2-2aaa-4b13-a329-2a10d75b85b4","timestamp":"2026-03-25T11:46:50.882Z"}
