ort: parseInt(process.env.PORT ?? \"3100\", 10),\n    databaseUrl: applyDbSchemaToUrl(requireEnv(\"DATABASE_URL\"), dbSchema),\n    dbSchema,\n    rpcUrl: requireEnv(\"RPC_URL\"),\n    wsRpcUrl: process.env.WS_RPC_URL || undefined,\n    serverKeypair: parseKeypair(requireEnv(\"SERVER_KEYPAIR\")),\n    jwtSecret: (() => {\n      const explicit = process.env.JWT_SECRET;\n      if (explicit) return new TextEncoder().encode(explicit);\n      // Derive from first 32 bytes of server keypair secret key\n      const kp = parseKeypair(requireEnv(\"SERVER_KEYPAIR\"));\n      return kp.secretKey.slice(0, 32);\n    })(),\n    cluster: process.env.SOLANA_CLUSTER ?? \"devnet\",\n    challengeTtlSeconds: parseInt(\n      process.env.CHALLENGE_TTL_SECONDS ?? \"300\",\n      10,\n    ),\n    accessTokenTtlSeconds: parseInt(\n      process.env.ACCESS_TOKEN_TTL_SECONDS ?? \"86400\",\n      10,\n    ),\n    refreshTokenTtlDays: parseInt(\n      process.env.REFRESH_TOKEN_TTL_DAYS ?? \"14\",\n      10,\n    ),\n    rateLimitPerWallet: parseInt(\n      process.env.RATE_LIMIT_PER_WALLET ?? \"10\",\n      10,\n    ),\n    rateLimitGlobal: parseInt(\n      process.env.RATE_LIMIT_GLOBAL ?? \"100\",\n      10,\n    ),\n    workerPollIntervalMs: parseInt(\n      process.env.WORKER_POLL_INTERVAL_MS ?? \"1000\",\n      10,\n    ),\n    entropyAccount: process.env.ENTROPY_ACCOUNT ?? \"SysvarS1otHashes111111111111111111111111111\",\n    pythBtcUsdAccount: process.env.PYTH_BTC_USD_ACCOUNT ?? \"4cSM2e6rvbGQUFiJbqytoVMi5GgghSMr8LwVrT9VPSPo\",\n    minSolBalance: parseFloat(process.env.MIN_SOL_BALANCE ?? \"0.1\"),\n    eventQueuePollMs: parseInt(\n      process.env.EVENT_QUEUE_POLL_MS ?? \"1500\",\n      10,\n    ),\n  };\n}\n","structuredPatch":[{"oldStart":20,"oldLines":6,"newStart":20,"newLines":8,"lines":["   pythBtcUsdAccount: string;","   minSolBalance: number;","   eventQueuePollMs: number;","+  referralDefaultRateBps: number;","+  referralMinClaimLamports: number;"," }"," "," function requireEn