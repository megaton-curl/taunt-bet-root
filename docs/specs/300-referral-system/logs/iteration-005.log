{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q8GxeVT8gzada6rZ7Rp8oN","type":"tool_result","content":"     1→/**\n     2→ * Database client module — typed query functions for `rounds` and `operator_events`.\n     3→ *\n     4→ * Phase transitions are unidirectional: created → locked → settling → settled,\n     5→ * or created → expired. The application layer rejects backward transitions.\n     6→ */\n     7→\n     8→import postgres from \"postgres\";\n     9→\n    10→// ---------------------------------------------------------------------------\n    11→// Types\n    12→// ---------------------------------------------------------------------------\n    13→\n    14→export type RoundPhase = \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    15→\n    16→export type CloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n    17→export type CloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n    18→\n    19→export interface CloseCallRound {\n    20→  round_id: string;\n    21→  pda: string;\n    22→  server_key: string;\n    23→  phase: CloseCallPhase;\n    24→  open_price: number;\n    25→  open_price_expo: number;\n    26→  close_price: number | null;\n    27→  outcome: CloseCallOutcome;\n    28→  green_pool: number;\n    29→  red_pool: number;\n    30→  total_fee: number;\n    31→  green_entries: Array<{ player: string; amountLamports: number }>;\n    32→  red_entries: Array<{ player: string; amountLamports: number }>;\n    33→  settle_tx: string | null;\n    34→  created_at: Date;\n    35→  settled_at: Date | null;\n    36→}\n    37→\n    38→export interface InsertCloseCallRoundParams {\n    39→  roundId: string;\n    40→  pda: string;\n    41→  serverKey: string;\n    42→  openPrice: number;\n    43→  openPriceExpo: number;\n    44→}\n    45→\n    46→export type OperatorEventType =\n    47→  | \"secret_generated\"\n    48→  | \"tx_built\"\n    49→  | \"match_detected\"\n    50→  | \"settle_submitted\"\n    51→  | \"settle_confirmed\"\n    52→  | \"settle_failed\"\n    53→  | \"settle_retried\"\n    54→  | \"timeout_detected\";\n    55→\n    56→export interface Round {\n    57→  pda: string;\n    58→  game: string;\n    59→  creator: string;\n    60→  server_key: string;\n    61→  secret: Buffer;\n    62→  commitment: Buffer;\n    63→  amount_lamports: number;\n    64→  side: number;\n    65→  match_id: string;\n    66→  phase: RoundPhase;\n    67→  target_slot: string | null;\n    68→  settle_tx: string | null;\n    69→  settle_attempts: number;\n    70→  result_hash: Buffer | null;\n    71→  result_side: number | null;\n    72→  winner: string | null;\n    73→  entries: unknown | null;\n    74→  created_at: Date;\n    75→  updated_at: Date;\n    76→}\n    77→\n    78→export interface InsertRoundParams {\n    79→  pda: string;\n    80→  game: string;\n    81→  creator: string;\n    82→  serverKey: string;\n    83→  secret: Buffer;\n    84→  commitment: Buffer;\n    85→  amountLamports: number;\n    86→  side: number;\n    87→  matchId: string;\n    88→  phase: RoundPhase;\n    89→  entries?: Array<{ player: string; amountLamports: number }>;\n    90→}\n    91→\n    92→export interface OperatorEvent {\n    93→  id: string;\n    94→  pda: string | null;\n    95→  event_type: OperatorEventType;\n    96→  payload: unknown;\n    97→  created_at: Date;\n    98→}\n    99→\n   100→// ---------------------------------------------------------------------------\n   101→// Transaction types\n   102→// ---------------------------------------------------------------------------\n   103→\n   104→export type TransactionType = \"deposit\" | \"payout\" | \"refund\";\n   105→\n   106→export interface Transaction {\n   107→  id: string;\n   108→  wallet: string;\n   109→  game: string;\n   110→  match_id: string;\n   111→  tx_type: TransactionType;\n   112→  amount_lamports: number;\n   113→  tx_sig: string;\n   114→  created_at: Date;\n   115→}\n   116→\n   117→export interface InsertTransactionParams {\n   118→  wallet: string;\n   119→  game: string;\n   120→  matchId: string;\n   121→  txType: TransactionType;\n   122→  amountLamports: number;\n   123→  txSig: string;\n   124→}\n   125→\n   126→// ---------------------------------------------------------------------------\n   127→// Referral types\n   128→// ---------------------------------------------------------------------------\n   129→\n   130→export interface ReferralCode {\n   131→  id: number;\n   132→  wallet: string;\n   133→  code: string;\n   134→  created_at: Date;\n   135→  updated_at: Date;\n   136→}\n   137→\n   138→export interface ReferralLink {\n   139→  id: number;\n   140→  referrer_wallet: string;\n   141→  referee_wallet: string;\n   142→  created_at: Date;\n   143→}\n   144→\n   145→// ---------------------------------------------------------------------------\n   146→// Phase transition guard\n   147→// ---------------------------------------------------------------------------\n   148→\n   149→/** Valid transitions: created→locked, locked→settling, settling→settled, created→expired */\n   150→const VALID_TRANSITIONS: Record<RoundPhase, readonly RoundPhase[]> = {\n   151→  created: [\"locked\", \"expired\"],\n   152→  locked: [\"settling\"],\n   153→  settling: [\"settled\"],\n   154→  settled: [],\n   155→  expired: [],\n   156→};\n   157→\n   158→function assertPhaseTransition(from: RoundPhase, to: RoundPhase): void {\n   159→  const allowed = VALID_TRANSITIONS[from];\n   160→  if (!allowed.includes(to)) {\n   161→    throw new Error(\n   162→      `Invalid phase transition: ${from} → ${to} (allowed: ${allowed.join(\", \") || \"none\"})`,\n   163→    );\n   164→  }\n   165→}\n   166→\n   167→// ---------------------------------------------------------------------------\n   168→// DB client\n   169→// ---------------------------------------------------------------------------\n   170→\n   171→export interface Db {\n   172→  /** Insert a new round. Throws on duplicate PDA (primary key violation). */\n   173→  insertRound(params: InsertRoundParams): Promise<Round>;\n   174→\n   175→  /** Delete a round by PDA. Returns true if a row was removed. */\n   176→  deleteRoundByPda(pda: string): Promise<boolean>;\n   177→\n   178→  /** Transition a round's phase. Enforces unidirectional state machine.\n   179→   *  Optional `updates` can set additional columns alongside the phase change. */\n   180→  updateRoundPhase(\n   181→    pda: string,\n   182→    newPhase: RoundPhase,\n   183→    updates?: Partial<\n   184→      Pick<Round, \"target_slot\" | \"settle_tx\" | \"settle_attempts\" | \"result_hash\" | \"result_side\" | \"winner\">\n   185→    >,\n   186→  ): Promise<Round>;\n   187→\n   188→  /** Update the entries JSONB column for a settled round. */\n   189→  updateRoundEntries(\n   190→    pda: string,\n   191→    entries: Array<{ player: string; amountLamports: number }>,\n   192→  ): Promise<Round>;\n   193→\n   194→  /** Get a single round by its PDA. Returns `undefined` if not found. */\n   195→  getRoundByPda(pda: string): Promise<Round | undefined>;\n   196→\n   197→  /** Get all rounds matching a given phase. */\n   198→  getRoundsByPhase(phase: RoundPhase): Promise<Round[]>;\n   199→\n   200→  /** Append an operator event to the audit log. */\n   201→  insertOperatorEvent(\n   202→    pda: string | null,\n   203→    eventType: OperatorEventType,\n   204→    payload?: unknown,\n   205→  ): Promise<OperatorEvent>;\n   206→\n   207→  /** Get the latest operator event for a PDA + type. */\n   208→  getLatestOperatorEvent(\n   209→    pda: string,\n   210→    eventType: OperatorEventType,\n   211→  ): Promise<OperatorEvent | undefined>;\n   212→\n   213→  /** Get a single round by its match_id. Returns `undefined` if not found. */\n   214→  getRoundByMatchId(matchId: string): Promise<Round | undefined>;\n   215→\n   216→  /** Batch-fetch the latest operator event per PDA for a given event type. */\n   217→  getLatestOperatorEventsForPdas(\n   218→    pdas: string[],\n   219→    eventType: OperatorEventType,\n   220→  ): Promise<Map<string, OperatorEvent>>;\n   221→\n   222→  /** Get recently settled rounds for a game, ordered newest first. */\n   223→  getRecentSettledRounds(game: string, limit: number): Promise<Round[]>;\n   224→\n   225→  /** Get count of unsettled rounds and age (seconds) of the oldest. */\n   226→  getUnsettledStats(): Promise<{ count: number; oldestAgeSeconds: number }>;\n   227→\n   228→  // -------------------------------------------------------------------------\n   229→  // Close Call rounds\n   230→  // -------------------------------------------------------------------------\n   231→\n   232→  /** Insert a new Close Call round. */\n   233→  insertCloseCallRound(params: InsertCloseCallRoundParams): Promise<CloseCallRound>;\n   234→\n   235→  /** Get a Close Call round by round_id (16-char hex). */\n   236→  getCloseCallRound(roundId: string): Promise<CloseCallRound | undefined>;\n   237→\n   238→  /** Get the current active (open) Close Call round. */\n   239→  getCloseCallCurrentRound(): Promise<CloseCallRound | undefined>;\n   240→\n   241→  /** Get the most recent settled/refunded Close Call rounds. */\n   242→  getCloseCallHistory(limit: number): Promise<CloseCallRound[]>;\n   243→\n   244→  /** Update a Close Call round after settlement. */\n   245→  settleCloseCallRound(\n   246→    roundId: string,\n   247→    updates: {\n   248→      phase: CloseCallPhase;\n   249→      outcome: CloseCallOutcome;\n   250→      closePrice?: number;\n   251→      greenPool?: number;\n   252→      redPool?: number;\n   253→      totalFee?: number;\n   254→      greenEntries?: Array<{ player: string; amountLamports: number }>;\n   255→      redEntries?: Array<{ player: string; amountLamports: number }>;\n   256→      settleTx?: string;\n   257→    },\n   258→  ): Promise<CloseCallRound>;\n   259→\n   260→  // -------------------------------------------------------------------------\n   261→  // Transactions\n   262→  // -------------------------------------------------------------------------\n   263→\n   264→  /** Insert a transaction. Uses ON CONFLICT DO NOTHING for idempotency. */\n   265→  insertTransaction(params: InsertTransactionParams): Promise<void>;\n   266→\n   267→  /** Insert multiple transactions in a single batch. */\n   268→  insertTransactions(params: InsertTransactionParams[]): Promise<void>;\n   269→\n   270→  /** Get paginated transactions for a wallet, newest first. */\n   271→  getTransactions(\n   272→    wallet: string,\n   273→    cursor?: string,\n   274→    limit?: number,\n   275→    game?: string,\n   276→  ): Promise<Transaction[]>;\n   277→\n   278→  // -------------------------------------------------------------------------\n   279→  // Referral — codes\n   280→  // -------------------------------------------------------------------------\n   281→\n   282→  /** Insert a new referral code for a wallet. Throws on duplicate wallet or code. */\n   283→  insertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n   284→\n   285→  /** Get a wallet's referral code. Returns `undefined` if none set. */\n   286→  getReferralCodeByWallet(wallet: string): Promise<ReferralCode | undefined>;\n   287→\n   288→  /** Look up a referral code record by code string. Returns `undefined` if not found. */\n   289→  getReferralCodeByCode(code: string): Promise<ReferralCode | undefined>;\n   290→\n   291→  /** Set or replace a wallet's referral code (INSERT … ON CONFLICT UPDATE). */\n   292→  upsertReferralCode(wallet: string, code: string): Promise<ReferralCode>;\n   293→\n   294→  // -------------------------------------------------------------------------\n   295→  // Referral — links\n   296→  // -------------------------------------------------------------------------\n   297→\n   298→  /** Create a referral link (referrer → referee). Throws on duplicate referee. */\n   299→  insertReferralLink(referrerWallet: string, refereeWallet: string): Promise<ReferralLink>;\n   300→\n   301→  /** Get the referral link for a referee wallet. Returns `undefined` if not referred. */\n   302→  getReferralLinkByReferee(refereeWallet: string): Promise<ReferralLink | undefined>;\n   303→\n   304→  /** Get all referral links where the given wallet is the referrer. */\n   305→  getReferralLinksByReferrer(referrerWallet: string): Promise<ReferralLink[]>;\n   306→\n   307→  /** Gracefully close the connection pool. */\n   308→  close(): Promise<void>;\n   309→}\n   310→\n   311→function normalizeCloseCallRound(row: CloseCallRound): CloseCallRound {\n   312→  return {\n   313→    ...row,\n   314→    open_price: Number(row.open_price),\n   315→    open_price_expo: Number(row.open_price_expo),\n   316→    close_price: row.close_price === null ? null : Number(row.close_price),\n   317→    green_pool: Number(row.green_pool),\n   318→    red_pool: Number(row.red_pool),\n   319→    total_fee: Number(row.total_fee),\n   320→    // JSONB comes back as parsed objects from postgres.js\n   321→    green_entries: Array.isArray(row.green_entries)\n   322→      ? row.green_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   323→      : [],\n   324→    red_entries: Array.isArray(row.red_entries)\n   325→      ? row.red_entries.map((e) => ({ player: e.player, amountLamports: Number(e.amountLamports) }))\n   326→      : [],\n   327→  };\n   328→}\n   329→\n   330→function normalizeTransaction(row: Transaction): Transaction {\n   331→  return {\n   332→    ...row,\n   333→    amount_lamports: Number(row.amount_lamports),\n   334→  };\n   335→}\n   336→\n   337→function normalizeRound(row: Round): Round {\n   338→  return {\n   339→    ...row,\n   340→    amount_lamports: Number(row.amount_lamports),\n   341→    side: Number(row.side),\n   342→    settle_attempts: Number(row.settle_attempts),\n   343→    result_side: row.result_side === null ? null : Number(row.result_side),\n   344→    // JSONB comes back as parsed objects from postgres.js\n   345→    entries: Array.isArray(row.entries)\n   346→      ? (row.entries as Array<{ player: string; amountLamports: number }>).map((e) => ({\n   347→          player: e.player,\n   348→          amountLamports: Number(e.amountLamports),\n   349→        }))\n   350→      : null,\n   351→  };\n   352→}\n   353→\n   354→export function createDb(databaseUrl: string): Db {\n   355→  const sql = postgres(databaseUrl);\n   356→\n   357→  return {\n   358→    async insertRound(params) {\n   359→      const rows = await sql<Round[]>`\n   360→        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase, entries)\n   361→        VALUES (\n   362→          ${params.pda},\n   363→          ${params.game},\n   364→          ${params.creator},\n   365→          ${params.serverKey},\n   366→          ${params.secret},\n   367→          ${params.commitment},\n   368→          ${params.amountLamports},\n   369→          ${params.side},\n   370→          ${params.matchId},\n   371→          ${params.phase},\n   372→          ${params.entries ? sql.json(params.entries) : null}\n   373→        )\n   374→        RETURNING *\n   375→      `;\n   376→      return normalizeRound(rows[0]!);\n   377→    },\n   378→\n   379→    async deleteRoundByPda(pda) {\n   380→      const rows = await sql<{ pda: string }[]>`\n   381→        DELETE FROM rounds WHERE pda = ${pda}\n   382→        RETURNING pda\n   383→      `;\n   384→      return rows.length > 0;\n   385→    },\n   386→\n   387→    async updateRoundPhase(pda, newPhase, updates) {\n   388→      // Fetch current phase to validate transition\n   389→      const current = await sql<Pick<Round, \"phase\">[]>`\n   390→        SELECT phase FROM rounds WHERE pda = ${pda}\n   391→      `;\n   392→\n   393→      if (current.length === 0) {\n   394→        throw new Error(`Round not found: ${pda}`);\n   395→      }\n   396→\n   397→      const currentPhase = current[0]!.phase as RoundPhase;\n   398→      assertPhaseTransition(currentPhase, newPhase);\n   399→\n   400→      // Build the update — always set phase + updated_at\n   401→      const rows = await sql<Round[]>`\n   402→        UPDATE rounds SET\n   403→          phase = ${newPhase},\n   404→          updated_at = now(),\n   405→          target_slot = COALESCE(${updates?.target_slot ?? null}, target_slot),\n   406→          settle_tx = COALESCE(${updates?.settle_tx ?? null}, settle_tx),\n   407→          settle_attempts = COALESCE(${updates?.settle_attempts ?? null}, settle_attempts),\n   408→          result_hash = COALESCE(${updates?.result_hash ?? null}, result_hash),\n   409→          result_side = COALESCE(${updates?.result_side ?? null}, result_side),\n   410→          winner = COALESCE(${updates?.winner ?? null}, winner)\n   411→        WHERE pda = ${pda}\n   412→        RETURNING *\n   413→      `;\n   414→\n   415→      return normalizeRound(rows[0]!);\n   416→    },\n   417→\n   418→    async updateRoundEntries(pda, entries) {\n   419→      const rows = await sql<Round[]>`\n   420→        UPDATE rounds SET\n   421→          entries = ${sql.json(entries)},\n   422→          updated_at = now()\n   423→        WHERE pda = ${pda}\n   424→        RETURNING *\n   425→      `;\n   426→      if (rows.length === 0) {\n   427→        throw new Error(`Round not found: ${pda}`);\n   428→      }\n   429→      return normalizeRound(rows[0]!);\n   430→    },\n   431→\n   432→    async getRoundByPda(pda) {\n   433→      const rows = await sql<Round[]>`\n   434→        SELECT * FROM rounds WHERE pda = ${pda}\n   435→      `;\n   436→      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   437→    },\n   438→\n   439→    async getRoundByMatchId(matchId) {\n   440→      const rows = await sql<Round[]>`\n   441→        SELECT * FROM rounds WHERE match_id = ${matchId}\n   442→      `;\n   443→      return rows[0] ? normalizeRound(rows[0]) : undefined;\n   444→    },\n   445→\n   446→    async getRoundsByPhase(phase) {\n   447→      const rows = await sql<Round[]>`\n   448→        SELECT * FROM rounds WHERE phase = ${phase}\n   449→      `;\n   450→      return rows.map(normalizeRound);\n   451→    },\n   452→\n   453→    async insertOperatorEvent(pda, eventType, payload) {\n   454→      const rows = await sql<OperatorEvent[]>`\n   455→        INSERT INTO operator_events (pda, event_type, payload)\n   456→        VALUES (${pda}, ${eventType}, ${sql.json(payload as postgres.JSONValue ?? null)})\n   457→        RETURNING *\n   458→      `;\n   459→      return rows[0]!;\n   460→    },\n   461→\n   462→    async getLatestOperatorEvent(pda, eventType) {\n   463→      const rows = await sql<OperatorEvent[]>`\n   464→        SELECT * FROM operator_events\n   465→        WHERE pda = ${pda} AND event_type = ${eventType}\n   466→        ORDER BY id DESC\n   467→        LIMIT 1\n   468→      `;\n   469→      return rows[0];\n   470→    },\n   471→\n   472→    async getLatestOperatorEventsForPdas(pdas, eventType) {\n   473→      if (pdas.length === 0) return new Map();\n   474→      const rows = await sql<OperatorEvent[]>`\n   475→        SELECT DISTINCT ON (pda) *\n   476→        FROM operator_events\n   477→        WHERE pda = ANY(${pdas}) AND event_type = ${eventType}\n   478→        ORDER BY pda, id DESC\n   479→      `;\n   480→      const map = new Map<string, OperatorEvent>();\n   481→      for (const row of rows) {\n   482→        if (row.pda) map.set(row.pda, row);\n   483→      }\n   484→      return map;\n   485→    },\n   486→\n   487→    async getRecentSettledRounds(game, limit) {\n   488→      const rows = await sql<Round[]>`\n   489→        SELECT * FROM rounds\n   490→        WHERE game = ${game} AND phase = 'settled'\n   491→        ORDER BY updated_at DESC\n   492→        LIMIT ${limit}\n   493→      `;\n   494→      return rows.map(normalizeRound);\n   495→    },\n   496→\n   497→    async getUnsettledStats() {\n   498→      const rows = await sql<{ count: string; oldest_age_seconds: string | null }[]>`\n   499→        SELECT\n   500→          COUNT(*)::text AS count,\n   501→          EXTRACT(EPOCH FROM (now() - MIN(created_at)))::text AS oldest_age_seconds\n   502→        FROM rounds\n   503→        WHERE phase NOT IN ('settled', 'expired')\n   504→      `;\n   505→      const row = rows[0]!;\n   506→      return {\n   507→        count: parseInt(row.count, 10),\n   508→        oldestAgeSeconds: row.oldest_age_seconds ? Math.round(parseFloat(row.oldest_age_seconds)) : 0,\n   509→      };\n   510→    },\n   511→\n   512→    // -----------------------------------------------------------------------\n   513→    // Close Call rounds\n   514→    // -----------------------------------------------------------------------\n   515→\n   516→    async insertCloseCallRound(params) {\n   517→      const rows = await sql<CloseCallRound[]>`\n   518→        INSERT INTO closecall_rounds (round_id, pda, server_key, open_price, open_price_expo)\n   519→        VALUES (\n   520→          ${params.roundId},\n   521→          ${params.pda},\n   522→          ${params.serverKey},\n   523→          ${params.openPrice},\n   524→          ${params.openPriceExpo}\n   525→        )\n   526→        RETURNING *\n   527→      `;\n   528→      return normalizeCloseCallRound(rows[0]!);\n   529→    },\n   530→\n   531→    async getCloseCallRound(roundId) {\n   532→      const rows = await sql<CloseCallRound[]>`\n   533→        SELECT * FROM closecall_rounds WHERE round_id = ${roundId}\n   534→      `;\n   535→      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n   536→    },\n   537→\n   538→    async getCloseCallCurrentRound() {\n   539→      const rows = await sql<CloseCallRound[]>`\n   540→        SELECT * FROM closecall_rounds\n   541→        WHERE phase = 'open'\n   542→        ORDER BY created_at DESC\n   543→        LIMIT 1\n   544→      `;\n   545→      return rows[0] ? normalizeCloseCallRound(rows[0]) : undefined;\n   546→    },\n   547→\n   548→    async getCloseCallHistory(limit) {\n   549→      const rows = await sql<CloseCallRound[]>`\n   550→        SELECT * FROM closecall_rounds\n   551→        WHERE phase IN ('settled', 'refunded')\n   552→        ORDER BY settled_at DESC\n   553→        LIMIT ${limit}\n   554→      `;\n   555→      return rows.map(normalizeCloseCallRound);\n   556→    },\n   557→\n   558→    async settleCloseCallRound(roundId, updates) {\n   559→      const rows = await sql<CloseCallRound[]>`\n   560→        UPDATE closecall_rounds SET\n   561→          phase = ${updates.phase},\n   562→          outcome = ${updates.outcome},\n   563→          close_price = COALESCE(${updates.closePrice ?? null}, close_price),\n   564→          green_pool = COALESCE(${updates.greenPool ?? null}, green_pool),\n   565→          red_pool = COALESCE(${updates.redPool ?? null}, red_pool),\n   566→          total_fee = COALESCE(${updates.totalFee ?? null}, total_fee),\n   567→          green_entries = COALESCE(${updates.greenEntries ? sql.json(updates.greenEntries) : null}, green_entries),\n   568→          red_entries = COALESCE(${updates.redEntries ? sql.json(updates.redEntries) : null}, red_entries),\n   569→          settle_tx = COALESCE(${updates.settleTx ?? null}, settle_tx),\n   570→          settled_at = now()\n   571→        WHERE round_id = ${roundId}\n   572→        RETURNING *\n   573→      `;\n   574→      if (rows.length === 0) {\n   575→        throw new Error(`Close Call round not found: ${roundId}`);\n   576→      }\n   577→      return normalizeCloseCallRound(rows[0]!);\n   578→    },\n   579→\n   580→    // -----------------------------------------------------------------------\n   581→    // Transactions\n   582→    // -----------------------------------------------------------------------\n   583→\n   584→    async insertTransaction(params) {\n   585→      await sql`\n   586→        INSERT INTO transactions (wallet, game, match_id, tx_type, amount_lamports, tx_sig)\n   587→        VALUES (\n   588→          ${params.wallet},\n   589→          ${params.game},\n   590→          ${params.matchId},\n   591→          ${params.txType},\n   592→          ${params.amountLamports},\n   593→          ${params.txSig}\n   594→        )\n   595→        ON CONFLICT DO NOTHING\n   596→      `;\n   597→    },\n   598→\n   599→    async insertTransactions(params) {\n   600→      if (params.length === 0) return;\n   601→      const values = params.map((p) => ({\n   602→        wallet: p.wallet,\n   603→        game: p.game,\n   604→        match_id: p.matchId,\n   605→        tx_type: p.txType,\n   606→        amount_lamports: p.amountLamports,\n   607→        tx_sig: p.txSig,\n   608→      }));\n   609→      await sql`\n   610→        INSERT INTO transactions ${sql(values, \"wallet\", \"game\", \"match_id\", \"tx_type\", \"amount_lamports\", \"tx_sig\")}\n   611→        ON CONFLICT DO NOTHING\n   612→      `;\n   613→    },\n   614→\n   615→    async getTransactions(wallet, cursor, limit = 20, game) {\n   616→      const effectiveLimit = Math.min(limit, 50);\n   617→      if (cursor && game) {\n   618→        const rows = await sql<Transaction[]>`\n   619→          SELECT * FROM transactions\n   620→          WHERE wallet = ${wallet} AND id < ${cursor} AND game = ${game}\n   621→          ORDER BY id DESC\n   622→          LIMIT ${effectiveLimit}\n   623→        `;\n   624→        return rows.map(normalizeTransaction);\n   625→      }\n   626→      if (cursor) {\n   627→        const rows = await sql<Transaction[]>`\n   628→          SELECT * FROM transactions\n   629→          WHERE wallet = ${wallet} AND id < ${cursor}\n   630→          ORDER BY id DESC\n   631→          LIMIT ${effectiveLimit}\n   632→        `;\n   633→        return rows.map(normalizeTransaction);\n   634→      }\n   635→      if (game) {\n   636→        const rows = await sql<Transaction[]>`\n   637→          SELECT * FROM transactions\n   638→          WHERE wallet = ${wallet} AND game = ${game}\n   639→          ORDER BY id DESC\n   640→          LIMIT ${effectiveLimit}\n   641→        `;\n   642→        return rows.map(normalizeTransaction);\n   643→      }\n   644→      const rows = await sql<Transaction[]>`\n   645→        SELECT * FROM transactions\n   646→        WHERE wallet = ${wallet}\n   647→        ORDER BY id DESC\n   648→        LIMIT ${effectiveLimit}\n   649→      `;\n   650→      return rows.map(normalizeTransaction);\n   651→    },\n   652→\n   653→    // -----------------------------------------------------------------------\n   654→    // Referral — codes\n   655→    // -----------------------------------------------------------------------\n   656→\n   657→    async insertReferralCode(wallet, code) {\n   658→      const rows = await sql<ReferralCode[]>`\n   659→        INSERT INTO referral_codes (wallet, code)\n   660→        VALUES (${wallet}, ${code})\n   661→        RETURNING *\n   662→      `;\n   663→      return rows[0]!;\n   664→    },\n   665→\n   666→    async getReferralCodeByWallet(wallet) {\n   667→      const rows = await sql<ReferralCode[]>`\n   668→        SELECT * FROM referral_codes WHERE wallet = ${wallet}\n   669→      `;\n   670→      return rows[0];\n   671→    },\n   672→\n   673→    async getReferralCodeByCode(code) {\n   674→      const rows = await sql<ReferralCode[]>`\n   675→        SELECT * FROM referral_codes WHERE code = ${code}\n   676→      `;\n   677→      return rows[0];\n   678→    },\n   679→\n   680→    async upsertReferralCode(wallet, code) {\n   681→      const rows = await sql<ReferralCode[]>`\n   682→        INSERT INTO referral_codes (wallet, code)\n   683→        VALUES (${wallet}, ${code})\n   684→        ON CONFLICT (wallet) DO UPDATE SET\n   685→          code = ${code},\n   686→          updated_at = now()\n   687→        RETURNING *\n   688→      `;\n   689→      return rows[0]!;\n   690→    },\n   691→\n   692→    // -- Referral links -------------------------------------------------------\n   693→\n   694→    async insertReferralLink(referrerWallet, refereeWallet) {\n   695→      const rows = await sql<ReferralLink[]>`\n   696→        INSERT INTO referral_links (referrer_wallet, referee_wallet)\n   697→        VALUES (${referrerWallet}, ${refereeWallet})\n   698→        RETURNING *\n   699→      `;\n   700→      return rows[0]!;\n   701→    },\n   702→\n   703→    async getReferralLinkByReferee(refereeWallet) {\n   704→      const rows = await sql<ReferralLink[]>`\n   705→        SELECT * FROM referral_links WHERE referee_wallet = ${refereeWallet}\n   706→      `;\n   707→      return rows[0];\n   708→    },\n   709→\n   710→    async getReferralLinksByReferrer(referrerWallet) {\n   711→      const rows = await sql<ReferralLink[]>`\n   712→        SELECT * FROM referral_links WHERE referrer_wallet = ${referrerWallet}\n   713→        ORDER BY created_at DESC\n   714→      `;\n   715→      return rows;\n   716→    },\n   717→\n   718→    async close() {\n   719→      await sql.end();\n   720→    },\n   721→  };\n   722→}\n   723→"}]},"parent_tool_use_id":"toolu_01Scb2yDQZ7QJRf85YhfUCzG","session_id":"7e052405-15aa-4b3b-94b0-00f5b3dd543f","uuid":"409bdfd7-34c6-4012-8de1-0c6de1af1a5d","timestamp":"2026-03-25T11:34:46.468Z"}
