{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RvqhujnNDXsvmYD273FAUq","type":"tool_result","content":"     1→/**\n     2→ * Known event type constants for the async event queue.\n     3→ *\n     4→ * Using a const object + derived union makes typos a compile error\n     5→ * instead of a dead event at runtime.\n     6→ */\n     7→\n     8→export const EventTypes = {\n     9→  REFERRAL_CODE_APPLIED: \"referral.code_applied\",\n    10→  REFERRAL_GAME_SETTLED: \"referral.game_settled\",\n    11→  REFERRAL_CLAIM_REQUESTED: \"referral.claim_requested\",\n    12→} as const;\n    13→\n    14→export type EventType = (typeof EventTypes)[keyof typeof EventTypes];\n    15→"}]},"parent_tool_use_id":"toolu_01PnsFyyJnUwtkd2cMCTGyPV","session_id":"7e052405-15aa-4b3b-94b0-00f5b3dd543f","uuid":"5aa3a5e3-1dad-4272-8bd9-2138d8d32a56","timestamp":"2026-03-25T11:35:16.709Z"}
