{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013iTp1UULMPRTTtjEJyyq1X","type":"tool_result","content":"     1→/**\n     2→ * Settle transaction builder + submission.\n     3→ *\n     4→ * Retrieves the stored secret, reads on-chain match + config data to resolve\n     5→ * all accounts, builds the `settle` instruction, submits it, and updates the\n     6→ * DB on confirmation.\n     7→ */\n     8→\n     9→import { createHash } from \"node:crypto\";\n    10→import { performance } from \"node:perf_hooks\";\n    11→import {\n    12→  Connection,\n    13→  Keypair,\n    14→  PublicKey,\n    15→  SystemProgram,\n    16→  Transaction,\n    17→  TransactionInstruction,\n    18→} from \"@solana/web3.js\";\n    19→import type { Db } from \"../db.js\";\n    20→import { logger } from \"../logger.js\";\n    21→import { COINFLIP_PROGRAM_ID, LORDOFRNGS_PROGRAM_ID, CLOSECALL_PROGRAM_ID } from \"../tx-builder.js\";\n    22→import { derivePlatformConfigPda, getPlatformConfig } from \"../platform-config.js\";\n    23→import { CoinflipIDL as coinflipIdl, LordofrngsIDL as lordIdl, ClosecallIDL as closecallIdl } from \"@rng-utopia/anchor-client\";\n    24→import {\n    25→  decodeCoinflipMatch,\n    26→  decodeLordRound,\n    27→  type DecodedJackpotRound,\n    28→} from \"./account-decoder.js\";\n    29→\n    30→// ---------------------------------------------------------------------------\n    31→// Instruction discriminators (from IDL — no hardcoded byte arrays)\n    32→// ---------------------------------------------------------------------------\n    33→\n    34→function getInstructionDiscriminator(\n    35→  idl: { instructions: Array<{ name: string; discriminator: number[] }> },\n    36→  instructionName: string,\n    37→): Buffer {\n    38→  const instruction = idl.instructions.find((entry) => entry.name === instructionName);\n    39→  if (!instruction) {\n    40→    throw new Error(`Instruction ${instructionName} not found in IDL`);\n    41→  }\n    42→  return Buffer.from(instruction.discriminator);\n    43→}\n    44→\n    45→const SETTLE_DISCRIMINATOR = getInstructionDiscriminator(coinflipIdl, \"settle\");\n    46→const CLAIM_PAYOUT_DISCRIMINATOR = getInstructionDiscriminator(\n    47→  lordIdl,\n    48→  \"claim_payout\",\n    49→);\n    50→const CC_BET_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"bet\");\n    51→const CC_SETTLE_ROUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"settle_round\");\n    52→const CC_TIMEOUT_REFUND_DISCRIMINATOR = getInstructionDiscriminator(closecallIdl, \"timeout_refund\");\n    53→\n    54→// ---------------------------------------------------------------------------\n    55→// Types\n    56→// ---------------------------------------------------------------------------\n    57→\n    58→export interface SettleTxDeps {\n    59→  db: Db;\n    60→  connection: Connection;\n    61→  serverKeypair: Keypair;\n    62→  entropyAccount: PublicKey;\n    63→}\n    64→\n    65→export interface SettleResult {\n    66→  txSignature: string;\n    67→  resultHash: Buffer;\n    68→  resultSide?: number;\n    69→  winningEntryIndex?: number;\n    70→  winner: string;\n    71→}\n    72→\n    73→// ---------------------------------------------------------------------------\n    74→// Instruction encoding\n    75→// ---------------------------------------------------------------------------\n    76→\n    77→/** Borsh-encode settle instruction data: discriminator(8) + secret(32) = 40 bytes */\n    78→function encodeSettleData(secret: Buffer): Buffer {\n    79→  return Buffer.concat([SETTLE_DISCRIMINATOR, secret]);\n    80→}\n    81→\n    82→function encodeClaimPayoutData(matchId: Buffer, secret: Buffer): Buffer {\n    83→  return Buffer.concat([CLAIM_PAYOUT_DISCRIMINATOR, matchId, secret]);\n    84→}\n    85→\n    86→// ---------------------------------------------------------------------------\n    87→// Result derivation (mirrors on-chain derive_result)\n    88→// ---------------------------------------------------------------------------\n    89→\n    90→/**\n    91→ * derive_result: SHA256(secret || entropy || game_pda || algo_ver)\n    92→ * Must match shared/src/fairness.rs `derive_result()`.\n    93→ */\n    94→function deriveResult(\n    95→  secret: Buffer,\n    96→  entropy: Buffer,\n    97→  matchPdaBytes: Buffer,\n    98→  algoVer: number,\n    99→): Buffer {\n   100→  return createHash(\"sha256\")\n   101→    .update(secret)\n   102→    .update(entropy)\n   103→    .update(matchPdaBytes)\n   104→    .update(Buffer.from([algoVer]))\n   105→    .digest();\n   106→}\n   107→\n   108→// ---------------------------------------------------------------------------\n   109→// Core settle function\n   110→// ---------------------------------------------------------------------------\n   111→\n   112→/**\n   113→ * Build, submit, and confirm a settle transaction for a locked match.\n   114→ *\n   115→ * Steps:\n   116→ * 1. Retrieve secret from DB\n   117→ * 2. Fetch match account data (creator, opponent, algo_ver, creator_side)\n   118→ * 3. Fetch config account data (treasury)\n   119→ * 4. Read entropy from the entropy account\n   120→ * 5. Pre-compute result (for DB storage — account is zeroed after settle)\n   121→ * 6. Build + submit settle tx\n   122→ * 7. Update DB on confirmation\n   123→ */\n   124→export async function settleMatch(\n   125→  deps: SettleTxDeps,\n   126→  pda: string,\n   127→): Promise<SettleResult> {\n   128→  const t0 = performance.now();\n   129→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   130→  const matchPubkey = new PublicKey(pda);\n   131→\n   132→  // 1. Retrieve secret from DB\n   133→  const round = await db.getRoundByPda(pda);\n   134→  const tDb = performance.now();\n   135→  if (!round) {\n   136→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   137→  }\n   138→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   139→    throw new PermanentSettleError(\n   140→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   141→    );\n   142→  }\n   143→\n   144→  const secret = Buffer.from(round.secret);\n   145→\n   146→  // Transition to settling (locked → settling)\n   147→  if (round.phase === \"locked\") {\n   148→    await db.updateRoundPhase(pda, \"settling\");\n   149→  }\n   150→\n   151→  // Log settle_submitted\n   152→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   153→    attempt: round.settle_attempts + 1,\n   154→  });\n   155→\n   156→  // 2-4. Fetch match, platform config, entropy, and blockhash in parallel\n   157→  const [platformConfigPda] = derivePlatformConfigPda();\n   158→  const [matchAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n   159→    await Promise.all([\n   160→      connection.getAccountInfo(matchPubkey),\n   161→      getPlatformConfig(connection),\n   162→      connection.getAccountInfo(entropyAccount),\n   163→      connection.getLatestBlockhash(),\n   164→    ]);\n   165→  const tFetch = performance.now();\n   166→\n   167→  if (!matchAccountInfo) {\n   168→    throw new PermanentSettleError(`Match account not found on-chain: ${pda}`);\n   169→  }\n   170→  if (!entropyInfo) {\n   171→    throw new TransientSettleError(\"Entropy account not available yet\");\n   172→  }\n   173→\n   174→  // IDL-driven decode — no manual byte offsets\n   175→  const match = decodeCoinflipMatch(Buffer.from(matchAccountInfo.data));\n   176→  const { feeBps, treasury } = platformConfig;\n   177→\n   178→  const { creator, opponent, creatorSide, entryAmount, algorithmVer: algoVer } = match;\n   179→\n   180→  const pool = entryAmount * 2n;\n   181→  const feeAmount = Number((pool * BigInt(feeBps)) / 10_000n);\n   182→  const payoutAmount = Number(pool) - feeAmount;\n   183→\n   184→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   185→\n   186→  // 5. Pre-compute result\n   187→  const matchPdaBytes = matchPubkey.toBuffer();\n   188→  const resultHash = deriveResult(secret, entropy, matchPdaBytes, algoVer);\n   189→  const resultSide = resultHash[0]! % 2;\n   190→  const winner = resultSide === creatorSide ? creator : opponent;\n   191→\n   192→  // 6. Build settle instruction (8 accounts, no profile CPI)\n   193→  const data = encodeSettleData(secret);\n   194→\n   195→  const instruction = new TransactionInstruction({\n   196→    keys: [\n   197→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller\n   198→      { pubkey: matchPubkey, isSigner: false, isWritable: true }, // coinflip_match\n   199→      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n   200→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   201→      { pubkey: treasury, isSigner: false, isWritable: true }, // treasury\n   202→      { pubkey: creator, isSigner: false, isWritable: true }, // creator\n   203→      { pubkey: opponent, isSigner: false, isWritable: true }, // opponent\n   204→      {\n   205→        pubkey: SystemProgram.programId,\n   206→        isSigner: false,\n   207→        isWritable: false,\n   208→      }, // system_program\n   209→    ],\n   210→    programId: COINFLIP_PROGRAM_ID,\n   211→    data,\n   212→  });\n   213→\n   214→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   215→\n   216→  const tx = new Transaction({\n   217→    feePayer: serverKeypair.publicKey,\n   218→    blockhash,\n   219→    lastValidBlockHeight,\n   220→  });\n   221→  tx.add(instruction);\n   222→  tx.sign(serverKeypair);\n   223→\n   224→  // 7. Submit and confirm\n   225→  const rawTx = tx.serialize();\n   226→  const tBuild = performance.now();\n   227→  const txSignature = await connection.sendRawTransaction(rawTx, {\n   228→    skipPreflight: false,\n   229→  });\n   230→  const tSend = performance.now();\n   231→\n   232→  logger.info(\"settlement transaction submitted\", {\n   233→    pda,\n   234→    txSignature,\n   235→    attempt: round.settle_attempts + 1,\n   236→    dbMs: Math.round(tDb - t0),\n   237→    fetchMs: Math.round(tFetch - tDb),\n   238→    buildMs: Math.round(tBuild - tFetch),\n   239→    sendMs: Math.round(tSend - tBuild),\n   240→  });\n   241→\n   242→  const confirmation = await connection.confirmTransaction(\n   243→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   244→    \"confirmed\",\n   245→  );\n   246→  const tConfirm = performance.now();\n   247→  if (confirmation.value.err) {\n   248→    throw new TransientSettleError(\n   249→      `Coinflip settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   250→    );\n   251→  }\n   252→\n   253→  // 8. Update DB — phase settling → settled\n   254→  const coinflipEntries = [\n   255→    { player: creator.toBase58(), amountLamports: Number(entryAmount) },\n   256→    { player: opponent.toBase58(), amountLamports: Number(entryAmount) },\n   257→  ];\n   258→\n   259→  await db.updateRoundPhase(pda, \"settled\", {\n   260→    settle_tx: txSignature,\n   261→    result_hash: resultHash,\n   262→    result_side: resultSide,\n   263→    winner: winner.toBase58(),\n   264→    settle_attempts: round.settle_attempts + 1,\n   265→  });\n   266→\n   267→  // Persist entries in dedicated JSONB column for direct access\n   268→  await db.updateRoundEntries(pda, coinflipEntries);\n   269→\n   270→  // Log settle_confirmed\n   271→  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   272→    txSignature,\n   273→    resultSide,\n   274→    winner: winner.toBase58(),\n   275→    entropy: entropy.toString(\"hex\"),\n   276→    payoutAmount,\n   277→    feeAmount,\n   278→    entries: coinflipEntries,\n   279→  });\n   280→\n   281→  // Write payout transaction for the winner\n   282→  await db.insertTransaction({\n   283→    wallet: winner.toBase58(),\n   284→    game: \"coinflip\",\n   285→    matchId: round.match_id,\n   286→    txType: \"payout\",\n   287→    amountLamports: payoutAmount,\n   288→    txSig: txSignature,\n   289→  });\n   290→\n   291→  const tDone = performance.now();\n   292→  logger.info(\"settlement transaction confirmed\", {\n   293→    pda,\n   294→    txSignature,\n   295→    resultSide,\n   296→    winner: winner.toBase58(),\n   297→    timing: {\n   298→      dbMs: Math.round(tDb - t0),\n   299→      fetchMs: Math.round(tFetch - tDb),\n   300→      buildMs: Math.round(tBuild - tFetch),\n   301→      sendMs: Math.round(tSend - tBuild),\n   302→      confirmMs: Math.round(tConfirm - tSend),\n   303→      dbWriteMs: Math.round(tDone - tConfirm),\n   304→      totalMs: Math.round(tDone - t0),\n   305→    },\n   306→  });\n   307→\n   308→  return {\n   309→    txSignature,\n   310→    resultHash,\n   311→    resultSide,\n   312→    winner: winner.toBase58(),\n   313→  };\n   314→}\n   315→\n   316→export async function settleLordRound(\n   317→  deps: SettleTxDeps,\n   318→  pda: string,\n   319→): Promise<SettleResult> {\n   320→  const t0 = performance.now();\n   321→  const { db, connection, serverKeypair, entropyAccount } = deps;\n   322→  const roundPubkey = new PublicKey(pda);\n   323→\n   324→  const round = await db.getRoundByPda(pda);\n   325→  const tDb = performance.now();\n   326→  if (!round) {\n   327→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   328→  }\n   329→  if (round.phase !== \"locked\" && round.phase !== \"settling\") {\n   330→    throw new PermanentSettleError(\n   331→      `Round ${pda} in unexpected phase: ${round.phase}`,\n   332→    );\n   333→  }\n   334→\n   335→  const secret = Buffer.from(round.secret);\n   336→\n   337→  if (round.phase === \"locked\") {\n   338→    await db.updateRoundPhase(pda, \"settling\");\n   339→  }\n   340→\n   341→  await db.insertOperatorEvent(pda, \"settle_submitted\", {\n   342→    attempt: round.settle_attempts + 1,\n   343→    game: \"lord\",\n   344→  });\n   345→\n   346→  const [platformConfigPda] = derivePlatformConfigPda();\n   347→  const [roundAccountInfo, platformConfig, entropyInfo, latestBlockhash] =\n   348→    await Promise.all([\n   349→      connection.getAccountInfo(roundPubkey),\n   350→      getPlatformConfig(connection),\n   351→      connection.getAccountInfo(entropyAccount),\n   352→      connection.getLatestBlockhash(),\n   353→    ]);\n   354→\n   355→  const tFetch = performance.now();\n   356→\n   357→  if (!roundAccountInfo) {\n   358→    throw new PermanentSettleError(`Lord round account not found on-chain: ${pda}`);\n   359→  }\n   360→  if (!entropyInfo) {\n   361→    throw new TransientSettleError(\"Entropy account not available yet\");\n   362→  }\n   363→\n   364→  // IDL-driven decode — no manual byte offsets or parseLordRound()\n   365→  const roundData: DecodedJackpotRound = decodeLordRound(Buffer.from(roundAccountInfo.data));\n   366→  const { feeBps, treasury } = platformConfig;\n   367→\n   368→  const entropy = Buffer.from(entropyInfo.data.subarray(0, 32));\n   369→  const resultHash = deriveResult(\n   370→    secret,\n   371→    entropy,\n   372→    roundPubkey.toBuffer(),\n   373→    roundData.algorithmVer,\n   374→  );\n   375→  const feeAmount = Number((roundData.totalAmountLamports * BigInt(feeBps)) / 10_000n);\n   376→  const payoutAmount = Number(roundData.totalAmountLamports) - feeAmount;\n   377→  const rentRefund = roundAccountInfo.lamports - Number(roundData.totalAmountLamports);\n   378→\n   379→  const raw = resultHash.readBigUInt64LE(0);\n   380→  const winningOffset = raw % roundData.totalAmountLamports;\n   381→\n   382→  let cumulative = 0n;\n   383→  let winnerEntryIndex = -1;\n   384→  let winner = roundData.entries[0]?.player;\n   385→  for (const [index, entry] of roundData.entries.entries()) {\n   386→    cumulative += entry.amountLamports;\n   387→    if (winningOffset < cumulative) {\n   388→      winnerEntryIndex = index;\n   389→      winner = entry.player;\n   390→      break;\n   391→    }\n   392→  }\n   393→\n   394→  if (!winner || winnerEntryIndex < 0) {\n   395→    throw new PermanentSettleError(\"Unable to derive Lord winner from entries\");\n   396→  }\n   397→\n   398→  const matchIdBuf = Buffer.from(round.match_id, \"hex\");\n   399→  const instruction = new TransactionInstruction({\n   400→    keys: [\n   401→      { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true }, // caller (receives rent refund)\n   402→      { pubkey: roundPubkey, isSigner: false, isWritable: true },\n   403→      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n   404→      { pubkey: entropyAccount, isSigner: false, isWritable: false }, // slot_hashes sysvar\n   405→      { pubkey: treasury, isSigner: false, isWritable: true },\n   406→      { pubkey: winner, isSigner: false, isWritable: true },\n   407→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   408→    ],\n   409→    programId: LORDOFRNGS_PROGRAM_ID,\n   410→    data: encodeClaimPayoutData(matchIdBuf, secret),\n   411→  });\n   412→\n   413→  const { blockhash, lastValidBlockHeight } = latestBlockhash;\n   414→  const tx = new Transaction({\n   415→    feePayer: serverKeypair.publicKey,\n   416→    blockhash,\n   417→    lastValidBlockHeight,\n   418→  });\n   419→  tx.add(instruction);\n   420→  tx.sign(serverKeypair);\n   421→\n   422→  const tBuild = performance.now();\n   423→  const txSignature = await connection.sendRawTransaction(tx.serialize(), {\n   424→    skipPreflight: false,\n   425→  });\n   426→  const tSend = performance.now();\n   427→\n   428→  logger.info(\"lord settlement transaction submitted\", {\n   429→    pda,\n   430→    txSignature,\n   431→    attempt: round.settle_attempts + 1,\n   432→    winningEntryIndex: winnerEntryIndex,\n   433→    dbMs: Math.round(tDb - t0),\n   434→    fetchMs: Math.round(tFetch - tDb),\n   435→    buildMs: Math.round(tBuild - tFetch),\n   436→    sendMs: Math.round(tSend - tBuild),\n   437→  });\n   438→\n   439→  const confirmation = await connection.confirmTransaction(\n   440→    { signature: txSignature, blockhash, lastValidBlockHeight },\n   441→    \"confirmed\",\n   442→  );\n   443→  const tConfirm = performance.now();\n   444→  if (confirmation.value.err) {\n   445→    throw new TransientSettleError(\n   446→      `Lord settle transaction ${txSignature} confirmed with error: ${JSON.stringify(confirmation.value.err)}`,\n   447→    );\n   448→  }\n   449→\n   450→  const serializedEntries = roundData.entries.map((e) => ({\n   451→    player: e.player.toBase58(),\n   452→    amountLamports: Number(e.amountLamports),\n   453→  }));\n   454→\n   455→  await db.updateRoundPhase(pda, \"settled\", {\n   456→    settle_tx: txSignature,\n   457→    result_hash: resultHash,\n   458→    result_side: winnerEntryIndex,\n   459→    winner: winner.toBase58(),\n   460→    settle_attempts: round.settle_attempts + 1,\n   461→  });\n   462→\n   463→  // Persist entries in dedicated JSONB column for direct access\n   464→  await db.updateRoundEntries(pda, serializedEntries);\n   465→\n   466→  await db.insertOperatorEvent(pda, \"settle_confirmed\", {\n   467→    txSignature,\n   468→    winner: winner.toBase58(),\n   469→    winningEntryIndex: winnerEntryIndex,\n   470→    game: \"lord\",\n   471→    entropy: entropy.toString(\"hex\"),\n   472→    winningOffset: winningOffset.toString(),\n   473→    totalAmountLamports: Number(roundData.totalAmountLamports),\n   474→    payoutAmount,\n   475→    feeAmount,\n   476→    rentRefund,\n   477→    entries: serializedEntries,\n   478→  });\n   479→\n   480→  // Write payout transaction for the winner\n   481→  await db.insertTransaction({\n   482→    wallet: winner.toBase58(),\n   483→    game: \"lord\",\n   484→    matchId: round.match_id,\n   485→    txType: \"payout\",\n   486→    amountLamports: payoutAmount,\n   487→    txSig: txSignature,\n   488→  });\n   489→\n   490→  const tDone = performance.now();\n   491→  logger.info(\"lord settlement transaction confirmed\", {\n   492→    pda,\n   493→    txSignature,\n   494→    winner: winner.toBase58(),\n   495→    winningEntryIndex: winnerEntryIndex,\n   496→    timing: {\n   497→      dbMs: Math.round(tDb - t0),\n   498→      fetchMs: Math.round(tFetch - tDb),\n   499→      buildMs: Math.round(tBuild - tFetch),\n   500→      sendMs: Math.round(tSend - tBuild),\n   501→      confirmMs: Math.round(tConfirm - tSend),\n   502→      dbWriteMs: Math.round(tDone - tConfirm),\n   503→      totalMs: Math.round(tDone - t0),\n   504→    },\n   505→  });\n   506→\n   507→  return {\n   508→    txSignature,\n   509→    resultHash,\n   510→    winningEntryIndex: winnerEntryIndex,\n   511→    winner: winner.toBase58(),\n   512→  };\n   513→}\n   514→\n   515→export async function settleRound(\n   516→  deps: SettleTxDeps,\n   517→  pda: string,\n   518→): Promise<SettleResult> {\n   519→  const round = await deps.db.getRoundByPda(pda);\n   520→  if (!round) {\n   521→    throw new PermanentSettleError(`Round not found in DB: ${pda}`);\n   522→  }\n   523→\n   524→  if (round.game === \"lord\") {\n   525→    return settleLordRound(deps, pda);\n   526→  }\n   527→\n   528→  return settleMatch(deps, pda);\n   529→}\n   530→\n   531→// ---------------------------------------------------------------------------\n   532→// Close Call — transaction builders\n   533→// ---------------------------------------------------------------------------\n   534→\n   535→function deriveCloseCallConfigPda(): [PublicKey, number] {\n   536→  return PublicKey.findProgramAddressSync(\n   537→    [Buffer.from(\"closecall_config\")],\n   538→    CLOSECALL_PROGRAM_ID,\n   539→  );\n   540→}\n   541→\n   542→\n   543→function minuteTsToBuffer(ts: bigint): Buffer {\n   544→  const buf = Buffer.alloc(8);\n   545→  buf.writeBigInt64LE(ts);\n   546→  return buf;\n   547→}\n   548→\n   549→function deriveCloseCallRoundPda(minuteTs: bigint): [PublicKey, number] {\n   550→  return PublicKey.findProgramAddressSync(\n   551→    [Buffer.from(\"cc_round\"), minuteTsToBuffer(minuteTs)],\n   552→    CLOSECALL_PROGRAM_ID,\n   553→  );\n   554→}\n   555→\n   556→/** Encode closecall instruction data: discriminator(8) + minute_ts(i64 LE, 8) = 16 bytes */\n   557→function encodeCcMinuteTsData(discriminator: Buffer, minuteTs: bigint): Buffer {\n   558→  const buf = Buffer.alloc(16);\n   559→  discriminator.copy(buf, 0);\n   560→  buf.writeBigInt64LE(minuteTs, 8);\n   561→  return buf;\n   562→}\n   563→\n   564→/** Encode closecall settle_round data: disc(8) + minute_ts(i64 LE, 8) + close_price(i64 LE, 8) + close_price_expo(i32 LE, 4) = 28 bytes */\n   565→function encodeCcSettleData(discriminator: Buffer, minuteTs: bigint, price: bigint, expo: number): Buffer {\n   566→  const buf = Buffer.alloc(28);\n   567→  discriminator.copy(buf, 0);\n   568→  buf.writeBigInt64LE(minuteTs, 8);\n   569→  buf.writeBigInt64LE(price, 16);\n   570→  buf.writeInt32LE(expo, 24);\n   571→  return buf;\n   572→}\n   573→\n   574→/**\n   575→ * Encode closecall bet data:\n   576→ * disc(8) + minute_ts(i64 LE, 8) + side(1) + amount(u64 LE, 8) + open_price(i64 LE, 8) + open_price_expo(i32 LE, 4) = 37 bytes\n   577→ */\n   578→function encodeCcBetData(\n   579→  discriminator: Buffer,\n   580→  minuteTs: bigint,\n   581→  side: number,\n   582→  amount: bigint,\n   583→  openPrice: bigint,\n   584→  openPriceExpo: number,\n   585→): Buffer {\n   586→  const buf = Buffer.alloc(37);\n   587→  discriminator.copy(buf, 0);\n   588→  buf.writeBigInt64LE(minuteTs, 8);\n   589→  buf.writeUInt8(side, 16);\n   590→  buf.writeBigUInt64LE(amount, 17);\n   591→  buf.writeBigInt64LE(openPrice, 25);\n   592→  buf.writeInt32LE(openPriceExpo, 33);\n   593→  return buf;\n   594→}\n   595→\n   596→export interface CloseCallTxDeps {\n   597→  connection: Connection;\n   598→  serverKeypair: Keypair;\n   599→}\n   600→\n   601→/**\n   602→ * Build a `bet` instruction (no transaction wrapping).\n   603→ *\n   604→ * Two signers: player (pays bet) + server (pays rent on first call).\n   605→ * Price + bet info passed as instruction args.\n   606→ * Uses init_if_needed — works for both round creation and joining.\n   607→ */\n   608→export function buildCloseCallBetIx(\n   609→  serverPubkey: PublicKey,\n   610→  playerPubkey: PublicKey,\n   611→  minuteTs: bigint,\n   612→  side: number,\n   613→  amountLamports: bigint,\n   614→  openPrice: bigint,\n   615→  openPriceExpo: number,\n   616→): TransactionInstruction {\n   617→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   618→  const [configPda] = deriveCloseCallConfigPda();\n   619→  const data = encodeCcBetData(\n   620→    CC_BET_DISCRIMINATOR,\n   621→    minuteTs,\n   622→    side,\n   623→    amountLamports,\n   624→    openPrice,\n   625→    openPriceExpo,\n   626→  );\n   627→\n   628→  return new TransactionInstruction({\n   629→    keys: [\n   630→      { pubkey: playerPubkey, isSigner: true, isWritable: true },  // player (pays bet)\n   631→      { pubkey: serverPubkey, isSigner: true, isWritable: true },  // server (pays rent on first call)\n   632→      { pubkey: configPda, isSigner: false, isWritable: false },   // config\n   633→      { pubkey: roundPda, isSigner: false, isWritable: true },     // round\n   634→      { pubkey: SystemProgram.programId, isSigner: false, isWritable: false },\n   635→    ],\n   636→    programId: CLOSECALL_PROGRAM_ID,\n   637→    data,\n   638→  });\n   639→}\n   640→\n   641→/**\n   642→ * Build a `settle_round` instruction (no transaction wrapping).\n   643→ * Price is passed as instruction args (no on-chain Pyth account).\n   644→ */\n   645→export function buildCloseCallSettleRoundIx(\n   646→  serverPubkey: PublicKey,\n   647→  minuteTs: bigint,\n   648→  closePrice: bigint,\n   649→  closePriceExpo: number,\n   650→  treasury: PublicKey,\n   651→  winnerAccounts: PublicKey[],\n   652→): TransactionInstruction {\n   653→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   654→  const [platformConfigPda] = derivePlatformConfigPda();\n   655→  const data = encodeCcSettleData(CC_SETTLE_ROUND_DISCRIMINATOR, minuteTs, closePrice, closePriceExpo);\n   656→\n   657→  return new TransactionInstruction({\n   658→    keys: [\n   659→      { pubkey: serverPubkey, isSigner: true, isWritable: true },\n   660→      { pubkey: roundPda, isSigner: false, isWritable: true },\n   661→      { pubkey: platformConfigPda, isSigner: false, isWritable: false }, // platform_config\n   662→      { pubkey: treasury, isSigner: false, isWritable: true },\n   663→      { pubkey: serverPubkey, isSigner: false, isWritable: true },\n   664→      ...winnerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n   665→    ],\n   666→    programId: CLOSECALL_PROGRAM_ID,\n   667→    data,\n   668→  });\n   669→}\n   670→\n   671→/**\n   672→ * Build a partially-signed `bet` transaction for the Close Call program.\n   673→ *\n   674→ * Two signers: player (pays bet) + server (pays rent on first call via init_if_needed).\n   675→ * Server signs immediately; the frontend must add the player signature before submitting.\n   676→ * Works for both round creation (first bet) and joining (subsequent bets).\n   677→ */\n   678→export async function buildCloseCallBetTx(\n   679→  deps: CloseCallTxDeps,\n   680→  playerPubkey: PublicKey,\n   681→  minuteTs: bigint,\n   682→  side: number,\n   683→  amountLamports: bigint,\n   684→  openPrice: bigint,\n   685→  openPriceExpo: number,\n   686→): Promise<{ tx: Transaction; roundPda: PublicKey }> {\n   687→  const { connection, serverKeypair } = deps;\n   688→\n   689→  const instruction = buildCloseCallBetIx(\n   690→    serverKeypair.publicKey,\n   691→    playerPubkey,\n   692→    minuteTs,\n   693→    side,\n   694→    amountLamports,\n   695→    openPrice,\n   696→    openPriceExpo,\n   697→  );\n   698→\n   699→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   700→\n   701→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   702→  const tx = new Transaction({ feePayer: playerPubkey, blockhash, lastValidBlockHeight });\n   703→  tx.add(instruction);\n   704→  tx.partialSign(serverKeypair);\n   705→\n   706→  return { tx, roundPda };\n   707→}\n   708→\n   709→/**\n   710→ * Build a signed `settle_round` transaction for the Close Call program.\n   711→ *\n   712→ * Price is passed as instruction args. Winners (or all players for refund)\n   713→ * are passed as remaining accounts for auto-payout.\n   714→ */\n   715→export async function buildCloseCallSettleRoundTx(\n   716→  deps: CloseCallTxDeps,\n   717→  minuteTs: bigint,\n   718→  closePrice: bigint,\n   719→  closePriceExpo: number,\n   720→  treasury: PublicKey,\n   721→  winnerAccounts: PublicKey[],\n   722→): Promise<Transaction> {\n   723→  const { connection, serverKeypair } = deps;\n   724→\n   725→  const instruction = buildCloseCallSettleRoundIx(\n   726→    serverKeypair.publicKey,\n   727→    minuteTs,\n   728→    closePrice,\n   729→    closePriceExpo,\n   730→    treasury,\n   731→    winnerAccounts,\n   732→  );\n   733→\n   734→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   735→  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n   736→  tx.add(instruction);\n   737→  tx.sign(serverKeypair);\n   738→\n   739→  return tx;\n   740→}\n   741→\n   742→/**\n   743→ * Build a signed `timeout_refund` transaction for the Close Call program.\n   744→ *\n   745→ * Permissionless after the resolve deadline. Refunds all players their exact\n   746→ * deposit via remaining accounts.\n   747→ */\n   748→export async function buildCloseCallTimeoutRefundTx(\n   749→  deps: CloseCallTxDeps,\n   750→  minuteTs: bigint,\n   751→  playerAccounts: PublicKey[],\n   752→): Promise<Transaction> {\n   753→  const { connection, serverKeypair } = deps;\n   754→\n   755→  const [roundPda] = deriveCloseCallRoundPda(minuteTs);\n   756→  const [configPda] = deriveCloseCallConfigPda();\n   757→  const data = encodeCcMinuteTsData(CC_TIMEOUT_REFUND_DISCRIMINATOR, minuteTs);\n   758→\n   759→  const keys = [\n   760→    { pubkey: serverKeypair.publicKey, isSigner: true, isWritable: true },  // caller\n   761→    { pubkey: roundPda, isSigner: false, isWritable: true },                 // round\n   762→    { pubkey: configPda, isSigner: false, isWritable: false },               // closecall_config\n   763→    { pubkey: serverKeypair.publicKey, isSigner: false, isWritable: true },  // rent_receiver (= round.server)\n   764→    ...playerAccounts.map((pk) => ({ pubkey: pk, isSigner: false, isWritable: true })),\n   765→  ];\n   766→\n   767→  const instruction = new TransactionInstruction({\n   768→    keys,\n   769→    programId: CLOSECALL_PROGRAM_ID,\n   770→    data,\n   771→  });\n   772→\n   773→  const { blockhash, lastValidBlockHeight } = await connection.getLatestBlockhash();\n   774→  const tx = new Transaction({ feePayer: serverKeypair.publicKey, blockhash, lastValidBlockHeight });\n   775→  tx.add(instruction);\n   776→  tx.sign(serverKeypair);\n   777→\n   778→  return tx;\n   779→}\n   780→\n   781→// ---------------------------------------------------------------------------\n   782→// Error types\n   783→// ---------------------------------------------------------------------------\n   784→\n   785→/** Permanent failure — should not be retried. */\n   786→export class PermanentSettleError extends Error {\n   787→  readonly permanent = true;\n   788→  constructor(message: string) {\n   789→    super(message);\n   790→    this.name = \"PermanentSettleError\";\n   791→  }\n   792→}\n   793→\n   794→/** Transient failure — safe to retry. */\n   795→export class TransientSettleError extends Error {\n   796→  readonly permanent = false;\n   797→  constructor(message: string) {\n   798→    super(message);\n   799→    this.name = \"TransientSettleError\";\n   800→  }\n   801→}\n   802→"}]},"parent_tool_use_id":"toolu_01PnsFyyJnUwtkd2cMCTGyPV","session_id":"7e052405-15aa-4b3b-94b0-00f5b3dd543f","uuid":"35264818-c788-4ae3-a3b2-2490db12a034","timestamp":"2026-03-25T11:35:38.550Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NgWw1LJibgxeyrBvG5FA1S","type":"tool_result","content":"     1→/**\n     2→ * Event producer — inserts an event into the queue within an existing\n     3→ * database transaction so the event is committed atomically with the\n     4→ * triggering operation.\n     5→ */\n     6→\n     7→import type postgres from \"postgres\";\n     8→import type { EventType } from \"./event-types.js\";\n     9→\n    10→/** The transaction/sql handle accepted by emitEvent — works with both sql and tx from sql.begin(). */\n    11→export type SqlOrTransaction = postgres.Sql;\n    12→\n    13→export interface EmitEventOptions {\n    14→  maxAttempts?: number; // default: 3\n    15→  scheduledAt?: Date; // default: now\n    16→}\n    17→\n    18→export async function emitEvent(\n    19→  tx: SqlOrTransaction,\n    20→  eventType: EventType,\n    21→  payload: Record<string, unknown>,\n    22→  options?: EmitEventOptions,\n    23→): Promise<{ eventId: bigint }> {\n    24→  const maxAttempts = options?.maxAttempts ?? 3;\n    25→  const scheduledAt = options?.scheduledAt ?? new Date();\n    26→\n    27→  const rows = await tx<{ id: string }[]>`\n    28→    INSERT INTO event_queue (event_type, payload, max_attempts, scheduled_at)\n    29→    VALUES (${eventType}, ${tx.json(payload as postgres.JSONValue)}, ${maxAttempts}, ${scheduledAt})\n    30→    RETURNING id\n    31→  `;\n    32→\n    33→  return { eventId: BigInt(rows[0]!.id) };\n    34→}\n    35→"}]},"parent_tool_use_id":"toolu_01PnsFyyJnUwtkd2cMCTGyPV","session_id":"7e052405-15aa-4b3b-94b0-00f5b3dd543f","uuid":"e4bdf745-f2be-49b1-9f94-fde5ff2e3cb8","timestamp":"2026-03-25T11:35:38.559Z"}
