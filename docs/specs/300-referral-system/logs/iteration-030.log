ct(() => {\n    46→    fetchStats();\n    47→  }, [fetchStats]);\n    48→\n    49→  // Poll claim status until terminal\n    50→  useEffect(() => {\n    51→    if (!claimResult || !accessToken) return;\n    52→    if (claimResult.status === \"completed\" || claimResult.status === \"failed\") {\n    53→      return;\n    54→    }\n    55→    const poll = async () => {\n    56→      try {\n    57→        const updated = await pollClaimStatus(accessToken, claimResult.claimId);\n    58→        setClaimResult(updated);\n    59→        if (updated.status === \"completed\") {\n    60→          fetchStats(); // refresh pending balance\n    61→        } else if (updated.status !== \"failed\") {\n    62→          pollRef.current = setTimeout(poll, 3000);\n    63→        }\n    64→      } catch {\n    65→        pollRef.current = setTimeout(poll, 5000);\n    66→      }\n    67→    };\n    68→    pollRef.current = setTimeout(poll, 2000);\n    69→    return () => {\n    70→      if (pollRef.current) clearTimeout(pollRef.current);\n    71→    };\n    72→  }, [claimResult, accessToken, fetchStats]);\n    73→\n    74→  const handleClaim = useCallback(async () => {\n    75→    if (!accessToken) return;\n    76→    setClaiming(true);\n    77→    setError(\"\");\n    78→    setClaimResult(null);\n    79→    try {\n    80→      const res = await requestReferralClaim(accessToken);\n    81→      setClaimResult(res);\n    82→    } catch (e) {\n    83→      setError(e instanceof Error ? e.message : \"Claim failed\");\n    84→    } finally {\n    85→      setClaiming(false);\n    86→    }\n    87→  }, [accessToken]);\n    88→\n    89→  const pendingLamports = Number(stats?.pendingLamports ?? \"0\");\n    90→  const earnedLamports = stats?.totalEarnedLamports ?? \"0\";\n    91→  const rebateLamports = stats?.totalRebateLamports ?? \"0\";\n    92→  const canClaim = pendingLamports >= MIN_CLAIM_LAMPORTS;\n    93→\n    94→  return (\n    95→    <div className=\"ref-claim-card\">\n    96→      <h3 className=\"ref-claim-card__title\">Pending Earnings</h3>\n    97→\n    98→      {loading ? (\n    99→        <div className=\"ref-claim-card__skeleton\" />\n   100→      ) : (\n   101→        <>\n   102→          <div className=\"ref-claim-card__balance\">\n   103→            {formatSol(String(pendingLamports))} <span className=\"ref-claim-card__sol\">SOL</span>\n   104→          </div>\n   105→\n   106→          <div className=\"ref-claim-card__breakdown\">\n   107→            <div className=\"ref-claim-card__breakdown-row\">\n   108→              <span>From referrals</span>\n   109→              <span>{formatSol(earnedLamports)} SOL</span>\n   110→            </div>\n   111→            <div className=\"ref-claim-card__breakdown-row\">\n   112→              <span>From fee rebates</span>\n   113→              <span>{formatSol(rebateLamports)} SOL</span>\n   114→            </div>\n   115→          </div>\n   116→\n   117→          {claimResult?.status === \"completed\" && claimResult.txSignature ? (\n   118→            <div className=\"ref-claim-card__success\">\n   119→              Claimed {formatSol(claimResult.amountLamports)} SOL{\" \"}\n   120→              <a\n   121→                href={explorerTxUrl(claimResult.txSignature)}\n   122→                target=\"_blank\"\n   123→                rel=\"noopener noreferrer\"\n   124→                className=\"ref-claim-card__tx-link\"\n   125→              >\n   126→                View transaction &#x2197;\n   127→              </a>\n   128→            </div>\n   129→          ) : claimResult?.status === \"failed\" ? (\n   130→            <div className=\"ref-claim-card__error\">\n   131→              Claim failed. Please try again.\n   132→            </div>\n   133→          ) : null}\n   134→\n   135→          {error && <div className=\"ref-claim-card__error\">{error}</div>}\n   136→\n   137→          <button\n   138→            type=\"button\"\n   139→            className=\"ref-claim-card__btn\"\n   140→            onClick={handleClaim}\n   141→            disabled={!canClaim || claiming || (claimResult?.status === \"pending\")}\n   142→          >\n   143→            {claiming\n   144→              ? \"Claiming...\"\n   145→              : claimResult?.status === \"pending\"\n   146→                ? \"Processing...\"\n   147→                : canClaim\n   148→                  ? \"Claim Earnings\"\n   149→                  : pendingLamports > 0\n   150→                    ? \"Below minimum (0.01 SOL)\"\n   151→                    : \"No pending earnings\"}\n   152→          </button>\n   153→        </>\n   154→      )}\n   155→    </div>\n   156→  );\n   157→}\n   158→"}]},"parent_tool_use_id":null,"session_id":"18302c5c-b9ec-4f75-9de3-1cbb537277bf","uuid":"de090968-69e0-4b1f-993b-98d9d30445f1","timestamp":"2026-03-25T14:11:20.467Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/referral/ReferralClaimCard.tsx","content":"import { useCallback, useEffect, useRef, useState } from \"react\";\nimport { useSession } from \"../../context/SessionContext\";\nimport {\n  getReferralStats,\n  requestReferralClaim,\n  pollClaimStatus,\n  type ReferralStatsResponse,\n  type ClaimResponse,\n} from \"../../lib/referral-api\";\nimport { explorerTxUrl } from \"../../lib/solana-env\";\n\nconst LAMPORTS_PER_SOL = 1_000_000_000;\nconst MIN_CLAIM_LAMPORTS = 10_000_000; // 0.01 SOL\n\nfunction formatSol(lamportsStr: string): string {\n  const sol = Number(lamportsStr) / LAMPORTS_PER_SOL;\n  if (sol >= 1_000_000) return `${(sol / 1_000_000).toFixed(1)}M`;\n  if (sol >= 1000) return `${(sol / 1000).toFixed(1)}k`;\n  if (sol >= 1) return sol.toFixed(2);\n  if (sol >= 0.01) return sol.toFixed(3);\n  return sol.toFixed(4);\n}\n\nexport function ReferralClaimCard() {\n  const { accessToken } = useSession();\n  const [loading, setLoading] = useState(true);\n  const [stats, setStats] = useState<ReferralStatsResponse | null>(null);\n  const [claiming, setClaiming] = useState(false);\n  const [claimResult, setClaimResult] = useState<ClaimResponse | null>(null);\n  const [error, setError] = useState(\"\");\n  const pollRef = useRef<ReturnType<typeof setTimeout> | null>(null);\n\n  const fetchStats = useCallback(async () => {\n    if (!accessToken) return;\n    try {\n      const res = await getReferralStats(accessToken);\n      setStats(res);\n    } catch {\n      /* unavailable — show zeros */\n    } finally {\n      setLoading(false);\n    }\n  }, [accessToken]);\n\n  useEffect(() => {\n    fetchStats();\n  }, [fetchStats]);\n\n  // Poll claim status until terminal\n  useEffect(() => {\n    if (!claimResult || !accessToken) return;\n    if (claimResult.status === \"completed\" || claimResult.status === \"failed\") {\n      return;\n    }\n    const poll = async () => {\n      try {\n        const updated = await pollClaimStatus(accessToken, claimResult.claimId);\n        setClaimResult(updated);\n        if (updated.status === \"completed\") {\n          fetchStats(); // refresh pending balance\n        } else if (updated.status !== \"failed\") {\n          pollRef.current = setTimeout(poll, 3000);\n        }\n      } catch {\n        pollRef.current = setTimeout(poll, 5000);\n      }\n    };\n    pollRef.current = setTimeout(poll, 2000);\n    return () => {\n      if (pollRef.current) clearTimeout(pollRef.current);\n    };\n  }, [claimResult, accessToken, fetchStats]);\n\n  const handleClaim = useCallback(async () => {\n    if (!accessToken) return;\n    setClaiming(true);\n    setError(\"\");\n    setClaimResult(null);\n    try {\n      const res = await requestReferralClaim(accessToken);\n      setClaimResult(res);\n    } catch (e) {\n      setError(e instanceof Error ? e.message : \"Claim failed\");\n    } finally {\n      setClaiming(false);\n    }\n  }, [accessToken]);\n\n  const pendingLamports = Number(stats?.pendingLamports ?? \"0\");\n  const earnedLamports = stats?.totalEarnedLamports ?? \"0\";\n  const rebateLamports = stats?.totalRebateLamports ?? \"0\";\n  const canClaim = pendingLamports >= MIN_CLAIM_LAMPORTS;\n\n  return (\n    <div className=\"ref-claim-card\">\n      <h3 className=\"ref-claim-card__title\">Pending Earnings</h3>\n\n      {loading ? (\n        <div className=\"ref-claim-card__skeleton\" />\n      ) : (\n        <>\n          <div className=\"ref-claim-card__balance\">\n            {formatSol(String(pendingLamports))} <span className=\"ref-claim-card__sol\">SOL</span>\n          </div>\n\n          <div className=\"ref-claim-card__breakdown\">\n            <div className=\"ref-claim-card__breakdown-row\">\n              <span>From referrals</span>\n              <span>{formatSol(earnedLamports)} SOL</span>\n            </div>\n            <div className=\"ref-claim-card__breakdown-row\">\n              <span>From fee rebates</span>\n              <span>{formatSol(rebateLamports)} SOL</span>\n            </div>\n          </div>\n\n          {claimResult?.status === \"completed\" && claimResult.txSignature ? (\n            <div className=\"ref-claim-card__success\">\n              Claimed {formatSol(claimResult.amountLamports)} SOL{\" \"}\n              <a\n                href={explorerTxUrl(claimResult.txSignature)}\n                target=\"_blank\"\n                rel=\"noopener noreferrer\"\n                className=\"ref-claim-card__tx-link\"\n              >\n                View transaction &#x2197;\n              </a>\n            </div>\n          ) : claimResult?.status === \"failed\" ? (\n            <div className=\"ref-claim-card__error\">\n              Claim failed. Please try again.\n            </div>\n          ) : null}\n\n          {error && <div className=\"ref-claim-card__error\">{error}</div>}\n\n          <button\n            type=\"button\"\n            className=\"ref-claim-card__btn\"\n            onClick={handleClaim}\n            disabled={!canClaim || claiming || (claimResult?.status === \"pending\")}\n          >\n            {claiming\n              ? \"Claiming...\"\n              : claimResult?.status === \"pending\"\n                ? \"Processing...\"\n                : canClaim\n                  ? \"Claim Earnings\"\n                  : pendingLamports > 0\n                    ? \"Below minimum (0.01 SOL)\"\n                    : \"No pending earnings\"}\n          </button>\n        </>\n      )}\n    </div>\n  );\n}\n","numLines":158,"startLine":1,"totalLines":158}}}
