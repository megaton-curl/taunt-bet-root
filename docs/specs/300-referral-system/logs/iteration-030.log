{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q825jSZbTperVt9bkJ1odw","type":"tool_result","content":"     1→/**\n     2→ * Local error-flow E2E tests: insufficient balance, join unavailable match,\n     3→ * settle already-claimed match.\n     4→ *\n     5→ * Tests run serially because later tests depend on chain state left by earlier\n     6→ * ones (e.g. additional airdrop in test 2).\n     7→ *\n     8→ * Prerequisites (handled by localnet-bootstrap.sh):\n     9→ * - solana-test-validator running with coinflip + platform programs\n    10→ * - Orao mock accounts pre-loaded (required for lifecycle in test 3)\n    11→ */\n    12→import { Connection } from \"@solana/web3.js\";\n    13→import { test, expect } from \"./fixtures\";\n    14→import * as po from \"./helpers/page-objects\";\n    15→import {\n    16→  fundWallet,\n    17→  PLAYER_A,\n    18→  PLAYER_B,\n    19→  LOCAL_RPC_URL,\n    20→} from \"./helpers/wallets\";\n    21→import { initializeLocalnet } from \"./helpers/localnet-setup\";\n    22→import { assertMatchClosed, assertMatchCreated, getCoinflipProgram } from \"./helpers/on-chain\";\n    23→\n    24→// ── Serial execution: skip remaining tests if one fails ───────────────\n    25→\n    26→test.describe(\"Error flow tests\", () => {\n    27→  test.describe.configure({ mode: \"serial\" });\n    28→\n    29→  test.beforeAll(async () => {\n    30→    await initializeLocalnet();\n    31→    const connection = new Connection(LOCAL_RPC_URL, \"confirmed\");\n    32→    // Fund Player A with minimal SOL — insufficient for iron tier (0.005 SOL)\n    33→    await fundWallet(connection, PLAYER_A.publicKey, 0.001);\n    34→    // Fund Player B with standard amount\n    35→    await fundWallet(connection, PLAYER_B.publicKey, 10);\n    36→  });\n    37→\n    38→  // ── Test 1: Insufficient balance ─────────────────────────────────────\n    39→\n    40→test(\"insufficient balance: creating match is rejected\", async ({\n    41→    playerAPage,\n    42→    connection,\n    43→  }) => {\n    44→    await po.navigateToCoinflip(playerAPage);\n    45→    await po.enterWager(playerAPage, 0.005);\n    46→    await po.selectSide(playerAPage, \"heads\");\n    47→\n    48→    // Click \"Create Game\" — balance (0.001 SOL) < wager (0.005 SOL)\n    49→    const createBtn = playerAPage.locator(po.sel.actionButton, {\n    50→      hasText: \"Create Game\",\n    51→    });\n    52→    await expect(createBtn).toBeEnabled();\n    53→    await createBtn.click();\n    54→\n    55→    // The current UI keeps the player in the create view when the tx is rejected.\n    56→    await expect(playerAPage.locator(po.sel.activeMatch)).toHaveCount(0);\n    57→    await expect(createBtn).toBeVisible();\n    58→\n    59→    // Verify no active match was created on-chain for the player.\n    60→    const program = getCoinflipProgram(connection);\n    61→    const matches = await program.account.coinflipMatch.all([\n    62→      { memcmp: { offset: 8, bytes: PLAYER_A.publicKey.toBase58() } },\n    63→      { dataSize: program.account.coinflipMatch.size },\n    64→    ]);\n    65→    expect(matches).toHaveLength(0);\n    66→  });\n    67→\n    68→  // ── Test 2: Join unavailable (cancelled) match ───────────────────────\n    69→\n    70→  test(\"joining unavailable match keeps player in the lobby\", async ({\n    71→    playerAPage,\n    72→    playerBPage,\n    73→    connection,\n    74→  }) => {\n    75→    // Fund A properly for this test (previous test left A with 0.001 SOL)\n    76→    await fundWallet(connection, PLAYER_A.publicKey, 10);\n    77→\n    78→    // A creates a match (iron tier, heads)\n    79→    await po.navigateToCoinflip(playerAPage);\n    80→    await po.createMatch(playerAPage, \"iron\", \"heads\");\n    81→    const { matchPda } = await assertMatchCreated(connection, PLAYER_A.publicKey, 0);\n    82→\n    83→    // B navigates and sees the match in lobby\n    84→    await po.navigateToCoinflip(playerBPage);\n    85→    await po.waitForLobbyMatch(playerBPage, 15_000);\n    86→\n    87→    // A cancels the match — PDA closes on-chain\n    88→    await po.cancelMatch(playerAPage);\n    89→    await assertMatchClosed(connection, matchPda);\n    90→\n    91→    // B tries to join the stale lobby card (lobby hasn't re-polled yet)\n    92→    const joinBtn = playerBPage\n    93→      .locator(\n    94→        `${po.sel.matchCard}:not(${po.sel.matchCardOwn}):not(${po.sel.matchCardClaimable})`,\n    95→      )\n    96→      .first()\n    97→      .locator(po.sel.matchCardJoinBtn);\n    98→    await joinBtn.click();\n    99→\n   100→    // The stale join attempt should not transition B into an active match.\n   101→    await expect(playerBPage.locator(po.sel.activeMatch)).toHaveCount(0);\n   102→    await expect(playerBPage.locator(po.sel.lobby)).toBeVisible();\n   103→  });\n   104→\n   105→  // ── Test 3: Settle already-claimed match ─────────────────────────────\n   106→\n   107→  test(\"settled match does not expose stale settle actions\", async ({\n   108→    playerAPage,\n   109→    playerBPage,\n   110→    connection,\n   111→  }) => {\n   112→    // A creates a match (iron tier, heads)\n   113→    await po.navigateToCoinflip(playerAPage);\n   114→    await po.createMatch(playerAPage, \"iron\", \"heads\");\n   115→    const { matchPda } = await assertMatchCreated(connection, PLAYER_A.publicKey, 0);\n   116→\n   117→    // B navigates and joins\n   118→    await po.navigateToCoinflip(playerBPage);\n   119→    await po.waitForLobbyMatch(playerBPage, 15_000);\n   120→    await po.joinMatch(playerBPage);\n   121→\n   122→    // Both wait for backend settlement and verify the outcomes are complementary.\n   123→    const [resultA, resultB] = await Promise.all([\n   124→      po.waitForResult(playerAPage, 30_000),\n   125→      po.waitForResult(playerBPage, 30_000),\n   126→    ]);\n   127→    expect(resultA).not.toBe(resultB);\n   128→\n   129→    await assertMatchClosed(connection, matchPda);\n   130→\n   131→    // Settled matches now auto-resolve; neither player should see stale claim/settle actions.\n   132→    await expect(\n   133→      playerAPage.locator(\"button\", { hasText: /Claim|Settle/i }),\n   134→    ).toHaveCount(0);\n   135→    await expect(\n   136→      playerBPage.locator(\"button\", { hasText: /Claim|Settle/i }),\n   137→    ).toHaveCount(0);\n   138→  });\n   139→});\n   140→"}]},"parent_tool_use_id":"toolu_01Lbc3QFfwCsMEC17ctBnBWJ","session_id":"18302c5c-b9ec-4f75-9de3-1cbb537277bf","uuid":"341d1f69-b987-4832-aa3a-40450680770d","timestamp":"2026-03-25T14:08:40.403Z"}
