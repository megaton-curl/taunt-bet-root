{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018D3vVKEUfdsdtwrwKJxQwG","type":"tool_result","content":"   100→ */\n   101→export async function enterWager(page: Page, amountSol: number): Promise<void> {\n   102→  const input = page.locator(\".rng-wager-input__input\").first();\n   103→  await expect(input).toBeVisible({ timeout: 15_000 });\n   104→  await input.fill(amountSol.toString());\n   105→}\n   106→\n   107→/**\n   108→ * Select a coin side (heads or tails) in the sidebar.\n   109→ */\n   110→export async function selectSide(page: Page, side: CoinSide): Promise<void> {\n   111→  const selector =\n   112→    side === \"heads\" ? sel.sideButtonHeads : sel.sideButtonTails;\n   113→  await page.click(selector);\n   114→  await expect(page.locator(selector)).toHaveClass(/coinflip-side-btn--selected/);\n   115→}\n   116→\n   117→/**\n   118→ * Create a match: enter wager amount, select side, click \"Create Game\".\n   119→ * Returns when the active match view (waiting state) is visible.\n   120→ */\n   121→export async function createMatch(\n   122→  page: Page,\n   123→  amountSol: number,\n   124→  side: CoinSide,\n   125→  options?: { timeout?: number },\n   126→): Promise<void> {\n   127→  // Ensure wallet is connected before interacting — prevents race on devnet\n   128→  await waitForWalletConnected(page);\n   129→  await enterWager(page, amountSol);\n   130→  await selectSide(page, side);\n   131→\n   132→  // Click create — button text is \"Create Game\"\n   133→  const createBtn = page.locator(sel.actionButton, {\n   134→    hasText: \"Create Game\",\n   135→  });\n   136→  await expect(createBtn).toBeEnabled();\n   137→  await createBtn.click();\n   138→\n   139→  // Wait for transition to active match (waiting for opponent).\n   140→  // Default 15s is fine for local; devnet callers should pass a longer timeout.\n   141→  await page.waitForSelector(sel.activeMatch, {\n   142→    state: \"visible\",\n   143→    timeout: options?.timeout ?? 15_000,\n   144→  });\n   145→}\n   146→\n   147→/**\n   148→ * Join a match visible in the lobby. If `matchIndex` is provided, join that\n   149→ * specific card (0-based). Otherwise joins the first joinable match.\n   150→ */\n   151→export async function joinMatch(\n   152→  page: Page,\n   153→  matchIndex = 0,\n   154→): Promise<void> {\n   155→  const cards = page.locator(\n   156→    `${sel.matchCard}:not(${sel.matchCardOwn}):not(${sel.matchCardClaimable})`,\n   157→  );\n   158→  const joinBtn = cards.nth(matchIndex).locator(sel.matchCardJoinBtn);\n   159→  await expect(joinBtn).toBeEnabled({ timeout: 10_000 });\n   160→  await joinBtn.click();\n   161→\n   162→  // Wait for active match view to appear\n   163→  await page.waitForSelector(sel.activeMatch, {\n   164→    state: \"visible\",\n   165→    timeout: 15_000,\n   166→  });\n   167→}\n   168→\n   169→/**\n   170→ * Join a specific match by exact match PDA id.\n   171→ */\n   172→export async function joinMatchById(\n   173→  page: Page,\n   174→  matchId: string,\n   175→): Promise<void> {\n   176→  const card = page.locator(`[data-match-id=\"${matchId}\"]`).first();\n   177→  await expect(card).toBeVisible({ timeout: 15_000 });\n   178→  const joinBtn = card.locator(sel.matchCardJoinBtn);\n   179→  await expect(joinBtn).toBeEnabled({ timeout: 10_000 });\n   180→  await joinBtn.click();\n   181→\n   182→  await page.waitForSelector(sel.activeMatch, {\n   183→    state: \"visible\",\n   184→    timeout: 15_000,\n   185→  });\n   186→}\n   187→\n   188→/**\n   189→ * Cancel the currently active match (phase = \"created\", waiting for opponent).\n   190→ * Clicks \"Cancel Match\" button in the ActiveMatchView.\n   191→ */\n   192→export async function cancelMatch(page: Page): Promise<void> {\n   193→  const cancelBtn = page.locator(\"button\", { hasText: \"Cancel Match\" });\n   194→  await expect(cancelBtn).toBeVisible({ timeout: 5_000 });\n   195→  await cancelBtn.click();\n   196→\n   197→  // Wait for lobby to reappear\n   198→  await page.waitForSelector(sel.lobby, {\n   199→    state: \"visible\",\n   200→    timeout: 15_000,\n   201→  });\n   202→}\n   203→\n   204→/**\n   205→ * Claim payout for the winner, or settle for the loser.\n   206→ * Clicks the \"Claim Payout\" or \"Settle & Return\" button in the sidebar.\n   207→ */\n   208→export async function claimOrSettle(page: Page): Promise<void> {\n   209→  // The claim/settle button is inside ActiveMatchView (not the sidebar)\n   210→  const claimBtn = page.locator(sel.activeMatch).locator(sel.actionButton).first();\n   211→  await expect(claimBtn).toBeEnabled({ timeout: 15_000 });\n   212→  await claimBtn.click();\n   213→\n   214→  // Wait for post-claim section to confirm claim completed\n   215→  await expect(\n   216→    page.locator(sel.postClaim),\n   217→  ).toBeVisible({ timeout: 15_000 });\n   218→}\n   219→\n   220→/**\n   221→ * Click \"Back to Lobby\" to return after claiming.\n   222→ */\n   223→export async function backToLobby(page: Page): Promise<void> {\n   224→  // \"Back to Lobby\" may appear in sidebar or post-claim area\n   225→  const btn = page.locator(\"button\", { hasText: \"Back to Lobby\" }).first();\n   226→  await expect(btn).toBeVisible();\n   227→  await btn.click();\n   228→  await page.waitForSelector(sel.lobby, {\n   229→    state: \"visible\",\n   230→    timeout: 10_000,\n   231→  });\n   232→}\n   233→\n   234→// ---------------------------------------------------------------------------\n   235→// Wait / assert primitives\n   236→// ---------------------------------------------------------------------------\n   237→\n   238→/**\n   239→ * Wait until the sidebar status text matches the expected phase label.\n   240→ * Phase labels: \"Waiting...\", \"Ready!\", \"Countdown...\", \"Flipping...\", \"Complete\"\n   241→ */\n   242→export async function waitForPhaseLabel(\n   243→  page: Page,\n   244→  label: string,\n   245→  timeout = 30_000,\n   246→): Promise<void> {\n   247→  await expect(page.locator(sel.sidebarStatus)).toHaveText(label, {\n   248→    timeout,\n   249→  });"}]},"parent_tool_use_id":"toolu_01Lbc3QFfwCsMEC17ctBnBWJ","session_id":"18302c5c-b9ec-4f75-9de3-1cbb537277bf","uuid":"8725cabc-9427-4b20-874c-6f6bb643d61c","timestamp":"2026-03-25T14:08:45.835Z"}
