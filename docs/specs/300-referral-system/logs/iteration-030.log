d.\n */\ntest.describe(\"Local E2E smoke\", () => {\n  test(\"app loads in real mode against local validator\", async ({\n    playerAPage,\n  }) => {\n    const consoleTracker = po.trackConsoleErrors(playerAPage);\n\n    await playerAPage.goto(\"/\", { waitUntil: \"networkidle\" });\n\n    // App renders the header\n    await expect(playerAPage.locator(\".header\")).toBeVisible({\n      timeout: 10_000,\n    });\n\n    // Wallet button is visible\n    await expect(playerAPage.locator(\".rng-wallet-button\")).toBeVisible();\n\n    // No critical console errors\n    consoleTracker.assertClean();\n  });\n});\n","numLines":31,"startLine":1,"totalLines":31}}}
