onst [items, setItems] = useState<ReferralEarningItem[]>([]);\n  const [page, setPage] = useState(1);\n  const [totalPages, setTotalPages] = useState(1);\n\n  const fetchPage = useCallback(\n    async (p: number) => {\n      if (!accessToken) return;\n      setLoading(true);\n      try {\n        const res = await getReferralEarnings(accessToken, p, PAGE_SIZE);\n        setItems(res.items);\n        setPage(res.pagination.page);\n        setTotalPages(res.pagination.totalPages);\n      } catch {\n        /* silently fail — keep current state */\n      } finally {\n        setLoading(false);\n      }\n    },\n    [accessToken],\n  );\n\n  useEffect(() => {\n    fetchPage(1);\n  }, [fetchPage]);\n\n  return (\n    <div className=\"ref-earnings\">\n      <h3 className=\"ref-earnings__title\">Earnings History</h3>\n\n      {loading && items.length === 0 ? (\n        <div className=\"ref-earnings__skeleton\">\n          {[0, 1, 2].map((i) => (\n            <div key={i} className=\"ref-earnings__skeleton-row\" />\n          ))}\n        </div>\n      ) : items.length === 0 ? (\n        <div className=\"ref-earnings__empty\">\n          No earnings yet. Share your link to start earning!\n        </div>\n      ) : (\n        <>\n          <div className=\"ref-earnings__table-wrap\">\n            <table className=\"ref-earnings__table\">\n              <thead>\n                <tr>\n                  <th>Date</th>\n                  <th>Game</th>\n                  <th>Referee</th>\n                  <th className=\"ref-earnings__col-right\">Wager</th>\n                  <th className=\"ref-earnings__col-right\">Your Earning</th>\n                </tr>\n              </thead>\n              <tbody>\n                {items.map((item) => (\n                  <tr key={`${item.roundId}-${item.refereeWallet}`}>\n                    <td className=\"ref-earnings__cell-date\">\n                      {formatDate(item.createdAt)}\n                    </td>\n                    <td>{formatGameType(item.gameType)}</td>\n                    <td className=\"ref-earnings__cell-wallet\">\n                      {truncateWallet(item.refereeWallet)}\n                    </td>\n                    <td className=\"ref-earnings__col-right ref-earnings__cell-mono\">\n                      {formatSol(item.wagerLamports)}\n                    </td>\n                    <td className=\"ref-earnings__col-right ref-earnings__cell-mono ref-earnings__cell-earning\">\n                      +{formatSol(item.earnedLamports)}\n                    </td>\n                  </tr>\n                ))}\n              </tbody>\n            </table>\n          </div>\n\n          {totalPages > 1 && (\n            <div className=\"ref-earnings__pagination\">\n              <button\n                type=\"button\"\n                className=\"ref-earnings__page-btn\"\n                disabled={page <= 1 || loading}\n                onClick={() => fetchPage(page - 1)}\n              >\n                &laquo; Prev\n              </button>\n              <span className=\"ref-earnings__page-info\">\n                {page} / {totalPages}\n              </span>\n              <button\n                type=\"button\"\n                className=\"ref-earnings__page-btn\"\n                disabled={page >= totalPages || loading}\n                onClick={() => fetchPage(page + 1)}\n              >\n                Next &raquo;\n              </button>\n            </div>\n          )}\n        </>\n      )}\n    </div>\n  );\n}\n","numLines":146,"startLine":1,"totalLines":146}}}
