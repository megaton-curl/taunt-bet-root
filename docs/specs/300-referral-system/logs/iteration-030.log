{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015aXwR2sLj8p8Va38CuL3hm","type":"tool_result","content":"     1→/**\n     2→ * Local lifecycle E2E test for Lord of the RNGs:\n     3→ * create round → join → countdown → backend settlement → verify.\n     4→ */\n     5→import { test, expect } from \"./fixtures\";\n     6→import * as po from \"./helpers/lord-page-objects\";\n     7→import { fundTestWallets, PLAYER_A } from \"./helpers/wallets\";\n     8→import { initializeLocalnet, ensurePlayerProfiles } from \"./helpers/localnet-setup\";\n     9→import {\n    10→  getLordProgram,\n    11→  getLordConfigPda,\n    12→  fetchLordRound,\n    13→  assertLordRoundClosed,\n    14→  assertLordTreasuryFee,\n    15→  snapshotBalance,\n    16→  type JackpotRoundAccount,\n    17→} from \"./helpers/on-chain\";\n    18→import { PublicKey } from \"@solana/web3.js\";\n    19→\n    20→async function withRetry<T>(\n    21→  operation: () => Promise<T>,\n    22→  isDone: (value: T) => boolean,\n    23→  attempts: number,\n    24→  delayMs: number,\n    25→): Promise<T> {\n    26→  let lastValue: T | undefined;\n    27→\n    28→  for (let attempt = 1; attempt <= attempts; attempt += 1) {\n    29→    lastValue = await operation();\n    30→    if (isDone(lastValue)) {\n    31→      return lastValue;\n    32→    }\n    33→    if (attempt < attempts) {\n    34→      await new Promise((resolve) => setTimeout(resolve, delayMs));\n    35→    }\n    36→  }\n    37→\n    38→  return lastValue as T;\n    39→}\n    40→\n    41→// Local settlement can take longer because the round waits for a future entropy slot.\n    42→test.setTimeout(330_000);\n    43→\n    44→// ── Suite setup ────────────────────────────────────────────────────────\n    45→\n    46→test.beforeAll(async () => {\n    47→  await fundTestWallets();\n    48→  await initializeLocalnet();\n    49→  await ensurePlayerProfiles();\n    50→});\n    51→\n    52→// ── Full lifecycle test ────────────────────────────────────────────────\n    53→\n    54→test(\"lord lifecycle: create → join → countdown → settle\", async ({\n    55→  playerAPage,\n    56→  playerBPage,\n    57→  connection,\n    58→}) => {\n    59→  // Track console errors in both contexts\n    60→  const consoleA = po.trackConsoleErrors(playerAPage);\n    61→  const consoleB = po.trackConsoleErrors(playerBPage);\n    62→\n    63→  // 1. Player A navigates to Lord of the RNGs and creates a round from the empty lobby\n    64→  await po.navigateToLord(playerAPage);\n    65→\n    66→  // Player A joins the round (creates it as first player)\n    67→  await po.joinRound(playerAPage);\n    68→\n    69→  const lordProgram = getLordProgram(connection);\n    70→  const allRounds = await lordProgram.account.jackpotRound.all();\n    71→  const activeRounds = allRounds.filter((r) => {\n    72→    const round = r.account as unknown as JackpotRoundAccount;\n    73→    return round.entries.some((entry) => entry.player.equals(PLAYER_A.publicKey));\n    74→  });\n    75→  expect(activeRounds.length).toBeGreaterThan(0);\n    76→\n    77→  const roundPda = activeRounds[0]!.publicKey;\n    78→  const round = activeRounds[0]!.account as unknown as JackpotRoundAccount;\n    79→  expect(round.entries.length).toBe(1);\n    80→  expect(round.entries[0]!.player.toBase58()).toBe(PLAYER_A.publicKey.toBase58());\n    81→\n    82→  // 2. Player B navigates and joins the newly visible open round\n    83→  await po.navigateToLord(playerBPage);\n    84→  await po.selectTier(playerBPage, 0);\n    85→\n    86→  // Player B joins the round (triggers countdown as 2nd unique player)\n    87→  await po.joinRound(playerBPage);\n    88→\n    89→  // Verify on-chain: 2 weighted entries, phase is Active (countdown started)\n    90→  const roundAfterJoin = await withRetry(\n    91→    () => fetchLordRound(connection, roundPda),\n    92→    (round) => round !== null && round.entries.length === 2,\n    93→    6,\n    94→    1000,\n    95→  );\n    96→  expect(roundAfterJoin).not.toBeNull();\n    97→  expect(roundAfterJoin!.entries.length).toBe(2);\n    98→  const phase = Object.keys(roundAfterJoin!.phase)[0];\n    99→  expect(phase).toBe(\"active\");\n   100→\n   101→  const [lordConfigPda] = getLordConfigPda();\n   102→  const lordConfig = await lordProgram.account.lordConfig.fetch(lordConfigPda);\n   103→  const treasury = (lordConfig as unknown as { treasury: PublicKey }).treasury;\n   104→  const treasuryBefore = await snapshotBalance(connection, treasury);\n   105→\n   106→  // The countdown is wall-time based and the backend settles after the entropy slot.\n   107→  await Promise.all([\n   108→    po.waitForSettlementUi(playerAPage, 240_000),\n   109→    po.waitForSettlementUi(playerBPage, 240_000),\n   110→  ]);\n   111→\n   112→  await assertLordRoundClosed(connection, roundPda);\n   113→\n   114→  await assertLordTreasuryFee(\n   115→    connection,\n   116→    treasury,\n   117→    treasuryBefore,\n   118→    roundAfterJoin!.totalAmountLamports.toNumber(),\n   119→  );\n   120→\n   121→  // ── Verify profile transactions ──────────────────────────────────\n   122→  const { assertProfileTransactions } = await import(\"../helpers/profile-assertions\");\n   123→  await assertProfileTransactions(playerAPage, {\n   124→    gameName: \"Jackpot\",\n   125→    gameRoute: \"/lord-of-rngs/\",\n   126→    minRows: 2,\n   127→  });\n   128→\n   129→  // No unhandled console errors in either context\n   130→  consoleA.assertClean();\n   131→  consoleB.assertClean();\n   132→});\n   133→"}]},"parent_tool_use_id":"toolu_01Lbc3QFfwCsMEC17ctBnBWJ","session_id":"18302c5c-b9ec-4f75-9de3-1cbb537277bf","uuid":"e33386a5-59d4-4f72-b2ca-d362807904a5","timestamp":"2026-03-25T14:08:46.263Z"}
