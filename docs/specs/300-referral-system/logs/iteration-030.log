{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CzUGYmrdS2L4m81XcKCVFn","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# localnet-bootstrap.sh — Start a fresh solana-test-validator with coinflip + platform + lordofrngs programs.\n     3→# Usage: ./scripts/localnet-bootstrap.sh\n     4→# Writes validator PID to .localnet.pid for teardown.\n     5→set -euo pipefail\n     6→\n     7→SCRIPT_DIR=\"$(cd \"$(dirname \"$0\")\" && pwd)\"\n     8→PLATFORM_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\n     9→SOLANA_DIR=\"$(cd \"$PLATFORM_DIR/../../solana\" && pwd)\"\n    10→\n    11→COINFLIP_SO=\"$SOLANA_DIR/target/deploy/coinflip.so\"\n    12→PLATFORM_SO=\"$SOLANA_DIR/target/deploy/platform.so\"\n    13→LORDOFRNGS_SO=\"$SOLANA_DIR/target/deploy/lordofrngs.so\"\n    14→COINFLIP_KEYPAIR=\"$SOLANA_DIR/target/deploy/coinflip-keypair.json\"\n    15→PLATFORM_KEYPAIR=\"$SOLANA_DIR/target/deploy/platform-keypair.json\"\n    16→LORDOFRNGS_KEYPAIR=\"$SOLANA_DIR/target/deploy/lordofrngs-keypair.json\"\n    17→\n    18→COINFLIP_ID=\"BdHFeqmkYe7znXV1Avk3zz496Pjo8QhEDN4MKPUTAWwx\"\n    19→PLATFORM_ID=\"85qwC1cDpSYkBBHUcN4nuZ119hCx4N94X38GjAHxnWjA\"\n    20→LORDOFRNGS_ID=\"B9Lufh9GvuucDxDRZBr3qPNe4cJaS5MQBQKZxgUT5qYa\"\n    21→\n    22→# Mock Orao VRF accounts (pre-loaded for deterministic local E2E tests)\n    23→ACCOUNTS_DIR=\"$SCRIPT_DIR/localnet-accounts\"\n    24→\n    25→RPC_URL=\"http://127.0.0.1:8899\"\n    26→PID_FILE=\"$PLATFORM_DIR/.localnet.pid\"\n    27→LEDGER_DIR=\"$PLATFORM_DIR/.localnet-ledger\"\n    28→LOG_FILE=\"$PLATFORM_DIR/.localnet-validator.log\"\n    29→SOLANA_TEST_VALIDATOR_BIN=\"${SOLANA_TEST_VALIDATOR_BIN:-$(command -v solana-test-validator || true)}\"\n    30→\n    31→MAX_WAIT=30  # seconds to wait for RPC readiness\n    32→\n    33→# ── Preflight checks ─────────────────────────────────────────────────\n    34→for f in \"$COINFLIP_SO\" \"$PLATFORM_SO\" \"$LORDOFRNGS_SO\" \"$COINFLIP_KEYPAIR\" \"$PLATFORM_KEYPAIR\" \"$LORDOFRNGS_KEYPAIR\"; do\n    35→  if [[ ! -f \"$f\" ]]; then\n    36→    echo \"ERROR: Missing $f — run 'anchor build' first.\" >&2\n    37→    exit 1\n    38→  fi\n    39→done\n    40→\n    41→if [[ -z \"$SOLANA_TEST_VALIDATOR_BIN\" || ! -x \"$SOLANA_TEST_VALIDATOR_BIN\" ]]; then\n    42→  echo \"ERROR: solana-test-validator not found on PATH.\" >&2\n    43→  exit 1\n    44→fi\n    45→\n    46→# Agave 3.x panics in some containerized environments unless io_uring is explicitly disabled.\n    47→# Default to the safe path here; callers can still override it if they have native support.\n    48→: \"${SOLANA_DISABLE_IO_URING:=1}\"\n    49→\n    50→# ── Kill any existing validator ───────────────────────────────────────\n    51→if [[ -f \"$PID_FILE\" ]]; then\n    52→  OLD_PID=$(cat \"$PID_FILE\")\n    53→  if kill -0 \"$OLD_PID\" 2>/dev/null; then\n    54→    echo \"Stopping existing validator (PID $OLD_PID)...\"\n    55→    kill \"$OLD_PID\" 2>/dev/null || true\n    56→    sleep 1\n    57→    kill -9 \"$OLD_PID\" 2>/dev/null || true\n    58→  fi\n    59→  rm -f \"$PID_FILE\"\n    60→fi\n    61→\n    62→# Also kill any stray validator on the same port\n    63→if lsof -ti :8899 &>/dev/null; then\n    64→  echo \"Killing process on port 8899...\"\n    65→  kill \"$(lsof -ti :8899)\" 2>/dev/null || true\n    66→  sleep 1\n    67→fi\n    68→\n    69→# ── Clean ledger for fresh state ──────────────────────────────────────\n    70→rm -rf \"$LEDGER_DIR\"\n    71→\n    72→# ── Start validator with programs preloaded at genesis ────────────────\n    73→echo \"Starting solana-test-validator...\"\n    74→SOLANA_DISABLE_IO_URING=\"$SOLANA_DISABLE_IO_URING\" \"$SOLANA_TEST_VALIDATOR_BIN\" \\\n    75→  --ledger \"$LEDGER_DIR\" \\\n    76→  --bpf-program \"$COINFLIP_ID\" \"$COINFLIP_SO\" \\\n    77→  --bpf-program \"$PLATFORM_ID\" \"$PLATFORM_SO\" \\\n    78→  --bpf-program \"$LORDOFRNGS_ID\" \"$LORDOFRNGS_SO\" \\\n    79→  --account 5ER1oENnV4srxYdAynUfRzWeQCPQaqMiAp4VqyMbSqnK \"$ACCOUNTS_DIR/orao-network-state.json\" \\\n    80→  --account S4ne8ejGPUwNMNsE8L7gtjbTaBLBfVGdWNH6VQrL58a \"$ACCOUNTS_DIR/orao-random-player-a.json\" \\\n    81→  --account Ecs89dz8NsNoSxyUtp54G2HPbmvJr8qZnxnWUqiLT92r \"$ACCOUNTS_DIR/orao-treasury.json\" \\\n    82→  --account 4grbA1oFgNUx6G7uPaEohYc5AyfU5NmZyvRbMgG52qq5 \"$ACCOUNTS_DIR/orao-random-lord-round0.json\" \\\n    83→  --reset \\\n    84→  --quiet \\\n    85→  > \"$LOG_FILE\" 2>&1 &\n    86→\n    87→VALIDATOR_PID=$!\n    88→echo \"$VALIDATOR_PID\" > \"$PID_FILE\"\n    89→echo \"Validator PID: $VALIDATOR_PID\"\n    90→\n    91→# ── Wait for RPC readiness ────────────────────────────────────────────\n    92→echo -n \"Waiting for RPC at $RPC_URL\"\n    93→ELAPSED=0\n    94→while (( ELAPSED < MAX_WAIT )); do\n    95→  if curl -s \"$RPC_URL\" \\\n    96→    -X POST \\\n    97→    -H \"Content-Type: application/json\" \\\n    98→    -d '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"getHealth\"}' 2>/dev/null \\\n    99→    | grep -q '\"result\"'; then\n   100→    echo \" ready (${ELAPSED}s)\"\n   101→    echo \"Localnet bootstrap complete.\"\n   102→    exit 0\n   103→  fi\n   104→\n   105→  # Check validator is still running\n   106→  if ! kill -0 \"$VALIDATOR_PID\" 2>/dev/null; then\n   107→    echo \"\"\n   108→    echo \"ERROR: Validator process exited unexpectedly. Log:\" >&2\n   109→    tail -20 \"$LOG_FILE\" >&2\n   110→    rm -f \"$PID_FILE\"\n   111→    exit 1\n   112→  fi\n   113→\n   114→  sleep 1\n   115→  ELAPSED=$(( ELAPSED + 1 ))\n   116→  echo -n \".\"\n   117→done\n   118→\n   119→echo \"\"\n   120→echo \"ERROR: Validator not ready after ${MAX_WAIT}s. Log:\" >&2\n   121→tail -20 \"$LOG_FILE\" >&2\n   122→kill \"$VALIDATOR_PID\" 2>/dev/null || true\n   123→rm -f \"$PID_FILE\"\n   124→exit 1\n   125→"}]},"parent_tool_use_id":"toolu_01Lbc3QFfwCsMEC17ctBnBWJ","session_id":"18302c5c-b9ec-4f75-9de3-1cbb537277bf","uuid":"cff48d0d-555b-42d1-a5db-53b46c366fbc","timestamp":"2026-03-25T14:09:08.144Z"}
