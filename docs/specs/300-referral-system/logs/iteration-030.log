{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011h2BBBFFedD5BesF3wgnDv","type":"tool_result","content":"     1→import { useCallback, useEffect, useState } from \"react\";\n     2→import { useSession } from \"../../context/SessionContext\";\n     3→import {\n     4→  getReferralCode,\n     5→  setReferralCode,\n     6→  type ReferralCodeResponse,\n     7→} from \"../../lib/referral-api\";\n     8→\n     9→const CODE_RE = /^[a-z0-9-]{3,16}$/;\n    10→\n    11→export function ReferralLinkCard() {\n    12→  const { accessToken } = useSession();\n    13→\n    14→  const [loading, setLoading] = useState(true);\n    15→  const [saving, setSaving] = useState(false);\n    16→  const [existing, setExisting] = useState<ReferralCodeResponse | null>(null);\n    17→  const [editing, setEditing] = useState(false);\n    18→  const [input, setInput] = useState(\"\");\n    19→  const [error, setError] = useState(\"\");\n    20→  const [copied, setCopied] = useState(false);\n    21→\n    22→  // Fetch existing code on mount\n    23→  useEffect(() => {\n    24→    if (!accessToken) return;\n    25→    let cancelled = false;\n    26→    getReferralCode(accessToken)\n    27→      .then((res) => {\n    28→        if (!cancelled) setExisting(res);\n    29→      })\n    30→      .catch(() => {\n    31→        /* 404 = no code yet, ignore */\n    32→      })\n    33→      .finally(() => {\n    34→        if (!cancelled) setLoading(false);\n    35→      });\n    36→    return () => {\n    37→      cancelled = true;\n    38→    };\n    39→  }, [accessToken]);\n    40→\n    41→  const validate = (code: string): string => {\n    42→    if (code.length < 3) return \"Code must be at least 3 characters\";\n    43→    if (code.length > 16) return \"Code must be at most 16 characters\";\n    44→    if (!CODE_RE.test(code)) return \"Only lowercase letters, numbers, and hyphens\";\n    45→    return \"\";\n    46→  };\n    47→\n    48→  const handleInputChange = (val: string) => {\n    49→    const lower = val.toLowerCase();\n    50→    setInput(lower);\n    51→    setError(lower ? validate(lower) : \"\");\n    52→  };\n    53→\n    54→  const handleSubmit = useCallback(async () => {\n    55→    if (!accessToken) return;\n    56→    const err = validate(input);\n    57→    if (err) {\n    58→      setError(err);\n    59→      return;\n    60→    }\n    61→    setSaving(true);\n    62→    setError(\"\");\n    63→    try {\n    64→      const res = await setReferralCode(accessToken, input);\n    65→      setExisting(res);\n    66→      setEditing(false);\n    67→      setInput(\"\");\n    68→    } catch (e) {\n    69→      setError(e instanceof Error ? e.message : \"Failed to set code\");\n    70→    } finally {\n    71→      setSaving(false);\n    72→    }\n    73→  }, [accessToken, input]);\n    74→\n    75→  const handleCopy = useCallback(() => {\n    76→    if (!existing) return;\n    77→    navigator.clipboard.writeText(existing.url).then(() => {\n    78→      setCopied(true);\n    79→      setTimeout(() => setCopied(false), 2000);\n    80→    });\n    81→  }, [existing]);\n    82→\n    83→  if (loading) {\n    84→    return (\n    85→      <div className=\"ref-link-card\">\n    86→        <h3 className=\"ref-link-card__title\">Your Referral Link</h3>\n    87→        <div className=\"ref-link-card__skeleton\" />\n    88→      </div>\n    89→    );\n    90→  }\n    91→\n    92→  // No code yet, or user is editing/changing\n    93→  if (!existing || editing) {\n    94→    return (\n    95→      <div className=\"ref-link-card\">\n    96→        <h3 className=\"ref-link-card__title\">\n    97→          {existing ? \"Change Referral Code\" : \"Your Referral Link\"}\n    98→        </h3>\n    99→        {!existing && (\n   100→          <p className=\"ref-link-card__desc\">\n   101→            Choose a custom code to create your referral link.\n   102→          </p>\n   103→        )}\n   104→        <div className=\"ref-link-card__form\">\n   105→          <div className=\"ref-link-card__input-row\">\n   106→            <span className=\"ref-link-card__prefix\">taunt.bet/r/</span>\n   107→            <input\n   108→              type=\"text\"\n   109→              className=\"ref-link-card__input\"\n   110→              placeholder=\"my-code\"\n   111→              value={input}\n   112→              onChange={(e) => handleInputChange(e.target.value)}\n   113→              onKeyDown={(e) => {\n   114→                if (e.key === \"Enter\" && !saving) handleSubmit();\n   115→              }}\n   116→              maxLength={16}\n   117→              disabled={saving}\n   118→              autoFocus\n   119→            />\n   120→          </div>\n   121→          {error && <p className=\"ref-link-card__error\">{error}</p>}\n   122→          <div className=\"ref-link-card__actions\">\n   123→            <button\n   124→              type=\"button\"\n   125→              className=\"ref-link-card__btn ref-link-card__btn--primary\"\n   126→              onClick={handleSubmit}\n   127→              disabled={saving || !input || !!error}\n   128→            >\n   129→              {saving ? \"Saving...\" : existing ? \"Update Code\" : \"Set Code\"}\n   130→            </button>\n   131→            {existing && (\n   132→              <button\n   133→                type=\"button\"\n   134→                className=\"ref-link-card__btn ref-link-card__btn--secondary\"\n   135→                onClick={() => {\n   136→                  setEditing(false);\n   137→                  setInput(\"\");\n   138→                  setError(\"\");\n   139→                }}\n   140→              >\n   141→                Cancel\n   142→              </button>\n   143→            )}\n   144→          </div>\n   145→        </div>\n   146→      </div>\n   147→    );\n   148→  }\n   149→\n   150→  // Code exists — show display mode\n   151→  return (\n   152→    <div className=\"ref-link-card\">\n   153→      <h3 className=\"ref-link-card__title\">Your Referral Link</h3>\n   154→      <div className=\"ref-link-card__display\">\n   155→        <div className=\"ref-link-card__url-row\">\n   156→          <input\n   157→            type=\"text\"\n   158→            className=\"ref-link-card__url\"\n   159→            value={existing.url}\n   160→            readOnly\n   161→          />\n   162→          <button\n   163→            type=\"button\"\n   164→            className=\"ref-link-card__btn ref-link-card__btn--copy\"\n   165→            onClick={handleCopy}\n   166→          >\n   167→            {copied ? \"Copied!\" : \"Copy Link\"}\n   168→          </button>\n   169→        </div>\n   170→        <button\n   171→          type=\"button\"\n   172→          className=\"ref-link-card__change\"\n   173→          onClick={() => {\n   174→            setEditing(true);\n   175→            setInput(existing.code);\n   176→          }}\n   177→        >\n   178→          Change code\n   179→        </button>\n   180→      </div>\n   181→    </div>\n   182→  );\n   183→}\n   184→"}]},"parent_tool_use_id":"toolu_01T4WKVm7wdB4nLSnnbkfAez","session_id":"18302c5c-b9ec-4f75-9de3-1cbb537277bf","uuid":"b5163427-9d23-41ff-af08-fabd2fea88f2","timestamp":"2026-03-25T14:08:14.413Z"}
