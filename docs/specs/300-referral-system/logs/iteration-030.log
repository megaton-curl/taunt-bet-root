{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vev49Ayi9u2tM2YVAQECj2","type":"tool_result","content":"     1→/* eslint-disable no-console */\n     2→/**\n     3→ * Devnet lifecycle E2E test: create → join → backend auto-settle → verify.\n     4→ *\n     5→ * Uses two isolated browser contexts (Player A and Player B) with deterministic\n     6→ * keypairs. The frontend talks to a live fairness backend for create + round\n     7→ * verification, while the backend settles against deployed devnet programs.\n     8→ */\n     9→import { test, expect } from \"./fixtures\";\n    10→import type { ConsoleMessage, Page } from \"@playwright/test\";\n    11→import * as po from \"../local/helpers/page-objects\";\n    12→import { PLAYER_A, PLAYER_B } from \"./helpers/wallets\";\n    13→import {\n    14→  validateDevnetEnv,\n    15→  verifyFairnessBackend,\n    16→  type DevnetConfig,\n    17→} from \"./helpers/env\";\n    18→import { withRetry } from \"./helpers/retry\";\n    19→import { ensureCleanState } from \"./helpers/on-chain-cleanup\";\n    20→import {\n    21→  assertMatchCreated,\n    22→  assertMatchClosed,\n    23→  assertTreasuryFee,\n    24→  getTreasuryAddress,\n    25→  snapshotBalance,\n    26→} from \"../local/helpers/on-chain\";\n    27→import { Connection, LAMPORTS_PER_SOL, type PublicKey } from \"@solana/web3.js\";\n    28→\n    29→const MIN_BALANCE_SOL = 0.1;\n    30→const SIDE_HEADS = 0;\n    31→const ENTRY_AMOUNT = 5_000_000;\n    32→const SETTLEMENT_TIMEOUT_MS = 120_000;\n    33→\n    34→const DEVNET_NOISE_PATTERNS = [\n    35→  \"favicon.ico\",\n    36→  \"downloadable font\",\n    37→  \"third-party cookie\",\n    38→  \"429\",\n    39→  \"Too Many Requests\",\n    40→  \"WebSocket\",\n    41→  \"ECONNRESET\",\n    42→  \"socket hang up\",\n    43→  \"FetchError\",\n    44→  \"NetworkError\",\n    45→  \"net::ERR_\",\n    46→  \"/auth/\",\n    47→];\n    48→\n    49→/** Capture [settlement-event] console lines from a page. */\n    50→function captureSettlementEvents(page: Page): string[] {\n    51→  const lines: string[] = [];\n    52→  page.on(\"console\", (msg) => {\n    53→    if (msg.text().includes(\"[settlement-event]\")) {\n    54→      lines.push(msg.text());\n    55→    }\n    56→  });\n    57→  return lines;\n    58→}\n    59→\n    60→interface BackendRoundResponse {\n    61→  pda: string;\n    62→  phase: \"created\" | \"locked\" | \"settling\" | \"settled\" | \"expired\";\n    63→  commitment: string;\n    64→  secret?: string;\n    65→  resultHash?: string | null;\n    66→  resultSide?: number | null;\n    67→  winner?: string | null;\n    68→  settleTx?: string | null;\n    69→}\n    70→\n    71→function filterDevnetNoise(errors: string[]): string[] {\n    72→  return errors.filter(\n    73→    (e) => !DEVNET_NOISE_PATTERNS.some((pattern) => e.includes(pattern)),\n    74→  );\n    75→}\n    76→\n    77→async function ensureFunded(\n    78→  connection: Connection,\n    79→  pubkey: PublicKey,\n    80→  label: string,"}]},"parent_tool_use_id":"toolu_01Lbc3QFfwCsMEC17ctBnBWJ","session_id":"18302c5c-b9ec-4f75-9de3-1cbb537277bf","uuid":"99734194-2074-44c8-8531-5b7232feb8c9","timestamp":"2026-03-25T14:09:08.225Z"}
