{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XnUTQunHmKXu1ojH2UZjuq","type":"tool_result","content":"     1→/**\n     2→ * On-chain assertion helpers for local E2E tests.\n     3→ *\n     4→ * Provides RPC-based helpers to query and assert match PDA state,\n     5→ * treasury fee deltas, and player profile stat updates.\n     6→ */\n     7→import { Connection, PublicKey } from \"@solana/web3.js\";\n     8→import { Program, AnchorProvider, type Idl } from \"@coral-xyz/anchor\";\n     9→import {\n    10→  CoinflipIDL,\n    11→  LordofrngsIDL,\n    12→  type Coinflip,\n    13→  type Lordofrngs,\n    14→} from \"@rng-utopia/anchor-client\";\n    15→\n    16→// ============ Program IDs ============\n    17→\n    18→/** Coinflip program address (from IDL). */\n    19→export const COINFLIP_PROGRAM_ID = new PublicKey(CoinflipIDL.address);\n    20→\n    21→/** Lord of RNGs program address (from IDL). */\n    22→export const LORDOFRNGS_PROGRAM_ID = new PublicKey(LordofrngsIDL.address);\n    23→\n    24→/** Platform fee: 500 basis points. Read from PlatformConfig on-chain. */\n    25→export const FEE_BPS = 500;\n    26→\n    27→/** Coinflip phase constants matching the on-chain program. */\n    28→export const COINFLIP_PHASE_WAITING = 0;\n    29→export const COINFLIP_PHASE_LOCKED = 1;\n    30→export const COINFLIP_PHASE_SETTLED = 2;\n    31→export const COINFLIP_PHASE_REFUNDED = 3;\n    32→\n    33→// ============ PDA Derivation ============\n    34→\n    35→/** Derive the match PDA for a creator + matchId. Seeds: [\"match\", creator, matchId]. */\n    36→export function getMatchPda(creator: PublicKey, matchId: Buffer | Uint8Array): [PublicKey, number] {\n    37→  return PublicKey.findProgramAddressSync(\n    38→    [Buffer.from(\"match\"), creator.toBuffer(), Buffer.from(matchId)],\n    39→    COINFLIP_PROGRAM_ID,\n    40→  );\n    41→}\n    42→\n    43→/** Derive the coinflip config PDA. Seeds: [\"coinflip_config\"]. */\n    44→export function getConfigPda(): [PublicKey, number] {\n    45→  return PublicKey.findProgramAddressSync(\n    46→    [Buffer.from(\"coinflip_config\")],\n    47→    COINFLIP_PROGRAM_ID,\n    48→  );\n    49→}\n    50→\n    51→// ============ Program Instances ============\n    52→\n    53→/**\n    54→ * Create a read-only Coinflip program instance.\n    55→ *\n    56→ * @param connection - Solana RPC connection\n    57→ */\n    58→export function getCoinflipProgram(connection: Connection): Program<Coinflip> {\n    59→  const provider = new AnchorProvider(\n    60→    connection,\n    61→    {} as AnchorProvider[\"wallet\"],\n    62→    { commitment: \"confirmed\" },\n    63→  );\n    64→  return new Program(CoinflipIDL as Idl as Coinflip, provider);\n    65→}\n    66→\n    67→// ============ Account Types ============\n    68→\n    69→/** Deserialized match account shape. */\n    70→export interface MatchAccount {\n    71→  creator: PublicKey;\n    72→  opponent: PublicKey;\n    73→  server: PublicKey;\n    74→  entryAmount: { toNumber(): number };\n    75→  creatorSide: number;\n    76→  phase: number;\n    77→  commitment: Uint8Array;\n    78→  algorithmVer: number;\n    79→  targetSlot: { toNumber(): number };\n    80→  resolveDeadline: { toNumber(): number };\n    81→  resultHash: Uint8Array;\n    82→  result: number;\n    83→  winner: PublicKey;\n    84→  createdAt: { toNumber(): number };\n    85→  matchId: number[];\n    86→  bump: number;\n    87→}\n    88→\n    89→function coinflipPhaseName(phase: number): \"waiting\" | \"locked\" | \"settled\" | \"refunded\" | \"unknown\" {\n    90→  switch (phase) {\n    91→    case COINFLIP_PHASE_WAITING:\n    92→      return \"waiting\";\n    93→    case COINFLIP_PHASE_LOCKED:\n    94→      return \"locked\";\n    95→    case COINFLIP_PHASE_SETTLED:\n    96→      return \"settled\";\n    97→    case COINFLIP_PHASE_REFUNDED:\n    98→      return \"refunded\";\n    99→    default:\n   100→      return \"unknown\";"}]},"parent_tool_use_id":"toolu_01Lbc3QFfwCsMEC17ctBnBWJ","session_id":"18302c5c-b9ec-4f75-9de3-1cbb537277bf","uuid":"fd3b77c4-bd23-4b5f-aeef-e2be8bdea958","timestamp":"2026-03-25T14:08:42.700Z"}
