{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SYCyKQr9sKDDN8YqWMPPPq","type":"tool_result","content":"     1→import { useEffect, useState } from \"react\";\n     2→import { useSession } from \"../../context/SessionContext\";\n     3→import { getReferralStats, type ReferralStatsResponse } from \"../../lib/referral-api\";\n     4→\n     5→const LAMPORTS_PER_SOL = 1_000_000_000;\n     6→\n     7→function formatSol(lamportsStr: string): string {\n     8→  const sol = Number(lamportsStr) / LAMPORTS_PER_SOL;\n     9→  if (sol >= 1_000_000) return `${(sol / 1_000_000).toFixed(1)}M`;\n    10→  if (sol >= 1000) return `${(sol / 1000).toFixed(1)}k`;\n    11→  if (sol >= 1) return sol.toFixed(2);\n    12→  if (sol >= 0.01) return sol.toFixed(3);\n    13→  return sol.toFixed(4);\n    14→}\n    15→\n    16→export function ReferralStatsCard() {\n    17→  const { accessToken } = useSession();\n    18→  const [loading, setLoading] = useState(true);\n    19→  const [stats, setStats] = useState<ReferralStatsResponse | null>(null);\n    20→\n    21→  useEffect(() => {\n    22→    if (!accessToken) return;\n    23→    let cancelled = false;\n    24→    getReferralStats(accessToken)\n    25→      .then((res) => {\n    26→        if (!cancelled) setStats(res);\n    27→      })\n    28→      .catch(() => {\n    29→        /* stats unavailable — show zeros */\n    30→      })\n    31→      .finally(() => {\n    32→        if (!cancelled) setLoading(false);\n    33→      });\n    34→    return () => {\n    35→      cancelled = true;\n    36→    };\n    37→  }, [accessToken]);\n    38→\n    39→  const items = [\n    40→    { label: \"Referred Players\", value: stats ? String(stats.referredCount) : \"0\" },\n    41→    { label: \"Active (7d)\", value: stats ? String(stats.activeCount) : \"0\" },\n    42→    { label: \"Total Volume\", value: stats ? formatSol(stats.totalVolumeLamports) + \" SOL\" : \"0 SOL\" },\n    43→    { label: \"Total Earned\", value: stats ? formatSol(stats.totalEarnedLamports) + \" SOL\" : \"0 SOL\" },\n    44→  ];\n    45→\n    46→  return (\n    47→    <div className=\"ref-stats-card\">\n    48→      <h3 className=\"ref-stats-card__title\">Stats</h3>\n    49→      <div className=\"ref-stats-card__grid\">\n    50→        {items.map((item) => (\n    51→          <div key={item.label} className=\"ref-stats-card__stat\">\n    52→            {loading ? (\n    53→              <div className=\"ref-stats-card__skeleton\" />\n    54→            ) : (\n    55→              <div className=\"ref-stats-card__value\">{item.value}</div>\n    56→            )}\n    57→            <div className=\"ref-stats-card__label\">{item.label}</div>\n    58→          </div>\n    59→        ))}\n    60→      </div>\n    61→    </div>\n    62→  );\n    63→}\n    64→"}]},"parent_tool_use_id":"toolu_01T4WKVm7wdB4nLSnnbkfAez","session_id":"18302c5c-b9ec-4f75-9de3-1cbb537277bf","uuid":"ad3f6303-c341-4b0d-b2b7-49eb8566c5c9","timestamp":"2026-03-25T14:08:14.548Z"}
