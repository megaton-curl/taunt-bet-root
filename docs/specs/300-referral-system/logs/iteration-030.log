    44→\n    45→    await po.navigateToCoinflip(playerAPage);\n    46→    await po.createMatch(playerAPage, \"iron\", \"heads\");\n    47→\n    48→    await po.navigateToCoinflip(playerBPage);\n    49→    await po.waitForLobbyMatch(playerBPage);\n    50→    await po.joinMatch(playerBPage);\n    51→\n    52→    // Wait for backend settlement\n    53→    await Promise.all([\n    54→      po.waitForResult(playerAPage, 30_000),\n    55→      po.waitForResult(playerBPage, 30_000),\n    56→    ]);\n    57→\n    58→    // ── Step 2: Navigate Player A to profile page ──\n    59→    // After page.goto(), the SPA reloads. SessionContext will restore\n    60→    // the session from the refresh token in localStorage (network call\n    61→    // to /auth/refresh or /auth/verify). We wait for that to complete\n    62→    // before clicking the Transactions tab, so the token is available\n    63→    // when useTransactions mounts.\n    64→\n    65→    const authDone = playerAPage.waitForResponse(\n    66→      (r) => r.url().includes(\"/auth/\") && r.status() < 400,\n    67→      { timeout: 15_000 },\n    68→    );\n    69→    await playerAPage.goto(\"/profile\");\n    70→    await authDone;\n    71→\n    72→    // Wait for profile header to confirm page rendered\n    73→    await expect(\n    74→      playerAPage.locator(profileSel.header),\n    75→    ).toBeVisible({ timeout: 10_000 });\n    76→\n    77→    // ── Step 3: Click Transactions tab ──\n    78→    await playerAPage.click(profileSel.tab(\"Transactions\"));\n    79→\n    80→    // ── Step 4: Wait for transaction table to appear ──\n    81→    // (not loading skeleton, not empty state)\n    82→    const table = playerAPage.locator(profileSel.txTable);\n    83→    await expect(table).toBeVisible({ timeout: 10_000 });\n    84→\n    85→    // ── Step 5: Verify Player A has at least 1 row (deposit, possibly payout) ──\n    86→    const rows = playerAPage.locator(profileSel.txRows);\n    87→    const rowCount = await rows.count();\n    88→    expect(rowCount).toBeGreaterThanOrEqual(1);\n    89→    expect(rowCount).toBeLessThanOrEqual(2);\n    90→\n    91→    // ── Step 6: Verify game name ──\n    92→    // API returns game = \"coinflip\", GAME_NAMES maps it to \"Flip You\"\n    93→    const firstLink = playerAPage.locator(profileSel.matchLink).first();\n    94→    await expect(firstLink).toContainText(\"Flip You\");\n    95→\n    96→    // ── Step 7: Verify transaction types ──\n    97→    const tableText = await table.textContent();\n    98→    expect(tableText).toContain(\"DEPOSIT\");\n    99→    // Player A may also have a PAYOUT row (if they won)\n   100→    if (rowCount === 2) {\n   101→      expect(tableText).toContain(\"PAYOUT\");\n   102→    }\n   103→\n   104→    // ── Step 8: Verify amounts display in SOL ──\n   105→    expect(tableText).toContain(\"SOL\");\n   106→\n   107→    // ── Step 9: Verify match deep-links ──\n   108→    // Each transaction row should link to /coinflip/:matchId\n   109→    const links = playerAPage.locator(profileSel.matchLink);\n   110→    const linkCount = await links.count();\n   111→    for (let i = 0; i < linkCount; i++) {\n   112→      const href = await links.nth(i).getAttribute(\"href\");\n   113→      expect(href).toMatch(/^\\/coinflip\\/.+/);\n   114→    }\n   115→\n   116→    // No unexpected console errors\n   117→    consoleA.assertClean();\n   118→  });\n   119→});\n   120→"}]},"parent_tool_use_id":null,"session_id":"18302c5c-b9ec-4f75-9de3-1cbb537277bf","uuid":"2036bceb-451a-437f-8869-6df65498c83f","timestamp":"2026-03-25T14:10:52.630Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/20-profile-transactions.spec.ts","content":"/**\n * Local E2E test: profile transactions after coinflip settlement.\n *\n * Plays a coinflip match to completion, then navigates to the profile page\n * and verifies that transaction rows (deposit + payout) appear in the\n * Transactions tab.\n *\n * Prerequisites (handled by run-e2e-local.sh):\n * - solana-test-validator running with deployed programs\n * - Backend running with postgres + migrations applied (including transactions)\n * - Test wallets funded\n */\nimport { test, expect } from \"./fixtures\";\nimport * as po from \"./helpers/page-objects\";\nimport { fundTestWallets } from \"./helpers/wallets\";\nimport { initializeLocalnet } from \"./helpers/localnet-setup\";\n\n// Selectors for profile page elements\nconst profileSel = {\n  header: \".profile-page__header\",\n  tab: (label: string) => `button:has-text(\"${label}\")`,\n  txTable: \".profile-transactions__table\",\n  txRows: \".profile-transactions__table tbody tr\",\n  txEmpty: \".profile-transactions__empty\",\n  txSkeleton: \".profile-transactions__skeleton\",\n  matchLink: \".profile-transactions__match-link\",\n};\n\ntest.describe(\"Profile transactions\", () => {\n  test.describe.configure({ mode: \"serial\" });\n\n  test.beforeAll(async () => {\n    await fundTestWallets();\n    await initializeLocalnet();\n  });\n\n  test(\"shows transaction history after coinflip settlement\", async ({\n    playerAPage,\n    playerBPage,\n  }) => {\n    const consoleA = po.trackConsoleErrors(playerAPage);\n\n    // ── Step 1: Play a coinflip match to generate transaction data ──\n\n    await po.navigateToCoinflip(playerAPage);\n    await po.createMatch(playerAPage, \"iron\", \"heads\");\n\n    await po.navigateToCoinflip(playerBPage);\n    await po.waitForLobbyMatch(playerBPage);\n    await po.joinMatch(playerBPage);\n\n    // Wait for backend settlement\n    await Promise.all([\n      po.waitForResult(playerAPage, 30_000),\n      po.waitForResult(playerBPage, 30_000),\n    ]);\n\n    // ── Step 2: Navigate Player A to profile page ──\n    // After page.goto(), the SPA reloads. SessionContext will restore\n    // the session from the refresh token in localStorage (network call\n    // to /auth/refresh or /auth/verify). We wait for that to complete\n    // before clicking the Transactions tab, so the token is available\n    // when useTransactions mounts.\n\n    const authDone = playerAPage.waitForResponse(\n      (r) => r.url().includes(\"/auth/\") && r.status() < 400,\n      { timeout: 15_000 },\n    );\n    await playerAPage.goto(\"/profile\");\n    await authDone;\n\n    // Wait for profile header to confirm page rendered\n    await expect(\n      playerAPage.locator(profileSel.header),\n    ).toBeVisible({ timeout: 10_000 });\n\n    // ── Step 3: Click Transactions tab ──\n    await playerAPage.click(profileSel.tab(\"Transactions\"));\n\n    // ── Step 4: Wait for transaction table to appear ──\n    // (not loading skeleton, not empty state)\n    const table = playerAPage.locator(profileSel.txTable);\n    await expect(table).toBeVisible({ timeout: 10_000 });\n\n    // ── Step 5: Verify Player A has at least 1 row (deposit, possibly payout) ──\n    const rows = playerAPage.locator(profileSel.txRows);\n    const rowCount = await rows.count();\n    expect(rowCount).toBeGreaterThanOrEqual(1);\n    expect(rowCount).toBeLessThanOrEqual(2);\n\n    // ── Step 6: Verify game name ──\n    // API returns game = \"coinflip\", GAME_NAMES maps it to \"Flip You\"\n    const firstLink = playerAPage.locator(profileSel.matchLink).first();\n    await expect(firstLink).toContainText(\"Flip You\");\n\n    // ── Step 7: Verify transaction types ──\n    const tableText = await table.textContent();\n    expect(tableText).toContain(\"DEPOSIT\");\n    // Player A may also have a PAYOUT row (if they won)\n    if (rowCount === 2) {\n      expect(tableText).toContain(\"PAYOUT\");\n    }\n\n    // ── Step 8: Verify amounts display in SOL ──\n    expect(tableText).toContain(\"SOL\");\n\n    // ── Step 9: Verify match deep-links ──\n    // Each transaction row should link to /coinflip/:matchId\n    const links = playerAPage.locator(profileSel.matchLink);\n    const linkCount = await links.count();\n    for (let i = 0; i < linkCount; i++) {\n      const href = await links.nth(i).getAttribute(\"href\");\n      expect(href).toMatch(/^\\/coinflip\\/.+/);\n    }\n\n    // No unexpected console errors\n    consoleA.assertClean();\n  });\n});\n","numLines":120,"startLine":1,"totalLines":120}}}
