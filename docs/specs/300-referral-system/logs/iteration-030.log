{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_014mfrwXqoLrvgnv8pfkDFYV","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01KzdaWHxWmBmnsMEduxEjXX","name":"Write","input":{"file_path":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/30-referral.spec.ts","content":"/**\n * Local E2E test: referral system flows.\n *\n * Tests the primary referral user flows:\n * 1. Player A sets a custom referral code on the /referrals page\n * 2. Player B visits /r/:code → code captured in localStorage → auto-applied on auth\n * 3. Player B's profile settings shows \"Referred by\" status\n * 4. Player A's referral stats update (1 referred player)\n *\n * Prerequisites (handled by run-e2e-local.sh):\n * - solana-test-validator running with deployed programs\n * - Backend running with postgres + migrations applied (including 011_referral)\n * - Test wallets funded\n */\nimport { test, expect } from \"./fixtures\";\nimport * as po from \"./helpers/page-objects\";\nimport { fundTestWallets } from \"./helpers/wallets\";\nimport { initializeLocalnet } from \"./helpers/localnet-setup\";\n\ntest.describe(\"Referral system\", () => {\n  test.describe.configure({ mode: \"serial\" });\n\n  test.beforeAll(async () => {\n    await fundTestWallets();\n    await initializeLocalnet();\n  });\n\n  test(\"set referral code, apply via link, verify stats and profile\", async ({\n    playerAPage,\n    playerBPage,\n  }) => {\n    const consoleA = po.trackConsoleErrors(playerAPage);\n    const consoleB = po.trackConsoleErrors(playerBPage);\n\n    // ── Step 1: Player A navigates to /referrals and sets a referral code ──\n\n    const authA = playerAPage.waitForResponse(\n      (r) => r.url().includes(\"/auth/\") && r.status() < 400,\n      { timeout: 15_000 },\n    );\n    await playerAPage.goto(\"/referrals\", { waitUntil: \"domcontentloaded\" });\n    await authA;\n\n    // Authenticated state renders the page title\n    await expect(playerAPage.locator(\".referral-page__title\")).toBeVisible({\n      timeout: 10_000,\n    });\n\n    // Wait for link card to finish loading → code input form appears\n    await expect(playerAPage.locator(\".ref-link-card__input\")).toBeVisible({\n      timeout: 10_000,\n    });\n\n    // Enter a custom referral code and submit\n    await playerAPage.fill(\".ref-link-card__input\", \"e2e-ref-test\");\n    await playerAPage.click(\".ref-link-card__btn--primary\");\n\n    // Code saved → URL display mode appears\n    await expect(playerAPage.locator(\".ref-link-card__url\")).toBeVisible({\n      timeout: 10_000,\n    });\n    const referralUrl = await playerAPage\n      .locator(\".ref-link-card__url\")\n      .inputValue();\n    expect(referralUrl).toContain(\"e2e-ref-test\");\n\n    // Verify all page sections rendered\n    await expect(playerAPage.locator(\".ref-stats-card\")).toBeVisible();\n    await expect(playerAPage.locator(\".ref-claim-card\")).toBeVisible();\n    await expect(playerAPage.locator(\".ref-earnings\")).toBeVisible();\n\n    // Earnings should be empty\n    await expect(playerAPage.locator(\".ref-earnings__empty\")).toBeVisible();\n\n    // Claim button shows no pending earnings\n    await expect(playerAPage.locator(\".ref-claim-card__btn\")).toContainText(\n      \"No pending earnings\",\n    );\n\n    // ── Step 2: Player B visits referral link → auto-applied ──\n\n    // Set up listener for the auto-apply API call BEFORE navigation\n    const applyPromise = playerBPage.waitForResponse(\n      (r) => r.url().includes(\"/referral/apply\"),\n      { timeout: 25_000 },\n    );\n\n    // Navigate to referral link — ReferralCapture stores code in\n    // localStorage and redirects to /. Auth triggers useReferralApply.\n    await playerBPage.goto(\"/r/e2e-ref-test\");\n    await po.waitForWalletConnected(playerBPage);\n\n    // Wait for the auto-apply to complete\n    const applyRes = await applyPromise;\n    expect(applyRes.status()).toBe(200);\n\n    // ── Step 3: Player B's profile shows \"Referred by\" ──\n\n    const authB = playerBPage.waitForResponse(\n      (r) => r.url().includes(\"/auth/\") && r.status() < 400,\n      { timeout: 15_000 },\n    );\n    await playerBPage.goto(\"/profile\", { waitUntil: \"domcontentloaded\" });\n    await authB;\n\n    await expect(\n      playerBPage.locator(\".profile-page__header\"),\n    ).toBeVisible({ timeout: 10_000 });\n\n    // Click Settings tab\n    await playerBPage.click('button:has-text(\"Settings\")');\n\n    // Referral section shows linked state\n    await expect(\n      playerBPage.locator(\".profile-settings__referral-linked\"),\n    ).toBeVisible({ timeout: 10_000 });\n\n    const linkedText = await playerBPage\n      .locator(\".profile-settings__referral-linked\")\n      .textContent();\n    expect(linkedText).toContain(\"Referred by:\");\n\n    // ── Step 4: Player A refreshes /referrals → stats show 1 referred ──\n\n    const authA2 = playerAPage.waitForResponse(\n      (r) => r.url().includes(\"/auth/\") && r.status() < 400,\n      { timeout: 15_000 },\n    );\n    await playerAPage.goto(\"/referrals\", { waitUntil: \"domcontentloaded\" });\n    await authA2;\n\n    await expect(playerAPage.locator(\".referral-page__title\")).toBeVisible({\n      timeout: 10_000,\n    });\n\n    // Wait for stats values to load\n    await expect(\n      playerAPage.locator(\".ref-stats-card__value\").first(),\n    ).toBeVisible({ timeout: 10_000 });\n\n    // First stat is \"Referred Players\" → should be \"1\"\n    const referredCount = await playerAPage\n      .locator(\".ref-stats-card__value\")\n      .first()\n      .textContent();\n    expect(referredCount?.trim()).toBe(\"1\");\n\n    // ── Step 5: Sidebar nav has Referrals link ──\n\n    await expect(\n      playerAPage.locator('.nv-item a[href=\"/referrals\"]'),\n    ).toBeVisible();\n\n    // No unexpected console errors\n    consoleA.assertClean();\n    consoleB.assertClean();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":9303,"cache_read_input_tokens":78641,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":9303},"output_tokens":53,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"18302c5c-b9ec-4f75-9de3-1cbb537277bf","uuid":"cf8a5214-adcf-4921-87f8-33b7cbfa6cab"}
