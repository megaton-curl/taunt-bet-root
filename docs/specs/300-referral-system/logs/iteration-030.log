{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Rxg8SiRXdoKfS18hDb3Kvi","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# run-e2e-local.sh — Single-entrypoint for local E2E tests.\n     3→# Runs: validator bootstrap → backend bootstrap → Playwright tests → teardown.\n     4→set -euo pipefail\n     5→\n     6→SCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n     7→APP_DIR=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\n     8→MONOREPO_DIR=\"$(cd \"$APP_DIR/../..\" && pwd)\"\n     9→BACKEND_DIR=\"$MONOREPO_DIR/services/backend\"\n    10→BACKEND_KEYPAIR_FILE=\"$APP_DIR/.local-backend-keypair.json\"\n    11→BACKEND_LOG=\"$APP_DIR/.local-backend.log\"\n    12→\n    13→RPC_URL=\"${RPC_URL:-http://127.0.0.1:8899}\"\n    14→PORT=\"${PORT:-3101}\"\n    15→VITE_FAIRNESS_BACKEND_URL=\"${VITE_FAIRNESS_BACKEND_URL:-http://127.0.0.1:${PORT}}\"\n    16→DATABASE_URL=\"${DATABASE_URL:-postgres:///postgres}\"\n    17→DB_SCHEMA=\"${DB_SCHEMA:-local_e2e}\"\n    18→\n    19→cleanup() {\n    20→  if [ -n \"${BACKEND_PID:-}\" ]; then\n    21→    kill \"$BACKEND_PID\" >/dev/null 2>&1 || true\n    22→    wait \"$BACKEND_PID\" >/dev/null 2>&1 || true\n    23→  fi\n    24→  echo \"==> Stopping localnet validator…\"\n    25→  bash \"$SCRIPT_DIR/localnet-teardown.sh\" || true\n    26→}\n    27→\n    28→wait_for_health() {\n    29→  local url=\"$1\"\n    30→  local attempts=30\n    31→\n    32→  for ((i=1; i<=attempts; i++)); do\n    33→    if curl -fsS \"$url\" >/dev/null 2>&1; then\n    34→      return 0\n    35→    fi\n    36→    sleep 2\n    37→  done\n    38→\n    39→  return 1\n    40→}\n    41→\n    42→free_port_if_busy() {\n    43→  local port=\"$1\"\n    44→  local pids\n    45→  pids=\"$(lsof -ti \":$port\" 2>/dev/null || true)\"\n    46→  if [ -z \"$pids\" ]; then\n    47→    return 0\n    48→  fi\n    49→\n    50→  echo \"==> Reclaiming port $port from stale process(es): $pids\"\n    51→  while IFS= read -r pid; do\n    52→    [ -z \"$pid\" ] && continue\n    53→    kill \"$pid\" >/dev/null 2>&1 || true\n    54→  done <<< \"$pids\"\n    55→\n    56→  sleep 1\n    57→}\n    58→\n    59→trap cleanup EXIT\n    60→\n    61→# --- Bootstrap ---\n    62→echo \"==> Starting localnet validator…\"\n    63→if ! bash \"$SCRIPT_DIR/localnet-bootstrap.sh\"; then\n    64→  echo \"❌ Localnet bootstrap failed\"\n    65→  exit 1\n    66→fi\n    67→\n    68→# Source backend .env if present without overriding explicit env vars.\n    69→if [ -f \"$BACKEND_DIR/.env\" ]; then\n    70→  while IFS='=' read -r key value; do\n    71→    [[ \"$key\" =~ ^[[:space:]]*# ]] && continue\n    72→    [[ -z \"$key\" ]] && continue\n    73→    key=\"$(echo \"$key\" | xargs)\"\n    74→    value=\"$(echo \"$value\" | xargs)\"\n    75→    if [ -z \"${!key:-}\" ]; then\n    76→      export \"$key=$value\"\n    77→    fi\n    78→  done < \"$BACKEND_DIR/.env\"\n    79→fi\n    80→\n    81→DATABASE_URL=\"${DATABASE_URL:-postgres:///postgres}\"\n    82→DB_SCHEMA=\"${DB_SCHEMA:-local_e2e}\"\n    83→RPC_URL=\"${RPC_URL:-http://127.0.0.1:8899}\"\n    84→\n    85→if ! pg_isready -q 2>/dev/null; then\n    86→  echo \"==> Starting PostgreSQL…\"\n    87→  pg_ctlcluster 16 main start 2>/dev/null || sudo pg_ctlcluster 16 main start 2>/dev/null || true\n    88→  for i in $(seq 1 10); do\n    89→    pg_isready -q 2>/dev/null && break\n    90→    sleep 1\n    91→  done\n    92→  if ! pg_isready -q 2>/dev/null; then\n    93→    echo \"❌ Could not start PostgreSQL\"\n    94→    exit 1\n    95→  fi\n    96→fi\n    97→\n    98→if [ ! -f \"$BACKEND_KEYPAIR_FILE\" ]; then\n    99→  echo \"==> Generating local backend signer…\"\n   100→  solana-keygen new --no-bip39-passphrase --silent -o \"$BACKEND_KEYPAIR_FILE\" >/dev/null\n   101→fi\n   102→\n   103→SERVER_KEYPAIR=\"${SERVER_KEYPAIR:-$(tr -d '\\n' < \"$BACKEND_KEYPAIR_FILE\")}\"\n   104→BACKEND_PUBKEY=\"$(solana address -k \"$BACKEND_KEYPAIR_FILE\")\"\n   105→echo \"==> Funding backend signer $BACKEND_PUBKEY…\"\n   106→solana airdrop 2 \"$BACKEND_PUBKEY\" --url \"$RPC_URL\" >/dev/null 2>&1 || true\n   107→\n   108→echo \"==> Running backend migrations…\"\n   109→(\n   110→  cd \"$MONOREPO_DIR\"\n   111→  DATABASE_URL=\"$DATABASE_URL\" \\\n   112→  DB_SCHEMA=\"$DB_SCHEMA\" \\\n   113→  RPC_URL=\"$RPC_URL\" \\\n   114→  SERVER_KEYPAIR=\"$SERVER_KEYPAIR\" \\\n   115→  PORT=\"$PORT\" \\\n   116→  pnpm --filter @rng-utopia/backend migrate\n   117→)\n   118→\n   119→echo \"==> Starting fairness backend…\"\n   120→free_port_if_busy \"$PORT\"\n   121→(\n   122→  cd \"$MONOREPO_DIR\"\n   123→  DATABASE_URL=\"$DATABASE_URL\" \\\n   124→  DB_SCHEMA=\"$DB_SCHEMA\" \\\n   125→  RPC_URL=\"$RPC_URL\" \\\n   126→  SERVER_KEYPAIR=\"$SERVER_KEYPAIR\" \\\n   127→  PORT=\"$PORT\" \\\n   128→  pnpm --filter @rng-utopia/backend dev\n   129→) >\"$BACKEND_LOG\" 2>&1 &\n   130→BACKEND_PID=$!\n   131→\n   132→if ! wait_for_health \"${VITE_FAIRNESS_BACKEND_URL}/health\"; then\n   133→  echo \"❌ Fairness backend failed to become healthy\"\n   134→  echo \"   Log: $BACKEND_LOG\"\n   135→  exit 1\n   136→fi\n   137→\n   138→# --- Run tests (capture exit code, always teardown after) ---\n   139→echo \"==> Running local E2E tests…\"\n   140→TEST_EXIT=0\n   141→(cd \"$APP_DIR\" && VITE_FAIRNESS_BACKEND_URL=\"$VITE_FAIRNESS_BACKEND_URL\" npx playwright test --config playwright.local.config.ts \"$@\") || TEST_EXIT=$?\n   142→\n   143→# --- Report ---\n   144→if [ \"$TEST_EXIT\" -eq 0 ]; then\n   145→  echo \"✅ Local E2E tests passed\"\n   146→else\n   147→  echo \"❌ Local E2E tests failed (exit $TEST_EXIT)\"\n   148→fi\n   149→\n   150→exit \"$TEST_EXIT\"\n   151→"}]},"parent_tool_use_id":"toolu_01Lbc3QFfwCsMEC17ctBnBWJ","session_id":"18302c5c-b9ec-4f75-9de3-1cbb537277bf","uuid":"f8dc396c-7a0e-495b-8652-63f13091cb89","timestamp":"2026-03-25T14:08:52.349Z"}
