rofile-socials__username\">{profile.discordUsername}</div>\n              )}\n            </div>\n            {profile.discordUsername ? (\n              <button\n                type=\"button\"\n                className=\"profile-socials__btn profile-socials__btn--disconnect\"\n                onClick={handleDisconnectDiscord}\n                disabled={connectingDiscord}\n              >\n                {connectingDiscord ? \"...\" : \"Disconnect\"}\n              </button>\n            ) : (\n              <button\n                type=\"button\"\n                className=\"profile-socials__btn profile-socials__btn--connect\"\n                onClick={handleConnectDiscord}\n                disabled={connectingDiscord}\n              >\n                {connectingDiscord ? \"...\" : \"Connect\"}\n              </button>\n            )}\n          </div>\n\n          {/* Twitter/X */}\n          <div className=\"profile-socials__item\">\n            <div className=\"profile-socials__icon\">\n              <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n                <path d=\"M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z\"/>\n              </svg>\n            </div>\n            <div className=\"profile-socials__info\">\n              <div className=\"profile-socials__name\">X (Twitter)</div>\n              {profile.twitterHandle && (\n                <div className=\"profile-socials__username\">{profile.twitterHandle}</div>\n              )}\n            </div>\n            {profile.twitterHandle ? (\n              <button\n                type=\"button\"\n                className=\"profile-socials__btn profile-socials__btn--disconnect\"\n                onClick={handleDisconnectTwitter}\n                disabled={connectingTwitter}\n              >\n                {connectingTwitter ? \"...\" : \"Disconnect\"}\n       