ading ? (\n          <div className=\"profile-settings__referral-skeleton\" />\n        ) : referrerWallet ? (\n          <div className=\"profile-settings__referral-linked\">\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"var(--color-green)\" strokeWidth=\"2\">\n              <path d=\"M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\" />\n              <path d=\"M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\" />\n            </svg>\n            <span>\n              Referred by: <strong title={referrerWallet}>{truncateAddress(referrerWallet)}</strong>\n            </span>\n          </div>\n        ) : referralSuccess ? (\n          <div className=\"profile-settings__referral-success\">\n            Referral code applied! You now receive a 10% fee rebate on all games.\n          </div>\n        ) : (\n          <>\n            <p className=\"profile-settings__referral-hint\">\n              Enter a referral code to receive a 10% fee rebate on all games.\n            </p>\n            <div className=\"profile-settings__input-group\">\n              <input\n                type=\"text\"\n                className=\"profile-settings__input\"\n                placeholder=\"Enter referral code\"\n                value={referralCode}\n                onChange={(e) => {\n                  setReferralCode(e.target.value);\n                  setReferralError(null);\n                }}\n                onKeyDown={(e) => { if (e.key === \"Enter\") handleApplyReferral(); }}\n                disabled={referralApplying}\n                maxLength={16}\n              />\n              <button\n                type=\"button\"\n                className=\"profile-settings__save-btn\"\n                onClick={handleApplyReferral}\n                disabled={referralApplying || !referralCode.trim()}\n              >\n                {referralApplying ? \"Applying...\" : \"Apply\"}\n              </button>\n        