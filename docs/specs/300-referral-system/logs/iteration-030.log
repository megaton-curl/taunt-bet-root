{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017vdx2MgNYkdt5XQZczfya4","type":"tool_result","content":"     1→/**\n     2→ * ProfileSettings - Settings tab content\n     3→ *\n     4→ * Shows connected wallet, referral code input, and social connections.\n     5→ * Avatar selection is handled via modal from the profile header.\n     6→ * Username editing is handled inline in the profile header.\n     7→ */\n     8→\n     9→import { useState, useEffect } from \"react\";\n    10→import type { PlayerProfile } from \"../types\";\n    11→import { usePlayerProfile } from \"../context/PlayerProfileContext\";\n    12→import { truncateAddress } from \"../utils/mock-simulation\";\n    13→import { useSession } from \"../../../context/SessionContext\";\n    14→import { getReferrer, applyReferralCode } from \"../../../lib/referral-api\";\n    15→\n    16→interface ProfileSettingsProps {\n    17→  profile: PlayerProfile;\n    18→}\n    19→\n    20→export function ProfileSettings({ profile }: ProfileSettingsProps) {\n    21→  const {\n    22→    connectDiscord,\n    23→    disconnectDiscord,\n    24→    connectTwitter,\n    25→    disconnectTwitter,\n    26→  } = usePlayerProfile();\n    27→  const { accessToken } = useSession();\n    28→\n    29→  const [connectingDiscord, setConnectingDiscord] = useState(false);\n    30→  const [connectingTwitter, setConnectingTwitter] = useState(false);\n    31→\n    32→  // Referral code section state\n    33→  const [referrerWallet, setReferrerWallet] = useState<string | null>(null);\n    34→  const [referrerLoading, setReferrerLoading] = useState(true);\n    35→  const [referralCode, setReferralCode] = useState(\"\");\n    36→  const [referralApplying, setReferralApplying] = useState(false);\n    37→  const [referralError, setReferralError] = useState<string | null>(null);\n    38→  const [referralSuccess, setReferralSuccess] = useState(false);\n    39→\n    40→  // Fetch referrer status on mount\n    41→  useEffect(() => {\n    42→    if (!accessToken) {\n    43→      setReferrerLoading(false);\n    44→      return;\n    45→    }\n    46→    let cancelled = false;\n    47→    getReferrer(accessToken)\n    48→      .then((data) => {\n    49→        if (!cancelled) setReferrerWallet(data.referrerWallet);\n    50→      })\n    51→      .catch(() => {\n    52→        // 404 = no referrer, which is fine\n    53→        if (!cancelled) setReferrerWallet(null);\n    54→      })\n    55→      .finally(() => {\n    56→        if (!cancelled) setReferrerLoading(false);\n    57→      });\n    58→    return () => { cancelled = true; };\n    59→  }, [accessToken]);\n    60→\n    61→  const handleApplyReferral = async () => {\n    62→    if (!accessToken) return;\n    63→    const code = referralCode.toLowerCase().trim();\n    64→    if (!code) {\n    65→      setReferralError(\"Please enter a referral code\");\n    66→      return;\n    67→    }\n    68→    setReferralError(null);\n    69→    setReferralApplying(true);\n    70→    try {\n    71→      const result = await applyReferralCode(accessToken, code);\n    72→      setReferrerWallet(result.referrer);\n    73→      setReferralSuccess(true);\n    74→      setReferralCode(\"\");\n    75→    } catch (err) {\n    76→      const msg = err instanceof Error ? err.message : \"Failed to apply referral code\";\n    77→      if (msg.includes(\"Cannot refer yourself\") || msg.includes(\"SELF_REFERRAL\")) {\n    78→        setReferralError(\"You cannot use your own referral code\");\n    79→      } else if (msg.includes(\"already linked\") || msg.includes(\"ALREADY_LINKED\")) {\n    80→        setReferralError(\"You are already linked to a referrer\");\n    81→      } else if (msg.includes(\"not found\") || msg.includes(\"NOT_FOUND\") || msg.includes(\"does not exist\")) {\n    82→        setReferralError(\"Referral code not found\");\n    83→      } else {\n    84→        setReferralError(msg);\n    85→      }\n    86→    } finally {\n    87→      setReferralApplying(false);\n    88→    }\n    89→  };\n    90→\n    91→  const handleConnectDiscord = async () => {\n    92→    setConnectingDiscord(true);\n    93→    try {\n    94→      await connectDiscord();\n    95→    } catch (error) {\n    96→      console.error(\"Failed to connect Discord:\", error);\n    97→    } finally {\n    98→      setConnectingDiscord(false);\n    99→    }\n   100→  };"}]},"parent_tool_use_id":null,"session_id":"18302c5c-b9ec-4f75-9de3-1cbb537277bf","uuid":"384966a5-2c1f-4483-adce-44c9c4103dda","timestamp":"2026-03-25T14:12:49.763Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/player-profile/components/ProfileSettings.tsx","content":"/**\n * ProfileSettings - Settings tab content\n *\n * Shows connected wallet, referral code input, and social connections.\n * Avatar selection is handled via modal from the profile header.\n * Username editing is handled inline in the profile header.\n */\n\nimport { useState, useEffect } from \"react\";\nimport type { PlayerProfile } from \"../types\";\nimport { usePlayerProfile } from \"../context/PlayerProfileContext\";\nimport { truncateAddress } from \"../utils/mock-simulation\";\nimport { useSession } from \"../../../context/SessionContext\";\nimport { getReferrer, applyReferralCode } from \"../../../lib/referral-api\";\n\ninterface ProfileSettingsProps {\n  profile: PlayerProfile;\n}\n\nexport function ProfileSettings({ profile }: ProfileSettingsProps) {\n  const {\n    connectDiscord,\n    disconnectDiscord,\n    connectTwitter,\n    disconnectTwitter,\n  } = usePlayerProfile();\n  const { accessToken } = useSession();\n\n  const [connectingDiscord, setConnectingDiscord] = useState(false);\n  const [connectingTwitter, setConnectingTwitter] = useState(false);\n\n  // Referral code section state\n  const [referrerWallet, setReferrerWallet] = useState<string | null>(null);\n  const [referrerLoading, setReferrerLoading] = useState(true);\n  const [referralCode, setReferralCode] = useState(\"\");\n  const [referralApplying, setReferralApplying] = useState(false);\n  const [referralError, setReferralError] = useState<string | null>(null);\n  const [referralSuccess, setReferralSuccess] = useState(false);\n\n  // Fetch referrer status on mount\n  useEffect(() => {\n    if (!accessToken) {\n      setReferrerLoading(false);\n      return;\n    }\n    let cancelled = false;\n    getReferrer(accessToken)\n      .then((data) => {\n        if (!cancelled) setReferrerWallet(data.referrerWallet);\n      })\n      .catch(() => {\n        // 404 = no referrer, which is fine\n        if (!cancelled) setReferrerWallet(null);\n      })\n      .finally(() => {\n        if (!cancelled) setReferrerLoading(false);\n      });\n    return () => { cancelled = true; };\n  }, [accessToken]);\n\n  const handleApplyReferral = async () => {\n    if (!accessToken) return;\n    const code = referralCode.toLowerCase().trim();\n    if (!code) {\n      setReferralError(\"Please enter a referral code\");\n      return;\n    }\n    setReferralError(null);\n    setReferralApplying(true);\n    try {\n      const result = await applyReferralCode(accessToken, code);\n      setReferrerWallet(result.referrer);\n      setReferralSuccess(true);\n      setReferralCode(\"\");\n    } catch (err) {\n      const msg = err instanceof Error ? err.message : \"Failed to apply referral code\";\n      if (msg.includes(\"Cannot refer yourself\") || msg.includes(\"SELF_REFERRAL\")) {\n        setReferralError(\"You cannot use your own referral code\");\n      } else if (msg.includes(\"already linked\") || msg.includes(\"ALREADY_LINKED\")) {\n        setReferralError(\"You are already linked to a referrer\");\n      } else if (msg.includes(\"not found\") || msg.includes(\"NOT_FOUND\") || msg.includes(\"does not exist\")) {\n        setReferralError(\"Referral code not found\");\n      } else {\n        setReferralError(msg);\n      }\n    } finally {\n      setReferralApplying(false);\n    }\n  };\n\n  const handleConnectDiscord = async () => {\n    setConnectingDiscord(true);\n    try {\n      await connectDiscord();\n    } catch (error) {\n      console.error(\"Failed to connect Discord:\", error);\n    } finally {\n      setConnectingDiscord(false);\n    }\n  };","numLines":100,"startLine":1,"totalLines":285}}}
