{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LpejTF5W1Et4qsCervVDA7","type":"tool_result","content":"    76→/**\n    77→ * Wait for the test wallet to auto-connect (visible via header button class).\n    78→ * Call after navigation when subsequent interactions require a connected wallet.\n    79→ */\n    80→export async function waitForWalletConnected(\n    81→  page: Page,\n    82→  timeout = 20_000,\n    83→): Promise<void> {\n    84→  await page.waitForSelector(\".rng-wallet-button--connected\", {\n    85→    state: \"visible\",\n    86→    timeout,\n    87→  });\n    88→}\n    89→\n    90→/**\n    91→ * Navigate to the coinflip page and wait for the lobby to render.\n    92→ */\n    93→export async function navigateToCoinflip(page: Page): Promise<void> {\n    94→  await page.goto(\"/coinflip\", { waitUntil: \"domcontentloaded\" });\n    95→  await page.waitForSelector(sel.main, { state: \"visible\", timeout: 15_000 });\n    96→}\n    97→\n    98→/**\n    99→ * Enter a wager amount in SOL into the WagerInput.\n   100→ */\n   101→export async function enterWager(page: Page, amountSol: number): Promise<void> {\n   102→  const input = page.locator(\".rng-wager-input__input\").first();\n   103→  await expect(input).toBeVisible({ timeout: 15_000 });\n   104→  await input.fill(amountSol.toString());\n   105→}\n   106→\n   107→/**\n   108→ * Select a coin side (heads or tails) in the sidebar.\n   109→ */\n   110→export async function selectSide(page: Page, side: CoinSide): Promise<void> {\n   111→  const selector =\n   112→    side === \"heads\" ? sel.sideButtonHeads : sel.sideButtonTails;\n   113→  await page.click(selector);\n   114→  await expect(page.locator(selector)).toHaveClass(/coinflip-side-btn--selected/);\n   115→}\n   116→\n   117→/**\n   118→ * Create a match: enter wager amount, select side, click \"Create Game\".\n   119→ * Returns when the active match view (waiting state) is visible.\n   120→ */\n   121→export async function createMatch(\n   122→  page: Page,\n   123→  amountSol: number,\n   124→  side: CoinSide,\n   125→  options?: { timeout?: number },\n   126→): Promise<void> {\n   127→  // Ensure wallet is connected before interacting — prevents race on devnet\n   128→  await waitForWalletConnected(page);\n   129→  await enterWager(page, amountSol);\n   130→  await selectSide(page, side);\n   131→\n   132→  // Click create — button text is \"Create Game\"\n   133→  const createBtn = page.locator(sel.actionButton, {\n   134→    hasText: \"Create Game\",\n   135→  });"}]},"parent_tool_use_id":null,"session_id":"18302c5c-b9ec-4f75-9de3-1cbb537277bf","uuid":"4b6bceee-2b67-4798-bf74-d51249431efa","timestamp":"2026-03-25T14:11:32.240Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/e2e/local/helpers/page-objects.ts","content":"/**\n * Wait for the test wallet to auto-connect (visible via header button class).\n * Call after navigation when subsequent interactions require a connected wallet.\n */\nexport async function waitForWalletConnected(\n  page: Page,\n  timeout = 20_000,\n): Promise<void> {\n  await page.waitForSelector(\".rng-wallet-button--connected\", {\n    state: \"visible\",\n    timeout,\n  });\n}\n\n/**\n * Navigate to the coinflip page and wait for the lobby to render.\n */\nexport async function navigateToCoinflip(page: Page): Promise<void> {\n  await page.goto(\"/coinflip\", { waitUntil: \"domcontentloaded\" });\n  await page.waitForSelector(sel.main, { state: \"visible\", timeout: 15_000 });\n}\n\n/**\n * Enter a wager amount in SOL into the WagerInput.\n */\nexport async function enterWager(page: Page, amountSol: number): Promise<void> {\n  const input = page.locator(\".rng-wager-input__input\").first();\n  await expect(input).toBeVisible({ timeout: 15_000 });\n  await input.fill(amountSol.toString());\n}\n\n/**\n * Select a coin side (heads or tails) in the sidebar.\n */\nexport async function selectSide(page: Page, side: CoinSide): Promise<void> {\n  const selector =\n    side === \"heads\" ? sel.sideButtonHeads : sel.sideButtonTails;\n  await page.click(selector);\n  await expect(page.locator(selector)).toHaveClass(/coinflip-side-btn--selected/);\n}\n\n/**\n * Create a match: enter wager amount, select side, click \"Create Game\".\n * Returns when the active match view (waiting state) is visible.\n */\nexport async function createMatch(\n  page: Page,\n  amountSol: number,\n  side: CoinSide,\n  options?: { timeout?: number },\n): Promise<void> {\n  // Ensure wallet is connected before interacting — prevents race on devnet\n  await waitForWalletConnected(page);\n  await enterWager(page, amountSol);\n  await selectSide(page, side);\n\n  // Click create — button text is \"Create Game\"\n  const createBtn = page.locator(sel.actionButton, {\n    hasText: \"Create Game\",\n  });","numLines":60,"startLine":76,"totalLines":427}}}
