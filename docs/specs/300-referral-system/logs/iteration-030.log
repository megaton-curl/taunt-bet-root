{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019zv8RfRWaAvch7VM4416H9","type":"tool_result","content":"     1→import { useCallback, useEffect, useState } from \"react\";\n     2→import { useSession } from \"../../context/SessionContext\";\n     3→import {\n     4→  getReferralEarnings,\n     5→  type ReferralEarningItem,\n     6→} from \"../../lib/referral-api\";\n     7→\n     8→const LAMPORTS_PER_SOL = 1_000_000_000;\n     9→const PAGE_SIZE = 20;\n    10→\n    11→function formatSol(lamportsStr: string): string {\n    12→  const sol = Number(lamportsStr) / LAMPORTS_PER_SOL;\n    13→  if (sol >= 1_000_000) return `${(sol / 1_000_000).toFixed(1)}M`;\n    14→  if (sol >= 1000) return `${(sol / 1000).toFixed(1)}k`;\n    15→  if (sol >= 1) return sol.toFixed(2);\n    16→  if (sol >= 0.01) return sol.toFixed(3);\n    17→  return sol.toFixed(4);\n    18→}\n    19→\n    20→function truncateWallet(wallet: string): string {\n    21→  if (wallet.length <= 10) return wallet;\n    22→  return `${wallet.slice(0, 4)}...${wallet.slice(-4)}`;\n    23→}\n    24→\n    25→function formatDate(iso: string): string {\n    26→  const d = new Date(iso);\n    27→  const month = String(d.getMonth() + 1).padStart(2, \"0\");\n    28→  const day = String(d.getDate()).padStart(2, \"0\");\n    29→  const hours = String(d.getHours()).padStart(2, \"0\");\n    30→  const minutes = String(d.getMinutes()).padStart(2, \"0\");\n    31→  return `${month}/${day} ${hours}:${minutes}`;\n    32→}\n    33→\n    34→function formatGameType(gameType: string): string {\n    35→  if (gameType === \"coinflip\") return \"Coinflip\";\n    36→  if (gameType === \"lord_of_rngs\") return \"Lord of RNGs\";\n    37→  return gameType;\n    38→}\n    39→\n    40→export function ReferralEarningsTable() {\n    41→  const { accessToken } = useSession();\n    42→  const [loading, setLoading] = useState(true);\n    43→  const [items, setItems] = useState<ReferralEarningItem[]>([]);\n    44→  const [page, setPage] = useState(1);\n    45→  const [totalPages, setTotalPages] = useState(1);\n    46→\n    47→  const fetchPage = useCallback(\n    48→    async (p: number) => {\n    49→      if (!accessToken) return;\n    50→      setLoading(true);\n    51→      try {\n    52→        const res = await getReferralEarnings(accessToken, p, PAGE_SIZE);\n    53→        setItems(res.items);\n    54→        setPage(res.pagination.page);\n    55→        setTotalPages(res.pagination.totalPages);\n    56→      } catch {\n    57→        /* silently fail — keep current state */\n    58→      } finally {\n    59→        setLoading(false);\n    60→      }\n    61→    },\n    62→    [accessToken],\n    63→  );\n    64→\n    65→  useEffect(() => {\n    66→    fetchPage(1);\n    67→  }, [fetchPage]);\n    68→\n    69→  return (\n    70→    <div className=\"ref-earnings\">\n    71→      <h3 className=\"ref-earnings__title\">Earnings History</h3>\n    72→\n    73→      {loading && items.length === 0 ? (\n    74→        <div className=\"ref-earnings__skeleton\">\n    75→          {[0, 1, 2].map((i) => (\n    76→            <div key={i} className=\"ref-earnings__skeleton-row\" />\n    77→          ))}\n    78→        </div>\n    79→      ) : items.length === 0 ? (\n    80→        <div className=\"ref-earnings__empty\">\n    81→          No earnings yet. Share your link to start earning!\n    82→        </div>\n    83→      ) : (\n    84→        <>\n    85→          <div className=\"ref-earnings__table-wrap\">\n    86→            <table className=\"ref-earnings__table\">\n    87→              <thead>\n    88→                <tr>\n    89→                  <th>Date</th>\n    90→                  <th>Game</th>\n    91→                  <th>Referee</th>\n    92→                  <th className=\"ref-earnings__col-right\">Wager</th>\n    93→                  <th className=\"ref-earnings__col-right\">Your Earning</th>\n    94→                </tr>\n    95→              </thead>\n    96→              <tbody>\n    97→                {items.map((item) => (\n    98→                  <tr key={`${item.roundId}-${item.refereeWallet}`}>\n    99→                    <td className=\"ref-earnings__cell-date\">\n   100→                      {formatDate(item.createdAt)}\n   101→                    </td>\n   102→                    <td>{formatGameType(item.gameType)}</td>\n   103→                    <td className=\"ref-earnings__cell-wallet\">\n   104→                      {truncateWallet(item.refereeWallet)}\n   105→                    </td>\n   106→                    <td className=\"ref-earnings__col-right ref-earnings__cell-mono\">\n   107→                      {formatSol(item.wagerLamports)}\n   108→                    </td>\n   109→                    <td className=\"ref-earnings__col-right ref-earnings__cell-mono ref-earnings__cell-earning\">\n   110→                      +{formatSol(item.earnedLamports)}\n   111→                    </td>\n   112→                  </tr>\n   113→                ))}\n   114→              </tbody>\n   115→            </table>\n   116→          </div>\n   117→\n   118→          {totalPages > 1 && (\n   119→            <div className=\"ref-earnings__pagination\">\n   120→              <button\n   121→                type=\"button\"\n   122→                className=\"ref-earnings__page-btn\"\n   123→                disabled={page <= 1 || loading}\n   124→                onClick={() => fetchPage(page - 1)}\n   125→              >\n   126→                &laquo; Prev\n   127→              </button>\n   128→              <span className=\"ref-earnings__page-info\">\n   129→                {page} / {totalPages}\n   130→              </span>\n   131→              <button\n   132→                type=\"button\"\n   133→                className=\"ref-earnings__page-btn\"\n   134→                disabled={page >= totalPages || loading}\n   135→                onClick={() => fetchPage(page + 1)}\n   136→              >\n   137→                Next &raquo;\n   138→              </button>\n   139→            </div>\n   140→          )}\n   141→        </>\n   142→      )}\n   143→    </div>\n   144→  );\n   145→}\n   146→"}]},"parent_tool_use_id":"toolu_01T4WKVm7wdB4nLSnnbkfAez","session_id":"18302c5c-b9ec-4f75-9de3-1cbb537277bf","uuid":"142eb1df-1960-4473-8483-804eb1287ffa","timestamp":"2026-03-25T14:08:16.797Z"}
