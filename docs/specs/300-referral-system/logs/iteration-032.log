formatSol(stats.totalEarnedLamports) + \" SOL\" : \"0 SOL\" },\n    44→  ];\n    45→\n    46→  return (\n    47→    <div className=\"ref-stats-card\">\n    48→      <h3 className=\"ref-stats-card__title\">Stats</h3>\n    49→      <div className=\"ref-stats-card__grid\">\n    50→        {items.map((item) => (\n    51→          <div key={item.label} className=\"ref-stats-card__stat\">\n    52→            {loading ? (\n    53→              <div className=\"ref-stats-card__skeleton\" />\n    54→            ) : (\n    55→              <div className=\"ref-stats-card__value\">{item.value}</div>\n    56→            )}\n    57→            <div className=\"ref-stats-card__label\">{item.label}</div>\n    58→          </div>\n    59→        ))}\n    60→      </div>\n    61→    </div>\n    62→  );\n    63→}\n    64→"}]},"parent_tool_use_id":null,"session_id":"04a5000a-cdc8-4275-a60d-f3cd96e399cf","uuid":"3acebe2b-a859-470d-8715-e6c868a4c5d0","timestamp":"2026-03-25T14:50:27.435Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/features/referral/ReferralStatsCard.tsx","content":"import { useEffect, useState } from \"react\";\nimport { useSession } from \"../../context/SessionContext\";\nimport { getReferralStats, type ReferralStatsResponse } from \"../../lib/referral-api\";\n\nconst LAMPORTS_PER_SOL = 1_000_000_000;\n\nfunction formatSol(lamportsStr: string): string {\n  const sol = Number(lamportsStr) / LAMPORTS_PER_SOL;\n  if (sol >= 1_000_000) return `${(sol / 1_000_000).toFixed(1)}M`;\n  if (sol >= 1000) return `${(sol / 1000).toFixed(1)}k`;\n  if (sol >= 1) return sol.toFixed(2);\n  if (sol >= 0.01) return sol.toFixed(3);\n  return sol.toFixed(4);\n}\n\nexport function ReferralStatsCard() {\n  const { accessToken } = useSession();\n  const [loading, setLoading] = useState(true);\n  const [stats, setStats] = useState<ReferralStatsResponse | null>(null);\n\n  useEffect(() => {\n    if (!accessToken) return;\n    let cancelled = false;\n    getReferralStats(accessToken)\n      .then((res) => {\n        if (!cancelled) setStats(res);\n      })\n      .catch(() => {\n        /* stats unavailable — show zeros */\n      })\n      .finally(() => {\n        if (!cancelled) setLoading(false);\n      });\n    return () => {\n      cancelled = true;\n    };\n  }, [accessToken]);\n\n  const items = [\n    { label: \"Referred Players\", value: stats ? String(stats.referredCount) : \"0\" },\n    { label: \"Active (7d)\", value: stats ? String(stats.activeCount) : \"0\" },\n    { label: \"Total Volume\", value: stats ? formatSol(stats.totalVolumeLamports) + \" SOL\" : \"0 SOL\" },\n    { label: \"Total Earned\", value: stats ? formatSol(stats.totalEarnedLamports) + \" SOL\" : \"0 SOL\" },\n  ];\n\n  return (\n    <div className=\"ref-stats-card\">\n      <h3 className=\"ref-stats-card__title\">Stats</h3>\n      <div className=\"ref-stats-card__grid\">\n        {items.map((item) => (\n          <div key={item.label} className=\"ref-stats-card__stat\">\n            {loading ? (\n              <div className=\"ref-stats-card__skeleton\" />\n            ) : (\n              <div className=\"ref-stats-card__value\">{item.value}</div>\n            )}\n            <div className=\"ref-stats-card__label\">{item.label}</div>\n          </div>\n        ))}\n      </div>\n    </div>\n  );\n}\n","numLines":64,"startLine":1,"totalLines":64}}}
