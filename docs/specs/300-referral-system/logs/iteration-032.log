{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SeHx81Y2uQ54D8X6tRqycZ","type":"tool_result","content":"     1→/**\n     2→ * Pure storage logic for auth session tokens.\n     3→ * No React — just localStorage + module-level in-memory access token.\n     4→ */\n     5→\n     6→const STORAGE_KEY = \"rng-utopia:session\";\n     7→\n     8→export interface PersistedWalletSession {\n     9→  wallet: string;\n    10→  cluster: string;\n    11→  refreshToken: string;\n    12→  refreshExpiresAt: string;\n    13→}\n    14→\n    15→// In-memory only — never stored in localStorage\n    16→let accessToken: string | null = null;\n    17→let accessExpiresAt: string | null = null;\n    18→\n    19→export function getAccessToken(): string | null {\n    20→  if (!accessToken || !accessExpiresAt) return null;\n    21→  // Check if expired (with 30s buffer)\n    22→  if (new Date(accessExpiresAt).getTime() - 30_000 < Date.now()) return null;\n    23→  return accessToken;\n    24→}\n    25→\n    26→export function setAccessToken(token: string, expiresAt: string): void {\n    27→  accessToken = token;\n    28→  accessExpiresAt = expiresAt;\n    29→}\n    30→\n    31→export function clearAccessToken(): void {\n    32→  accessToken = null;\n    33→  accessExpiresAt = null;\n    34→}\n    35→\n    36→export function getAccessExpiresAt(): string | null {\n    37→  return accessExpiresAt;\n    38→}\n    39→\n    40→export function getPersistedSession(): PersistedWalletSession | null {\n    41→  try {\n    42→    const raw = localStorage.getItem(STORAGE_KEY);\n    43→    if (!raw) return null;\n    44→    const parsed = JSON.parse(raw) as PersistedWalletSession;\n    45→    // Check refresh token expiry\n    46→    if (new Date(parsed.refreshExpiresAt).getTime() < Date.now()) {\n    47→      localStorage.removeItem(STORAGE_KEY);\n    48→      return null;\n    49→    }\n    50→    return parsed;\n    51→  } catch {\n    52→    return null;\n    53→  }\n    54→}\n    55→\n    56→export function setPersistedSession(session: PersistedWalletSession): void {\n    57→  localStorage.setItem(STORAGE_KEY, JSON.stringify(session));\n    58→}\n    59→\n    60→export function clearPersistedSession(): void {\n    61→  localStorage.removeItem(STORAGE_KEY);\n    62→  clearAccessToken();\n    63→}\n    64→"}]},"parent_tool_use_id":null,"session_id":"04a5000a-cdc8-4275-a60d-f3cd96e399cf","uuid":"9499d83c-97f3-481c-bab1-07d041288def","timestamp":"2026-03-25T14:55:06.435Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/lib/auth-store.ts","content":"/**\n * Pure storage logic for auth session tokens.\n * No React — just localStorage + module-level in-memory access token.\n */\n\nconst STORAGE_KEY = \"rng-utopia:session\";\n\nexport interface PersistedWalletSession {\n  wallet: string;\n  cluster: string;\n  refreshToken: string;\n  refreshExpiresAt: string;\n}\n\n// In-memory only — never stored in localStorage\nlet accessToken: string | null = null;\nlet accessExpiresAt: string | null = null;\n\nexport function getAccessToken(): string | null {\n  if (!accessToken || !accessExpiresAt) return null;\n  // Check if expired (with 30s buffer)\n  if (new Date(accessExpiresAt).getTime() - 30_000 < Date.now()) return null;\n  return accessToken;\n}\n\nexport function setAccessToken(token: string, expiresAt: string): void {\n  accessToken = token;\n  accessExpiresAt = expiresAt;\n}\n\nexport function clearAccessToken(): void {\n  accessToken = null;\n  accessExpiresAt = null;\n}\n\nexport function getAccessExpiresAt(): string | null {\n  return accessExpiresAt;\n}\n\nexport function getPersistedSession(): PersistedWalletSession | null {\n  try {\n    const raw = localStorage.getItem(STORAGE_KEY);\n    if (!raw) return null;\n    const parsed = JSON.parse(raw) as PersistedWalletSession;\n    // Check refresh token expiry\n    if (new Date(parsed.refreshExpiresAt).getTime() < Date.now()) {\n      localStorage.removeItem(STORAGE_KEY);\n      return null;\n    }\n    return parsed;\n  } catch {\n    return null;\n  }\n}\n\nexport function setPersistedSession(session: PersistedWalletSession): void {\n  localStorage.setItem(STORAGE_KEY, JSON.stringify(session));\n}\n\nexport function clearPersistedSession(): void {\n  localStorage.removeItem(STORAGE_KEY);\n  clearAccessToken();\n}\n","numLines":64,"startLine":1,"totalLines":64}}}
