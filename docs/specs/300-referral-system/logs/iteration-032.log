{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016nEP5d46taUPb4gscaHAPz","type":"tool_result","content":"     1→/**\n     2→ * Thin fetch wrappers for the /referral/* backend endpoints.\n     3→ * All calls require JWT Bearer auth from useSession().accessToken.\n     4→ */\n     5→\n     6→const BACKEND_URL = (\n     7→  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n     8→    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n     9→).replace(/\\/$/, \"\");\n    10→\n    11→/* ── Response types ─────────────────────────────────────────────── */\n    12→\n    13→export interface ReferralCodeResponse {\n    14→  code: string;\n    15→  url: string;\n    16→}\n    17→\n    18→export interface ApplyReferralResponse {\n    19→  referrer: string;\n    20→  benefit: string;\n    21→}\n    22→\n    23→export interface ReferrerResponse {\n    24→  referrerWallet: string;\n    25→  linkedAt: string;\n    26→}\n    27→\n    28→export interface ReferralStatsResponse {\n    29→  referredCount: number;\n    30→  activeCount: number;\n    31→  totalVolumeLamports: string;\n    32→  totalEarnedLamports: string;\n    33→  totalRebateLamports: string;\n    34→  pendingLamports: string;\n    35→}\n    36→\n    37→export interface ReferralEarningItem {\n    38→  roundId: string;\n    39→  gameType: string;\n    40→  refereeWallet: string;\n    41→  wagerLamports: string;\n    42→  earnedLamports: string;\n    43→  createdAt: string;\n    44→}\n    45→\n    46→export interface ReferralEarningsResponse {\n    47→  items: ReferralEarningItem[];\n    48→  pagination: { page: number; totalPages: number };\n    49→}\n    50→\n    51→export interface ClaimResponse {\n    52→  claimId: string;\n    53→  amountLamports: string;\n    54→  status: \"pending\" | \"completed\" | \"failed\";\n    55→  txSignature?: string;\n    56→}\n    57→\n    58→/* ── Helpers ────────────────────────────────────────────────────── */\n    59→\n    60→async function parseResponse<T>(res: Response): Promise<T> {\n    61→  const json = await res.json();\n    62→  if (!res.ok) {\n    63→    const err = json?.error;\n    64→    const msg =\n    65→      typeof err === \"string\"\n    66→        ? err\n    67→        : typeof err?.message === \"string\"\n    68→          ? err.message\n    69→          : `Referral request failed (${res.status})`;\n    70→    throw new Error(msg);\n    71→  }\n    72→  return json as T;\n    73→}\n    74→\n    75→function authHeaders(token: string): Record<string, string> {\n    76→  return {\n    77→    \"Content-Type\": \"application/json\",\n    78→    Authorization: `Bearer ${token}`,\n    79→  };\n    80→}\n    81→\n    82→/* ── API functions ──────────────────────────────────────────────── */\n    83→\n    84→/** Set (or replace) the authenticated player's referral code. */\n    85→export async function setReferralCode(\n    86→  token: string,\n    87→  code: string,\n    88→): Promise<ReferralCodeResponse> {\n    89→  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    90→    method: \"POST\",\n    91→    headers: authHeaders(token),\n    92→    body: JSON.stringify({ code }),\n    93→  });\n    94→  return parseResponse<ReferralCodeResponse>(res);\n    95→}\n    96→\n    97→/** Get the authenticated player's current referral code, or throw on 404. */\n    98→export async function getReferralCode(\n    99→  token: string,\n   100→): Promise<ReferralCodeResponse> {\n   101→  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n   102→    headers: authHeaders(token),\n   103→  });\n   104→  return parseResponse<ReferralCodeResponse>(res);\n   105→}\n   106→\n   107→/** Apply a referral code to the authenticated player (link to referrer). */\n   108→export async function applyReferralCode(\n   109→  token: string,\n   110→  code: string,\n   111→): Promise<ApplyReferralResponse> {\n   112→  const res = await fetch(`${BACKEND_URL}/referral/apply`, {\n   113→    method: \"POST\",\n   114→    headers: authHeaders(token),\n   115→    body: JSON.stringify({ code }),\n   116→  });\n   117→  return parseResponse<ApplyReferralResponse>(res);\n   118→}\n   119→\n   120→/** Get the authenticated player's referrer, or throw on 404 (no referrer). */\n   121→export async function getReferrer(\n   122→  token: string,\n   123→): Promise<ReferrerResponse> {\n   124→  const res = await fetch(`${BACKEND_URL}/referral/referrer`, {\n   125→    headers: authHeaders(token),\n   126→  });\n   127→  return parseResponse<ReferrerResponse>(res);\n   128→}\n   129→\n   130→/** Get referral summary stats for the authenticated player. */\n   131→export async function getReferralStats(\n   132→  token: string,\n   133→): Promise<ReferralStatsResponse> {\n   134→  const res = await fetch(`${BACKEND_URL}/referral/stats`, {\n   135→    headers: authHeaders(token),\n   136→  });\n   137→  return parseResponse<ReferralStatsResponse>(res);\n   138→}\n   139→\n   140→/** Get paginated per-game referral earnings log. */\n   141→export async function getReferralEarnings(\n   142→  token: string,\n   143→  page?: number,\n   144→  limit?: number,\n   145→): Promise<ReferralEarningsResponse> {\n   146→  const parts: string[] = [];\n   147→  if (page != null) parts.push(`page=${page}`);\n   148→  if (limit != null) parts.push(`limit=${limit}`);\n   149→  const qs = parts.length ? `?${parts.join(\"&\")}` : \"\";\n   150→  const res = await fetch(`${BACKEND_URL}/referral/earnings${qs}`, {\n   151→    headers: authHeaders(token),\n   152→  });\n   153→  return parseResponse<ReferralEarningsResponse>(res);\n   154→}\n   155→\n   156→/** Request an async claim of all pending referral earnings. Returns 202. */\n   157→export async function requestReferralClaim(\n   158→  token: string,\n   159→): Promise<ClaimResponse> {\n   160→  const res = await fetch(`${BACKEND_URL}/referral/claim`, {\n   161→    method: \"POST\",\n   162→    headers: authHeaders(token),\n   163→  });\n   164→  return parseResponse<ClaimResponse>(res);\n   165→}\n   166→\n   167→/** Poll the status of an existing claim by ID. */\n   168→export async function pollClaimStatus(\n   169→  token: string,\n   170→  claimId: string,\n   171→): Promise<ClaimResponse> {\n   172→  const res = await fetch(`${BACKEND_URL}/referral/claim/${claimId}`, {\n   173→    headers: authHeaders(token),\n   174→  });\n   175→  return parseResponse<ClaimResponse>(res);\n   176→}\n   177→"}]},"parent_tool_use_id":null,"session_id":"04a5000a-cdc8-4275-a60d-f3cd96e399cf","uuid":"51526cda-ce29-4548-92a8-4d6aad9a899d","timestamp":"2026-03-25T14:50:39.209Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/apps/platform/src/lib/referral-api.ts","content":"/**\n * Thin fetch wrappers for the /referral/* backend endpoints.\n * All calls require JWT Bearer auth from useSession().accessToken.\n */\n\nconst BACKEND_URL = (\n  (import.meta as unknown as { env: Record<string, string | undefined> }).env\n    .VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\"\n).replace(/\\/$/, \"\");\n\n/* ── Response types ─────────────────────────────────────────────── */\n\nexport interface ReferralCodeResponse {\n  code: string;\n  url: string;\n}\n\nexport interface ApplyReferralResponse {\n  referrer: string;\n  benefit: string;\n}\n\nexport interface ReferrerResponse {\n  referrerWallet: string;\n  linkedAt: string;\n}\n\nexport interface ReferralStatsResponse {\n  referredCount: number;\n  activeCount: number;\n  totalVolumeLamports: string;\n  totalEarnedLamports: string;\n  totalRebateLamports: string;\n  pendingLamports: string;\n}\n\nexport interface ReferralEarningItem {\n  roundId: string;\n  gameType: string;\n  refereeWallet: string;\n  wagerLamports: string;\n  earnedLamports: string;\n  createdAt: string;\n}\n\nexport interface ReferralEarningsResponse {\n  items: ReferralEarningItem[];\n  pagination: { page: number; totalPages: number };\n}\n\nexport interface ClaimResponse {\n  claimId: string;\n  amountLamports: string;\n  status: \"pending\" | \"completed\" | \"failed\";\n  txSignature?: string;\n}\n\n/* ── Helpers ────────────────────────────────────────────────────── */\n\nasync function parseResponse<T>(res: Response): Promise<T> {\n  const json = await res.json();\n  if (!res.ok) {\n    const err = json?.error;\n    const msg =\n      typeof err === \"string\"\n        ? err\n        : typeof err?.message === \"string\"\n          ? err.message\n          : `Referral request failed (${res.status})`;\n    throw new Error(msg);\n  }\n  return json as T;\n}\n\nfunction authHeaders(token: string): Record<string, string> {\n  return {\n    \"Content-Type\": \"application/json\",\n    Authorization: `Bearer ${token}`,\n  };\n}\n\n/* ── API functions ──────────────────────────────────────────────── */\n\n/** Set (or replace) the authenticated player's referral code. */\nexport async function setReferralCode(\n  token: string,\n  code: string,\n): Promise<ReferralCodeResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    method: \"POST\",\n    headers: authHeaders(token),\n    body: JSON.stringify({ code }),\n  });\n  return parseResponse<ReferralCodeResponse>(res);\n}\n\n/** Get the authenticated player's current referral code, or throw on 404. */\nexport async function getReferralCode(\n  token: string,\n): Promise<ReferralCodeResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/code`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ReferralCodeResponse>(res);\n}\n\n/** Apply a referral code to the authenticated player (link to referrer). */\nexport async function applyReferralCode(\n  token: string,\n  code: string,\n): Promise<ApplyReferralResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/apply`, {\n    method: \"POST\",\n    headers: authHeaders(token),\n    body: JSON.stringify({ code }),\n  });\n  return parseResponse<ApplyReferralResponse>(res);\n}\n\n/** Get the authenticated player's referrer, or throw on 404 (no referrer). */\nexport async function getReferrer(\n  token: string,\n): Promise<ReferrerResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/referrer`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ReferrerResponse>(res);\n}\n\n/** Get referral summary stats for the authenticated player. */\nexport async function getReferralStats(\n  token: string,\n): Promise<ReferralStatsResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/stats`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ReferralStatsResponse>(res);\n}\n\n/** Get paginated per-game referral earnings log. */\nexport async function getReferralEarnings(\n  token: string,\n  page?: number,\n  limit?: number,\n): Promise<ReferralEarningsResponse> {\n  const parts: string[] = [];\n  if (page != null) parts.push(`page=${page}`);\n  if (limit != null) parts.push(`limit=${limit}`);\n  const qs = parts.length ? `?${parts.join(\"&\")}` : \"\";\n  const res = await fetch(`${BACKEND_URL}/referral/earnings${qs}`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ReferralEarningsResponse>(res);\n}\n\n/** Request an async claim of all pending referral earnings. Returns 202. */\nexport async function requestReferralClaim(\n  token: string,\n): Promise<ClaimResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/claim`, {\n    method: \"POST\",\n    headers: authHeaders(token),\n  });\n  return parseResponse<ClaimResponse>(res);\n}\n\n/** Poll the status of an existing claim by ID. */\nexport async function pollClaimStatus(\n  token: string,\n  claimId: string,\n): Promise<ClaimResponse> {\n  const res = await fetch(`${BACKEND_URL}/referral/claim/${claimId}`, {\n    headers: authHeaders(token),\n  });\n  return parseResponse<ClaimResponse>(res);\n}\n","numLines":177,"startLine":1,"totalLines":177}}}
