it stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n        timeout: 5000,\n      });\n\n      // Wait for authenticated content to render\n      await stablePage.waitForSelector(\".referral-page__content\", {\n        timeout: 10000,\n      });\n\n      // Re-inject animation freeze CSS (connect flow may have triggered transitions)\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      // Settle time for UI to stabilize\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\"referrals-connected.png\", { fullPage: true });\n    });"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":954,"cache_read_input_tokens":93325,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":954},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"04a5000a-cdc8-4275-a60d-f3cd96e399cf","uuid":"a86d8dfd-3890-41ab-82c6-be60abddb919"}
