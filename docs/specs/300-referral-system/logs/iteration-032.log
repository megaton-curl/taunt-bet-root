, [balanceLamports]);\n   164→\n   165→  // Extended context value with mock-specific methods\n   166→  const value: WalletContextValue & {\n   167→    updateBalance: (deltaLamports: number) => void;\n   168→    getBalance: () => number;\n   169→    getBalanceLamports: () => number;\n   170→    isMock: boolean;\n   171→  } = {\n   172→    ...state,\n   173→    connect,\n   174→    disconnect,\n   175→    sendTransaction,\n   176→    signMessage,\n   177→    updateBalance,\n   178→    getBalance,\n   179→    getBalanceLamports,\n   180→    isMock: true,\n   181→  };\n   182→\n   183→  return (\n   184→    <WalletContext.Provider value={value}>{children}</WalletContext.Provider>\n   185→  );\n   186→}\n   187→"}]},"parent_tool_use_id":null,"session_id":"04a5000a-cdc8-4275-a60d-f3cd96e399cf","uuid":"abb5a2af-d402-4d88-8ad3-91196698f6a6","timestamp":"2026-03-25T14:52:35.990Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/packages/wallet/src/mock/MockWalletProvider.tsx","content":"import { ReactNode, useState, useCallback, useEffect } from \"react\";\nimport { PublicKey, Transaction } from \"@solana/web3.js\";\nimport { WalletContext } from \"../context\";\nimport { WalletContextValue, WalletState } from \"../types\";\nimport {\n  MockConfig,\n  DEFAULT_MOCK_CONFIG,\n  createMockKeypair,\n  loadPersistedState,\n  persistState,\n  clearPersistedState,\n  generateMockSignature,\n  delay,\n  solToLamports,\n  lamportsToSol,\n  getPublicKeyFromAddress,\n} from \"./MockWalletState\";\n\ninterface MockWalletProviderProps {\n  children: ReactNode;\n  config?: Partial<MockConfig>;\n}\n\nconst initialState: WalletState = {\n  connected: false,\n  connecting: false,\n  address: null,\n  publicKey: null,\n};\n\nexport function MockWalletProvider({\n  children,\n  config: userConfig,\n}: MockWalletProviderProps) {\n  const config: MockConfig = { ...DEFAULT_MOCK_CONFIG, ...userConfig };\n\n  const [state, setState] = useState<WalletState>(initialState);\n  const [balanceLamports, setBalanceLamports] = useState<number>(\n    solToLamports(config.initialBalance)\n  );\n\n  // Load persisted state on mount\n  useEffect(() => {\n    if (config.persistState) {\n      const persisted = loadPersistedState();\n      if (persisted) {\n        setBalanceLamports(persisted.balance);\n        if (config.autoConnect) {\n          const pubKey = getPublicKeyFromAddress(persisted.address);\n          setState({\n            connected: true,\n            connecting: false,\n            address: persisted.address,\n            publicKey: pubKey,\n          });\n        }\n      }\n    }\n  }, [config.persistState, config.autoConnect]);\n\n  // Persist state changes\n  useEffect(() => {\n    if (config.persistState && state.connected && state.address) {\n      persistState({\n        address: state.address,\n        balance: balanceLamports,\n      });\n    }\n  }, [config.persistState, state.connected, state.address, balanceLamports]);\n\n  const connect = useCallback(async () => {\n    setState((prev) => ({ ...prev, connecting: true }));\n\n    try {\n      await delay(config.simulatedLatency);\n\n      // Check for persisted state first\n      const persisted = loadPersistedState();\n      let address: string;\n      let pubKey: PublicKey;\n\n      if (persisted) {\n        address = persisted.address;\n        pubKey = getPublicKeyFromAddress(address);\n        setBalanceLamports(solToLamports(config.initialBalance));\n      } else {\n        // Generate new mock keypair\n        const keypair = createMockKeypair();\n        address = keypair.publicKey.toBase58();\n        pubKey = keypair.publicKey;\n        setBalanceLamports(solToLamports(config.initialBalance));\n      }\n\n      setState({\n        connected: true,\n        connecting: false,\n        address,\n        publicKey: pubKey,\n      });\n    } catch (error) {\n      console.error(\"Mock wallet connect failed:\", error);\n      setState((prev) => ({ ...prev, connecting: false }));\n      throw error;\n    }\n  }, [config.simulatedLatency, config.initialBalance]);\n\n  const disconnect = useCallback(async () => {\n    await delay(config.simulatedLatency / 2);\n\n    if (!config.persistState) {\n      clearPersistedState();\n    }\n\n    setState(initialState);\n  }, [config.simulatedLatency, config.persistState]);\n\n  const sendTransaction = useCallback(\n    async (_transaction: Transaction): Promise<string> => {\n      if (!state.connected) {\n        throw new Error(\"Wallet not connected\");\n      }\n\n      await delay(config.simulatedLatency);\n\n      // Simulate random failure (5% chance)\n      if (Math.random() < 0.05) {\n        throw new Error(\"Mock transaction simulation failed\");\n      }\n\n      // Return mock signature\n      return generateMockSignature();\n    },\n    [state.connected, config.simulatedLatency]\n  );\n\n  const signMessage = useCallback(\n    async (_message: Uint8Array): Promise<Uint8Array> => {\n      if (!state.connected) {\n        throw new Error(\"Wallet not connected\");\n      }\n\n      await delay(config.simulatedLatency / 2);\n\n      // Return mock signature (64 bytes)\n      const mockSig = new Uint8Array(64);\n      crypto.getRandomValues(mockSig);\n      return mockSig;\n    },\n    [state.connected, config.simulatedLatency]\n  );\n\n  // Expose balance management for mock transactions\n  const updateBalance = useCallback((deltaLamports: number) => {\n    setBalanceLamports((prev) => Math.max(0, prev + deltaLamports));\n  }, []);\n\n  const getBalance = useCallback(() => {\n    return lamportsToSol(balanceLamports);\n  }, [balanceLamports]);\n\n  const getBalanceLamports = useCallback(() => {\n    return balanceLamports;\n  }, [balanceLamports]);\n\n  // Extended context value with mock-specific methods\n  const value: WalletContextValue & {\n    updateBalance: (deltaLamports: number) => void;\n    getBalance: () => number;\n    getBalanceLamports: () => number;\n    isMock: boolean;\n  } = {\n    ...state,\n    connect,\n    disconnect,\n    sendTransaction,\n    signMessage,\n    updateBalance,\n    getBalance,\n    getBalanceLamports,\n    isMock: true,\n  };\n\n  return (\n    <WalletContext.Provider value={value}>{children}</WalletContext.Provider>\n  );\n}\n","numLines":187,"startLine":1,"totalLines":187}}}
