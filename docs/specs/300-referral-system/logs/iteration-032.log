{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VdXjzjQpo4WSew4LVdfCYQ","type":"tool_result","content":"     1→/**\n     2→ * Local E2E test: referral system flows.\n     3→ *\n     4→ * Tests the primary referral user flows:\n     5→ * 1. Player A sets a custom referral code on the /referrals page\n     6→ * 2. Player B visits /r/:code → code captured in localStorage → auto-applied on auth\n     7→ * 3. Player B's profile settings shows \"Referred by\" status\n     8→ * 4. Player A's referral stats update (1 referred player)\n     9→ *\n    10→ * Prerequisites (handled by run-e2e-local.sh):\n    11→ * - solana-test-validator running with deployed programs\n    12→ * - Backend running with postgres + migrations applied (including 011_referral)\n    13→ * - Test wallets funded\n    14→ */\n    15→import { test, expect } from \"./fixtures\";\n    16→import * as po from \"./helpers/page-objects\";\n    17→import { fundTestWallets } from \"./helpers/wallets\";\n    18→import { initializeLocalnet } from \"./helpers/localnet-setup\";\n    19→\n    20→test.describe(\"Referral system\", () => {\n    21→  test.describe.configure({ mode: \"serial\" });\n    22→\n    23→  test.beforeAll(async () => {\n    24→    await fundTestWallets();\n    25→    await initializeLocalnet();\n    26→  });\n    27→\n    28→  test(\"set referral code, apply via link, verify stats and profile\", async ({\n    29→    playerAPage,\n    30→    playerBPage,\n    31→  }) => {\n    32→    const consoleA = po.trackConsoleErrors(playerAPage);\n    33→    const consoleB = po.trackConsoleErrors(playerBPage);\n    34→\n    35→    // ── Step 1: Player A navigates to /referrals and sets a referral code ──\n    36→\n    37→    const authA = playerAPage.waitForResponse(\n    38→      (r) => r.url().includes(\"/auth/\") && r.status() < 400,\n    39→      { timeout: 15_000 },\n    40→    );\n    41→    await playerAPage.goto(\"/referrals\", { waitUntil: \"domcontentloaded\" });\n    42→    await authA;\n    43→\n    44→    // Authenticated state renders the page title\n    45→    await expect(playerAPage.locator(\".referral-page__title\")).toBeVisible({\n    46→      timeout: 10_000,\n    47→    });\n    48→\n    49→    // Wait for link card to finish loading → code input form appears\n    50→    await expect(playerAPage.locator(\".ref-link-card__input\")).toBeVisible({\n    51→      timeout: 10_000,\n    52→    });\n    53→\n    54→    // Enter a custom referral code and submit\n    55→    await playerAPage.fill(\".ref-link-card__input\", \"e2e-ref-test\");\n    56→    await playerAPage.click(\".ref-link-card__btn--primary\");\n    57→\n    58→    // Code saved → URL display mode appears\n    59→    await expect(playerAPage.locator(\".ref-link-card__url\")).toBeVisible({\n    60→      timeout: 10_000,\n    61→    });\n    62→    const referralUrl = await playerAPage\n    63→      .locator(\".ref-link-card__url\")\n    64→      .inputValue();\n    65→    expect(referralUrl).toContain(\"e2e-ref-test\");\n    66→\n    67→    // Verify all page sections rendered\n    68→    await expect(playerAPage.locator(\".ref-stats-card\")).toBeVisible();\n    69→    await expect(playerAPage.locator(\".ref-claim-card\")).toBeVisible();\n    70→    await expect(playerAPage.locator(\".ref-earnings\")).toBeVisible();\n    71→\n    72→    // Earnings should be empty\n    73→    await expect(playerAPage.locator(\".ref-earnings__empty\")).toBeVisible();\n    74→\n    75→    // Claim button shows no pending earnings\n    76→    await expect(playerAPage.locator(\".ref-claim-card__btn\")).toContainText(\n    77→      \"No pending earnings\",\n    78→    );\n    79→\n    80→    // ── Step 2: Player B visits referral link → auto-applied ──\n    81→\n    82→    // Set up listener for the auto-apply API call BEFORE navigation\n    83→    const applyPromise = playerBPage.waitForResponse(\n    84→      (r) => r.url().includes(\"/referral/apply\"),\n    85→      { timeout: 25_000 },\n    86→    );\n    87→\n    88→    // Navigate to referral link — ReferralCapture stores code in\n    89→    // localStorage and redirects to /. Auth triggers useReferralApply.\n    90→    await playerBPage.goto(\"/r/e2e-ref-test\");\n    91→    await po.waitForWalletConnected(playerBPage);\n    92→\n    93→    // Wait for the auto-apply to complete\n    94→    const applyRes = await applyPromise;\n    95→    expect(applyRes.status()).toBe(200);\n    96→\n    97→    // ── Step 3: Player B's profile shows \"Referred by\" ──\n    98→\n    99→    const authB = playerBPage.waitForResponse(\n   100→      (r) => r.url().includes(\"/auth/\") && r.status() < 400,\n   101→      { timeout: 15_000 },\n   102→    );\n   103→    await playerBPage.goto(\"/profile\", { waitUntil: \"domcontentloaded\" });\n   104→    await authB;\n   105→\n   106→    await expect(\n   107→      playerBPage.locator(\".profile-page__header\"),\n   108→    ).toBeVisible({ timeout: 10_000 });\n   109→\n   110→    // Click Settings tab\n   111→    await playerBPage.click('button:has-text(\"Settings\")');\n   112→\n   113→    // Referral section shows linked state\n   114→    await expect(\n   115→      playerBPage.locator(\".profile-settings__referral-linked\"),\n   116→    ).toBeVisible({ timeout: 10_000 });\n   117→\n   118→    const linkedText = await playerBPage\n   119→      .locator(\".profile-settings__referral-linked\")\n   120→      .textContent();\n   121→    expect(linkedText).toContain(\"Referred by:\");\n   122→\n   123→    // ── Step 4: Player A refreshes /referrals → stats show 1 referred ──\n   124→\n   125→    const authA2 = playerAPage.waitForResponse(\n   126→      (r) => r.url().includes(\"/auth/\") && r.status() < 400,\n   127→      { timeout: 15_000 },\n   128→    );\n   129→    await playerAPage.goto(\"/referrals\", { waitUntil: \"domcontentloaded\" });\n   130→    await authA2;\n   131→\n   132→    await expect(playerAPage.locator(\".referral-page__title\")).toBeVisible({\n   133→      timeout: 10_000,\n   134→    });\n   135→\n   136→    // Wait for stats values to load\n   137→    await expect(\n   138→      playerAPage.locator(\".ref-stats-card__value\").first(),\n   139→    ).toBeVisible({ timeout: 10_000 });\n   140→\n   141→    // First stat is \"Referred Players\" → should be \"1\"\n   142→    const referredCount = await playerAPage\n   143→      .locator(\".ref-stats-card__value\")\n   144→      .first()\n   145→      .textContent();\n   146→    expect(referredCount?.trim()).toBe(\"1\");\n   147→\n   148→    // ── Step 5: Sidebar nav has Referrals link ──\n   149→\n   150→    await expect(\n   151→      playerAPage.locator('.nv-item a[href=\"/referrals\"]'),\n   152→    ).toBeVisible();\n   153→\n   154→    // No unexpected console errors\n   155→    consoleA.assertClean();\n   156→    consoleB.assertClean();\n   157→  });\n   158→});\n   159→"}]},"parent_tool_use_id":"toolu_01AfxDiWSB8xqyHheyGXqzjR","session_id":"04a5000a-cdc8-4275-a60d-f3cd96e399cf","uuid":"6b62d37b-7ac3-474e-8b3b-662ef1cf3a50","timestamp":"2026-03-25T14:47:36.621Z"}
