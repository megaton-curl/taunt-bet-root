{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019cPqDvrzDsf4JQkUzu5fCs","type":"tool_result","content":"     1→/**\n     2→ * SessionContext — JWT session management for wallet authentication.\n     3→ *\n     4→ * Provides sign-once authentication: wallet signs a human-readable challenge\n     5→ * on connect, backend issues JWT access + refresh tokens, and all subsequent\n     6→ * requests use Bearer tokens.\n     7→ */\n     8→\n     9→import {\n    10→  createContext,\n    11→  useContext,\n    12→  useState,\n    13→  useCallback,\n    14→  useEffect,\n    15→  useRef,\n    16→  type ReactNode,\n    17→} from \"react\";\n    18→import bs58 from \"bs58\";\n    19→import { useWallet } from \"@rng-utopia/wallet/hooks\";\n    20→import { SOLANA_CLUSTER } from \"../lib/solana-env\";\n    21→import {\n    22→  requestChallenge,\n    23→  verifyChallenge,\n    24→  refreshSession,\n    25→  logout,\n    26→} from \"../lib/auth-api\";\n    27→import {\n    28→  getAccessToken,\n    29→  setAccessToken,\n    30→  getPersistedSession,\n    31→  setPersistedSession,\n    32→  clearPersistedSession,\n    33→  getAccessExpiresAt,\n    34→} from \"../lib/auth-store\";\n    35→\n    36→interface SessionContextValue {\n    37→  isAuthenticated: boolean;\n    38→  isAuthenticating: boolean;\n    39→  accessToken: string | null;\n    40→  authenticate: () => Promise<string>;\n    41→  clearSession: () => void;\n    42→}\n    43→\n    44→const SessionContext = createContext<SessionContextValue | null>(null);\n    45→\n    46→export function SessionProvider({ children }: { children: ReactNode }) {\n    47→  const { connected, publicKey, signMessage } = useWallet();\n    48→\n    49→  const [isAuthenticated, setIsAuthenticated] = useState(false);\n    50→  const [isAuthenticating, setIsAuthenticating] = useState(false);\n    51→\n    52→  // Mutex for refresh — only one in-flight refresh at a time\n    53→  const refreshPromiseRef = useRef<Promise<boolean> | null>(null);\n    54→  const refreshTimerRef = useRef<number | null>(null);\n    55→  const prevWalletRef = useRef<string | null>(null);\n    56→\n    57→  const clearSession = useCallback(() => {\n    58→    const session = getPersistedSession();\n    59→    if (session) {\n    60→      // Best-effort logout on backend\n    61→      logout(session.refreshToken).catch(() => {});\n    62→    }\n    63→    clearPersistedSession();\n    64→    setIsAuthenticated(false);\n    65→    if (refreshTimerRef.current !== null) {\n    66→      clearTimeout(refreshTimerRef.current);\n    67→      refreshTimerRef.current = null;\n    68→    }\n    69→  }, []);\n    70→\n    71→  // Schedule proactive refresh ~5 min before access token expiry\n    72→  const scheduleRefresh = useCallback(() => {\n    73→    if (refreshTimerRef.current !== null) {\n    74→      clearTimeout(refreshTimerRef.current);\n    75→    }\n    76→\n    77→    const expiresAt = getAccessExpiresAt();\n    78→    if (!expiresAt) return;\n    79→\n    80→    const msUntilExpiry = new Date(expiresAt).getTime() - Date.now();\n    81→    // Refresh 5 minutes before expiry, or immediately if < 5 min remaining\n    82→    const refreshIn = Math.max(msUntilExpiry - 5 * 60 * 1000, 0);\n    83→\n    84→    refreshTimerRef.current = window.setTimeout(() => {\n    85→      refreshTimerRef.current = null;\n    86→      void tryRefresh();\n    87→    }, refreshIn);\n    88→  }, []); // eslint-disable-line react-hooks/exhaustive-deps\n    89→\n    90→  const tryRefresh = useCallback(async (): Promise<boolean> => {\n    91→    // Mutex: if a refresh is already in-flight, await the same promise\n    92→    if (refreshPromiseRef.current) {\n    93→      return refreshPromiseRef.current;\n    94→    }\n    95→\n    96→    const session = getPersistedSession();\n    97→    if (!session) return false;\n    98→\n    99→    const promise = (async () => {\n   100→      try {\n   101→        const result = await refreshSession(session.refreshToken);\n   102→        setAccessToken(result.accessToken, result.accessExpiresAt);\n   103→        setPersistedSession({\n   104→          wallet: session.wallet,\n   105→          cluster: session.cluster,\n   106→          refreshToken: result.refreshToken,\n   107→          refreshExpiresAt: result.refreshExpiresAt,\n   108→        });\n   109→        setIsAuthenticated(true);\n   110→        scheduleRefresh();\n   111→        return true;\n   112→      } catch {\n   113→        // Refresh failed — clear session\n   114→        clearPersistedSession();\n   115→        setIsAuthenticated(false);\n   116→        return false;\n   117→      } finally {\n   118→        refreshPromiseRef.current = null;\n   119→      }\n   120→    })();\n   121→\n   122→    refreshPromiseRef.current = promise;\n   123→    return promise;\n   124→  }, [scheduleRefresh]);\n   125→\n   126→  const authenticate = useCallback(async () => {\n   127→    if (!connected || !publicKey || !signMessage) {\n   128→      throw new Error(\"Wallet not connected or does not support message signing\");\n   129→    }\n   130→\n   131→    setIsAuthenticating(true);\n   132→    try {\n   133→      const wallet = publicKey.toBase58();\n   134→\n   135→      // 1. Request challenge from backend\n   136→      const challenge = await requestChallenge(wallet);\n   137→\n   138→      // 2. Check challenge hasn't expired\n   139→      if (new Date(challenge.expiresAt).getTime() < Date.now()) {\n   140→        throw new Error(\"Challenge expired before signing\");\n   141→      }\n   142→\n   143→      // 3. Sign the human-readable message with wallet\n   144→      const messageBytes = new TextEncoder().encode(challenge.message);\n   145→      const signatureBytes = await signMessage(messageBytes);\n   146→      const signature = bs58.encode(signatureBytes);\n   147→\n   148→      // 4. Verify with backend — get tokens\n   149→      const result = await verifyChallenge(challenge.nonce, wallet, signature);\n   150→\n   151→      // 5. Store tokens\n   152→      setAccessToken(result.accessToken, result.accessExpiresAt);\n   153→      setPersistedSession({\n   154→        wallet,\n   155→        cluster: SOLANA_CLUSTER,\n   156→        refreshToken: result.refreshToken,\n   157→        refreshExpiresAt: result.refreshExpiresAt,\n   158→      });\n   159→\n   160→      setIsAuthenticated(true);\n   161→      scheduleRefresh();\n   162→      return result.accessToken;\n   163→    } catch (err) {\n   164→      // Clean up on failure\n   165→      clearPersistedSession();\n   166→      setIsAuthenticated(false);\n   167→      throw err;\n   168→    } finally {\n   169→      setIsAuthenticating(false);\n   170→    }\n   171→  }, [connected, publicKey, signMessage, scheduleRefresh]);\n   172→\n   173→  // Handle wallet connect: try to restore session or authenticate\n   174→  useEffect(() => {\n   175→    if (!connected || !publicKey) {\n   176→      // Wallet disconnected\n   177→      if (prevWalletRef.current !== null) {\n   178→        clearSession();\n   179→        prevWalletRef.current = null;\n   180→      }\n   181→      return;\n   182→    }\n   183→\n   184→    const wallet = publicKey.toBase58();\n   185→\n   186→    // Wallet switched — clear old session first\n   187→    if (prevWalletRef.current !== null && prevWalletRef.current !== wallet) {\n   188→      clearSession();\n   189→    }\n   190→    prevWalletRef.current = wallet;\n   191→\n   192→    // Check for existing session\n   193→    const session = getPersistedSession();\n   194→    if (session && session.wallet === wallet) {\n   195→      // Try silent refresh\n   196→      const existingAccessToken = getAccessToken();\n   197→      if (existingAccessToken) {\n   198→        // Access token still valid\n   199→        setIsAuthenticated(true);\n   200→        scheduleRefresh();\n   201→        return;\n   202→      }\n   203→\n   204→      // Access token expired, try refresh\n   205→      void tryRefresh().then((success) => {\n   206→        if (!success) {\n   207→          // Refresh failed, need new sign-in\n   208→          void authenticate().catch(() => {\n   209→            // Authentication failed — user may have rejected\n   210→          });\n   211→        }\n   212→      });\n   213→      return;\n   214→    }\n   215→\n   216→    // No matching session — trigger new authentication\n   217→    void authenticate().catch(() => {\n   218→      // Authentication failed — user may have rejected signing\n   219→    });\n   220→  }, [connected, publicKey]); // eslint-disable-line react-hooks/exhaustive-deps\n   221→\n   222→  // Cleanup on unmount\n   223→  useEffect(() => {\n   224→    return () => {\n   225→      if (refreshTimerRef.current !== null) {\n   226→        clearTimeout(refreshTimerRef.current);\n   227→      }\n   228→    };\n   229→  }, []);\n   230→\n   231→  const value: SessionContextValue = {\n   232→    isAuthenticated,\n   233→    isAuthenticating,\n   234→    accessToken: isAuthenticated ? getAccessToken() : null,\n   235→    authenticate,\n   236→    clearSession,\n   237→  };\n   238→\n   239→  return (\n   240→    <SessionContext.Provider value={value}>\n   241→      {children}\n   242→    </SessionContext.Provider>\n   243→  );\n   244→}\n   245→\n   246→export function useSession(): SessionContextValue {\n   247→  const context = useContext(SessionContext);\n   248→  if (!context) {\n   249→    throw new Error(\"useSession must be used within SessionProvider\");\n   250→  }\n   251→  return context;\n   252→}\n   253→"}]},"parent_tool_use_id":"toolu_01AfxDiWSB8xqyHheyGXqzjR","session_id":"04a5000a-cdc8-4275-a60d-f3cd96e399cf","uuid":"ce678a74-ad08-4423-9e5b-15c38e0b978f","timestamp":"2026-03-25T14:47:39.954Z"}
