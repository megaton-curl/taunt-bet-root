{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YAJ9EM25oDXnaCQVN69rMU","type":"tool_result","content":"     1→import { useCallback, useEffect, useState } from \"react\";\n     2→import { useSession } from \"../../context/SessionContext\";\n     3→import {\n     4→  getReferralCode,\n     5→  setReferralCode,\n     6→  type ReferralCodeResponse,\n     7→} from \"../../lib/referral-api\";\n     8→\n     9→const CODE_RE = /^[a-z0-9-]{3,16}$/;\n    10→\n    11→export function ReferralLinkCard() {\n    12→  const { accessToken } = useSession();\n    13→\n    14→  const [loading, setLoading] = useState(true);\n    15→  const [saving, setSaving] = useState(false);\n    16→  const [existing, setExisting] = useState<ReferralCodeResponse | null>(null);\n    17→  const [editing, setEditing] = useState(false);\n    18→  const [input, setInput] = useState(\"\");\n    19→  const [error, setError] = useState(\"\");\n    20→  const [copied, setCopied] = useState(false);\n    21→\n    22→  // Fetch existing code on mount\n    23→  useEffect(() => {\n    24→    if (!accessToken) return;\n    25→    let cancelled = false;\n    26→    getReferralCode(accessToken)\n    27→      .then((res) => {\n    28→        if (!cancelled) setExisting(res);\n    29→      })\n    30→      .catch(() => {\n    31→        /* 404 = no code yet, ignore */\n    32→      })\n    33→      .finally(() => {\n    34→        if (!cancelled) setLoading(false);\n    35→      });\n    36→    return () => {\n    37→      cancelled = true;\n    38→    };\n    39→  }, [accessToken]);\n    40→\n    41→  const validate = (code: string): string => {\n    42→    if (code.length < 3) return \"Code must be at least 3 characters\";\n    43→    if (code.length > 16) return \"Code must be at most 16 characters\";\n    44→    if (!CODE_RE.test(code)) return \"Only lowercase letters, numbers, and hyphens\";\n    45→    return \"\";\n    46→  };\n    47→\n    48→  const handleInputChange = (val: string) => {\n    49→    const lower = val.toLowerCase();\n    50→    setInput(lower);"}]},"parent_tool_use_id":"toolu_01AfxDiWSB8xqyHheyGXqzjR","session_id":"04a5000a-cdc8-4275-a60d-f3cd96e399cf","uuid":"ecf90bdb-9a00-42e6-9d66-a64007dd2db7","timestamp":"2026-03-25T14:47:43.221Z"}
