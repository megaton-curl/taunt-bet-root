\n      await stablePage.goto(\"/\");\n\n      // Click the wallet connect button\n      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n\n      // Wait for connected state\n      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n        timeout: 5000,\n      });\n\n      // Re-inject animation freeze CSS (connect flow may have triggered transitions)\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      // Settle time for UI to stabilize\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\"home-connected.png\", { fullPage: true });\n    });\n  });\n\n  test.describe(\"Profile page\", () => {\n    test(\"wallet connected\", async ({ stablePage }) => {\n      // Clear persisted state first so connect generates fresh from seeded PRNG\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/profile\");\n\n      // Click the wallet connect button\n      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n\n      // Wait for connected state\n      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n        timeout: 5000,\n      });\n\n      // Re-inject animation freeze CSS (connect flow may have triggered transitions)\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      // Settle time for UI to stabilize\n      await stablePage.waitForTimeout(300);\n\n      // Avatar SVG has sub-pixel rendering variance; allow slightly higher threshold\n      await expect(stablePage).toHaveScreenshot(\"profile-connected.png\", {\n        fullPage: true,\n        maxDiffPixelRatio: 0.03,\n      });\n    });\n\n    test(\"transactions tab — empty state\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/profile\");\n\n      // Connect wallet\n      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n        timeout: 5000,\n      });\n\n      // Click the Transactions tab\n      await stablePage\n        .locator(\".profile-page__tab\", { hasText: \"Transactions\" })\n        .click();\n\n      // Wait for the transactions empty state to render\n      await stablePage.waitForSelector(\".profile-transactions__empty\", {\n        timeout: 5000,\n      });\n\n      // Re-inject animation freeze CSS\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\n        \"profile-transactions-empty.png\",\n        {\n          fullPage: true,\n          maxDiffPixelRatio: 0.03,\n        },\n      );\n    });\n  });\n\n  test.describe(\"Lord of the RNGs page\", () => {\n    test(\"round lobby — wallet disconnected\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/lord-of-rngs\");\n\n      // Wait for lobby to render (round cards or \"No open rounds\" message)\n      await stablePage.waitForSelector(\".lotr-tier-lobby\", { timeout: 10_000 });\n\n      await expect(stablePage).toHaveScreenshot(\"lotr-lobby-disconnected.png\", { fullPage: true });\n    });\n\n    test(\"round selected — shows sidebar and round view\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/lord-of-rngs\");\n\n      // Wait for lobby to render\n      await stablePage.waitForSelector(\".lotr-tier-lobby\", { timeout: 10_000 });\n\n      // Click the first round card if available\n      const card = stablePage.locator(\".lotr-tier-card\").first();\n      if (await card.isVisible({ timeout: 3_000 }).catch(() => false)) {\n        await card.click();\n        await stablePage.waitForSelector(\".lotr-sidebar\", { timeout: 5_000 });\n      }\n\n      // Settle UI transitions\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\"lotr-tier-selected.png\", { fullPage: true });\n    });\n\n    test(\"round selected — wallet connected with sidebar controls\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/lord-of-rngs\");\n\n      // Wait for lobby\n      await stablePage.waitForSelector(\".lotr-tier-lobby\", { timeout: 10_000 });\n\n      // Connect wallet\n      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n      await stablePage.waitForSelector(\".rng-wallet-button--connected\", { timeout: 5_000 });\n\n      // Click first round card if available\n      const card = stablePage.locator(\".lotr-tier-card\").first();\n      if (await card.isVisible({ timeout: 3_000 }).catch(() => false)) {\n        await card.click();\n        await stablePage.waitForSelector(\".lotr-sidebar\", { timeout: 5_000 });\n      }\n\n      // Re-inject animation freeze CSS after interactions\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      // Settle UI\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\"lotr-tier-connected.png\", { fullPage: true });\n    });\n\n    test(\"back to lobby — human navigates back from round view\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/lord-of-rngs\");\n\n      // Wait for lobby\n      await stablePage.waitForSelector(\".lotr-tier-lobby\", { timeout: 10_000 });\n\n      // Select a round if available\n      const card = stablePage.locator(\".lotr-tier-card\").first();\n      if (await card.isVisible({ timeout: 3_000 }).catch(() => false)) {\n        await card.click();\n        await stablePage.waitForSelector(\".lotr-sidebar\", { timeout: 5_000 });\n\n        // Click back button to return to lobby\n        const backBtn = stablePage.getByRole(\"button\", { name: /back to lobby/i });\n        if (await backBtn.isVisible({ timeout: 3_000 }).catch(() => false)) {\n          await backBtn.click();\n        }\n      }\n\n      // Wait for lobby to reappear\n      await stablePage.waitForSelector(\".lotr-tier-lobby\", { timeout: 5_000 });\n\n      // Settle\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\"lotr-back-to-lobby.png\", { fullPage: true });\n    });\n  });\n\n  test.describe(\"Close Call page\", () => {\n    test(\"wallet disconnected\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/close-call\");\n      await expect(stablePage).toHaveScreenshot(\"closecall-disconnected.png\", { fullPage: true });\n    });\n\n    test(\"wallet connected\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/close-call\");\n\n      // Click the wallet connect button\n      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n\n      // Wait for connected state\n      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n        timeout: 5000,\n      });\n\n      // Re-inject animation freeze CSS (connect flow may have triggered transitions)\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      // Settle time for UI to stabilize\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\"closecall-connected.png\", { fullPage: true });\n    });\n  });\n\n  test.describe(\"Referrals page\", () => {\n    test(\"wallet disconnected\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/referrals\");\n\n      // Wait for the connect prompt to render\n      await stablePage.waitForSelector(\".referral-page__connect\", {\n        timeout: 5000,\n      });\n\n      await expect(stablePage).toHaveScreenshot(\"referrals-disconnected.png\", { fullPage: true });\n    });\n\n    test(\"wallet connected\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/referrals\");\n\n      // Click the wallet connect button\n      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n\n      // Wait for connected state\n      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n        timeout: 5000,\n      });\n\n      // Wait for authenticated content to render\n      await stablePage.waitForSelector(\".referral-page__content\", {\n        timeout: 5000,\n      });\n\n      // Re-inject animation freeze CSS (connect flow may have triggered transitions)\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      // Settle time for UI to stabilize\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\"referrals-connected.png\", { fullPage: true });\n    });\n  });\n\n  test.describe(\"Coinflip page\", () => {\n    test(\"wallet disconnected\", async ({ stablePage }) => {\n      // Clear any persisted wallet state to ensure disconnected\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/coinflip\");\n      await expect(stablePage).toHaveScreenshot(\"coinflip-disconnected.png\", { fullPage: true });\n    });\n\n    test(\"wallet connected\", async ({ stablePage }) => {\n      // Clear persisted state first so connect generates fresh from seeded PRNG\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/coinflip\");\n\n      // Click the wallet connect button\n      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n\n      // Wait for connected state\n      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n        timeout: 5000,\n      });\n\n      // Re-inject animation freeze CSS (connect flow may have triggered transitions)\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      // Settle time for UI to stabilize\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\"coinflip-connected.png\", { fullPage: true });\n    });\n\n    test(\"error toast below middle container\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/coinflip\");\n\n      // Inject a representative error toast at runtime so placement is snapshot-tested.\n      await stablePage.evaluate(() => {\n        const existing = document.querySelector(\".coinflip-error-toast\");\n        i