\"Not found\" }) }),\n      );\n      await stablePage.route((url) => url.pathname === \"/referral/stats\", (route) =>\n        route.fulfill({\n          status: 200,\n          contentType: \"application/json\",\n          body: JSON.stringify({\n            referredCount: 0,\n            activeCount: 0,\n            totalVolumeLamports: \"0\",\n            totalEarnedLamports: \"0\",\n            totalRebateLamports: \"0\",\n            pendingLamports: \"0\",\n          }),\n        }),\n      );\n      await stablePage.route((url) => url.pathname.startsWith(\"/referral/earnings\"), (route) =>\n        route.fulfill({\n          status: 200,\n          contentType: \"application/json\",\n          body: JSON.stringify({ items: [], pagination: { page: 1, totalPages: 1 } }),\n        }),\n      );\n\n      await stablePage.goto(\"/referrals\");\n\n      // Click the wallet connect button\n      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n\n      // Wait for connected state\n      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n        timeout: 5000,\n      });\n\n      // Wait for authenticated content to render (auth flow includes mock latency)\n      await stablePage.waitForSelector(\".referral-page__content\", {\n        timeout: 15000,\n      });","newString":"    test(\"wallet connected\", async ({ stablePage }) => {\n      // Intercept fetch at the JS level to mock auth + referral API.\n      // This is more reliable than page.route() for visual tests because it\n      // runs synchronously inside the browser context.\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n\n        const futureDate = new Date(Date.now() + 86_400_000).toISOString();\n        const originalFetch = window.fetch;\n        window.fetch = async (input: RequestInfo | URL, init?: RequestInit) => {\n          const url = typeof input === \"string\" ? input : input instanceof URL ? input.href : input.url;\n          if (url.includes(\"/auth/challenge\")) {\n            return new Response(JSON.stringify({\n              nonce: \"visual-test-nonce\",\n              message: \"Sign this message to authenticate with TAUNT.\",\n              expiresAt: futureDate,\n            }), { status: 200, headers: { \"Content-Type\": \"application/json\" } });\n          }\n          if (url.includes(\"/auth/verify\")) {\n            return new Response(JSON.stringify({\n              accessToken: \"visual-test-token\",\n              accessExpiresAt: futureDate,\n              refreshToken: \"visual-test-refresh\",\n              refreshExpiresAt: futureDate,\n            }), { status: 200, headers: { \"Content-Type\": \"application/json\" } });\n          }\n          if (url.includes(\"/referral/code\") && (!init || init.method === \"GET\" || !init.method)) {\n            return new Response(JSON.stringify({ error: \"Not found\" }),\n              { status: 404, headers: { \"Content-Type\": \"application/json\" } });\n          }\n          if (url.includes(\"/referral/stats\")) {\n            return new Response(JSON.stringify({\n              referredCount: 0, activeCount: 0,\n              totalVolumeLamports: \"0\", totalEarnedLamports: \"0\",\n              totalRebateLamports: \"0\", pendingLamports: \"0\",\n            }), { status: 200, headers: { \"Content-Type\": \"application/json\" } });\n          }\n          if (url.includes(\"/referral/earnings\")) {\n            return new Response(JSON.stringify({\n              items: [], pagination: { page: 1, totalPages: 1 },\n            }), { status: 200, headers: { \"Content-Type\": \"application/json\" } });\n          }\n          return originalFetch(input, init);\n        };\n      });\n\n      await stablePage.goto(\"/referrals\");\n\n      // Click the wallet connect button\n      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n\n      // Wait for connected state\n      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n        timeout: 5000,\n      });\n\n      // Wait for authenticated content to render (auth flow includes mock wallet latency)\n      await stablePage.waitForSelector(\".referral-page__content\", {\n        timeout: 15000,\n      });","originalFile":"import { test, expect } from \"../fixtures\";\n\ntest.describe(\"State variants\", () => {\n  test.describe(\"Home page\", () => {\n    test(\"wallet disconnected\", async ({ stablePage }) => {\n      // Clear any persisted wallet state to ensure disconnected\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/\");\n      await expect(stablePage).toHaveScreenshot(\"home-disconnected.png\", { fullPage: true });\n    });\n\n    test(\"wallet connected\", async ({ stablePage }) => {\n      // Clear persisted state first so connect generates fresh from seeded PRNG\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/\");\n\n      // Click the wallet connect button\n      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n\n      // Wait for connected state\n      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n        timeout: 5000,\n      });\n\n      // Re-inject animation freeze CSS (connect flow may have triggered transitions)\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      // Settle time for UI to stabilize\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\"home-connected.png\", { fullPage: true });\n    });\n  });\n\n  test.describe(\"Profile page\", () => {\n    test(\"wallet connected\", async ({ stablePage }) => {\n      // Clear persisted state first so connect generates fresh from seeded PRNG\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/profile\");\n\n      // Click the wallet connect button\n      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n\n      // Wait for connected state\n      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n        timeout: 5000,\n      });\n\n      // Re-inject animation freeze CSS (connect flow may have triggered transitions)\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      // Settle time for UI to stabilize\n      await stablePage.waitForTimeout(300);\n\n      // Avatar SVG has sub-pixel rendering variance; allow slightly higher threshold\n      await expect(stablePage).toHaveScreenshot(\"profile-connected.png\", {\n        fullPage: true,\n        maxDiffPixelRatio: 0.03,\n      });\n    });\n\n    test(\"transactions tab — empty state\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/profile\");\n\n      // Connect wallet\n      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n        timeout: 5000,\n      });\n\n      // Click the Transactions tab\n      await stablePage\n        .locator(\".profile-page__tab\", { hasText: \"Transactions\" })\n        .click();\n\n      // Wait for the transactions empty state to render\n      await stablePage.waitForSelector(\".profile-transactions__empty\", {\n        timeout: 5000,\n      });\n\n      // Re-inject animation freeze CSS\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\n        \"profile-transactions-empty.png\",\n        {\n          fullPage: true,\n          maxDiffPixelRatio: 0.03,\n        },\n      );\n    });\n  });\n\n  test.describe(\"Lord of the RNGs page\", () => {\n    test(\"round lobby — wallet disconnected\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/lord-of-rngs\");\n\n      // Wait for lobby to render (round cards or \"No open rounds\" message)\n      await stablePage.waitForSelector(\".lotr-tier-lobby\", { timeout: 10_000 });\n\n      await expect(stablePage).toHaveScreenshot(\"lotr-lobby-disconnected.png\", { fullPage: true });\n    });\n\n    test(\"round selected — shows sidebar and round view\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/lord-of-rngs\");\n\n      // Wait for lobby to render\n      await stablePage.waitForSelector(\".lotr-tier-lobby\", { timeout: 10_000 });\n\n      // Click the first round card if available\n      const card = stablePage.locator(\".lotr-tier-card\").first();\n      if (await card.isVisible({ timeout: 3_000 }).catch(() => false)) {\n        await card.click();\n        await stablePage.waitForSelector(\".lotr-sidebar\", { timeout: 5_000 });\n      }\n\n      // Settle UI transitions\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\"lotr-tier-selected.png\", { fullPage: true });\n    });\n\n    test(\"round selected — wallet connected with sidebar controls\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/lord-of-rngs\");\n\n      // Wait for lobby\n      await stablePage.waitForSelector(\".lotr-tier-lobby\", { timeout: 10_000 });\n\n      // Connect wallet\n      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n      await stablePage.waitForSelector(\".rng-wallet-button--connected\", { timeout: 5_000 });\n\n      // Click first round card if available\n      const card = stablePage.locator(\".lotr-tier-card\").first();\n      if (await card.isVisible({ timeout: 3_000 }).catch(() => false)) {\n        await card.click();\n        await stablePage.waitForSelector(\".lotr-sidebar\", { timeout: 5_000 });\n      }\n\n      // Re-inject animation freeze CSS after interactions\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      // Settle UI\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\"lotr-tier-connected.png\", { fullPage: true });\n    });\n\n    test(\"back to lobby — human navigates back from round view\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/lord-of-rngs\");\n\n      // Wait for lobby\n      await stablePage.waitForSelector(\".lotr-tier-lobby\", { timeout: 10_000 });\n\n      // Select a round if available\n      const card = stablePage.locator(\".lotr-tier-card\").first();\n      if (await card.isVisible({ timeout: 3_000 }).catch(() => false)) {\n        await card.click();\n        await stablePage.waitForSelector(\".lotr-sidebar\", { timeout: 5_000 });\n\n        // Click back button to return to lobby\n        const backBtn = stablePage.getByRole(\"button\", { name: /back to lobby/i });\n        if (await backBtn.isVisible({ timeout: 3_000 }).catch(() => false)) {\n          await backBtn.click();\n        }\n      }\n\n      // Wait for lobby to reappear\n      await stablePage.waitForSelector(\".lotr-tier-lobby\", { timeout: 5_000 });\n\n      // Settle\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\"lotr-back-to-lobby.png\", { fullPage: true });\n    });\n  });\n\n  test.describe(\"Close Call page\", () => {\n    test(\"wallet disconnected\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/close-call\");\n      await expect(stablePage).toHaveScreenshot(\"closecall-disconnected.png\", { fullPage: true });\n    });\n\n    test(\"wallet connected\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/close-call\");\n\n      // Click the wallet connect button\n      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n\n      // Wait for connected state\n      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n        timeout: 5000,\n      });\n\n      // Re-inject animation freeze CSS (connect flow may have triggered transitions)\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      // Settle time for UI to stabilize\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\"closecall-connected.png\", { fullPage: true });\n    });\n  });\n\n  test.describe(\"Referrals page\", () => {\n    test(\"wallet disconnected\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/referrals\");\n\n      // Wait for the connect prompt to render\n      await stablePage.waitForSelector(\".referral-page__connect\", {\n        timeout: 5000,\n      });\n\n      await expect(stablePage).toHaveScreenshot(\"referrals-disconnected.png\", { fullPage: true });\n    });\n\n    test(\"wallet connected\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n\n      // Mock all backend API calls (no backend in visual tests).\n      // Auth endpoints return valid tokens; referral endpoints return empty data.\n      const futureDate = new Date(Date.now() + 86_400_000).toISOString();\n      await stablePage.route((url) => url.pathname.endsWith(\"/auth/challenge\"), (route) =>\n        route.fulfill({\n          status: 200,\n          contentType: \"application/json\",\n          body: JSON.stringify({\n            nonce: \"visual-test-nonce\",\n            message: \"Sign this message to authenticate with TAUNT.\",\n            expiresAt: futureDate,\n          }),\n        }),\n      );\n      await stablePage.route((url) => url.pathname.endsWith(\"/auth/verify\"), (route) =>\n        route.fulfill({\n          status: 200,\n          contentType: \"application/json\",\n          body: JSON.stringify({\n            accessToken: \"visual-test-token\",\n            accessExpiresAt: futureDate,\n            refreshToken: \"visual-test-refresh\",\n            refreshExpiresAt: futureDate,\n          }),\n        }),\n      );\n      await stablePage.route((url) => url.pathname === \"/referral/code\", (route) =>\n        route.fulfill({ status: 404, contentType: \"application/json\", body: JSON.stringify({ error: \"Not found\" }) }),\n      );\n      await stablePage.route((url) => url.pathname === \"/referral/stats\", (route) =>\n        route.fulfill({\n          status: 200,\n          contentType: \"application/json\",\n          body: JSON.stringify({\n            referredCount: 0,\n            activeCount: 0,\n            totalVolumeLamports: \"0\",\n            totalEarnedLamports: \"0\",\n            totalRebateLamports: \"0\",\n            pendingLamports: \"0\",\n          }),\n        }),\n      );\n      await stablePage.route((url) => url.pathname.startsWith(\"/referral/earnings\"), (route) =>\n        route.fulfill({\n          status: 200,\n          contentType: \"application/json\",\n          body: JSON.stringify({ items: [], pagination: { page: 1, totalPages: 1 } }),\n        }),\n      );\n\n      await stablePage.goto(\"/referrals\");\n\n      // Click the wallet connect button\n      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n\n      // Wait for connected state\n      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n        timeout: 5000,\n      });\n\n      // Wait for authenticated content to render (auth flow includes mock latency)\n      await stablePage.waitForSelector(\".referral-page__content\", {\n        timeout: 15000,\n      });\n\n      // Re-inject animation freeze CSS (connect flow may have triggered transitions)\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      // Settle time for UI to stabilize\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\"referrals-connected.png\", { fullPage: true });\n    });\n  });\n\n  test.describe(\"Coinflip page\", () => {\n    test(\"wallet disconnected\", async ({ stablePage }) => {\n      // Clear any persisted wallet state to ensure disconnected\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/coinflip\");\n      await expect(stablePage).toHaveScreenshot(\"coinflip-disconnected.png\", { fullPage: true });\n    });\n\n    test(\"wallet connected\", async ({ stablePage }) => {\n      // Clear persisted state first so connect generates fresh from seeded PRNG\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/coinflip\");\n\n      // Click the wallet connect button\n      await stablePage.locator(\".rng-wallet-button--disconnected\").click();\n\n      // Wait for connected state\n      await stablePage.waitForSelector(\".rng-wallet-button--connected\", {\n        timeout: 5000,\n      });\n\n      // Re-inject animation freeze CSS (connect flow may have triggered transitions)\n      await stablePage.addStyleTag({\n        content: `\n          *, *::before, *::after {\n            animation-duration: 0s !important;\n            animation-delay: 0s !important;\n            transition-duration: 0s !important;\n            transition-delay: 0s !important;\n            scroll-behavior: auto !important;\n          }\n          svg { animation-play-state: paused !important; }\n        `,\n      });\n\n      // Settle time for UI to stabilize\n      await stablePage.waitForTimeout(300);\n\n      await expect(stablePage).toHaveScreenshot(\"coinflip-connected.png\", { fullPage: true });\n    });\n\n    test(\"error toast below middle container\", async ({ stablePage }) => {\n      await stablePage.addInitScript(() => {\n        localStorage.removeItem(\"rng-utopia-mock-wallet\");\n      });\n      await stablePage.goto(\"/coinflip\");\n\n      // Inject a representative error toast at runtime so placement is snapshot-tested.\n      await stablePage.evaluate(() => {\n        const existing = document.querySelector(\".coinflip-error-toast\");\n        if (existing) existing.remove();\n\n        const wrapper = document.createElement(\"div\");\n        wrapper.className = \"coinflip-error-toast\";\n\n        const toast = document.createElement(\"div\");\n        toast.className = \"rng-toast rng-toast--error\";\n        toast.setAttribute(\"role\", \"alert\");\n\n        const message = document.createElement(\"span\");\n        message.className = \"rng-toast__message\";\n        message.textContent = \"Transaction cancelled by user.\";\n\n        const close = document.createElement(\"button\");\n        close.className = \"rng-toast__close\";\n        close.setAttribute(\"type\", \"button\");\n        close.textContent = \"×\";\n\n        toast.append(message, close);\n        wrapper.appendChild(toast);\n        document.body.appendChild(wrapper);\n      });\n\n      await stablePage.waitForTimeout(300);\n      await expect(stablePage).toHaveScreenshot(\"coinflip-error-toast-position.png\", { fullPage: true });\n    });\n  });\n});\n","structuredPatch":[{"oldStart":302,"oldLines":61,"newStart":302,"newLines":51,"lines":["     });"," ","     test(\"wallet connected\", async ({ stablePage }) => {","+      // Intercept fetch at the JS level to mock auth + referral API.","+      // This is more reliable than page.route() for visual tests because it","+      // runs synchronously inside the browser context.","       await stablePage.addInitScript(() => {","         localStorage.removeItem(\"rng-utopia-mock-wallet\");","+","+        const futureDate = new Date(Date.now() + 86_400_000).toISOString();","+        const originalFetch = window.fetch;","+        window.fetch = async (input: RequestInfo | URL, init?: RequestInit) => {","+          const url = typeof input === \"string\" ? input : input instanceof URL ? input.href : input.url;","+          if (url.includes(\"/auth/challenge\")) {","+            return new Response(JSON.stringify({","+              nonce: \"visual-test-nonce\",","+              message: \"Sign this message to authenticate with TAUNT.\",","+              expiresAt: futureDate,","+            }), { status: 200, headers: { \"Content-Type\": \"application/json\" } });","+          }","+          if (url.includes(\"/auth/verify\")) {","+            return new Response(JSON.stringify({","+              accessToken: \"visual-test-token\",","+              accessExpiresAt: futureDate,","+              refreshToken: \"visual-test-refresh\",","+              refreshExpiresAt: futureDate,","+            }), { status: 200, headers: { \"Content-Type\": \"application/json\" } });","+          }","+          if (url.includes(\"/referral/code\") && (!init || init.method === \"GET\" || !init.method)) {","+            return new Response(JSON.stringify({ err