{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G2X1ucjq5k3ZrztbsLp8Nu","type":"tool_result","content":"   140→    app.route(\n   141→      \"/fairness/coinflip\",\n   142→      createCoinflipRoutes({\n   143→        db,\n   144→        connection: mockConn as unknown as Connection,\n   145→        serverKeypair,\n   146→      }),\n   147→    );\n   148→    app.route(\n   149→      \"/fairness/lord\",\n   150→      createLordRoutes({\n   151→        db,\n   152→        connection: mockConn as unknown as Connection,\n   153→        serverKeypair,\n   154→      }),\n   155→    );\n   156→\n   157→    app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n   158→\n   159→    app.route(\n   160→      \"/health\",\n   161→      createHealthRoutes({\n   162→        db,\n   163→        connection: mockConn as unknown as Connection,\n   164→        serverKey: serverKeypair.publicKey,\n   165→        isWorkerRunning: () => true,\n   166→        minSolBalance: 0.1,\n   167→      }),\n   168→    );\n   169→\n   170→    return app;\n   171→  }\n   172→\n   173→  // -----------------------------------------------------------------------\n   174→  // POST /fairness/coinflip/create\n   175→  // -----------------------------------------------------------------------\n   176→\n   177→  describe(\"POST /fairness/coinflip/create\", () => {\n   178→    it(\"returns 200 with valid JWT\", async () => {\n   179→      const app = buildApp();\n   180→      const wallet = creatorKeypair.publicKey.toBase58();\n   181→      const token = await makeJwt(wallet);\n   182→      const body = makeBody(wallet);\n   183→\n   184→      const res = await app.request(\"/fairness/coinflip/create\", {\n   185→        method: \"POST\",\n   186→        headers: {\n   187→          \"Content-Type\": \"application/json\",\n   188→          \"Authorization\": `Bearer ${token}`,\n   189→        },\n   190→        body: JSON.stringify(body),\n   191→      });\n   192→\n   193→      expect(res.status).toBe(200);\n   194→      const json = (await res.json()) as Record<string, unknown>;\n   195→      expect(json.transaction).toBeDefined();\n   196→      expect(typeof json.transaction).toBe(\"string\");\n   197→      expect(json.matchPda).toBeDefined();\n   198→      expect(typeof json.matchPda).toBe(\"string\");\n   199→      expect(json.commitment).toBeDefined();\n   200→      expect(typeof json.commitment).toBe(\"string\");\n   201→      expect(json.lastValidBlockHeight).toBeDefined();\n   202→      expect(typeof json.lastValidBlockHeight).toBe(\"number\");\n   203→      // Commitment should be 64 hex chars (32 bytes)\n   204→      expect((json.commitment as string).length).toBe(64);\n   205→    });\n   206→\n   207→    it(\"returns 401 with missing JWT\", async () => {\n   208→      const app = buildApp();\n   209→      const wallet = creatorKeypair.publicKey.toBase58();\n   210→      const body = makeBody(wallet);\n   211→\n   212→      const res = await app.request(\"/fairness/coinflip/create\", {\n   213→        method: \"POST\",\n   214→        headers: { \"Content-Type\": \"application/json\" },\n   215→        body: JSON.stringify(body),\n   216→      });\n   217→\n   218→      expect(res.status).toBe(401);\n   219→      const json = (await res.json()) as Record<string, unknown>;\n   220→      expect(json.error).toBeDefined();\n   221→    });\n   222→\n   223→    it(\"returns 401 with expired JWT\", async () => {\n   224→      const app = buildApp();\n   225→      const wallet = creatorKeypair.publicKey.toBase58();\n   226→      const token = await makeJwt(wallet, { expiresIn: -10 });\n   227→      const body = makeBody(wallet);\n   228→\n   229→      const res = await app.request(\"/fairness/coinflip/create\", {\n   230→        method: \"POST\",\n   231→        headers: {\n   232→          \"Content-Type\": \"application/json\",\n   233→          \"Authorization\": `Bearer ${token}`,\n   234→        },\n   235→        body: JSON.stringify(body),\n   236→      });\n   237→\n   238→      expect(res.status).toBe(401);\n   239→      const json = (await res.json()) as Record<string, unknown>;\n   240→      expect(json.error).toBeDefined();\n   241→    });\n   242→\n   243→    it(\"returns 403 when body wallet mismatches JWT wallet\", async () => {\n   244→      const app = buildApp();\n   245→      const wallet = creatorKeypair.publicKey.toBase58();\n   246→      const otherWallet = Keypair.generate().publicKey.toBase58();\n   247→      const token = await makeJwt(wallet);\n   248→      const body = makeBody(otherWallet); // Different wallet in body\n   249→\n   250→      const res = await app.request(\"/fairness/coinflip/create\", {\n   251→        method: \"POST\",\n   252→        headers: {\n   253→          \"Content-Type\": \"application/json\",\n   254→          \"Authorization\": `Bearer ${token}`,\n   255→        },\n   256→        body: JSON.stringify(body),\n   257→      });\n   258→\n   259→      expect(res.status).toBe(403);\n   260→    });\n   261→\n   262→    it(\"returns 409 with duplicate PDA (match ID collision)\", async () => {\n   263→      const app = buildApp();\n   264→      const wallet = creatorKeypair.publicKey.toBase58();\n   265→\n   266→      // First request — should succeed\n   267→      const token1 = await makeJwt(wallet);\n   268→      const body1 = makeBody(wallet);\n   269→      const res1 = await app.request(\"/fairness/coinflip/create\", {\n   270→        method: \"POST\",\n   271→        headers: {\n   272→          \"Content-Type\": \"application/json\",\n   273→          \"Authorization\": `Bearer ${token1}`,\n   274→        },\n   275→        body: JSON.stringify(body1),\n   276→      });\n   277→      expect(res1.status).toBe(200);\n   278→      const json1 = (await res1.json()) as { matchPda: string };\n   279→\n   280→      // Manually insert a second round with a similar PDA to force the collision\n   281→      const fakeSecret = Buffer.alloc(32, 0x01);\n   282→      const fakeCommitment = Buffer.alloc(32, 0x02);\n   283→      await rawSql`\n   284→        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase)\n   285→        VALUES (${json1.matchPda + \"X\"}, 'coinflip', ${wallet}, ${creatorKeypair.publicKey.toBase58()},\n   286→                ${fakeSecret}, ${fakeCommitment}, ${AMOUNT_LAMPORTS}, ${SIDE_HEADS}, ${\"deadbeefcafebabe\"}, 'created')\n   287→      `;\n   288→    });\n   289→\n   290→    it(\"returns 429 when rate limit exceeded\", async () => {\n   291→      // Create app with very low per-wallet limit\n   292→      const app = buildApp({ perWallet: 2, global: 100 });\n   293→      const wallet = creatorKeypair.publicKey.toBase58();\n   294→\n   295→      // Send 2 requests (within limit)\n   296→      for (let i = 0; i < 2; i++) {\n   297→        const token = await makeJwt(wallet);\n   298→        const body = makeBody(wallet);\n   299→        const res = await app.request(\"/fairness/coinflip/create\", {\n   300→          method: \"POST\",\n   301→          headers: {\n   302→            \"Content-Type\": \"application/json\",\n   303→            \"Authorization\": `Bearer ${token}`,\n   304→          },\n   305→          body: JSON.stringify(body),\n   306→        });\n   307→        expect(res.status).toBe(200);\n   308→      }\n   309→\n   310→      // Third request should be rate-limited\n   311→      const token3 = await makeJwt(wallet);\n   312→      const body3 = makeBody(wallet);\n   313→      const res3 = await app.request(\"/fairness/coinflip/create\", {\n   314→        method: \"POST\",\n   315→        headers: {\n   316→          \"Content-Type\": \"application/json\",\n   317→          \"Authorization\": `Bearer ${token3}`,\n   318→        },\n   319→        body: JSON.stringify(body3),\n   320→      });\n   321→      expect(res3.status).toBe(429);\n   322→      expect(res3.headers.get(\"Retry-After\")).toBeDefined();\n   323→      const json = (await res3.json()) as Record<string, unknown>;\n   324→      expect(json.error).toContain(\"Too many\");\n   325→    });\n   326→  });\n   327→\n   328→  describe(\"POST /fairness/lord/create\", () => {\n   329→    it(\"returns 200 with valid JWT\", async () => {\n   330→      const app = buildApp();\n   331→      const wallet = creatorKeypair.publicKey.toBase58();\n   332→      const token = await makeJwt(wallet);\n   333→\n   334→      const res = await app.request(\"/fairness/lord/create\", {\n   335→        method: \"POST\",\n   336→        headers: {\n   337→          \"Content-Type\": \"application/json\",\n   338→          Authorization: `Bearer ${token}`,\n   339→        },"}]},"parent_tool_use_id":"toolu_017bgrWZXudT5RyeVbZm3geb","session_id":"e377e535-4c51-477c-a8e7-f05957c224f0","uuid":"6db871d1-94cf-4ba6-9d4e-e3e3251c4a7a","timestamp":"2026-03-25T15:20:36.248Z"}
