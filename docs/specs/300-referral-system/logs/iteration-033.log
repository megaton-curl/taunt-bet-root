{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_018nTYzb91GmAmrssZ5cwPQN","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01MdqqvbKcF14EYBXAnyqoa8","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/endpoints.test.ts","old_string":"    app.route(\n      \"/health\",\n      createHealthRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKey: serverKeypair.publicKey,\n        isWorkerRunning: () => true,\n        minSolBalance: 0.1,\n      }),\n    );","new_string":"    app.route(\n      \"/health\",\n      createHealthRoutes({\n        db,\n        sql: rawSql,\n        connection: mockConn as unknown as Connection,\n        serverKey: serverKeypair.publicKey,\n        isWorkerRunning: () => true,\n        minSolBalance: 0.1,\n      }),\n    );"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3086,"cache_read_input_tokens":62202,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3086},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e377e535-4c51-477c-a8e7-f05957c224f0","uuid":"9ee31897-d0e1-43ee-9f70-d0b6634de701"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MdqqvbKcF14EYBXAnyqoa8","type":"tool_result","content":"The file /workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/endpoints.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"e377e535-4c51-477c-a8e7-f05957c224f0","uuid":"9f7e4177-34e3-4b0a-a053-5ae2b5324202","timestamp":"2026-03-25T15:21:51.075Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/endpoints.test.ts","oldString":"    app.route(\n      \"/health\",\n      createHealthRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKey: serverKeypair.publicKey,\n        isWorkerRunning: () => true,\n        minSolBalance: 0.1,\n      }),\n    );","newString":"    app.route(\n      \"/health\",\n      createHealthRoutes({\n        db,\n        sql: rawSql,\n        connection: mockConn as unknown as Connection,\n        serverKey: serverKeypair.publicKey,\n        isWorkerRunning: () => true,\n        minSolBalance: 0.1,\n      }),\n    );","originalFile":"/**\n * HTTP endpoint tests — exercises the full middleware stack (rate limit + JWT auth)\n * and route handlers for all endpoints:\n *\n * POST /fairness/coinflip/create:\n *   - 200 with valid JWT\n *   - 401 with missing JWT\n *   - 401 with expired JWT\n *   - 409 with duplicate PDA (same wallet + match ID collision)\n *   - 429 when rate limit exceeded\n *\n * GET /fairness/rounds/:pda:\n *   - 200 for known PDA\n *   - 404 for unknown PDA\n *\n * GET /health:\n *   - 200 with expected fields\n */\n\nimport { describe, it, beforeAll, afterAll, beforeEach, expect } from \"vitest\";\nimport { Hono } from \"hono\";\nimport { Keypair, LAMPORTS_PER_SOL } from \"@solana/web3.js\";\nimport type { Connection } from \"@solana/web3.js\";\nimport { SignJWT } from \"jose\";\nimport postgres from \"postgres\";\nimport { createDb, type Db } from \"../db.js\";\nimport { createCoinflipRoutes } from \"../routes/create.js\";\nimport { createLordRoutes } from \"../routes/lord-create.js\";\nimport { createRoundsRoutes } from \"../routes/rounds.js\";\nimport { createHealthRoutes } from \"../routes/health.js\";\nimport { createJwtAuthMiddleware } from \"../middleware/jwt-auth.js\";\nimport { createRateLimitMiddleware } from \"../middleware/rate-limit.js\";\n\n// ---------------------------------------------------------------------------\n// Constants\n// ---------------------------------------------------------------------------\n\nconst DATABASE_URL = process.env.DATABASE_URL ?? \"postgresql://vscode@localhost:5432/rng_utopia_dev\";\nconst AMOUNT_LAMPORTS = 5_000_000; // 0.005 SOL\nconst SIDE_HEADS = 0;\nconst JWT_SECRET = new TextEncoder().encode(\"test-secret-for-endpoint-tests\");\n\n// ---------------------------------------------------------------------------\n// Minimal mock Connection (only what routes + health need)\n// ---------------------------------------------------------------------------\n\nclass MockConnection {\n  async getLatestBlockhash() {\n    return {\n      blockhash: \"EETubP5AKHgjPAhzPkA6E6knR1eLPYkevFhfMsaS8CgZ\",\n      lastValidBlockHeight: 999_999,\n    };\n  }\n\n  async getAccountInfo() {\n    return null;\n  }\n\n  async getBalance() {\n    return 1.5 * LAMPORTS_PER_SOL;\n  }\n}\n\n// ---------------------------------------------------------------------------\n// JWT helper\n// ---------------------------------------------------------------------------\n\nasync function makeJwt(wallet: string, opts?: { expiresIn?: number }) {\n  const now = Math.floor(Date.now() / 1000);\n  return new SignJWT({ sub: wallet })\n    .setProtectedHeader({ alg: \"HS256\" })\n    .setIssuedAt(now)\n    .setExpirationTime(now + (opts?.expiresIn ?? 3600))\n    .sign(JWT_SECRET);\n}\n\nfunction makeBody(wallet: string, overrides?: Partial<{ amountLamports: number; side: number }>) {\n  return {\n    wallet,\n    amountLamports: overrides?.amountLamports ?? AMOUNT_LAMPORTS,\n    side: overrides?.side ?? SIDE_HEADS,\n  };\n}\n\nfunction makeLordBody(wallet: string, overrides?: Partial<{ amountLamports: number }>) {\n  return {\n    wallet,\n    amountLamports: overrides?.amountLamports ?? AMOUNT_LAMPORTS,\n  };\n}\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"HTTP endpoint tests\", () => {\n  let db: Db;\n  let rawSql: ReturnType<typeof postgres>;\n  let mockConn: MockConnection;\n\n  const serverKeypair = Keypair.generate();\n  const creatorKeypair = Keypair.generate();\n\n  beforeAll(async () => {\n    db = createDb(DATABASE_URL);\n    rawSql = postgres(DATABASE_URL);\n  });\n\n  afterAll(async () => {\n    await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE rounds, operator_events RESTART IDENTITY`;\n    mockConn = new MockConnection();\n  });\n\n  // -----------------------------------------------------------------------\n  // Helper: build a fresh Hono app with full middleware stack\n  // -----------------------------------------------------------------------\n\n  function buildApp(opts?: { perWallet?: number; global?: number }) {\n    const app = new Hono();\n\n    app.use(\n      \"/fairness/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n    );\n\n    app.use(\n      \"/fairness/*\",\n      createRateLimitMiddleware({\n        perWallet: opts?.perWallet ?? 10,\n        global: opts?.global ?? 100,\n        windowMs: 60_000,\n      }),\n    );\n\n    app.route(\n      \"/fairness/coinflip\",\n      createCoinflipRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n    app.route(\n      \"/fairness/lord\",\n      createLordRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n\n    app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n\n    app.route(\n      \"/health\",\n      createHealthRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKey: serverKeypair.publicKey,\n        isWorkerRunning: () => true,\n        minSolBalance: 0.1,\n      }),\n    );\n\n    return app;\n  }\n\n  // -----------------------------------------------------------------------\n  // POST /fairness/coinflip/create\n  // -----------------------------------------------------------------------\n\n  describe(\"POST /fairness/coinflip/create\", () => {\n    it(\"returns 200 with valid JWT\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const token = await makeJwt(wallet);\n      const body = makeBody(wallet);\n\n      const res = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${token}`,\n        },\n        body: JSON.stringify(body),\n      });\n\n      expect(res.status).toBe(200);\n      const json = (await res.json()) as Record<string, unknown>;\n      expect(json.transaction).toBeDefined();\n      expect(typeof json.transaction).toBe(\"string\");\n      expect(json.matchPda).toBeDefined();\n      expect(typeof json.matchPda).toBe(\"string\");\n      expect(json.commitment).toBeDefined();\n      expect(typeof json.commitment).toBe(\"string\");\n      expect(json.lastValidBlockHeight).toBeDefined();\n      expect(typeof json.lastValidBlockHeight).toBe(\"number\");\n      // Commitment should be 64 hex chars (32 bytes)\n      expect((json.commitment as string).length).toBe(64);\n    });\n\n    it(\"returns 401 with missing JWT\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const body = makeBody(wallet);\n\n      const res = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify(body),\n      });\n\n      expect(res.status).toBe(401);\n      const json = (await res.json()) as Record<string, unknown>;\n      expect(json.error).toBeDefined();\n    });\n\n    it(\"returns 401 with expired JWT\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const token = await makeJwt(wallet, { expiresIn: -10 });\n      const body = makeBody(wallet);\n\n      const res = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${token}`,\n        },\n        body: JSON.stringify(body),\n      });\n\n      expect(res.status).toBe(401);\n      const json = (await res.json()) as Record<string, unknown>;\n      expect(json.error).toBeDefined();\n    });\n\n    it(\"returns 403 when body wallet mismatches JWT wallet\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const otherWallet = Keypair.generate().publicKey.toBase58();\n      const token = await makeJwt(wallet);\n      const body = makeBody(otherWallet); // Different wallet in body\n\n      const res = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${token}`,\n        },\n        body: JSON.stringify(body),\n      });\n\n      expect(res.status).toBe(403);\n    });\n\n    it(\"returns 409 with duplicate PDA (match ID collision)\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n\n      // First request — should succeed\n      const token1 = await makeJwt(wallet);\n      const body1 = makeBody(wallet);\n      const res1 = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${token1}`,\n        },\n        body: JSON.stringify(body1),\n      });\n      expect(res1.status).toBe(200);\n      const json1 = (await res1.json()) as { matchPda: string };\n\n      // Manually insert a second round with a similar PDA to force the collision\n      const fakeSecret = Buffer.alloc(32, 0x01);\n      const fakeCommitment = Buffer.alloc(32, 0x02);\n      await rawSql`\n        INSERT INTO rounds (pda, game, creator, server_key, secret, commitment, amount_lamports, side, match_id, phase)\n        VALUES (${json1.matchPda + \"X\"}, 'coinflip', ${wallet}, ${creatorKeypair.publicKey.toBase58()},\n                ${fakeSecret}, ${fakeCommitment}, ${AMOUNT_LAMPORTS}, ${SIDE_HEADS}, ${\"deadbeefcafebabe\"}, 'created')\n      `;\n    });\n\n    it(\"returns 429 when rate limit exceeded\", async () => {\n      // Create app with very low per-wallet limit\n      const app = buildApp({ perWallet: 2, global: 100 });\n      const wallet = creatorKeypair.publicKey.toBase58();\n\n      // Send 2 requests (within limit)\n      for (let i = 0; i < 2; i++) {\n        const token = await makeJwt(wallet);\n        const body = makeBody(wallet);\n        const res = await app.request(\"/fairness/coinflip/create\", {\n          method: \"POST\",\n          headers: {\n            \"Content-Type\": \"application/json\",\n            \"Authorization\": `Bearer ${token}`,\n          },\n          body: JSON.stringify(body),\n        });\n        expect(res.status).toBe(200);\n      }\n\n      // Third request should be rate-limited\n      const token3 = await makeJwt(wallet);\n      const body3 = makeBody(wallet);\n      const res3 = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${token3}`,\n        },\n        body: JSON.stringify(body3),\n      });\n      expect(res3.status).toBe(429);\n      expect(res3.headers.get(\"Retry-After\")).toBeDefined();\n      const json = (await res3.json()) as Record<string, unknown>;\n      expect(json.error).toContain(\"Too many\");\n    });\n  });\n\n  describe(\"POST /fairness/lord/create\", () => {\n    it(\"returns 200 with valid JWT\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const token = await makeJwt(wallet);\n\n      const res = await app.request(\"/fairness/lord/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          Authorization: `Bearer ${token}`,\n        },\n        body: JSON.stringify(makeLordBody(wallet)),\n      });\n\n      expect(res.status).toBe(200);\n      const json = (await res.json()) as Record<string, unknown>;\n      expect(typeof json.transaction).toBe(\"string\");\n      expect(typeof json.roundPda).toBe(\"string\");\n      expect(typeof json.matchId).toBe(\"string\");\n      expect(typeof json.commitment).toBe(\"string\");\n      expect(typeof json.lastValidBlockHeight).toBe(\"number\");\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /fairness/rounds/:pda\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /fairness/rounds/:pda\", () => {\n    it(\"returns 200 for known PDA\", async () => {\n      const app = buildApp();\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const token = await makeJwt(wallet);\n      const body = makeBody(wallet);\n\n      // Create a round first\n      const createRes = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${token}`,\n        },\n        body: JSON.stringify(body),\n      });\n      expect(createRes.status).toBe(200);\n      const createJson = (await createRes.json()) as { matchPda: string; commitment: string };\n\n      // Fetch the round (GET — no auth needed)\n      const roundRes = await app.request(`/fairness/rounds/${createJson.matchPda}`);\n      expect(roundRes.status).toBe(200);\n\n      const roundJson = (await roundRes.json()) as Record<string, unknown>;\n      expect(roundJson.pda).toBe(createJson.matchPda);\n      expect(roundJson.game).toBe(\"coinflip\");\n      expect(roundJson.phase).toBe(\"created\");\n      expect(roundJson.creator).toBe(wallet);\n      expect(roundJson.commitment).toBe(createJson.commitment);\n      expect(roundJson.amountLamports).toBe(AMOUNT_LAMPORTS);\n      expect(roundJson.side).toBe(SIDE_HEADS);\n      expect(roundJson.createdAt).toBeDefined();\n      expect(roundJson.updatedAt).toBeDefined();\n      // Unsettled: secret and verification should NOT be present\n      expect(roundJson.secret).toBeUndefined();\n      expect(roundJson.verification).toBeUndefined();\n    });\n\n    it(\"returns 404 for unknown PDA\", async () => {\n      const app = buildApp();\n      const unknownPda = Keypair.generate().publicKey.toBase58();\n      const res = await app.request(`/fairness/rounds/${unknownPda}`);\n      expect(res.status).toBe(404);\n      const json = (await res.json()) as Record<string, unknown>;\n      expect(json.error).toContain(\"not found\");\n    });\n  });\n\n  // -----------------------------------------------------------------------\n  // GET /health\n  // -----------------------------------------------------------------------\n\n  describe(\"GET /health\", () => {\n    it(\"returns 200 with expected fields\", async () => {\n      const app = buildApp();\n      const res = await app.request(\"/health\");\n      expect(res.status).toBe(200);\n\n      const json = (await res.json()) as Record<string, unknown>;\n      expect(json.status).toBe(\"ok\");\n      expect(json.version).toBe(\"0.1.0\");\n      expect(json.serverKey).toBe(serverKeypair.publicKey.toBase58());\n      expect(typeof json.solBalance).toBe(\"number\");\n      expect(json.solBalance).toBe(1.5);\n      expect(json.dbConnected).toBe(true);\n      expect(json.workerRunning).toBe(true);\n      expect(typeof json.unsettledCount).toBe(\"number\");\n      expect(typeof json.oldestUnsettledAge).toBe(\"number\");\n    });\n\n    it(\"reflects unsettled round count\", async () => {\n      const app = buildApp();\n\n      // Create a round so there's an unsettled one\n      const wallet = creatorKeypair.publicKey.toBase58();\n      const token = await makeJwt(wallet);\n      const body = makeBody(wallet);\n      const createRes = await app.request(\"/fairness/coinflip/create\", {\n        method: \"POST\",\n        headers: {\n          \"Content-Type\": \"application/json\",\n          \"Authorization\": `Bearer ${token}`,\n        },\n        body: JSON.stringify(body),\n      });\n      expect(createRes.status).toBe(200);\n\n      const healthRes = await app.request(\"/health\");\n      expect(healthRes.status).toBe(200);\n      const json = (await healthRes.json()) as Record<string, unknown>;\n      expect(json.unsettledCount).toBe(1);\n    });\n  });\n});\n","structuredPatch":[{"oldStart":160,"oldLines":6,"newStart":160,"newLines":7,"lines":["       \"/health\",","       createHealthRoutes({","         db,","+        sql: rawSql,","         connection: mockConn as unknown as Connection,","         serverKey: serverKeypair.publicKey,","         isWorkerRunning: () => true,"]}],"userModified":false,"replaceAll":false}}
