ction: mockConn as unknown as Connection,\n   145→        serverKeypair,\n   146→      }),\n   147→    );\n   148→    app.route(\n   149→      \"/fairness/lord\",\n   150→      createLordRoutes({\n   151→        db,\n   152→        connection: mockConn as unknown as Connection,\n   153→        serverKeypair,\n   154→      }),\n   155→    );\n   156→\n   157→    app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n   158→\n   159→    app.route(\n   160→      \"/health\",\n   161→      createHealthRoutes({\n   162→        db,\n   163→        connection: mockConn as unknown as Connection,\n   164→        serverKey: serverKeypair.publicKey,\n   165→        isWorkerRunning: () => true,\n   166→        minSolBalance: 0.1,\n   167→      }),\n   168→    );\n   169→\n   170→    return app;\n   171→  }\n   172→\n   173→  // -----------------------------------------------------------------------\n   174→  // POST /fairness/coinflip/create"}]},"parent_tool_use_id":null,"session_id":"e377e535-4c51-477c-a8e7-f05957c224f0","uuid":"ce3b6d6c-7ecf-415a-b931-71c2d3c3cd4a","timestamp":"2026-03-25T15:21:44.484Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/sources/rng-utopia/services/backend/src/__tests__/endpoints.test.ts","content":"}\n\n// ---------------------------------------------------------------------------\n// Test suite\n// ---------------------------------------------------------------------------\n\ndescribe(\"HTTP endpoint tests\", () => {\n  let db: Db;\n  let rawSql: ReturnType<typeof postgres>;\n  let mockConn: MockConnection;\n\n  const serverKeypair = Keypair.generate();\n  const creatorKeypair = Keypair.generate();\n\n  beforeAll(async () => {\n    db = createDb(DATABASE_URL);\n    rawSql = postgres(DATABASE_URL);\n  });\n\n  afterAll(async () => {\n    await db.close();\n    await rawSql.end();\n  });\n\n  beforeEach(async () => {\n    await rawSql`TRUNCATE rounds, operator_events RESTART IDENTITY`;\n    mockConn = new MockConnection();\n  });\n\n  // -----------------------------------------------------------------------\n  // Helper: build a fresh Hono app with full middleware stack\n  // -----------------------------------------------------------------------\n\n  function buildApp(opts?: { perWallet?: number; global?: number }) {\n    const app = new Hono();\n\n    app.use(\n      \"/fairness/*\",\n      createJwtAuthMiddleware({ jwtSecret: JWT_SECRET }),\n    );\n\n    app.use(\n      \"/fairness/*\",\n      createRateLimitMiddleware({\n        perWallet: opts?.perWallet ?? 10,\n        global: opts?.global ?? 100,\n        windowMs: 60_000,\n      }),\n    );\n\n    app.route(\n      \"/fairness/coinflip\",\n      createCoinflipRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n    app.route(\n      \"/fairness/lord\",\n      createLordRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKeypair,\n      }),\n    );\n\n    app.route(\"/fairness/rounds\", createRoundsRoutes({ db }));\n\n    app.route(\n      \"/health\",\n      createHealthRoutes({\n        db,\n        connection: mockConn as unknown as Connection,\n        serverKey: serverKeypair.publicKey,\n        isWorkerRunning: () => true,\n        minSolBalance: 0.1,\n      }),\n    );\n\n    return app;\n  }\n\n  // -----------------------------------------------------------------------\n  // POST /fairness/coinflip/create","numLines":85,"startLine":90,"totalLines":451}}}
