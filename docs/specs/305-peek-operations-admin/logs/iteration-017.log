  >\n155\t            Data unavailable: {loadError}\n156\t          </p>\n157\t        ) : null}\n158\t        <form\n159\t          style={{\n160\t            display: \"grid\",\n161\t            gap: \"0.75rem\",\n162\t            gridTemplateColumns: \"repeat(auto-fit, minmax(180px, 1fr))\",\n163\t            alignItems: \"end\",\n164\t          }}\n165\t        >\n166\t          <input name=\"query\" type=\"hidden\" value={params.query} />\n167\t\n168\t          <label style={fieldStyle}>\n169\t            <span>Sort</span>\n170\t            <select defaultValue={params.sort} name=\"sort\" style={inputStyle}>\n171\t              <option value=\"joinedAt\">Joined</option>\n172\t              <option value=\"refereeCount\">Referee count</option>\n173\t            </select>\n174\t          </label>\n175\t\n176\t          <label style={fieldStyle}>\n177\t            <span>Direction</span>\n178\t            <select defaultValue={params.direction} name=\"direction\" style={inputStyle}>\n179\t              <option value=\"desc\">Newest first</option>\n180\t              <option value=\"asc\">Oldest first</option>\n181\t            </select>\n182\t          </label>\n183\t\n184\t          <label style={checkboxStyle}>\n185\t            <input defaultChecked={params.filters.hasReferrer} name=\"hasReferrer\" type=\"checkbox\" value=\"true\" />\n186\t            <span>Has referrer</span>\n187\t          </label>\n188\t\n189\t          <label style={checkboxStyle}>\n190\t            <input defaultChecked={params.filters.hasReferees} name=\"hasReferees\" type=\"checkbox\" value=\"true\" />\n191\t            <span>Has referees</span>\n192\t          </label>\n193\t\n194\t          <label style={checkboxStyle}>\n195\t            <input defaultChecked={params.filters.hasCode} name=\"hasCode\" type=\"checkbox\" value=\"true\" />\n196\t            <span>Has code</span>\n197\t          </label>\n198\t\n199\t          <label style={checkboxStyle}>\n200\t            <input\n201\t   