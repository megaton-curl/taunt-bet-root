{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JJ6avT3MybUGag7ap9edoy","type":"tool_result","content":"1\t// Recent activity list (FR-3 command-center \"high-signal activity\").\n2\t//\n3\t// Browser-safe presentational component for the latest `operator_events` rows\n4\t// projected into `PeekRecentActivityItem` shape. Renders a dense list with the\n5\t// fields an operator scans first (time, event type, actor email, route +\n6\t// resource label). Empty state is operator-readable; non-null `error` renders\n7\t// `role=\"alert\"` and suppresses the list.\n8\t\n9\timport type { CSSProperties } from \"react\";\n10\timport Link from \"next/link\";\n11\timport type { PeekRecentActivityItem } from \"../lib/types/peek\";\n12\t\n13\texport type RecentActivityListProps = {\n14\t  items: ReadonlyArray<PeekRecentActivityItem>;\n15\t  error: string | null;\n16\t};\n17\t\n18\texport function RecentActivityList({ items, error }: RecentActivityListProps) {\n19\t  if (error) {\n20\t    return (\n21\t      <div role=\"alert\" style={errorBoxStyle}>\n22\t        Recent activity unavailable: {error}\n23\t      </div>\n24\t    );\n25\t  }\n26\t\n27\t  if (items.length === 0) {\n28\t    return (\n29\t      <div role=\"status\" style={emptyBoxStyle}>\n30\t        No recent operator activity recorded yet.\n31\t      </div>\n32\t    );\n33\t  }\n34\t\n35\t  return (\n36\t    <ul aria-label=\"Recent operator activity\" style={listStyle}>\n37\t      {items.map((item) => {\n38\t        const resourceLabel =\n39\t          item.resourceType && item.resourceId\n40\t            ? `${item.resourceType}:${item.resourceId}`\n41\t            : item.resourceType ?? item.resourceId ?? null;\n42\t        return (\n43\t          <li key={item.id} style={itemStyle}>\n44\t            <span style={timeStyle}>{item.createdAt}</span>\n45\t            <span style={typeStyle}>{item.eventType}</span>\n46\t            <span style={actorStyle}>{item.actorEmail ?? \"—\"}</span>\n47\t            <span style={resourceStyle}>\n48\t              {item.route ? (\n49\t                <Link href={item.route} style={routeStyle}>\n50\t                  {item.route}\n51\t                </Link>\n52\t              ) : null}\n53\t              {resourceLabel ? (\n54\t                <span style={resourceLabelStyle}>{resourceLabel}</span>\n55\t              ) : null}\n56\t            </span>\n57\t          </li>\n58\t        );\n59\t      })}\n60\t    </ul>\n61\t  );\n62\t}\n63\t\n64\tconst listStyle: CSSProperties = {\n65\t  margin: 0,\n66\t  padding: 0,\n67\t  listStyle: \"none\",\n68\t  border: \"1px solid #1e293b\",\n69\t  borderRadius: \"0.75rem\",\n70\t  background: \"#0b1220\",\n71\t  display: \"grid\",\n72\t};\n73\t\n74\tconst itemStyle: CSSProperties = {\n75\t  display: \"grid\",\n76\t  gridTemplateColumns:\n77\t    \"minmax(200px, auto) minmax(140px, auto) minmax(160px, 1fr) minmax(200px, 2fr)\",\n78\t  gap: \"0.75rem\",\n79\t  padding: \"0.5rem 0.75rem\",\n80\t  borderTop: \"1px solid #111827\",\n81\t  fontSize: \"0.8125rem\",\n82\t  color: \"#cbd5f5\",\n83\t};\n84\t\n85\tconst timeStyle: CSSProperties = {\n86\t  color: \"#94a3b8\",\n87\t  fontFamily: \"monospace\",\n88\t};\n89\t\n90\tconst typeStyle: CSSProperties = {\n91\t  fontWeight: 600,\n92\t};\n93\t\n94\tconst actorStyle: CSSProperties = {\n95\t  color: \"#cbd5f5\",\n96\t};\n97\t\n98\tconst resourceStyle: CSSProperties = {\n99\t  display: \"flex\",\n100\t  gap: \"0.5rem\",\n101\t  alignItems: \"center\",\n102\t  flexWrap: \"wrap\",\n103\t};\n104\t\n105\tconst routeStyle: CSSProperties = {\n106\t  color: \"#93c5fd\",\n107\t  textDecoration: \"none\",\n108\t};\n109\t\n110\tconst resourceLabelStyle: CSSProperties = {\n111\t  color: \"#94a3b8\",\n112\t  fontFamily: \"monospace\",\n113\t};\n114\t\n115\tconst emptyBoxStyle: CSSProperties = {\n116\t  padding: \"1rem\",\n117\t  borderRadius: \"0.75rem\",\n118\t  border: \"1px solid #1e293b\",\n119\t  background: \"#0b1220\",\n120\t  color: \"#94a3b8\",\n121\t  fontSize: \"0.875rem\",\n122\t};\n123\t\n124\tconst errorBoxStyle: CSSProperties = {\n125\t  margin: 0,\n126\t  padding: \"0.75rem 1rem\",\n127\t  borderRadius: \"0.75rem\",\n128\t  background: \"#3f1d1d\",\n129\t  color: \"#fecaca\",\n130\t};\n131\t"}]},"parent_tool_use_id":null,"session_id":"79b2f404-c98f-4d13-a0b5-57be01bc96a8","uuid":"532d511d-d22c-47ea-90cc-bb8e490c1efe","timestamp":"2026-04-25T11:37:05.284Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/recent-activity-list.tsx","content":"// Recent activity list (FR-3 command-center \"high-signal activity\").\n//\n// Browser-safe presentational component for the latest `operator_events` rows\n// projected into `PeekRecentActivityItem` shape. Renders a dense list with the\n// fields an operator scans first (time, event type, actor email, route +\n// resource label). Empty state is operator-readable; non-null `error` renders\n// `role=\"alert\"` and suppresses the list.\n\nimport type { CSSProperties } from \"react\";\nimport Link from \"next/link\";\nimport type { PeekRecentActivityItem } from \"../lib/types/peek\";\n\nexport type RecentActivityListProps = {\n  items: ReadonlyArray<PeekRecentActivityItem>;\n  error: string | null;\n};\n\nexport function RecentActivityList({ items, error }: RecentActivityListProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorBoxStyle}>\n        Recent activity unavailable: {error}\n      </div>\n    );\n  }\n\n  if (items.length === 0) {\n    return (\n      <div role=\"status\" style={emptyBoxStyle}>\n        No recent operator activity recorded yet.\n      </div>\n    );\n  }\n\n  return (\n    <ul aria-label=\"Recent operator activity\" style={listStyle}>\n      {items.map((item) => {\n        const resourceLabel =\n          item.resourceType && item.resourceId\n            ? `${item.resourceType}:${item.resourceId}`\n            : item.resourceType ?? item.resourceId ?? null;\n        return (\n          <li key={item.id} style={itemStyle}>\n            <span style={timeStyle}>{item.createdAt}</span>\n            <span style={typeStyle}>{item.eventType}</span>\n            <span style={actorStyle}>{item.actorEmail ?? \"—\"}</span>\n            <span style={resourceStyle}>\n              {item.route ? (\n                <Link href={item.route} style={routeStyle}>\n                  {item.route}\n                </Link>\n              ) : null}\n              {resourceLabel ? (\n                <span style={resourceLabelStyle}>{resourceLabel}</span>\n              ) : null}\n            </span>\n          </li>\n        );\n      })}\n    </ul>\n  );\n}\n\nconst listStyle: CSSProperties = {\n  margin: 0,\n  padding: 0,\n  listStyle: \"none\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n  background: \"#0b1220\",\n  display: \"grid\",\n};\n\nconst itemStyle: CSSProperties = {\n  display: \"grid\",\n  gridTemplateColumns:\n    \"minmax(200px, auto) minmax(140px, auto) minmax(160px, 1fr) minmax(200px, 2fr)\",\n  gap: \"0.75rem\",\n  padding: \"0.5rem 0.75rem\",\n  borderTop: \"1px solid #111827\",\n  fontSize: \"0.8125rem\",\n  color: \"#cbd5f5\",\n};\n\nconst timeStyle: CSSProperties = {\n  color: \"#94a3b8\",\n  fontFamily: \"monospace\",\n};\n\nconst typeStyle: CSSProperties = {\n  fontWeight: 600,\n};\n\nconst actorStyle: CSSProperties = {\n  color: \"#cbd5f5\",\n};\n\nconst resourceStyle: CSSProperties = {\n  display: \"flex\",\n  gap: \"0.5rem\",\n  alignItems: \"center\",\n  flexWrap: \"wrap\",\n};\n\nconst routeStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst resourceLabelStyle: CSSProperties = {\n  color: \"#94a3b8\",\n  fontFamily: \"monospace\",\n};\n\nconst emptyBoxStyle: CSSProperties = {\n  padding: \"1rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px solid #1e293b\",\n  background: \"#0b1220\",\n  color: \"#94a3b8\",\n  fontSize: \"0.875rem\",\n};\n\nconst errorBoxStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n","numLines":131,"startLine":1,"totalLines":131}}}
