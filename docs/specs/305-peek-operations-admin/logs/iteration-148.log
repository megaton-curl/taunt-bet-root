{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SG3TAAdCx6XskxaeE7dLHr","type":"tool_result","content":"1\t// Approved mutation registry (FR-14).\n2\t//\n3\t// The runner consumes a frozen registry keyed by stable action id. Each\n4\t// definition declares the FR-2 access-policy action id, the audit\n5\t// `resourceType` to record on `peek.change.applied`, a zod input schema, and\n6\t// an `execute` callback that runs inside a transaction (`sql.begin`) and\n7\t// returns the audit-friendly resource id + before/after change list.\n8\t//\n9\t// Adding a new approved mutation is a four-line change: import the\n10\t// definition, add it to the `entries` list, register the matching action id\n11\t// in `peek/src/server/access-policy.ts` (`PEEK_ACTION_RULES`) so the role\n12\t// check has a rule to find, and ship the matching frontend wiring iteration.\n13\t//\n14\t// Approved mutations land one at a time. The registered mutations to date are\n15\t// `kol_rate.update` (referral_kol_rates create/update) and\n16\t// `fraud_flag.status.update` (fraud_flags status transition); dogpile cancel\n17\t// and reward config edit ship in subsequent FR-14 iterations.\n18\t\n19\timport type { Sql } from \"postgres\";\n20\timport type { ZodTypeAny } from \"zod\";\n21\timport type { PeekAuditChange } from \"../../lib/types/peek\";\n22\timport { fraudFlagStatusUpdateMutation } from \"./fraud-flag\";\n23\timport { kolRateUpdateMutation } from \"./kol-rate\";\n24\t\n25\texport type PeekMutationActionId = string;\n26\t\n27\texport type PeekMutationActorContext = {\n28\t  email: string;\n29\t  route: string | null;\n30\t  requestId?: string | null;\n31\t};\n32\t\n33\texport type PeekMutationExecuteContext<TInput> = {\n34\t  input: TInput;\n35\t  sql: Sql;\n36\t  actor: PeekMutationActorContext;\n37\t};\n38\t\n39\texport type PeekMutationExecuteResult = {\n40\t  // Audit identifier for the row the mutation touched. `null` when the\n41\t  // mutation creates a new row whose id is not separately surfaced.\n42\t  resourceId: string | null;\n43\t  // Before/after diff persisted to the `peek.change.applied` audit payload.\n44\t  // `null` when the mutation does not produce a field-level diff (e.g.\n45\t  // a pure create).\n46\t  changes: ReadonlyArray<PeekAuditChange> | null;\n47\t};\n48\t\n49\texport type PeekMutationDefinition<TInput = unknown> = {\n50\t  actionId: PeekMutationActionId;\n51\t  resourceType: string;\n52\t  schema: ZodTypeAny;\n53\t  execute: (\n54\t    ctx: PeekMutationExecuteContext<TInput>,\n55\t  ) => Promise<PeekMutationExecuteResult>;\n56\t};\n57\t\n58\texport type PeekMutationRegistry = Readonly<\n59\t  Record<PeekMutationActionId, PeekMutationDefinition>\n60\t>;\n61\t\n62\tconst entries: ReadonlyArray<PeekMutationDefinition> = [\n63\t  kolRateUpdateMutation as PeekMutationDefinition,\n64\t  fraudFlagStatusUpdateMutation as PeekMutationDefinition,\n65\t];\n66\t\n67\texport const PEEK_MUTATIONS: PeekMutationRegistry = Object.freeze(\n68\t  entries.reduce<Record<string, PeekMutationDefinition>>((acc, def) => {\n69\t    acc[def.actionId] = def;\n70\t    return acc;\n71\t  }, {}),\n72\t);\n73\t\n74\texport function getPeekMutation(\n75\t  actionId: PeekMutationActionId,\n76\t  registry: PeekMutationRegistry = PEEK_MUTATIONS,\n77\t): PeekMutationDefinition | null {\n78\t  return registry[actionId] ?? null;\n79\t}\n80\t"}]},"parent_tool_use_id":null,"session_id":"d6b841b0-5eab-4233-bb67-840874dc8e96","uuid":"f4cbd5b1-5210-4ff7-ad56-0f2df73a1d90","timestamp":"2026-04-26T15:38:04.498Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/mutations/registry.ts","content":"// Approved mutation registry (FR-14).\n//\n// The runner consumes a frozen registry keyed by stable action id. Each\n// definition declares the FR-2 access-policy action id, the audit\n// `resourceType` to record on `peek.change.applied`, a zod input schema, and\n// an `execute` callback that runs inside a transaction (`sql.begin`) and\n// returns the audit-friendly resource id + before/after change list.\n//\n// Adding a new approved mutation is a four-line change: import the\n// definition, add it to the `entries` list, register the matching action id\n// in `peek/src/server/access-policy.ts` (`PEEK_ACTION_RULES`) so the role\n// check has a rule to find, and ship the matching frontend wiring iteration.\n//\n// Approved mutations land one at a time. The registered mutations to date are\n// `kol_rate.update` (referral_kol_rates create/update) and\n// `fraud_flag.status.update` (fraud_flags status transition); dogpile cancel\n// and reward config edit ship in subsequent FR-14 iterations.\n\nimport type { Sql } from \"postgres\";\nimport type { ZodTypeAny } from \"zod\";\nimport type { PeekAuditChange } from \"../../lib/types/peek\";\nimport { fraudFlagStatusUpdateMutation } from \"./fraud-flag\";\nimport { kolRateUpdateMutation } from \"./kol-rate\";\n\nexport type PeekMutationActionId = string;\n\nexport type PeekMutationActorContext = {\n  email: string;\n  route: string | null;\n  requestId?: string | null;\n};\n\nexport type PeekMutationExecuteContext<TInput> = {\n  input: TInput;\n  sql: Sql;\n  actor: PeekMutationActorContext;\n};\n\nexport type PeekMutationExecuteResult = {\n  // Audit identifier for the row the mutation touched. `null` when the\n  // mutation creates a new row whose id is not separately surfaced.\n  resourceId: string | null;\n  // Before/after diff persisted to the `peek.change.applied` audit payload.\n  // `null` when the mutation does not produce a field-level diff (e.g.\n  // a pure create).\n  changes: ReadonlyArray<PeekAuditChange> | null;\n};\n\nexport type PeekMutationDefinition<TInput = unknown> = {\n  actionId: PeekMutationActionId;\n  resourceType: string;\n  schema: ZodTypeAny;\n  execute: (\n    ctx: PeekMutationExecuteContext<TInput>,\n  ) => Promise<PeekMutationExecuteResult>;\n};\n\nexport type PeekMutationRegistry = Readonly<\n  Record<PeekMutationActionId, PeekMutationDefinition>\n>;\n\nconst entries: ReadonlyArray<PeekMutationDefinition> = [\n  kolRateUpdateMutation as PeekMutationDefinition,\n  fraudFlagStatusUpdateMutation as PeekMutationDefinition,\n];\n\nexport const PEEK_MUTATIONS: PeekMutationRegistry = Object.freeze(\n  entries.reduce<Record<string, PeekMutationDefinition>>((acc, def) => {\n    acc[def.actionId] = def;\n    return acc;\n  }, {}),\n);\n\nexport function getPeekMutation(\n  actionId: PeekMutationActionId,\n  registry: PeekMutationRegistry = PEEK_MUTATIONS,\n): PeekMutationDefinition | null {\n  return registry[actionId] ?? null;\n}\n","numLines":80,"startLine":1,"totalLines":80}}}
