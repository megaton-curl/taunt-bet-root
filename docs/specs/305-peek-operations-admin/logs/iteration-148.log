ue };\n    return result;\n  });\n  return { writer, calls };\n}\n\ntype SqlCall = {\n  fragments: ReadonlyArray<string>;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ExistingRow = {\n  id: string;\n  status: FraudFlagStatus;\n};\n\nfunction createSqlMock(options: {\n  existingRow?: ExistingRow | null;\n  failOnUpdate?: Error;\n} = {}): {\n  sql: Sql;\n  txCalls: SqlCall[];\n  beginCalls: number;\n  rolledBack: boolean;\n} {\n  const txCalls: SqlCall[] = [];\n  let beginCalls = 0;\n  let rolledBack = false;\n\n  const txSql = ((\n    fragments: TemplateStringsArray,\n    ...values: ReadonlyArray<unknown>\n  ) => {\n    const frags = Array.from(fragments);\n    txCalls.push({ fragments: frags, values });\n    const head = (frags[0] ?? \"\").trim().toLowerCase();\n    if (head.startsWith(\"select\")) {\n      return Promise.resolve(\n        options.existingRow ? [options.existingRow] : [],\n      );\n    }\n    if (head.startsWith(\"update\") && options.failOnUpdate) {\n      return Promise.reject(options.failOnUpdate);\n    }\n    return Promise.resolve([]);\n  }) as unknown as Sql;\n\n  const sql = {\n    async begin<T>(callback: (tx: Sql) => Promise<T>): Promise<T> {\n      beginCalls += 1;\n      try {\n        return await callback(txSql);\n      } catch (err) {\n        rolledBack = true;\n        throw err;\n      }\n    },\n  } as unknown as Sql;\n\n  return {\n    sql,\n    txCalls,\n    get beginCalls() {\n      return beginCalls;\n    },\n    get rolledBack() {\n      return rolledBack;\n    },\n  } as ReturnType<typeof createSqlMock>;\n}\n\nconst ACTOR: PeekMutationActorContext = Object.freeze({\n  email: \"admin@example.com\",\n  route: \"/users/user-1\",\n  requestId: \"req-fraud-1\",\n});\n\nconst ACTION_RULES: ReadonlyArray<PeekActionRule> = [\n  { actionId: \"fraud_flag.status.update\", roles: [\"admin\"] },\n];\n\nconst REGISTRY: PeekMutationRegistry = Object.freeze({\n  \"fraud_flag.status.update\":\n    fraudFlagStatusUpdateMutation as unknown as PeekMutationRegistry[string],\n});\n\nfunction findCall(\n  txCalls: ReadonlyArray<SqlCall>,\n  prefix: string,\n): SqlCall | undefined {\n  return txCalls.find((call) =>\n    (call.fragments[0] ?? \"\").trim().toLowerCase().startsWith(prefix),\n  );\n}\n\n// ---------------------------------------------------------------------------\n// Schema-level tests\n// ---------------------------------------------------------------------------\n\ndescribe(\"fraudFlagStatusUpdateInputSchema\", () => {\n  it(\"accepts a valid input shape\", () => {\n    const parsed = fraudFlagStatusUpdateInputSchema.safeParse({\n      flagId: \"42\",\n      nextStatus: \"reviewed\",\n    });\n    expect(parsed.success).toBe(true);\n  });\n\n  it(\"rejects a non-numeric flagId\", () => {\n    const parsed = fraudFlagStatusUpdateInputSchema.safeParse({\n      flagId: \"abc\",\n      nextStatus: \"reviewed\",\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects an empty flagId after trim\", () => {\n    const parsed = fraudFlagStatusUpdateInputSchema.safeParse({\n      flagId: \"   \",\n      nextStatus: \"reviewed\",\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"trims whitespace from flagId\", () => {\n    const parsed = fraudFlagStatusUpdateInputSchema.parse({\n      flagId: \"  42  \",\n      nextStatus: \"open\",\n    });\n    expect(parsed.flagId).toBe(\"42\");\n  });\n\n  it(\"rejects an unknown nextStatus value\", () => {\n    const parsed = fraudFlagStatusUpdateInputSchema.safeParse({\n      flagId: \"1\",\n      nextStatus: \"archived\",\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects unknown extra fields (strict)\", () => {\n    const parsed = fraudFlagStatusUpdateInputSchema.safeParse({\n      flagId: \"1\",\n      nextStatus: \"reviewed\",\n      smuggled: \"x\",\n    });\n    expect(parsed.success).toBe(false);\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Transition matrix\n// ---------------------------------------------------------------------------\n\ndescribe(\"FRAUD_FLAG_ALLOWED_TRANSITIONS\", () => {\n  it(\"admits exactly the five allowed (from, to) tuples\", () => {\n    const tuples = FRAUD_FLAG_ALLOWED_TRANSITIONS.map(([f, t]) => `${f}->${t}`);\n    expect([...tuples].sort()).toEqual(\n      [\n        \"open->reviewed\",\n        \"open->dismissed\",\n        \"reviewed->open\",\n        \"reviewed->dismissed\",\n        \"dismissed->open\",\n      ].sort(),\n    );\n  });\n\n  it(\"denies dismissed -> reviewed (must reopen first)\", () => {\n    expect(isFraudFlagTransitionAllowed(\"dismissed\", \"reviewed\")).toBe(false);\n  });\n\n  it(\"denies every no-op X -> X transition\", () => {\n    for (const status of FRAUD_FLAG_STATUSES) {\n      expect(isFraudFlagTransitionAllowed(status, status)).toBe(false);\n    }\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Definition wiring\n// ---------------------------------------------------------------------------\n\ndescribe(\"fraudFlagStatusUpdateMutation definition\", () => {\n  it(\"registers the FR-14 actionId and resourceType expected by the audit log\", () => {\n    expect(fraudFlagStatusUpdateMutation.actionId).toBe(\n      \"fraud_flag.status.update\",\n    );\n    expect(fraudFlagStatusUpdateMutation.resourceType).toBe(\"fraud_flags\");\n  });\n});\n\n// ---------------------------------------------------------------------------\n// End-to-end runner tests\n// ---------------------------------------------------------------------------\n\ndescribe(\"fraud_flag.status.update via runPeekMutation\", () => {\n  it(\"performs a valid open -> reviewed transition, sets resolved_at, and emits peek.change.applied with status diff\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { id: \"42\", status: \"open\" },\n    });\n\n    const result: PeekMutationRunResult = await runPeekMutation({\n      actionId: \"fraud_flag.status.update\",\n      rawInput: { flagId: \"42\", nextStatus: \"reviewed\" },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(true);\n    if (!result.ok) return;\n    expect(result.actionId).toBe(\"fraud_flag.status.update\");\n    expect(result.resourceId).toBe(\"42\");\n    expect(result.changes).toEqual([\n      { field: \"status\", before: \"open\", after: \"reviewed\" },\n    ] as ReadonlyArray<PeekAuditChange>);\n\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(false);\n\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    const updateCall = findCall(sqlMock.txCalls, \"update\");\n    expect(updateCall).toBeDefined();\n    // Non-open transitions bind nextStatus + flagId only — resolved_at is now().\n    expect(updateCall?.values).toEqual([\"reviewed\", \"42\"]);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n    expect(audit.calls[0]?.payload).toMatchObject({\n      actorEmail: ACTOR.email,\n      route: ACTOR.route,\n      actionId: \"fraud_flag.status.update\",\n      resourceType: \"fraud_flags\",\n      resourceId: \"42\",\n      filterSummary: null,\n      resultCount: null,\n      requestId: ACTOR.requestId,\n      rejectionReason: null,\n    });\n    expect(audit.calls[0]?.payload.changes).toEqual([\n      { field: \"status\", before: \"open\", after: \"reviewed\" },\n    ]);\n    // Audit must be written on the in-tx Sql so the change + audit row are atomic.\n    expect(audit.calls[0]?.sql).toBeDefined();\n  });\n\n  it(\"performs a reopen (dismissed -> open), clears resolved_at, and emits applied audit\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { id: \"7\", status: \"dismissed\" },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"fraud_flag.status.update\",\n      rawInput: { flagId: \"7\", nextStatus: \"open\" },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(true);\n    if (!result.ok) return;\n    expect(result.changes).toEqual([\n      { field: \"status\", before: \"dismissed\", after: \"open\" },\n    ]);\n\n    const updateCall = findCall(sqlMock.txCalls, \"update\");\n    // Reopen branch binds nextStatus + flagId; resolved_at is set to NULL literal.\n    expect(updateCall?.values).toEqual([\"open\", \"7\"]);\n    // Reopen UPDATE writes resolved_at = null (not now()).\n    const updateSql = (updateCall?.fragments ?? []).join(\"?\").toLowerCase();\n    expect(updateSql).toContain(\"resolved_at = null\");\n    expect(updateSql).not.toContain(\"now()\");\n\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n  });\n\n  it(\"rejects an invalid dismissed -> reviewed transition with peek.change.rejected, rolls back, and never UPDATEs\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { id: \"9\", status: \"dismissed\" },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"fraud_flag.status.update\",\n      rawInput: { flagId: \"9\", nextStatus: \"reviewed\" },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"execution_failed\");\n      expect(result.message).toContain(\"invalid_transition\");\n      expect(result.message).toContain(\"dismissed\");\n      expect(result.message).toContain(\"reviewed\");\n    }\n\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(true);\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n      /^execution_failed: invalid_transition: dismissed -> reviewed$/,\n    );\n    expect(audit.calls[0]?.payload.actionId).toBe(\"fraud_flag.status.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"fraud_flags\");\n    expect(audit.calls[0]?.payload.changes).toBeNull();\n  });\n\n  it(\"rejects a no-op X -> X transition with peek.change.rejected and never UPDATEs\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { id: \"11\", status: \"open\" },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"fraud_flag.status.update\",\n      rawInput: { flagId: \"11\", nextStatus: \"open\" },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"execution_failed\");\n      expect(result.message).toContain(\"invalid_transition\");\n    }\n    expect(sqlMock.rolledBack).toBe(true);\n    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n      /invalid_transition: open -> open/,\n    );\n  });\n\n  it(\"rejects an unknown flag id with peek.change.rejected, rolls back, and never UPDATEs\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({ existingRow: null });\n\n    const result = await runPeekMutation({\n      actionId: \"fraud_flag.status.update\",\n      rawInput: { flagId: \"999\", nextStatus: \"reviewed\" },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"execution_failed\");\n      expect(result.message).toContain(\"unknown_flag\");\n      expect(result.message).toContain(\"999\");\n    }\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(true);\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n      /^execution_failed: unknown_flag: 999$/,\n    );\n    expect(audit.calls[0]?.payload.actionId).toBe(\"fraud_flag.status.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"fraud_flags\");\n  });\n\n  it(\"rejects a non-admin actor with peek.change.rejected and never queries the DB\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { id: \"1\", status: \"open\" },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"fraud_flag.status.update\",\n      rawInput: { flagId: \"1\", nextStatus: \"reviewed\" },\n      actorRole: \"business\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(sqlMock.txCalls).toHaveLength(0);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n    expect(audit.calls[0]?.payload.actionId).toBe(\"fraud_flag.status.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"fraud_flags\");\n  });\n\n  it(\"rejects an actor with no resolved role with peek.change.rejected\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { id: \"1\", status: \"open\" },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"fraud_flag.status.update\",\n      rawInput: { flagId: \"1\", nextStatus: \"reviewed\" },\n      actorRole: null,\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n  });\n\n  it(\"rejects an invalid input via the schema with peek.change.rejected and never opens a transaction\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock();\n\n    const result = await runPeekMutation({\n      actionId: \"fraud_flag.status.update\",\n      rawInput: { flagId: \"abc\", nextStatus: \"reviewed\" },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"invalid_input\");\n      expect(result.fieldErrors?.flagId?.length).toBeGreaterThan(0);\n    }\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(sqlMock.txCalls).toHaveLength(0);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n    expect(audit.calls[0]?.payload.actionId).toBe(\"fraud_flag.status.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"fraud_flags\");\n    expect(audit.calls[0]?.payload.changes).toBeNull();\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
