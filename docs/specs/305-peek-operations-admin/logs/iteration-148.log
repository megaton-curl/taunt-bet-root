{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016UhRwtdF1YnPtQQ9o7Fxk4","type":"tool_result","content":"1\timport { describe, expect, it, vi } from \"vitest\";\n2\timport type { Sql } from \"postgres\";\n3\timport type { PeekActionRule } from \"../../access-policy\";\n4\timport type { PeekAuditWriteResult } from \"../../audit/writer\";\n5\timport type {\n6\t  PeekAuditChange,\n7\t  PeekAuditPayload,\n8\t} from \"../../../lib/types/peek\";\n9\timport {\n10\t  KOL_RATE_BPS_MAX,\n11\t  KOL_RATE_BPS_MIN,\n12\t  kolRateUpdateInputSchema,\n13\t  kolRateUpdateMutation,\n14\t} from \"../kol-rate\";\n15\timport {\n16\t  runPeekMutation,\n17\t  type PeekMutationAuditWriter,\n18\t  type PeekMutationRunResult,\n19\t} from \"../runner\";\n20\timport {\n21\t  type PeekMutationActorContext,\n22\t  type PeekMutationRegistry,\n23\t} from \"../registry\";\n24\t\n25\t// ---------------------------------------------------------------------------\n26\t// Test scaffolding\n27\t// ---------------------------------------------------------------------------\n28\t\n29\ttype AuditCall = {\n30\t  eventType: string;\n31\t  payload: PeekAuditPayload;\n32\t  sql: Sql | undefined;\n33\t};\n34\t\n35\tfunction createAuditWriter(): {\n36\t  writer: PeekMutationAuditWriter;\n37\t  calls: AuditCall[];\n38\t} {\n39\t  const calls: AuditCall[] = [];\n40\t  const writer: PeekMutationAuditWriter = vi.fn(async (input, options) => {\n41\t    calls.push({\n42\t      eventType: input.eventType,\n43\t      payload: input.payload,\n44\t      sql: options?.sql,\n45\t    });\n46\t    const result: PeekAuditWriteResult = { ok: true };\n47\t    return result;\n48\t  });\n49\t  return { writer, calls };\n50\t}\n51\t\n52\t// `Sql` mock that emulates `postgres`'s tagged-template + `sql.begin` API just\n53\t// enough for the kol-rate mutation. The mutation only issues:\n54\t//   1. a `select ... for update` to read the existing row, and\n55\t//   2. either `update referral_kol_rates ...` or\n56\t//      `insert into referral_kol_rates ...`\n57\t// so tests can identify each call by inspecting the leading SQL fragment.\n58\t\n59\ttype SqlCall = {\n60\t  fragments: ReadonlyArray<string>;\n61\t  values: ReadonlyArray<unknown>;\n62\t};\n63\t\n64\ttype ExistingRow = {\n65\t  userId: string;\n66\t  wallet: string;\n67\t  rateBps: number;\n68\t};\n69\t\n70\tfunction createSqlMock(options: {\n71\t  existingRow?: ExistingRow | null;\n72\t  failOnInsert?: Error;\n73\t} = {}): {\n74\t  sql: Sql;\n75\t  txCalls: SqlCall[];\n76\t  beginCalls: number;\n77\t  rolledBack: boolean;\n78\t} {\n79\t  const txCalls: SqlCall[] = [];\n80\t  let beginCalls = 0;\n81\t  let rolledBack = false;\n82\t\n83\t  const txSql = ((\n84\t    fragments: TemplateStringsArray,\n85\t    ...values: ReadonlyArray<unknown>\n86\t  ) => {\n87\t    const frags = Array.from(fragments);\n88\t    txCalls.push({ fragments: frags, values });\n89\t    const head = (frags[0] ?? \"\").trim().toLowerCase();\n90\t    if (head.startsWith(\"select\")) {\n91\t      // SELECT ... FOR UPDATE → return [existingRow] or [].\n92\t      return Promise.resolve(\n93\t        options.existingRow ? [options.existingRow] : [],\n94\t      );\n95\t    }\n96\t    if (head.startsWith(\"insert\") && options.failOnInsert) {\n97\t      return Promise.reject(options.failOnInsert);\n98\t    }\n99\t    // UPDATE / INSERT → resolve to an empty array (postgres pattern).\n100\t    return Promise.resolve([]);\n101\t  }) as unknown as Sql;\n102\t\n103\t  const sql = {\n104\t    async begin<T>(callback: (tx: Sql) => Promise<T>): Promise<T> {\n105\t      beginCalls += 1;\n106\t      try {\n107\t        return await callback(txSql);\n108\t      } catch (err) {\n109\t        rolledBack = true;\n110\t        throw err;\n111\t      }\n112\t    },\n113\t  } as unknown as Sql;\n114\t\n115\t  return {\n116\t    sql,\n117\t    txCalls,\n118\t    get beginCalls() {\n119\t      return beginCalls;\n120\t    },\n121\t    get rolledBack() {\n122\t      return rolledBack;\n123\t    },\n124\t  } as ReturnType<typeof createSqlMock>;\n125\t}\n126\t\n127\tconst ACTOR: PeekMutationActorContext = Object.freeze({\n128\t  email: \"alice@example.com\",\n129\t  route: \"/growth/kol\",\n130\t  requestId: \"req-kol-1\",\n131\t});\n132\t\n133\tconst ACTION_RULES: ReadonlyArray<PeekActionRule> = [\n134\t  { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n135\t];\n136\t\n137\tconst REGISTRY: PeekMutationRegistry = Object.freeze({\n138\t  \"kol_rate.update\": kolRateUpdateMutation as unknown as PeekMutationRegistry[string],\n139\t});\n140\t\n141\tfunction findCall(\n142\t  txCalls: ReadonlyArray<SqlCall>,\n143\t  prefix: string,\n144\t): SqlCall | undefined {\n145\t  return txCalls.find((call) =>\n146\t    (call.fragments[0] ?? \"\").trim().toLowerCase().startsWith(prefix),\n147\t  );\n148\t}\n149\t\n150\t// ---------------------------------------------------------------------------\n151\t// Schema-level tests (FR-14 \"rate validation\")\n152\t// ---------------------------------------------------------------------------\n153\t\n154\tdescribe(\"kolRateUpdateInputSchema\", () => {\n155\t  it(\"accepts a valid input shape\", () => {\n156\t    const parsed = kolRateUpdateInputSchema.safeParse({\n157\t      userId: \"user-1\",\n158\t      wallet: \"WaLLeT11111111111111111111111111111111111111\",\n159\t      rateBps: 1500,\n160\t    });\n161\t    expect(parsed.success).toBe(true);\n162\t  });\n163\t\n164\t  it(\"rejects a negative rateBps\", () => {\n165\t    const parsed = kolRateUpdateInputSchema.safeParse({\n166\t      userId: \"user-1\",\n167\t      wallet: \"wallet\",\n168\t      rateBps: -1,\n169\t    });\n170\t    expect(parsed.success).toBe(false);\n171\t  });\n172\t\n173\t  it(\"rejects rateBps above KOL_RATE_BPS_MAX (10000)\", () => {\n174\t    const parsed = kolRateUpdateInputSchema.safeParse({\n175\t      userId: \"user-1\",\n176\t      wallet: \"wallet\",\n177\t      rateBps: KOL_RATE_BPS_MAX + 1,\n178\t    });\n179\t    expect(parsed.success).toBe(false);\n180\t  });\n181\t\n182\t  it(\"rejects a non-integer rateBps\", () => {\n183\t    const parsed = kolRateUpdateInputSchema.safeParse({\n184\t      userId: \"user-1\",\n185\t      wallet: \"wallet\",\n186\t      rateBps: 100.5,\n187\t    });\n188\t    expect(parsed.success).toBe(false);\n189\t  });\n190\t\n191\t  it(\"rejects empty userId / wallet (after trim)\", () => {\n192\t    const a = kolRateUpdateInputSchema.safeParse({\n193\t      userId: \"  \",\n194\t      wallet: \"wallet\",\n195\t      rateBps: 100,\n196\t    });\n197\t    const b = kolRateUpdateInputSchema.safeParse({\n198\t      userId: \"user-1\",\n199\t      wallet: \"  \",\n200\t      rateBps: 100,\n201\t    });\n202\t    expect(a.success).toBe(false);\n203\t    expect(b.success).toBe(false);\n204\t  });\n205\t\n206\t  it(\"trims whitespace from userId and wallet\", () => {\n207\t    const parsed = kolRateUpdateInputSchema.parse({\n208\t      userId: \"  user-1 \",\n209\t      wallet: \"  wallet-x  \",\n210\t      rateBps: 250,\n211\t    });\n212\t    expect(parsed.userId).toBe(\"user-1\");\n213\t    expect(parsed.wallet).toBe(\"wallet-x\");\n214\t  });\n215\t\n216\t  it(\"accepts the boundary values 0 and 10000\", () => {\n217\t    expect(\n218\t      kolRateUpdateInputSchema.safeParse({\n219\t        userId: \"user-1\",\n220\t        wallet: \"wallet\",\n221\t        rateBps: KOL_RATE_BPS_MIN,\n222\t      }).success,\n223\t    ).toBe(true);\n224\t    expect(\n225\t      kolRateUpdateInputSchema.safeParse({\n226\t        userId: \"user-1\",\n227\t        wallet: \"wallet\",\n228\t        rateBps: KOL_RATE_BPS_MAX,\n229\t      }).success,\n230\t    ).toBe(true);\n231\t  });\n232\t\n233\t  it(\"rejects unknown extra fields (strict)\", () => {\n234\t    const parsed = kolRateUpdateInputSchema.safeParse({\n235\t      userId: \"user-1\",\n236\t      wallet: \"wallet\",\n237\t      rateBps: 100,\n238\t      smuggled: \"value\",\n239\t    });\n240\t    expect(parsed.success).toBe(false);\n241\t  });\n242\t});\n243\t\n244\t// ---------------------------------------------------------------------------\n245\t// Definition wiring\n246\t// ---------------------------------------------------------------------------\n247\t\n248\tdescribe(\"kolRateUpdateMutation definition\", () => {\n249\t  it(\"registers the FR-14 actionId and resourceType expected by the audit log\", () => {\n250\t    expect(kolRateUpdateMutation.actionId).toBe(\"kol_rate.update\");\n251\t    expect(kolRateUpdateMutation.resourceType).toBe(\"referral_kol_rates\");\n252\t  });\n253\t});\n254\t\n255\t// ---------------------------------------------------------------------------\n256\t// End-to-end runner tests (FR-14 create / update / unauthorized / audit)\n257\t// ---------------------------------------------------------------------------\n258\t\n259\tdescribe(\"kol_rate.update via runPeekMutation\", () => {\n260\t  it(\"creates a row when no existing record matches userId and emits an applied audit with full new state\", async () => {\n261\t    const audit = createAuditWriter();\n262\t    const sqlMock = createSqlMock({ existingRow: null });\n263\t\n264\t    const result: PeekMutationRunResult = await runPeekMutation({\n265\t      actionId: \"kol_rate.update\",\n266\t      rawInput: {\n267\t        userId: \"user-1\",\n268\t        wallet: \"WaLLeT-1\",\n269\t        rateBps: 750,\n270\t      },\n271\t      actorRole: \"admin\",\n272\t      actor: ACTOR,\n273\t      sql: sqlMock.sql,\n274\t      registry: REGISTRY,\n275\t      actionRules: ACTION_RULES,\n276\t      auditWriter: audit.writer,\n277\t    });\n278\t\n279\t    expect(result.ok).toBe(true);\n280\t    if (!result.ok) return;\n281\t    expect(result.actionId).toBe(\"kol_rate.update\");\n282\t    expect(result.resourceId).toBe(\"user-1\");\n283\t    expect(result.changes).toEqual([\n284\t      { field: \"wallet\", before: null, after: \"WaLLeT-1\" },\n285\t      { field: \"rate_bps\", before: null, after: 750 },\n286\t    ] as ReadonlyArray<PeekAuditChange>);\n287\t\n288\t    // Transaction was opened and committed.\n289\t    expect(sqlMock.beginCalls).toBe(1);\n290\t    expect(sqlMock.rolledBack).toBe(false);\n291\t\n292\t    // SELECT ... FOR UPDATE was issued, then INSERT (no UPDATE).\n293\t    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n294\t    expect(findCall(sqlMock.txCalls, \"insert\")).toBeDefined();\n295\t    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n296\t\n297\t    // INSERT carries userId + wallet + rateBps + actor email as set_by.\n298\t    const insertCall = findCall(sqlMock.txCalls, \"insert\");\n299\t    expect(insertCall?.values).toEqual([\n300\t      \"user-1\",\n301\t      \"WaLLeT-1\",\n302\t      750,\n303\t      ACTOR.email,\n304\t    ]);\n305\t\n306\t    // Exactly one audit event: peek.change.applied on the in-tx Sql.\n307\t    expect(audit.calls).toHaveLength(1);\n308\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n309\t    expect(audit.calls[0]?.payload).toMatchObject({\n310\t      actorEmail: ACTOR.email,\n311\t      route: ACTOR.route,\n312\t      actionId: \"kol_rate.update\",\n313\t      resourceType: \"referral_kol_rates\",\n314\t      resourceId: \"user-1\",\n315\t      filterSummary: null,\n316\t      resultCount: null,\n317\t      requestId: ACTOR.requestId,\n318\t      rejectionReason: null,\n319\t    });\n320\t    expect(audit.calls[0]?.payload.changes).toEqual([\n321\t      { field: \"wallet\", before: null, after: \"WaLLeT-1\" },\n322\t      { field: \"rate_bps\", before: null, after: 750 },\n323\t    ]);\n324\t  });\n325\t\n326\t  it(\"updates an existing row, diffs only the fields that actually changed, and skips set_by/updated_at in the audit diff\", async () => {\n327\t    const audit = createAuditWriter();\n328\t    const sqlMock = createSqlMock({\n329\t      existingRow: {\n330\t        userId: \"user-1\",\n331\t        wallet: \"WaLLeT-old\",\n332\t        rateBps: 1000,\n333\t      },\n334\t    });\n335\t\n336\t    const result = await runPeekMutation({\n337\t      actionId: \"kol_rate.update\",\n338\t      rawInput: {\n339\t        userId: \"user-1\",\n340\t        // wallet unchanged → must not appear in diff.\n341\t        wallet: \"WaLLeT-old\",\n342\t        rateBps: 1500,\n343\t      },\n344\t      actorRole: \"business\",\n345\t      actor: ACTOR,\n346\t      sql: sqlMock.sql,\n347\t      registry: REGISTRY,\n348\t      actionRules: ACTION_RULES,\n349\t      auditWriter: audit.writer,\n350\t    });\n351\t\n352\t    expect(result.ok).toBe(true);\n353\t    if (!result.ok) return;\n354\t    expect(result.resourceId).toBe(\"user-1\");\n355\t    expect(result.changes).toEqual([\n356\t      { field: \"rate_bps\", before: 1000, after: 1500 },\n357\t    ]);\n358\t\n359\t    // SELECT + UPDATE (no INSERT).\n360\t    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n361\t    expect(findCall(sqlMock.txCalls, \"update\")).toBeDefined();\n362\t    expect(findCall(sqlMock.txCalls, \"insert\")).toBeUndefined();\n363\t\n364\t    const updateCall = findCall(sqlMock.txCalls, \"update\");\n365\t    // UPDATE binds wallet, rate_bps, set_by, then user_id.\n366\t    expect(updateCall?.values).toEqual([\n367\t      \"WaLLeT-old\",\n368\t      1500,\n369\t      ACTOR.email,\n370\t      \"user-1\",\n371\t    ]);\n372\t\n373\t    // Audit diff excludes set_by and updated_at — operator metadata, not config.\n374\t    const changes = audit.calls[0]?.payload.changes ?? [];\n375\t    const fields = changes.map((c) => c.field);\n376\t    expect(fields).not.toContain(\"set_by\");\n377\t    expect(fields).not.toContain(\"updated_at\");\n378\t    expect(fields).toEqual([\"rate_bps\"]);\n379\t  });\n380\t\n381\t  it(\"emits an applied audit with an empty diff when the update is a no-op (same wallet + same rate)\", async () => {\n382\t    const audit = createAuditWriter();\n383\t    const sqlMock = createSqlMock({\n384\t      existingRow: {\n385\t        userId: \"user-1\",\n386\t        wallet: \"WaLLeT-x\",\n387\t        rateBps: 1500,\n388\t      },\n389\t    });\n390\t\n391\t    const result = await runPeekMutation({\n392\t      actionId: \"kol_rate.update\",\n393\t      rawInput: {\n394\t        userId: \"user-1\",\n395\t        wallet: \"WaLLeT-x\",\n396\t        rateBps: 1500,\n397\t      },\n398\t      actorRole: \"admin\",\n399\t      actor: ACTOR,\n400\t      sql: sqlMock.sql,\n401\t      registry: REGISTRY,\n402\t      actionRules: ACTION_RULES,\n403\t      auditWriter: audit.writer,\n404\t    });\n405\t\n406\t    expect(result.ok).toBe(true);\n407\t    if (!result.ok) return;\n408\t    expect(result.changes).toEqual([]);\n409\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n410\t    expect(audit.calls[0]?.payload.changes).toEqual([]);\n411\t  });\n412\t\n413\t  it(\"rejects an invalid rateBps via the schema with peek.change.rejected and never opens a transaction\", async () => {\n414\t    const audit = createAuditWriter();\n415\t    const sqlMock = createSqlMock();\n416\t\n417\t    const result = await runPeekMutation({\n418\t      actionId: \"kol_rate.update\",\n419\t      rawInput: {\n420\t        userId: \"user-1\",\n421\t        wallet: \"WaLLeT-1\",\n422\t        rateBps: KOL_RATE_BPS_MAX + 1,\n423\t      },\n424\t      actorRole: \"admin\",\n425\t      actor: ACTOR,\n426\t      sql: sqlMock.sql,\n427\t      registry: REGISTRY,\n428\t      actionRules: ACTION_RULES,\n429\t      auditWriter: audit.writer,\n430\t    });\n431\t\n432\t    expect(result.ok).toBe(false);\n433\t    if (!result.ok) {\n434\t      expect(result.reason).toBe(\"invalid_input\");\n435\t      expect(result.fieldErrors?.rateBps?.length).toBeGreaterThan(0);\n436\t    }\n437\t    expect(sqlMock.beginCalls).toBe(0);\n438\t    expect(sqlMock.txCalls).toHaveLength(0);\n439\t\n440\t    expect(audit.calls).toHaveLength(1);\n441\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n442\t    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n443\t    expect(audit.calls[0]?.payload.actionId).toBe(\"kol_rate.update\");\n444\t    expect(audit.calls[0]?.payload.resourceType).toBe(\"referral_kol_rates\");\n445\t    expect(audit.calls[0]?.payload.changes).toBeNull();\n446\t  });\n447\t\n448\t  it(\"rejects an unauthorized actor role with peek.change.rejected and never queries the DB\", async () => {\n449\t    const audit = createAuditWriter();\n450\t    const sqlMock = createSqlMock();\n451\t\n452\t    // Tighten action rule so business is denied.\n453\t    const adminOnly: ReadonlyArray<PeekActionRule> = [\n454\t      { actionId: \"kol_rate.update\", roles: [\"admin\"] },\n455\t    ];\n456\t\n457\t    const result = await runPeekMutation({\n458\t      actionId: \"kol_rate.update\",\n459\t      rawInput: {\n460\t        userId: \"user-1\",\n461\t        wallet: \"WaLLeT-1\",\n462\t        rateBps: 1500,\n463\t      },\n464\t      actorRole: \"business\",\n465\t      actor: ACTOR,\n466\t      sql: sqlMock.sql,\n467\t      registry: REGISTRY,\n468\t      actionRules: adminOnly,\n469\t      auditWriter: audit.writer,\n470\t    });\n471\t\n472\t    expect(result.ok).toBe(false);\n473\t    if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n474\t\n475\t    expect(sqlMock.beginCalls).toBe(0);\n476\t    expect(sqlMock.txCalls).toHaveLength(0);\n477\t\n478\t    expect(audit.calls).toHaveLength(1);\n479\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n480\t    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n481\t    expect(audit.calls[0]?.payload.actionId).toBe(\"kol_rate.update\");\n482\t    expect(audit.calls[0]?.payload.resourceType).toBe(\"referral_kol_rates\");\n483\t  });\n484\t\n485\t  it(\"rolls back and emits peek.change.rejected when the INSERT collides with the wallet UNIQUE constraint\", async () => {\n486\t    const audit = createAuditWriter();\n487\t    const sqlMock = createSqlMock({\n488\t      existingRow: null,\n489\t      failOnInsert: new Error(\n490\t        'duplicate key value violates unique constraint \"referral_kol_rates_wallet_key\"',\n491\t      ),\n492\t    });\n493\t\n494\t    const result = await runPeekMutation({\n495\t      actionId: \"kol_rate.update\",\n496\t      rawInput: {\n497\t        userId: \"user-1\",\n498\t        wallet: \"WaLLeT-collides\",\n499\t        rateBps: 1500,\n500\t      },\n501\t      actorRole: \"admin\",\n502\t      actor: ACTOR,\n503\t      sql: sqlMock.sql,\n504\t      registry: REGISTRY,\n505\t      actionRules: ACTION_RULES,\n506\t      auditWriter: audit.writer,\n507\t    });\n508\t\n509\t    expect(result.ok).toBe(false);\n510\t    if (!result.ok) {\n511\t      expect(result.reason).toBe(\"execution_failed\");\n512\t      expect(result.message).toContain(\"duplicate key\");\n513\t    }\n514\t    expect(sqlMock.beginCalls).toBe(1);\n515\t    expect(sqlMock.rolledBack).toBe(true);\n516\t\n517\t    expect(audit.calls).toHaveLength(1);\n518\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n519\t    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n520\t      /^execution_failed: /,\n521\t    );\n522\t    expect(audit.calls[0]?.payload.actionId).toBe(\"kol_rate.update\");\n523\t    expect(audit.calls[0]?.payload.resourceType).toBe(\"referral_kol_rates\");\n524\t  });\n525\t});\n526\t"}]},"parent_tool_use_id":null,"session_id":"d6b841b0-5eab-4233-bb67-840874dc8e96","uuid":"6ae2f4e3-d177-45d8-8e68-57df3515a710","timestamp":"2026-04-26T15:37:58.570Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/mutations/__tests__/kol-rate.test.ts","content":"import { describe, expect, it, vi } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport type { PeekActionRule } from \"../../access-policy\";\nimport type { PeekAuditWriteResult } from \"../../audit/writer\";\nimport type {\n  PeekAuditChange,\n  PeekAuditPayload,\n} from \"../../../lib/types/peek\";\nimport {\n  KOL_RATE_BPS_MAX,\n  KOL_RATE_BPS_MIN,\n  kolRateUpdateInputSchema,\n  kolRateUpdateMutation,\n} from \"../kol-rate\";\nimport {\n  runPeekMutation,\n  type PeekMutationAuditWriter,\n  type PeekMutationRunResult,\n} from \"../runner\";\nimport {\n  type PeekMutationActorContext,\n  type PeekMutationRegistry,\n} from \"../registry\";\n\n// ---------------------------------------------------------------------------\n// Test scaffolding\n// ---------------------------------------------------------------------------\n\ntype AuditCall = {\n  eventType: string;\n  payload: PeekAuditPayload;\n  sql: Sql | undefined;\n};\n\nfunction createAuditWriter(): {\n  writer: PeekMutationAuditWriter;\n  calls: AuditCall[];\n} {\n  const calls: AuditCall[] = [];\n  const writer: PeekMutationAuditWriter = vi.fn(async (input, options) => {\n    calls.push({\n      eventType: input.eventType,\n      payload: input.payload,\n      sql: options?.sql,\n    });\n    const result: PeekAuditWriteResult = { ok: true };\n    return result;\n  });\n  return { writer, calls };\n}\n\n// `Sql` mock that emulates `postgres`'s tagged-template + `sql.begin` API just\n// enough for the kol-rate mutation. The mutation only issues:\n//   1. a `select ... for update` to read the existing row, and\n//   2. either `update referral_kol_rates ...` or\n//      `insert into referral_kol_rates ...`\n// so tests can identify each call by inspecting the leading SQL fragment.\n\ntype SqlCall = {\n  fragments: ReadonlyArray<string>;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ExistingRow = {\n  userId: string;\n  wallet: string;\n  rateBps: number;\n};\n\nfunction createSqlMock(options: {\n  existingRow?: ExistingRow | null;\n  failOnInsert?: Error;\n} = {}): {\n  sql: Sql;\n  txCalls: SqlCall[];\n  beginCalls: number;\n  rolledBack: boolean;\n} {\n  const txCalls: SqlCall[] = [];\n  let beginCalls = 0;\n  let rolledBack = false;\n\n  const txSql = ((\n    fragments: TemplateStringsArray,\n    ...values: ReadonlyArray<unknown>\n  ) => {\n    const frags = Array.from(fragments);\n    txCalls.push({ fragments: frags, values });\n    const head = (frags[0] ?? \"\").trim().toLowerCase();\n    if (head.startsWith(\"select\")) {\n      // SELECT ... FOR UPDATE → return [existingRow] or [].\n      return Promise.resolve(\n        options.existingRow ? [options.existingRow] : [],\n      );\n    }\n    if (head.startsWith(\"insert\") && options.failOnInsert) {\n      return Promise.reject(options.failOnInsert);\n    }\n    // UPDATE / INSERT → resolve to an empty array (postgres pattern).\n    return Promise.resolve([]);\n  }) as unknown as Sql;\n\n  const sql = {\n    async begin<T>(callback: (tx: Sql) => Promise<T>): Promise<T> {\n      beginCalls += 1;\n      try {\n        return await callback(txSql);\n      } catch (err) {\n        rolledBack = true;\n        throw err;\n      }\n    },\n  } as unknown as Sql;\n\n  return {\n    sql,\n    txCalls,\n    get beginCalls() {\n      return beginCalls;\n    },\n    get rolledBack() {\n      return rolledBack;\n    },\n  } as ReturnType<typeof createSqlMock>;\n}\n\nconst ACTOR: PeekMutationActorContext = Object.freeze({\n  email: \"alice@example.com\",\n  route: \"/growth/kol\",\n  requestId: \"req-kol-1\",\n});\n\nconst ACTION_RULES: ReadonlyArray<PeekActionRule> = [\n  { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n];\n\nconst REGISTRY: PeekMutationRegistry = Object.freeze({\n  \"kol_rate.update\": kolRateUpdateMutation as unknown as PeekMutationRegistry[string],\n});\n\nfunction findCall(\n  txCalls: ReadonlyArray<SqlCall>,\n  prefix: string,\n): SqlCall | undefined {\n  return txCalls.find((call) =>\n    (call.fragments[0] ?? \"\").trim().toLowerCase().startsWith(prefix),\n  );\n}\n\n// ---------------------------------------------------------------------------\n// Schema-level tests (FR-14 \"rate validation\")\n// ---------------------------------------------------------------------------\n\ndescribe(\"kolRateUpdateInputSchema\", () => {\n  it(\"accepts a valid input shape\", () => {\n    const parsed = kolRateUpdateInputSchema.safeParse({\n      userId: \"user-1\",\n      wallet: \"WaLLeT11111111111111111111111111111111111111\",\n      rateBps: 1500,\n    });\n    expect(parsed.success).toBe(true);\n  });\n\n  it(\"rejects a negative rateBps\", () => {\n    const parsed = kolRateUpdateInputSchema.safeParse({\n      userId: \"user-1\",\n      wallet: \"wallet\",\n      rateBps: -1,\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects rateBps above KOL_RATE_BPS_MAX (10000)\", () => {\n    const parsed = kolRateUpdateInputSchema.safeParse({\n      userId: \"user-1\",\n      wallet: \"wallet\",\n      rateBps: KOL_RATE_BPS_MAX + 1,\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects a non-integer rateBps\", () => {\n    const parsed = kolRateUpdateInputSchema.safeParse({\n      userId: \"user-1\",\n      wallet: \"wallet\",\n      rateBps: 100.5,\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects empty userId / wallet (after trim)\", () => {\n    const a = kolRateUpdateInputSchema.safeParse({\n      userId: \"  \",\n      wallet: \"wallet\",\n      rateBps: 100,\n    });\n    const b = kolRateUpdateInputSchema.safeParse({\n      userId: \"user-1\",\n      wallet: \"  \",\n      rateBps: 100,\n    });\n    expect(a.success).toBe(false);\n    expect(b.success).toBe(false);\n  });\n\n  it(\"trims whitespace from userId and wallet\", () => {\n    const parsed = kolRateUpdateInputSchema.parse({\n      userId: \"  user-1 \",\n      wallet: \"  wallet-x  \",\n      rateBps: 250,\n    });\n    expect(parsed.userId).toBe(\"user-1\");\n    expect(parsed.wallet).toBe(\"wallet-x\");\n  });\n\n  it(\"accepts the boundary values 0 and 10000\", () => {\n    expect(\n      kolRateUpdateInputSchema.safeParse({\n        userId: \"user-1\",\n        wallet: \"wallet\",\n        rateBps: KOL_RATE_BPS_MIN,\n      }).success,\n    ).toBe(true);\n    expect(\n      kolRateUpdateInputSchema.safeParse({\n        userId: \"user-1\",\n        wallet: \"wallet\",\n        rateBps: KOL_RATE_BPS_MAX,\n      }).success,\n    ).toBe(true);\n  });\n\n  it(\"rejects unknown extra fields (strict)\", () => {\n    const parsed = kolRateUpdateInputSchema.safeParse({\n      userId: \"user-1\",\n      wallet: \"wallet\",\n      rateBps: 100,\n      smuggled: \"value\",\n    });\n    expect(parsed.success).toBe(false);\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Definition wiring\n// ---------------------------------------------------------------------------\n\ndescribe(\"kolRateUpdateMutation definition\", () => {\n  it(\"registers the FR-14 actionId and resourceType expected by the audit log\", () => {\n    expect(kolRateUpdateMutation.actionId).toBe(\"kol_rate.update\");\n    expect(kolRateUpdateMutation.resourceType).toBe(\"referral_kol_rates\");\n  });\n});\n\n// ---------------------------------------------------------------------------\n// End-to-end runner tests (FR-14 create / update / unauthorized / audit)\n// ---------------------------------------------------------------------------\n\ndescribe(\"kol_rate.update via runPeekMutation\", () => {\n  it(\"creates a row when no existing record matches userId and emits an applied audit with full new state\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({ existingRow: null });\n\n    const result: PeekMutationRunResult = await runPeekMutation({\n      actionId: \"kol_rate.update\",\n      rawInput: {\n        userId: \"user-1\",\n        wallet: \"WaLLeT-1\",\n        rateBps: 750,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(true);\n    if (!result.ok) return;\n    expect(result.actionId).toBe(\"kol_rate.update\");\n    expect(result.resourceId).toBe(\"user-1\");\n    expect(result.changes).toEqual([\n      { field: \"wallet\", before: null, after: \"WaLLeT-1\" },\n      { field: \"rate_bps\", before: null, after: 750 },\n    ] as ReadonlyArray<PeekAuditChange>);\n\n    // Transaction was opened and committed.\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(false);\n\n    // SELECT ... FOR UPDATE was issued, then INSERT (no UPDATE).\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    expect(findCall(sqlMock.txCalls, \"insert\")).toBeDefined();\n    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n\n    // INSERT carries userId + wallet + rateBps + actor email as set_by.\n    const insertCall = findCall(sqlMock.txCalls, \"insert\");\n    expect(insertCall?.values).toEqual([\n      \"user-1\",\n      \"WaLLeT-1\",\n      750,\n      ACTOR.email,\n    ]);\n\n    // Exactly one audit event: peek.change.applied on the in-tx Sql.\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n    expect(audit.calls[0]?.payload).toMatchObject({\n      actorEmail: ACTOR.email,\n      route: ACTOR.route,\n      actionId: \"kol_rate.update\",\n      resourceType: \"referral_kol_rates\",\n      resourceId: \"user-1\",\n      filterSummary: null,\n      resultCount: null,\n      requestId: ACTOR.requestId,\n      rejectionReason: null,\n    });\n    expect(audit.calls[0]?.payload.changes).toEqual([\n      { field: \"wallet\", before: null, after: \"WaLLeT-1\" },\n      { field: \"rate_bps\", before: null, after: 750 },\n    ]);\n  });\n\n  it(\"updates an existing row, diffs only the fields that actually changed, and skips set_by/updated_at in the audit diff\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: {\n        userId: \"user-1\",\n        wallet: \"WaLLeT-old\",\n        rateBps: 1000,\n      },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"kol_rate.update\",\n      rawInput: {\n        userId: \"user-1\",\n        // wallet unchanged → must not appear in diff.\n        wallet: \"WaLLeT-old\",\n        rateBps: 1500,\n      },\n      actorRole: \"business\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(true);\n    if (!result.ok) return;\n    expect(result.resourceId).toBe(\"user-1\");\n    expect(result.changes).toEqual([\n      { field: \"rate_bps\", before: 1000, after: 1500 },\n    ]);\n\n    // SELECT + UPDATE (no INSERT).\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    expect(findCall(sqlMock.txCalls, \"update\")).toBeDefined();\n    expect(findCall(sqlMock.txCalls, \"insert\")).toBeUndefined();\n\n    const updateCall = findCall(sqlMock.txCalls, \"update\");\n    // UPDATE binds wallet, rate_bps, set_by, then user_id.\n    expect(updateCall?.values).toEqual([\n      \"WaLLeT-old\",\n      1500,\n      ACTOR.email,\n      \"user-1\",\n    ]);\n\n    // Audit diff excludes set_by and updated_at — operator metadata, not config.\n    const changes = audit.calls[0]?.payload.changes ?? [];\n    const fields = changes.map((c) => c.field);\n    expect(fields).not.toContain(\"set_by\");\n    expect(fields).not.toContain(\"updated_at\");\n    expect(fields).toEqual([\"rate_bps\"]);\n  });\n\n  it(\"emits an applied audit with an empty diff when the update is a no-op (same wallet + same rate)\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: {\n        userId: \"user-1\",\n        wallet: \"WaLLeT-x\",\n        rateBps: 1500,\n      },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"kol_rate.update\",\n      rawInput: {\n        userId: \"user-1\",\n        wallet: \"WaLLeT-x\",\n        rateBps: 1500,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(true);\n    if (!result.ok) return;\n    expect(result.changes).toEqual([]);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n    expect(audit.calls[0]?.payload.changes).toEqual([]);\n  });\n\n  it(\"rejects an invalid rateBps via the schema with peek.change.rejected and never opens a transaction\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock();\n\n    const result = await runPeekMutation({\n      actionId: \"kol_rate.update\",\n      rawInput: {\n        userId: \"user-1\",\n        wallet: \"WaLLeT-1\",\n        rateBps: KOL_RATE_BPS_MAX + 1,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"invalid_input\");\n      expect(result.fieldErrors?.rateBps?.length).toBeGreaterThan(0);\n    }\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(sqlMock.txCalls).toHaveLength(0);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n    expect(audit.calls[0]?.payload.actionId).toBe(\"kol_rate.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"referral_kol_rates\");\n    expect(audit.calls[0]?.payload.changes).toBeNull();\n  });\n\n  it(\"rejects an unauthorized actor role with peek.change.rejected and never queries the DB\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock();\n\n    // Tighten action rule so business is denied.\n    const adminOnly: ReadonlyArray<PeekActionRule> = [\n      { actionId: \"kol_rate.update\", roles: [\"admin\"] },\n    ];\n\n    const result = await runPeekMutation({\n      actionId: \"kol_rate.update\",\n      rawInput: {\n        userId: \"user-1\",\n        wallet: \"WaLLeT-1\",\n        rateBps: 1500,\n      },\n      actorRole: \"business\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: adminOnly,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(sqlMock.txCalls).toHaveLength(0);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n    expect(audit.calls[0]?.payload.actionId).toBe(\"kol_rate.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"referral_kol_rates\");\n  });\n\n  it(\"rolls back and emits peek.change.rejected when the INSERT collides with the wallet UNIQUE constraint\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: null,\n      failOnInsert: new Error(\n        'duplicate key value violates unique constraint \"referral_kol_rates_wallet_key\"',\n      ),\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"kol_rate.update\",\n      rawInput: {\n        userId: \"user-1\",\n        wallet: \"WaLLeT-collides\",\n        rateBps: 1500,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"execution_failed\");\n      expect(result.message).toContain(\"duplicate key\");\n    }\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(true);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n      /^execution_failed: /,\n    );\n    expect(audit.calls[0]?.payload.actionId).toBe(\"kol_rate.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"referral_kol_rates\");\n  });\n});\n","numLines":526,"startLine":1,"totalLines":526}}}
