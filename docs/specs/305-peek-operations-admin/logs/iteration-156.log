{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YNNwRGZtKcDa658vYATW8S","type":"tool_result","content":"1\t/**\n2\t * Local E2E: Waitlist app + backend smoke test.\n3\t *\n4\t * Verifies:\n5\t * 1. Waitlist app loads and renders (Playwright browser test)\n6\t * 2. Backend health endpoint responds\n7\t * 3. Auth challenge-response flow works (API-level, programmatic signing)\n8\t * 4. Referral code set + apply flow works (API-level)\n9\t *\n10\t * Prerequisites:\n11\t * - Backend running at http://localhost:3100 (DATABASE_URL pointing to local PG)\n12\t * - Waitlist app running at http://localhost:5173 (npm run dev)\n13\t *\n14\t * Run: cd e2e && pnpm exec playwright test local/waitlist-smoke.spec.ts\n15\t */\n16\timport { test, expect } from \"@playwright/test\";\n17\timport { Keypair } from \"@solana/web3.js\";\n18\timport { sign } from \"tweetnacl\";\n19\timport bs58 from \"bs58\";\n20\t\n21\tconst BACKEND_URL = process.env.VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\";\n22\tconst WAITLIST_URL = process.env.WAITLIST_URL ?? \"http://127.0.0.1:5173\";\n23\t\n24\t// Deterministic test keypairs (not funded — no on-chain ops needed)\n25\tconst USER_A = Keypair.generate();\n26\tconst USER_B = Keypair.generate();\n27\t\n28\t// ── Auth helper ────────────────────────────────────────────────────\n29\t\n30\tasync function authenticate(keypair: Keypair): Promise<{\n31\t  accessToken: string;\n32\t  refreshToken: string;\n33\t}> {\n34\t  const wallet = keypair.publicKey.toBase58();\n35\t\n36\t  const challengeResp = await fetch(`${BACKEND_URL}/auth/challenge`, {\n37\t    method: \"POST\",\n38\t    headers: { \"Content-Type\": \"application/json\" },\n39\t    body: JSON.stringify({ wallet }),\n40\t  });\n41\t  expect(challengeResp.ok).toBe(true);\n42\t  const { nonce, message } = (await challengeResp.json()) as {\n43\t    nonce: string;\n44\t    message: string;\n45\t  };\n46\t\n47\t  const messageBytes = new TextEncoder().encode(message);\n48\t  const signature = sign.detached(messageBytes, keypair.secretKey);\n49\t  const signatureBase58 = bs58.encode(signature);\n50\t\n51\t  const verifyResp = await fetch(`${BACKEND_URL}/auth/verify`, {\n52\t    method: \"POST\",\n53\t    headers: { \"Content-Type\": \"application/json\" },\n54\t    body: JSON.stringify({ nonce, wallet, signature: signatureBase58 }),\n55\t  });\n56\t  expect(verifyResp.ok).toBe(true);\n57\t  const tokens = (await verifyResp.json()) as {\n58\t    accessToken: string;\n59\t    refreshToken: string;\n60\t  };\n61\t  return tokens;\n62\t}\n63\t\n64\tfunction authHeaders(token: string) {\n65\t  return {\n66\t    \"Content-Type\": \"application/json\",\n67\t    Authorization: `Bearer ${token}`,\n68\t  };\n69\t}\n70\t\n71\t// ── Tests ──────────────────────────────────────────────────────────\n72\t\n73\ttest.describe(\"waitlist + backend smoke\", () => {\n74\t  test(\"backend health check\", async () => {\n75\t    const resp = await fetch(`${BACKEND_URL}/health`);\n76\t    expect(resp.ok).toBe(true);\n77\t    const body = (await resp.json()) as { status: string };\n78\t    expect(body.status).toBe(\"ok\");\n79\t  });\n80\t\n81\t  test(\"waitlist app loads and renders\", async ({ page }) => {\n82\t    await page.goto(WAITLIST_URL);\n83\t    // App should render (not blank screen)\n84\t    await expect(page.locator(\"body\")).not.toBeEmpty();\n85\t    // Should have some visible content within 10s (check for any button — proves React rendered)\n86\t    await expect(page.locator(\"button\").first()).toBeVisible({ timeout: 10_000 });\n87\t  });\n88\t\n89\t  test(\"waitlist shows connect wallet button\", async ({ page }) => {\n90\t    await page.goto(WAITLIST_URL);\n91\t    // Should have a wallet connect button/element\n92\t    const connectBtn = page.locator(\"button\").filter({ hasText: /connect|wallet/i }).first();\n93\t    await expect(connectBtn).toBeVisible({ timeout: 10_000 });\n94\t  });\n95\t\n96\t  test(\"auth: challenge → verify → profile created → refresh → logout\", async () => {\n97\t    // 1. Authenticate\n98\t    const { accessToken, refreshToken } = await authenticate(USER_A);\n99\t    expect(accessToken).toBeTruthy();\n100\t    expect(refreshToken).toBeTruthy();\n101\t\n102\t    // 2. Profile was auto-created — GET /profile/me should work\n103\t    const profileResp = await fetch(`${BACKEND_URL}/profile/me`, {\n104\t      headers: authHeaders(accessToken),\n105\t    });\n106\t    expect(profileResp.ok).toBe(true);\n107\t    const profile = (await profileResp.json()) as {\n108\t      userId: string;\n109\t      username: string;\n110\t    };\n111\t    expect(profile.userId).toMatch(/^usr_/);\n112\t    expect(profile.username).toBeTruthy();\n113\t\n114\t    // 3. Refresh token works\n115\t    const refreshResp = await fetch(`${BACKEND_URL}/auth/refresh`, {\n116\t      method: \"POST\",\n117\t      headers: { \"Content-Type\": \"application/json\" },\n118\t      body: JSON.stringify({ refreshToken }),\n119\t    });\n120\t    expect(refreshResp.ok).toBe(true);\n121\t    const newTokens = (await refreshResp.json()) as {\n122\t      accessToken: string;\n123\t      refreshToken: string;\n124\t    };\n125\t    expect(newTokens.accessToken).toBeTruthy();\n126\t\n127\t    // 4. Logout\n128\t    const logoutResp = await fetch(`${BACKEND_URL}/auth/logout`, {\n129\t      method: \"POST\",\n130\t      headers: { \"Content-Type\": \"application/json\" },\n131\t      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n132\t    });\n133\t    expect(logoutResp.ok).toBe(true);\n134\t  });\n135\t\n136\t  test(\"referral: set code → apply → verify link\", async () => {\n137\t    // Authenticate both users\n138\t    const { accessToken: tokenA } = await authenticate(USER_A);\n139\t    const { accessToken: tokenB } = await authenticate(USER_B);\n140\t\n141\t    // User A sets a referral code\n142\t    const codeResp = await fetch(`${BACKEND_URL}/referral/code`, {\n143\t      method: \"POST\",\n144\t      headers: authHeaders(tokenA),\n145\t      body: JSON.stringify({ code: `t-${Date.now().toString(36)}` }),\n146\t    });\n147\t    if (!codeResp.ok) {\n148\t      const errBody = await codeResp.text();\n149\t      throw new Error(`POST /referral/code failed (${codeResp.status}): ${errBody}`);\n150\t    }\n151\t    const { code } = (await codeResp.json()) as { code: string };\n152\t    expect(code).toBeTruthy();\n153\t\n154\t    // User B applies the code\n155\t    const applyResp = await fetch(`${BACKEND_URL}/referral/apply`, {\n156\t      method: \"POST\",\n157\t      headers: authHeaders(tokenB),\n158\t      body: JSON.stringify({ code }),\n159\t    });\n160\t    expect(applyResp.ok).toBe(true);\n161\t\n162\t    // Verify the link exists\n163\t    const referrerResp = await fetch(`${BACKEND_URL}/referral/referrer`, {\n164\t      headers: authHeaders(tokenB),\n165\t    });\n166\t    expect(referrerResp.ok).toBe(true);\n167\t    const referrer = (await referrerResp.json()) as {\n168\t      referrerUserId: string;\n169\t      referrerUsername: string;\n170\t      referrerCode: string;\n171\t    };\n172\t    expect(referrer.referrerCode).toBe(code);\n173\t    expect(referrer.referrerUsername).toBeTruthy();\n174\t\n175\t    // User A sees the referral in their list\n176\t    const referralsResp = await fetch(`${BACKEND_URL}/referral/referrals`, {\n177\t      headers: authHeaders(tokenA),\n178\t    });\n179\t    expect(referralsResp.ok).toBe(true);\n180\t    const referrals = (await referralsResp.json()) as {\n181\t      items: Array<{ refereeUserId: string; refereeUsername: string }>;\n182\t    };\n183\t    expect(referrals.items.length).toBeGreaterThanOrEqual(1);\n184\t    expect(referrals.items[0].refereeUsername).toBeTruthy();\n185\t  });\n186\t});\n187\t"}]},"parent_tool_use_id":null,"session_id":"b47d8a49-464b-4771-b4dd-051e0ec1f7ed","uuid":"162898d5-ab04-49bc-ae82-4b506d237c7d","timestamp":"2026-04-26T20:10:40.484Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/e2e/local/waitlist-smoke.spec.ts","content":"/**\n * Local E2E: Waitlist app + backend smoke test.\n *\n * Verifies:\n * 1. Waitlist app loads and renders (Playwright browser test)\n * 2. Backend health endpoint responds\n * 3. Auth challenge-response flow works (API-level, programmatic signing)\n * 4. Referral code set + apply flow works (API-level)\n *\n * Prerequisites:\n * - Backend running at http://localhost:3100 (DATABASE_URL pointing to local PG)\n * - Waitlist app running at http://localhost:5173 (npm run dev)\n *\n * Run: cd e2e && pnpm exec playwright test local/waitlist-smoke.spec.ts\n */\nimport { test, expect } from \"@playwright/test\";\nimport { Keypair } from \"@solana/web3.js\";\nimport { sign } from \"tweetnacl\";\nimport bs58 from \"bs58\";\n\nconst BACKEND_URL = process.env.VITE_FAIRNESS_BACKEND_URL ?? \"http://127.0.0.1:3100\";\nconst WAITLIST_URL = process.env.WAITLIST_URL ?? \"http://127.0.0.1:5173\";\n\n// Deterministic test keypairs (not funded — no on-chain ops needed)\nconst USER_A = Keypair.generate();\nconst USER_B = Keypair.generate();\n\n// ── Auth helper ────────────────────────────────────────────────────\n\nasync function authenticate(keypair: Keypair): Promise<{\n  accessToken: string;\n  refreshToken: string;\n}> {\n  const wallet = keypair.publicKey.toBase58();\n\n  const challengeResp = await fetch(`${BACKEND_URL}/auth/challenge`, {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ wallet }),\n  });\n  expect(challengeResp.ok).toBe(true);\n  const { nonce, message } = (await challengeResp.json()) as {\n    nonce: string;\n    message: string;\n  };\n\n  const messageBytes = new TextEncoder().encode(message);\n  const signature = sign.detached(messageBytes, keypair.secretKey);\n  const signatureBase58 = bs58.encode(signature);\n\n  const verifyResp = await fetch(`${BACKEND_URL}/auth/verify`, {\n    method: \"POST\",\n    headers: { \"Content-Type\": \"application/json\" },\n    body: JSON.stringify({ nonce, wallet, signature: signatureBase58 }),\n  });\n  expect(verifyResp.ok).toBe(true);\n  const tokens = (await verifyResp.json()) as {\n    accessToken: string;\n    refreshToken: string;\n  };\n  return tokens;\n}\n\nfunction authHeaders(token: string) {\n  return {\n    \"Content-Type\": \"application/json\",\n    Authorization: `Bearer ${token}`,\n  };\n}\n\n// ── Tests ──────────────────────────────────────────────────────────\n\ntest.describe(\"waitlist + backend smoke\", () => {\n  test(\"backend health check\", async () => {\n    const resp = await fetch(`${BACKEND_URL}/health`);\n    expect(resp.ok).toBe(true);\n    const body = (await resp.json()) as { status: string };\n    expect(body.status).toBe(\"ok\");\n  });\n\n  test(\"waitlist app loads and renders\", async ({ page }) => {\n    await page.goto(WAITLIST_URL);\n    // App should render (not blank screen)\n    await expect(page.locator(\"body\")).not.toBeEmpty();\n    // Should have some visible content within 10s (check for any button — proves React rendered)\n    await expect(page.locator(\"button\").first()).toBeVisible({ timeout: 10_000 });\n  });\n\n  test(\"waitlist shows connect wallet button\", async ({ page }) => {\n    await page.goto(WAITLIST_URL);\n    // Should have a wallet connect button/element\n    const connectBtn = page.locator(\"button\").filter({ hasText: /connect|wallet/i }).first();\n    await expect(connectBtn).toBeVisible({ timeout: 10_000 });\n  });\n\n  test(\"auth: challenge → verify → profile created → refresh → logout\", async () => {\n    // 1. Authenticate\n    const { accessToken, refreshToken } = await authenticate(USER_A);\n    expect(accessToken).toBeTruthy();\n    expect(refreshToken).toBeTruthy();\n\n    // 2. Profile was auto-created — GET /profile/me should work\n    const profileResp = await fetch(`${BACKEND_URL}/profile/me`, {\n      headers: authHeaders(accessToken),\n    });\n    expect(profileResp.ok).toBe(true);\n    const profile = (await profileResp.json()) as {\n      userId: string;\n      username: string;\n    };\n    expect(profile.userId).toMatch(/^usr_/);\n    expect(profile.username).toBeTruthy();\n\n    // 3. Refresh token works\n    const refreshResp = await fetch(`${BACKEND_URL}/auth/refresh`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken }),\n    });\n    expect(refreshResp.ok).toBe(true);\n    const newTokens = (await refreshResp.json()) as {\n      accessToken: string;\n      refreshToken: string;\n    };\n    expect(newTokens.accessToken).toBeTruthy();\n\n    // 4. Logout\n    const logoutResp = await fetch(`${BACKEND_URL}/auth/logout`, {\n      method: \"POST\",\n      headers: { \"Content-Type\": \"application/json\" },\n      body: JSON.stringify({ refreshToken: newTokens.refreshToken }),\n    });\n    expect(logoutResp.ok).toBe(true);\n  });\n\n  test(\"referral: set code → apply → verify link\", async () => {\n    // Authenticate both users\n    const { accessToken: tokenA } = await authenticate(USER_A);\n    const { accessToken: tokenB } = await authenticate(USER_B);\n\n    // User A sets a referral code\n    const codeResp = await fetch(`${BACKEND_URL}/referral/code`, {\n      method: \"POST\",\n      headers: authHeaders(tokenA),\n      body: JSON.stringify({ code: `t-${Date.now().toString(36)}` }),\n    });\n    if (!codeResp.ok) {\n      const errBody = await codeResp.text();\n      throw new Error(`POST /referral/code failed (${codeResp.status}): ${errBody}`);\n    }\n    const { code } = (await codeResp.json()) as { code: string };\n    expect(code).toBeTruthy();\n\n    // User B applies the code\n    const applyResp = await fetch(`${BACKEND_URL}/referral/apply`, {\n      method: \"POST\",\n      headers: authHeaders(tokenB),\n      body: JSON.stringify({ code }),\n    });\n    expect(applyResp.ok).toBe(true);\n\n    // Verify the link exists\n    const referrerResp = await fetch(`${BACKEND_URL}/referral/referrer`, {\n      headers: authHeaders(tokenB),\n    });\n    expect(referrerResp.ok).toBe(true);\n    const referrer = (await referrerResp.json()) as {\n      referrerUserId: string;\n      referrerUsername: string;\n      referrerCode: string;\n    };\n    expect(referrer.referrerCode).toBe(code);\n    expect(referrer.referrerUsername).toBeTruthy();\n\n    // User A sees the referral in their list\n    const referralsResp = await fetch(`${BACKEND_URL}/referral/referrals`, {\n      headers: authHeaders(tokenA),\n    });\n    expect(referralsResp.ok).toBe(true);\n    const referrals = (await referralsResp.json()) as {\n      items: Array<{ refereeUserId: string; refereeUsername: string }>;\n    };\n    expect(referrals.items.length).toBeGreaterThanOrEqual(1);\n    expect(referrals.items[0].refereeUsername).toBeTruthy();\n  });\n});\n","numLines":187,"startLine":1,"totalLines":187}}}
