 verification for Taunt Bet\n#\n# Usage:\n#   ./scripts/verify              Full verification (all steps)\n#   ./scripts/verify --anchor     Anchor programs only (build + test)\n#   ./scripts/verify --ts         TypeScript only (lint + typecheck + test)\n#   ./scripts/verify --devnet     Devnet E2E tests (non-blocking, skips if env vars missing)\n#\n# Note:\n#   Chat verification currently lives in the `chat/` submodule as `pnpm verify`.\n#   Telegram verification currently lives in the `telegram/` submodule as\n#   `pnpm verify`.\n#   Root verify intentionally remains limited to `backend/` and `solana/` until\n#   the chat/telegram service contracts stabilise.\n# =============================================================================\n\n# Color codes\nGREEN='\\033[0;32m'\nRED='\\033[0;31m'\nYELLOW='\\033[0;33m'\nNC='\\033[0m'\n\nMODE=\"${1:-full}\"\n\n# Normalize flags\ncase \"$MODE\" in\n    --anchor|--anchor-only|anchor) MODE=\"anchor\" ;;\n    --ts|--ts-only|ts) MODE=\"ts\" ;;\n    --devnet|devnet) MODE=\"devnet\" ;;\n    --full|full|\"\") MODE=\"full\" ;;\n    *)\n        echo \"Usage: ./scripts/verify [--anchor|--ts|--devnet|--full]\"\n        exit 1\n        ;;\nesac\n\nROOT=\"$(cd \"$(dirname \"$0\")/..\" && pwd)\"\n\necho -e \"${GREEN}=== Taunt Bet Verification ($MODE) ===${NC}\"\n\n# Check for submodules\nif [ ! -f \"$ROOT/backend/package.json\" ]; then\n    echo -e \"${RED}[FAIL] Backend submodule not initialized.${NC}\"\n    echo \"Run: git submodule update --init --recursive\"\n    exit 1\nfi\n\n# ---------------------------------------------------------------------------\n# TypeScript steps (lint, typecheck, test)\n# ---------------------------------------------------------------------------\nrun_ts() {\n    cd \"$ROOT/backend\"\n\n    # Install dependencies if missing\n    if [ ! -d \"node_modules\" ]; then\n        echo -e \"${GREEN}[INFO] Installing dependencies...${NC}\"\n        pnpm install\n    fi\n\n    echo -e \"${GREEN}[STEP] Linting...${NC}\"\n    pnpm lint\n\n    echo -e \"${GREEN}[STEP] Typechecking...${NC}\"\n    pnpm typecheck\n\n    echo -e \"${GREEN}[STEP] Testing (TS packages)...${NC}\"\n    pnpm test\n\n    cd \"$ROOT\"\n}\n\n# ---------------------------------------------------------------------------\n# Anchor steps (build + test)\n# ---------------------------------------------------------------------------\nrun_anchor() {\n    if ! command -v anchor &>/dev/null; then\n        echo -e \"${YELLOW}[SKIP] Anchor tests (anchor CLI not found)${NC}\"\n        return 0\n    fi\n\n    cd \"$ROOT/solana\"\n\n    if [ ! -d \"node_modules\" ]; then\n        pnpm install --ignore-workspace\n    fi\n\n    echo -e \"${GREEN}[STEP] Building Anchor programs...${NC}\"\n    anchor build\n\n    echo -e \"${GREEN}[STEP] Testing (Anchor programs)...${NC}\"\n    pnpm exec mocha --require tsx/cjs -t 1000000 --exit tests/closecall.ts tests/flipyou.ts tests/potshot.ts tests/platform.ts\n\n    cd \"$ROOT\"\n}\n\n# ---------------------------------------------------------------------------\n# Devnet E2E tests (non-blocking)\n# ---------------------------------------------------------------------------\nrun_devnet_e2e() {\n    if [ -z \"${VITE_FLIPYOU_PROGRAM_ID:-}\" ]; then\n        echo -e \"${YELLOW}[SKIP] Devnet E2E (VITE_FLIPYOU_PROGRAM_ID not set)${NC}\"\n        return 0\n    fi\n\n    if [ ! -d \"$ROOT/e2e/node_modules\" ]; then\n        echo -e \"${GREEN}[INFO] Installing E2E dependencies...${NC}\"\n        cd \"$ROOT/e2e\" && pnpm install && cd \"$ROOT\"\n    fi\n\n    echo -e \"${GREEN}[STEP] Running devnet E2E tests...${NC}\"\n    if cd \"$ROOT/e2e\" && pnpm exec playwright test; then\n        echo -e \"${GREEN}[PASS] Devnet E2E tests passed${NC}\"\n    else\n        echo -e \"${YELLOW}[WARN] Devnet E2E tests failed (non-blocking)${NC}\"\n    fi\n\n    cd \"$ROOT\"\n    return 0\n}\n\n# ---------------------------------------------------------------------------\n# Fee constant consistency check (always runs)\n# ---------------------------------------------------------------------------\necho -e \"${GREEN}[STEP] Checking fee constant consistency...${NC}\"\n\"$ROOT/scripts/check-fees.sh\"\n\n# ---------------------------------------------------------------------------\n# Run based on mode\n# ---------------------------------------------------------------------------\ncase \"$MODE\" in\n    full)\n        run_ts\n        run_anchor\n        ;;\n    ts)\n        run_ts\n        ;;\n    anchor)\n        run_anchor\n        ;;\n    devnet)\n        run_devnet_e2e\n        ;;\nesac\n\necho -e \"${GREEN}=== VERIFICATION PASSED ($MODE) ===${NC}\"\nexit 0\n","numLines":153,"startLine":1,"totalLines":153}}}
