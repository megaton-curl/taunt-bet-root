    {value}\n            </option>\n          ))}\n        </select>\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Event type</span>\n        <input\n          name=\"queueFilterType\"\n          type=\"text\"\n          defaultValue={filters.eventType ?? \"\"}\n          placeholder=\"e.g. points.grant\"\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Event id</span>\n        <input\n          name=\"queueFilterId\"\n          type=\"text\"\n          defaultValue={filters.id ?? \"\"}\n          placeholder=\"event_queue.id\"\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Payload user id</span>\n        <input\n          name=\"queueFilterUserId\"\n          type=\"text\"\n          defaultValue={filters.payloadUserId ?? \"\"}\n          placeholder=\"payload.userId\"\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Age bucket</span>\n        <select\n          name=\"queueFilterAge\"\n          defaultValue={filters.ageBucket ?? \"\"}\n          style={inputStyle}\n        >\n          <option value=\"\">Any</option>\n          {PEEK_EVENT_QUEUE_AGE_BUCKETS.map((bucket) => (\n            <option key={bucket.id} value={bucket.id}>\n              {bucket.label}\n            </option>\n          ))}\n        </select>\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Scheduled from</span>\n        <input\n          name=\"queueFilterScheduledFrom\"\n          type=\"date\"\n          defaultValue={(filters.scheduledFrom ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Scheduled to</span>\n        <input\n          name=\"queueFilterScheduledTo\"\n          type=\"date\"\n          defaultValue={(filters.scheduledTo ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Created from</span>\n        <input\n          name=\"queueFilterCreatedFrom\"\n          type=\"date\"\n          defaultValue={(filters.createdFrom ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Created to</span>\n        <input\n          name=\"queueFilterCreatedTo\"\n          type=\"date\"\n          defaultValue={(filters.createdTo ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <button type=\"submit\" style={buttonStyle}>\n        Apply filters\n      </button>\n    </form>\n  );\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n  gridTemplateColumns: \"repeat(auto-fit, minmax(180px, 1fr))\",\n  alignItems: \"end\",\n};\n\nconst fieldStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.35rem\",\n  fontSize: \"0.875rem\",\n};\n\nconst inputStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #334155\",\n  background: \"#111827\",\n  color: \"#e2e8f0\",\n  padding: \"0.625rem 0.75rem\",\n};\n\nconst buttonStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #475569\",\n  background: \"#1d4ed8\",\n  color: \"#eff6ff\",\n  padding: \"0.75rem 1rem\",\n  fontWeight: 600,\n};\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_012PEw5edtwCpvvjkX7gA2oy","type":"message","role":"assistant","content":[{"type":"text","text":"Now the table component. It needs to render row data with status chip, error preview, linked drilldowns, and a \"Open detail\" link that sets `selectedId`."}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2012,"cache_read_input_tokens":115081,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2012},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"fe23ce19-cc23-4081-8a30-8dd2baa79aad","uuid":"2d1e9956-8cd8-48c2-b9d9-f7e51a05ea1c"}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_012PEw5edtwCpvvjkX7gA2oy","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_018T6mecbPWwUrY5ZKsLbyeW","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/event-queue-table.tsx","content":"// Event queue table for /operations/queue (FR-10).\n//\n// Read-only dense table over `PeekEventQueueListRow`. Status drives the chip\n// tone (failed/dead = warning/negative — the FR-10 attention states). Each row\n// links to the detail panel via `?selectedId=<id>` so the URL stays shareable\n// and the detail panel renders alongside the table on the same route. Linked\n// payload ids (userId, roundId, claimId) are surfaced inline so an operator\n// can pivot directly into /users/[userId] or future /games/.../rounds/...\n// pages without opening the JSONB.\n//\n// All queue mutations (retry / cancel / replay) are explicitly out of scope\n// for this spec — no buttons or editable inputs are rendered.\nimport Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekEventQueueListRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type EventQueueTableProps = {\n  rows: ReadonlyArray<PeekEventQueueListRow>;\n  selectedId?: string | null;\n  selectedIdHrefBuilder?: (row: PeekEventQueueListRow) => string;\n  error?: string | null;\n};\n\nexport function EventQueueTable({\n  rows,\n  selectedId = null,\n  selectedIdHrefBuilder,\n  error = null,\n}: EventQueueTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Event queue rows unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>\n          No event_queue rows match these filters.\n        </p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see pending, processing,\n          completed, failed, and dead events.\n        </p>\n      </div>\n    );\n  }\n\n  const buildHref =\n    selectedIdHrefBuilder ?? ((row) => `/operations/queue?selectedId=${encodeURIComponent(row.id)}`);\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Status</th>\n            <th style={headerCellStyle(\"left\")}>Event type</th>\n            <th style={headerCellStyle(\"right\")}>Attempts</th>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>Scheduled</th>\n            <th style={headerCellStyle(\"left\")}>Started</th>\n            <th style={headerCellStyle(\"left\")}>Completed</th>\n            <th style={headerCellStyle(\"left\")}>Linked</th>\n            <th style={headerCellStyle(\"left\")}>Error</th>\n            <th style={headerCellStyle(\"left\")}>ID</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => {\n            const isSelected = selectedId === row.id;\n            const detailHref = buildHref(row);\n            return (\n              <tr\n                key={row.id}\n                aria-current={isSelected ? \"true\" : undefined}\n                style={isSelected ? selectedRowStyle : bodyRowStyle}\n              >\n                <td style={bodyCellStyle(\"left\")}>\n                  <StatusChip\n                    label={row.status}\n                    tone={queueStatusTone(row.status)}\n                  />\n                </td>\n                <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                  {row.eventType}\n                </td>\n                <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                  {row.attempts.toLocaleString(\"en-US\")} /{\" \"}\n                  {row.maxAttempts.toLocaleString(\"en-US\")}\n                </td>\n                <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n                <td style={bodyCellStyle(\"left\")}>{row.scheduledAt}</td>\n                <td style={bodyCellStyle(\"left\")}>{row.startedAt ?? \"—\"}</td>\n                <td style={bodyCellStyle(\"left\")}>{row.completedAt ?? \"—\"}</td>\n                <td style={bodyCellStyle(\"left\")}>\n                  {renderLinked(row)}\n                </td>\n                <td style={{ ...bodyCellStyle(\"left\"), maxWidth: \"20rem\" }}>\n                  {row.errorPreview ? (\n                    <span style={errorPreviewStyle}>{row.errorPreview}</span>\n                  ) : (\n                    \"—\"\n                  )}\n                </td>\n                <td style={bodyCellStyle(\"left\")}>\n                  <Link\n                    href={detailHref}\n                    aria-label={`Open detail for event ${row.id}`}\n                    style={detailLinkStyle}\n                  >\n                    {row.id}\n                  </Link>\n                </td>\n              </tr>\n            );\n          })}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction renderLinked(row: PeekEventQueueListRow) {\n  const { userId, roundId, claimId } = row.linked;\n  if (!userId && !roundId && !claimId) return <span>—</span>;\n  return (\n    <div style={linkedStyle}>\n      {userId ? (\n        <Link\n          href={`/users/${encodeURIComponent(userId)}`}\n          style={linkedLinkStyle}\n        >\n          user {userId}\n        </Link>\n      ) : null}\n      {roundId ? (\n        <span style={linkedTokenStyle}>round {roundId}</span>\n      ) : null}\n      {claimId ? (\n        <span style={linkedTokenStyle}>claim {claimId}</span>\n      ) : null}\n    </div>\n  );\n}\n\nexport function queueStatusTone(value: string): PeekStatusTone {\n  if (value === \"completed\") return \"positive\";\n  if (value === \"processing\") return \"info\";\n  if (value === \"pending\") return \"neutral\";\n  if (value === \"failed\") return \"warning\";\n  if (value === \"dead\") return \"negative\";\n  return \"neutral\";\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst selectedRowStyle: CSSProperties = {\n  ...bodyRowStyle,\n  background: \"#172554\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorPreviewStyle: CSSProperties = {\n  display: \"block\",\n  whiteSpace: \"pre-wrap\",\n  wordBreak: \"break-word\",\n  color: \"#fecaca\",\n  fontFamily: \"monospace\",\n  fontSize: \"0.75rem\",\n};\n\nconst linkedStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst linkedLinkStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  fontSize: \"0.75rem\",\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst linkedTokenStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  fontSize: \"0.75rem\",\n  color: \"#cbd5f5\",\n};\n\nconst detailLinkStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  fontSize: \"0.75rem\",\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2012,"cache_read_input_tokens":115081,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2012},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"fe23ce19-cc23-4081-8a30-8dd2baa79aad","uuid":"efe55458-f7d0-4d8f-9cfe-2bbfda335071"}
