      <div style={metaRowStyle}>\n              <dt style={metaTermStyle}>As of</dt>\n              <dd style={metaValueStyle}>{metric.asOf ?? \"—\"}</dd>\n            </div>\n          </dl>\n          {metric.drilldownHref ? (\n            <Link href={metric.drilldownHref} style={drilldownStyle}>\n              View rows →\n            </Link>\n          ) : null}\n        </article>\n      ))}\n    </section>\n  );\n}\n\nconst cardStyle: CSSProperties = {\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n  padding: \"1rem\",\n  background: \"#111827\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst cardHeaderStyle: CSSProperties = {\n  display: \"flex\",\n  alignItems: \"center\",\n  justifyContent: \"space-between\",\n  gap: \"0.5rem\",\n};\n\nconst labelStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.875rem\",\n  fontWeight: 600,\n};\n\nconst valueStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1.75rem\",\n  fontWeight: 700,\n};\n\nconst unitStyle: CSSProperties = {\n  fontSize: \"0.875rem\",\n  fontWeight: 500,\n  color: \"#94a3b8\",\n  marginLeft: \"0.25rem\",\n};\n\nconst definitionStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.8125rem\",\n  color: \"#cbd5f5\",\n};\n\nconst metaStyle: CSSProperties = {\n  margin: 0,\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst metaRowStyle: CSSProperties = {\n  display: \"flex\",\n  justifyContent: \"space-between\",\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n};\n\nconst metaTermStyle: CSSProperties = {\n  margin: 0,\n};\n\nconst metaValueStyle: CSSProperties = {\n  margin: 0,\n  textAlign: \"right\",\n};\n\nconst drilldownStyle: CSSProperties = {\n  fontSize: \"0.8125rem\",\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nfunction freshnessStyle(freshness: PeekMetric[\"freshness\"]): CSSProperties {\n  const tones: Record<PeekMetric[\"freshness\"], { background: string; color: string }> = {\n    live: { background: \"#064e3b\", color: \"#a7f3d0\" },\n    cached: { background: \"#1f2937\", color: \"#cbd5f5\" },\n    manual: { background: \"#3f3f46\", color: \"#fde68a\" },\n    sampled: { background: \"#312e81\", color: \"#c7d2fe\" },\n  };\n  const tone = tones[freshness];\n  return {\n    fontSize: \"0.6875rem\",\n    textTransform: \"uppercase\",\n    letterSpacing: \"0.05em\",\n    padding: \"0.125rem 0.5rem\",\n    borderRadius: \"9999px\",\n    background: tone.background,\n    color: tone.color,\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px solid #1e293b\",\n  background: \"#0b1220\",\n  color: \"#94a3b8\",\n  fontSize: \"0.875rem\",\n};\n","numLines":181,"startLine":1,"totalLines":181}}}
