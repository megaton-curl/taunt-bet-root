{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R4wGTLKkKNsHtoxGaihY45","type":"tool_result","content":"page.tsx\n// /economy/points — points economy admin page (FR-9).\n//\n// Reads two migration-011 tables via `get-points-and-crates.ts`:\n//   - player_points  — top point holders (filterable by user/wallet)\n//   - point_grants   — append-only grant ledger (filterable by user, source\n//                      type, source id, and a [from, to) date window)\n//\n// Both filter bars submit to this same route so URL-addressable filters\n// (FR-4) survive page reloads and can be shared inside the team.\nimport type { CSSProperties } from \"react\";\nimport {\n  PlayerPointsFilterBar,\n  PointGrantsFilterBar,\n} from \"../../../src/components/economy-points-filter-bar\";\nimport { PlayerPointsTable } from \"../../../src/components/player-points-table\";\nimport { PointGrantsTable } from \"../../../src/components/point-grants-table\";\nimport {\n  normalizePlayerPointsFiltersFromSearchParams,\n  normalizePointGrantFiltersFromSearchParams,\n} from \"../../../src/lib/economy-search-params\";\nimport type {\n  PeekPlayerPointsRow,\n  PeekPointGrantLedgerRow,\n} from \"../../../src/lib/types/peek\";\nimport {\n  getPeekActorContext,\n  isRouteAllowedForRole,\n} from \"../../../src/server/access-policy\";\nimport {\n  PEEK_PLAYER_POINTS_DEFAULT_LIMIT,\n  PEEK_POINT_GRANTS_DEFAULT_LIMIT,\n  listPlayerPoints,\n  listPointGrants,\n} from \"../../../src/server/db/queries/get-points-and-crates\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst ROUTE = \"/economy/points\";\n\nexport default async function EconomyPointsPage({\n  searchParams,\n}: {\n  searchParams: Promise<Record<string, string | string[] | undefined>>;\n}) {\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n\n  if (!allowed) {\n    return (\n      <main style={mainStyle}>\n        <header>\n          <h1>Economy · Points</h1>\n        </header>\n        <p role=\"alert\" style={errorStyle}>\n          You do not have access to this page.\n        </p>\n      </main>\n    );\n  }\n\n  const params = await searchParams;\n  const pointsFilters = normalizePlayerPointsFiltersFromSearchParams(params);\n  const grantFilters = normalizePointGrantFiltersFromSearchParams(params);\n\n  let pointsRows: ReadonlyArray<PeekPlayerPointsRow> = [];\n  let grantRows: ReadonlyArray<PeekPointGrantLedgerRow> = [];\n  let pointsError: string | null = null;\n  let grantsError: string | null = null;\n\n  try {\n    pointsRows = await listPlayerPoints({ filters: pointsFilters });\n  } catch (error) {\n    pointsError =\n      error instanceof Error\n        ? error.message\n        : \"Player points could not be loaded.\";\n  }\n\n  try {\n    grantRows = await listPointGrants({ filters: grantFilters });\n  } catch (error) {\n    grantsError =\n      error instanceof Error\n        ? error.message\n        : \"Point grants could not be loaded.\";\n  }\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <h1>Economy · Points</h1>\n        <p style={leadStyle}>\n          Top point holders and the append-only grant ledger. Drill into a row\n          to open the user-detail page for that player.\n        </p>\n      </header>\n\n      <section\n        aria-labelledby=\"balances-heading\"\n        id=\"balances\"","is_error":false}]},"parent_tool_use_id":null,"session_id":"fe23ce19-cc23-4081-8a30-8dd2baa79aad","uuid":"2b63a258-c6cb-42e6-b19c-fe1242bad939","timestamp":"2026-04-26T06:53:43.469Z","tool_use_result":{"stdout":"page.tsx\n// /economy/points — points economy admin page (FR-9).\n//\n// Reads two migration-011 tables via `get-points-and-crates.ts`:\n//   - player_points  — top point holders (filterable by user/wallet)\n//   - point_grants   — append-only grant ledger (filterable by user, source\n//                      type, source id, and a [from, to) date window)\n//\n// Both filter bars submit to this same route so URL-addressable filters\n// (FR-4) survive page reloads and can be shared inside the team.\nimport type { CSSProperties } from \"react\";\nimport {\n  PlayerPointsFilterBar,\n  PointGrantsFilterBar,\n} from \"../../../src/components/economy-points-filter-bar\";\nimport { PlayerPointsTable } from \"../../../src/components/player-points-table\";\nimport { PointGrantsTable } from \"../../../src/components/point-grants-table\";\nimport {\n  normalizePlayerPointsFiltersFromSearchParams,\n  normalizePointGrantFiltersFromSearchParams,\n} from \"../../../src/lib/economy-search-params\";\nimport type {\n  PeekPlayerPointsRow,\n  PeekPointGrantLedgerRow,\n} from \"../../../src/lib/types/peek\";\nimport {\n  getPeekActorContext,\n  isRouteAllowedForRole,\n} from \"../../../src/server/access-policy\";\nimport {\n  PEEK_PLAYER_POINTS_DEFAULT_LIMIT,\n  PEEK_POINT_GRANTS_DEFAULT_LIMIT,\n  listPlayerPoints,\n  listPointGrants,\n} from \"../../../src/server/db/queries/get-points-and-crates\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst ROUTE = \"/economy/points\";\n\nexport default async function EconomyPointsPage({\n  searchParams,\n}: {\n  searchParams: Promise<Record<string, string | string[] | undefined>>;\n}) {\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n\n  if (!allowed) {\n    return (\n      <main style={mainStyle}>\n        <header>\n          <h1>Economy · Points</h1>\n        </header>\n        <p role=\"alert\" style={errorStyle}>\n          You do not have access to this page.\n        </p>\n      </main>\n    );\n  }\n\n  const params = await searchParams;\n  const pointsFilters = normalizePlayerPointsFiltersFromSearchParams(params);\n  const grantFilters = normalizePointGrantFiltersFromSearchParams(params);\n\n  let pointsRows: ReadonlyArray<PeekPlayerPointsRow> = [];\n  let grantRows: ReadonlyArray<PeekPointGrantLedgerRow> = [];\n  let pointsError: s