{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EBWyGji3oYTFo93gPB4PZp","type":"tool_result","content":"1\t// Persistent admin shell (FR-3): brand, role-aware primary navigation, and a\n2\t// verified-actor identity strip. Also renders the access-denied / missing-config\n3\t// states without echoing the verified email back to the page (FR-3 + FR-1).\n4\t//\n5\t// Pure presentational: takes actor + filtered nav items + optional access-issue\n6\t// reason as props. Filtering inaccessible nav items happens in the server\n7\t// layout (which holds the policy module); the shell itself stays browser-safe\n8\t// so it can be rendered in component tests without `next/headers`.\n9\timport Link from \"next/link\";\n10\timport type { CSSProperties, ReactNode } from \"react\";\n11\timport type { PeekActorView } from \"../lib/types/peek\";\n12\t\n13\texport type AdminShellNavItem = {\n14\t  id: string;\n15\t  label: string;\n16\t  href: string;\n17\t};\n18\t\n19\texport type AdminShellAccessIssue = \"no-identity\" | \"no-role\";\n20\t\n21\texport type AdminShellProps = {\n22\t  actor: PeekActorView | null;\n23\t  navItems: ReadonlyArray<AdminShellNavItem>;\n24\t  children: ReactNode;\n25\t  accessIssue?: AdminShellAccessIssue | null;\n26\t};\n27\t\n28\texport function AdminShell({\n29\t  actor,\n30\t  navItems,\n31\t  children,\n32\t  accessIssue = null,\n33\t}: AdminShellProps) {\n34\t  const denied = accessIssue !== null;\n35\t\n36\t  return (\n37\t    <div style={shellStyle}>\n38\t      <header style={headerStyle} aria-label=\"Peek admin shell\">\n39\t        <div style={brandStyle}>Peek</div>\n40\t\n41\t        {!denied && actor && navItems.length > 0 ? (\n42\t          <nav aria-label=\"Primary\" style={navStyle}>\n43\t            <ul style={navListStyle}>\n44\t              {navItems.map((item) => (\n45\t                <li key={item.id}>\n46\t                  <Link href={item.href} style={navLinkStyle}>\n47\t                    {item.label}\n48\t                  </Link>\n49\t                </li>\n50\t              ))}\n51\t            </ul>\n52\t          </nav>\n53\t        ) : null}\n54\t\n55\t        {!denied && actor ? (\n56\t          <div style={identityStyle} aria-label=\"Verified actor\">\n57\t            <span style={emailStyle}>{actor.email}</span>\n58\t            <span\n59\t              data-role={actor.role}\n60\t              aria-label={`Resolved role: ${actor.role}`}\n61\t              style={roleBadgeStyle(actor.role)}\n62\t            >\n63\t              {actor.role}\n64\t            </span>\n65\t          </div>\n66\t        ) : null}\n67\t      </header>\n68\t\n69\t      {denied ? (\n70\t        <section role=\"alert\" aria-label=\"Access denied\" style={deniedStyle}>\n71\t          <h1 style={deniedTitleStyle}>{deniedTitle(accessIssue!)}</h1>\n72\t          <p style={deniedBodyStyle}>{deniedBody(accessIssue!)}</p>\n73\t        </section>\n74\t      ) : (\n75\t        children\n76\t      )}\n77\t    </div>\n78\t  );\n79\t}\n80\t\n81\tfunction deniedTitle(issue: AdminShellAccessIssue): string {\n82\t  return issue === \"no-role\" ? \"Local role not assigned\" : \"Access not available\";\n83\t}\n84\t\n85\tfunction deniedBody(issue: AdminShellAccessIssue): string {\n86\t  return issue === \"no-role\"\n87\t    ? \"This identity reached peek but no local peek role is configured for it. Contact a peek admin to be added to the role policy.\"\n88\t    : \"Cloudflare Access did not deliver a verified identity. Sign in via Cloudflare Access to continue.\";\n89\t}\n90\t\n91\tconst shellStyle: CSSProperties = {\n92\t  display: \"grid\",\n93\t  gap: \"1.5rem\",\n94\t};\n95\t\n96\tconst headerStyle: CSSProperties = {\n97\t  display: \"flex\",\n98\t  flexWrap: \"wrap\",\n99\t  alignItems: \"center\",\n100\t  gap: \"1rem\",\n101\t  padding: \"0.875rem 1.25rem\",\n102\t  borderRadius: \"0.75rem\",\n103\t  background: \"#0b1220\",\n104\t  border: \"1px solid #1e293b\",\n105\t};\n106\t\n107\tconst brandStyle: CSSProperties = {\n108\t  fontSize: \"1rem\",\n109\t  fontWeight: 700,\n110\t  color: \"#eff6ff\",\n111\t  letterSpacing: \"0.02em\",\n112\t};\n113\t\n114\tconst navStyle: CSSProperties = {\n115\t  flex: 1,\n116\t};\n117\t\n118\tconst navListStyle: CSSProperties = {\n119\t  display: \"flex\",\n120\t  flexWrap: \"wrap\",\n121\t  gap: \"0.375rem\",\n122\t  listStyle: \"none\",\n123\t  margin: 0,\n124\t  padding: 0,\n125\t};\n126\t\n127\tconst navLinkStyle: CSSProperties = {\n128\t  display: \"inline-flex\",\n129\t  alignItems: \"center\",\n130\t  fontSize: \"0.8125rem\",\n131\t  textDecoration: \"none\",\n132\t  color: \"#cbd5f5\",\n133\t  padding: \"0.375rem 0.75rem\",\n134\t  borderRadius: \"9999px\",\n135\t  border: \"1px solid #1e293b\",\n136\t};\n137\t\n138\tconst identityStyle: CSSProperties = {\n139\t  display: \"inline-flex\",\n140\t  alignItems: \"center\",\n141\t  gap: \"0.5rem\",\n142\t  fontSize: \"0.8125rem\",\n143\t  color: \"#94a3b8\",\n144\t};\n145\t\n146\tconst emailStyle: CSSProperties = {\n147\t  color: \"#e2e8f0\",\n148\t};\n149\t\n150\tfunction roleBadgeStyle(role: PeekActorView[\"role\"]): CSSProperties {\n151\t  const palette =\n152\t    role === \"admin\"\n153\t      ? { bg: \"#3f1d1d\", fg: \"#fecaca\", border: \"#7f1d1d\" }\n154\t      : { bg: \"#172554\", fg: \"#bfdbfe\", border: \"#1e3a8a\" };\n155\t  return {\n156\t    display: \"inline-flex\",\n157\t    alignItems: \"center\",\n158\t    fontSize: \"0.6875rem\",\n159\t    fontWeight: 700,\n160\t    letterSpacing: \"0.05em\",\n161\t    textTransform: \"uppercase\",\n162\t    padding: \"0.125rem 0.5rem\",\n163\t    borderRadius: \"9999px\",\n164\t    background: palette.bg,\n165\t    color: palette.fg,\n166\t    border: `1px solid ${palette.border}`,\n167\t  };\n168\t}\n169\t\n170\tconst deniedStyle: CSSProperties = {\n171\t  display: \"grid\",\n172\t  gap: \"0.5rem\",\n173\t  padding: \"1.5rem\",\n174\t  borderRadius: \"0.75rem\",\n175\t  border: \"1px solid #7f1d1d\",\n176\t  background: \"#3f1d1d\",\n177\t  color: \"#fecaca\",\n178\t};\n179\t\n180\tconst deniedTitleStyle: CSSProperties = {\n181\t  margin: 0,\n182\t  fontSize: \"1.125rem\",\n183\t  fontWeight: 700,\n184\t};\n185\t\n186\tconst deniedBodyStyle: CSSProperties = {\n187\t  margin: 0,\n188\t  fontSize: \"0.875rem\",\n189\t};\n190\t"}]},"parent_tool_use_id":null,"session_id":"fe23ce19-cc23-4081-8a30-8dd2baa79aad","uuid":"b5bbcf0b-e8ad-416b-a53f-98cf86c85329","timestamp":"2026-04-26T06:53:51.743Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/admin-shell.tsx","content":"// Persistent admin shell (FR-3): brand, role-aware primary navigation, and a\n// verified-actor identity strip. Also renders the access-denied / missing-config\n// states without echoing the verified email back to the page (FR-3 + FR-1).\n//\n// Pure presentational: takes actor + filtered nav items + optional access-issue\n// reason as props. Filtering inaccessible nav items happens in the server\n// layout (which holds the policy module); the shell itself stays browser-safe\n// so it can be rendered in component tests without `next/headers`.\nimport Link from \"next/link\";\nimport type { CSSProperties, ReactNode } from \"react\";\nimport type { PeekActorView } from \"../lib/types/peek\";\n\nexport type AdminShellNavItem = {\n  id: string;\n  label: string;\n  href: string;\n};\n\nexport type AdminShellAccessIssue = \"no-identity\" | \"no-role\";\n\nexport type AdminShellProps = {\n  actor: PeekActorView | null;\n  navItems: ReadonlyArray<AdminShellNavItem>;\n  children: ReactNode;\n  accessIssue?: AdminShellAccessIssue | null;\n};\n\nexport function AdminShell({\n  actor,\n  navItems,\n  children,\n  accessIssue = null,\n}: AdminShellProps) {\n  const denied = accessIssue !== null;\n\n  return (\n    <div style={shellStyle}>\n      <header style={headerStyle} aria-label=\"Peek admin shell\">\n        <div style={brandStyle}>Peek</div>\n\n        {!denied && actor && navItems.length > 0 ? (\n          <nav aria-label=\"Primary\" style={navStyle}>\n            <ul style={navListStyle}>\n              {navItems.map((item) => (\n                <li key={item.id}>\n                  <Link href={item.href} style={navLinkStyle}>\n                    {item.label}\n                  </Link>\n                </li>\n              ))}\n            </ul>\n          </nav>\n        ) : null}\n\n        {!denied && actor ? (\n          <div style={identityStyle} aria-label=\"Verified actor\">\n            <span style={emailStyle}>{actor.email}</span>\n            <span\n              data-role={actor.role}\n              aria-label={`Resolved role: ${actor.role}`}\n              style={roleBadgeStyle(actor.role)}\n            >\n              {actor.role}\n            </span>\n          </div>\n        ) : null}\n      </header>\n\n      {denied ? (\n        <section role=\"alert\" aria-label=\"Access denied\" style={deniedStyle}>\n          <h1 style={deniedTitleStyle}>{deniedTitle(accessIssue!)}</h1>\n          <p style={deniedBodyStyle}>{deniedBody(accessIssue!)}</p>\n        </section>\n      ) : (\n        children\n      )}\n    </div>\n  );\n}\n\nfunction deniedTitle(issue: AdminShellAccessIssue): string {\n  return issue === \"no-role\" ? \"Local role not assigned\" : \"Access not available\";\n}\n\nfunction deniedBody(issue: AdminShellAccessIssue): string {\n  return issue === \"no-role\"\n    ? \"This identity reached peek but no local peek role is configured for it. Contact a peek admin to be added to the role policy.\"\n    : \"Cloudflare Access did not deliver a verified identity. Sign in via Cloudflare Access to continue.\";\n}\n\nconst shellStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst headerStyle: CSSProperties = {\n  display: \"flex\",\n  flexWrap: \"wrap\",\n  alignItems: \"center\",\n  gap: \"1rem\",\n  padding: \"0.875rem 1.25rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#0b1220\",\n  border: \"1px solid #1e293b\",\n};\n\nconst brandStyle: CSSProperties = {\n  fontSize: \"1rem\",\n  fontWeight: 700,\n  color: \"#eff6ff\",\n  letterSpacing: \"0.02em\",\n};\n\nconst navStyle: CSSProperties = {\n  flex: 1,\n};\n\nconst navListStyle: CSSProperties = {\n  display: \"flex\",\n  flexWrap: \"wrap\",\n  gap: \"0.375rem\",\n  listStyle: \"none\",\n  margin: 0,\n  padding: 0,\n};\n\nconst navLinkStyle: CSSProperties = {\n  display: \"inline-flex\",\n  alignItems: \"center\",\n  fontSize: \"0.8125rem\",\n  textDecoration: \"none\",\n  color: \"#cbd5f5\",\n  padding: \"0.375rem 0.75rem\",\n  borderRadius: \"9999px\",\n  border: \"1px solid #1e293b\",\n};\n\nconst identityStyle: CSSProperties = {\n  display: \"inline-flex\",\n  alignItems: \"center\",\n  gap: \"0.5rem\",\n  fontSize: \"0.8125rem\",\n  color: \"#94a3b8\",\n};\n\nconst emailStyle: CSSProperties = {\n  color: \"#e2e8f0\",\n};\n\nfunction roleBadgeStyle(role: PeekActorView[\"role\"]): CSSProperties {\n  const palette =\n    role === \"admin\"\n      ? { bg: \"#3f1d1d\", fg: \"#fecaca\", border: \"#7f1d1d\" }\n      : { bg: \"#172554\", fg: \"#bfdbfe\", border: \"#1e3a8a\" };\n  return {\n    display: \"inline-flex\",\n    alignItems: \"center\",\n    fontSize: \"0.6875rem\",\n    fontWeight: 700,\n    letterSpacing: \"0.05em\",\n    textTransform: \"uppercase\",\n    padding: \"0.125rem 0.5rem\",\n    borderRadius: \"9999px\",\n    background: palette.bg,\n    color: palette.fg,\n    border: `1px solid ${palette.border}`,\n  };\n}\n\nconst deniedStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.5rem\",\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px solid #7f1d1d\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst deniedTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1.125rem\",\n  fontWeight: 700,\n};\n\nconst deniedBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n};\n","numLines":190,"startLine":1,"totalLines":190}}}
