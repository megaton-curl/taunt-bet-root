{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BdcjAZXHWUy9dAbJTFNFWX","type":"tool_result","content":"1\t// URL-addressable filter params for /operations/dogpile (FR-9).\n2\t//\n3\t// Two prefixed param groups co-exist on the same page so each table can be\n4\t// filtered independently while the URL stays shareable:\n5\t//\n6\t//   dogpile events — `dogpFilter*`  (status, starts_at date range)\n7\t//   fraud flags    — `fraudFilter*` (status, user, flag type, created date\n8\t//                                     range)\n9\t//\n10\t// Empty / whitespace-only values normalise to `null`. Unknown enum values for\n11\t// `status` and `fraud status` normalise to `null` so a stale URL chip cannot\n12\t// lie about the table's filter state.\n13\t\n14\timport { PEEK_DOGPILE_STATUSES } from \"./types/peek\";\n15\timport type {\n16\t  PeekDogpileEventFilters,\n17\t  PeekFraudFlagFilters,\n18\t} from \"./types/peek\";\n19\t\n20\texport const PEEK_FRAUD_FLAG_STATUSES: ReadonlyArray<string> = [\n21\t  \"open\",\n22\t  \"reviewed\",\n23\t  \"dismissed\",\n24\t];\n25\t\n26\texport const PEEK_DOGPILE_STATUS_VALUES: ReadonlyArray<string> =\n27\t  PEEK_DOGPILE_STATUSES;\n28\t\n29\tfunction readSingleValue(value: string | string[] | undefined): string {\n30\t  return Array.isArray(value) ? value[0] ?? \"\" : value ?? \"\";\n31\t}\n32\t\n33\tfunction trimOrNull(value: string): string | null {\n34\t  const trimmed = value.trim();\n35\t  return trimmed.length > 0 ? trimmed : null;\n36\t}\n37\t\n38\tfunction allowlistOrNull(\n39\t  value: string | null,\n40\t  allowed: ReadonlyArray<string>,\n41\t): string | null {\n42\t  if (!value) return null;\n43\t  return allowed.includes(value) ? value : null;\n44\t}\n45\t\n46\texport function normalizeDogpileEventFiltersFromSearchParams(\n47\t  input: Record<string, string | string[] | undefined>,\n48\t): PeekDogpileEventFilters {\n49\t  const status = trimOrNull(readSingleValue(input.dogpFilterStatus));\n50\t  return {\n51\t    status: allowlistOrNull(status, PEEK_DOGPILE_STATUS_VALUES),\n52\t    startsFrom: trimOrNull(readSingleValue(input.dogpFilterFrom)),\n53\t    startsTo: trimOrNull(readSingleValue(input.dogpFilterTo)),\n54\t  };\n55\t}\n56\t\n57\texport function normalizeFraudFlagFiltersFromSearchParams(\n58\t  input: Record<string, string | string[] | undefined>,\n59\t): PeekFraudFlagFilters {\n60\t  const status = trimOrNull(readSingleValue(input.fraudFilterStatus));\n61\t  return {\n62\t    status: allowlistOrNull(status, PEEK_FRAUD_FLAG_STATUSES),\n63\t    userId: trimOrNull(readSingleValue(input.fraudFilterUserId)),\n64\t    flagType: trimOrNull(readSingleValue(input.fraudFilterFlagType)),\n65\t    createdFrom: trimOrNull(readSingleValue(input.fraudFilterFrom)),\n66\t    createdTo: trimOrNull(readSingleValue(input.fraudFilterTo)),\n67\t  };\n68\t}\n69\t"}]},"parent_tool_use_id":null,"session_id":"fe23ce19-cc23-4081-8a30-8dd2baa79aad","uuid":"716c63f6-5172-4c3e-a4b6-9f466f05cda2","timestamp":"2026-04-26T06:53:23.251Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/operations-dogpile-search-params.ts","content":"// URL-addressable filter params for /operations/dogpile (FR-9).\n//\n// Two prefixed param groups co-exist on the same page so each table can be\n// filtered independently while the URL stays shareable:\n//\n//   dogpile events — `dogpFilter*`  (status, starts_at date range)\n//   fraud flags    — `fraudFilter*` (status, user, flag type, created date\n//                                     range)\n//\n// Empty / whitespace-only values normalise to `null`. Unknown enum values for\n// `status` and `fraud status` normalise to `null` so a stale URL chip cannot\n// lie about the table's filter state.\n\nimport { PEEK_DOGPILE_STATUSES } from \"./types/peek\";\nimport type {\n  PeekDogpileEventFilters,\n  PeekFraudFlagFilters,\n} from \"./types/peek\";\n\nexport const PEEK_FRAUD_FLAG_STATUSES: ReadonlyArray<string> = [\n  \"open\",\n  \"reviewed\",\n  \"dismissed\",\n];\n\nexport const PEEK_DOGPILE_STATUS_VALUES: ReadonlyArray<string> =\n  PEEK_DOGPILE_STATUSES;\n\nfunction readSingleValue(value: string | string[] | undefined): string {\n  return Array.isArray(value) ? value[0] ?? \"\" : value ?? \"\";\n}\n\nfunction trimOrNull(value: string): string | null {\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nfunction allowlistOrNull(\n  value: string | null,\n  allowed: ReadonlyArray<string>,\n): string | null {\n  if (!value) return null;\n  return allowed.includes(value) ? value : null;\n}\n\nexport function normalizeDogpileEventFiltersFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): PeekDogpileEventFilters {\n  const status = trimOrNull(readSingleValue(input.dogpFilterStatus));\n  return {\n    status: allowlistOrNull(status, PEEK_DOGPILE_STATUS_VALUES),\n    startsFrom: trimOrNull(readSingleValue(input.dogpFilterFrom)),\n    startsTo: trimOrNull(readSingleValue(input.dogpFilterTo)),\n  };\n}\n\nexport function normalizeFraudFlagFiltersFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): PeekFraudFlagFilters {\n  const status = trimOrNull(readSingleValue(input.fraudFilterStatus));\n  return {\n    status: allowlistOrNull(status, PEEK_FRAUD_FLAG_STATUSES),\n    userId: trimOrNull(readSingleValue(input.fraudFilterUserId)),\n    flagType: trimOrNull(readSingleValue(input.fraudFilterFlagType)),\n    createdFrom: trimOrNull(readSingleValue(input.fraudFilterFrom)),\n    createdTo: trimOrNull(readSingleValue(input.fraudFilterTo)),\n  };\n}\n","numLines":69,"startLine":1,"totalLines":69}}}
