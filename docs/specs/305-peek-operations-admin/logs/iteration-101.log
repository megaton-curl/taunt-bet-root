{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_017Lwjhp5cQe8XbowYV8oLiP","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_014VjZCb5dyAu4ZEapSzF18K","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/event-queue-filter-bar.tsx","content":"// URL-addressable filter bar for /operations/queue (FR-10, FR-4).\n//\n// Filters mirror the spec line \"status, event type, id, payload user id when\n// present, scheduled_at, created_at, and age\". Submitting the form posts\n// queryparams with the `queueFilter*` prefix declared in\n// `operations-queue-search-params.ts`. The `selectedId` param is intentionally\n// not included as a hidden input so opening a row's detail panel never\n// re-applies the row id back into the filter form on submit.\nimport type { CSSProperties } from \"react\";\nimport {\n  PEEK_EVENT_QUEUE_AGE_BUCKETS,\n  PEEK_EVENT_QUEUE_STATUSES,\n} from \"../lib/types/peek\";\nimport type { PeekEventQueueFilters } from \"../lib/types/peek\";\n\nexport type EventQueueFilterBarProps = {\n  filters: PeekEventQueueFilters;\n  action?: string;\n};\n\nexport function EventQueueFilterBar({\n  filters,\n  action = \"/operations/queue\",\n}: EventQueueFilterBarProps) {\n  return (\n    <form\n      action={action}\n      method=\"get\"\n      role=\"search\"\n      aria-label=\"Filter event queue\"\n      style={formStyle}\n    >\n      <label style={fieldStyle}>\n        <span>Status</span>\n        <select\n          name=\"queueFilterStatus\"\n          defaultValue={filters.status ?? \"\"}\n          style={inputStyle}\n        >\n          <option value=\"\">Any</option>\n          {PEEK_EVENT_QUEUE_STATUSES.map((value) => (\n            <option key={value} value={value}>\n              {value}\n            </option>\n          ))}\n        </select>\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Event type</span>\n        <input\n          name=\"queueFilterType\"\n          type=\"text\"\n          defaultValue={filters.eventType ?? \"\"}\n          placeholder=\"e.g. points.grant\"\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Event id</span>\n        <input\n          name=\"queueFilterId\"\n          type=\"text\"\n          defaultValue={filters.id ?? \"\"}\n          placeholder=\"event_queue.id\"\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Payload user id</span>\n        <input\n          name=\"queueFilterUserId\"\n          type=\"text\"\n          defaultValue={filters.payloadUserId ?? \"\"}\n          placeholder=\"payload.userId\"\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Age bucket</span>\n        <select\n          name=\"queueFilterAge\"\n          defaultValue={filters.ageBucket ?? \"\"}\n          style={inputStyle}\n        >\n          <option value=\"\">Any</option>\n          {PEEK_EVENT_QUEUE_AGE_BUCKETS.map((bucket) => (\n            <option key={bucket.id} value={bucket.id}>\n              {bucket.label}\n            </option>\n          ))}\n        </select>\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Scheduled from</span>\n        <input\n          name=\"queueFilterScheduledFrom\"\n          type=\"date\"\n          defaultValue={(filters.scheduledFrom ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Scheduled to</span>\n        <input\n          name=\"queueFilterScheduledTo\"\n          type=\"date\"\n          defaultValue={(filters.scheduledTo ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Created from</span>\n        <input\n          name=\"queueFilterCreatedFrom\"\n          type=\"date\"\n          defaultValue={(filters.createdFrom ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Created to</span>\n        <input\n          name=\"queueFilterCreatedTo\"\n          type=\"date\"\n          defaultValue={(filters.createdTo ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <button type=\"submit\" style={buttonStyle}>\n        Apply filters\n      </button>\n    </form>\n  );\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n  gridTemplateColumns: \"repeat(auto-fit, minmax(180px, 1fr))\",\n  alignItems: \"end\",\n};\n\nconst fieldStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.35rem\",\n  fontSize: \"0.875rem\",\n};\n\nconst inputStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #334155\",\n  background: \"#111827\",\n  color: \"#e2e8f0\",\n  padding: \"0.625rem 0.75rem\",\n};\n\nconst buttonStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #475569\",\n  background: \"#1d4ed8\",\n  color: \"#eff6ff\",\n  padding: \"0.75rem 1rem\",\n  fontWeight: 600,\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1979,"cache_read_input_tokens":113102,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1979},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"fe23ce19-cc23-4081-8a30-8dd2baa79aad","uuid":"da24dde4-b05e-4ab4-b4c0-056d1e5dcf68"}
