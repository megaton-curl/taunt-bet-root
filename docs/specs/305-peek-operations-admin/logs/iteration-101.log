{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0159oM9fqBtV7r4QxhePLZk7","type":"tool_result","content":"1\t// Event-queue admin queries (FR-10).\n2\t//\n3\t// Backs the upcoming `/operations/queue` page. Reads `event_queue`\n4\t// (migration 009) in read-only mode — every queue mutation (retry, cancel,\n5\t// replay) is explicitly out of scope for this spec. The page is a support /\n6\t// audit surface, not a control panel.\n7\t//\n8\t// Three exports:\n9\t//\n10\t//   - `getEventQueueOverview`     — bounded counts for the FR-4 metric strip\n11\t//     (status counts, type counts, age buckets) plus the at-max-attempts and\n12\t//     aged-pending attention metrics. Status counts cover all five migration\n13\t//     check-constraint values (`pending` / `processing` / `completed` /\n14\t//     `failed` / `dead`) so the operator can see a 0 row rather than miss a\n15\t//     state. Type counts are bounded server-side (top 50 by count) so a\n16\t//     malformed enqueue path cannot blow up the page.\n17\t//\n18\t//   - `listEventQueue`            — bounded filtered list. Filters mirror the\n19\t//     spec line \"status, event type, id, payload user id when present,\n20\t//     scheduled_at, created_at, and age\". The `payloadUserId` filter reads\n21\t//     `payload->>'userId'` (camelCase — every backend handler in\n22\t//     `backend/src/queue/handlers/` writes the key in camelCase). The `age`\n23\t//     filter accepts a `PeekEventQueueAgeBucketId` value and applies the\n24\t//     bucket's `[minHoursInclusive, maxHoursExclusive)` window against the\n25\t//     event's `created_at`. Each row carries an `errorPreview` (head, redacted)\n26\t//     and best-effort linked resource ids (`userId` / `roundId` / `claimId`)\n27\t//     extracted server-side from the JSONB payload.\n28\t//\n29\t//   - `getEventQueueDetail`       — single-row detail. Returns the full JSONB\n30\t//     payload + error text with secret redaction applied via\n31\t//     `redactJsonValue` / `redactNullableString` from `peek/src/server/audit/`.\n32\t//     The audit-module helpers are the single source of truth for the\n33\t//     redaction policy.\n34\t\n35\timport type { Sql } from \"postgres\";\n36\timport {\n37\t  PEEK_EVENT_QUEUE_AGE_BUCKETS,\n38\t  PEEK_EVENT_QUEUE_STATUSES,\n39\t  type PeekEventQueueAgeBucketCount,\n40\t  type PeekEventQueueAgeBucketId,\n41\t  type PeekEventQueueDetail,\n42\t  type PeekEventQueueFilters,\n43\t  type PeekEventQueueLinkedIds,\n44\t  type PeekEventQueueListRow,\n45\t  type PeekEventQueueOverview,\n46\t  type PeekEventQueueOverviewMetricId,\n47\t  type PeekEventQueueStatus,\n48\t  type PeekEventQueueStatusCount,\n49\t  type PeekEventQueueTypeCount,\n50\t  type PeekMetric,\n51\t} from \"../../../lib/types/peek\";\n52\timport { redactJsonValue, redactNullableString } from \"../../audit/redact\";\n53\timport { getSqlClient } from \"../client\";\n54\t\n55\texport const PEEK_EVENT_QUEUE_DEFAULT_LIMIT = 100;\n56\texport const PEEK_EVENT_QUEUE_MAX_LIMIT = 500;\n57\texport const PEEK_EVENT_QUEUE_TYPE_COUNT_LIMIT = 50;\n58\texport const PEEK_EVENT_QUEUE_AGED_PENDING_HOURS = 6;\n59\texport const PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS = 240;\n60\t\n61\texport type ListEventQueueOptions = {\n62\t  sql?: Sql;\n63\t  limit?: number;\n64\t  filters?: Partial<PeekEventQueueFilters>;\n65\t  now?: Date;\n66\t};\n67\t\n68\texport type GetEventQueueDetailOptions = {\n69\t  sql?: Sql;\n70\t  id: string;\n71\t};\n72\t\n73\texport type GetEventQueueOverviewOptions = {\n74\t  sql?: Sql;\n75\t  now?: Date;\n76\t  agedPendingHours?: number;\n77\t  typeCountLimit?: number;\n78\t};\n79\t\n80\tfunction clampLimit(\n81\t  raw: number | undefined,\n82\t  fallback: number,\n83\t  max: number,\n84\t): number {\n85\t  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n86\t  const floored = Math.floor(raw);\n87\t  if (floored <= 0) return 1;\n88\t  return Math.min(max, floored);\n89\t}\n90\t\n91\tfunction trimOrNull(value: string | null | undefined): string | null {\n92\t  if (typeof value !== \"string\") return null;\n93\t  const trimmed = value.trim();\n94\t  return trimmed.length > 0 ? trimmed : null;\n95\t}\n96\t\n97\tfunction readInt(value: number | string | null | undefined): number {\n98\t  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n99\t  if (typeof value === \"string\") {\n100\t    const parsed = Number.parseInt(value, 10);\n101\t    return Number.isFinite(parsed) ? parsed : 0;\n102\t  }\n103\t  return 0;\n104\t}\n105\t\n106\tfunction formatCount(count: number): string {\n107\t  return count.toLocaleString(\"en-US\");\n108\t}\n109\t\n110\tfunction isAgeBucketId(value: string): value is PeekEventQueueAgeBucketId {\n111\t  return PEEK_EVENT_QUEUE_AGE_BUCKETS.some((bucket) => bucket.id === value);\n112\t}\n113\t\n114\tfunction previewError(error: string | null): string | null {\n115\t  const redacted = redactNullableString(error);\n116\t  if (redacted === null) return null;\n117\t  if (redacted.length <= PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS) return redacted;\n118\t  return `${redacted.slice(0, PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS)}…`;\n119\t}\n120\t\n121\t// `event_queue.payload` strings are surfaced to operators as scalar drill-down\n122\t// hooks (userId, roundId, claimId). Backend handlers always write these keys\n123\t// camelCase (`backend/src/queue/handlers/*`). The redactor still protects\n124\t// against an opaque secret accidentally landing in the same key — the linked-id\n125\t// values are passed through `redactNullableString` before the row is shaped.\n126\tfunction readLinkedId(\n127\t  row: { userId: string | null; roundId: string | null; claimId: string | null },\n128\t): PeekEventQueueLinkedIds {\n129\t  return {\n130\t    userId: redactNullableString(trimOrNull(row.userId)),\n131\t    roundId: redactNullableString(trimOrNull(row.roundId)),\n132\t    claimId: redactNullableString(trimOrNull(row.claimId)),\n133\t  };\n134\t}\n135\t\n136\texport async function listEventQueue(\n137\t  options: ListEventQueueOptions = {},\n138\t): Promise<ReadonlyArray<PeekEventQueueListRow>> {\n139\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n140\t  const limit = clampLimit(\n141\t    options.limit,\n142\t    PEEK_EVENT_QUEUE_DEFAULT_LIMIT,\n143\t    PEEK_EVENT_QUEUE_MAX_LIMIT,\n144\t  );\n145\t\n146\t  const filters = options.filters ?? {};\n147\t  const status = trimOrNull(filters.status ?? null);\n148\t  const eventType = trimOrNull(filters.eventType ?? null);\n149\t  const id = trimOrNull(filters.id ?? null);\n150\t  const payloadUserId = trimOrNull(filters.payloadUserId ?? null);\n151\t  const scheduledFrom = trimOrNull(filters.scheduledFrom ?? null);\n152\t  const scheduledTo = trimOrNull(filters.scheduledTo ?? null);\n153\t  const createdFrom = trimOrNull(filters.createdFrom ?? null);\n154\t  const createdTo = trimOrNull(filters.createdTo ?? null);\n155\t  const ageBucketRaw = trimOrNull(filters.ageBucket ?? null);\n156\t\n157\t  const now = options.now ?? new Date();\n158\t  const ageBucket =\n159\t    ageBucketRaw !== null && isAgeBucketId(ageBucketRaw) ? ageBucketRaw : null;\n160\t  const ageWindow = ageBucket\n161\t    ? PEEK_EVENT_QUEUE_AGE_BUCKETS.find((b) => b.id === ageBucket) ?? null\n162\t    : null;\n163\t  const ageMaxIso = ageWindow\n164\t    ? new Date(now.getTime() - ageWindow.minHoursInclusive * 60 * 60 * 1000).toISOString()\n165\t    : null;\n166\t  const ageMinIso =\n167\t    ageWindow && ageWindow.maxHoursExclusive !== null\n168\t      ? new Date(now.getTime() - ageWindow.maxHoursExclusive * 60 * 60 * 1000).toISOString()\n169\t      : null;\n170\t  const ageHasMin = ageMinIso !== null;\n171\t\n172\t  const rows = await sql<\n173\t    Array<{\n174\t      id: string;\n175\t      eventType: string;\n176\t      status: string;\n177\t      attempts: number | string;\n178\t      maxAttempts: number | string;\n179\t      scheduledAt: string;\n180\t      startedAt: string | null;\n181\t      completedAt: string | null;\n182\t      createdAt: string;\n183\t      error: string | null;\n184\t      userId: string | null;\n185\t      roundId: string | null;\n186\t      claimId: string | null;\n187\t    }>\n188\t  >`\n189\t    select\n190\t      eq.id::text as \"id\",\n191\t      eq.event_type as \"eventType\",\n192\t      eq.status as \"status\",\n193\t      eq.attempts as \"attempts\",\n194\t      eq.max_attempts as \"maxAttempts\",\n195\t      eq.scheduled_at::text as \"scheduledAt\",\n196\t      eq.started_at::text as \"startedAt\",\n197\t      eq.completed_at::text as \"completedAt\",\n198\t      eq.created_at::text as \"createdAt\",\n199\t      eq.error as \"error\",\n200\t      eq.payload->>'userId' as \"userId\",\n201\t      eq.payload->>'roundId' as \"roundId\",\n202\t      eq.payload->>'claimId' as \"claimId\"\n203\t    from event_queue eq\n204\t    where\n205\t      (${status === null} or eq.status = ${status ?? \"\"})\n206\t      and (${eventType === null} or eq.event_type = ${eventType ?? \"\"})\n207\t      and (${id === null} or eq.id::text = ${id ?? \"\"})\n208\t      and (${payloadUserId === null} or eq.payload->>'userId' = ${payloadUserId ?? \"\"})\n209\t      and (${scheduledFrom === null} or eq.scheduled_at >= ${scheduledFrom ?? \"\"}::timestamptz)\n210\t      and (${scheduledTo === null} or eq.scheduled_at < ${scheduledTo ?? \"\"}::timestamptz)\n211\t      and (${createdFrom === null} or eq.created_at >= ${createdFrom ?? \"\"}::timestamptz)\n212\t      and (${createdTo === null} or eq.created_at < ${createdTo ?? \"\"}::timestamptz)\n213\t      and (${ageMaxIso === null} or eq.created_at <= ${ageMaxIso ?? \"\"}::timestamptz)\n214\t      and (${ageHasMin === false} or eq.created_at > ${ageMinIso ?? \"\"}::timestamptz)\n215\t    order by eq.created_at desc, eq.id desc\n216\t    limit ${limit}\n217\t  `;\n218\t\n219\t  return rows.map((row) => ({\n220\t    id: row.id,\n221\t    eventType: row.eventType,\n222\t    status: row.status,\n223\t    attempts: readInt(row.attempts),\n224\t    maxAttempts: readInt(row.maxAttempts),\n225\t    scheduledAt: row.scheduledAt,\n226\t    startedAt: row.startedAt,\n227\t    completedAt: row.completedAt,\n228\t    createdAt: row.createdAt,\n229\t    errorPreview: previewError(row.error),\n230\t    linked: readLinkedId(row),\n231\t  }));\n232\t}\n233\t\n234\texport async function getEventQueueDetail(\n235\t  options: GetEventQueueDetailOptions,\n236\t): Promise<PeekEventQueueDetail | null> {\n237\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n238\t  const id = trimOrNull(options.id);\n239\t  if (id === null) return null;\n240\t\n241\t  const rows = await sql<\n242\t    Array<{\n243\t      id: string;\n244\t      eventType: string;\n245\t      status: string;\n246\t      attempts: number | string;\n247\t      maxAttempts: number | string;\n248\t      scheduledAt: string;\n249\t      startedAt: string | null;\n250\t      completedAt: string | null;\n251\t      createdAt: string;\n252\t      error: string | null;\n253\t      payload: unknown;\n254\t      userId: string | null;\n255\t      roundId: string | null;\n256\t      claimId: string | null;\n257\t    }>\n258\t  >`\n259\t    select\n260\t      eq.id::text as \"id\",\n261\t      eq.event_type as \"eventType\",\n262\t      eq.status as \"status\",\n263\t      eq.attempts as \"attempts\",\n264\t      eq.max_attempts as \"maxAttempts\",\n265\t      eq.scheduled_at::text as \"scheduledAt\",\n266\t      eq.started_at::text as \"startedAt\",\n267\t      eq.completed_at::text as \"completedAt\",\n268\t      eq.created_at::text as \"createdAt\",\n269\t      eq.error as \"error\",\n270\t      eq.payload as \"payload\",\n271\t      eq.payload->>'userId' as \"userId\",\n272\t      eq.payload->>'roundId' as \"roundId\",\n273\t      eq.payload->>'claimId' as \"claimId\"\n274\t    from event_queue eq\n275\t    where eq.id::text = ${id}\n276\t    limit 1\n277\t  `;\n278\t\n279\t  const row = rows[0];\n280\t  if (!row) return null;\n281\t\n282\t  return {\n283\t    id: row.id,\n284\t    eventType: row.eventType,\n285\t    status: row.status,\n286\t    attempts: readInt(row.attempts),\n287\t    maxAttempts: readInt(row.maxAttempts),\n288\t    scheduledAt: row.scheduledAt,\n289\t    startedAt: row.startedAt,\n290\t    completedAt: row.completedAt,\n291\t    createdAt: row.createdAt,\n292\t    error: redactNullableString(row.error),\n293\t    payload: redactJsonValue(row.payload),\n294\t    linked: readLinkedId(row),\n295\t  };\n296\t}\n297\t\n298\ttype MetricBlueprint = {\n299\t  id: PeekEventQueueOverviewMetricId;\n300\t  label: string;\n301\t  unit: string | null;\n302\t  source: string;\n303\t  windowLabel: string;\n304\t  definition: string;\n305\t  drilldownHref: string | null;\n306\t};\n307\t\n308\tfunction buildMetric(\n309\t  blueprint: MetricBlueprint,\n310\t  raw: number,\n311\t  display: string,\n312\t  asOf: string,\n313\t): PeekMetric {\n314\t  return {\n315\t    id: blueprint.id,\n316\t    label: blueprint.label,\n317\t    value: raw,\n318\t    valueDisplay: display,\n319\t    unit: blueprint.unit,\n320\t    source: blueprint.source,\n321\t    windowLabel: blueprint.windowLabel,\n322\t    asOf,\n323\t    definition: blueprint.definition,\n324\t    freshness: \"live\",\n325\t    drilldownHref: blueprint.drilldownHref,\n326\t  };\n327\t}\n328\t\n329\texport async function getEventQueueOverview(\n330\t  options: GetEventQueueOverviewOptions = {},\n331\t): Promise<PeekEventQueueOverview> {\n332\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n333\t  const now = options.now ?? new Date();\n334\t  const generatedAt = now.toISOString();\n335\t  const agedPendingHours = clampLimit(\n336\t    options.agedPendingHours,\n337\t    PEEK_EVENT_QUEUE_AGED_PENDING_HOURS,\n338\t    24 * 30,\n339\t  );\n340\t  const typeCountLimit = clampLimit(\n341\t    options.typeCountLimit,\n342\t    PEEK_EVENT_QUEUE_TYPE_COUNT_LIMIT,\n343\t    PEEK_EVENT_QUEUE_TYPE_COUNT_LIMIT,\n344\t  );\n345\t  const agedPendingThresholdIso = new Date(\n346\t    now.getTime() - agedPendingHours * 60 * 60 * 1000,\n347\t  ).toISOString();\n348\t\n349\t  // Age-bucket boundaries: each bucket is a half-open window\n350\t  // [minHoursInclusive, maxHoursExclusive) over `now - created_at`. The \"open\"\n351\t  // last bucket has no maxHoursExclusive — it covers everything aged at least\n352\t  // `minHoursInclusive` hours.\n353\t  const ageBucketBoundaries = PEEK_EVENT_QUEUE_AGE_BUCKETS.map((bucket) => ({\n354\t    id: bucket.id,\n355\t    label: bucket.label,\n356\t    olderThanIso: new Date(\n357\t      now.getTime() - bucket.minHoursInclusive * 60 * 60 * 1000,\n358\t    ).toISOString(),\n359\t    youngerThanIso:\n360\t      bucket.maxHoursExclusive === null\n361\t        ? null\n362\t        : new Date(\n363\t            now.getTime() - bucket.maxHoursExclusive * 60 * 60 * 1000,\n364\t          ).toISOString(),\n365\t  }));\n366\t\n367\t  const ageBucketQueries = ageBucketBoundaries.map((boundary) => {\n368\t    const youngerThan = boundary.youngerThanIso;\n369\t    const youngerOpen = youngerThan === null;\n370\t    return sql<Array<{ value: number | string }>>`\n371\t      select count(*)::int as \"value\"\n372\t      from event_queue eq\n373\t      where eq.created_at <= ${boundary.olderThanIso}::timestamptz\n374\t        and (${youngerOpen} or eq.created_at > ${youngerThan ?? \"\"}::timestamptz)\n375\t    `;\n376\t  });\n377\t\n378\t  // Split into two awaits so the typed tuple destructuring stays narrow\n379\t  // (mixing the heterogeneous queries above with the homogeneous age-bucket\n380\t  // queries via `...spread` would broaden every element to the union).\n381\t  const [statusRows, typeRows, atMaxAttemptsRows, agedPendingRows] =\n382\t    await Promise.all([\n383\t      sql<Array<{ status: string; value: number | string }>>`\n384\t        select eq.status as \"status\", count(*)::int as \"value\"\n385\t        from event_queue eq\n386\t        group by eq.status\n387\t      `,\n388\t      sql<Array<{ eventType: string; value: number | string }>>`\n389\t        select eq.event_type as \"eventType\", count(*)::int as \"value\"\n390\t        from event_queue eq\n391\t        group by eq.event_type\n392\t        order by count(*) desc, eq.event_type asc\n393\t        limit ${typeCountLimit}\n394\t      `,\n395\t      sql<Array<{ value: number | string }>>`\n396\t        select count(*)::int as \"value\"\n397\t        from event_queue eq\n398\t        where eq.status in ('pending', 'processing', 'failed', 'dead')\n399\t          and eq.attempts >= eq.max_attempts\n400\t      `,\n401\t      sql<Array<{ value: number | string }>>`\n402\t        select count(*)::int as \"value\"\n403\t        from event_queue eq\n404\t        where eq.status = 'pending'\n405\t          and eq.created_at <= ${agedPendingThresholdIso}::timestamptz\n406\t      `,\n407\t    ]);\n408\t  const ageBucketResponses = await Promise.all(ageBucketQueries);\n409\t\n410\t  // Status counts: project the migration's full status set so a missing status\n411\t  // shows as a 0 row rather than silently disappearing.\n412\t  const statusCountByValue = new Map<string, number>();\n413\t  for (const row of statusRows) {\n414\t    statusCountByValue.set(row.status, readInt(row.value));\n415\t  }\n416\t  const statusCounts: ReadonlyArray<PeekEventQueueStatusCount> =\n417\t    PEEK_EVENT_QUEUE_STATUSES.map((status) => ({\n418\t      status,\n419\t      count: statusCountByValue.get(status) ?? 0,\n420\t    }));\n421\t\n422\t  const typeCounts: ReadonlyArray<PeekEventQueueTypeCount> = typeRows.map(\n423\t    (row) => ({\n424\t      eventType: row.eventType,\n425\t      count: readInt(row.value),\n426\t    }),\n427\t  );\n428\t\n429\t  const ageBuckets: ReadonlyArray<PeekEventQueueAgeBucketCount> =\n430\t    PEEK_EVENT_QUEUE_AGE_BUCKETS.map((bucket, index) => ({\n431\t      id: bucket.id,\n432\t      label: bucket.label,\n433\t      count: readInt(ageBucketResponses[index]?.[0]?.value ?? 0),\n434\t    }));\n435\t\n436\t  const pending = statusCountByValue.get(\"pending\") ?? 0;\n437\t  const processing = statusCountByValue.get(\"processing\") ?? 0;\n438\t  const failed = statusCountByValue.get(\"failed\") ?? 0;\n439\t  const dead = statusCountByValue.get(\"dead\") ?? 0;\n440\t  const atMaxAttempts = readInt(atMaxAttemptsRows[0]?.value ?? 0);\n441\t  const agedPending = readInt(agedPendingRows[0]?.value ?? 0);\n442\t\n443\t  const agedPendingWindowLabel = `Pending for ≥ ${agedPendingHours}h`;\n444\t\n445\t  const blueprints: ReadonlyArray<{\n446\t    blueprint: MetricBlueprint;\n447\t    raw: number;\n448\t    display: string;\n449\t  }> = [\n450\t    {\n451\t      blueprint: {\n452\t        id: \"queue.pending\",\n453\t        label: \"Pending events\",\n454\t        unit: \"events\",\n455\t        source: \"event_queue\",\n456\t        windowLabel: \"Current\",\n457\t        definition:\n458\t          \"Count of event_queue rows with status = 'pending' — work waiting to be picked up by a worker.\",\n459\t        drilldownHref: \"/operations/queue?status=pending\",\n460\t      },\n461\t      raw: pending,\n462\t      display: formatCount(pending),\n463\t    },\n464\t    {\n465\t      blueprint: {\n466\t        id: \"queue.processing\",\n467\t        label: \"Processing events\",\n468\t        unit: \"events\",\n469\t        source: \"event_queue\",\n470\t        windowLabel: \"Current\",\n471\t        definition:\n472\t          \"Count of event_queue rows with status = 'processing' — currently in flight on a worker.\",\n473\t        drilldownHref: \"/operations/queue?status=processing\",\n474\t      },\n475\t      raw: processing,\n476\t      display: formatCount(processing),\n477\t    },\n478\t    {\n479\t      blueprint: {\n480\t        id: \"queue.failed\",\n481\t        label: \"Failed events\",\n482\t        unit: \"events\",\n483\t        source: \"event_queue\",\n484\t        windowLabel: \"Current\",\n485\t        definition:\n486\t          \"Count of event_queue rows with status = 'failed' — last attempt errored, may still be retried before max_attempts.\",\n487\t        drilldownHref: \"/operations/queue?status=failed\",\n488\t      },\n489\t      raw: failed,\n490\t      display: formatCount(failed),\n491\t    },\n492\t    {\n493\t      blueprint: {\n494\t        id: \"queue.dead\",\n495\t        label: \"Dead events\",\n496\t        unit: \"events\",\n497\t        source: \"event_queue\",\n498\t        windowLabel: \"Current\",\n499\t        definition:\n500\t          \"Count of event_queue rows with status = 'dead' — past max_attempts and not retried.\",\n501\t        drilldownHref: \"/operations/queue?status=dead\",\n502\t      },\n503\t      raw: dead,\n504\t      display: formatCount(dead),\n505\t    },\n506\t    {\n507\t      blueprint: {\n508\t        id: \"queue.at_max_attempts\",\n509\t        label: \"At max attempts\",\n510\t        unit: \"events\",\n511\t        source: \"event_queue\",\n512\t        windowLabel: \"Current\",\n513\t        definition:\n514\t          \"Non-completed event_queue rows whose attempts ≥ max_attempts — exhausted retry budget.\",\n515\t        drilldownHref: null,\n516\t      },\n517\t      raw: atMaxAttempts,\n518\t      display: formatCount(atMaxAttempts),\n519\t    },\n520\t    {\n521\t      blueprint: {\n522\t        id: \"queue.aged_pending\",\n523\t        label: \"Aged pending\",\n524\t        unit: \"events\",\n525\t        source: \"event_queue\",\n526\t        windowLabel: agedPendingWindowLabel,\n527\t        definition: `Pending event_queue rows whose created_at is at least ${agedPendingHours}h ago — worker may be stalled.`,\n528\t        drilldownHref: `/operations/queue?status=pending&age=lt_24h`,\n529\t      },\n530\t      raw: agedPending,\n531\t      display: formatCount(agedPending),\n532\t    },\n533\t  ];\n534\t\n535\t  return {\n536\t    generatedAt,\n537\t    metrics: blue