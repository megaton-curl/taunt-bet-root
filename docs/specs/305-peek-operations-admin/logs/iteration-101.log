{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01WQc5KxZg5bLMRnY4As3TA8","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01PLqqWP6qLpScT1EcopYz6t","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/lib/operations-queue-search-params.ts","content":"// URL-addressable filter params for /operations/queue (FR-10).\n//\n// One filter group per page (`queueFilter*`) plus a single `selectedId` param\n// that drives the side-by-side detail panel. Empty / whitespace values\n// normalise to `null`. Unknown enum values for `status` and `age` normalise to\n// `null` so a stale URL chip cannot lie about the table's filter state.\n\nimport {\n  PEEK_EVENT_QUEUE_AGE_BUCKETS,\n  PEEK_EVENT_QUEUE_STATUSES,\n} from \"./types/peek\";\nimport type { PeekEventQueueFilters } from \"./types/peek\";\n\nexport const PEEK_EVENT_QUEUE_STATUS_VALUES: ReadonlyArray<string> =\n  PEEK_EVENT_QUEUE_STATUSES;\n\nexport const PEEK_EVENT_QUEUE_AGE_BUCKET_VALUES: ReadonlyArray<string> =\n  PEEK_EVENT_QUEUE_AGE_BUCKETS.map((bucket) => bucket.id);\n\nfunction readSingleValue(value: string | string[] | undefined): string {\n  return Array.isArray(value) ? value[0] ?? \"\" : value ?? \"\";\n}\n\nfunction trimOrNull(value: string): string | null {\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nfunction allowlistOrNull(\n  value: string | null,\n  allowed: ReadonlyArray<string>,\n): string | null {\n  if (!value) return null;\n  return allowed.includes(value) ? value : null;\n}\n\nexport function normalizeEventQueueFiltersFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): PeekEventQueueFilters {\n  const status = trimOrNull(readSingleValue(input.queueFilterStatus));\n  const ageBucket = trimOrNull(readSingleValue(input.queueFilterAge));\n  return {\n    status: allowlistOrNull(status, PEEK_EVENT_QUEUE_STATUS_VALUES),\n    eventType: trimOrNull(readSingleValue(input.queueFilterType)),\n    id: trimOrNull(readSingleValue(input.queueFilterId)),\n    payloadUserId: trimOrNull(readSingleValue(input.queueFilterUserId)),\n    scheduledFrom: trimOrNull(readSingleValue(input.queueFilterScheduledFrom)),\n    scheduledTo: trimOrNull(readSingleValue(input.queueFilterScheduledTo)),\n    createdFrom: trimOrNull(readSingleValue(input.queueFilterCreatedFrom)),\n    createdTo: trimOrNull(readSingleValue(input.queueFilterCreatedTo)),\n    ageBucket: allowlistOrNull(ageBucket, PEEK_EVENT_QUEUE_AGE_BUCKET_VALUES),\n  };\n}\n\nexport function readSelectedQueueIdFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): string | null {\n  return trimOrNull(readSingleValue(input.selectedId));\n}\n\n// Two-arg overload tolerated for callers that prefer to pass URLSearchParams\n// indirectly. Also exposes the prefix tokens so the filter bar form fields stay\n// in lockstep with the URL parser without duplicating the literals.\nexport const PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES = {\n  status: \"queueFilterStatus\",\n  eventType: \"queueFilterType\",\n  id: \"queueFilterId\",\n  payloadUserId: \"queueFilterUserId\",\n  scheduledFrom: \"queueFilterScheduledFrom\",\n  scheduledTo: \"queueFilterScheduledTo\",\n  createdFrom: \"queueFilterCreatedFrom\",\n  createdTo: \"queueFilterCreatedTo\",\n  ageBucket: \"queueFilterAge\",\n  selectedId: \"selectedId\",\n} as const;\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2865,"cache_read_input_tokens":110237,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2865},"output_tokens":44,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"fe23ce19-cc23-4081-8a30-8dd2baa79aad","uuid":"fed83b3d-c67d-4eca-bd8c-20df657550e0"}
