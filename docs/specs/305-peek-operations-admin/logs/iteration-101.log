queue/handlers/` writes the key in camelCase). The `age`\n//     filter accepts a `PeekEventQueueAgeBucketId` value and applies the\n//     bucket's `[minHoursInclusive, maxHoursExclusive)` window against the\n//     event's `created_at`. Each row carries an `errorPreview` (head, redacted)\n//     and best-effort linked resource ids (`userId` / `roundId` / `claimId`)\n//     extracted server-side from the JSONB payload.\n//\n//   - `getEventQueueDetail`       — single-row detail. Returns the full JSONB\n//     payload + error text with secret redaction applied via\n//     `redactJsonValue` / `redactNullableString` from `peek/src/server/audit/`.\n//     The audit-module helpers are the single source of truth for the\n//     redaction policy.\n\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_EVENT_QUEUE_AGE_BUCKETS,\n  PEEK_EVENT_QUEUE_STATUSES,\n  type PeekEventQueueAgeBucketCount,\n  type PeekEventQueueAgeBucketId,\n  type PeekEventQueueDetail,\n  type PeekEventQueueFilters,\n  type PeekEventQueueLinkedIds,\n  type PeekEventQueueListRow,\n  type PeekEventQueueOverview,\n  type PeekEventQueueOverviewMetricId,\n  type PeekEventQueueStatus,\n  type PeekEventQueueStatusCount,\n  type PeekEventQueueTypeCount,\n  type PeekMetric,\n} from \"../../../lib/types/peek\";\nimport { redactJsonValue, redactNullableString } from \"../../audit/redact\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_EVENT_QUEUE_DEFAULT_LIMIT = 100;\nexport const PEEK_EVENT_QUEUE_MAX_LIMIT = 500;\nexport const PEEK_EVENT_QUEUE_TYPE_COUNT_LIMIT = 50;\nexport const PEEK_EVENT_QUEUE_AGED_PENDING_HOURS = 6;\nexport const PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS = 240;\n\nexport type ListEventQueueOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekEventQueueFilters>;\n  now?: Date;\n};\n\nexport type GetEventQueueDetailOptions = {\n  sql?: Sql;\n  id: string;\n};\n\nexport type GetEventQueueOverviewOptions = {\n  sql?: Sql;\n  now?: Date;\n  agedPendingHours?: number;\n  typeCountLimit?: number;\n};\n\nfunction clampLimit(\n  raw: number | undefined,\n  fallback: number,\n  max: number,\n): number {\n  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n  const floored = Math.floor(raw);\n  if (floored <= 0) return 1;\n  return Math.min(max, floored);\n}\n\nfunction trimOrNull(value: string | null | undefined): string | null {\n  if (typeof value !== \"string\") return null;\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nfunction readInt(value: number | string | null | undefined): number {\n  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n  if (typeof value === \"string\") {\n    const parsed = Number.parseInt(value, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\nfunction isAgeBucketId(value: string): value is PeekEventQueueAgeBucketId {\n  return PEEK_EVENT_QUEUE_AGE_BUCKETS.some((bucket) => bucket.id === value);\n}\n\nfunction previewError(error: string | null): string | null {\n  const redacted = redactNullableString(error);\n  if (redacted === null) return null;\n  if (redacted.length <= PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS) return redacted;\n  return `${redacted.slice(0, PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS)}…`;\n}\n\n// `event_queue.payload` strings are surfaced to operators as scalar drill-down\n// hooks (userId, roundId, claimId). Backend handlers always write these keys\n// camelCase (`backend/src/queue/handlers/*`). The redactor still protects\n// against an opaque secret accidentally landing in the same key — the linked-id\n// values are passed through `redactNullableString` before the row is shaped.\nfunction readLinkedId(\n  row: { userId: string | null; roundId: string | null; claimId: string | null },\n): PeekEventQueueLinkedIds {\n  return {\n    userId: redactNullableString(trimOrNull(row.userId)),\n    roundId: redactNullableString(trimOrNull(row.roundId)),\n    claimId: redactNullableString(trimOrNull(row.claimId)),\n  };\n}\n\nexport async function listEventQueue(\n  options: ListEventQueueOptions = {},\n): Promise<ReadonlyArray<PeekEventQueueListRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_EVENT_QUEUE_DEFAULT_LIMIT,\n    PEEK_EVENT_QUEUE_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const status = trimOrNull(filters.status ?? null);\n  const eventType = trimOrNull(filters.eventType ?? null);\n  const id = trimOrNull(filters.id ?? null);\n  const payloadUserId = trimOrNull(filters.payloadUserId ?? null);\n  const scheduledFrom = trimOrNull(filters.scheduledFrom ?? null);\n  const scheduledTo = trimOrNull(filters.scheduledTo ?? null);\n  const createdFrom = trimOrNull(filters.createdFrom ?? null);\n  const createdTo = trimOrNull(filters.createdTo ?? null);\n  const ageBucketRaw = trimOrNull(filters.ageBucket ?? null);\n\n  const now = options.now ?? new Date();\n  const ageBucket =\n    ageBucketRaw !== null && isAgeBucketId(ageBucketRaw) ? ageBucketRaw : null;\n  const ageWindow = ageBucket\n    ? PEEK_EVENT_QUEUE_AGE_BUCKETS.find((b) => b.id === ageBucket) ?? null\n    : null;\n  const ageMaxIso = ageWindow\n    ? new Date(now.getTime() - ageWindow.minHoursInclusive * 60 * 60 * 1000).toISOString()\n    : null;\n  const ageMinIso =\n    ageWindow && ageWindow.maxHoursExclusive !== null\n      ? new Date(now.getTime() - ageWindow.maxHoursExclusive * 60 * 60 * 1000).toISOString()\n      : null;\n  const ageHasMin = ageMinIso !== null;\n\n  const rows = await sql<\n    Array<{\n      id: string;\n      eventType: string;\n      status: string;\n      attempts: number | string;\n      maxAttempts: number | string;\n      scheduledAt: string;\n      startedAt: string | null;\n      completedAt: string | null;\n      createdAt: string;\n      error: string | null;\n      userId: string | null;\n      roundId: string | null;\n      claimId: string | null;\n    }>\n  >`\n    select\n      eq.id::text as \"id\",\n      eq.event_type as \"eventType\",\n      eq.status as \"status\",\n      eq.attempts as \"attempts\",\n      eq.max_attempts as \"maxAttempts\",\n      eq.scheduled_at::text as \"scheduledAt\",\n      eq.started_at::text as \"startedAt\",\n      eq.completed_at::text as \"completedAt\",\n      eq.created_at::text as \"createdAt\",\n      eq.error as \"error\",\n      eq.payload->>'userId' as \"userId\",\n      eq.payload->>'roundId' as \"roundId\",\n      eq.payload->>'claimId' as \"claimId\"\n    from event_queue eq\n    where\n      (${status === null} or eq.status = ${status ?? \"\"})\n      and (${eventType === null} or eq.event_type = ${eventType ?? \"\"})\n      and (${id === null} or eq.id::text = ${id ?? \"\"})\n      and (${payloadUserId === null} or eq.payload->>'userId' = ${payloadUserId ?? \"\"})\n      and (${scheduledFrom === null} or eq.scheduled_at >= ${scheduledFrom ?? \"\"}::timestamptz)\n      and (${scheduledTo === null} or eq.scheduled_at < ${scheduledTo ?? \"\"}::timestamptz)\n      and (${createdFrom === null} or eq.created_at >= ${createdFrom ?? \"\"}::timestamptz)\n      and (${createdTo === null} or eq.created_at < ${createdTo ?? \"\"}::timestamptz)\n      and (${ageMaxIso === null} or eq.created_at <= ${ageMaxIso ?? \"\"}::timestamptz)\n      and (${ageHasMin === false} or eq.created_at > ${ageMinIso ?? \"\"}::timestamptz)\n    order by eq.created_at desc, eq.id desc\n    limit ${limit}\n  `;\n\n  return rows.map((row) => ({\n    id: row.id,\n    eventType: row.eventType,\n    status: row.status,\n    attempts: readInt(row.attempts),\n    maxAttempts: readInt(row.maxAttempts),\n    scheduledAt: row.scheduledAt,\n    startedAt: row.startedAt,\n    completedAt: row.completedAt,\n    createdAt: row.createdAt,\n    errorPreview: previewError(row.error),\n    linked: readLinkedId(row),\n  }));\n}\n\nexport async function getEventQueueDetail(\n  options: GetEventQueueDetailOptions,\n): Promise<PeekEventQueueDetail | null> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const id = trimOrNull(options.id);\n  if (id === null) return null;\n\n  const rows = await sql<\n    Array<{\n      id: string;\n      eventType: string;\n      status: string;\n      attempts: number | string;\n      maxAttempts: number | string;\n      scheduledAt: string;\n      startedAt: string | null;\n      completedAt: string | null;\n      createdAt: string;\n      error: string | null;\n      payload: unknown;\n      userId: string | null;\n      roundId: string | null;\n      claimId: string | null;\n    }>\n  >`\n    select\n      eq.id::text as \"id\",\n      eq.event_type as \"eventType\",\n      eq.status as \"status\",\n      eq.attempts as \"attempts\",\n      eq.max_attempts as \"maxAttempts\",\n      eq.scheduled_at::text as \"scheduledAt\",\n      eq.started_at::text as \"startedAt\",\n      eq.completed_at::text as \"completedAt\",\n      eq.created_at::text as \"createdAt\",\n      eq.error as \"error\",\n      eq.payload as \"payload\",\n      eq.payload->>'userId' as \"userId\",\n      eq.payload->>'roundId' as \"roundId\",\n      eq.payload->>'claimId' as \"claimId\"\n    from event_queue eq\n    where eq.id::text = ${id}\n    limit 1\n  `;\n\n  const row = rows[0];\n  if (!row) return null;\n\n  return {\n    id: row.id,\n    eventType: row.eventType,\n    status: row.status,\n    attempts: readInt(row.attempts),\n    maxAttempts: readInt(row.maxAttempts),\n    scheduledAt: row.scheduledAt,\n    startedAt: row.startedAt,\n    completedAt: row.completedAt,\n    createdAt: row.createdAt,\n    error: redactNullableString(row.error),\n    payload: redactJsonValue(row.payload),\n    linked: readLinkedId(row),\n  };\n}\n\ntype MetricBlueprint = {\n  id: PeekEventQueueOverviewMetricId;\n  label: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  definition: string;\n  drilldownHref: string | null;\n};\n\nfunction buildMetric(\n  blueprint: MetricBlueprint,\n  raw: number,\n  display: string,\n  asOf: string,\n): PeekMetric {\n  return {\n    id: blueprint.id,\n    label: blueprint.label,\n    value: raw,\n    valueDisplay: display,\n    unit: blueprint.unit,\n    source: blueprint.source,\n    windowLabel: blueprint.windowLabel,\n    asOf,\n    definition: blueprint.definition,\n    freshness: \"live\",\n    drilldownHref: blueprint.drilldownHref,\n  };\n}\n\nexport async function getEventQueueOverview(\n  options: GetEventQueueOverviewOptions = {},\n): Promise<PeekEventQueueOverview> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n  const agedPendingHours = clampLimit(\n    options.agedPendingHours,\n    PEEK_EVENT_QUEUE_AGED_PENDING_HOURS,\n    24 * 30,\n  );\n  const typeCountLimit = clampLimit(\n    options.typeCountLimit,\n    PEEK_EVENT_QUEUE_TYPE_COUNT_LIMIT,\n    PEEK_EVENT_QUEUE_TYPE_COUNT_LIMIT,\n  );\n  const agedPendingThresholdIso = new Date(\n    now.getTime() - agedPendingHours * 60 * 60 * 1000,\n  ).toISOString();\n\n  // Age-bucket boundaries: each bucket is a half-open window\n  // [minHoursInclusive, maxHoursExclusive) over `now - created_at`. The \"open\"\n  // last bucket has no maxHoursExclusive — it covers everything aged at least\n  // `minHoursInclusive` hours.\n  const ageBucketBoundaries = PEEK_EVENT_QUEUE_AGE_BUCKETS.map((bucket) => ({\n    id: bucket.id,\n    label: bucket.label,\n    olderThanIso: new Date(\n      now.getTime() - bucket.minHoursInclusive * 60 * 60 * 1000,\n    ).toISOString(),\n    youngerThanIso:\n      bucket.maxHoursExclusive === null\n        ? null\n        : new Date(\n            now.getTime() - bucket.maxHoursExclusive * 60 * 60 * 1000,\n          ).toISOString(),\n  }));\n\n  const ageBucketQueries = ageBucketBoundaries.map((boundary) => {\n    const youngerThan = boundary.youngerThanIso;\n    const youngerOpen = youngerThan === null;\n    return sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from event_queue eq\n      where eq.created_at <= ${boundary.olderThanIso}::timestamptz\n        and (${youngerOpen} or eq.created_at > ${youngerThan ?? \"\"}::timestamptz)\n    `;\n  });\n\n  // Split into two awaits so the typed tuple destructuring stays narrow\n  // (mixing the heterogeneous queries above with the homogeneous age-bucket\n  // queries via `...spread` would broaden every element to the union).\n  const [statusRows, typeRows, atMaxAttemptsRows, agedPendingRows] =\n    await Promise.all([\n      sql<Array<{ status: string; value: number | string }>>`\n        select eq.status as \"status\", count(*)::int as \"value\"\n        from event_queue eq\n        group by eq.status\n      `,\n      sql<Array<{ eventType: string; value: number | string }>>`\n        select eq.event_type as \"eventType\", count(*)::int as \"value\"\n        from event_queue eq\n        group by eq.event_type\n        order by count(*) desc, eq.event_type asc\n        limit ${typeCountLimit}\n      `,\n      sql<Array<{ value: number | string }>>`\n        select count(*)::int as \"value\"\n        from event_queue eq\n        where eq.status in ('pending', 'processing', 'failed', 'dead')\n          and eq.attempts >= eq.max_attempts\n      `,\n      sql<Array<{ value: number | string }>>`\n        select count(*)::int as \"value\"\n        from event_queue eq\n        where eq.status = 'pending'\n          and eq.created_at <= ${agedPendingThresholdIso}::timestamptz\n      `,\n    ]);\n  const ageBucketResponses = await Promise.all(ageBucketQueries);\n\n  // Status counts: project the migration's full status set so a missing status\n  // shows as a 0 row rather than silently disappearing.\n  const statusCountByValue = new Map<string, number>();\n  for (const row of statusRows) {\n    statusCountByValue.set(row.status, readInt(row.value));\n  }\n  const statusCounts: ReadonlyArray<PeekEventQueueStatusCount> =\n    PEEK_EVENT_QUEUE_STATUSES.map((status) => ({\n      status,\n      count: statusCountByValue.get(status) ?? 0,\n    }));\n\n  const typeCounts: ReadonlyArray<PeekEventQueueTypeCount> = typeRows.map(\n    (row) => ({\n      eventType: row.eventType,\n      count: readInt(row.value),\n    }),\n  );\n\n  const ageBuckets: ReadonlyArray<PeekEventQueueAgeBucketCount> =\n    PEEK_EVENT_QUEUE_AGE_BUCKETS.map((bucket, index) => ({\n      id: bucket.id,\n      label: bucket.label,\n      count: readInt(ageBucketResponses[index]?.[0]?.value ?? 0),\n    }));\n\n  const pending = statusCountByValue.get(\"pending\") ?? 0;\n  const processing = statusCountByValue.get(\"processing\") ?? 0;\n  const failed = statusCountByValue.get(\"failed\") ?? 0;\n  const dead = statusCountByValue.get(\"dead\") ?? 0;\n  const atMaxAttempts = readInt(atMaxAttemptsRows[0]?.value ?? 0);\n  const agedPending = readInt(agedPendingRows[0]?.value ?? 0);\n\n  const agedPendingWindowLabel = `Pending for ≥ ${agedPendingHours}h`;\n\n  const blueprints: ReadonlyArray<{\n    blueprint: MetricBlueprint;\n    raw: number;\n    display: string;\n  }> = [\n    {\n      blueprint: {\n        id: \"queue.pending\",\n        label: \"Pending events\",\n        unit: \"events\",\n        source: \"event_queue\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of event_queue rows with status = 'pending' — work waiting to be picked up by a worker.\",\n        drilldownHref: \"/operations/queue?status=pending\",\n      },\n      raw: pending,\n      display: formatCount(pending),\n    },\n    {\n      blueprint: {\n        id: \"queue.processing\",\n        label: \"Processing events\",\n        unit: \"events\",\n        source: \"event_queue\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of event_queue rows with status = 'processing' — currently in flight on a worker.\",\n        drilldownHref: \"/operations/queue?status=processing\",\n      },\n      raw: processing,\n      display: formatCount(processing),\n    },\n    {\n      blueprint: {\n        id: \"queue.failed\",\n        label: \"Failed events\",\n        unit: \"events\",\n        source: \"event_queue\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of event_queue rows with status = 'failed' — last attempt errored, may still be retried before max_attempts.\",\n        drilldownHref: \"/operations/queue?status=failed\",\n      },\n      raw: failed,\n      display: formatCount(failed),\n    },\n    {\n      blueprint: {\n        id: \"queue.dead\",\n        label: \"Dead events\",\n        unit: \"events\",\n        source: \"event_queue\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of event_queue rows with status = 'dead' — past max_attempts and not retried.\",\n        drilldownHref: \"/operations/queue?status=dead\",\n      },\n      raw: dead,\n      display: formatCount(dead),\n    },\n    {\n      blueprint: {\n        id: \"queue.at_max_attempts\",\n        label: \"At max attempts\",\n        unit: \"events\",\n        source: \"event_queue\",\n        windowLabel: \"Current\",\n        definition:\n          \"Non-completed event_queue rows whose attempts ≥ max_attempts — exhausted retry budget.\",\n        drilldownHref: null,\n      },\n      raw: atMaxAttempts,\n      display: formatCount(atMaxAttempts),\n    },\n    {\n      blueprint: {\n        id: \"queue.aged_pending\",\n        label: \"Aged pending\",\n        unit: \"events\",\n        source: \"event_queue\",\n        windowLabel: agedPendingWindowLabel,\n        definition: `Pending event_queue rows whose created_at is at least ${agedPendingHours}h ago — worker may be stalled.`,\n        drilldownHref: `/operations/queue?status=pending&age=lt_24h`,\n      },\n      raw: age