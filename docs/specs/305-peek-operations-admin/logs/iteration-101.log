{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01LT7kpcKEE43EfD7hXspLus","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01BhQ9aFKKS2ooWvAiS5gk4k","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/app/operations/queue/page.tsx","content":"// /operations/queue — Event queue admin page (FR-10).\n//\n// Reads `event_queue` (migration 009) via `get-event-queue.ts` and composes:\n//\n//   - Metric strip   — pending / processing / failed / dead / at_max_attempts\n//                      / aged_pending. Failed and dead counts double as the\n//                      attention links called out by FR-10 (drilldown to\n//                      `?status=failed` / `?status=dead`).\n//   - Status + type breakdown — full status distribution and the top 50\n//                      event types by frequency, so an operator can see which\n//                      event_type is generating the dead/failed pile.\n//   - Filter bar     — status, event type, id, payload user id, scheduled +\n//                      created date windows, age bucket. URL-addressable\n//                      (`queueFilter*`).\n//   - Filtered table — bounded list with a row-level link that sets\n//                      `?selectedId=<id>` to open the detail panel.\n//   - Detail panel   — full payload rendered with secret redaction applied\n//                      server-side (`redactJsonValue` / `redactNullableString`\n//                      from the audit module).\n//\n// Read-only — retry / cancel / replay are explicitly out of scope (FR-10\n// line 342) and live behind a future mutation spec.\nimport type { CSSProperties } from \"react\";\nimport { EventQueueDetailPanel } from \"../../../src/components/event-queue-detail-panel\";\nimport { EventQueueFilterBar } from \"../../../src/components/event-queue-filter-bar\";\nimport { EventQueueTable } from \"../../../src/components/event-queue-table\";\nimport { MetricStrip } from \"../../../src/components/metric-strip\";\nimport {\n  normalizeEventQueueFiltersFromSearchParams,\n  readSelectedQueueIdFromSearchParams,\n} from \"../../../src/lib/operations-queue-search-params\";\nimport type {\n  PeekEventQueueDetail,\n  PeekEventQueueListRow,\n  PeekEventQueueOverview,\n} from \"../../../src/lib/types/peek\";\nimport {\n  getPeekActorContext,\n  isRouteAllowedForRole,\n} from \"../../../src/server/access-policy\";\nimport {\n  PEEK_EVENT_QUEUE_DEFAULT_LIMIT,\n  getEventQueueDetail,\n  getEventQueueOverview,\n  listEventQueue,\n} from \"../../../src/server/db/queries/get-event-queue\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst ROUTE = \"/operations/queue\";\n\nexport default async function OperationsQueuePage({\n  searchParams,\n}: {\n  searchParams: Promise<Record<string, string | string[] | undefined>>;\n}) {\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n\n  if (!allowed) {\n    return (\n      <main style={mainStyle}>\n        <header>\n          <h1>Operations · Event queue</h1>\n        </header>\n        <p role=\"alert\" style={errorStyle}>\n          You do not have access to this page.\n        </p>\n      </main>\n    );\n  }\n\n  const params = await searchParams;\n  const filters = normalizeEventQueueFiltersFromSearchParams(params);\n  const selectedId = readSelectedQueueIdFromSearchParams(params);\n\n  let overview: PeekEventQueueOverview = {\n    generatedAt: new Date().toISOString(),\n    metrics: [],\n    statusCounts: [],\n    typeCounts: [],\n    ageBuckets: [],\n  };\n  let rows: ReadonlyArray<PeekEventQueueListRow> = [];\n  let detail: PeekEventQueueDetail | null = null;\n  let detailNotFound = false;\n\n  let overviewError: string | null = null;\n  let rowsError: string | null = null;\n  let detailError: string | null = null;\n\n  try {\n    overview = await getEventQueueOverview();\n  } catch (error) {\n    overviewError =\n      error instanceof Error\n        ? error.message\n        : \"Event queue overview could not be loaded.\";\n  }\n\n  try {\n    rows = await listEventQueue({ filters });\n  } catch (error) {\n    rowsError =\n      error instanceof Error\n        ? error.message\n        : \"Event queue rows could not be loaded.\";\n  }\n\n  if (selectedId !== null) {\n    try {\n      detail = await getEventQueueDetail({ id: selectedId });\n      detailNotFound = detail === null;\n    } catch (error) {\n      detailError =\n        error instanceof Error\n          ? error.message\n          : \"Event queue detail could not be loaded.\";\n    }\n  }\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <h1>Operations · Event queue</h1>\n        <p style={leadStyle}>\n          Async work tracking from <code>event_queue</code>. Read-only —\n          retry, cancel, and replay actions are out of scope for this spec.\n          Failed and dead events are surfaced both as attention links in the\n          metric strip and as filter chips below.\n        </p>\n      </header>\n\n      <section aria-labelledby=\"overview-heading\">\n        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n          Overview\n        </h2>\n        <MetricStrip metrics={overview.metrics} error={overviewError} />\n      </section>\n\n      <section aria-labelledby=\"breakdown-heading\" style={sectionStyle}>\n        <h2 id=\"breakdown-heading\" style={sectionHeadingStyle}>\n          Status &amp; type breakdown\n        </h2>\n        <div style={breakdownGridStyle}>\n          <BreakdownCard\n            heading=\"Status\"\n            empty=\"No events yet.\"\n            rows={overview.statusCounts.map((row) => ({\n              key: row.status,\n              left: row.status,\n              right: row.count.toLocaleString(\"en-US\"),\n            }))}\n          />\n          <BreakdownCard\n            heading=\"Top event types\"\n            empty=\"No events yet.\"\n            rows={overview.typeCounts.map((row) => ({\n              key: row.eventType,\n              left: row.eventType,\n              right: row.count.toLocaleString(\"en-US\"),\n            }))}\n          />\n          <BreakdownCard\n            heading=\"Age buckets\"\n            empty=\"No events yet.\"\n            rows={overview.ageBuckets.map((row) => ({\n              key: row.id,\n              left: row.label,\n              right: row.count.toLocaleString(\"en-US\"),\n            }))}\n          />\n        </div>\n      </section>\n\n      <section\n        aria-labelledby=\"rows-heading\"\n        id=\"rows\"\n        style={sectionStyle}\n      >\n        <h2 id=\"rows-heading\" style={sectionHeadingStyle}>\n          Filtered events\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_EVENT_QUEUE_DEFAULT_LIMIT} rows · sorted newest first\n          · server-side capped. Filter by status, event type, event id,\n          payload user id, age bucket, and scheduled / created date windows.\n          Click an id to open the redacted payload.\n        </p>\n        <EventQueueFilterBar filters={filters} action={ROUTE} />\n        <div style={listAndDetailStyle}>\n          <EventQueueTable\n            rows={rows}\n            selectedId={selectedId}\n            error={rowsError}\n          />\n          <EventQueueDetailPanel\n            detail={detail}\n            selectedId={selectedId}\n            notFound={detailNotFound}\n            error={detailError}\n          />\n        </div>\n      </section>\n    </main>\n  );\n}\n\ntype BreakdownCardProps = {\n  heading: string;\n  empty: string;\n  rows: ReadonlyArray<{ key: string; left: string; right: string }>;\n};\n\nfunction BreakdownCard({ heading, empty, rows }: BreakdownCardProps) {\n  return (\n    <article style={breakdownCardStyle}>\n      <h3 style={breakdownHeadingStyle}>{heading}</h3>\n      {rows.length === 0 ? (\n        <p style={breakdownEmptyStyle}>{empty}</p>\n      ) : (\n        <ul style={breakdownListStyle}>\n          {rows.map((row) => (\n            <li key={row.key} style={breakdownRowStyle}>\n              <span style={breakdownLeftStyle}>{row.left}</span>\n              <span style={breakdownRightStyle}>{row.right}</span>\n            </li>\n          ))}\n        </ul>\n      )}\n    </article>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst listAndDetailStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1rem\",\n  gridTemplateColumns: \"minmax(0, 2fr) minmax(0, 1fr)\",\n  alignItems: \"start\",\n};\n\nconst breakdownGridStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1rem\",\n  gridTemplateColumns: \"repeat(auto-fit, minmax(220px, 1fr))\",\n};\n\nconst breakdownCardStyle: CSSProperties = {\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n  padding: \"1rem\",\n  background: \"#111827\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst breakdownHeadingStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n};\n\nconst breakdownEmptyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.8125rem\",\n  color: \"#94a3b8\",\n};\n\nconst breakdownListStyle: CSSProperties = {\n  margin: 0,\n  padding: 0,\n  listStyle: \"none\",\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst breakdownRowStyle: CSSProperties = {\n  display: \"flex\",\n  justifyContent: \"space-between\",\n  fontSize: \"0.8125rem\",\n  color: \"#e2e8f0\",\n};\n\nconst breakdownLeftStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  color: \"#cbd5f5\",\n};\n\nconst breakdownRightStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  color: \"#94a3b8\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":428,"cache_read_input_tokens":124072,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":428},"output_tokens":72,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"fe23ce19-cc23-4081-8a30-8dd2baa79aad","uuid":"24b5a470-036f-4a42-a53b-5f597e95dd55"}
