"0.125rem 0.5rem\",\n62\t    borderRadius: \"9999px\",\n63\t    background: t.background,\n64\t    color: t.color,\n65\t    border: `1px solid ${t.border}`,\n66\t    whiteSpace: \"nowrap\",\n67\t  };\n68\t}\n69\t\n70\tconst emptyStyle: CSSProperties = {\n71\t  display: \"inline-flex\",\n72\t  alignItems: \"center\",\n73\t  fontSize: \"0.75rem\",\n74\t  color: \"#94a3b8\",\n75\t  padding: \"0.125rem 0.25rem\",\n76\t};\n77\t\n78\tconst errorStyle: CSSProperties = {\n79\t  display: \"inline-flex\",\n80\t  alignItems: \"center\",\n81\t  fontSize: \"0.75rem\",\n82\t  padding: \"0.125rem 0.5rem\",\n83\t  borderRadius: \"9999px\",\n84\t  background: \"#3f1d1d\",\n85\t  color: \"#fecaca\",\n86\t  border: \"1px solid #991b1b\",\n87\t};\n88\t"}]},"parent_tool_use_id":null,"session_id":"fe23ce19-cc23-4081-8a30-8dd2baa79aad","uuid":"5a21958e-f309-4086-bb9e-086d606c2430","timestamp":"2026-04-26T06:53:29.929Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/status-chip.tsx","content":"import type { CSSProperties } from \"react\";\nimport type { PeekStatusTone } from \"../lib/types/peek\";\n\nexport type StatusChipProps = {\n  label: string | null;\n  tone?: PeekStatusTone;\n  title?: string;\n  error?: string | null;\n};\n\nexport function StatusChip({\n  label,\n  tone = \"neutral\",\n  title,\n  error = null,\n}: StatusChipProps) {\n  if (error) {\n    return (\n      <span role=\"alert\" style={errorStyle}>\n        Status unavailable: {error}\n      </span>\n    );\n  }\n\n  if (!label) {\n    return (\n      <span role=\"status\" aria-label=\"status missing\" style={emptyStyle}>\n        —\n      </span>\n    );\n  }\n\n  return (\n    <span\n      role=\"status\"\n      data-tone={tone}\n      title={title}\n      style={chipStyle(tone)}\n    >\n      {label}\n    </span>\n  );\n}\n\nfunction chipStyle(tone: PeekStatusTone): CSSProperties {\n  const tones: Record<PeekStatusTone, { background: string; color: string; border: str