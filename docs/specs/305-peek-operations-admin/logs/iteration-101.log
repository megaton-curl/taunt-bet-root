n125\t  display: \"flex\",\n126\t  justifyContent: \"space-between\",\n127\t  fontSize: \"0.75rem\",\n128\t  color: \"#94a3b8\",\n129\t};\n130\t\n131\tconst metaTermStyle: CSSProperties = {\n132\t  margin: 0,\n133\t};\n134\t\n135\tconst metaValueStyle: CSSProperties = {\n136\t  margin: 0,\n137\t  textAlign: \"right\",\n138\t};\n139\t\n140\tconst drilldownStyle: CSSProperties = {\n141\t  fontSize: \"0.8125rem\",\n142\t  color: \"#93c5fd\",\n143\t  textDecoration: \"none\",\n144\t};\n145\t\n146\tfunction freshnessStyle(freshness: PeekMetric[\"freshness\"]): CSSProperties {\n147\t  const tones: Record<PeekMetric[\"freshness\"], { background: string; color: string }> = {\n148\t    live: { background: \"#064e3b\", color: \"#a7f3d0\" },\n149\t    cached: { background: \"#1f2937\", color: \"#cbd5f5\" },\n150\t    manual: { background: \"#3f3f46\", color: \"#fde68a\" },\n151\t    sampled: { background: \"#312e81\", color: \"#c7d2fe\" },\n152\t  };\n153\t  const tone = tones[freshness];\n154\t  return {\n155\t    fontSize: \"0.6875rem\",\n156\t    textTransform: \"uppercase\",\n157\t    letterSpacing: \"0.05em\",\n158\t    padding: \"0.125rem 0.5rem\",\n159\t    borderRadius: \"9999px\",\n160\t    background: tone.background,\n161\t    color: tone.color,\n162\t  };\n163\t}\n164\t\n165\tconst errorStyle: CSSProperties = {\n166\t  margin: 0,\n167\t  padding: \"0.75rem 1rem\",\n168\t  borderRadius: \"0.75rem\",\n169\t  background: \"#3f1d1d\",\n170\t  color: \"#fecaca\",\n171\t};\n172\t\n173\tconst emptyStyle: CSSProperties = {\n174\t  padding: \"1rem\",\n175\t  borderRadius: \"0.75rem\",\n176\t  border: \"1px solid #1e293b\",\n177\t  background: \"#0b1220\",\n178\t  color: \"#94a3b8\",\n179\t  fontSize: \"0.875rem\",\n180\t};\n181\t"}]},"parent_tool_use_id":null,"session_id":"fe23ce19-cc23-4081-8a30-8dd2baa79aad","uuid":"2ad13c33-b1b9-410a-95ce-15905d80671e","timestamp":"2026-04-26T06:53:36.343Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/