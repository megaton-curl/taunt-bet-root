{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013Ndm3oBNdTiGHJRde3jtwQ","type":"tool_result","content":"1\t// Component tests for the FR-9 /operations/dogpile filter bars.\n2\t//\n3\t// Two prefixed forms (`dogpFilter*`, `fraudFilter*`) share the same\n4\t// /operations/dogpile page so each table can be filtered independently while\n5\t// the URL stays shareable. These tests verify:\n6\t//   - the form posts to /operations/dogpile via GET\n7\t//   - each input uses its prefixed name (no collision across forms)\n8\t//   - the status selects expose every allowlisted enum value\n9\t//   - populated filters pre-fill every field\n10\t//   - ISO timestamps in date filters are truncated to YYYY-MM-DD\n11\t//   - the custom action prop overrides the default form target\n12\t\n13\timport { describe, expect, it } from \"vitest\";\n14\timport { render, screen } from \"@testing-library/react\";\n15\timport {\n16\t  DogpileEventsFilterBar,\n17\t  FraudFlagsFilterBar,\n18\t} from \"../operations-dogpile-filter-bar\";\n19\timport {\n20\t  PEEK_DOGPILE_STATUS_VALUES,\n21\t  PEEK_FRAUD_FLAG_STATUSES,\n22\t} from \"../../lib/operations-dogpile-search-params\";\n23\timport type {\n24\t  PeekDogpileEventFilters,\n25\t  PeekFraudFlagFilters,\n26\t} from \"../../lib/types/peek\";\n27\t\n28\tconst EMPTY_DOGP_FILTERS: PeekDogpileEventFilters = {\n29\t  status: null,\n30\t  startsFrom: null,\n31\t  startsTo: null,\n32\t};\n33\t\n34\tconst POPULATED_DOGP_FILTERS: PeekDogpileEventFilters = {\n35\t  status: \"active\",\n36\t  startsFrom: \"2026-04-01\",\n37\t  startsTo: \"2026-04-26\",\n38\t};\n39\t\n40\tconst EMPTY_FRAUD_FILTERS: PeekFraudFlagFilters = {\n41\t  status: null,\n42\t  userId: null,\n43\t  flagType: null,\n44\t  createdFrom: null,\n45\t  createdTo: null,\n46\t};\n47\t\n48\tconst POPULATED_FRAUD_FILTERS: PeekFraudFlagFilters = {\n49\t  status: \"open\",\n50\t  userId: \"user-1\",\n51\t  flagType: \"self_referral\",\n52\t  createdFrom: \"2026-04-01\",\n53\t  createdTo: \"2026-04-26\",\n54\t};\n55\t\n56\tdescribe(\"DogpileEventsFilterBar\", () => {\n57\t  it(\"empty: form posts to /operations/dogpile by default with all inputs blank and 'Any' selected\", () => {\n58\t    render(<DogpileEventsFilterBar filters={EMPTY_DOGP_FILTERS} />);\n59\t\n60\t    const form = screen.getByRole(\"search\", { name: \"Filter dogpile events\" });\n61\t    expect(form).toHaveAttribute(\"action\", \"/operations/dogpile\");\n62\t    expect(form).toHaveAttribute(\"method\", \"get\");\n63\t\n64\t    const status = screen.getByLabelText(\"Status\") as HTMLSelectElement;\n65\t    expect(status.value).toBe(\"\");\n66\t    const optionValues = Array.from(status.options).map((o) => o.value);\n67\t    expect(optionValues).toContain(\"\");\n68\t    for (const value of PEEK_DOGPILE_STATUS_VALUES) {\n69\t      expect(optionValues).toContain(value);\n70\t    }\n71\t  });\n72\t\n73\t  it(\"populated: pre-fills every field including the status select\", () => {\n74\t    render(<DogpileEventsFilterBar filters={POPULATED_DOGP_FILTERS} />);\n75\t\n76\t    expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).value).toBe(\n77\t      \"active\",\n78\t    );\n79\t    expect(\n80\t      (screen.getByLabelText(\"Starts from\") as HTMLInputElement).value,\n81\t    ).toBe(\"2026-04-01\");\n82\t    expect(\n83\t      (screen.getByLabelText(\"Starts to\") as HTMLInputElement).value,\n84\t    ).toBe(\"2026-04-26\");\n85\t  });\n86\t\n87\t  it(\"inputs use the dogpFilter* prefix so the form can co-exist with the fraud bar\", () => {\n88\t    render(<DogpileEventsFilterBar filters={EMPTY_DOGP_FILTERS} />);\n89\t\n90\t    expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).name).toBe(\n91\t      \"dogpFilterStatus\",\n92\t    );\n93\t    expect(\n94\t      (screen.getByLabelText(\"Starts from\") as HTMLInputElement).name,\n95\t    ).toBe(\"dogpFilterFrom\");\n96\t    expect((screen.getByLabelText(\"Starts to\") as HTMLInputElement).name).toBe(\n97\t      \"dogpFilterTo\",\n98\t    );\n99\t  });\n100\t\n101\t  it(\"populated: ISO timestamps in startsFrom/startsTo are truncated to YYYY-MM-DD\", () => {\n102\t    render(\n103\t      <DogpileEventsFilterBar\n104\t        filters={{\n105\t          status: null,\n106\t          startsFrom: \"2026-04-01T10:00:00.000Z\",\n107\t          startsTo: \"2026-04-26T23:59:59.999Z\",\n108\t        }}\n109\t      />,\n110\t    );\n111\t\n112\t    expect(\n113\t      (screen.getByLabelText(\"Starts from\") as HTMLInputElement).value,\n114\t    ).toBe(\"2026-04-01\");\n115\t    expect(\n116\t      (screen.getByLabelText(\"Starts to\") as HTMLInputElement).value,\n117\t    ).toBe(\"2026-04-26\");\n118\t  });\n119\t\n120\t  it(\"custom action overrides the default form target\", () => {\n121\t    render(\n122\t      <DogpileEventsFilterBar\n123\t        filters={EMPTY_DOGP_FILTERS}\n124\t        action=\"/operations/dogpile?embed=1\"\n125\t      />,\n126\t    );\n127\t\n128\t    const form = screen.getByRole(\"search\", { name: \"Filter dogpile events\" });\n129\t    expect(form).toHaveAttribute(\"action\", \"/operations/dogpile?embed=1\");\n130\t  });\n131\t});\n132\t\n133\tdescribe(\"FraudFlagsFilterBar\", () => {\n134\t  it(\"empty: form posts to /operations/dogpile by default with all inputs blank and 'Any' selected\", () => {\n135\t    render(<FraudFlagsFilterBar filters={EMPTY_FRAUD_FILTERS} />);\n136\t\n137\t    const form = screen.getByRole(\"search\", { name: \"Filter fraud flags\" });\n138\t    expect(form).toHaveAttribute(\"action\", \"/operations/dogpile\");\n139\t    expect(form).toHaveAttribute(\"method\", \"get\");\n140\t\n141\t    const status = screen.getByLabelText(\"Status\") as HTMLSelectElement;\n142\t    expect(status.value).toBe(\"\");\n143\t    const optionValues = Array.from(status.options).map((o) => o.value);\n144\t    expect(optionValues).toContain(\"\");\n145\t    for (const value of PEEK_FRAUD_FLAG_STATUSES) {\n146\t      expect(optionValues).toContain(value);\n147\t    }\n148\t  });\n149\t\n150\t  it(\"populated: pre-fills every field\", () => {\n151\t    render(<FraudFlagsFilterBar filters={POPULATED_FRAUD_FILTERS} />);\n152\t\n153\t    expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).value).toBe(\n154\t      \"open\",\n155\t    );\n156\t    expect((screen.getByLabelText(\"User ID\") as HTMLInputElement).value).toBe(\n157\t      \"user-1\",\n158\t    );\n159\t    expect((screen.getByLabelText(\"Flag type\") as HTMLInputElement).value).toBe(\n160\t      \"self_referral\",\n161\t    );\n162\t    expect(\n163\t      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n164\t    ).toBe(\"2026-04-01\");\n165\t    expect(\n166\t      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n167\t    ).toBe(\"2026-04-26\");\n168\t  });\n169\t\n170\t  it(\"inputs use the fraudFilter* prefix so the form can co-exist with the dogpile bar\", () => {\n171\t    render(<FraudFlagsFilterBar filters={EMPTY_FRAUD_FILTERS} />);\n172\t\n173\t    expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).name).toBe(\n174\t      \"fraudFilterStatus\",\n175\t    );\n176\t    expect((screen.getByLabelText(\"User ID\") as HTMLInputElement).name).toBe(\n177\t      \"fraudFilterUserId\",\n178\t    );\n179\t    expect((screen.getByLabelText(\"Flag type\") as HTMLInputElement).name).toBe(\n180\t      \"fraudFilterFlagType\",\n181\t    );\n182\t    expect(\n183\t      (screen.getByLabelText(\"Created from\") as HTMLInputElement).name,\n184\t    ).toBe(\"fraudFilterFrom\");\n185\t    expect(\n186\t      (screen.getByLabelText(\"Created to\") as HTMLInputElement).name,\n187\t    ).toBe(\"fraudFilterTo\");\n188\t  });\n189\t\n190\t  it(\"populated: ISO timestamps in createdFrom/createdTo are truncated to YYYY-MM-DD\", () => {\n191\t    render(\n192\t      <FraudFlagsFilterBar\n193\t        filters={{\n194\t          status: null,\n195\t          userId: null,\n196\t          flagType: null,\n197\t          createdFrom: \"2026-04-01T10:00:00.000Z\",\n198\t          createdTo: \"2026-04-26T23:59:59.999Z\",\n199\t        }}\n200\t      />,\n201\t    );\n202\t\n203\t    expect(\n204\t      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n205\t    ).toBe(\"2026-04-01\");\n206\t    expect(\n207\t      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n208\t    ).toBe(\"2026-04-26\");\n209\t  });\n210\t\n211\t  it(\"custom action overrides the default form target\", () => {\n212\t    render(\n213\t      <FraudFlagsFilterBar\n214\t        filters={EMPTY_FRAUD_FILTERS}\n215\t        action=\"/operations/dogpile?embed=1\"\n216\t      />,\n217\t    );\n218\t\n219\t    const form = screen.getByRole(\"search\", { name: \"Filter fraud flags\" });\n220\t    expect(form).toHaveAttribute(\"action\", \"/operations/dogpile?embed=1\");\n221\t  });\n222\t});\n223\t"}]},"parent_tool_use_id":null,"session_id":"031ce74d-15ee-4888-a00b-e081672f539b","uuid":"374a9891-d37f-4e52-a5f9-64cf767dd317","timestamp":"2026-04-26T07:02:20.689Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/operations-dogpile-filter-bar.test.tsx","content":"// Component tests for the FR-9 /operations/dogpile filter bars.\n//\n// Two prefixed forms (`dogpFilter*`, `fraudFilter*`) share the same\n// /operations/dogpile page so each table can be filtered independently while\n// the URL stays shareable. These tests verify:\n//   - the form posts to /operations/dogpile via GET\n//   - each input uses its prefixed name (no collision across forms)\n//   - the status selects expose every allowlisted enum value\n//   - populated filters pre-fill every field\n//   - ISO timestamps in date filters are truncated to YYYY-MM-DD\n//   - the custom action prop overrides the default form target\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport {\n  DogpileEventsFilterBar,\n  FraudFlagsFilterBar,\n} from \"../operations-dogpile-filter-bar\";\nimport {\n  PEEK_DOGPILE_STATUS_VALUES,\n  PEEK_FRAUD_FLAG_STATUSES,\n} from \"../../lib/operations-dogpile-search-params\";\nimport type {\n  PeekDogpileEventFilters,\n  PeekFraudFlagFilters,\n} from \"../../lib/types/peek\";\n\nconst EMPTY_DOGP_FILTERS: PeekDogpileEventFilters = {\n  status: null,\n  startsFrom: null,\n  startsTo: null,\n};\n\nconst POPULATED_DOGP_FILTERS: PeekDogpileEventFilters = {\n  status: \"active\",\n  startsFrom: \"2026-04-01\",\n  startsTo: \"2026-04-26\",\n};\n\nconst EMPTY_FRAUD_FILTERS: PeekFraudFlagFilters = {\n  status: null,\n  userId: null,\n  flagType: null,\n  createdFrom: null,\n  createdTo: null,\n};\n\nconst POPULATED_FRAUD_FILTERS: PeekFraudFlagFilters = {\n  status: \"open\",\n  userId: \"user-1\",\n  flagType: \"self_referral\",\n  createdFrom: \"2026-04-01\",\n  createdTo: \"2026-04-26\",\n};\n\ndescribe(\"DogpileEventsFilterBar\", () => {\n  it(\"empty: form posts to /operations/dogpile by default with all inputs blank and 'Any' selected\", () => {\n    render(<DogpileEventsFilterBar filters={EMPTY_DOGP_FILTERS} />);\n\n    const form = screen.getByRole(\"search\", { name: \"Filter dogpile events\" });\n    expect(form).toHaveAttribute(\"action\", \"/operations/dogpile\");\n    expect(form).toHaveAttribute(\"method\", \"get\");\n\n    const status = screen.getByLabelText(\"Status\") as HTMLSelectElement;\n    expect(status.value).toBe(\"\");\n    const optionValues = Array.from(status.options).map((o) => o.value);\n    expect(optionValues).toContain(\"\");\n    for (const value of PEEK_DOGPILE_STATUS_VALUES) {\n      expect(optionValues).toContain(value);\n    }\n  });\n\n  it(\"populated: pre-fills every field including the status select\", () => {\n    render(<DogpileEventsFilterBar filters={POPULATED_DOGP_FILTERS} />);\n\n    expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).value).toBe(\n      \"active\",\n    );\n    expect(\n      (screen.getByLabelText(\"Starts from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Starts to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n  });\n\n  it(\"inputs use the dogpFilter* prefix so the form can co-exist with the fraud bar\", () => {\n    render(<DogpileEventsFilterBar filters={EMPTY_DOGP_FILTERS} />);\n\n    expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).name).toBe(\n      \"dogpFilterStatus\",\n    );\n    expect(\n      (screen.getByLabelText(\"Starts from\") as HTMLInputElement).name,\n    ).toBe(\"dogpFilterFrom\");\n    expect((screen.getByLabelText(\"Starts to\") as HTMLInputElement).name).toBe(\n      \"dogpFilterTo\",\n    );\n  });\n\n  it(\"populated: ISO timestamps in startsFrom/startsTo are truncated to YYYY-MM-DD\", () => {\n    render(\n      <DogpileEventsFilterBar\n        filters={{\n          status: null,\n          startsFrom: \"2026-04-01T10:00:00.000Z\",\n          startsTo: \"2026-04-26T23:59:59.999Z\",\n        }}\n      />,\n    );\n\n    expect(\n      (screen.getByLabelText(\"Starts from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Starts to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n  });\n\n  it(\"custom action overrides the default form target\", () => {\n    render(\n      <DogpileEventsFilterBar\n        filters={EMPTY_DOGP_FILTERS}\n        action=\"/operations/dogpile?embed=1\"\n      />,\n    );\n\n    const form = screen.getByRole(\"search\", { name: \"Filter dogpile events\" });\n    expect(form).toHaveAttribute(\"action\", \"/operations/dogpile?embed=1\");\n  });\n});\n\ndescribe(\"FraudFlagsFilterBar\", () => {\n  it(\"empty: form posts to /operations/dogpile by default with all inputs blank and 'Any' selected\", () => {\n    render(<FraudFlagsFilterBar filters={EMPTY_FRAUD_FILTERS} />);\n\n    const form = screen.getByRole(\"search\", { name: \"Filter fraud flags\" });\n    expect(form).toHaveAttribute(\"action\", \"/operations/dogpile\");\n    expect(form).toHaveAttribute(\"method\", \"get\");\n\n    const status = screen.getByLabelText(\"Status\") as HTMLSelectElement;\n    expect(status.value).toBe(\"\");\n    const optionValues = Array.from(status.options).map((o) => o.value);\n    expect(optionValues).toContain(\"\");\n    for (const value of PEEK_FRAUD_FLAG_STATUSES) {\n      expect(optionValues).toContain(value);\n    }\n  });\n\n  it(\"populated: pre-fills every field\", () => {\n    render(<FraudFlagsFilterBar filters={POPULATED_FRAUD_FILTERS} />);\n\n    expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).value).toBe(\n      \"open\",\n    );\n    expect((screen.getByLabelText(\"User ID\") as HTMLInputElement).value).toBe(\n      \"user-1\",\n    );\n    expect((screen.getByLabelText(\"Flag type\") as HTMLInputElement).value).toBe(\n      \"self_referral\",\n    );\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n  });\n\n  it(\"inputs use the fraudFilter* prefix so the form can co-exist with the dogpile bar\", () => {\n    render(<FraudFlagsFilterBar filters={EMPTY_FRAUD_FILTERS} />);\n\n    expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).name).toBe(\n      \"fraudFilterStatus\",\n    );\n    expect((screen.getByLabelText(\"User ID\") as HTMLInputElement).name).toBe(\n      \"fraudFilterUserId\",\n    );\n    expect((screen.getByLabelText(\"Flag type\") as HTMLInputElement).name).toBe(\n      \"fraudFilterFlagType\",\n    );\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).name,\n    ).toBe(\"fraudFilterFrom\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).name,\n    ).toBe(\"fraudFilterTo\");\n  });\n\n  it(\"populated: ISO timestamps in createdFrom/createdTo are truncated to YYYY-MM-DD\", () => {\n    render(\n      <FraudFlagsFilterBar\n        filters={{\n          status: null,\n          userId: null,\n          flagType: null,\n          createdFrom: \"2026-04-01T10:00:00.000Z\",\n          createdTo: \"2026-04-26T23:59:59.999Z\",\n        }}\n      />,\n    );\n\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n  });\n\n  it(\"custom action overrides the default form target\", () => {\n    render(\n      <FraudFlagsFilterBar\n        filters={EMPTY_FRAUD_FILTERS}\n        action=\"/operations/dogpile?embed=1\"\n      />,\n    );\n\n    const form = screen.getByRole(\"search\", { name: \"Filter fraud flags\" });\n    expect(form).toHaveAttribute(\"action\", \"/operations/dogpile?embed=1\");\n  });\n});\n","numLines":223,"startLine":1,"totalLines":223}}}
