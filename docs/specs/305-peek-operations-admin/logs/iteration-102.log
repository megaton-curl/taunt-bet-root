ueFilterStatus: \"stalled\",\n      }).status,\n    ).toBeNull();\n  });\n\n  it(\"ageBucket: every allowlisted value passes through verbatim\", () => {\n    for (const value of PEEK_EVENT_QUEUE_AGE_BUCKET_VALUES) {\n      const filters = normalizeEventQueueFiltersFromSearchParams({\n        queueFilterAge: value,\n      });\n      expect(filters.ageBucket).toBe(value);\n    }\n  });\n\n  it(\"ageBucket: unknown bucket id normalises to null so a stale link cannot apply a fake window\", () => {\n    expect(\n      normalizeEventQueueFiltersFromSearchParams({\n        queueFilterAge: \"yesterday\",\n      }).ageBucket,\n    ).toBeNull();\n  });\n\n  it(\"array values: only the first element is read\", () => {\n    expect(\n      normalizeEventQueueFiltersFromSearchParams({\n        queueFilterStatus: [\"failed\", \"dead\"],\n      }).status,\n    ).toBe(\"failed\");\n  });\n\n  it(\"undefined input value normalises to null without throwing\", () => {\n    expect(\n      normalizeEventQueueFiltersFromSearchParams({\n        queueFilterStatus: undefined,\n        queueFilterType: undefined,\n      }),\n    ).toEqual({\n      status: null,\n      eventType: null,\n      id: null,\n      payloadUserId: null,\n      scheduledFrom: null,\n      scheduledTo: null,\n      createdFrom: null,\n      createdTo: null,\n      ageBucket: null,\n    });\n  });\n});\n\ndescribe(\"readSelectedQueueIdFromSearchParams\", () => {\n  it(\"returns null for an absent selectedId\", () => {\n    expect(readSelectedQueueIdFromSearchParams({})).toBeNull();\n  });\n\n  it(\"returns null for a whitespace-only selectedId\", () => {\n    expect(\n      readSelectedQueueIdFromSearchParams({ selectedId: \"    \" }),\n    ).toBeNull();\n  });\n\n  it(\"trims and returns the value when present\", () => {\n    expect(\n      readSelectedQueueIdFromSearchParams({\n        selectedId: \"  11111111-1111-1111-1111-111111111111  \",\n      }),\n    ).toBe(\"11111111-1111-1111-1111-111111111111\");\n  });\n\n  it(\"array values: only the first element is read\", () => {\n    expect(\n      readSelectedQueueIdFromSearchParams({\n        selectedId: [\"a\", \"b\"],\n      }),\n    ).toBe(\"a\");\n  });\n});\n\ndescribe(\"PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES\", () => {\n  it(\"declares the same param names the form fields submit\", () => {\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.status).toBe(\n      \"queueFilterStatus\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.eventType).toBe(\n      \"queueFilterType\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.id).toBe(\"queueFilterId\");\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.payloadUserId).toBe(\n      \"queueFilterUserId\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.scheduledFrom).toBe(\n      \"queueFilterScheduledFrom\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.scheduledTo).toBe(\n      \"queueFilterScheduledTo\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.createdFrom).toBe(\n      \"queueFilterCreatedFrom\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.createdTo).toBe(\n      \"queueFilterCreatedTo\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.ageBucket).toBe(\n      \"queueFilterAge\",\n    );\n    // The `selectedId` token belongs to the same map so the table component\n    // can build shareable detail-panel links without re-declaring the literal.\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.selectedId).toBe(\"selectedId\");\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_019ntrP7152KVTVKv7Zox7Mu","type":"message","role":"assistant","content":[{"type":"text","text":"Now create the filter-bar component test:"}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3328,"cache_read_input_tokens":149493,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3328},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"031ce74d-15ee-4888-a00b-e081672f539b","uuid":"70e875bb-555d-4648-9bb2-c40ec6b7c084"}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_019ntrP7152KVTVKv7Zox7Mu","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Q8JLFJndhPSay27bVQnWXh","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/__tests__/event-queue-filter-bar.test.tsx","content":"// Component tests for the FR-10 /operations/queue filter bar.\n//\n// The filter bar is a query-string GET form (no JS), so each test asserts:\n//   - the form posts to /operations/queue via GET;\n//   - each input/select uses its `queueFilter*` name (matches the URL parser);\n//   - the status + age-bucket selects expose every allowlisted enum value;\n//   - populated filters pre-fill every field;\n//   - ISO timestamps in date filters are truncated to YYYY-MM-DD;\n//   - the custom action prop overrides the default form target;\n//   - the `selectedId` param is intentionally NOT a hidden input (submitting\n//     the filter form clears the detail panel rather than reopening the row).\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { EventQueueFilterBar } from \"../event-queue-filter-bar\";\nimport {\n  PEEK_EVENT_QUEUE_AGE_BUCKETS,\n  PEEK_EVENT_QUEUE_STATUSES,\n} from \"../../lib/types/peek\";\nimport type { PeekEventQueueFilters } from \"../../lib/types/peek\";\n\nconst EMPTY_FILTERS: PeekEventQueueFilters = {\n  status: null,\n  eventType: null,\n  id: null,\n  payloadUserId: null,\n  scheduledFrom: null,\n  scheduledTo: null,\n  createdFrom: null,\n  createdTo: null,\n  ageBucket: null,\n};\n\nconst POPULATED_FILTERS: PeekEventQueueFilters = {\n  status: \"failed\",\n  eventType: \"points.grant\",\n  id: \"11111111-1111-1111-1111-111111111111\",\n  payloadUserId: \"user-9\",\n  scheduledFrom: \"2026-04-01\",\n  scheduledTo: \"2026-04-26\",\n  createdFrom: \"2026-04-01\",\n  createdTo: \"2026-04-26\",\n  ageBucket: \"lt_24h\",\n};\n\ndescribe(\"EventQueueFilterBar\", () => {\n  it(\"empty: form posts to /operations/queue by default with all inputs blank and 'Any' selected\", () => {\n    render(<EventQueueFilterBar filters={EMPTY_FILTERS} />);\n\n    const form = screen.getByRole(\"search\", { name: \"Filter event queue\" });\n    expect(form).toHaveAttribute(\"action\", \"/operations/queue\");\n    expect(form).toHaveAttribute(\"method\", \"get\");\n\n    const status = screen.getByLabelText(\"Status\") as HTMLSelectElement;\n    expect(status.value).toBe(\"\");\n    const statusOptionValues = Array.from(status.options).map((o) => o.value);\n    expect(statusOptionValues).toContain(\"\");\n    for (const value of PEEK_EVENT_QUEUE_STATUSES) {\n      expect(statusOptionValues).toContain(value);\n    }\n\n    const ageBucket = screen.getByLabelText(\"Age bucket\") as HTMLSelectElement;\n    expect(ageBucket.value).toBe(\"\");\n    const ageOptionValues = Array.from(ageBucket.options).map((o) => o.value);\n    expect(ageOptionValues).toContain(\"\");\n    for (const bucket of PEEK_EVENT_QUEUE_AGE_BUCKETS) {\n      expect(ageOptionValues).toContain(bucket.id);\n    }\n\n    expect((screen.getByLabelText(\"Event type\") as HTMLInputElement).value).toBe(\n      \"\",\n    );\n    expect((screen.getByLabelText(\"Event id\") as HTMLInputElement).value).toBe(\n      \"\",\n    );\n    expect(\n      (screen.getByLabelText(\"Payload user id\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Scheduled from\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Scheduled to\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"\");\n  });\n\n  it(\"populated: pre-fills every field including the status + age-bucket selects\", () => {\n    render(<EventQueueFilterBar filters={POPULATED_FILTERS} />);\n\n    expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).value).toBe(\n      \"failed\",\n    );\n    expect(\n      (screen.getByLabelText(\"Age bucket\") as HTMLSelectElement).value,\n    ).toBe(\"lt_24h\");\n    expect(\n      (screen.getByLabelText(\"Event type\") as HTMLInputElement).value,\n    ).toBe(\"points.grant\");\n    expect((screen.getByLabelText(\"Event id\") as HTMLInputElement).value).toBe(\n      \"11111111-1111-1111-1111-111111111111\",\n    );\n    expect(\n      (screen.getByLabelText(\"Payload user id\") as HTMLInputElement).value,\n    ).toBe(\"user-9\");\n    expect(\n      (screen.getByLabelText(\"Scheduled from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Scheduled to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n  });\n\n  it(\"inputs use the queueFilter* prefix so the URL parser binds back without collisions\", () => {\n    render(<EventQueueFilterBar filters={EMPTY_FILTERS} />);\n\n    expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).name).toBe(\n      \"queueFilterStatus\",\n    );\n    expect(\n      (screen.getByLabelText(\"Age bucket\") as HTMLSelectElement).name,\n    ).toBe(\"queueFilterAge\");\n    expect(\n      (screen.getByLabelText(\"Event type\") as HTMLInputElement).name,\n    ).toBe(\"queueFilterType\");\n    expect((screen.getByLabelText(\"Event id\") as HTMLInputElement).name).toBe(\n      \"queueFilterId\",\n    );\n    expect(\n      (screen.getByLabelText(\"Payload user id\") as HTMLInputElement).name,\n    ).toBe(\"queueFilterUserId\");\n    expect(\n      (screen.getByLabelText(\"Scheduled from\") as HTMLInputElement).name,\n    ).toBe(\"queueFilterScheduledFrom\");\n    expect(\n      (screen.getByLabelText(\"Scheduled to\") as HTMLInputElement).name,\n    ).toBe(\"queueFilterScheduledTo\");\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).name,\n    ).toBe(\"queueFilterCreatedFrom\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).name,\n    ).toBe(\"queueFilterCreatedTo\");\n  });\n\n  it(\"populated: ISO timestamps in date filters are truncated to YYYY-MM-DD for the date inputs\", () => {\n    render(\n      <EventQueueFilterBar\n        filters={{\n          ...EMPTY_FILTERS,\n          scheduledFrom: \"2026-04-01T10:00:00.000Z\",\n          scheduledTo: \"2026-04-26T23:59:59.999Z\",\n          createdFrom: \"2026-04-01T10:00:00.000Z\",\n          createdTo: \"2026-04-26T23:59:59.999Z\",\n        }}\n      />,\n    );\n\n    expect(\n      (screen.getByLabelText(\"Scheduled from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Scheduled to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n  });\n\n  it(\"custom action overrides the default form target\", () => {\n    render(\n      <EventQueueFilterBar\n        filters={EMPTY_FILTERS}\n        action=\"/operations/queue?embed=1\"\n      />,\n    );\n    const form = screen.getByRole(\"search\", { name: \"Filter event queue\" });\n    expect(form).toHaveAttribute(\"action\", \"/operations/queue?embed=1\");\n  });\n\n  it(\"does NOT render a hidden selectedId input — submitting the filter form clears the detail panel\", () => {\n    // The filter bar submitting must NOT carry the previously-selected detail\n    // row id forward (otherwise opening a detail row would never clear via\n    // a filter submission). The component-level invariant: there must be no\n    // `<input name=\"selectedId\">` element rendered.\n    const { container } = render(<EventQueueFilterBar filters={EMPTY_FILTERS} />);\n    expect(container.querySelector(\"input[name='selectedId']\")).toBeNull();\n  });\n\n  it(\"status: state-transition coverage — every PEEK_EVENT_QUEUE_STATUSES value is renderable as a chosen option\", () => {\n    for (const value of PEEK_EVENT_QUEUE_STATUSES) {\n      const { unmount } = render(\n        <EventQueueFilterBar filters={{ ...EMPTY_FILTERS, status: value }} />,\n      );\n      expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).value).toBe(\n        value,\n      );\n      unmount();\n    }\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3328,"cache_read_input_tokens":149493,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3328},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"031ce74d-15ee-4888-a00b-e081672f539b","uuid":"11dc4537-ac17-4208-9c35-0dbd9f23fbb6"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q8JLFJndhPSay27bVQnWXh","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/components/__tests__/event-queue-filter-bar.test.tsx"}]},"parent_tool_use_id":null,"session_id":"031ce74d-15ee-4888-a00b-e081672f539b","uuid":"1a3f2558-8d94-4d06-a932-547dde55f724","timestamp":"2026-04-26T07:05:34.299Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/event-queue-filter-bar.test.tsx","content":"// Component tests for the FR-10 /operations/queue filter bar.\n//\n// The filter bar is a query-string GET form (no JS), so each test asserts:\n//   - the form posts to /operations/queue via GET;\n//   - each input/select uses its `queueFilter*` name (matches the URL parser);\n//   - the status + age-bucket selects expose every allowlisted enum value;\n//   - populated filters pre-fill every field;\n//   - ISO timestamps in date filters are truncated to YYYY-MM-DD;\n//   - the custom action prop overrides the default form target;\n//   - the `selectedId` param is intentionally NOT a hidden input (submitting\n//     the filter form clears the detail panel rather than reopening the row).\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { EventQueueFilterBar } from \"../event-queue-filter-bar\";\nimport {\n  PEEK_EVENT_QUEUE_AGE_BUCKETS,\n  PEEK_EVENT_QUEUE_STATUSES,\n} from \"../../lib/types/peek\";\nimport type { PeekEventQueueFilters } from \"../../lib/types/peek\";\n\nconst EMPTY_FILTERS: PeekEventQueueFilters = {\n  status: null,\n  eventType: null,\n  id: null,\n  payloadUserId: null,\n  scheduledFrom: null,\n  scheduledTo: null,\n  createdFrom: null,\n  createdTo: null,\n  ageBucket: null,\n};\n\nconst POPULATED_FILTERS: PeekEventQueueFilters = {\n  status: \"failed\",\n  eventType: \"points.grant\",\n  id: \"11111111-1111-1111-1111-111111111111\",\n  payloadUserId: \"user-9\",\n  scheduledFrom: \"2026-04-01\",\n  scheduledTo: \"2026-04-26\",\n  createdFrom: \"2026-04-01\",\n  createdTo: \"2026-04-26\",\n  ageBucket: \"lt_24h\",\n};\n\ndescribe(\"EventQueueFilterBar\", () => {\n  it(\"empty: form posts to /operations/queue by default with all inputs blank and 'Any' selected\", () => {\n    render(<EventQueueFilterBar filters={EMPTY_FILTERS} />);\n\n    const form = screen.getByRole(\"search\", { name: \"Filter event queue\" });\n    expect(form).toHaveAttribute(\"action\", \"/operations/queue\");\n    expect(form).toHaveAttribute(\"method\", \"get\");\n\n    const status = screen.getByLabelText(\"Status\") as HTMLSelectElement;\n    expect(status.value).toBe(\"\");\n    const statusOptionValues = Array.from(status.options).map((o) => o.value);\n    expect(statusOptionValues).toContain(\"\");\n    for (const value of PEEK_EVENT_QUEUE_STATUSES) {\n      expect(statusOptionValues).toContain(value);\n    }\n\n    const ageBucket = screen.getByLabelText(\"Age bucket\") as HTMLSelectElement;\n    expect(ageBucket.value).toBe(\"\");\n    const ageOptionValues = Array.from(ageBucket.options).map((o) => o.value);\n    expect(ageOptionValues).toContain(\"\");\n    for (const bucket of PEEK_EVENT_QUEUE_AGE_BUCKETS) {\n      expect(ageOptionValues).toContain(bucket.id);\n    }\n\n    expect((screen.getByLabelText(\"Event type\") as HTMLInputElement).value).toBe(\n      \"\",\n    );\n    expect((screen.getByLabelText(\"Event id\") as HTMLInputElement).value).toBe(\n      \"\",\n    );\n    expect(\n      (screen.getByLabelText(\"Payload user id\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Scheduled from\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Scheduled to\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"\");\n  });\n\n  it(\"populated: pre-fills every field including the status + age-bucket selects\", () => {\n    render(<EventQueueFilterBar filters={POPULATED_FILTERS} />);\n\n    expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).value).toBe(\n      \"failed\",\n    );\n    expect(\n      (screen.getByLabelText(\"Age bucket\") as HTMLSelectElement).value,\n    ).toBe(\"lt_24h\");\n    expect(\n      (screen.getByLabelText(\"Event type\") as HTMLInputElement).value,\n    ).toBe(\"points.grant\");\n    expect((screen.getByLabelText(\"Event id\") as HTMLInputElement).value).toBe(\n      \"11111111-1111-1111-1111-111111111111\",\n    );\n    expect(\n      (screen.getByLabelText(\"Payload user id\") as HTMLInputElement).value,\n    ).toBe(\"user-9\");\n    expect(\n      (screen.getByLabelText(\"Scheduled from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Scheduled to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n  });\n\n  it(\"inputs use the queueFilter* prefix so the URL parser binds back without collisions\", () => {\n    render(<EventQueueFilterBar filters={EMPTY_FILTERS} />);\n\n    expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).name).toBe(\n      \"queueFilterStatus\",\n    );\n    expect(\n      (screen.getByLabelText(\"Age bucket\") as HTMLSelectElement).name,\n    ).toBe(\"queueFilterAge\");\n    expect(\n      (screen.getByLabelText(\"Event type\") as HTMLInputElement).name,\n    ).toBe(\"queueFilterType\");\n    expect((screen.getByLabelText(\"Event id\") as HTMLInputElement).name).toBe(\n      \"queueFilterId\",\n    );\n    expect(\n      (screen.getByLabelText(\"Payload user id\") as HTMLInputElement).name,\n    ).toBe(\"queueFilterUserId\");\n    expect(\n      (screen.getByLabelText(\"Scheduled from\") as HTMLInputElement).name,\n    ).toBe(\"queueFilterScheduledFrom\");\n    expect(\n      (screen.getByLabelText(\"Scheduled to\") as HTMLInputElement).name,\n    ).toBe(\"queueFilterScheduledTo\");\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).name,\n    ).toBe(\"queueFilterCreatedFrom\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).name,\n    ).toBe(\"queueFilterCreatedTo\");\n  });\n\n  it(\"populated: ISO timestamps in date filters are truncated to YYYY-MM-DD for the date inputs\", () => {\n    render(\n      <EventQueueFilterBar\n        filters={{\n          ...EMPTY_FILTERS,\n          scheduledFrom: \"2026-04-01T10:00:00.000Z\",\n          scheduledTo: \"2026-04-26T23:59:59.999Z\",\n          createdFrom: \"2026-04-01T10:00:00.000Z\",\n          createdTo: \"2026-04-26T23:59:59.999Z\",\n        }}\n      />,\n    );\n\n    expect(\n      (screen.getByLabelText(\"Scheduled from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Scheduled to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n  });\n\n  it(\"custom action overrides the default form target\", () => {\n    render(\n      <EventQueueFilterBar\n        filters={EMPTY_FILTERS}\n        action=\"/operations/queue?embed=1\"\n      />,\n    );\n    const form = screen.getByRole(\"search\", { name: \"Filter event queue\" });\n    expect(form).toHaveAttribute(\"action\", \"/operations/queue?embed=1\");\n  });\n\n  it(\"does NOT render a hidden selectedId input — submitting the filter form clears the detail panel\", () => {\n    // The filter bar submitting must NOT carry the previously-selected detail\n    // row id forward (otherwise opening a detail row would never clear via\n    // a filter submission). The component-level invariant: there must be no\n    // `<input name=\"selectedId\">` element rendered.\n    const { container } = render(<EventQueueFilterBar filters={EMPTY_FILTERS} />);\n    expect(container.querySelector(\"input[name='selectedId']\")).toBeNull();\n  });\n\n  it(\"status: state-transition coverage — every PEEK_EVENT_QUEUE_STATUSES value is renderable as a chosen option\", () => {\n    for (const value of PEEK_EVENT_QUEUE_STATUSES) {\n      const { unmount } = render(\n        <EventQueueFilterBar filters={{ ...EMPTY_FILTERS, status: value }} />,\n      );\n      expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).value).toBe(\n        value,\n      );\n      unmount();\n    }\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01UMLbnsAqcxFckYsFMDVCWF","type":"message","role":"assistant","content":[{"type":"text","text":"Now create the table component test:"}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3649,"cache_read_input_tokens":152821,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3649},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"031ce74d-15ee-4888-a00b-e081672f539b","uuid":"7bfab38e-1c3b-4895-af1c-ce883d4e1692"}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01UMLbnsAqcxFckYsFMDVCWF","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01UgMah3JsUuMZLq9t7TxeYW","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/__tests__/event-queue-table.test.tsx","content":"// Component tests for the FR-10 /operations/queue event queue table.\n//\n// Read-only by spec — every queue mutation (retry / cancel / replay) lives\n// behind a future spec (FR-10 line 342). These tests assert there are no edit\n// affordances rendered, every status drives the right chip tone, the linked\n// payload ids surface as drilldowns, and the row id anchor sets\n// `?selectedId=<id>` so the detail panel can resolve it server-side.\n//\n// Coverage spans the spec line \"pending, failed, dead, aged, filtered,\n// redacted-payload states\": fixtures cover every lifecycle status, and a\n// dedicated test asserts the redacted error preview round-trips verbatim into\n// the row.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport {\n  EventQueueTable,\n  queueStatusTone,\n} from \"../event-queue-table\";\nimport { PEEK_AUDIT_REDACTED } from \"../../lib/types/peek\";\nimport type { PeekEventQueueListRow } from \"../../lib/types/peek\";\n\nconst ROW_PENDING: PeekEventQueueListRow = {\n  id: \"11111111-1111-1111-1111-111111111111\",\n  eventType: \"points.grant\",\n  status: \"pending\",\n  attempts: 0,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-26T10:00:00.000Z\",\n  startedAt: null,\n  completedAt: null,\n  createdAt: \"2026-04-26T09:55:00.000Z\",\n  errorPreview: null,\n  linked: { userId: \"user-9\", roundId: null, claimId: null },\n};\n\nconst ROW_FAILED: PeekEventQueueListRow = {\n  id: \"22222222-2222-2222-2222-222222222222\",\n  eventType: \"claims.process\",\n  status: \"failed\",\n  attempts: 3,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-26T10:00:00.000Z\",\n  startedAt: \"2026-04-26T10:01:00.000Z\",\n  completedAt: null,\n  createdAt: \"2026-04-26T09:55:00.000Z\",\n  errorPreview: \"RpcError: connection refused\",\n  linked: { userId: \"user-3\", roundId: null, claimId: \"claim-7\" },\n};\n\nconst ROW_DEAD: PeekEventQueueListRow = {\n  id: \"33333333-3333-3333-3333-333333333333\",\n  eventType: \"rewards.payout\",\n  status: \"dead\",\n  attempts: 5,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-25T10:00:00.000Z\",\n  startedAt: \"2026-04-25T10:01:00.000Z\",\n  completedAt: null,\n  createdAt: \"2026-04-25T09:55:00.000Z\",\n  errorPreview: PEEK_AUDIT_REDACTED,\n  linked: { userId: null, roundId: \"round-9\", claimId: null },\n};\n\nconst ROW_PROCESSING: PeekEventQueueListRow = {\n  id: \"44444444-4444-4444-4444-444444444444\",\n  eventType: \"points.grant\",\n  status: \"processing\",\n  attempts: 1,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-26T10:00:00.000Z\",\n  startedAt: \"2026-04-26T10:00:30.000Z\",\n  completedAt: null,\n  createdAt: \"2026-04-26T09:55:00.000Z\",\n  errorPreview: null,\n  linked: { userId: null, roundId: null, claimId: null },\n};\n\nconst ROW_COMPLETED: PeekEventQueueListRow = {\n  id: \"55555555-5555-5555-5555-555555555555\",\n  eventType: \"points.grant\",\n  status: \"completed\",\n  attempts: 1,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-26T09:00:00.000Z\",\n  startedAt: \"2026-04-26T09:00:30.000Z\",\n  completedAt: \"2026-04-26T09:01:00.000Z\",\n  createdAt: \"2026-04-26T08:55:00.000Z\",\n  errorPreview: null,\n  linked: { userId: \"user-1\", roundId: null, claimId: null },\n};\n\ndescribe(\"EventQueueTable\", () => {\n  it(\"populated: renders the operator columns and every lifecycle status chip\", () => {\n    render(\n      <EventQueueTable\n        rows={[ROW_PENDING, ROW_PROCESSING, ROW_FAILED, ROW_DEAD, ROW_COMPLETED]}\n      />,\n    );\n\n    for (const header of [\n      \"Status\",\n      \"Event type\",\n      \"Attempts\",\n      \"Created\",\n      \"Scheduled\",\n      \"Started\",\n      \"Completed\",\n      \"Linked\",\n      \"Error\",\n      \"ID\",\n    ]) {\n      expect(screen.getByText(header)).toBeInTheDocument();\n    }\n\n    // State-transition coverage: a chip per migration status.\n    expect(screen.getByText(\"pending\")).toBeInTheDocument();\n    expect(screen.getByText(\"processing\")).toBeInTheDocument();\n    expect(screen.getByText(\"failed\")).toBeInTheDocument();\n    expect(screen.getByText(\"dead\")).toBeInTheDocument();\n    expect(screen.getByText(\"completed\")).toBeInTheDocument();\n  });\n\n  it(\"populated: attempts cell renders attempts/maxAttempts with thousands separators\", () => {\n    const big: PeekEventQueueListRow = {\n      ...ROW_FAILED,\n      attempts: 1234,\n      maxAttempts: 5678,\n    };\n    render(<EventQueueTable rows={[big]} />);\n    expect(screen.getByText(\"1,234 / 5,678\")).toBeInTheDocument();\n  });\n\n  it(\"populated: failed row links payload userId and claimId — userId is the only drilldown\", () => {\n    render(<EventQueueTable rows={[ROW_FAILED]} />);\n    // userId is rendered as a Next.js link to /users/[userId].\n    const link = screen.getByRole(\"link\", { name: /user user-3/ });\n    expect(link).toHaveAttribute(\"href\", \"/users/user-3\");\n    // Round and claim ids surface as inline tokens (read-only — no future\n    // route exists yet for /games/.../rounds/<id> or /claims/<id>).\n    expect(screen.getByText(/claim claim-7/)).toBeInTheDocument();\n  });\n\n  it(\"populated: dead row preserves the redacted error preview verbatim — secrets never reach the operator\", () => {\n    render(<EventQueueTable rows={[ROW_DEAD]} />);\n    // The redacted sentinel from the audit module surfaces in the cell so\n    // an operator can confirm the value was redacted without seeing it.\n    expect(screen.getByText(PEEK_AUDIT_REDACTED)).toBeInTheDocument();\n  });\n\n  it(\"populated: row id is the detail-panel anchor — links to ?selectedId=<encoded id>\", () => {\n    render(<EventQueueTable rows={[ROW_FAILED]} />);\n    const anchor = screen.getByRole(\"link\", {\n      name: `Open detail for event ${ROW_FAILED.id}`,\n    });\n    expect(anchor).toHaveAttribute(\n      \"href\",\n      `/operations/queue?selectedId=${encodeURIComponent(ROW_FAILED.id)}`,\n    );\n  });\n\n  it(\"populated: aria-current marks the selected row when selectedId matches\", () => {\n    const { container } = render(\n      <EventQueueTable\n        rows={[ROW_PENDING, ROW_FAILED]}\n        selectedId={ROW_FAILED.id}\n      />,\n    );\n    const currentRow = container.querySelector(\"tr[aria-current='true']\");\n    expect(currentRow).not.toBeNull();\n    // The other row has no aria-current marker.\n    const otherRows = container.querySelectorAll(\"tbody tr\");\n    let withMarker = 0;\n    otherRows.forEach((tr) => {\n      if (tr.getAttribute(\"aria-current\") === \"true\") withMarker += 1;\n    });\n    expect(withMarker).toBe(1);\n  });\n\n  it(\"populated: selectedIdHrefBuilder override lets the table be reused for audit views or tests\", () => {\n    render(\n      <EventQueueTable\n        rows={[ROW_FAILED]}\n        selectedIdHrefBuilder={(row) => `/audit/queue/${row.id}`}\n      />,\n    );\n    const anchor = screen.getByRole(\"link\", {\n      name: `Open detail for event ${ROW_FAILED.id}`,\n    });\n    expect(anchor).toHaveAttribute(\"href\", `/audit/queue/${ROW_FAILED.id}`);\n  });\n\n  it(\"populated: a row with no linked ids renders a plain em-dash (no broken drilldown shells)\", () => {\n    render(<EventQueueTable rows={[ROW_PROCESSING]} />);\n    // ROW_PROCESSING has all linked ids null. The Linked cell renders \"—\".\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(1);\n  });\n\n  it(\"read-only: no edit affordances rendered (no buttons, no editable inputs, no checkboxes)\", () => {\n    // FR-10 line 342: retry / cancel / replay are explicitly out of scope.\n    // The table must not render any mutating control. Only drilldown links\n    // (user, detail anchor) are allowed.\n    render(\n      <EventQueueTable\n        rows={[ROW_PENDING, ROW_PROCESSING, ROW_FAILED, ROW_DEAD, ROW_COMPLETED]}\n      />,\n    );\n    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n    expect(screen.queryByRole(\"textbox\")).toBeNull();\n    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n    expect(screen.queryAllByRole(\"link\").length).toBeGreaterThan(0);\n  });\n\n  it(\"empty: renders the operator status block when no rows match\", () => {\n    render(<EventQueueTable rows={[]} />);\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\n      \"No event_queue rows match these filters.\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n    render(\n      <EventQueueTable rows={[ROW_FAILED]} error=\"connection refused\" />,\n    );\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Event queue rows unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n\ndescribe(\"queueStatusTone\", () => {\n  it(\"maps every migration status to a deterministic tone\", () => {\n    expect(queueStatusTone(\"completed\")).toBe(\"positive\");\n    expect(queueStatusTone(\"processing\")).toBe(\"info\");\n    expect(queueStatusTone(\"pending\")).toBe(\"neutral\");\n    expect(queueStatusTone(\"failed\")).toBe(\"warning\");\n    expect(queueStatusTone(\"dead\")).toBe(\"negative\");\n  });\n\n  it(\"falls back to neutral for an unknown status\", () => {\n    expect(queueStatusTone(\"unknown\")).toBe(\"neutral\");\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3649,"cache_read_input_tokens":152821,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3649},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"031ce74d-15ee-4888-a00b-e081672f539b","uuid":"ec17f2cf-ffcc-471b-b25a-0f007a90d053"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UgMah3JsUuMZLq9t7TxeYW","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/components/__tests__/event-queue-table.test.tsx"}]},"parent_tool_use_id":null,"session_id":"031ce74d-15ee-4888-a00b-e081672f539b","uuid":"708bee1a-69c5-4e11-9218-24b82dc44abc","timestamp":"2026-04-26T07:06:31.504Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/event-queue-table.test.tsx","content":"// Component tests for the FR-10 /operations/queue event queue table.\n//\n// Read-only by spec — every queue mutation (retry / cancel / replay) lives\n// behind a future spec (FR-10 line 342). These tests assert there are no edit\n// affordances rendered, every status drives the right chip tone, the linked\n// payload ids surface as drilldowns, and the row id anchor sets\n// `?selectedId=<id>` so the detail panel can resolve it server-side.\n//\n// Coverage spans the spec line \"pending, failed, dead, aged, filtered,\n// redacted-payload states\": fixtures cover every lifecycle status, and a\n// dedicated test asserts the redacted error preview round-trips verbatim into\n// the row.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport {\n  EventQueueTable,\n  queueStatusTone,\n} from \"../event-queue-table\";\nimport { PEEK_AUDIT_REDACTED } from \"../../lib/types/peek\";\nimport type { PeekEventQueueListRow } from \"../../lib/types/peek\";\n\nconst ROW_PENDING: PeekEventQueueListRow = {\n  id: \"11111111-1111-1111-1111-111111111111\",\n  eventType: \"points.grant\",\n  status: \"pending\",\n  attempts: 0,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-26T10:00:00.000Z\",\n  startedAt: null,\n  completedAt: null,\n  createdAt: \"2026-04-26T09:55:00.000Z\",\n  errorPreview: null,\n  linked: { userId: \"user-9\", roundId: null, claimId: null },\n};\n\nconst ROW_FAILED: PeekEventQueueListRow = {\n  id: \"22222222-2222-2222-2222-222222222222\",\n  eventType: \"claims.process\",\n  status: \"failed\",\n  attempts: 3,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-26T10:00:00.000Z\",\n  startedAt: \"2026-04-26T10:01:00.000Z\",\n  completedAt: null,\n  createdAt: \"2026-04-26T09:55:00.000Z\",\n  errorPreview: \"RpcError: connection refused\",\n  linked: { userId: \"user-3\", roundId: null, claimId: \"claim-7\" },\n};\n\nconst ROW_DEAD: PeekEventQueueListRow = {\n  id: \"33333333-3333-3333-3333-333333333333\",\n  eventType: \"rewards.payout\",\n  status: \"dead\",\n  attempts: 5,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-25T10:00:00.000Z\",\n  startedAt: \"2026-04-25T10:01:00.000Z\",\n  completedAt: null,\n  createdAt: \"2026-04-25T09:55:00.000Z\",\n  errorPreview: PEEK_AUDIT_REDACTED,\n  linked: { userId: null, roundId: \"round-9\", claimId: null },\n};\n\nconst ROW_PROCESSING: PeekEventQueueListRow = {\n  id: \"44444444-4444-4444-4444-444444444444\",\n  eventType: \"points.grant\",\n  status: \"processing\",\n  attempts: 1,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-26T10:00:00.000Z\",\n  startedAt: \"2026-04-26T10:00:30.000Z\",\n  completedAt: null,\n  createdAt: \"2026-04-26T09:55:00.000Z\",\n  errorPreview: null,\n  linked: { userId: null, roundId: null, claimId: null },\n};\n\nconst ROW_COMPLETED: PeekEventQueueListRow = {\n  id: \"55555555-5555-5555-5555-555555555555\",\n  eventType: \"points.grant\",\n  status: \"completed\",\n  attempts: 1,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-26T09:00:00.000Z\",\n  startedAt: \"2026-04-26T09:00:30.000Z\",\n  completedAt: \"2026-04-26T09:01:00.000Z\",\n  createdAt: \"2026-04-26T08:55:00.000Z\",\n  errorPreview: null,\n  linked: { userId: \"user-1\", roundId: null, claimId: null },\n};\n\ndescribe(\"EventQueueTable\", () => {\n  it(\"populated: renders the operator columns and every lifecycle status chip\", () => {\n    render(\n      <EventQueueTable\n        rows={[ROW_PENDING, ROW_PROCESSING, ROW_FAILED, ROW_DEAD, ROW_COMPLETED]}\n      />,\n    );\n\n    for (const header of [\n      \"Status\",\n      \"Event type\",\n      \"Attempts\",\n      \"Created\",\n      \"Scheduled\",\n      \"Started\",\n      \"Completed\",\n      \"Linked\",\n      \"Error\",\n      \"ID\",\n    ]) {\n      expect(screen.getByText(header)).toBeInTheDocument();\n    }\n\n    // State-transition coverage: a chip per migration status.\n    expect(screen.getByText(\"pending\")).toBeInTheDocument();\n    expect(screen.getByText(\"processing\")).toBeInTheDocument();\n    expect(screen.getByText(\"failed\")).toBeInTheDocument();\n    expect(screen.getByText(\"dead\")).toBeInTheDocument();\n    expect(screen.getByText(\"completed\")).toBeInTheDocument();\n  });\n\n  it(\"populated: attempts cell renders attempts/maxAttempts with thousands separators\", () => {\n    const big: PeekEventQueueListRow = {\n      ...ROW_FAILED,\n      attempts: 1234,\n      maxAttempts: 5678,\n    };\n    render(<EventQueueTable rows={[big]} />);\n    expect(screen.getByText(\"1,234 / 5,678\")).toBeInTheDocument();\n  });\n\n  it(\"populated: failed row links payload userId and claimId — userId is the only drilldown\", () => {\n    render(<EventQueueTable rows={[ROW_FAILED]} />);\n    // userId is rendered as a Next.js link to /users/[userId].\n    const link = screen.getByRole(\"link\", { name: /user user-3/ });\n    expect(link).toHaveAttribute(\"href\", \"/users/user-3\");\n    // Round and claim ids surface as inline tokens (read-only — no future\n    // route exists yet for /games/.../rounds/<id> or /claims/<id>).\n    expect(screen.getByText(/claim claim-7/)).toBeInTheDocument();\n  });\n\n  it(\"populated: dead row preserves the redacted error preview verbatim — secrets never reach the operator\", () => {\n    render(<EventQueueTable rows={[ROW_DEAD]} />);\n    // The redacted sentinel from the audit module surfaces in the cell so\n    // an operator can confirm the value was redacted without seeing it.\n    expect(screen.getByText(PEEK_AUDIT_REDACTED)).toBeInTheDocument();\n  });\n\n  it(\"populated: row id is the detail-panel anchor — links to ?selectedId=<encoded id>\", () => {\n    render(<EventQueueTable rows={[ROW_FAILED]} />);\n    const anchor = screen.getByRole(\"link\", {\n      name: `Open detail for event ${ROW_FAILED.id}`,\n    });\n    expect(anchor).toHaveAttribute(\n      \"href\",\n      `/operations/queue?selectedId=${encodeURIComponent(ROW_FAILED.id)}`,\n    );\n  });\n\n  it(\"populated: aria-current marks the selected row when selectedId matches\", () => {\n    const { container } = render(\n      <EventQueueTable\n        rows={[ROW_PENDING, ROW_FAILED]}\n        selectedId={ROW_FAILED.id}\n      />,\n    );\n    const currentRow = container.querySelector(\"tr[aria-current='true']\");\n    expect(currentRow).not.toBeNull();\n    // The other row has no aria-current marker.\n    const otherRows = container.querySelectorAll(\"tbody tr\");\n    let withMarker = 0;\n    otherRows.forEach((tr) => {\n      if (tr.getAttribute(\"aria-current\") === \"true\") withMarker += 1;\n    });\n    expect(withMarker).toBe(1);\n  });\n\n  it(\"populated: selectedIdHrefBuilder override lets the table be reused for audit views or tests\", () => {\n    render(\n      <EventQueueTable\n        rows={[ROW_FAILED]}\n        selectedIdHrefBuilder={(row) => `/audit/queue/${row.id}`}\n      />,\n    );\n    const anchor = screen.getByRole(\"link\", {\n      name: `Open detail for event ${ROW_FAILED.id}`,\n    });\n    expect(anchor).toHaveAttribute(\"href\", `/audit/queue/${ROW_FAILED.id}`);\n  });\n\n  it(\"populated: a row with no linked ids renders a plain em-dash (no broken drilldown shells)\", () => {\n    render(<EventQueueTable rows={[ROW_PROCESSING]} />);\n    // ROW_PROCESSING has all linked ids null. The Linked cell renders \"—\".\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(1);\n  });\n\n  it(\"read-only: no edit affordances rendered (no buttons, no editable inputs, no checkboxes)\", () => {\n    // FR-10 line 342: retry / cancel / replay are explicitly out of scope.\n    // The table must not render any mutating control. Only drilldown links\n    // (user, detail anchor) are allowed.\n    render(\n      <EventQueueTable\n        rows={[ROW_PENDING, ROW_PROCESSING, ROW_FAILED, ROW_DEAD, ROW_COMPLETED]}\n      />,\n    );\n    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n    expect(screen.queryByRole(\"textbox\")).toBeNull();\n    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n    expect(screen.queryAllByRole(\"link\").length).toBeGreaterThan(0);\n  });\n\n  it(\"empty: renders the operator status block when no rows match\", () => {\n    render(<EventQueueTable rows={[]} />);\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\n      \"No event_queue rows match these filters.\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n    render(\n      <EventQueueTable rows={[ROW_FAILED]} error=\"connection refused\" />,\n    );\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Event queue rows unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n\ndescribe(\"queueStatusTone\", () => {\n  it(\"maps every migration status to a deterministic tone\", () => {\n    expect(queueStatusTone(\"completed\")).toBe(\"positive\");\n    expect(queueStatusTone(\"processing\")).toBe(\"info\");\n    expect(queueStatusTone(\"pending\")).toBe(\"neutral\");\n    expect(queueStatusTone(\"failed\")).toBe(\"warning\");\n    expect(queueStatusTone(\"dead\")).toBe(\"negative\");\n  });\n\n  it(\"falls back to neutral for an unknown status\", () => {\n    expect(queueStatusTone(\"unknown\")).toBe(\"neutral\");\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01UQUNcgBEGMzUVsbNLAtpXT","type":"message","role":"assistant","content":[{"type":"text","text":"Now create the detail panel test:"}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4144,"cache_read_input_tokens":156470,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4144},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"031ce74d-15ee-4888-a00b-e081672f539b","uuid":"b8f2dcb2-de3a-4e13-8069-34819a8bdbe7"}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01UQUNcgBEGMzUVsbNLAtpXT","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011rcbyUuESRJGZZXErHB5VC","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/__tests__/event-queue-detail-panel.test.tsx","content":"// Component tests for the FR-10 /operations/queue detail panel.\n//\n// The panel renders one row alongside the queue list when `?selectedId=<id>`\n// is on the URL. Payload + error fields have already been redacted server-side\n// via the audit redactor — the panel re-renders the redacted output verbatim\n// so an operator can confirm the `PEEK_AUDIT_REDACTED` marker is in place\n// without ever seeing the original secret.\n//\n// Coverage spans the spec line \"redacted-payload states\": a dedicated test\n// asserts the JSONB payload renders as JSON (with redaction sentinels intact)\n// and the error block falls back to \"—\" when null.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { EventQueueDetailPanel } from \"../event-queue-detail-panel\";\nimport { PEEK_AUDIT_REDACTED } from \"../../lib/types/peek\";\nimport type { PeekEventQueueDetail } from \"../../lib/types/peek\";\n\nconst DETAIL_FAILED: PeekEventQueueDetail = {\n  id: \"11111111-1111-1111-1111-111111111111\",\n  eventType: \"claims.process\",\n  status: \"failed\",\n  attempts: 3,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-26T10:00:00.000Z\",\n  startedAt: \"2026-04-26T10:01:00.000Z\",\n  completedAt: null,\n  createdAt: \"2026-04-26T09:55:00.000Z\",\n  error: \"RpcError: connection refused\",\n  payload: { userId: \"user-9\", claimAmount: \"5000000\" },\n  linked: { userId: \"user-9\", roundId: null, claimId: \"claim-3\" },\n};\n\nconst DETAIL_DEAD_REDACTED: PeekEventQueueDetail = {\n  id: \"22222222-2222-2222-2222-222222222222\",\n  eventType: \"auth.callback\",\n  status: \"dead\",\n  attempts: 5,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-25T10:00:00.000Z\",\n  startedAt: \"2026-04-25T10:01:00.000Z\",\n  completedAt: null,\n  createdAt: \"2026-04-25T09:55:00.000Z\",\n  error: PEEK_AUDIT_REDACTED,\n  payload: {\n    userId: \"user-9\",\n    // Server-side redactor has already replaced the secret with the marker.\n    authHeader: PEEK_AUDIT_REDACTED,\n  },\n  linked: { userId: \"user-9\", roundId: null, claimId: null },\n};\n\nconst DETAIL_PENDING_NULL_ERROR: PeekEventQueueDetail = {\n  id: \"33333333-3333-3333-3333-333333333333\",\n  eventType: \"points.grant\",\n  status: \"pending\",\n  attempts: 0,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-26T10:00:00.000Z\",\n  startedAt: null,\n  completedAt: null,\n  createdAt: \"2026-04-26T09:55:00.000Z\",\n  error: null,\n  payload: { userId: \"user-9\", amount: 100 },\n  linked: { userId: \"user-9\", roundId: null, claimId: null },\n};\n\ndescribe(\"EventQueueDetailPanel\", () => {\n  it(\"hint state: with no selectedId, prompts the operator to choose a row\", () => {\n    render(<EventQueueDetailPanel detail={null} selectedId={null} />);\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\n      \"Select a row id to load the full payload.\",\n    );\n  });\n\n  it(\"not-found state: surfaces the missing-id message and never renders the meta panel\", () => {\n    render(\n      <EventQueueDetailPanel\n        detail={null}\n        selectedId=\"abc\"\n        notFound={true}\n      />,\n    );\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(/no event_queue row matches id abc/i);\n  });\n\n  it(\"error: alerts and never renders the title section\", () => {\n    render(\n      <EventQueueDetailPanel\n        detail={null}\n        selectedId=\"abc\"\n        error=\"connection refused\"\n      />,\n    );\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Detail unavailable: connection refused\",\n    );\n    expect(screen.queryByText(\"Payload (redacted)\")).toBeNull();\n  });\n\n  it(\"populated: renders status chip, attempts ratio, lifecycle timestamps, and the user-detail drilldown\", () => {\n    render(\n      <EventQueueDetailPanel\n        detail={DETAIL_FAILED}\n        selectedId={DETAIL_FAILED.id}\n      />,\n    );\n\n    expect(screen.getByText(\"failed\")).toBeInTheDocument();\n    expect(screen.getByText(`Event ${DETAIL_FAILED.id}`)).toBeInTheDocument();\n    expect(screen.getByText(\"3 / 5\")).toBeInTheDocument();\n    expect(screen.getByText(DETAIL_FAILED.createdAt)).toBeInTheDocument();\n    expect(screen.getByText(DETAIL_FAILED.scheduledAt)).toBeInTheDocument();\n\n    const userLink = screen.getByRole(\"link\", { name: \"user-9\" });\n    expect(userLink).toHaveAttribute(\"href\", \"/users/user-9\");\n  });\n\n  it(\"populated: error renders inside a <pre> block when present\", () => {\n    const { container } = render(\n      <EventQueueDetailPanel\n        detail={DETAIL_FAILED}\n        selectedId={DETAIL_FAILED.id}\n      />,\n    );\n    const pres = container.querySelectorAll(\"pre\");\n    expect(pres.length).toBeGreaterThanOrEqual(2);\n    const errorPre = Array.from(pres).find((node) =>\n      node.textContent?.includes(\"RpcError: connection refused\"),\n    );\n    expect(errorPre).not.toBeUndefined();\n  });\n\n  it(\"payload: JSON serialises with 2-space indent into a <pre> block\", () => {\n    const { container } = render(\n      <EventQueueDetailPanel\n        detail={DETAIL_FAILED}\n        selectedId={DETAIL_FAILED.id}\n      />,\n    );\n    const pres = container.querySelectorAll(\"pre\");\n    const expected = JSON.stringify(DETAIL_FAILED.payload, null, 2);\n    const payloadPre = Array.from(pres).find(\n      (node) => node.textContent === expected,\n    );\n    expect(payloadPre).not.toBeUndefined();\n  });\n\n  it(\"redacted-payload state: server-side redaction sentinels round-trip into both the error block and the payload JSON\", () => {\n    const { container } = render(\n      <EventQueueDetailPanel\n        detail={DETAIL_DEAD_REDACTED}\n        selectedId={DETAIL_DEAD_REDACTED.id}\n      />,\n    );\n    // The `error` field is rendered into a <pre> with the sentinel intact.\n    const pres = container.querySelectorAll(\"pre\");\n    expect(pres.length).toBeGreaterThanOrEqual(2);\n\n    const allPreText = Array.from(pres)\n      .map((p) => p.textContent ?? \"\")\n      .join(\"\\n\");\n    // Both the error and the payload render the redaction marker.\n    expect(allPreText).toContain(PEEK_AUDIT_REDACTED);\n\n    // The original secret never reaches the rendered output.\n    expect(allPreText).not.toContain(\"Bearer \");\n    expect(allPreText).not.toContain(\"eyJhbGciOi\");\n    expect(allPreText).not.toContain(\"postgres://\");\n  });\n\n  it(\"null error: renders '—' instead of an empty <pre>\", () => {\n    render(\n      <EventQueueDetailPanel\n        detail={DETAIL_PENDING_NULL_ERROR}\n        selectedId={DETAIL_PENDING_NULL_ERROR.id}\n      />,\n    );\n    // The Error (redacted) section heading appears...\n    expect(screen.getByText(/error \\(redacted\\)/i)).toBeInTheDocument();\n    // ...followed by a \"—\" placeholder when the error is null.\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(1);\n  });\n\n  it(\"read-only: renders no edit affordances (no buttons, no editable inputs, no checkboxes)\", () => {\n    // FR-10 line 342: retry / cancel / replay are out of scope. The detail\n    // panel is the highest-detail surface for queue events, so we explicitly\n    // assert it never renders a mutating control even when the operator is\n    // viewing a dead/failed row.\n    render(\n      <EventQueueDetailPanel\n        detail={DETAIL_DEAD_REDACTED}\n        selectedId={DETAIL_DEAD_REDACTED.id}\n      />,\n    );\n    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n    expect(screen.queryByRole(\"textbox\")).toBeNull();\n    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n  });\n\n  it(\"read-only notice: anchors the FR-10 line 342 out-of-scope statement\", () => {\n    render(\n      <EventQueueDetailPanel\n        detail={DETAIL_FAILED}\n        selectedId={DETAIL_FAILED.id}\n      />,\n    );\n    expect(\n      screen.getByText(\n        /retry, cancel, and replay actions are out of scope/i,\n      ),\n    ).toBeInTheDocument();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4144,"cache_read_input_tokens":156470,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4144},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"031ce74d-15ee-4888-a00b-e081672f539b","uuid":"5e0ed454-7584-4cca-b590-6bfe1bd08124"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011rcbyUuESRJGZZXErHB5VC","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/components/__tests__/event-queue-detail-panel.test.tsx"}]},"parent_tool_use_id":null,"session_id":"031ce74d-15ee-4888-a00b-e081672f539b","uuid":"bc074f2d-d572-4cf3-86d6-583f5e140ddd","timestamp":"2026-04-26T07:07:06.933Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/event-queue-detail-panel.test.tsx","content":"// Component tests for the FR-10 /operations/queue detail panel.\n//\n// The panel renders one row alongside the queue list when `?selectedId=<id>`\n// is on the URL. Payload + error fields have already been redacted server-side\n// via the audit redactor — the panel re-renders the redacted output verbatim\n// so an operator can confirm the `PEEK_AUDIT_REDACTED` marker is in place\n// without ever seeing the original secret.\n//\n// Coverage spans the spec line \"redacted-payload states\": a dedicated test\n// asserts the JSONB payload renders as JSON (with redaction sentinels intact)\n// and the error block falls back to \"—\" when null.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { EventQueueDetailPanel } from \"../event-queue-detail-panel\";\nimport { PEEK_AUDIT_REDACTED } from \"../../lib/types/peek\";\nimport type { PeekEventQueueDetail } from \"../../lib/types/peek\";\n\nconst DETAIL_FAILED: PeekEventQueueDetail = {\n  id: \"11111111-1111-1111-1111-111111111111\",\n  eventType: \"claims.process\",\n  status: \"failed\",\n  attempts: 3,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-26T10:00:00.000Z\",\n  startedAt: \"2026-04-26T10:01:00.000Z\",\n  completedAt: null,\n  createdAt: \"2026-04-26T09:55:00.000Z\",\n  error: \"RpcError: connection refused\",\n  payload: { userId: \"user-9\", claimAmount: \"5000000\" },\n  linked: { userId: \"user-9\", roundId: null, claimId: \"claim-3\" },\n};\n\nconst DETAIL_DEAD_REDACTED: PeekEventQueueDetail = {\n  id: \"22222222-2222-2222-2222-222222222222\",\n  eventType: \"auth.callback\",\n  status: \"dead\",\n  attempts: 5,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-25T10:00:00.000Z\",\n  startedAt: \"2026-04-25T10:01:00.000Z\",\n  completedAt: null,\n  createdAt: \"2026-04-25T09:55:00.000Z\",\n  error: PEEK_AUDIT_REDACTED,\n  payload: {\n    userId: \"user-9\",\n    // Server-side redactor has already replaced the secret with the marker.\n    authHeader: PEEK_AUDIT_REDACTED,\n  },\n  linked: { userId: \"user-9\", roundId: null, claimId: null },\n};\n\nconst DETAIL_PENDING_NULL_ERROR: PeekEventQueueDetail = {\n  id: \"33333333-3333-3333-3333-333333333333\",\n  eventType: \"points.grant\",\n  status: \"pending\",\n  attempts: 0,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-26T10:00:00.000Z\",\n  startedAt: null,\n  completedAt: null,\n  createdAt: \"2026-04-26T09:55:00.000Z\",\n  error: null,\n  payload: { userId: \"user-9\", amount: 100 },\n  linked: { userId: \"user-9\", roundId: null, claimId: null },\n};\n\ndescribe(\"EventQueueDetailPanel\", () => {\n  it(\"hint state: with no selectedId, prompts the operator to choose a row\", () => {\n    render(<EventQueueDetailPanel detail={null} selectedId={null} />);\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\n      \"Select a row id to load the full payload.\",\n    );\n  });\n\n  it(\"not-found state: surfaces the missing-id message and never renders the meta panel\", () => {\n    render(\n      <EventQueueDetailPanel\n        detail={null}\n        selectedId=\"abc\"\n        notFound={true}\n      />,\n    );\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(/no event_queue row matches id abc/i);\n  });\n\n  it(\"error: alerts and never renders the title section\", () => {\n    render(\n      <EventQueueDetailPanel\n        detail={null}\n        selectedId=\"abc\"\n        error=\"connection refused\"\n      />,\n    );\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Detail unavailable: connection refused\",\n    );\n    expect(screen.queryByText(\"Payload (redacted)\")).toBeNull();\n  });\n\n  it(\"populated: renders status chip, attempts ratio, lifecycle timestamps, and the user-detail drilldown\", () => {\n    render(\n      <EventQueueDetailPanel\n        detail={DETAIL_FAILED}\n        selectedId={DETAIL_FAILED.id}\n      />,\n    );\n\n    expect(screen.getByText(\"failed\")).toBeInTheDocument();\n    expect(screen.getByText(`Event ${DETAIL_FAILED.id}`)).toBeInTheDocument();\n    expect(screen.getByText(\"3 / 5\")).toBeInTheDocument();\n    expect(screen.getByText(DETAIL_FAILED.createdAt)).toBeInTheDocument();\n    expect(screen.getByText(DETAIL_FAILED.scheduledAt)).toBeInTheDocument();\n\n    const userLink = screen.getByRole(\"link\", { name: \"user-9\" });\n    expect(userLink).toHaveAttribute(\"href\", \"/users/user-9\");\n  });\n\n  it(\"populated: error renders inside a <pre> block when present\", () => {\n    const { container } = render(\n      <EventQueueDetailPanel\n        detail={DETAIL_FAILED}\n        selectedId={DETAIL_FAILED.id}\n      />,\n    );\n    const pres = container.querySelectorAll(\"pre\");\n    expect(pres.length).toBeGreaterThanOrEqual(2);\n    const errorPre = Array.from(pres).find((node) =>\n      node.textContent?.includes(\"RpcError: connection refused\"),\n    );\n    expect(errorPre).not.toBeUndefined();\n  });\n\n  it(\"payload: JSON serialises with 2-space indent into a <pre> block\", () => {\n    const { container } = render(\n      <EventQueueDetailPanel\n        detail={DETAIL_FAILED}\n        selectedId={DETAIL_FAILED.id}\n      />,\n    );\n    const pres = container.querySelectorAll(\"pre\");\n    const expected = JSON.stringify(DETAIL_FAILED.payload, null, 2);\n    const payloadPre = Array.from(pres).find(\n      (node) => node.textContent === expected,\n    );\n    expect(payloadPre).not.toBeUndefined();\n  });\n\n  it(\"redacted-payload state: server-side redaction sentinels round-trip into both the error block and the payload JSON\", () => {\n    const { container } = render(\n      <EventQueueDetailPanel\n        detail={DETAIL_DEAD_REDACTED}\n        selectedId={DETAIL_DEAD_REDACTED.id}\n      />,\n    );\n    // The `error` field is rendered into a <pre> with the sentinel intact.\n    const pres = container.querySelectorAll(\"pre\");\n    expect(pres.length).toBeGreaterThanOrEqual(2);\n\n    const allPreText = Array.from(pres)\n      .map((p) => p.textContent ?? \"\")\n      .join(\"\\n\");\n    // Both the error and the payload render the redaction marker.\n    expect(allPreText).toContain(PEEK_AUDIT_REDACTED);\n\n    // The original secret never reaches the rendered output.\n    expect(allPreText).not.toContain(\"Bearer \");\n    expect(allPreText).not.toContain(\"eyJhbGciOi\");\n    expect(allPreText).not.toContain(\"postgres://\");\n  });\n\n  it(\"null error: renders '—' instead of an empty <pre>\", () => {\n    render(\n      <EventQueueDetailPanel\n        detail={DETAIL_PENDING_NULL_ERROR}\n        selectedId={DETAIL_PENDING_NULL_ERROR.id}\n      />,\n    );\n    // The Error (redacted) section heading appears...\n    expect(screen.getByText(/error \\(redacted\\)/i)).toBeInTheDocument();\n    // ...followed by a \"—\" placeholder when the error is null.\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(1);\n  });\n\n  it(\"read-only: renders no edit affordances (no buttons, no editable inputs, no checkboxes)\", () => {\n    // FR-10 line 342: retry / cancel / replay are out of scope. The detail\n    // panel is the highest-detail surface for queue events, so we explicitly\n    // assert it never renders a mutating control even when the operator is\n    // viewing a dead/failed row.\n    render(\n      <EventQueueDetailPanel\n        detail={DETAIL_DEAD_REDACTED}\n        selectedId={DETAIL_DEAD_REDACTED.id}\n      />,\n    );\n    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n    expect(screen.queryByRole(\"textbox\")).toBeNull();\n    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n  });\n\n  it(\"read-only notice: anchors the FR-10 line 342 out-of-scope statement\", () => {\n    render(\n      <EventQueueDetailPanel\n        detail={DETAIL_FAILED}\n        selectedId={DETAIL_FAILED.id}\n      />,\n    );\n    expect(\n      screen.getByText(\n        /retry, cancel, and replay actions are out of scope/i,\n      ),\n    ).toBeInTheDocument();\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
