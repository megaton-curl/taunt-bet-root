{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y8ZxCGVLYC8qh5WfotUqCi","type":"tool_result","content":"1\t// Event queue table for /operations/queue (FR-10).\n2\t//\n3\t// Read-only dense table over `PeekEventQueueListRow`. Status drives the chip\n4\t// tone (failed/dead = warning/negative — the FR-10 attention states). Each row\n5\t// links to the detail panel via `?selectedId=<id>` so the URL stays shareable\n6\t// and the detail panel renders alongside the table on the same route. Linked\n7\t// payload ids (userId, roundId, claimId) are surfaced inline so an operator\n8\t// can pivot directly into /users/[userId] or future /games/.../rounds/...\n9\t// pages without opening the JSONB.\n10\t//\n11\t// All queue mutations (retry / cancel / replay) are explicitly out of scope\n12\t// for this spec — no buttons or editable inputs are rendered.\n13\timport Link from \"next/link\";\n14\timport type { CSSProperties } from \"react\";\n15\timport type {\n16\t  PeekEventQueueListRow,\n17\t  PeekStatusTone,\n18\t} from \"../lib/types/peek\";\n19\timport { StatusChip } from \"./status-chip\";\n20\t\n21\texport type EventQueueTableProps = {\n22\t  rows: ReadonlyArray<PeekEventQueueListRow>;\n23\t  selectedId?: string | null;\n24\t  selectedIdHrefBuilder?: (row: PeekEventQueueListRow) => string;\n25\t  error?: string | null;\n26\t};\n27\t\n28\texport function EventQueueTable({\n29\t  rows,\n30\t  selectedId = null,\n31\t  selectedIdHrefBuilder,\n32\t  error = null,\n33\t}: EventQueueTableProps) {\n34\t  if (error) {\n35\t    return (\n36\t      <div role=\"alert\" style={errorStyle}>\n37\t        Event queue rows unavailable: {error}\n38\t      </div>\n39\t    );\n40\t  }\n41\t\n42\t  if (rows.length === 0) {\n43\t    return (\n44\t      <div role=\"status\" style={emptyStyle}>\n45\t        <p style={emptyTitleStyle}>\n46\t          No event_queue rows match these filters.\n47\t        </p>\n48\t        <p style={emptyBodyStyle}>\n49\t          Adjust the filters above or clear them to see pending, processing,\n50\t          completed, failed, and dead events.\n51\t        </p>\n52\t      </div>\n53\t    );\n54\t  }\n55\t\n56\t  const buildHref =\n57\t    selectedIdHrefBuilder ?? ((row) => `/operations/queue?selectedId=${encodeURIComponent(row.id)}`);\n58\t\n59\t  return (\n60\t    <div style={wrapperStyle}>\n61\t      <table style={tableStyle}>\n62\t        <thead>\n63\t          <tr style={headerRowStyle}>\n64\t            <th style={headerCellStyle(\"left\")}>Status</th>\n65\t            <th style={headerCellStyle(\"left\")}>Event type</th>\n66\t            <th style={headerCellStyle(\"right\")}>Attempts</th>\n67\t            <th style={headerCellStyle(\"left\")}>Created</th>\n68\t            <th style={headerCellStyle(\"left\")}>Scheduled</th>\n69\t            <th style={headerCellStyle(\"left\")}>Started</th>\n70\t            <th style={headerCellStyle(\"left\")}>Completed</th>\n71\t            <th style={headerCellStyle(\"left\")}>Linked</th>\n72\t            <th style={headerCellStyle(\"left\")}>Error</th>\n73\t            <th style={headerCellStyle(\"left\")}>ID</th>\n74\t          </tr>\n75\t        </thead>\n76\t        <tbody>\n77\t          {rows.map((row) => {\n78\t            const isSelected = selectedId === row.id;\n79\t            const detailHref = buildHref(row);\n80\t            return (\n81\t              <tr\n82\t                key={row.id}\n83\t                aria-current={isSelected ? \"true\" : undefined}\n84\t                style={isSelected ? selectedRowStyle : bodyRowStyle}\n85\t              >\n86\t                <td style={bodyCellStyle(\"left\")}>\n87\t                  <StatusChip\n88\t                    label={row.status}\n89\t                    tone={queueStatusTone(row.status)}\n90\t                  />\n91\t                </td>\n92\t                <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n93\t                  {row.eventType}\n94\t                </td>\n95\t                <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n96\t                  {row.attempts.toLocaleString(\"en-US\")} /{\" \"}\n97\t                  {row.maxAttempts.toLocaleString(\"en-US\")}\n98\t                </td>\n99\t                <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n100\t                <td style={bodyCellStyle(\"left\")}>{row.scheduledAt}</td>\n101\t                <td style={bodyCellStyle(\"left\")}>{row.startedAt ?? \"—\"}</td>\n102\t                <td style={bodyCellStyle(\"left\")}>{row.completedAt ?? \"—\"}</td>\n103\t                <td style={bodyCellStyle(\"left\")}>\n104\t                  {renderLinked(row)}\n105\t                </td>\n106\t                <td style={{ ...bodyCellStyle(\"left\"), maxWidth: \"20rem\" }}>\n107\t                  {row.errorPreview ? (\n108\t                    <span style={errorPreviewStyle}>{row.errorPreview}</span>\n109\t                  ) : (\n110\t                    \"—\"\n111\t                  )}\n112\t                </td>\n113\t                <td style={bodyCellStyle(\"left\")}>\n114\t                  <Link\n115\t                    href={detailHref}\n116\t                    aria-label={`Open detail for event ${row.id}`}\n117\t                    style={detailLinkStyle}\n118\t                  >\n119\t                    {row.id}\n120\t                  </Link>\n121\t                </td>\n122\t              </tr>\n123\t            );\n124\t          })}\n125\t        </tbody>\n126\t      </table>\n127\t    </div>\n128\t  );\n129\t}\n130\t\n131\tfunction renderLinked(row: PeekEventQueueListRow) {\n132\t  const { userId, roundId, claimId } = row.linked;\n133\t  if (!userId && !roundId && !claimId) return <span>—</span>;\n134\t  return (\n135\t    <div style={linkedStyle}>\n136\t      {userId ? (\n137\t        <Link\n138\t          href={`/users/${encodeURIComponent(userId)}`}\n139\t          style={linkedLinkStyle}\n140\t        >\n141\t          user {userId}\n142\t        </Link>\n143\t      ) : null}\n144\t      {roundId ? (\n145\t        <span style={linkedTokenStyle}>round {roundId}</span>\n146\t      ) : null}\n147\t      {claimId ? (\n148\t        <span style={linkedTokenStyle}>claim {claimId}</span>\n149\t      ) : null}\n150\t    </div>\n151\t  );\n152\t}\n153\t\n154\texport function queueStatusTone(value: string): PeekStatusTone {\n155\t  if (value === \"completed\") return \"positive\";\n156\t  if (value === \"processing\") return \"info\";\n157\t  if (value === \"pending\") return \"neutral\";\n158\t  if (value === \"failed\") return \"warning\";\n159\t  if (value === \"dead\") return \"negative\";\n160\t  return \"neutral\";\n161\t}\n162\t\n163\tconst wrapperStyle: CSSProperties = {\n164\t  overflowX: \"auto\",\n165\t  border: \"1px solid #1e293b\",\n166\t  borderRadius: \"0.75rem\",\n167\t};\n168\t\n169\tconst tableStyle: CSSProperties = {\n170\t  width: \"100%\",\n171\t  borderCollapse: \"collapse\",\n172\t};\n173\t\n174\tconst headerRowStyle: CSSProperties = {\n175\t  background: \"#111827\",\n176\t  color: \"#94a3b8\",\n177\t};\n178\t\n179\tconst bodyRowStyle: CSSProperties = {\n180\t  borderTop: \"1px solid #1e293b\",\n181\t};\n182\t\n183\tconst selectedRowStyle: CSSProperties = {\n184\t  ...bodyRowStyle,\n185\t  background: \"#172554\",\n186\t};\n187\t\n188\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n189\t  return {\n190\t    padding: \"0.75rem\",\n191\t    textAlign: align,\n192\t    fontSize: \"0.875rem\",\n193\t    fontWeight: 600,\n194\t  };\n195\t}\n196\t\n197\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n198\t  return {\n199\t    padding: \"0.75rem\",\n200\t    textAlign: align,\n201\t    fontSize: \"0.875rem\",\n202\t    color: \"#e2e8f0\",\n203\t    verticalAlign: \"top\",\n204\t  };\n205\t}\n206\t\n207\tconst errorPreviewStyle: CSSProperties = {\n208\t  display: \"block\",\n209\t  whiteSpace: \"pre-wrap\",\n210\t  wordBreak: \"break-word\",\n211\t  color: \"#fecaca\",\n212\t  fontFamily: \"monospace\",\n213\t  fontSize: \"0.75rem\",\n214\t};\n215\t\n216\tconst linkedStyle: CSSProperties = {\n217\t  display: \"grid\",\n218\t  gap: \"0.25rem\",\n219\t};\n220\t\n221\tconst linkedLinkStyle: CSSProperties = {\n222\t  fontFamily: \"monospace\",\n223\t  fontSize: \"0.75rem\",\n224\t  color: \"#93c5fd\",\n225\t  textDecoration: \"none\",\n226\t};\n227\t\n228\tconst linkedTokenStyle: CSSProperties = {\n229\t  fontFamily: \"monospace\",\n230\t  fontSize: \"0.75rem\",\n231\t  color: \"#cbd5f5\",\n232\t};\n233\t\n234\tconst detailLinkStyle: CSSProperties = {\n235\t  fontFamily: \"monospace\",\n236\t  fontSize: \"0.75rem\",\n237\t  color: \"#93c5fd\",\n238\t  textDecoration: \"none\",\n239\t};\n240\t\n241\tconst errorStyle: CSSProperties = {\n242\t  margin: 0,\n243\t  padding: \"0.75rem 1rem\",\n244\t  borderRadius: \"0.75rem\",\n245\t  background: \"#3f1d1d\",\n246\t  color: \"#fecaca\",\n247\t};\n248\t\n249\tconst emptyStyle: CSSProperties = {\n250\t  padding: \"1.5rem\",\n251\t  borderRadius: \"0.75rem\",\n252\t  border: \"1px dashed #334155\",\n253\t  background: \"#0b1220\",\n254\t  color: \"#cbd5f5\",\n255\t  display: \"grid\",\n256\t  gap: \"0.5rem\",\n257\t};\n258\t\n259\tconst emptyTitleStyle: CSSProperties = {\n260\t  margin: 0,\n261\t  fontSize: \"1rem\",\n262\t  fontWeight: 600,\n263\t};\n264\t\n265\tconst emptyBodyStyle: CSSProperties = {\n266\t  margin: 0,\n267\t  fontSize: \"0.875rem\",\n268\t  color: \"#94a3b8\",\n269\t};\n270\t"}]},"parent_tool_use_id":null,"session_id":"031ce74d-15ee-4888-a00b-e081672f539b","uuid":"dccbc5eb-74d0-4613-a4ed-34859e671beb","timestamp":"2026-04-26T07:00:35.076Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/event-queue-table.tsx","content":"// Event queue table for /operations/queue (FR-10).\n//\n// Read-only dense table over `PeekEventQueueListRow`. Status drives the chip\n// tone (failed/dead = warning/negative — the FR-10 attention states). Each row\n// links to the detail panel via `?selectedId=<id>` so the URL stays shareable\n// and the detail panel renders alongside the table on the same route. Linked\n// payload ids (userId, roundId, claimId) are surfaced inline so an operator\n// can pivot directly into /users/[userId] or future /games/.../rounds/...\n// pages without opening the JSONB.\n//\n// All queue mutations (retry / cancel / replay) are explicitly out of scope\n// for this spec — no buttons or editable inputs are rendered.\nimport Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekEventQueueListRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type EventQueueTableProps = {\n  rows: ReadonlyArray<PeekEventQueueListRow>;\n  selectedId?: string | null;\n  selectedIdHrefBuilder?: (row: PeekEventQueueListRow) => string;\n  error?: string | null;\n};\n\nexport function EventQueueTable({\n  rows,\n  selectedId = null,\n  selectedIdHrefBuilder,\n  error = null,\n}: EventQueueTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Event queue rows unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>\n          No event_queue rows match these filters.\n        </p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see pending, processing,\n          completed, failed, and dead events.\n        </p>\n      </div>\n    );\n  }\n\n  const buildHref =\n    selectedIdHrefBuilder ?? ((row) => `/operations/queue?selectedId=${encodeURIComponent(row.id)}`);\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Status</th>\n            <th style={headerCellStyle(\"left\")}>Event type</th>\n            <th style={headerCellStyle(\"right\")}>Attempts</th>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>Scheduled</th>\n            <th style={headerCellStyle(\"left\")}>Started</th>\n            <th style={headerCellStyle(\"left\")}>Completed</th>\n            <th style={headerCellStyle(\"left\")}>Linked</th>\n            <th style={headerCellStyle(\"left\")}>Error</th>\n            <th style={headerCellStyle(\"left\")}>ID</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => {\n            const isSelected = selectedId === row.id;\n            const detailHref = buildHref(row);\n            return (\n              <tr\n                key={row.id}\n                aria-current={isSelected ? \"true\" : undefined}\n                style={isSelected ? selectedRowStyle : bodyRowStyle}\n              >\n                <td style={bodyCellStyle(\"left\")}>\n                  <StatusChip\n                    label={row.status}\n                    tone={queueStatusTone(row.status)}\n                  />\n                </td>\n                <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                  {row.eventType}\n                </td>\n                <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                  {row.attempts.toLocaleString(\"en-US\")} /{\" \"}\n                  {row.maxAttempts.toLocaleString(\"en-US\")}\n                </td>\n                <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n                <td style={bodyCellStyle(\"left\")}>{row.scheduledAt}</td>\n                <td style={bodyCellStyle(\"left\")}>{row.startedAt ?? \"—\"}</td>\n                <td style={bodyCellStyle(\"left\")}>{row.completedAt ?? \"—\"}</td>\n                <td style={bodyCellStyle(\"left\")}>\n                  {renderLinked(row)}\n                </td>\n                <td style={{ ...bodyCellStyle(\"left\"), maxWidth: \"20rem\" }}>\n                  {row.errorPreview ? (\n                    <span style={errorPreviewStyle}>{row.errorPreview}</span>\n                  ) : (\n                    \"—\"\n                  )}\n                </td>\n                <td style={bodyCellStyle(\"left\")}>\n                  <Link\n                    href={detailHref}\n                    aria-label={`Open detail for event ${row.id}`}\n                    style={detailLinkStyle}\n                  >\n                    {row.id}\n                  </Link>\n                </td>\n              </tr>\n            );\n          })}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction renderLinked(row: PeekEventQueueListRow) {\n  const { userId, roundId, claimId } = row.linked;\n  if (!userId && !roundId && !claimId) return <span>—</span>;\n  return (\n    <div style={linkedStyle}>\n      {userId ? (\n        <Link\n          href={`/users/${encodeURIComponent(userId)}`}\n          style={linkedLinkStyle}\n        >\n          user {userId}\n        </Link>\n      ) : null}\n      {roundId ? (\n        <span style={linkedTokenStyle}>round {roundId}</span>\n      ) : null}\n      {claimId ? (\n        <span style={linkedTokenStyle}>claim {claimId}</span>\n      ) : null}\n    </div>\n  );\n}\n\nexport function queueStatusTone(value: string): PeekStatusTone {\n  if (value === \"completed\") return \"positive\";\n  if (value === \"processing\") return \"info\";\n  if (value === \"pending\") return \"neutral\";\n  if (value === \"failed\") return \"warning\";\n  if (value === \"dead\") return \"negative\";\n  return \"neutral\";\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst selectedRowStyle: CSSProperties = {\n  ...bodyRowStyle,\n  background: \"#172554\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorPreviewStyle: CSSProperties = {\n  display: \"block\",\n  whiteSpace: \"pre-wrap\",\n  wordBreak: \"break-word\",\n  color: \"#fecaca\",\n  fontFamily: \"monospace\",\n  fontSize: \"0.75rem\",\n};\n\nconst linkedStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst linkedLinkStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  fontSize: \"0.75rem\",\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst linkedTokenStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  fontSize: \"0.75rem\",\n  color: \"#cbd5f5\",\n};\n\nconst detailLinkStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  fontSize: \"0.75rem\",\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":270,"startLine":1,"totalLines":270}}}
