{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_016PADimTtQZZqKHTkye3Qfm","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01LdNaoV4RURyMpxsrWCbQJA","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-event-queue.test.ts","content":"// Query tests for the FR-10 event-queue admin reads (`get-event-queue.ts`).\n//\n// Backs `/operations/queue`. The spec line driving these tests is:\n// \"Queue query + page tests for pending, failed, dead, aged, filtered,\n// redacted-payload states.\" Each case asserts:\n//   - state-transition coverage (pending / processing / failed / dead);\n//   - bounded SQL (limit clamps);\n//   - filter binding into the right slot of the (`null` ? \"\" : value) toggle;\n//   - age-bucket window application;\n//   - secret redaction at every surfacing path (`error`, `payload`, linked ids).\n//\n// Mirrors the SQL-mock pattern used in `get-points-and-crates.test.ts`,\n// `get-dogpile-and-fraud.test.ts`, and `get-rewards.test.ts`: a tagged-template\n// stub records each call (joined SQL text + bound values) and dequeues a\n// per-call response so each test can assert which SQL fired, in what order,\n// and with which clamps.\n//\n// Read-only guarantee: every queue mutation (retry / cancel / replay) is\n// explicitly out of scope for spec 305 (FR-10 line 342). These tests keep the\n// queries SELECT-only so a future regression cannot silently introduce a\n// queue write.\n\nimport { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_EVENT_QUEUE_AGED_PENDING_HOURS,\n  PEEK_EVENT_QUEUE_DEFAULT_LIMIT,\n  PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS,\n  PEEK_EVENT_QUEUE_MAX_LIMIT,\n  PEEK_EVENT_QUEUE_TYPE_COUNT_LIMIT,\n  getEventQueueDetail,\n  getEventQueueOverview,\n  listEventQueue,\n} from \"../get-event-queue\";\nimport {\n  PEEK_AUDIT_REDACTED,\n  PEEK_EVENT_QUEUE_AGE_BUCKETS,\n  PEEK_EVENT_QUEUE_OVERVIEW_METRIC_IDS,\n  PEEK_EVENT_QUEUE_STATUSES,\n} from \"../../../../lib/types/peek\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\nfunction expectReadOnly(call: SqlCall) {\n  expect(call.text).not.toMatch(/\\binsert\\s+into\\b/i);\n  expect(call.text).not.toMatch(/\\bupdate\\s+\\w/i);\n  expect(call.text).not.toMatch(/\\bdelete\\s+from\\b/i);\n  expect(call.text).toMatch(/\\bselect\\b/i);\n}\n\ndescribe(\"listEventQueue\", () => {\n  it(\"default: clamps to PEEK_EVENT_QUEUE_DEFAULT_LIMIT and reads from event_queue with the right column projection\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expectReadOnly(call);\n    expect(call.text).toMatch(/from event_queue eq/i);\n    // Linked-id projection mirrors the spec line \"linked user/round/claim\n    // routes when identifiers are present\" (FR-10).\n    expect(call.text).toMatch(/eq\\.payload->>'userId'/);\n    expect(call.text).toMatch(/eq\\.payload->>'roundId'/);\n    expect(call.text).toMatch(/eq\\.payload->>'claimId'/);\n    expect(call.text).toMatch(/order by eq\\.created_at desc, eq\\.id desc/i);\n    expect(call.values).toContain(PEEK_EVENT_QUEUE_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      limit: PEEK_EVENT_QUEUE_MAX_LIMIT + 100,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_EVENT_QUEUE_MAX_LIMIT);\n  });\n\n  it(\"non-positive limit clamps to 1\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({ sql: mock.sql, limit: 0 });\n    expect(mock.calls[0].values).toContain(1);\n  });\n\n  it(\"non-finite limit falls back to the default\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({ sql: mock.sql, limit: Number.NaN });\n    expect(mock.calls[0].values).toContain(PEEK_EVENT_QUEUE_DEFAULT_LIMIT);\n  });\n\n  it(\"filters: empty filters bind null sentinels so every where-clause toggle is true\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({ sql: mock.sql, filters: {} });\n\n    // 9 togglable predicates (status / event type / id / payload user id /\n    // scheduled[from,to) / created[from,to) / age max / age min). Each\n    // predicate uses (${X === null} or eq.<col> = ${X ?? \"\"}) so an \"all-null\"\n    // input binds 9 `true` sentinels.\n    const trueBinds = mock.calls[0].values.filter((v) => v === true).length;\n    expect(trueBinds).toBeGreaterThanOrEqual(9);\n  });\n\n  it(\"filters: status='dead' binds the value verbatim and toggles the predicate on\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: { status: \"dead\" },\n    });\n\n    const values = mock.calls[0].values;\n    expect(values).toContain(\"dead\");\n    // status=dead disables the (${null}) escape hatch → at least one `false`\n    // sentinel reaches the bound values.\n    expect(values).toContain(false);\n  });\n\n  it(\"filters: state-transition coverage — every status enum binds verbatim\", async () => {\n    for (const status of PEEK_EVENT_QUEUE_STATUSES) {\n      const mock = createSqlMock([[]]);\n      await listEventQueue({ sql: mock.sql, filters: { status } });\n      expect(mock.calls[0].values).toContain(status);\n    }\n  });\n\n  it(\"filters: status='pending' binds verbatim — drives the queue.pending drilldown\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({ sql: mock.sql, filters: { status: \"pending\" } });\n    expect(mock.calls[0].values).toContain(\"pending\");\n  });\n\n  it(\"filters: status='failed' binds verbatim — drives the FR-10 attention link\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({ sql: mock.sql, filters: { status: \"failed\" } });\n    expect(mock.calls[0].values).toContain(\"failed\");\n  });\n\n  it(\"filters: payloadUserId reads through eq.payload->>'userId' and binds verbatim\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: { payloadUserId: \"user-9\" },\n    });\n    expect(mock.calls[0].text).toMatch(/eq\\.payload->>'userId' = /);\n    expect(mock.calls[0].values).toContain(\"user-9\");\n  });\n\n  it(\"filters: every supported filter (status, eventType, id, payloadUserId, scheduledFrom, scheduledTo, createdFrom, createdTo) flows into the bound values\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: {\n        status: \"failed\",\n        eventType: \"points.grant\",\n        id: \"11111111-1111-1111-1111-111111111111\",\n        payloadUserId: \"user-9\",\n        scheduledFrom: \"2026-04-01T00:00:00.000Z\",\n        scheduledTo: \"2026-04-26T00:00:00.000Z\",\n        createdFrom: \"2026-04-01T00:00:00.000Z\",\n        createdTo: \"2026-04-26T00:00:00.000Z\",\n      },\n    });\n\n    const values = mock.calls[0].values;\n    expect(values).toContain(\"failed\");\n    expect(values).toContain(\"points.grant\");\n    expect(values).toContain(\"11111111-1111-1111-1111-111111111111\");\n    expect(values).toContain(\"user-9\");\n    expect(values).toContain(\"2026-04-01T00:00:00.000Z\");\n    expect(values).toContain(\"2026-04-26T00:00:00.000Z\");\n    // Date filters cast through ::timestamptz so the SQL keeps tz-correct\n    // half-open windows.\n    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n  });\n\n  it(\"filters: whitespace-only filter values normalize to null (toggle stays true)\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: { status: \"   \", eventType: \"\" },\n    });\n\n    // Both filters become null → both toggles become true and neither\n    // value sneaks through.\n    expect(mock.calls[0].values).not.toContain(\"   \");\n  });\n\n  it(\"filters: age bucket lt_1h applies an upper bound on created_at via the `now - 0h` boundary\", async () => {\n    const now = new Date(\"2026-04-26T12:00:00.000Z\");\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: { ageBucket: \"lt_1h\" },\n      now,\n    });\n\n    // The `lt_1h` bucket is [0h, 1h): older-than = now - 0h, younger-than =\n    // now - 1h. The query binds both ISO strings into the timestamptz\n    // comparisons.\n    const values = mock.calls[0].values;\n    expect(values).toContain(now.toISOString());\n    const oneHourAgo = new Date(now.getTime() - 60 * 60 * 1000).toISOString();\n    expect(values).toContain(oneHourAgo);\n  });\n\n  it(\"filters: age bucket gte_7d uses the open-ended last bucket — no younger bound\", async () => {\n    const now = new Date(\"2026-04-26T12:00:00.000Z\");\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: { ageBucket: \"gte_7d\" },\n      now,\n    });\n\n    const values = mock.calls[0].values;\n    const sevenDaysAgo = new Date(\n      now.getTime() - 7 * 24 * 60 * 60 * 1000,\n    ).toISOString();\n    expect(values).toContain(sevenDaysAgo);\n    // The min-side toggle (`ageHasMin`) binds `false` for the open-ended\n    // bucket — confirms the predicate is skipped.\n    expect(values).toContain(false);\n  });\n\n  it(\"filters: unknown age bucket id falls back to null (no age window applied)\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: { ageBucket: \"yesterday\" },\n    });\n\n    // Both age-window toggles bind `true` (the predicate is skipped) and\n    // neither boundary ISO string appears in the values.\n    const trueBinds = mock.calls[0].values.filter((v) => v === true).length;\n    expect(trueBinds).toBeGreaterThanOrEqual(9);\n  });\n\n  it(\"populated: row mapping projects the migration columns and surfaces an error preview\", async () => {\n    const row = {\n      id: \"11111111-1111-1111-1111-111111111111\",\n      eventType: \"points.grant\",\n      status: \"failed\",\n      attempts: 3,\n      maxAttempts: 5,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: \"2026-04-26T10:01:00.000Z\",\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: \"RpcError: connection refused\",\n      userId: \"user-9\",\n      roundId: \"round-3\",\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n\n    const rows = await listEventQueue({ sql: mock.sql });\n    expect(rows).toHaveLength(1);\n    expect(rows[0].status).toBe(\"failed\");\n    expect(rows[0].attempts).toBe(3);\n    expect(rows[0].maxAttempts).toBe(5);\n    expect(rows[0].errorPreview).toBe(\"RpcError: connection refused\");\n    expect(rows[0].linked).toEqual({\n      userId: \"user-9\",\n      roundId: \"round-3\",\n      claimId: null,\n    });\n  });\n\n  it(\"populated: stringified attempts/maxAttempts coerce to integers via readInt\", async () => {\n    const row = {\n      id: \"abc\",\n      eventType: \"points.grant\",\n      status: \"failed\",\n      attempts: \"7\",\n      maxAttempts: \"10\",\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: null,\n      userId: null,\n      roundId: null,\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listEventQueue({ sql: mock.sql });\n    expect(rows[0].attempts).toBe(7);\n    expect(rows[0].maxAttempts).toBe(10);\n  });\n\n  it(\"populated: an oversized error string is truncated with an ellipsis at PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS\", async () => {\n    const big = \"x\".repeat(PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS + 50);\n    const row = {\n      id: \"abc\",\n      eventType: \"points.grant\",\n      status: \"dead\",\n      attempts: 5,\n      maxAttempts: 5,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: big,\n      userId: null,\n      roundId: null,\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listEventQueue({ sql: mock.sql });\n    expect(rows[0].errorPreview).not.toBeNull();\n    expect(rows[0].errorPreview?.length).toBe(\n      PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS + 1, // \"+1\" for the trailing ellipsis\n    );\n    expect(rows[0].errorPreview?.endsWith(\"…\")).toBe(true);\n  });\n\n  it(\"redaction: an error string that looks like a JWT is replaced with PEEK_AUDIT_REDACTED in the preview\", async () => {\n    const jwt =\n      \"eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ1c2VyLTkifQ.signature_segment\";\n    const row = {\n      id: \"abc\",\n      eventType: \"auth.callback\",\n      status: \"failed\",\n      attempts: 1,\n      maxAttempts: 3,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: jwt,\n      userId: null,\n      roundId: null,\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listEventQueue({ sql: mock.sql });\n    expect(rows[0].errorPreview).toBe(PEEK_AUDIT_REDACTED);\n    // The original secret never reaches the surface.\n    expect(rows[0].errorPreview).not.toContain(\"eyJ\");\n  });\n\n  it(\"redaction: a payload-derived linked id that looks like a postgres URL is redacted\", async () => {\n    // Pathological input: a queue worker accidentally serialised a connection\n    // string into payload.userId. The list-row should redact it before the\n    // row leaves the server.\n    const row = {\n      id: \"abc\",\n      eventType: \"points.grant\",\n      status: \"pending\",\n      attempts: 0,\n      maxAttempts: 5,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: null,\n      userId: \"postgres://user:pass@host:5432/db\",\n      roundId: null,\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listEventQueue({ sql: mock.sql });\n    expect(rows[0].linked.userId).toBe(PEEK_AUDIT_REDACTED);\n    expect(rows[0].linked.userId).not.toContain(\"postgres://\");\n  });\n\n  it(\"sparse: an empty result set returns []\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listEventQueue({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"connection refused\")]);\n    await expect(listEventQueue({ sql: mock.sql })).rejects.toThrowError(\n      \"connection refused\",\n    );\n  });\n});\n\ndescribe(\"getEventQueueDetail\", () => {\n  it(\"returns null when id is missing\", async () => {\n    const mock = createSqlMock([]);\n    const detail = await getEventQueueDetail({ sql: mock.sql, id: \"\" });\n    expect(detail).toBeNull();\n    // No SQL fired — the early return short-circuits before the lookup.\n    expect(mock.calls).toHaveLength(0);\n  });\n\n  it(\"returns null when the row is not found\", async () => {\n    const mock = createSqlMock([[]]);\n    const detail = await getEventQueueDetail({ sql: mock.sql, id: \"missing\" });\n    expect(detail).toBeNull();\n  });\n\n  it(\"populated: passes through the columns and applies redactJsonValue / redactNullableString\", async () => {\n    const payload = {\n      userId: \"user-9\",\n      claimAmount: \"5000000\",\n      // A nested string that looks like a Bearer token must round-trip as the\n      // PEEK_AUDIT_REDACTED marker.\n      authHeader: \"Bearer abcdefgh1234567890\",\n    };\n    const row = {\n      id: \"11111111-1111-1111-1111-111111111111\",\n      eventType: \"claims.process\",\n      status: \"failed\",\n      attempts: 2,\n      maxAttempts: 5,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: \"RpcError: connection refused\",\n      payload,\n      userId: \"user-9\",\n      roundId: null,\n      claimId: \"claim-3\",\n    };\n    const mock = createSqlMock([[row]]);\n    const detail = await getEventQueueDetail({\n      sql: mock.sql,\n      id: \"11111111-1111-1111-1111-111111111111\",\n    });\n    expect(detail).not.toBeNull();\n    expect(detail?.id).toBe(\"11111111-1111-1111-1111-111111111111\");\n    expect(detail?.error).toBe(\"RpcError: connection refused\");\n    expect(detail?.linked).toEqual({\n      userId: \"user-9\",\n      roundId: null,\n      claimId: \"claim-3\",\n    });\n    // The Bearer token in the JSONB payload is redacted recursively.\n    const redactedPayload = detail?.payload as Record<string, unknown>;\n    expect(redactedPayload.authHeader).toBe(PEEK_AUDIT_REDACTED);\n    // Non-secret keys round-trip verbatim.\n    expect(redactedPayload.userId).toBe(\"user-9\");\n    expect(redactedPayload.claimAmount).toBe(\"5000000\");\n  });\n\n  it(\"redaction: a bare error string that looks like a DB URL is redacted (the audit redactor swaps the value)\", async () => {\n    const row = {\n      id: \"abc\",\n      eventType: \"claims.process\",\n      status: \"failed\",\n      attempts: 2,\n      maxAttempts: 5,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: \"fatal: postgres://user:secret@host:5432/db unreachable\",\n      payload: null,\n      userId: null,\n      roundId: null,\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const detail = await getEventQueueDetail({ sql: mock.sql, id: \"abc\" });\n    expect(detail?.error).toBe(PEEK_AUDIT_REDACTED);\n    // The original credential never reaches the operator UI.\n    expect(detail?.error).not.toContain(\"secret\");\n  });\n\n  it(\"redaction: cycles in the JSONB payload are guarded — no infinite loop\", async () => {\n    type Cyc = { a: number; self?: unknown };\n    const cyclic: Cyc = { a: 1 };\n    cyclic.self = cyclic;\n\n    const row = {\n      id: \"abc\",\n      eventType: \"claims.process\",\n      status: \"failed\",\n      attempts: 2,\n      maxAttempts: 5,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: null,\n      payload: cyclic,\n      userId: null,\n      roundId: null,\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const detail = await getEventQueueDetail({ sql: mock.sql, id: \"abc\" });\n    const redacted = detail?.payload as Record<string, unknown>;\n    expect(redacted.a).toBe(1);\n    // The cycle is broken with the redacted sentinel rather than crashing\n    // the renderer.\n    expect(redacted.self).toBe(PEEK_AUDIT_REDACTED);\n  });\n});\n\ndescribe(\"getEventQueueOverview\", () => {\n  // Eager-built SQL templates: the .map() callback in\n  // get-event-queue.ts runs before Promise.all, so the 5 age-bucket queries\n  // dispatch FIRST (one per PEEK_EVENT_QUEUE_AGE_BUCKETS entry), then the four\n  // status / type / at_max / aged_pending queries dispatch as the\n  // Promise.all() argument array is built. The mock cursor advances in that\n  // exact order, so per-call responses must follow the same shape.\n  const ageBucketResponses = PEEK_EVENT_QUEUE_AGE_BUCKETS.map(\n    () => [{ value: 0 }] as const,\n  );\n\n  it(\"metric strip exposes every PeekEventQueueOverviewMetricId in order\", async () => {\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      [], // status rows\n      [], // type rows\n      [{ value: 0 }], // at_max\n      [{ value: 0 }], // aged_pending\n    ];\n    const mock = createSqlMock(responses);\n    const now = new Date(\"2026-04-26T12:00:00.000Z\");\n    const overview = await getEventQueueOverview({ sql: mock.sql, now });\n\n    expect(overview.metrics.map((m) => m.id)).toEqual(\n      PEEK_EVENT_QUEUE_OVERVIEW_METRIC_IDS,\n    );\n    // Every metric carries the FR-4 metadata.\n    for (const metric of overview.metrics) {\n      expect(metric.label.length).toBeGreaterThan(0);\n      expect(metric.source).toBe(\"event_queue\");\n      expect(metric.freshness).toBe(\"live\");\n      expect(metric.asOf).toBe(now.toISOString());\n      expect(metric.definition.length).toBeGreaterThan(0);\n    }\n    expect(overview.generatedAt).toBe(now.toISOString());\n  });\n\n  it(\"status counts: missing migration values still appear as 0 rows so an absent state is visible\", async () => {\n    // The status query returns only `pending` — the four other statuses must\n    // still appear with count: 0.\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      [{ status: \"pending\", value: 7 }],\n      [],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ];\n    const mock = createSqlMock(responses);\n    const overview = await getEventQueueOverview({ sql: mock.sql });\n\n    const lookup = new Map(\n      overview.statusCounts.map((s) => [s.status, s.count] as const),\n    );\n    expect(lookup.get(\"pending\")).toBe(7);\n    expect(lookup.get(\"processing\")).toBe(0);\n    expect(lookup.get(\"failed\")).toBe(0);\n    expect(lookup.get(\"dead\")).toBe(0);\n    expect(lookup.get(\"completed\")).toBe(0);\n    // The full migration set is projected so the operator never sees a\n    // missing row.\n    expect(overview.statusCounts.map((s) => s.status)).toEqual(\n      PEEK_EVENT_QUEUE_STATUSES,\n    );\n  });\n\n  it(\"status counts: pending / processing / failed / dead all round-trip into the metric strip\", async () => {\n    const statusResponse = [\n      { status: \"pending\", value: 1 },\n      { status: \"processing\", value: 2 },\n      { status: \"failed\", value: 3 },\n      { status: \"dead\", value: 4 },\n      { status: \"completed\", value: 5 },\n    ];\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      statusResponse,\n      [],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ];\n    const mock = createSqlMock(responses);\n    const overview = await getEventQueueOverview({ sql: mock.sql });\n\n    const m = new Map(overview.metrics.map((m) => [m.id, m] as const));\n    expect(m.get(\"queue.pending\")?.value).toBe(1);\n    expect(m.get(\"queue.processing\")?.value).toBe(2);\n    expect(m.get(\"queue.failed\")?.value).toBe(3);\n    expect(m.get(\"queue.dead\")?.value).toBe(4);\n    expect(m.get(\"queue.failed\")?.valueDisplay).toBe(\"3\");\n    // Failed and dead drilldowns are the FR-10 attention links.\n    expect(m.get(\"queue.failed\")?.drilldownHref).toBe(\n      \"/operations/queue?status=failed\",\n    );\n    expect(m.get(\"queue.dead\")?.drilldownHref).toBe(\n      \"/operations/queue?status=dead\",\n    );\n  });\n\n  it(\"type counts: bound by typeCountLimit (top 50 by count) — caller-passed values pass through clampLimit\", async () => {\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      [],\n      [{ eventType: \"points.grant\", value: 100 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ];\n    const mock = createSqlMock(responses);\n    await getEventQueueOverview({ sql: mock.sql });\n\n    // The type-count call (after the 5 age-bucket queries → index 6 = 0-indexed `5+1=6` → `mock.calls[6]`) must contain the type-count limit value.\n    const typeCountCall = mock.calls[6];\n    expect(typeCountCall.text).toMatch(/group by eq\\.event_type/i);\n    expect(typeCountCall.text).toMatch(/order by count\\(\\*\\) desc/i);\n    expect(typeCountCall.values).toContain(PEEK_EVENT_QUEUE_TYPE_COUNT_LIMIT);\n  });\n\n  it(\"aged-pending: defaults to PEEK_EVENT_QUEUE_AGED_PENDING_HOURS hours ago\", async () => {\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      [],\n      [],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ];\n    const mock = createSqlMock(responses);\n    const now = new Date(\"2026-04-26T12:00:00.000Z\");\n    await getEventQueueOverview({ sql: mock.sql, now });\n\n    const expected = new Date(\n      now.getTime() - PEEK_EVENT_QUEUE_AGED_PENDING_HOURS * 60 * 60 * 1000,\n    ).toISOString();\n    // Aged-pending is the 9th call (index 8): 5 buckets + status + type + atMax + agedPending.\n    const agedCall = mock.calls[8];\n    expect(agedCall.text).toMatch(/where eq\\.status = /i);\n    expect(agedCall.text).toMatch(/eq\\.created_at <=/i);\n    expect(agedCall.values).toContain(expected);\n  });\n\n  it(\"aged-pending: caller-supplied hours flows through, label updates\", async () => {\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      [],\n      [],\n      [{ value: 0 }],\n      [{ value: 12 }],\n    ];\n    const mock = createSqlMock(responses);\n    const now = new Date(\"2026-04-26T12:00:00.000Z\");\n    const overview = await getEventQueueOverview({\n      sql: mock.sql,\n      now,\n      agedPendingHours: 48,\n    });\n\n    const aged = overview.metrics.find((m) => m.id === \"queue.aged_pending\");\n    expect(aged?.windowLabel).toBe(\"Pending for ≥ 48h\");\n    expect(aged?.value).toBe(12);\n    const expected = new Date(\n      now.getTime() - 48 * 60 * 60 * 1000,\n    ).toISOString();\n    expect(mock.calls[8].values).toContain(expected);\n  });\n\n  it(\"at_max_attempts: filters attempts >= max_attempts on the non-completed lifecycle states\", async () => {\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      [],\n      [],\n      [{ value: 9 }],\n      [{ value: 0 }],\n    ];\n    const mock = createSqlMock(responses);\n    const overview = await getEventQueueOverview({ sql: mock.sql });\n\n    // at_max is the 8th call (index 7): 5 buckets + status + type + atMax.\n    const atMaxCall = mock.calls[7];\n    expect(atMaxCall.text).toMatch(\n      /eq\\.status in \\('pending', 'processing', 'failed', 'dead'\\)/i,\n    );\n    expect(atMaxCall.text).toMatch(/eq\\.attempts >= eq\\.max_attempts/i);\n    const atMax = overview.metrics.find((m) => m.id === \"queue.at_max_attempts\");\n    expect(atMax?.value).toBe(9);\n  });\n\n  it(\"age buckets: every PEEK_EVENT_QUEUE_AGE_BUCKETS entry is queried with its half-open boundary\", async () => {\n    // Each age bucket → one count(*) query. The first 5 mock calls correspond\n    // to the buckets in PEEK_EVENT_QUEUE_AGE_BUCKETS order.\n    const counts = [11, 22, 33, 44, 55];\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...counts.map((c) => [{ value: c }]),\n      [],\n      [],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ];\n    const mock = createSqlMock(responses);\n    const overview = await getEventQueueOverview({ sql: mock.sql });\n\n    expect(overview.ageBuckets.map((b) => b.id)).toEqual(\n      PEEK_EVENT_QUEUE_AGE_BUCKETS.map((b) => b.id),\n    );\n    expect(overview.ageBuckets.map((b) => b.count)).toEqual(counts);\n\n    // The last bucket (`gte_7d`) is open-ended — its query binds the\n    // `youngerOpen` true sentinel rather than a tz string for the lower bound.\n    const gte7d = mock.calls[PEEK_EVENT_QUEUE_AGE_BUCKETS.length - 1];\n    expect(gte7d.values).toContain(true);\n  });\n\n  it(\"read-only guarantee: every overview query is SELECT only\", async () => {\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      [],\n      [],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ];\n    const mock = createSqlMock(responses);\n    await getEventQueueOverview({ sql: mock.sql });\n    for (const call of mock.calls) {\n      expectReadOnly(call);\n    }\n  });\n\n  it(\"sparse: an empty database returns 0s across every metric without crashing\", async () => {\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      [],\n      [],\n      [],\n      [],\n    ];\n    const mock = createSqlMock(responses);\n    const overview = await getEventQueueOverview({ sql: mock.sql });\n\n    for (const metric of overview.metrics) {\n      expect(metric.value).toBe(0);\n      expect(metric.valueDisplay).toBe(\"0\");\n    }\n    for (const sc of overview.statusCounts) {\n      expect(sc.count).toBe(0);\n    }\n    expect(overview.typeCounts).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      new Error(\"query timeout\"),\n      [],\n      [],\n      [],\n    ];\n    const mock = createSqlMock(responses);\n    await expect(getEventQueueOverview({ sql: mock.sql })).rejects.toThrowError(\n      \"query timeout\",\n    );\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":6097,"cache_read_input_tokens":130825,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":6097},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"031ce74d-15ee-4888-a00b-e081672f539b","uuid":"4c929fb7-7110-47ae-beeb-a99adf623888"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LdNaoV4RURyMpxsrWCbQJA","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-event-queue.test.ts"}]},"parent_tool_use_id":null,"session_id":"031ce74d-15ee-4888-a00b-e081672f539b","uuid":"2ad66c00-cfbc-4908-920a-739e204f517d","timestamp":"2026-04-26T07:04:30.148Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-event-queue.test.ts","content":"// Query tests for the FR-10 event-queue admin reads (`get-event-queue.ts`).\n//\n// Backs `/operations/queue`. The spec line driving these tests is:\n// \"Queue query + page tests for pending, failed, dead, aged, filtered,\n// redacted-payload states.\" Each case asserts:\n//   - state-transition coverage (pending / processing / failed / dead);\n//   - bounded SQL (limit clamps);\n//   - filter binding into the right slot of the (`null` ? \"\" : value) toggle;\n//   - age-bucket window application;\n//   - secret redaction at every surfacing path (`error`, `payload`, linked ids).\n//\n// Mirrors the SQL-mock pattern used in `get-points-and-crates.test.ts`,\n// `get-dogpile-and-fraud.test.ts`, and `get-rewards.test.ts`: a tagged-template\n// stub records each call (joined SQL text + bound values) and dequeues a\n// per-call response so each test can assert which SQL fired, in what order,\n// and with which clamps.\n//\n// Read-only guarantee: every queue mutation (retry / cancel / replay) is\n// explicitly out of scope for spec 305 (FR-10 line 342). These tests keep the\n// queries SELECT-only so a future regression cannot silently introduce a\n// queue write.\n\nimport { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_EVENT_QUEUE_AGED_PENDING_HOURS,\n  PEEK_EVENT_QUEUE_DEFAULT_LIMIT,\n  PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS,\n  PEEK_EVENT_QUEUE_MAX_LIMIT,\n  PEEK_EVENT_QUEUE_TYPE_COUNT_LIMIT,\n  getEventQueueDetail,\n  getEventQueueOverview,\n  listEventQueue,\n} from \"../get-event-queue\";\nimport {\n  PEEK_AUDIT_REDACTED,\n  PEEK_EVENT_QUEUE_AGE_BUCKETS,\n  PEEK_EVENT_QUEUE_OVERVIEW_METRIC_IDS,\n  PEEK_EVENT_QUEUE_STATUSES,\n} from \"../../../../lib/types/peek\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\nfunction expectReadOnly(call: SqlCall) {\n  expect(call.text).not.toMatch(/\\binsert\\s+into\\b/i);\n  expect(call.text).not.toMatch(/\\bupdate\\s+\\w/i);\n  expect(call.text).not.toMatch(/\\bdelete\\s+from\\b/i);\n  expect(call.text).toMatch(/\\bselect\\b/i);\n}\n\ndescribe(\"listEventQueue\", () => {\n  it(\"default: clamps to PEEK_EVENT_QUEUE_DEFAULT_LIMIT and reads from event_queue with the right column projection\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expectReadOnly(call);\n    expect(call.text).toMatch(/from event_queue eq/i);\n    // Linked-id projection mirrors the spec line \"linked user/round/claim\n    // routes when identifiers are present\" (FR-10).\n    expect(call.text).toMatch(/eq\\.payload->>'userId'/);\n    expect(call.text).toMatch(/eq\\.payload->>'roundId'/);\n    expect(call.text).toMatch(/eq\\.payload->>'claimId'/);\n    expect(call.text).toMatch(/order by eq\\.created_at desc, eq\\.id desc/i);\n    expect(call.values).toContain(PEEK_EVENT_QUEUE_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      limit: PEEK_EVENT_QUEUE_MAX_LIMIT + 100,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_EVENT_QUEUE_MAX_LIMIT);\n  });\n\n  it(\"non-positive limit clamps to 1\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({ sql: mock.sql, limit: 0 });\n    expect(mock.calls[0].values).toContain(1);\n  });\n\n  it(\"non-finite limit falls back to the default\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({ sql: mock.sql, limit: Number.NaN });\n    expect(mock.calls[0].values).toContain(PEEK_EVENT_QUEUE_DEFAULT_LIMIT);\n  });\n\n  it(\"filters: empty filters bind null sentinels so every where-clause toggle is true\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({ sql: mock.sql, filters: {} });\n\n    // 9 togglable predicates (status / event type / id / payload user id /\n    // scheduled[from,to) / created[from,to) / age max / age min). Each\n    // predicate uses (${X === null} or eq.<col> = ${X ?? \"\"}) so an \"all-null\"\n    // input binds 9 `true` sentinels.\n    const trueBinds = mock.calls[0].values.filter((v) => v === true).length;\n    expect(trueBinds).toBeGreaterThanOrEqual(9);\n  });\n\n  it(\"filters: status='dead' binds the value verbatim and toggles the predicate on\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: { status: \"dead\" },\n    });\n\n    const values = mock.calls[0].values;\n    expect(values).toContain(\"dead\");\n    // status=dead disables the (${null}) escape hatch → at least one `false`\n    // sentinel reaches the bound values.\n    expect(values).toContain(false);\n  });\n\n  it(\"filters: state-transition coverage — every status enum binds verbatim\", async () => {\n    for (const status of PEEK_EVENT_QUEUE_STATUSES) {\n      const mock = createSqlMock([[]]);\n      await listEventQueue({ sql: mock.sql, filters: { status } });\n      expect(mock.calls[0].values).toContain(status);\n    }\n  });\n\n  it(\"filters: status='pending' binds verbatim — drives the queue.pending drilldown\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({ sql: mock.sql, filters: { status: \"pending\" } });\n    expect(mock.calls[0].values).toContain(\"pending\");\n  });\n\n  it(\"filters: status='failed' binds verbatim — drives the FR-10 attention link\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({ sql: mock.sql, filters: { status: \"failed\" } });\n    expect(mock.calls[0].values).toContain(\"failed\");\n  });\n\n  it(\"filters: payloadUserId reads through eq.payload->>'userId' and binds verbatim\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: { payloadUserId: \"user-9\" },\n    });\n    expect(mock.calls[0].text).toMatch(/eq\\.payload->>'userId' = /);\n    expect(mock.calls[0].values).toContain(\"user-9\");\n  });\n\n  it(\"filters: every supported filter (status, eventType, id, payloadUserId, scheduledFrom, scheduledTo, createdFrom, createdTo) flows into the bound values\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: {\n        status: \"failed\",\n        eventType: \"points.grant\",\n        id: \"11111111-1111-1111-1111-111111111111\",\n        payloadUserId: \"user-9\",\n        scheduledFrom: \"2026-04-01T00:00:00.000Z\",\n        scheduledTo: \"2026-04-26T00:00:00.000Z\",\n        createdFrom: \"2026-04-01T00:00:00.000Z\",\n        createdTo: \"2026-04-26T00:00:00.000Z\",\n      },\n    });\n\n    const values = mock.calls[0].values;\n    expect(values).toContain(\"failed\");\n    expect(values).toContain(\"points.grant\");\n    expect(values).toContain(\"11111111-1111-1111-1111-111111111111\");\n    expect(values).toContain(\"user-9\");\n    expect(values).toContain(\"2026-04-01T00:00:00.000Z\");\n    expect(values).toContain(\"2026-04-26T00:00:00.000Z\");\n    // Date filters cast through ::timestamptz so the SQL keeps tz-correct\n    // half-open windows.\n    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n  });\n\n  it(\"filters: whitespace-only filter values normalize to null (toggle stays true)\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: { status: \"   \", eventType: \"\" },\n    });\n\n    // Both filters become null → both toggles become true and neither\n    // value sneaks through.\n    expect(mock.calls[0].values).not.toContain(\"   \");\n  });\n\n  it(\"filters: age bucket lt_1h applies an upper bound on created_at via the `now - 0h` boundary\", async () => {\n    const now = new Date(\"2026-04-26T12:00:00.000Z\");\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: { ageBucket: \"lt_1h\" },\n      now,\n    });\n\n    // The `lt_1h` bucket is [0h, 1h): older-than = now - 0h, younger-than =\n    // now - 1h. The query binds both ISO strings into the timestamptz\n    // comparisons.\n    const values = mock.calls[0].values;\n    expect(values).toContain(now.toISOString());\n    const oneHourAgo = new Date(now.getTime() - 60 * 60 * 1000).toISOString();\n    expect(values).toContain(oneHourAgo);\n  });\n\n  it(\"filters: age bucket gte_7d uses the open-ended last bucket — no younger bound\", async () => {\n    const now = new Date(\"2026-04-26T12:00:00.000Z\");\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: { ageBucket: \"gte_7d\" },\n      now,\n    });\n\n    const values = mock.calls[0].values;\n    const sevenDaysAgo = new Date(\n      now.getTime() - 7 * 24 * 60 * 60 * 1000,\n    ).toISOString();\n    expect(values).toContain(sevenDaysAgo);\n    // The min-side toggle (`ageHasMin`) binds `false` for the open-ended\n    // bucket — confirms the predicate is skipped.\n    expect(values).toContain(false);\n  });\n\n  it(\"filters: unknown age bucket id falls back to null (no age window applied)\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: { ageBucket: \"yesterday\" },\n    });\n\n    // Both age-window toggles bind `true` (the predicate is skipped) and\n    // neither boundary ISO string appears in the values.\n    const trueBinds = mock.calls[0].values.filter((v) => v === true).length;\n    expect(trueBinds).toBeGreaterThanOrEqual(9);\n  });\n\n  it(\"populated: row mapping projects the migration columns and surfaces an error preview\", async () => {\n    const row = {\n      id: \"11111111-1111-1111-1111-111111111111\",\n      eventType: \"points.grant\",\n      status: \"failed\",\n      attempts: 3,\n      maxAttempts: 5,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: \"2026-04-26T10:01:00.000Z\",\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: \"RpcError: connection refused\",\n      userId: \"user-9\",\n      roundId: \"round-3\",\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n\n    const rows = await listEventQueue({ sql: mock.sql });\n    expect(rows).toHaveLength(1);\n    expect(rows[0].status).toBe(\"failed\");\n    expect(rows[0].attempts).toBe(3);\n    expect(rows[0].maxAttempts).toBe(5);\n    expect(rows[0].errorPreview).toBe(\"RpcError: connection refused\");\n    expect(rows[0].linked).toEqual({\n      userId: \"user-9\",\n      roundId: \"round-3\",\n      claimId: null,\n    });\n  });\n\n  it(\"populated: stringified attempts/maxAttempts coerce to integers via readInt\", async () => {\n    const row = {\n      id: \"abc\",\n      eventType: \"points.grant\",\n      status: \"failed\",\n      attempts: \"7\",\n      maxAttempts: \"10\",\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: null,\n      userId: null,\n      roundId: null,\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listEventQueue({ sql: mock.sql });\n    expect(rows[0].attempts).toBe(7);\n    expect(rows[0].maxAttempts).toBe(10);\n  });\n\n  it(\"populated: an oversized error string is truncated with an ellipsis at PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS\", async () => {\n    const big = \"x\".repeat(PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS + 50);\n    const row = {\n      id: \"abc\",\n      eventType: \"points.grant\",\n      status: \"dead\",\n      attempts: 5,\n      maxAttempts: 5,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: big,\n      userId: null,\n      roundId: null,\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listEventQueue({ sql: mock.sql });\n    expect(rows[0].errorPreview).not.toBeNull();\n    expect(rows[0].errorPreview?.length).toBe(\n      PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS + 1, // \"+1\" for the trailing ellipsis\n    );\n    expect(rows[0].errorPreview?.endsWith(\"…\")).toBe(true);\n  });\n\n  it(\"redaction: an error string that looks like a JWT is replaced with PEEK_AUDIT_REDACTED in the preview\", async () => {\n    const jwt =\n      \"eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ1c2VyLTkifQ.signature_segment\";\n    const row = {\n      id: \"abc\",\n      eventType: \"auth.callback\",\n      status: \"failed\",\n      attempts: 1,\n      maxAttempts: 3,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: jwt,\n      userId: null,\n      roundId: null,\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listEventQueue({ sql: mock.sql });\n    expect(rows[0].errorPreview).toBe(PEEK_AUDIT_REDACTED);\n    // The original secret never reaches the surface.\n    expect(rows[0].errorPreview).not.toContain(\"eyJ\");\n  });\n\n  it(\"redaction: a payload-derived linked id that looks like a postgres URL is redacted\", async () => {\n    // Pathological input: a queue worker accidentally serialised a connection\n    // string into payload.userId. The list-row should redact it before the\n    // row leaves the server.\n    const row = {\n      id: \"abc\",\n      eventType: \"points.grant\",\n      status: \"pending\",\n      attempts: 0,\n      maxAttempts: 5,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: null,\n      userId: \"postgres://user:pass@host:5432/db\",\n      roundId: null,\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listEventQueue({ sql: mock.sql });\n    expect(rows[0].linked.userId).toBe(PEEK_AUDIT_REDACTED);\n    expect(rows[0].linked.userId).not.toContain(\"postgres://\");\n  });\n\n  it(\"sparse: an empty result set returns []\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listEventQueue({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"connection refused\")]);\n    await expect(listEventQueue({ sql: mock.sql })).rejects.toThrowError(\n      \"connection refused\",\n    );\n  });\n});\n\ndescribe(\"getEventQueueDetail\", () => {\n  it(\"returns null when id is missing\", async () => {\n    const mock = createSqlMock([]);\n    const detail = await getEventQueueDetail({ sql: mock.sql, id: \"\" });\n    expect(detail).toBeNull();\n    // No SQL fired — the early return short-circuits before the lookup.\n    expect(mock.calls).toHaveLength(0);\n  });\n\n  it(\"returns null when the row is not found\", async () => {\n    const mock = createSqlMock([[]]);\n    const detail = await getEventQueueDetail({ sql: mock.sql, id: \"missing\" });\n    expect(detail).toBeNull();\n  });\n\n  it(\"populated: passes through the columns and applies redactJsonValue / redactNullableString\", async () => {\n    const payload = {\n      userId: \"user-9\",\n      claimAmount: \"5000000\",\n      // A nested string that looks like a Bearer token must round-trip as the\n      // PEEK_AUDIT_REDACTED marker.\n      authHeader: \"Bearer abcdefgh1234567890\",\n    };\n    const row = {\n      id: \"11111111-1111-1111-1111-111111111111\",\n      eventType: \"claims.process\",\n      status: \"failed\",\n      attempts: 2,\n      maxAttempts: 5,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: \"RpcError: connection refused\",\n      payload,\n      userId: \"user-9\",\n      roundId: null,\n      claimId: \"claim-3\",\n    };\n    const mock = createSqlMock([[row]]);\n    const detail = await getEventQueueDetail({\n      sql: mock.sql,\n      id: \"11111111-1111-1111-1111-111111111111\",\n    });\n    expect(detail).not.toBeNull();\n    expect(detail?.id).toBe(\"11111111-1111-1111-1111-111111111111\");\n    expect(detail?.error).toBe(\"RpcError: connection refused\");\n    expect(detail?.linked).toEqual({\n      userId: \"user-9\",\n      roundId: null,\n      claimId: \"claim-3\",\n    });\n    // The Bearer token in the JSONB payload is redacted recursively.\n    const redactedPayload = detail?.payload as Record<string, unknown>;\n    expect(redactedPayload.authHeader).toBe(PEEK_AUDIT_REDACTED);\n    // Non-secret keys round-trip verbatim.\n    expect(redactedPayload.userId).toBe(\"user-9\");\n    expect(redactedPayload.claimAmount).toBe(\"5000000\");\n  });\n\n  it(\"redaction: a bare error string that looks like a DB URL is redacted (the audit redactor swaps the value)\", async () => {\n    const row = {\n      id: \"abc\",\n      eventType: \"claims.process\",\n      status: \"failed\",\n      attempts: 2,\n      maxAttempts: 5,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: \"fatal: postgres://user:secret@host:5432/db unreachable\",\n      payload: null,\n      userId: null,\n      roundId: null,\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const detail = await getEventQueueDetail({ sql: mock.sql, id: \"abc\" });\n    expect(detail?.error).toBe(PEEK_AUDIT_REDACTED);\n    // The original credential never reaches the operator UI.\n    expect(detail?.error).not.toContain(\"secret\");\n  });\n\n  it(\"redaction: cycles in the JSONB payload are guarded — no infinite loop\", async () => {\n    type Cyc = { a: number; self?: unknown };\n    const cyclic: Cyc = { a: 1 };\n    cyclic.self = cyclic;\n\n    const row = {\n      id: \"abc\",\n      eventType: \"claims.process\",\n      status: \"failed\",\n      attempts: 2,\n      maxAttempts: 5,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: null,\n      payload: cyclic,\n      userId: null,\n      roundId: null,\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const detail = await getEventQueueDetail({ sql: mock.sql, id: \"abc\" });\n    const redacted = detail?.payload as Record<string, unknown>;\n    expect(redacted.a).toBe(1);\n    // The cycle is broken with the redacted sentinel rather than crashing\n    // the renderer.\n    expect(redacted.self).toBe(PEEK_AUDIT_REDACTED);\n  });\n});\n\ndescribe(\"getEventQueueOverview\", () => {\n  // Eager-built SQL templates: the .map() callback in\n  // get-event-queue.ts runs before Promise.all, so the 5 age-bucket queries\n  // dispatch FIRST (one per PEEK_EVENT_QUEUE_AGE_BUCKETS entry), then the four\n  // status / type / at_max / aged_pending queries dispatch as the\n  // Promise.all() argument array is built. The mock cursor advances in that\n  // exact order, so per-call responses must follow the same shape.\n  const ageBucketResponses = PEEK_EVENT_QUEUE_AGE_BUCKETS.map(\n    () => [{ value: 0 }] as const,\n  );\n\n  it(\"metric strip exposes every PeekEventQueueOverviewMetricId in order\", async () => {\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      [], // status rows\n      [], // type rows\n      [{ value: 0 }], // at_max\n      [{ value: 0 }], // aged_pending\n    ];\n    const mock = createSqlMock(responses);\n    const now = new Date(\"2026-04-26T12:00:00.000Z\");\n    const overview = await getEventQueueOverview({ sql: mock.sql, now });\n\n    expect(overview.metrics.map((m) => m.id)).toEqual(\n      PEEK_EVENT_QUEUE_OVERVIEW_METRIC_IDS,\n    );\n    // Every metric carries the FR-4 metadata.\n    for (const metric of overview.metrics) {\n      expect(metric.label.length).toBeGreaterThan(0);\n      expect(metric.source).toBe(\"event_queue\");\n      expect(metric.freshness).toBe(\"live\");\n      expect(metric.asOf).toBe(now.toISOString());\n      expect(metric.definition.length).toBeGreaterThan(0);\n    }\n    expect(overview.generatedAt).toBe(now.toISOString());\n  });\n\n  it(\"status counts: missing migration values still appear as 0 rows so an absent state is visible\", async () => {\n    // The status query returns only `pending` — the four other statuses must\n    // still appear with count: 0.\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      [{ status: \"pending\", value: 7 }],\n      [],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ];\n    const mock = createSqlMock(responses);\n    const overview = await getEventQueueOverview({ sql: mock.sql });\n\n    const lookup = new Map(\n      overview.statusCounts.map((s) => [s.status, s.count] as const),\n    );\n    expect(lookup.get(\"pending\")).toBe(7);\n    expect(lookup.get(\"processing\")).toBe(0);\n    expect(lookup.get(\"failed\")).toBe(0);\n    expect(lookup.get(\"dead\")).toBe(0);\n    expect(lookup.get(\"completed\")).toBe(0);\n    // The full migration set is projected so the operator never sees a\n    // missing row.\n    expect(overview.statusCounts.map((s) => s.status)).toEqual(\n      PEEK_EVENT_QUEUE_STATUSES,\n    );\n  });\n\n  it(\"status counts: pending / processing / failed / dead all round-trip into the metric strip\", async () => {\n    const statusResponse = [\n      { status: \"pending\", value: 1 },\n      { status: \"processing\", value: 2 },\n      { status: \"failed\", value: 3 },\n      { status: \"dead\", value: 4 },\n      { status: \"completed\", value: 5 },\n    ];\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      statusResponse,\n      [],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ];\n    const mock = createSqlMock(responses);\n    const overview = await getEventQueueOverview({ sql: mock.sql });\n\n    const m = new Map(overview.metrics.map((m) => [m.id, m] as const));\n    expect(m.get(\"queue.pending\")?.value).toBe(1);\n    expect(m.get(\"queue.processing\")?.value).toBe(2);\n    expect(m.get(\"queue.failed\")?.value).toBe(3);\n    expect(m.get(\"queue.dead\")?.value).toBe(4);\n    expect(m.get(\"queue.failed\")?.valueDisplay).toBe(\"3\");\n    // Failed and dead drilldowns are the FR-10 attention links.\n    expect(m.get(\"queue.failed\")?.drilldownHref).toBe(\n      \"/operations/queue?status=failed\",\n    );\n    expect(m.get(\"queue.dead\")?.drilldownHref).toBe(\n      \"/operations/queue?status=dead\",\n    );\n  });\n\n  it(\"type counts: bound by typeCountLimit (top 50 by count) — caller-passed values pass through clampLimit\", async () => {\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      [],\n      [{ eventType: \"points.grant\", value: 100 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ];\n    const mock = createSqlMock(responses);\n    await getEventQueueOverview({ sql: mock.sql });\n\n    // The type-count call (after the 5 age-bucket queries → index 6 = 0-indexed `5+1=6` → `mock.calls[6]`) must contain the type-count limit value.\n    const typeCountCall = mock.calls[6];\n    expect(typeCountCall.text).toMatch(/group by eq\\.event_type/i);\n    expect(typeCountCall.text).toMatch(/order by count\\(\\*\\) desc/i);\n    expect(typeCountCall.values).toContain(PEEK_EVENT_QUEUE_TYPE_COUNT_LIMIT);\n  });\n\n  it(\"aged-pending: defaults to PEEK_EVENT_QUEUE_AGED_PENDING_HOURS hours ago\", async () => {\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      [],\n      [],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ];\n    const mock = createSqlMock(responses);\n    const now = new Date(\"2026-04-26T12:00:00.000Z\");\n    await getEventQueueOverview({ sql: mock.sql, now });\n\n    const expected = new Date(\n      now.getTime() - PEEK_EVENT_QUEUE_AGED_PENDING_HOURS * 60 * 60 * 1000,\n    ).toISOString();\n    // Aged-pending is the 9th call (index 8): 5 buckets + status + type + atMax + agedPending.\n    const agedCall = mock.calls[8];\n    expect(agedCall.text).toMatch(/where eq\\.status = /i);\n    expect(agedCall.text).toMatch(/eq\\.created_at <=/i);\n    expect(agedCall.values).toContain(expected);\n  });\n\n  it(\"aged-pending: caller-supplied hours flows through, label updates\", async () => {\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      [],\n      [],\n      [{ value: 0 }],\n      [{ value: 12 }],\n    ];\n    const mock = createSqlMock(responses);\n    const now = new Date(\"2026-04-26T12:00:00.000Z\");\n    const overview = await getEventQueueOverview({\n      sql: mock.sql,\n      now,\n      agedPendingHours: 48,\n    });\n\n    const aged = overview.metrics.find((m) => m.id === \"queue.aged_pending\");\n    expect(aged?.windowLabel).toBe(\"Pending for ≥ 48h\");\n    expect(aged?.value).toBe(12);\n    const expected = new Date(\n      now.getTime() - 48 * 60 * 60 * 1000,\n    ).toISOString();\n    expect(mock.calls[8].values).toContain(expected);\n  });\n\n  it(\"at_max_attempts: filters attempts >= max_attempts on the non-completed lifecycle states\", async () => {\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      [],\n      [],\n      [{ value: 9 }],\n      [{ value: 0 }],\n    ];\n    const mock = createSqlMock(responses);\n    const overview = await getEventQueueOverview({ sql: mock.sql });\n\n    // at_max is the 8th call (index 7): 5 buckets + status + type + atMax.\n    const atMaxCall = mock.calls[7];\n    expect(atMaxCall.text).toMatch(\n      /eq\\.status in \\('pending', 'processing', 'failed', 'dead'\\)/i,\n    );\n    expect(atMaxCall.text).toMatch(/eq\\.attempts >= eq\\.max_attempts/i);\n    const atMax = overview.metrics.find((m) => m.id === \"queue.at_max_attempts\");\n    expect(atMax?.value).toBe(9);\n  });\n\n  it(\"age buckets: every PEEK_EVENT_QUEUE_AGE_BUCKETS entry is queried with its half-open boundary\", async () => {\n    // Each age bucket → one count(*) query. The first 5 mock calls correspond\n    // to the buckets in PEEK_EVENT_QUEUE_AGE_BUCKETS order.\n    const counts = [11, 22, 33, 44, 55];\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...counts.map((c) => [{ value: c }]),\n      [],\n      [],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ];\n    const mock = createSqlMock(responses);\n    const overview = await getEventQueueOverview({ sql: mock.sql });\n\n    expect(overview.ageBuckets.map((b) => b.id)).toEqual(\n      PEEK_EVENT_QUEUE_AGE_BUCKETS.map((b) => b.id),\n    );\n    expect(overview.ageBuckets.map((b) => b.count)).toEqual(counts);\n\n    // The last bucket (`gte_7d`) is open-ended — its query binds the\n    // `youngerOpen` true sentinel rather than a tz string for the lower bound.\n    const gte7d = mock.calls[PEEK_EVENT_QUEUE_AGE_BUCKETS.length - 1];\n    expect(gte7d.values).toContain(true);\n  });\n\n  it(\"read-only guarantee: every overview query is SELECT only\", async () => {\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      [],\n      [],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ];\n    const mock = createSqlMock(responses);\n    await getEventQueueOverview({ sql: mock.sql });\n    for (const call of mock.calls) {\n      expectReadOnly(call);\n    }\n  });\n\n  it(\"sparse: an empty database returns 0s across every metric without crashing\", async () => {\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      [],\n      [],\n      [],\n      [],\n    ];\n    const mock = createSqlMock(responses);\n    const overview = await getEventQueueOverview({ sql: mock.sql });\n\n    for (const metric of overview.metrics) {\n      expect(metric.value).toBe(0);\n      expect(metric.valueDisplay).toBe(\"0\");\n    }\n    for (const sc of overview.statusCounts) {\n      expect(sc.count).toBe(0);\n    }\n    expect(overview.typeCounts).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const responses: ReadonlyArray<ResponseValue> = [\n      ...ageBucketResponses,\n      new Error(\"query timeout\"),\n      [],\n      [],\n      [],\n    ];\n    const mock = createSqlMock(responses);\n    await expect(getEventQueueOverview({ sql: mock.sql })).rejects.toThrowError(\n      \"query timeout\",\n    );\n  });\n});\n","