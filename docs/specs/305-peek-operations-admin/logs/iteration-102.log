{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01TANf5DBF7N4HLBLYS9g9RE","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011vS2gWweJwcmpXKAa3EtWU","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/lib/__tests__/operations-queue-search-params.test.ts","content":"// Tests for the FR-10 /operations/queue URL-addressable filter normaliser.\n//\n// One filter group (`queueFilter*`) plus a single `selectedId` param drives\n// the side-by-side detail panel. The normaliser is the contract that keeps a\n// stale URL chip from lying about a table's filter state — empty/whitespace →\n// null, unknown enum → null, recognised allowlist values pass through.\n\nimport { describe, expect, it } from \"vitest\";\nimport {\n  PEEK_EVENT_QUEUE_AGE_BUCKET_VALUES,\n  PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES,\n  PEEK_EVENT_QUEUE_STATUS_VALUES,\n  normalizeEventQueueFiltersFromSearchParams,\n  readSelectedQueueIdFromSearchParams,\n} from \"../operations-queue-search-params\";\n\ndescribe(\"normalizeEventQueueFiltersFromSearchParams\", () => {\n  it(\"empty input: every filter normalises to null\", () => {\n    expect(normalizeEventQueueFiltersFromSearchParams({})).toEqual({\n      status: null,\n      eventType: null,\n      id: null,\n      payloadUserId: null,\n      scheduledFrom: null,\n      scheduledTo: null,\n      createdFrom: null,\n      createdTo: null,\n      ageBucket: null,\n    });\n  });\n\n  it(\"whitespace-only values normalise to null across every filter\", () => {\n    expect(\n      normalizeEventQueueFiltersFromSearchParams({\n        queueFilterStatus: \"  \",\n        queueFilterType: \"   \",\n        queueFilterId: \" \",\n        queueFilterUserId: \"    \",\n        queueFilterAge: \"   \",\n        queueFilterScheduledFrom: \" \",\n        queueFilterScheduledTo: \" \",\n        queueFilterCreatedFrom: \" \",\n        queueFilterCreatedTo: \" \",\n      }),\n    ).toEqual({\n      status: null,\n      eventType: null,\n      id: null,\n      payloadUserId: null,\n      scheduledFrom: null,\n      scheduledTo: null,\n      createdFrom: null,\n      createdTo: null,\n      ageBucket: null,\n    });\n  });\n\n  it(\"populated: every supported filter flows through with trimming\", () => {\n    const filters = normalizeEventQueueFiltersFromSearchParams({\n      queueFilterStatus: \"failed\",\n      queueFilterType: \"  points.grant  \",\n      queueFilterId: \"  11111111-1111-1111-1111-111111111111  \",\n      queueFilterUserId: \" user-9 \",\n      queueFilterAge: \"lt_24h\",\n      queueFilterScheduledFrom: \"2026-04-01\",\n      queueFilterScheduledTo: \"2026-04-26\",\n      queueFilterCreatedFrom: \"2026-04-01\",\n      queueFilterCreatedTo: \"2026-04-26\",\n    });\n    expect(filters).toEqual({\n      status: \"failed\",\n      eventType: \"points.grant\",\n      id: \"11111111-1111-1111-1111-111111111111\",\n      payloadUserId: \"user-9\",\n      ageBucket: \"lt_24h\",\n      scheduledFrom: \"2026-04-01\",\n      scheduledTo: \"2026-04-26\",\n      createdFrom: \"2026-04-01\",\n      createdTo: \"2026-04-26\",\n    });\n  });\n\n  it(\"status: state-transition coverage — every allowlisted value passes through verbatim\", () => {\n    // pending / processing / completed / failed / dead — every queue\n    // lifecycle state is filterable.\n    for (const value of PEEK_EVENT_QUEUE_STATUS_VALUES) {\n      const filters = normalizeEventQueueFiltersFromSearchParams({\n        queueFilterStatus: value,\n      });\n      expect(filters.status).toBe(value);\n    }\n  });\n\n  it(\"status: unknown enum value normalises to null so a stale URL chip cannot lie\", () => {\n    expect(\n      normalizeEventQueueFiltersFromSearchParams({\n        queueFilterStatus: \"stalled\",\n      }).status,\n    ).toBeNull();\n  });\n\n  it(\"ageBucket: every allowlisted value passes through verbatim\", () => {\n    for (const value of PEEK_EVENT_QUEUE_AGE_BUCKET_VALUES) {\n      const filters = normalizeEventQueueFiltersFromSearchParams({\n        queueFilterAge: value,\n      });\n      expect(filters.ageBucket).toBe(value);\n    }\n  });\n\n  it(\"ageBucket: unknown bucket id normalises to null so a stale link cannot apply a fake window\", () => {\n    expect(\n      normalizeEventQueueFiltersFromSearchParams({\n        queueFilterAge: \"yesterday\",\n      }).ageBucket,\n    ).toBeNull();\n  });\n\n  it(\"array values: only the first element is read\", () => {\n    expect(\n      normalizeEventQueueFiltersFromSearchParams({\n        queueFilterStatus: [\"failed\", \"dead\"],\n      }).status,\n    ).toBe(\"failed\");\n  });\n\n  it(\"undefined input value normalises to null without throwing\", () => {\n    expect(\n      normalizeEventQueueFiltersFromSearchParams({\n        queueFilterStatus: undefined,\n        queueFilterType: undefined,\n      }),\n    ).toEqual({\n      status: null,\n      eventType: null,\n      id: null,\n      payloadUserId: null,\n      scheduledFrom: null,\n      scheduledTo: null,\n      createdFrom: null,\n      createdTo: null,\n      ageBucket: null,\n    });\n  });\n});\n\ndescribe(\"readSelectedQueueIdFromSearchParams\", () => {\n  it(\"returns null for an absent selectedId\", () => {\n    expect(readSelectedQueueIdFromSearchParams({})).toBeNull();\n  });\n\n  it(\"returns null for a whitespace-only selectedId\", () => {\n    expect(\n      readSelectedQueueIdFromSearchParams({ selectedId: \"    \" }),\n    ).toBeNull();\n  });\n\n  it(\"trims and returns the value when present\", () => {\n    expect(\n      readSelectedQueueIdFromSearchParams({\n        selectedId: \"  11111111-1111-1111-1111-111111111111  \",\n      }),\n    ).toBe(\"11111111-1111-1111-1111-111111111111\");\n  });\n\n  it(\"array values: only the first element is read\", () => {\n    expect(\n      readSelectedQueueIdFromSearchParams({\n        selectedId: [\"a\", \"b\"],\n      }),\n    ).toBe(\"a\");\n  });\n});\n\ndescribe(\"PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES\", () => {\n  it(\"declares the same param names the form fields submit\", () => {\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.status).toBe(\n      \"queueFilterStatus\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.eventType).toBe(\n      \"queueFilterType\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.id).toBe(\"queueFilterId\");\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.payloadUserId).toBe(\n      \"queueFilterUserId\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.scheduledFrom).toBe(\n      \"queueFilterScheduledFrom\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.scheduledTo).toBe(\n      \"queueFilterScheduledTo\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.createdFrom).toBe(\n      \"queueFilterCreatedFrom\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.createdTo).toBe(\n      \"queueFilterCreatedTo\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.ageBucket).toBe(\n      \"queueFilterAge\",\n    );\n    // The `selectedId` token belongs to the same map so the table component\n    // can build shareable detail-panel links without re-declaring the literal.\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.selectedId).toBe(\"selectedId\");\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":12571,"cache_read_input_tokens":136922,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":12571},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"031ce74d-15ee-4888-a00b-e081672f539b","uuid":"90ee0200-5186-4682-9fc3-d514fbcae13e"}
