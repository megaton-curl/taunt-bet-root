{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LT5371UBRjgBWJkUCAepSa","type":"tool_result","content":"1\t// URL-addressable filter params for /operations/queue (FR-10).\n2\t//\n3\t// One filter group per page (`queueFilter*`) plus a single `selectedId` param\n4\t// that drives the side-by-side detail panel. Empty / whitespace values\n5\t// normalise to `null`. Unknown enum values for `status` and `age` normalise to\n6\t// `null` so a stale URL chip cannot lie about the table's filter state.\n7\t\n8\timport {\n9\t  PEEK_EVENT_QUEUE_AGE_BUCKETS,\n10\t  PEEK_EVENT_QUEUE_STATUSES,\n11\t} from \"./types/peek\";\n12\timport type { PeekEventQueueFilters } from \"./types/peek\";\n13\t\n14\texport const PEEK_EVENT_QUEUE_STATUS_VALUES: ReadonlyArray<string> =\n15\t  PEEK_EVENT_QUEUE_STATUSES;\n16\t\n17\texport const PEEK_EVENT_QUEUE_AGE_BUCKET_VALUES: ReadonlyArray<string> =\n18\t  PEEK_EVENT_QUEUE_AGE_BUCKETS.map((bucket) => bucket.id);\n19\t\n20\tfunction readSingleValue(value: string | string[] | undefined): string {\n21\t  return Array.isArray(value) ? value[0] ?? \"\" : value ?? \"\";\n22\t}\n23\t\n24\tfunction trimOrNull(value: string): string | null {\n25\t  const trimmed = value.trim();\n26\t  return trimmed.length > 0 ? trimmed : null;\n27\t}\n28\t\n29\tfunction allowlistOrNull(\n30\t  value: string | null,\n31\t  allowed: ReadonlyArray<string>,\n32\t): string | null {\n33\t  if (!value) return null;\n34\t  return allowed.includes(value) ? value : null;\n35\t}\n36\t\n37\texport function normalizeEventQueueFiltersFromSearchParams(\n38\t  input: Record<string, string | string[] | undefined>,\n39\t): PeekEventQueueFilters {\n40\t  const status = trimOrNull(readSingleValue(input.queueFilterStatus));\n41\t  const ageBucket = trimOrNull(readSingleValue(input.queueFilterAge));\n42\t  return {\n43\t    status: allowlistOrNull(status, PEEK_EVENT_QUEUE_STATUS_VALUES),\n44\t    eventType: trimOrNull(readSingleValue(input.queueFilterType)),\n45\t    id: trimOrNull(readSingleValue(input.queueFilterId)),\n46\t    payloadUserId: trimOrNull(readSingleValue(input.queueFilterUserId)),\n47\t    scheduledFrom: trimOrNull(readSingleValue(input.queueFilterScheduledFrom)),\n48\t    scheduledTo: trimOrNull(readSingleValue(input.queueFilterScheduledTo)),\n49\t    createdFrom: trimOrNull(readSingleValue(input.queueFilterCreatedFrom)),\n50\t    createdTo: trimOrNull(readSingleValue(input.queueFilterCreatedTo)),\n51\t    ageBucket: allowlistOrNull(ageBucket, PEEK_EVENT_QUEUE_AGE_BUCKET_VALUES),\n52\t  };\n53\t}\n54\t\n55\texport function readSelectedQueueIdFromSearchParams(\n56\t  input: Record<string, string | string[] | undefined>,\n57\t): string | null {\n58\t  return trimOrNull(readSingleValue(input.selectedId));\n59\t}\n60\t\n61\t// Two-arg overload tolerated for callers that prefer to pass URLSearchParams\n62\t// indirectly. Also exposes the prefix tokens so the filter bar form fields stay\n63\t// in lockstep with the URL parser without duplicating the literals.\n64\texport const PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES = {\n65\t  status: \"queueFilterStatus\",\n66\t  eventType: \"queueFilterType\",\n67\t  id: \"queueFilterId\",\n68\t  payloadUserId: \"queueFilterUserId\",\n69\t  scheduledFrom: \"queueFilterScheduledFrom\",\n70\t  scheduledTo: \"queueFilterScheduledTo\",\n71\t  createdFrom: \"queueFilterCreatedFrom\",\n72\t  createdTo: \"queueFilterCreatedTo\",\n73\t  ageBucket: \"queueFilterAge\",\n74\t  selectedId: \"selectedId\",\n75\t} as const;\n76\t"}]},"parent_tool_use_id":null,"session_id":"031ce74d-15ee-4888-a00b-e081672f539b","uuid":"0088309e-8151-4047-a90c-7c2b705ba989","timestamp":"2026-04-26T07:00:40.258Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/operations-queue-search-params.ts","content":"// URL-addressable filter params for /operations/queue (FR-10).\n//\n// One filter group per page (`queueFilter*`) plus a single `selectedId` param\n// that drives the side-by-s