{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QvoejSQTzqkrbpgE72UueV","type":"tool_result","content":"1\t// Component tests for the FR-9 fraud flags review table.\n2\t//\n3\t// Read-only by spec — every fraud_flags status transition lives behind the\n4\t// FR-14 `fraud_flag.status.update` action id (declared in\n5\t// `peek/src/server/access-policy.ts`, not yet implemented). These tests assert\n6\t// there are no edit affordances, every status drives the right chip tone, and\n7\t// the JSONB `details` payload renders verbatim.\n8\t\n9\timport { describe, expect, it } from \"vitest\";\n10\timport { render, screen } from \"@testing-library/react\";\n11\timport { FraudFlagsTable } from \"../fraud-flags-table\";\n12\timport type { PeekFraudFlagListRow } from \"../../lib/types/peek\";\n13\t\n14\tconst ROW_OPEN: PeekFraudFlagListRow = {\n15\t  id: \"1\",\n16\t  userId: \"user-1\",\n17\t  username: \"alice\",\n18\t  wallet: \"Wal1...\",\n19\t  flagType: \"self_referral\",\n20\t  status: \"open\",\n21\t  relatedId: \"ref-9\",\n22\t  details: { reason: \"loop\", referrer_id: \"ref-9\", attempts: 3 },\n23\t  createdAt: \"2026-04-26T09:00:00.000Z\",\n24\t  resolvedAt: null,\n25\t};\n26\t\n27\tconst ROW_REVIEWED: PeekFraudFlagListRow = {\n28\t  id: \"2\",\n29\t  userId: \"user-2\",\n30\t  username: null,\n31\t  wallet: null,\n32\t  flagType: \"rapid_signup\",\n33\t  status: \"reviewed\",\n34\t  relatedId: null,\n35\t  details: null,\n36\t  createdAt: \"2026-04-25T09:00:00.000Z\",\n37\t  resolvedAt: \"2026-04-25T10:00:00.000Z\",\n38\t};\n39\t\n40\tconst ROW_DISMISSED: PeekFraudFlagListRow = {\n41\t  id: \"3\",\n42\t  userId: \"user-3\",\n43\t  username: \"carol\",\n44\t  wallet: \"Wal3...\",\n45\t  flagType: \"vpn\",\n46\t  status: \"dismissed\",\n47\t  relatedId: null,\n48\t  details: { evidence: \"rotating_proxy\", checked_by: \"ops\" },\n49\t  createdAt: \"2026-04-24T09:00:00.000Z\",\n50\t  resolvedAt: \"2026-04-24T11:00:00.000Z\",\n51\t};\n52\t\n53\tdescribe(\"FraudFlagsTable\", () => {\n54\t  it(\"populated: renders the operator columns and every status chip variant\", () => {\n55\t    render(\n56\t      <FraudFlagsTable rows={[ROW_OPEN, ROW_REVIEWED, ROW_DISMISSED]} />,\n57\t    );\n58\t\n59\t    for (const header of [\n60\t      \"Status\",\n61\t      \"Flag type\",\n62\t      \"User\",\n63\t      \"Wallet\",\n64\t      \"Related\",\n65\t      \"Details\",\n66\t      \"Created\",\n67\t      \"Resolved\",\n68\t      \"ID\",\n69\t    ]) {\n70\t      expect(screen.getByText(header)).toBeInTheDocument();\n71\t    }\n72\t\n73\t    // State transition coverage: open / reviewed / dismissed chips.\n74\t    expect(screen.getByText(\"open\")).toBeInTheDocument();\n75\t    expect(screen.getByText(\"reviewed\")).toBeInTheDocument();\n76\t    expect(screen.getByText(\"dismissed\")).toBeInTheDocument();\n77\t  });\n78\t\n79\t  it(\"populated: username links to /users/[userId] with the userId fallback when sparse\", () => {\n80\t    render(\n81\t      <FraudFlagsTable rows={[ROW_OPEN, ROW_REVIEWED]} />,\n82\t    );\n83\t\n84\t    const aliceLink = screen.getByRole(\"link\", { name: \"alice\" });\n85\t    expect(aliceLink).toHaveAttribute(\"href\", \"/users/user-1\");\n86\t\n87\t    // ROW_REVIEWED has username=null → fallback to userId on the link label.\n88\t    const fallbackLink = screen.getByRole(\"link\", { name: \"user-2\" });\n89\t    expect(fallbackLink).toHaveAttribute(\"href\", \"/users/user-2\");\n90\t  });\n91\t\n92\t  it(\"populated: JSONB details column renders verbatim inside a <pre> block\", () => {\n93\t    const { container } = render(<FraudFlagsTable rows={[ROW_OPEN]} />);\n94\t\n95\t    // The full JSON payload round-trips so an operator can paste it. The\n96\t    // content lives inside a `<pre>` block — read its textContent rather than\n97\t    // relying on testing-library's whitespace-normalising getByText matcher.\n98\t    const pre = container.querySelector(\"pre\");\n99\t    expect(pre).not.toBeNull();\n100\t    const stringified = JSON.stringify(ROW_OPEN.details, null, 2);\n101\t    expect(pre?.textContent).toBe(stringified);\n102\t  });\n103\t\n104\t  it(\"populated: null details / wallet / relatedId / resolvedAt all render '—'\", () => {\n105\t    render(<FraudFlagsTable rows={[ROW_REVIEWED]} />);\n106\t\n107\t    // ROW_REVIEWED is null on wallet, relatedId, details, but reviewed has\n108\t    // resolvedAt set — so we expect at least 3 dashes from the sparse cells.\n109\t    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(3);\n110\t  });\n111\t\n112\t  it(\"read-only: no edit affordances rendered (no buttons, no editable inputs, no checkboxes)\", () => {\n113\t    // FR-14 keeps every fraud_flags status transition behind\n114\t    // `fraud_flag.status.update`. The table must not render any mutating\n115\t    // control — only the link to the user-detail drilldown is allowed.\n116\t    render(<FraudFlagsTable rows={[ROW_OPEN, ROW_REVIEWED, ROW_DISMISSED]} />);\n117\t\n118\t    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n119\t    expect(screen.queryByRole(\"textbox\")).toBeNull();\n120\t    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n121\t    // Links exist (drilldown only), but no submit/form actions.\n122\t    expect(screen.queryAllByRole(\"link\").length).toBeGreaterThan(0);\n123\t  });\n124\t\n125\t  it(\"empty: renders the operator status block when no flags exist\", () => {\n126\t    render(<FraudFlagsTable rows={[]} />);\n127\t\n128\t    const status = screen.getByRole(\"status\");\n129\t    expect(status).toHaveTextContent(\n130\t      \"No fraud_flags rows match these filters.\",\n131\t    );\n132\t    expect(screen.queryByRole(\"table\")).toBeNull();\n133\t  });\n134\t\n135\t  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n136\t    render(\n137\t      <FraudFlagsTable rows={[ROW_OPEN]} error=\"connection refused\" />,\n138\t    );\n139\t\n140\t    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n141\t      \"Fraud flags unavailable: connection refused\",\n142\t    );\n143\t    expect(screen.queryByRole(\"table\")).toBeNull();\n144\t    expect(screen.queryByRole(\"status\")).toBeNull();\n145\t  });\n146\t});\n147\t"}]},"parent_tool_use_id":null,"session_id":"031ce74d-15ee-4888-a00b-e081672f539b","uuid":"bdc0c124-a6bb-4fd8-bc77-249a8b2881da","timestamp":"2026-04-26T07:01:47.652Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/fraud-flags-table.test.tsx","content":"// Component tests for the FR-9 fraud flags review table.\n//\n// Read-only by spec — every fraud_flags status transition lives behind the\n// FR-14 `fraud_flag.status.update` action id (declared in\n// `peek/src/server/access-policy.ts`, not yet implemented). These tests assert\n// there are no edit affordances, every status drives the right chip tone, and\n// the JSONB `details` payload renders verbatim.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { FraudFlagsTable } from \"../fraud-flags-table\";\nimport type { PeekFraudFlagListRow } from \"../../lib/types/peek\";\n\nconst ROW_OPEN: PeekFraudFlagListRow = {\n  id: \"1\",\n  userId: \"user-1\",\n  username: \"alice\",\n  wallet: \"Wal1...\",\n  flagType: \"self_referral\",\n  status: \"open\",\n  relatedId: \"ref-9\",\n  details: { reason: \"loop\", referrer_id: \"ref-9\", attempts: 3 },\n  createdAt: \"2026-04-26T09:00:00.000Z\",\n  resolvedAt: null,\n};\n\nconst ROW_REVIEWED: PeekFraudFlagListRow = {\n  id: \"2\",\n  userId: \"user-2\",\n  username: null,\n  wallet: null,\n  flagType: \"rapid_signup\",\n  status: \"reviewed\",\n  relatedId: null,\n  details: null,\n  createdAt: \"2026-04-25T09:00:00.000Z\",\n  resolvedAt: \"2026-04-25T10:00:00.000Z\",\n};\n\nconst ROW_DISMISSED: PeekFraudFlagListRow = {\n  id: \"3\",\n  userId: \"user-3\",\n  username: \"carol\",\n  wallet: \"Wal3...\",\n  flagType: \"vpn\",\n  status: \"dismissed\",\n  relatedId: null,\n  details: { evidence: \"rotating_proxy\", checked_by: \"ops\" },\n  createdAt: \"2026-04-24T09:00:00.000Z\",\n  resolvedAt: \"2026-04-24T11:00:00.000Z\",\n};\n\ndescribe(\"FraudFlagsTable\", () => {\n  it(\"populated: renders the operator columns and every status chip variant\", () => {\n    render(\n      <FraudFlagsTable rows={[ROW_OPEN, ROW_REVIEWED, ROW_DISMISSED]} />,\n    );\n\n    for (const header of [\n      \"Status\",\n      \"Flag type\",\n      \"User\",\n      \"Wallet\",\n      \"Related\",\n      \"Details\",\n      \"Created\",\n      \"Resolved\",\n      \"ID\",\n    ]) {\n      expect(screen.getByText(header)).toBeInTheDocument();\n    }\n\n    // State transition coverage: open / reviewed / dismissed chips.\n    expect(screen.getByText(\"open\")).toBeInTheDocument();\n    expect(screen.getByText(\"reviewed\")).toBeInTheDocument();\n    expect(screen.getByText(\"dismissed\")).toBeInTheDocument();\n  });\n\n  it(\"populated: username links to /users/[userId] with the userId fallback when sparse\", () => {\n    render(\n      <FraudFlagsTable rows={[ROW_OPEN, ROW_REVIEWED]} />,\n    );\n\n    const aliceLink = screen.getByRole(\"link\", { name: \"alice\" });\n    expect(aliceLink).toHaveAttribute(\"href\", \"/users/user-1\");\n\n    // ROW_REVIEWED has username=null → fallback to userId on the link label.\n    const fallbackLink = screen.getByRole(\"link\", { name: \"user-2\" });\n    expect(fallbackLink).toHaveAttribute(\"href\", \"/users/user-2\");\n  });\n\n  it(\"populated: JSONB details column renders verbatim inside a <pre> block\", () => {\n    const { container } = render(<FraudFlagsTable rows={[ROW_OPEN]} />);\n\n    // The full JSON payload round-trips so an operator can paste it. The\n    // content lives inside a `<pre>` block — read its textContent rather than\n    // relying on testing-library's whitespace-normalising getByText matcher.\n    const pre = container.querySelector(\"pre\");\n    expect(pre).not.toBeNull();\n    const stringified = JSON.stringify(ROW_OPEN.details, null, 2);\n    expect(pre?.textContent).toBe(stringified);\n  });\n\n  it(\"populated: null details / wallet / relatedId / resolvedAt all render '—'\", () => {\n    render(<FraudFlagsTable rows={[ROW_REVIEWED]} />);\n\n    // ROW_REVIEWED is null on wallet, relatedId, details, but reviewed has\n    // resolvedAt set — so we expect at least 3 dashes from the sparse cells.\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(3);\n  });\n\n  it(\"read-only: no edit affordances rendered (no buttons, no editable inputs, no checkboxes)\", () => {\n    // FR-14 keeps every fraud_flags status transition behind\n    // `fraud_flag.status.update`. The table must not render any mutating\n    // control — only the link to the user-detail drilldown is allowed.\n    render(<FraudFlagsTable rows={[ROW_OPEN, ROW_REVIEWED, ROW_DISMISSED]} />);\n\n    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n    expect(screen.queryByRole(\"textbox\")).toBeNull();\n    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n    // Links exist (drilldown only), but no submit/form actions.\n    expect(screen.queryAllByRole(\"link\").length).toBeGreaterThan(0);\n  });\n\n  it(\"empty: renders the operator status block when no flags exist\", () => {\n    render(<FraudFlagsTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\n      \"No fraud_flags rows match these filters.\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n    render(\n      <FraudFlagsTable rows={[ROW_OPEN]} error=\"connection refused\" />,\n    );\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Fraud flags unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n","numLines":147,"startLine":1,"totalLines":147}}}
