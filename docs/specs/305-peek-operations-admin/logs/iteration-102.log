{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013nTa4ZtXu5gryXZAhEuqKP","type":"tool_result","content":"1\t// Query tests for the FR-9 points + crates economy admin reads\n2\t// (`get-points-and-crates.ts`).\n3\t//\n4\t// Mirrors the SQL-mock pattern from `get-rewards.test.ts` and\n5\t// `get-growth-referrals.test.ts`: a tagged-template stub records each call\n6\t// (joined SQL text + bound values) and dequeues a per-call response so each\n7\t// test can assert which SQL fired, in what order, and with which clamps.\n8\t\n9\timport { describe, expect, it } from \"vitest\";\n10\timport type { Sql } from \"postgres\";\n11\timport {\n12\t  PEEK_CRATE_DROPS_DEFAULT_LIMIT,\n13\t  PEEK_CRATE_DROPS_MAX_LIMIT,\n14\t  PEEK_PLAYER_POINTS_DEFAULT_LIMIT,\n15\t  PEEK_PLAYER_POINTS_MAX_LIMIT,\n16\t  PEEK_POINT_GRANTS_DEFAULT_LIMIT,\n17\t  PEEK_POINT_GRANTS_MAX_LIMIT,\n18\t  listCrateDrops,\n19\t  listPlayerPoints,\n20\t  listPointGrants,\n21\t} from \"../get-points-and-crates\";\n22\t\n23\ttype SqlCall = {\n24\t  text: string;\n25\t  values: ReadonlyArray<unknown>;\n26\t};\n27\t\n28\ttype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n29\t\n30\ttype SqlMock = {\n31\t  sql: Sql;\n32\t  calls: ReadonlyArray<SqlCall>;\n33\t};\n34\t\n35\tfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n36\t  const calls: SqlCall[] = [];\n37\t  let cursor = 0;\n38\t\n39\t  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n40\t    const text = [...strings].join(\"?\");\n41\t    calls.push({ text, values: [...values] });\n42\t    const next = responses[cursor++];\n43\t    if (next instanceof Error) return Promise.reject(next);\n44\t    return Promise.resolve(next ?? []);\n45\t  };\n46\t\n47\t  const sql = fn as unknown as Sql;\n48\t  return { sql, calls };\n49\t}\n50\t\n51\tdescribe(\"listPlayerPoints\", () => {\n52\t  it(\"default limit: clamps to PEEK_PLAYER_POINTS_DEFAULT_LIMIT and reads from player_points joined with player_profiles\", async () => {\n53\t    const mock = createSqlMock([[]]);\n54\t    await listPlayerPoints({ sql: mock.sql });\n55\t\n56\t    expect(mock.calls).toHaveLength(1);\n57\t    const call = mock.calls[0];\n58\t    expect(call.text).toMatch(/from player_points pp/i);\n59\t    expect(call.text).toMatch(\n60\t      /left join player_profiles prof on prof\\.user_id = pp\\.user_id/i,\n61\t    );\n62\t    expect(call.text).toMatch(/order by pp\\.balance desc, pp\\.user_id asc/i);\n63\t    expect(call.values).toContain(PEEK_PLAYER_POINTS_DEFAULT_LIMIT);\n64\t  });\n65\t\n66\t  it(\"explicit limit: passes the caller value through clampLimit\", async () => {\n67\t    const mock = createSqlMock([[]]);\n68\t    await listPlayerPoints({ sql: mock.sql, limit: 25 });\n69\t    expect(mock.calls[0].values).toContain(25);\n70\t  });\n71\t\n72\t  it(\"limit clamps to MAX when caller asks for more\", async () => {\n73\t    const mock = createSqlMock([[]]);\n74\t    await listPlayerPoints({\n75\t      sql: mock.sql,\n76\t      limit: PEEK_PLAYER_POINTS_MAX_LIMIT + 100,\n77\t    });\n78\t    expect(mock.calls[0].values).toContain(PEEK_PLAYER_POINTS_MAX_LIMIT);\n79\t  });\n80\t\n81\t  it(\"non-positive limit clamps to 1\", async () => {\n82\t    const mock = createSqlMock([[]]);\n83\t    await listPlayerPoints({ sql: mock.sql, limit: 0 });\n84\t    expect(mock.calls[0].values).toContain(1);\n85\t  });\n86\t\n87\t  it(\"non-finite limit falls back to the default\", async () => {\n88\t    const mock = createSqlMock([[]]);\n89\t    await listPlayerPoints({ sql: mock.sql, limit: Number.NaN });\n90\t    expect(mock.calls[0].values).toContain(PEEK_PLAYER_POINTS_DEFAULT_LIMIT);\n91\t  });\n92\t\n93\t  it(\"filters: empty filters bind null sentinels so the where-clause skips both predicates\", async () => {\n94\t    const mock = createSqlMock([[]]);\n95\t    await listPlayerPoints({ sql: mock.sql, filters: {} });\n96\t\n97\t    // The query uses (${userId === null} or pp.user_id = ${userId ?? \"\"}) so\n98\t    // when both are null, two `true` sentinels and two empty-string placeholders\n99\t    // are bound.\n100\t    expect(mock.calls[0].values).toContain(true);\n101\t    expect(mock.calls[0].values).toContain(\"\");\n102\t  });\n103\t\n104\t  it(\"filters: non-empty user_id and wallet bind their values verbatim\", async () => {\n105\t    const mock = createSqlMock([[]]);\n106\t    await listPlayerPoints({\n107\t      sql: mock.sql,\n108\t      filters: { userId: \"user-1\", wallet: \"WALLET123\" },\n109\t    });\n110\t    const values = mock.calls[0].values;\n111\t    expect(values).toContain(\"user-1\");\n112\t    expect(values).toContain(\"WALLET123\");\n113\t    // Both predicates are now active, so the `(${null}) || ...` toggles are false.\n114\t    expect(values).toContain(false);\n115\t  });\n116\t\n117\t  it(\"filters: whitespace-only filter values normalize to null\", async () => {\n118\t    const mock = createSqlMock([[]]);\n119\t    await listPlayerPoints({\n120\t      sql: mock.sql,\n121\t      filters: { userId: \"   \", wallet: \"\" },\n122\t    });\n123\t    // Both filters become null → both toggles become `true`.\n124\t    const values = mock.calls[0].values;\n125\t    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(2);\n126\t  });\n127\t\n128\t  it(\"populated: returns rows verbatim — bigint balances are passed through as text\", async () => {\n129\t    const row = {\n130\t      userId: \"user-1\",\n131\t      username: \"alice\",\n132\t      wallet: \"WALLET123\",\n133\t      balance: \"9007199254740993\", // larger than Number.MAX_SAFE_INTEGER\n134\t      lifetimeEarned: \"9007199254740993\",\n135\t      updatedAt: \"2026-04-25T10:00:00.000Z\",\n136\t    };\n137\t    const mock = createSqlMock([[row]]);\n138\t\n139\t    const rows = await listPlayerPoints({ sql: mock.sql });\n140\t    expect(rows).toEqual([row]);\n141\t    // `balance` round-trips as `string`, preserving precision the JS Number type\n142\t    // would lose.\n143\t    expect(typeof rows[0].balance).toBe(\"string\");\n144\t    expect(rows[0].balance).toBe(\"9007199254740993\");\n145\t  });\n146\t\n147\t  it(\"sparse: an empty result set returns []\", async () => {\n148\t    const mock = createSqlMock([[]]);\n149\t    const rows = await listPlayerPoints({ sql: mock.sql });\n150\t    expect(rows).toEqual([]);\n151\t  });\n152\t\n153\t  it(\"load-error: a rejected query propagates\", async () => {\n154\t    const mock = createSqlMock([new Error(\"connection refused\")]);\n155\t    await expect(listPlayerPoints({ sql: mock.sql })).rejects.toThrowError(\n156\t      \"connection refused\",\n157\t    );\n158\t  });\n159\t});\n160\t\n161\tdescribe(\"listPointGrants\", () => {\n162\t  it(\"default limit: clamps to PEEK_POINT_GRANTS_DEFAULT_LIMIT and reads from point_grants joined with player_profiles\", async () => {\n163\t    const mock = createSqlMock([[]]);\n164\t    await listPointGrants({ sql: mock.sql });\n165\t\n166\t    expect(mock.calls).toHaveLength(1);\n167\t    const call = mock.calls[0];\n168\t    expect(call.text).toMatch(/from point_grants pg/i);\n169\t    expect(call.text).toMatch(\n170\t      /left join player_profiles prof on prof\\.user_id = pg\\.user_id/i,\n171\t    );\n172\t    expect(call.text).toMatch(/order by pg\\.created_at desc, pg\\.id desc/i);\n173\t    expect(call.values).toContain(PEEK_POINT_GRANTS_DEFAULT_LIMIT);\n174\t  });\n175\t\n176\t  it(\"limit clamps to MAX when caller asks for more\", async () => {\n177\t    const mock = createSqlMock([[]]);\n178\t    await listPointGrants({\n179\t      sql: mock.sql,\n180\t      limit: PEEK_POINT_GRANTS_MAX_LIMIT + 999,\n181\t    });\n182\t    expect(mock.calls[0].values).toContain(PEEK_POINT_GRANTS_MAX_LIMIT);\n183\t  });\n184\t\n185\t  it(\"filters: every supported filter (userId, sourceType, sourceId, createdFrom, createdTo) flows into bound values\", async () => {\n186\t    const mock = createSqlMock([[]]);\n187\t    await listPointGrants({\n188\t      sql: mock.sql,\n189\t      filters: {\n190\t        userId: \"user-9\",\n191\t        sourceType: \"challenge_completed\",\n192\t        sourceId: \"challenge-7\",\n193\t        createdFrom: \"2026-04-01\",\n194\t        createdTo: \"2026-04-26\",\n195\t      },\n196\t    });\n197\t    const values = mock.calls[0].values;\n198\t    expect(values).toContain(\"user-9\");\n199\t    expect(values).toContain(\"challenge_completed\");\n200\t    expect(values).toContain(\"challenge-7\");\n201\t    expect(values).toContain(\"2026-04-01\");\n202\t    expect(values).toContain(\"2026-04-26\");\n203\t  });\n204\t\n205\t  it(\"filters: empty filters bind null sentinels so all predicates are skipped\", async () => {\n206\t    const mock = createSqlMock([[]]);\n207\t    await listPointGrants({ sql: mock.sql, filters: {} });\n208\t    const values = mock.calls[0].values;\n209\t    // 5 filters → 5 `true` sentinels (one per predicate).\n210\t    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(5);\n211\t  });\n212\t\n213\t  it(\"filters: createdFrom/createdTo are cast to timestamptz\", async () => {\n214\t    const mock = createSqlMock([[]]);\n215\t    await listPointGrants({\n216\t      sql: mock.sql,\n217\t      filters: { createdFrom: \"2026-04-01\", createdTo: \"2026-04-26\" },\n218\t    });\n219\t    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n220\t  });\n221\t\n222\t  it(\"populated: bigint amounts round-trip as text\", async () => {\n223\t    const row = {\n224\t      id: \"1001\",\n225\t      userId: \"user-1\",\n226\t      username: \"alice\",\n227\t      wallet: \"WALLET123\",\n228\t      sourceType: \"wager\",\n229\t      sourceId: \"round-42\",\n230\t      amount: \"12345678901234567\",\n231\t      createdAt: \"2026-04-25T10:00:00.000Z\",\n232\t    };\n233\t    const mock = createSqlMock([[row]]);\n234\t    const rows = await listPointGrants({ sql: mock.sql });\n235\t    expect(rows).toEqual([row]);\n236\