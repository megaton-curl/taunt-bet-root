{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XQ72gC54qW7zHKa5uETfKY","type":"tool_result","content":"1\t// /operations/queue — Event queue admin page (FR-10).\n2\t//\n3\t// Reads `event_queue` (migration 009) via `get-event-queue.ts` and composes:\n4\t//\n5\t//   - Metric strip   — pending / processing / failed / dead / at_max_attempts\n6\t//                      / aged_pending. Failed and dead counts double as the\n7\t//                      attention links called out by FR-10 (drilldown to\n8\t//                      `?status=failed` / `?status=dead`).\n9\t//   - Status + type breakdown — full status distribution and the top 50\n10\t//                      event types by frequency, so an operator can see which\n11\t//                      event_type is generating the dead/failed pile.\n12\t//   - Filter bar     — status, event type, id, payload user id, scheduled +\n13\t//                      created date windows, age bucket. URL-addressable\n14\t//                      (`queueFilter*`).\n15\t//   - Filtered table — bounded list with a row-level link that sets\n16\t//                      `?selectedId=<id>` to open the detail panel.\n17\t//   - Detail panel   — full payload rendered with secret redaction applied\n18\t//                      server-side (`redactJsonValue` / `redactNullableString`\n19\t//                      from the audit module).\n20\t//\n21\t// Read-only — retry / cancel / replay are explicitly out of scope (FR-10\n22\t// line 342) and live behind a future mutation spec.\n23\timport type { CSSProperties } from \"react\";\n24\timport { EventQueueDetailPanel } from \"../../../src/components/event-queue-detail-panel\";\n25\timport { EventQueueFilterBar } from \"../../../src/components/event-queue-filter-bar\";\n26\timport { EventQueueTable } from \"../../../src/components/event-queue-table\";\n27\timport { MetricStrip } from \"../../../src/components/metric-strip\";\n28\timport {\n29\t  normalizeEventQueueFiltersFromSearchParams,\n30\t  readSelectedQueueIdFromSearchParams,\n31\t} from \"../../../src/lib/operations-queue-search-params\";\n32\timport type {\n33\t  PeekEventQueueDetail,\n34\t  PeekEventQueueListRow,\n35\t  PeekEventQueueOverview,\n36\t} from \"../../../src/lib/types/peek\";\n37\timport {\n38\t  getPeekActorContext,\n39\t  isRouteAllowedForRole,\n40\t} from \"../../../src/server/access-policy\";\n41\timport {\n42\t  PEEK_EVENT_QUEUE_DEFAULT_LIMIT,\n43\t  getEventQueueDetail,\n44\t  getEventQueueOverview,\n45\t  listEventQueue,\n46\t} from \"../../../src/server/db/queries/get-event-queue\";\n47\t\n48\texport const dynamic = \"force-dynamic\";\n49\t\n50\tconst ROUTE = \"/operations/queue\";\n51\t\n52\texport default async function OperationsQueuePage({\n53\t  searchParams,\n54\t}: {\n55\t  searchParams: Promise<Record<string, string | string[] | undefined>>;\n56\t}) {\n57\t  const actor = await getPeekActorContext();\n58\t  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n59\t\n60\t  if (!allowed) {\n61\t    return (\n62\t      <main style={mainStyle}>\n63\t        <header>\n64\t          <h1>Operations · Event queue</h1>\n65\t        </header>\n66\t        <p role=\"alert\" style={errorStyle}>\n67\t          You do not have access to this page.\n68\t        </p>\n69\t      </main>\n70\t    );\n71\t  }\n72\t\n73\t  const params = await searchParams;\n74\t  const filters = normalizeEventQueueFiltersFromSearchParams(params);\n75\t  const selectedId = readSelectedQueueIdFromSearchParams(params);\n76\t\n77\t  let overview: PeekEventQueueOverview = {\n78\t    generatedAt: new Date().toISOString(),\n79\t    metrics: [],\n80\t    statusCounts: [],\n81\t    typeCounts: [],\n82\t    ageBuckets: [],\n83\t  };\n84\t  let rows: ReadonlyArray<PeekEventQueueListRow> = [];\n85\t  let detail: PeekEventQueueDetail | null = null;\n86\t  let detailNotFound = false;\n87\t\n88\t  let overviewError: string | null = null;\n89\t  let rowsError: string | null = null;\n90\t  let detailError: string | null = null;\n91\t\n92\t  try {\n93\t    overview = await getEventQueueOverview();\n94\t  } catch (error) {\n95\t    overviewError =\n96\t      error instanceof Error\n97\t        ? error.message\n98\t        : \"Event queue overview could not be loaded.\";\n99\t  }\n100\t\n101\t  try {\n102\t    rows = await listEventQueue({ filters });\n103\t  } catch (error) {\n104\t    rowsError =\n105\t      error instanceof Error\n106\t        ? error.message\n107\t        : \"Event queue rows could not be loaded.\";\n108\t  }\n109\t\n110\t  if (selectedId !== null) {\n111\t    try {\n112\t      detail = await getEventQueueDetail({ id: selectedId });\n113\t      detailNotFound = detail === null;\n114\t    } catch (error) {\n115\t      detailError =\n116\t        error instanceof Error\n117\t          ? error.message\n118\t          : \"Event queue detail could not be loaded.\";\n119\t    }\n120\t  }\n121\t\n122\t  return (\n123\t    <main style={mainStyle}>\n124\t      <header>\n125\t        <h1>Operations · Event queue</h1>\n126\t        <p style={leadStyle}>\n127\t          Async work tracking from <code>event_queue</code>. Read-only —\n128\t          retry, cancel, and replay actions are out of scope for this spec.\n129\t          Failed and dead events are surfaced both as attention links in the\n130\t          metric strip and as filter chips below.\n131\t        </p>\n132\t      </header>\n133\t\n134\t      <section aria-labelledby=\"overview-heading\">\n135\t        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n136\t          Overview\n137\t        </h2>\n138\t        <MetricStrip metrics={overview.metrics} error={overviewError} />\n139\t      </section>\n140\t\n141\t      <section aria-labelledby=\"breakdown-heading\" style={sectionStyle}>\n142\t        <h2 id=\"breakdown-heading\" style={sectionHeadingStyle}>\n143\t          Status &amp; type breakdown\n144\t        </h2>\n145\t        <div style={breakdownGridStyle}>\n146\t          <BreakdownCard\n147\t            heading=\"Status\"\n148\t            empty=\"No events yet.\"\n149\t            rows={overview.statusCounts.map((row) => ({\n150\t              key: row.status,\n151\t              left: row.status,\n152\t              right: row.count.toLocaleString(\"en-US\"),\n153\t            }))}\n154\t          />\n155\t          <BreakdownCard\n156\t            heading=\"Top event types\"\n157\t            empty=\"No events yet.\"\n158\t            rows={overview.typeCounts.map((row) => ({\n159\t              key: row.eventType,\n160\t              left: row.eventType,\n161\t              right: row.count.toLocaleString(\"en-US\"),\n162\t            }))}\n163\t          />\n164\t          <BreakdownCard\n165\t            heading=\"Age buckets\"\n166\t            empty=\"No events yet.\"\n167\t            rows={overview.ageBuckets.map((row) => ({\n168\t              key: row.id,\n169\t              left: row.label,\n170\t              right: row.count.toLocaleString(\"en-US\"),\n171\t            }))}\n172\t          />\n173\t        </div>\n174\t      </section>\n175\t\n176\t      <section\n177\t        aria-labelledby=\"rows-heading\"\n178\t        id=\"rows\"\n179\t        style={sectionStyle}\n180\t      >\n181\t        <h2 id=\"rows-heading\" style={sectionHeadingStyle}>\n182\t          Filtered events\n183\t        </h2>\n184\t        <p style={hintStyle}>\n185\t          Default {PEEK_EVENT_QUEUE_DEFAULT_LIMIT} rows · sorted newest first\n186\t          · server-side capped. Filter by status, event type, event id,\n187\t          payload user id, age bucket, and scheduled / created date windows.\n188\t          Click an id to open the redacted payload.\n189\t        </p>\n190\t        <EventQueueFilterBar filters={filters} action={ROUTE} />\n191\t        <div style={listAndDetailStyle}>\n192\t          <EventQueueTable\n193\t            rows={rows}\n194\t            selectedId={selectedId}\n195\t            error={rowsError}\n196\t          />\n197\t          <EventQueueDetailPanel\n198\t            detail={detail}\n199\t            selectedId={selectedId}\n200\t            notFound={detailNotFound}\n201\t            error={detailError}\n202\t          />\n203\t        </div>\n204\t      </section>\n205\t    </main>\n206\t  );\n207\t}\n208\t\n209\ttype BreakdownCardProps = {\n210\t  heading: string;\n211\t  empty: string;\n212\t  rows: ReadonlyArray<{ key: string; left: string; right: string }>;\n213\t};\n214\t\n215\tfunction BreakdownCard({ heading, empty, rows }: BreakdownCardProps) {\n216\t  return (\n217\t    <article style={breakdownCardStyle}>\n218\t      <h3 style={breakdownHeadingStyle}>{heading}</h3>\n219\t      {rows.length === 0 ? (\n220\t        <p style={breakdownEmptyStyle}>{empty}</p>\n221\t      ) : (\n222\t        <ul style={breakdownListStyle}>\n223\t          {rows.map((row) => (\n224\t            <li key={row.key} style={breakdownRowStyle}>\n225\t              <span style={breakdownLeftStyle}>{row.left}</span>\n226\t              <span style={breakdownRightStyle}>{row.right}</span>\n227\t            </li>\n228\t          ))}\n229\t        </ul>\n230\t      )}\n231\t    </article>\n232\t  );\n233\t}\n234\t\n235\tconst mainStyle: CSSProperties = {\n236\t  display: \"grid\",\n237\t  gap: \"1.5rem\",\n238\t};\n239\t\n240\tconst sectionStyle: CSSProperties = {\n241\t  display: \"grid\",\n242\t  gap: \"0.75rem\",\n243\t};\n244\t\n245\tconst sectionHeadingStyle: CSSProperties = {\n246\t  margin: \"0 0 0.75rem\",\n247\t  fontSize: \"1rem\",\n248\t  fontWeight: 600,\n249\t  color: \"#cbd5f5\",\n250\t  textTransform: \"uppercase\",\n251\t  letterSpacing: \"0.05em\",\n252\t};\n253\t\n254\tconst leadStyle: CSSProperties = {\n255\t  margin: \"0.25rem 0 0\",\n256\t  color: \"#94a3b8\",\n257\t};\n258\t\n259\tconst hintStyle: CSSProperties = {\n260\t  margin: 0,\n261\t  color: \"#94a3b8\",\n262\t  fontSize: \"0.8125rem\",\n263\t};\n264\t\n265\tconst errorStyle: CSSProperties = {\n266\t  margin: 0,\n267\t  padding: \"0.75rem 1rem\",\n268\t  borderRadius: \"0.75rem\",\n269\t  background: \"#3f1d1d\",\n270\t  color: \"#fecaca\",\n271\t};\n272\t\n273\tconst listAndDetailStyle: CSSProperties = {\n274\t  display: \"grid\",\n275\t  gap: \"1rem\",\n276\t  gridTemplateColumns: \"minmax(0, 2fr) minmax(0, 1fr)\",\n277\t  alignItems: \"start\",\n278\t};\n279\t\n280\tconst breakdownGridStyle: CSSProperties = {\n281\t  display: \"grid\",\n282\t  gap: \"1rem\",\n283\t  gridTemplateColumns: \"repeat(auto-fit, minmax(220px, 1fr))\",\n284\t};\n285\t\n286\tconst breakdownCardStyle: CSSProperties = {\n287\t  border: \"1px solid #1e293b\",\n288\t  borderRadius: \"0.75rem\",\n289\t  padding: \"1rem\",\n290\t  background: \"#111827\",\n291\t  display: \"grid\",\n292\t  gap: \"0.5rem\",\n293\t};\n294\t\n295\tconst breakdownHeadingStyle: CSSProperties = {\n296\t  margin: 0,\n297\t  fontSize: \"0.875rem\",\n298\t  fontWeight: 600,\n299\t  color: \"#cbd5f5\",\n300\t};\n301\t\n302\tconst breakdownEmptyStyle: CSSProperties = {\n303\t  margin: 0,\n304\t  fontSize: \"0.8125rem\",\n305\t  color: \"#94a3b8\",\n306\t};\n307\t\n308\tconst breakdownListStyle: CSSProperties = {\n309\t  margin: 0,\n310\t  padding: 0,\n311\t  listStyle: \"none\",\n312\t  display: \"grid\",\n313\t  gap: \"0.25rem\",\n314\t};\n315\t\n316\tconst breakdownRowStyle: CSSProperties = {\n317\t  display: \"flex\",\n318\t  justifyContent: \"space-between\",\n319\t  fontSize: \"0.8125rem\",\n320\t  color: \"#e2e8f0\",\n321\t};\n322\t\n323\tconst breakdownLeftStyle: CSSProperties = {\n324\t  fontFamily: \"monospace\",\n325\t  color: \"#cbd5f5\",\n326\t};\n327\t\n328\tconst breakdownRightStyle: CSSProperties = {\n329\t  fontFamily: \"monospace\",\n330\t  color: \"#94a3b8\",\n331\t};\n332\t"}]},"parent_tool_use_id":null,"session_id":"031ce74d-15ee-4888-a00b-e081672f539b","uuid":"02b72cea-a1a7-4b64-8aa9-31ec9f137ad7","timestamp":"2026-04-26T07:00:42.395Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/app/operations/queue/page.tsx","content":"// /operations/queue — Event queue admin page (FR-10).\n//\n// Reads `event_queue` (migration 009) via `get-event-queue.ts` and composes:\n//\n//   - Metric strip   — pending / processing / failed / dead / at_max_attempts\n//                      / aged_pending. Failed and dead counts double as the\n//                      attention links called out by FR-10 (drilldown to\n//                      `?status=failed` / `?status=dead`).\n//   - Status + type breakdown — full status distribution and the top 50\n//                      event types by frequency, so an operator can see which\n//                      event_type is generating the dead/failed pile.\n//   - Filter bar     — status, event type, id, payload user id, scheduled +\n//                      created date windows, age bucket. URL-addressable\n//                      (`queueFilter*`).\n//   - Filtered table — bounded list with a row-level link that sets\n//                      `?selectedId=<id>` to open the detail panel.\n//   - Detail panel   — full payload rendered with secret redaction applied\n//                      server-side (`redactJsonValue` / `redactNullableString`\n//                      from the audit module).\n//\n// Read-only — retry / cancel / replay are explicitly out of scope (FR-10\n// line 342) and live behind a future mutation spec.\nimport type { CSSProperties } from \"react\";\nimport { EventQueueDetailPanel } from \"../../../src/components/event-queue-detail-panel\";\nimport { EventQueueFilterBar } from \"../../../src/components/event-queue-filter-bar\";\nimport { EventQueueTable } from \"../../../src/components/event-queue-table\";\nimport { MetricStrip } from \"../../../src/components/metric-strip\";\nimport {\n  normalizeEventQueueFiltersFromSearchParams,\n  readSelectedQueueIdFromSearchParams,\n} from \"../../../src/lib/operations-queue-search-params\";\nimport type {\n  PeekEventQueueDetail,\n  PeekEventQueueListRow,\n  PeekEventQueueOverview,\n} from \"../../../src/lib/types/peek\";\nimport {\n  getPeekActorContext,\n  isRouteAllowedForRole,\n} from \"../../../src/server/access-policy\";\nimport {\n  PEEK_EVENT_QUEUE_DEFAULT_LIMIT,\n  getEventQueueDetail,\n  getEventQueueOverview,\n  listEventQueue,\n} from \"../../../src/server/db/queries/get-event-queue\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst ROUTE = \"/operations/queue\";\n\nexport default async function OperationsQueuePage({\n  searchParams,\n}: {\n  searchParams: Promise<Record<string, string | string[] | undefined>>;\n}) {\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n\n  if (!allowed) {\n    return (\n      <main style={mainStyle}>\n        <header>\n          <h1>Operations · Event queue</h1>\n        </header>\n        <p role=\"alert\" style={errorStyle}>\n          You do not have access to this page.\n        </p>\n      </main>\n    );\n  }\n\n  const params = await searchParams;\n  const filters = normalizeEventQueueFiltersFromSearchParams(params);\n  const selectedId = readSelectedQueueIdFromSearchParams(params);\n\n  let overview: PeekEventQueueOverview = {\n    generatedAt: new Date().toISOString(),\n    metrics: [],\n    statusCounts: [],\n    typeCounts: [],\n    ageBuckets: [],\n  };\n  let rows: ReadonlyArray<PeekEventQueueListRow> = [];\n  let detail: PeekEventQueueDetail | null = null;\n  let detailNotFound = false;\n\n  let overviewError: string | null = null;\n  let rowsError: string | null = null;\n  let detailError: string | null = null;\n\n  try {\n    overview = await getEventQueueOverview();\n  } catch (error) {\n    overviewError =\n      error instanceof Error\n        ? error.message\n        : \"Event queue overview could not be loaded.\";\n  }\n\n  try {\n    rows = await listEventQueue({ filters });\n  } catch (error) {\n    rowsError =\n      error instanceof Error\n        ? error.message\n        : \"Event queue rows could not be loaded.\";\n  }\n\n  if (selectedId !== null) {\n    try {\n      detail = await getEventQueueDetail({ id: selectedId });\n      detailNotFound = detail === null;\n    } catch (error) {\n      detailError =\n        error instanceof Error\n          ? error.message\n          : \"Event queue detail could not be loaded.\";\n    }\n  }\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <h1>Operations · Event queue</h1>\n        <p style={leadStyle}>\n          Async work tracking from <code>event_queue</code>. Read-only —\n          retry, cancel, and replay actions are out of scope for this spec.\n          Failed and dead events are surfaced both as attention links in the\n          metric strip and as filter chips below.\n        </p>\n      </header>\n\n      <section aria-labelledby=\"overview-heading\">\n        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n          Overview\n        </h2>\n        <MetricStrip metrics={overview.metrics} error={overviewError} />\n      </section>\n\n      <section aria-labelledby=\"breakdown-heading\" style={sectionStyle}>\n        <h2 id=\"breakdown-heading\" style={sectionHeadingStyle}>\n          Status &amp; type breakdown\n        </h2>\n        <div style={breakdownGridStyle}>\n          <BreakdownCard\n            heading=\"Status\"\n            empty=\"No events yet.\"\n            rows={overview.statusCounts.map((row) => ({\n              key: row.status,\n              left: row.status,\n              right: row.count.toLocaleString(\"en-US\"),\n            }))}\n          />\n          <BreakdownCard\n            heading=\"Top event types\"\n            empty=\"No events yet.\"\n            rows={overview.typeCounts.map((row) => ({\n              key: row.eventType,\n              left: row.eventType,\n              right: row.count.toLocaleString(\"en-US\"),\n            }))}\n          />\n          <BreakdownCard\n            heading=\"Age buckets\"\n            empty=\"No events yet.\"\n            rows={overview.ageBuckets.map((row) => ({\n              key: row.id,\n              left: row.label,\n              right: row.count.toLocaleString(\"en-US\"),\n            }))}\n          />\n        </div>\n      </section>\n\n      <section\n        aria-labelledby=\"rows-heading\"\n        id=\"rows\"\n        style={sectionStyle}\n      >\n        <h2 id=\"rows-heading\" style={sectionHeadingStyle}>\n          Filtered events\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_EVENT_QUEUE_DEFAULT_LIMIT} rows · sorted newest first\n          · server-side capped. Filter by status, event type, event id,\n          payload user id, age bucket, and scheduled / created date windows.\n          Click an id to open the redacted payload.\n        </p>\n        <EventQueueFilterBar filters={filters} action={ROUTE} />\n        <div style={listAndDetailStyle}>\n          <EventQueueTable\n            rows={rows}\n            selectedId={selectedId}\n            error={rowsError}\n          />\n          <EventQueueDetailPanel\n            detail={detail}\n            selectedId={selectedId}\n            notFound={detailNotFound}\n            error={detailError}\n          />\n        </div>\n      </section>\n    </main>\n  );\n}\n\ntype BreakdownCardProps = {\n  heading: string;\n  empty: string;\n  rows: ReadonlyArray<{ key: string; left: string; right: string }>;\n};\n\nfunction BreakdownCard({ heading, empty, rows }: BreakdownCardProps) {\n  return (\n    <article style={breakdownCardStyle}>\n      <h3 style={breakdownHeadingStyle}>{heading}</h3>\n      {rows.length === 0 ? (\n        <p style={breakdownEmptyStyle}>{empty}</p>\n      ) : (\n        <ul style={breakdownListStyle}>\n          {rows.map((row) => (\n            <li key={row.key} style={breakdownRowStyle}>\n              <span style={breakdownLeftStyle}>{row.left}</span>\n              <span style={breakdownRightStyle}>{row.right}</span>\n            </li>\n          ))}\n        </ul>\n      )}\n    </article>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst listAndDetailStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1rem\",\n  gridTemplateColumns: \"minmax(0, 2fr) minmax(0, 1fr)\",\n  alignItems: \"start\",\n};\n\nconst breakdownGridStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1rem\",\n  gridTemplateColumns: \"repeat(auto-fit, minmax(220px, 1fr))\",\n};\n\nconst breakdownCardStyle: CSSProperties = {\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n  padding: \"1rem\",\n  background: \"#111827\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst breakdownHeadingStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n};\n\nconst breakdownEmptyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.8125rem\",\n  color: \"#94a3b8\",\n};\n\nconst breakdownListStyle: CSSProperties = {\n  margin: 0,\n  padding: 0,\n  listStyle: \"none\",\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst breakdownRowStyle: CSSProperties = {\n  display: \"flex\",\n  justifyContent: \"space-between\",\n  fontSize: \"0.8125rem\",\n  color: \"#e2e8f0\",\n};\n\nconst breakdownLeftStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  color: \"#cbd5f5\",\n};\n\nconst breakdownRightStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  color: \"#94a3b8\",\n};\n","numLines":332,"startLine":1,"totalLines":332}}}
