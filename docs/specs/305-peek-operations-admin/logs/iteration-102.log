{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T4A28J3AP8aHYDPGBU3BXN","type":"tool_result","content":"1\t// Event queue detail panel for /operations/queue (FR-10).\n2\t//\n3\t// Renders one `PeekEventQueueDetail` row alongside the event queue list when\n4\t// `?selectedId=<id>` is on the URL. The payload + error fields have already\n5\t// been redacted server-side via the audit redactor — `looksLikeSecret` strings\n6\t// are replaced with the `PEEK_AUDIT_REDACTED` marker before reaching this\n7\t// component (see `peek/src/server/db/queries/get-event-queue.ts`). This view\n8\t// re-renders the redacted JSON verbatim so an operator can confirm a secret\n9\t// was not leaked, but cannot see the original value.\n10\t//\n11\t// Read-only — retry / cancel / replay actions are explicitly out of scope\n12\t// (FR-10 line 342). No buttons or editable inputs are rendered.\n13\timport Link from \"next/link\";\n14\timport type { CSSProperties } from \"react\";\n15\timport type {\n16\t  PeekEventQueueDetail,\n17\t  PeekStatusTone,\n18\t} from \"../lib/types/peek\";\n19\timport { StatusChip } from \"./status-chip\";\n20\t\n21\texport type EventQueueDetailPanelProps = {\n22\t  detail: PeekEventQueueDetail | null;\n23\t  selectedId: string | null;\n24\t  notFound?: boolean;\n25\t  error?: string | null;\n26\t};\n27\t\n28\texport function EventQueueDetailPanel({\n29\t  detail,\n30\t  selectedId,\n31\t  notFound = false,\n32\t  error = null,\n33\t}: EventQueueDetailPanelProps) {\n34\t  if (error) {\n35\t    return (\n36\t      <aside aria-label=\"Event queue detail\" style={errorStyle} role=\"alert\">\n37\t        Detail unavailable: {error}\n38\t      </aside>\n39\t    );\n40\t  }\n41\t\n42\t  if (selectedId === null) {\n43\t    return (\n44\t      <aside aria-label=\"Event queue detail\" style={hintStyle} role=\"status\">\n45\t        Select a row id to load the full payload.\n46\t      </aside>\n47\t    );\n48\t  }\n49\t\n50\t  if (!detail) {\n51\t    return (\n52\t      <aside aria-label=\"Event queue detail\" style={hintStyle} role=\"status\">\n53\t        {notFound\n54\t          ? `No event_queue row matches id ${selectedId}.`\n55\t          : \"Loading detail…\"}\n56\t      </aside>\n57\t    );\n58\t  }\n59\t\n60\t  return (\n61\t    <aside aria-label=\"Event queue detail\" style={panelStyle}>\n62\t      <header style={panelHeaderStyle}>\n63\t        <div style={titleRowStyle}>\n64\t          <StatusChip\n65\t            label={detail.status}\n66\t            tone={queueStatusTone(detail.status)}\n67\t          />\n68\t          <h3 style={titleStyle}>Event {detail.id}</h3>\n69\t        </div>\n70\t        <p style={subtitleStyle}>\n71\t          <span style={monoStyle}>{detail.eventType}</span>\n72\t        </p>\n73\t      </header>\n74\t\n75\t      <dl style={metaListStyle}>\n76\t        <MetaRow label=\"Attempts\">\n77\t          <span style={monoStyle}>\n78\t            {detail.attempts.toLocaleString(\"en-US\")} /{\" \"}\n79\t            {detail.maxAttempts.toLocaleString(\"en-US\")}\n80\t          </span>\n81\t        </MetaRow>\n82\t        <MetaRow label=\"Created\">{detail.createdAt}</MetaRow>\n83\t        <MetaRow label=\"Scheduled\">{detail.scheduledAt}</MetaRow>\n84\t        <MetaRow label=\"Started\">{detail.startedAt ?? \"—\"}</MetaRow>\n85\t        <MetaRow label=\"Completed\">{detail.completedAt ?? \"—\"}</MetaRow>\n86\t        {detail.linked.userId ? (\n87\t          <MetaRow label=\"User\">\n88\t            <Link\n89\t              href={`/users/${encodeURIComponent(detail.linked.userId)}`}\n90\t              style={linkStyle}\n91\t            >\n92\t              {detail.linked.userId}\n93\t            </Link>\n94\t          </MetaRow>\n95\t        ) : null}\n96\t        {detail.linked.roundId ? (\n97\t          <MetaRow label=\"Round\">\n98\t            <span style={monoStyle}>{detail.linked.roundId}</span>\n99\t          </MetaRow>\n100\t        ) : null}\n101\t        {detail.linked.cl