{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GXZq6o1bHd2sGZvWEYC6a3","type":"tool_result","content":"1\t// Tests for the FR-9 /operations/dogpile URL-addressable filter normalisers.\n2\t//\n3\t// Two prefixed param groups (`dogpFilter*`, `fraudFilter*`) co-exist on the\n4\t// same page so each table can be filtered independently. The normalisers are\n5\t// the contract that keeps a stale URL chip from lying about a table's filter\n6\t// state — empty/whitespace → null, unknown enum → null, recognised allowlist\n7\t// values pass through.\n8\t\n9\timport { describe, expect, it } from \"vitest\";\n10\timport {\n11\t  PEEK_DOGPILE_STATUS_VALUES,\n12\t  PEEK_FRAUD_FLAG_STATUSES,\n13\t  normalizeDogpileEventFiltersFromSearchParams,\n14\t  normalizeFraudFlagFiltersFromSearchParams,\n15\t} from \"../operations-dogpile-search-params\";\n16\t\n17\tdescribe(\"normalizeDogpileEventFiltersFromSearchParams\", () => {\n18\t  it(\"empty input: every filter normalises to null\", () => {\n19\t    expect(normalizeDogpileEventFiltersFromSearchParams({})).toEqual({\n20\t      status: null,\n21\t      startsFrom: null,\n22\t      startsTo: null,\n23\t    });\n24\t  });\n25\t\n26\t  it(\"whitespace-only values normalise to null\", () => {\n27\t    expect(\n28\t      normalizeDogpileEventFiltersFromSearchParams({\n29\t        dogpFilterStatus: \"   \",\n30\t        dogpFilterFrom: \"   \",\n31\t        dogpFilterTo: \"   \",\n32\t      }),\n33\t    ).toEqual({ status: null, startsFrom: null, startsTo: null });\n34\t  });\n35\t\n36\t  it(\"populated: every field flows through with trimming applied\", () => {\n37\t    const filters = normalizeDogpileEventFiltersFromSearchParams({\n38\t      dogpFilterStatus: \"active\",\n39\t      dogpFilterFrom: \"  2026-04-01  \",\n40\t      dogpFilterTo: \"2026-04-26\",\n41\t    });\n42\t    expect(filters).toEqual({\n43\t      status: \"active\",\n44\t      startsFrom: \"2026-04-01\",\n45\t      startsTo: \"2026-04-26\",\n46\t    });\n47\t  });\n48\t\n49\t  it(\"status: every allowlisted value passes through verbatim\", () => {\n50\t    // State-transition coverage: scheduled / active / ended / cancelled.\n51\t    for (const value of PEEK_DOGPILE_STATUS_VALUES) {\n52\t      const filters = normalizeDogpileEventFiltersFromSearchParams({\n53\t        dogpFilterStatus: value,\n54\t      });\n55\t      expect(filters.status).toBe(value);\n56\t    }\n57\t  });\n58\t\n59\t  it(\"status: unknown enum value normalises to null so a stale URL chip cannot lie\", () => {\n60\t    expect(\n61\t      normalizeDogpileEventFiltersFromSearchParams({\n62\t        dogpFilterStatus: \"stalled\",\n63\t      }).status,\n64\t    ).toBeNull();\n65\t  });\n66\t\n67\t  it(\"array values: only the first element is read\", () => {\n68\t    expect(\n69\t      normalizeDogpileEventFiltersFromSearchParams({\n70\t        dogpFilterStatus: [\"active\", \"scheduled\"],\n71\t      }).status,\n72\t    ).toBe(\"active\");\n73\t  });\n74\t});\n75\t\n76\tdescribe(\"normalizeFraudFlagFiltersFromSearchParams\", () => {\n77\t  it(\"empty input: every filter normalises to null\", () => {\n78\t    expect(normalizeFraudFlagFiltersFromSearchParams({})).toEqual({\n79\t      status: null,\n80\t      userId: null,\n81\t      flagType: null,\n82\t      createdFrom: null,\n83\t      createdTo: null,\n84\t    });\n85\t  });\n86\t\n87\t  it(\"populated: every field flows through with trimming\", () => {\n88\t    const filters = normalizeFraudFlagFiltersFromSearchParams({\n89\t      fraudFilterStatus: \"open\",\n90\t      fraudFilterUserId: \"  user-1  \",\n91\t      fraudFilterFlagType: \" self_referral \",\n92\t      fraudFilterFrom: \"2026-04-01\",\n93\t      fraudFilterTo: \"2026-04-26\",\n94\t    });\n95\t    expect(filters).toEqual({\n96\t      status: \"open\",\n97\t      userId: \"user-1\",\n98\t      flagType: \"self_referral\",\n99\t      createdFrom: \"2026-04-01\",\n100\t      createdTo: \"2026-04-26\",\n101\t    });\n102\t  });\n103\t\n104\t  it(\"status transitions: every allowlisted value passes through verbatim\", () => {\n105\t    // State-transition coverage: open / reviewed / dismissed.\n106\t    for (const status of PEEK_FRAUD_FLAG_STATUSES) {\n107\t      const filters = normalizeFraudFlagFiltersFromSearchParams({\n108\t        fraudFilterStatus: status,\n109\t      });\n110\t      expect(filters.status).toBe(status);\n111\t    }\n112\t  });\n113\t\n114\t  it(\"status: unknown enum value normalises to null\", () => {\n115\t    expect(\n116\t      normalizeFraudFlagFiltersFromSearchParams({\n117\t        fraudFilterStatus: \"escalated\",\n118\t      }).status,\n119\t    ).toBeNull();\n120\t  });\n121\t\n122\t  it(\"status: empty status normalises to null\", () => {\n123\t    expect(\n124\t      normalizeFraudFlagFiltersFromSearchParams({\n125\t        fraudFilterStatus: \"\",\n126\t      }).status,\n127\t    ).toBeNull();\n128\t  });\n129\t\n130\t  it(\"flagType: free-text values pass through verbatim (no allowlist) — migration drives the catalog\", () => {\n131\t    // fraud_flags.flag_type has no enum check in migration-011, so the URL\n132\t    // can be scoped to any flag-type string the writer used. The normaliser\n133\t    // just trims whitespace.\n134\t    const filters = normalizeFraudFlagFiltersFromSearchParams({\n135\t      fraudFilterFlagType: \"rapid_signup_burst\",\n136\t    });\n137\t    expect(filters.flagType).toBe(\"rapid_signup_burst\");\n138\t  });\n139\t\n140\t  it(\"array values: only the first element is read\", () => {\n141\t    expect(\n142\t      normalizeFraudFlagFiltersFromSearchParams({\n143\t        fraudFilterUserId: [\"user-1\", \"user-2\"],\n144\t      }).userId,\n145\t    ).toBe(\"user-1\");\n146\t  });\n147\t});\n148\t"}]},"parent_tool_use_id":null,"session_id":"031ce74d-15ee-4888-a00b-e081672f539b","uuid":"5621efab-a48b-4f0a-b7d9-66dfa4407fed","timestamp":"2026-04-26T07:01:27.644Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/__tests__/operations-dogpile-search-params.test.ts","content":"// Tests for the FR-9 /operations/dogpile URL-addressable filter normalisers.\n//\n// Two prefixed param groups (`dogpFilter*`, `fraudFilter*`) co-exist on the\n// same page so each table can be filtered independently. The normalisers are\n// the contract that keeps a stale URL chip from lying about a table's filter\n// state — empty/whitespace → null, unknown enum → null, recognised allowlist\n// values pass through.\n\nimport { describe, expect, it } from \"vitest\";\nimport {\n  PEEK_DOGPILE_STATUS_VALUES,\n  PEEK_FRAUD_FLAG_STATUSES,\n  normalizeDogpileEventFiltersFromSearchParams,\n  normalizeFraudFlagFiltersFromSearchParams,\n} from \"../operations-dogpile-search-params\";\n\ndescribe(\"normalizeDogpileEventFiltersFromSearchParams\", () => {\n  it(\"empty input: every filter normalises to null\", () => {\n    expect(normalizeDogpileEventFiltersFromSearchParams({})).toEqual({\n      status: null,\n      startsFrom: null,\n      startsTo: null,\n    });\n  });\n\n  it(\"whitespace-only values normalise to null\", () => {\n    expect(\n      normalizeDogpileEventFiltersFromSearchParams({\n        dogpFilterStatus: \"   \",\n        dogpFilterFrom: \"   \",\n        dogpFilterTo: \"   \",\n      }),\n    ).toEqual({ status: null, startsFrom: null, startsTo: null });\n  });\n\n  it(\"populated: every field flows through with trimming applied\", () => {\n    const filters = normalizeDogpileEventFiltersFromSearchParams({\n      dogpFilterStatus: \"active\",\n      dogpFilterFrom: \"  2026-04-01  \",\n      dogpFilterTo: \"2026-04-26\",\n    });\n    expect(filters).toEqual({\n      status: \"active\",\n      startsFrom: \"2026-04-01\",\n      startsTo: \"2026-04-26\",\n    });\n  });\n\n  it(\"status: every allowlisted value passes through verbatim\", () => {\n    // State-transition coverage: scheduled / active / ended / cancelled.\n    for (const value of PEEK_DOGPILE_STATUS_VALUES) {\n      const filters = normalizeDogpileEventFiltersFromSearchParams({\n        dogpFilterStatus: value,\n      });\n      expect(filters.status).toBe(value);\n    }\n  });\n\n  it(\"status: unknown enum value normalises to null so a stale URL chip cannot lie\", () => {\n    expect(\n      normalizeDogpileEventFiltersFromSearchParams({\n        dogpFilterStatus: \"stalled\",\n      }).status,\n    ).toBeNull();\n  });\n\n  it(\"array values: only the first element is read\", () => {\n    expect(\n      normalizeDogpileEventFiltersFromSearchParams({\n        dogpFilterStatus: [\"active\", \"scheduled\"],\n      }).status,\n    ).toBe(\"active\");\n  });\n});\n\ndescribe(\"normalizeFraudFlagFiltersFromSearchParams\", () => {\n  it(\"empty input: every filter normalises to null\", () => {\n    expect(normalizeFraudFlagFiltersFromSearchParams({})).toEqual({\n      status: null,\n      userId: null,\n      flagType: null,\n      createdFrom: null,\n      createdTo: null,\n    });\n  });\n\n  it(\"populated: every field flows through with trimming\", () => {\n    const filters = normalizeFraudFlagFiltersFromSearchParams({\n      fraudFilterStatus: \"open\",\n      fraudFilterUserId: \"  user-1  \",\n      fraudFilterFlagType: \" self_referral \",\n      fraudFilterFrom: \"2026-04-01\",\n      fraudFilterTo: \"2026-04-26\",\n    });\n    expect(filters).toEqual({\n      status: \"open\",\n      userId: \"user-1\",\n      flagType: \"self_referral\",\n      createdFrom: \"2026-04-01\",\n      createdTo: \"2026-04-26\",\n    });\n  });\n\n  it(\"status transitions: every allowlisted value passes through verbatim\", () => {\n    // State-transition coverage: open / reviewed / dismissed.\n    for (const status of PEEK_FRAUD_FLAG_STATUSES) {\n      const filters = normalizeFraudFlagFiltersFromSearchParams({\n        fraudFilterStatus: status,\n      });\n      expect(filters.status).toBe(status);\n    }\n  });\n\n  it(\"status: unknown enum value normalises to null\", () => {\n    expect(\n      normalizeFraudFlagFiltersFromSearchParams({\n        fraudFilterStatus: \"escalated\",\n      }).status,\n    ).toBeNull();\n  });\n\n  it(\"status: empty status normalises to null\", () => {\n    expect(\n      normalizeFraudFlagFiltersFromSearchParams({\n        fraudFilterStatus: \"\",\n      }).status,\n    ).toBeNull();\n  });\n\n  it(\"flagType: free-text values pass through verbatim (no allowlist) — migration drives the catalog\", () => {\n    // fraud_flags.flag_type has no enum check in migration-011, so the URL\n    // can be scoped to any flag-type string the writer used. The normaliser\n    // just trims whitespace.\n    const filters = normalizeFraudFlagFiltersFromSearchParams({\n      fraudFilterFlagType: \"rapid_signup_burst\",\n    });\n    expect(filters.flagType).toBe(\"rapid_signup_burst\");\n  });\n\n  it(\"array values: only the first element is read\", () => {\n    expect(\n      normalizeFraudFlagFiltersFromSearchParams({\n        fraudFilterUserId: [\"user-1\", \"user-2\"],\n      }).userId,\n    ).toBe(\"user-1\");\n  });\n});\n","numLines":148,"startLine":1,"totalLines":148}}}
