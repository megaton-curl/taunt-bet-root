\n  if (!value) return false;\n  return (\n    JWT_PATTERN.test(value) ||\n    DB_URL_PATTERN.test(value) ||\n    PRIVATE_KEY_PATTERN.test(value) ||\n    BEARER_PATTERN.test(value) ||\n    CF_ACCESS_HEADER_PATTERN.test(value)\n  );\n}\n\nexport function redactScalar(value: PeekAuditScalar): PeekAuditScalar {\n  if (typeof value !== \"string\") return value;\n  return looksLikeSecret(value) ? PEEK_AUDIT_REDACTED : value;\n}\n\nexport function redactNullableString(value: string | null): string | null {\n  if (value === null) return null;\n  return looksLikeSecret(value) ? PEEK_AUDIT_REDACTED : value;\n}\n\nexport function redactChange(change: PeekAuditChange): PeekAuditChange {\n  return {\n    field: change.field,\n    before: redactScalar(change.before),\n    after: redactScalar(change.after),\n  };\n}\n\nexport function redactPayload(payload: PeekAuditPayload): PeekAuditPayload {\n  return {\n    actorEmail: payload.actorEmail,\n    route: redactNullableString(payload.route),\n    actionId: redactNullableString(payload.actionId),\n    resourceType: redactNullableString(payload.resourceType),\n    resourceId: redactNullableString(payload.resourceId),\n    filterSummary: redactNullableString(payload.filterSummary),\n    resultCount: payload.resultCount,\n    requestId: redactNullableString(payload.requestId),\n    rejectionReason: redactNullableString(payload.rejectionReason),\n    changes: payload.changes ? payload.changes.map(redactChange) : null,\n  };\n}\n\n// Recursively redact every string scalar inside a JSON-shaped value (object,\n// array, primitive). Used by `peek/src/server/db/queries/get-event-queue.ts`\n// when surfacing the JSONB `event_queue.payload` column to the operator UI:\n// the original payload may carry strings the queue worker treats as opaque\n// blobs (e.g. an Anchor signature, a Bearer token forwarded from a webhook),\n// and FR-10 requires the queue detail panel to redact known secrets at render\n// time. Cycles do not occur in JSONB rows but are guarded against defensively\n// so a malformed input cannot stall the renderer.\nexport function redactJsonValue(value: unknown): unknown {\n  return redactJsonValueInner(value, new WeakSet<object>());\n}\n\nfunction redactJsonValueInner(\n  value: unknown,\n  seen: WeakSet<object>,\n): unknown {\n  if (typeof value === \"string\") {\n    return looksLikeSecret(value) ? PEEK_AUDIT_REDACTED : value;\n  }\n  if (value === null || typeof value !== \"object\") {\n    return value;\n  }\n  if (seen.has(value)) {\n    return PEEK_AUDIT_REDACTED;\n  }\n  seen.add(value);\n  if (Array.isArray(value)) {\n    return value.map((item) => redactJsonValueInner(item, seen));\n  }\n  const entries = Object.entries(value as Record<string, unknown>);\n  const out: Record<string, unknown> = {};\n  for (const [key, inner] of entries) {\n    out[key] = redactJsonValueInner(inner, seen);\n  }\n  return out;\n}\n","numLines":104,"startLine":1,"totalLines":104}}}
