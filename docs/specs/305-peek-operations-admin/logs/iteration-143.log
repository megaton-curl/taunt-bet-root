a custom registry, custom action rules, and a custom audit emitter\n// (no network/DB I/O is required to unit-test it).\n\nimport type { Sql } from \"postgres\";\nimport {\n  isActionAllowedForRole,\n  PEEK_ACTION_RULES,\n  type PeekActionRule,\n  type PeekRole,\n} from \"../access-policy\";\nimport {\n  writePeekAuditEvent,\n  type PeekAuditWriteResult,\n} from \"../audit/writer\";\nimport { getSqlClient } from \"../db/client\";\nimport type { PeekAuditChange } from \"../../lib/types/peek\";\nimport {\n  getPeekMutation,\n  PEEK_MUTATIONS,\n  type PeekMutationActionId,\n  type PeekMutationActorContext,\n  type PeekMutationDefinition,\n  type PeekMutationRegistry,\n} from \"./registry\";\n\nexport type PeekMutationFailureReason =\n  | \"unknown_action\"\n  | \"unauthorized\"\n  | \"invalid_input\"\n  | \"execution_failed\"\n  | \"audit_emit_failed\";\n\nexport type PeekMutationSuccess = {\n  ok: true;\n  actionId: PeekMutationActionId;\n  resourceId: string | null;\n  changes: ReadonlyArray<PeekAuditChange> | null;\n};\n\nexport type PeekMutationFailure = {\n  ok: false;\n  reason: PeekMutationFailureReason;\n  message: string;\n  fieldErrors?: Readonly<Record<string, ReadonlyArray<string>>>;\n};\n\nexport type PeekMutationRunResult = PeekMutationSuccess | PeekMutationFailure;\n\nexport type PeekMutationAuditWriter = (\n  input: Parameters<typeof writePeekAuditEvent>[0],\n  options?: Parameters<typeof writePeekAuditEvent>[1],\n) => Promise<PeekAuditWriteResult>;\n\nexport type PeekMutationRunInput = {\n  actionId: PeekMutationActionId;\n  rawInput: unknown;\n  actorRole: PeekRole | null;\n  actor: PeekMutationActorContext;\n  sql?: Sql;\n  registry?: PeekMutationRegistry;\n  actionRules?: ReadonlyArray<PeekActionRule>;\n  auditWriter?: PeekMutationAuditWriter;\n};\n\nconst AUDIT_FAILURE_PREFIX = \"peek_audit_emit_failed:\";\n\nfunction buildAppliedPayload(\n  input: PeekMutationRunInput,\n  definition: PeekMutationDefinition,\n  resourceId: string | null,\n  changes: ReadonlyArray<PeekAuditChange> | null,\n) {\n  return {\n    eventType: \"peek.change.applied\" as const,\n    payload: {\n      actorEmail: input.actor.email,\n      route: input.actor.route ?? null,\n      actionId: input.actionId,\n      resourceType: definition.resourceType,\n      resourceId,\n      filterSummary: null,\n      resultCount: null,\n      requestId: input.actor.requestId ?? null,\n      rejectionReason: null,\n      changes,\n    },\n  };\n}\n\nfunction buildRejectedPayload(\n  input: PeekMutationRunInput,\n  definition: PeekMutationDefinition | null,\n  rejectionReason: string,\n  resourceId: string | null,\n) {\n  return {\n    eventType: \"peek.change.rejected\" as const,\n    payload: {\n      actorEmail: input.actor.email,\n      route: input.actor.route ?? null,\n      actionId: input.actionId,\n      resourceType: definition ? definition.resourceType : null,\n      resourceId,\n      filterSummary: null,\n      resultCount: null,\n      requestId: input.actor.requestId ?? null,\n      rejectionReason,\n      changes: null,\n    },\n  };\n}\n\nfunction flattenFieldErrors(error: {\n  flatten?: () => { fieldErrors?: Record<string, string[] | undefined> };\n}): Readonly<Record<string, ReadonlyArray<string>>> {\n  if (typeof error.flatten !== \"function\") return {};\n  const flat = error.flatten();\n  const fieldErrors = flat.fieldErrors ?? {};\n  const out: Record<string, ReadonlyArray<string>> = {};\n  for (const [key, value] of Object.entries(fieldErrors)) {\n    if (Array.isArray(value) && value.length > 0) out[key] = value;\n  }\n  return out;\n}\n\nexport async function runPeekMutation(\n  input: PeekMutationRunInput,\n): Promise<PeekMutationRunResult> {\n  const registry = input.registry ?? PEEK_MUTATIONS;\n  const sql = input.sql ?? (getSqlClient() as unknown as Sql);\n  const writer = input.auditWriter ?? writePeekAuditEvent;\n  const actionRules = input.actionRules ?? PEEK_ACTION_RULES;\n\n  const definition = getPeekMutation(input.actionId, registry);\n  if (!definition) {\n    await writer(buildRejectedPayload(input, null, \"unknown_action\", null), {\n      sql,\n    });\n    return {\n      ok: false,\n      reason: \"unknown_action\",\n      message: `No registered mutation for action \"${input.actionId}\".`,\n    };\n  }\n\n  if (!isActionAllowedForRole(input.actionId, input.actorRole, actionRules)) {\n    await writer(\n      buildRejectedPayload(input, definition, \"unauthorized\", null),\n      { sql },\n    );\n    return {\n      ok: false,\n      reason: \"unauthorized\",\n      message: `Actor is not authorized to perform action \"${input.actionId}\".`,\n    };\n  }\n\n  const parsed = definition.schema.safeParse(input.rawInput);\n  if (!parsed.success) {\n    const fieldErrors = flattenFieldErrors(parsed.error);\n    await writer(\n      buildRejectedPayload(input, definition, \"invalid_input\", null),\n      { sql },\n    );\n    return {\n      ok: false,\n      reason: \"invalid_input\",\n      message: \"Input failed validation.\",\n      fieldErrors,\n    };\n  }\n\n  let executeResult: { resourceId: string | null; changes: ReadonlyArray<PeekAuditChange> | null } | null = null;\n  let runtimeError: Error | null = null;\n\n  try {\n    executeResult = await sql.begin(async (sqlTx) => {\n      const result = await definition.execute({\n        input: parsed.data,\n        sql: sqlTx as unknown as Sql,\n        actor: input.actor,\n      });\n      const auditResult = await writer(\n        buildAppliedPayload(\n          input,\n          definition,\n          result.resourceId,\n          result.changes,\n        ),\n        { sql: sqlTx as unknown as Sql },\n      );\n      if (!auditResult.ok) {\n        // Throw to trigger transaction rollback so we never leave a\n        // committed mutation without its audit record.\n        throw new Error(`${AUDIT_FAILURE_PREFIX}${auditResult.reason}`);\n      }\n      return { resourceId: result.resourceId, changes: result.changes };\n    }) as { resourceId: string | null; changes: ReadonlyArray<PeekAuditChange> | null };\n  } catch (error) {\n    runtimeError = error instanceof Error ? error : new Error(\"unknown\");\n  }\n\n  if (runtimeError) {\n    const isAuditFailure = runtimeError.message.startsWith(AUDIT_FAILURE_PREFIX);\n    const rejectionReason = isAuditFailure\n      ? runtimeError.message\n      : `execution_failed: ${runtimeError.message}`;\n    await writer(\n      buildRejectedPayload(input, definition, rejectionReason, null),\n      { sql },\n    );\n    return {\n      ok: false,\n      reason: isAuditFailure ? \"audit_emit_failed\" : \"execution_failed\",\n      message: isAuditFailure\n        ? `Audit emission failed (${runtimeError.message.slice(AUDIT_FAILURE_PREFIX.length)}); mutation was rolled back.`\n        : runtimeError.message,\n    };\n  }\n\n  if (!executeResult) {\n    // Defensive: sql.begin should always either return or throw.\n    return {\n      ok: false,\n      reason: \"execution_failed\",\n      message: \"Mutation transaction returned no result.\",\n    };\n  }\n\n  return {\n    ok: true,\n    actionId: input.actionId,\n    resourceId: executeResult.resourceId,\n    changes: executeResult.changes,\n  };\n}\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_015hGCH2QwFok2AbESdFxPVZ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01KPuSuihVW7WNtZxQk5ENYC","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/mutations/index.ts","content":"// Public surface for the peek mutations module (FR-14).\n//\n// Subsequent FR-14 iterations import `runPeekMutation` to wire the\n// approved mutation actions (KOL rate, fraud-flag status, dogpile cancel,\n// reward-config edit) into route handlers, and import the registry types\n// to register new mutation definitions alongside the framework.\n\nexport {\n  PEEK_MUTATIONS,\n  getPeekMutation,\n  type PeekMutationActionId,\n  type PeekMutationActorContext,\n  type PeekMutationDefinition,\n  type PeekMutationExecuteContext,\n  type PeekMutationExecuteResult,\n  type PeekMutationRegistry,\n} from \"./registry\";\nexport {\n  runPeekMutation,\n  type PeekMutationAuditWriter,\n  type PeekMutationFailure,\n  type PeekMutationFailureReason,\n  type PeekMutationRunInput,\n  type PeekMutationRunResult,\n  type PeekMutationSuccess,\n} from \"./runner\";\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3600,"cache_read_input_tokens":103172,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3600},"output_tokens":64,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"242d752c-50cc-49e1-a8d0-306af8621059","uuid":"5900255d-f7ce-4d7d-b108-8be74a49df86"}
