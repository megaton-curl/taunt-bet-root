{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UsDB775fN92AjGhJ8W3fdJ","type":"tool_result","content":"1\t// Secret-redaction helpers for the peek audit writer (FR-11).\n2\t//\n3\t// Audit payloads must never persist JWTs, access tokens, DB connection URLs,\n4\t// private keys, or other raw secrets. The writer always passes the caller's\n5\t// payload through `redactPayload` before insertion; if a value matches a known\n6\t// secret pattern it is replaced with the `PEEK_AUDIT_REDACTED` sentinel. The\n7\t// audit-view UI renders that sentinel verbatim so reviewers see that a field\n8\t// was redacted rather than silently absent.\n9\t\n10\timport {\n11\t  PEEK_AUDIT_REDACTED,\n12\t  type PeekAuditChange,\n13\t  type PeekAuditPayload,\n14\t  type PeekAuditScalar,\n15\t} from \"../../lib/types/peek\";\n16\t\n17\tconst JWT_PATTERN = /\\beyJ[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\b/;\n18\tconst DB_URL_PATTERN =\n19\t  /\\b(?:postgres(?:ql)?|mysql|mongodb(?:\\+srv)?|redis|amqps?)(?:\\+[a-z0-9]+)?:\\/\\/[^\\s]+/i;\n20\tconst PRIVATE_KEY_PATTERN = /-----BEGIN [A-Z0-9 ]*PRIVATE KEY-----/;\n21\tconst BEARER_PATTERN = /\\bBearer\\s+[A-Za-z0-9._~+/=-]{8,}/i;\n22\tconst CF_ACCESS_HEADER_PATTERN = /\\bcf-access-jwt-assertion\\s*[:=]/i;\n23\t\n24\texport function looksLikeSecret(value: string): boolean {\n25\t  if (!value) return false;\n26\t  return (\n27\t    JWT_PATTERN.test(value) ||\n28\t    DB_URL_PATTERN.test(value) ||\n29\t    PRIVATE_KEY_PATTERN.test(value) ||\n30\t    BEARER_PATTERN.test(value) ||\n31\t    CF_ACCESS_HEADER_PATTERN.test(value)\n32\t  );\n33\t}\n34\t\n35\texport function redactScalar(value: PeekAuditScalar): PeekAuditScalar {\n36\t  if (typeof value !== \"string\") return value;\n37\t  return looksLikeSecret(value) ? PEEK_AUDIT_REDACTED : value;\n38\t}\n39\t\n40\texport function redactNullableString(value: string | null): string | null {\n41\t  if (value === null) return null;\n42\t  return looksLikeSecret(value) ? PEEK_AUDIT_REDACTED : value;\n43\t}\n44\t\n45\texport function redactChange(change: PeekAuditChange): PeekAuditChange {\n46\t  return {\n47\t    field: change.field,\n48\t    before: redactScalar(change.before),\n49\t    after: redactScalar(change.after),\n50\t  };\n51\t}\n52\t\n53\texport function redactPayload(payload: PeekAuditPayload): PeekAuditPayload {\n54\t  return {\n55\t    actorEmail: payload.actorEmail,\n56\t    route: redactNullableString(payload.route),\n57\t    actionId: redactNullableString(payload.actionId),\n58\t    resourceType: redactNullableString(payload.resourceType),\n59\t    resourceId: redactNullableString(payload.resourceId),\n60\t    filterSummary: redactNullableString(payload.filterSummary),\n61\t    resultCount: payload.resultCount,\n62\t    requestId: redactNullableString(payload.requestId),\n63\t    rejectionReason: redactNullableString(payload.rejectionReason),\n64\t    changes: payload.changes ? payload.changes.map(redactChange) : null,\n65\t  };\n66\t}\n67\t\n68\t// Recursively redact every string scalar inside a JSON-shaped value (object,\n69\t// array, primitive). Used by `peek/src/server/db/queries/get-event-queue.ts`\n70\t// when surfacing the JSONB `event_queue.payload` column to the operator UI:\n71\t// the original payload may carry strings the queue worker treats as opaque\n72\t// blobs (e.g. an Anchor signature, a Bearer token forwarded from a webhook),\n73\t// and FR-10 requires the queue detail panel to redact known secrets at render\n74\t// time. Cycles do not occur in JSONB rows but are guarded against defensively\n75\t// so a malformed input cannot stall the renderer.\n76\texport function redactJsonValue(value: unknown): unknown {\n77\t  return redactJsonValueInner(value, new WeakSet<object>());\n78\t}\n79\t\n80\tfunction redactJsonValueInner(\n81\t  value: unknown,\n82\t  seen: WeakSet<object>,\n83\t): unknown {\n84\t  if (typeof value === \"string\") {\n85\t    return looksLikeSecret(value) ? PEEK_AUDIT_REDACTED : value;