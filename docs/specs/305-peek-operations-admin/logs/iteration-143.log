{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0189qdTeGvvADaXFRrGus6dY","type":"tool_result","content":"/workspaces/rng-utopia/peek/src/server/db/client.ts\nimport postgres from \"postgres\";\n\nlet cachedClient: ReturnType<typeof postgres> | null = null;\nconst DEFAULT_CONNECT_TIMEOUT_SECONDS = 5;\n\nexport function getDatabaseUrlFromEnv(\n  env: Record<string, string | undefined> = process.env\n) {\n  const databaseUrl = env.DATABASE_URL;\n\n  if (!databaseUrl) {\n    throw new Error(\"DATABASE_URL is required\");\n  }\n\n  return databaseUrl;\n}\n\nexport function getConnectTimeoutSecondsFromEnv(\n  env: Record<string, string | undefined> = process.env\n) {\n  const rawValue = env.PEEK_DB_CONNECT_TIMEOUT_SECONDS ?? env.PGCONNECT_TIMEOUT;\n  const parsedValue = rawValue ? Number.parseInt(rawValue, 10) : Number.NaN;\n\n  if (Number.isFinite(parsedValue) && parsedValue > 0) {\n    return parsedValue;\n  }\n\n  return DEFAULT_CONNECT_TIMEOUT_SECONDS;\n}\n\nexport function getSqlClient() {\n  if (!cachedClient) {\n    cachedClient = postgres(getDatabaseUrlFromEnv(), {\n      max: 5,\n      prepare: true,\n      connect_timeout: getConnectTimeoutSecondsFromEnv(),\n    });\n  }\n\n  return cachedClient;\n}","is_error":false}]},"parent_tool_use_id":null,"session_id":"242d752c-50cc-49e1-a8d0-306af8621059","uuid":"6772647a-5683-48c4-b3c8-434026b944d7","timestamp":"2026-04-26T15:06:48.387Z","tool_use_result":{"stdout":"/workspaces/rng-utopia/peek/src/server/db/client.ts\nimport postgres from \"postgres\";\n\nlet cachedClient: ReturnType<typeof postgres> | null = null;\nconst DEFAULT_CONNECT_TIMEOUT_SECONDS = 5;\n\nexport function getDatabaseUrlFromEnv(\n  env: Record<string, string | undefined> = process.env\n) {\n  const databaseUrl = env.DATABASE_URL;\n\n  if (!databaseUrl) {\n    throw new Error(\"DATABASE_URL is required\");\n  }\n\n  return databaseUrl;\n}\n\nexport function getConnectTimeoutSecondsFromEnv(\n  env: Record<string, string | undefined> = process.env\n) {\n  const rawValue = env.PEEK_DB_CONNECT_TIMEOUT_SECONDS ?? env.PGCONNECT_TIMEOUT;\n  const parsedValue = rawValue ? Number.parseInt(rawValue, 10) : Number.NaN;\n\n  if (Number.isFinite(parsedValue) && parsedValue > 0) {\n    return parsedValue;\n  }\n\n  return DEFAULT_CONNECT_TIMEOUT_SECONDS;\n}\n\nexport function getSqlClient() {\n  if (!cachedClient) {\n    cachedClient = postgres(getDatabaseUrlFromEnv(), {\n      max: 5,\n      prepare: true,\n      connect_timeout: getConnectTimeoutSecondsFromEnv(),\n    });\n  }\n\n  return cachedClient;\n}","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
