{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BDsTKtF8Bkqd3cHeMW1RyH","type":"tool_result","content":"1\t// Runner unit tests (FR-12).\n2\t//\n3\t// Covers required-filter enforcement, row-cap clamping (and `rowCapApplied`\n4\t// truthiness), filename composition, audit-event emission BEFORE rows are\n5\t// returned, audit-emit-failure refusal, unknown-entity refusal, and the\n6\t// production-without-audit-config gate. The runner is dependency-injected so\n7\t// these tests never touch a real database or the real audit writer.\n8\t\n9\timport { describe, expect, it, vi } from \"vitest\";\n10\timport {\n11\t  isPeekAuditConfigured,\n12\t  runPeekExport,\n13\t  type PeekExportActorContext,\n14\t  type PeekExportAuditWriter,\n15\t  type PeekExportRunResult,\n16\t} from \"../runner\";\n17\timport type {\n18\t  PeekExporterDefinition,\n19\t  PeekExporterRegistry,\n20\t} from \"../registry\";\n21\timport type { PeekTableColumn } from \"../../../lib/types/peek\";\n22\timport type { Sql } from \"postgres\";\n23\timport type { PeekAuditWriteResult } from \"../../audit/writer\";\n24\t\n25\ttype FetchSpy = ReturnType<typeof vi.fn>;\n26\t\n27\tconst ACTOR: PeekExportActorContext = {\n28\t  email: \"alice@example.com\",\n29\t  route: \"/growth/referrals\",\n30\t  requestId: \"req-export-1\",\n31\t};\n32\t\n33\tconst COLUMNS: ReadonlyArray<PeekTableColumn> = [\n34\t  { id: \"id\", label: \"Id\", align: \"left\", sortable: false },\n35\t  { id: \"name\", label: \"Name\", align: \"left\", sortable: false },\n36\t];\n37\t\n38\tfunction makeRows(count: number): ReadonlyArray<Record<string, string>> {\n39\t  return Array.from({ length: count }, (_, i) => ({\n40\t    id: String(i + 1),\n41\t    name: `row-${i + 1}`,\n42\t  }));\n43\t}\n44\t\n45\tfunction makeExporter(\n46\t  overrides: Partial<PeekExporterDefinition> & {\n47\t    fetchRows?: number;\n48\t    requireAtLeastOneFilter?: boolean;\n49\t    maxRowsPerExport?: number;\n50\t  } = {},\n51\t): { definition: PeekExporterDefinition; fetch: FetchSpy } {\n52\t  const fetchRows = overrides.fetchRows ?? 3;\n53\t  const maxRowsPerExport = overrides.maxRowsPerExport ?? 100;\n54\t  const requireAtLeastOneFilter = overrides.requireAtLeastOneFilter ?? false;\n55\t\n56\t  const fetch: FetchSpy = vi.fn(\n57\t    async ({ rowCap }: { rowCap: number }) => {\n58\t      // Mimic real exporters: request rowCap+1 internally so `rowCapApplied`\n59\t      // is honest. The test fixture decides how many rows the source actually\n60\t      // produced via `fetchRows`.\n61\t      const produced = makeRows(Math.min(fetchRows, rowCap + 1));\n62\t      const rowCapApplied = fetchRows > rowCap;\n63\t      const trimmed = rowCapApplied ? produced.slice(0, rowCap) : produced;\n64\t      return { rows: trimmed, rowCapApplied };\n65\t    },\n66\t  );\n67\t\n68\t  const definition: PeekExporterDefinition = {\n69\t    entity: \"claims\",\n70\t    resourceType: \"referral_claim\",\n71\t    columns: COLUMNS,\n72\t    maxRowsPerExport,\n73\t    requireAtLeastOneFilter,\n74\t    fetch: fetch as unknown as PeekExporterDefinition[\"fetch\"],\n75\t    buildFilterSlug: (filters) =>\n76\t      Object.entries(filters)\n77\t        .filter(([, v]) => v != null && v !== \"\")\n78\t        .map(([k, v]) => `${k}-${v}`)\n79\t        .join(\"_\"),\n80\t    ...overrides,\n81\t  };\n82\t\n83\t  return { definition, fetch };\n84\t}\n85\t\n86\tfunction makeRegistry(\n87\t  exporter: PeekExporterDefinition,\n88\t): PeekExporterRegistry {\n89\t  return Object.freeze({ [exporter.entity]: exporter });\n90\t}\n91\t\n92\tconst FAKE_SQL = {} as unknown as Sql;\n93\t\n94\tfunction makeAuditWriter(\n95\t  result: PeekAuditWriteResult = { ok: true },\n96\t): { writer: PeekExportAuditWriter; calls: Array<unknown> } {\n97\t  const calls: Array<unknown> = [];\n98\t  const writer: PeekExportAuditWriter = vi.fn(async (input) => {\n99\t    calls.push(input);\n100\t    return result;"}]},"parent_tool_use_id":null,"session_id":"242d752c-50cc-49e1-a8d0-306af8621059","uuid":"527becdd-cea4-49a7-9136-be12d06ac39b","timestamp":"2026-04-26T15:07:18.079Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/exports/__tests__/runner.test.ts","content":"// Runner unit tests (FR-12).\n//\n// Covers required-filter enforcement, row-cap clamping (and `rowCapApplied`\n// truthiness), filename composition, audit-event emission BEFORE rows are\n// returned, audit-emit-failure refusal, unknown-entity refusal, and the\n// production-without-audit-config gate. The runner is dependency-injected so\n// these tests never touch a real database or the real audit writer.\n\nimport { describe, expect, it, vi } from \"vitest\";\nimport {\n  isPeekAuditConfigured,\n  runPeekExport,\n  type PeekExportActorContext,\n  type PeekExportAuditWriter,\n  type PeekExportRunResult,\n} from \"../runner\";\nimport type {\n  PeekExporterDefinition,\n  PeekExporterRegistry,\n} from \"../registry\";\nimport type { PeekTableColumn } from \"../../../lib/types/peek\";\nimport type { Sql } from \"postgres\";\nimport type { PeekAuditWriteResult } from \"../../audit/writer\";\n\ntype FetchSpy = ReturnType<typeof vi.fn>;\n\nconst ACTOR: PeekExportActorContext = {\n  email: \"alice@example.com\",\n  route: \"/growth/referrals\",\n  requestId: \"req-export-1\",\n};\n\nconst COLUMNS: ReadonlyArray<PeekTableColumn> = [\n  { id: \"id\", label: \"Id\", align: \"left\", sortable: false },\n  { id: \"name\", label: \"Name\", align: \"left\", sortable: false },\n];\n\nfunction makeRows(count: number): ReadonlyArray<Record<string, string>> {\n  return Array.from({ length: count }, (_, i) => ({\n    id: String(i + 1),\n    name: `row-${i + 1}`,\n  }));\n}\n\nfunction makeExporter(\n  overrides: Partial<PeekExporterDefinition> & {\n    fetchRows?: number;\n    requireAtLeastOneFilter?: boolean;\n    maxRowsPerExport?: number;\n  } = {},\n): { definition: PeekExporterDefinition; fetch: FetchSpy } {\n  const fetchRows = overrides.fetchRows ?? 3;\n  const maxRowsPerExport = overrides.maxRowsPerExport ?? 100;\n  const requireAtLeastOneFilter = overrides.requireAtLeastOneFilter ?? false;\n\n  const fetch: FetchSpy = vi.fn(\n    async ({ rowCap }: { rowCap: number }) => {\n      // Mimic real exporters: request rowCap+1 internally so `rowCapApplied`\n      // is honest. The test fixture decides how many rows the source actually\n      // produced via `fetchRows`.\n      const produced = makeRows(Math.min(fetchRows, rowCap + 1));\n      const rowCapApplied = fetchRows > rowCap;\n      const trimmed = rowCapApplied ? produced.slice(0, rowCap) : produced;\n      return { rows: trimmed, rowCapApplied };\n    },\n  );\n\n  const definition: PeekExporterDefinition = {\n    entity: \"claims\",\n    resourceType: \"referral_claim\",\n    columns: COLUMNS,\n    maxRowsPerExport,\n    requireAtLeastOneFilter,\n    fetch: fetch as unknown as PeekExporterDefinition[\"fetch\"],\n    buildFilterSlug: (filters) =>\n      Object.entries(filters)\n        .filter(([, v]) => v != null && v !== \"\")\n        .map(([k, v]) => `${k}-${v}`)\n        .join(\"_\"),\n    ...overrides,\n  };\n\n  return { definition, fetch };\n}\n\nfunction makeRegistry(\n  exporter: PeekExporterDefinition,\n): PeekExporterRegistry {\n  return Object.freeze({ [exporter.entity]: exporter });\n}\n\nconst FAKE_SQL = {} as unknown as Sql;\n\nfunction makeAuditWriter(\n  result: PeekAuditWriteResult = { ok: true },\n): { writer: PeekExportAuditWriter; calls: Array<unknown> } {\n  const calls: Array<unknown> = [];\n  const writer: PeekExportAuditWriter = vi.fn(async (input) => {\n    calls.push(input);\n    return result;","numLines":100,"startLine":1,"totalLines":660}}}
