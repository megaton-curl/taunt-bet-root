{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012AQFqYfJp65nGNj4tx5Zs4","type":"tool_result","content":"1\t// Universal search results (FR-5).\n2\t//\n3\t// Browser-safe presentational component. Takes a `PeekSearchResponse` (or a\n4\t// null response when no search has been run yet) and renders results grouped\n5\t// by entity type (user, referral, linked account, round, transaction, queue\n6\t// event). Each result row carries enough context to disambiguate similar\n7\t// matches (label, sublabel, context). Truncated groups (when the per-group\n8\t// limit was hit) advertise the cap so operators know to narrow the query.\n9\t// Empty groups are skipped; an entirely-empty response renders an\n10\t// operator-readable status. Non-null `error` renders `role=\"alert\"` and\n11\t// suppresses results.\n12\t\n13\timport type { CSSProperties } from \"react\";\n14\timport Link from \"next/link\";\n15\timport type {\n16\t  PeekSearchEntityType,\n17\t  PeekSearchGroup,\n18\t  PeekSearchResponse,\n19\t  PeekSearchResult,\n20\t} from \"../lib/types/peek\";\n21\t\n22\texport type UniversalSearchResultsProps = {\n23\t  response: PeekSearchResponse | null;\n24\t  error: string | null;\n25\t};\n26\t\n27\tconst ENTITY_LABELS: Record<PeekSearchEntityType, string> = {\n28\t  user: \"Users\",\n29\t  referral: \"Referral codes\",\n30\t  linked_account: \"Linked accounts\",\n31\t  round: \"Rounds\",\n32\t  transaction: \"Transactions\",\n33\t  queue_event: \"Queue events\",\n34\t};\n35\t\n36\texport function UniversalSearchResults({\n37\t  response,\n38\t  error,\n39\t}: UniversalSearchResultsProps) {\n40\t  if (error) {\n41\t    return (\n42\t      <div role=\"alert\" style={errorBoxStyle}>\n43\t        Search unavailable: {error}\n44\t      </div>\n45\t    );\n46\t  }\n47\t\n48\t  if (!response || response.query.length === 0) {\n49\t    return null;\n50\t  }\n51\t\n52\t  if (response.totalResults === 0) {\n53\t    return (\n54\t      <div role=\"status\" style={emptyBoxStyle}>\n55\t        No matches for &quot;{response.query}&quot; across users, referral\n56\t        codes, linked accounts, rounds, transactions, or queue events.\n57\t      </div>\n58\t    );\n59\t  }\n60\t\n61\t  const populatedGroups = response.groups.filter(\n62\t    (group) => group.results.length > 0,\n63\t  );\n64\t\n65\t  return (\n66\t    <div\n67\t      aria-label=\"Universal search results\"\n68\t      role=\"region\"\n69\t      style={containerStyle}\n70\t    >\n71\t      <p style={summaryStyle}>\n72\t        {response.totalResults} match\n73\t        {response.totalResults === 1 ? \"\" : \"es\"} for &quot;{response.query}\n74\t        &quot;\n75\t      </p>\n76\t      {populatedGroups.map((group) => (\n77\t        <SearchGroup\n78\t          group={group}\n79\t          key={group.entityType}\n80\t          perGroupLimit={response.perGroupLimit}"}]},"parent_tool_use_id":null,"session_id":"ccf88516-a980-494a-b5f7-15e03a3372de","uuid":"383e74c8-031d-4e91-93ff-378903e57e9f","timestamp":"2026-04-25T13:58:41.737Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/universal-search-results.tsx","content":"// Universal search results (FR-5).\n//\n// Browser-safe presentational component. Takes a `PeekSearchResponse` (or a\n// null response when no search has been run yet) and renders results grouped\n// by entity type (user, referral, linked account, round, transaction, queue\n// event). Each result row carries enough context to disambiguate similar\n// matches (label, sublabel, context). Truncated groups (when the per-group\n// limit was hit) advertise the cap so operators know to narrow the query.\n// Empty groups are skipped; an entirely-empty response renders an\n// operator-readable status. Non-null `error` renders `role=\"alert\"` and\n// suppresses results.\n\nimport type { CSSProperties } from \"react\";\nimport Link from \"next/link\";\nimport type {\n  PeekSearchEntityType,\n  PeekSearchGroup,\n  PeekSearchResponse,\n  PeekSearchResult,\n} from \"../lib/types/peek\";\n\nexport type UniversalSearchResultsProps = {\n  response: PeekSearchResponse | null;\n  error: string | null;\n};\n\nconst ENTITY_LABELS: Record<PeekSearchEntityType, string> = {\n  user: \"Users\",\n  referral: \"Referral codes\",\n  linked_account: \"Linked accounts\",\n  round: \"Rounds\",\n  transaction: \"Transactions\",\n  queue_event: \"Queue events\",\n};\n\nexport function UniversalSearchResults({\n  response,\n  error,\n}: UniversalSearchResultsProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorBoxStyle}>\n        Search unavailable: {error}\n      </div>\n    );\n  }\n\n  if (!response || response.query.length === 0) {\n    return null;\n  }\n\n  if (response.totalResults === 0) {\n    return (\n      <div role=\"status\" style={emptyBoxStyle}>\n        No matches for &quot;{response.query}&quot; across users, referral\n        codes, linked accounts, rounds, transactions, or queue events.\n      </div>\n    );\n  }\n\n  const populatedGroups = response.groups.filter(\n    (group) => group.results.length > 0,\n  );\n\n  return (\n    <div\n      aria-label=\"Universal search results\"\n      role=\"region\"\n      style={containerStyle}\n    >\n      <p style={summaryStyle}>\n        {response.totalResults} match\n        {response.totalResults === 1 ? \"\" : \"es\"} for &quot;{response.query}\n        &quot;\n      </p>\n      {populatedGroups.map((group) => (\n        <SearchGroup\n          group={group}\n          key={group.entityType}\n          perGroupLimit={response.perGroupLimit}","numLines":80,"startLine":1,"totalLines":230}}}
