{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y6hfvkXcqTJKC4JohiSkdJ","type":"tool_result","content":"1\timport type { CSSProperties, ReactNode } from \"react\";\n2\t\n3\texport type PeekDetailSection = {\n4\t  id: string;\n5\t  label: string;\n6\t  body: ReactNode;\n7\t};\n8\t\n9\texport type DetailPanelProps = {\n10\t  sections: ReadonlyArray<PeekDetailSection>;\n11\t  activeId?: string | null;\n12\t  ariaLabel?: string;\n13\t  emptyTitle?: string;\n14\t  emptyBody?: string | null;\n15\t  error?: string | null;\n16\t};\n17\t\n18\texport function DetailPanel({\n19\t  sections,\n20\t  activeId = null,\n21\t  ariaLabel = \"Detail sections\",\n22\t  emptyTitle = \"No sections available for this view.\",\n23\t  emptyBody = null,\n24\t  error = null,\n25\t}: DetailPanelProps) {\n26\t  if (error) {\n27\t    return (\n28\t      <div role=\"alert\" style={errorStyle}>\n29\t        Detail panel unavailable: {error}\n30\t      </div>\n31\t    );\n32\t  }\n33\t\n34\t  if (sections.length === 0) {\n35\t    return (\n36\t      <div role=\"status\" style={emptyStyle}>\n37\t        <p style={emptyTitleStyle}>{emptyTitle}</p>\n38\t        {emptyBody ? <p style={emptyBodyStyle}>{emptyBody}</p> : null}\n39\t      </div>\n40\t    );\n41\t  }\n42\t\n43\t  return (\n44\t    <div style={wrapperStyle}>\n45\t      <nav aria-label={ariaLabel} style={navStyle}>\n46\t        <ul style={listStyle}>\n47\t          {sections.map((section) => {\n48\t            const isActive = activeId === section.id;\n49\t            return (\n50\t              <li key={section.id}>\n51\t                <a\n52\t                  href={`#${section.id}`}\n53\t                  aria-current={isActive ? \"true\" : undefined}\n54\t                  style={isActive ? activeLinkStyle : linkStyle}\n55\t                >\n56\t                  {section.label}\n57\t                </a>\n58\t              </li>\n59\t            );\n60\t          })}"}]},"parent_tool_use_id":null,"session_id":"ccf88516-a980-494a-b5f7-15e03a3372de","uuid":"659b2a7e-9ffb-4ea9-adc1-a2d54b4bc37b","timestamp":"2026-04-25T14:00:01.794Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/detail-panel.tsx","content":"import type { CSSProperties, ReactNode } from \"react\";\n\nexport type PeekDetailSection = {\n  id: string;\n  label: string;\n  body: ReactNode;\n};\n\nexport type DetailPanelProps = {\n  sections: ReadonlyArray<PeekDetailSection>;\n  activeId?: string | null;\n  ariaLabel?: string;\n  emptyTitle?: string;\n  emptyBody?: string | null;\n  error?: string | null;\n};\n\nexport function DetailPanel({\n  sections,\n  activeId = null,\n  ariaLabel = \"Detail sections\",\n  emptyTitle = \"No sections available for this view.\",\n  emptyBody = null,\n  error = null,\n}: DetailPanelProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Detail panel unavailable: {error}\n      </div>\n    );\n  }\n\n  if (sections.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>{emptyTitle}</p>\n        {emptyBody ? <p style={emptyBodyStyle}>{emptyBody}</p> : null}\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <nav aria-label={ariaLabel} style={navStyle}>\n        <ul style={listStyle}>\n          {sections.map((section) => {\n            const isActive = activeId === section.id;\n            return (\n              <li key={section.id}>\n                <a\n                  href={`#${section.id}`}\n                  aria-current={isActive ? \"true\" : undefined}\n                  style={isActive ? activeLinkStyle : linkStyle}\n                >\n                  {section.label}\n                </a>\n              </li>\n            );\n          })}","numLines":60,"startLine":1,"totalLines":171}}}
