"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/search-params.ts","content":"export type PeekSearchParams = {\n  query: string;\n  sort: \"joinedAt\" | \"refereeCount\";\n  direction: \"asc\" | \"desc\";\n  page: number;\n  pageSize: number;\n  filters: {\n    hasReferrer: boolean;\n    hasReferees: boolean;\n    hasCode: boolean;\n    hasTelegram: boolean;\n  };\n};\n\nfunction readSingleValue(value: string | string[] | undefined) {\n  return Array.isArray(value) ? value[0] ?? \"\" : value ?? \"\";\n}\n\nfunction readPositiveInteger(\n  value: string | string[] | undefined,\n  fallback: number\n) {\n  const parsedValue = Number.parseInt(readSingleValue(value), 10);\n\n  if (Number.isFinite(parsedValue) && parsedValue > 0) {\n    return parsedValue;\n  }\n\n  return fallback;\n}\n\nexport function normalizePeekSearchParams(\n  input: Record<string, string | string[] | undefined>\n): PeekSearchParams {\n  return {\n    query: readSingleValue(input.query),\n    sort: readSingleValue(input.sort) === \"refereeCount\" ? \"refereeCount\" : \"joinedAt\",\n    direction: readSingleValue(input.direction) === \"asc\" ? \"asc\" : \"desc\",\n    page: readPositiveInteger(input.page, 1),\n    pageSize: Number(process.env.PEEK_DEFAULT_PAGE_SIZE || \"50\"),\n    filters: {\n      hasReferrer: readSingleValue(input.hasReferrer) === \"true\",\n      hasReferees: readSingleValue(input.hasReferees) === \"true\",\n      hasCode: readSingleValue(input.hasCode) === \"true\",\n      hasTelegram: readSingleValue(input.hasTelegram) === \"true\",\n    },\n  };\n}\n","numLines":49,"startLine":1,"totalLines":49}}}
