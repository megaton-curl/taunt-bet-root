{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017J3dSHTfnobA7GiEdzRrQq","type":"tool_result","content":"1\t// Round-detail view (FR-8). Server-renderable, props-only component used by\n2\t// `/games/[game]/rounds/[roundId]/page.tsx`. Lives in `src/components` so it\n3\t// can be tested directly with @testing-library/react against a synthetic\n4\t// `PeekRoundDetail` without spinning up the whole route.\n5\t\n6\timport Link from \"next/link\";\n7\timport type { CSSProperties, ReactNode } from \"react\";\n8\timport { StatusChip } from \"./status-chip\";\n9\timport type {\n10\t  PeekCloseCallOutcome,\n11\t  PeekCloseCallPhase,\n12\t  PeekCloseCallRoundRow,\n13\t  PeekGameId,\n14\t  PeekRoundDetail,\n15\t  PeekRoundEntryRow,\n16\t  PeekRoundPhase,\n17\t  PeekRoundRow,\n18\t  PeekRoundTransactionRow,\n19\t  PeekStatusTone,\n20\t} from \"../lib/types/peek\";\n21\t\n22\texport type RoundDetailViewProps = {\n23\t  detail: PeekRoundDetail;\n24\t};\n25\t\n26\texport function RoundDetailView({ detail }: RoundDetailViewProps) {\n27\t  return (\n28\t    <>\n29\t      <Section heading=\"Round summary\" headingId=\"round-summary-heading\">\n30\t        {detail.game === \"closecall\" ? (\n31\t          <CloseCallSummary round={detail.round} />\n32\t        ) : (\n33\t          <RoundSummary round={detail.round} />\n34\t        )}\n35\t      </Section>\n36\t\n37\t      <Section heading=\"Entries\" headingId=\"entries-heading\">\n38\t        <p style={hintStyle}>\n39\t          {detail.entries.length} participant\n40\t          {detail.entries.length === 1 ? \"\" : \"s\"} from{\" \"}\n41\t          <code style={codeStyle}>game_entries</code> · sorted oldest first.\n42\t        </p>\n43\t        <EntriesTable entries={detail.entries} game={detail.game} />\n44\t      </Section>\n45\t\n46\t      <Section heading=\"Transactions\" headingId=\"transactions-heading\">\n47\t        <p style={hintStyle}>\n48\t          {detail.transactions.length} on-chain SOL movement\n49\t          {detail.transactions.length === 1 ? \"\" : \"s\"} from{\" \"}\n50\t          <code style={codeStyle}>transactions</code> · sorted oldest first.\n51\t        </p>\n52\t        <TransactionsTable transactions={detail.transactions} />\n53\t      </Section>\n54\t    </>\n55\t  );\n56\t}\n57\t\n58\tfunction RoundSummary({ round }: { round: PeekRoundRow }) {\n59\t  return (\n60\t    <dl style={summaryGridStyle}>\n61\t      <SummaryItem label=\"Phase\">\n62\t        <StatusChip label={round.phase} tone={phaseTone(round.phase)} />\n63\t      </SummaryItem>\n64\t      <SummaryItem label=\"Match ID\">\n65\t        <Mono title={round.matchId}>{round.matchId}</Mono>\n66\t      </SummaryItem>\n67\t      <SummaryItem label=\"PDA\">\n68\t        <Mono title={round.pda}>{round.pda}</Mono>\n69\t      </SummaryItem>\n70\t      <SummaryItem label=\"Creator\">\n71\t        <Mono title={round.creator}>{round.creator}</Mono>\n72\t      </SummaryItem>\n73\t      <SummaryItem label=\"Amount (lamports)\">\n74\t        {formatNumber(round.amountLamports)}\n75\t      </SummaryItem>\n76\t      <SummaryItem label=\"Target slot\">\n77\t        {round.targetSlot ? formatNumber(round.targetSlot) : \"—\"}\n78\t      </SummaryItem>\n79\t      <SummaryItem label=\"Settle attempts\">\n80\t        {String(round.settleAttempts)}\n81\t      </SummaryItem>\n82\t      <SummaryItem label=\"Result side\">\n83\t        {round.resultSide === null ? \"—\" : String(round.resultSide)}\n84\t      </SummaryItem>\n85\t      <SummaryItem label=\"Winner\">\n86\t        {round.winner ? <Mono title={round.winner}>{round.winner}</Mono> : \"—\"}\n87\t      </SummaryItem>\n88\t      <SummaryItem label=\"Settle tx\">\n89\t        {round.settleTx ? (\n90\t          <Mono title={round.settleTx}>{round.settleTx}</Mono>\n91\t        ) : (\n92\t          \"—\"\n93\t        )}\n94\t      </SummaryItem>\n95\t      <SummaryItem label=\"Created\">{round.createdAt}</SummaryItem>\n96\t      <SummaryItem label=\"Updated\">{round.updatedAt}</SummaryItem>\n97\t      <SummaryItem label=\"Settled\">{round.settledAt ?? \"—\"}</SummaryItem>\n98\t    </dl>\n99\t  );\n100\t}"}]},"parent_tool_use_id":null,"session_id":"ccf88516-a980-494a-b5f7-15e03a3372de","uuid":"d96b41e7-9251-42c9-9af9-816d07abf2b8","timestamp":"2026-04-25T14:00:04.821Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/round-detail-view.tsx","content":"// Round-detail view (FR-8). Server-renderable, props-only component used by\n// `/games/[game]/rounds/[roundId]/page.tsx`. Lives in `src/components` so it\n// can be tested directly with @testing-library/react against a synthetic\n// `PeekRoundDetail` without spinning up the whole route.\n\nimport Link from \"next/link\";\nimport type { CSSProperties, ReactNode } from \"react\";\nimport { StatusChip } from \"./status-chip\";\nimport type {\n  PeekCloseCallOutcome,\n  PeekCloseCallPhase,\n  PeekCloseCallRoundRow,\n  PeekGameId,\n  PeekRoundDetail,\n  PeekRoundEntryRow,\n  PeekRoundPhase,\n  PeekRoundRow,\n  PeekRoundTransactionRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\n\nexport type RoundDetailViewProps = {\n  detail: PeekRoundDetail;\n};\n\nexport function RoundDetailView({ detail }: RoundDetailViewProps) {\n  return (\n    <>\n      <Section heading=\"Round summary\" headingId=\"round-summary-heading\">\n        {detail.game === \"closecall\" ? (\n          <CloseCallSummary round={detail.round} />\n        ) : (\n          <RoundSummary round={detail.round} />\n        )}\n      </Section>\n\n      <Section heading=\"Entries\" headingId=\"entries-heading\">\n        <p style={hintStyle}>\n          {detail.entries.length} participant\n          {detail.entries.length === 1 ? \"\" : \"s\"} from{\" \"}\n          <code style={codeStyle}>game_entries</code> · sorted oldest first.\n        </p>\n        <EntriesTable entries={detail.entries} game={detail.game} />\n      </Section>\n\n      <Section heading=\"Transactions\" headingId=\"transactions-heading\">\n        <p style={hintStyle}>\n          {detail.transactions.length} on-chain SOL movement\n          {detail.transactions.length === 1 ? \"\" : \"s\"} from{\" \"}\n          <code style={codeStyle}>transactions</code> · sorted oldest first.\n        </p>\n        <TransactionsTable transactions={detail.transactions} />\n      </Section>\n    </>\n  );\n}\n\nfunction RoundSummary({ round }: { round: PeekRoundRow }) {\n  return (\n    <dl style={summaryGridStyle}>\n      <SummaryItem label=\"Phase\">\n        <StatusChip label={round.phase} tone={phaseTone(round.phase)} />\n      </SummaryItem>\n      <SummaryItem label=\"Match ID\">\n        <Mono title={round.matchId}>{round.matchId}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"PDA\">\n        <Mono title={round.pda}>{round.pda}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"Creator\">\n        <Mono title={round.creator}>{round.creator}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"Amount (lamports)\">\n        {formatNumber(round.amountLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Target slot\">\n        {round.targetSlot ? formatNumber(round.targetSlot) : \"—\"}\n      </SummaryItem>\n      <SummaryItem label=\"Settle attempts\">\n        {String(round.settleAttempts)}\n      </SummaryItem>\n      <SummaryItem label=\"Result side\">\n        {round.resultSide === null ? \"—\" : String(round.resultSide)}\n      </SummaryItem>\n      <SummaryItem label=\"Winner\">\n        {round.winner ? <Mono title={round.winner}>{round.winner}</Mono> : \"—\"}\n      </SummaryItem>\n      <SummaryItem label=\"Settle tx\">\n        {round.settleTx ? (\n          <Mono title={round.settleTx}>{round.settleTx}</Mono>\n        ) : (\n          \"—\"\n        )}\n      </SummaryItem>\n      <SummaryItem label=\"Created\">{round.createdAt}</SummaryItem>\n      <SummaryItem label=\"Updated\">{round.updatedAt}</SummaryItem>\n      <SummaryItem label=\"Settled\">{round.settledAt ?? \"—\"}</SummaryItem>\n    </dl>\n  );\n}","numLines":100,"startLine":1,"totalLines":490}}}
