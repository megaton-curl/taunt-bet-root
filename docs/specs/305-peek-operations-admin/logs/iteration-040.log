{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013XB6ioBUEMBW2dFn9Fspmm","type":"tool_result","content":"1\t// /games — cross-game activity overview (FR-8).\n2\t//\n3\t// Reads `getGamesOverview()` (iteration 30) and renders a 6-metric strip plus\n4\t// the per-game `game_entries` counters table. Deferred games (Crash, Game of\n5\t// Trades, Chart the Course, Slots Utopia, Tug of Earn) appear only as\n6\t// documented placeholders per System Invariant 13: they have no persisted\n7\t// source yet, so we do not fabricate empty data rows for them.\n8\timport type { CSSProperties } from \"react\";\n9\timport { GamesOverviewTable } from \"../../src/components/games-overview-table\";\n10\timport { MetricStrip } from \"../../src/components/metric-strip\";\n11\timport { PEEK_DEFERRED_GAMES } from \"../../src/lib/deferred-games\";\n12\timport type {\n13\t  PeekGameOverview,\n14\t  PeekGameOverviewRow,\n15\t} from \"../../src/lib/types/peek\";\n16\timport {\n17\t  getPeekActorContext,\n18\t  isRouteAllowedForRole,\n19\t} from \"../../src/server/access-policy\";\n20\timport { getGamesOverview } from \"../../src/server/db/queries/get-games-overview\";\n21\t\n22\texport const dynamic = \"force-dynamic\";\n23\t\n24\tconst ROUTE = \"/games\";\n25\t\n26\texport default async function GamesOverviewPage() {\n27\t  const actor = await getPeekActorContext();\n28\t  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n29\t\n30\t  if (!allowed) {\n31\t    return (\n32\t      <main style={mainStyle}>\n33\t        <header>\n34\t          <h1>Games</h1>\n35\t        </header>\n36\t        <p role=\"alert\" style={errorStyle}>\n37\t          You do not have access to this page.\n38\t        </p>\n39\t      </main>\n40\t    );\n41\t  }\n42\t\n43\t  let overview: PeekGameOverview = {\n44\t    generatedAt: new Date().toISOString(),\n45\t    metrics: [],\n46\t    perGame: [],\n47\t  };\n48\t  let overviewError: string | null = null;\n49\t  let perGame: ReadonlyArray<PeekGameOverviewRow> = [];\n50\t\n51\t  try {\n52\t    overview = await getGamesOverview();\n53\t    perGame = overview.perGame;\n54\t  } catch (error) {\n55\t    overviewError =\n56\t      error instanceof Error\n57\t        ? error.message\n58\t        : \"Games overview could not be loaded.\";\n59\t  }\n60\t\n61\t  return (\n62\t    <main style={mainStyle}>\n63\t      <header>\n64\t        <h1>Games</h1>\n65\t        <p style={leadStyle}>\n66\t          Cross-game activity from `game_entries` across FlipYou, Pot Shot, and\n67\t          Close Call. Deferred games appear as documented placeholders until\n68\t          their persisted data sources land.\n69\t        </p>\n70\t      </header>\n71\t\n72\t      <section aria-labelledby=\"overview-heading\">\n73\t        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n74\t          Overview\n75\t        </h2>\n76\t        <MetricStrip metrics={overview.metrics} error={overviewError} />\n77\t      </section>\n78\t\n79\t      <section\n80\t        aria-labelledby=\"per-game-heading\"\n81\t        id=\"per-game\"\n82\t        style={sectionStyle}\n83\t      >\n84\t        <h2 id=\"per-game-heading\" style={sectionHeadingStyle}>\n85\t          Per-game activity\n86\t        </h2>\n87\t        <p style={hintStyle}>\n88\t          One row per active game · counters from `game_entries` · all-time.\n89\t        </p>\n90\t        <GamesOverviewTable rows={perGame} error={overviewError} />\n91\t      </section>\n92\t\n93\t      <section\n94\t        aria-labelledby=\"deferred-heading\"\n95\t        id=\"deferred\"\n96\t        style={sectionStyle}\n97\t      >\n98\t        <h2 id=\"deferred-heading\" style={sectionHeadingStyle}>\n99\t          Deferred games\n100\t        </h2>\n101\t        <p style={hintStyle}>\n102\t          Listed for visibility only; no persisted data source yet, so no\n103\t          counters are computed (System Invariant 13).\n104\t        </p>\n105\t        <ul style={deferredListStyle}>\n106\t          {PEEK_DEFERRED_GAMES.map((game) => (\n107\t            <li key={game.id} style={deferredItemStyle}>\n108\t              <span style={deferredLabelStyle}>{game.label}</span>\n109\t              <span style={deferredReasonStyle}>{game.reason}</span>\n110\t            </li>\n111\t          ))}\n112\t        </ul>\n113\t      </section>\n114\t    </main>\n115\t  );\n116\t}\n117\t\n118\tconst mainStyle: CSSProperties = {\n119\t  display: \"grid\",\n120\t  gap: \"1.5rem\",\n121\t};\n122\t\n123\tconst sectionStyle: CSSProperties = {\n124\t  display: \"grid\",\n125\t  gap: \"0.75rem\",\n126\t};\n127\t\n128\tconst sectionHeadingStyle: CSSProperties = {\n129\t  margin: \"0 0 0.75rem\",\n130\t  fontSize: \"1rem\",\n131\t  fontWeight: 600,\n132\t  color: \"#cbd5f5\",\n133\t  textTransform: \"uppercase\",\n134\t  letterSpacing: \"0.05em\",\n135\t};\n136\t\n137\tconst leadStyle: CSSProperties = {\n138\t  margin: \"0.25rem 0 0\",\n139\t  color: \"#94a3b8\",\n140\t};\n141\t\n142\tconst hintStyle: CSSProperties = {\n143\t  margin: 0,\n144\t  color: \"#94a3b8\",\n145\t  fontSize: \"0.8125rem\",\n146\t};\n147\t\n148\tconst errorStyle: CSSProperties = {\n149\t  margin: 0,\n150\t  padding: \"0.75rem 1rem\",\n151\t  borderRadius: \"0.75rem\",\n152\t  background: \"#3f1d1d\",\n153\t  color: \"#fecaca\",\n154\t};\n155\t\n156\tconst deferredListStyle: CSSProperties = {\n157\t  margin: 0,\n158\t  padding: 0,\n159\t  listStyle: \"none\",\n160\t  display: \"grid\",\n161\t  gap: \"0.5rem\",\n162\t};\n163\t\n164\tconst deferredItemStyle: CSSProperties = {\n165\t  display: \"flex\",\n166\t  flexWrap: \"wrap\",\n167\t  alignItems: \"baseline\",\n168\t  gap: \"0.5rem\",\n169\t  padding: \"0.625rem 0.875rem\",\n170\t  borderRadius: \"0.5rem\",\n171\t  border: \"1px dashed #334155\",\n172\t  background: \"#0b1220\",\n173\t};\n174\t\n175\tconst deferredLabelStyle: CSSProperties = {\n176\t  fontWeight: 600,\n177\t  color: \"#cbd5f5\",\n178\t};\n179\t\n180\tconst deferredReasonStyle: CSSProperties = {\n181\t  color: \"#94a3b8\",\n182\t  fontSize: \"0.8125rem\",\n183\t};\n184\t"}]},"parent_tool_use_id":null,"session_id":"ccf88516-a980-494a-b5f7-15e03a3372de","uuid":"6c2b78ca-053d-43da-b357-ce4074134d21","timestamp":"2026-04-25T13:57:43.346Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/app/games/page.tsx","content":"// /games — cross-game activity overview (FR-8).\n//\n// Reads `getGamesOverview()` (iteration 30) and renders a 6-metric strip plus\n// the per-game `game_entries` counters table. Deferred games (Crash, Game of\n// Trades, Chart the Course, Slots Utopia, Tug of Earn) appear only as\n// documented placeholders per System Invariant 13: they have no persisted\n// source yet, so we do not fabricate empty data rows for them.\nimport type { CSSProperties } from \"react\";\nimport { GamesOverviewTable } from \"../../src/components/games-overview-table\";\nimport { MetricStrip } from \"../../src/components/metric-strip\";\nimport { PEEK_DEFERRED_GAMES } from \"../../src/lib/deferred-games\";\nimport type {\n  PeekGameOverview,\n  PeekGameOverviewRow,\n} from \"../../src/lib/types/peek\";\nimport {\n  getPeekActorContext,\n  isRouteAllowedForRole,\n} from \"../../src/server/access-policy\";\nimport { getGamesOverview } from \"../../src/server/db/queries/get-games-overview\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst ROUTE = \"/games\";\n\nexport default async function GamesOverviewPage() {\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n\n  if (!allowed) {\n    return (\n      <main style={mainStyle}>\n        <header>\n          <h1>Games</h1>\n        </header>\n        <p role=\"alert\" style={errorStyle}>\n          You do not have access to this page.\n        </p>\n      </main>\n    );\n  }\n\n  let overview: PeekGameOverview = {\n    generatedAt: new Date().toISOString(),\n    metrics: [],\n    perGame: [],\n  };\n  let overviewError: string | null = null;\n  let perGame: ReadonlyArray<PeekGameOverviewRow> = [];\n\n  try {\n    overview = await getGamesOverview();\n    perGame = overview.perGame;\n  } catch (error) {\n    overviewError =\n      error instanceof Error\n        ? error.message\n        : \"Games overview could not be loaded.\";\n  }\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <h1>Games</h1>\n        <p style={leadStyle}>\n          Cross-game activity from `game_entries` across FlipYou, Pot Shot, and\n          Close Call. Deferred games appear as documented placeholders until\n          their persisted data sources land.\n        </p>\n      </header>\n\n      <section aria-labelledby=\"overview-heading\">\n        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n          Overview\n        </h2>\n        <MetricStrip metrics={overview.metrics} error={overviewError} />\n      </section>\n\n      <section\n        aria-labelledby=\"per-game-heading\"\n        id=\"per-game\"\n        style={sectionStyle}\n      >\n        <h2 id=\"per-game-heading\" style={sectionHeadingStyle}>\n          Per-game activity\n        </h2>\n        <p style={hintStyle}>\n          One row per active game · counters from `game_entries` · all-time.\n        </p>\n        <GamesOverviewTable rows={perGame} error={overviewError} />\n      </section>\n\n      <section\n        aria-labelledby=\"deferred-heading\"\n        id=\"deferred\"\n        style={sectionStyle}\n      >\n        <h2 id=\"deferred-heading\" style={sectionHeadingStyle}>\n          Deferred games\n        </h2>\n        <p style={hintStyle}>\n          Listed for visibility only; no persisted data source yet, so no\n          counters are computed (System Invariant 13).\n        </p>\n        <ul style={deferredListStyle}>\n          {PEEK_DEFERRED_GAMES.map((game) => (\n            <li key={game.id} style={deferredItemStyle}>\n              <span style={deferredLabelStyle}>{game.label}</span>\n              <span style={deferredReasonStyle}>{game.reason}</span>\n            </li>\n          ))}\n        </ul>\n      </section>\n    </main>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst deferredListStyle: CSSProperties = {\n  margin: 0,\n  padding: 0,\n  listStyle: \"none\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst deferredItemStyle: CSSProperties = {\n  display: \"flex\",\n  flexWrap: \"wrap\",\n  alignItems: \"baseline\",\n  gap: \"0.5rem\",\n  padding: \"0.625rem 0.875rem\",\n  borderRadius: \"0.5rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n};\n\nconst deferredLabelStyle: CSSProperties = {\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n};\n\nconst deferredReasonStyle: CSSProperties = {\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n","numLines":184,"startLine":1,"totalLines":184}}}
