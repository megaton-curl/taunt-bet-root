left\")}>Requested</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>\n            <th style={headerCellStyle(\"left\")}>Status</th>\n            <th style={headerCellStyle(\"right\")}>Retries</th>\n            <th style={headerCellStyle(\"left\")}>Tx signature</th>\n            <th style={headerCellStyle(\"left\")}>Processed</th>\n            <th style={headerCellStyle(\"left\")}>Error</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{row.requestedAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <Link href={`/users/${row.userId}`} style={linkStyle}>\n                  {row.username ?? row.userId}\n                </Link>\n                {row.username ? (\n                  <span style={subValueStyle}> · {row.userId}</span>\n                ) : null}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.wallet}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatLamports(row.amountLamports)}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.status}\n                  tone={statusTone(row.status)}\n                />\n              </td>\n              <td style={bodyCellStyle(\"right\")}>{row.retryCount}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.txSignature ?? \"—\"}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.processedAt ?? \"—\"}</td>\n              <td style={bodyCellStyle(\"left\")}>{row.error ?? \"—\"}</td>\n            </tr>\n          ))}