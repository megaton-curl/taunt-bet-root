{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FkjGtjEWsb84wGE2FwUdXn","type":"tool_result","content":"1\t// Per-game overview table for /games (FR-8).\n2\t//\n3\t// Dense readonly table over `PeekGameOverviewRow` showing the operational\n4\t// counters the spec calls out: entries, unique users, wagered lamports,\n5\t// settled entries, refund entries, payout lamports, wins, losses. Lamport\n6\t// columns are right-aligned and grouped with thousands separators; counts use\n7\t// integer formatting per FR-4.\n8\timport type { CSSProperties } from \"react\";\n9\timport type { PeekGameId, PeekGameOverviewRow } from \"../lib/types/peek\";\n10\t\n11\texport type GamesOverviewTableProps = {\n12\t  rows: ReadonlyArray<PeekGameOverviewRow>;\n13\t  error?: string | null;\n14\t};\n15\t\n16\tconst GAME_LABELS: Record<PeekGameId, string> = {\n17\t  flipyou: \"FlipYou\",\n18\t  potshot: \"Pot Shot\",\n19\t  closecall: \"Close Call\",\n20\t};\n21\t\n22\texport function GamesOverviewTable({\n23\t  rows,\n24\t  error = null,\n25\t}: GamesOverviewTableProps) {\n26\t  if (error) {\n27\t    return (\n28\t      <div role=\"alert\" style={errorStyle}>\n29\t        Per-game activity unavailable: {error}\n30\t      </div>\n31\t    );\n32\t  }\n33\t\n34\t  if (rows.length === 0) {\n35\t    return (\n36\t      <div role=\"status\" style={emptyStyle}>\n37\t        <p style={emptyTitleStyle}>No game activity recorded.</p>\n38\t        <p style={emptyBodyStyle}>\n39\t          `game_entries` is empty, so no per-game counters can be rendered.\n40\t        </p>\n41\t      </div>\n42\t    );\n43\t  }\n44\t\n45\t  return (\n46\t    <div style={wrapperStyle}>\n47\t      <table style={tableStyle}>\n48\t        <thead>\n49\t          <tr style={headerRowStyle}>\n50\t            <th style={headerCellStyle(\"left\")}>Game</th>\n51\t            <th style={headerCellStyle(\"right\")}>Entries</th>\n52\t            <th style={headerCellStyle(\"right\")}>Unique users</th>\n53\t            <th style={headerCellStyle(\"right\")}>Wagered (lamports)</th>\n54\t            <th style={headerCellStyle(\"right\")}>Settled</th>\n55\t            <th style={headerCellStyle(\"right\")}>Refunds</th>\n56\t            <th style={headerCellStyle(\"right\")}>Paid out (lamports)</th>\n57\t            <th style={headerCellStyle(\"right\")}>Wins</th>\n58\t            <th style={headerCellStyle(\"right\")}>Losses</th>\n59\t          </tr>\n60\t        </thead>\n61\t        <tbody>\n62\t          {rows.map((row) => (\n63\t            <tr key={row.game} style={bodyRowStyle}>\n64\t              <td style={bodyCellStyle(\"left\")}>\n65\t                <span style={gameLabelStyle}>{GAME_LABELS[row.game]}</span>\n66\t                <span style={subValueStyle}> · {row.game}</span>\n67\t              </td>\n68\t              <td style={bodyCellStyle(\"right\")}>{formatCount(row.entries)}</td>\n69\t              <td style={bodyCellStyle(\"right\")}>\n70\t                {formatCount(row.uniqueUsers)}\n71\t              </td>\n72\t              <td style={bodyCellStyle(\"right\")}>\n73\t                {formatLamports(row.wageredLamports)}\n74\t              </td>\n75\t              <td style={bodyCellStyle(\"right\")}>\n76\t                {formatCount(row.settledEntries)}\n77\t              </td>\n78\t              <td style={bodyCellStyle(\"right\")}>\n79\t                {formatCount(row.refundEntries)}\n80\t              </td>\n81\t              <td style={bodyCellStyle(\"right\")}>\n82\t                {formatLamports(row.payoutLamports)}\n83\t              </td>\n84\t              <td style={bodyCellStyle(\"right\")}>{formatCount(row.wins)}</td>\n85\t              <td style={bodyCellStyle(\"right\")}>{formatCount(row.losses)}</td>\n86\t            </tr>\n87\t          ))}\n88\t        </tbody>\n89\t      </table>\n90\t    </div>\n91\t  );\n92\t}\n93\t\n94\tfunction formatCount(value: number): string {\n95\t  return value.toLocaleString(\"en-US\");\n96\t}\n97\t\n98\tfunction formatLamports(value: string): string {\n99\t  if (!value || value === \"0\") return \"0\";\n100\t  const negative = value.startsWith(\"-\");\n101\t  const digits = negative ? value.slice(1) : value;\n102\t  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n103\t  return negative ? `-${grouped}` : grouped;\n104\t}\n105\t\n106\tconst wrapperStyle: CSSProperties = {\n107\t  overflowX: \"auto\",\n108\t  border: \"1px solid #1e293b\",\n109\t  borderRadius: \"0.75rem\",\n110\t};\n111\t\n112\tconst tableStyle: CSSProperties = {\n113\t  width: \"100%\",\n114\t  borderCollapse: \"collapse\",\n115\t};\n116\t\n117\tconst headerRowStyle: CSSProperties = {\n118\t  background: \"#111827\",\n119\t  color: \"#94a3b8\",\n120\t};\n121\t\n122\tconst bodyRowStyle: CSSProperties = {\n123\t  borderTop: \"1px solid #1e293b\",\n124\t};\n125\t\n126\tconst gameLabelStyle: CSSProperties = {\n127\t  color: \"#e2e8f0\",\n128\t  fontWeight: 600,\n129\t};\n130\t\n131\tconst subValueStyle: CSSProperties = {\n132\t  color: \"#64748b\",\n133\t  fontSize: \"0.75rem\",\n134\t  marginLeft: \"0.25rem\",\n135\t};\n136\t\n137\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n138\t  return {\n139\t    padding: \"0.75rem\",\n140\t    textAlign: align,\n141\t    fontSize: \"0.875rem\",\n142\t    fontWeight: 600,\n143\t  };\n144\t}\n145\t\n146\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n147\t  return {\n148\t    padding: \"0.75rem\",\n149\t    textAlign: align,\n150\t    fontSize: \"0.875rem\",\n151\t  };\n152\t}\n153\t\n154\tconst errorStyle: CSSProperties = {\n155\t  margin: 0,\n156\t  padding: \"0.75rem 1rem\",\n157\t  borderRadius: \"0.75rem\",\n158\t  background: \"#3f1d1d\",\n159\t  color: \"#fecaca\",\n160\t};\n161\t\n162\tconst emptyStyle: CSSProperties = {\n163\t  padding: \"1.5rem\",\n164\t  borderRadius: \"0.75rem\",\n165\t  border: \"1px dashed #334155\",\n166\t  background: \"#0b1220\",\n167\t  color: \"#cbd5f5\",\n168\t  display: \"grid\",\n169\t  gap: \"0.5rem\",\n170\t};\n171\t\n172\tconst emptyTitleStyle: CSSProperties = {\n173\t  margin: 0,\n174\t  fontSize: \"1rem\",\n175\t  fontWeight: 600,\n176\t};\n177\t\n178\tconst emptyBodyStyle: CSSProperties = {\n179\t  margin: 0,\n180\t  fontSize: \"0.875rem\",\n181\t  color: \"#94a3b8\",\n182\t};\n183\t"}]},"parent_tool_use_id":null,"session_id":"ccf88516-a980-494a-b5f7-15e03a3372de","uuid":"b61fa991-7248-4e3e-8843-25976d21e49f","timestamp":"2026-04-25T13:57:41.120Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/games-overview-table.tsx","content":"// Per-game overview table for /games (FR-8).\n//\n// Dense readonly table over `PeekGameOverviewRow` showing the operational\n// counters the spec calls out: entries, unique users, wagered lamports,\n// settled entries, refund entries, payout lamports, wins, losses. Lamport\n// columns are right-aligned and grouped with thousands separators; counts use\n// integer formatting per FR-4.\nimport type { CSSProperties } from \"react\";\nimport type { PeekGameId, PeekGameOverviewRow } from \"../lib/types/peek\";\n\nexport type GamesOverviewTableProps = {\n  rows: ReadonlyArray<PeekGameOverviewRow>;\n  error?: string | null;\n};\n\nconst GAME_LABELS: Record<PeekGameId, string> = {\n  flipyou: \"FlipYou\",\n  potshot: \"Pot Shot\",\n  closecall: \"Close Call\",\n};\n\nexport function GamesOverviewTable({\n  rows,\n  error = null,\n}: GamesOverviewTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Per-game activity unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No game activity recorded.</p>\n        <p style={emptyBodyStyle}>\n          `game_entries` is empty, so no per-game counters can be rendered.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Game</th>\n            <th style={headerCellStyle(\"right\")}>Entries</th>\n            <th style={headerCellStyle(\"right\")}>Unique users</th>\n            <th style={headerCellStyle(\"right\")}>Wagered (lamports)</th>\n            <th style={headerCellStyle(\"right\")}>Settled</th>\n            <th style={headerCellStyle(\"right\")}>Refunds</th>\n            <th style={headerCellStyle(\"right\")}>Paid out (lamports)</th>\n            <th style={headerCellStyle(\"right\")}>Wins</th>\n            <th style={headerCellStyle(\"right\")}>Losses</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.game} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>\n                <span style={gameLabelStyle}>{GAME_LABELS[row.game]}</span>\n                <span style={subValueStyle}> · {row.game}</span>\n              </td>\n              <td style={bodyCellStyle(\"right\")}>{formatCount(row.entries)}</td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatCount(row.uniqueUsers)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatLamports(row.wageredLamports)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatCount(row.settledEntries)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatCount(row.refundEntries)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatLamports(row.payoutLamports)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>{formatCount(row.wins)}</td>\n              <td style={bodyCellStyle(\"right\")}>{formatCount(row.losses)}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction formatCount(value: number): string {\n  return value.toLocaleString(\"en-US\");\n}\n\nfunction formatLamports(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst gameLabelStyle: CSSProperties = {\n  color: \"#e2e8f0\",\n  fontWeight: 600,\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n  marginLeft: \"0.25rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":183,"startLine":1,"totalLines":183}}}
