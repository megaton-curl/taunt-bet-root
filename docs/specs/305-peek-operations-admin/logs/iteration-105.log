{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016wSj7QyDsA7xdXkFT7bFaf","type":"tool_result","content":"1\t// Component tests for the FR-10 /operations/queue filter bar.\n2\t//\n3\t// The filter bar is a query-string GET form (no JS), so each test asserts:\n4\t//   - the form posts to /operations/queue via GET;\n5\t//   - each input/select uses its `queueFilter*` name (matches the URL parser);\n6\t//   - the status + age-bucket selects expose every allowlisted enum value;\n7\t//   - populated filters pre-fill every field;\n8\t//   - ISO timestamps in date filters are truncated to YYYY-MM-DD;\n9\t//   - the custom action prop overrides the default form target;\n10\t//   - the `selectedId` param is intentionally NOT a hidden input (submitting\n11\t//     the filter form clears the detail panel rather than reopening the row).\n12\t\n13\timport { describe, expect, it } from \"vitest\";\n14\timport { render, screen } from \"@testing-library/react\";\n15\timport { EventQueueFilterBar } from \"../event-queue-filter-bar\";\n16\timport {\n17\t  PEEK_EVENT_QUEUE_AGE_BUCKETS,\n18\t  PEEK_EVENT_QUEUE_STATUSES,\n19\t} from \"../../lib/types/peek\";\n20\timport type { PeekEventQueueFilters } from \"../../lib/types/peek\";\n21\t\n22\tconst EMPTY_FILTERS: PeekEventQueueFilters = {\n23\t  status: null,\n24\t  eventType: null,\n25\t  id: null,\n26\t  payloadUserId: null,\n27\t  scheduledFrom: null,\n28\t  scheduledTo: null,\n29\t  createdFrom: null,\n30\t  createdTo: null,\n31\t  ageBucket: null,\n32\t};\n33\t\n34\tconst POPULATED_FILTERS: PeekEventQueueFilters = {\n35\t  status: \"failed\",\n36\t  eventType: \"points.grant\",\n37\t  id: \"11111111-1111-1111-1111-111111111111\",\n38\t  payloadUserId: \"user-9\",\n39\t  scheduledFrom: \"2026-04-01\",\n40\t  scheduledTo: \"2026-04-26\",\n41\t  createdFrom: \"2026-04-01\",\n42\t  createdTo: \"2026-04-26\",\n43\t  ageBucket: \"lt_24h\",\n44\t};\n45\t\n46\tdescribe(\"EventQueueFilterBar\", () => {\n47\t  it(\"empty: form posts to /operations/queue by default with all inputs blank and 'Any' selected\", () => {\n48\t    render(<EventQueueFilterBar filters={EMPTY_FILTERS} />);\n49\t\n50\t    const form = screen.getByRole(\"search\", { name: \"Filter event queue\" });\n51\t    expect(form).toHaveAttribute(\"action\", \"/operations/queue\");\n52\t    expect(form).toHaveAttribute(\"method\", \"get\");\n53\t\n54\t    const status = screen.getByLabelText(\"Status\") as HTMLSelectElement;\n55\t    expect(status.value).toBe(\"\");\n56\t    const statusOptionValues = Array.from(status.options).map((o) => o.value);\n57\t    expect(statusOptionValues).toContain(\"\");\n58\t    for (const value of PEEK_EVENT_QUEUE_STATUSES) {\n59\t      expect(statusOptionValues).toContain(value);\n60\t    }\n61\t\n62\t    const ageBucket = screen.getByLabelText(\"Age bucket\") as HTMLSelectElement;\n63\t    expect(ageBucket.value).toBe(\"\");\n64\t    const ageOptionValues = Array.from(ageBucket.options).map((o) => o.value);\n65\t    expect(ageOptionValues).toContain(\"\");\n66\t    for (const bucket of PEEK_EVENT_QUEUE_AGE_BUCKETS) {\n67\t      expect(ageOptionValues).toContain(bucket.id);\n68\t    }\n69\t\n70\t    expect((screen.getByLabelText(\"Event type\") as HTMLInputElement).value).toBe(\n71\t      \"\",\n72\t    );\n73\t    expect((screen.getByLabelText(\"Event id\") as HTMLInputElement).value).toBe(\n74\t      \"\",\n75\t    );\n76\t    expect(\n77\t      (screen.getByLabelText(\"Payload user id\") as HTMLInputElement).value,\n78\t    ).toBe(\"\");\n79\t    expect(\n80\t      (screen.getByLabelText(\"Scheduled from\") as HTMLInputElement).value,\n81\t    ).toBe(\"\");\n82\t    expect(\n83\t      (screen.getByLabelText(\"Scheduled to\") as HTMLInputElement).value,\n84\t    ).toBe(\"\");\n85\t    expect(\n86\t      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n87\t    ).toBe(\"\");\n88\t    expect(\n89\t      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n90\t    ).toBe(\"\");\n91\t  });\n92\t\n93\t  it(\"populated: pre-fills every field including the status + age-bucket selects\", () => {\n94\t    render(<EventQueueFilterBar filters={POPULATED_FILTERS} />);\n95\t\n96\t    expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).value).toBe(\n97\t      \"failed\",\n98\t    );\n99\t    expect(\n100\t      (screen.getByLabelText(\"Age bucket\") as HTMLSelectElement).value,\n101\t    ).toBe(\"lt_24h\");\n102\t    expect(\n103\t      (screen.getByLabelText(\"Event type\") as HTMLInputElement).value,\n104\t    ).toBe(\"points.grant\");\n105\t    expect((screen.getByLabelText(\"Event id\") as HTMLInputElement).value).toBe(\n106\t      \"11111111-1111-1111-1111-111111111111\",\n107\t    );\n108\t    expect(\n109\t      (screen.getByLabelText(\"Payload user id\") as HTMLInputElement).value,\n110\t    ).toBe(\"user-9\");\n111\t    expect(\n112\t      (screen.getByLabelText(\"Scheduled from\") as HTMLInputElement).value,\n113\t    ).toBe(\"2026-04-01\");\n114\t    expect(\n115\t      (screen.getByLabelText(\"Scheduled to\") as HTMLInputElement).value,\n116\t    ).toBe(\"2026-04-26\");\n117\t    expect(\n118\t      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n119\t    ).toBe(\"2026-04-01\");\n120\t    expect(\n121\t      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n122\t    ).toBe(\"2026-04-26\");\n123\t  });\n124\t\n125\t  it(\"inputs use the queueFilter* prefix so the URL parser binds back without collisions\", () => {\n126\t    render(<EventQueueFilterBar filters={EMPTY_FILTERS} />);\n127\t\n128\t    expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).name).toBe(\n129\t      \"queueFilterStatus\",\n130\t    );\n131\t    expect(\n132\t      (screen.getByLabelText(\"Age bucket\") as HTMLSelectElement).name,\n133\t    ).toBe(\"queueFilterAge\");\n134\t    expect(\n135\t      (screen.getByLabelText(\"Event type\") as HTMLInputElement).name,\n136\t    ).toBe(\"queueFilterType\");\n137\t    expect((screen.getByLabelText(\"Event id\") as HTMLInputElement).name).toBe(\n138\t      \"queueFilterId\",\n139\t    );\n140\t    expect(\n141\t      (screen.getByLabelText(\"Payload user id\") as HTMLInputElement).name,\n142\t    ).toBe(\"queueFilterUserId\");\n143\t    expect(\n144\t      (screen.getByLabelText(\"Scheduled from\") as HTMLInputElement).name,\n145\t    ).toBe(\"queueFilterScheduledFrom\");\n146\t    expect(\n147\t      (screen.getByLabelText(\"Scheduled to\") as HTMLInputElement).name,\n148\t    ).toBe(\"queueFilterScheduledTo\");\n149\t    expect(\n150\t      (screen.getByLabelText(\"Created from\") as HTMLInputElement).name,\n151\t    ).toBe(\"queueFilterCreatedFrom\");\n152\t    expect(\n153\t      (screen.getByLabelText(\"Created to\") as HTMLInputElement).name,\n154\t    ).toBe(\"queueFilterCreatedTo\");\n155\t  });\n156\t\n157\t  it(\"populated: ISO timestamps in date filters are truncated to YYYY-MM-DD for the date inputs\", () => {\n158\t    render(\n159\t      <EventQueueFilterBar\n160\t        filters={{\n161\t          ...EMPTY_FILTERS,\n162\t          scheduledFrom: \"2026-04-01T10:00:00.000Z\",\n163\t          scheduledTo: \"2026-04-26T23:59:59.999Z\",\n164\t          createdFrom: \"2026-04-01T10:00:00.000Z\",\n165\t          createdTo: \"2026-04-26T23:59:59.999Z\",\n166\t        }}\n167\t      />,\n168\t    );\n169\t\n170\t    expect(\n171\t      (screen.getByLabelText(\"Scheduled from\") as HTMLInputElement).value,\n172\t    ).toBe(\"2026-04-01\");\n173\t    expect(\n174\t      (screen.getByLabelText(\"Scheduled to\") as HTMLInputElement).value,\n175\t    ).toBe(\"2026-04-26\");\n176\t    expect(\n177\t      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n178\t    ).toBe(\"2026-04-01\");\n179\t    expect(\n180\t      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n181\t    ).toBe(\"2026-04-26\");\n182\t  });\n183\t\n184\t  it(\"custom action overrides the default form target\", () => {\n185\t    render(\n186\t      <EventQueueFilterBar\n187\t        filters={EMPTY_FILTERS}\n188\t        action=\"/operations/queue?embed=1\"\n189\t      />,\n190\t    );\n191\t    const form = screen.getByRole(\"search\", { name: \"Filter event queue\" });\n192\t    expect(form).toHaveAttribute(\"action\", \"/operations/queue?embed=1\");\n193\t  });\n194\t\n195\t  it(\"does NOT render a hidden selectedId input — submitting the filter form clears the detail panel\", () => {\n196\t    // The filter bar submitting must NOT carry the previously-selected detail\n197\t    // row id forward (otherwise opening a detail row would never clear via\n198\t    // a filter submission). The component-level invariant: there must be no\n199\t    // `<input name=\"selectedId\">` element rendered.\n200\t    const { container } = render(<EventQueueFilterBar filters={EMPTY_FILTERS} />);\n201\t    expect(container.querySelector(\"input[name='selectedId']\")).toBeNull();\n202\t  });\n203\t\n204\t  it(\"status: state-transition coverage — every PEEK_EVENT_QUEUE_STATUSES value is renderable as a chosen option\", () => {\n205\t    for (const value of PEEK_EVENT_QUEUE_STATUSES) {\n206\t      const { unmount } = render(\n207\t        <EventQueueFilterBar filters={{ ...EMPTY_FILTERS, status: value }} />,\n208\t      );\n209\t      expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).value).toBe(\n210\t        value,\n211\t      );\n212\t      unmount();\n213\t    }\n214\t  });\n215\t});\n216\t"}]},"parent_tool_use_id":null,"session_id":"94a07cbb-8d25-425b-954a-4878bb9ef4df","uuid":"cfffcaff-93eb-4507-89c0-0aee17105ec4","timestamp":"2026-04-26T07:24:03.171Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/event-queue-filter-bar.test.tsx","content":"// Component tests for the FR-10 /operations/queue filter bar.\n//\n// The filter bar is a query-string GET form (no JS), so each test asserts:\n//   - the form posts to /operations/queue via GET;\n//   - each input/select uses its `queueFilter*` name (matches the URL parser);\n//   - the status + age-bucket selects expose every allowlisted enum value;\n//   - populated filters pre-fill every field;\n//   - ISO timestamps in date filters are truncated to YYYY-MM-DD;\n//   - the custom action prop overrides the default form target;\n//   - the `selectedId` param is intentionally NOT a hidden input (submitting\n//     the filter form clears the detail panel rather than reopening the row).\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { EventQueueFilterBar } from \"../event-queue-filter-bar\";\nimport {\n  PEEK_EVENT_QUEUE_AGE_BUCKETS,\n  PEEK_EVENT_QUEUE_STATUSES,\n} from \"../../lib/types/peek\";\nimport type { PeekEventQueueFilters } from \"../../lib/types/peek\";\n\nconst EMPTY_FILTERS: PeekEventQueueFilters = {\n  status: null,\n  eventType: null,\n  id: null,\n  payloadUserId: null,\n  scheduledFrom: null,\n  scheduledTo: null,\n  createdFrom: null,\n  createdTo: null,\n  ageBucket: null,\n};\n\nconst POPULATED_FILTERS: PeekEventQueueFilters = {\n  status: \"failed\",\n  eventType: \"points.grant\",\n  id: \"11111111-1111-1111-1111-111111111111\",\n  payloadUserId: \"user-9\",\n  scheduledFrom: \"2026-04-01\",\n  scheduledTo: \"2026-04-26\",\n  createdFrom: \"2026-04-01\",\n  createdTo: \"2026-04-26\",\n  ageBucket: \"lt_24h\",\n};\n\ndescribe(\"EventQueueFilterBar\", () => {\n  it(\"empty: form posts to /operations/queue by default with all inputs blank and 'Any' selected\", () => {\n    render(<EventQueueFilterBar filters={EMPTY_FILTERS} />);\n\n    const form = screen.getByRole(\"search\", { name: \"Filter event queue\" });\n    expect(form).toHaveAttribute(\"action\", \"/operations/queue\");\n    expect(form).toHaveAttribute(\"method\", \"get\");\n\n    const status = screen.getByLabelText(\"Status\") as HTMLSelectElement;\n    expect(status.value).toBe(\"\");\n    const statusOptionValues = Array.from(status.options).map((o) => o.value);\n    expect(statusOptionValues).toContain(\"\");\n    for (const value of PEEK_EVENT_QUEUE_STATUSES) {\n      expect(statusOptionValues).toContain(value);\n    }\n\n    const ageBucket = screen.getByLabelText(\"Age bucket\") as HTMLSelectElement;\n    expect(ageBucket.value).toBe(\"\");\n    const ageOptionValues = Array.from(ageBucket.options).map((o) => o.value);\n    expect(ageOptionValues).toContain(\"\");\n    for (const bucket of PEEK_EVENT_QUEUE_AGE_BUCKETS) {\n      expect(ageOptionValues).toContain(bucket.id);\n    }\n\n    expect((screen.getByLabelText(\"Event type\") as HTMLInputElement).value).toBe(\n      \"\",\n    );\n    expect((screen.getByLabelText(\"Event id\") as HTMLInputElement).value).toBe(\n      \"\",\n    );\n    expect(\n      (screen.getByLabelText(\"Payload user id\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Scheduled from\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Scheduled to\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"\");\n  });\n\n  it(\"populated: pre-fills every field including the status + age-bucket selects\", () => {\n    render(<EventQueueFilterBar filters={POPULATED_FILTERS} />);\n\n    expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).value).toBe(\n      \"failed\",\n    );\n    expect(\n      (screen.getByLabelText(\"Age bucket\") as HTMLSelectElement).value,\n    ).toBe(\"lt_24h\");\n    expect(\n      (screen.getByLabelText(\"Event type\") as HTMLInputElement).value,\n    ).toBe(\"points.grant\");\n    expect((screen.getByLabelText(\"Event id\") as HTMLInputElement).value).toBe(\n      \"11111111-1111-1111-1111-111111111111\",\n    );\n    expect(\n      (screen.getByLabelText(\"Payload user id\") as HTMLInputElement).value,\n    ).toBe(\"user-9\");\n    expect(\n      (screen.getByLabelText(\"Scheduled from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Scheduled to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n  });\n\n  it(\"inputs use the queueFilter* prefix so the URL parser binds back without collisions\", () => {\n    render(<EventQueueFilterBar filters={EMPTY_FILTERS} />);\n\n    expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).name).toBe(\n      \"queueFilterStatus\",\n    );\n    expect(\n      (screen.getByLabelText(\"Age bucket\") as HTMLSelectElement).name,\n    ).toBe(\"queueFilterAge\");\n    expect(\n      (screen.getByLabelText(\"Event type\") as HTMLInputElement).name,\n    ).toBe(\"queueFilterType\");\n    expect((screen.getByLabelText(\"Event id\") as HTMLInputElement).name).toBe(\n      \"queueFilterId\",\n    );\n    expect(\n      (screen.getByLabelText(\"Payload user id\") as HTMLInputElement).name,\n    ).toBe(\"queueFilterUserId\");\n    expect(\n      (screen.getByLabelText(\"Scheduled from\") as HTMLInputElement).name,\n    ).toBe(\"queueFilterScheduledFrom\");\n    expect(\n      (screen.getByLabelText(\"Scheduled to\") as HTMLInputElement).name,\n    ).toBe(\"queueFilterScheduledTo\");\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).name,\n    ).toBe(\"queueFilterCreatedFrom\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).name,\n    ).toBe(\"queueFilterCreatedTo\");\n  });\n\n  it(\"populated: ISO timestamps in date filters are truncated to YYYY-MM-DD for the date inputs\", () => {\n    render(\n      <EventQueueFilterBar\n        filters={{\n          ...EMPTY_FILTERS,\n          scheduledFrom: \"2026-04-01T10:00:00.000Z\",\n          scheduledTo: \"2026-04-26T23:59:59.999Z\",\n          createdFrom: \"2026-04-01T10:00:00.000Z\",\n          createdTo: \"2026-04-26T23:59:59.999Z\",\n        }}\n      />,\n    );\n\n    expect(\n      (screen.getByLabelText(\"Scheduled from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Scheduled to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n  });\n\n  it(\"custom action overrides the default form target\", () => {\n    render(\n      <EventQueueFilterBar\n        filters={EMPTY_FILTERS}\n        action=\"/operations/queue?embed=1\"\n      />,\n    );\n    const form = screen.getByRole(\"search\", { name: \"Filter event queue\" });\n    expect(form).toHaveAttribute(\"action\", \"/operations/queue?embed=1\");\n  });\n\n  it(\"does NOT render a hidden selectedId input — submitting the filter form clears the detail panel\", () => {\n    // The filter bar submitting must NOT carry the previously-selected detail\n    // row id forward (otherwise opening a detail row would never clear via\n    // a filter submission). The component-level invariant: there must be no\n    // `<input name=\"selectedId\">` element rendered.\n    const { container } = render(<EventQueueFilterBar filters={EMPTY_FILTERS} />);\n    expect(container.querySelector(\"input[name='selectedId']\")).toBeNull();\n  });\n\n  it(\"status: state-transition coverage — every PEEK_EVENT_QUEUE_STATUSES value is renderable as a chosen option\", () => {\n    for (const value of PEEK_EVENT_QUEUE_STATUSES) {\n      const { unmount } = render(\n        <EventQueueFilterBar filters={{ ...EMPTY_FILTERS, status: value }} />,\n      );\n      expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).value).toBe(\n        value,\n      );\n      unmount();\n    }\n  });\n});\n","numLines":216,"startLine":1,"totalLines":216}}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01SKjgBdBRiiKFK5fsps8v1u","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_018e8MTQ1mFJPFb8b2tRvW32","name":"Read","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/__tests__/event-queue-table.test.tsx"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1615,"cache_read_input_tokens":91510,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1615},"output_tokens":72,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"94a07cbb-8d25-425b-954a-4878bb9ef4df","uuid":"6b9a5a9f-5d17-4b87-8e0b-ff88ff06cf91"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018e8MTQ1mFJPFb8b2tRvW32","type":"tool_result","content":"1\t// Component tests for the FR-10 /operations/queue event queue table.\n2\t//\n3\t// Read-only by spec — every queue mutation (retry / cancel / replay) lives\n4\t// behind a future spec (FR-10 line 342). These tests assert there are no edit\n5\t// affordances rendered, every status drives the right chip tone, the linked\n6\t// payload ids surface as drilldowns, and the row id anchor sets\n7\t// `?selectedId=<id>` so the detail panel can resolve it server-side.\n8\t//\n9\t// Coverage spans the spec line \"pending, failed, dead, aged, filtered,\n10\t// redacted-payload states\": fixtures cover every lifecycle status, and a\n11\t// dedicated test asserts the redacted error preview round-trips verbatim into\n12\t// the row.\n13\t\n14\timport { describe, expect, it } from \"vitest\";\n15\timport { render, screen } from \"@testing-library/react\";\n16\timport {\n17\t  EventQueueTable,\n18\t  queueStatusTone,\n19\t} from \"../event-queue-table\";\n20\timport { PEEK_AUDIT_REDACTED } from \"../../lib/types/peek\";\n21\timport type { PeekEventQueueListRow } from \"../../lib/types/peek\";\n22\t\n23\tconst ROW_PENDING: PeekEventQueueListRow = {\n24\t  id: \"11111111-1111-1111-1111-111111111111\",\n25\t  eventType: \"points.grant\",\n26\t  status: \"pending\",\n27\t  attempts: 0,\n28\t  maxAttempts: 5,\n29\t  scheduledAt: \"2026-04-26T10:00:00.000Z\",\n30\t  startedAt: null,\n31\t  completedAt: null,\n32\t  createdAt: \"2026-04-26T09:55:00.000Z\",\n33\t  errorPreview: null,\n34\t  linked: { userId: \"user-9\", roundId: null, claimId: null },\n35\t};\n36\t\n37\tconst ROW_FAILED: PeekEventQueueListRow = {\n38\t  id: \"22222222-2222-2222-2222-222222222222\",\n39\t  eventType: \"claims.process\",\n40\t  status: \"failed\",\n41\t  attempts: 3,\n42\t  maxAttempts: 5,\n43\t  scheduledAt: \"2026-04-26T10:00:00.000Z\",\n44\t  startedAt: \"2026-04-26T10:01:00.000Z\",\n45\t  completedAt: null,\n46\t  createdAt: \"2026-04-26T09:55:00.000Z\",\n47\t  errorPreview: \"RpcError: connection refused\",\n48\t  linked: { userId: \"user-3\", roundId: null, claimId: \"claim-7\" },\n49\t};\n50\t\n51\tconst ROW_DEAD: PeekEventQueueListRow = {\n52\t  id: \"33333333-3333-3333-3333-333333333333\",\n53\t  eventType: \"rewards.payout\",\n54\t  status: \"dead\",\n55\t  attempts: 5,\n56\t  maxAttempts: 5,\n57\t  scheduledAt: \"2026-04-25T10:00:00.000Z\",\n58\t  startedAt: \"2026-04-25T10:01:00.000Z\",\n59\t  completedAt: null,\n60\t  createdAt: \"2026-04-25T09:55:00.000Z\",\n61\t  errorPreview: PEEK_AUDIT_REDACTED,\n62\t  linked: { userId: null, roundId: \"round-9\", claimId: null },\n63\t};\n64\t\n65\tconst ROW_PROCESSING: PeekEventQueueListRow = {\n66\t  id: \"44444444-4444-4444-4444-444444444444\",\n67\t  eventType: \"points.grant\",\n68\t  status: \"processing\",\n69\t  attempts: 1,\n70\t  maxAttempts: 5,\n71\t  scheduledAt: \"2026-04-26T10:00:00.000Z\",\n72\t  startedAt: \"2026-04-26T10:00:30.000Z\",\n73\t  completedAt: null,\n74\t  createdAt: \"2026-04-26T09:55:00.000Z\",\n75\t  errorPreview: null,\n76\t  linked: { userId: null, roundId: null, claimId: null },\n77\t};\n78\t\n79\tconst ROW_COMPLETED: PeekEventQueueListRow = {\n80\t  id: \"55555555-5555-5555-5555-555555555555\",\n81\t  eventType: \"points.grant\",\n82\t  status: \"completed\",\n83\t  attempts: 1,\n84\t  maxAttempts: 5,\n85\t  scheduledAt: \"2026-04-26T09:00:00.000Z\",\n86\t  startedAt: \"2026-04-26T09:00:30.000Z\",\n87\t  completedAt: \"2026-04-26T09:01:00.000Z\",\n88\t  createdAt: \"2026-04-26T08:55:00.000Z\",\n89\t  errorPreview: null,\n90\t  linked: { userId: \"user-1\", roundId: null, claimId: null },\n91\t};\n92\t\n93\tdescribe(\"EventQueueTable\", () => {\n94\t  it(\"populated: renders the operator columns and every lifecycle status chip\", () => {\n95\t    render(\n96\t      <EventQueueTable\n97\t        rows={[ROW_PENDING, ROW_PROCESSING, ROW_FAILED, ROW_DEAD, ROW_COMPLETED]}\n98\t      />,\n99\t    );\n100\t\n101\t    for (const header of [\n102\t      \"Status\",\n103\t      \"Event type\",\n104\t      \"Attempts\",\n105\t      \"Created\",\n106\t      \"Scheduled\",\n107\t      \"Started\",\n108\t      \"Completed\",\n109\t      \"Linked\",\n110\t      \"Error\",\n111\t      \"ID\",\n112\t    ]) {\n113\t      expect(screen.getByText(header)).toBeInTheDocument();\n114\t    }\n115\t\n116\t    // State-transition coverage: a chip per migration status.\n117\t    expect(screen.getByText(\"pending\")).toBeInTheDocument();\n118\t    expect(screen.getByText(\"processing\")).toBeInTheDocument();\n119\t    expect(screen.getByText(\"failed\")).toBeInTheDocument();\n120\t    expect(screen.getByText(\"dead\")).toBeInTheDocument();\n121\t    expect(screen.getByText(\"completed\")).toBeInTheDocument();\n122\t  });\n123\t\n124\t  it(\"populated: attempts cell renders attempts/maxAttempts with thousands separators\", () => {\n125\t    const big: PeekEventQueueListRow = {\n126\t      ...ROW_FAILED,\n127\t      attempts: 1234,\n128\t      maxAttempts: 5678,\n129\t    };\n130\t    render(<EventQueueTable rows={[big]} />);\n131\t    expect(screen.getByText(\"1,234 / 5,678\")).toBeInTheDocument();\n132\t  });\n133\t\n134\t  it(\"populated: failed row links payload userId and claimId — userId is the only drilldown\", () => {\n135\t    render(<EventQueueTable rows={[ROW_FAILED]} />);\n136\t    // userId is rendered as a Next.js link to /users/[userId].\n137\t    const link = screen.getByRole(\"link\", { name: /user user-3/ });\n138\t    expect(link).toHaveAttribute(\"href\", \"/users/user-3\");\n139\t    // Round and claim ids surface as inline tokens (read-only — no future\n140\t    // route exists yet for /games/.../rounds/<id> or /claims/<id>).\n141\t    expect(screen.getByText(/claim claim-7/)).toBeInTheDocument();\n142\t  });\n143\t\n144\t  it(\"populated: dead row preserves the redacted error preview verbatim — secrets never reach the operator\", () => {\n145\t    render(<EventQueueTable rows={[ROW_DEAD]} />);\n146\t    // The redacted sentinel from the audit module surfaces in the cell so\n147\t    // an operator can confirm the value was redacted without seeing it.\n148\t    expect(screen.getByText(PEEK_AUDIT_REDACTED)).toBeInTheDocument();\n149\t  });\n150\t\n151\t  it(\"populated: row id is the detail-panel anchor — links to ?selectedId=<encoded id>\", () => {\n152\t    render(<EventQueueTable rows={[ROW_FAILED]} />);\n153\t    const anchor = screen.getByRole(\"link\", {\n154\t      name: `Open detail for event ${ROW_FAILED.id}`,\n155\t    });\n156\t    expect(anchor).toHaveAttribute(\n157\t      \"href\",\n158\t      `/operations/queue?selectedId=${encodeURIComponent(ROW_FAILED.id)}`,\n159\t    );\n160\t  });\n161\t\n162\t  it(\"populated: aria-current marks the selected row when selectedId matches\", () => {\n163\t    const { container } = render(\n164\t      <EventQueueTable\n165\t        rows={[ROW_PENDING, ROW_FAILED]}\n166\t        selectedId={ROW_FAILED.id}\n167\t      />,\n168\t    );\n169\t    const currentRow = container.querySelector(\"tr[aria-current='true']\");\n170\t    expect(currentRow).not.toBeNull();\n171\t    // The other row has no aria-current marker.\n172\t    const otherRows = container.querySelectorAll(\"tbody tr\");\n173\t    let withMarker = 0;\n174\t    otherRows.forEach((tr) => {\n175\t      if (tr.getAttribute(\"aria-current\") === \"true\") withMarker += 1;\n176\t    });\n177\t    expect(withMarker).toBe(1);\n178\t  });\n179\t\n180\t  it(\"populated: selectedIdHrefBuilder override lets the table be reused for audit views or tests\", () => {\n181\t    render(\n182\t      <EventQueueTable\n183\t        rows={[ROW_FAILED]}\n184\t        selectedIdHrefBuilder={(row) => `/audit/queue/${row.id}`}\n185\t      />,\n186\t    );\n187\t    const anchor = screen.getByRole(\"link\", {\n188\t      name: `Open detail for event ${ROW_FAILED.id}`,\n189\t    });\n190\t    expect(anchor).toHaveAttribute(\"href\", `/audit/queue/${ROW_FAILED.id}`);\n191\t  });\n192\t\n193\t  it(\"populated: a row with no linked ids renders a plain em-dash (no broken drilldown shells)\", () => {\n194\t    render(<EventQueueTable rows={[ROW_PROCESSING]} />);\n195\t    // ROW_PROCESSING has all linked ids null. The Linked cell renders \"—\".\n196\t    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(1);\n197\t  });\n198\t\n199\t  it(\"read-only: no edit affordances rendered (no buttons, no editable inputs, no checkboxes)\", () => {\n200\t    // FR-10 line 342: retry / cancel / replay are explicitly out of scope.\n201\t    // The table must not render any mutating control. Only drilldown links\n202\t    // (user, detail anchor) are allowed.\n203\t    render(\n204\t      <EventQueueTable\n205\t        rows={[ROW_PENDING, ROW_PROCESSING, ROW_FAILED, ROW_DEAD, ROW_COMPLETED]}\n206\t      />,\n207\t    );\n208\t    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n209\t    expect(screen.queryByRole(\"textbox\")).toBeNull();\n210\t    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n211\t    expect(screen.queryAllByRole(\"link\").length).toBeGreaterThan(0);\n212\t  });\n213\t\n214\t  it(\"empty: renders the operator status block when no rows match\", () => {\n215\t    render(<EventQueueTable rows={[]} />);\n216\t    const status = screen.getByRole(\"status\");\n217\t    expect(status).toHaveTextContent(\n218\t      \"No event_queue rows match these filters.\",\n219\t    );\n220\t    expect(screen.queryByRole(\"table\")).toBeNull();\n221\t  });\n222\t\n223\t  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n224\t    render(\n225\t      <EventQueueTable rows={[ROW_FAILED]} error=\"connection refused\" />,\n226\t    );\n227\t    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n228\t      \"Event queue rows unavailable: connection refused\",\n229\t    );\n230\t    expect(screen.queryByRole(\"table\")).toBeNull();\n231\t    expect(screen.queryByRole(\"status\")).toBeNull();\n232\t  });\n233\t});\n234\t\n235\tdescribe(\"queueStatusTone\", () => {\n236\t  it(\"maps every migration status to a deterministic tone\", () => {\n237\t    expect(queueStatusTone(\"completed\")).toBe(\"positive\");\n238\t    expect(queueStatusTone(\"processing\")).toBe(\"info\");\n239\t    expect(queueStatusTone(\"pending\")).toBe(\"neutral\");\n240\t    expect(queueStatusTone(\"failed\")).toBe(\"warning\");\n241\t    expect(queueStatusTone(\"dead\")).toBe(\"negative\");\n242\t  });\n243\t\n244\t  it(\"falls back to neutral for an unknown status\", () => {\n245\t    expect(queueStatusTone(\"unknown\")).toBe(\"neutral\");\n246\t  });\n247\t});\n248\t"}]},"parent_tool_use_id":null,"session_id":"94a07cbb-8d25-425b-954a-4878bb9ef4df","uuid":"288ffe6e-71de-41a7-9edb-034fc20132bc","timestamp":"2026-04-26T07:24:03.512Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/event-queue-table.test.tsx","content":"// Component tests for the FR-10 /operations/queue event queue table.\n//\n// Read-only by spec — every queue mutation (retry / cancel / replay) lives\n// behind a future spec (FR-10 line 342). These tests assert there are no edit\n// affordances rendered, every status drives the right chip tone, the linked\n// payload ids surface as drilldowns, and the row id anchor sets\n// `?selectedId=<id>` so the detail panel can resolve it server-side.\n//\n// Coverage spans the spec line \"pending, failed, dead, aged, filtered,\n// redacted-payload states\": fixtures cover every lifecycle status, and a\n// dedicated test asserts the redacted error preview round-trips verbatim into\n// the row.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport {\n  EventQueueTable,\n  queueStatusTone,\n} from \"../event-queue-table\";\nimport { PEEK_AUDIT_REDACTED } from \"../../lib/types/peek\";\nimport type { PeekEventQueueListRow } from \"../../lib/types/peek\";\n\nconst ROW_PENDING: PeekEventQueueListRow = {\n  id: \"11111111-1111-1111-1111-111111111111\",\n  eventType: \"points.grant\",\n  status: \"pending\",\n  attempts: 0,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-26T10:00:00.000Z\",\n  startedAt: null,\n  completedAt: null,\n  createdAt: \"2026-04-26T09:55:00.000Z\",\n  errorPreview: null,\n  linked: { userId: \"user-9\", roundId: null, claimId: null },\n};\n\nconst ROW_FAILED: PeekEventQueueListRow = {\n  id: \"22222222-2222-2222-2222-222222222222\",\n  eventType: \"claims.process\",\n  status: \"failed\",\n  attempts: 3,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-26T10:00:00.000Z\",\n  startedAt: \"2026-04-26T10:01:00.000Z\",\n  completedAt: null,\n  createdAt: \"2026-04-26T09:55:00.000Z\",\n  errorPreview: \"RpcError: connection refused\",\n  linked: { userId: \"user-3\", roundId: null, claimId: \"claim-7\" },\n};\n\nconst ROW_DEAD: PeekEventQueueListRow = {\n  id: \"33333333-3333-3333-3333-333333333333\",\n  eventType: \"rewards.payout\",\n  status: \"dead\",\n  attempts: 5,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-25T10:00:00.000Z\",\n  startedAt: \"2026-04-25T10:01:00.000Z\",\n  completedAt: null,\n  createdAt: \"2026-04-25T09:55:00.000Z\",\n  errorPreview: PEEK_AUDIT_REDACTED,\n  linked: { userId: null, roundId: \"round-9\", claimId: null },\n};\n\nconst ROW_PROCESSING: PeekEventQueueListRow = {\n  id: \"44444444-4444-4444-4444-444444444444\",\n  eventType: \"points.grant\",\n  status: \"processing\",\n  attempts: 1,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-26T10:00:00.000Z\",\n  startedAt: \"2026-04-26T10:00:30.000Z\",\n  completedAt: null,\n  createdAt: \"2026-04-26T09:55:00.000Z\",\n  errorPreview: null,\n  linked: { userId: null, roundId: null, claimId: null },\n};\n\nconst ROW_COMPLETED: PeekEventQueueListRow = {\n  id: \"55555555-5555-5555-5555-555555555555\",\n  eventType: \"points.grant\",\n  status: \"completed\",\n  attempts: 1,\n  maxAttempts: 5,\n  scheduledAt: \"2026-04-26T09:00:00.000Z\",\n  startedAt: \"2026-04-26T09:00:30.000Z\",\n  completedAt: \"2026-04-26T09:01:00.000Z\",\n  createdAt: \"2026-04-26T08:55:00.000Z\",\n  errorPreview: null,\n  linked: { userId: \"user-1\", roundId: null, claimId: null },\n};\n\ndescribe(\"EventQueueTable\", () => {\n  it(\"populated: renders the operator columns and every lifecycle status chip\", () => {\n    render(\n      <EventQueueTable\n        rows={[ROW_PENDING, ROW_PROCESSING, ROW_FAILED, ROW_DEAD, ROW_COMPLETED]}\n      />,\n    );\n\n    for (const header of [\n      \"Status\",\n      \"Event type\",\n      \"Attempts\",\n      \"Created\",\n      \"Scheduled\",\n      \"Started\",\n      \"Completed\",\n      \"Linked\",\n      \"Error\",\n      \"ID\",\n    ]) {\n      expect(screen.getByText(header)).toBeInTheDocument();\n    }\n\n    // State-transition coverage: a chip per migration status.\n    expect(screen.getByText(\"pending\")).toBeInTheDocument();\n    expect(screen.getByText(\"processing\")).toBeInTheDocument();\n    expect(screen.getByText(\"failed\")).toBeInTheDocument();\n    expect(screen.getByText(\"dead\")).toBeInTheDocument();\n    expect(screen.getByText(\"completed\")).toBeInTheDocument();\n  });\n\n  it(\"populated: attempts cell renders attempts/maxAttempts with thousands separators\", () => {\n    const big: PeekEventQueueListRow = {\n      ...ROW_FAILED,\n      attempts: 1234,\n      maxAttempts: 5678,\n    };\n    render(<EventQueueTable rows={[big]} />);\n    expect(screen.getByText(\"1,234 / 5,678\")).toBeInTheDocument();\n  });\n\n  it(\"populated: failed row links payload userId and claimId — userId is the only drilldown\", () => {\n    render(<EventQueueTable rows={[ROW_FAILED]} />);\n    // userId is rendered as a Next.js link to /users/[userId].\n    const link = screen.getByRole(\"link\", { name: /user user-3/ });\n    expect(link).toHaveAttribute(\"href\", \"/users/user-3\");\n    // Round and claim ids surface as inline tokens (read-only — no future\n    // route exists yet for /games/.../rounds/<id> or /claims/<id>).\n    expect(screen.getByText(/claim claim-7/)).toBeInTheDocument();\n  });\n\n  it(\"populated: dead row preserves the redacted error preview verbatim — secrets never reach the operator\", () => {\n    render(<EventQueueTable rows={[ROW_DEAD]} />);\n    // The redacted sentinel from the audit module surfaces in the cell so\n    // an operator can confirm the value was redacted without seeing it.\n    expect(screen.getByText(PEEK_AUDIT_REDACTED)).toBeInTheDocument();\n  });\n\n  it(\"populated: row id is the detail-panel anchor — links to ?selectedId=<encoded id>\", () => {\n    render(<EventQueueTable rows={[ROW_FAILED]} />);\n    const anchor = screen.getByRole(\"link\", {\n      name: `Open detail for event ${ROW_FAILED.id}`,\n    });\n    expect(anchor).toHaveAttribute(\n      \"href\",\n      `/operations/queue?selectedId=${encodeURIComponent(ROW_FAILED.id)}`,\n    );\n  });\n\n  it(\"populated: aria-current marks the selected row when selectedId matches\", () => {\n    const { container } = render(\n      <EventQueueTable\n        rows={[ROW_PENDING, ROW_FAILED]}\n        selectedId={ROW_FAILED.id}\n      />,\n    );\n    const currentRow = container.querySelector(\"tr[aria-current='true']\");\n    expect(currentRow).not.toBeNull();\n    // The other row has no aria-current marker.\n    const otherRows = container.querySelectorAll(\"tbody tr\");\n    let withMarker = 0;\n    otherRows.forEach((tr) => {\n      if (tr.getAttribute(\"aria-current\") === \"true\") withMarker += 1;\n    });\n    expect(withMarker).toBe(1);\n  });\n\n  it(\"populated: selectedIdHrefBuilder override lets the table be reused for audit views or tests\", () => {\n    render(\n      <EventQueueTable\n        rows={[ROW_FAILED]}\n        selectedIdHrefBuilder={(row) => `/audit/queue/${row.id}`}\n      />,\n    );\n    const anchor = screen.getByRole(\"link\", {\n      name: `Open detail for event ${ROW_FAILED.id}`,\n    });\n    expect(anchor).toHaveAttribute(\"href\", `/audit/queue/${ROW_FAILED.id}`);\n  });\n\n  it(\"populated: a row with no linked ids renders a plain em-dash (no broken drilldown shells)\", () => {\n    render(<EventQueueTable rows={[ROW_PROCESSING]} />);\n    // ROW_PROCESSING has all linked ids null. The Linked cell renders \"—\".\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(1);\n  });\n\n  it(\"read-only: no edit affordances rendered (no buttons, no editable inputs, no checkboxes)\", () => {\n    // FR-10 line 342: retry / cancel / replay are explicitly out of scope.\n    // The table must not render any mutating control. Only drilldown links\n    // (user, detail anchor) are allowed.\n    render(\n      <EventQueueTable\n        rows={[ROW_PENDING, ROW_PROCESSING, ROW_FAILED, ROW_DEAD, ROW_COMPLETED]}\n      />,\n    );\n    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n    expect(screen.queryByRole(\"textbox\")).toBeNull();\n    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n    expect(screen.queryAllByRole(\"link\").length).toBeGreaterThan(0);\n  });\n\n  it(\"empty: renders the operator status block when no rows match\", () => {\n    render(<EventQueueTable rows={[]} />);\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\n      \"No event_queue rows match these filters.\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n    render(\n      <EventQueueTable rows={[ROW_FAILED]} error=\"connection refused\" />,\n    );\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Event queue rows unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n\ndescribe(\"queueStatusTone\", () => {\n  it(\"maps every migration status to a deterministic tone\", () => {\n    expect(queueStatusTone(\"completed\")).toBe(\"positive\");\n    expect(queueStatusTone(\"processing\")).toBe(\"info\");\n    expect(queueStatusTone(\"pending\")).toBe(\"neutral\");\n    expect(queueStatusTone(\"failed\")).toBe(\"warning\");\n    expect(queueStatusTone(\"dead\")).toBe(\"negative\");\n  });\n\n  it(\"falls back to neutral for an unknown status\", () => {\n    expect(queueStatusTone(\"unknown\")).toBe(\"neutral\");\n  });\n});\n","numLines":248,"startLine":1,"totalLines":248}}}
