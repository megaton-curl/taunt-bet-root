{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RN6YtYxiXcrfC5bjuiBvVr","type":"tool_result","content":"1\t// Tests for the FR-10 /operations/queue URL-addressable filter normaliser.\n2\t//\n3\t// One filter group (`queueFilter*`) plus a single `selectedId` param drives\n4\t// the side-by-side detail panel. The normaliser is the contract that keeps a\n5\t// stale URL chip from lying about a table's filter state — empty/whitespace →\n6\t// null, unknown enum → null, recognised allowlist values pass through.\n7\t\n8\timport { describe, expect, it } from \"vitest\";\n9\timport {\n10\t  PEEK_EVENT_QUEUE_AGE_BUCKET_VALUES,\n11\t  PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES,\n12\t  PEEK_EVENT_QUEUE_STATUS_VALUES,\n13\t  normalizeEventQueueFiltersFromSearchParams,\n14\t  readSelectedQueueIdFromSearchParams,\n15\t} from \"../operations-queue-search-params\";\n16\t\n17\tdescribe(\"normalizeEventQueueFiltersFromSearchParams\", () => {\n18\t  it(\"empty input: every filter normalises to null\", () => {\n19\t    expect(normalizeEventQueueFiltersFromSearchParams({})).toEqual({\n20\t      status: null,\n21\t      eventType: null,\n22\t      id: null,\n23\t      payloadUserId: null,\n24\t      scheduledFrom: null,\n25\t      scheduledTo: null,\n26\t      createdFrom: null,\n27\t      createdTo: null,\n28\t      ageBucket: null,\n29\t    });\n30\t  });\n31\t\n32\t  it(\"whitespace-only values normalise to null across every filter\", () => {\n33\t    expect(\n34\t      normalizeEventQueueFiltersFromSearchParams({\n35\t        queueFilterStatus: \"  \",\n36\t        queueFilterType: \"   \",\n37\t        queueFilterId: \" \",\n38\t        queueFilterUserId: \"    \",\n39\t        queueFilterAge: \"   \",\n40\t        queueFilterScheduledFrom: \" \",\n41\t        queueFilterScheduledTo: \" \",\n42\t        queueFilterCreatedFrom: \" \",\n43\t        queueFilterCreatedTo: \" \",\n44\t      }),\n45\t    ).toEqual({\n46\t      status: null,\n47\t      eventType: null,\n48\t      id: null,\n49\t      payloadUserId: null,\n50\t      scheduledFrom: null,\n51\t      scheduledTo: null,\n52\t      createdFrom: null,\n53\t      createdTo: null,\n54\t      ageBucket: null,\n55\t    });\n56\t  });\n57\t\n58\t  it(\"populated: every supported filter flows through with trimming\", () => {\n59\t    const filters = normalizeEventQueueFiltersFromSearchParams({\n60\t      queueFilterStatus: \"failed\",\n61\t      queueFilterType: \"  points.grant  \",\n62\t      queueFilterId: \"  11111111-1111-1111-1111-111111111111  \",\n63\t      queueFilterUserId: \" user-9 \",\n64\t      queueFilterAge: \"lt_24h\",\n65\t      queueFilterScheduledFrom: \"2026-04-01\",\n66\t      queueFilterScheduledTo: \"2026-04-26\",\n67\t      queueFilterCreatedFrom: \"2026-04-01\",\n68\t      queueFilterCreatedTo: \"2026-04-26\",\n69\t    });\n70\t    expect(filters).toEqual({\n71\t      status: \"failed\",\n72\t      eventType: \"points.grant\",\n73\t      id: \"11111111-1111-1111-1111-111111111111\",\n74\t      payloadUserId: \"user-9\",\n75\t      ageBucket: \"lt_24h\",\n76\t      scheduledFrom: \"2026-04-01\",\n77\t      scheduledTo: \"2026-04-26\",\n78\t      createdFrom: \"2026-04-01\",\n79\t      createdTo: \"2026-04-26\",\n80\t    });\n81\t  });\n82\t\n83\t  it(\"status: state-transition coverage — every allowlisted value passes through verbatim\", () => {\n84\t    // pending / processing / completed / failed / dead — every queue\n85\t    // lifecycle state is filterable.\n86\t    for (const value of PEEK_EVENT_QUEUE_STATUS_VALUES) {\n87\t      const filters = normalizeEventQueueFiltersFromSearchParams({\n88\t        queueFilterStatus: value,\n89\t      });\n90\t      expect(filters.status).toBe(value);\n91\t    }\n92\t  });\n93\t\n94\t  it(\"status: unknown enum value normalises to null so a stale URL chip cannot lie\", () => {\n95\t    expect(\n96\t      normalizeEventQueueFiltersFromSearchParams({\n97\t        queueFilterStatus: \"stalled\",\n98\t      }).status,\n99\t    ).toBeNull();\n100\t  });\n101\t\n102\t  it(\"ageBucket: every allowlisted value passes through verbatim\", () => {\n103\t    for (const value of PEEK_EVENT_QUEUE_AGE_BUCKET_VALUES) {\n104\t      const filters = normalizeEventQueueFiltersFromSearchParams({\n105\t        queueFilterAge: value,\n106\t      });\n107\t      expect(filters.ageBucket).toBe(value);\n108\t    }\n109\t  });\n110\t\n111\t  it(\"ageBucket: unknown bucket id normalises to null so a stale link cannot apply a fake window\", () => {\n112\t    expect(\n113\t      normalizeEventQueueFiltersFromSearchParams({\n114\t        queueFilterAge: \"yesterday\",\n115\t      }).ageBucket,\n116\t    ).toBeNull();\n117\t  });\n118\t\n119\t  it(\"array values: only the first element is read\", () => {\n120\t    expect(\n121\t      normalizeEventQueueFiltersFromSearchParams({\n122\t        queueFilterStatus: [\"failed\", \"dead\"],\n123\t      }).status,\n124\t    ).toBe(\"failed\");\n125\t  });\n126\t\n127\t  it(\"undefined input value normalises to null without throwing\", () => {\n128\t    expect(\n129\t      normalizeEventQueueFiltersFromSearchParams({\n130\t        queueFilterStatus: undefined,\n131\t        queueFilterType: undefined,\n132\t      }),\n133\t    ).toEqual({\n134\t      status: null,\n135\t      eventType: null,\n136\t      id: null,\n137\t      payloadUserId: null,\n138\t      scheduledFrom: null,\n139\t      scheduledTo: null,\n140\t      createdFrom: null,\n141\t      createdTo: null,\n142\t      ageBucket: null,\n143\t    });\n144\t  });\n145\t});\n146\t\n147\tdescribe(\"readSelectedQueueIdFromSearchParams\", () => {\n148\t  it(\"returns null for an absent selectedId\", () => {\n149\t    expect(readSelectedQueueIdFromSearchParams({})).toBeNull();\n150\t  });\n151\t\n152\t  it(\"returns null for a whitespace-only selectedId\", () => {\n153\t    expect(\n154\t      readSelectedQueueIdFromSearchParams({ selectedId: \"    \" }),\n155\t    ).toBeNull();\n156\t  });\n157\t\n158\t  it(\"trims and returns the value when present\", () => {\n159\t    expect(\n160\t      readSelectedQueueIdFromSearchParams({\n161\t        selectedId: \"  11111111-1111-1111-1111-111111111111  \",\n162\t      }),\n163\t    ).toBe(\"11111111-1111-1111-1111-111111111111\");\n164\t  });\n165\t\n166\t  it(\"array values: only the first element is read\", () => {\n167\t    expect(\n168\t      readSelectedQueueIdFromSearchParams({\n169\t        selectedId: [\"a\", \"b\"],\n170\t      }),\n171\t    ).toBe(\"a\");\n172\t  });\n173\t});\n174\t\n175\tdescribe(\"PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES\", () => {\n176\t  it(\"declares the same param names the form fields submit\", () => {\n177\t    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.status).toBe(\n178\t      \"queueFilterStatus\",\n179\t    );\n180\t    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.eventType).toBe(\n181\t      \"queueFilterType\",\n182\t    );\n183\t    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.id).toBe(\"queueFilterId\");\n184\t    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.payloadUserId).toBe(\n185\t      \"queueFilterUserId\",\n186\t    );\n187\t    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.scheduledFrom).toBe(\n188\t      \"queueFilterScheduledFrom\",\n189\t    );\n190\t    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.scheduledTo).toBe(\n191\t      \"queueFilterScheduledTo\",\n192\t    );\n193\t    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.createdFrom).toBe(\n194\t      \"queueFilterCreatedFrom\",\n195\t    );\n196\t    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.createdTo).toBe(\n197\t      \"queueFilterCreatedTo\",\n198\t    );\n199\t    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.ageBucket).toBe(\n200\t      \"queueFilterAge\",\n201\t    );\n202\t    // The `selectedId` token belongs to the same map so the table component\n203\t    // can build shareable detail-panel links without re-declaring the literal.\n204\t    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.selectedId).toBe(\"selectedId\");\n205\t  });\n206\t});\n207\t"}]},"parent_tool_use_id":null,"session_id":"94a07cbb-8d25-425b-954a-4878bb9ef4df","uuid":"4e91e74a-73ea-4491-8dda-b59e04232e58","timestamp":"2026-04-26T07:24:47.516Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/__tests__/operations-queue-search-params.test.ts","content":"// Tests for the FR-10 /operations/queue URL-addressable filter normaliser.\n//\n// One filter group (`queueFilter*`) plus a single `selectedId` param drives\n// the side-by-side detail panel. The normaliser is the contract that keeps a\n// stale URL chip from lying about a table's filter state — empty/whitespace →\n// null, unknown enum → null, recognised allowlist values pass through.\n\nimport { describe, expect, it } from \"vitest\";\nimport {\n  PEEK_EVENT_QUEUE_AGE_BUCKET_VALUES,\n  PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES,\n  PEEK_EVENT_QUEUE_STATUS_VALUES,\n  normalizeEventQueueFiltersFromSearchParams,\n  readSelectedQueueIdFromSearchParams,\n} from \"../operations-queue-search-params\";\n\ndescribe(\"normalizeEventQueueFiltersFromSearchParams\", () => {\n  it(\"empty input: every filter normalises to null\", () => {\n    expect(normalizeEventQueueFiltersFromSearchParams({})).toEqual({\n      status: null,\n      eventType: null,\n      id: null,\n      payloadUserId: null,\n      scheduledFrom: null,\n      scheduledTo: null,\n      createdFrom: null,\n      createdTo: null,\n      ageBucket: null,\n    });\n  });\n\n  it(\"whitespace-only values normalise to null across every filter\", () => {\n    expect(\n      normalizeEventQueueFiltersFromSearchParams({\n        queueFilterStatus: \"  \",\n        queueFilterType: \"   \",\n        queueFilterId: \" \",\n        queueFilterUserId: \"    \",\n        queueFilterAge: \"   \",\n        queueFilterScheduledFrom: \" \",\n        queueFilterScheduledTo: \" \",\n        queueFilterCreatedFrom: \" \",\n        queueFilterCreatedTo: \" \",\n      }),\n    ).toEqual({\n      status: null,\n      eventType: null,\n      id: null,\n      payloadUserId: null,\n      scheduledFrom: null,\n      scheduledTo: null,\n      createdFrom: null,\n      createdTo: null,\n      ageBucket: null,\n    });\n  });\n\n  it(\"populated: every supported filter flows through with trimming\", () => {\n    const filters = normalizeEventQueueFiltersFromSearchParams({\n      queueFilterStatus: \"failed\",\n      queueFilterType: \"  points.grant  \",\n      queueFilterId: \"  11111111-1111-1111-1111-111111111111  \",\n      queueFilterUserId: \" user-9 \",\n      queueFilterAge: \"lt_24h\",\n      queueFilterScheduledFrom: \"2026-04-01\",\n      queueFilterScheduledTo: \"2026-04-26\",\n      queueFilterCreatedFrom: \"2026-04-01\",\n      queueFilterCreatedTo: \"2026-04-26\",\n    });\n    expect(filters).toEqual({\n      status: \"failed\",\n      eventType: \"points.grant\",\n      id: \"11111111-1111-1111-1111-111111111111\",\n      payloadUserId: \"user-9\",\n      ageBucket: \"lt_24h\",\n      scheduledFrom: \"2026-04-01\",\n      scheduledTo: \"2026-04-26\",\n      createdFrom: \"2026-04-01\",\n      createdTo: \"2026-04-26\",\n    });\n  });\n\n  it(\"status: state-transition coverage — every allowlisted value passes through verbatim\", () => {\n    // pending / processing / completed / failed / dead — every queue\n    // lifecycle state is filterable.\n    for (const value of PEEK_EVENT_QUEUE_STATUS_VALUES) {\n      const filters = normalizeEventQueueFiltersFromSearchParams({\n        queueFilterStatus: value,\n      });\n      expect(filters.status).toBe(value);\n    }\n  });\n\n  it(\"status: unknown enum value normalises to null so a stale URL chip cannot lie\", () => {\n    expect(\n      normalizeEventQueueFiltersFromSearchParams({\n        queueFilterStatus: \"stalled\",\n      }).status,\n    ).toBeNull();\n  });\n\n  it(\"ageBucket: every allowlisted value passes through verbatim\", () => {\n    for (const value of PEEK_EVENT_QUEUE_AGE_BUCKET_VALUES) {\n      const filters = normalizeEventQueueFiltersFromSearchParams({\n        queueFilterAge: value,\n      });\n      expect(filters.ageBucket).toBe(value);\n    }\n  });\n\n  it(\"ageBucket: unknown bucket id normalises to null so a stale link cannot apply a fake window\", () => {\n    expect(\n      normalizeEventQueueFiltersFromSearchParams({\n        queueFilterAge: \"yesterday\",\n      }).ageBucket,\n    ).toBeNull();\n  });\n\n  it(\"array values: only the first element is read\", () => {\n    expect(\n      normalizeEventQueueFiltersFromSearchParams({\n        queueFilterStatus: [\"failed\", \"dead\"],\n      }).status,\n    ).toBe(\"failed\");\n  });\n\n  it(\"undefined input value normalises to null without throwing\", () => {\n    expect(\n      normalizeEventQueueFiltersFromSearchParams({\n        queueFilterStatus: undefined,\n        queueFilterType: undefined,\n      }),\n    ).toEqual({\n      status: null,\n      eventType: null,\n      id: null,\n      payloadUserId: null,\n      scheduledFrom: null,\n      scheduledTo: null,\n      createdFrom: null,\n      createdTo: null,\n      ageBucket: null,\n    });\n  });\n});\n\ndescribe(\"readSelectedQueueIdFromSearchParams\", () => {\n  it(\"returns null for an absent selectedId\", () => {\n    expect(readSelectedQueueIdFromSearchParams({})).toBeNull();\n  });\n\n  it(\"returns null for a whitespace-only selectedId\", () => {\n    expect(\n      readSelectedQueueIdFromSearchParams({ selectedId: \"    \" }),\n    ).toBeNull();\n  });\n\n  it(\"trims and returns the value when present\", () => {\n    expect(\n      readSelectedQueueIdFromSearchParams({\n        selectedId: \"  11111111-1111-1111-1111-111111111111  \",\n      }),\n    ).toBe(\"11111111-1111-1111-1111-111111111111\");\n  });\n\n  it(\"array values: only the first element is read\", () => {\n    expect(\n      readSelectedQueueIdFromSearchParams({\n        selectedId: [\"a\", \"b\"],\n      }),\n    ).toBe(\"a\");\n  });\n});\n\ndescribe(\"PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES\", () => {\n  it(\"declares the same param names the form fields submit\", () => {\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.status).toBe(\n      \"queueFilterStatus\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.eventType).toBe(\n      \"queueFilterType\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.id).toBe(\"queueFilterId\");\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.payloadUserId).toBe(\n      \"queueFilterUserId\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.scheduledFrom).toBe(\n      \"queueFilterScheduledFrom\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.scheduledTo).toBe(\n      \"queueFilterScheduledTo\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.createdFrom).toBe(\n      \"queueFilterCreatedFrom\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.createdTo).toBe(\n      \"queueFilterCreatedTo\",\n    );\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.ageBucket).toBe(\n      \"queueFilterAge\",\n    );\n    // The `selectedId` token belongs to the same map so the table component\n    // can build shareable detail-panel links without re-declaring the literal.\n    expect(PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES.selectedId).toBe(\"selectedId\");\n  });\n});\n","numLines":207,"startLine":1,"totalLines":207}}}
