{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DqPLmePDqi3DJakrJqp4Ps","type":"tool_result","content":"1\t// Audit-log admin queries (FR-11 audit view).\n2\t//\n3\t// Backs the upcoming `/audit` page. Reads `operator_events` (migration 002)\n4\t// filtered to the `peek.*` event types the audit writer (FR-11) emits. The\n5\t// page is admin-only via the FR-2 page-level allowlist; this module remains\n6\t// strictly read-only — `operator_events` rows are append-only by contract and\n7\t// the admin UI never edits them.\n8\t//\n9\t// Three exports:\n10\t//\n11\t//   - `getAuditOverview` — bounded counts for the FR-4 metric strip:\n12\t//     total `peek.*` events in the last 24h plus the four interesting\n13\t//     event-type subtotals (export, access denied, change applied, change\n14\t//     rejected). Also returns the full per-event-type count breakdown so the\n15\t//     page can render a sparse-aware breakdown card.\n16\t//\n17\t//   - `listAuditEvents` — bounded filtered list. Filters mirror the FR-11 spec\n18\t//     line \"filters by event type, actor email, resource id, route, and date\".\n19\t//     Each row arrives as a `PeekAuditEvent` with the writer's serialized\n20\t//     `PeekAuditPayload` shape; payload values were already passed through\n21\t//     `redactPayload` at write time but `listAuditEvents` re-applies\n22\t//     `redactNullableString` defensively so a hand-crafted row that bypassed\n23\t//     the writer cannot leak.\n24\t//\n25\t//   - The internal `coerceAuditEventTypeFilter` normaliser keeps the SQL\n26\t//     \"any peek.*\" predicate honest: an unknown event type silently falls\n27\t//     back to the broad \"starts with `peek.`\" filter rather than binding a\n28\t//     value that would never match anything.\n29\t\n30\timport type { Sql } from \"postgres\";\n31\timport {\n32\t  PEEK_AUDIT_EVENT_TYPES,\n33\t  isPeekAuditEventType,\n34\t  type PeekAuditChange,\n35\t  type PeekAuditEvent,\n36\t  type PeekAuditEventType,\n37\t  type PeekAuditEventTypeCount,\n38\t  type PeekAuditFilters,\n39\t  type PeekAuditOverview,\n40\t  type PeekAuditOverviewMetricId,\n41\t  type PeekAuditPayload,\n42\t  type PeekMetric,\n43\t} from \"../../../lib/types/peek\";\n44\timport { redactNullableString } from \"../../audit/redact\";\n45\timport { getSqlClient } from \"../client\";\n46\t\n47\texport const PEEK_AUDIT_DEFAULT_LIMIT = 100;\n48\texport const PEEK_AUDIT_MAX_LIMIT = 500;\n49\texport const PEEK_AUDIT_OVERVIEW_WINDOW_HOURS = 24;\n50\t\n51\texport type ListAuditEventsOptions = {\n52\t  sql?: Sql;\n53\t  limit?: number;\n54\t  filters?: Partial<PeekAuditFilters>;\n55\t};\n56\t\n57\texport type GetAuditOverviewOptions = {\n58\t  sql?: Sql;\n59\t  now?: Date;\n60\t  windowHours?: number;\n61\t};\n62\t\n63\tfunction clampLimit(\n64\t  raw: number | undefined,\n65\t  fallback: number,\n66\t  max: number,\n67\t): number {\n68\t  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n69\t  const floored = Math.floor(raw);\n70\t  if (floored <= 0) return 1;\n71\t  return Math.min(max, floored);\n72\t}\n73\t\n74\tfunction trimOrNull(value: string | null | undefined): string | null {\n75\t  if (typeof value !== \"string\") return null;\n76\t  const trimmed = value.trim();\n77\t  return trimmed.length > 0 ? trimmed : null;\n78\t}\n79\t\n80\tfunction readInt(value: number | string | null | undefined): number {\n81\t  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n82\t  if (typeof value === \"string\") {\n83\t    const parsed = Number.parseInt(value, 10);\n84\t    return Number.isFinite(parsed) ? parsed : 0;\n85\t  }\n86\t  return 0;\n87\t}\n88\t\n89\tfunction formatCount(count: number): string {\n90\t  return count.toLocaleString(\"en-US\");\n91\t}\n92\t\n93\t// `eventType` filter is a discriminated string: a known `PeekAuditEventType`\n94\t// binds verbatim, an unknown value normalises to `null` so the query falls back\n95\t// to the \"any peek.*\" predicate. This keeps a stale URL chip from silently\n96\t// dropping the result set to zero.\n97\tfunction coerceAuditEventTypeFilter(\n98\t  raw: string | null,\n99\t): PeekAuditEventType | null {\n100\t  if (raw === null) return null;\n101\t  return isPeekAuditEventType(raw) ? raw : null;\n102\t}\n103\t\n104\t// Re-applies the redaction policy on read so a row inserted by some path that\n105\t// bypassed the writer cannot leak. `redactNullableString` is idempotent for\n106\t// values that already round-tripped through the writer.\n107\tfunction rehydratePayload(raw: unknown): PeekAuditPayload {\n108\t  const obj = (raw && typeof raw === \"object\" ? raw : {}) as Record<\n109\t    string,\n110\t    unknown\n111\t  >;\n112\t\n113\t  const actorEmail =\n114\t    typeof obj.actorEmail === \"string\" && obj.actorEmail.length > 0\n115\t      ? obj.actorEmail\n116\t      : \"\";\n117\t  const route = redactNullableString(\n118\t    typeof obj.route === \"string\" ? obj.route : null,\n119\t  );\n120\t  const actionId = redactNullableString(\n121\t    typeof obj.actionId === \"string\" ? obj.actionId : null,\n122\t  );\n123\t  const resourceType = redactNullableString(\n124\t    typeof obj.resourceType === \"string\" ? obj.resourceType : null,\n125\t  );\n126\t  const resourceId = redactNullableString(\n127\t    typeof obj.resourceId === \"string\" ? obj.resourceId : null,\n128\t  );\n129\t  const filterSummary = redactNullableString(\n130\t    typeof obj.filterSummary === \"string\" ? obj.filterSummary : null,\n131\t  );\n132\t  const requestId = redactNullableString(\n133\t    typeof obj.requestId === \"string\" ? obj.requestId : null,\n134\t  );\n135\t  const rejectionReason = redactNullableString(\n136\t    typeof obj.rejectionReason === \"string\" ? obj.rejectionReason : null,\n137\t  );\n138\t  const resultCount =\n139\t    typeof obj.resultCount === \"number\" && Number.isFinite(obj.resultCount)\n140\t      ? obj.resultCount\n141\t      : null;\n142\t  const changes = Array.isArray(obj.changes)\n143\t    ? ((obj.changes as ReadonlyArray<unknown>).filter(\n144\t        (entry): entry is PeekAuditChange =>\n145\t          entry !== null &&\n146\t          typeof entry === \"object\" &&\n147\t          \"field\" in entry,\n148\t      ) as ReadonlyArray<PeekAuditChange>)\n149\t    : null;\n150\t\n151\t  return {\n152\t    actorEmail,\n153\t    route,\n154\t    actionId,\n155\t    resourceType,\n156\t    resourceId,\n157\t    filterSummary,\n158\t    resultCount,\n159\t    requestId,\n160\t    rejectionReason,\n161\t    changes,\n162\t  };\n163\t}\n164\t\n165\texport async function listAuditEvents(\n166\t  options: ListAuditEventsOptions = {},\n167\t): Promise<ReadonlyArray<PeekAuditEvent>> {\n168\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n169\t  const limit = clampLimit(\n170\t    options.limit,\n171\t    PEEK_AUDIT_DEFAULT_LIMIT,\n172\t    PEEK_AUDIT_MAX_LIMIT,\n173\t  );\n174\t\n175\t  const filters = options.filters ?? {};\n176\t  const eventType = coerceAuditEventTypeFilter(\n177\t    trimOrNull(filters.eventType ?? null),\n178\t  );\n179\t  const actorEmailRaw = trimOrNull(filters.actorEmail ?? null);\n180\t  const actorEmail = actorEmailRaw ? actorEmailRaw.toLowerCase() : null;\n181\t  const resourceId = trimOrNull(filters.resourceId ?? null);\n182\t  const route = trimOrNull(filters.route ?? null);\n183\t  const createdFrom = trimOrNull(filters.createdFrom ?? null);\n184\t  const createdTo = trimOrNull(filters.createdTo ?? null);\n185\t\n186\t  const rows = await sql<\n187\t    Array<{\n188\t      id: string;\n189\t      eventType: string;\n190\t      createdAt: string;\n191\t      payload: unknown;\n192\t    }>\n193\t  >`\n194\t    select\n195\t      oe.id::text as \"id\",\n196\t      oe.event_type as \"eventType\",\n197\t      oe.created_at::text as \"createdAt\",\n198\t      oe.payload as \"payload\"\n199\t    from operator_events oe\n200\t    where\n201\t      (${eventType === null} or oe.event_type = ${eventType ?? \"\"})\n202\t      and (${eventType !== null} or oe.event_type like 'peek.%')\n203\t      and (${actorEmail === null} or lower(oe.payload->>'actorEmail') = ${actorEmail ?? \"\"})\n204\t      and (${resourceId === null} or oe.payload->>'resourceId' = ${resourceId ?? \"\"})\n205\t      and (${route === null} or oe.payload->>'route' = ${route ?? \"\"})\n206\t      and (${createdFrom === null} or oe.created_at >= ${createdFrom ?? \"\"}::timestamptz)\n207\t      and (${createdTo === null} or oe.created_at < ${createdTo ?? \"\"}::timestamptz)\n208\t    order by oe.created_at desc, oe.id desc\n209\t    limit ${limit}\n210\t  `;\n211\t\n212\t  return rows\n213\t    .filter((row) => isPeekAuditEventType(row.eventType))\n214\t    .map((row) => ({\n215\t      id: row.id,\n216\t      eventType: row.eventType as PeekAuditEventType,\n217\t      createdAt: row.createdAt,\n218\t      payload: rehydratePayload(row.payload),\n219\t    }));\n220\t}\n221\t\n222\ttype MetricBlueprint = {\n223\t  id: PeekAuditOverviewMetricId;\n224\t  label: string;\n225\t  unit: string | null;\n226\t  source: string;\n227\t  windowLabel: string;\n228\t  definition: string;\n229\t  drilldownHref: string | null;\n230\t};\n231\t\n232\tfunction buildMetric(\n233\t  blueprint: MetricBlueprint,\n234\t  raw: number,\n235\t  display: string,\n236\t  asOf: string,\n237\t): PeekMetric {\n238\t  return {\n239\t    id: blueprint.id,\n240\t    label: blueprint.label,\n241\t    value: raw,\n242\t    valueDisplay: display,\n243\t    unit: blueprint.unit,\n244\t    source: blueprint.source,\n245\t    windowLabel: blueprint.windowLabel,\n246\t    asOf,\n247\t    definition: blueprint.definition,\n248\t    freshness: \"live\",\n249\t    drilldownHref: blueprint.drilldownHref,\n250\t  };\n251\t}\n252\t\n253\texport async function getAuditOverview(\n254\t  options: GetAuditOverviewOptions = {},\n255\t): Promise<PeekAuditOverview> {\n256\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n257\t  const now = options.now ?? new Date();\n258\t  const generatedAt = now.toISOString();\n259\t  const windowHours = clampLimit(\n260\t    options.windowHours,\n261\t    PEEK_AUDIT_OVERVIEW_WINDOW_HOURS,\n262\t    24 * 30,\n263\t  );\n264\t  const windowStartIso = new Date(\n265\t    now.getTime() - windowHours * 60 * 60 * 1000,\n266\t  ).toISOString();\n267\t  const windowLabel =\n268\t    windowHours === 24 ? \"Last 24h\" : `Last ${windowHours}h`;\n269\t\n270\t  const eventTypeRows = await sql<\n271\t    Array<{ eventType: string; value: number | string }>\n272\t  >`\n273\t    select oe.event_type as \"eventType\", count(*)::int as \"value\"\n274\t    from operator_events oe\n275\t    where oe.event_type like 'peek.%'\n276\t      and oe.created_at >= ${windowStartIso}::timestamptz\n277\t    group by oe.event_type\n278\t  `;\n279\t\n280\t  const countByType = new Map<string, number>();\n281\t  for (const row of eventTypeRows) {\n282\t    countByType.set(row.eventType, readInt(row.value));\n283\t  }\n284\t\n285\t  const eventTypeCounts: ReadonlyArray<PeekAuditEventTypeCount> =\n286\t    PEEK_AUDIT_EVENT_TYPES.map((eventType) => ({\n287\t      eventType,\n288\t      count: countByType.get(eventType) ?? 0,\n289\t    }));\n290\t\n291\t  const total = eventTypeCounts.reduce((acc, row) => acc + row.count, 0);\n292\t  const exports = countByType.get(\"peek.export\") ?? 0;\n293\t  const accessDenied = countByType.get(\"peek.access.denied\") ?? 0;\n294\t  const changesApplied = countByType.get(\"peek.change.applied\") ?? 0;\n295\t  const changesRejected = countByType.get(\"peek.change.rejected\") ?? 0;\n296\t\n297\t  const blueprints: ReadonlyArray<{\n298\t    blueprint: MetricBlueprint;\n299\t    raw: number;\n300\t    display: string;\n301\t  }> = [\n302\t    {\n303\t      blueprint: {\n304\t        id: \"audit.total_24h\",\n305\t        label: \"Total peek.* events\",\n306\t        unit: \"events\",\n307\t        source: \"operator_events\",\n308\t        windowLabel,\n309\t        definition:\n310\t          \"Count of operator_events rows with event_type like 'peek.%' in the configured window — every audit-emitting peek surface contributes.\",\n311\t        drilldownHref: \"/audit\",\n312\t      },\n313\t      raw: total,\n314\t      display: formatCount(total),\n315\t    },\n316\t    {\n317\t      blueprint: {\n318\t        id: \"audit.exports_24h\",\n319\t        label: \"Exports\",\n320\t        unit: \"events\",\n321\t        source: \"operator_events\",\n322\t        windowLabel,\n323\t        definition:\n324\t          \"Count of operator_events rows with event_type = 'peek.export' — every CSV export emits one before the bytes return.\",\n325\t        drilldownHref: \"/audit?eventType=peek.export\",\n326\t      },\n327\t      raw: exports,\n328\t      display: formatCount(exports),\n329\t    },\n330\t    {\n331\t      blueprint: {\n332\t        id: \"audit.access_denied_24h\",\n333\t        label: \"Access denied\",\n334\t        unit: \"events\",\n335\t        source: \"operator_events\",\n336\t        windowLabel,\n337\t        definition:\n338\t          \"Count of operator_events rows with event_type = 'peek.access.denied' — Cloudflare-verified actor blocked by local role policy.\",\n339\t        drilldownHref: \"/audit?eventType=peek.access.denied\",\n340\t      },\n341\t      raw: accessDenied,\n342\t      display: formatCount(accessDenied),\n343\t    },\n344\t    {\n345\t      blueprint: {\n346\t        id: \"audit.changes_applied_24h\",\n347\t        label: \"Changes applied\",\n348\t        unit: \"events\",\n349\t        source: \"operator_events\",\n350\t        windowLabel,\n351\t        definition:\n352\t          \"Count of operator_events rows with event_type = 'peek.change.applied' — admin mutations that committed.\",\n353\t        drilldownHref: \"/audit?eventType=peek.change.applied\",\n354\t      },\n355\t      raw: changesApplied,\n356\t      display: formatCount(changesApplied),\n357\t    },\n358\t    {\n359\t      blueprint: {\n360\t        id: \"audit.changes_rejected_24h\",\n361\t        label: \"Changes rejected\",\n362\t        unit: \"events\",\n363\t        source: \"operator_events\",\n364\t        windowLabel,\n365\t        definition:\n366\t          \"Count of operator_events rows with event_type = 'peek.change.rejected' — admin mutations denied or validation-failed.\",\n367\t        drilldownHref: \"/audit?eventType=peek.change.rejected\",\n368\t      },\n369\t      raw: changesRejected,\n370\t      display: formatCount(changesRejected),\n371\t    },\n372\t  ];\n373\t\n374\t  return {\n375\t    generatedAt,\n376\t    metrics: blueprints.map(({ blueprint, raw, display }) =>\n377\t      buildMetric(blueprint, raw, display, generatedAt),\n378\t    ),\n379\t    eventTypeCounts,\n380\t  };\n381\t}\n382\t\n383\texport { PEEK_AUDIT_EVENT_TYPES };\n384\t"}]},"parent_tool_use_id":null,"session_id":"94a07cbb-8d25-425b-954a-4878bb9ef4df","uuid":"69aa6a44-86c1-4f08-bdcf-8202554e24ec","timestamp":"2026-04-26T07:23:44.248Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-audit-events.ts","content":"// Audit-log admin queries (FR-11 audit view).\n//\n// Backs the upcoming `/audit` page. Reads `operator_events` (migration 002)\n// filtered to the `peek.*` event types the audit writer (FR-11) emits. The\n// page is admin-only via the FR-2 page-level allowlist; this module remains\n// strictly read-only — `operator_events` rows are append-only by contract and\n// the admin UI never edits them.\n//\n// Three exports:\n//\n//   - `getAuditOverview` — bounded counts for the FR-4 metric strip:\n//     total `peek.*` events in the last 24h plus the four interesting\n//     event-type subtotals (export, access denied, change applied, change\n//     rejected). Also returns the full per-event-type count breakdown so the\n//     page can render a sparse-aware breakdown card.\n//\n//   - `listAuditEvents` — bounded filtered list. Filters mirror the FR-11 spec\n//     line \"filters by event type, actor email, resource id, route, and date\".\n//     Each row arrives as a `PeekAuditEvent` with the writer's serialized\n//     `PeekAuditPayload` shape; payload values were already passed through\n//     `redactPayload` at write time but `listAuditEvents` re-applies\n//     `redactNullableString` defensively so a hand-crafted row that bypassed\n//     the writer cannot leak.\n//\n//   - The internal `coerceAuditEventTypeFilter` normaliser keeps the SQL\n//     \"any peek.*\" predicate honest: an unknown event type silently falls\n//     back to the broad \"starts with `peek.`\" filter rather than binding a\n//     value that would never match anything.\n\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_AUDIT_EVENT_TYPES,\n  isPeekAuditEventType,\n  type PeekAuditChange,\n  type PeekAuditEvent,\n  type PeekAuditEventType,\n  type PeekAuditEventTypeCount,\n  type PeekAuditFilters,\n  type PeekAuditOverview,\n  type PeekAuditOverviewMetricId,\n  type PeekAuditPayload,\n  type PeekMetric,\n} from \"../../../lib/types/peek\";\nimport { redactNullableString } from \"../../audit/redact\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_AUDIT_DEFAULT_LIMIT = 100;\nexport const PEEK_AUDIT_MAX_LIMIT = 500;\nexport const PEEK_AUDIT_OVERVIEW_WINDOW_HOURS = 24;\n\nexport type ListAuditEventsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekAuditFilters>;\n};\n\nexport type GetAuditOverviewOptions = {\n  sql?: Sql;\n  now?: Date;\n  windowHours?: number;\n};\n\nfunction clampLimit(\n  raw: number | undefined,\n  fallback: number,\n  max: number,\n): number {\n  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n  const floored = Math.floor(raw);\n  if (floored <= 0) return 1;\n  return Math.min(max, floored);\n}\n\nfunction trimOrNull(value: string | null | undefined): string | null {\n  if (typeof value !== \"string\") return null;\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nfunction readInt(value: number | string | null | undefined): number {\n  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n  if (typeof value === \"string\") {\n    const parsed = Number.parseInt(value, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\n// `eventType` filter is a discriminated string: a known `PeekAuditEventType`\n// binds verbatim, an unknown value normalises to `null` so the query falls back\n// to the \"any peek.*\" predicate. This keeps a stale URL chip from silently\n// dropping the result set to zero.\nfunction coerceAuditEventTypeFilter(\n  raw: string | null,\n): PeekAuditEventType | null {\n  if (raw === null) return null;\n  return isPeekAuditEventType(raw) ? raw : null;\n}\n\n// Re-applies the redaction policy on read so a row inserted by some path that\n// bypassed the writer cannot leak. `redactNullableString` is idempotent for\n// values that already round-tripped through the writer.\nfunction rehydratePayload(raw: unknown): PeekAuditPayload {\n  const obj = (raw && typeof raw === \"object\" ? raw : {}) as Record<\n    string,\n    unknown\n  >;\n\n  const actorEmail =\n    typeof obj.actorEmail === \"string\" && obj.actorEmail.length > 0\n      ? obj.actorEmail\n      : \"\";\n  const route = redactNullableString(\n    typeof obj.route === \"string\" ? obj.route : null,\n  );\n  const actionId = redactNullableString(\n    typeof obj.actionId === \"string\" ? obj.actionId : null,\n  );\n  const resourceType = redactNullableString(\n    typeof obj.resourceType === \"string\" ? obj.resourceType : null,\n  );\n  const resourceId = redactNullableString(\n    typeof obj.resourceId === \"string\" ? obj.resourceId : null,\n  );\n  const filterSummary = redactNullableString(\n    typeof obj.filterSummary === \"string\" ? obj.filterSummary : null,\n  );\n  const requestId = redactNullableString(\n    typeof obj.requestId === \"string\" ? obj.requestId : null,\n  );\n  const rejectionReason = redactNullableString(\n    typeof obj.rejectionReason === \"string\" ? obj.rejectionReason : null,\n  );\n  const resultCount =\n    typeof obj.resultCount === \"number\" && Number.isFinite(obj.resultCount)\n      ? obj.resultCount\n      : null;\n  const changes = Array.isArray(obj.changes)\n    ? ((obj.changes as ReadonlyArray<unknown>).filter(\n        (entry): entry is PeekAuditChange =>\n          entry !== null &&\n          typeof entry === \"object\" &&\n          \"field\" in entry,\n      ) as ReadonlyArray<PeekAuditChange>)\n    : null;\n\n  return {\n    actorEmail,\n    route,\n    actionId,\n    resourceType,\n    resourceId,\n    filterSummary,\n    resultCount,\n    requestId,\n    rejectionReason,\n    changes,\n  };\n}\n\nexport async function listAuditEvents(\n  options: ListAuditEventsOptions = {},\n): Promise<ReadonlyArray<PeekAuditEvent>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_AUDIT_DEFAULT_LIMIT,\n    PEEK_AUDIT_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const eventType = coerceAuditEventTypeFilter(\n    trimOrNull(filters.eventType ?? null),\n  );\n  const actorEmailRaw = trimOrNull(filters.actorEmail ?? null);\n  const actorEmail = actorEmailRaw ? actorEmailRaw.toLowerCase() : null;\n  const resourceId = trimOrNull(filters.resourceId ?? null);\n  const route = trimOrNull(filters.route ?? null);\n  const createdFrom = trimOrNull(filters.createdFrom ?? null);\n  const createdTo = trimOrNull(filters.createdTo ?? null);\n\n  const rows = await sql<\n    Array<{\n      id: string;\n      eventType: string;\n      createdAt: string;\n      payload: unknown;\n    }>\n  >`\n    select\n      oe.id::text as \"id\",\n      oe.event_type as \"eventType\",\n      oe.created_at::text as \"createdAt\",\n      oe.payload as \"payload\"\n    from operator_events oe\n    where\n      (${eventType === null} or oe.event_type = ${eventType ?? \"\"})\n      and (${eventType !== null} or oe.event_type like 'peek.%')\n      and (${actorEmail === null} or lower(oe.payload->>'actorEmail') = ${actorEmail ?? \"\"})\n      and (${resourceId === null} or oe.payload->>'resourceId' = ${resourceId ?? \"\"})\n      and (${route === null} or oe.payload->>'route' = ${route ?? \"\"})\n      and (${createdFrom === null} or oe.created_at >= ${createdFrom ?? \"\"}::timestamptz)\n      and (${createdTo === null} or oe.created_at < ${createdTo ?? \"\"}::timestamptz)\n    order by oe.created_at desc, oe.id desc\n    limit ${limit}\n  `;\n\n  return rows\n    .filter((row) => isPeekAuditEventType(row.eventType))\n    .map((row) => ({\n      id: row.id,\n      eventType: row.eventType as PeekAuditEventType,\n      createdAt: row.createdAt,\n      payload: rehydratePayload(row.payload),\n    }));\n}\n\ntype MetricBlueprint = {\n  id: PeekAuditOverviewMetricId;\n  label: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  definition: string;\n  drilldownHref: string | null;\n};\n\nfunction buildMetric(\n  blueprint: MetricBlueprint,\n  raw: number,\n  display: string,\n  asOf: string,\n): PeekMetric {\n  return {\n    id: blueprint.id,\n    label: blueprint.label,\n    value: raw,\n    valueDisplay: display,\n    unit: blueprint.unit,\n    source: blueprint.source,\n    windowLabel: blueprint.windowLabel,\n    asOf,\n    definition: blueprint.definition,\n    freshness: \"live\",\n    drilldownHref: blueprint.drilldownHref,\n  };\n}\n\nexport async function getAuditOverview(\n  options: GetAuditOverviewOptions = {},\n): Promise<PeekAuditOverview> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n  const windowHours = clampLimit(\n    options.windowHours,\n    PEEK_AUDIT_OVERVIEW_WINDOW_HOURS,\n    24 * 30,\n  );\n  const windowStartIso = new Date(\n    now.getTime() - windowHours * 60 * 60 * 1000,\n  ).toISOString();\n  const windowLabel =\n    windowHours === 24 ? \"Last 24h\" : `Last ${windowHours}h`;\n\n  const eventTypeRows = await sql<\n    Array<{ eventType: string; value: number | string }>\n  >`\n    select oe.event_type as \"eventType\", count(*)::int as \"value\"\n    from operator_events oe\n    where oe.event_type like 'peek.%'\n      and oe.created_at >= ${windowStartIso}::timestamptz\n    group by oe.event_type\n  `;\n\n  const countByType = new Map<string, number>();\n  for (const row of eventTypeRows) {\n    countByType.set(row.eventType, readInt(row.value));\n  }\n\n  const eventTypeCounts: ReadonlyArray<PeekAuditEventTypeCount> =\n    PEEK_AUDIT_EVENT_TYPES.map((eventType) => ({\n      eventType,\n      count: countByType.get(eventType) ?? 0,\n    }));\n\n  const total = eventTypeCounts.reduce((acc, row) => acc + row.count, 0);\n  const exports = countByType.get(\"peek.export\") ?? 0;\n  const accessDenied = countByType.get(\"peek.access.denied\") ?? 0;\n  const changesApplied = countByType.get(\"peek.change.applied\") ?? 0;\n  const changesRejected = countByType.get(\"peek.change.rejected\") ?? 0;\n\n  const blueprints: ReadonlyArray<{\n    blueprint: MetricBlueprint;\n    raw: number;\n    display: string;\n  }> = [\n    {\n      blueprint: {\n        id: \"audit.total_24h\",\n        label: \"Total peek.* events\",\n        unit: \"events\",\n        source: \"operator_events\",\n        windowLabel,\n        definition:\n          \"Count of operator_events rows with event_type like 'peek.%' in the configured window — every audit-emitting peek surface contributes.\",\n        drilldownHref: \"/audit\",\n      },\n      raw: total,\n      display: formatCount(total),\n    },\n    {\n      blueprint: {\n        id: \"audit.exports_24h\",\n        label: \"Exports\",\n        unit: \"events\",\n        source: \"operator_events\",\n        windowLabel,\n        definition:\n          \"Count of operator_events rows with event_type = 'peek.export' — every CSV export emits one before the bytes return.\",\n        drilldownHref: \"/audit?eventType=peek.export\",\n      },\n      raw: exports,\n      display: formatCount(exports),\n    },\n    {\n      blueprint: {\n        id: \"audit.access_denied_24h\",\n        label: \"Access denied\",\n        unit: \"events\",\n        source: \"operator_events\",\n        windowLabel,\n        definition:\n          \"Count of operator_events rows with event_type = 'peek.access.denied' — Cloudflare-verified actor blocked by local role policy.\",\n        drilldownHref: \"/audit?eventType=peek.access.denied\",\n      },\n      raw: accessDenied,\n      display: formatCount(accessDenied),\n    },\n    {\n      blueprint: {\n        id: \"audit.changes_applied_24h\",\n        label: \"Changes applied\",\n        unit: \"events\",\n        source: \"operator_events\",\n        windowLabel,\n        definition:\n          \"Count of operator_events rows with event_type = 'peek.change.applied' — admin mutations that committed.\",\n        drilldownHref: \"/audit?eventType=peek.change.applied\",\n      },\n      raw: changesApplied,\n      display: formatCount(changesApplied),\n    },\n    {\n      blueprint: {\n        id: \"audit.changes_rejected_24h\",\n        label: \"Changes rejected\",\n        unit: \"events\",\n        source: \"operator_events\",\n        windowLabel,\n        definition:\n          \"Count of operator_events rows with event_type = 'peek.change.rejected' — admin mutations denied or validation-failed.\",\n        drilldownHref: \"/audit?eventType=peek.change.rejected\",\n      },\n      raw: changesRejected,\n      display: formatCount(changesRejected),\n    },\n  ];\n\n  return {\n    generatedAt,\n    metrics: blueprints.map(({ blueprint, raw, display }) =>\n      buildMetric(blueprint, raw, display, generatedAt),\n    ),\n    eventTypeCounts,\n  };\n}\n\nexport { PEEK_AUDIT_EVENT_TYPES };\n","numLines":384,"startLine":1,"totalLines":384}}}
