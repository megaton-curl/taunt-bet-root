{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01SGNG1X8p938H7aqWxtesWh","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_016U4U5LrCQ3rCnL4DPDEKbk","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/lib/__tests__/audit-search-params.test.ts","content":"// Tests for the FR-11 /audit URL-addressable filter normaliser.\n//\n// `/audit` consumes two filter sources:\n//   - the in-page filter form, which submits long-form `auditFilter*` params;\n//   - the command-center metric drilldowns and any deep-links, which use the\n//     short-form `eventType` chip (no prefix).\n//\n// The normaliser is the contract that keeps a stale URL chip from lying about\n// the table's filter state — empty/whitespace → null, unknown event type →\n// null, recognised allowlist values pass through, and the short form wins\n// when both are present (so an operator's drilldown intent always overrides\n// any leftover form state).\n\nimport { describe, expect, it } from \"vitest\";\nimport {\n  PEEK_AUDIT_EVENT_TYPE_VALUES,\n  PEEK_AUDIT_FILTER_PARAM_NAMES,\n  normalizeAuditFiltersFromSearchParams,\n} from \"../audit-search-params\";\nimport { PEEK_AUDIT_EVENT_TYPES } from \"../types/peek\";\n\ndescribe(\"normalizeAuditFiltersFromSearchParams\", () => {\n  it(\"empty input: every filter normalises to null\", () => {\n    expect(normalizeAuditFiltersFromSearchParams({})).toEqual({\n      eventType: null,\n      actorEmail: null,\n      resourceId: null,\n      route: null,\n      createdFrom: null,\n      createdTo: null,\n    });\n  });\n\n  it(\"whitespace-only values normalise to null across every filter\", () => {\n    expect(\n      normalizeAuditFiltersFromSearchParams({\n        eventType: \"  \",\n        auditFilterEventType: \"  \",\n        auditFilterActor: \"   \",\n        auditFilterResource: \"  \",\n        auditFilterRoute: \" \",\n        auditFilterCreatedFrom: \" \",\n        auditFilterCreatedTo: \" \",\n      }),\n    ).toEqual({\n      eventType: null,\n      actorEmail: null,\n      resourceId: null,\n      route: null,\n      createdFrom: null,\n      createdTo: null,\n    });\n  });\n\n  it(\"populated: every supported filter flows through with trimming\", () => {\n    expect(\n      normalizeAuditFiltersFromSearchParams({\n        auditFilterEventType: \"peek.export\",\n        auditFilterActor: \"  alice@example.com  \",\n        auditFilterResource: \"  user-9  \",\n        auditFilterRoute: \"  /users/[userId]  \",\n        auditFilterCreatedFrom: \"2026-04-01\",\n        auditFilterCreatedTo: \"2026-04-26\",\n      }),\n    ).toEqual({\n      eventType: \"peek.export\",\n      actorEmail: \"alice@example.com\",\n      resourceId: \"user-9\",\n      route: \"/users/[userId]\",\n      createdFrom: \"2026-04-01\",\n      createdTo: \"2026-04-26\",\n    });\n  });\n\n  it(\"eventType: state-transition coverage — every PeekAuditEventType passes through verbatim\", () => {\n    for (const value of PEEK_AUDIT_EVENT_TYPES) {\n      const filters = normalizeAuditFiltersFromSearchParams({\n        auditFilterEventType: value,\n      });\n      expect(filters.eventType).toBe(value);\n    }\n  });\n\n  it(\"eventType: unknown value normalises to null so a stale URL chip cannot lie\", () => {\n    expect(\n      normalizeAuditFiltersFromSearchParams({\n        auditFilterEventType: \"peek.not.a.real.event\",\n      }).eventType,\n    ).toBeNull();\n\n    expect(\n      normalizeAuditFiltersFromSearchParams({\n        eventType: \"totally-bogus\",\n      }).eventType,\n    ).toBeNull();\n  });\n\n  it(\"eventType: short-form `?eventType=` wins over the long-form `auditFilterEventType` so command-center drilldowns override form state\", () => {\n    expect(\n      normalizeAuditFiltersFromSearchParams({\n        eventType: \"peek.export\",\n        auditFilterEventType: \"peek.search\",\n      }).eventType,\n    ).toBe(\"peek.export\");\n  });\n\n  it(\"eventType: short-form short-circuits to long-form when short is empty/whitespace\", () => {\n    expect(\n      normalizeAuditFiltersFromSearchParams({\n        eventType: \"  \",\n        auditFilterEventType: \"peek.search\",\n      }).eventType,\n    ).toBe(\"peek.search\");\n  });\n\n  it(\"eventType: short-form unknown does NOT silently fall through to the long-form (a bogus chip stays bogus)\", () => {\n    // The short-form value coerces first; an unknown value normalises to null\n    // and the long-form is intentionally not consulted as a fallback. This\n    // keeps deep-links honest: if a drilldown deep-links to a stale event\n    // type, the page does not silently substitute a different filter.\n    expect(\n      normalizeAuditFiltersFromSearchParams({\n        eventType: \"totally-bogus\",\n        auditFilterEventType: \"peek.export\",\n      }).eventType,\n    ).toBeNull();\n  });\n\n  it(\"array values: only the first element is read\", () => {\n    expect(\n      normalizeAuditFiltersFromSearchParams({\n        auditFilterEventType: [\"peek.export\", \"peek.search\"],\n        auditFilterActor: [\"alice@example.com\", \"bob@example.com\"],\n      }),\n    ).toEqual({\n      eventType: \"peek.export\",\n      actorEmail: \"alice@example.com\",\n      resourceId: null,\n      route: null,\n      createdFrom: null,\n      createdTo: null,\n    });\n  });\n\n  it(\"undefined input value normalises to null without throwing\", () => {\n    expect(\n      normalizeAuditFiltersFromSearchParams({\n        auditFilterEventType: undefined,\n        auditFilterActor: undefined,\n        auditFilterResource: undefined,\n        auditFilterRoute: undefined,\n        auditFilterCreatedFrom: undefined,\n        auditFilterCreatedTo: undefined,\n      }),\n    ).toEqual({\n      eventType: null,\n      actorEmail: null,\n      resourceId: null,\n      route: null,\n      createdFrom: null,\n      createdTo: null,\n    });\n  });\n});\n\ndescribe(\"PEEK_AUDIT_FILTER_PARAM_NAMES\", () => {\n  it(\"declares the same param names the form fields submit\", () => {\n    expect(PEEK_AUDIT_FILTER_PARAM_NAMES.eventType).toBe(\n      \"auditFilterEventType\",\n    );\n    expect(PEEK_AUDIT_FILTER_PARAM_NAMES.actorEmail).toBe(\"auditFilterActor\");\n    expect(PEEK_AUDIT_FILTER_PARAM_NAMES.resourceId).toBe(\n      \"auditFilterResource\",\n    );\n    expect(PEEK_AUDIT_FILTER_PARAM_NAMES.route).toBe(\"auditFilterRoute\");\n    expect(PEEK_AUDIT_FILTER_PARAM_NAMES.createdFrom).toBe(\n      \"auditFilterCreatedFrom\",\n    );\n    expect(PEEK_AUDIT_FILTER_PARAM_NAMES.createdTo).toBe(\n      \"auditFilterCreatedTo\",\n    );\n  });\n});\n\ndescribe(\"PEEK_AUDIT_EVENT_TYPE_VALUES\", () => {\n  it(\"mirrors the canonical PEEK_AUDIT_EVENT_TYPES list verbatim\", () => {\n    expect([...PEEK_AUDIT_EVENT_TYPE_VALUES]).toEqual([...PEEK_AUDIT_EVENT_TYPES]);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2379,"cache_read_input_tokens":125212,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2379},"output_tokens":38,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"94a07cbb-8d25-425b-954a-4878bb9ef4df","uuid":"c1f87607-b8a6-4442-a4c6-a9084d2212de"}
