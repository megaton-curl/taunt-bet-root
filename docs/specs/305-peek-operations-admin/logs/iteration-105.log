", href: \"/access\" },\n];\n\nconst BUSINESS_NAV_ITEMS: ReadonlyArray<AdminShellNavItem> = ALL_NAV_ITEMS.filter(\n  (item) => item.id !== \"audit\",\n);\n\ndescribe(\"AdminShell\", () => {\n  it(\"populated (admin): renders brand, every nav link, actor email, and the resolved role badge\", () => {\n    render(\n      <AdminShell\n        actor={{ email: \"alice@example.com\", role: \"admin\" }}\n        navItems={ALL_NAV_ITEMS}\n      >\n        <p>page content</p>\n      </AdminShell>,\n    );\n\n    expect(screen.getByText(\"Peek\")).toBeInTheDocument();\n\n    const nav = screen.getByRole(\"navigation\", { name: \"Primary\" });\n    const labels = within(nav)\n      .getAllByRole(\"link\")\n      .map((link) => link.textContent);\n    expect(labels).toEqual([\n      \"Users\",\n      \"Growth\",\n      \"Games\",\n      \"Economy\",\n      \"Operations\",\n      \"Audit\",\n      \"Access\",\n    ]);\n    expect(within(nav).getByRole(\"link\", { name: \"Audit\" })).toHaveAttribute(\n      \"href\",\n      \"/audit\",\n    );\n\n    const identity = screen.getByLabelText(\"Verified actor\");\n    expect(identity).toHaveTextContent(\"alice@example.com\");\n\n    const roleBadge = screen.getByLabelText(\"Resolved role: admin\");\n    expect(roleBadge).toHaveTextContent(\"admin\");\n    expect(roleBadge).toHaveAttribute(\"data-role\", \"admin\");\n\n    expect(screen.getByText(\"page content\")).toBeInTheDocument();\n  });\n\n  it(\"populated (business): hides Audit when caller did not include it in navItems\", () => {\n    render(\n      <AdminShell\n        actor={{ email: \"biz@example.com\", role: \"business\" }}\n        navItems={BUSINESS_NAV_ITEMS}\n      >\n        <p>page content</p>\n      </AdminShell>,\n    );\n\n    const nav = screen.getByRole(\"navigation\", { name: \"Primary\" });\n    const labels = within(nav)\n      .getAllByRole(\"link\")\n      .map((link) => link.textContent);\n    expect(labels).toEqual([\n      \"Users\",\n      \"Growth\",\n      \"Games\",\n      \"Economy\",\n      \"Operations\",\n      \"Access\",\n    ]);\n    expect(within(nav).queryByRole(\"link\", { name: \"Audit\" })).toBeNull();\n\n    const roleBadge = screen.getByLabelText(\"Resolved role: business\");\n    expect(roleBadge).toHaveAttribute(\"data-role\", \"business\");\n  });\n\n  it(\"no-role: renders the access-denied alert without echoing the verified email or rendering nav/children\", () => {\n    render(\n      <AdminShell\n        actor={null}\n        navItems={[]}\n        accessIssue=\"no-role\"\n      >\n        <p data-testid=\"hidden-children\">page content</p>\n      </AdminShell>,\n    );\n\n    const alert = screen.getByRole(\"alert\", { name: \"Access denied\" });\n    expect(alert).toHaveTextContent(\"Local role not assigned\");\n    expect(alert).toHaveTextContent(\n      \"no local peek role is configured for it\",\n    );\n\n    expect(alert.textContent ?? \"\").not.toContain(\"@\");\n\n    expect(screen.queryByRole(\"navigation\", { name: \"Primary\" })).toBeNull();\n    expect(screen.queryByLabelText(\"Verified actor\")).toBeNull();\n    expect(screen.queryByTestId(\"hidden-children\")).toBeNull();\n  });\n\n  it(\"no-identity: renders a generic missing-identity alert and suppresses nav/identity/children\", () => {\n    render(\n      <AdminShell\n        actor={null}\n        navItems={[]}\n        accessIssue=\"no-identity\"\n      >\n        <p data-testid=\"hidden-children\">page content</p>\n      </AdminShell>,\n    );\n\n    const alert = screen.getByRole(\"alert\", { name: \"Access denied\" });\n    expect(alert).toHaveTextContent(\"Access not available\");\n    expect(alert).toHaveTextContent(\"Cloudflare Access did not deliver\");\n\n    expect(alert.textContent ?? \"\").not.toContain(\"@\");\n\n    expect(screen.queryByRole(\"navigation\", { name: \"Primary\" })).toBeNull();\n    expect(screen.queryByLabelText(\"Verified actor\")).toBeNull();\n    expect(screen.queryByTestId(\"hidden-children\")).toBeNull();\n  });\n\n  it(\"no-role with stale actor: still suppresses identity and nav so denied state never leaks the verified email\", () => {\n    render(\n      <AdminShell\n        actor={{ email: \"alice@example.com\", role: \"admin\" }}\n        navItems={ALL_NAV_ITEMS}\n        accessIssue=\"no-role\"\n      >\n        <p data-testid=\"hidden-children\">page content</p>\n      </AdminShell>,\n    );\n\n    expect(screen.queryByLabelText(\"Verified actor\")).toBeNull();\n    expect(screen.queryByText(\"alice@example.com\")).toBeNull();\n    expect(screen.queryByRole(\"navigation\", { name: \"Primary\" })).toBeNull();\n    expect(screen.queryByTestId(\"hidden-children\")).toBeNull();\n    expect(screen.getByRole(\"alert\", { name: \"Access denied\" })).toBeInTheDocument();\n  });\n\n  it(\"populated with empty navItems: renders identity but no primary nav (defensive for unconfigured nav)\", () => {\n    render(\n      <AdminShell\n        actor={{ email: \"biz@example.com\", role: \"business\" }}\n        navItems={[]}\n      >\n        <p data-testid=\"page-children\">page content</p>\n      </AdminShell>,\n    );\n\n    expect(screen.queryByRole(\"navigation\", { name: \"Primary\" })).toBeNull();\n    expect(screen.getByLabelText(\"Verified actor\")).toHaveTextContent(\n      \"biz@example.com\",\n    );\n    expect(screen.getByTestId(\"page-children\")).toBeInTheDocument();\n  });\n});\n","numLines":172,"startLine":1,"totalLines":172}}}
