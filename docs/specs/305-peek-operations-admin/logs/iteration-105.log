{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RQ2LUryx86p9sy2piNqKfp","type":"tool_result","content":"270\t      startedAt: \"2026-04-26T10:01:00.000Z\",\n271\t      completedAt: null,\n272\t      createdAt: \"2026-04-26T09:55:00.000Z\",\n273\t      error: \"RpcError: connection refused\",\n274\t      userId: \"user-9\",\n275\t      roundId: \"round-3\",\n276\t      claimId: null,\n277\t    };\n278\t    const mock = createSqlMock([[row]]);\n279\t\n280\t    const rows = await listEventQueue({ sql: mock.sql });\n281\t    expect(rows).toHaveLength(1);\n282\t    expect(rows[0].status).toBe(\"failed\");\n283\t    expect(rows[0].attempts).toBe(3);\n284\t    expect(rows[0].maxAttempts).toBe(5);\n285\t    expect(rows[0].errorPreview).toBe(\"RpcError: connection refused\");\n286\t    expect(rows[0].linked).toEqual({\n287\t      userId: \"user-9\",\n288\t      roundId: \"round-3\",\n289\t      claimId: null,\n290\t    });\n291\t  });\n292\t\n293\t  it(\"populated: stringified attempts/maxAttempts coerce to integers via readInt\", async () => {\n294\t    const row = {\n295\t      id: \"abc\",\n296\t      eventType: \"points.grant\",\n297\t      status: \"failed\",\n298\t      attempts: \"7\",\n299\t      maxAttempts: \"10\",\n300\t      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n301\t      startedAt: null,\n302\t      completedAt: null,\n303\t      createdAt: \"2026-04-26T09:55:00.000Z\",\n304\t      error: null,\n305\t      userId: null,\n306\t      roundId: null,\n307\t      claimId: null,\n308\t    };\n309\t    const mock = createSqlMock([[row]]);\n310\t    const rows = await listEventQueue({ sql: mock.sql });\n311\t    expect(rows[0].attempts).toBe(7);\n312\t    expect(rows[0].maxAttempts).toBe(10);\n313\t  });\n314\t\n315\t  it(\"populated: an oversized error string is truncated with an ellipsis at PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS\", async () => {\n316\t    const big = \"x\".repeat(PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS + 50);\n317\t    const row = {\n318\t      id: \"abc\",\n319\t      eventType: \"points.grant\",\n320\t      status: \"dead\",\n321\t      attempts: 5,\n322\t      maxAttempts: 5,\n323\t      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n324\t      startedAt: null,\n325\t      completedAt: null,\n326\t      createdAt: \"2026-04-26T09:55:00.000Z\",\n327\t      error: big,\n328\t      userId: null,\n329\t      roundId: null,\n330\t      claimId: null,\n331\t    };\n332\t    const mock = createSqlMock([[row]]);\n333\t    const rows = await listEventQueue({ sql: mock.sql });\n334\t    expect(rows[0].errorPreview).not.toBeNull();\n335\t    expect(rows[0].errorPreview?.length).toBe(\n336\t      PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS + 1, // \"+1\" for the trailing ellipsis\n337\t    );\n338\t    expect(rows[0].errorPreview?.endsWith(\"…\")).toBe(true);\n339\t  });\n340\t\n341\t  it(\"redaction: an error string that looks like a JWT is replaced with PEEK_AUDIT_REDACTED in the preview\", async () => {\n342\t    const jwt =\n343\t      \"eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ1c2VyLTkifQ.signature_segment\";\n344\t    const row = {\n345\t      id: \"abc\",\n346\t      eventType: \"auth.callback\",\n347\t      status: \"failed\",\n348\t      attempts: 1,\n349\t      maxAttempts: 3,\n350\t      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n351\t      startedAt: null,\n352\t      completedAt: null,\n353\t      createdAt: \"2026-04-26T09:55:00.000Z\",\n354\t      error: jwt,\n355\t      userId: null,\n356\t      roundId: null,\n357\t      claimId: null,\n358\t    };\n359\t    const mock = createSqlMock([[row]]);\n360\t    const rows = await listEventQueue({ sql: mock.sql });\n361\t    expect(rows[0].errorPreview).toBe(PEEK_AUDIT_REDACTED);\n362\t    // The original secret never reaches the surface.\n363\t    expect(rows[0].errorPreview).not.toContain(\"eyJ\");\n364\t  });\n365\t\n366\t  it(\"redaction: a payload-derived linked id that looks like a postgres URL is redacted\", async () => {\n367\t    // Pathological input: a queue worker accidentally serialised a connection\n368\t    // string into payload.userId. The list-row should redact it before the\n369\t    // row leaves the server.\n370\t    const row = {\n371\t      id: \"abc\",\n372\t      eventType: \"points.grant\",\n373\t      status: \"pending\",\n374\t      attempts: 0,\n375\t      maxAttempts: 5,\n376\t      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n377\t      startedAt: null,\n378\t      completedAt: null,\n379\t      createdAt: \"2026-04-26T09:55:00.000Z\",\n380\t      error: null,\n381\t      userId: \"postgres://user:pass@host:5432/db\",\n382\t      roundId: null,\n383\t      claimId: null,\n384\t    };\n385\t    const mock = createSqlMock([[row]]);\n386\t    const rows = await listEventQueue({ sql: mock.sql });\n387\t    expect(rows[0].linked.userId).toBe(PEEK_AUDIT_REDACTED);\n388\t    expect(rows[0].linked.userId).not.toContain(\"postgres://\");\n389\t  });\n390\t\n391\t  it(\"sparse: an empty result set returns []\", async () => {\n392\t    const mock = createSqlMock([[]]);\n393\t    const rows = await listEventQueue({ sql: mock.sql });\n394\t    expect(rows).toEqual([]);\n395\t  });\n396\t\n397\t  it(\"load-error: a rejected query propagates\", async () => {\n398\t    const mock = createSqlMock([new Error(\"connection refused\")]);\n399\t    await expect(listEventQueue({ sql: mock.sql })).rejects.toThrowError(\n400\t      \"connection refused\",\n401\t    );\n402\t  });\n403\t});\n404\t\n405\tdescribe(\"getEventQueueDetail\", () => {\n406\t  it(\"returns null when id is missing\", async () => {\n407\t    const mock = createSqlMock([]);\n408\t    const detail = await getEventQueueDetail({ sql: mock.sql, id: \"\" });\n409\t    expect(detail).toBeNull();\n410\t    // No SQL fired — the early return short-circuits before the lookup.\n411\t    expect(mock.calls).toHaveLength(0);\n412\t  });\n413\t\n414\t  it(\"returns null when the row is not found\", async () => {\n415\t    const mock = createSqlMock([[]]);\n416\t    const detail = await getEventQueueDetail({ sql: mock.sql, id: \"missing\" });\n417\t    expect(detail).toBeNull();\n418\t  });\n419\t\n420\t  it(\"populated: passes through the columns and applies redactJsonValue / redactNullableString\", async () => {\n421\t    const payload = {\n422\t      userId: \"user-9\",\n423\t      claimAmount: \"5000000\",\n424\t      // A nested string that looks like a Bearer token must round-trip as the\n425\t      // PEEK_AUDIT_REDACTED marker.\n426\t      authHeader: \"Bearer abcdefgh1234567890\",\n427\t    };\n428\t    const row = {\n429\t      id: \"11111111-1111-1111-1111-111111111111\",\n430\t      eventType: \"claims.process\",\n431\t      status: \"failed\",\n432\t      attempts: 2,\n433\t      maxAttempts: 5,\n434\t      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n435\t      startedAt: null,\n436\t      completedAt: null,\n437\t      createdAt: \"2026-04-26T09:55:00.000Z\",\n438\t      error: \"RpcError: connection refused\",\n439\t      payload,\n440\t      userId: \"user-9\",\n441\t      roundId: null,\n442\t      claimId: \"claim-3\",\n443\t    };\n444\t    const mock = createSqlMock([[row]]);\n445\t    const detail = await getEventQueueDetail({\n446\t      sql: mock.sql,\n447\t      id: \"11111111-1111-1111-1111-111111111111\",\n448\t    });\n449\t    expect(detail).not.toBeNull();\n450\t    expect(detail?.id).toBe(\"11111111-1111-1111-1111-111111111111\");\n451\t    expect(detail?.error).toBe(\"RpcError: connection refused\");\n452\t    expect(detail?.linked).toEqual({\n453\t      userId: \"user-9\",\n454\t      roundId: null,\n455\t      claimId: \"claim-3\",\n456\t    });\n457\t    // The Bearer token in the JSONB payload is redacted recursively.\n458\t    const redactedPayload = detail?.payload as Record<string, unknown>;\n459\t    expect(redactedPayload.authHeader).toBe(PEEK_AUDIT_REDACTED);\n460\t    // Non-secret keys round-trip verbatim.\n461\t    expect(redactedPayload.userId).toBe(\"user-9\");\n462\t    expect(redactedPayload.claimAmount).toBe(\"5000000\");\n463\t  });\n464\t\n465\t  it(\"redaction: a bare error string that looks like a DB URL is redacted (the audit redactor swaps the value)\", async () => {\n466\t    const row = {\n467\t      id: \"abc\",\n468\t      eventType: \"claims.process\",\n469\t      status: \"failed\",\n470\t      attempts: 2,\n471\t      maxAttempts: 5,\n472\t      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n473\t      startedAt: null,\n474\t      completedAt: null,\n475\t      createdAt: \"2026-04-26T09:55:00.000Z\",\n476\t      error: \"fatal: postgres://user:secret@host:5432/db unreachable\",\n477\t      payload: null,\n478\t      userId: null,\n479\t      roundId: null,\n480\t      claimId: null,\n481\t    };\n482\t    const mock = createSqlMock([[row]]);\n483\t    const detail = await getEventQueueDetail({ sql: mock.sql, id: \"abc\" });\n484\t    expect(detail?.error).toBe(PEEK_AUDIT_REDACTED);\n485\t    // The original credential never reaches the operator UI.\n486\t    expect(detail?.error).not.toContain(\"secret\");\n487\t  });\n488\t\n489\t  it(\"redaction: cycles in the JSONB payload are guarded — no infinite loop\", async () => {\n490\t    type Cyc = { a: number; self?: unknown };\n491\t    const cyclic: Cyc = { a: 1 };\n492\t    cyclic.self = cyclic;\n493\t\n494\t    const row = {\n495\t      id: \"abc\",\n496\t      eventType: \"claims.process\",\n497\t      status: \"failed\",\n498\t      attempts: 2,\n499\t      maxAttempts: 5,\n500\t      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n501\t      startedAt: null,\n502\t      completedAt: null,\n503\t      createdAt: \"2026-04-26T09:55:00.000Z\",\n504\t      error: null,\n505\t      payload: cyclic,\n506\t      userId: null,\n507\t      roundId: null,\n508\t      claimId: null,\n509\t    };\n510\t    const mock = createSqlMock([[row]]);\n511\t    const detail = await getEventQueueDetail({ sql: mock.sql, id: \"abc\" });\n512\t    const redacted = detail?.payload as Record<string, unknown>;\n513\t    expect(redacted.a).toBe(1);\n514\t    // The cycle is broken with the redacted sentinel rather than crashing\n515\t    // the renderer.\n516\t    expect(redacted.self).toBe(PEEK_AUDIT_REDACTED);\n517\t  });\n518\t});\n519\t"}]},"parent_tool_use_id":null,"session_id":"94a07cbb-8d25-425b-954a-4878bb9ef4df","uuid":"889e1970-e093-4efe-a270-900ab9238020","timestamp":"2026-04-26T07:24:33.015Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-event-queue.test.ts","content":"      startedAt: \"2026-04-26T10:01:00.000Z\",\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: \"RpcError: connection refused\",\n      userId: \"user-9\",\n      roundId: \"round-3\",\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n\n    const rows = await listEventQueue({ sql: mock.sql });\n    expect(rows).toHaveLength(1);\n    expect(rows[0].status).toBe(\"failed\");\n    expect(rows[0].attempts).toBe(3);\n    expect(rows[0].maxAttempts).toBe(5);\n    expect(rows[0].errorPreview).toBe(\"RpcError: connection refused\");\n    expect(rows[0].linked).toEqual({\n      userId: \"user-9\",\n      roundId: \"round-3\",\n      claimId: null,\n    });\n  });\n\n  it(\"populated: stringified attempts/maxAttempts coerce to integers via readInt\", async () => {\n    const row = {\n      id: \"abc\",\n      eventType: \"points.grant\",\n      status: \"failed\",\n      attempts: \"7\",\n      maxAttempts: \"10\",\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: null,\n      userId: null,\n      roundId: null,\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listEventQueue({ sql: mock.sql });\n    expect(rows[0].attempts).toBe(7);\n    expect(rows[0].maxAttempts).toBe(10);\n  });\n\n  it(\"populated: an oversized error string is truncated with an ellipsis at PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS\", async () => {\n    const big = \"x\".repeat(PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS + 50);\n    const row = {\n      id: \"abc\",\n      eventType: \"points.grant\",\n      status: \"dead\",\n      attempts: 5,\n      maxAttempts: 5,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: big,\n      userId: null,\n      roundId: null,\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listEventQueue({ sql: mock.sql });\n    expect(rows[0].errorPreview).not.toBeNull();\n    expect(rows[0].errorPreview?.length).toBe(\n      PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS + 1, // \"+1\" for the trailing ellipsis\n    );\n    expect(rows[0].errorPreview?.endsWith(\"…\")).toBe(true);\n  });\n\n  it(\"redaction: an error string that looks like a JWT is replaced with PEEK_AUDIT_REDACTED in the preview\", async () => {\n    const jwt =\n      \"eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ1c2VyLTkifQ.signature_segment\";\n    const row = {\n      id: \"abc\",\n      eventType: \"auth.callback\",\n      status: \"failed\",\n      attempts: 1,\n      maxAttempts: 3,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: jwt,\n      userId: null,\n      roundId: null,\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listEventQueue({ sql: mock.sql });\n    expect(rows[0].errorPreview).toBe(PEEK_AUDIT_REDACTED);\n    // The original secret never reaches the surface.\n    expect(rows[0].errorPreview).not.toContain(\"eyJ\");\n  });\n\n  it(\"redaction: a payload-derived linked id that looks like a postgres URL is redacted\", async () => {\n    // Pathological input: a queue worker accidentally serialised a connection\n    // string into payload.userId. The list-row should redact it before the\n    // row leaves the server.\n    const row = {\n      id: \"abc\",\n      eventType: \"points.grant\",\n      status: \"pending\",\n      attempts: 0,\n      maxAttempts: 5,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: null,\n      userId: \"postgres://user:pass@host:5432/db\",\n      roundId: null,\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listEventQueue({ sql: mock.sql });\n    expect(rows[0].linked.userId).toBe(PEEK_AUDIT_REDACTED);\n    expect(rows[0].linked.userId).not.toContain(\"postgres://\");\n  });\n\n  it(\"sparse: an empty result set returns []\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listEventQueue({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"connection refused\")]);\n    await expect(listEventQueue({ sql: mock.sql })).rejects.toThrowError(\n      \"connection refused\",\n    );\n  });\n});\n\ndescribe(\"getEventQueueDetail\", () => {\n  it(\"returns null when id is missing\", async () => {\n    const mock = createSqlMock([]);\n    const detail = await getEventQueueDetail({ sql: mock.sql, id: \"\" });\n    expect(detail).toBeNull();\n    // No SQL fired — the early return short-circuits before the lookup.\n    expect(mock.calls).toHaveLength(0);\n  });\n\n  it(\"returns null when the row is not found\", async () => {\n    const mock = createSqlMock([[]]);\n    const detail = await getEventQueueDetail({ sql: mock.sql, id: \"missing\" });\n    expect(detail).toBeNull();\n  });\n\n  it(\"populated: passes through the columns and applies redactJsonValue / redactNullableString\", async () => {\n    const payload = {\n      userId: \"user-9\",\n      claimAmount: \"5000000\",\n      // A nested string that looks like a Bearer token must round-trip as the\n      // PEEK_AUDIT_REDACTED marker.\n      authHeader: \"Bearer abcdefgh1234567890\",\n    };\n    const row = {\n      id: \"11111111-1111-1111-1111-111111111111\",\n      eventType: \"claims.process\",\n      status: \"failed\",\n      attempts: 2,\n      maxAttempts: 5,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: \"RpcError: connection refused\",\n      payload,\n      userId: \"user-9\",\n      roundId: null,\n      claimId: \"claim-3\",\n    };\n    const mock = createSqlMock([[row]]);\n    const detail = await getEventQueueDetail({\n      sql: mock.sql,\n      id: \"11111111-1111-1111-1111-111111111111\",\n    });\n    expect(detail).not.toBeNull();\n    expect(detail?.id).toBe(\"11111111-1111-1111-1111-111111111111\");\n    expect(detail?.error).toBe(\"RpcError: connection refused\");\n    expect(detail?.linked).toEqual({\n      userId: \"user-9\",\n      roundId: null,\n      claimId: \"claim-3\",\n    });\n    // The Bearer token in the JSONB payload is redacted recursively.\n    const redactedPayload = detail?.payload as Record<string, unknown>;\n    expect(redactedPayload.authHeader).toBe(PEEK_AUDIT_REDACTED);\n    // Non-secret keys round-trip verbatim.\n    expect(redactedPayload.userId).toBe(\"user-9\");\n    expect(redactedPayload.claimAmount).toBe(\"5000000\");\n  });\n\n  it(\"redaction: a bare error string that looks like a DB URL is redacted (the audit redactor swaps the value)\", async () => {\n    const row = {\n      id: \"abc\",\n      eventType: \"claims.process\",\n      status: \"failed\",\n      attempts: 2,\n      maxAttempts: 5,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: \"fatal: postgres://user:secret@host:5432/db unreachable\",\n      payload: null,\n      userId: null,\n      roundId: null,\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const detail = await getEventQueueDetail({ sql: mock.sql, id: \"abc\" });\n    expect(detail?.error).toBe(PEEK_AUDIT_REDACTED);\n    // The original credential never reaches the operator UI.\n    expect(detail?.error).not.toContain(\"secret\");\n  });\n\n  it(\"redaction: cycles in the JSONB payload are guarded — no infinite loop\", async () => {\n    type Cyc = { a: number; self?: unknown };\n    const cyclic: Cyc = { a: 1 };\n    cyclic.self = cyclic;\n\n    const row = {\n      id: \"abc\",\n      eventType: \"claims.process\",\n      status: \"failed\",\n      attempts: 2,\n      maxAttempts: 5,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",\n      startedAt: null,\n      completedAt: null,\n      createdAt: \"2026-04-26T09:55:00.000Z\",\n      error: null,\n      payload: cyclic,\n      userId: null,\n      roundId: null,\n      claimId: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const detail = await getEventQueueDetail({ sql: mock.sql, id: \"abc\" });\n    const redacted = detail?.payload as Record<string, unknown>;\n    expect(redacted.a).toBe(1);\n    // The cycle is broken with the redacted sentinel rather than crashing\n    // the renderer.\n    expect(redacted.self).toBe(PEEK_AUDIT_REDACTED);\n  });\n});\n","numLines":250,"startLine":270,"totalLines":779}}}
