{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01KUGHS1wLJS6Qruio5DqQrm","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01LMGnEPzPMKtwFNw1nCauvo","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/__tests__/audit-events-filter-bar.test.tsx","content":"// Component tests for the FR-11 /audit filter bar.\n//\n// The filter bar is a query-string GET form (no JS), so each test asserts:\n//   - the form posts to /audit via GET;\n//   - each input/select uses its `auditFilter*` name (matches the URL parser);\n//   - the event-type select exposes every allowlisted PeekAuditEventType plus\n//     the \"Any peek.*\" empty option;\n//   - populated filters pre-fill every field;\n//   - ISO timestamps in date filters are truncated to YYYY-MM-DD;\n//   - the custom `action` prop overrides the default form target;\n//   - the form does NOT carry a hidden short-form `eventType` chip (submitting\n//     the form swaps the chip out for the in-form `auditFilterEventType` so\n//     the form is the single source of truth on submit).\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { AuditEventsFilterBar } from \"../audit-events-filter-bar\";\nimport { PEEK_AUDIT_EVENT_TYPES } from \"../../lib/types/peek\";\nimport type { PeekAuditFilters } from \"../../lib/types/peek\";\n\nconst EMPTY_FILTERS: PeekAuditFilters = {\n  eventType: null,\n  actorEmail: null,\n  resourceId: null,\n  route: null,\n  createdFrom: null,\n  createdTo: null,\n};\n\nconst POPULATED_FILTERS: PeekAuditFilters = {\n  eventType: \"peek.export\",\n  actorEmail: \"alice@example.com\",\n  resourceId: \"user-9\",\n  route: \"/users/[userId]\",\n  createdFrom: \"2026-04-01\",\n  createdTo: \"2026-04-26\",\n};\n\ndescribe(\"AuditEventsFilterBar\", () => {\n  it(\"empty: form posts to /audit by default with all inputs blank and 'Any peek.*' selected\", () => {\n    render(<AuditEventsFilterBar filters={EMPTY_FILTERS} />);\n\n    const form = screen.getByRole(\"search\", { name: \"Filter audit events\" });\n    expect(form).toHaveAttribute(\"action\", \"/audit\");\n    expect(form).toHaveAttribute(\"method\", \"get\");\n\n    const eventType = screen.getByLabelText(\"Event type\") as HTMLSelectElement;\n    expect(eventType.value).toBe(\"\");\n    const optionValues = Array.from(eventType.options).map((o) => o.value);\n    expect(optionValues).toContain(\"\");\n    for (const value of PEEK_AUDIT_EVENT_TYPES) {\n      expect(optionValues).toContain(value);\n    }\n    // \"Any peek.*\" is the empty-option label so an operator can clear the filter.\n    const emptyOption = Array.from(eventType.options).find((o) => o.value === \"\");\n    expect(emptyOption?.textContent).toContain(\"Any\");\n\n    expect((screen.getByLabelText(\"Actor email\") as HTMLInputElement).value).toBe(\n      \"\",\n    );\n    expect((screen.getByLabelText(\"Resource id\") as HTMLInputElement).value).toBe(\n      \"\",\n    );\n    expect((screen.getByLabelText(\"Route\") as HTMLInputElement).value).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect((screen.getByLabelText(\"Created to\") as HTMLInputElement).value).toBe(\n      \"\",\n    );\n  });\n\n  it(\"populated: pre-fills every field including the event-type select\", () => {\n    render(<AuditEventsFilterBar filters={POPULATED_FILTERS} />);\n\n    expect(\n      (screen.getByLabelText(\"Event type\") as HTMLSelectElement).value,\n    ).toBe(\"peek.export\");\n    expect(\n      (screen.getByLabelText(\"Actor email\") as HTMLInputElement).value,\n    ).toBe(\"alice@example.com\");\n    expect(\n      (screen.getByLabelText(\"Resource id\") as HTMLInputElement).value,\n    ).toBe(\"user-9\");\n    expect((screen.getByLabelText(\"Route\") as HTMLInputElement).value).toBe(\n      \"/users/[userId]\",\n    );\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n  });\n\n  it(\"inputs use the auditFilter* prefix so the URL parser binds back without collisions\", () => {\n    render(<AuditEventsFilterBar filters={EMPTY_FILTERS} />);\n\n    expect(\n      (screen.getByLabelText(\"Event type\") as HTMLSelectElement).name,\n    ).toBe(\"auditFilterEventType\");\n    expect(\n      (screen.getByLabelText(\"Actor email\") as HTMLInputElement).name,\n    ).toBe(\"auditFilterActor\");\n    expect(\n      (screen.getByLabelText(\"Resource id\") as HTMLInputElement).name,\n    ).toBe(\"auditFilterResource\");\n    expect((screen.getByLabelText(\"Route\") as HTMLInputElement).name).toBe(\n      \"auditFilterRoute\",\n    );\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).name,\n    ).toBe(\"auditFilterCreatedFrom\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).name,\n    ).toBe(\"auditFilterCreatedTo\");\n  });\n\n  it(\"populated: ISO timestamps in date filters are truncated to YYYY-MM-DD for the date inputs\", () => {\n    render(\n      <AuditEventsFilterBar\n        filters={{\n          ...EMPTY_FILTERS,\n          createdFrom: \"2026-04-01T10:00:00.000Z\",\n          createdTo: \"2026-04-26T23:59:59.999Z\",\n        }}\n      />,\n    );\n\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n  });\n\n  it(\"custom action overrides the default form target\", () => {\n    render(\n      <AuditEventsFilterBar filters={EMPTY_FILTERS} action=\"/audit?embed=1\" />,\n    );\n    const form = screen.getByRole(\"search\", { name: \"Filter audit events\" });\n    expect(form).toHaveAttribute(\"action\", \"/audit?embed=1\");\n  });\n\n  it(\"does NOT render a hidden short-form `eventType` input — submitting clears stale chip state\", () => {\n    // The form submits the long-form `auditFilterEventType`. If a short-form\n    // chip carried over as a hidden input, it would override the user's\n    // current selection on submit and lock the table to the original drilldown.\n    const { container } = render(\n      <AuditEventsFilterBar\n        filters={{ ...EMPTY_FILTERS, eventType: \"peek.export\" }}\n      />,\n    );\n    expect(container.querySelector(\"input[name='eventType']\")).toBeNull();\n  });\n\n  it(\"eventType: state-transition coverage — every PEEK_AUDIT_EVENT_TYPES value is renderable as a chosen option\", () => {\n    for (const value of PEEK_AUDIT_EVENT_TYPES) {\n      const { unmount } = render(\n        <AuditEventsFilterBar filters={{ ...EMPTY_FILTERS, eventType: value }} />,\n      );\n      expect(\n        (screen.getByLabelText(\"Event type\") as HTMLSelectElement).value,\n      ).toBe(value);\n      unmount();\n    }\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2968,"cache_read_input_tokens":127591,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2968},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"94a07cbb-8d25-425b-954a-4878bb9ef4df","uuid":"dd38e628-5101-4bce-b7d9-ef8e217028ef"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LMGnEPzPMKtwFNw1nCauvo","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/components/__tests__/audit-events-filter-bar.test.tsx"}]},"parent_tool_use_id":null,"session_id":"94a07cbb-8d25-425b-954a-4878bb9ef4df","uuid":"33838840-8f60-4c1c-aeff-a6cd56b25c10","timestamp":"2026-04-26T07:26:10.750Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/audit-events-filter-bar.test.tsx","content":"// Component tests for the FR-11 /audit filter bar.\n//\n// The filter bar is a query-string GET form (no JS), so each test asserts:\n//   - the form posts to /audit via GET;\n//   - each input/select uses its `auditFilter*` name (matches the URL parser);\n//   - the event-type select exposes every allowlisted PeekAuditEventType plus\n//     the \"Any peek.*\" empty option;\n//   - populated filters pre-fill every field;\n//   - ISO timestamps in date filters are truncated to YYYY-MM-DD;\n//   - the custom `action` prop overrides the default form target;\n//   - the form does NOT carry a hidden short-form `eventType` chip (submitting\n//     the form swaps the chip out for the in-form `auditFilterEventType` so\n//     the form is the single source of truth on submit).\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { AuditEventsFilterBar } from \"../audit-events-filter-bar\";\nimport { PEEK_AUDIT_EVENT_TYPES } from \"../../lib/types/peek\";\nimport type { PeekAuditFilters } from \"../../lib/types/peek\";\n\nconst EMPTY_FILTERS: PeekAuditFilters = {\n  eventType: null,\n  actorEmail: null,\n  resourceId: null,\n  route: null,\n  createdFrom: null,\n  createdTo: null,\n};\n\nconst POPULATED_FILTERS: PeekAuditFilters = {\n  eventType: \"peek.export\",\n  actorEmail: \"alice@example.com\",\n  resourceId: \"user-9\",\n  route: \"/users/[userId]\",\n  createdFrom: \"2026-04-01\",\n  createdTo: \"2026-04-26\",\n};\n\ndescribe(\"AuditEventsFilterBar\", () => {\n  it(\"empty: form posts to /audit by default with all inputs blank and 'Any peek.*' selected\", () => {\n    render(<AuditEventsFilterBar filters={EMPTY_FILTERS} />);\n\n    const form = screen.getByRole(\"search\", { name: \"Filter audit events\" });\n    expect(form).toHaveAttribute(\"action\", \"/audit\");\n    expect(form).toHaveAttribute(\"method\", \"get\");\n\n    const eventType = screen.getByLabelText(\"Event type\") as HTMLSelectElement;\n    expect(eventType.value).toBe(\"\");\n    const optionValues = Array.from(eventType.options).map((o) => o.value);\n    expect(optionValues).toContain(\"\");\n    for (const value of PEEK_AUDIT_EVENT_TYPES) {\n      expect(optionValues).toContain(value);\n    }\n    // \"Any peek.*\" is the empty-option label so an operator can clear the filter.\n    const emptyOption = Array.from(eventType.options).find((o) => o.value === \"\");\n    expect(emptyOption?.textContent).toContain(\"Any\");\n\n    expect((screen.getByLabelText(\"Actor email\") as HTMLInputElement).value).toBe(\n      \"\",\n    );\n    expect((screen.getByLabelText(\"Resource id\") as HTMLInputElement).value).toBe(\n      \"\",\n    );\n    expect((screen.getByLabelText(\"Route\") as HTMLInputElement).value).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect((screen.getByLabelText(\"Created to\") as HTMLInputElement).value).toBe(\n      \"\",\n    );\n  });\n\n  it(\"populated: pre-fills every field including the event-type select\", () => {\n    render(<AuditEventsFilterBar filters={POPULATED_FILTERS} />);\n\n    expect(\n      (screen.getByLabelText(\"Event type\") as HTMLSelectElement).value,\n    ).toBe(\"peek.export\");\n    expect(\n      (screen.getByLabelText(\"Actor email\") as HTMLInputElement).value,\n    ).toBe(\"alice@example.com\");\n    expect(\n      (screen.getByLabelText(\"Resource id\") as HTMLInputElement).value,\n    ).toBe(\"user-9\");\n    expect((screen.getByLabelText(\"Route\") as HTMLInputElement).value).toBe(\n      \"/users/[userId]\",\n    );\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n  });\n\n  it(\"inputs use the auditFilter* prefix so the URL parser binds back without collisions\", () => {\n    render(<AuditEventsFilterBar filters={EMPTY_FILTERS} />);\n\n    expect(\n      (screen.getByLabelText(\"Event type\") as HTMLSelectElement).name,\n    ).toBe(\"auditFilterEventType\");\n    expect(\n      (screen.getByLabelText(\"Actor email\") as HTMLInputElement).name,\n    ).toBe(\"auditFilterActor\");\n    expect(\n      (screen.getByLabelText(\"Resource id\") as HTMLInputElement).name,\n    ).toBe(\"auditFilterResource\");\n    expect((screen.getByLabelText(\"Route\") as HTMLInputElement).name).toBe(\n      \"auditFilterRoute\",\n    );\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).name,\n    ).toBe(\"auditFilterCreatedFrom\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).name,\n    ).toBe(\"auditFilterCreatedTo\");\n  });\n\n  it(\"populated: ISO timestamps in date filters are truncated to YYYY-MM-DD for the date inputs\", () => {\n    render(\n      <AuditEventsFilterBar\n        filters={{\n          ...EMPTY_FILTERS,\n          createdFrom: \"2026-04-01T10:00:00.000Z\",\n          createdTo: \"2026-04-26T23:59:59.999Z\",\n        }}\n      />,\n    );\n\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n  });\n\n  it(\"custom action overrides the default form target\", () => {\n    render(\n      <AuditEventsFilterBar filters={EMPTY_FILTERS} action=\"/audit?embed=1\" />,\n    );\n    const form = screen.getByRole(\"search\", { name: \"Filter audit events\" });\n    expect(form).toHaveAttribute(\"action\", \"/audit?embed=1\");\n  });\n\n  it(\"does NOT render a hidden short-form `eventType` input — submitting clears stale chip state\", () => {\n    // The form submits the long-form `auditFilterEventType`. If a short-form\n    // chip carried over as a hidden input, it would override the user's\n    // current selection on submit and lock the table to the original drilldown.\n    const { container } = render(\n      <AuditEventsFilterBar\n        filters={{ ...EMPTY_FILTERS, eventType: \"peek.export\" }}\n      />,\n    );\n    expect(container.querySelector(\"input[name='eventType']\")).toBeNull();\n  });\n\n  it(\"eventType: state-transition coverage — every PEEK_AUDIT_EVENT_TYPES value is renderable as a chosen option\", () => {\n    for (const value of PEEK_AUDIT_EVENT_TYPES) {\n      const { unmount } = render(\n        <AuditEventsFilterBar filters={{ ...EMPTY_FILTERS, eventType: value }} />,\n      );\n      expect(\n        (screen.getByLabelText(\"Event type\") as HTMLSelectElement).value,\n      ).toBe(value);\n      unmount();\n    }\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01GFTBi3FVZXus9F2QgQhgsf","type":"message","role":"assistant","content":[{"type":"text","text":"Now the table component test:"}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3042,"cache_read_input_tokens":130559,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3042},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"94a07cbb-8d25-425b-954a-4878bb9ef4df","uuid":"198f50e0-127c-4ae2-a025-7bee11edb32d"}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01GFTBi3FVZXus9F2QgQhgsf","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011rRj3HUgQcB7TWsKPhC1tY","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/__tests__/audit-events-table.test.tsx","content":"// Component tests for the FR-11 /audit events table.\n//\n// Read-only by spec — `operator_events` is append-only and the admin UI never\n// edits or deletes audit rows. These tests assert there are no edit\n// affordances rendered, every event-type drives the right chip tone, the\n// PEEK_AUDIT_REDACTED sentinel surfaces verbatim at render time (FR-11\n// \"renders verbatim so reviewers can see that a field was redacted, not\n// silently absent\"), and the empty/error states are scoped to the table only\n// so the rest of the page keeps working.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen, within } from \"@testing-library/react\";\nimport {\n  AuditEventsTable,\n  auditEventTone,\n} from \"../audit-events-table\";\nimport {\n  PEEK_AUDIT_EVENT_TYPES,\n  PEEK_AUDIT_REDACTED,\n} from \"../../lib/types/peek\";\nimport type {\n  PeekAuditEvent,\n  PeekAuditEventType,\n  PeekAuditPayload,\n} from \"../../lib/types/peek\";\n\nfunction basePayload(overrides: Partial<PeekAuditPayload> = {}): PeekAuditPayload {\n  return {\n    actorEmail: \"alice@example.com\",\n    route: \"/users/[userId]\",\n    actionId: null,\n    resourceType: \"user\",\n    resourceId: \"user-9\",\n    filterSummary: null,\n    resultCount: null,\n    requestId: null,\n    rejectionReason: null,\n    changes: null,\n    ...overrides,\n  };\n}\n\nconst EVENT_SEARCH: PeekAuditEvent = {\n  id: \"11111111-1111-1111-1111-111111111111\",\n  eventType: \"peek.search\",\n  createdAt: \"2026-04-26T10:00:00.000Z\",\n  payload: basePayload({\n    route: \"/search\",\n    actionId: \"peek.search\",\n    resourceType: null,\n    resourceId: null,\n    filterSummary: \"q=alice\",\n    resultCount: 7,\n  }),\n};\n\nconst EVENT_VIEW_SENSITIVE: PeekAuditEvent = {\n  id: \"22222222-2222-2222-2222-222222222222\",\n  eventType: \"peek.user.view_sensitive\",\n  createdAt: \"2026-04-26T10:01:00.000Z\",\n  payload: basePayload({\n    actorEmail: \"bob@example.com\",\n    actionId: \"peek.user.view\",\n    requestId: \"req-abc\",\n  }),\n};\n\nconst EVENT_EXPORT: PeekAuditEvent = {\n  id: \"33333333-3333-3333-3333-333333333333\",\n  eventType: \"peek.export\",\n  createdAt: \"2026-04-26T10:02:00.000Z\",\n  payload: basePayload({\n    actionId: \"peek.export.referrals\",\n    resourceType: \"referrals\",\n    resourceId: null,\n    filterSummary: \"status=pending\",\n    resultCount: 1234,\n  }),\n};\n\nconst EVENT_ACCESS_DENIED: PeekAuditEvent = {\n  id: \"44444444-4444-4444-4444-444444444444\",\n  eventType: \"peek.access.denied\",\n  createdAt: \"2026-04-26T10:03:00.000Z\",\n  payload: basePayload({\n    actorEmail: \"outsider@example.com\",\n    route: \"/audit\",\n    actionId: null,\n    resourceType: null,\n    resourceId: null,\n    rejectionReason: \"role=business not allowed for /audit\",\n  }),\n};\n\nconst EVENT_CHANGE_APPLIED: PeekAuditEvent = {\n  id: \"55555555-5555-5555-5555-555555555555\",\n  eventType: \"peek.change.applied\",\n  createdAt: \"2026-04-26T10:04:00.000Z\",\n  payload: basePayload({\n    actionId: \"kol_rate.update\",\n    resourceType: \"referral_kol_rate\",\n    resourceId: \"kol-1\",\n    changes: [\n      { field: \"rate_bps\", before: 500, after: 600 },\n      { field: \"set_by\", before: \"alice@example.com\", after: \"alice@example.com\" },\n    ],\n  }),\n};\n\nconst EVENT_CHANGE_REJECTED: PeekAuditEvent = {\n  id: \"66666666-6666-6666-6666-666666666666\",\n  eventType: \"peek.change.rejected\",\n  createdAt: \"2026-04-26T10:05:00.000Z\",\n  payload: basePayload({\n    actionId: \"fraud_flag.status.update\",\n    resourceType: \"fraud_flag\",\n    resourceId: \"flag-7\",\n    rejectionReason: \"invalid transition: open → resolved\",\n  }),\n};\n\ndescribe(\"AuditEventsTable\", () => {\n  it(\"populated: renders all operator columns and one chip per peek.* event type\", () => {\n    render(\n      <AuditEventsTable\n        rows={[\n          EVENT_SEARCH,\n          EVENT_VIEW_SENSITIVE,\n          EVENT_EXPORT,\n          EVENT_ACCESS_DENIED,\n          EVENT_CHANGE_APPLIED,\n          EVENT_CHANGE_REJECTED,\n        ]}\n      />,\n    );\n\n    for (const header of [\n      \"Event type\",\n      \"Created\",\n      \"Actor\",\n      \"Route\",\n      \"Action\",\n      \"Resource\",\n      \"Filter\",\n      \"Result\",\n      \"Notes\",\n      \"ID\",\n    ]) {\n      expect(screen.getByText(header)).toBeInTheDocument();\n    }\n\n    // State-transition coverage: every PeekAuditEventType renders as a chip.\n    for (const eventType of PEEK_AUDIT_EVENT_TYPES) {\n      expect(screen.getByText(eventType)).toBeInTheDocument();\n    }\n  });\n\n  it(\"populated: actor / created / filter / route / resource columns surface payload values verbatim\", () => {\n    render(<AuditEventsTable rows={[EVENT_EXPORT]} />);\n    expect(screen.getByText(\"alice@example.com\")).toBeInTheDocument();\n    expect(screen.getByText(\"2026-04-26T10:02:00.000Z\")).toBeInTheDocument();\n    expect(screen.getByText(\"status=pending\")).toBeInTheDocument();\n    expect(screen.getByText(\"/users/[userId]\")).toBeInTheDocument();\n    expect(screen.getByText(\"referrals\")).toBeInTheDocument();\n    // Result count uses thousands separators per FR-4 integer formatting.\n    expect(screen.getByText(\"1,234\")).toBeInTheDocument();\n  });\n\n  it(\"populated: actorEmail empty string falls back to em-dash so a missing actor never renders as blank\", () => {\n    const eventNoActor: PeekAuditEvent = {\n      ...EVENT_SEARCH,\n      payload: basePayload({ actorEmail: \"\", actionId: \"peek.search\" }),\n    };\n    render(<AuditEventsTable rows={[eventNoActor]} />);\n    // The actor cell renders an em-dash when actorEmail is the empty string\n    // (the rehydrated payload normalises missing actors to \"\" not null).\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThan(0);\n  });\n\n  it(\"populated: rejected change row shows the rejection reason and routes through the negative tone\", () => {\n    render(<AuditEventsTable rows={[EVENT_CHANGE_REJECTED]} />);\n    expect(\n      screen.getByText(/rejected:.*invalid transition/),\n    ).toBeInTheDocument();\n    expect(screen.getByText(\"peek.change.rejected\")).toBeInTheDocument();\n  });\n\n  it(\"populated: applied change row shows the changes count in the notes column\", () => {\n    render(<AuditEventsTable rows={[EVENT_CHANGE_APPLIED]} />);\n    expect(screen.getByText(/changes:.*2/)).toBeInTheDocument();\n  });\n\n  it(\"populated: requestId surfaces in the notes column when present\", () => {\n    render(<AuditEventsTable rows={[EVENT_VIEW_SENSITIVE]} />);\n    expect(screen.getByText(/req:.*req-abc/)).toBeInTheDocument();\n  });\n\n  it(\"redaction at render time: a redacted route / actionId / resourceId / filterSummary surfaces the PEEK_AUDIT_REDACTED sentinel verbatim\", () => {\n    const redacted: PeekAuditEvent = {\n      id: \"redacted-id\",\n      eventType: \"peek.user.view_sensitive\",\n      createdAt: \"2026-04-26T10:06:00.000Z\",\n      payload: basePayload({\n        actorEmail: \"alice@example.com\",\n        route: PEEK_AUDIT_REDACTED,\n        actionId: PEEK_AUDIT_REDACTED,\n        resourceType: PEEK_AUDIT_REDACTED,\n        resourceId: PEEK_AUDIT_REDACTED,\n        filterSummary: PEEK_AUDIT_REDACTED,\n        requestId: PEEK_AUDIT_REDACTED,\n        rejectionReason: PEEK_AUDIT_REDACTED,\n      }),\n    };\n    render(<AuditEventsTable rows={[redacted]} />);\n    // The redacted sentinel must surface in every redacted slot — never\n    // silently absent. The sentinel itself is non-secret and is the FR-11\n    // contract for \"this field was scrubbed\".\n    const redactedCells = screen.getAllByText(PEEK_AUDIT_REDACTED);\n    // Route, action, resourceType, resourceId, filterSummary, requestId,\n    // rejectionReason — seven redacted slots.\n    expect(redactedCells.length).toBeGreaterThanOrEqual(5);\n  });\n\n  it(\"redaction at render time: a non-redacted row keeps the values verbatim and never invents the sentinel\", () => {\n    render(<AuditEventsTable rows={[EVENT_SEARCH]} />);\n    expect(screen.queryByText(PEEK_AUDIT_REDACTED)).toBeNull();\n  });\n\n  it(\"read-only: no edit affordances rendered (no buttons, no editable inputs, no checkboxes)\", () => {\n    // FR-11: operator_events is append-only and the admin UI never edits\n    // or deletes audit rows. The table must render only read-only content.\n    render(\n      <AuditEventsTable\n        rows={[\n          EVENT_SEARCH,\n          EVENT_EXPORT,\n          EVENT_ACCESS_DENIED,\n          EVENT_CHANGE_APPLIED,\n        ]}\n      />,\n    );\n    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n    expect(screen.queryByRole(\"textbox\")).toBeNull();\n    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n  });\n\n  it(\"populated: nullable cells fall back to em-dash instead of rendering empty content\", () => {\n    const sparse: PeekAuditEvent = {\n      id: \"sparse\",\n      eventType: \"peek.search\",\n      createdAt: \"2026-04-26T10:00:00.000Z\",\n      payload: basePayload({\n        actorEmail: \"alice@example.com\",\n        route: null,\n        actionId: null,\n        resourceType: null,\n        resourceId: null,\n        filterSummary: null,\n        resultCount: null,\n        requestId: null,\n        rejectionReason: null,\n        changes: null,\n      }),\n    };\n    const { container } = render(<AuditEventsTable rows={[sparse]} />);\n    const cellTexts = within(container).getAllByText(\"—\");\n    // Route, Action, Resource, Filter, Result, Notes — six em-dash fallbacks.\n    expect(cellTexts.length).toBeGreaterThanOrEqual(5);\n  });\n\n  it(\"empty: renders the operator status block when no rows match\", () => {\n    render(<AuditEventsTable rows={[]} />);\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(/operator events match these filters/i);\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n    render(<AuditEventsTable rows={[]} error=\"connection refused\" />);\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Audit events unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n\n  it(\"error: a non-empty rows array with an error still hides the table — error wins over data\", () => {\n    render(<AuditEventsTable rows={[EVENT_SEARCH]} error=\"timeout\" />);\n    expect(screen.getByRole(\"alert\")).toBeInTheDocument();\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n});\n\ndescribe(\"auditEventTone\", () => {\n  it(\"maps every PeekAuditEventType to a deterministic tone matching the FR-10 attention conventions\", () => {\n    expect(auditEventTone(\"peek.change.applied\")).toBe(\"positive\");\n    expect(auditEventTone(\"peek.change.rejected\")).toBe(\"negative\");\n    expect(auditEventTone(\"peek.access.denied\")).toBe(\"negative\");\n    expect(auditEventTone(\"peek.export\")).toBe(\"warning\");\n    expect(auditEventTone(\"peek.user.view_sensitive\")).toBe(\"info\");\n    expect(auditEventTone(\"peek.search\")).toBe(\"neutral\");\n  });\n\n  it(\"falls back to neutral for an unknown event type\", () => {\n    expect(\n      auditEventTone(\"peek.totally.bogus\" as unknown as PeekAuditEventType),\n    ).toBe(\"neutral\");\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3042,"cache_read_input_tokens":130559,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3042},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"94a07cbb-8d25-425b-954a-4878bb9ef4df","uuid":"5e0ae7ee-cd38-487e-96c4-6d56c88babad"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011rRj3HUgQcB7TWsKPhC1tY","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/components/__tests__/audit-events-table.test.tsx"}]},"parent_tool_use_id":null,"session_id":"94a07cbb-8d25-425b-954a-4878bb9ef4df","uuid":"557e04df-6559-4f83-815d-0ce5c4289b9e","timestamp":"2026-04-26T07:27:00.604Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/audit-events-table.test.tsx","content":"// Component tests for the FR-11 /audit events table.\n//\n// Read-only by spec — `operator_events` is append-only and the admin UI never\n// edits or deletes audit rows. These tests assert there are no edit\n// affordances rendered, every event-type drives the right chip tone, the\n// PEEK_AUDIT_REDACTED sentinel surfaces verbatim at render time (FR-11\n// \"renders verbatim so reviewers can see that a field was redacted, not\n// silently absent\"), and the empty/error states are scoped to the table only\n// so the rest of the page keeps working.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen, within } from \"@testing-library/react\";\nimport {\n  AuditEventsTable,\n  auditEventTone,\n} from \"../audit-events-table\";\nimport {\n  PEEK_AUDIT_EVENT_TYPES,\n  PEEK_AUDIT_REDACTED,\n} from \"../../lib/types/peek\";\nimport type {\n  PeekAuditEvent,\n  PeekAuditEventType,\n  PeekAuditPayload,\n} from \"../../lib/types/peek\";\n\nfunction basePayload(overrides: Partial<PeekAuditPayload> = {}): PeekAuditPayload {\n  return {\n    actorEmail: \"alice@example.com\",\n    route: \"/users/[userId]\",\n    actionId: null,\n    resourceType: \"user\",\n    resourceId: \"user-9\",\n    filterSummary: null,\n    resultCount: null,\n    requestId: null,\n    rejectionReason: null,\n    changes: null,\n    ...overrides,\n  };\n}\n\nconst EVENT_SEARCH: PeekAuditEvent = {\n  id: \"11111111-1111-1111-1111-111111111111\",\n  eventType: \"peek.search\",\n  createdAt: \"2026-04-26T10:00:00.000Z\",\n  payload: basePayload({\n    route: \"/search\",\n    actionId: \"peek.search\",\n    resourceType: null,\n    resourceId: null,\n    filterSummary: \"q=alice\",\n    resultCount: 7,\n  }),\n};\n\nconst EVENT_VIEW_SENSITIVE: PeekAuditEvent = {\n  id: \"22222222-2222-2222-2222-222222222222\",\n  eventType: \"peek.user.view_sensitive\",\n  createdAt: \"2026-04-26T10:01:00.000Z\",\n  payload: basePayload({\n    actorEmail: \"bob@example.com\",\n    actionId: \"peek.user.view\",\n    requestId: \"req-abc\",\n  }),\n};\n\nconst EVENT_EXPORT: PeekAuditEvent = {\n  id: \"33333333-3333-3333-3333-333333333333\",\n  eventType: \"peek.export\",\n  createdAt: \"2026-04-26T10:02:00.000Z\",\n  payload: basePayload({\n    actionId: \"peek.export.referrals\",\n    resourceType: \"referrals\",\n    resourceId: null,\n    filterSummary: \"status=pending\",\n    resultCount: 1234,\n  }),\n};\n\nconst EVENT_ACCESS_DENIED: PeekAuditEvent = {\n  id: \"44444444-4444-4444-4444-444444444444\",\n  eventType: \"peek.access.denied\",\n  createdAt: \"2026-04-26T10:03:00.000Z\",\n  payload: basePayload({\n    actorEmail: \"outsider@example.com\",\n    route: \"/audit\",\n    actionId: null,\n    resourceType: null,\n    resourceId: null,\n    rejectionReason: \"role=business not allowed for /audit\",\n  }),\n};\n\nconst EVENT_CHANGE_APPLIED: PeekAuditEvent = {\n  id: \"55555555-5555-5555-5555-555555555555\",\n  eventType: \"peek.change.applied\",\n  createdAt: \"2026-04-26T10:04:00.000Z\",\n  payload: basePayload({\n    actionId: \"kol_rate.update\",\n    resourceType: \"referral_kol_rate\",\n    resourceId: \"kol-1\",\n    changes: [\n      { field: \"rate_bps\", before: 500, after: 600 },\n      { field: \"set_by\", before: \"alice@example.com\", after: \"alice@example.com\" },\n    ],\n  }),\n};\n\nconst EVENT_CHANGE_REJECTED: PeekAuditEvent = {\n  id: \"66666666-6666-6666-6666-666666666666\",\n  eventType: \"peek.change.rejected\",\n  createdAt: \"2026-04-26T10:05:00.000Z\",\n  payload: basePayload({\n    actionId: \"fraud_flag.status.update\",\n    resourceType: \"fraud_flag\",\n    resourceId: \"flag-7\",\n    rejectionReason: \"invalid transition: open → resolved\",\n  }),\n};\n\ndescribe(\"AuditEventsTable\", () => {\n  it(\"populated: renders all operator columns and one chip per peek.* event type\", () => {\n    render(\n      <AuditEventsTable\n        rows={[\n          EVENT_SEARCH,\n          EVENT_VIEW_SENSITIVE,\n          EVENT_EXPORT,\n          EVENT_ACCESS_DENIED,\n          EVENT_CHANGE_APPLIED,\n          EVENT_CHANGE_REJECTED,\n        ]}\n      />,\n    );\n\n    for (const header of [\n      \"Event type\",\n      \"Created\",\n      \"Actor\",\n      \"Route\",\n      \"Action\",\n      \"Resource\",\n      \"Filter\",\n      \"Result\",\n      \"Notes\",\n      \"ID\",\n    ]) {\n      expect(screen.getByText(header)).toBeInTheDocument();\n    }\n\n    // State-transition coverage: every PeekAuditEventType renders as a chip.\n    for (const eventType of PEEK_AUDIT_EVENT_TYPES) {\n      expect(screen.getByText(eventType)).toBeInTheDocument();\n    }\n  });\n\n  it(\"populated: actor / created / filter / route / resource columns surface payload values verbatim\", () => {\n    render(<AuditEventsTable rows={[EVENT_EXPORT]} />);\n    expect(screen.getByText(\"alice@example.com\")).toBeInTheDocument();\n    expect(screen.getByText(\"2026-04-26T10:02:00.000Z\")).toBeInTheDocument();\n    expect(screen.getByText(\"status=pending\")).toBeInTheDocument();\n    expect(screen.getByText(\"/users/[userId]\")).toBeInTheDocument();\n    expect(screen.getByText(\"referrals\")).toBeInTheDocument();\n    // Result count uses thousands separators per FR-4 integer formatting.\n    expect(screen.getByText(\"1,234\")).toBeInTheDocument();\n  });\n\n  it(\"populated: actorEmail empty string falls back to em-dash so a missing actor never renders as blank\", () => {\n    const eventNoActor: PeekAuditEvent = {\n      ...EVENT_SEARCH,\n      payload: basePayload({ actorEmail: \"\", actionId: \"peek.search\" }),\n    };\n    render(<AuditEventsTable rows={[eventNoActor]} />);\n    // The actor cell renders an em-dash when actorEmail is the empty string\n    // (the rehydrated payload normalises missing actors to \"\" not null).\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThan(0);\n  });\n\n  it(\"populated: rejected change row shows the rejection reason and routes through the negative tone\", () => {\n    render(<AuditEventsTable rows={[EVENT_CHANGE_REJECTED]} />);\n    expect(\n      screen.getByText(/rejected:.*invalid transition/),\n    ).toBeInTheDocument();\n    expect(screen.getByText(\"peek.change.rejected\")).toBeInTheDocument();\n  });\n\n  it(\"populated: applied change row shows the changes count in the notes column\", () => {\n    render(<AuditEventsTable rows={[EVENT_CHANGE_APPLIED]} />);\n    expect(screen.getByText(/changes:.*2/)).toBeInTheDocument();\n  });\n\n  it(\"populated: requestId surfaces in the notes column when present\", () => {\n    render(<AuditEventsTable rows={[EVENT_VIEW_SENSITIVE]} />);\n    expect(screen.getByText(/req:.*req-abc/)).toBeInTheDocument();\n  });\n\n  it(\"redaction at render time: a redacted route / actionId / resourceId / filterSummary surfaces the PEEK_AUDIT_REDACTED sentinel verbatim\", () => {\n    const redacted: PeekAuditEvent = {\n      id: \"redacted-id\",\n      eventType: \"peek.user.view_sensitive\",\n      createdAt: \"2026-04-26T10:06:00.000Z\",\n      payload: basePayload({\n        actorEmail: \"alice@example.com\",\n        route: PEEK_AUDIT_REDACTED,\n        actionId: PEEK_AUDIT_REDACTED,\n        resourceType: PEEK_AUDIT_REDACTED,\n        resourceId: PEEK_AUDIT_REDACTED,\n        filterSummary: PEEK_AUDIT_REDACTED,\n        requestId: PEEK_AUDIT_REDACTED,\n        rejectionReason: PEEK_AUDIT_REDACTED,\n      }),\n    };\n    render(<AuditEventsTable rows={[redacted]} />);\n    // The redacted sentinel must surface in every redacted slot — never\n    // silently absent. The sentinel itself is non-secret and is the FR-11\n    // contract for \"this field was scrubbed\".\n    const redactedCells = screen.getAllByText(PEEK_AUDIT_REDACTED);\n    // Route, action, resourceType, resourceId, filterSummary, requestId,\n    // rejectionReason — seven redacted slots.\n    expect(redactedCells.length).toBeGreaterThanOrEqual(5);\n  });\n\n  it(\"redaction at render time: a non-redacted row keeps the values verbatim and never invents the sentinel\", () => {\n    render(<AuditEventsTable rows={[EVENT_SEARCH]} />);\n    expect(screen.queryByText(PEEK_AUDIT_REDACTED)).toBeNull();\n  });\n\n  it(\"read-only: no edit affordances rendered (no buttons, no editable inputs, no checkboxes)\", () => {\n    // FR-11: operator_events is append-only and the admin UI never edits\n    // or deletes audit rows. The table must render only read-only content.\n    render(\n      <AuditEventsTable\n        rows={[\n          EVENT_SEARCH,\n          EVENT_EXPORT,\n          EVENT_ACCESS_DENIED,\n          EVENT_CHANGE_APPLIED,\n        ]}\n      />,\n    );\n    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n    expect(screen.queryByRole(\"textbox\")).toBeNull();\n    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n  });\n\n  it(\"populated: nullable cells fall back to em-dash instead of rendering empty content\", () => {\n    const sparse: PeekAuditEvent = {\n      id: \"sparse\",\n      eventType: \"peek.search\",\n      createdAt: \"2026-04-26T10:00:00.000Z\",\n      payload: basePayload({\n        actorEmail: \"alice@example.com\",\n        route: null,\n        actionId: null,\n        resourceType: null,\n        resourceId: null,\n        filterSummary: null,\n        resultCount: null,\n        requestId: null,\n        rejectionReason: null,\n        changes: null,\n      }),\n    };\n    const { container } = render(<AuditEventsTable rows={[sparse]} />);\n    const cellTexts = within(container).getAllByText(\"—\");\n    // Route, Action, Resource, Filter, Result, Notes — six em-dash fallbacks.\n    expect(cellTexts.length).toBeGreaterThanOrEqual(5);\n  });\n\n  it(\"empty: renders the operator status block when no rows match\", () => {\n    render(<AuditEventsTable rows={[]} />);\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(/operator events match these filters/i);\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n    render(<AuditEventsTable rows={[]} error=\"connection refused\" />);\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Audit events unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n\n  it(\"error: a non-empty rows array with an error still hides the table — error wins over data\", () => {\n    render(<AuditEventsTable rows={[EVENT_SEARCH]} error=\"timeout\" />);\n    expect(screen.getByRole(\"alert\")).toBeInTheDocument();\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n});\n\ndescribe(\"auditEventTone\", () => {\n  it(\"maps every PeekAuditEventType to a deterministic tone matching the FR-10 attention conventions\", () => {\n    expect(auditEventTone(\"peek.change.applied\")).toBe(\"positive\");\n    expect(auditEventTone(\"peek.change.rejected\")).toBe(\"negative\");\n    expect(auditEventTone(\"peek.access.denied\")).toBe(\"negative\");\n    expect(auditEventTone(\"peek.export\")).toBe(\"warning\");\n    expect(auditEventTone(\"peek.user.view_sensitive\")).toBe(\"info\");\n    expect(auditEventTone(\"peek.search\")).toBe(\"neutral\");\n  });\n\n  it(\"falls back to neutral for an unknown event type\", () => {\n    expect(\n      auditEventTone(\"peek.totally.bogus\" as unknown as PeekAuditEventType),\n    ).toBe(\"neutral\");\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01BbFzWzpqBg78RFPdPBAfXW","type":"message","role":"assistant","content":[{"type":"text","text":"Now the query test:"}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4931,"cache_read_input_tokens":133601,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4931},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"94a07cbb-8d25-425b-954a-4878bb9ef4df","uuid":"a09544ac-3e6b-4877-8ff0-a282f431892d"}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01BbFzWzpqBg78RFPdPBAfXW","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_012sAn6u9YrP7DJ4Vr37RZ11","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-audit-events.test.ts","content":"// Query tests for the FR-11 audit-log admin reads (`get-audit-events.ts`).\n//\n// Backs `/audit`. The spec line driving these tests is:\n// \"/audit tests for role gating, filters, sensitive payload redaction at\n// render time, empty/error\".\n//\n// Role gating is enforced at the page (via `isRouteAllowedForRole(\"/audit\",\n// role)`) and is covered by the access-policy tests. These tests focus on the\n// data layer:\n//   - state-transition coverage: every PeekAuditEventType filters verbatim;\n//   - bounded SQL (limit clamps);\n//   - filter binding into the right slot of the (`null` ? \"\" : value) toggle;\n//   - actor-email case-insensitive match;\n//   - secret redaction defensively re-applied on read so a row inserted by\n//     some path that bypassed the writer still cannot leak;\n//   - empty / load-error states.\n//\n// Mirrors the SQL-mock pattern used in `get-event-queue.test.ts`,\n// `get-points-and-crates.test.ts`, and `get-rewards.test.ts`.\n\nimport { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_AUDIT_DEFAULT_LIMIT,\n  PEEK_AUDIT_MAX_LIMIT,\n  PEEK_AUDIT_OVERVIEW_WINDOW_HOURS,\n  getAuditOverview,\n  listAuditEvents,\n} from \"../get-audit-events\";\nimport {\n  PEEK_AUDIT_EVENT_TYPES,\n  PEEK_AUDIT_REDACTED,\n} from \"../../../../lib/types/peek\";\nimport type { PeekAuditEventType } from \"../../../../lib/types/peek\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\nfunction expectReadOnly(call: SqlCall) {\n  expect(call.text).not.toMatch(/\\binsert\\s+into\\b/i);\n  expect(call.text).not.toMatch(/\\bupdate\\s+\\w/i);\n  expect(call.text).not.toMatch(/\\bdelete\\s+from\\b/i);\n  expect(call.text).toMatch(/\\bselect\\b/i);\n}\n\nfunction basePayload(overrides: Record<string, unknown> = {}): Record<string, unknown> {\n  return {\n    actorEmail: \"alice@example.com\",\n    route: \"/users/[userId]\",\n    actionId: null,\n    resourceType: \"user\",\n    resourceId: \"user-9\",\n    filterSummary: null,\n    resultCount: null,\n    requestId: null,\n    rejectionReason: null,\n    changes: null,\n    ...overrides,\n  };\n}\n\ndescribe(\"listAuditEvents\", () => {\n  it(\"default: clamps to PEEK_AUDIT_DEFAULT_LIMIT and reads from operator_events with the right column projection\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expectReadOnly(call);\n    expect(call.text).toMatch(/from operator_events oe/i);\n    expect(call.text).toMatch(/oe\\.event_type/);\n    expect(call.text).toMatch(/oe\\.created_at/);\n    expect(call.text).toMatch(/oe\\.payload/);\n    expect(call.text).toMatch(\n      /order by oe\\.created_at desc, oe\\.id desc/i,\n    );\n    expect(call.values).toContain(PEEK_AUDIT_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({ sql: mock.sql, limit: PEEK_AUDIT_MAX_LIMIT + 100 });\n    expect(mock.calls[0].values).toContain(PEEK_AUDIT_MAX_LIMIT);\n  });\n\n  it(\"non-positive limit clamps to 1\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({ sql: mock.sql, limit: 0 });\n    expect(mock.calls[0].values).toContain(1);\n  });\n\n  it(\"non-finite limit falls back to the default\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({ sql: mock.sql, limit: Number.NaN });\n    expect(mock.calls[0].values).toContain(PEEK_AUDIT_DEFAULT_LIMIT);\n  });\n\n  it(\"filters: empty filters bind null sentinels so every where-clause toggle skips the predicate\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({ sql: mock.sql, filters: {} });\n\n    // The query has 6 togglable predicates (eventType / actorEmail /\n    // resourceId / route / createdFrom / createdTo). Each predicate uses\n    // (${X === null} or oe.<col> = ${X ?? \"\"}); an \"all-null\" input binds 6\n    // `true` sentinels — plus the `eventType !== null` toggle that activates\n    // the broad `peek.%` fallback (so 7 boolean sentinels total).\n    const trueBinds = mock.calls[0].values.filter((v) => v === true).length;\n    expect(trueBinds).toBeGreaterThanOrEqual(6);\n    // The peek.% fallback fires when no eventType is bound.\n    expect(mock.calls[0].text).toMatch(/like 'peek\\.%'/);\n  });\n\n  it(\"filters: state-transition coverage — every PeekAuditEventType binds verbatim\", async () => {\n    for (const eventType of PEEK_AUDIT_EVENT_TYPES) {\n      const mock = createSqlMock([[]]);\n      await listAuditEvents({ sql: mock.sql, filters: { eventType } });\n      expect(mock.calls[0].values).toContain(eventType);\n    }\n  });\n\n  it(\"filters: eventType='peek.export' disables the broad peek.% predicate (no false-positive matches)\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({\n      sql: mock.sql,\n      filters: { eventType: \"peek.export\" },\n    });\n    const values = mock.calls[0].values;\n    expect(values).toContain(\"peek.export\");\n    // Bound `false` for the peek.% fallback toggle when an explicit eventType\n    // is set — confirms the predicate is skipped (no double-match risk).\n    expect(values).toContain(false);\n  });\n\n  it(\"filters: actor email is normalised to lowercase before binding so `Alice@Example.COM` matches `alice@example.com`\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({\n      sql: mock.sql,\n      filters: { actorEmail: \"Alice@Example.COM\" },\n    });\n    expect(mock.calls[0].text).toMatch(/lower\\(oe\\.payload->>'actorEmail'\\)/);\n    expect(mock.calls[0].values).toContain(\"alice@example.com\");\n    // The original mixed-case value never reaches the bound parameters.\n    expect(mock.calls[0].values).not.toContain(\"Alice@Example.COM\");\n  });\n\n  it(\"filters: resourceId binds verbatim against payload->>'resourceId'\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({\n      sql: mock.sql,\n      filters: { resourceId: \"user-9\" },\n    });\n    expect(mock.calls[0].text).toMatch(/oe\\.payload->>'resourceId' = /);\n    expect(mock.calls[0].values).toContain(\"user-9\");\n  });\n\n  it(\"filters: route binds verbatim against payload->>'route'\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({\n      sql: mock.sql,\n      filters: { route: \"/users/[userId]\" },\n    });\n    expect(mock.calls[0].text).toMatch(/oe\\.payload->>'route' = /);\n    expect(mock.calls[0].values).toContain(\"/users/[userId]\");\n  });\n\n  it(\"filters: createdFrom and createdTo cast through ::timestamptz so half-open windows stay tz-correct\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({\n      sql: mock.sql,\n      filters: {\n        createdFrom: \"2026-04-01T00:00:00.000Z\",\n        createdTo: \"2026-04-26T00:00:00.000Z\",\n      },\n    });\n    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n    expect(mock.calls[0].values).toContain(\"2026-04-01T00:00:00.000Z\");\n    expect(mock.calls[0].values).toContain(\"2026-04-26T00:00:00.000Z\");\n  });\n\n  it(\"filters: every supported filter (eventType, actorEmail, resourceId, route, createdFrom, createdTo) flows into the bound values\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({\n      sql: mock.sql,\n      filters: {\n        eventType: \"peek.export\",\n        actorEmail: \"alice@example.com\",\n        resourceId: \"user-9\",\n        route: \"/users/[userId]\",\n        createdFrom: \"2026-04-01T00:00:00.000Z\",\n        createdTo: \"2026-04-26T00:00:00.000Z\",\n      },\n    });\n    const values = mock.calls[0].values;\n    expect(values).toContain(\"peek.export\");\n    expect(values).toContain(\"alice@example.com\");\n    expect(values).toContain(\"user-9\");\n    expect(values).toContain(\"/users/[userId]\");\n    expect(values).toContain(\"2026-04-01T00:00:00.000Z\");\n    expect(values).toContain(\"2026-04-26T00:00:00.000Z\");\n  });\n\n  it(\"filters: whitespace-only filter values normalise to null (toggle stays in pass-through mode)\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({\n      sql: mock.sql,\n      filters: {\n        eventType: \"  \" as unknown as PeekAuditEventType,\n        actorEmail: \"  \",\n        resourceId: \"   \",\n        route: \"  \",\n        createdFrom: \"  \",\n        createdTo: \"  \",\n      },\n    });\n    // None of the whitespace strings appear in the bound values.\n    expect(mock.calls[0].values).not.toContain(\"  \");\n    expect(mock.calls[0].values).not.toContain(\"   \");\n  });\n\n  it(\"filters: an unknown eventType value silently falls back to the broad `peek.%` predicate (a stale URL chip cannot drop result count to zero)\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({\n      sql: mock.sql,\n      filters: {\n        eventType: \"peek.totally.bogus\" as unknown as PeekAuditEventType,\n      },\n    });\n    // The peek.% fallback fires.\n    expect(mock.calls[0].text).toMatch(/like 'peek\\.%'/);\n    // The bogus value is dropped, never bound.\n    expect(mock.calls[0].values).not.toContain(\"peek.totally.bogus\");\n  });\n\n  it(\"populated: row mapping projects the audit columns and recovers a typed PeekAuditEvent\", async () => {\n    const row = {\n      id: \"11111111-1111-1111-1111-111111111111\",\n      eventType: \"peek.export\",\n      createdAt: \"2026-04-26T10:00:00.000Z\",\n      payload: basePayload({\n        actorEmail: \"alice@example.com\",\n        route: \"/growth/referrals\",\n        actionId: \"peek.export.referrals\",\n        filterSummary: \"status=pending\",\n        resultCount: 42,\n        requestId: \"req-1\",\n      }),\n    };\n    const mock = createSqlMock([[row]]);\n\n    const rows = await listAuditEvents({ sql: mock.sql });\n    expect(rows).toHaveLength(1);\n    expect(rows[0].id).toBe(\"11111111-1111-1111-1111-111111111111\");\n    expect(rows[0].eventType).toBe(\"peek.export\");\n    expect(rows[0].createdAt).toBe(\"2026-04-26T10:00:00.000Z\");\n    expect(rows[0].payload.actorEmail).toBe(\"alice@example.com\");\n    expect(rows[0].payload.route).toBe(\"/growth/referrals\");\n    expect(rows[0].payload.actionId).toBe(\"peek.export.referrals\");\n    expect(rows[0].payload.filterSummary).toBe(\"status=pending\");\n    expect(rows[0].payload.resultCount).toBe(42);\n    expect(rows[0].payload.requestId).toBe(\"req-1\");\n  });\n\n  it(\"populated: rows whose event_type is not in PEEK_AUDIT_EVENT_TYPES are dropped (defensive — the SQL filter restricts to peek.* but a bypass insert could slip)\", async () => {\n    const row = {\n      id: \"abc\",\n      eventType: \"system.something\",\n      createdAt: \"2026-04-26T10:00:00.000Z\",\n      payload: basePayload(),\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listAuditEvents({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"populated: payload changes array round-trips with the original field/before/after triples\", async () => {\n    const row = {\n      id: \"abc\",\n      eventType: \"peek.change.applied\",\n      createdAt: \"2026-04-26T10:00:00.000Z\",\n      payload: basePayload({\n        actionId: \"kol_rate.update\",\n        changes: [\n          { field: \"rate_bps\", before: 500, after: 600 },\n        ],\n      }),\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listAuditEvents({ sql: mock.sql });\n    expect(rows[0].payload.changes).toHaveLength(1);\n    expect(rows[0].payload.changes?.[0].field).toBe(\"rate_bps\");\n    expect(rows[0].payload.changes?.[0].before).toBe(500);\n    expect(rows[0].payload.changes?.[0].after).toBe(600);\n  });\n\n  it(\"populated: changes that are not array-like normalise to null (defensive shape coercion)\", async () => {\n    const row = {\n      id: \"abc\",\n      eventType: \"peek.change.applied\",\n      createdAt: \"2026-04-26T10:00:00.000Z\",\n      payload: basePayload({ changes: \"not-an-array\" }),\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listAuditEvents({ sql: mock.sql });\n    expect(rows[0].payload.changes).toBeNull();\n  });\n\n  it(\"redaction defensively re-applied on read: a route that looks like a JWT round-trips as PEEK_AUDIT_REDACTED (the writer should have caught this; the read layer is the second line of defence)\", async () => {\n    const jwt =\n      \"eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ1c2VyLTkifQ.signature_segment\";\n    const row = {\n      id: \"abc\",\n      eventType: \"peek.search\",\n      createdAt: \"2026-04-26T10:00:00.000Z\",\n      payload: basePayload({ route: jwt }),\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listAuditEvents({ sql: mock.sql });\n    expect(rows[0].payload.route).toBe(PEEK_AUDIT_REDACTED);\n    // The original token never reaches the surface.\n    expect(rows[0].payload.route).not.toContain(\"eyJ\");\n  });\n\n  it(\"redaction defensively re-applied on read: a rejection reason containing a Postgres URL is replaced with the sentinel\", async () => {\n    const url = \"postgres://user:secret@host:5432/db\";\n    const row = {\n      id: \"abc\",\n      eventType: \"peek.change.rejected\",\n      createdAt: \"2026-04-26T10:00:00.000Z\",\n      payload: basePayload({ rejectionReason: `fatal: ${url} unreachable` }),\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listAuditEvents({ sql: mock.sql });\n    expect(rows[0].payload.rejectionReason).toBe(PEEK_AUDIT_REDACTED);\n    expect(rows[0].payload.rejectionReason).not.toContain(\"secret\");\n  });\n\n  it(\"redaction defensively re-applied on read: every nullable string slot is run through the redactor\", async () => {\n    const jwt =\n      \"eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ1c2VyLTkifQ.signature_segment\";\n    const row = {\n      id: \"abc\",\n      eventType: \"peek.user.view_sensitive\",\n      createdAt: \"2026-04-26T10:00:00.000Z\",\n      payload: basePayload({\n        route: jwt,\n        actionId: jwt,\n        resourceType: jwt,\n        resourceId: jwt,\n        filterSummary: jwt,\n        requestId: jwt,\n        rejectionReason: jwt,\n      }),\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listAuditEvents({ sql: mock.sql });\n    const p = rows[0].payload;\n    expect(p.route).toBe(PEEK_AUDIT_REDACTED);\n    expect(p.actionId).toBe(PEEK_AUDIT_REDACTED);\n    expect(p.resourceType).toBe(PEEK_AUDIT_REDACTED);\n    expect(p.resourceId).toBe(PEEK_AUDIT_REDACTED);\n    expect(p.filterSummary).toBe(PEEK_AUDIT_REDACTED);\n    expect(p.requestId).toBe(PEEK_AUDIT_REDACTED);\n    expect(p.rejectionReason).toBe(PEEK_AUDIT_REDACTED);\n  });\n\n  it(\"populated: a row with a non-object payload normalises to a default shape so the renderer cannot crash on a malformed insert\", async () => {\n    const row = {\n      id: \"abc\",\n      eventType: \"peek.search\",\n      createdAt: \"2026-04-26T10:00:00.000Z\",\n      payload: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listAuditEvents({ sql: mock.sql });\n    expect(rows[0].payload.actorEmail).toBe(\"\");\n    expect(rows[0].payload.route).toBeNull();\n    expect(rows[0].payload.changes).toBeNull();\n  });\n\n  it(\"empty: an empty result set returns []\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listAuditEvents({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"connection refused\")]);\n    await expect(listAuditEvents({ sql: mock.sql })).rejects.toThrowError(\n      \"connection refused\",\n    );\n  });\n});\n\ndescribe(\"getAuditOverview\", () => {\n  it(\"returns the FR-4 metric strip with the canonical metric ids and drilldown hrefs\", async () => {\n    const mock = createSqlMock([\n      [\n        { eventType: \"peek.export\", value: 3 },\n        { eventType: \"peek.access.denied\", value: 1 },\n        { eventType: \"peek.change.applied\", value: 5 },\n        { eventType: \"peek.change.rejected\", value: 2 },\n        { eventType: \"peek.search\", value: 9 },\n        { eventType: \"peek.user.view_sensitive\", value: 4 },\n      ],\n    ]);\n\n    const overview = await getAuditOverview({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    expectReadOnly(mock.calls[0]);\n    expect(mock.calls[0].text).toMatch(/like 'peek\\.%'/);\n    expect(mock.calls[0].text).toMatch(/group by oe\\.event_type/i);\n\n    const metricIds = overview.metrics.map((m) => m.id);\n    expect(metricIds).toEqual([\n      \"audit.total_24h\",\n      \"audit.exports_24h\",\n      \"audit.access_denied_24h\",\n      \"audit.changes_applied_24h\",\n      \"audit.changes_rejected_24h\",\n    ]);\n\n    // Total is the sum of all six event-type counts.\n    expect(overview.metrics[0].value).toBe(3 + 1 + 5 + 2 + 9 + 4);\n    expect(overview.metrics[1].value).toBe(3); // exports\n    expect(overview.metrics[2].value).toBe(1); // access denied\n    expect(overview.metrics[3].value).toBe(5); // changes applied\n    expect(overview.metrics[4].value).toBe(2); // changes rejected\n\n    // Each metric carries a definition + source per FR-4.\n    for (const metric of overview.metrics) {\n      expect(metric.source).toBe(\"operator_events\");\n      expect(metric.definition.length).toBeGreaterThan(0);\n      expect(metric.freshness).toBe(\"live\");\n    }\n\n    // Drilldowns route back into /audit with the matching short-form chip.\n    expect(overview.metrics[0].drilldownHref).toBe(\"/audit\");\n    expect(overview.metrics[1].drilldownHref).toBe(\"/audit?eventType=peek.export\");\n    expect(overview.metrics[2].drilldownHref).toBe(\n      \"/audit?eventType=peek.access.denied\",\n    );\n    expect(overview.metrics[3].drilldownHref).toBe(\n      \"/audit?eventType=peek.change.applied\",\n    );\n    expect(overview.metrics[4].drilldownHref).toBe(\n      \"/audit?eventType=peek.change.rejected\",\n    );\n  });\n\n  it(\"returns an event-type breakdown covering EVERY PeekAuditEventType — sparse types stay in the list with count=0 (FR-4 sparse-data discipline)\", async () => {\n    // The query returns only two event types; the remaining four must still\n    // appear in the breakdown with count=0 so the rendered card never silently\n    // drops a measured-zero row.\n    const mock = createSqlMock([\n      [\n        { eventType: \"peek.export\", value: 2 },\n        { eventType: \"peek.search\", value: 1 },\n      ],\n    ]);\n\n    const overview = await getAuditOverview({ sql: mock.sql });\n    expect(overview.eventTypeCounts).toHaveLength(PEEK_AUDIT_EVENT_TYPES.length);\n\n    const byEvent = new Map(\n      overview.eventTypeCounts.map((row) => [row.eventType, row.count]),\n    );\n    expect(byEvent.get(\"peek.export\")).toBe(2);\n    expect(byEvent.get(\"peek.search\")).toBe(1);\n    expect(byEvent.get(\"peek.access.denied\")).toBe(0);\n    expect(byEvent.get(\"peek.user.view_sensitive\")).toBe(0);\n    expect(byEvent.get(\"peek.change.applied\")).toBe(0);\n    expect(byEvent.get(\"peek.change.rejected\")).toBe(0);\n  });\n\n  it(\"empty: zero rows surfaces zero counts everywhere — no broken sparse render\", async () => {\n    const mock = createSqlMock([[]]);\n    const overview = await getAuditOverview({ sql: mock.sql });\n    for (const metric of overview.metrics) {\n      expect(metric.value).toBe(0);\n      expect(metric.valueDisplay).toBe(\"0\");\n    }\n    for (const row of overview.eventTypeCounts) {\n      expect(row.count).toBe(0);\n    }\n  });\n\n  it(\"window: defaults to the last 24h and binds the rolling start instant as ISO timestamptz\", async () => {\n    const now = new Date(\"2026-04-26T12:00:00.000Z\");\n    const mock = createSqlMock([[]]);\n    await getAuditOverview({ sql: mock.sql, now });\n\n    const values = mock.calls[0].values;\n    const expectedStart = new Date(\n      now.getTime() - PEEK_AUDIT_OVERVIEW_WINDOW_HOURS * 60 * 60 * 1000,\n    ).toISOString();\n    expect(values).toContain(expectedStart);\n    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n  });\n\n  it(\"window: a custom windowHours value flows into the bound start instant and the metric label\", async () => {\n    const now = new Date(\"2026-04-26T12:00:00.000Z\");\n    const mock = createSqlMock([[]]);\n    const overview = await getAuditOverview({\n      sql: mock.sql,\n      now,\n      windowHours: 48,\n    });\n\n    const expectedStart = new Date(\n      now.getTime() - 48 * 60 * 60 * 1000,\n    ).toISOString();\n    expect(mock.calls[0].values).toContain(expectedStart);\n\n    for (const metric of overview.metrics) {\n      expect(metric.windowLabel).toContain(\"48\");\n    }\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"connection refused\")]);\n    await expect(getAuditOverview({ sql: mock.sql })).rejects.toThrowError(\n      \"connection refused\",\n    );\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4931,"cache_read_input_tokens":133601,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4931},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"94a07cbb-8d25-425b-954a-4878bb9ef4df","uuid":"86275ecc-9136-47f2-af3a-0bc78cfe391a"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012sAn6u9YrP7DJ4Vr37RZ11","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-audit-events.test.ts"}]},"parent_tool_use_id":null,"session_id":"94a07cbb-8d25-425b-954a-4878bb9ef4df","uuid":"dfb647f9-a97a-446f-b862-fbfbce732cd2","timestamp":"2026-04-26T07:28:34.647Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-audit-events.test.ts","content":"// Query tests for the FR-11 audit-log admin reads (`get-audit-events.ts`).\n//\n// Backs `/audit`. The spec line driving these tests is:\n// \"/audit tests for role gating, filters, sensitive payload redaction at\n// render time, empty/error\".\n//\n// Role gating is enforced at the page (via `isRouteAllowedForRole(\"/audit\",\n// role)`) and is covered by the access-policy tests. These tests focus on the\n// data layer:\n//   - state-transition coverage: every PeekAuditEventType filters verbatim;\n//   - bounded SQL (limit clamps);\n//   - filter binding into the right slot of the (`null` ? \"\" : value) toggle;\n//   - actor-email case-insensitive match;\n//   - secret redaction defensively re-applied on read so a row inserted by\n//     some path that bypassed the writer still cannot leak;\n//   - empty / load-error states.\n//\n// Mirrors the SQL-mock pattern used in `get-event-queue.test.ts`,\n// `get-points-and-crates.test.ts`, and `get-rewards.test.ts`.\n\nimport { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_AUDIT_DEFAULT_LIMIT,\n  PEEK_AUDIT_MAX_LIMIT,\n  PEEK_AUDIT_OVERVIEW_WINDOW_HOURS,\n  getAuditOverview,\n  listAuditEvents,\n} from \"../get-audit-events\";\nimport {\n  PEEK_AUDIT_EVENT_TYPES,\n  PEEK_AUDIT_REDACTED,\n} from \"../../../../lib/types/peek\";\nimport type { PeekAuditEventType } from \"../../../../lib/types/peek\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\nfunction expectReadOnly(call: SqlCall) {\n  expect(call.text).not.toMatch(/\\binsert\\s+into\\b/i);\n  expect(call.text).not.toMatch(/\\bupdate\\s+\\w/i);\n  expect(call.text).not.toMatch(/\\bdelete\\s+from\\b/i);\n  expect(call.text).toMatch(/\\bselect\\b/i);\n}\n\nfunction basePayload(overrides: Record<string, unknown> = {}): Record<string, unknown> {\n  return {\n    actorEmail: \"alice@example.com\",\n    route: \"/users/[userId]\",\n    actionId: null,\n    resourceType: \"user\",\n    resourceId: \"user-9\",\n    filterSummary: null,\n    resultCount: null,\n    requestId: null,\n    rejectionReason: null,\n    changes: null,\n    ...overrides,\n  };\n}\n\ndescribe(\"listAuditEvents\", () => {\n  it(\"default: clamps to PEEK_AUDIT_DEFAULT_LIMIT and reads from operator_events with the right column projection\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expectReadOnly(call);\n    expect(call.text).toMatch(/from operator_events oe/i);\n    expect(call.text).toMatch(/oe\\.event_type/);\n    expect(call.text).toMatch(/oe\\.created_at/);\n    expect(call.text).toMatch(/oe\\.payload/);\n    expect(call.text).toMatch(\n      /order by oe\\.created_at desc, oe\\.id desc/i,\n    );\n    expect(call.values).toContain(PEEK_AUDIT_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({ sql: mock.sql, limit: PEEK_AUDIT_MAX_LIMIT + 100 });\n    expect(mock.calls[0].values).toContain(PEEK_AUDIT_MAX_LIMIT);\n  });\n\n  it(\"non-positive limit clamps to 1\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({ sql: mock.sql, limit: 0 });\n    expect(mock.calls[0].values).toContain(1);\n  });\n\n  it(\"non-finite limit falls back to the default\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({ sql: mock.sql, limit: Number.NaN });\n    expect(mock.calls[0].values).toContain(PEEK_AUDIT_DEFAULT_LIMIT);\n  });\n\n  it(\"filters: empty filters bind null sentinels so every where-clause toggle skips the predicate\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({ sql: mock.sql, filters: {} });\n\n    // The query has 6 togglable predicates (eventType / actorEmail /\n    // resourceId / route / createdFrom / createdTo). Each predicate uses\n    // (${X === null} or oe.<col> = ${X ?? \"\"}); an \"all-null\" input binds 6\n    // `true` sentinels — plus the `eventType !== null` toggle that activates\n    // the broad `peek.%` fallback (so 7 boolean sentinels total).\n    const trueBinds = mock.calls[0].values.filter((v) => v === true).length;\n    expect(trueBinds).toBeGreaterThanOrEqual(6);\n    // The peek.% fallback fires when no eventType is bound.\n    expect(mock.calls[0].text).toMatch(/like 'peek\\.%'/);\n  });\n\n  it(\"filters: state-transition coverage — every PeekAuditEventType binds verbatim\", async () => {\n    for (const eventType of PEEK_AUDIT_EVENT_TYPES) {\n      const mock = createSqlMock([[]]);\n      await listAuditEvents({ sql: mock.sql, filters: { eventType } });\n      expect(mock.calls[0].values).toContain(eventType);\n    }\n  });\n\n  it(\"filters: eventType='peek.export' disables the broad peek.% predicate (no false-positive matches)\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({\n      sql: mock.sql,\n      filters: { eventType: \"peek.export\" },\n    });\n    const values = mock.calls[0].values;\n    expect(values).toContain(\"peek.export\");\n    // Bound `false` for the peek.% fallback toggle when an explicit eventType\n    // is set — confirms the predicate is skipped (no double-match risk).\n    expect(values).toContain(false);\n  });\n\n  it(\"filters: actor email is normalised to lowercase before binding so `Alice@Example.COM` matches `alice@example.com`\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({\n      sql: mock.sql,\n      filters: { actorEmail: \"Alice@Example.COM\" },\n    });\n    expect(mock.calls[0].text).toMatch(/lower\\(oe\\.payload->>'actorEmail'\\)/);\n    expect(mock.calls[0].values).toContain(\"alice@example.com\");\n    // The original mixed-case value never reaches the bound parameters.\n    expect(mock.calls[0].values).not.toContain(\"Alice@Example.COM\");\n  });\n\n  it(\"filters: resourceId binds verbatim against payload->>'resourceId'\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({\n      sql: mock.sql,\n      filters: { resourceId: \"user-9\" },\n    });\n    expect(mock.calls[0].text).toMatch(/oe\\.payload->>'resourceId' = /);\n    expect(mock.calls[0].values).toContain(\"user-9\");\n  });\n\n  it(\"filters: route binds verbatim against payload->>'route'\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({\n      sql: mock.sql,\n      filters: { route: \"/users/[userId]\" },\n    });\n    expect(mock.calls[0].text).toMatch(/oe\\.payload->>'route' = /);\n    expect(mock.calls[0].values).toContain(\"/users/[userId]\");\n  });\n\n  it(\"filters: createdFrom and createdTo cast through ::timestamptz so half-open windows stay tz-correct\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({\n      sql: mock.sql,\n      filters: {\n        createdFrom: \"2026-04-01T00:00:00.000Z\",\n        createdTo: \"2026-04-26T00:00:00.000Z\",\n      },\n    });\n    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n    expect(mock.calls[0].values).toContain(\"2026-04-01T00:00:00.000Z\");\n    expect(mock.calls[0].values).toContain(\"2026-04-26T00:00:00.000Z\");\n  });\n\n  it(\"filters: every supported filter (eventType, actorEmail, resourceId, route, createdFrom, createdTo) flows into the bound values\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({\n      sql: mock.sql,\n      filters: {\n        eventType: \"peek.export\",\n        actorEmail: \"alice@example.com\",\n        resourceId: \"user-9\",\n        route: \"/users/[userId]\",\n        createdFrom: \"2026-04-01T00:00:00.000Z\",\n        createdTo: \"2026-04-26T00:00:00.000Z\",\n      },\n    });\n    const values = mock.calls[0].values;\n    expect(values).toContain(\"peek.export\");\n    expect(values).toContain(\"alice@example.com\");\n    expect(values).toContain(\"user-9\");\n    expect(values).toContain(\"/users/[userId]\");\n    expect(values).toContain(\"2026-04-01T00:00:00.000Z\");\n    expect(values).toContain(\"2026-04-26T00:00:00.000Z\");\n  });\n\n  it(\"filters: whitespace-only filter values normalise to null (toggle stays in pass-through mode)\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({\n      sql: mock.sql,\n      filters: {\n        eventType: \"  \" as unknown as PeekAuditEventType,\n        actorEmail: \"  \",\n        resourceId: \"   \",\n        route: \"  \",\n        createdFrom: \"  \",\n        createdTo: \"  \",\n      },\n    });\n    // None of the whitespace strings appear in the bound values.\n    expect(mock.calls[0].values).not.toContain(\"  \");\n    expect(mock.calls[0].values).not.toContain(\"   \");\n  });\n\n  it(\"filters: an unknown eventType value silently falls back to the broad `peek.%` predicate (a stale URL chip cannot drop result count to zero)\", async () => {\n    const mock = createSqlMock([[]]);\n    await listAuditEvents({\n      sql: mock.sql,\n      filters: {\n        eventType: \"peek.totally.bogus\" as unknown as PeekAuditEventType,\n      },\n    });\n    // The peek.% fallback fires.\n    expect(mock.calls[0].text).toMatch(/like 'peek\\.%'/);\n    // The bogus value is dropped, never bound.\n    expect(mock.calls[0].values).not.toContain(\"peek.totally.bogus\");\n  });\n\n  it(\"populated: row mapping projects the audit columns and recovers a typed PeekAuditEvent\", async () => {\n    const row = {\n      id: \"11111111-1111-1111-1111-111111111111\",\n      eventType: \"peek.export\",\n      createdAt: \"2026-04-26T10:00:00.000Z\",\n      payload: basePayload({\n        actorEmail: \"alice@example.com\",\n        route: \"/growth/referrals\",\n        actionId: \"peek.export.referrals\",\n        filterSummary: \"status=pending\",\n        resultCount: 42,\n        requestId: \"req-1\",\n      }),\n    };\n    const mock = createSqlMock([[row]]);\n\n    const rows = await listAuditEvents({ sql: mock.sql });\n    expect(rows).toHaveLength(1);\n    expect(rows[0].id).toBe(\"11111111-1111-1111-1111-111111111111\");\n    expect(rows[0].eventType).toBe(\"peek.export\");\n    expect(rows[0].createdAt).toBe(\"2026-04-26T10:00:00.000Z\");\n    expect(rows[0].payload.actorEmail).toBe(\"alice@example.com\");\n    expect(rows[0].payload.route).toBe(\"/growth/referrals\");\n    expect(rows[0].payload.actionId).toBe(\"peek.export.referrals\");\n    expect(rows[0].payload.filterSummary).toBe(\"status=pending\");\n    expect(rows[0].payload.resultCount).toBe(42);\n    expect(rows[0].payload.requestId).toBe(\"req-1\");\n  });\n\n  it(\"populated: rows whose event_type is not in PEEK_AUDIT_EVENT_TYPES are dropped (defensive — the SQL filter restricts to peek.* but a bypass insert could slip)\", async () => {\n    const row = {\n      id: \"abc\",\n      eventType: \"system.something\",\n      createdAt: \"2026-04-26T10:00:00.000Z\",\n      payload: basePayload(),\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listAuditEvents({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"populated: payload changes array round-trips with the original field/before/after triples\", async () => {\n    const row = {\n      id: \"abc\",\n      eventType: \"peek.change.applied\",\n      createdAt: \"2026-04-26T10:00:00.000Z\",\n      payload: basePayload({\n        actionId: \"kol_rate.update\",\n        changes: [\n          { field: \"rate_bps\", before: 500, after: 600 },\n        ],\n      }),\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listAuditEvents({ sql: mock.sql });\n    expect(rows[0].payload.changes).toHaveLength(1);\n    expect(rows[0].payload.changes?.[0].field).toBe(\"rate_bps\");\n    expect(rows[0].payload.changes?.[0].before).toBe(500);\n    expect(rows[0].payload.changes?.[0].after).toBe(600);\n  });\n\n  it(\"populated: changes that are not array-like normalise to null (defensive shape coercion)\", async () => {\n    const row = {\n      id: \"abc\",\n      eventType: \"peek.change.applied\",\n      createdAt: \"2026-04-26T10:00:00.000Z\",\n      payload: basePayload({ changes: \"not-an-array\" }),\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listAuditEvents({ sql: mock.sql });\n    expect(rows[0].payload.changes).toBeNull();\n  });\n\n  it(\"redaction defensively re-applied on read: a route that looks like a JWT round-trips as PEEK_AUDIT_REDACTED (the writer should have caught this; the read layer is the second line of defence)\", async () => {\n    const jwt =\n      \"eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ1c2VyLTkifQ.signature_segment\";\n    const row = {\n      id: \"abc\",\n      eventType: \"peek.search\",\n      createdAt: \"2026-04-26T10:00:00.000Z\",\n      payload: basePayload({ route: jwt }),\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listAuditEvents({ sql: mock.sql });\n    expect(rows[0].payload.route).toBe(PEEK_AUDIT_REDACTED);\n    // The original token never reaches the surface.\n    expect(rows[0].payload.route).not.toContain(\"eyJ\");\n  });\n\n  it(\"redaction defensively re-applied on read: a rejection reason containing a Postgres URL is replaced with the sentinel\", async () => {\n    const url = \"postgres://user:secret@host:5432/db\";\n    const row = {\n      id: \"abc\",\n      eventType: \"peek.change.rejected\",\n      createdAt: \"2026-04-26T10:00:00.000Z\",\n      payload: basePayload({ rejectionReason: `fatal: ${url} unreachable` }),\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listAuditEvents({ sql: mock.sql });\n    expect(rows[0].payload.rejectionReason).toBe(PEEK_AUDIT_REDACTED);\n    expect(rows[0].payload.rejectionReason).not.toContain(\"secret\");\n  });\n\n  it(\"redaction defensively re-applied on read: every nullable string slot is run through the redactor\", async () => {\n    const jwt =\n      \"eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ1c2VyLTkifQ.signature_segment\";\n    const row = {\n      id: \"abc\",\n      eventType: \"peek.user.view_sensitive\",\n      createdAt: \"2026-04-26T10:00:00.000Z\",\n      payload: basePayload({\n        route: jwt,\n        actionId: jwt,\n        resourceType: jwt,\n        resourceId: jwt,\n        filterSummary: jwt,\n        requestId: jwt,\n        rejectionReason: jwt,\n      }),\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listAuditEvents({ sql: mock.sql });\n    const p = rows[0].payload;\n    expect(p.route).toBe(PEEK_AUDIT_REDACTED);\n    expect(p.actionId).toBe(PEEK_AUDIT_REDACTED);\n    expect(p.resourceType).toBe(PEEK_AUDIT_REDACTED);\n    expect(p.resourceId).toBe(PEEK_AUDIT_REDACTED);\n    expect(p.filterSummary).toBe(PEEK_AUDIT_REDACTED);\n    expect(p.requestId).toBe(PEEK_AUDIT_REDACTED);\n    expect(p.rejectionReason).toBe(PEEK_AUDIT_REDACTED);\n  });\n\n  it(\"populated: a row with a non-object payload normalises to a default shape so the renderer cannot crash on a malformed insert\", async () => {\n    const row = {\n      id: \"abc\",\n      eventType: \"peek.search\",\n      createdAt: \"2026-04-26T10:00:00.000Z\",\n      payload: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listAuditEvents({ sql: mock.sql });\n    expect(rows[0].payload.actorEmail).toBe(\"\");\n    expect(rows[0].payload.route).toBeNull();\n    expect(rows[0].payload.changes).toBeNull();\n  });\n\n  it(\"empty: an empty result set returns []\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listAuditEvents({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"connection refused\")]);\n    await expect(listAuditEvents({ sql: mock.sql })).rejects.toThrowError(\n      \"connection refused\",\n    );\n  });\n});\n\ndescribe(\"getAuditOverview\", () => {\n  it(\"returns the FR-4 metric strip with the canonical metric ids and drilldown hrefs\", async () => {\n    const mock = createSqlMock([\n      [\n        { eventType: \"peek.export\", value: 3 },\n        { eventType: \"peek.access.denied\", value: 1 },\n        { eventType: \"peek.change.applied\", value: 5 },\n        { eventType: \"peek.change.rejected\", value: 2 },\n        { eventType: \"peek.search\", value: 9 },\n        { eventType: \"peek.user.view_sensitive\", value: 4 },\n      ],\n    ]);\n\n    const overview = await getAuditOverview({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    expectReadOnly(mock.calls[0]);\n    expect(mock.calls[0].text).toMatch(/like 'peek\\.%'/);\n    expect(mock.calls[0].text).toMatch(/group by oe\\.event_type/i);\n\n    const metricIds = overview.metrics.map((m) => m.id);\n    expect(metricIds).toEqual([\n      \"audit.total_24h\",\n      \"audit.exports_24h\",\n      \"audit.access_denied_24h\",\n      \"audit.changes_applied_24h\",\n      \"audit.changes_rejected_24h\",\n    ]);\n\n    // Total is the sum of all six event-type counts.\n    expect(overview.metrics[0].value).toBe(3 + 1 + 5 + 2 + 9 + 4);\n    expect(overview.metrics[1].value).toBe(3); // exports\n    expect(overview.metrics[2].value).toBe(1); // access denied\n    expect(overview.metrics[3].value).toBe(5); // changes applied\n    expect(overview.metrics[4].value).toBe(2); // changes rejected\n\n    // Each metric carries a definition + source per FR-4.\n    for (const metric of overview.metrics) {\n      expect(metric.source).toBe(\"operator_events\");\n      expect(metric.definition.length).toBeGreaterThan(0);\n      expect(metric.freshness).toBe(\"live\");\n    }\n\n    // Drilldowns route back into /audit with the matching short-form chip.\n    expect(overview.metrics[0].drilldownHref).toBe(\"/audit\");\n    expect(overview.metrics[1].drilldownHref).toBe(\"/audit?eventType=peek.export\");\n    expect(overview.metrics[2].drilldownHref).toBe(\n      \"/audit?eventType=peek.access.denied\",\n    );\n    expect(overview.metrics[3].drilldownHref).toBe(\n      \"/audit?eventType=peek.change.applied\",\n    );\n    expect(overview.metrics[4].drilldownHref).toBe(\n      \"/audit?eventType=peek.change.rejected\",\n    );\n  });\n\n  it(\"returns an event-type breakdown covering EVERY PeekAuditEventType — sparse types stay in the list with count=0 (FR-4 sparse-data discipline)\", async () => {\n    // The query returns only two event types; the remaining four must still\n    // appear in the breakdown with count=0 so the rendered card never silently\n    // drops a measured-zero row.\n    const mock = createSqlMock([\n      [\n        { eventType: \"peek.export\", value: 2 },\n        { eventType: \"peek.search\", value: 1 },\n      ],\n    ]);\n\n    const overview = await getAuditOverview({ sql: mock.sql });\n    expect(overview.eventTypeCounts).toHaveLength(PEEK_AUDIT_EVENT_TYPES.length);\n\n    const byEvent = new Map(\n      overview.eventTypeCounts.map((row) => [row.eventType, row.count]),\n    );\n    expect(byEvent.get(\"peek.export\")).toBe(2);\n    expect(byEvent.get(\"peek.search\")).toBe(1);\n    expect(byEvent.get(\"peek.access.denied\")).toBe(0);\n    expect(byEvent.get(\"peek.user.view_sensitive\")).toBe(0);\n    expect(byEvent.get(\"peek.change.applied\")).toBe(0);\n    expect(byEvent.get(\"peek.change.rejected\")).toBe(0);\n  });\n\n  it(\"empty: zero rows surfaces zero counts everywhere — no broken sparse render\", async () => {\n    const mock = createSqlMock([[]]);\n    const overview = await getAuditOverview({ sql: mock.sql });\n    for (const metric of overview.metrics) {\n      expect(metric.value).toBe(0);\n      expect(metric.valueDisplay).toBe(\"0\");\n    }\n    for (const row of overview.eventTypeCounts) {\n      expect(row.count).toBe(0);\n    }\n  });\n\n  it(\"window: defaults to the last 24h and binds the rolling start instant as ISO timestamptz\", async () => {\n    const now = new Date(\"2026-04-26T12:00:00.000Z\");\n    const mock = createSqlMock([[]]);\n    await getAuditOverview({ sql: mock.sql, now });\n\n    const values = mock.calls[0].values;\n    const expectedStart = new Date(\n      now.getTime() - PEEK_AUDIT_OVERVIEW_WINDOW_HOURS * 60 * 60 * 1000,\n    ).toISOString();\n    expect(values).toContain(expectedStart);\n    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n  });\n\n  it(\"window: a custom windowHours value flows into the bound start instant and the metric label\", async () => {\n    const now = new Date(\"2026-04-26T12:00:00.000Z\");\n    const mock = createSqlMock([[]]);\n    const overview = await getAuditOverview({\n      sql: mock.sql,\n      now,\n      windowHours: 48,\n    });\n\n    const expectedStart = new Date(\n      now.getTime() - 48 * 60 * 60 * 1000,\n    ).toISOString();\n    expect(mock.calls[0].values).toContain(expectedStart);\n\n    for (const metric of overview.metrics) {\n      expect(metric.windowLabel).toContain(\"48\");\n    }\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"connection refused\")]);\n    await expect(getAuditOverview({ sql: mock.sql })).rejects.toThrowError(\n      \"connection refused\",\n    );\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
