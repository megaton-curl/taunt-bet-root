{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F2ftbH1x2MmAE6gpnW4NUz","type":"tool_result","content":"1\t// Audit events table for /audit (FR-11 audit view).\n2\t//\n3\t// Read-only dense table over `PeekAuditEvent` rows. Payload values were\n4\t// already passed through `redactPayload` at write time and `listAuditEvents`\n5\t// re-applies `redactNullableString` on read; this component renders strings\n6\t// verbatim so the `PEEK_AUDIT_REDACTED` sentinel surfaces explicitly when a\n7\t// field was redacted (FR-11). The `peek.access.denied` and `peek.change.rejected`\n8\t// chip tones match the FR-10 attention semantics so dead/failed/denied states\n9\t// stand out consistently across the admin shell.\n10\t//\n11\t// All audit mutations are out of scope by definition — `operator_events` is\n12\t// append-only and the admin UI never edits or deletes rows.\n13\timport type { CSSProperties } from \"react\";\n14\timport {\n15\t  PEEK_AUDIT_REDACTED,\n16\t  type PeekAuditEvent,\n17\t  type PeekAuditEventType,\n18\t  type PeekStatusTone,\n19\t} from \"../lib/types/peek\";\n20\timport { StatusChip } from \"./status-chip\";\n21\t\n22\texport type AuditEventsTableProps = {\n23\t  rows: ReadonlyArray<PeekAuditEvent>;\n24\t  error?: string | null;\n25\t};\n26\t\n27\texport function AuditEventsTable({\n28\t  rows,\n29\t  error = null,\n30\t}: AuditEventsTableProps) {\n31\t  if (error) {\n32\t    return (\n33\t      <div role=\"alert\" style={errorStyle}>\n34\t        Audit events unavailable: {error}\n35\t      </div>\n36\t    );\n37\t  }\n38\t\n39\t  if (rows.length === 0) {\n40\t    return (\n41\t      <div role=\"status\" style={emptyStyle}>\n42\t        <p style={emptyTitleStyle}>\n43\t          No <code>peek.*</code> operator events match these filters.\n44\t        </p>\n45\t        <p style={emptyBodyStyle}>\n46\t          Adjust the filters above or clear them to see searches, sensitive\n47\t          views, exports, denied access, and applied or rejected mutations.\n48\t        </p>\n49\t      </div>\n50\t    );\n51\t  }\n52\t\n53\t  return (\n54\t    <div style={wrapperStyle}>\n55\t      <table style={tableStyle}>\n56\t        <thead>\n57\t          <tr style={headerRowStyle}>\n58\t            <th style={headerCellStyle(\"left\")}>Event type</th>\n59\t            <th style={headerCellStyle(\"left\")}>Created</th>\n60\t            <th style={headerCellStyle(\"left\")}>Actor</th>\n61\t            <th style={headerCellStyle(\"left\")}>Route</th>\n62\t            <th style={headerCellStyle(\"left\")}>Action</th>\n63\t            <th style={headerCellStyle(\"left\")}>Resource</th>\n64\t            <th style={headerCellStyle(\"left\")}>Filter</th>\n65\t            <th style={headerCellStyle(\"right\")}>Result</th>\n66\t            <th style={headerCellStyle(\"left\")}>Notes</th>\n67\t            <th style={headerCellStyle(\"left\")}>ID</th>\n68\t          </tr>\n69\t        </thead>\n70\t        <tbody>\n71\t          {rows.map((row) => (\n72\t            <tr key={row.id} style={bodyRowStyle}>\n73\t              <td style={bodyCellStyle(\"left\")}>\n74\t                <StatusChip\n75\t                  label={row.eventType}\n76\t                  tone={auditEventTone(row.eventType)}\n77\t                />\n78\t              </td>\n79\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n80\t                {row.createdAt}\n81\t              </td>\n82\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n83\t                {row.payload.actorEmail || \"—\"}\n84\t              </td>\n85\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n86\t                {renderRedactable(row.payload.route)}\n87\t              </td>\n88\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n89\t                {renderRedactable(row.payload.actionId)}\n90\t              </td>\n91\t              <td style={bodyCellStyle(\"left\")}>\n92\t                {renderResource(row.payload.resourceType, row.payload.resourceId)}\n93\t              </td>\n94\t              <td style={{ ...bodyCellStyle(\"left\"), maxWidth: \"16rem\" }}>\n95\t                {renderRedactable(row.payload.filterSummary)}\n96\t              </td>\n97\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n98\t                {row.payload.resultCount === null\n99\t                  ? \"—\"\n100\t                  : row.payload.resultCount.toLocaleString(\"en-US\")}\n101\t              </td>\n102\t              <td style={{ ...bodyCellStyle(\"left\"), maxWidth: \"16rem\" }}>\n103\t                {renderNotes(row)}\n104\t              </td>\n105\t              <td\n106\t                style={{\n107\t                  ...bodyCellStyle(\"left\"),\n108\t                  fontFamily: \"monospace\",\n109\t                  color: \"#94a3b8\",\n110\t                  fontSize: \"0.75rem\",\n111\t                }}\n112\t              >\n113\t                {row.id}\n114\t              </td>\n115\t            </tr>\n116\t          ))}\n117\t        </tbody>\n118\t      </table>\n119\t    </div>\n120\t  );\n121\t}\n122\t\n123\tfunction renderRedactable(value: string | null) {\n124\t  if (value === null) return <>—</>;\n125\t  if (value === PEEK_AUDIT_REDACTED) {\n126\t    return <span style={redactedStyle}>{PEEK_AUDIT_REDACTED}</span>;\n127\t  }\n128\t  return <>{value}</>;\n129\t}\n130\t\n131\tfunction renderResource(\n132\t  resourceType: string | null,\n133\t  resourceId: string | null,\n134\t) {\n135\t  if (resourceType === null && resourceId === null) return <>—</>;\n136\t  return (\n137\t    <div style={resourceStyle}>\n138\t      {resourceType ? (\n139\t        <span style={resourceTypeStyle}>{renderRedactable(resourceType)}</span>\n140\t      ) : null}\n141\t      {resourceId ? (\n142\t        <span style={resourceIdStyle}>{renderRedactable(resourceId)}</span>\n143\t      ) : null}\n144\t    </div>\n145\t  );\n146\t}\n147\t\n148\tfunction renderNotes(row: PeekAuditEvent) {\n149\t  const { rejectionReason, requestId, changes } = row.payload;\n150\t  type NoteFragment = { key: string; node: React.ReactNode };\n151\t  const fragments: NoteFragment[] = [];\n152\t\n153\t  if (rejectionReason) {\n154\t    fragments.push({\n155\t      key: \"rejection\",\n156\t      node: (\n157\t        <span style={notesRejectionStyle}>\n158\t          rejected: {renderRedactable(rejectionReason)}\n159\t        </span>\n160\t      ),\n161\t    });\n162\t  }\n163\t  if (requestId) {\n164\t    fragments.push({\n165\t      key: \"request\",\n166\t      node: (\n167\t        <span style={notesMutedStyle}>req: {renderRedactable(requestId)}</span>\n168\t      ),\n169\t    });\n170\t  }\n171\t  if (changes && changes.length > 0) {\n172\t    fragments.push({\n173\t      key: \"changes\",\n174\t      node: (\n175\t        <span style={notesMutedStyle}>\n176\t          changes: {changes.length.toLocaleString(\"en-US\")}\n177\t        </span>\n178\t      ),\n179\t    });\n180\t  }\n181\t\n182\t  if (fragments.length === 0) return <>—</>;\n183\t  return (\n184\t    <div style={notesStyle}>\n185\t      {fragments.map((fragment) => (\n186\t        <span key={fragment.key}>{fragment.node}</span>\n187\t      ))}\n188\t    </div>\n189\t  );\n190\t}\n191\t\n192\texport function auditEventTone(value: PeekAuditEventType): PeekStatusTone {\n193\t  if (value === \"peek.change.applied\") return \"positive\";\n194\t  if (value === \"peek.change.rejected\") return \"negative\";\n195\t  if (value === \"peek.access.denied\") return \"negative\";\n196\t  if (value === \"peek.export\") return \"warning\";\n197\t  if (value === \"peek.user.view_sensitive\") return \"info\";\n198\t  if (value === \"peek.search\") return \"neutral\";\n199\t  return \"neutral\";\n200\t}\n201\t\n202\tconst wrapperStyle: CSSProperties = {\n203\t  overflowX: \"auto\",\n204\t  border: \"1px solid #1e293b\",\n205\t  borderRadius: \"0.75rem\",\n206\t};\n207\t\n208\tconst tableStyle: CSSProperties = {\n209\t  width: \"100%\",\n210\t  borderCollapse: \"collapse\",\n211\t};\n212\t\n213\tconst headerRowStyle: CSSProperties = {\n214\t  background: \"#111827\",\n215\t  color: \"#94a3b8\",\n216\t};\n217\t\n218\tconst bodyRowStyle: CSSProperties = {\n219\t  borderTop: \"1px solid #1e293b\",\n220\t};\n221\t\n222\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n223\t  return {\n224\t    padding: \"0.75rem\",\n225\t    textAlign: align,\n226\t    fontSize: \"0.875rem\",\n227\t    fontWeight: 600,\n228\t  };\n229\t}\n230\t\n231\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n232\t  return {\n233\t    padding: \"0.75rem\",\n234\t    textAlign: align,\n235\t    fontSize: \"0.875rem\",\n236\t    color: \"#e2e8f0\",\n237\t    verticalAlign: \"top\",\n238\t  };\n239\t}\n240\t\n241\tconst redactedStyle: CSSProperties = {\n242\t  fontFamily: \"monospace\",\n243\t  color: \"#fbbf24\",\n244\t  background: \"#1f2937\",\n245\t  padding: \"0.0625rem 0.375rem\",\n246\t  borderRadius: \"0.25rem\",\n247\t  fontSize: \"0.75rem\",\n248\t};\n249\t\n250\tconst resourceStyle: CSSProperties = {\n251\t  display: \"grid\",\n252\t  gap: \"0.125rem\",\n253\t  fontFamily: \"monospace\",\n254\t  fontSize: \"0.8125rem\",\n255\t};\n256\t\n257\tconst resourceTypeStyle: CSSProperties = {\n258\t  color: \"#94a3b8\",\n259\t  fontSize: \"0.75rem\",\n260\t};\n261\t\n262\tconst resourceIdStyle: CSSProperties = {\n263\t  color: \"#cbd5f5\",\n264\t  wordBreak: \"break-all\",\n265\t};\n266\t\n267\tconst notesStyle: CSSProperties = {\n268\t  display: \"grid\",\n269\t  gap: \"0.125rem\",\n270\t  fontSize: \"0.75rem\",\n271\t};\n272\t\n273\tconst notesRejectionStyle: CSSProperties = {\n274\t  color: \"#fecaca\",\n275\t  fontFamily: \"monospace\",\n276\t};\n277\t\n278\tconst notesMutedStyle: CSSProperties = {\n279\t  color: \"#94a3b8\",\n280\t  fontFamily: \"monospace\",\n281\t};\n282\t\n283\tconst errorStyle: CSSProperties = {\n284\t  margin: 0,\n285\t  padding: \"0.75rem 1rem\",\n286\t  borderRadius: \"0.75rem\",\n287\t  background: \"#3f1d1d\",\n288\t  color: \"#fecaca\",\n289\t};\n290\t\n291\tconst emptyStyle: CSSProperties = {\n292\t  padding: \"1.5rem\",\n293\t  borderRadius: \"0.75rem\",\n294\t  border: \"1px dashed #334155\",\n295\t  background: \"#0b1220\",\n296\t  color: \"#cbd5f5\",\n297\t  display: \"grid\",\n298\t  gap: \"0.5rem\",\n299\t};\n300\t\n301\tconst emptyTitleStyle: CSSProperties = {\n302\t  margin: 0,\n303\t  fontSize: \"1rem\",\n304\t  fontWeight: 600,\n305\t};\n306\t\n307\tconst emptyBodyStyle: CSSProperties = {\n308\t  margin: 0,\n309\t  fontSize: \"0.875rem\",\n310\t  color: \"#94a3b8\",\n311\t};\n312\t"}]},"parent_tool_use_id":null,"session_id":"94a07cbb-8d25-425b-954a-4878bb9ef4df","uuid":"9b06ea6b-03c8-4ea6-a1f6-590644704ee8","timestamp":"2026-04-26T07:23:37.585Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/audit-events-table.tsx","content":"// Audit events table for /audit (FR-11 audit view).\n//\n// Read-only dense table over `PeekAuditEvent` rows. Payload values were\n// already passed through `redactPayload` at write time and `listAuditEvents`\n// re-applies `redactNullableString` on read; this component renders strings\n// verbatim so the `PEEK_AUDIT_REDACTED` sentinel surfaces explicitly when a\n// field was redacted (FR-11). The `peek.access.denied` and `peek.change.rejected`\n// chip tones match the FR-10 attention semantics so dead/failed/denied states\n// stand out consistently across the admin shell.\n//\n// All audit mutations are out of scope by definition — `operator_events` is\n// append-only and the admin UI never edits or deletes rows.\nimport type { CSSProperties } from \"react\";\nimport {\n  PEEK_AUDIT_REDACTED,\n  type PeekAuditEvent,\n  type PeekAuditEventType,\n  type PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type AuditEventsTableProps = {\n  rows: ReadonlyArray<PeekAuditEvent>;\n  error?: string | null;\n};\n\nexport function AuditEventsTable({\n  rows,\n  error = null,\n}: AuditEventsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Audit events unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>\n          No <code>peek.*</code> operator events match these filters.\n        </p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see searches, sensitive\n          views, exports, denied access, and applied or rejected mutations.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Event type</th>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>Actor</th>\n            <th style={headerCellStyle(\"left\")}>Route</th>\n            <th style={headerCellStyle(\"left\")}>Action</th>\n            <th style={headerCellStyle(\"left\")}>Resource</th>\n            <th style={headerCellStyle(\"left\")}>Filter</th>\n            <th style={headerCellStyle(\"right\")}>Result</th>\n            <th style={headerCellStyle(\"left\")}>Notes</th>\n            <th style={headerCellStyle(\"left\")}>ID</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.eventType}\n                  tone={auditEventTone(row.eventType)}\n                />\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.createdAt}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.payload.actorEmail || \"—\"}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {renderRedactable(row.payload.route)}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {renderRedactable(row.payload.actionId)}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                {renderResource(row.payload.resourceType, row.payload.resourceId)}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), maxWidth: \"16rem\" }}>\n                {renderRedactable(row.payload.filterSummary)}\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.payload.resultCount === null\n                  ? \"—\"\n                  : row.payload.resultCount.toLocaleString(\"en-US\")}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), maxWidth: \"16rem\" }}>\n                {renderNotes(row)}\n              </td>\n              <td\n                style={{\n                  ...bodyCellStyle(\"left\"),\n                  fontFamily: \"monospace\",\n                  color: \"#94a3b8\",\n                  fontSize: \"0.75rem\",\n                }}\n              >\n                {row.id}\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction renderRedactable(value: string | null) {\n  if (value === null) return <>—</>;\n  if (value === PEEK_AUDIT_REDACTED) {\n    return <span style={redactedStyle}>{PEEK_AUDIT_REDACTED}</span>;\n  }\n  return <>{value}</>;\n}\n\nfunction renderResource(\n  resourceType: string | null,\n  resourceId: string | null,\n) {\n  if (resourceType === null && resourceId === null) return <>—</>;\n  return (\n    <div style={resourceStyle}>\n      {resourceType ? (\n        <span style={resourceTypeStyle}>{renderRedactable(resourceType)}</span>\n      ) : null}\n      {resourceId ? (\n        <span style={resourceIdStyle}>{renderRedactable(resourceId)}</span>\n      ) : null}\n    </div>\n  );\n}\n\nfunction renderNotes(row: PeekAuditEvent) {\n  const { rejectionReason, requestId, changes } = row.payload;\n  type NoteFragment = { key: string; node: React.ReactNode };\n  const fragments: NoteFragment[] = [];\n\n  if (rejectionReason) {\n    fragments.push({\n      key: \"rejection\",\n      node: (\n        <span style={notesRejectionStyle}>\n          rejected: {renderRedactable(rejectionReason)}\n        </span>\n      ),\n    });\n  }\n  if (requestId) {\n    fragments.push({\n      key: \"request\",\n      node: (\n        <span style={notesMutedStyle}>req: {renderRedactable(requestId)}</span>\n      ),\n    });\n  }\n  if (changes && changes.length > 0) {\n    fragments.push({\n      key: \"changes\",\n      node: (\n        <span style={notesMutedStyle}>\n          changes: {changes.length.toLocaleString(\"en-US\")}\n        </span>\n      ),\n    });\n  }\n\n  if (fragments.length === 0) return <>—</>;\n  return (\n    <div style={notesStyle}>\n      {fragments.map((fragment) => (\n        <span key={fragment.key}>{fragment.node}</span>\n      ))}\n    </div>\n  );\n}\n\nexport function auditEventTone(value: PeekAuditEventType): PeekStatusTone {\n  if (value === \"peek.change.applied\") return \"positive\";\n  if (value === \"peek.change.rejected\") return \"negative\";\n  if (value === \"peek.access.denied\") return \"negative\";\n  if (value === \"peek.export\") return \"warning\";\n  if (value === \"peek.user.view_sensitive\") return \"info\";\n  if (value === \"peek.search\") return \"neutral\";\n  return \"neutral\";\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst redactedStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  color: \"#fbbf24\",\n  background: \"#1f2937\",\n  padding: \"0.0625rem 0.375rem\",\n  borderRadius: \"0.25rem\",\n  fontSize: \"0.75rem\",\n};\n\nconst resourceStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.125rem\",\n  fontFamily: \"monospace\",\n  fontSize: \"0.8125rem\",\n};\n\nconst resourceTypeStyle: CSSProperties = {\n  color: \"#94a3b8\",\n  fontSize: \"0.75rem\",\n};\n\nconst resourceIdStyle: CSSProperties = {\n  color: \"#cbd5f5\",\n  wordBreak: \"break-all\",\n};\n\nconst notesStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.125rem\",\n  fontSize: \"0.75rem\",\n};\n\nconst notesRejectionStyle: CSSProperties = {\n  color: \"#fecaca\",\n  fontFamily: \"monospace\",\n};\n\nconst notesMutedStyle: CSSProperties = {\n  color: \"#94a3b8\",\n  fontFamily: \"monospace\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":312,"startLine":1,"totalLines":312}}}
