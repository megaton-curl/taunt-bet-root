{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KqvvnA4MxwukmjkmB3AyLb","type":"tool_result","content":"1\t// URL-addressable filter params for /audit (FR-11 audit view).\n2\t//\n3\t// One filter group per page (`auditFilter*` for inputs that match the spec line\n4\t// \"filters by event type, actor email, resource id, route, and date\" plus the\n5\t// short-form `eventType` chip used by the home/command-center metric drilldown\n6\t// links emitted by `getAuditOverview`). Empty / whitespace values normalise to\n7\t// `null`. Unknown values for `eventType` normalise to `null` so a stale URL\n8\t// chip cannot lie about the table's filter state.\n9\t//\n10\t// `eventType` is intentionally allowed both with and without the `auditFilter`\n11\t// prefix: the home metric strip drills into `/audit?eventType=peek.export`\n12\t// (short form, matches the SQL filter and the dashboard convention used by\n13\t// `get-command-center-attention.ts`); the in-page filter form uses the longer\n14\t// `auditFilterEventType` so it cannot collide with other surfaces. The short\n15\t// form wins when both are present so an operator's drilldown intent always\n16\t// overrides any leftover form state.\n17\t\n18\timport {\n19\t  PEEK_AUDIT_EVENT_TYPES,\n20\t  isPeekAuditEventType,\n21\t} from \"./types/peek\";\n22\timport type { PeekAuditEventType, PeekAuditFilters } from \"./types/peek\";\n23\t\n24\texport const PEEK_AUDIT_EVENT_TYPE_VALUES: ReadonlyArray<string> =\n25\t  PEEK_AUDIT_EVENT_TYPES;\n26\t\n27\tfunction readSingleValue(value: string | string[] | undefined): string {\n28\t  return Array.isArray(value) ? value[0] ?? \"\" : value ?? \"\";\n29\t}\n30\t\n31\tfunction trimOrNull(value: string): string | null {\n32\t  const trimmed = value.trim();\n33\t  return trimmed.length > 0 ? trimmed : null;\n34\t}\n35\t\n36\tfunction coerceEventType(raw: string | null): PeekAuditEventType | null {\n37\t  if (raw === null) return null;\n38\t  return isPeekAuditEventType(raw) ? raw : null;\n39\t}\n40\t\n41\texport function normalizeAuditFiltersFromSearchParams(\n42\t  input: Record<string, string | string[] | undefined>,\n43\t): PeekAuditFilters {\n44\t  const eventTypeShort = trimOrNull(readSingleValue(input.eventType));\n45\t  const eventTypeLong = trimOrNull(readSingleValue(input.auditFilterEventType));\n46\t  const eventType = coerceEventType(eventTypeShort ?? eventTypeLong);\n47\t\n48\t  return {\n49\t    eventType,\n50\t    actorEmail: trimOrNull(readSingleValue(input.auditFilterActor)),\n51\t    resourceId: trimOrNull(readSingleValue(input.auditFilterResource)),\n52\t    route: trimOrNull(readSingleValue(input.auditFilterRoute)),\n53\t    createdFrom: trimOrNull(readSingleValue(input.auditFilterCreatedFrom)),\n54\t    createdTo: trimOrNull(readSingleValue(input.auditFilterCreatedTo)),\n55\t  };\n56\t}\n57\t\n58\texport const PEEK_AUDIT_FILTER_PARAM_NAMES = {\n59\t  eventType: \"auditFilterEventType\",\n60\t  actorEmail: \"auditFilterActor\",\n61\t  resourceId: \"auditFilterResource\",\n62\t  route: \"auditFilterRoute\",\n63\t  createdFrom: \"auditFilterCreatedFrom\",\n64\t  createdTo: \"auditFilterCreatedTo\",\n65\t} as const;\n66\t"}]},"parent_tool_use_id":null,"session_id":"94a07cbb-8d25-425b-954a-4878bb9ef4df","uuid":"6ba9b1f3-2105-4799-bdc4-bc6b19ec29a4","timestamp":"2026-04-26T07:23:40.274Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/audit-search-params.ts","content":"// URL-addressable filter params for /audit (FR-11 audit view).\n//\n// One filter group per page (`auditFilter*` for inputs that match the spec line\n// \"filters by event type, actor email, resource id, route, and date\" plus the\n// short-form `eventType` chip used by the home/command-center metric drilldown\n// links emitted by `getAuditOverview`). Empty / whitespace values normalise to\n// `null`. Unknown values for `eventType` normalise to `null` so a stale URL\n// chip cannot lie about the table's filter state.\n//\n// `eventType` is intentionally allowed both with and without the `auditFilter`\n// prefix: the home metric strip drills into `/audit?eventType=peek.export`\n// (short form, matches the SQL filter and the dashboard convention used by\n// `get-command-center-attention.ts`); the in-page filter form uses the longer\n// `auditFilterEventType` so it cannot collide with other surfaces. The short\n// form wins when both are present so an operator's drilldown intent always\n// overrides any leftover form state.\n\nimport {\n  PEEK_AUDIT_EVENT_TYPES,\n  isPeekAuditEventType,\n} from \"./types/peek\";\nimport type { PeekAuditEventType, PeekAuditFilters } from \"./types/peek\";\n\nexport const PEEK_AUDIT_EVENT_TYPE_VALUES: ReadonlyArray<string> =\n  PEEK_AUDIT_EVENT_TYPES;\n\nfunction readSingleValue(value: string | string[] | undefined): string {\n  return Array.isArray(value) ? value[0] ?? \"\" : value ?? \"\";\n}\n\nfunction trimOrNull(value: string): string | null {\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nfunction coerceEventType(raw: string | null): PeekAuditEventType | null {\n  if (raw === null) return null;\n  return isPeekAuditEventType(raw) ? raw : null;\n}\n\nexport function normalizeAuditFiltersFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): PeekAuditFilters {\n  const eventTypeShort = trimOrNull(readSingleValue(input.eventType));\n  const eventTypeLong = trimOrNull(readSingleValue(input.auditFilterEventType));\n  const eventType = coerceEventType(eventTypeShort ?? eventTypeLong);\n\n  return {\n    eventType,\n    actorEmail: trimOrNull(readSingleValue(input.auditFilterActor)),\n    resourceId: trimOrNull(readSingleValue(input.auditFilterResource)),\n    route: trimOrNull(readSingleValue(input.auditFilterRoute)),\n    createdFrom: trimOrNull(readSingleValue(input.auditFilterCreatedFrom)),\n    createdTo: trimOrNull(readSingleValue(input.auditFilterCreatedTo)),\n  };\n}\n\nexport const PEEK_AUDIT_FILTER_PARAM_NAMES = {\n  eventType: \"auditFilterEventType\",\n  actorEmail: \"auditFilterActor\",\n  resourceId: \"auditFilterResource\",\n  route: \"auditFilterRoute\",\n  createdFrom: \"auditFilterCreatedFrom\",\n  createdTo: \"auditFilterCreatedTo\",\n} as const;\n","numLines":66,"startLine":1,"totalLines":66}}}
