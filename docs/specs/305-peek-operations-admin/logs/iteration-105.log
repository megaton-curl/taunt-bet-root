{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C2nEsBd3yu9Kw58oaa5pix","type":"tool_result","content":"120\t    // 9 togglable predicates (status / event type / id / payload user id /\n121\t    // scheduled[from,to) / created[from,to) / age max / age min). Each\n122\t    // predicate uses (${X === null} or eq.<col> = ${X ?? \"\"}) so an \"all-null\"\n123\t    // input binds 9 `true` sentinels.\n124\t    const trueBinds = mock.calls[0].values.filter((v) => v === true).length;\n125\t    expect(trueBinds).toBeGreaterThanOrEqual(9);\n126\t  });\n127\t\n128\t  it(\"filters: status='dead' binds the value verbatim and toggles the predicate on\", async () => {\n129\t    const mock = createSqlMock([[]]);\n130\t    await listEventQueue({\n131\t      sql: mock.sql,\n132\t      filters: { status: \"dead\" },\n133\t    });\n134\t\n135\t    const values = mock.calls[0].values;\n136\t    expect(values).toContain(\"dead\");\n137\t    // status=dead disables the (${null}) escape hatch → at least one `false`\n138\t    // sentinel reaches the bound values.\n139\t    expect(values).toContain(false);\n140\t  });\n141\t\n142\t  it(\"filters: state-transition coverage — every status enum binds verbatim\", async () => {\n143\t    for (const status of PEEK_EVENT_QUEUE_STATUSES) {\n144\t      const mock = createSqlMock([[]]);\n145\t      await listEventQueue({ sql: mock.sql, filters: { status } });\n146\t      expect(mock.calls[0].values).toContain(status);\n147\t    }\n148\t  });\n149\t\n150\t  it(\"filters: status='pending' binds verbatim — drives the queue.pending drilldown\", async () => {\n151\t    const mock = createSqlMock([[]]);\n152\t    await listEventQueue({ sql: mock.sql, filters: { status: \"pending\" } });\n153\t    expect(mock.calls[0].values).toContain(\"pending\");\n154\t  });\n155\t\n156\t  it(\"filters: status='failed' binds verbatim — drives the FR-10 attention link\", async () => {\n157\t    const mock = createSqlMock([[]]);\n158\t    await listEventQueue({ sql: mock.sql, filters: { status: \"failed\" } });\n159\t    expect(mock.calls[0].values).toContain(\"failed\");\n160\t  });\n161\t\n162\t  it(\"filters: payloadUserId reads through eq.payload->>'userId' and binds verbatim\", async () => {\n163\t    const mock = createSqlMock([[]]);\n164\t    await listEventQueue({\n165\t      sql: mock.sql,\n166\t      filters: { payloadUserId: \"user-9\" },\n167\t    });\n168\t    expect(mock.calls[0].text).toMatch(/eq\\.payload->>'userId' = /);\n169\t    expect(mock.calls[0].values).toContain(\"user-9\");\n170\t  });\n171\t\n172\t  it(\"filters: every supported filter (status, eventType, id, payloadUserId, scheduledFrom, scheduledTo, createdFrom, createdTo) flows into the bound values\", async () => {\n173\t    const mock = createSqlMock([[]]);\n174\t    await listEventQueue({\n175\t      sql: mock.sql,\n176\t      filters: {\n177\t        status: \"failed\",\n178\t        eventType: \"points.grant\",\n179\t        id: \"11111111-1111-1111-1111-111111111111\",\n180\t        payloadUserId: \"user-9\",\n181\t        scheduledFrom: \"2026-04-01T00:00:00.000Z\",\n182\t        scheduledTo: \"2026-04-26T00:00:00.000Z\",\n183\t        createdFrom: \"2026-04-01T00:00:00.000Z\",\n184\t        createdTo: \"2026-04-26T00:00:00.000Z\",\n185\t      },\n186\t    });\n187\t\n188\t    const values = mock.calls[0].values;\n189\t    expect(values).toContain(\"failed\");\n190\t    expect(values).toContain(\"points.grant\");\n191\t    expect(values).toContain(\"11111111-1111-1111-1111-111111111111\");\n192\t    expect(values).toContain(\"user-9\");\n193\t    expect(values).toContain(\"2026-04-01T00:00:00.000Z\");\n194\t    expect(values).toContain(\"2026-04-26T00:00:00.000Z\");\n195\t    // Date filters cast through ::timestamptz so the SQL keeps tz-correct\n196\t    // half-open windows.\n197\t    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n198\t  });\n199\t\n200\t  it(\"filters: whitespace-only filter values normalize to null (toggle stays true)\", async () => {\n201\t    const mock = createSqlMock([[]]);\n202\t    await listEventQueue({\n203\t      sql: mock.sql,\n204\t      filters: { status: \"   \", eventType: \"\" },\n205\t    });\n206\t\n207\t    // Both filters become null → both toggles become true and neither\n208\t    // value sneaks through.\n209\t    expect(mock.calls[0].values).not.toContain(\"   \");\n210\t  });\n211\t\n212\t  it(\"filters: age bucket lt_1h applies an upper bound on created_at via the `now - 0h` boundary\", async () => {\n213\t    const now = new Date(\"2026-04-26T12:00:00.000Z\");\n214\t    const mock = createSqlMock([[]]);\n215\t    await listEventQueue({\n216\t      sql: mock.sql,\n217\t      filters: { ageBucket: \"lt_1h\" },\n218\t      now,\n219\t    });\n220\t\n221\t    // The `lt_1h` bucket is [0h, 1h): older-than = now - 0h, younger-than =\n222\t    // now - 1h. The query binds both ISO strings into the timestamptz\n223\t    // comparisons.\n224\t    const values = mock.calls[0].values;\n225\t    expect(values).toContain(now.toISOString());\n226\t    const oneHourAgo = new Date(now.getTime() - 60 * 60 * 1000).toISOString();\n227\t    expect(values).toContain(oneHourAgo);\n228\t  });\n229\t\n230\t  it(\"filters: age bucket gte_7d uses the open-ended last bucket — no younger bound\", async () => {\n231\t    const now = new Date(\"2026-04-26T12:00:00.000Z\");\n232\t    const mock = createSqlMock([[]]);\n233\t    await listEventQueue({\n234\t      sql: mock.sql,\n235\t      filters: { ageBucket: \"gte_7d\" },\n236\t      now,\n237\t    });\n238\t\n239\t    const values = mock.calls[0].values;\n240\t    const sevenDaysAgo = new Date(\n241\t      now.getTime() - 7 * 24 * 60 * 60 * 1000,\n242\t    ).toISOString();\n243\t    expect(values).toContain(sevenDaysAgo);\n244\t    // The min-side toggle (`ageHasMin`) binds `false` for the open-ended\n245\t    // bucket — confirms the predicate is skipped.\n246\t    expect(values).toContain(false);\n247\t  });\n248\t\n249\t  it(\"filters: unknown age bucket id falls back to null (no age window applied)\", async () => {\n250\t    const mock = createSqlMock([[]]);\n251\t    await listEventQueue({\n252\t      sql: mock.sql,\n253\t      filters: { ageBucket: \"yesterday\" },\n254\t    });\n255\t\n256\t    // Both age-window toggles bind `true` (the predicate is skipped) and\n257\t    // neither boundary ISO string appears in the values.\n258\t    const trueBinds = mock.calls[0].values.filter((v) => v === true).length;\n259\t    expect(trueBinds).toBeGreaterThanOrEqual(9);\n260\t  });\n261\t\n262\t  it(\"populated: row mapping projects the migration columns and surfaces an error preview\", async () => {\n263\t    const row = {\n264\t      id: \"11111111-1111-1111-1111-111111111111\",\n265\t      eventType: \"points.grant\",\n266\t      status: \"failed\",\n267\t      attempts: 3,\n268\t      maxAttempts: 5,\n269\t      scheduledAt: \"2026-04-26T10:00:00.000Z\","}]},"parent_tool_use_id":null,"session_id":"94a07cbb-8d25-425b-954a-4878bb9ef4df","uuid":"4fcee6e6-1a9f-428e-a8d3-8b5bb7460eeb","timestamp":"2026-04-26T07:24:30.095Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-event-queue.test.ts","content":"    // 9 togglable predicates (status / event type / id / payload user id /\n    // scheduled[from,to) / created[from,to) / age max / age min). Each\n    // predicate uses (${X === null} or eq.<col> = ${X ?? \"\"}) so an \"all-null\"\n    // input binds 9 `true` sentinels.\n    const trueBinds = mock.calls[0].values.filter((v) => v === true).length;\n    expect(trueBinds).toBeGreaterThanOrEqual(9);\n  });\n\n  it(\"filters: status='dead' binds the value verbatim and toggles the predicate on\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: { status: \"dead\" },\n    });\n\n    const values = mock.calls[0].values;\n    expect(values).toContain(\"dead\");\n    // status=dead disables the (${null}) escape hatch → at least one `false`\n    // sentinel reaches the bound values.\n    expect(values).toContain(false);\n  });\n\n  it(\"filters: state-transition coverage — every status enum binds verbatim\", async () => {\n    for (const status of PEEK_EVENT_QUEUE_STATUSES) {\n      const mock = createSqlMock([[]]);\n      await listEventQueue({ sql: mock.sql, filters: { status } });\n      expect(mock.calls[0].values).toContain(status);\n    }\n  });\n\n  it(\"filters: status='pending' binds verbatim — drives the queue.pending drilldown\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({ sql: mock.sql, filters: { status: \"pending\" } });\n    expect(mock.calls[0].values).toContain(\"pending\");\n  });\n\n  it(\"filters: status='failed' binds verbatim — drives the FR-10 attention link\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({ sql: mock.sql, filters: { status: \"failed\" } });\n    expect(mock.calls[0].values).toContain(\"failed\");\n  });\n\n  it(\"filters: payloadUserId reads through eq.payload->>'userId' and binds verbatim\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: { payloadUserId: \"user-9\" },\n    });\n    expect(mock.calls[0].text).toMatch(/eq\\.payload->>'userId' = /);\n    expect(mock.calls[0].values).toContain(\"user-9\");\n  });\n\n  it(\"filters: every supported filter (status, eventType, id, payloadUserId, scheduledFrom, scheduledTo, createdFrom, createdTo) flows into the bound values\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: {\n        status: \"failed\",\n        eventType: \"points.grant\",\n        id: \"11111111-1111-1111-1111-111111111111\",\n        payloadUserId: \"user-9\",\n        scheduledFrom: \"2026-04-01T00:00:00.000Z\",\n        scheduledTo: \"2026-04-26T00:00:00.000Z\",\n        createdFrom: \"2026-04-01T00:00:00.000Z\",\n        createdTo: \"2026-04-26T00:00:00.000Z\",\n      },\n    });\n\n    const values = mock.calls[0].values;\n    expect(values).toContain(\"failed\");\n    expect(values).toContain(\"points.grant\");\n    expect(values).toContain(\"11111111-1111-1111-1111-111111111111\");\n    expect(values).toContain(\"user-9\");\n    expect(values).toContain(\"2026-04-01T00:00:00.000Z\");\n    expect(values).toContain(\"2026-04-26T00:00:00.000Z\");\n    // Date filters cast through ::timestamptz so the SQL keeps tz-correct\n    // half-open windows.\n    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n  });\n\n  it(\"filters: whitespace-only filter values normalize to null (toggle stays true)\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: { status: \"   \", eventType: \"\" },\n    });\n\n    // Both filters become null → both toggles become true and neither\n    // value sneaks through.\n    expect(mock.calls[0].values).not.toContain(\"   \");\n  });\n\n  it(\"filters: age bucket lt_1h applies an upper bound on created_at via the `now - 0h` boundary\", async () => {\n    const now = new Date(\"2026-04-26T12:00:00.000Z\");\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: { ageBucket: \"lt_1h\" },\n      now,\n    });\n\n    // The `lt_1h` bucket is [0h, 1h): older-than = now - 0h, younger-than =\n    // now - 1h. The query binds both ISO strings into the timestamptz\n    // comparisons.\n    const values = mock.calls[0].values;\n    expect(values).toContain(now.toISOString());\n    const oneHourAgo = new Date(now.getTime() - 60 * 60 * 1000).toISOString();\n    expect(values).toContain(oneHourAgo);\n  });\n\n  it(\"filters: age bucket gte_7d uses the open-ended last bucket — no younger bound\", async () => {\n    const now = new Date(\"2026-04-26T12:00:00.000Z\");\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: { ageBucket: \"gte_7d\" },\n      now,\n    });\n\n    const values = mock.calls[0].values;\n    const sevenDaysAgo = new Date(\n      now.getTime() - 7 * 24 * 60 * 60 * 1000,\n    ).toISOString();\n    expect(values).toContain(sevenDaysAgo);\n    // The min-side toggle (`ageHasMin`) binds `false` for the open-ended\n    // bucket — confirms the predicate is skipped.\n    expect(values).toContain(false);\n  });\n\n  it(\"filters: unknown age bucket id falls back to null (no age window applied)\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      filters: { ageBucket: \"yesterday\" },\n    });\n\n    // Both age-window toggles bind `true` (the predicate is skipped) and\n    // neither boundary ISO string appears in the values.\n    const trueBinds = mock.calls[0].values.filter((v) => v === true).length;\n    expect(trueBinds).toBeGreaterThanOrEqual(9);\n  });\n\n  it(\"populated: row mapping projects the migration columns and surfaces an error preview\", async () => {\n    const row = {\n      id: \"11111111-1111-1111-1111-111111111111\",\n      eventType: \"points.grant\",\n      status: \"failed\",\n      attempts: 3,\n      maxAttempts: 5,\n      scheduledAt: \"2026-04-26T10:00:00.000Z\",","numLines":150,"startLine":120,"totalLines":779}}}
