{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01V73fuUXqnPXFe7Tmxdc61n","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_018LTNZA4NoZRijcC4AewtG7","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/__tests__/reward-pool-card.test.tsx","content":"import { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { RewardPoolCard } from \"../reward-pool-card\";\nimport type { PeekRewardPool } from \"../../lib/types/peek\";\n\nconst POOL: PeekRewardPool = {\n  balanceLamports: \"1500000000\",\n  lifetimeFunded: \"9000000000\",\n  lifetimePaid: \"7500000000\",\n  updatedAt: \"2026-04-25T10:00:00.000Z\",\n};\n\ndescribe(\"RewardPoolCard\", () => {\n  it(\"populated: renders the four labelled cells with thousands-separator lamports, raw u64 stays in title=\", () => {\n    render(<RewardPoolCard pool={POOL} />);\n\n    expect(screen.getByText(\"Balance (lamports)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Lifetime funded (lamports)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Lifetime paid (lamports)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Updated\")).toBeInTheDocument();\n\n    // Visible labels use thousands separators (FR-4 monetary precision /\n    // operator readability).\n    expect(screen.getByText(\"1,500,000,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"9,000,000,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"7,500,000,000\")).toBeInTheDocument();\n    expect(\n      screen.getByText(\"2026-04-25T10:00:00.000Z\"),\n    ).toBeInTheDocument();\n\n    // Raw u64 lives in the title attribute for hover audit.\n    const balance = screen.getByText(\"1,500,000,000\");\n    expect(balance).toHaveAttribute(\"title\", \"1500000000\");\n  });\n\n  it(\"populated: zero pool renders a bare '0' (preserves measured-zero semantics)\", () => {\n    render(\n      <RewardPoolCard\n        pool={{\n          balanceLamports: \"0\",\n          lifetimeFunded: \"0\",\n          lifetimePaid: \"0\",\n          updatedAt: \"2026-04-25T10:00:00.000Z\",\n        }}\n      />,\n    );\n    // Three lamport cells all render bare \"0\" — measured zero, not \"0,000\".\n    expect(screen.getAllByText(\"0\").length).toBe(3);\n  });\n\n  it(\"empty (singleton missing): renders an operator status block pointing at id = 1\", () => {\n    render(<RewardPoolCard pool={null} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"No reward_pool singleton row.\");\n    expect(status).toHaveTextContent(\"reward_pool(id = 1)\");\n    expect(screen.queryByRole(\"alert\")).toBeNull();\n  });\n\n  it(\"error: renders an alert message and hides the data + empty status\", () => {\n    render(<RewardPoolCard pool={POOL} error=\"connection refused\" />);\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Reward pool unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"status\")).toBeNull();\n    expect(screen.queryByText(\"1,500,000,000\")).toBeNull();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":7244,"cache_read_input_tokens":101166,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":7244},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"b77bbed1-945f-44ec-8430-ad135cabe0b1","uuid":"0232fa6f-85a3-4106-889c-951f85d9bbdb"}
