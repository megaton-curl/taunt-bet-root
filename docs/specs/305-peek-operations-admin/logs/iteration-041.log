{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PnD5wjy3fFq6Aj1MfNXmnh","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport { render, screen } from \"@testing-library/react\";\n3\timport { GrowthKolTable } from \"../growth-kol-table\";\n4\timport type { PeekKolPerformanceRow } from \"../../lib/types/peek\";\n5\t\n6\tconst ROW_KOL: PeekKolPerformanceRow = {\n7\t  userId: \"u-1\",\n8\t  username: \"alice\",\n9\t  wallet: \"wallet-1\",\n10\t  rateBps: 250,\n11\t  setBy: \"admin@example.com\",\n12\t  createdAt: \"2026-04-01T00:00:00.000Z\",\n13\t  updatedAt: \"2026-04-10T00:00:00.000Z\",\n14\t  refereeCount: 12,\n15\t  referredWagerLamports: \"8000000\",\n16\t  referrerEarnedLamports: \"200000\",\n17\t};\n18\t\n19\tconst ROW_NEW_KOL: PeekKolPerformanceRow = {\n20\t  userId: \"u-2\",\n21\t  username: null,\n22\t  wallet: \"wallet-2\",\n23\t  rateBps: 100,\n24\t  setBy: \"admin@example.com\",\n25\t  createdAt: \"2026-04-15T00:00:00.000Z\",\n26\t  updatedAt: \"2026-04-15T00:00:00.000Z\",\n27\t  refereeCount: 0,\n28\t  referredWagerLamports: \"0\",\n29\t  referrerEarnedLamports: \"0\",\n30\t};\n31\t\n32\tdescribe(\"GrowthKolTable\", () => {\n33\t  it(\"populated: renders the operator columns, drill-down, formatted lamports, and KOL-side fields\", () => {\n34\t    render(<GrowthKolTable rows={[ROW_KOL, ROW_NEW_KOL]} />);\n35\t\n36\t    expect(screen.getByText(\"User\")).toBeInTheDocument();\n37\t    expect(screen.getByText(\"Wallet\")).toBeInTheDocument();\n38\t    expect(screen.getByText(\"Rate (bps)\")).toBeInTheDocument();\n39\t    expect(screen.getByText(\"Set by\")).toBeInTheDocument();\n40\t    expect(screen.getByText(\"Created\")).toBeInTheDocument();\n41\t    expect(screen.getByText(\"Updated\")).toBeInTheDocument();\n42\t    expect(screen.getByText(\"Referees\")).toBeInTheDocument();\n43\t    expect(screen.getByText(\"Wager (lamports)\")).toBeInTheDocument();\n44\t    expect(screen.getByText(\"Earned (lamports)\")).toBeInTheDocument();\n45\t\n46\t    // Drill-down per row.\n47\t    expect(screen.getByRole(\"link\", { name: \"alice\" })).toHaveAttribute(\n48\t      \"href\",\n49\t      \"/users/u-1\",\n50\t    );\n51\t    // Username-less row falls back to userId as the link label.\n52\t    expect(screen.getByRole(\"link\", { name: \"u-2\" })).toHaveAttribute(\n53\t      \"href\",\n54\t      \"/users/u-2\",\n55\t    );\n56\t\n57\t    // KOL-side fields.\n58\t    expect(screen.getByText(\"250\")).toBeInTheDocument();\n59\t    expect(screen.getByText(\"100\")).toBeInTheDocument();\n60\t    expect(screen.getAllByText(\"admin@example.com\").length).toBe(2);\n61\t\n62\t    // Performance numbers formatted with thousands separator; \"0\" stays bare.\n63\t    expect(screen.getByText(\"8,000,000\")).toBeInTheDocument();\n64\t    expect(screen.getByText(\"200,000\")).toBeInTheDocument();\n65\t  });\n66\t\n67\t  it(\"empty: renders a status block when no KOL rates have been configured\", () => {\n68\t    render(<GrowthKolTable rows={[]} />);\n69\t\n70\t    const status = screen.getByRole(\"status\");\n71\t    expect(status).toHaveTextContent(\"No KOL rates configured.\");\n72\t    expect(status).toHaveTextContent(\"referral_kol_rates\");\n73\t    expect(screen.queryByRole(\"table\")).toBeNull();\n74\t  });\n75\t\n76\t  it(\"error: renders an alert message and hides rows\", () => {\n77\t    render(<GrowthKolTable rows={[ROW_KOL]} error=\"connection refused\" />);\n78\t\n79\t    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n80\t      \"KOL table unavailable: connection refused\",\n81\t    );\n82\t    expect(screen.queryByRole(\"table\")).toBeNull();\n83\t    expect(screen.queryByRole(\"status\")).toBeNull();\n84\t  });\n85\t});\n86\t"}]},"parent_tool_use_id":null,"session_id":"b77bbed1-945f-44ec-8430-ad135cabe0b1","uuid":"b9a3fd4d-9ff2-432d-8137-ce096fe739bb","timestamp":"2026-04-25T14:05:14.518Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/growth-kol-table.test.tsx","content":"import { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { GrowthKolTable } from \"../growth-kol-table\";\nimport type { PeekKolPerformanceRow } from \"../../lib/types/peek\";\n\nconst ROW_KOL: PeekKolPerformanceRow = {\n  userId: \"u-1\",\n  username: \"alice\",\n  wallet: \"wallet-1\",\n  rateBps: 250,\n  setBy: \"admin@example.com\",\n  createdAt: \"2026-04-01T00:00:00.000Z\",\n  updatedAt: \"2026-04-10T00:00:00.000Z\",\n  refereeCount: 12,\n  referredWagerLamports: \"8000000\",\n  referrerEarnedLamports: \"200000\",\n};\n\nconst ROW_NEW_KOL: PeekKolPerformanceRow = {\n  userId: \"u-2\",\n  username: null,\n  wallet: \"wallet-2\",\n  rateBps: 100,\n  setBy: \"admin@example.com\",\n  createdAt: \"2026-04-15T00:00:00.000Z\",\n  updatedAt: \"2026-04-15T00:00:00.000Z\",\n  refereeCount: 0,\n  referredWagerLamports: \"0\",\n  referrerEarnedLamports: \"0\",\n};\n\ndescribe(\"GrowthKolTable\", () => {\n  it(\"populated: renders the operator columns, drill-down, formatted lamports, and KOL-side fields\", () => {\n    render(<GrowthKolTable rows={[ROW_KOL, ROW_NEW_KOL]} />);\n\n    expect(screen.getByText(\"User\")).toBeInTheDocument();\n    expect(screen.getByText(\"Wallet\")).toBeInTheDocument();\n    expect(screen.getByText(\"Rate (bps)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Set by\")).toBeInTheDocument();\n    expect(screen.getByText(\"Created\")).toBeInTheDocument();\n    expect(screen.getByText(\"Updated\")).toBeInTheDocument();\n    expect(screen.getByText(\"Referees\")).toBeInTheDocument();\n    expect(screen.getByText(\"Wager (lamports)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Earned (lamports)\")).toBeInTheDocument();\n\n    // Drill-down per row.\n    expect(screen.getByRole(\"link\", { name: \"alice\" })).toHaveAttribute(\n      \"href\",\n      \"/users/u-1\",\n    );\n    // Username-less row falls back to userId as the link label.\n    expect(screen.getByRole(\"link\", { name: \"u-2\" })).toHaveAttribute(\n      \"href\",\n      \"/users/u-2\",\n    );\n\n    // KOL-side fields.\n    expect(screen.getByText(\"250\")).toBeInTheDocument();\n    expect(screen.getByText(\"100\")).toBeInTheDocument();\n    expect(screen.getAllByText(\"admin@example.com\").length).toBe(2);\n\n    // Performance numbers formatted with thousands separator; \"0\" stays bare.\n    expect(screen.getByText(\"8,000,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"200,000\")).toBeInTheDocument();\n  });\n\n  it(\"empty: renders a status block when no KOL rates have been configured\", () => {\n    render(<GrowthKolTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"No KOL rates configured.\");\n    expect(status).toHaveTextContent(\"referral_kol_rates\");\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert message and hides rows\", () => {\n    render(<GrowthKolTable rows={[ROW_KOL]} error=\"connection refused\" />);\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"KOL table unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n","numLines":86,"startLine":1,"totalLines":86}}}
