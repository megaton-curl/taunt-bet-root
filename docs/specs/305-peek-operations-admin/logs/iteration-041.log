{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01CnAmYGURYtD7r2cY9M2RTU","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01N7NXcyf661pbBFB1SwuAay","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/__tests__/reward-config-table.test.tsx","content":"import { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { RewardConfigTable } from \"../reward-config-table\";\nimport type { PeekRewardConfigRow } from \"../../lib/types/peek\";\n\nconst ROW_KNOWN: PeekRewardConfigRow = {\n  key: \"points_per_dollar\",\n  value: \"10\",\n  updatedAt: \"2026-04-25T10:00:00.000Z\",\n  definition:\n    \"Points granted per USD-equivalent of wager — drives the wager → points conversion rate.\",\n  expectedType: \"integer\",\n};\n\nconst ROW_RATIO: PeekRewardConfigRow = {\n  key: \"reward_pool_fee_share\",\n  value: \"0.25\",\n  updatedAt: \"2026-04-25T10:00:00.000Z\",\n  definition:\n    \"Fraction of platform fee diverted into the reward pool on each settled round (0..1).\",\n  expectedType: \"ratio\",\n};\n\nconst ROW_UNKNOWN: PeekRewardConfigRow = {\n  key: \"experimental_unmapped_key\",\n  value: \"42\",\n  updatedAt: \"2026-04-25T10:00:00.000Z\",\n  definition: null,\n  expectedType: \"unknown\",\n};\n\ndescribe(\"RewardConfigTable\", () => {\n  it(\"populated: renders the operator columns, the type chip, the value, and the inline definition\", () => {\n    render(<RewardConfigTable rows={[ROW_KNOWN, ROW_RATIO]} />);\n\n    expect(screen.getByText(\"Key\")).toBeInTheDocument();\n    expect(screen.getByText(\"Type\")).toBeInTheDocument();\n    expect(screen.getByText(\"Value\")).toBeInTheDocument();\n    expect(screen.getByText(\"Definition\")).toBeInTheDocument();\n    expect(screen.getByText(\"Updated\")).toBeInTheDocument();\n\n    expect(screen.getByText(\"points_per_dollar\")).toBeInTheDocument();\n    expect(screen.getByText(\"reward_pool_fee_share\")).toBeInTheDocument();\n    expect(screen.getByText(\"integer\")).toBeInTheDocument();\n    expect(screen.getByText(\"ratio\")).toBeInTheDocument();\n    expect(screen.getByText(\"10\")).toBeInTheDocument();\n    expect(screen.getByText(\"0.25\")).toBeInTheDocument();\n    expect(\n      screen.getByText(\n        \"Points granted per USD-equivalent of wager — drives the wager → points conversion rate.\",\n      ),\n    ).toBeInTheDocument();\n  });\n\n  it(\"populated: an unknown key surfaces the warning hint instead of faking a definition\", () => {\n    render(<RewardConfigTable rows={[ROW_UNKNOWN]} />);\n\n    expect(screen.getByText(\"experimental_unmapped_key\")).toBeInTheDocument();\n    expect(screen.getByText(\"unknown\")).toBeInTheDocument();\n    expect(\n      screen.getByText(/Unregistered key — extend/i),\n    ).toBeInTheDocument();\n    // The hint mentions the registry symbol so an operator knows where to add the entry.\n    expect(\n      screen.getByText(/PEEK_REWARD_CONFIG_KEY_REGISTRY/i),\n    ).toBeInTheDocument();\n  });\n\n  it(\"empty: renders an operator status block when no reward_config rows exist\", () => {\n    render(<RewardConfigTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"No reward_config rows.\");\n    expect(status).toHaveTextContent(\"reward_config\");\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert message and hides both the table and the empty status\", () => {\n    render(\n      <RewardConfigTable rows={[ROW_KNOWN]} error=\"connection refused\" />,\n    );\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Reward config unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"inp