derRowStyle}>\n58\t            <th style={headerCellStyle(\"left\")}>Key</th>\n59\t            <th style={headerCellStyle(\"left\")}>Type</th>\n60\t            <th style={headerCellStyle(\"right\")}>Value</th>\n61\t            <th style={headerCellStyle(\"left\")}>Definition</th>\n62\t            <th style={headerCellStyle(\"left\")}>Updated</th>\n63\t          </tr>\n64\t        </thead>\n65\t        <tbody>\n66\t          {rows.map((row) => (\n67\t            <tr key={row.key} style={bodyRowStyle}>\n68\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n69\t                {row.key}\n70\t              </td>\n71\t              <td style={bodyCellStyle(\"left\")}>\n72\t                <StatusChip\n73\t                  label={row.expectedType}\n74\t                  tone={TYPE_TONE[row.expectedType]}\n75\t                />\n76\t              </td>\n77\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n78\t                {row.value}\n79\t              </td>\n80\t              <td style={bodyCellStyle(\"left\")}>\n81\t                {row.definition ?? (\n82\t                  <span style={unknownStyle}>\n83\t                    Unregistered key — extend\n84\t                    PEEK_REWARD_CONFIG_KEY_REGISTRY to document this.\n85\t                  </span>\n86\t                )}\n87\t              </td>\n88\t              <td style={bodyCellStyle(\"left\")}>{row.updatedAt}</td>\n89\t            </tr>\n90\t          ))}\n91\t        </tbody>\n92\t      </table>\n93\t    </div>\n94\t  );\n95\t}\n96\t\n97\tconst wrapperStyle: CSSProperties = {\n98\t  overflowX: \"auto\",\n99\t  border: \"1px solid #1e293b\",\n100\t  borderRadius: \"0.75rem\",\n101\t};\n102\t\n103\tconst tableStyle: CSSProperties = {\n104\t  width: \"100%\",\n105\t  borderCollapse: \"collapse\",\n106\t};\n107\t\n108\tconst headerRowStyle: CSSProperties = {\n109\t  background: \"#111827\",\n110\t  color: \"#94a3b8\",\n111\t};\n112