{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013MTxbcYVhzMWPLdXfuco7w","type":"tool_result","content":"1\t// Reward-pool fundings table for /economy/rewards (FR-9).\n2\t//\n3\t// Append-only ledger of per-round funding events. Drill-down to the source\n4\t// round goes via the universal-search entry point on `/?query=...` because\n5\t// `reward_pool_fundings.round_id` is a free-form text identifier without an\n6\t// attached game type — the search resolver groups results by entity type and\n7\t// surfaces the matching round (flipyou/potshot match_id or closecall round\n8\t// PDA) with a direct `/games/[game]/rounds/[roundId]` link.\n9\timport Link from \"next/link\";\n10\timport type { CSSProperties } from \"react\";\n11\timport type { PeekRewardPoolFundingRow } from \"../lib/types/peek\";\n12\t\n13\texport type RewardPoolFundingsTableProps = {\n14\t  rows: ReadonlyArray<PeekRewardPoolFundingRow>;\n15\t  error?: string | null;\n16\t};\n17\t\n18\texport function RewardPoolFundingsTable({\n19\t  rows,\n20\t  error = null,\n21\t}: RewardPoolFundingsTableProps) {\n22\t  if (error) {\n23\t    return (\n24\t      <div role=\"alert\" style={errorStyle}>\n25\t        Reward pool fundings unavailable: {error}\n26\t      </div>\n27\t    );\n28\t  }\n29\t\n30\t  if (rows.length === 0) {\n31\t    return (\n32\t      <div role=\"status\" style={emptyStyle}>\n33\t        <p style={emptyTitleStyle}>No reward_pool_fundings rows.</p>\n34\t        <p style={emptyBodyStyle}>\n35\t          No settled rounds have funded the reward pool yet, so the ledger is\n36\t          empty.\n37\t        </p>\n38\t      </div>\n39\t    );\n40\t  }\n41\t\n42\t  return (\n43\t    <div style={wrapperStyle}>\n44\t      <table style={tableStyle}>\n45\t        <thead>\n46\t          <tr style={headerRowStyle}>\n47\t            <th style={headerCellStyle(\"left\")}>Created</th>\n48\t            <th style={headerCellStyle(\"left\")}>Source round</th>\n49\t            <th style={headerCellStyle(\"right\")}>Fee (lamports)</th>\n50\t            <th style={headerCellStyle(\"right\")}>Funded (lamports)</th>\n51\t            <th style={headerCellStyle(\"right\")}>Funding ID</th>\n52\t          </tr>\n53\t        </thead>\n54\t        <tbody>\n55\t          {rows.map((row) => (\n56\t            <tr key={row.id} style={bodyRowStyle}>\n57\t              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n58\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n59\t                <Link\n60\t                  href={`/?query=${encodeURIComponent(row.roundId)}`}\n61\t                  style={linkStyle}\n62\t                  title={`Open universal search for round ${row.roundId}`}\n63\t                >\n64\t                  {row.roundId}\n65\t                </Link>\n66\t              </td>\n67\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n68\t                {formatLamports(row.feeLamports)}\n69\t              </td>\n70\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n71\t                {formatLamports(row.fundedLamports)}\n72\t              </td>\n73\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n74\t                {row.id}\n75\t              </td>\n76\t            </tr>\n77\t          ))}\n78\t        </tbody>\n79\t      </table>\n80\t    </div>\n81\t  );\n82\t}\n83\t\n84\tfunction formatLamports(value: string): string {\n85\t  if (!value || value === \"0\") return \"0\";\n86\t  const negative = value.startsWith(\"-\");\n87\t  const digits = negative ? value.slice(1) : value;\n88\t  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n89\t  return negative ? `-${grouped}` : grouped;\n90\t}\n91\t\n92\tconst wrapperStyle: CSSProperties = {\n93\t  overflowX: \"auto\",\n94\t  border: \"1px solid #1e293b\",\n95\t  borderRadius: \"0.75rem\",\n96\t};\n97\t\n98\tconst tableStyle: CSSProperties = {\n99\t  width: \"100%\",\n100\t  borderCollapse: \"collapse\",\n101\t};\n102\t\n103\tconst headerRowStyle: CSSProperties = {\n104\t  background: \"#111827\",\n105\t  color: \"#94a3b8\",\n106\t};\n107\t\n108\tconst bodyRowStyle: CSSProperties = {\n109\t  borderTop: \"1px solid #1e293b\",\n110\t};\n111\t\n112\tconst linkStyle: CSSProperties = {\n113\t  color: \"#93c5fd\",\n114\t  textDecoration: \"none\",\n115\t};\n116\t\n117\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n118\t  return {\n119\t    padding: \"0.75rem\",\n120\t    textAlign: align,\n121\t    fontSize: \"0.875rem\",\n122\t    fontWeight: 600,\n123\t  };\n124\t}\n125\t\n126\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n127\t  return {\n128\t    padding: \"0.75rem\",\n129\t    textAlign: align,\n130\t    fontSize: \"0.875rem\",\n131\t    color: \"#e2e8f0\",\n132\t  };\n133\t}\n134\t\n135\tconst errorStyle: CSSProperties = {\n136\t  margin: 0,\n137\t  padding: \"0.75rem 1rem\",\n138\t  borderRadius: \"0.75rem\",\n139\t  background: \"#3f1d1d\",\n140\t  color: \"#fecaca\",\n141\t};\n142\t\n143\tconst emptyStyle: CSSProperties = {\n144\t  padding: \"1.5rem\",\n145\t  borderRadius: \"0.75rem\",\n146\t  border: \"1px dashed #334155\",\n147\t  background: \"#0b1220\",\n148\t  color: \"#cbd5f5\",\n149\t  display: \"grid\",\n150\t  gap: \"0.5rem\",\n151\t};\n152\t\n153\tconst emptyTitleStyle: CSSProperties = {\n154\t  margin: 0,\n155\t  fontSize: \"1rem\",\n156\t  fontWeight: 600,\n157\t};\n158\t\n159\tconst emptyBodyStyle: CSSProperties = {\n160\t  margin: 0,\n161\t  fontSize: \"0.875rem\",\n162\t  color: \"#94a3b8\",\n163\t};\n164\t"}]},"parent_tool_use_id":null,"session_id":"b77bbed1-945f-44ec-8430-ad135cabe0b1","uuid":"741404fd-158c-4339-8ddc-f4b7e83869b0","timestamp":"2026-04-25T14:05:11.347Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/reward-pool-fundings-table.tsx","content":"// Reward-pool fundings table for /economy/rewards (FR-9).\n//\n// Append-only ledger of per-round funding events. Drill-down to the source\n// round goes via the universal-search entry point on `/?query=...` because\n// `reward_pool_fundings.round_id` is a free-form text identifier without an\n// attached game type — the search resolver groups results by entity type and\n// surfaces the matching round (flipyou/potshot match_id or closecall round\n// PDA) with a direct `/games/[game]/rounds/[roundId]` link.\nimport Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type { PeekRewardPoolFundingRow } from \"../lib/types/peek\";\n\nexport type RewardPoolFundingsTableProps = {\n  rows: ReadonlyArray<PeekRewardPoolFundingRow>;\n  error?: string | null;\n};\n\nexport function RewardPoolFundingsTable({\n  rows,\n  error = null,\n}: RewardPoolFundingsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Reward pool fundings unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No reward_pool_fundings rows.</p>\n        <p style={emptyBodyStyle}>\n          No settled rounds have funded the reward pool yet, so the ledger is\n          empty.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>Source round</th>\n            <th style={headerCellStyle(\"right\")}>Fee (lamports)</th>\n            <th style={headerCellStyle(\"right\")}>Funded (lamports)</th>\n            <th style={headerCellStyle(\"right\")}>Funding ID</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <Link\n                  href={`/?query=${encodeURIComponent(row.roundId)}`}\n                  style={linkStyle}\n                  title={`Open universal search for round ${row.roundId}`}\n                >\n                  {row.roundId}\n                </Link>\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {formatLamports(row.feeLamports)}\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {formatLamports(row.fundedLamports)}\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.id}\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction formatLamports(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":164,"startLine":1,"totalLines":164}}}
