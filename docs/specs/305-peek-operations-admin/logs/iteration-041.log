{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0132pKYvmtL1he2LBxMi9uEs","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport type { Sql } from \"postgres\";\n3\timport {\n4\t  PEEK_GROWTH_CLAIMS_DEFAULT_LIMIT,\n5\t  PEEK_GROWTH_CLAIMS_MAX_LIMIT,\n6\t  PEEK_GROWTH_KOL_DEFAULT_LIMIT,\n7\t  PEEK_GROWTH_KOL_MAX_LIMIT,\n8\t  PEEK_GROWTH_TOP_REFERRERS_DEFAULT_LIMIT,\n9\t  PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT,\n10\t  getGrowthReferralOverview,\n11\t  getReferralGraphNode,\n12\t  listKolPerformance,\n13\t  listReferralClaims,\n14\t  listTopReferrers,\n15\t} from \"../get-growth-referrals\";\n16\timport {\n17\t  PEEK_GROWTH_OVERVIEW_METRIC_IDS,\n18\t  type PeekGrowthOverviewMetricId,\n19\t} from \"../../../../lib/types/peek\";\n20\t\n21\ttype SqlCall = {\n22\t  text: string;\n23\t  values: ReadonlyArray<unknown>;\n24\t};\n25\t\n26\ttype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n27\t\n28\ttype SqlMock = {\n29\t  sql: Sql;\n30\t  calls: ReadonlyArray<SqlCall>;\n31\t};\n32\t\n33\t// SQL mock that tracks every tagged-template call and returns a queued\n34\t// response per call (rows or an Error to reject). Mirrors the pattern used\n35\t// in get-command-center-attention.test.ts so behaviour stays consistent\n36\t// across query test modules.\n37\tfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n38\t  const calls: SqlCall[] = [];\n39\t  let cursor = 0;\n40\t\n41\t  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n42\t    const text = [...strings].join(\"?\");\n43\t    calls.push({ text, values: [...values] });\n44\t    const next = responses[cursor++];\n45\t    if (next instanceof Error) return Promise.reject(next);\n46\t    return Promise.resolve(next ?? []);\n47\t  };\n48\t\n49\t  const sql = fn as unknown as Sql;\n50\t  return { sql, calls };\n51\t}\n52\t\n53\t// Eight overview queries fire in parallel via Promise.all. Order:\n54\t// 0 referrers, 1 referredUsers, 2 activatedReferred, 3 referrerEarnings,\n55\t// 4 refereeRebates, 5 pendingClaimsLamports, 6 failedClaims, 7 kolCount.\n56\tconst OVERVIEW_ORDER: ReadonlyArray<PeekGrowthOverviewMetricId> = [\n57\t  \"growth.referrers\",\n58\t  \"growth.referred_users\",\n59\t  \"growth.activated_referred_users\",\n60\t  \"growth.referrer_earnings_lamports\",\n61\t  \"growth.referee_rebates_lamports\",\n62\t  \"growth.pending_claims_lamports\",\n63\t  \"growth.failed_claims\",\n64\t  \"growth.kol_count\",\n65\t];\n66\t\n67\tdescribe(\"getGrowthReferralOverview\", () => {\n68\t  it(\"populated: emits one PeekMetric per FR-4 id with correct values, units, and bookkeeping\", async () => {\n69\t    const mock = createSqlMock([\n70\t      [{ value: 5 }],\n71\t      [{ value: 12 }],\n72\t      [{ value: 7 }],\n73\t      [{ value: \"1500000000\" }],\n74\t      [{ value: \"750000000\" }],\n75\t      [{ value: \"300000000\" }],\n76\t      [{ value: 2 }],\n77\t      [{ value: 3 }],\n78\t    ]);\n79\t    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n80\t\n81\t    const result = await getGrowthReferralOverview({ sql: mock.sql, now });\n82\t\n83\t    expect(result.generatedAt).toBe(\"2026-04-25T10:00:00.000Z\");\n84\t    expect(result.metrics).toHaveLength(8);\n85\t    expect(result.metrics.map((m) => m.id)).toEqual(OVERVIEW_ORDER);\n86\t    // Every advertised id from the type union is emitted.\n87\t    for (const id of PEEK_GROWTH_OVERVIEW_METRIC_IDS) {\n88\t      expect(result.metrics.find((m) => m.id === id)).toBeDefined();\n89\t    }\n90\t    for (const metric of result.metrics) {\n91\t      expect(metric.asOf).toBe(\"2026-04-25T10:00:00.000Z\");\n92\t      expect(metric.freshness).toBe(\"live\");\n93\t      expect(metric.label.length).toBeGreaterThan(0);\n94\t      expect(metric.definition.length).toBeGreaterThan(0);\n95\t      expect(metric.source.length).toBeGreaterThan(0);\n96\t      expect(metric.windowLabel.length).toBeGreaterThan(0);\n97\t      expect(metric.drilldownHref).not.toBeNull();\n98\t    }\n99\t\n100\t    const byId = new Map(result.metrics.map((m) => [m.id, m]));"}]},"parent_tool_use_id":null,"session_id":"b77bbed1-945f-44ec-8430-ad135cabe0b1","uuid":"bac28086-bfb7-4d8f-b5c6-c7a26d19db00","timestamp":"2026-04-25T14:04:56.582Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-growth-referrals.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_GROWTH_CLAIMS_DEFAULT_LIMIT,\n  PEEK_GROWTH_CLAIMS_MAX_LIMIT,\n  PEEK_GROWTH_KOL_DEFAULT_LIMIT,\n  PEEK_GROWTH_KOL_MAX_LIMIT,\n  PEEK_GROWTH_TOP_REFERRERS_DEFAULT_LIMIT,\n  PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT,\n  getGrowthReferralOverview,\n  getReferralGraphNode,\n  listKolPerformance,\n  listReferralClaims,\n  listTopReferrers,\n} from \"../get-growth-referrals\";\nimport {\n  PEEK_GROWTH_OVERVIEW_METRIC_IDS,\n  type PeekGrowthOverviewMetricId,\n} from \"../../../../lib/types/peek\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\n// SQL mock that tracks every tagged-template call and returns a queued\n// response per call (rows or an Error to reject). Mirrors the pattern used\n// in get-command-center-attention.test.ts so behaviour stays consistent\n// across query test modules.\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\n// Eight overview queries fire in parallel via Promise.all. Order:\n// 0 referrers, 1 referredUsers, 2 activatedReferred, 3 referrerEarnings,\n// 4 refereeRebates, 5 pendingClaimsLamports, 6 failedClaims, 7 kolCount.\nconst OVERVIEW_ORDER: ReadonlyArray<PeekGrowthOverviewMetricId> = [\n  \"growth.referrers\",\n  \"growth.referred_users\",\n  \"growth.activated_referred_users\",\n  \"growth.referrer_earnings_lamports\",\n  \"growth.referee_rebates_lamports\",\n  \"growth.pending_claims_lamports\",\n  \"growth.failed_claims\",\n  \"growth.kol_count\",\n];\n\ndescribe(\"getGrowthReferralOverview\", () => {\n  it(\"populated: emits one PeekMetric per FR-4 id with correct values, units, and bookkeeping\", async () => {\n    const mock = createSqlMock([\n      [{ value: 5 }],\n      [{ value: 12 }],\n      [{ value: 7 }],\n      [{ value: \"1500000000\" }],\n      [{ value: \"750000000\" }],\n      [{ value: \"300000000\" }],\n      [{ value: 2 }],\n      [{ value: 3 }],\n    ]);\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getGrowthReferralOverview({ sql: mock.sql, now });\n\n    expect(result.generatedAt).toBe(\"2026-04-25T10:00:00.000Z\");\n    expect(result.metrics).toHaveLength(8);\n    expect(result.metrics.map((m) => m.id)).toEqual(OVERVIEW_ORDER);\n    // Every advertised id from the type union is emitted.\n    for (const id of PEEK_GROWTH_OVERVIEW_METRIC_IDS) {\n      expect(result.metrics.find((m) => m.id === id)).toBeDefined();\n    }\n    for (const metric of result.metrics) {\n      expect(metric.asOf).toBe(\"2026-04-25T10:00:00.000Z\");\n      expect(metric.freshness).toBe(\"live\");\n      expect(metric.label.length).toBeGreaterThan(0);\n      expect(metric.definition.length).toBeGreaterThan(0);\n      expect(metric.source.length).toBeGreaterThan(0);\n      expect(metric.windowLabel.length).toBeGreaterThan(0);\n      expect(metric.drilldownHref).not.toBeNull();\n    }\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));","numLines":100,"startLine":1,"totalLines":566}}}
