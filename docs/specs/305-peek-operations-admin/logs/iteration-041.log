ext(\"Funding ID\")).toBeInTheDocument();\n\n    expect(screen.getByText(\"200,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"150,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"1,000,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"750,000\")).toBeInTheDocument();\n    expect(\n      screen.getByText(\"2026-04-25T10:00:00.000Z\"),\n    ).toBeInTheDocument();\n    expect(\n      screen.getByText(\"2026-04-25T11:00:00.000Z\"),\n    ).toBeInTheDocument();\n  });\n\n  it(\"populated: source round drills into universal search for the round id (FR-9 funding-source linkage)\", () => {\n    render(<RewardPoolFundingsTable rows={[ROW_FLIPYOU]} />);\n\n    // The funding ledger has no game column — drill-down is intentionally\n    // routed through `/?query=<roundId>` so universal search resolves to the\n    // matching flipyou/potshot/closecall round and surfaces the direct\n    // /games/[game]/rounds/[roundId] link.\n    const link = screen.getByRole(\"link\", { name: \"match-abc-123\" });\n    expect(link).toHaveAttribute(\n      \"href\",\n      `/?query=${encodeURIComponent(\"match-abc-123\")}`,\n    );\n    expect(link).toHaveAttribute(\n      \"title\",\n      \"Open universal search for round match-abc-123\",\n    );\n  });\n\n  it(\"populated: closecall PDA-style round ids are encoded into the search query just like match ids\", () => {\n    render(<RewardPoolFundingsTable rows={[ROW_CLOSECALL]} />);\n\n    const link = screen.getByRole(\"link\", { name: \"CCpda1234567890\" });\n    expect(link).toHaveAttribute(\n      \"href\",\n      `/?query=${encodeURIComponent(\"CCpda1234567890\")}`,\n    );\n  });\n\n  it(\"populated: zero-funded rows render bare '0' in fee + funded cells\", () => {\n    render(<RewardPoolFundingsTable rows={[ROW_ZEROES]} />);\n\n    const row = screen.getByText(\"round-zero\").closest(\"tr\")!;\n    // fee + funded both render bare \"0\".\n    expect(row.textContent).toContain(\"0\");\n  });\n\n  it(\"empty: renders an operator status block when the ledger has no rows\", () => {\n    render(<RewardPoolFundingsTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"No reward_pool_fundings rows.\");\n    expect(status).toHaveTextContent(\n      \"No settled rounds have funded the reward pool yet\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert message and hides both the table and the empty status\", () => {\n    render(\n      <RewardPoolFundingsTable\n        rows={[ROW_FLIPYOU]}\n        error=\"connection refused\"\n      />,\n    );\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Reward pool fundings unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
