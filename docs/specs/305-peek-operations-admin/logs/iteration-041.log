{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_018VfbZptEExmM56DQSkoegA","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01LJV3sAB6MozAcf1muSRcDV","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-rewards.test.ts","content":"// Query tests for the FR-9 reward-economy admin reads (`get-rewards.ts`).\n//\n// Mirrors the SQL-mock pattern used in `get-growth-referrals.test.ts` and\n// `get-command-center-attention.test.ts`: a tagged-template stub records each\n// call (joined SQL text + bound values) and dequeues a per-call response so\n// each test can assert which SQL fired, in what order, and with which clamps.\n\nimport { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS,\n  PEEK_REWARD_CONFIG_KEY_REGISTRY,\n  PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT,\n  PEEK_REWARD_POOL_FUNDINGS_MAX_LIMIT,\n  getRewardPool,\n  getRewardsOverview,\n  listRewardConfig,\n  listRewardPoolFundings,\n} from \"../get-rewards\";\nimport {\n  PEEK_REWARDS_OVERVIEW_METRIC_IDS,\n  type PeekRewardsOverviewMetricId,\n} from \"../../../../lib/types/peek\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\n// `getRewardsOverview` runs two queries in parallel via Promise.all:\n// 0 = reward_pool singleton read, 1 = recent fundings count.\nconst OVERVIEW_ORDER: ReadonlyArray<PeekRewardsOverviewMetricId> = [\n  \"rewards.balance_lamports\",\n  \"rewards.lifetime_funded_lamports\",\n  \"rewards.lifetime_paid_lamports\",\n  \"rewards.recent_fundings\",\n];\n\ndescribe(\"listRewardConfig\", () => {\n  it(\"populated: annotates known keys with definition + expected type from the registry\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          key: \"points_per_dollar\",\n          value: \"10\",\n          updatedAt: \"2026-04-20T00:00:00.000Z\",\n        },\n        {\n          key: \"reward_pool_fee_share\",\n          value: \"0.25\",\n          updatedAt: \"2026-04-21T00:00:00.000Z\",\n        },\n      ],\n    ]);\n\n    const rows = await listRewardConfig({ sql: mock.sql });\n\n    expect(rows).toHaveLength(2);\n    const byKey = new Map(rows.map((r) => [r.key, r]));\n    const points = byKey.get(\"points_per_dollar\");\n    expect(points?.value).toBe(\"10\");\n    expect(points?.expectedType).toBe(\n      PEEK_REWARD_CONFIG_KEY_REGISTRY.points_per_dollar?.expectedType,\n    );\n    expect(points?.definition).toBe(\n      PEEK_REWARD_CONFIG_KEY_REGISTRY.points_per_dollar?.definition,\n    );\n    const ratio = byKey.get(\"reward_pool_fee_share\");\n    expect(ratio?.expectedType).toBe(\"ratio\");\n    expect(ratio?.definition).not.toBeNull();\n  });\n\n  it(\"populated: unknown keys still surface with definition: null + expectedType: 'unknown'\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          key: \"experimental_unmapped_key\",\n          value: \"42\",\n          updatedAt: \"2026-04-25T00:00:00.000Z\",\n        },\n      ],\n    ]);\n\n    const rows = await listRewardConfig({ sql: mock.sql });\n\n    expect(rows).toHaveLength(1);\n    expect(rows[0]).toEqual({\n      key: \"experimental_unmapped_key\",\n      value: \"42\",\n      updatedAt: \"2026-04-25T00:00:00.000Z\",\n      definition: null,\n      expectedType: \"unknown\",\n    });\n  });\n\n  it(\"empty: returns an empty array when the table is empty\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listRewardConfig({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"reads from reward_config ordered by key asc\", async () => {\n    const mock = createSqlMock([[]]);\n    await listRewardConfig({ sql: mock.sql });\n    expect(mock.calls).toHaveLength(1);\n    expect(mock.calls[0].text).toMatch(/from reward_config/i);\n    expect(mock.calls[0].text).toMatch(/order by key asc/i);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"connection refused\")]);\n    await expect(listRewardConfig({ sql: mock.sql })).rejects.toThrowError(\n      \"connection refused\",\n    );\n  });\n});\n\ndescribe(\"getRewardPool\", () => {\n  it(\"populated: returns the singleton row with all four lamport/timestamp fields\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          balanceLamports: \"1500000000\",\n          lifetimeFunded: \"9000000000\",\n          lifetimePaid: \"7500000000\",\n          updatedAt: \"2026-04-25T10:00:00.000Z\",\n        },\n      ],\n    ]);\n\n    const pool = await getRewardPool({ sql: mock.sql });\n\n    expect(pool).toEqual({\n      balanceLamports: \"1500000000\",\n      lifetimeFunded: \"9000000000\",\n      lifetimePaid: \"7500000000\",\n      updatedAt: \"2026-04-25T10:00:00.000Z\",\n    });\n  });\n\n  it(\"populated: null/empty lamport columns coerce to '0' via readSum\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          balanceLamports: null,\n          lifetimeFunded: \"\",\n          lifetimePaid: undefined,\n          updatedAt: \"2026-04-25T10:00:00.000Z\",\n        },\n      ],\n    ]);\n\n    const pool = await getRewardPool({ sql: mock.sql });\n\n    expect(pool).toEqual({\n      balanceLamports: \"0\",\n      lifetimeFunded: \"0\",\n      lifetimePaid: \"0\",\n      updatedAt: \"2026-04-25T10:00:00.000Z\",\n    });\n  });\n\n  it(\"empty (singleton missing): returns null instead of throwing\", async () => {\n    const mock = createSqlMock([[]]);\n    const pool = await getRewardPool({ sql: mock.sql });\n    expect(pool).toBeNull();\n  });\n\n  it(\"reads reward_pool where id = 1 limit 1\", async () => {\n    const mock = createSqlMock([[]]);\n    await getRewardPool({ sql: mock.sql });\n    expect(mock.calls).toHaveLength(1);\n    expect(mock.calls[0].text).toMatch(/from reward_pool/i);\n    expect(mock.calls[0].text).toMatch(/where id = 1/i);\n    expect(mock.calls[0].text).toMatch(/limit 1/i);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"db down\")]);\n    await expect(getRewardPool({ sql: mock.sql })).rejects.toThrowError(\n      \"db down\",\n    );\n  });\n});\n\ndescribe(\"listRewardPoolFundings\", () => {\n  it(\"default limit: clamps to PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT and reads the ledger\", async () => {\n    const mock = createSqlMock([[]]);\n    await listRewardPoolFundings({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expect(call.text).toMatch(/from reward_pool_fundings/i);\n    expect(call.text).toMatch(/order by created_at desc, id desc/i);\n    expect(call.values).toContain(PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT);\n  });\n\n  it(\"explicit limit: passes the caller value through clampLimit\", async () => {\n    const mock = createSqlMock([[]]);\n    await listRewardPoolFundings({ sql: mock.sql, limit: 25 });\n    expect(mock.calls[0].values).toContain(25);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listRewardPoolFundings({\n      sql: mock.sql,\n      limit: PEEK_REWARD_POOL_FUNDINGS_MAX_LIMIT + 100,\n    });\n    expect(mock.calls[0].values).toContain(\n      PEEK_REWARD_POOL_FUNDINGS_MAX_LIMIT,\n    );\n  });\n\n  it(\"non-positive limit clamps to 1\", async () => {\n    const mock = createSqlMock([[]]);\n    await listRewardPoolFundings({ sql: mock.sql, limit: 0 });\n    expect(mock.calls[0].values).toContain(1);\n  });\n\n  it(\"non-finite limit falls back to the default\", async () => {\n    const mock = createSqlMock([[]]);\n    await listRewardPoolFundings({ sql: mock.sql, limit: Number.NaN });\n    expect(mock.calls[0].values).toContain(\n      PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT,\n    );\n  });\n\n  it(\"populated: returns rows with the funding-source linkage (roundId from reward_pool_fundings.round_id)\", async () => {\n    const row = {\n      id: \"42\",\n      roundId: \"match-abc-123\",\n      feeLamports: \"200000\",\n      fundedLamports: \"150000\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n    };\n    const mock = createSqlMock([[row]]);\n\n    const rows = await listRewardPoolFundings({ sql: mock.sql });\n\n    expect(rows).toEqual([row]);\n    // The funding source linkage comes back via the `roundId` field. The\n    // page wires this through universal search (`/?query=<roundId>`); the\n    // query itself just has to surface the column.\n    expect(rows[0].roundId).toBe(\"match-abc-123\");\n  });\n\n  it(\"empty: returns an empty array when no fundings exist\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listRewardPoolFundings({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"query timeout\")]);\n    await expect(\n      listRewardPoolFundings({ sql: mock.sql }),\n    ).rejects.toThrowError(\"query timeout\");\n  });\n});\n\ndescribe(\"getRewardsOverview\", () => {\n  it(\"populated: emits one PeekMetric per FR-4 id with correct values, units, and bookkeeping\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          balanceLamports: \"1500000000\",\n          lifetimeFunded: \"9000000000\",\n          lifetimePaid: \"7500000000\",\n        },\n      ],\n      [{ value: 7 }],\n    ]);\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getRewardsOverview({ sql: mock.sql, now });\n\n    expect(result.generatedAt).toBe(\"2026-04-25T10:00:00.000Z\");\n    expect(result.metrics).toHaveLength(4);\n    expect(result.metrics.map((m) => m.id)).toEqual(OVERVIEW_ORDER);\n    for (const id of PEEK_REWARDS_OVERVIEW_METRIC_IDS) {\n      expect(result.metrics.find((m) => m.id === id)).toBeDefined();\n    }\n    for (const metric of result.metrics) {\n      expect(metric.asOf).toBe(\"2026-04-25T10:00:00.000Z\");\n      expect(metric.freshness).toBe(\"live\");\n      expect(metric.label.length).toBeGreaterThan(0);\n      expect(metric.definition.length).toBeGreaterThan(0);\n      expect(metric.source.length).toBeGreaterThan(0);\n      expect(metric.windowLabel.length).toBeGreaterThan(0);\n      expect(metric.drilldownHref).not.toBeNull();\n    }\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"rewards.balance_lamports\")?.value).toBe(\"1500000000\");\n    expect(byId.get(\"rewards.balance_lamports\")?.valueDisplay).toBe(\n      \"1,500,000,000\",\n    );\n    expect(byId.get(\"rewards.balance_lamports\")?.unit).toBe(\"lamports\");\n    expect(byId.get(\"rewards.balance_lamports\")?.drilldownHref).toBe(\n      \"/economy/rewards#pool\",\n    );\n\n    expect(byId.get(\"rewards.lifetime_funded_lamports\")?.value).toBe(\n      \"9000000000\",\n    );\n    expect(\n      byId.get(\"rewards.lifetime_funded_lamports\")?.valueDisplay,\n    ).toBe(\"9,000,000,000\");\n    expect(\n      byId.get(\"rewards.lifetime_funded_lamports\")?.drilldownHref,\n    ).toBe(\"/economy/rewards#fundings\");\n\n    expect(byId.get(\"rewards.lifetime_paid_lamports\")?.value).toBe(\n      \"7500000000\",\n    );\n    expect(byId.get(\"rewards.lifetime_paid_lamports\")?.valueDisplay).toBe(\n      \"7,500,000,000\",\n    );\n\n    expect(byId.get(\"rewards.recent_fundings\")?.value).toBe(7);\n    expect(byId.get(\"rewards.recent_fundings\")?.valueDisplay).toBe(\"7\");\n    expect(byId.get(\"rewards.recent_fundings\")?.unit).toBe(\"events\");\n    expect(byId.get(\"rewards.recent_fundings\")?.drilldownHref).toBe(\n      \"/economy/rewards#fundings\",\n    );\n  });\n\n  it(\"populated (large recent fundings): formats valueDisplay with thousands separator\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          balanceLamports: \"0\",\n          lifetimeFunded: \"0\",\n          lifetimePaid: \"0\",\n        },\n      ],\n      [{ value: 1234 }],\n    ]);\n    const result = await getRewardsOverview({ sql: mock.sql });\n    const recent = result.metrics.find(\n      (m) => m.id === \"rewards.recent_fundings\",\n    );\n    expect(recent?.value).toBe(1234);\n    expect(recent?.valueDisplay).toBe(\"1,234\");\n  });\n\n  it(\"sparse (singleton missing): every lamport metric coerces to '0' and recent fundings to 0 without dropping a metric\", async () => {\n    const mock = createSqlMock([[], []]);\n\n    const result = await getRewardsOverview({ sql: mock.sql });\n\n    expect(result.metrics).toHaveLength(4);\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"rewards.balance_lamports\")?.value).toBe(\"0\");\n    expect(byId.get(\"rewards.balance_lamports\")?.valueDisplay).toBe(\"0\");\n    expect(byId.get(\"rewards.lifetime_funded_lamports\")?.value).toBe(\"0\");\n    expect(byId.get(\"rewards.lifetime_paid_lamports\")?.value).toBe(\"0\");\n    expect(byId.get(\"rewards.recent_fundings\")?.value).toBe(0);\n    expect(byId.get(\"rewards.recent_fundings\")?.valueDisplay).toBe(\"0\");\n  });\n\n  it(\"string count coercion: a postgres ::int count served as a string converts to a number\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          balanceLamports: \"0\",\n          lifetimeFunded: \"0\",\n          lifetimePaid: \"0\",\n        },\n      ],\n      [{ value: \"9\" }],\n    ]);\n    const result = await getRewardsOverview({ sql: mock.sql });\n    const recent = result.metrics.find(\n      (m) => m.id === \"rewards.recent_fundings\",\n    );\n    expect(recent?.value).toBe(9);\n  });\n\n  it(\"recent fundings window: default window label uses PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS and binds the matching `since` timestamp\", async () => {\n    const mock = createSqlMock([\n      [{ balanceLamports: \"0\", lifetimeFunded: \"0\", lifetimePaid: \"0\" }],\n      [{ value: 0 }],\n    ]);\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getRewardsOverview({ sql: mock.sql, now });\n    const recent = result.metrics.find(\n      (m) => m.id === \"rewards.recent_fundings\",\n    );\n    expect(recent?.windowLabel).toBe(\n      `Last ${PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS}h`,\n    );\n\n    // The fundings query (call index 1) binds the cutoff timestamp.\n    const since = new Date(\n      now.getTime() -\n        PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS * 60 * 60 * 1000,\n    ).toISOString();\n    expect(mock.calls[1].values).toContain(since);\n  });\n\n  it(\"recent fundings window: caller-provided window flows into the window label and the `since` cutoff\", async () => {\n    const mock = createSqlMock([\n      [{ balanceLamports: \"0\", lifetimeFunded: \"0\", lifetimePaid: \"0\" }],\n      [{ value: 0 }],\n    ]);\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getRewardsOverview({\n      sql: mock.sql,\n      now,\n      recentFundingsWindowHours: 6,\n    });\n    const recent = result.metrics.find(\n      (m) => m.id === \"rewards.recent_fundings\",\n    );\n    expect(recent?.windowLabel).toBe(\"Last 6h\");\n    const since = new Date(\n      now.getTime() - 6 * 60 * 60 * 1000,\n    ).toISOString();\n    expect(mock.calls[1].values).toContain(since);\n  });\n\n  it(\"load-error: a rejected query propagates so the page can render the alert state\", async () => {\n    const mock = createSqlMock([\n      new Error(\"connection refused\"),\n      [{ value: 0 }],\n    ]);\n    await expect(\n      getRewardsOverview({ sql: mock.sql }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n\n  it(\"queries fire in parallel: the second SQL call sees the second response even though both run via Promise.all\", async () => {\n    const mock = createSqlMock([\n      [{ balanceLamports: \"10\", lifetimeFunded: \"10\", lifetimePaid: \"0\" }],\n      [{ value: 3 }],\n    ]);\n    await getRewardsOverview({ sql: mock.sql });\n    expect(mock.calls).toHaveLength(2);\n    expect(mock.calls[0].text).toMatch(/from reward_pool/i);\n    expect(mock.calls[1].text).toMatch(/from reward_pool_fundings/i);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":479,"cache_read_input_tokens":100687,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":479},"output_tokens":6,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"b77bbed1-945f-44ec-8430-ad135cabe0b1","uuid":"903a5193-c19a-48b9-b00d-09e660020553"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LJV3sAB6MozAcf1muSRcDV","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-rewards.test.ts"}]},"parent_tool_use_id":null,"session_id":"b77bbed1-945f-44ec-8430-ad135cabe0b1","uuid":"e4fa37b0-48bc-4f00-9cca-a5e22bf9c825","timestamp":"2026-04-25T14:07:13.180Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-rewards.test.ts","content":"// Query tests for the FR-9 reward-economy admin reads (`get-rewards.ts`).\n//\n// Mirrors the SQL-mock pattern used in `get-growth-referrals.test.ts` and\n// `get-command-center-attention.test.ts`: a tagged-template stub records each\n// call (joined SQL text + bound values) and dequeues a per-call response so\n// each test can assert which SQL fired, in what order, and with which clamps.\n\nimport { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS,\n  PEEK_REWARD_CONFIG_KEY_REGISTRY,\n  PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT,\n  PEEK_REWARD_POOL_FUNDINGS_MAX_LIMIT,\n  getRewardPool,\n  getRewardsOverview,\n  listRewardConfig,\n  listRewardPoolFundings,\n} from \"../get-rewards\";\nimport {\n  PEEK_REWARDS_OVERVIEW_METRIC_IDS,\n  type PeekRewardsOverviewMetricId,\n} from \"../../../../lib/types/peek\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\n// `getRewardsOverview` runs two queries in parallel via Promise.all:\n// 0 = reward_pool singleton read, 1 = recent fundings count.\nconst OVERVIEW_ORDER: ReadonlyArray<PeekRewardsOverviewMetricId> = [\n  \"rewards.balance_lamports\",\n  \"rewards.lifetime_funded_lamports\",\n  \"rewards.lifetime_paid_lamports\",\n  \"rewards.recent_fundings\",\n];\n\ndescribe(\"listRewardConfig\", () => {\n  it(\"populated: annotates known keys with definition + expected type from the registry\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          key: \"points_per_dollar\",\n          value: \"10\",\n          updatedAt: \"2026-04-20T00:00:00.000Z\",\n        },\n        {\n          key: \"reward_pool_fee_share\",\n          value: \"0.25\",\n          updatedAt: \"2026-04-21T00:00:00.000Z\",\n        },\n      ],\n    ]);\n\n    const rows = await listRewardConfig({ sql: mock.sql });\n\n    expect(rows).toHaveLength(2);\n    const byKey = new Map(rows.map((r) => [r.key, r]));\n    const points = byKey.get(\"points_per_dollar\");\n    expect(points?.value).toBe(\"10\");\n    expect(points?.expectedType).toBe(\n      PEEK_REWARD_CONFIG_KEY_REGISTRY.points_per_dollar?.expectedType,\n    );\n    expect(points?.definition).toBe(\n      PEEK_REWARD_CONFIG_KEY_REGISTRY.points_per_dollar?.definition,\n    );\n    const ratio = byKey.get(\"reward_pool_fee_share\");\n    expect(ratio?.expectedType).toBe(\"ratio\");\n    expect(ratio?.definition).not.toBeNull();\n  });\n\n  it(\"populated: unknown keys still surface with definition: null + expectedType: 'unknown'\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          key: \"experimental_unmapped_key\",\n          value: \"42\",\n          updatedAt: \"2026-04-25T00:00:00.000Z\",\n        },\n      ],\n    ]);\n\n    const rows = await listRewardConfig({ sql: mock.sql });\n\n    expect(rows).toHaveLength(1);\n    expect(rows[0]).toEqual({\n      key: \"experimental_unmapped_key\",\n      value: \"42\",\n      updatedAt: \"2026-04-25T00:00:00.000Z\",\n      definition: null,\n      expectedType: \"unknown\",\n    });\n  });\n\n  it(\"empty: returns an empty array when the table is empty\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listRewardConfig({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"reads from reward_config ordered by key asc\", async () => {\n    const mock = createSqlMock([[]]);\n    await listRewardConfig({ sql: mock.sql });\n    expect(mock.calls).toHaveLength(1);\n    expect(mock.calls[0].text).toMatch(/from reward_config/i);\n    expect(mock.calls[0].text).toMatch(/order by key asc/i);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"connection refused\")]);\n    await expect(listRewardConfig({ sql: mock.sql })).rejects.toThrowError(\n      \"connection refused\",\n    );\n  });\n});\n\ndescribe(\"getRewardPool\", () => {\n  it(\"populated: returns the singleton row with all four lamport/timestamp fields\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          balanceLamports: \"1500000000\",\n          lifetimeFunded: \"9000000000\",\n          lifetimePaid: \"7500000000\",\n          updatedAt: \"2026-04-25T10:00:00.000Z\",\n        },\n      ],\n    ]);\n\n    const pool = await getRewardPool({ sql: mock.sql });\n\n    expect(pool).toEqual({\n      balanceLamports: \"1500000000\",\n      lifetimeFunded: \"9000000000\",\n      lifetimePaid: \"7500000000\",\n      updatedAt: \"2026-04-25T10:00:00.000Z\",\n    });\n  });\n\n  it(\"populated: null/empty lamport columns coerce to '0' via readSum\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          balanceLamports: null,\n          lifetimeFunded: \"\",\n          lifetimePaid: undefined,\n          updatedAt: \"2026-04-25T10:00:00.000Z\",\n        },\n      ],\n    ]);\n\n    const pool = await getRewardPool({ sql: mock.sql });\n\n    expect(pool).toEqual({\n      balanceLamports: \"0\",\n      lifetimeFunded: \"0\",\n      lifetimePaid: \"0\",\n      updatedAt: \"2026-04-25T10:00:00.000Z\",\n    });\n  });\n\n  it(\"empty (singleton missing): returns null instead of throwing\", async () => {\n    const mock = createSqlMock([[]]);\n    const pool = await getRewardPool({ sql: mock.sql });\n    expect(pool).toBeNull();\n  });\n\n  it(\"reads reward_pool where id = 1 limit 1\", async () => {\n    const mock = createSqlMock([[]]);\n    await getRewardPool({ sql: mock.sql });\n    expect(mock.calls).toHaveLength(1);\n    expect(mock.calls[0].text).toMatch(/from reward_pool/i);\n    expect(mock.calls[0].text).toMatch(/where id = 1/i);\n    expect(mock.calls[0].text).toMatch(/limit 1/i);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"db down\")]);\n    await expect(getRewardPool({ sql: mock.sql })).rejects.toThrowError(\n      \"db down\",\n    );\n  });\n});\n\ndescribe(\"listRewardPoolFundings\", () => {\n  it(\"default limit: clamps to PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT and reads the ledger\", async () => {\n    const mock = createSqlMock([[]]);\n    await listRewardPoolFundings({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expect(call.text).toMatch(/from reward_pool_fundings/i);\n    expect(call.text).toMatch(/order by created_at desc, id desc/i);\n    expect(call.values).toContain(PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT);\n  });\n\n  it(\"explicit limit: passes the caller value through clampLimit\", async () => {\n    const mock = createSqlMock([[]]);\n    await listRewardPoolFundings({ sql: mock.sql, limit: 25 });\n    expect(mock.calls[0].values).toContain(25);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listRewardPoolFundings({\n      sql: mock.sql,\n      limit: PEEK_REWARD_POOL_FUNDINGS_MAX_LIMIT + 100,\n    });\n    expect(mock.calls[0].values).toContain(\n      PEEK_REWARD_POOL_FUNDINGS_MAX_LIMIT,\n    );\n  });\n\n  it(\"non-positive limit clamps to 1\", async () => {\n    const mock = createSqlMock([[]]);\n    await listRewardPoolFundings({ sql: mock.sql, limit: 0 });\n    expect(mock.calls[0].values).toContain(1);\n  });\n\n  it(\"non-finite limit falls back to the default\", async () => {\n    const mock = createSqlMock([[]]);\n    await listRewardPoolFundings({ sql: mock.sql, limit: Number.NaN });\n    expect(mock.calls[0].values).toContain(\n      PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT,\n    );\n  });\n\n  it(\"populated: returns rows with the funding-source linkage (roundId from reward_pool_fundings.round_id)\", async () => {\n    const row = {\n      id: \"42\",\n      roundId: \"match-abc-123\",\n      feeLamports: \"200000\",\n      fundedLamports: \"150000\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n    };\n    const mock = createSqlMock([[row]]);\n\n    const rows = await listRewardPoolFundings({ sql: mock.sql });\n\n    expect(rows).toEqual([row]);\n    // The funding source linkage comes back via the `roundId` field. The\n    // page wires this through universal search (`/?query=<roundId>`); the\n    // query itself just has to surface the column.\n    expect(rows[0].roundId).toBe(\"match-abc-123\");\n  });\n\n  it(\"empty: returns an empty array when no fundings exist\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listRewardPoolFundings({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"query timeout\")]);\n    await expect(\n      listRewardPoolFundings({ sql: mock.sql }),\n    ).rejects.toThrowError(\"query timeout\");\n  });\n});\n\ndescribe(\"getRewardsOverview\", () => {\n  it(\"populated: emits one PeekMetric per FR-4 id with correct values, units, and bookkeeping\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          balanceLamports: \"1500000000\",\n          lifetimeFunded: \"9000000000\",\n          lifetimePaid: \"7500000000\",\n        },\n      ],\n      [{ value: 7 }],\n    ]);\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getRewardsOverview({ sql: mock.sql, now });\n\n    expect(result.generatedAt).toBe(\"2026-04-25T10:00:00.000Z\");\n    expect(result.metrics).toHaveLength(4);\n    expect(result.metrics.map((m) => m.id)).toEqual(OVERVIEW_ORDER);\n    for (const id of PEEK_REWARDS_OVERVIEW_METRIC_IDS) {\n      expect(result.metrics.find((m) => m.id === id)).toBeDefined();\n    }\n    for (const metric of result.metrics) {\n      expect(metric.asOf).toBe(\"2026-04-25T10:00:00.000Z\");\n      expect(metric.freshness).toBe(\"live\");\n      expect(metric.label.length).toBeGreaterThan(0);\n      expect(metric.definition.length).toBeGreaterThan(0);\n      expect(metric.source.length).toBeGreaterThan(0);\n      expect(metric.windowLabel.length).toBeGreaterThan(0);\n      expect(metric.drilldownHref).not.toBeNull();\n    }\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"rewards.balance_lamports\")?.value).toBe(\"1500000000\");\n    expect(byId.get(\"rewards.balance_lamports\")?.valueDisplay).toBe(\n      \"1,500,000,000\",\n    );\n    expect(byId.get(\"rewards.balance_lamports\")?.unit).toBe(\"lamports\");\n    expect(byId.get(\"rewards.balance_lamports\")?.drilldownHref).toBe(\n      \"/economy/rewards#pool\",\n    );\n\n    expect(byId.get(\"rewards.lifetime_funded_lamports\")?.value).toBe(\n      \"9000000000\",\n    );\n    expect(\n      byId.get(\"rewards.lifetime_funded_lamports\")?.valueDisplay,\n    ).toBe(\"9,000,000,000\");\n    expect(\n      byId.get(\"rewards.lifetime_funded_lamports\")?.drilldownHref,\n    ).toBe(\"/economy/rewards#fundings\");\n\n    expect(byId.get(\"rewards.lifetime_paid_lamports\")?.value).toBe(\n      \"7500000000\",\n    );\n    expect(byId.get(\"rewards.lifetime_paid_lamports\")?.valueDisplay).toBe(\n      \"7,500,000,000\",\n    );\n\n    expect(byId.get(\"rewards.recent_fundings\")?.value).toBe(7);\n    expect(byId.get(\"rewards.recent_fundings\")?.valueDisplay).toBe(\"7\");\n    expect(byId.get(\"rewards.recent_fundings\")?.unit).toBe(\"events\");\n    expect(byId.get(\"rewards.recent_fundings\")?.drilldownHref).toBe(\n      \"/economy/rewards#fundings\",\n    );\n  });\n\n  it(\"populated (large recent fundings): formats valueDisplay with thousands separator\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          balanceLamports: \"0\",\n          lifetimeFunded: \"0\",\n          lifetimePaid: \"0\",\n        },\n      ],\n      [{ value: 1234 }],\n    ]);\n    const result = await getRewardsOverview({ sql: mock.sql });\n    const recent = result.metrics.find(\n      (m) => m.id === \"rewards.recent_fundings\",\n    );\n    expect(recent?.value).toBe(1234);\n    expect(recent?.valueDisplay).toBe(\"1,234\");\n  });\n\n  it(\"sparse (singleton missing): every lamport metric coerces to '0' and recent fundings to 0 without dropping a metric\", async () => {\n    const mock = createSqlMock([[], []]);\n\n    const result = await getRewardsOverview({ sql: mock.sql });\n\n    expect(result.metrics).toHaveLength(4);\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"rewards.balance_lamports\")?.value).toBe(\"0\");\n    expect(byId.get(\"rewards.balance_lamports\")?.valueDisplay).toBe(\"0\");\n    expect(byId.get(\"rewards.lifetime_funded_lamports\")?.value).toBe(\"0\");\n    expect(byId.get(\"rewards.lifetime_paid_lamports\")?.value).toBe(\"0\");\n    expect(byId.get(\"rewards.recent_fundings\")?.value).toBe(0);\n    expect(byId.get(\"rewards.recent_fundings\")?.valueDisplay).toBe(\"0\");\n  });\n\n  it(\"string count coercion: a postgres ::int count served as a string converts to a number\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          balanceLamports: \"0\",\n          lifetimeFunded: \"0\",\n          lifetimePaid: \"0\",\n        },\n      ],\n      [{ value: \"9\" }],\n    ]);\n    const result = await getRewardsOverview({ sql: mock.sql });\n    const recent = result.metrics.find(\n      (m) => m.id === \"rewards.recent_fundings\",\n    );\n    expect(recent?.value).toBe(9);\n  });\n\n  it(\"recent fundings window: default window label uses PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS and binds the matching `since` timestamp\", async () => {\n    const mock = createSqlMock([\n      [{ balanceLamports: \"0\", lifetimeFunded: \"0\", lifetimePaid: \"0\" }],\n      [{ value: 0 }],\n    ]);\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getRewardsOverview({ sql: mock.sql, now });\n    const recent = result.metrics.find(\n      (m) => m.id === \"rewards.recent_fundings\",\n    );\n    expect(recent?.windowLabel).toBe(\n      `Last ${PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS}h`,\n    );\n\n    // The fundings query (call index 1) binds the cutoff timestamp.\n    const since = new Date(\n      now.getTime() -\n        PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS * 60 * 60 * 1000,\n    ).toISOString();\n    expect(mock.calls[1].values).toContain(since);\n  });\n\n  it(\"recent fundings window: caller-provided window flows into the window label and the `since` cutoff\", async () => {\n    const mock = createSqlMock([\n      [{ balanceLamports: \"0\", lifetimeFunded: \"0\", lifetimePaid: \"0\" }],\n      [{ value: 0 }],\n    ]);\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getRewardsOverview({\n      sql: mock.sql,\n      now,\n      recentFundingsWindowHours: 6,\n    });\n    const recent = result.metrics.find(\n      (m) => m.id === \"rewards.recent_fundings\",\n    );\n    expect(recent?.windowLabel).toBe(\"Last 6h\");\n    const since = new Date(\n      now.getTime() - 6 * 60 * 60 * 1000,\n    ).toISOString();\n    expect(mock.calls[1].values).toContain(since);\n  });\n\n  it(\"load-error: a rejected query propagates so the page can render the alert state\", async () => {\n    const mock = createSqlMock([\n      new Error(\"connection refused\"),\n      [{ value: 0 }],\n    ]);\n    await expect(\n      getRewardsOverview({ sql: mock.sql }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n\n  it(\"queries fire in parallel: the second SQL call sees the second response even though both run via Promise.all\", async () => {\n    const mock = createSqlMock([\n      [{ balanceLamports: \"10\", lifetimeFunded: \"10\", lifetimePaid: \"0\" }],\n      [{ value: 3 }],\n    ]);\n    await getRewardsOverview({ sql: mock.sql });\n    expect(mock.calls).toHaveLength(2);\n    expect(mock.calls[0].text).toMatch(/from reward_pool/i);\n    expect(mock.calls[1].text).toMatch(/from reward_pool_fundings/i);\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
