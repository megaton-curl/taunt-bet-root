{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01Wtn7GPbR9RdsAFyb6fbSsV","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01WeSRNidjLnGbtBZqUs21J5","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/__tests__/reward-pool-fundings-table.test.tsx","content":"import { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { RewardPoolFundingsTable } from \"../reward-pool-fundings-table\";\nimport type { PeekRewardPoolFundingRow } from \"../../lib/types/peek\";\n\nconst ROW_FLIPYOU: PeekRewardPoolFundingRow = {\n  id: \"42\",\n  roundId: \"match-abc-123\",\n  feeLamports: \"200000\",\n  fundedLamports: \"150000\",\n  createdAt: \"2026-04-25T10:00:00.000Z\",\n};\n\nconst ROW_CLOSECALL: PeekRewardPoolFundingRow = {\n  id: \"43\",\n  roundId: \"CCpda1234567890\",\n  feeLamports: \"1000000\",\n  fundedLamports: \"750000\",\n  createdAt: \"2026-04-25T11:00:00.000Z\",\n};\n\nconst ROW_ZEROES: PeekRewardPoolFundingRow = {\n  id: \"44\",\n  roundId: \"round-zero\",\n  feeLamports: \"0\",\n  fundedLamports: \"0\",\n  createdAt: \"2026-04-25T12:00:00.000Z\",\n};\n\ndescribe(\"RewardPoolFundingsTable\", () => {\n  it(\"populated: renders one row per funding with the operator columns and lamport thousands-separator formatting\", () => {\n    render(\n      <RewardPoolFundingsTable rows={[ROW_FLIPYOU, ROW_CLOSECALL]} />,\n    );\n\n    expect(screen.getByText(\"Created\")).toBeInTheDocument();\n    expect(screen.getByText(\"Source round\")).toBeInTheDocument();\n    expect(screen.getByText(\"Fee (lamports)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Funded (lamports)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Funding ID\")).toBeInTheDocument();\n\n    expect(screen.getByText(\"200,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"150,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"1,000,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"750,000\")).toBeInTheDocument();\n    expect(\n      screen.getByText(\"2026-04-25T10:00:00.000Z\"),\n    ).toBeInTheDocument();\n    expect(\n      screen.getByText(\"2026-04-25T11:00:00.000Z\"),\n    ).toBeInTheDocument();\n  });\n\n  it(\"populated: source round drills into universal search for the round id (FR-9 funding-source linkage)\", () => {\n    render(<RewardPoolFundingsTable rows={[ROW_FLIPYOU]} />);\n\n    // The funding ledger has no game column — drill-down is intentionally\n    // routed through `/?query=<roundId>` so universal search resolves to the\n    // matching flipyou/potshot/closecall round and surfaces the direct\n    // /games/[game]/rounds/[roundId] link.\n    const link = screen.getByRole(\"link\", { name: \"match-abc-123\" });\n    expect(link).toHaveAttribute(\n      \"href\",\n      `/?query=${encodeURIComponent(\"match-abc-123\")}`,\n    );\n    expect(link).toHaveAttribute(\n      \"title\",\n      \"Open universal search for round match-abc-123\",\n    );\n  });\n\n  it(\"populated: closecall PDA-style round ids are encoded into the search query just like match ids\", () => {\n    render(<RewardPoolFundingsTable rows={[ROW_CLOSECALL]} />);\n\n    const link = screen.getByRole(\"link\", { name: \"CCpda1234567890\" });\n    expect(link).toHaveAttribute(\n      \"href\",\n      `/?query=${encodeURIComponent(\"CCpda1234567890\")}`,\n    );\n  });\n\n  it(\"populated: zero-funded rows render bare '0' in fee + funded cells\", () => {\n    render(<RewardPoolFundingsTable rows={[ROW_ZEROES]} />);\n\n    const row = screen.getByText(\"round-zero\").closest(\"tr\")!;\n    // fee + funded both render bare \"0\".\n    expect(row.textContent).toContain(\"0\");\n  });\n\n  it(\"empty: renders an operator status block when the ledger has no rows\", () => {\n    render(<RewardPoolFundingsTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"No reward_pool_fundings rows.\");\n    expect(status).toHaveTextContent(\n      \"No settled rounds have funded the reward pool yet\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert message and hides both the table and the empty status\", () => {\n    render(\n      <RewardPoolFundingsTable\n        rows={[ROW_FLIPYOU]}\n        error=\"connection refused\"\n      />,\n    );\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Reward pool fundings unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1622,"cache_read_input_tokens":109731,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1622},"output_tokens":68,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"b77bbed1-945f-44ec-8430-ad135cabe0b1","uuid":"8bfc75d6-9fb7-4472-a24d-f7e25e4694a6"}
