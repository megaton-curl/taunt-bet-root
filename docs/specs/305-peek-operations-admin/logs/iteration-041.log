een.getByText(\"Refunds\")).toBeInTheDocument();\n56\t    expect(screen.getByText(\"Paid out (lamports)\")).toBeInTheDocument();\n57\t    expect(screen.getByText(\"Wins\")).toBeInTheDocument();\n58\t    expect(screen.getByText(\"Losses\")).toBeInTheDocument();\n59\t\n60\t    expect(screen.getByText(\"FlipYou\")).toBeInTheDocument();\n61\t    expect(screen.getByText(\"Pot Shot\")).toBeInTheDocument();\n62\t    expect(screen.getByText(\"Close Call\")).toBeInTheDocument();\n63\t\n64\t    // Raw ids appear as sublabels next to the friendly name (operator audit).\n65\t    expect(screen.getByText(/· flipyou/)).toBeInTheDocument();\n66\t    expect(screen.getByText(/· potshot/)).toBeInTheDocument();\n67\t    expect(screen.getByText(/· closecall/)).toBeInTheDocument();\n68\t\n69\t    // Counts are integer-formatted with thousands separators (FR-4).\n70\t    expect(screen.getByText(\"1,234\")).toBeInTheDocument();\n71\t    expect(screen.getByText(\"567\")).toBeInTheDocument();\n72\t    expect(screen.getByText(\"1,200\")).toBeInTheDocument();\n73\t    // Lamport sums use the same formatting; \"0\" stays bare for zero rows.\n74\t    expect(screen.getByText(\"8,000,000,000\")).toBeInTheDocument();\n75\t    expect(screen.getByText(\"7,500,000,000\")).toBeInTheDocument();\n76\t  });\n77\t\n78\t  it(\"populated: zero-filled per-game rows show literal '0' across every counter, not em-dashes (preserves measured-zero semantics)\", () => {\n79\t    render(<GamesOverviewTable rows={[ROW_POTSHOT_EMPTY]} />);\n80\t\n81\t    const row = screen.getByText(\"Pot Shot\").closest(\"tr\")!;\n82\t    // Every numeric cell renders \"0\" — there are 8 numeric columns.\n83\t    expect(within(row).getAllByText(\"0\").length).toBe(8);\n84\t  });\n85\t\n86\t  it(\"sparse (no active games yet): renders the operator empty state pointing at game_entries\", () => {\n87\t    render(<GamesOverviewTable rows={[]} />);\n88\t\n89\t    const status = screen.getByRole(\"status\");\n90\t    expect(status).toHaveTextContent(\"No game activity recorded.\");\n91\t    expect(status).toHaveTextContent(\"game_entries\");\n92\t    expect(screen.queryByRole(\"table\")).toBeNull();\n93\t  });\n94\t\n95\t  it(\"error: renders an alert message and suppresses both the table and the empty status\", () => {\n96\t    render(\n97\t      <GamesOverviewTable\n98\t        rows={[ROW_FLIPYOU]}\n99\t        error=\"connection refused\"\n100\t      />,\n101\t    );\n102\t\n103\t    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n104\t      \"Per-game activity unavailable: connection refused\",\n105\t    );\n106\t    expect(screen.queryByRole(\"table\")).toBeNull();\n107\t    expect(screen.queryByRole(\"status\")).toBeNull();\n108\t  });\n109\t});\n110\t"}]},"parent_tool_use_id":null,"session_id":"b77bbed1-945f-44ec-8430-ad135cabe0b1","uuid":"84db9abb-3365-4e1b-ad89-fa1f8ac964d1","timestamp":"2026-04-25T14:05:59.882Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/games-overview-table.test.tsx","content":"import { describe, expect, it } from \"vitest\";\nimport { render, screen, within } from \"@testing-library/react\";\nimport { GamesOverviewTable } from \"../games-overview-table\";\nimport type { PeekGameOverviewRow } from \"../../lib/types/peek\";\n\nconst ROW_FLIPYOU: PeekGameOverviewRow = {\n  game: \"flipyou\",\n  entries: 1234,\n  uniqueUsers: 567,\n  wageredLamports: \"8000000000\",\n  settledEntries: 1200,\n  refundEntries: 12,\n  payoutLamports: \"7500000000\",\n  wins: 600,\n  losses: 588,\n};\n\nconst ROW_POTSHOT_EMPTY: PeekGameOverviewRow = {\n  game: \"potshot\",\n  entries: 0,\n  uniqueUsers: 0,\n  wageredLamports: \"0\",\n  settledEntries: 0,\n  refundEntries: 0,\n  payoutLamports: \"0\",\n  wins: 0,\n  losses: 0,\n};\n\nconst ROW_CLOSECALL: PeekGameOverviewRow = {\n  game: \"closecall\",\n  entries: 42,\n  uniqueUsers: 30,\n  wageredLamports: \"500000\",\n  settledEntries: 40,\n  refundEntries: 1,\n  payoutLamports: \"450000\",\n  wins: 20,\n  losses: 19,\n};\n\ndescribe(\"GamesOverviewTable\", () => {\n  it(\"populated: renders one row per game with friendly label + raw id, all 9 numeric columns, and lamport thousands-separator formatting\", () => {\n    render(\n      <GamesOverviewTable\n        rows={[ROW_FLIPYOU, ROW_POTSHOT_EMPTY, ROW_CLOSECALL]}\n      />,\n    );\n\n    expect(screen.getByText(\"Game\")).toBeInTheDocument();\n    expect(screen.getByText(\"Entries\")).toBeInTheDocument();\n    expect(screen.getByText(\"Unique users\")).toBeInTheDocument();\n    expect(screen.getByText(\"Wagered (lamports)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Settled\")).toBeInTheDocument();\n    expect(screen.getByText(\"Refunds\")).toBeInTheDocument();\n    expect(screen.getByText(\"Paid out (lamports)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Wins\")).toBeInTheDocument();\n    expect(screen.getByText(\"Losses\")).toBeInTheDocument();\n\n    expect(screen.getByText(\"FlipYou\")).toBeInTheDocument();\n    expect(screen.getByText(\"Pot Shot\")).toBeInTheDocument();\n    expect(screen.getByText(\"Close Call\")).toBeInTheDocument();\n\n    // Raw ids appear as sublabels next to the friendly name (operator audit).\n    expect(screen.getByText(/· flipyou/)).toBeInTheDocument();\n    expect(screen.getByText(/· potshot/)).toBeInTheDocument();\n    expect(screen.getByText(/· closecall/)).toBeInTheDocument();\n\n    // Counts are integer-formatted with thousands separators (FR-4).\n    expect(screen.getByText(\"1,234\")).toBeInTheDocument();\n    expect(screen.getByText(\"567\")).toBeInTheDocument();\n    expect(screen.getByText(\"1,200\")).toBeInTheDocument();\n    // Lamport sums use the same formatting; \"0\" stays bare for zero rows.\n    expect(screen.getByText(\"8,000,000,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"7,500,000,000\")).toBeInTheDocument();\n  });\n\n  it(\"populated: zero-filled per-game rows show literal '0' across every counter, not em-dashes (preserves measured-zero semantics)\", () => {\n    render(<GamesOverviewTable rows={[ROW_POTSHOT_EMPTY]} />);\n\n    const row = screen.getByText(\"Pot Shot\").closest(\"tr\")!;\n    // Every numeric cell renders \"0\" — there are 8 numeric columns.\n    expect(within(row).getAllByText(\"0\").length).toBe(8);\n  });\n\n  it(\"sparse (no active games yet): renders the operator empty state pointing at game_entries\", () => {\n    render(<GamesOverviewTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"No game activity recorded.\");\n    expect(status).toHaveTextContent(\"game_entries\");\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert message and suppresses both the table and the empty status\", () => {\n    render(\n      <GamesOverviewTable\n        rows={[ROW_FLIPYOU]}\n        error=\"connection refused\"\n      />,\n    );\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Per-game activity unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n","numLines":110,"startLine":1,"totalLines":110}}}
