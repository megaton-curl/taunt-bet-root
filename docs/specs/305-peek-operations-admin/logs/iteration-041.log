{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UG2FKFEpQ8WaXP28iiqceq","type":"tool_result","content":"1\t// /economy/rewards — reward economy admin page (FR-9).\n2\t//\n3\t// Reads the migration-011 reward-economy tables via `get-rewards.ts` and\n4\t// composes the FR-4 metric strip + the three FR-9 surfaces:\n5\t//\n6\t//   - Pool balance card    — singleton `reward_pool` accounting row\n7\t//   - Reward config table  — operator-tunable economy parameters\n8\t//   - Recent fundings      — append-only `reward_pool_fundings` ledger with\n9\t//                            drill-down to the source round (universal-search\n10\t//                            entry point: `/?query=<round_id>`)\n11\t//\n12\t// Editing is out of scope here — selected `reward_config` keys can later be\n13\t// edited through the FR-14 mutation surface (separate iteration).\n14\timport type { CSSProperties } from \"react\";\n15\timport { MetricStrip } from \"../../../src/components/metric-strip\";\n16\timport { RewardConfigTable } from \"../../../src/components/reward-config-table\";\n17\timport { RewardPoolCard } from \"../../../src/components/reward-pool-card\";\n18\timport { RewardPoolFundingsTable } from \"../../../src/components/reward-pool-fundings-table\";\n19\timport type {\n20\t  PeekRewardConfigRow,\n21\t  PeekRewardPool,\n22\t  PeekRewardPoolFundingRow,\n23\t  PeekRewardsOverview,\n24\t} from \"../../../src/lib/types/peek\";\n25\timport {\n26\t  getPeekActorContext,\n27\t  isRouteAllowedForRole,\n28\t} from \"../../../src/server/access-policy\";\n29\timport {\n30\t  PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT,\n31\t  getRewardPool,\n32\t  getRewardsOverview,\n33\t  listRewardConfig,\n34\t  listRewardPoolFundings,\n35\t} from \"../../../src/server/db/queries/get-rewards\";\n36\t\n37\texport const dynamic = \"force-dynamic\";\n38\t\n39\tconst ROUTE = \"/economy/rewards\";\n40\t\n41\texport default async function EconomyRewardsPage() {\n42\t  const actor = await getPeekActorContext();\n43\t  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n44\t\n45\t  if (!allowed) {\n46\t    return (\n47\t      <main style={mainStyle}>\n48\t        <header>\n49\t          <h1>Economy · Rewards</h1>\n50\t        </header>\n51\t        <p role=\"alert\" style={errorStyle}>\n52\t          You do not have access to this page.\n53\t        </p>\n54\t      </main>\n55\t    );\n56\t  }\n57\t\n58\t  let overview: PeekRewardsOverview = {\n59\t    generatedAt: new Date().toISOString(),\n60\t    metrics: [],\n61\t  };\n62\t  let pool: PeekRewardPool | null = null;\n63\t  let config: ReadonlyArray<PeekRewardConfigRow> = [];\n64\t  let fundings: ReadonlyArray<PeekRewardPoolFundingRow> = [];\n65\t\n66\t  let overviewError: string | null = null;\n67\t  let poolError: string | null = null;\n68\t  let configError: string | null = null;\n69\t  let fundingsError: string | null = null;\n70\t\n71\t  try {\n72\t    overview = await getRewardsOverview();\n73\t  } catch (error) {\n74\t    overviewError =\n75\t      error instanceof Error\n76\t        ? error.message\n77\t        : \"Rewards overview could not be loaded.\";\n78\t  }\n79\t\n80\t  try {\n81\t    pool = await getRewardPool();\n82\t  } catch (error) {\n83\t    poolError =\n84\t      error instanceof Error\n85\t        ? error.message\n86\t        : \"Reward pool singleton could not be loaded.\";\n87\t  }\n88\t\n89\t  try {\n90\t    config = await listRewardConfig();\n91\t  } catch (error) {\n92\t    configError =\n93\t      error instanceof Error\n94\t        ? error.message\n95\t        : \"Reward config rows could not be loaded.\";\n96\t  }\n97\t\n98\t  try {\n99\t    fundings = await listRewardPoolFundings();\n100\t  } catch (error) {\n101\t    fundingsError =\n102\t      error instanceof Error\n103\t        ? error.message\n104\t        : \"Reward pool fundings could not be loaded.\";\n105\t  }\n106\t\n107\t  return (\n108\t    <main style={mainStyle}>\n109\t      <header>\n110\t        <h1>Economy · Rewards</h1>\n111\t        <p style={leadStyle}>\n112\t          Reward pool accounting, operator-tunable economy config, and the\n113\t          per-round funding ledger. Drill into a funding row to open universal\n114\t          search for the source round.\n115\t        </p>\n116\t      </header>\n117\t\n118\t      <section aria-labelledby=\"overview-heading\">\n119\t        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n120\t          Overview\n121\t        </h2>\n122\t        <MetricStrip metrics={overview.metrics} error={overviewError} />\n123\t      </section>\n124\t\n125\t      <section aria-labelledby=\"pool-heading\" id=\"pool\" style={sectionStyle}>\n126\t        <h2 id=\"pool-heading\" style={sectionHeadingStyle}>\n127\t          Pool balance\n128\t        </h2>\n129\t        <p style={hintStyle}>\n130\t          Singleton row from `reward_pool` (id = 1) · live read · lamports\n131\t          retain raw u64 precision in the cell `title=` for hover audit.\n132\t        </p>\n133\t        <RewardPoolCard pool={pool} error={poolError} />\n134\t      </section>\n135\t\n136\t      <section\n137\t        aria-labelledby=\"config-heading\"\n138\t        id=\"config\"\n139\t        style={sectionStyle}\n140\t      >\n141\t        <h2 id=\"config-heading\" style={sectionHeadingStyle}>\n142\t          Reward config\n143\t        </h2>\n144\t        <p style={hintStyle}>\n145\t          All keys from `reward_config` · sorted alphabetically · read-only.\n146\t          Editing selected keys will be wired through the FR-14 mutation surface\n147\t          in a later iteration.\n148\t        </p>\n149\t        <RewardConfigTable rows={config} error={configError} />\n150\t      </section>\n151\t\n152\t      <section\n153\t        aria-labelledby=\"fundings-heading\"\n154\t        id=\"fundings\"\n155\t        style={sectionStyle}\n156\t      >\n157\t        <h2 id=\"fundings-heading\" style={sectionHeadingStyle}>\n158\t          Recent pool fundings\n159\t        </h2>\n160\t        <p style={hintStyle}>\n161\t          Default {PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT} rows · sorted\n162\t          newest first · server-side capped. Click a source round to open\n163\t          universal search and drill into the originating game round.\n164\t        </p>\n165\t        <RewardPoolFundingsTable rows={fundings} error={fundingsError} />\n166\t      </section>\n167\t    </main>\n168\t  );\n169\t}\n170\t\n171\tconst mainStyle: CSSProperties = {\n172\t  display: \"grid\",\n173\t  gap: \"1.5rem\",\n174\t};\n175\t\n176\tconst sectionStyle: CSSProperties = {\n177\t  display: \"grid\",\n178\t  gap: \"0.75rem\",\n179\t};\n180\t\n181\tconst sectionHeadingStyle: CSSProperties = {\n182\t  margin: \"0 0 0.75rem\",\n183\t  fontSize: \"1rem\",\n184\t  fontWeight: 600,\n185\t  color: \"#cbd5f5\",\n186\t  textTransform: \"uppercase\",\n187\t  letterSpacing: \"0.05em\",\n188\t};\n189\t\n190\tconst leadStyle: CSSProperties = {\n191\t  margin: \"0.25rem 0 0\",\n192\t  color: \"#94a3b8\",\n193\t};\n194\t\n195\tconst hintStyle: CSSProperties = {\n196\t  margin: 0,\n197\t  color: \"#94a3b8\",\n198\t  fontSize: \"0.8125rem\",\n199\t};\n200\t\n201\tconst errorStyle: CSSProperties = {\n202\t  margin: 0,\n203\t  padding: \"0.75rem 1rem\",\n204\t  borderRadius: \"0.75rem\",\n205\t  background: \"#3f1d1d\",\n206\t  color: \"#fecaca\",\n207\t};\n208\t"}]},"parent_tool_use_id":null,"session_id":"b77bbed1-945f-44ec-8430-ad135cabe0b1","uuid":"0655128a-04e5-4d38-9ff8-70e93a6fa8a2","timestamp":"2026-04-25T14:04:53.354Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/app/economy/rewards/page.tsx","content":"// /economy/rewards — reward economy admin page (FR-9).\n//\n// Reads the migration-011 reward-economy tables via `get-rewards.ts` and\n// composes the FR-4 metric strip + the three FR-9 surfaces:\n//\n//   - Pool balance card    — singleton `reward_pool` accounting row\n//   - Reward config table  — operator-tunable economy parameters\n//   - Recent fundings      — append-only `reward_pool_fundings` ledger with\n//                            drill-down to the source round (universal-search\n//                            entry point: `/?query=<round_id>`)\n//\n// Editing is out of scope here — selected `reward_config` keys can later be\n// edited through the FR-14 mutation surface (separate iteration).\nimport type { CSSProperties } from \"react\";\nimport { MetricStrip } from \"../../../src/components/metric-strip\";\nimport { RewardConfigTable } from \"../../../src/components/reward-config-table\";\nimport { RewardPoolCard } from \"../../../src/components/reward-pool-card\";\nimport { RewardPoolFundingsTable } from \"../../../src/components/reward-pool-fundings-table\";\nimport type {\n  PeekRewardConfigRow,\n  PeekRewardPool,\n  PeekRewardPoolFundingRow,\n  PeekRewardsOverview,\n} from \"../../../src/lib/types/peek\";\nimport {\n  getPeekActorContext,\n  isRouteAllowedForRole,\n} from \"../../../src/server/access-policy\";\nimport {\n  PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT,\n  getRewardPool,\n  getRewardsOverview,\n  listRewardConfig,\n  listRewardPoolFundings,\n} from \"../../../src/server/db/queries/get-rewards\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst ROUTE = \"/economy/rewards\";\n\nexport default async function EconomyRewardsPage() {\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n\n  if (!allowed) {\n    return (\n      <main style={mainStyle}>\n        <header>\n          <h1>Economy · Rewards</h1>\n        </header>\n        <p role=\"alert\" style={errorStyle}>\n          You do not have access to this page.\n        </p>\n      </main>\n    );\n  }\n\n  let overview: PeekRewardsOverview = {\n    generatedAt: new Date().toISOString(),\n    metrics: [],\n  };\n  let pool: PeekRewardPool | null = null;\n  let config: ReadonlyArray<PeekRewardConfigRow> = [];\n  let fundings: ReadonlyArray<PeekRewardPoolFundingRow> = [];\n\n  let overviewError: string | null = null;\n  let poolError: string | null = null;\n  let configError: string | null = null;\n  let fundingsError: string | null = null;\n\n  try {\n    overview = await getRewardsOverview();\n  } catch (error) {\n    overviewError =\n      error instanceof Error\n        ? error.message\n        : \"Rewards overview could not be loaded.\";\n  }\n\n  try {\n    pool = await getRewardPool();\n  } catch (error) {\n    poolError =\n      error instanceof Error\n        ? error.message\n        : \"Reward pool singleton could not be loaded.\";\n  }\n\n  try {\n    config = await listRewardConfig();\n  } catch (error) {\n    configError =\n      error instanceof Error\n        ? error.message\n        : \"Reward config rows could not be loaded.\";\n  }\n\n  try {\n    fundings = await listRewardPoolFundings();\n  } catch (error) {\n    fundingsError =\n      error instanceof Error\n        ? error.message\n        : \"Reward pool fundings could not be loaded.\";\n  }\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <h1>Economy · Rewards</h1>\n        <p style={leadStyle}>\n          Reward pool accounting, operator-tunable economy config, and the\n          per-round funding ledger. Drill into a funding row to open universal\n          search for the source round.\n        </p>\n      </header>\n\n      <section aria-labelledby=\"overview-heading\">\n        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n          Overview\n        </h2>\n        <MetricStrip metrics={overview.metrics} error={overviewError} />\n      </section>\n\n      <section aria-labelledby=\"pool-heading\" id=\"pool\" style={sectionStyle}>\n        <h2 id=\"pool-heading\" style={sectionHeadingStyle}>\n          Pool balance\n        </h2>\n        <p style={hintStyle}>\n          Singleton row from `reward_pool` (id = 1) · live read · lamports\n          retain raw u64 precision in the cell `title=` for hover audit.\n        </p>\n        <RewardPoolCard pool={pool} error={poolError} />\n      </section>\n\n      <section\n        aria-labelledby=\"config-heading\"\n        id=\"config\"\n        style={sectionStyle}\n      >\n        <h2 id=\"config-heading\" style={sectionHeadingStyle}>\n          Reward config\n        </h2>\n        <p style={hintStyle}>\n          All keys from `reward_config` · sorted alphabetically · read-only.\n          Editing selected keys will be wired through the FR-14 mutation surface\n          in a later iteration.\n        </p>\n        <RewardConfigTable rows={config} error={configError} />\n      </section>\n\n      <section\n        aria-labelledby=\"fundings-heading\"\n        id=\"fundings\"\n        style={sectionStyle}\n      >\n        <h2 id=\"fundings-heading\" style={sectionHeadingStyle}>\n          Recent pool fundings\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT} rows · sorted\n          newest first · server-side capped. Click a source round to open\n          universal search and drill into the originating game round.\n        </p>\n        <RewardPoolFundingsTable rows={fundings} error={fundingsError} />\n      </section>\n    </main>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n","numLines":208,"startLine":1,"totalLines":208}}}
