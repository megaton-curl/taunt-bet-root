"content":"{\n  \"name\": \"@taunt-bet/peek\",\n  \"version\": \"1.0.0\",\n  \"description\": \"Internal admin app for waitlist and referral visibility.\",\n  \"scripts\": {\n    \"test\": \"vitest run\",\n    \"dev\": \"next dev\",\n    \"build\": \"next build\",\n    \"start\": \"next start\",\n    \"lint\": \"eslint .\",\n    \"typecheck\": \"tsc --noEmit -p tsconfig.typecheck.json\",\n    \"test:watch\": \"vitest\",\n    \"test:e2e\": \"playwright test\",\n    \"verify\": \"pnpm lint && pnpm typecheck && pnpm test && pnpm build\"\n  },\n  \"keywords\": [],\n  \"author\": \"\",\n  \"license\": \"ISC\",\n  \"private\": true,\n  \"dependencies\": {\n    \"jose\": \"^6.2.2\",\n    \"next\": \"^16.2.4\",\n    \"postgres\": \"^3.4.9\",\n    \"react\": \"^19.2.5\",\n    \"react-dom\": \"^19.2.5\",\n    \"zod\": \"^4.3.6\"\n  },\n  \"devDependencies\": {\n    \"@playwright/test\": \"^1.59.1\",\n    \"@testing-library/jest-dom\": \"^6.9.1\",\n    \"@testing-library/react\": \"^16.3.2\",\n    \"@testing-library/user-event\": \"^14.6.1\",\n    \"@types/node\": \"^25.6.0\",\n    \"@types/react\": \"^19.2.14\",\n    \"@types/react-dom\": \"^19.2.3\",\n    \"@vitejs/plugin-react\": \"^4.3.4\",\n    \"eslint\": \"^9.39.4\",\n    \"eslint-config-next\": \"^16.2.4\",\n    \"jsdom\": \"^24.1.3\",\n    \"typescript\": \"^6.0.3\",\n    \"vite\": \"^5.4.21\",\n    \"vitest\": \"3.2.4\"\n  },\n  \"packageManager\": \"pnpm@10.33.0\"\n}\n","numLines":46,"startLine":1,"totalLines":46}}}
