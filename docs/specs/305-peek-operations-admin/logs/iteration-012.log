{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TKquhKXB9w9nJjHkiiAH3P","type":"tool_result","content":"1\t// Server-only audit writer for peek (FR-11).\n2\t//\n3\t// Writes `peek.*` events into the existing `operator_events` table so internal\n4\t// access (`peek.search`, `peek.user.view_sensitive`, `peek.export`,\n5\t// `peek.access.denied`) and admin changes (`peek.change.applied`,\n6\t// `peek.change.rejected`) leave a reviewable trail without a new migration.\n7\t//\n8\t// Behavior contract:\n9\t// - Every payload runs through `redactPayload` before persistence; secrets\n10\t//   never reach the DB.\n11\t// - Inserts go to a single `operator_events` row keyed by `event_type`. The\n12\t//   `pda` column is left null because peek audit records are not round-keyed.\n13\t// - Insert failures are logged server-side and returned as a structured\n14\t//   `{ ok: false, reason }`. The caller MUST NOT propagate the failure detail\n15\t//   to the browser; sensitive data must not leak through error rendering.\n16\t\n17\timport type { Sql } from \"postgres\";\n18\timport {\n19\t  type PeekAuditEventType,\n20\t  type PeekAuditPayload,\n21\t} from \"../../lib/types/peek\";\n22\timport { getSqlClient } from \"../db/client\";\n23\timport { redactPayload } from \"./redact\";\n24\t\n25\texport type PeekAuditInput = {\n26\t  eventType: PeekAuditEventType;\n27\t  payload: PeekAuditPayload;\n28\t};\n29\t\n30\texport type PeekAuditWriteResult =\n31\t  | { ok: true }\n32\t  | { ok: false; reason: \"invalid_payload\" | \"insert_failed\" };\n33\t\n34\texport type PeekAuditWriterOptions = {\n35\t  sql?: Sql;\n36\t  logger?: (message: string, context: Record<string, unknown>) => void;\n37\t};\n38\t\n39\tfunction defaultLogger(\n40\t  message: string,\n41\t  context: Record<string, unknown>,\n42\t): void {\n43\t  // Server-only console logging; never returned to the browser.\n44\t  console.error(message, context);\n45\t}\n46\t\n47\texport async function writePeekAuditEvent(\n48\t  input: PeekAuditInput,\n49\t  options: PeekAuditWriterOptions = {},\n50\t): Promise<PeekAuditWriteResult> {\n51\t  if (!input.payload.actorEmail) {\n52\t    return { ok: false, reason: \"invalid_payload\" };\n53\t  }\n54\t\n55\t  const safePayload = redactPayload(input.payload);\n56\t  const sql = options.sql ?? getSqlClient();\n57\t  const logger = options.logger ?? defaultLogger;\n58\t\n59\t  try {\n60\t    await sql`\n61\t      insert into operator_events (event_type, payload)\n62\t      values (${input.eventType}, ${sql.json(\n63\t        safePayload as unknown as Parameters<typeof sql.json>[0],\n64\t      )})\n65\t    `;\n66\t    return { ok: true };\n67\t  } catch (error) {\n68\t    logger(\"[peek-audit] insert failed\", {\n69\t      eventType: input.eventType,\n70\t      message: error instanceof Error ? error.message : \"unknown\",\n71\t    });\n72\t    return { ok: false, reason: \"insert_failed\" };\n73\t  }\n74\t}\n75\t"}]},"parent_tool_use_id":null,"session_id":"443dea4c-b718-4ccf-a11b-4dc193e5bf07","uuid":"998a3e39-3403-4e83-a713-13ee29bafe9f","timestamp":"2026-04-25T11:10:57.607Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/audit/writer.ts","content":"// Server-only audit writer for peek (FR-11).\n//\n// Writes `peek.*` events into the existing `operator_events` table so internal\n// access (`peek.search`, `peek.user.view_sensitive`, `peek.export`,\n// `peek.access.denied`) and admin changes (`peek.change.applied`,\n// `peek.change.rejected`) leave a reviewable trail without a new migration.\n//\n// Behavior contract:\n// - Every payload runs through `redactPayload` before persistence; secrets\n//   never reach the DB.\n// - Inserts go to a single `operator_events` row keyed by `event_type`. The\n//   `pda` column is left null because peek audit records are not round-keyed.\n// - Insert failures are logged server-side and returned as a structured\n//   `{ ok: false, reason }`. The caller MUST NOT propagate the failure detail\n//   to the browser; sensitive data must not leak through error rendering.\n\nimport type { Sql } from \"postgres\";\nimport {\n  type PeekAuditEventType,\n  type PeekAuditPayload,\n} from \"../../lib/types/peek\";\nimport { getSqlClient } from \"../db/client\";\nimport { redactPayload } from \"./redact\";\n\nexport type PeekAuditInput = {\n  eventType: PeekAuditEventType;\n  payload: PeekAuditPayload;\n};\n\nexport type PeekAuditWriteResult =\n  | { ok: true }\n  | { ok: false; reason: \"invalid_payload\" | \"insert_failed\" };\n\nexport type PeekAuditWriterOptions = {\n  sql?: Sql;\n  logger?: (message: string, context: Record<string, unknown>) => void;\n};\n\nfunction defaultLogger(\n  message: string,\n  context: Record<string, unknown>,\n): void {\n  // Server-only console logging; never returned to the browser.\n  console.error(message, context);\n}\n\nexport async function writePeekAuditEvent(\n  input: PeekAuditInput,\n  options: PeekAuditWriterOptions = {},\n): Promise<PeekAuditWriteResult> {\n  if (!input.payload.actorEmail) {\n    return { ok: false, reason: \"invalid_payload\" };\n  }\n\n  const safePayload = redactPayload(input.payload);\n  const sql = options.sql ?? getSqlClient();\n  const logger = options.logger ?? defaultLogger;\n\n  try {\n    await sql`\n      insert into operator_events (event_type, payload)\n      values (${input.eventType}, ${sql.json(\n        safePayload as unknown as Parameters<typeof sql.json>[0],\n      )})\n    `;\n    return { ok: true };\n  } catch (error) {\n    logger(\"[peek-audit] insert failed\", {\n      eventType: input.eventType,\n      message: error instanceof Error ? error.message : \"unknown\",\n    });\n    return { ok: false, reason: \"insert_failed\" };\n  }\n}\n","numLines":75,"startLine":1,"totalLines":75}}}
