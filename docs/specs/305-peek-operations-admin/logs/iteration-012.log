{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_0184otgeR6RPTh9atYSFTL9n","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01S95F6DqJJNiwX2G1w9y6Fu","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/audit/__tests__/writer.test.ts","content":"import { describe, expect, it, vi } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_AUDIT_REDACTED,\n  type PeekAuditPayload,\n} from \"../../../lib/types/peek\";\nimport { writePeekAuditEvent } from \"../writer\";\n\ntype SqlCall = { strings: ReadonlyArray<string>; values: ReadonlyArray<unknown> };\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n  jsonArgs: ReadonlyArray<unknown>;\n};\n\nconst JSON_SENTINEL = Symbol(\"peek-audit-json\");\n\nfunction createSqlMock(options: { error?: Error } = {}): SqlMock {\n  const calls: SqlCall[] = [];\n  const jsonArgs: unknown[] = [];\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    calls.push({ strings: [...strings], values: [...values] });\n    if (options.error) return Promise.reject(options.error);\n    return Promise.resolve([]);\n  };\n\n  const sql = Object.assign(fn, {\n    json(value: unknown) {\n      jsonArgs.push(value);\n      return { [JSON_SENTINEL]: value };\n    },\n  }) as unknown as Sql;\n\n  return { sql, calls, jsonArgs };\n}\n\nfunction basePayload(\n  overrides: Partial<PeekAuditPayload> = {},\n): PeekAuditPayload {\n  return {\n    actorEmail: \"alice@example.com\",\n    route: null,\n    actionId: null,\n    resourceType: null,\n    resourceId: null,\n    filterSummary: null,\n    resultCount: null,\n    requestId: null,\n    rejectionReason: null,\n    changes: null,\n    ...overrides,\n  };\n}\n\nfunction persistedPayload(mock: SqlMock): PeekAuditPayload {\n  expect(mock.jsonArgs).toHaveLength(1);\n  return mock.jsonArgs[0] as PeekAuditPayload;\n}\n\ndescribe(\"writePeekAuditEvent\", () => {\n  it(\"persists a sensitive read with the full FR-11 payload\", async () => {\n    const mock = createSqlMock();\n\n    const result = await writePeekAuditEvent(\n      {\n        eventType: \"peek.user.view_sensitive\",\n        payload: basePayload({\n          route: \"/users/u-1\",\n          actionId: \"user.view_sensitive\",\n          resourceType: \"user\",\n          resourceId: \"u-1\",\n          filterSummary: \"tab=identity\",\n          resultCount: 1,\n          requestId: \"req-123\",\n        }),\n      },\n      { sql: mock.sql },\n    );\n\n    expect(result).toEqual({ ok: true });\n    expect(mock.calls).toHaveLength(1);\n    const insert = mock.calls[0];\n    expect(insert.strings.join(\" \")).toMatch(/insert into operator_events/i);\n    expect(insert.values[0]).toBe(\"peek.user.view_sensitive\");\n\n    const stored = persistedPayload(mock);\n    expect(stored).toEqual({\n      actorEmail: \"alice@example.com\",\n      route: \"/users/u-1\",\n      actionId: \"user.view_sensitive\",\n      resourceType: \"user\",\n      resourceId: \"u-1\",\n      filterSummary: \"tab=identity\",\n      resultCount: 1,\n      requestId: \"req-123\",\n      rejectionReason: null,\n      changes: null,\n    });\n  });\n\n  it(\"persists an export event with result-count and filter summary\", async () => {\n    const mock = createSqlMock();\n\n    const result = await writePeekAuditEvent(\n      {\n        eventType: \"peek.export\",\n        payload: basePayload({\n          route: \"/growth/referrals/export\",\n          actionId: \"referrers.export\",\n          resourceType: \"export\",\n          resourceId: null,\n          filterSummary: \"status=pending&from=2026-04-01\",\n          resultCount: 142,\n          requestId: \"req-export-7\",\n        }),\n      },\n      { sql: mock.sql },\n    );\n\n    expect(result).toEqual({ ok: true });\n    expect(mock.calls[0]?.values[0]).toBe(\"peek.export\");\n\n    const stored = persistedPayload(mock);\n    expect(stored.actorEmail).toBe(\"alice@example.com\");\n    expect(stored.actionId).toBe(\"referrers.export\");\n    expect(stored.resultCount).toBe(142);\n    expect(stored.filterSummary).toBe(\"status=pending&from=2026-04-01\");\n  });\n\n  it(\"persists an access-denied event with the route and rejection reason\", async () => {\n    const mock = createSqlMock();\n\n    const result = await writePeekAuditEvent(\n      {\n        eventType: \"peek.access.denied\",\n        payload: basePayload({\n          route: \"/audit\",\n          actionId: null,\n          rejectionReason: \"role_required:admin\",\n          resourceType: \"route\",\n          resourceId: \"/audit\",\n        }),\n      },\n      { sql: mock.sql },\n    );\n\n    expect(result).toEqual({ ok: true });\n    expect(mock.calls[0]?.values[0]).toBe(\"peek.access.denied\");\n\n    const stored = persistedPayload(mock);\n    expect(stored.rejectionReason).toBe(\"role_required:admin\");\n    expect(stored.route).toBe(\"/audit\");\n  });\n\n  it(\"persists a mutation-applied event with before/after changes\", async () => {\n    const mock = createSqlMock();\n\n    const result = await writePeekAuditEvent(\n      {\n        eventType: \"peek.change.applied\",\n        payload: basePayload({\n          route: \"/growth/kol\",\n          actionId: \"kol_rate.update\",\n          resourceType: \"referral_kol_rates\",\n          resourceId: \"kol-7\",\n          changes: [\n            { field: \"rate_bps\", before: 1000, after: 1500 },\n            { field: \"set_by\", before: \"alice@example.com\", after: \"alice@example.com\" },\n          ],\n        }),\n      },\n      { sql: mock.sql },\n    );\n\n    expect(result).toEqual({ ok: true });\n    expect(mock.calls[0]?.values[0]).toBe(\"peek.change.applied\");\n\n    const stored = persistedPayload(mock);\n    expect(stored.changes).toEqual([\n      { field: \"rate_bps\", before: 1000, after: 1500 },\n      { field: \"set_by\", before: \"alice@example.com\", after: \"alice@example.com\" },\n    ]);\n  });\n\n  it(\"persists a mutation-rejected event with the rejection reason and no submitted secrets\", async () => {\n    const mock = createSqlMock();\n\n    const result = await writePeekAuditEvent(\n      {\n        eventType: \"peek.change.rejected\",\n        payload: basePayload({\n          route: \"/economy/rewards\",\n          actionId: \"reward_config.update\",\n          resourceType: \"reward_config\",\n          resourceId: \"max_daily_payout_lamports\",\n          rejectionReason: \"value_out_of_range\",\n          changes: [\n            { field: \"value\", before: \"100000\", after: \"999999999999\" },\n          ],\n        }),\n      },\n      { sql: mock.sql },\n    );\n\n    expect(result).toEqual({ ok: true });\n    expect(mock.calls[0]?.values[0]).toBe(\"peek.change.rejected\");\n\n    const stored = persistedPayload(mock);\n    expect(stored.rejectionReason).toBe(\"value_out_of_range\");\n    expect(stored.changes?.[0]?.after).toBe(\"999999999999\");\n  });\n\n  it(\"redacts JWT tokens, DB URLs, private keys, Bearer headers, and CF access headers before persisting\", async () => {\n    const mock = createSqlMock();\n\n    const jwt =\n      \"eyJhbGciOiJSUzI1NiJ9.eyJzdWIiOiJhbGljZSJ9.signaturesignaturesignature\";\n    const dbUrl = \"postgresql://user:pw@db.internal:5432/peek?sslmode=require\";\n    const privateKey = \"-----BEGIN RSA PRIVATE KEY-----\\nABCDEF\\n-----END RSA PRIVATE KEY-----\";\n    const bearer = \"Bearer abc123def456ghi789\";\n    const cfHeader = \"cf-access-jwt-assertion: somevalue\";\n\n    const result = await writePeekAuditEvent(\n      {\n        eventType: \"peek.search\",\n        payload: basePayload({\n          route: dbUrl,\n          actionId: bearer,\n          resourceType: \"search\",\n          resourceId: jwt,\n          filterSummary: cfHeader,\n          requestId: privateKey,\n          changes: [\n            { field: \"token\", before: jwt, after: \"harmless\" },\n            { field: \"conn\", before: \"harmless\", after: dbUrl },\n          ],\n        }),\n      },\n      { sql: mock.sql },\n    );\n\n    expect(result).toEqual({ ok: true });\n    const stored = persistedPayload(mock);\n\n    expect(stored.route).toBe(PEEK_AUDIT_REDACTED);\n    expect(stored.actionId).toBe(PEEK_AUDIT_REDACTED);\n    expect(stored.resourceId).toBe(PEEK_AUDIT_REDACTED);\n    expect(stored.filterSummary).toBe(PEEK_AUDIT_REDACTED);\n    expect(stored.requestId).toBe(PEEK_AUDIT_REDACTED);\n    expect(stored.changes).toEqual([\n      { field: \"token\", before: PEEK_AUDIT_REDACTED, after: \"harmless\" },\n      { field: \"conn\", before: \"harmless\", after: PEEK_AUDIT_REDACTED },\n    ]);\n\n    const serialized = JSON.stringify(stored);\n    expect(serialized).not.toContain(jwt);\n    expect(serialized).not.toContain(dbUrl);\n    expect(serialized).not.toContain(\"PRIVATE KEY\");\n    expect(serialized).not.toContain(\"Bearer \");\n    expect(serialized).not.toContain(\"cf-access-jwt-assertion\");\n  });\n\n  it(\"rejects payloads with an empty actor email without inserting a row\", async () => {\n    const mock = createSqlMock();\n\n    const result = await writePeekAuditEvent(\n      {\n        eventType: \"peek.search\",\n        payload: basePayload({ actorEmail: \"\" }),\n      },\n      { sql: mock.sql },\n    );\n\n    expect(result).toEqual({ ok: false, reason: \"invalid_payload\" });\n    expect(mock.calls).toHaveLength(0);\n    expect(mock.jsonArgs).toHaveLength(0);\n  });\n\n  it(\"returns insert_failed and logs the error when the DB rejects the insert\", async () => {\n    const mock = createSqlMock({\n      error: new Error(\"connection refused: postgres://hidden:secret@host\"),\n    });\n    const logger = vi.fn();\n\n    const result = await writePeekAuditEvent(\n      {\n        eventType: \"peek.export\",\n        payload: basePayload({ actionId: \"users.export\" }),\n      },\n      { sql: mock.sql, logger },\n    );\n\n    expect(result).toEqual({ ok: false, reason: \"insert_failed\" });\n    expect(logger).toHaveBeenCalledTimes(1);\n    const [message, context] = logger.mock.calls[0] ?? [];\n    expect(message).toBe(\"[peek-audit] insert failed\");\n    expect(context).toMatchObject({ eventType: \"peek.export\" });\n  });\n\n  it(\"does not propagate the underlying DB error to the caller\", async () => {\n    const mock = createSqlMock({\n      error: new Error(\"internal: schema=peek password=hunter2\"),\n    });\n    // Suppress the default console.error so the failure path stays quiet during the test.\n    const logger = vi.fn();\n\n    const result = await writePeekAuditEvent(\n      {\n        eventType: \"peek.access.denied\",\n        payload: basePayload(),\n      },\n      { sql: mock.sql, logger },\n    );\n\n    expect(result).toEqual({ ok: false, reason: \"insert_failed\" });\n    // The result is a closed union; \"insert_failed\" carries no error detail.\n    expect(JSON.stringify(result)).not.toContain(\"hunter2\");\n    expect(JSON.stringify(result)).not.toContain(\"password\");\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1874,"cache_read_input_tokens":84995,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1874},"output_tokens":6,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"443dea4c-b718-4ccf-a11b-4dc193e5bf07","uuid":"68929dda-3838-429b-8c25-cdd2045ded63"}
