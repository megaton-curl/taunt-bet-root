{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Hb4QTLLELbrzt3GhFK8PPb","type":"tool_result","content":"1\t// Browser-safe view-model primitives for `peek`.\n2\t//\n3\t// Foundational shapes used across feature pages: metric metadata (FR-4),\n4\t// URL-addressable table filters, pagination, sort, and a small table-row base\n5\t// type that per-feature row types can extend. Per-feature shapes (PeekUserRow,\n6\t// PeekUserDetail, future referral/game/queue/etc. rows) live alongside or\n7\t// extend these primitives.\n8\t\n9\timport type { PeekRole } from \"../access-policy\";\n10\t\n11\t// --- Existing 303-era shapes (kept stable for current callers) ---------------\n12\t\n13\texport type PeekSummary = {\n14\t  totalUsers: number;\n15\t  totalUsersWithCodes: number;\n16\t  totalReferredUsers: number;\n17\t  totalUniqueReferrers: number;\n18\t};\n19\t\n20\texport type PeekUserRow = {\n21\t  userId: string;\n22\t  username: string | null;\n23\t  wallet: string;\n24\t  joinedAt: string;\n25\t  referralCode: string | null;\n26\t  referrerUserId: string | null;\n27\t  referrerCode: string | null;\n28\t  refereeCount: number;\n29\t  telegramUsername: string | null;\n30\t  telegramUserId: string | null;\n31\t};\n32\t\n33\texport type PeekUserDetail = {\n34\t  user: PeekUserRow;\n35\t  inboundReferral: {\n36\t    referrerUserId: string | null;\n37\t    referrerCode: string | null;\n38\t    linkedAt: string | null;\n39\t  };\n40\t  outboundReferees: Array<{\n41\t    refereeUserId: string;\n42\t    refereeUsername: string | null;\n43\t    createdAt: string;\n44\t  }>;\n45\t  telegram: {\n46\t    state: \"active\" | \"none\";\n47\t    telegramUserId: string | null;\n48\t    telegramUsername: string | null;\n49\t  };\n50\t};\n51\t\n52\t// --- Actor view model (browser-safe) -----------------------------------------\n53\t\n54\texport type PeekActorView = {\n55\t  email: string;\n56\t  role: PeekRole;\n57\t};\n58\t\n59\t// --- Metric metadata (FR-4) --------------------------------------------------\n60\t//\n61\t// Each metric carries the bookkeeping required by the data-surfacing standard:\n62\t// stable id, label, value, source table/query, time window, \"as of\" timestamp,\n63\t// short definition, optional unit, and optional drill-down link to the filtered\n64\t// detail rows behind the number.\n65\t\n66\texport type PeekMetricFreshness = \"live\" | \"cached\" | \"manual\" | \"sampled\";\n67\t\n68\texport type PeekMetric = {\n69\t  id: string;\n70\t  label: string;\n71\t  value: number | string | null;\n72\t  valueDisplay: string;\n73\t  unit: string | null;\n74\t  source: string;\n75\t  windowLabel: string;\n76\t  asOf: string | null;\n77\t  definition: string;\n78\t  freshness: PeekMetricFreshness;\n79\t  drilldownHref: string | null;\n80\t};\n81\t\n82\t// --- Pagination primitive ----------------------------------------------------\n83\t\n84\texport type PeekPagination = {\n85\t  page: number;\n86\t  pageSize: number;\n87\t  totalCount: number;\n88\t  totalPages: number;\n89\t};\n90\t\n91\t// --- Sort primitive ----------------------------------------------------------\n92\t\n93\texport type PeekSortDirection = \"asc\" | \"desc\";\n94\t\n95\texport type PeekTableSort = {\n96\t  column: string;\n97\t  direction: PeekSortDirection;\n98\t};\n99\t\n100\t// --- Table filter primitive (URL-addressable) --------------------------------\n101\t\n102\texport type PeekFilterKind =\n103\t  | \"text\"\n104\t  | \"select\"\n105\t  | \"boolean\"\n106\t  | \"date\"\n107\t  | \"dateRange\";\n108\t\n109\texport type PeekFilterOption = {\n110\t  value: string;\n111\t  label: string;\n112\t};\n113\t\n114\texport type PeekTableFilter = {\n115\t  id: string;\n116\t  label: string;\n117\t  kind: PeekFilterKind;\n118\t  value: string | null;\n119\t  options: ReadonlyArray<PeekFilterOption> | null;\n120\t  placeholder: string | null;\n121\t  required: boolean;\n122\t};\n123\t\n124\t// --- Status chip tone (shared) -----------------------------------------------\n125\t\n126\texport type PeekStatusTone =\n127\t  | \"neutral\"\n128\t  | \"positive\"\n129\t  | \"warning\"\n130\t  | \"negative\"\n131\t  | \"info\";\n132\t\n133\t// --- Empty-state primitive ---------------------------------------------------\n134\t\n135\texport type PeekEmptyState = {\n136\t  title: string;\n137\t  body: string | null;\n138\t};\n139\t\n140\t// --- Table row + column primitives -------------------------------------------\n141\t//\n142\t// Per-feature row types extend `PeekTableRowBase` for the shared identifier +\n143\t// optional drill-down link, then add feature-specific fields. The shared dense\n144\t// table component reads `columns` for layout and per-row data via the typed\n145\t// row shape supplied by the feature page.\n146\t\n147\texport type PeekTableColumnAlign = \"left\" | \"right\" | \"center\";\n148\t\n149\texport type PeekTableColumn = {\n150\t  id: string;\n151\t  label: string;\n152\t  align: PeekTableColumnAlign;\n153\t  sortable: boolean;\n154\t};\n155\t\n156\texport type PeekTableRowBase = {\n157\t  id: string;\n158\t  href: string | null;\n159\t};\n160\t\n161\texport type PeekTableViewModel<TRow extends PeekTableRowBase> = {\n162\t  columns: ReadonlyArray<PeekTableColumn>;\n163\t  rows: ReadonlyArray<TRow>;\n164\t  pagination: PeekPagination;\n165\t  filters: ReadonlyArray<PeekTableFilter>;\n166\t  sort: PeekTableSort | null;\n167\t  empty: PeekEmptyState;\n168\t};\n169\t\n170\t// --- Audit event contracts (FR-11) -------------------------------------------\n171\t//\n172\t// Browser-safe view of `operator_events` rows the audit writer produces under\n173\t// `peek.*` event types. The `PeekAuditPayload` shape pins the fields required by\n174\t// FR-11 so the writer (`peek/src/server/audit/**`, next iteration) and the audit\n175\t// view (`/audit`, later iteration) agree on a serialization contract. Secrets\n176\t// (JWTs, access tokens, DB URLs, private keys, raw secrets) must be replaced by\n177\t// `PEEK_AUDIT_REDACTED` before persisting; the audit-view component renders the\n178\t// token verbatim so reviewers can see that a field was redacted (not silently\n179\t// absent).\n180\t\n181\texport type PeekAuditEventType =\n182\t  | \"peek.search\"\n183\t  | \"peek.user.view_sensitive\"\n184\t  | \"peek.export\"\n185\t  | \"peek.access.denied\"\n186\t  | \"peek.change.applied\"\n187\t  | \"peek.change.rejected\";\n188\t\n189\texport const PEEK_AUDIT_EVENT_TYPES: ReadonlyArray<PeekAuditEventType> = [\n190\t  \"peek.search\",\n191\t  \"peek.user.view_sensitive\",\n192\t  \"peek.export\",\n193\t  \"peek.access.denied\",\n194\t  \"peek.change.applied\",\n195\t  \"peek.change.rejected\",\n196\t];\n197\t\n198\texport function isPeekAuditEventType(\n199\t  value: unknown,\n200\t): value is PeekAuditEventType {\n201\t  return (\n202\t    typeof value === \"string\" &&\n203\t    (PEEK_AUDIT_EVENT_TYPES as ReadonlyArray<string>).includes(value)\n204\t  );\n205\t}\n206\t\n207\texport const PEEK_AUDIT_REDACTED = \"[REDACTED]\";\n208\t\n209\texport type PeekAuditScalar = string | number | boolean | null;\n210\t\n211\texport type PeekAuditChange = {\n212\t  field: string;\n213\t  before: PeekAuditScalar;\n214\t  after: PeekAuditScalar;\n215\t};\n216\t\n217\texport type PeekAuditPayload = {\n218\t  actorEmail: string;\n219\t  route: string | null;\n220\t  actionId: string | null;\n221\t  resourceType: string | null;\n222\t  resourceId: string | null;\n223\t  filterSummary: string | null;\n224\t  resultCount: number | null;\n225\t  requestId: string | null;\n226\t  rejectionReason: string | null;\n227\t  changes: ReadonlyArray<PeekAuditChange> | null;\n228\t};\n229\t\n230\texport type PeekAuditEvent = {\n231\t  id: string;\n232\t  eventType: PeekAuditEventType;\n233\t  createdAt: string;\n234\t  payload: PeekAuditPayload;\n235\t};\n236\t\n237\t// --- Export contracts (FR-12) ------------------------------------------------\n238\t//\n239\t// Exports are server-rendered CSVs gated by the same page-level access as the\n240\t// source page, bounded by a server-side row cap, named with a deterministic\n241\t// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n242\t// bytes return. Export rows reuse the table view-model column ids so the export\n243\t// shape stays in lockstep with the rendered table; values are pre-formatted\n244\t// strings so CSV serialization stays straightforward and locale-stable.\n245\t\n246\texport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n247\t\n248\texport type PeekExportEntity =\n249\t  | \"users\"\n250\t  | \"referrers\"\n251\t  | \"kol\"\n252\t  | \"claims\"\n253\t  | \"rounds\"\n254\t  | \"transactions\"\n255\t  | \"queue\"\n256\t  | \"audit\";\n257\t\n258\texport type PeekExportRow = Record<string, string>;\n259\t\n260\texport type PeekExportFilenameInput = {\n261\t  entity: PeekExportEntity;\n262\t  date: string;\n263\t  filterSlug: string;\n264\t};\n265\t\n266\texport type PeekExportResult = {\n267\t  filename: string;\n268\t  rowCount: number;\n269\t  rowCap: number;\n270\t  rowCapApplied: boolean;\n271\t  columns: ReadonlyArray<PeekTableColumn>;\n272\t  rows: ReadonlyArray<PeekExportRow>;\n273\t};\n274\t"}]},"parent_tool_use_id":null,"session_id":"443dea4c-b718-4ccf-a11b-4dc193e5bf07","uuid":"78265929-f856-4d84-b52d-0cf6279c7037","timestamp":"2026-04-25T11:11:03.285Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","content":"// Browser-safe view-model primitives for `peek`.\n//\n// Foundational shapes used across feature pages: metric metadata (FR-4),\n// URL-addressable table filters, pagination, sort, and a small table-row base\n// type that per-feature row types can extend. Per-feature shapes (PeekUserRow,\n// PeekUserDetail, future referral/game/queue/etc. rows) live alongside or\n// extend these primitives.\n\nimport type { PeekRole } from \"../access-policy\";\n\n// --- Existing 303-era shapes (kept stable for current callers) ---------------\n\nexport type PeekSummary = {\n  totalUsers: number;\n  totalUsersWithCodes: number;\n  totalReferredUsers: number;\n  totalUniqueReferrers: number;\n};\n\nexport type PeekUserRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  joinedAt: string;\n  referralCode: string | null;\n  referrerUserId: string | null;\n  referrerCode: string | null;\n  refereeCount: number;\n  telegramUsername: string | null;\n  telegramUserId: string | null;\n};\n\nexport type PeekUserDetail = {\n  user: PeekUserRow;\n  inboundReferral: {\n    referrerUserId: string | null;\n    referrerCode: string | null;\n    linkedAt: string | null;\n  };\n  outboundReferees: Array<{\n    refereeUserId: string;\n    refereeUsername: string | null;\n    createdAt: string;\n  }>;\n  telegram: {\n    state: \"active\" | \"none\";\n    telegramUserId: string | null;\n    telegramUsername: string | null;\n  };\n};\n\n// --- Actor view model (browser-safe) -----------------------------------------\n\nexport type PeekActorView = {\n  email: string;\n  role: PeekRole;\n};\n\n// --- Metric metadata (FR-4) --------------------------------------------------\n//\n// Each metric carries the bookkeeping required by the data-surfacing standard:\n// stable id, label, value, source table/query, time window, \"as of\" timestamp,\n// short definition, optional unit, and optional drill-down link to the filtered\n// detail rows behind the number.\n\nexport type PeekMetricFreshness = \"live\" | \"cached\" | \"manual\" | \"sampled\";\n\nexport type PeekMetric = {\n  id: string;\n  label: string;\n  value: number | string | null;\n  valueDisplay: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  asOf: string | null;\n  definition: string;\n  freshness: PeekMetricFreshness;\n  drilldownHref: string | null;\n};\n\n// --- Pagination primitive ----------------------------------------------------\n\nexport type PeekPagination = {\n  page: number;\n  pageSize: number;\n  totalCount: number;\n  totalPages: number;\n};\n\n// --- Sort primitive ----------------------------------------------------------\n\nexport type PeekSortDirection = \"asc\" | \"desc\";\n\nexport type PeekTableSort = {\n  column: string;\n  direction: PeekSortDirection;\n};\n\n// --- Table filter primitive (URL-addressable) --------------------------------\n\nexport type PeekFilterKind =\n  | \"text\"\n  | \"select\"\n  | \"boolean\"\n  | \"date\"\n  | \"dateRange\";\n\nexport type PeekFilterOption = {\n  value: string;\n  label: string;\n};\n\nexport type PeekTableFilter = {\n  id: string;\n  label: string;\n  kind: PeekFilterKind;\n  value: string | null;\n  options: ReadonlyArray<PeekFilterOption> | null;\n  placeholder: string | null;\n  required: boolean;\n};\n\n// --- Status chip tone (shared) -----------------------------------------------\n\nexport type PeekStatusTone =\n  | \"neutral\"\n  | \"positive\"\n  | \"warning\"\n  | \"negative\"\n  | \"info\";\n\n// --- Empty-state primitive ---------------------------------------------------\n\nexport type PeekEmptyState = {\n  title: string;\n  body: string | null;\n};\n\n// --- Table row + column primitives -------------------------------------------\n//\n// Per-feature row types extend `PeekTableRowBase` for the shared identifier +\n// optional drill-down link, then add feature-specific fields. The shared dense\n// table component reads `columns` for layout and per-row data via the typed\n// row shape supplied by the feature page.\n\nexport type PeekTableColumnAlign = \"left\" | \"right\" | \"center\";\n\nexport type PeekTableColumn = {\n  id: string;\n  label: string;\n  align: PeekTableColumnAlign;\n  sortable: boolean;\n};\n\nexport type PeekTableRowBase = {\n  id: string;\n  href: string | null;\n};\n\nexport type PeekTableViewModel<TRow extends PeekTableRowBase> = {\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<TRow>;\n  pagination: PeekPagination;\n  filters: ReadonlyArray<PeekTableFilter>;\n  sort: PeekTableSort | null;\n  empty: PeekEmptyState;\n};\n\n// --- Audit event contracts (FR-11) -------------------------------------------\n//\n// Browser-safe view of `operator_events` rows the audit writer produces under\n// `peek.*` event types. The `PeekAuditPayload` shape pins the fields required by\n// FR-11 so the writer (`peek/src/server/audit/**`, next iteration) and the audit\n// view (`/audit`, later iteration) agree on a serialization contract. Secrets\n// (JWTs, access tokens, DB URLs, private keys, raw secrets) must be replaced by\n// `PEEK_AUDIT_REDACTED` before persisting; the audit-view component renders the\n// token verbatim so reviewers can see that a field was redacted (not silently\n// absent).\n\nexport type PeekAuditEventType =\n  | \"peek.search\"\n  | \"peek.user.view_sensitive\"\n  | \"peek.export\"\n  | \"peek.access.denied\"\n  | \"peek.change.applied\"\n  | \"peek.change.rejected\";\n\nexport const PEEK_AUDIT_EVENT_TYPES: ReadonlyArray<PeekAuditEventType> = [\n  \"peek.search\",\n  \"peek.user.view_sensitive\",\n  \"peek.export\",\n  \"peek.access.denied\",\n  \"peek.change.applied\",\n  \"peek.change.rejected\",\n];\n\nexport function isPeekAuditEventType(\n  value: unknown,\n): value is PeekAuditEventType {\n  return (\n    typeof value === \"string\" &&\n    (PEEK_AUDIT_EVENT_TYPES as ReadonlyArray<string>).includes(value)\n  );\n}\n\nexport const PEEK_AUDIT_REDACTED = \"[REDACTED]\";\n\nexport type PeekAuditScalar = string | number | boolean | null;\n\nexport type PeekAuditChange = {\n  field: string;\n  before: PeekAuditScalar;\n  after: PeekAuditScalar;\n};\n\nexport type PeekAuditPayload = {\n  actorEmail: string;\n  route: string | null;\n  actionId: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  filterSummary: string | null;\n  resultCount: number | null;\n  requestId: string | null;\n  rejectionReason: string | null;\n  changes: ReadonlyArray<PeekAuditChange> | null;\n};\n\nexport type PeekAuditEvent = {\n  id: string;\n  eventType: PeekAuditEventType;\n  createdAt: string;\n  payload: PeekAuditPayload;\n};\n\n// --- Export contracts (FR-12) ------------------------------------------------\n//\n// Exports are server-rendered CSVs gated by the same page-level access as the\n// source page, bounded by a server-side row cap, named with a deterministic\n// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n// bytes return. Export rows reuse the table view-model column ids so the export\n// shape stays in lockstep with the rendered table; values are pre-formatted\n// strings so CSV serialization stays straightforward and locale-stable.\n\nexport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n\nexport type PeekExportEntity =\n  | \"users\"\n  | \"referrers\"\n  | \"kol\"\n  | \"claims\"\n  | \"rounds\"\n  | \"transactions\"\n  | \"queue\"\n  | \"audit\";\n\nexport type PeekExportRow = Record<string, string>;\n\nexport type PeekExportFilenameInput = {\n  entity: PeekExportEntity;\n  date: string;\n  filterSlug: string;\n};\n\nexport type PeekExportResult = {\n  filename: string;\n  rowCount: number;\n  rowCap: number;\n  rowCapApplied: boolean;\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<PeekExportRow>;\n};\n","numLines":274,"startLine":1,"totalLines":274}}}
