{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QqyBoUE1Hs1vSLhFs7APkv","type":"tool_result","content":"1\timport { afterEach, describe, expect, it, vi } from \"vitest\";\n2\timport {\n3\t  getPeekActorContext,\n4\t  getRequiredRolesForAction,\n5\t  getRequiredRolesForRoute,\n6\t  isActionAllowedForRole,\n7\t  isRouteAllowedForRole,\n8\t  loadPeekRolePolicyFromEnv,\n9\t  normalizeActorEmail,\n10\t  parsePeekRolePolicy,\n11\t  PEEK_ACTION_RULES,\n12\t  PEEK_DEFAULT_ROUTE_ROLES,\n13\t  PEEK_ROUTE_RULES,\n14\t  resolveRoleForEmail,\n15\t  type PeekActionRule,\n16\t  type PeekRolePolicy,\n17\t  type PeekRouteRule,\n18\t} from \"../access-policy\";\n19\timport { VERIFIED_ACCESS_EMAIL_HEADER } from \"../cloudflare-access\";\n20\t\n21\tconst mockHeaders = vi.fn();\n22\tvi.mock(\"next/headers\", () => ({\n23\t  headers: () => mockHeaders(),\n24\t}));\n25\t\n26\tfunction makeHeaders(map: Record<string, string>): Headers {\n27\t  const h = new Headers();\n28\t  for (const [k, v] of Object.entries(map)) h.set(k, v);\n29\t  return h;\n30\t}\n31\t\n32\tdescribe(\"parsePeekRolePolicy\", () => {\n33\t  it(\"returns [] for non-array input\", () => {\n34\t    expect(parsePeekRolePolicy(null)).toEqual([]);\n35\t    expect(parsePeekRolePolicy(undefined)).toEqual([]);\n36\t    expect(parsePeekRolePolicy(\"oops\")).toEqual([]);\n37\t    expect(parsePeekRolePolicy({ match: \"x@y.z\", role: \"admin\" })).toEqual([]);\n38\t  });\n39\t\n40\t  it(\"normalizes match values: trims and lowercases\", () => {\n41\t    expect(\n42\t      parsePeekRolePolicy([\n43\t        { match: \"  Alice@Example.COM \", role: \"admin\" },\n44\t        { match: \"*@Example.COM\", role: \"business\" },\n45\t      ]),\n46\t    ).toEqual([\n47\t      { match: \"alice@example.com\", role: \"admin\" },\n48\t      { match: \"*@example.com\", role: \"business\" },\n49\t    ]);\n50\t  });"}]},"parent_tool_use_id":null,"session_id":"c13e3955-6531-43fa-8b53-b8ade5fa464f","uuid":"1a772dd9-db2f-4f