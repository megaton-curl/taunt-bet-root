le}>{emptyTitle}</p>\n        {emptyBody ? <p style={emptyBodyStyle}>{emptyBody}</p> : null}\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <nav aria-label={ariaLabel} style={navStyle}>\n        <ul style={listStyle}>\n          {sections.map((section) => {\n            const isActive = activeId === section.id;\n            return (\n              <li key={section.id}>\n                <a\n                  href={`#${section.id}`}\n                  aria-current={isActive ? \"true\" : undefined}\n                  style={isActive ? activeLinkStyle : linkStyle}\n                >\n                  {section.label}\n                </a>\n              </li>\n            );\n          })}\n        </ul>\n      </nav>\n      <div style={sectionsStyle}>\n        {sections.map((section) => (\n          <section\n            key={section.id}\n            id={section.id}\n            aria-labelledby={`peek-section-${section.id}-label`}\n            style={sectionStyle}\n          >\n            <h2 id={`peek-section-${section.id}-label`} style={sectionHeadingStyle}>\n              {section.label}\n            </h2>\n            <div>{section.body}</div>\n          </section>\n        ))}\n      </div>\n    </div>\n  );\n}\n\nconst wrapperStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1rem\",\n};\n\nconst navStyle: CSSProperties = {\n  position: \"sticky\",\n  top: 0,\n  background: \"#0b1220\",\n  paddingBlock: \"0.5rem\",\n};\n\nconst listStyle: CSSProperties = {\n  listStyle: \"none\",\n  margin: 0,\n  padding: 0,\n  display: \"flex\",\n  gap: \"0.5rem\",\n  flexWrap: \"wrap\",\n};\n\nconst linkStyle: CSSProperties = {\n  display: \"inline-flex\",\n  alignItems: \"center\",\n  fontSize: \"0.8125rem\",\n  textDecoration: \"none\",\n  color: \"#94a3b8\",\n  padding: \"0.375rem 0.75rem\",\n  borderRadius: \"9999px\",\n  border: \"1px solid #1e293b\",\n};\n\nconst activeLinkStyle: CSSProperties = {\n  ...linkStyle,\n  color: \"#eff6f