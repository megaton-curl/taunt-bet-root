{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014yhi3FZQYvjJ4UGrgMrAXy","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport { render, screen } from \"@testing-library/react\";\n3\timport { EmptyState } from \"../empty-state\";\n4\timport type { PeekEmptyState } from \"../../lib/types/peek\";\n5\t\n6\tconst populatedState: PeekEmptyState = {\n7\t  title: \"No failed claims in this time window.\",\n8\t  body: \"Adjust the date range or status filter to broaden the search.\",\n9\t};\n10\t\n11\tconst sparseState: PeekEmptyState = {\n12\t  title: \"No data available.\",\n13\t  body: null,\n14\t};\n15\t\n16\tdescribe(\"EmptyState\", () => {\n17\t  it(\"populated: renders title + operator-copy body inside a status region\", () => {\n18\t    render(<EmptyState state={populatedState} />);\n19\t\n20\t    const region = screen.getByRole(\"status\");\n21\t    expect(region).toHaveTextContent(\"No failed claims in this time window.\");\n22\t    expect(region).toHaveTextContent(\n23\t      \"Adjust the date range or status filter to broaden the search.\",\n24\t    );\n25\t  });\n26\t\n27\t  it(\"sparse: renders only the title when body is null\", () => {\n28\t    render(<EmptyState state={sparseState} />);\n29\t\n30\t    const region = screen.getByRole(\"status\");\n31\t    expect(region).toHaveTextContent(\"No data available.\");\n32\t    expect(region.querySelectorAll(\"p\").length).toBe(1);\n33\t  });\n34\t\n35\t  it(\"error: renders an alert and not the empty status\", () => {\n36\t    render(<EmptyState state={populatedState} error=\"render failure\" />);\n37\t\n38\t    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n39\t      \"Empty state unavailable: render failure\",\n40\t    );\n41\t    expect(screen.queryByRole(\"status\")).toBeNull();\n42\t  });\n43\t});\n44\t"}]},"parent_tool_use_id":null,"session_id":"c13e3955-6531-43fa-8b53-b8ade5fa464f","uuid":"61067c82-d084-4224-bd1b-d5bda0af2ffb","time