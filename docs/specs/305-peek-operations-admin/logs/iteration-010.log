{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MVMPaBxCv6znvfiYjd62pq","type":"tool_result","content":"1\timport Link from \"next/link\";\n2\timport type { CSSProperties, ReactNode } from \"react\";\n3\timport type {\n4\t  PeekSortDirection,\n5\t  PeekTableRowBase,\n6\t  PeekTableViewModel,\n7\t} from \"../lib/types/peek\";\n8\t\n9\texport type PeekTableProps<TRow extends PeekTableRowBase> = {\n10\t  viewModel: PeekTableViewModel<TRow>;\n11\t  renderCell: (row: TRow, columnId: string) => ReactNode;\n12\t  buildSortHref?: (columnId: string, nextDirection: PeekSortDirection) => string;\n13\t  error?: string | null;\n14\t};\n15\t\n16\texport function PeekTable<TRow extends PeekTableRowBase>({\n17\t  viewModel,\n18\t  renderCell,\n19\t  buildSortHref,\n20\t  error = null,\n21\t}: PeekTableProps<TRow>) {\n22\t  if (error) {\n23\t    return (\n24\t      <div role=\"alert\" style={errorStyle}>\n25\t        Data unavailable: {error}\n26\t      </div>\n27\t    );\n28\t  }\n29\t\n30\t  const { columns, rows, sort, empty } = viewModel;\n31\t\n32\t  if (rows.length === 0) {\n33\t    return (\n34\t      <div role=\"status\" style={emptyStyle}>\n35\t        <p style={emptyTitleStyle}>{empty.title}</p>\n36\t        {empty.body ? <p style={emptyBodyStyle}>{empty.body}</p> : null}\n37\t      </div>\n38\t    );\n39\t  }\n40\t\n41\t  return (\n42\t    <div style={wrapperStyle}>\n43\t      <table style={tableStyle}>\n44\t        <thead>\n45\t          <tr style={headerRowStyle}>\n46\t            {columns.map((column) => {\n47\t              const isSorted = sort?.column === column.id;\n48\t              const indicator = isSorted ? (sort?.direction === \"asc\" ? \" ▲\" : \" ▼\") : \"\";\n49\t              const baseStyle = headerCellStyle(column.align);\n50\t              if (!column.sortable || !buildSortHref) {\n51\t                return (\n52\t                  <th key={column.id} style={baseStyle}>\n53\t                    {column.label}\n54\t                    {indicator}\n55\t                  </th>\n56\t                );\n57\t              }\n58\t              const nextDirection: PeekSortDirection =\n59\t                isSorted && sort?.direction === \"desc\" ? \"asc\" : \"desc\";\n60\t              return (\n61\t                <th key={column.id} style={baseStyle} aria-sort={ariaSort(sort, column.id)}>\n62\t                  <Link href={buildSortHref(column.id, nextDirection)} style={sortLinkStyle}>\n63\t                    {column.label}\n64\t                    {indicator}\n65\t                  </Link>\n66\t                </th>\n67\t              );\n68\t            })}\n69\t          </tr>\n70\t        </thead>\n71\t        <tbody>\n72\t          {rows.map((row) => (\n73\t            <tr key={row.id} style={bodyRowStyle}>\n74\t              {columns.map((column) => (\n75\t                <td key={column.id} style={bodyCellStyle(column.align)}>\n76\t                  {renderCell(row, column.id)}\n77\t                </td>\n78\t              ))}\n79\t            </tr>\n80\t          ))}\n81\t        </tbody>\n82\t      </table>\n83\t    </div>\n84\t  );\n85\t}\n86\t\n87\tfunction ariaSort(\n88\t  sort: PeekTableViewModel<PeekTableRowBase>[\"sort\"],\n89\t  columnId: string,\n90\t): \"ascending\" | \"descending\" | \"none\" {\n91\t  if (!sort || sort.column !== columnId) return \"none\";\n92\t  return sort.direction === \"asc\" ? \"ascending\" : \"descending\";\n93\t}\n94\t\n95\tconst wrapperStyle: CSSProperties = {\n96\t  overflowX: \"auto\",\n97\t  border: \"1px solid #1e293b\",\n98\t  borderRadius: \"0.75rem\",\n99\t};\n100\t\n101\tconst tableStyle: CSSProperties = {\n102\t  width: \"100%\",\n103\t  borderCollapse: \"collapse\",\n104\t};\n105\t\n106\tconst headerRowStyle: CSSProperties = {\n107\t  background: \"#111827\",\n108\t  color: \"#94a3b8\",\n109\t};\n110\t\n111\tconst bodyRowStyle: CSSProperties = {\n112\t  borderTop: \"1px solid #1e293b\",\n113\t};\n114\t\n115\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n116\t  return {\n117\t    padding: \"0.75rem\",\n118\t    textAlign: align,\n119\t    fontSize: \"0.875rem\",\n120\t    fontWeight: 600,\n121\t  };\n122\t}\n123\t\n124\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n125\t  return {\n126\t    padding: \"0.75rem\",\n127\t    textAlign: align,\n128\t    fontSize: \"0.875rem\",\n129\t  };\n130\t}\n131\t\n132\tconst sortLinkStyle: CSSProperties = {\n133\t  color: \"inherit\",\n134\t  textDecoration: \"none\",\n135\t};\n136\t\n137\tconst errorStyle: CSSProperties = {\n138\t  margin: 0,\n139\t  padding: \"0.75rem 1rem\",\n140\t  borderRadius: \"0.75rem\",\n141\t  background: \"#3f1d1d\",\n142\t  color: \"#fecaca\",\n143\t};\n144\t\n145\tconst emptyStyle: CSSProperties = {\n146\t  padding: \"1.5rem\",\n147\t  borderRadius: \"0.75rem\",\n148\t  border: \"1px solid #1e293b\",\n149\t  background: \"#0b1220\",\n150\t  color: \"#cbd5f5\",\n151\t};\n152\t\n153\tconst emptyTitleStyle: CSSProperties = {\n154\t  margin: 0,\n155\t  fontSize: \"1rem\",\n156\t  fontWeight: 600,\n157\t};\n158\t\n159\tconst emptyBodyStyle: CSSProperties = {\n160\t  margin: \"0.5rem 0 0\",\n161\t  fontSize: \"0.875rem\",\n162\t  color: \"#94a3b8\",\n163\t};\n164\t"}]},"parent_tool_use_id":null,"session_id":"c13e3955-6531-43fa-8b53-b8ade5fa464f","uuid":"d841212f-2d63-4ccb-8871-83dbb4b93ec2","timestamp":"2026-04-25T10:59:49.590Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/peek-table.tsx","content":"import Link from \"next/link\";\nimport type { CSSProperties, ReactNode } from \"react\";\nimport type {\n  PeekSortDirection,\n  PeekTableRowBase,\n  PeekTableViewModel,\n} from \"../lib/types/peek\";\n\nexport type PeekTableProps<TRow extends PeekTableRowBase> = {\n  viewModel: PeekTableViewModel<TRow>;\n  renderCell: (row: TRow, columnId: string) => ReactNode;\n  buildSortHref?: (columnId: string, nextDirection: PeekSortDirection) => string;\n  error?: string | null;\n};\n\nexport function PeekTable<TRow extends PeekTableRowBase>({\n  viewModel,\n  renderCell,\n  buildSortHref,\n  error = null,\n}: PeekTableProps<TRow>) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Data unavailable: {error}\n      </div>\n    );\n  }\n\n  const { columns, rows, sort, empty } = viewModel;\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>{empty.title}</p>\n        {empty.body ? <p style={emptyBodyStyle}>{empty.body}</p> : null}\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            {columns.map((column) => {\n              const isSorted = sort?.column === column.id;\n              const indicator = isSorted ? (sort?.direction === \"asc\" ? \" ▲\" : \" ▼\") : \"\";\n              const baseStyle = headerCellStyle(column.align);\n              if (!column.sortable || !buildSortHref) {\n                return (\n                  <th key={column.id} style={baseStyle}>\n                    {column.label}\n                    {indicator}\n                  </th>\n                );\n              }\n              const nextDirection: PeekSortDirection =\n                isSorted && sort?.direction === \"desc\" ? \"asc\" : \"desc\";\n              return (\n                <th key={column.id} style={baseStyle} aria-sort={ariaSort(sort, column.id)}>\n                  <Link href={buildSortHref(column.id, nextDirection)} style={sortLinkStyle}>\n                    {column.label}\n                    {indicator}\n                  </Link>\n                </th>\n              );\n            })}\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              {columns.map((column) => (\n                <td key={column.id} style={bodyCellStyle(column.align)}>\n                  {renderCell(row, column.id)}\n                </td>\n              ))}\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction ariaSort(\n  sort: PeekTableViewModel<PeekTableRowBase>[\"sort\"],\n  columnId: string,\n): \"ascending\" | \"descending\" | \"none\" {\n  if (!sort || sort.column !== columnId) return \"none\";\n  return sort.direction === \"asc\" ? \"ascending\" : \"descending\";\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n  };\n}\n\nconst sortLinkStyle: CSSProperties = {\n  color: \"inherit\",\n  textDecoration: \"none\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px solid #1e293b\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: \"0.5rem 0 0\",\n  fontSize: \"0.875rem\",\n  color: 