{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01HWxSDNkVdq5AfuRGD7spGV","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01SJA5BSa1nuzaWG9rBFgfQk","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/admin-shell-nav.ts","content":"// Server-only admin-shell nav model (FR-3).\n//\n// The full nav (Users, Growth, Games, Economy, Operations, Audit, Access) is\n// declared once here and resolved against the route-prefix policy in\n// `access-policy.ts`. The layout filters the list against the resolved actor\n// role before passing it to the AdminShell so the shell itself stays a pure\n// presentational component.\nimport { isRouteAllowedForRole } from \"./access-policy\";\nimport type { PeekRole } from \"../lib/access-policy\";\nimport type { AdminShellNavItem } from \"../components/admin-shell\";\n\nexport const PEEK_ADMIN_SHELL_NAV: ReadonlyArray<AdminShellNavItem> = [\n  { id: \"users\", label: \"Users\", href: \"/users\" },\n  { id: \"growth\", label: \"Growth\", href: \"/growth/referrals\" },\n  { id: \"games\", label: \"Games\", href: \"/games\" },\n  { id: \"economy\", label: \"Economy\", href: \"/economy/rewards\" },\n  { id: \"operations\", label: \"Operations\", href: \"/operations/queue\" },\n  { id: \"audit\", label: \"Audit\", href: \"/audit\" },\n  { id: \"access\", label: \"Access\", href: \"/access\" },\n];\n\nexport function getVisibleNavItemsForRole(\n  role: PeekRole | null,\n  items: ReadonlyArray<AdminShellNavItem> = PEEK_ADMIN_SHELL_NAV,\n): ReadonlyArray<AdminShellNavItem> {\n  if (!role) return [];\n  return items.filter((item) => isRouteAllowedForRole(item.href, role));\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2350,"cache_read_input_tokens":110453,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2350},"output_tokens":3,"service_tier":"sta