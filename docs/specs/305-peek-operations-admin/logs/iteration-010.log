{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R5FdpLeXRK98Kp5pgvN7DZ","type":"tool_result","content":"1\t// Browser-safe role identifiers used in `peek` view models.\n2\t//\n3\t// The full server-only policy (env-loaded entries, route + action rules,\n4\t// actor-context resolution) lives in `peek/src/server/access-policy.ts`.\n5\t// Only the literal role names + a stable role list cross into client bundles\n6\t// so the admin shell can render the resolved role badge and gate UI affordances\n7\t// without pulling in server config, env reads, or `next/headers`.\n8\t\n9\texport type PeekRole = \"business\" | \"admin\";\n10\t\n11\texport const PEEK_ROLES: ReadonlyArray<PeekRole> = [\"business\", \"admin\"];\n12\t\n13\texport function isPeekRole(value: unknown): value is PeekRole {\n14\t  return value === \"business\" || value === \"admin\";\n15\t}\n16\t"}]},"parent_tool_use_id":null,"session_id":"c13e3955-6531-43fa-8b53-b8ade5fa464f","uuid":"e61b50d2-67ea-4801-8133-467a9ec27ccd","timestamp":"2026-04-25T10:59:47.331Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/access-policy.ts","content":"// Browser-safe role identifiers used in `peek` view models.\n//\n// The full server-only policy (env-loaded entries, route + action rules,\n// actor-context resolution) lives in `peek/src/server/access-policy.ts`.\n// Only the literal role names + a stable role list cross into client bundles\n// so the admin shell can render the resolved role badge and gate UI affordances\n// without pulling in server config, env reads, or `next/headers`.\n\nexport type PeekRole = \"business\" | \"admin\";\n\nexport const PEEK_ROLES: ReadonlyArray<PeekRole> = [\"business\", \"admin\"];\n\nexport function isPeekRole(value: unknown): value is PeekRole {\n  return value === \"business\" || value === \"admin\";\n}\n","numLines":16,"startLine":1,"totalLines":16}}}
