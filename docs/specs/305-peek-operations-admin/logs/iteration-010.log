render(<DetailPanel sections={sections} />);\n\n    const nav = screen.getByRole(\"navigation\");\n    for (const link of within(nav).getAllByRole(\"link\")) {\n      expect(link.hasAttribute(\"aria-current\")).toBe(false);\n    }\n  });\n\n  it(\"sparse: renders the operator empty state when sections is empty\", () => {\n    render(\n      <DetailPanel\n        sections={[]}\n        emptyTitle=\"No sections available.\"\n        emptyBody=\"This user has no recorded support context yet.\"\n      />,\n    );\n\n    const region = screen.getByRole(\"status\");\n    expect(region).toHaveTextContent(\"No sections available.\");\n    expect(region).toHaveTextContent(\"This user has no recorded support context yet.\");\n    expect(screen.queryByRole(\"navigation\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and not the detail layout\", () => {\n    render(<DetailPanel sections={sections} error=\"query failed\" />);\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Detail panel unavailable: query failed\",\n    );\n    expect(screen.queryByRole(\"navigation\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n","numLines":89,"startLine":1,"totalLines":89}}}
