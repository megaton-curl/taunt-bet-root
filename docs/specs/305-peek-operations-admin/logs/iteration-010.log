{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01GBJXBJVrojKZ19Y79boSbi","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TmS628ZgR78c7GkxVx2ZRo","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/__tests__/admin-shell-nav.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport {\n  PEEK_ADMIN_SHELL_NAV,\n  getVisibleNavItemsForRole,\n} from \"../admin-shell-nav\";\n\ndescribe(\"getVisibleNavItemsForRole\", () => {\n  it(\"admin sees every primary nav group, including Audit\", () => {\n    const visible = getVisibleNavItemsForRole(\"admin\");\n    expect(visible.map((item) => item.id)).toEqual([\n      \"users\",\n      \"growth\",\n      \"games\",\n      \"economy\",\n      \"operations\",\n      \"audit\",\n      \"access\",\n    ]);\n  });\n\n  it(\"business hides Audit but keeps the rest\", () => {\n    const visible = getVisibleNavItemsForRole(\"business\");\n    expect(visible.map((item) => item.id)).toEqual([\n      \"users\",\n      \"growth\",\n      \"games\",\n      \"economy\",\n      \"operations\",\n      \"access\",\n    ]);\n    expect(visible.some((item) => item.id === \"audit\")).toBe(false);\n  });\n\n  it(\"null role hides every link\", () => {\n    expect(getVisibleNavItemsForRole(null)).toEqual([]);\n  });\n\n  it(\"declared nav covers the FR-3 navigation groups\", () => {\n    expect(PEEK_ADMIN_SHELL_NAV.map((item) => item.id)).toEqual([\n      \"users\",\n      \"growth\",\n      \"games\",\n      \"economy\",\n      \"operations\",\n      \"audit\",\n      \"access\",\n    ]);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2516,"cache_read_input_tokens":115084,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2516},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":nul