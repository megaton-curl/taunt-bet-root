{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YTgjYVnmCKLaom27xJN94t","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport { render, screen, within } from \"@testing-library/react\";\n3\timport { DetailPanel, type PeekDetailSection } from \"../detail-panel\";\n4\t\n5\tconst sections: ReadonlyArray<PeekDetailSection> = [\n6\t  {\n7\t    id: \"identity\",\n8\t    label: \"Identity\",\n9\t    body: <p data-testid=\"identity-body\">user-1234</p>,\n10\t  },\n11\t  {\n12\t    id: \"linked-accounts\",\n13\t    label: \"Linked accounts\",\n14\t    body: <p data-testid=\"linked-body\">Telegram: connected</p>,\n15\t  },\n16\t  {\n17\t    id: \"referrals\",\n18\t    label: \"Referrals\",\n19\t    body: <p data-testid=\"referrals-body\">5 referees</p>,\n20\t  },\n21\t];\n22\t\n23\tdescribe(\"DetailPanel\", () => {\n24\t  it(\"populated: renders anchor nav, marks the active section, and renders each section with its body\", () => {\n25\t    render(<DetailPanel sections={sections} activeId=\"linked-accounts\" />);\n26\t\n27\t    const nav = screen.getByRole(\"navigation\", { name: \"Detail sections\" });\n28\t    const navLinks = within(nav).getAllByRole(\"link\");\n29\t    expect(navLinks.map((link) => link.textContent)).toEqual([\n30\t      \"Identity\",\n31\t      \"Linked accounts\",\n32\t      \"Referrals\",\n33\t    ]);\n34\t    expect(navLinks.map((link) => link.getAttribute(\"href\"))).toEqual([\n35\t      \"#identity\",\n36\t      \"#linked-accounts\",\n37\t      \"#referrals\",\n38\t    ]);\n39\t\n40\t    const activeLink = navLinks.find((link) => link.getAttribute(\"aria-current\") === \"true\");\n41\t    expect(activeLink?.textContent).toBe(\"Linked accounts\");\n42\t\n43\t    expect(screen.getByTestId(\"identity-body\")).toBeInTheDocument();\n44\t    expect(screen.getByTestId(\"linked-body\")).toBeInTheDocument();\n45\t    expect(screen.getByTestId(\"referrals-body\")).toBeInTheDocument();\n46\t\n47\t    const headings = screen.getAllByRole(\"heading\", { level: 2 });\n48\t    expect(headings.map((heading) => heading.textContent)).toEqual([\n49\t      \"Identity\",\n50\t      \"Linked accounts\",\n51\t      \"Referrals\",\n52\t    ]);\n53\t  });\n54\t\n55\t  it(\"populated: leaves all links non-active when no activeId is provided\", () => {\n56\t    render(<DetailPanel sections={sections} />);\n57\t\n58\t    const nav = screen.getByRole(\"navigation\");\n59\t    for (const link of within(nav).getAllByRole(\"link\")) {\n60\t      expect(link.hasAttribute(\"aria-current\")).toBe(false);\n61\t    }\n62\t  });\n63\t\n64\t  it(\"sparse: renders the operator empty state when sections is empty\", () => {\n65\t    render(\n66\t      <DetailPanel\n67\t        sections={[]}\n68\t        emptyTitle=\"No sections available.\"\n69\t        emptyBody=\"This user has no recorded support context yet.\"\n70\t      />,\n71\t    );\n72\t\n73\t    const region = screen.getByRole(\"status\");\n74\t    expect(region).toHaveTextContent(\"No sections available.\");\n75\t    expect(region).toHaveTextContent(\"This user has no recorded support context yet.\");\n76\t    expect(screen.queryByRole(\"navigation\")).toBeNull();\n77\t  });\n78\t\n79\t  it(\"error: renders an alert and not the detail layout\", () => {\n80\t    render(<DetailPanel sections={sections} error=\"query failed\" />);\n81\t\n82\t    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n83\t      \"Detail panel unavailable: query failed\",\n84\t    );\n85\t    expect(screen.queryByRole(\"navigation\")).toBeNull();\n86\t    expect(screen.queryByRole(\"status\")).toBeNull();\n87\t  });\n88\t});\n89\t"}]},"parent_tool_use_id":null,"session_id":"c13e3955-6531-43fa-8b53-b8ade5fa464f","uuid":"985e4ed2-0c7d-4e57-8bd0-d1174ae0bf50","timestamp":"2026-04-25T10:59:54.959Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/detail-panel.test.tsx","content":"import { descr