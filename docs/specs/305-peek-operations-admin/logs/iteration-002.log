{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BvE4rUxd8Z9jMfoitysLtK","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport {\n3\t  getVerifiedCloudflareAccessEmailFromHeaders,\n4\t  verifyCloudflareAccessJwt,\n5\t} from \"../cloudflare-access\";\n6\t\n7\tdescribe(\"cloudflare access verification\", () => {\n8\t  it(\"verifies a Cloudflare Access JWT and returns the email claim\", async () => {\n9\t    const { keyPair, publicJwk } = await createAccessKey(\"access-key\");\n10\t    const token = await createSignedAccessJwt({\n11\t      aud: \"peek-audience\",\n12\t      email: \"admin@example.com\",\n13\t      issuer: \"https://taunt.cloudflareaccess.com\",\n14\t      keyId: \"access-key\",\n15\t      keyPair,\n16\t    });\n17\t\n18\t    await expect(\n19\t      verifyCloudflareAccessJwt(token, {\n20\t        audience: \"peek-audience\",\n21\t        jwks: [publicJwk],\n22\t        teamDomain: \"https://taunt.cloudflareaccess.com\",\n23\t      }),\n24\t    ).resolves.toEqual({\n25\t      ok: true,\n26\t      email: \"admin@example.com\",\n27\t    });\n28\t  });\n29\t\n30\t  it(\"rejects requests without a signed Access JWT\", async () => {\n31\t    await expect(\n32\t      verifyCloudflareAccessJwt(null, {\n33\t        audience: \"peek-audience\",\n34\t        jwks: [],\n35\t        teamDomain: \"https://taunt.cloudflareaccess.com\",\n36\t      }),\n37\t    ).resolves.toEqual({\n38\t      ok: false,\n39\t      reason: \"missing_token\",\n40\t    });\n41\t  });\n42\t\n43\t  it(\"rejects Access JWTs for another audience\", async () => {\n44\t    const { keyPair, publicJwk } = await createAccessKey(\"access-key\");\n45\t    const token = await createSignedAccessJwt({\n46\t      aud: \"other-audience\",\n47\t      email: \"admin@example.com\",\n48\t      issuer: \"https://taunt.cloudflareaccess.com\",\n49\t      keyId: \"access-key\",\n50\t      keyPair,\n51\t    });\n52\t\n53\t    await expect(\n54\t      verifyCloudflareAccessJwt(token, {\n55\t        audience: \"peek-audience\",\n56\t        jwks: [publicJwk],\n57\t        teamDomain: \"https://taunt.cloudflareaccess.com\",\n58\t      }),\n59\t    ).resolves.toEqual({\n60\t      ok: false,\n61\t      reason: \"invalid_audience\",\n62\t    });\n63\t  });\n64\t\n65\t  it(\"rejects unsigned tokens even when the claims look valid\", async () => {\n66\t    const token = [\n67\t      encodeBase64Url({ alg: \"none\", kid: \"access-key\", typ: \"JWT\" }),\n68\t      encodeBase64Url({\n69\t        aud: \"peek-audience\",\n70\t        email: \"admin@example.com\",\n71\t        exp: Math.floor(Date.now() / 1000) + 300,\n72\t        iss: \"https://taunt.cloudflareaccess.com\",\n73\t      }),\n74\t      \"signature\",\n75\t    ].join(\".\");\n76\t\n77\t    await expect(\n78\t      verifyCloudflareAccessJwt(token, {\n79\t        audience: \"peek-audience\",\n80\t        jwks: [],\n81\t        teamDomain: \"https://taunt.cloudflareaccess.com\",\n82\t      }),\n83\t    ).resolves.toEqual({\n84\t      ok: false,\n85\t      reason: \"unsupported_algorithm\",\n86\t    });\n87\t  });\n88\t\n89\t  it(\"uses the verified JWT email instead of trusting identity headers\", async () => {\n90\t    const { keyPair, publicJwk } = await createAccessKey(\"access-key\");\n91\t    const token = await createSignedAccessJwt({\n92\t      aud: \"peek-audience\",\n93\t      email: \"verified@example.com\",\n94\t      issuer: \"https://taunt.cloudflareaccess.com\",\n95\t      keyId: \"access-key\",\n96\t      keyPair,\n97\t    });\n98\t    const headers = new Headers({\n99\t      \"cf-access-authenticated-user-email\": \"spoofed@example.com\",\n100\t      \"cf-access-jwt-assertion\": token,\n101\t    });\n102\t\n103\t    await expect(\n104\t      getVerifiedCloudflareAccessEmailFromHeaders(headers, {\n105\t        audience: \"peek-audience\",\n106\t        jwks: [publicJwk],\n107\t        teamDomain: \"https://taunt.cloudflareaccess.com\",\n108\t      }),\n109\t    ).resolves.toEqual({\n110\t      ok: true,\n111\t      email: \"verified@example.com\",\n112\t    });\n113\t  });\n114\t});\n115\t\n116\tasync function createAccessKey(keyId: string) {\n117\t  const keyPair = await crypto.subtle.generateKey(\n118\t    {\n119\t      name: \"RSASSA-PKCS1-v1_5\",\n120\t      modulusLength: 2048,\n121\t      publicExponent: new Uint8Array([1, 0, 1]),\n122\t      hash: \"SHA-256\",\n123\t    },\n124\t    true,\n125\t    [\"sign\", \"verify\"],\n126\t  );\n127\t  const publicJwk = await crypto.subtle.exportKey(\"jwk\", keyPair.publicKey);\n128\t  return {\n129\t    keyPair,\n130\t    publicJwk: {\n131\t      ...publicJwk,\n132\t      alg: \"RS256\",\n133\t      kid: keyId,\n134\t      use: \"sig\",\n135\t    },\n136\t  };\n137\t}\n138\t\n139\tasync function createSignedAccessJwt({\n140\t  aud,\n141\t  email,\n142\t  issuer,\n143\t  keyId,\n144\t  keyPair,\n145\t}: {\n146\t  aud: string;\n147\t  email: string;\n148\t  issuer: string;\n149\t  keyId: string;\n150\t  keyPair: CryptoKeyPair;\n151\t}): Promise<string> {\n152\t  const header = encodeBase64Url({ alg: \"RS256\", kid: keyId, typ: \"JWT\" });\n153\t  const payload = encodeBase64Url({\n154\t    aud,\n155\t    email,\n156\t    exp: Math.floor(Date.now() / 1000) + 300,\n157\t    iat: Math.floor(Date.now() / 1000),\n158\t    iss: issuer,\n159\t  });\n160\t  const signature = await crypto.subtle.sign(\n161\t    \"RSASSA-PKCS1-v1_5\",\n162\t    keyPair.privateKey,\n163\t    new TextEncoder().encode(`${header}.${payload}`),\n164\t  );\n165\t\n166\t  return `${header}.${payload}.${encodeBytesBase64Url(new Uint8Array(signature))}`;\n167\t}\n168\t\n169\tfunction encodeBase64Url(value: unknown): string {\n170\t  return encodeBytesBase64Url(Buffer.from(JSON.stringify(value)));\n171\t}\n172\t\n173\tfunction encodeBytesBase64Url(value: Uint8Array): string {\n174\t  return Buffer.from(value)\n175\t    .toString(\"base64\")\n176\t    .replaceAll(\"+\", \"-\")\n177\t    .replaceAll(\"/\", \"_\")\n178\t    .replaceAll(\"=\", \"\");\n179\t}\n180\t"}]},"parent_tool_use_id":null,"session_id":"63526e4e-208c-4618-a778-2242e5b4c8ce","uuid":"62bb8f82-3eb8-4097-8401-daf268213c55","timestamp":"2026-04-25T10:27:17.203Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/__tests__/cloudflare-access.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport {\n  getVerifiedCloudflareAccessEmailFromHeaders,\n  verifyCloudflareAccessJwt,\n} from \"../cloudflare-access\";\n\ndescribe(\"cloudflare access verification\", () => {\n  it(\"verifies a Cloudflare Access JWT and returns the email claim\", async () => {\n    const { keyPair, publicJwk } = await createAccessKey(\"access-key\");\n    const token = await createSignedAccessJwt({\n      aud: \"peek-audience\",\n      email: \"admin@example.com\",\n      issuer: \"https://taunt.cloudflareaccess.com\",\n      keyId: \"access-key\",\n      keyPair,\n    });\n\n    await expect(\n      verifyCloudflareAccessJwt(token, {\n        audience: \"peek-audience\",\n        jwks: [publicJwk],\n        teamDomain: \"https://taunt.cloudflareaccess.com\",\n      }),\n    ).resolves.toEqual({\n      ok: true,\n      email: \"admin@example.com\",\n    });\n  });\n\n  it(\"rejects requests without a signed Access JWT\", async () => {\n    await expect(\n      verifyCloudflareAccessJwt(null, {\n        audience: \"peek-audience\",\n        jwks: [],\n        teamDomain: \"https://taunt.cloudflareaccess.com\",\n      }),\n    ).resolves.toEqual({\n      ok: false,\n      reason: \"missing_token\",\n    });\n  });\n\n  it(\"rejects Access JWTs for another audience\", async () => {\n    const { keyPair, publicJwk } = await createAccessKey(\"access-key\");\n    const token = await createSignedAccessJwt({\n      aud: \"other-audience\",\n      email: \"admin@example.com\",\n      issuer: \"https://taunt.cloudflareaccess.com\",\n      keyId: \"access-key\",\n      keyPair,\n    });\n\n    await expect(\n      verifyCloudflareAccessJwt(token, {\n        audience: \"peek-audience\",\n        jwks: [publicJwk],\n        teamDomain: \"https://taunt.cloudflareaccess.com\",\n      }),\n    ).resolves.toEqual({\n      ok: false,\n      reason: \"invalid_audience\",\n    });\n  });\n\n  it(\"rejects unsigned tokens even when the claims look valid\", async () => {\n    const token = [\n      encodeBase64Url({ alg: \"none\", kid: \"access-key\", typ: \"JWT\" }),\n      encodeBase64Url({\n        aud: \"peek-audience\",\n        email: \"admin@example.com\",\n        exp: Math.floor(Date.now() / 1000) + 300,\n        iss: \"https://taunt.cloudflareaccess.com\",\n      }),\n      \"signature\",\n    ].join(\".\");\n\n    await expect(\n      verifyCloudflareAccessJwt(token, {\n        audience: \"peek-audience\",\n        jwks: [],\n        teamDomain: \"https://taunt.cloudflareaccess.com\",\n      }),\n    ).resolves.toEqual({\n      ok: false,\n      reason: \"unsupported_algorithm\",\n    });\n  });\n\n  it(\"uses the verified JWT email instead of trusting identity headers\", async () => {\n    const { keyPair, publicJwk } = await createAccessKey(\"access-key\");\n    const token = await createSignedAccessJwt({\n      aud: \"peek-audience\",\n      email: \"verified@example.com\",\n      issuer: \"https://taunt.cloudflareaccess.com\",\n      keyId: \"access-key\",\n      keyPair,\n    });\n    const headers = new Headers({\n      \"cf-access-authenticated-user-email\": \"spoofed@example.com\",\n      \"cf-access-jwt-assertion\": token,\n    });\n\n    await expect(\n      getVerifiedCloudflareAccessEmailFromHeaders(headers, {\n        audience: \"peek-audience\",\n        jwks: [publicJwk],\n        teamDomain: \"https://taunt.cloudflareaccess.com\",\n      }),\n    ).resolves.toEqual({\n      ok: true,\n      email: \"verified@example.com\",\n    });\n  });\n});\n\nasync function createAccessKey(keyId: string) {\n  const keyPair = await crypto.subtle.generateKey(\n    {\n      name: \"RSASSA-PKCS1-v1_5\",\n      modulusLength: 2048,\n      publicExponent: new Uint8Array([1, 0, 1]),\n      hash: \"SHA-256\",\n    },\n    true,\n    [\"sign\", \"verify\"],\n  );\n  const publicJwk = await crypto.subtle.exportKey(\"jwk\", keyPair.publicKey);\n  return {\n    keyPair,\n    publicJwk: {\n      ...publicJwk,\n      alg: \"RS256\",\n      kid: keyId,\n      use: \"sig\",\n    },\n  };\n}\n\nasync function createSignedAccessJwt({\n  aud,\n  email,\n  issuer,\n  keyId,\n  keyPair,\n}: {\n  aud: string;\n  email: string;\n  issuer: string;\n  keyId: string;\n  keyPair: CryptoKeyPair;\n}): Promise<string> {\n  const header = encodeBase64Url({ alg: \"RS256\", kid: keyId, typ: \"JWT\" });\n  const payload = encodeBase64Url({\n    aud,\n    email,\n    exp: Math.floor(Date.now() / 1000) + 300,\n    iat: Math.floor(Date.now() / 1000),\n    iss: issuer,\n  });\n  const signature = await crypto.subtle.sign(\n    \"RSASSA-PKCS1-v1_5\",\n    keyPair.privateKey,\n    new TextEncoder().encode(`${header}.${payload}`),\n  );\n\n  return `${header}.${payload}.${encodeBytesBase64Url(new Uint8Array(signature))}`;\n}\n\nfunction encodeBase64Url(value: unknown): string {\n  return encodeBytesBase64Url(Buffer.from(JSON.stringify(value)));\n}\n\nfunction encodeBytesBase64Url(value: Uint8Array): string {\n  return Buffer.from(value)\n    .toString(\"base64\")\n    .replaceAll(\"+\", \"-\")\n    .replaceAll(\"/\", \"_\")\n    .replaceAll(\"=\", \"\");\n}\n","numLines":180,"startLine":1,"totalLines":180}}}
