{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01F5bm1LajBhLsyHnYcptHif","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01SKg8Wm37bZpHF5D2HeFMg1","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/__tests__/cloudflare-access-middleware.test.ts","content":"import { NextRequest } from \"next/server\";\nimport { afterEach, describe, expect, it } from \"vitest\";\nimport { proxy } from \"../../../proxy\";\nimport { VERIFIED_ACCESS_EMAIL_HEADER } from \"../cloudflare-access\";\n\nconst originalEnv = { ...process.env };\n\nfunction resetEnv() {\n  process.env = { ...originalEnv };\n  delete process.env.CF_ACCESS_AUD;\n  delete process.env.CF_ACCESS_TEAM_DOMAIN;\n  delete process.env.PEEK_DEV_ACCESS_EMAIL;\n}\n\ndescribe(\"cloudflare access middleware\", () => {\n  afterEach(resetEnv);\n\n  it(\"blocks direct production traffic without a Cloudflare Access JWT\", async () => {\n    process.env.NODE_ENV = \"production\";\n    process.env.CF_ACCESS_AUD = \"peek-audience\";\n    process.env.CF_ACCESS_TEAM_DOMAIN = \"https://taunt.cloudflareaccess.com\";\n\n    const response = await proxy(\n      new NextRequest(\"https://dev.tb.reporting.win/\"),\n    );\n\n    expect(response.status).toBe(403);\n    await expect(response.text()).resolves.toBe(\"Cloudflare Access required\");\n  });\n\n  it(\"returns 500 in production when Cloudflare Access env is missing\", async () => {\n    process.env.NODE_ENV = \"production\";\n    delete process.env.CF_ACCESS_AUD;\n    delete process.env.CF_ACCESS_TEAM_DOMAIN;\n\n    const response = await proxy(\n      new NextRequest(\"https://dev.tb.reporting.win/\"),\n    );\n\n    expect(response.status).toBe(500);\n    await expect(response.text()).resolves.toBe(\n      \"Cloudflare Access is not configured\",\n    );\n  });\n\n  it(\"ignores PEEK_DEV_ACCESS_EMAIL in production\", async () => {\n    process.env.NODE_ENV = \"production\";\n    process.env.PEEK_DEV_ACCESS_EMAIL = \"dev@example.com\";\n    process.env.CF_ACCESS_AUD = \"peek-audience\";\n    process.env.CF_ACCESS_TEAM_DOMAIN = \"https://taunt.cloudflareaccess.com\";\n\n    const response = await proxy(\n      new NextRequest(\"https://dev.tb.reporting.win/\"),\n    );\n\n    expect(response.status).toBe(403);\n    expect(\n      response.headers.get(`x-middleware-request-${VERIFIED_ACCESS_EMAIL_HEADER}`),\n    ).toBeNull();\n  });\n\n  it(\"honors PEEK_DEV_ACCESS_EMAIL bypass in development\", async () => {\n    process.env.NODE_ENV = \"development\";\n    process.env.PEEK_DEV_ACCESS_EMAIL = \"Dev@Example.COM\";\n\n    const response = await proxy(\n      new NextRequest(\"http://localhost:3000/\"),\n    );\n\n    expect(response.status).toBe(200);\n    expect(\n      response.headers.get(`x-middleware-request-${VERIFIED_ACCESS_EMAIL_HEADER}`),\n    ).toBe(\"dev@example.com\");\n  });\n\n  it(\"ignores a malformed PEEK_DEV_ACCESS_EMAIL in development\", async () => {\n    process.env.NODE_ENV = \"development\";\n    process.env.PEEK_DEV_ACCESS_EMAIL = \"not-an-email\";\n\n    const response = await proxy(\n      new NextRequest(\"http://localhost:3000/\"),\n    );\n\n    expect(response.status).toBe(200);\n    expect(\n      response.headers.get(`x-middleware-request-${VERIFIED_ACCESS_EMAIL_HEADER}`),\n    ).toBeNull();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":947,"cache_read_input_tokens":85690,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":947},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"63526e4e-208c-4618-a778-2242e5b4c8ce","uuid":"a04e425f-62bc-4254-9585-d661630d725b"}
