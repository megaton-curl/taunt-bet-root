dflare-access\";\n\ndescribe(\"cloudflare access verification\", () => {\n  it(\"verifies a Cloudflare Access JWT and returns the email claim\", async () => {\n    const { keyPair, publicJwk } = await createAccessKey(\"access-key\");\n    const token = await createSignedAccessJwt({\n      aud: \"peek-audience\",\n      email: \"admin@example.com\",\n      issuer: \"https://taunt.cloudflareaccess.com\",\n      keyId: \"access-key\",\n      keyPair,\n    });\n\n    await expect(\n      verifyCloudflareAccessJwt(token, {\n        audience: \"peek-audience\",\n        jwks: [publicJwk],\n        teamDomain: \"https://taunt.cloudflareaccess.com\",\n      }),\n    ).resolves.toEqual({\n      ok: true,\n      email: \"admin@example.com\",\n    });\n  });\n\n  it(\"rejects requests without a signed Access JWT\", async () => {\n    await expect(\n      verifyCloudflareAccessJwt(null, {\n        audience: \"peek-audience\",\n        jwks: [],\n        teamDomain: \"https://taunt.cloudflareaccess.com\",\n      }),\n    ).resolves.toEqual({\n      ok: false,\n      reason: \"missing_token\",\n    });\n  });\n\n  it(\"rejects Access JWTs for another audience\", async () => {\n    const { keyPair, publicJwk } = await createAccessKey(\"access-key\");\n    const token = await createSignedAccessJwt({\n      aud: \"other-audience\",\n      email: \"admin@example.com\",\n      issuer: \"https://taunt.cloudflareaccess.com\",\n      keyId: \"access-key\",\n      keyPair,\n    });\n\n    await expect(\n      verifyCloudflareAccessJwt(token, {\n        audience: \"peek-audience\",\n        jwks: [publicJwk],\n        teamDomain: \"https://taunt.cloudflareaccess.com\",\n      }),\n    ).resolves.toEqual({\n      ok: false,\n      reason: \"invalid_audience\",\n    });\n  });\n\n  it(\"rejects unsigned tokens even when the claims look valid\", async () => {\n    const token = [\n      encodeBase64Url({ alg: \"none\", kid: \"access-key\", typ: \"JWT\" }),\n      encodeBase64Url({\n        aud: \"peek-audience\",\n        email: \"admin@example.com\",\n        exp: Math.floor(Date.now() / 1000) + 300,\n        iss: \"https://taunt.cloudflareaccess.com\",\n      }),\n      \"signature\",\n    ].join(\".\");\n\n    await expect(\n      verifyCloudflareAccessJwt(token, {\n        audience: \"peek-audience\",\n        jwks: [],\n        teamDomain: \"https://taunt.cloudflareaccess.com\",\n      }),\n    ).resolves.toEqual({\n      ok: false,\n      reason: \"unsupported_algorithm\",\n    });\n  });\n\n  it(\"uses the verified JWT email instead of trusting identity headers\", async () => {\n    const { keyPair, publicJwk } = await createAccessKey(\"access-key\");\n    const token = await createSignedAccessJwt({\n      aud: \"peek-audience\",\n      email: \"verified@example.com\",\n      issuer: \"https://taunt.cloudflareaccess.com\",\n      keyId: \"access-key\",\n      keyPair,\n    });\n    const headers = new Headers({\n      \"cf-access-authenticated-user-email\": \"spoofed@example.com\",\n      \"cf-access-jwt-assertion\": token,\n    });\n\n    await expect(\n      getVerifiedCloudflareAccessEmailFromHeaders(headers, {\n        audience: \"peek-audience\",\n        jwks: [publicJwk],\n        teamDomain: \"https://taunt.cloudflareaccess.com\",\n      }),\n    ).resolves.toEqual({\n      ok: true,\n      email: \"verified@example.com\",\n    });\n  });\n});\n\nasync function createAccessKey(keyId: string) {\n  const keyPair = await crypto.subtle.generateKey(\n    {\n      name: \"RSASSA-PKCS1-v1_5\",\n      modulusLength: 2048,\n      publicExponent: new Uint8Array([1, 0, 1]),\n      hash: \"SHA-256\",\n    },\n    true,\n    [\"sign\", \"verify\"],\n  );\n  const publicJwk = await crypto.subtle.exportKey(\"jwk\", keyPair.publicKey);\n  return {\n    keyPair,\n    publicJwk: {\n      ...publicJwk,\n      alg: \"RS256\",\n      kid: keyId,\n      use: \"sig\",\n    },\n  };\n}\n\nasync function createSignedAccessJwt({\n  aud,\n  email,\n  issuer,\n  keyId,\n  keyPair,\n}: {\n  aud: string;\n  email: string;\n  issuer: string;\n  keyId: string;\n  keyPair: CryptoKeyPair;\n}): Promise<string> {\n  const header = encodeBase64Url({ alg: \"RS256\", kid: keyId, typ: \"JWT\" });\n  const payload = encodeBase64Url({\n    aud,\n    email,\n    exp: Math.floor(Date.now() / 1000) + 300,\n    iat: Math.floor(Date.now() / 1000),\n    iss: issuer,\n  });\n  const signature = await crypto.subtle.sign(\n    \"RSASSA-PKCS1-v1_5\",\n    keyPair.privateKey,\n    new TextEncoder().encode(`${header}.${payload}`),\n  );\n\n  return `${header}.${payload}.${encodeBytesBase64Url(new Uint8Array(signature))}`;\n}\n\nfunction encodeBase64Url(value: unknown): string {\n  return encodeBytesBase64Url(Buffer.from(JSON.stringify(value)));\n}\n\nfunction encodeBytesBase64Url(value: Uint8Array): string {\n  return Buffer.from(value)\n    .toString(\"base64\")\n    .replaceAll(\"+\", \"-\")\n    .replaceAll(\"/\", \"_\")\n    .replaceAll(\"=\", \"\");\n}\n","userModified":false}}
