CloudflareAccessVerificationOptions,\n): Promise<CloudflareAccessVerificationResult> {\n  return verifyCloudflareAccessJwt(\n    requestHeaders.get(\"cf-access-jwt-assertion\"),\n    options,\n  );\n}\n\nexport async function verifyCloudflareAccessJwt(\n  token: string | null,\n  options: CloudflareAccessVerificationOptions,\n): Promise<CloudflareAccessVerificationResult> {\n  if (!token) {\n    return { ok: false, reason: \"missing_token\" };\n  }\n\n  const issuer = normalizeTeamDomain(options.teamDomain);\n  const getKey = options.jwks\n    ? createLocalJWKSet({ keys: options.jwks })\n    : getRemoteJwks(issuer);\n\n  let payload: JWTPayload;\n  try {\n    const result = await jwtVerify(token, getKey, {\n      algorithms: [\"RS256\"],\n      audience: options.audience,\n      currentDate: options.now,\n      issuer,\n    });\n    payload = result.payload;\n  } catch (error) {\n    return { ok: false, reason: mapJoseError(error) };\n  }\n\n  const email = typeof payload.email === \"string\" ? payload.email : null;\n  return { ok: true, email: normalizeEmail(email) };\n}\n\nfunction getRemoteJwks(issuer: string): JWTVerifyGetKey {\n  const cached = remoteJwksCache.get(issuer);\n  if (cached) {\n    return cached;\n  }\n  const resolver = createRemoteJWKSet(new URL(`${issuer}/cdn-cgi/access/certs`));\n  remoteJwksCache.set(issuer, resolver);\n  return resolver;\n}\n\nfunction mapJoseError(error: unknown): CloudflareAccessVerificationReason {\n  if (error instanceof joseErrors.JWTExpired) {\n    return \"expired_token\";\n  }\n  if (error instanceof joseErrors.JWTClaimValidationFailed) {\n    if (error.claim === \"iss\") {\n      return \"invalid_issuer\";\n    }\n    if (error.claim === \"aud\") {\n      return \"invalid_audience\";\n    }\n    return \"invalid_claims\";\n  }\n  if (\n    error instanceof joseErrors.JOSEAlgNotAllowed ||\n    error instanceof joseErrors.JOSENotSupported\n  ) {\n    return \"unsupported_algorithm\";\n  }\n  if (error instanceof joseErrors.JWKSNoMatchingKey) {\n    return \"missing_key\";\n  }\n  if (error instanceof joseErrors.JWSSignatureVerificationFailed) {\n    return \"invalid_signature\";\n  }\n  if (\n    error instanceof joseErrors.JWKSTimeout ||\n    error instanceof joseErrors.JWKSInvalid ||\n    error instanceof joseErrors.JWKInvalid\n  ) {\n    return \"jwks_unavailable\";\n  }\n  if (\n    error instanceof joseErrors.JWTInvalid ||\n    error instanceof joseErrors.JWSInvalid\n  ) {\n    return \"malformed_token\";\n  }\n  return \"jwks_unavailable\";\n}\n\nfunction normalizeEmail(value: string | null | undefined): string | null {\n  const email = value?.trim();\n\n  if (!email || !/^[^\\s@]+@[^\\s@]+$/.test(email)) {\n    return null;\n  }\n\n  return email;\n}\n\nfunction normalizeTeamDomain(value: string): string {\n  return value.trim().replace(/\\/+$/, \"\");\n}\n","structuredPatch":[{"oldStart":127,"oldLines":7,"newStart":127,"newLines":7,"lines":[" }"," "," function normalizeEmail(value: string | null | undefined): string | null {","-  const email = value?.trim();","+  const email = value?.trim().toLowerCase();"," ","   if (!email || !/^[^\\s@]+@[^\\s@]+$/.test(email)) {","     return null;"]}],"userModified":false,"replaceAll":false}}
