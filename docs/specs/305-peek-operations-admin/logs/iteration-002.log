re-access\";\n\nexport async function proxy(request: NextRequest) {\n  const teamDomain = process.env.CF_ACCESS_TEAM_DOMAIN?.trim();\n  const audience = process.env.CF_ACCESS_AUD?.trim();\n\n  if (!teamDomain || !audience) {\n    if (process.env.NODE_ENV === \"development\") {\n      return NextResponse.next();\n    }\n\n    return new NextResponse(\"Cloudflare Access is not configured\", {\n      status: 500,\n    });\n  }\n\n  const verification = await verifyCloudflareAccessJwt(\n    request.headers.get(\"cf-access-jwt-assertion\"),\n    {\n      audience,\n      teamDomain,\n    },\n  );\n\n  if (!verification.ok) {\n    return new NextResponse(\"Cloudflare Access required\", { status: 403 });\n  }\n\n  const requestHeaders = new Headers(request.headers);\n\n  if (verification.email) {\n    requestHeaders.set(VERIFIED_ACCESS_EMAIL_HEADER, verification.email);\n  }\n\n  return NextResponse.next({\n    request: {\n      headers: requestHeaders,\n    },\n  });\n}\n\nexport const config = {\n  matcher: [\"/((?!_next/static|_next/image|favicon.ico).*)\"],\n};\n","numLines":49,"startLine":1,"totalLines":49}}}
