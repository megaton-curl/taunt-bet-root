{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01S4zeZoP9cprozPP1ThSGE5","type":"tool_result","content":"1\t// Dogpile + fraud admin queries (FR-9).\n2\t//\n3\t// Backs the upcoming `/operations/dogpile` page and the fraud-review surface.\n4\t// Reads two migration-011 tables in read-only mode (no dogpile or fraud-flag\n5\t// editing — that lives behind the FR-14 mutation framework; `dogpile.cancel`\n6\t// and `fraud_flag.status.update` action ids are already declared in\n7\t// `peek/src/server/access-policy.ts`):\n8\t//\n9\t//   - dogpile_events  — `listDogpileEvents` returns the scheduled / active /\n10\t//     ended / cancelled lifecycle rows joined with the parent `campaigns` row\n11\t//     (campaign_id is nullable so the join is a left join). Each row is\n12\t//     annotated with the count of `game_entries` and `point_grants` whose\n13\t//     `created_at` falls within the event's `[starts_at, ends_at)` window —\n14\t//     this is the operator-readable \"linked\" set the spec calls out\n15\t//     (FR-9 line 327: \"linked campaigns/game_entries/point_grants\"). There\n16\t//     is no FK from those ledger tables to `dogpile_events`; the worker\n17\t//     applies the multiplier purely based on the time window\n18\t//     (`backend/src/queue/handlers/points-grant.ts`), so a window-based\n19\t//     count is the closest operator-meaningful link.\n20\t//\n21\t//   - fraud_flags     — `listFraudFlags` returns the open / reviewed /\n22\t//     dismissed review queue joined with `player_profiles` for username +\n23\t//     wallet context. The JSONB `details` column round-trips verbatim so the\n24\t//     operator-facing UI can show whatever metadata the writer attached.\n25\t//     Read-only — every status transition is gated by the\n26\t//     `fraud_flag.status.update` mutation action (FR-14, not yet built).\n27\t//\n28\t// `getDogpileFraudOverview` produces the FR-4 metric strip for the page:\n29\t// scheduled, active, ended-in-window, cancelled-in-window, open fraud flags.\n30\t//\n31\t// All queries are bounded server-side (default 100, max 500). Bigint identity\n32\t// ids round-trip as `text` to preserve precision; the dogpile multiplier is\n33\t// returned as `text` because it is stored as `NUMERIC(4,2)` and the UI\n34\t// formats it at render time.\n35\t\n36\timport type { Sql } from \"postgres\";\n37\timport {\n38\t  type PeekDogpileEventFilters,\n39\t  type PeekDogpileEventRow,\n40\t  type PeekDogpileFraudOverview,\n41\t  type PeekDogpileFraudOverviewMetricId,\n42\t  type PeekFraudFlagFilters,\n43\t  type PeekFraudFlagListRow,\n44\t  type PeekMetric,\n45\t} from \"../../../lib/types/peek\";\n46\timport { getSqlClient } from \"../client\";\n47\t\n48\texport const PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT = 100;\n49\texport const PEEK_DOGPILE_EVENTS_MAX_LIMIT = 500;\n50\texport const PEEK_FRAUD_FLAGS_DEFAULT_LIMIT = 100;\n51\texport const PEEK_FRAUD_FLAGS_MAX_LIMIT = 500;\n52\texport const PEEK_DOGPILE_FRAUD_OVERVIEW_WINDOW_HOURS = 24;\n53\t\n54\texport type ListDogpileEventsOptions = {\n55\t  sql?: Sql;\n56\t  limit?: number;\n57\t  filters?: Partial<PeekDogpileEventFilters>;\n58\t};\n59\t\n60\texport type ListFraudFlagsOptions = {\n61\t  sql?: Sql;\n62\t  limit?: number;\n63\t  filters?: Partial<PeekFraudFlagFilters>;\n64\t};\n65\t\n66\texport type DogpileFraudOverviewOptions = {\n67\t  sql?: Sql;\n68\t  now?: Date;\n69\t  windowHours?: number;\n70\t};\n71\t\n72\tfunction clampLimit(\n73\t  raw: number | undefined,\n74\t  fallback: number,\n75\t  max: number,\n76\t): number {\n77\t  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n78\t  const floored = Math.floor(raw);\n79\t  if (floored <= 0) return 1;\n80\t  return Math.min(max, floored);\n81\t}\n82\t\n83\tfunction trimOrNull(value: string | null | undefined): string | null {\n84\t  if (typeof value !== \"string\") return null;\n85\t  const trimmed = value.trim();\n86\t  return trimmed.length > 0 ? trimmed : null;\n87\t}\n88\t\n89\tfunction readInt(value: number | string | null | undefined): number {\n90\t  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n91\t  if (typeof value === \"string\") {\n92\t    const parsed = Number.parseInt(value, 10);\n93\t    return Number.isFinite(parsed) ? parsed : 0;\n94\t  }\n95\t  return 0;\n96\t}\n97\t\n98\tfunction formatCount(count: number): string {\n99\t  return count.toLocaleString(\"en-US\");\n100\t}\n101\t\n102\texport async function listDogpileEvents(\n103\t  options: ListDogpileEventsOptions = {},\n104\t): Promise<ReadonlyArray<PeekDogpileEventRow>> {\n105\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n106\t  const limit = clampLimit(\n107\t    options.limit,\n108\t    PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT,\n109\t    PEEK_DOGPILE_EVENTS_MAX_LIMIT,\n110\t  );\n111\t\n112\t  const filters = options.filters ?? {};\n113\t  const status = trimOrNull(filters.status ?? null);\n114\t  const startsFrom = trimOrNull(filters.startsFrom ?? null);\n115\t  const startsTo = trimOrNull(filters.startsTo ?? null);\n116\t\n117\t  const rows = await sql<\n118\t    Array<{\n119\t      id: string;\n120\t      campaignId: string | null;\n121\t      campaignName: string | null;\n122\t      campaignType: string | null;\n123\t      startsAt: string;\n124\t      endsAt: string;\n125\t      multiplier: string;\n126\t      status: string;\n127\t      createdAt: string;\n128\t      gameEntryCount: number | string;\n129\t      pointGrantCount: number | string;\n130\t    }>\n131\t  >`\n132\t    select\n133\t      d.id::text as \"id\",\n134\t      d.campaign_id::text as \"campaignId\",\n135\t      c.name as \"campaignName\",\n136\t      c.campaign_type as \"campaignType\",\n137\t      d.starts_at::text as \"startsAt\",\n138\t      d.ends_at::text as \"endsAt\",\n139\t      d.multiplier::text as \"multiplier\",\n140\t      d.status as \"status\",\n141\t      d.created_at::text as \"createdAt\",\n142\t      (\n143\t        select count(*)::int\n144\t        from game_entries ge\n145\t        where ge.created_at >= d.starts_at\n146\t          and ge.created_at < d.ends_at\n147\t      ) as \"gameEntryCount\",\n148\t      (\n149\t        select count(*)::int\n150\t        from point_grants pg\n151\t        where pg.created_at >= d.starts_at\n152\t          and pg.created_at < d.ends_at\n153\t      ) as \"pointGrantCount\"\n154\t    from dogpile_events d\n155\t    left join campaigns c on c.id = d.campaign_id\n156\t    where\n157\t      (${status === null} or d.status = ${status ?? \"\"})\n158\t      and (${startsFrom === null} or d.starts_at >= ${startsFrom ?? \"\"}::timestamptz)\n159\t      and (${startsTo === null} or d.starts_at < ${startsTo ?? \"\"}::timestamptz)\n160\t    order by d.starts_at desc, d.id desc\n161\t    limit ${limit}\n162\t  `;\n163\t\n164\t  return rows.map((row) => ({\n165\t    id: row.id,\n166\t    campaignId: row.campaignId,\n167\t    campaignName: row.campaignName,\n168\t    campaignType: row.campaignType,\n169\t    startsAt: row.startsAt,\n170\t    endsAt: row.endsAt,\n171\t    multiplier: row.multiplier,\n172\t    status: row.status,\n173\t    createdAt: row.createdAt,\n174\t    gameEntryCount: readInt(row.gameEntryCount),\n175\t    pointGrantCount: readInt(row.pointGrantCount),\n176\t  }));\n177\t}\n178\t\n179\texport async function listFraudFlags(\n180\t  options: ListFraudFlagsOptions = {},\n181\t): Promise<ReadonlyArray<PeekFraudFlagListRow>> {\n182\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n183\t  const limit = clampLimit(\n184\t    options.limit,\n185\t    PEEK_FRAUD_FLAGS_DEFAULT_LIMIT,\n186\t    PEEK_FRAUD_FLAGS_MAX_LIMIT,\n187\t  );\n188\t\n189\t  const filters = options.filters ?? {};\n190\t  const status = trimOrNull(filters.status ?? null);\n191\t  const userId = trimOrNull(filters.userId ?? null);\n192\t  const flagType = trimOrNull(filters.flagType ?? null);\n193\t  const createdFrom = trimOrNull(filters.createdFrom ?? null);\n194\t  const createdTo = trimOrNull(filters.createdTo ?? null);\n195\t\n196\t  const rows = await sql<\n197\t    Array<{\n198\t      id: string;\n199\t      userId: string;\n200\t      username: string | null;\n201\t      wallet: string | null;\n202\t      flagType: string;\n203\t      status: string;\n204\t      relatedId: string | null;\n205\t      details: Record<string, unknown> | null;\n206\t      createdAt: string;\n207\t      resolvedAt: string | null;\n208\t    }>\n209\t  >`\n210\t    select\n211\t      f.id::text as \"id\",\n212\t      f.user_id as \"userId\",\n213\t      prof.username as \"username\",\n214\t      prof.wallet as \"wallet\",\n215\t      f.flag_type as \"flagType\",\n216\t      f.status as \"status\",\n217\t      f.related_id as \"relatedId\",\n218\t      f.details as \"details\",\n219\t      f.created_at::text as \"createdAt\",\n220\t      f.resolved_at::text as \"resolvedAt\"\n221\t    from fraud_flags f\n222\t    left join player_profiles prof on prof.user_id = f.user_id\n223\t    where\n224\t      (${status === null} or f.status = ${status ?? \"\"})\n225\t      and (${userId === null} or f.user_id = ${userId ?? \"\"})\n226\t      and (${flagType === null} or f.flag_type = ${flagType ?? \"\"})\n227\t      and (${createdFrom === null} or f.created_at >= ${createdFrom ?? \"\"}::timestamptz)\n228\t      and (${createdTo === null} or f.created_at < ${createdTo ?? \"\"}::timestamptz)\n229\t    order by\n230\t      case f.status when 'open' then 0 when 'reviewed' then 1 else 2 end,\n231\t      f.created_at desc,\n232\t      f.id desc\n233\t    limit ${limit}\n234\t  `;\n235\t\n236\t  return rows.map((row) => ({\n237\t    id: row.id,\n238\t    userId: row.userId,\n239\t    username: row.username,\n240\t    wallet: row.wallet,\n241\t    flagType: row.flagType,\n242\t    status: row.status,\n243\t    relatedId: row.relatedId,\n244\t    details: row.details,\n245\t    createdAt: row.createdAt,\n246\t    resolvedAt: row.resolvedAt,\n247\t  }));\n248\t}\n249\t\n250\ttype MetricBlueprint = {\n251\t  id: PeekDogpileFraudOverviewMetricId;\n252\t  label: string;\n253\t  unit: string | null;\n254\t  source: string;\n255\t  windowLabel: string;\n256\t  definition: string;\n257\t  drilldownHref: string | null;\n258\t};\n259\t\n260\tfunction buildMetric(\n261\t  blueprint: MetricBlueprint,\n262\t  raw: number,\n263\t  display: string,\n264\t  asOf: string,\n265\t): PeekMetric {\n266\t  return {\n267\t    id: blueprint.id,\n268\t    label: blueprint.label,\n269\t    value: raw,\n270\t    valueDisplay: display,\n271\t    unit: blueprint.unit,\n272\t    source: blueprint.source,\n273\t    windowLabel: blueprint.windowLabel,\n274\t    asOf,\n275\t    definition: blueprint.definition,\n276\t    freshness: \"live\",\n277\t    drilldownHref: blueprint.drilldownHref,\n278\t  };\n279\t}\n280\t\n281\texport async function getDogpileFraudOverview(\n282\t  options: DogpileFraudOverviewOptions = {},\n283\t): Promise<PeekDogpileFraudOverview> {\n284\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n285\t  const now = options.now ?? new Date();\n286\t  const generatedAt = now.toISOString();\n287\t  const windowHours = clampLimit(\n288\t    options.windowHours,\n289\t    PEEK_DOGPILE_FRAUD_OVERVIEW_WINDOW_HOURS,\n290\t    24 * 30,\n291\t  );\n292\t  const since = new Date(now.getTime() - windowHours * 60 * 60 * 1000);\n293\t  const sinceIso = since.toISOString();\n294\t\n295\t  const [\n296\t    scheduledRows,\n297\t    activeRows,\n298\t    endedWindowRows,\n299\t    cancelledWindowRows,\n300\t    openFraudRows,\n301\t  ] = await Promise.all([\n302\t    sql<Array<{ value: number | string }>>`\n303\t      select count(*)::int as \"value\"\n304\t      from dogpile_events\n305\t      where status = 'scheduled'\n306\t    `,\n307\t    sql<Array<{ value: number | string }>>`\n308\t      select count(*)::int as \"value\"\n309\t      from dogpile_events\n310\t      where status = 'active'\n311\t    `,\n312\t    sql<Array<{ value: number | string }>>`\n313\t      select count(*)::int as \"value\"\n314\t      from dogpile_events\n315\t      where status = 'ended'\n316\t        and ends_at >= ${sinceIso}::timestamptz\n317\t    `,\n318\t    sql<Array<{ value: number | string }>>`\n319\t      select count(*)::int as \"value\"\n320\t      from dogpile_events\n321\t      where status = 'cancelled'\n322\t        and created_at >= ${sinceIso}::timestamptz\n323\t    `,\n324\t    sql<Array<{ value: number | string }>>`\n325\t      select count(*)::int as \"value\"\n326\t      from fraud_flags\n327\t      where status = 'open'\n328\t    `,\n329\t  ]);\n330\t\n331\t  const scheduled = readInt(scheduledRows[0]?.value ?? 0);\n332\t  const active = readInt(activeRows[0]?.value ?? 0);\n333\t  const endedWindow = readInt(endedWindowRows[0]?.value ?? 0);\n334\t  const cancelledWindow = readInt(cancelledWindowRows[0]?.value ?? 0);\n335\t  const openFraud = readInt(openFraudRows[0]?.value ?? 0);\n336\t\n337\t  const windowLabel = `Last ${windowHours}h`;\n338\t\n339\t  const blueprints: ReadonlyArray<{\n340\t    blueprint: MetricBlueprint;\n341\t    raw: number;\n342\t    display: string;\n343\t  }> = [\n344\t    {\n345\t      blueprint: {\n346\t        id: \"dogpile.scheduled\",\n347\t        label: \"Scheduled events\",\n348\t        unit: \"events\",\n349\t        source: \"dogpile_events\",\n350\t        windowLabel: \"Current\",\n351\t        definition:\n352\t          \"Count of dogpile_events rows with status = 'scheduled' — events booked but not yet active.\",\n353\t        drilldownHref: \"/operations/dogpile?status=scheduled\",\n354\t      },\n355\t      raw: scheduled,\n356\t      display: formatCount(scheduled),\n357\t    },\n358\t    {\n359\t      blueprint: {\n360\t        id: \"dogpile.active\",\n361\t        label: \"Active events\",\n362\t        unit: \"events\",\n363\t        source: \"dogpile_events\",\n364\t        windowLabel: \"Current\",\n365\t        definition:\n366\t          \"Count of dogpile_events rows with status = 'active' — events currently applying their multiplier to point grants.\",\n367\t        drilldownHref: \"/operations/dogpile?status=active\",\n368\t      },\n369\t      raw: active,\n370\t      display: formatCount(active),\n371\t    },\n372\t    {\n373\t      blueprint: {\n374\t        id: \"dogpile.ended_window\",\n375\t        label: \"Ended events\",\n376\t        unit: \"events\",\n377\t        source: \"dogpile_events\",\n378\t        windowLabel,\n379\t        definition: `Count of dogpile_events rows with status = 'ended' whose ends_at falls within the last ${windowHours} hours.`,\n380\t        drilldownHref: \"/operations/dogpile?status=ended\",\n381\t      },\n382\t      raw: endedWindow,\n383\t      display: formatCount(endedWindow),\n384\t    },\n385\t    {\n386\t      blueprint: {\n387\t        id: \"dogpile.cancelled_window\",\n388\t        label: \"Cancelled events\",\n389\t        unit: \"events\",\n390\t        source: \"dogpile_events\",\n391\t        windowLabel,\n392\t        definition: `Count of dogpile_events rows with status = 'cancelled' created within the last ${windowHours} hours — events the operator stopped before they could apply.`,\n393\t        drilldownHref: \"/operations/dogpile?status=cancelled\",\n394\t      },\n395\t      raw: cancelledWindow,\n396\t      display: formatCount(cancelledWindow),\n397\t    },\n398\t    {\n399\t      blueprint: {\n400\t        id: \"fraud.open_flags\",\n401\t        label: \"Open fraud flags\",\n402\t        unit: \"flags\",\n403\t        source: \"fraud_flags\",\n404\t        windowLabel: \"Current\",\n405\t        definition:\n406\t          \"Count of fraud_flags rows with status = 'open' — review queue awaiting an admin decision.\",\n407\t        drilldownHref: \"/operations/dogpile?fraudStatus=open#fraud\",\n408\t      },\n409\t      raw: openFraud,\n410\t      display: formatCount(openFraud),\n411\t    },\n412\t  ];\n413\t\n414\t  return {\n415\t    generatedAt,\n416\t    metrics: blueprints.map(({ blueprint, raw, display }) =>\n417\t      buildMetric(blueprint, raw, display, generatedAt),\n418\t    ),\n419\t  };\n420\t}\n421\t"}]},"parent_tool_use_id":null,"session_id":"2a495ebd-2cda-4eb4-ae9f-5caaba2d57d7","uuid":"da7eb700-1009-45b4-83a9-c4dd4de97577","timestamp":"2026-04-26T06:27:53.604Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-dogpile-and-fraud.ts","content":"// Dogpile + fraud admin queries (FR-9).\n//\n// Backs the upcoming `/operations/dogpile` page and the fraud-review surface.\n// Reads two migration-011 tables in read-only mode (no dogpile or fraud-flag\n// editing — that lives behind the FR-14 mutation framework; `dogpile.cancel`\n// and `fraud_flag.status.update` action ids are already declared in\n// `peek/src/server/access-policy.ts`):\n//\n//   - dogpile_events  — `listDogpileEvents` returns the scheduled / active /\n//     ended / cancelled lifecycle rows joined with the parent `campaigns` row\n//     (campaign_id is nullable so the join is a left join). Each row is\n//     annotated with the count of `game_entries` and `point_grants` whose\n//     `created_at` falls within the event's `[starts_at, ends_at)` window —\n//     this is the operator-readable \"linked\" set the spec calls out\n//     (FR-9 line 327: \"linked campaigns/game_entries/point_grants\"). There\n//     is no FK from those ledger tables to `dogpile_events`; the worker\n//     applies the multiplier purely based on the time window\n//     (`backend/src/queue/handlers/points-grant.ts`), so a window-based\n//     count is the closest operator-meaningful link.\n//\n//   - fraud_flags     — `listFraudFlags` returns the open / reviewed /\n//     dismissed review queue joined with `player_profiles` for username +\n//     wallet context. The JSONB `details` column round-trips verbatim so the\n//     operator-facing UI can show whatever metadata the writer attached.\n//     Read-only — every status transition is gated by the\n//     `fraud_flag.status.update` mutation action (FR-14, not yet built).\n//\n// `getDogpileFraudOverview` produces the FR-4 metric strip for the page:\n// scheduled, active, ended-in-window, cancelled-in-window, open fraud flags.\n//\n// All queries are bounded server-side (default 100, max 500). Bigint identity\n// ids round-trip as `text` to preserve precision; the dogpile multiplier is\n// returned as `text` because it is stored as `NUMERIC(4,2)` and the UI\n// formats it at render time.\n\nimport type { Sql } from \"postgres\";\nimport {\n  type PeekDogpileEventFilters,\n  type PeekDogpileEventRow,\n  type PeekDogpileFraudOverview,\n  type PeekDogpileFraudOverviewMetricId,\n  type PeekFraudFlagFilters,\n  type PeekFraudFlagListRow,\n  type PeekMetric,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT = 100;\nexport const PEEK_DOGPILE_EVENTS_MAX_LIMIT = 500;\nexport const PEEK_FRAUD_FLAGS_DEFAULT_LIMIT = 100;\nexport const PEEK_FRAUD_FLAGS_MAX_LIMIT = 500;\nexport const PEEK_DOGPILE_FRAUD_OVERVIEW_WINDOW_HOURS = 24;\n\nexport type ListDogpileEventsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekDogpileEventFilters>;\n};\n\nexport type ListFraudFlagsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekFraudFlagFilters>;\n};\n\nexport type DogpileFraudOverviewOptions = {\n  sql?: Sql;\n  now?: Date;\n  windowHours?: number;\n};\n\nfunction clampLimit(\n  raw: number | undefined,\n  fallback: number,\n  max: number,\n): number {\n  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n  const floored = Math.floor(raw);\n  if (floored <= 0) return 1;\n  return Math.min(max, floored);\n}\n\nfunction trimOrNull(value: string | null | undefined): string | null {\n  if (typeof value !== \"string\") return null;\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nfunction readInt(value: number | string | null | undefined): number {\n  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n  if (typeof value === \"string\") {\n    const parsed = Number.parseInt(value, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\nexport async function listDogpileEvents(\n  options: ListDogpileEventsOptions = {},\n): Promise<ReadonlyArray<PeekDogpileEventRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT,\n    PEEK_DOGPILE_EVENTS_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const status = trimOrNull(filters.status ?? null);\n  const startsFrom = trimOrNull(filters.startsFrom ?? null);\n  const startsTo = trimOrNull(filters.startsTo ?? null);\n\n  const rows = await sql<\n    Array<{\n      id: string;\n      campaignId: string | null;\n      campaignName: string | null;\n      campaignType: string | null;\n      startsAt: string;\n      endsAt: string;\n      multiplier: string;\n      status: string;\n      createdAt: string;\n      gameEntryCount: number | string;\n      pointGrantCount: number | string;\n    }>\n  >`\n    select\n      d.id::text as \"id\",\n      d.campaign_id::text as \"campaignId\",\n      c.name as \"campaignName\",\n      c.campaign_type as \"campaignType\",\n      d.starts_at::text as \"startsAt\",\n      d.ends_at::text as \"endsAt\",\n      d.multiplier::text as \"multiplier\",\n      d.status as \"status\",\n      d.created_at::text as \"createdAt\",\n      (\n        select count(*)::int\n        from game_entries ge\n        where ge.created_at >= d.starts_at\n          and ge.created_at < d.ends_at\n      ) as \"gameEntryCount\",\n      (\n        select count(*)::int\n        from point_grants pg\n        where pg.created_at >= d.starts_at\n          and pg.created_at < d.ends_at\n      ) as \"pointGrantCount\"\n    from dogpile_events d\n    left join campaigns c on c.id = d.campaign_id\n    where\n      (${status === null} or d.status = ${status ?? \"\"})\n      and (${startsFrom === null} or d.starts_at >= ${startsFrom ?? \"\"}::timestamptz)\n      and (${startsTo === null} or d.starts_at < ${startsTo ?? \"\"}::timestamptz)\n    order by d.starts_at desc, d.id desc\n    limit ${limit}\n  `;\n\n  return rows.map((row) => ({\n    id: row.id,\n    campaignId: row.campaignId,\n    campaignName: row.campaignName,\n    campaignType: row.campaignType,\n    startsAt: row.startsAt,\n    endsAt: row.endsAt,\n    multiplier: row.multiplier,\n    status: row.status,\n    createdAt: row.createdAt,\n    gameEntryCount: readInt(row.gameEntryCount),\n    pointGrantCount: readInt(row.pointGrantCount),\n  }));\n}\n\nexport async function listFraudFlags(\n  options: ListFraudFlagsOptions = {},\n): Promise<ReadonlyArray<PeekFraudFlagListRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_FRAUD_FLAGS_DEFAULT_LIMIT,\n    PEEK_FRAUD_FLAGS_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const status = trimOrNull(filters.status ?? null);\n  const userId = trimOrNull(filters.userId ?? null);\n  const flagType = trimOrNull(filters.flagType ?? null);\n  const createdFrom = trimOrNull(filters.createdFrom ?? null);\n  const createdTo = trimOrNull(filters.createdTo ?? null);\n\n  const rows = await sql<\n    Array<{\n      id: string;\n      userId: string;\n      username: string | null;\n      wallet: string | null;\n      flagType: string;\n      status: string;\n      relatedId: string | null;\n      details: Record<string, unknown> | null;\n      createdAt: string;\n      resolvedAt: string | null;\n    }>\n  >`\n    select\n      f.id::text as \"id\",\n      f.user_id as \"userId\",\n      prof.username as \"username\",\n      prof.wallet as \"wallet\",\n      f.flag_type as \"flagType\",\n      f.status as \"status\",\n      f.related_id as \"relatedId\",\n      f.details as \"details\",\n      f.created_at::text as \"createdAt\",\n      f.resolved_at::text as \"resolvedAt\"\n    from fraud_flags f\n    left join player_profiles prof on prof.user_id = f.user_id\n    where\n      (${status === null} or f.status = ${status ?? \"\"})\n      and (${userId === null} or f.user_id = ${userId ?? \"\"})\n      and (${flagType === null} or f.flag_type = ${flagType ?? \"\"})\n      and (${createdFrom === null} or f.created_at >= ${createdFrom ?? \"\"}::timestamptz)\n      and (${createdTo === null} or f.created_at < ${createdTo ?? \"\"}::timestamptz)\n    order by\n      case f.status when 'open' then 0 when 'reviewed' then 1 else 2 end,\n      f.created_at desc,\n      f.id desc\n    limit ${limit}\n  `;\n\n  return rows.map((row) => ({\n    id: row.id,\n    userId: row.userId,\n    username: row.username,\n    wallet: row.wallet,\n    flagType: row.flagType,\n    status: row.status,\n    relatedId: row.relatedId,\n    details: row.details,\n    createdAt: row.createdAt,\n    resolvedAt: row.resolvedAt,\n  }));\n}\n\ntype MetricBlueprint = {\n  id: PeekDogpileFraudOverviewMetricId;\n  label: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  definition: string;\n  drilldownHref: string | null;\n};\n\nfunction buildMetric(\n  blueprint: MetricBlueprint,\n  raw: number,\n  display: string,\n  asOf: string,\n): PeekMetric {\n  return {\n    id: blueprint.id,\n    label: blueprint.label,\n    value: raw,\n    valueDisplay: display,\n    unit: blueprint.unit,\n    source: blueprint.source,\n    windowLabel: blueprint.windowLabel,\n    asOf,\n    definition: blueprint.definition,\n    freshness: \"live\",\n    drilldownHref: blueprint.drilldownHref,\n  };\n}\n\nexport async function getDogpileFraudOverview(\n  options: DogpileFraudOverviewOptions = {},\n): Promise<PeekDogpileFraudOverview> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n  const windowHours = clampLimit(\n    options.windowHours,\n    PEEK_DOGPILE_FRAUD_OVERVIEW_WINDOW_HOURS,\n    24 * 30,\n  );\n  const since = new Date(now.getTime() - windowHours * 60 * 60 * 1000);\n  const sinceIso = since.toISOString();\n\n  const [\n    scheduledRows,\n    activeRows,\n    endedWindowRows,\n    cancelledWindowRows,\n    openFraudRows,\n  ] = await Promise.all([\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from dogpile_events\n      where status = 'scheduled'\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from dogpile_events\n      where status = 'active'\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from dogpile_events\n      where status = 'ended'\n        and ends_at >= ${sinceIso}::timestamptz\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from dogpile_events\n      where status = 'cancelled'\n        and created_at >= ${sinceIso}::timestamptz\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from fraud_flags\n      where status = 'open'\n    `,\n  ]);\n\n  const scheduled = readInt(scheduledRows[0]?.value ?? 0);\n  const active = readInt(activeRows[0]?.value ?? 0);\n  const endedWindow = readInt(endedWindowRows[0]?.value ?? 0);\n  const cancelledWindow = readInt(cancelledWindowRows[0]?.value ?? 0);\n  const openFraud = readInt(openFraudRows[0]?.value ?? 0);\n\n  const windowLabel = `Last ${windowHours}h`;\n\n  const blueprints: ReadonlyArray<{\n    blueprint: MetricBlueprint;\n    raw: number;\n    display: string;\n  }> = [\n    {\n      blueprint: {\n        id: \"dogpile.scheduled\",\n        label: \"Scheduled events\",\n        unit: \"events\",\n        source: \"dogpile_events\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of dogpile_events rows with status = 'scheduled' — events booked but not yet active.\",\n        drilldownHref: \"/operations/dogpile?status=scheduled\",\n      },\n      raw: scheduled,\n      display: formatCount(scheduled),\n    },\n    {\n      blueprint: {\n        id: \"dogpile.active\",\n        label: \"Active events\",\n        unit: \"events\",\n        source: \"dogpile_events\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of dogpile_events rows with status = 'active' — events currently applying their multiplier to point grants.\",\n        drilldownHref: \"/operations/dogpile?status=active\",\n      },\n      raw: active,\n      display: formatCount(active),\n    },\n    {\n      blueprint: {\n        id: \"dogpile.ended_window\",\n        label: \"Ended events\",\n        unit: \"events\",\n        source: \"dogpile_events\",\n        windowLabel,\n        definition: `Count of dogpile_events rows with status = 'ended' whose ends_at falls within the last ${windowHours} hours.`,\n        drilldownHref: \"/operations/dogpile?status=ended\",\n      },\n      raw: endedWindow,\n      display: formatCount(endedWindow),\n    },\n    {\n      blueprint: {\n        id: \"dogpile.cancelled_window\",\n        label: \"Cancelled events\",\n        unit: \"events\",\n        source: \"dogpile_events\",\n        windowLabel,\n        definition: `Count of dogpile_events rows with status = 'cancelled' created within the last ${windowHours} hours — events the operator stopped before they could apply.`,\n        drilldownHref: \"/operations/dogpile?status=cancelled\",\n      },\n      raw: cancelledWindow,\n      display: formatCount(cancelledWindow),\n    },\n    {\n      blueprint: {\n        id: \"fraud.open_flags\",\n        label: \"Open fraud flags\",\n        unit: \"flags\",\n        source: \"fraud_flags\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of fraud_flags rows with status = 'open' — review queue awaiting an admin decision.\",\n        drilldownHref: \"/operations/dogpile?fraudStatus=open#fraud\",\n      },\n      raw: openFraud,\n      display: formatCount(openFraud),\n    },\n  ];\n\n  return {\n    generatedAt,\n    metrics: blueprints.map(({ blueprint, raw, display }) =>\n      buildMetric(blueprint, raw, display, generatedAt),\n    ),\n  };\n}\n","numLines":421,"startLine":1,"totalLines":421}}}
