{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SM9ZU3yCKoNPRxQ3ZJkkf7","type":"tool_result","content":"1\t// Progress events table for /economy/challenges (FR-9).\n2\t//\n3\t// Read-only append-only ledger over `PeekProgressEventRow`. Each row pins a\n4\t// specific game round to an assignment for anti-gaming audit. The user cell\n5\t// links to user-detail and the round id is shown verbatim so an operator can\n6\t// paste it into universal search to inspect the originating round.\n7\timport Link from \"next/link\";\n8\timport type { CSSProperties } from \"react\";\n9\timport type { PeekProgressEventRow } from \"../lib/types/peek\";\n10\t\n11\texport type ProgressEventsTableProps = {\n12\t  rows: ReadonlyArray<PeekProgressEventRow>;\n13\t  error?: string | null;\n14\t};\n15\t\n16\texport function ProgressEventsTable({\n17\t  rows,\n18\t  error = null,\n19\t}: ProgressEventsTableProps) {\n20\t  if (error) {\n21\t    return (\n22\t      <div role=\"alert\" style={errorStyle}>\n23\t        Progress events unavailable: {error}\n24\t      </div>\n25\t    );\n26\t  }\n27\t\n28\t  if (rows.length === 0) {\n29\t    return (\n30\t      <div role=\"status\" style={emptyStyle}>\n31\t        <p style={emptyTitleStyle}>\n32\t          No progress_events rows match these filters.\n33\t        </p>\n34\t        <p style={emptyBodyStyle}>\n35\t          Adjust the filters above or clear them to see recent progress events.\n36\t        </p>\n37\t      </div>\n38\t    );\n39\t  }\n40\t\n41\t  return (\n42\t    <div style={wrapperStyle}>\n43\t      <table style={tableStyle}>\n44\t        <thead>\n45\t          <tr style={headerRowStyle}>\n46\t            <th style={headerCellStyle(\"left\")}>Created</th>\n47\t            <th style={headerCellStyle(\"left\")}>User</th>\n48\t            <th style={headerCellStyle(\"left\")}>Challenge</th>\n49\t            <th style={headerCellStyle(\"left\")}>Assignment</th>\n50\t            <th style={headerCellStyle(\"left\")}>Round</th>\n51\t            <th style={headerCellStyle(\"right\")}>Δ progress</th>\n52\t            <th style={headerCellStyle(\"left\")}>ID</th>\n53\t          </tr>\n54\t        </thead>\n55\t        <tbody>\n56\t          {rows.map((row) => (\n57\t            <tr key={row.id} style={bodyRowStyle}>\n58\t              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n59\t              <td style={bodyCellStyle(\"left\")}>\n60\t                <Link href={`/users/${row.userId}`} style={linkStyle}>\n61\t                  {row.username ?? row.userId}\n62\t                </Link>\n63\t                {row.username ? (\n64\t                  <span style={subValueStyle}> · {row.userId}</span>\n65\t                ) : null}\n66\t              </td>\n67\t              <td style={bodyCellStyle(\"left\")}>\n68\t                <div>{row.challengeTitle ?? \"—\"}</div>\n69\t                <div style={{ ...subValueStyle, fontFamily: \"monospace\" }}>\n70\t                  {row.challengeId ?? \"—\"}\n71\t                </div>\n72\t              </td>\n73\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n74\t                {row.assignmentId}\n75\t              </td>\n76\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n77\t                {row.roundId}\n78\t              </td>\n79\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n80\t                {row.progressDelta.toLocaleString(\"en-US\")}\n81\t              </td>\n82\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n83\t                {row.id}\n84\t              </td>\n85\t            </tr>\n86\t          ))}\n87\t        </tbody>\n88\t      </table>\n89\t    </div>\n90\t  );\n91\t}\n92\t\n93\tconst wrapperStyle: CSSProperties = {\n94\t  overflowX: \"auto\",\n95\t  border: \"1px solid #1e293b\",\n96\t  borderRadius: \"0.75rem\",\n97\t};\n98\t\n99\tconst tableStyle: CSSProperties = {\n100\t  width: \"100%\",\n101\t  borderCollapse: \"collapse\",\n102\t};\n103\t\n104\tconst headerRowStyle: CSSProperties = {\n105\t  background: \"#111827\",\n106\t  color: \"#94a3b8\",\n107\t};\n108\t\n109\tconst bodyRowStyle: CSSProperties = {\n110\t  borderTop: \"1px solid #1e293b\",\n111\t};\n112\t\n113\tconst linkStyle: CSSProperties = {\n114\t  color: \"#93c5fd\",\n115\t  textDecoration: \"none\",\n116\t};\n117\t\n118\tconst subValueStyle: CSSProperties = {\n119\t  color: \"#64748b\",\n120\t  fontSize: \"0.75rem\",\n121\t};\n122\t\n123\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n124\t  return {\n125\t    padding: \"0.75rem\",\n126\t    textAlign: align,\n127\t    fontSize: \"0.875rem\",\n128\t    fontWeight: 600,\n129\t  };\n130\t}\n131\t\n132\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n133\t  return {\n134\t    padding: \"0.75rem\",\n135\t    textAlign: align,\n136\t    fontSize: \"0.875rem\",\n137\t    color: \"#e2e8f0\",\n138\t    verticalAlign: \"top\",\n139\t  };\n140\t}\n141\t\n142\tconst errorStyle: CSSProperties = {\n143\t  margin: 0,\n144\t  padding: \"0.75rem 1rem\",\n145\t  borderRadius: \"0.75rem\",\n146\t  background: \"#3f1d1d\",\n147\t  color: \"#fecaca\",\n148\t};\n149\t\n150\tconst emptyStyle: CSSProperties = {\n151\t  padding: \"1.5rem\",\n152\t  borderRadius: \"0.75rem\",\n153\t  border: \"1px dashed #334155\",\n154\t  background: \"#0b1220\",\n155\t  color: \"#cbd5f5\",\n156\t  display: \"grid\",\n157\t  gap: \"0.5rem\",\n158\t};\n159\t\n160\tconst emptyTitleStyle: CSSProperties = {\n161\t  margin: 0,\n162\t  fontSize: \"1rem\",\n163\t  fontWeight: 600,\n164\t};\n165\t\n166\tconst emptyBodyStyle: CSSProperties = {\n167\t  margin: 0,\n168\t  fontSize: \"0.875rem\",\n169\t  color: \"#94a3b8\",\n170\t};\n171\t"}]},"parent_tool_use_id":null,"session_id":"2a495ebd-2cda-4eb4-ae9f-5caaba2d57d7","uuid":"cd009e7d-8b8c-48dd-8a20-c509591f3353","timestamp":"2026-04-26T06:28:46.743Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/progress-events-table.tsx","content":"// Progress events table for /economy/challenges (FR-9).\n//\n// Read-only append-only ledger over `PeekProgressEventRow`. Each row pins a\n// specific game round to an assignment for anti-gaming audit. The user cell\n// links to user-detail and the round id is shown verbatim so an operator can\n// paste it into universal search to inspect the originating round.\nimport Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type { PeekProgressEventRow } from \"../lib/types/peek\";\n\nexport type ProgressEventsTableProps = {\n  rows: ReadonlyArray<PeekProgressEventRow>;\n  error?: string | null;\n};\n\nexport function ProgressEventsTable({\n  rows,\n  error = null,\n}: ProgressEventsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Progress events unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>\n          No progress_events rows match these filters.\n        </p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see recent progress events.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Challenge</th>\n            <th style={headerCellStyle(\"left\")}>Assignment</th>\n            <th style={headerCellStyle(\"left\")}>Round</th>\n            <th style={headerCellStyle(\"right\")}>Δ progress</th>\n            <th style={headerCellStyle(\"left\")}>ID</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <Link href={`/users/${row.userId}`} style={linkStyle}>\n                  {row.username ?? row.userId}\n                </Link>\n                {row.username ? (\n                  <span style={subValueStyle}> · {row.userId}</span>\n                ) : null}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <div>{row.challengeTitle ?? \"—\"}</div>\n                <div style={{ ...subValueStyle, fontFamily: \"monospace\" }}>\n                  {row.challengeId ?? \"—\"}\n                </div>\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.assignmentId}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.roundId}\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.progressDelta.toLocaleString(\"en-US\")}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.id}\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":171,"startLine":1,"totalLines":171}}}
