ferral\"\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Created from</span>\n        <input\n          name=\"fraudFilterFrom\"\n          type=\"date\"\n          defaultValue={(filters.createdFrom ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Created to</span>\n        <input\n          name=\"fraudFilterTo\"\n          type=\"date\"\n          defaultValue={(filters.createdTo ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <button type=\"submit\" style={buttonStyle}>\n        Apply filters\n      </button>\n    </form>\n  );\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n  gridTemplateColumns: \"repeat(auto-fit, minmax(180px, 1fr))\",\n  alignItems: \"end\",\n};\n\nconst fieldStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.35rem\",\n  fontSize: \"0.875rem\",\n};\n\nconst inputStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #334155\",\n  background: \"#111827\",\n  color: \"#e2e8f0\",\n  padding: \"0.625rem 0.75rem\",\n};\n\nconst buttonStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #475569\",\n  background: \"#1d4ed8\",\n  color: \"#eff6ff\",\n  padding: \"0.75rem 1rem\",\n  fontWeight: 600,\n};\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01U4CRxDdFa2diRmnjawKwWV","type":"message","role":"assistant","content":[{"type":"text","text":"Now the dogpile events table."}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2055,"cache_read_input_tokens":118434,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2055},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"2a495ebd-2cda-4eb4-ae9f-5caaba2d57d7","uuid":"9fa970d0-a91c-4a4f-a9aa-64cc71613349"}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01U4CRxDdFa2diRmnjawKwWV","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01HsvWHGbnXDPCdC9X3SYEUJ","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/dogpile-events-table.tsx","content":"// Dogpile events table for /operations/dogpile (FR-9).\n//\n// Read-only dense table over `PeekDogpileEventRow`. Status drives the chip\n// tone so an operator can spot scheduled vs active vs ended/cancelled at a\n// glance. Each row also surfaces the count of game_entries and point_grants\n// whose `created_at` falls inside the dogpile window — the closest\n// operator-meaningful \"linked\" set the spec calls out (FR-9). Editing dogpile\n// events is out of scope here; cancellation lives behind the FR-14\n// `dogpile.cancel` action id (not yet implemented).\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekDogpileEventRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type DogpileEventsTableProps = {\n  rows: ReadonlyArray<PeekDogpileEventRow>;\n  error?: string | null;\n};\n\nexport function DogpileEventsTable({\n  rows,\n  error = null,\n}: DogpileEventsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Dogpile events unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>\n          No dogpile_events rows match these filters.\n        </p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see scheduled, active,\n          ended, and cancelled events.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Status</th>\n            <th style={headerCellStyle(\"left\")}>Campaign</th>\n            <th style={headerCellStyle(\"left\")}>Starts</th>\n            <th style={headerCellStyle(\"left\")}>Ends</th>\n            <th style={headerCellStyle(\"right\")}>Multiplier</th>\n            <th style={headerCellStyle(\"right\")}>Game entries</th>\n            <th style={headerCellStyle(\"right\")}>Point grants</th>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>ID</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.status}\n                  tone={dogpileStatusTone(row.status)}\n                />\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <div>{row.campaignName ?? \"—\"}</div>\n                {row.campaignType ? (\n                  <div style={subValueStyle}>{row.campaignType}</div>\n                ) : null}\n                {row.campaignId ? (\n                  <div style={{ ...subValueStyle, fontFamily: \"monospace\" }}>\n                    {row.campaignId}\n                  </div>\n                ) : null}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.startsAt}</td>\n              <td style={bodyCellStyle(\"left\")}>{row.endsAt}</td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.multiplier}×\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.gameEntryCount.toLocaleString(\"en-US\")}\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.pointGrantCount.toLocaleString(\"en-US\")}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.id}\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction dogpileStatusTone(value: string): PeekStatusTone {\n  if (value === \"scheduled\") return \"info\";\n  if (value === \"active\") return \"positive\";\n  if (value === \"ended\") return \"neutral\";\n  if (value === \"cancelled\") return \"warning\";\n  return \"neutral\";\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2055,"cache_read_input_tokens":118434,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2055},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"2a495ebd-2cda-4eb4-ae9f-5caaba2d57d7","uuid":"2b0ecef6-ab73-41b5-a253-13ff0f4c9459"}
