ing }> = {\n    neutral: { background: \"#1f2937\", color: \"#cbd5f5\", border: \"#334155\" },\n    positive: { background: \"#064e3b\", color: \"#a7f3d0\", border: \"#065f46\" },\n    warning: { background: \"#3f3f00\", color: \"#fde68a\", border: \"#b45309\" },\n    negative: { background: \"#3f1d1d\", color: \"#fecaca\", border: \"#991b1b\" },\n    info: { background: \"#1e293b\", color: \"#bfdbfe\", border: \"#1d4ed8\" },\n  };\n  const t = tones[tone];\n  return {\n    display: \"inline-flex\",\n    alignItems: \"center\",\n    fontSize: \"0.6875rem\",\n    fontWeight: 600,\n    textTransform: \"uppercase\",\n    letterSpacing: \"0.05em\",\n    padding: \"0.125rem 0.5rem\",\n    borderRadius: \"9999px\",\n    background: t.background,\n    color: t.color,\n    border: `1px solid ${t.border}`,\n    whiteSpace: \"nowrap\",\n  };\n}\n\nconst emptyStyle: CSSProperties = {\n  display: \"inline-flex\",\n  alignItems: \"center\",\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n  padding: \"0.125rem 0.25rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  display: \"inline-flex\",\n  alignItems: \"center\",\n  fontSize: \"0.75rem\",\n  padding: \"0.125rem 0.5rem\",\n  borderRadius: \"9999px\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n  border: \"1px solid #991b1b\",\n};\n","numLines":88,"startLine":1,"totalLines":88}}}
