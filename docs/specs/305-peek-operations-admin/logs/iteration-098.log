{\n    assignmentId: trimOrNull(readSingleValue(input.progFilterAssignmentId)),\n    challengeId: trimOrNull(readSingleValue(input.progFilterChallengeId)),\n    userId: trimOrNull(readSingleValue(input.progFilterUserId)),\n    roundId: trimOrNull(readSingleValue(input.progFilterRoundId)),\n    createdFrom: trimOrNull(readSingleValue(input.progFilterFrom)),\n    createdTo: trimOrNull(readSingleValue(input.progFilterTo)),\n  };\n}\n\nexport function normalizeBonusCompletionFiltersFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): PeekBonusCompletionFilters {\n  return {\n    userId: trimOrNull(readSingleValue(input.bcFilterUserId)),\n    bonusId: trimOrNull(readSingleValue(input.bcFilterBonusId)),\n    campaignId: trimOrNull(readSingleValue(input.bcFilterCampaignId)),\n    periodKey: trimOrNull(readSingleValue(input.bcFilterPeriodKey)),\n    completedFrom: trimOrNull(readSingleValue(input.bcFilterFrom)),\n    completedTo: trimOrNull(readSingleValue(input.bcFilterTo)),\n  };\n}\n","numLines":103,"startLine":1,"totalLines":103}}}
