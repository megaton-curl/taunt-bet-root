e={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>User ID</span>\n        <input\n          name=\"progFilterUserId\"\n          type=\"text\"\n          defaultValue={filters.userId ?? \"\"}\n          placeholder=\"user_id\"\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Round ID</span>\n        <input\n          name=\"progFilterRoundId\"\n          type=\"text\"\n          defaultValue={filters.roundId ?? \"\"}\n          placeholder=\"round id (PDA)\"\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Created from</span>\n        <input\n          name=\"progFilterFrom\"\n          type=\"date\"\n          defaultValue={(filters.createdFrom ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Created to</span>\n        <input\n          name=\"progFilterTo\"\n          type=\"date\"\n          defaultValue={(filters.createdTo ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <button type=\"submit\" style={buttonStyle}>\n        Apply filters\n      </button>\n    </form>\n  );\n}\n\nexport function BonusCompletionsFilterBar({\n  filters,\n  action = \"/economy/challenges\",\n}: BonusCompletionsFilterBarProps) {\n  return (\n    <form\n      action={action}\n      method=\"get\"\n      role=\"search\"\n      aria-label=\"Filter bonus completions\"\n      style={formStyle}\n    >\n      <label style={fieldStyle}>\n        <span>User ID</span>\n        <input\n          name=\"bcFilterUserId\"\n          type=\"text\"\n          defaultValue={filters.userId ?? \"\"}\n          placeholder=\"user_id\"\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Bonus ID</span>\n        <input\n          name=\"bcFilterBonusId\"\n          type=\"text\"\n          defaultValue={filters.bonusId ?? \"\"}\n          placeholder=\"bonus id\"\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Campaign ID</span>\n        <input\n          name=\"bcFilterCampaignId\"\n          type=\"text\"\n          defaultValue={filters.campaignId ?? \"\"}\n          placeholder=\"campaign id\"\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Period key</span>\n        <input\n          name=\"bcFilterPeriodKey\"\n          type=\"text\"\n          defaultValue={filters.periodKey ?? \"\"}\n          placeholder=\"e.g. 2026-04-26\"\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Completed from</span>\n        <input\n          name=\"bcFilterFrom\"\n          type=\"date\"\n          defaultValue={(filters.completedFrom ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Completed to</span>\n        <input\n          name=\"bcFilterTo\"\n          type=\"date\"\n          defaultValue={(filters.completedTo ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <button type=\"submit\" style={buttonStyle}>\n        Apply filters\n      </button>\n    </form>\n  );\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n  gridTemplateColumns: \"repeat(auto-fit, minmax(180px, 1fr))\",\n  alignItems: \"end\",\n};\n\nconst fieldStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.35rem\",\n  fontSize: \"0.875rem\",\n};\n\nconst inputStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #334155\",\n  background: \"#111827\",\n  color: \"#e2e8f0\",\n  padding: \"0.625rem 0.75rem\",\n};\n\nconst buttonStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #475569\"