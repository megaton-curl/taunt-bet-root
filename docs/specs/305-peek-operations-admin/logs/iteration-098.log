{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GPPET86KPfZE1Uyqff9KaU","type":"tool_result","content":"1\t// Challenge assignments table for /economy/challenges (FR-9).\n2\t//\n3\t// Read-only table over `PeekChallengeAssignmentRow`. Status is rendered as a\n4\t// status chip; progress is rendered with the migration-011 target so an\n5\t// operator can see how far an assignment is from completion. The user cell\n6\t// links to the user-detail page.\n7\timport Link from \"next/link\";\n8\timport type { CSSProperties } from \"react\";\n9\timport type {\n10\t  PeekChallengeAssignmentRow,\n11\t  PeekStatusTone,\n12\t} from \"../lib/types/peek\";\n13\timport { StatusChip } from \"./status-chip\";\n14\t\n15\texport type ChallengeAssignmentsTableProps = {\n16\t  rows: ReadonlyArray<PeekChallengeAssignmentRow>;\n17\t  error?: string | null;\n18\t};\n19\t\n20\texport function ChallengeAssignmentsTable({\n21\t  rows,\n22\t  error = null,\n23\t}: ChallengeAssignmentsTableProps) {\n24\t  if (error) {\n25\t    return (\n26\t      <div role=\"alert\" style={errorStyle}>\n27\t        Challenge assignments unavailable: {error}\n28\t      </div>\n29\t    );\n30\t  }\n31\t\n32\t  if (rows.length === 0) {\n33\t    return (\n34\t      <div role=\"status\" style={emptyStyle}>\n35\t        <p style={emptyTitleStyle}>\n36\t          No challenge_assignments rows match these filters.\n37\t        </p>\n38\t        <p style={emptyBodyStyle}>\n39\t          Adjust the filters above or clear them to see active and recent\n40\t          assignments.\n41\t        </p>\n42\t      </div>\n43\t    );\n44\t  }\n45\t\n46\t  return (\n47\t    <div style={wrapperStyle}>\n48\t      <table style={tableStyle}>\n49\t        <thead>\n50\t          <tr style={headerRowStyle}>\n51\t            <th style={headerCellStyle(\"left\")}>Assigned</th>\n52\t            <th style={headerCellStyle(\"left\")}>User</th>\n53\t            <th style={headerCellStyle(\"left\")}>Challenge</th>\n54\t            <th style={headerCellStyle(\"left\")}>Campaign</th>\n55\t            <th style={headerCellStyle(\"left\")}>Period</th>\n56\t            <th style={headerCellStyle(\"left\")}>Status</th>\n57\t            <th style={headerCellStyle(\"right\")}>Progress</th>\n58\t            <th style={headerCellStyle(\"left\")}>Expires</th>\n59\t            <th style={headerCellStyle(\"left\")}>Completed</th>\n60\t            <th style={headerCellStyle(\"left\")}>ID</th>\n61\t          </tr>\n62\t        </thead>\n63\t        <tbody>\n64\t          {rows.map((row) => (\n65\t            <tr key={row.id} style={bodyRowStyle}>\n66\t              <td style={bodyCellStyle(\"left\")}>{row.assignedAt}</td>\n67\t              <td style={bodyCellStyle(\"left\")}>\n68\t                <Link href={`/users/${row.userId}`} style={linkStyle}>\n69\t                  {row.username ?? row.userId}\n70\t                </Link>\n71\t                {row.username ? (\n72\t                  <span style={subValueStyle}> · {row.userId}</span>\n73\t                ) : null}\n74\t              </td>\n75\t              <td style={bodyCellStyle(\"left\")}>\n76\t                <div>{row.challengeTitle ?? \"—\"}</div>\n77\t                <div style={{ ...subValueStyle, fontFamily: \"monospace\" }}>\n78\t                  {row.challengeId}\n79\t                </div>\n80\t              </td>\n81\t              <td style={bodyCellStyle(\"left\")}>{row.campaignName ?? \"—\"}</td>\n82\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n83\t                {row.periodKey}\n84\t              </td>\n85\t              <td style={bodyCellStyle(\"left\")}>\n86\t                <StatusChip\n87\t                  label={row.status}\n88\t                  tone={assignmentStatusTone(row.status)}\n89\t                />\n90\t              </td>\n91\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n92\t                {row.progress.toLocaleString(\"en-US\")}\n93\t                <span style={subValueStyle}>\n94\t                  {\" \"}\n95\t                  / {row.target.toLocaleString(\"en-US\")}\n96\t                </span>\n97\t              </td>\n98\t              <td style={bodyCellStyle(\"left\")}>{row.expiresAt ?? \"—\"}</td>\n99\t              <td style={bodyCellStyle(\"left\")}>{row.completedAt ?? \"—\"}</td>\n100\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n101\t                {row.id}\n102\t              </td>\n103\t            </tr>\n104\t          ))}\n105\t        </tbody>\n106\t      </table>\n107\t    </div>\n108\t  );\n109\t}\n110\t\n111\tfunction assignmentStatusTone(value: string): PeekStatusTone {\n112\t  if (value === \"active\") return \"info\";\n113\t  if (value === \"completed\") return \"positive\";\n114\t  if (value === \"expired\") return \"warning\";\n115\t  return \"neutral\";\n116\t}\n117\t\n118\tconst wrapperStyle: CSSProperties = {\n119\t  overflowX: \"auto\",\n120\t  border: \"1px solid #1e293b\",\n121\t  borderRadius: \"0.75rem\",\n122\t};\n123\t\n124\tconst tableStyle: CSSProperties = {\n125\t  width: \"100%\",\n126\t  borderCollapse: \"collapse\",\n127\t};\n128\t\n129\tconst headerRowStyle: CSSProperties = {\n130\t  background: \"#111827\",\n131\t  color: \"#94a3b8\",\n132\t};\n133\t\n134\tconst bodyRowStyle: CSSProperties = {\n135\t  borderTop: \"1px solid #1e293b\",\n136\t};\n137\t\n138\tconst linkStyle: CSSProperties = {\n139\t  color: \"#93c5fd\",\n140\t  textDecoration: \"none\",\n141\t};\n142\t\n143\tconst subValueStyle: CSSProperties = {\n144\t  color: \"#64748b\",\n145\t  fontSize: \"0.75rem\",\n146\t};\n147\t\n148\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n149\t  return {\n150\t    padding: \"0.75rem\",\n151\t    textAlign: align,\n152\t    fontSize: \"0.875rem\",\n153\t    fontWeight: 600,\n154\t  };\n155\t}\n156\t\n157\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n158\t  return {\n159\t    padding: \"0.75rem\",\n160\t    textAlign: align,\n161\t    fontSize: \"0.875rem\",\n162\t    color: \"#e2e8f0\",\n163\t    verticalAlign: \"top\",\n164\t  };\n165\t}\n166\t\n167\tconst errorStyle: CSSProperties = {\n168\t  margin: 0,\n169\t  padding: \"0.75rem 1rem\",\n170\t  borderRadius: \"0.75rem\",\n171\t  background: \"#3f1d1d\",\n172\t  color: \"#fecaca\",\n173\t};\n174\t\n175\tconst emptyStyle: CSSProperties = {\n176\t  padding: \"1.5rem\",\n177\t  borderRadius: \"0.75rem\",\n178\t  border: \"1px dashed #334155\",\n179\t  background: \"#0b1220\",\n180\t  color: \"#cbd5f5\",\n181\t  display: \"grid\",\n182\t  gap: \"0.5rem\",\n183\t};\n184\t\n185\tconst emptyTitleStyle: CSSProperties = {\n186\t  margin: 0,\n187\t  fontSize: \"1rem\",\n188\t  fontWeight: 600,\n189\t};\n190\t\n191\tconst emptyBodyStyle: CSSProperties = {\n192\t  margin: 0,\n193\t  fontSize: \"0.875rem\",\n194\t  color: \"#94a3b8\",\n195\t};\n196\t"}]},"parent_tool_use_id":null,"session_id":"2a495ebd-2cda-4eb4-ae9f-5caaba2d57d7","uuid":"4a60ce53-3bcc-49a8-84b0-0b96fefd8249","timestamp":"2026-04-26T06:28:40.821Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/challenge-assignments-table.tsx","content":"// Challenge assignments table for /economy/challenges (FR-9).\n//\n// Read-only table over `PeekChallengeAssignmentRow`. Status is rendered as a\n// status chip; progress is rendered with the migration-011 target so an\n// operator can see how far an assignment is from completion. The user cell\n// links to the user-detail page.\nimport Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekChallengeAssignmentRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type ChallengeAssignmentsTableProps = {\n  rows: ReadonlyArray<PeekChallengeAssignmentRow>;\n  error?: string | null;\n};\n\nexport function ChallengeAssignmentsTable({\n  rows,\n  error = null,\n}: ChallengeAssignmentsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Challenge assignments unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>\n          No challenge_assignments rows match these filters.\n        </p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see active and recent\n          assignments.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Assigned</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Challenge</th>\n            <th style={headerCellStyle(\"left\")}>Campaign</th>\n            <th style={headerCellStyle(\"left\")}>Period</th>\n            <th style={headerCellStyle(\"left\")}>Status</th>\n            <th style={headerCellStyle(\"right\")}>Progress</th>\n            <th style={headerCellStyle(\"left\")}>Expires</th>\n            <th style={headerCellStyle(\"left\")}>Completed</th>\n            <th style={headerCellStyle(\"left\")}>ID</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{row.assignedAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <Link href={`/users/${row.userId}`} style={linkStyle}>\n                  {row.username ?? row.userId}\n                </Link>\n                {row.username ? (\n                  <span style={subValueStyle}> · {row.userId}</span>\n                ) : null}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <div>{row.challengeTitle ?? \"—\"}</div>\n                <div style={{ ...subValueStyle, fontFamily: \"monospace\" }}>\n                  {row.challengeId}\n                </div>\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.campaignName ?? \"—\"}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.periodKey}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.status}\n                  tone={assignmentStatusTone(row.status)}\n                />\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.progress.toLocaleString(\"en-US\")}\n                <span style={subValueStyle}>\n                  {\" \"}\n                  / {row.target.toLocaleString(\"en-US\")}\n                </span>\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.expiresAt ?? \"—\"}</td>\n              <td style={bodyCellStyle(\"left\")}>{row.completedAt ?? \"—\"}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.id}\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction assignmentStatusTone(value: string): PeekStatusTone {\n  if (value === \"active\") return \"info\";\n  if (value === \"completed\") return \"positive\";\n  if (value === \"expired\") return \"warning\";\n  return \"neutral\";\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":196,"startLine":1,"totalLines":196}}}
