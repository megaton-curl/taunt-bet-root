{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Qa8Pc9kcVjmzWAbXaX6vnd","type":"tool_result","content":"960\t};\n961\t\n962\t// --- Points + crates ledger admin (FR-9) -------------------------------------\n963\t//\n964\t// Browser-safe view models for `/economy/points` and `/economy/crates`. Reads\n965\t// three migration-011 tables:\n966\t//\n967\t//   - player_points     — per-user points balance + lifetime earned, listed\n968\t//     across users and joined with `player_profiles` for username context.\n969\t//   - point_grants      — append-only point-grant ledger; the cross-user row\n970\t//     extends the per-user `PeekPointGrantRow` with the user identity columns\n971\t//     the operator-facing list needs.\n972\t//   - crate_drops       — per-user crate ledger with status (`pending`,\n973\t//     `granted`, `failed`); the cross-user row extends `PeekCrateDropRow` with\n974\t//     the same user identity columns.\n975\t//\n976\t// All bigint counters round-trip as `text` to preserve precision (FR-4). The\n977\t// status / type / source-type values are loosely typed (string) so the UI can\n978\t// pass through the same value the migration's CHECK constraints already\n979\t// enforce server-side without a second source of truth here.\n980\t\n981\texport type PeekPlayerPointsRow = {\n982\t  userId: string;\n983\t  username: string | null;\n984\t  wallet: string;\n985\t  balance: string;\n986\t  lifetimeEarned: string;\n987\t  updatedAt: string;\n988\t};\n989\t\n990\texport type PeekPlayerPointsFilters = {\n991\t  userId: string | null;\n992\t  wallet: string | null;\n993\t};\n994\t\n995\texport type PeekPointGrantLedgerRow = PeekPointGrantRow & {\n996\t  userId: string;\n997\t  username: string | null;\n998\t  wallet: string;\n999\t};\n1000\t\n1001\texport type PeekPointGrantFilters = {\n1002\t  userId: string | null;\n1003\t  sourceType: string | null;\n1004\t  sourceId: string | null;\n1005\t  createdFrom: string | null;\n1006\t  createdTo: string | null;\n1007\t};\n1008\t\n1009\t// `wallet` is nullable because `crate_drops` has no wallet column of its own\n1010\t// and the join falls back to `player_profiles.wallet`; an orphaned crate_drop\n1011\t// (extremely rare — there is no FK constraint, but every drop is created\n1012\t// alongside a profile) renders with `wallet: null` rather than a fake \"\".\n1013\texport type PeekCrateDropLedgerRow = PeekCrateDropRow & {\n1014\t  userId: string;\n1015\t  username: string | null;\n1016\t  wallet: string | null;\n1017\t};\n1018\t\n1019\texport type PeekCrateDropFilters = {\n1020\t  userId: string | null;\n1021\t  crateType: string | null;\n1022\t  status: string | null;\n1023\t  triggerType: string | null;\n1024\t  createdFrom: string | null;\n1025\t  createdTo: string | null;"}]},"parent_tool_use_id":null,"session_id":"52947d6e-307c-4766-b691-49307cce9598","uuid":"4dd0005d-6f85-4007-91b2-9bd38ef8b842","timestamp":"2026-04-25T15:08:31.272Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","content":"};\n\n// --- Points + crates ledger admin (FR-9) -------------------------------------\n//\n// Browser-safe view models for `/economy/points` and `/economy/crates`. Reads\n// three migration-011 tables:\n//\n//   - player_points     — per-user points balance + lifetime earned, listed\n//     across users and joined with `player_profiles` for username context.\n//   - point_grants      — append-only point-grant ledger; the cross-user row\n//     extends the per-user `PeekPointGrantRow` with the user identity columns\n//     the operator-facing list needs.\n//   - crate_drops       — per-user crate ledger with status (`pending`,\n//     `granted`, `failed`); the cross-user row extends `PeekCrateDropRow` with\n//     the same user identity columns.\n//\n// All bigint counters round-trip as `text` to preserve precision (FR-4). The\n// status / type / source-type values are loosely typed (string) so the UI can\n// pass through the same value the migration's CHECK constraints already\n// enforce server-side without a second source of truth here.\n\nexport type PeekPlayerPointsRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  balance: string;\n  lifetimeEarned: string;\n  updatedAt: string;\n};\n\nexport type PeekPlayerPointsFilters = {\n  userId: string | null;\n  wallet: string | null;\n};\n\nexport type PeekPointGrantLedgerRow = PeekPointGrantRow & {\n  userId: string;\n  username: string | null;\n  wallet: string;\n};\n\nexport type PeekPointGrantFilters = {\n  userId: string | null;\n  sourceType: string | null;\n  sourceId: string | null;\n  createdFrom: string | null;\n  createdTo: string | null;\n};\n\n// `wallet` is nullable because `crate_drops` has no wallet column of its own\n// and the join falls back to `player_profiles.wallet`; an orphaned crate_drop\n// (extremely rare — there is no FK constraint, but every drop is created\n// alongside a profile) renders with `wallet: null` rather than a fake \"\".\nexport type PeekCrateDropLedgerRow = PeekCrateDropRow & {\n  userId: string;\n  username: string | null;\n  wallet: string | null;\n};\n\nexport type PeekCrateDropFilters = {\n  userId: string | null;\n  crateType: string | null;\n  status: string | null;\n  triggerType: string | null;\n  createdFrom: string | null;\n  createdTo: string | null;","numLines":66,"startLine":960,"totalLines":1027}}}
