{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LPpEjvcP8DG1Ex1aNyEXuK","type":"tool_result","content":"1\t// Server-only admin-shell nav model (FR-3).\n2\t//\n3\t// The full nav (Users, Growth, Games, Economy, Operations, Audit, Access) is\n4\t// declared once here and resolved against the route-prefix policy in\n5\t// `access-policy.ts`. The layout filters the list against the resolved actor\n6\t// role before passing it to the AdminShell so the shell itself stays a pure\n7\t// presentational component.\n8\timport { isRouteAllowedForRole } from \"./access-policy\";\n9\timport type { PeekRole } from \"../lib/access-policy\";\n10\timport type { AdminShellNavItem } from \"../components/admin-shell\";\n11\t\n12\texport const PEEK_ADMIN_SHELL_NAV: ReadonlyArray<AdminShellNavItem> = [\n13\t  { id: \"users\", label: \"Users\", href: \"/users\" },\n14\t  { id: \"growth\", label: \"Growth\", href: \"/growth/referrals\" },\n15\t  { id: \"games\", label: \"Games\", href: \"/games\" },\n16\t  { id: \"economy\", label: \"Economy\", href: \"/economy/rewards\" },\n17\t  { id: \"operations\", label: \"Operations\", href: \"/operations/queue\" },\n18\t  { id: \"audit\", label: \"Audit\", href: \"/audit\" },\n19\t  { id: \"access\", label: \"Access\", href: \"/access\" },\n20\t];\n21\t\n22\texport function getVisibleNavItemsForRole(\n23\t  role: PeekRole | null,\n24\t  items: ReadonlyArray<AdminShellNavItem> = PEEK_ADMIN_SHELL_NAV,\n25\t): ReadonlyArray<AdminShellNavItem> {\n26\t  if (!role) return [];\n27\t  return items.filter((item) => isRouteAllowedForRole(item.href, role));\n28\t}\n29\t"}]},"parent_tool_use_id":null,"session_id":"52947d6e-307c-4766-b691-49307cce9598","uuid":"272fc0ee-41c0-44e7-a343-4f304b9fd13b","timestamp":"2026-04-25T15:09:24.102Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/admin-shell-nav.ts","content":"// Server-only admin-shell nav model (FR-3).\n//\n// The full nav (Users, Growth