{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01W3AcehqKrw6cbSPBFje7KZ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01HPQaCDB4gJoJRaCPgXE3dk","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/player-points-table.tsx","content":"// Cross-user player_points table for /economy/points (FR-9).\n//\n// Read-only dense table over `PeekPlayerPointsRow`. Bigint balances round-trip\n// as text to preserve precision (FR-4). The user cell links to the user-detail\n// page so an operator can drill into the matching profile in one click.\nimport Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type { PeekPlayerPointsRow } from \"../lib/types/peek\";\n\nexport type PlayerPointsTableProps = {\n  rows: ReadonlyArray<PeekPlayerPointsRow>;\n  error?: string | null;\n};\n\nexport function PlayerPointsTable({\n  rows,\n  error = null,\n}: PlayerPointsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Player points unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No player_points rows match these filters.</p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see the top point holders.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"right\")}>Balance</th>\n            <th style={headerCellStyle(\"right\")}>Lifetime earned</th>\n            <th style={headerCellStyle(\"left\")}>Updated</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.userId} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>\n                <Link href={`/users/${row.userId}`} style={linkStyle}>\n                  {row.username ?? row.userId}\n                </Link>\n                {row.username ? (\n                  <span style={subValueStyle}> · {row.userId}</span>\n                ) : null}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.wallet}\n              </td>\n              <td\n                style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}\n                title={row.balance}\n              >\n                {formatCount(row.balance)}\n              </td>\n              <td\n                style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}\n                title={row.lifetimeEarned}\n              >\n                {formatCount(row.lifetimeEarned)}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.updatedAt}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction formatCount(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  if (!/^[0-9]+$/.test(digits)) return value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n  marginLeft: \"0.25rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2330,"cache_read_input_tokens":109491,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2330},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"52947d6e-307c-4766-b691-49307cce9598","uuid":"efffe7b3-64f3-46f1-86c9-29a77f267e56"}
