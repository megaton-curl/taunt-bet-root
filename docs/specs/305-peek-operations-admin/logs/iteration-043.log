{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014FDFUmUsvBcxZ8CXgt6Dft","type":"tool_result","content":"1\t// Reward config table for /economy/rewards (FR-9).\n2\t//\n3\t// Read-only dense table over `PeekRewardConfigRow`. Each row shows the key,\n4\t// value, expected value type chip, an inline definition (or an \"unknown key\"\n5\t// hint for rows whose key has not been registered), and the last-updated\n6\t// timestamp. Editing is out of scope for this iteration (FR-14 / future\n7\t// reward-config mutation work owns that flow).\n8\timport type { CSSProperties } from \"react\";\n9\timport type {\n10\t  PeekRewardConfigExpectedType,\n11\t  PeekRewardConfigRow,\n12\t  PeekStatusTone,\n13\t} from \"../lib/types/peek\";\n14\timport { StatusChip } from \"./status-chip\";\n15\t\n16\texport type RewardConfigTableProps = {\n17\t  rows: ReadonlyArray<PeekRewardConfigRow>;\n18\t  error?: string | null;\n19\t};\n20\t\n21\tconst TYPE_TONE: Record<PeekRewardConfigExpectedType, PeekStatusTone> = {\n22\t  integer: \"info\",\n23\t  float: \"info\",\n24\t  ratio: \"info\",\n25\t  lamports: \"info\",\n26\t  unknown: \"warning\",\n27\t};\n28\t\n29\texport function RewardConfigTable({\n30\t  rows,\n31\t  error = null,\n32\t}: RewardConfigTableProps) {\n33\t  if (error) {\n34\t    return (\n35\t      <div role=\"alert\" style={errorStyle}>\n36\t        Reward config unavailable: {error}\n37\t      </div>\n38\t    );\n39\t  }\n40\t\n41\t  if (rows.length === 0) {\n42\t    return (\n43\t      <div role=\"status\" style={emptyStyle}>\n44\t        <p style={emptyTitleStyle}>No reward_config rows.</p>\n45\t        <p style={emptyBodyStyle}>\n46\t          The `reward_config` table has not been seeded yet, so no economy\n47\t          parameters can be displayed.\n48\t        </p>\n49\t      </div>\n50\t    );\n51\t  }\n52\t\n53\t  return (\n54\t    <div style={wrapperStyle}>\n55\t      <table style={tableStyle}>\n56\t        <thead>\n57\t          <tr style={headerRowStyle}>\n58\t            <th style={headerCellStyle(\"left\")}>Key</th>\n59\t            <th style={headerCellStyle(\"left\")}>Type</th>\n60\t            <th style={headerCellStyle(\"right\")}>Value</th>\n61\t            <th style={headerCellStyle(\"left\")}>Definition</th>\n62\t            <th style={headerCellStyle(\"left\")}>Updated</th>\n63\t          </tr>\n64\t        </thead>\n65\t        <tbody>\n66\t          {rows.map((row) => (\n67\t            <tr key={row.key} style={bodyRowStyle}>\n68\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n69\t                {row.key}\n70\t              </td>\n71\t              <td style={bodyCellStyle(\"left\")}>\n72\t                <StatusChip\n73\t                  label={row.expectedType}\n74\t                  tone={TYPE_TONE[row.expectedType]}\n75\t                />\n76\t              </td>\n77\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n78\t                {row.value}\n79\t              </td>\n80\t              <td style={bodyCellStyle(\"left\")}>\n81\t                {row.definition ?? (\n82\t                  <span style={unknownStyle}>\n83\t                    Unregistered key — extend\n84\t                    PEEK_REWARD_CONFIG_KEY_REGISTRY to document this.\n85\t                  </span>\n86\t                )}\n87\t              </td>\n88\t              <td style={bodyCellStyle(\"left\")}>{row.updatedAt}</td>\n89\t            </tr>\n90\t          ))}\n91\t        </tbody>\n92\t      </table>\n93\t    </div>\n94\t  );\n95\t}\n96\t\n97\tconst wrapperStyle: CSSProperties = {\n98\t  overflowX: \"auto\",\n99\t  border: \"1px solid #1e293b\",\n100\t  borderRadius: \"0.75rem\",\n101\t};\n102\t\n103\tconst tableStyle: CSSProperties = {\n104\t  width: \"100%\",\n105\t  borderCollapse: \"collapse\",\n106\t};\n107\t\n108\tconst headerRowStyle: CSSProperties = {\n109\t  background: \"#111827\",\n110\t  color: \"#94a3b8\",\n111\t};\n112\t\n113\tconst bodyRowStyle: CSSProperties = {\n114\t  borderTop: \"1px solid #1e293b\",\n115\t};\n116\t\n117\tconst unknownStyle: CSSProperties = {\n118\t  color: \"#fde68a\",\n119\t  fontSize: \"0.8125rem\",\n120\t};\n121\t\n122\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n123\t  return {\n124\t    padding: \"0.75rem\",\n125\t    textAlign: align,\n126\t    fontSize: \"0.875rem\",\n127\t    fontWeight: 600,\n128\t  };\n129\t}\n130\t\n131\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n132\t  return {\n133\t    padding: \"0.75rem\",\n134\t    textAlign: align,\n135\t    fontSize: \"0.875rem\",\n136\t    color: \"#e2e8f0\",\n137\t    verticalAlign: \"top\",\n138\t  };\n139\t}\n140\t\n141\tconst errorStyle: CSSProperties = {\n142\t  margin: 0,\n143\t  padding: \"0.75rem 1rem\",\n144\t  borderRadius: \"0.75rem\",\n145\t  background: \"#3f1d1d\",\n146\t  color: \"#fecaca\",\n147\t};\n148\t\n149\tconst emptyStyle: CSSProperties = {\n150\t  padding: \"1.5rem\",\n151\t  borderRadius: \"0.75rem\",\n152\t  border: \"1px dashed #334155\",\n153\t  background: \"#0b1220\",\n154\t  color: \"#cbd5f5\",\n155\t  display: \"grid\",\n156\t  gap: \"0.5rem\",\n157\t};\n158\t\n159\tconst emptyTitleStyle: CSSProperties = {\n160\t  margin: 0,\n161\t  fontSize: \"1rem\",\n162\t  fontWeight: 600,\n163\t};\n164\t\n165\tconst emptyBodyStyle: CSSProperties = {\n166\t  margin: 0,\n167\t  fontSize: \"0.875rem\",\n168\t  color: \"#94a3b8\",\n169\t};\n170\t"}]},"parent_tool_use_id":null,"session_id":"52947d6e-307c-4766-b691-49307cce9598","uuid":"402a9c89-fddb-41b5-ad3a-a4b6f02c058b","timestamp":"2026-04-25T15:09:05.462Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/reward-config-table.tsx","content":"// Reward config table for /economy/rewards (FR-9).\n//\n// Read-only dense table over `PeekRewardConfigRow`. Each row shows the key,\n// value, expected value type chip, an inline definition (or an \"unknown key\"\n// hint for rows whose key has not been registered), and the last-updated\n// timestamp. Editing is out of scope for this iteration (FR-14 / future\n// reward-config mutation work owns that flow).\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekRewardConfigExpectedType,\n  PeekRewardConfigRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type RewardConfigTableProps = {\n  rows: ReadonlyArray<PeekRewardConfigRow>;\n  error?: string | null;\n};\n\nconst TYPE_TONE: Record<PeekRewardConfigExpectedType, PeekStatusTone> = {\n  integer: \"info\",\n  float: \"info\",\n  ratio: \"info\",\n  lamports: \"info\",\n  unknown: \"warning\",\n};\n\nexport function RewardConfigTable({\n  rows,\n  error = null,\n}: RewardConfigTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Reward config unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No reward_config rows.</p>\n        <p style={emptyBodyStyle}>\n          The `reward_config` table has not been seeded yet, so no economy\n          parameters can be displayed.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Key</th>\n            <th style={headerCellStyle(\"left\")}>Type</th>\n            <th style={headerCellStyle(\"right\")}>Value</th>\n            <th style={headerCellStyle(\"left\")}>Definition</th>\n            <th style={headerCellStyle(\"left\")}>Updated</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.key} style={bodyRowStyle}>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.key}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.expectedType}\n                  tone={TYPE_TONE[row.expectedType]}\n                />\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.value}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                {row.definition ?? (\n                  <span style={unknownStyle}>\n                    Unregistered key — extend\n                    PEEK_REWARD_CONFIG_KEY_REGISTRY to document this.\n                  </span>\n                )}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.updatedAt}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst unknownStyle: CSSProperties = {\n  color: \"#fde68a\",\n  fontSize: \"0.8125rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":170,"startLine":1,"totalLines":170}}}
