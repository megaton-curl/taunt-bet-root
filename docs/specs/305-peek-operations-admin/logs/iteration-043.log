{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JAutBQQxMPv39J4exNyfXx","type":"tool_result","content":"1\t// Points + crates economy admin queries (FR-9).\n2\t//\n3\t// Backs the upcoming `/economy/points` and `/economy/crates` pages. Reads three\n4\t// migration-011 tables:\n5\t//\n6\t//   - player_points        — per-user balance + lifetime earned. Listed\n7\t//     across users with optional user_id / wallet filters; joined with\n8\t//     `player_profiles` for the username column.\n9\t//   - point_grants         — append-only grant ledger. Filterable by user_id,\n10\t//     source_type, source_id, and created_at date range. Joined with\n11\t//     `player_profiles` so an operator can scan grants without a second\n12\t//     lookup.\n13\t//   - crate_drops          — per-user crate ledger with `pending` / `granted`\n14\t//     / `failed` status. Filterable by user_id, crate_type, status,\n15\t//     trigger_type, and created_at date range. Joined with `player_profiles`\n16\t//     for username context.\n17\t//\n18\t// All queries are bounded server-side; bigint counters round-trip as `text` to\n19\t// preserve precision (FR-4). Filter values that the migration constrains via\n20\t// CHECK are passed through as opaque strings — the database is the single\n21\t// source of truth for which values are valid; passing an unknown value just\n22\t// returns no rows.\n23\t\n24\timport type { Sql } from \"postgres\";\n25\timport {\n26\t  type PeekCrateDropFilters,\n27\t  type PeekCrateDropLedgerRow,\n28\t  type PeekPlayerPointsFilters,\n29\t  type PeekPlayerPointsRow,\n30\t  type PeekPointGrantFilters,\n31\t  type PeekPointGrantLedgerRow,\n32\t} from \"../../../lib/types/peek\";\n33\timport { getSqlClient } from \"../client\";\n34\t\n35\texport const PEEK_PLAYER_POINTS_DEFAULT_LIMIT = 100;\n36\texport const PEEK_PLAYER_POINTS_MAX_LIMIT = 500;\n37\texport const PEEK_POINT_GRANTS_DEFAULT_LIMIT = 100;\n38\texport const PEEK_POINT_GRANTS_MAX_LIMIT = 500;\n39\texport const PEEK_CRATE_DROPS_DEFAULT_LIMIT = 100;\n40\texport const PEEK_CRATE_DROPS_MAX_LIMIT = 500;\n41\t\n42\texport type ListPlayerPointsOptions = {\n43\t  sql?: Sql;\n44\t  limit?: number;\n45\t  filters?: Partial<PeekPlayerPointsFilters>;\n46\t};\n47\t\n48\texport type ListPointGrantsOptions = {\n49\t  sql?: Sql;\n50\t  limit?: number;\n51\t  filters?: Partial<PeekPointGrantFilters>;\n52\t};\n53\t\n54\texport type ListCrateDropsOptions = {\n55\t  sql?: Sql;\n56\t  limit?: number;\n57\t  filters?: Partial<PeekCrateDropFilters>;\n58\t};\n59\t\n60\tfunction clampLimit(\n61\t  raw: number | undefined,\n62\t  fallback: number,\n63\t  max: number,\n64\t): number {\n65\t  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n66\t  const floored = Math.floor(raw);\n67\t  if (floored <= 0) return 1;\n68\t  return Math.min(max, floored);\n69\t}\n70\t\n71\tfunction trimOrNull(value: string | null | undefined): string | null {\n72\t  if (typeof value !== \"string\") return null;\n73\t  const trimmed = value.trim();\n74\t  return trimmed.length > 0 ? trimmed : null;\n75\t}\n76\t\n77\texport async function listPlayerPoints(\n78\t  options: ListPlayerPointsOptions = {},\n79\t): Promise<ReadonlyArray<PeekPlayerPointsRow>> {\n80\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n81\t  const limit = clampLimit(\n82\t    options.limit,\n83\t    PEEK_PLAYER_POINTS_DEFAULT_LIMIT,\n84\t    PEEK_PLAYER_POINTS_MAX_LIMIT,\n85\t  );\n86\t\n87\t  const filters = options.filters ?? {};\n88\t  const userId = trimOrNull(filters.userId ?? null);\n89\t  const wallet = trimOrNull(filters.wallet ?? null);\n90\t\n91\t  return sql<Array<PeekPlayerPointsRow>>`\n92\t    select\n93\t      pp.user_id as \"userId\",\n94\t      prof.username as \"username\",\n95\t      pp.wallet as \"wallet\",\n96\t      pp.balance::text as \"balance\",\n97\t      pp.lifetime_earned::text as \"lifetimeEarned\",\n98\t      pp.updated_at::text as \"updatedAt\"\n99\t    from player_points pp\n100\t    left join player_profiles prof on prof.user_id = pp.user_id\n101\t    where\n102\t      (${userId === null} or pp.user_id = ${userId ?? \"\"})\n103\t      and (${wallet === null} or pp.wallet = ${wallet ?? \"\"})\n104\t    order by pp.balance desc, pp.user_id asc\n105\t    limit ${limit}\n106\t  `;\n107\t}\n108\t\n109\texport async function listPointGrants(\n110\t  options: ListPointGrantsOptions = {},\n111\t): Promise<ReadonlyArray<PeekPointGrantLedgerRow>> {\n112\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n113\t  const limit = clampLimit(\n114\t    options.limit,\n115\t    PEEK_POINT_GRANTS_DEFAULT_LIMIT,\n116\t    PEEK_POINT_GRANTS_MAX_LIMIT,\n117\t  );\n118\t\n119\t  const filters = options.filters ?? {};\n120\t  const userId = trimOrNull(filters.userId ?? null);\n121\t  const sourceType = trimOrNull(filters.sourceType ?? null);\n122\t  const sourceId = trimOrNull(filters.sourceId ?? null);\n123\t  const createdFrom = trimOrNull(filters.createdFrom ?? null);\n124\t  const createdTo = trimOrNull(filters.createdTo ?? null);\n125\t\n126\t  return sql<Array<PeekPointGrantLedgerRow>>`\n127\t    select\n128\t      pg.id::text as \"id\",\n129\t      pg.user_id as \"userId\",\n130\t      prof.username as \"username\",\n131\t      pg.wallet as \"wallet\",\n132\t      pg.source_type as \"sourceType\",\n133\t      pg.source_id as \"sourceId\",\n134\t      pg.amount::text as \"amount\",\n135\t      pg.created_at::text as \"createdAt\"\n136\t    from point_grants pg\n137\t    left join player_profiles prof on prof.user_id = pg.user_id\n138\t    where\n139\t      (${userId === null} or pg.user_id = ${userId ?? \"\"})\n140\t      and (${sourceType === null} or pg.source_type = ${sourceType ?? \"\"})\n141\t      and (${sourceId === null} or pg.source_id = ${sourceId ?? \"\"})\n142\t      and (${createdFrom === null} or pg.created_at >= ${createdFrom ?? \"\"}::timestamptz)\n143\t      and (${createdTo === null} or pg.created_at < ${createdTo ?? \"\"}::timestamptz)\n144\t    order by pg.created_at desc, pg.id desc\n145\t    limit ${limit}\n146\t  `;\n147\t}\n148\t\n149\texport async function listCrateDrops(\n150\t  options: ListCrateDropsOptions = {},\n151\t): Promise<ReadonlyArray<PeekCrateDropLedgerRow>> {\n152\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n153\t  const limit = clampLimit(\n154\t    options.limit,\n155\t    PEEK_CRATE_DROPS_DEFAULT_LIMIT,\n156\t    PEEK_CRATE_DROPS_MAX_LIMIT,\n157\t  );\n158\t\n159\t  const filters = options.filters ?? {};\n160\t  const userId = trimOrNull(filters.userId ?? null);\n161\t  const crateType = trimOrNull(filters.crateType ?? null);\n162\t  const status = trimOrNull(filters.status ?? null);\n163\t  const triggerType = trimOrNull(filters.triggerType ?? null);\n164\t  const createdFrom = trimOrNull(filters.createdFrom ?? null);\n165\t  const createdTo = trimOrNull(filters.createdTo ?? null);\n166\t\n167\t  return sql<Array<PeekCrateDropLedgerRow>>`\n168\t    select\n169\t      cd.id::text as \"id\",\n170\t      cd.user_id as \"userId\",\n171\t      prof.username as \"username\",\n172\t      prof.wallet as \"wallet\",\n173\t      cd.trigger_type as \"triggerType\",\n174\t      cd.trigger_id as \"triggerId\",\n175\t      cd.crate_type as \"crateType\",\n176\t      cd.contents_amount as \"contentsAmount\",\n177\t      cd.status as \"status\",\n178\t      cd.created_at::text as \"createdAt\",\n179\t      cd.granted_at::text as \"grantedAt\"\n180\t    from crate_drops cd\n181\t    left join player_profiles prof on prof.user_id = cd.user_id\n182\t    where\n183\t      (${userId === null} or cd.user_id = ${userId ?? \"\"})\n184\t      and (${crateType === null} or cd.crate_type = ${crateType ?? \"\"})\n185\t      and (${status === null} or cd.status = ${status ?? \"\"})\n186\t      and (${triggerType === null} or cd.trigger_type = ${triggerType ?? \"\"})\n187\t      and (${createdFrom === null} or cd.created_at >= ${createdFrom ?? \"\"}::timestamptz)\n188\t      and (${createdTo === null} or cd.created_at < ${createdTo ?? \"\"}::timestamptz)\n189\t    order by cd.created_at desc, cd.id desc\n190\t    limit ${limit}\n191\t  `;\n192\t}\n193\t"}]},"parent_tool_use_id":null,"session_id":"52947d6e-307c-4766-b691-49307cce9598","uuid":"02c4abe2-4626-4edd-9da1-7c70f34b82f3","timestamp":"2026-04-25T15:07:55.567Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-points-and-crates.ts","content":"// Points + crates economy admin queries (FR-9).\n//\n// Backs the upcoming `/economy/points` and `/economy/crates` pages. Reads three\n// migration-011 tables:\n//\n//   - player_points        — per-user balance + lifetime earned. Listed\n//     across users with optional user_id / wallet filters; joined with\n//     `player_profiles` for the username column.\n//   - point_grants         — append-only grant ledger. Filterable by user_id,\n//     source_type, source_id, and created_at date range. Joined with\n//     `player_profiles` so an operator can scan grants without a second\n//     lookup.\n//   - crate_drops          — per-user crate ledger with `pending` / `granted`\n//     / `failed` status. Filterable by user_id, crate_type, status,\n//     trigger_type, and created_at date range. Joined with `player_profiles`\n//     for username context.\n//\n// All queries are bounded server-side; bigint counters round-trip as `text` to\n// preserve precision (FR-4). Filter values that the migration constrains via\n// CHECK are passed through as opaque strings — the database is the single\n// source of truth for which values are valid; passing an unknown value just\n// returns no rows.\n\nimport type { Sql } from \"postgres\";\nimport {\n  type PeekCrateDropFilters,\n  type PeekCrateDropLedgerRow,\n  type PeekPlayerPointsFilters,\n  type PeekPlayerPointsRow,\n  type PeekPointGrantFilters,\n  type PeekPointGrantLedgerRow,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_PLAYER_POINTS_DEFAULT_LIMIT = 100;\nexport const PEEK_PLAYER_POINTS_MAX_LIMIT = 500;\nexport const PEEK_POINT_GRANTS_DEFAULT_LIMIT = 100;\nexport const PEEK_POINT_GRANTS_MAX_LIMIT = 500;\nexport const PEEK_CRATE_DROPS_DEFAULT_LIMIT = 100;\nexport const PEEK_CRATE_DROPS_MAX_LIMIT = 500;\n\nexport type ListPlayerPointsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekPlayerPointsFilters>;\n};\n\nexport type ListPointGrantsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekPointGrantFilters>;\n};\n\nexport type ListCrateDropsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekCrateDropFilters>;\n};\n\nfunction clampLimit(\n  raw: number | undefined,\n  fallback: number,\n  max: number,\n): number {\n  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n  const floored = Math.floor(raw);\n  if (floored <= 0) return 1;\n  return Math.min(max, floored);\n}\n\nfunction trimOrNull(value: string | null | undefined): string | null {\n  if (typeof value !== \"string\") return null;\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nexport async function listPlayerPoints(\n  options: ListPlayerPointsOptions = {},\n): Promise<ReadonlyArray<PeekPlayerPointsRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_PLAYER_POINTS_DEFAULT_LIMIT,\n    PEEK_PLAYER_POINTS_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const userId = trimOrNull(filters.userId ?? null);\n  const wallet = trimOrNull(filters.wallet ?? null);\n\n  return sql<Array<PeekPlayerPointsRow>>`\n    select\n      pp.user_id as \"userId\",\n      prof.username as \"username\",\n      pp.wallet as \"wallet\",\n      pp.balance::text as \"balance\",\n      pp.lifetime_earned::text as \"lifetimeEarned\",\n      pp.updated_at::text as \"updatedAt\"\n    from player_points pp\n    left join player_profiles prof on prof.user_id = pp.user_id\n    where\n      (${userId === null} or pp.user_id = ${userId ?? \"\"})\n      and (${wallet === null} or pp.wallet = ${wallet ?? \"\"})\n    order by pp.balance desc, pp.user_id asc\n    limit ${limit}\n  `;\n}\n\nexport async function listPointGrants(\n  options: ListPointGrantsOptions = {},\n): Promise<ReadonlyArray<PeekPointGrantLedgerRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_POINT_GRANTS_DEFAULT_LIMIT,\n    PEEK_POINT_GRANTS_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const userId = trimOrNull(filters.userId ?? null);\n  const sourceType = trimOrNull(filters.sourceType ?? null);\n  const sourceId = trimOrNull(filters.sourceId ?? null);\n  const createdFrom = trimOrNull(filters.createdFrom ?? null);\n  const createdTo = trimOrNull(filters.createdTo ?? null);\n\n  return sql<Array<PeekPointGrantLedgerRow>>`\n    select\n      pg.id::text as \"id\",\n      pg.user_id as \"userId\",\n      prof.username as \"username\",\n      pg.wallet as \"wallet\",\n      pg.source_type as \"sourceType\",\n      pg.source_id as \"sourceId\",\n      pg.amount::text as \"amount\",\n      pg.created_at::text as \"createdAt\"\n    from point_grants pg\n    left join player_profiles prof on prof.user_id = pg.user_id\n    where\n      (${userId === null} or pg.user_id = ${userId ?? \"\"})\n      and (${sourceType === null} or pg.source_type = ${sourceType ?? \"\"})\n      and (${sourceId === null} or pg.source_id = ${sourceId ?? \"\"})\n      and (${createdFrom === null} or pg.created_at >= ${createdFrom ?? \"\"}::timestamptz)\n      and (${createdTo === null} or pg.created_at < ${createdTo ?? \"\"}::timestamptz)\n    order by pg.created_at desc, pg.id desc\n    limit ${limit}\n  `;\n}\n\nexport async function listCrateDrops(\n  options: ListCrateDropsOptions = {},\n): Promise<ReadonlyArray<PeekCrateDropLedgerRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_CRATE_DROPS_DEFAULT_LIMIT,\n    PEEK_CRATE_DROPS_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const userId = trimOrNull(filters.userId ?? null);\n  const crateType = trimOrNull(filters.crateType ?? null);\n  const status = trimOrNull(filters.status ?? null);\n  const triggerType = trimOrNull(filters.triggerType ?? null);\n  const createdFrom = trimOrNull(filters.createdFrom ?? null);\n  const createdTo = trimOrNull(filters.createdTo ?? null);\n\n  return sql<Array<PeekCrateDropLedgerRow>>`\n    select\n      cd.id::text as \"id\",\n      cd.user_id as \"userId\",\n      prof.username as \"username\",\n      prof.wallet as \"wallet\",\n      cd.trigger_type as \"triggerType\",\n      cd.trigger_id as \"triggerId\",\n      cd.crate_type as \"crateType\",\n      cd.contents_amount as \"contentsAmount\",\n      cd.status as \"status\",\n      cd.created_at::text as \"createdAt\",\n      cd.granted_at::text as \"grantedAt\"\n    from crate_drops cd\n    left join player_profiles prof on prof.user_id = cd.user_id\n    where\n      (${userId === null} or cd.user_id = ${userId ?? \"\"})\n      and (${crateType === null} or cd.crate_type = ${crateType ?? \"\"})\n      and (${status === null} or cd.status = ${status ?? \"\"})\n      and (${triggerType === null} or cd.trigger_type = ${triggerType ?? \"\"})\n      and (${createdFrom === null} or cd.created_at >= ${createdFrom ?? \"\"}::timestamptz)\n      and (${createdTo === null} or cd.created_at < ${createdTo ?? \"\"}::timestamptz)\n    order by cd.created_at desc, cd.id desc\n    limit ${limit}\n  `;\n}\n","numLines":193,"startLine":1,"totalLines":193}}}
