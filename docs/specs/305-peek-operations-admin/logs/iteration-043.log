{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NCx6eKGTZ944PF6sRhJCef","type":"tool_result","content":"1\t// URL-addressable claim filter bar for /growth/referrals (FR-7, FR-4).\n2\t//\n3\t// Submits to the same page (`/growth/referrals`) so the claim filters are\n4\t// shareable. Status is a select (pending/processing/error/completed/failed)\n5\t// matching the migration check constraint; \"failed\" is the virtual alias the\n6\t// engine widens to ('failed','error').\n7\timport type { CSSProperties } from \"react\";\n8\timport type { PeekReferralClaimFilters } from \"../lib/types/peek\";\n9\timport { PEEK_REFERRAL_CLAIM_STATUSES } from \"../lib/growth-search-params\";\n10\t\n11\texport type GrowthClaimsFilterBarProps = {\n12\t  filters: PeekReferralClaimFilters;\n13\t  action?: string;\n14\t};\n15\t\n16\texport function GrowthClaimsFilterBar({\n17\t  filters,\n18\t  action = \"/growth/referrals\",\n19\t}: GrowthClaimsFilterBarProps) {\n20\t  return (\n21\t    <form\n22\t      action={action}\n23\t      method=\"get\"\n24\t      role=\"search\"\n25\t      aria-label=\"Filter referral claims\"\n26\t      style={formStyle}\n27\t    >\n28\t      <label style={fieldStyle}>\n29\t        <span>Status</span>\n30\t        <select\n31\t          name=\"claimStatus\"\n32\t          defaultValue={filters.status ?? \"\"}\n33\t          style={inputStyle}\n34\t        >\n35\t          <option value=\"\">Any</option>\n36\t          {PEEK_REFERRAL_CLAIM_STATUSES.map((status) => (\n37\t            <option key={status} value={status}>\n38\t              {status}\n39\t            </option>\n40\t          ))}\n41\t        </select>\n42\t      </label>\n43\t\n44\t      <label style={fieldStyle}>\n45\t        <span>User ID</span>\n46\t        <input\n47\t          name=\"claimUserId\"\n48\t          type=\"text\"\n49\t          defaultValue={filters.userId ?? \"\"}\n50\t          placeholder=\"user_id\"\n51\t          style={inputStyle}\n52\t        />\n53\t      </label>\n54\t\n55\t      <label style={fieldStyle}>\n56\t        <span>Min amount (lamports)</span>\n57\t        <input\n58\t          name=\"claimMinAmount\"\n59\t          type=\"text\"\n60\t          inputMode=\"numeric\"\n61\t          defaultValue={filters.minAmountLamports ?? \"\"}\n62\t          style={inputStyle}\n63\t        />\n64\t      </label>\n65\t\n66\t      <label style={fieldStyle}>\n67\t        <span>Max amount (lamports)</span>\n68\t        <input\n69\t          name=\"claimMaxAmount\"\n70\t          type=\"text\"\n71\t          inputMode=\"numeric\"\n72\t          defaultValue={filters.maxAmountLamports ?? \"\"}\n73\t          style={inputStyle}\n74\t        />\n75\t      </label>\n76\t\n77\t      <label style={fieldStyle}>\n78\t        <span>Requested from</span>\n79\t        <input\n80\t          name=\"claimRequestedFrom\"\n81\t          type=\"date\"\n82\t          defaultValue={(filters.requestedFrom ?? \"\").slice(0, 10)}\n83\t          style={inputStyle}\n84\t        />\n85\t      </label>\n86\t\n87\t      <label style={fieldStyle}>\n88\t        <span>Requested to</span>\n89\t        <input\n90\t          name=\"claimRequestedTo\"\n91\t          type=\"date\"\n92\t          defaultValue={(filters.requestedTo ?? \"\").slice(0, 10)}\n93\t          style={inputStyle}\n94\t        />\n95\t      </label>\n96\t\n97\t      <label style={fieldStyle}>\n98\t        <span>Tx signature</span>\n99\t        <input\n100\t          name=\"claimTxSignature\"\n101\t          type=\"text\"\n102\t          defaultValue={filters.txSignature ?? \"\"}\n103\t          placeholder=\"exact match\"\n104\t          style={inputStyle}\n105\t        />\n106\t      </label>\n107\t\n108\t      <label style={fieldStyle}>\n109\t        <span>Error contains</span>\n110\t        <input\n111\t          name=\"claimError\"\n112\t          type=\"text\"\n113\t          defaultValue={filters.errorContains ?? \"\"}\n114\t          placeholder=\"ILIKE %text%\"\n115\t          style={inputStyle}\n116\t        />\n117\t      </label>\n118\t\n119\t      <button type=\"submit\" style={buttonStyle}>\n120\t        Apply filters\n121\t      </button>\n122\t    </form>\n123\t  );\n124\t}\n125\t\n126\tconst formStyle: CSSProperties = {\n127\t  display: \"grid\",\n128\t  gap: \"0.75rem\",\n129\t  gridTemplateColumns: \"repeat(auto-fit, minmax(180px, 1fr))\",\n130\t  alignItems: \"end\",\n131\t};\n132\t\n133\tconst fieldStyle: CSSProperties = {\n134\t  display: \"grid\",\n135\t  gap: \"0.35rem\",\n136\t  fontSize: \"0.875rem\",\n137\t};\n138\t\n139\tconst inputStyle: CSSProperties = {\n140\t  borderRadius: \"0.5rem\",\n141\t  border: \"1px solid #334155\",\n142\t  background: \"#111827\",\n143\t  color: \"#e2e8f0\",\n144\t  padding: \"0.625rem 0.75rem\",\n145\t};\n146\t\n147\tconst buttonStyle: CSSProperties = {\n148\t  borderRadius: \"0.5rem\",\n149\t  border: \"1px solid #475569\",\n150\t  background: \"#1d4ed8\",\n151\t  color: \"#eff6ff\",\n152\t  padding: \"0.75rem 1rem\",\n153\t  fontWeight: 600,\n154\t};\n155\t"}]},"parent_tool_use_id":null,"session_id":"52947d6e-307c-4766-b691-49307cce9598","uuid":"40bc35eb-f33d-4407-8e40-fed104e963c3","timestamp":"2026-04-25T15:08:09.708Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/growth-claims-filter-bar.tsx","content":"// URL-addressable claim filter bar for /growth/referrals (FR-7, FR-4).\n//\n// Submits to the same page (`/growth/referrals`) so the claim filters are\n// shareable. Status is a select (pending/processing/error/completed/failed)\n// matching the migration check constraint; \"failed\" is the virtual alias the\n// engine widens to ('failed','error').\nimport type { CSSProperties } from \"react\";\nimport type { PeekReferralClaimFilters } from \"../lib/types/peek\";\nimport { PEEK_REFERRAL_CLAIM_STATUSES } from \"../lib/growth-search-params\";\n\nexport type GrowthClaimsFilterBarProps = {\n  filters: PeekReferralClaimFilters;\n  action?: string;\n};\n\nexport function GrowthClaimsFilterBar({\n  filters,\n  action = \"/growth/referrals\",\n}: GrowthClaimsFilterBarProps) {\n  return (\n    <form\n      action={action}\n      method=\"get\"\n      role=\"search\"\n      aria-label=\"Filter referral claims\"\n      style={formStyle}\n    >\n      <label style={fieldStyle}>\n        <span>Status</span>\n        <select\n          name=\"claimStatus\"\n          defaultValue={filters.status ?? \"\"}\n          style={inputStyle}\n        >\n          <option value=\"\">Any</option>\n          {PEEK_REFERRAL_CLAIM_STATUSES.map((status) => (\n            <option key={status} value={status}>\n              {status}\n            </option>\n          ))}\n        </select>\n      </label>\n\n      <label style={fieldStyle}>\n        <span>User ID</span>\n        <input\n          name=\"claimUserId\"\n          type=\"text\"\n          defaultValue={filters.userId ?? \"\"}\n          placeholder=\"user_id\"\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Min amount (lamports)</span>\n        <input\n          name=\"claimMinAmount\"\n          type=\"text\"\n          inputMode=\"numeric\"\n          defaultValue={filters.minAmountLamports ?? \"\"}\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Max amount (lamports)</span>\n        <input\n          name=\"claimMaxAmount\"\n          type=\"text\"\n          inputMode=\"numeric\"\n          defaultValue={filters.maxAmountLamports ?? \"\"}\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Requested from</span>\n        <input\n          name=\"claimRequestedFrom\"\n          type=\"date\"\n          defaultValue={(filters.requestedFrom ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Requested to</span>\n        <input\n          name=\"claimRequestedTo\"\n          type=\"date\"\n          defaultValue={(filters.requestedTo ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Tx signature</span>\n        <input\n          name=\"claimTxSignature\"\n          type=\"text\"\n          defaultValue={filters.txSignature ?? \"\"}\n          placeholder=\"exact match\"\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Error contains</span>\n        <input\n          name=\"claimError\"\n          type=\"text\"\n          defaultValue={filters.errorContains ?? \"\"}\n          placeholder=\"ILIKE %text%\"\n          style={inputStyle}\n        />\n      </label>\n\n      <button type=\"submit\" style={buttonStyle}>\n        Apply filters\n      </button>\n    </form>\n  );\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n  gridTemplateColumns: \"repeat(auto-fit, minmax(180px, 1fr))\",\n  alignItems: \"end\",\n};\n\nconst fieldStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.35rem\",\n  fontSize: \"0.875rem\",\n};\n\nconst inputStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #334155\",\n  background: \"#111827\",\n  color: \"#e2e8f0\",\n  padding: \"0.625rem 0.75rem\",\n};\n\nconst buttonStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #475569\",\n  background: \"#1d4ed8\",\n  color: \"#eff6ff\",\n  padding: \"0.75rem 1rem\",\n  fontWeight: 600,\n};\n","numLines":155,"startLine":1,"totalLines":155}}}
