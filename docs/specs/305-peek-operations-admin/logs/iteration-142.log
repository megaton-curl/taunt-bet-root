{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JauzCv7xRDkXRYXo5qdbtc","type":"tool_result","content":"1\t// Server-side export runner (FR-12).\n2\t//\n3\t// Orchestrates a single CSV export end to end:\n4\t//   1. Look up the approved exporter for the requested entity.\n5\t//   2. Refuse \"no filter\" exports when the exporter requires at least one\n6\t//      filter (avoids unfiltered full-table dumps per FR-12).\n7\t//   3. Refuse the export in production when audit logging is not configured\n8\t//      (\"Exports are disabled in production if audit logging is not\n9\t//      configured.\" — FR-12 last bullet).\n10\t//   4. Compute an effective row cap bounded by the per-entity ceiling\n11\t//      (`maxRowsPerExport`) and the global default (`PEEK_EXPORT_ROW_CAP_DEFAULT`).\n12\t//   5. Invoke the exporter's `fetch` to build the view-model rows.\n13\t//   6. Emit a `peek.export` audit event BEFORE returning the rows. If audit\n14\t//      emission fails, refuse to return the rows so we never serve data we\n15\t//      could not record.\n16\t//\n17\t// The runner is dependency-injectable for tests: callers can pass a mock\n18\t// `Sql`, a custom registry, a custom audit emitter, and a custom env.\n19\t\n20\timport type { Sql } from \"postgres\";\n21\timport {\n22\t  PEEK_EXPORT_ROW_CAP_DEFAULT,\n23\t  type PeekExportEntity,\n24\t  type PeekExportResult,\n25\t} from \"../../lib/types/peek\";\n26\timport {\n27\t  writePeekAuditEvent,\n28\t  type PeekAuditWriteResult,\n29\t} from \"../audit/writer\";\n30\timport { getSqlClient } from \"../db/client\";\n31\timport { buildPeekExportFilename } from \"./filename\";\n32\timport {\n33\t  getPeekExporter,\n34\t  PEEK_EXPORTERS,\n35\t  type PeekExporterDefinition,\n36\t  type PeekExporterFilters,\n37\t  type PeekExporterRegistry,\n38\t} from \"./registry\";\n39\t\n40\texport type PeekExportFailureReason =\n41\t  | \"unknown_entity\"\n42\t  | \"no_filters\"\n43\t  | \"audit_unavailable\"\n44\t  | \"audit_emit_failed\";\n45\t\n46\texport type PeekExportRunResult =\n47\t  | { ok: true; result: PeekExportResult }\n48\t  | { ok: false; reason: PeekExportFailureReason; message: string };\n49\t\n50\texport type PeekExportActorContext = {\n51\t  email: string;\n52\t  route: string | null;\n53\t  requestId?: string | null;\n54\t};\n55\t\n56\texport type PeekExportAuditWriter = (\n57\t  input: Parameters<typeof writePeekAuditEvent>[0],\n58\t  options?: Parameters<typeof writePeekAuditEvent>[1],\n59\t) => Promise<PeekAuditWriteResult>;\n60\t\n61\texport type PeekExportRunInput = {\n62\t  entity: PeekExportEntity;\n63\t  filters?: PeekExporterFilters;\n64\t  rowCap?: number;\n65\t  actor: PeekExportActorContext;\n66\t  now?: Date;\n67\t  sql?: Sql;\n68\t  registry?: PeekExporterRegistry;\n69\t  auditWriter?: PeekExportAuditWriter;\n70\t  env?: NodeJS.ProcessEnv;\n71\t};\n72\t\n73\t// Production gate: exports refuse to run when audit logging cannot be\n74\t// configured. The audit writer reads `DATABASE_URL` via `getSqlClient` so the\n75\t// \"configured\" signal is the same env var that would let the writer connect.\n76\texport function isPeekAuditConfigured(\n77\t  env: NodeJS.ProcessEnv = process.env,\n78\t): boolean {\n79\t  const url = env.DATABASE_URL;\n80\t  return typeof url === \"string\" && url.length > 0;\n81\t}\n82\t\n83\tfunction isProduction(env: NodeJS.ProcessEnv): boolean {\n84\t  return env.NODE_ENV === \"production\";\n85\t}\n86\t\n87\tfunction hasAnyFilter(filters: PeekExporterFilters): boolean {\n88\t  for (const value of Object.values(filters)) {\n89\t    if (value !== null && value !== undefined && value !== \"\") return true;\n90\t  }\n91\t  return false;\n92\t}\n93\t\n94\tfunction clampRowCap(\n95\t  raw: number | undefined,\n96\t  perEntityMax: number,\n97\t): number {\n98\t  const ceiling = Math.max(1, Math.min(perEntityMax, PEEK_EXPORT_ROW_CAP_DEFAULT));\n99\t  if (typeof raw !== \"number\" || !Number.isFinite(raw) || raw <= 0) {\n100\t    return ceiling;"}]},"parent_tool_use_id":null,"session_id":"d007807c-1f68-4e76-afc1-d4448d7bbf7d","uuid":"d6728e08-b3a3-46d4-b241-8434871cc7c8","timestamp":"2026-04-26T15:01:10.355Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/exports/runner.ts","content":"// Server-side export runner (FR-12).\n//\n// Orchestrates a single CSV export end to end:\n//   1. Look up the approved exporter for the requested entity.\n//   2. Refuse \"no filter\" exports when the exporter requires at least one\n//      filter (avoids unfiltered full-table dumps per FR-12).\n//   3. Refuse the export in production when audit logging is not configured\n//      (\"Exports are disabled in production if audit logging is not\n//      configured.\" — FR-12 last bullet).\n//   4. Compute an effective row cap bounded by the per-entity ceiling\n//      (`maxRowsPerExport`) and the global default (`PEEK_EXPORT_ROW_CAP_DEFAULT`).\n//   5. Invoke the exporter's `fetch` to build the view-model rows.\n//   6. Emit a `peek.export` audit event BEFORE returning the rows. If audit\n//      emission fails, refuse to return the rows so we never serve data we\n//      could not record.\n//\n// The runner is dependency-injectable for tests: callers can pass a mock\n// `Sql`, a custom registry, a custom audit emitter, and a custom env.\n\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_EXPORT_ROW_CAP_DEFAULT,\n  type PeekExportEntity,\n  type PeekExportResult,\n} from \"../../lib/types/peek\";\nimport {\n  writePeekAuditEvent,\n  type PeekAuditWriteResult,\n} from \"../audit/writer\";\nimport { getSqlClient } from \"../db/client\";\nimport { buildPeekExportFilename } from \"./filename\";\nimport {\n  getPeekExporter,\n  PEEK_EXPORTERS,\n  type PeekExporterDefinition,\n  type PeekExporterFilters,\n  type PeekExporterRegistry,\n} from \"./registry\";\n\nexport type PeekExportFailureReason =\n  | \"unknown_entity\"\n  | \"no_filters\"\n  | \"audit_unavailable\"\n  | \"audit_emit_failed\";\n\nexport type PeekExportRunResult =\n  | { ok: true; result: PeekExportResult }\n  | { ok: false; reason: PeekExportFailureReason; message: string };\n\nexport type PeekExportActorContext = {\n  email: string;\n  route: string | null;\n  requestId?: string | null;\n};\n\nexport type PeekExportAuditWriter = (\n  input: Parameters<typeof writePeekAuditEvent>[0],\n  options?: Parameters<typeof writePeekAuditEvent>[1],\n) => Promise<PeekAuditWriteResult>;\n\nexport type PeekExportRunInput = {\n  entity: PeekExportEntity;\n  filters?: PeekExporterFilters;\n  rowCap?: number;\n  actor: PeekExportActorContext;\n  now?: Date;\n  sql?: Sql;\n  registry?: PeekExporterRegistry;\n  auditWriter?: PeekExportAuditWriter;\n  env?: NodeJS.ProcessEnv;\n};\n\n// Production gate: exports refuse to run when audit logging cannot be\n// configured. The audit writer reads `DATABASE_URL` via `getSqlClient` so the\n// \"configured\" signal is the same env var that would let the writer connect.\nexport function isPeekAuditConfigured(\n  env: NodeJS.ProcessEnv = process.env,\n): boolean {\n  const url = env.DATABASE_URL;\n  return typeof url === \"string\" && url.length > 0;\n}\n\nfunction isProduction(env: NodeJS.ProcessEnv): boolean {\n  return env.NODE_ENV === \"production\";\n}\n\nfunction hasAnyFilter(filters: PeekExporterFilters): boolean {\n  for (const value of Object.values(filters)) {\n    if (value !== null && value !== undefined && value !== \"\") return true;\n  }\n  return false;\n}\n\nfunction clampRowCap(\n  raw: number | undefined,\n  perEntityMax: number,\n): number {\n  const ceiling = Math.max(1, Math.min(perEntityMax, PEEK_EXPORT_ROW_CAP_DEFAULT));\n  if (typeof raw !== \"number\" || !Number.isFinite(raw) || raw <= 0) {\n    return ceiling;","numLines":100,"startLine":1,"totalLines":218}}}
