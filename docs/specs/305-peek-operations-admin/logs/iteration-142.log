{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UMxqZFJp2R6ApmRyyTeCuV","type":"tool_result","content":"1\t// Server-side export filename helpers (FR-12).\n2\t//\n3\t// FR-12 requires export filenames to include the entity, the export date, and\n4\t// a filter slug. The slug is built from the same filter values that bounded\n5\t// the SQL query so the filename is deterministic for a given filter set, can\n6\t// be re-derived during audit review, and cannot leak path-traversal segments\n7\t// or whitespace into the response `Content-Disposition` header.\n8\t\n9\timport type { PeekExportFilenameInput } from \"../../lib/types/peek\";\n10\t\n11\tconst FILENAME_UNSAFE = /[^a-z0-9_-]+/g;\n12\tconst FILENAME_REPEATED_DASH = /-+/g;\n13\tconst FILENAME_TRIM_DASH = /^-+|-+$/g;\n14\t\n15\t// Lowercase + ASCII; replace anything outside `[a-z0-9_-]` with `-`; collapse\n16\t// repeated dashes; trim leading/trailing dashes. Never returns a string that\n17\t// could be misinterpreted as a path segment, hidden file, or shell argument.\n18\texport function slugForFilename(value: string): string {\n19\t  if (!value) return \"\";\n20\t  return value\n21\t    .toLowerCase()\n22\t    .replace(FILENAME_UNSAFE, \"-\")\n23\t    .replace(FILENAME_REPEATED_DASH, \"-\")\n24\t    .replace(FILENAME_TRIM_DASH, \"\");\n25\t}\n26\t\n27\t// `peek-{entity}-{YYYY-MM-DD}-{filterSlug?}.csv` — entity, date, and filter\n28\t// slug are slugified independently so a missing filter slug omits the trailing\n29\t// segment cleanly. Always returns a non-empty `peek-...csv` value.\n30\texport function buildPeekExportFilename(input: PeekExportFilenameInput): string {\n31\t  const entity = slugForFilename(input.entity);\n32\t  const date = slugForFilename(input.date);\n33\t  const filter = slugForFilename(input.filterSlug);\n34\t  const segments = [\"peek\", entity || \"export\", date || \"undated\"];\n35\t  if (filter) segments.push(filter);\n36\t  return `${segments.join(\"-\")}.csv`;\n37\t}\n38\t"}]},"parent_tool_use_id":null,"session_id":"d007807c-1f68-4e76-afc1-d4448d7bbf7d","uuid":"b081e6e0-e28b-409b-89f1-8aa347f5599a","timestamp":"2026-04-26T14:59:01.759Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/exports/filename.ts","content":"// Server-side export filename helpers (FR-12).\n//\n// FR-12 requires export filenames to include the entity, the export date, and\n// a filter slug. The slug is built from the same filter values that bounded\n// the SQL query so the filename is deterministic for a given filter set, can\n// be re-derived during audit review, and cannot leak path-traversal segments\n// or whitespace into the response `Content-Disposition` header.\n\nimport type { PeekExportFilenameInput } from \"../../lib/types/peek\";\n\nconst FILENAME_UNSAFE = /[^a-z0-9_-]+/g;\nconst FILENAME_REPEATED_DASH = /-+/g;\nconst FILENAME_TRIM_DASH = /^-+|-+$/g;\n\n// Lowercase + ASCII; replace anything outside `[a-z0-9_-]` with `-`; collapse\n// repeated dashes; trim leading/trailing dashes. Never returns a string that\n// could be misinterpreted as a path segment, hidden file, or shell argument.\nexport function slugForFilename(value: string): string {\n  if (!value) return \"\";\n  return value\n    .toLowerCase()\n    .replace(FILENAME_UNSAFE, \"-\")\n    .replace(FILENAME_REPEATED_DASH, \"-\")\n    .replace(FILENAME_TRIM_DASH, \"\");\n}\n\n// `peek-{entity}-{YYYY-MM-DD}-{filterSlug?}.csv` — entity, date, and filter\n// slug are slugified independently so a missing filter slug omits the trailing\n// segment cleanly. Always returns a non-empty `peek-...csv` value.\nexport function buildPeekExportFilename(input: PeekExportFilenameInput): string {\n  const entity = slugForFilename(input.entity);\n  const date = slugForFilename(input.date);\n  const filter = slugForFilename(input.filterSlug);\n  const segments = [\"peek\", entity || \"export\", date || \"undated\"];\n  if (filter) segments.push(filter);\n  return `${segments.join(\"-\")}.csv`;\n}\n","numLines":38,"startLine":1,"totalLines":38}}}
