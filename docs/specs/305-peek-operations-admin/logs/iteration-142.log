{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_014uRdbYFzfF4ZPS4jgrNBzK","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Sr4NrS4jonbsMpenUv3Q99","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/peek/src/server/exports/__tests__/runner.test.ts","old_string":"describe(\"isPeekAuditConfigured\", () => {\n  it(\"is true when DATABASE_URL is a non-empty string\", () => {\n    expect(\n      isPeekAuditConfigured({ DATABASE_URL: \"postgres://x\" } as NodeJS.ProcessEnv),\n    ).toBe(true);\n  });\n\n  it(\"is false when DATABASE_URL is missing or empty\", () => {\n    expect(isPeekAuditConfigured({} as NodeJS.ProcessEnv)).toBe(false);\n    expect(\n      isPeekAuditConfigured({ DATABASE_URL: \"\" } as NodeJS.ProcessEnv),\n    ).toBe(false);\n  });\n});","new_string":"describe(\"isPeekAuditConfigured\", () => {\n  it(\"is true when DATABASE_URL is a non-empty string\", () => {\n    expect(\n      isPeekAuditConfigured({\n        NODE_ENV: \"test\",\n        DATABASE_URL: \"postgres://x\",\n      } as NodeJS.ProcessEnv),\n    ).toBe(true);\n  });\n\n  it(\"is false when DATABASE_URL is missing or empty\", () => {\n    expect(\n      isPeekAuditConfigured({ NODE_ENV: \"test\" } as NodeJS.ProcessEnv),\n    ).toBe(false);\n    expect(\n      isPeekAuditConfigured({\n        NODE_ENV: \"test\",\n        DATABASE_URL: \"\",\n      } as NodeJS.ProcessEnv),\n    ).toBe(false);\n  });\n});"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":523,"cache_read_input_tokens":113797,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":523},"output_tokens":72,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"d007807c-1f68-4e76-afc1-d4448d7bbf7d","uuid":"8ced5f9e-02fa-4dad-865e-99f617397b27"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Sr4NrS4jonbsMpenUv3Q99","type":"tool_result","content":"The file /workspaces/rng-utopia/peek/src/server/exports/__tests__/runner.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"d007807c-1f68-4e76-afc1-d4448d7bbf7d","uuid":"2141fd29-8e83-4fd7-b36b-873a3df869d0","timestamp":"2026-04-26T15:02:02.367Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/peek/src/server/exports/__tests__/runner.test.ts","oldString":"describe(\"isPeekAuditConfigured\", () => {\n  it(\"is true when DATABASE_URL is a non-empty string\", () => {\n    expect(\n      isPeekAuditConfigured({ DATABASE_URL: \"postgres://x\" } as NodeJS.ProcessEnv),\n    ).toBe(true);\n  });\n\n  it(\"is false when DATABASE_URL is missing or empty\", () => {\n    expect(isPeekAuditConfigured({} as NodeJS.ProcessEnv)).toBe(false);\n    expect(\n      isPeekAuditConfigured({ DATABASE_URL: \"\" } as NodeJS.ProcessEnv),\n    ).toBe(false);\n  });\n});","newString":"describe(\"isPeekAuditConfigured\", () => {\n  it(\"is true when DATABASE_URL is a non-empty string\", () => {\n    expect(\n      isPeekAuditConfigured({\n        NODE_ENV: \"test\",\n        DATABASE_URL: \"postgres://x\",\n      } as NodeJS.ProcessEnv),\n    ).toBe(true);\n  });\n\n  it(\"is false when DATABASE_URL is missing or empty\", () => {\n    expect(\n      isPeekAuditConfigured({ NODE_ENV: \"test\" } as NodeJS.ProcessEnv),\n    ).toBe(false);\n    expect(\n      isPeekAuditConfigured({\n        NODE_ENV: \"test\",\n        DATABASE_URL: \"\",\n      } as NodeJS.ProcessEnv),\n    ).toBe(false);\n  });\n});","originalFile":"// Runner unit tests (FR-12).\n//\n// Covers required-filter enforcement, row-cap clamping (and `rowCapApplied`\n// truthiness), filename composition, audit-event emission BEFORE rows are\n// returned, audit-emit-failure refusal, unknown-entity refusal, and the\n// production-without-audit-config gate. The runner is dependency-injected so\n// these tests never touch a real database or the real audit writer.\n\nimport { describe, expect, it, vi } from \"vitest\";\nimport {\n  isPeekAuditConfigured,\n  runPeekExport,\n  type PeekExportActorContext,\n  type PeekExportAuditWriter,\n  type PeekExportRunResult,\n} from \"../runner\";\nimport type {\n  PeekExporterDefinition,\n  PeekExporterRegistry,\n} from \"../registry\";\nimport type { PeekTableColumn } from \"../../../lib/types/peek\";\nimport type { Sql } from \"postgres\";\nimport type { PeekAuditWriteResult } from \"../../audit/writer\";\n\ntype FetchSpy = ReturnType<typeof vi.fn>;\n\nconst ACTOR: PeekExportActorContext = {\n  email: \"alice@example.com\",\n  route: \"/growth/referrals\",\n  requestId: \"req-export-1\",\n};\n\nconst COLUMNS: ReadonlyArray<PeekTableColumn> = [\n  { id: \"id\", label: \"Id\", align: \"left\", sortable: false },\n  { id: \"name\", label: \"Name\", align: \"left\", sortable: false },\n];\n\nfunction makeRows(count: number): ReadonlyArray<Record<string, string>> {\n  return Array.from({ length: count }, (_, i) => ({\n    id: String(i + 1),\n    name: `row-${i + 1}`,\n  }));\n}\n\nfunction makeExporter(\n  overrides: Partial<PeekExporterDefinition> & {\n    fetchRows?: number;\n    requireAtLeastOneFilter?: boolean;\n    maxRowsPerExport?: number;\n  } = {},\n): { definition: PeekExporterDefinition; fetch: FetchSpy } {\n  const fetchRows = overrides.fetchRows ?? 3;\n  const maxRowsPerExport = overrides.maxRowsPerExport ?? 100;\n  const requireAtLeastOneFilter = overrides.requireAtLeastOneFilter ?? false;\n\n  const fetch: FetchSpy = vi.fn(\n    async ({ rowCap }: { rowCap: number }) => {\n      // Mimic real exporters: request rowCap+1 internally so `rowCapApplied`\n      // is honest. The test fixture decides how many rows the source actually\n      // produced via `fetchRows`.\n      const produced = makeRows(Math.min(fetchRows, rowCap + 1));\n      const rowCapApplied = fetchRows > rowCap;\n      const trimmed = rowCapApplied ? produced.slice(0, rowCap) : produced;\n      return { rows: trimmed, rowCapApplied };\n    },\n  );\n\n  const definition: PeekExporterDefinition = {\n    entity: \"claims\",\n    resourceType: \"referral_claim\",\n    columns: COLUMNS,\n    maxRowsPerExport,\n    requireAtLeastOneFilter,\n    fetch: fetch as unknown as PeekExporterDefinition[\"fetch\"],\n    buildFilterSlug: (filters) =>\n      Object.entries(filters)\n        .filter(([, v]) => v != null && v !== \"\")\n        .map(([k, v]) => `${k}-${v}`)\n        .join(\"_\"),\n    ...overrides,\n  };\n\n  return { definition, fetch };\n}\n\nfunction makeRegistry(\n  exporter: PeekExporterDefinition,\n): PeekExporterRegistry {\n  return Object.freeze({ [exporter.entity]: exporter });\n}\n\nconst FAKE_SQL = {} as unknown as Sql;\n\nfunction makeAuditWriter(\n  result: PeekAuditWriteResult = { ok: true },\n): { writer: PeekExportAuditWriter; calls: Array<unknown> } {\n  const calls: Array<unknown> = [];\n  const writer: PeekExportAuditWriter = vi.fn(async (input) => {\n    calls.push(input);\n    return result;\n  });\n  return { writer, calls };\n}\n\nfunction expectOk(\n  result: PeekExportRunResult,\n): Extract<PeekExportRunResult, { ok: true }> {\n  if (!result.ok) {\n    throw new Error(\n      `Expected ok=true result, got failure: ${result.reason} ${result.message}`,\n    );\n  }\n  return result;\n}\n\ndescribe(\"runPeekExport\", () => {\n  describe(\"required filters\", () => {\n    it(\"rejects with no_filters when the exporter requires a filter and none is supplied\", async () => {\n      const { definition, fetch } = makeExporter({\n        requireAtLeastOneFilter: true,\n      });\n      const audit = makeAuditWriter();\n\n      const result = await runPeekExport({\n        entity: \"claims\",\n        actor: ACTOR,\n        registry: makeRegistry(definition),\n        sql: FAKE_SQL,\n        auditWriter: audit.writer,\n        env: { NODE_ENV: \"test\", DATABASE_URL: \"postgres://x\" },\n      });\n\n      expect(result).toEqual({\n        ok: false,\n        reason: \"no_filters\",\n        message: 'Export \"claims\" requires at least one filter.',\n      });\n      expect(fetch).not.toHaveBeenCalled();\n      expect(audit.calls).toHaveLength(0);\n    });\n\n    it(\"rejects when every filter value is null/empty/undefined\", async () => {\n      const { definition, fetch } = makeExporter({\n        requireAtLeastOneFilter: true,\n      });\n      const audit = makeAuditWriter();\n\n      const result = await runPeekExport({\n        entity: \"claims\",\n        filters: { status: null, userId: \"\", txSignature: null },\n        actor: ACTOR,\n        registry: makeRegistry(definition),\n        sql: FAKE_SQL,\n        auditWriter: audit.writer,\n        env: { NODE_ENV: \"test\", DATABASE_URL: \"postgres://x\" },\n      });\n\n      expect(result.ok).toBe(false);\n      if (!result.ok) expect(result.reason).toBe(\"no_filters\");\n      expect(fetch).not.toHaveBeenCalled();\n    });\n\n    it(\"succeeds when at least one filter has a non-empty value\", async () => {\n      const { definition, fetch } = makeExporter({\n        requireAtLeastOneFilter: true,\n        fetchRows: 2,\n      });\n      const audit = makeAuditWriter();\n\n      const result = await runPeekExport({\n        entity: \"claims\",\n        filters: { status: \"pending\", userId: \"\", txSignature: null },\n        actor: ACTOR,\n        registry: makeRegistry(definition),\n        sql: FAKE_SQL,\n        auditWriter: audit.writer,\n        env: { NODE_ENV: \"test\", DATABASE_URL: \"postgres://x\" },\n      });\n\n      const ok = expectOk(result);\n      expect(ok.result.rowCount).toBe(2);\n      expect(fetch).toHaveBeenCalledTimes(1);\n    });\n\n    it(\"does not require filters for bounded ranked-list exporters\", async () => {\n      const { definition } = makeExporter({\n        entity: \"referrers\",\n        requireAtLeastOneFilter: false,\n        fetchRows: 5,\n        maxRowsPerExport: 250,\n        buildFilterSlug: () => \"\",\n      });\n      const audit = makeAuditWriter();\n\n      const result = await runPeekExport({\n        entity: \"referrers\",\n        actor: ACTOR,\n        registry: makeRegistry(definition),\n        sql: FAKE_SQL,\n        auditWriter: audit.writer,\n        env: { NODE_ENV: \"test\", DATABASE_URL: \"postgres://x\" },\n      });\n\n      const ok = expectOk(result);\n      expect(ok.result.rowCount).toBe(5);\n      expect(ok.result.filename).toMatch(/^peek-referrers-\\d{4}-\\d{2}-\\d{2}\\.csv$/);\n    });\n  });\n\n  describe(\"row caps\", () => {\n    it(\"applies the global default cap when no rowCap and no per-entity max smaller than default\", async () => {\n      const { definition, fetch } = makeExporter({\n        fetchRows: 1,\n        maxRowsPerExport: 10000, // larger than PEEK_EXPORT_ROW_CAP_DEFAULT (5000)\n      });\n      const audit = makeAuditWriter();\n\n      const result = await runPeekExport({\n        entity: \"claims\",\n        filters: { status: \"pending\" },\n        actor: ACTOR,\n        registry: makeRegistry(definition),\n        sql: FAKE_SQL,\n        auditWriter: audit.writer,\n        env: { NODE_ENV: \"test\", DATABASE_URL: \"postgres://x\" },\n      });\n\n      const ok = expectOk(result);\n      expect(ok.result.rowCap).toBe(5000);\n      const fetchCall = fetch.mock.calls[0]?.[0] as { rowCap: number };\n      expect(fetchCall.rowCap).toBe(5000);\n    });\n\n    it(\"clamps rowCap to the per-entity max even when caller asks for more\", async () => {\n      const { definition } = makeExporter({\n        fetchRows: 1,\n        maxRowsPerExport: 50,\n      });\n      const audit = makeAuditWriter();\n\n      const result = await runPeekExport({\n        entity: \"claims\",\n        filters: { status: \"pending\" },\n        rowCap: 9999,\n        actor: ACTOR,\n        registry: makeRegistry(definition),\n        sql: FAKE_SQL,\n        auditWriter: audit.writer,\n        env: { NODE_ENV: \"test\", DATABASE_URL: \"postgres://x\" },\n      });\n\n      const ok = expectOk(result);\n      expect(ok.result.rowCap).toBe(50);\n    });\n\n    it(\"honors a smaller caller-supplied rowCap below the per-entity max\", async () => {\n      const { definition } = makeExporter({\n        fetchRows: 1,\n        maxRowsPerExport: 1000,\n      });\n      const audit = makeAuditWriter();\n\n      const result = await runPeekExport({\n        entity: \"claims\",\n        filters: { status: \"pending\" },\n        rowCap: 25,\n        actor: ACTOR,\n        registry: makeRegistry(definition),\n        sql: FAKE_SQL,\n        auditWriter: audit.writer,\n        env: { NODE_ENV: \"test\", DATABASE_URL: \"postgres://x\" },\n      });\n\n      const ok = expectOk(result);\n      expect(ok.result.rowCap).toBe(25);\n    });\n\n    it(\"falls back to the per-entity ceiling when rowCap is invalid (zero, negative, NaN)\", async () => {\n      const { definition } = makeExporter({\n        fetchRows: 1,\n        maxRowsPerExport: 80,\n      });\n      const audit = makeAuditWriter();\n\n      for (const bad of [0, -10, Number.NaN]) {\n        const result = await runPeekExport({\n          entity: \"claims\",\n          filters: { status: \"pending\" },\n          rowCap: bad,\n          actor: ACTOR,\n          registry: makeRegistry(definition),\n          sql: FAKE_SQL,\n          auditWriter: audit.writer,\n          env: { NODE_ENV: \"test\", DATABASE_URL: \"postgres://x\" },\n        });\n        const ok = expectOk(result);\n        expect(ok.result.rowCap).toBe(80);\n      }\n    });\n\n    it(\"flags rowCapApplied=true when the underlying source returned more than the cap\", async () => {\n      const { definition } = makeExporter({\n        fetchRows: 7,\n        maxRowsPerExport: 5,\n      });\n      const audit = makeAuditWriter();\n\n      const result = await runPeekExport({\n        entity: \"claims\",\n        filters: { status: \"pending\" },\n        actor: ACTOR,\n        registry: makeRegistry(definition),\n        sql: FAKE_SQL,\n        auditWriter: audit.writer,\n        env: { NODE_ENV: \"test\", DATABASE_URL: \"postgres://x\" },\n      });\n\n      const ok = expectOk(result);\n      expect(ok.result.rowCount).toBe(5);\n      expect(ok.result.rowCapApplied).toBe(true);\n    });\n\n    it(\"flags rowCapApplied=false when the source returned at or below the cap\", async () => {\n      const { definition } = makeExporter({\n        fetchRows: 3,\n        maxRowsPerExport: 5,\n      });\n      const audit = makeAuditWriter();\n\n      const result = await runPeekExport({\n        entity: \"claims\",\n        filters: { status: \"pending\" },\n        actor: ACTOR,\n        registry: makeRegistry(definition),\n        sql: FAKE_SQL,\n        auditWriter: audit.writer,\n        env: { NODE_ENV: \"test\", DATABASE_URL: \"postgres://x\" },\n      });\n\n      const ok = expectOk(result);\n      expect(ok.result.rowCount).toBe(3);\n      expect(ok.result.rowCapApplied).toBe(false);\n    });\n  });\n\n  describe(\"filename\", () => {\n    it(\"includes entity, date, and filter slug\", async () => {\n      const { definition } = makeExporter({\n        fetchRows: 1,\n        requireAtLeastOneFilter: true,\n      });\n      const audit = makeAuditWriter();\n\n      const result = await runPeekExport({\n        entity: \"claims\",\n        filters: { status: \"pending\" },\n        actor: ACTOR,\n        registry: makeRegistry(definition),\n        sql: FAKE_SQL,\n        auditWriter: audit.writer,\n        env: { NODE_ENV: \"test\", DATABASE_URL: \"postgres://x\" },\n        now: new Date(\"2026-04-26T12:00:00Z\"),\n      });\n\n      const ok = expectOk(result);\n      expect(ok.result.filename).toBe(\n        \"peek-claims-2026-04-26-status-pending.csv\",\n      );\n    });\n\n    it(\"omits the filter slug segment when the slug is empty\", async () => {\n      const { definition } = makeExporter({\n        entity: \"referrers\",\n        requireAtLeastOneFilter: false,\n        fetchRows: 1,\n        buildFilterSlug: () => \"\",\n      });\n      const audit = makeAuditWriter();\n\n      const result = await runPeekExport({\n        entity: \"referrers\",\n        actor: ACTOR,\n        registry: makeRegistry(definition),\n        sql: FAKE_SQL,\n        auditWriter: audit.writer,\n        env: { NODE_ENV: \"test\", DATABASE_URL: \"postgres://x\" },\n        now: new Date(\"2026-04-26T12:00:00Z\"),\n      });\n\n      const ok = expectOk(result);\n      expect(ok.result.filename).toBe(\"peek-referrers-2026-04-26.csv\");\n    });\n  });\n\n  describe(\"audit events\", () => {\n    it(\"emits a peek.export event with the actor, action id, route, filter summary, and result count\", async () => {\n      const { definition } = makeExporter({\n        fetchRows: 4,\n        requireAtLeastOneFilter: true,\n      });\n      const audit = makeAuditWriter();\n\n      const result = await runPeekExport({\n        entity: \"claims\",\n        filters: { status: \"pending\", userId: \"u-1\" },\n        actor: ACTOR,\n        registry: makeRegistry(definition),\n        sql: FAKE_SQL,\n        auditWriter: audit.writer,\n        env: { NODE_ENV: \"test\", DATABASE_URL: \"postgres://x\" },\n      });\n\n      expectOk(result);\n      expect(audit.calls).toHaveLength(1);\n      const [call] = audit.calls as Array<{\n        eventType: string;\n        payload: Record<string, unknown>;\n      }>;\n      expect(call.eventType).toBe(\"peek.export\");\n      expect(call.payload).toMatchObject({\n        actorEmail: \"alice@example.com\",\n        route: \"/growth/referrals\",\n        actionId: \"export.claims\",\n        resourceType: \"referral_claim\",\n        resourceId: null,\n        resultCount: 4,\n        requestId: \"req-export-1\",\n        rejectionReason: null,\n        changes: null,\n      });\n      // filter summary is the comma-separated key=value list of applied filters\n      expect(call.payload.filterSummary).toBe(\n        \"status=pending, userId=u-1\",\n      );\n    });\n\n    it(\"emits the audit event BEFORE the row data is built (audit-then-return order)\", async () => {\n      // Capture the call order: fetch must happen, then audit, then the result\n      // is returned. We assert the ordering by spying on both.\n      const { definition, fetch } = makeExporter({\n        fetchRows: 1,\n        requireAtLeastOneFilter: true,\n      });\n      const order: string[] = [];\n      const fetchSpy = fetch as unknown as FetchSpy;\n      fetchSpy.mockImplementationOnce(async ({ rowCap }) => {\n        order.push(\"fetch\");\n        const rows = makeRows(Math.min(1, rowCap + 1));\n        return { rows, rowCapApplied: false };\n      });\n      const audit: PeekExportAuditWriter = vi.fn(async () => {\n        order.push(\"audit\");\n        return { ok: true as const };\n      });\n\n      const result = await runPeekExport({\n        entity: \"claims\",\n        filters: { status: \"pending\" },\n        actor: ACTOR,\n        registry: makeRegistry(definition),\n        sql: FAKE_SQL,\n        auditWriter: audit,\n        env: { NODE_ENV: \"test\", DATABASE_URL: \"postgres://x\" },\n      });\n\n      expectOk(result);\n      // audit MUST be called before the runner builds and returns the success\n      // result; the result construction is synchronous after audit, so only\n      // the [fetch, audit] sequencing is observable.\n      expect(order).toEqual([\"fetch\", \"audit\"]);\n    });\n\n    it(\"returns audit_emit_failed and refuses to ship rows when audit insert fails\", async () => {\n      const { definition } = makeExporter({\n        fetchRows: 5,\n        requireAtLeastOneFilter: true,\n      });\n      const audit = makeAuditWriter({ ok: false, reason: \"insert_failed\" });\n\n      const result = await runPeekExport({\n        entity: \"claims\",\n        filters: { status: \"pending\" },\n        actor: ACTOR,\n        registry: makeRegistry(definition),\n        sql: FAKE_SQL,\n        auditWriter: audit.writer,\n        env: { NODE_ENV: \"test\", DATABASE_URL: \"postgres://x\" },\n      });\n\n      expect(result.ok).toBe(false);\n      if (!result.ok) {\n        expect(result.reason).toBe(\"audit_emit_failed\");\n        // No row payload of any kind in the failure result.\n        expect(JSON.stringify(result)).not.toContain(\"row-1\");\n      }\n    });\n\n    it(\"uses null filterSummary when no filters are present (bounded ranked exporter)\", async () => {\n      const { definition } = makeExporter({\n        entity: \"kol\",\n        requireAtLeastOneFilter: false,\n        fetchRows: 1,\n        buildFilterSlug: () => \"\",\n      });\n      const audit = makeAuditWriter();\n\n      await runPeekExport({\n        entity: \"kol\",\n        actor: ACTOR,\n        registry: makeRegistry(definition),\n        sql: FAKE_SQL,\n        auditWriter: audit.writer,\n        env: { NODE_ENV: \"test\", DATABASE_URL: \"postgres://x\" },\n      });\n\n      const [call] = audit.calls as Array<{\n        payload: Record<string, unknown>;\n      }>;\n      expect(call.payload.filterSummary).toBeNull();\n    });\n  });\n\n  describe(\"unknown entity\", () => {\n    it(\"returns unknown_entity when no exporter is registered\", async () => {\n      const audit = makeAuditWriter();\n      const result = await runPeekExport({\n        entity: \"users\",\n        actor: ACTOR,\n        registry: Object.freeze({}),\n        sql: FAKE_SQL,\n        auditWriter: audit.writer,\n        env: { NODE_ENV: \"test\", DATABASE_URL: \"postgres://x\" },\n      });\n\n      expect(result.ok).toBe(false);\n      if (!result.ok) {\n        expect(result.reason).toBe(\"unknown_entity\");\n      }\n      expect(audit.calls).toHaveLength(0);\n    });\n  });\n\n  describe(\"production audit gate\", () => {\n    it(\"returns audit_unavailable in production when DATABASE_URL is unset\", async () => {\n      const { definition, fetch } = makeExporter({\n        fetchRows: 1,\n        requireAtLeastOneFilter: true,\n      });\n      const audit = makeAuditWriter();\n\n      const result = await runPeekExport({\n        entity: \"claims\",\n        filters: { status: \"pending\" },\n        actor: ACTOR,\n        registry: makeRegistry(definition),\n        sql: FAKE_SQL,\n        auditWriter: audit.writer,\n        env: { NODE_ENV: \"production\" }, // DATABASE_URL intentionally missing\n      });\n\n      expect(result).toEqual({\n        ok: false,\n        reason: \"audit_unavailable\",\n        message:\n          \"Exports are disabled in production when audit logging is not configured.\",\n      });\n      expect(fetch).not.toHaveBeenCalled();\n      expect(audit.calls).toHaveLength(0);\n    });\n\n    it(\"returns audit_unavailable in production when DATABASE_URL is empty string\", async () => {\n      const { definition } = makeExporter({\n        fetchRows: 1,\n        requireAtLeastOneFilter: true,\n      });\n      const audit = makeAuditWriter();\n\n      const result = await runPeekExport({\n        entity: \"claims\",\n        filters: { status: \"pending\" },\n        actor: ACTOR,\n        registry: makeRegistry(definition),\n        sql: FAKE_SQL,\n        auditWriter: audit.writer,\n        env: { NODE_ENV: \"production\", DATABASE_URL: \"\" },\n      });\n\n      expect(result.ok).toBe(false);\n      if (!result.ok) expect(result.reason).toBe(\"audit_unavailable\");\n    });\n\n    it(\"succeeds in production when DATABASE_URL is configured\", async () => {\n      const { definition } = makeExporter({\n        fetchRows: 1,\n        requireAtLeastOneFilter: true,\n      });\n      const audit = makeAuditWriter();\n\n      const result = await runPeekExport({\n        entity: \"claims\",\n        filters: { status: \"pending\" },\n        actor: ACTOR,\n        registry: makeRegistry(definition),\n        sql: FAKE_SQL,\n        auditWriter: audit.writer,\n        env: {\n          NODE_ENV: \"production\",\n          DATABASE_URL: \"postgres://user:pw@host:5432/db\",\n        },\n      });\n\n      expectOk(result);\n      expect(audit.calls).toHaveLength(1);\n    });\n\n    it(\"permits exports outside production even when DATABASE_URL is unset\", async () => {\n      const { definition } = makeExporter({\n        fetchRows: 1,\n        requireAtLeastOneFilter: true,\n      });\n      const audit = makeAuditWriter();\n\n      const result = await runPeekExport({\n        entity: \"claims\",\n        filters: { status: \"pending\" },\n        actor: ACTOR,\n        registry: makeRegistry(definition),\n        sql: FAKE_SQL,\n        auditWriter: audit.writer,\n        env: { NODE_ENV: \"development\" },\n      });\n\n      expectOk(result);\n    });\n  });\n});\n\ndescribe(\"isPeekAuditConfigured\", () => {\n  it(\"is true when DATABASE_URL is a non-empty string\", () => {\n    expect(\n      isPeekAuditConfigured({ DATABASE_URL: \"postgres://x\" } as NodeJS.ProcessEnv),\n    ).toBe(true);\n  });\n\n  it(\"is false when DATABASE_URL is missing or empty\", () => {\n    expect(isPeekAuditConfigured({} as NodeJS.ProcessEnv)).toBe(false);\n    expect(\n      isPeekAuditConfigured({ DATABASE_URL: \"\" } as NodeJS.ProcessEnv),\n    ).toBe(false);\n  });\n});\n","structuredPatch":[{"oldStart":638,"oldLines":14,"newStart":638,"newLines":22,"lines":[" describe(\"isPeekAuditConfigured\", () => {","   it(\"is true when DATABASE_URL is a non-empty string\", () => {","     expect(","-      isPeekAuditConfigured({ DATABASE_URL: \"postgres://x\" } as NodeJS.ProcessEnv),","+      isPeekAuditConfigured({","+        NODE_ENV: \"test\",","+        DATABASE_URL: \"postgres://x\",","+      } as NodeJS.ProcessEnv),","     ).toBe(true);","   });"," ","   it(\"is false when DATABASE_URL is missing or empty\", () => {","-    expect(isPeekAuditConfigured({} as NodeJS.ProcessEnv)).toBe(false);","     expect(","-      isPeekAuditConfigured({ DATABASE_URL: \"\" } as NodeJS.ProcessEnv),","+      isPeekAuditConfigured({ NODE_ENV: \"test\" } as NodeJS.ProcessEnv),","     ).toBe(false);","+    expect(","+      isPeekAuditConfigured({","+        NODE_ENV: \"test\",","+        DATABASE_URL: \"\",","+      } as NodeJS.ProcessEnv),","+    ).toBe(false);","   });"," });"]}],"userModified":false,"replaceAll":false}}
