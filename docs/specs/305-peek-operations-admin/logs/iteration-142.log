{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RoTj8QdWmm76YjyRGktcQA","type":"tool_result","content":"435\t    });\n436\t\n437\t    it(\"emits the audit event BEFORE the row data is built (audit-then-return order)\", async () => {\n438\t      // Capture the call order: fetch must happen, then audit, then the result\n439\t      // is returned. We assert the ordering by spying on both.\n440\t      const { definition, fetch } = makeExporter({\n441\t        fetchRows: 1,\n442\t        requireAtLeastOneFilter: true,\n443\t      });\n444\t      const order: string[] = [];\n445\t      const fetchSpy = fetch as unknown as FetchSpy;\n446\t      fetchSpy.mockImplementationOnce(async ({ rowCap }) => {\n447\t        order.push(\"fetch\");\n448\t        const rows = makeRows(Math.min(1, rowCap + 1));\n449\t        return { rows, rowCapApplied: false };\n450\t      });\n451\t      const audit: PeekExportAuditWriter = vi.fn(async () => {\n452\t        order.push(\"audit\");\n453\t        return { ok: true };\n454\t      });\n455\t\n456\t      const result = await runPeekExport({\n457\t        entity: \"claims\",\n458\t        filters: { status: \"pending\" },\n459\t        actor: ACTOR,\n460\t        registry: makeRegistry(definition),\n461\t        sql: FAKE_SQL,\n462\t        auditWriter: audit,\n463\t        env: { NODE_ENV: \"test\", DATABASE_URL: \"postgres://x\" },\n464\t      });\n465\t\n466\t      expectOk(result);\n467\t      // audit MUST be called before the runner builds and returns the success\n468\t      // result; the result construction is synchronous after audit, so only\n469\t      // the [fetch, audit] sequencing is observable.\n470\t      expect(order).toEqual([\"fetch\", \"audit\"]);\n471\t    });\n472\t\n473\t    it(\"returns audit_emit_failed and refuses to ship rows when audit insert fails\", async () => {\n474\t      const { definition } = makeExporter({\n475\t        fetchRows: 5,\n476\t        requireAtLeastOneFilter: true,\n