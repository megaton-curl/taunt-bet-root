{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_013TNaaLuXxQvnXc7RwbSbH6","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_016vRAfiDR3CEq8yMbfvh9GZ","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/mutations/fraud-flag.ts","content":"// Approved FR-14 mutation: update the `status` column of a `fraud_flags` row.\n//\n// Scope:\n//   - Identified by the BIGINT `fraud_flags.id` rendered as text.\n//   - Only the `status` column moves; the diff records the before/after pair\n//     so the audit row carries the full state transition.\n//   - `resolved_at` is bumped server-side whenever the flag leaves `open` and\n//     cleared when the flag is reopened. It is operator/derived metadata and\n//     stays out of the audit diff (matches the kol-rate `set_by`/`updated_at`\n//     precedent).\n//\n// Allowed-transition matrix:\n//   open      -> reviewed | dismissed\n//   reviewed  -> open     | dismissed\n//   dismissed -> open\n//\n//   Disallowed:\n//     - dismissed -> reviewed (must reopen first; review is a state for active\n//       investigation, not a re-classification of a closed flag).\n//     - any no-op (X -> X), so audit rows always reflect a real movement.\n//\n// Failure semantics (surfaced through the runner's execute path):\n//   - Unknown flag id        -> thrown error -> result `execution_failed` /\n//     audit `peek.change.rejected` with `rejectionReason` starting\n//     `execution_failed: unknown_flag:`.\n//   - Disallowed transition  -> thrown error -> result `execution_failed` /\n//     audit `peek.change.rejected` with `rejectionReason` starting\n//     `execution_failed: invalid_transition:`.\n//   - Schema validation failures (missing flagId, bad nextStatus, no-op caught\n//     up-front) -> the runner's `invalid_input` path before any DB work.\n//\n// Authorization:\n//   `fraud_flag.status.update` is admin-only per FR-2 `PEEK_ACTION_RULES`.\n//   The runner enforces this before `execute` is called.\n\nimport type { Sql } from \"postgres\";\nimport { z } from \"zod\";\nimport type { PeekAuditChange } from \"../../lib/types/peek\";\nimport type {\n  PeekMutationDefinition,\n  PeekMutationExecuteContext,\n  PeekMutationExecuteResult,\n} from \"./registry\";\n\nexport const FRAUD_FLAG_STATUSES = [\"open\", \"reviewed\", \"dismissed\"] as const;\nexport type FraudFlagStatus = (typeof FRAUD_FLAG_STATUSES)[number];\n\n// (from, to) tuples that are admitted by the transition matrix.\nexport const FRAUD_FLAG_ALLOWED_TRANSITIONS: ReadonlyArray<\n  readonly [FraudFlagStatus, FraudFlagStatus]\n> = Object.freeze([\n  [\"open\", \"reviewed\"],\n  [\"open\", \"dismissed\"],\n  [\"reviewed\", \"open\"],\n  [\"reviewed\", \"dismissed\"],\n  [\"dismissed\", \"open\"],\n] as const);\n\nexport function isFraudFlagTransitionAllowed(\n  from: FraudFlagStatus,\n  to: FraudFlagStatus,\n): boolean {\n  return FRAUD_FLAG_ALLOWED_TRANSITIONS.some(\n    ([f, t]) => f === from && t === to,\n  );\n}\n\n// `flagId` is the BIGINT primary key serialized as text (matches the existing\n// `get-dogpile-and-fraud.listFraudFlags` view-model contract).\nexport const fraudFlagStatusUpdateInputSchema = z\n  .object({\n    flagId: z\n      .string()\n      .trim()\n      .min(1)\n      .regex(/^[0-9]+$/u, \"flagId must be a positive integer\"),\n    nextStatus: z.enum(FRAUD_FLAG_STATUSES),\n  })\n  .strict();\n\nexport type FraudFlagStatusUpdateInput = z.infer<\n  typeof fraudFlagStatusUpdateInputSchema\n>;\n\ntype ExistingFraudFlagRow = {\n  id: string;\n  status: FraudFlagStatus;\n};\n\nasync function fetchExistingRow(\n  sql: Sql,\n  flagId: string,\n): Promise<ExistingFraudFlagRow | null> {\n  const rows = await sql<Array<ExistingFraudFlagRow>>`\n    select\n      id::text as \"id\",\n      status as \"status\"\n    from fraud_flags\n    where id::text = ${flagId}\n    for update\n  `;\n  return rows[0] ?? null;\n}\n\nasync function executeFraudFlagStatusUpdate(\n  ctx: PeekMutationExecuteContext<FraudFlagStatusUpdateInput>,\n): Promise<PeekMutationExecuteResult> {\n  const { sql, input } = ctx;\n  const { flagId, nextStatus } = input;\n\n  const existing = await fetchExistingRow(sql, flagId);\n  if (!existing) {\n    throw new Error(`unknown_flag: ${flagId}`);\n  }\n\n  const fromStatus = existing.status;\n  if (!isFraudFlagTransitionAllowed(fromStatus, nextStatus)) {\n    throw new Error(`invalid_transition: ${fromStatus} -> ${nextStatus}`);\n  }\n\n  if (nextStatus === \"open\") {\n    await sql`\n      update fraud_flags\n      set status = ${nextStatus}, resolved_at = null\n      where id::text = ${flagId}\n    `;\n  } else {\n    await sql`\n      update fraud_flags\n      set status = ${nextStatus}, resolved_at = now()\n      where id::text = ${flagId}\n    `;\n  }\n\n  const changes: ReadonlyArray<PeekAuditChange> = [\n    { field: \"status\", before: fromStatus, after: nextStatus },\n  ];\n  return { resourceId: existing.id, changes };\n}\n\nexport const fraudFlagStatusUpdateMutation: PeekMutationDefinition<FraudFlagStatusUpdateInput> =\n  {\n    actionId: \"fraud_flag.status.update\",\n    resourceType: \"fraud_flags\",\n    schema: fraudFlagStatusUpdateInputSchema,\n    execute:\n      executeFraudFlagStatusUpdate as PeekMutationDefinition[\"execute\"],\n  };\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1218,"cache_read_input_tokens":107091,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1218},"output_tokens":46,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"ac0c4bb5-fd14-4fda-adaf-f3ade788ced5","uuid":"31bcf657-78f4-47eb-96a7-dcd12304b42d"}
