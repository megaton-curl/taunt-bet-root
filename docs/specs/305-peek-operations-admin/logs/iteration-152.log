react\";\nimport { MetricStrip } from \"../../../src/components/metric-strip\";\nimport { RewardConfigTable } from \"../../../src/components/reward-config-table\";\nimport { RewardPoolCard } from \"../../../src/components/reward-pool-card\";\nimport { RewardPoolFundingsTable } from \"../../../src/components/reward-pool-fundings-table\";\nimport type {\n  PeekRewardConfigRow,\n  PeekRewardPool,\n  PeekRewardPoolFundingRow,\n  PeekRewardsOverview,\n} from \"../../../src/lib/types/peek\";\nimport {\n  getPeekActorContext,\n  isRouteAllowedForRole,\n} from \"../../../src/server/access-policy\";\nimport {\n  PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT,\n  getRewardPool,\n  getRewardsOverview,\n  listRewardConfig,\n  listRewardPoolFundings,\n} from \"../../../src/server/db/queries/get-rewards\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst ROUTE = \"/economy/rewards\";\n\nexport default async function EconomyRewardsPage() {\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n\n  if (!allowed) {\n    return (\n      <main style={mainStyle}>\n        <header>\n          <h1>Economy · Rewards</h1>\n        </header>\n        <p role=\"alert\" style={errorStyle}>\n          You do not have access to this page.\n        </p>\n      </main>\n    );\n  }\n\n  let overview: PeekRewardsOverview = {\n    generatedAt: new Date().toISOString(),\n    metrics: [],\n  };\n  let pool: PeekRewardPool | null = null;\n  let config: ReadonlyArray<PeekRewardConfigRow> = [];\n  let fundings: ReadonlyArray<PeekRewardPoolFundingRow> = [];\n\n  let overviewError: string | null = null;\n  let poolError: string | null = null;\n  let configError: string | null = null;\n  let fundingsError: string | null = null;\n\n  try {\n    overview = await getRewardsOverview();\n  } catch (error) {\n    overviewError =\n      error instanceof Error\n        ? error.message\n        : \"Rewards overview could not be loaded.\";\n  }\n\n  try {\n    pool = await getRewardPool();\n  } catch (error) {\n    poolError =\n      error instanceof Error\n        ? error.message\n        : \"Reward pool singleton could not be loaded.\";\n  }\n\n  try {\n    config = await listRewardConfig();\n  } catch (error) {\n    configError =\n      error instanceof Error\n        ? error.message\n        : \"Reward config rows could not be loaded.\";\n  }\n\n  try {\n    fundings = await listRewardPoolFundings();\n  } catch (error) {\n    fundingsError =\n      error instanceof Error\n        ? error.message\n        : \"Reward pool fundings could not be loaded.\";\n  }\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <h1>Economy · Rewards</h1>\n        <p style={leadStyle}>\n          Reward pool accounting, operator-tunable economy config, and the\n          per-round funding ledger. Drill into a funding row to open universal\n          search for the source round.\n        </p>\n      </header>\n\n      <section aria-labelledby=\"overview-heading\">\n        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n          Overview\n        </h2>\n        <MetricStrip metrics={overview.metrics} error={overviewError} />\n      </section>\n\n      <section aria-labelledby=\"pool-heading\" id=\"pool\" style={sectionStyle}>\n        <h2 id=\"pool-heading\" style={sectionHeadingStyle}>\n          Pool balance\n        </h2>\n        <p style={hintStyle}>\n          Singleton row from `reward_pool` (id = 1) · live read · lamports\n          retain raw u64 precision in the cell `title=` for hover audit.\n        </p>\n        <RewardPoolCard pool={pool} error={poolError} />\n      </section>\n\n      <section\n        aria-labelledby=\"config-heading\"\n        id=\"config\"\n        style={sectionStyle}\n      >\n        <h2 id=\"config-heading\" style={sectionHeadingStyle}>\n          Reward config\n        </h2>\n        <p style={hintStyle}>\n          All keys from `reward_config` · sorted alphabetically · read-only.\n          Editing selected keys will be wired through the FR-14 mutation surface\n          in a later iteration.\n        </p>\n        <RewardConfigTable rows={config} error={configError} />\n      </section>\n\n      <section\n        aria-labelledby=\"fundings-heading\"\n        id=\"fundings\"\n        style={sectionStyle}\n      >\n        <h2 id=\"fundings-heading\" style={sectionHeadingStyle}>\n          Recent pool fundings\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT} rows · sorted\n          newest first · server-side capped. Click a source round to open\n          universal search and drill into the originating game round.\n        </p>\n        <RewardPoolFundingsTable rows={fundings} error={fundingsError} />\n      </section>\n    </main>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n","structuredPatch":[{"oldStart":24,"oldLines":6,"newStart":24,"newLines":7,"lines":[" } from \"../../../src/lib/types/peek\";"," import {","   getPeekActorContext,","+  isActionAllowedForRole,","   isRouteAllowedForRole,"," } from \"../../../src/server/access-policy\";"," import {"]},{"oldStart":33,"oldLines":6,"newStart":34,"newLines":7,"lines":["   listRewardConfig,","   listRewardPoolFundings,",