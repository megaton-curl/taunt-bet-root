\"monospace\" }}>\n                {row.pointGrantCount.toLocaleString(\"en-US\")}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.id}\n              </td>\n              {canCancelDogpile ? (\n                <td style={bodyCellStyle(\"left\")}>\n                  <DogpileCancelMutationForm\n                    eventId={row.id}\n                    currentStatus={row.status}\n                  />\n                </td>\n              ) : null}\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}","originalFile":"// Dogpile events table for /operations/dogpile (FR-9).\n//\n// Dense table over `PeekDogpileEventRow`. Status drives the chip tone so an\n// operator can spot scheduled vs active vs ended/cancelled at a glance. Each\n// row also surfaces the count of game_entries and point_grants whose\n// `created_at` falls inside the dogpile window — the closest\n// operator-meaningful \"linked\" set the spec calls out (FR-9).\n//\n// FR-14 wiring: when `canCancelDogpile` is true the table appends a\n// \"Cancel\" column rendering `DogpileCancelMutationForm` per row whose\n// status is exactly `scheduled`. Non-scheduled rows render an empty cell;\n// non-authorized actors do not see the column at all.\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekDogpileEventRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { DogpileCancelMutationForm } from \"./mutations/dogpile-cancel-mutation-form\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type DogpileEventsTableProps = {\n  rows: ReadonlyArray<PeekDogpileEventRow>;\n  error?: string | null;\n  canCancelDogpile?: boolean;\n};\n\nexport function DogpileEventsTable({\n  rows,\n  error = null,\n  canCancelDogpile = false,\n}: DogpileEventsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Dogpile events unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>\n          No dogpile_events rows match these filters.\n        </p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see scheduled, active,\n          ended, and cancelled events.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Status</th>\n            <th style={headerCellStyle(\"left\")}>Campaign</th>\n            <th style={headerCellStyle(\"left\")}>Starts</th>\n            <th style={headerCellStyle(\"left\")}>Ends</th>\n            <th style={headerCellStyle(\"right\")}>Multiplier</th>\n            <th style={headerCellStyle(\"right\")}>Game entries</th>\n            <th style={headerCellStyle(\"right\")}>Point grants</th>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>ID</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.status}\n                  tone={dogpileStatusTone(row.status)}\n                />\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <div>{row.campaignName ?? \"—\"}</div>\n                {row.campaignType ? (\n                  <div style={subValueStyle}>{row.campaignType}</div>\n                ) : null}\n                {row.campaignId ? (\n                  <div style={{ ...subValueStyle, fontFamily: \"monospace\" }}>\n                    {row.campaignId}\n                  </div>\n                ) : null}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.startsAt}</td>\n              <td style={bodyCellStyle(\"left\")}>{row.endsAt}</td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.multiplier}×\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.gameEntryCount.toLocaleString(\"en-US\")}\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.pointGrantCount.toLocaleString(\"en-US\")}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.id}\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction dogpileStatusTone(value: string): PeekStatusTone {\n  if (value === \"scheduled\") return \"info\";\n  if (value === \"active\") return \"positive\";\n  if (value === \"ended\") return \"neutral\";\n  if (value === \"cancelled\") return \"warning\";\n  return \"neutral\";\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","structuredPatch":[{"oldStart":65,"oldLines":6,"newStart":65,"newLines":9,"lines":["             <th style={headerCellStyle(\"right\")}>Point grants</th>","             <th style={headerCellStyle(\"left\")}>Created</th>","             <th style={headerCellStyle(\"left\")}>ID</th>","+            {canCancelDogpile ? (","+              <th style={headerCellStyle(\"left\")}>Cancel</th>","+            ) : null}","           </tr>","         </thead>","         <tbody>"]},{"oldStart":102,"oldLines":6,"newStart":105,"newLines":14,"lines":["               <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>","                 {row.id}","               </td>","+              {canCancelDogpile ? (","+                <td style={bodyCellStyle(\"left\")}>","+                  <DogpileCancelMutationForm","+                    eventId={row.id}","+                    currentStatus={row.status}","+                  />","+                </td>","+              ) : null}","             </tr>","           ))}","         </tbody>"]}],"userModified":false,"replaceAll":false}}
