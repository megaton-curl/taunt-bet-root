       <span style={oldValueStyle}>scheduled</span>\n        <span style={arrowStyle}>→</span>\n        <span style={newValueStyle}>cancelled</span>\n      </div>\n\n      <button type=\"submit\" disabled={pending} style={submitStyle}>\n        {pending ? \"Cancelling…\" : \"Cancel scheduled event\"}\n      </button>\n\n      <MutationFeedback state={state} successLabel=\"Dogpile event cancelled.\" />\n    </form>\n  );\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst diffStyle: CSSProperties = {\n  display: \"flex\",\n  alignItems: \"center\",\n  gap: \"0.5rem\",\n  fontSize: \"0.75rem\",\n  fontFamily: \"monospace\",\n};\n\nconst oldValueStyle: CSSProperties = {\n  color: \"#64748b\",\n};\n\nconst newValueStyle: CSSProperties = {\n  color: \"#fcd34d\",\n};\n\nconst arrowStyle: CSSProperties = {\n  color: \"#475569\",\n};\n\nconst submitStyle: CSSProperties = {\n  padding: \"0.375rem 0.75rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #92400e\",\n  background: \"#b45309\",\n  color: \"#fffbeb\",\n  fontSize: \"0.8125rem\",\n  fontWeight: 600,\n  cursor: \"pointer\",\n};\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01DSVpiAVFz58j6jRaif1aHj","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TezKSkBHA2vpk1RWTXNN8V","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/mutations/reward-config-mutation-form.tsx","content":"// FR-14 mutation form: edit a single allowlisted `reward_config` row.\n//\n// Rendered inline in `reward-config-table.tsx` for admin actors and\n// only for rows whose `key` is in the allowlist\n// (`PEEK_REWARD_CONFIG_EDITABLE_KEYS`). The form requires an explicit\n// confirmation checkbox (`confirm: true`) because reward-economy edits\n// are economically sensitive — the FR-14 contract treats a missing or\n// false `confirm` as `invalid_input`. The submit button stays disabled\n// until the operator (a) types a value that differs from the existing\n// row's value and (b) checks the confirmation box, so the UI reflects\n// the mutation's \"no-op rejection\" rule before it ships a request.\n\n\"use client\";\n\nimport type { CSSProperties } from \"react\";\nimport { useActionState, useId, useState } from \"react\";\nimport {\n  PEEK_MUTATION_INITIAL_STATE,\n  rewardConfigUpdateAction,\n} from \"../../server/actions/peek-mutations\";\nimport { MutationFeedback } from \"./mutation-feedback\";\n\nexport type RewardConfigMutationFormProps = {\n  rowKey: string;\n  expectedType: \"integer\" | \"float\" | \"ratio\" | \"lamports\";\n  valueCurrent: string;\n};\n\nexport function RewardConfigMutationForm({\n  rowKey,\n  expectedType,\n  valueCurrent,\n}: RewardConfigMutationFormProps) {\n  const [state, dispatch, pending] = useActionState(\n    rewardConfigUpdateAction,\n    PEEK_MUTATION_INITIAL_STATE,\n  );\n  const valueId = useId();\n  const confirmId = useId();\n  const [pendingValue, setPendingValue] = useState(valueCurrent);\n  const [confirmed, setConfirmed] = useState(false);\n\n  const isNoop = pendingValue.trim() === valueCurrent.trim();\n  const canSubmit = !pending && !isNoop && confirmed;\n\n  return (\n    <form\n      action={dispatch}\n      style={formStyle}\n      aria-label=\"Edit reward config value\"\n    >\n      <input type=\"hidden\" name=\"key\" value={rowKey} />\n\n      <div style={fieldRowStyle}>\n        <label htmlFor={valueId} style={labelStyle}>\n          Value ({expectedType})\n        </label>\n        <div style={oldValueStyle}>old: {valueCurrent}</div>\n        <input\n          id={valueId}\n          name=\"value\"\n          type=\"text\"\n          inputMode={\n            expectedType === \"integer\" || expectedType === \"lamports\"\n              ? \"numeric\"\n              : \"decimal\"\n          }\n          defaultValue={valueCurrent}\n          required\n          style={inputStyle}\n          autoComplete=\"off\"\n          spellCheck={false}\n          onChange={(event) => setPendingValue(event.currentTarget.value)}\n        />\n        {isNoop ? (\n          <p style={hintStyle}>New value matches the current value.</p>\n        ) : (\n          <p style={diffHintStyle}>\n            new: <span style={newValueStyle}>{pendingValue}</span>\n          </p>\n        )}\n      </div>\n\n      <label htmlFor={confirmId} style={confirmRowStyle}>\n        <input\n          id={confirmId}\n          type=\"checkbox\"\n          name=\"confirm\"\n          value=\"true\"\n          checked={confirmed}\n          onChange={(event) => setConfirmed(event.currentTarget.checked)}\n          style={checkboxStyle}\n        />\n        <span>\n          I confirm this reward-economy change. (Required by FR-14.)\n        </span>\n      </label>\n\n      <button type=\"submit\" disabled={!canSubmit} style={submitStyle}>\n        {pending ? \"Applying…\" : \"Apply value change\"}\n      </button>\n\n      <MutationFeedback state={state} successLabel=\"Reward config updated.\" />\n    </form>\n  );\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst fieldRowStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst labelStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n  color: \"#94a3b8\",\n};\n\nconst oldValueStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  color: \"#64748b\",\n  fontFamily: \"monospace\",\n};\n\nconst newValueStyle: CSSProperties = {\n  color: \"#fcd34d\",\n};\n\nconst inputStyle: CSSProperties = {\n  padding: \"0.375rem 0.5rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #334155\",\n  background: \"#0f172a\",\n  color: \"#e2e8f0\",\n  fontSize: \"0.8125rem\",\n  fontFamily: \"monospace\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n  fontStyle: \"italic\",\n};\n\nconst diffHintStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n  fontFamily: \"monospace\",\n};\n\nconst confirmRowStyle: CSSProperties = {\n  display: \"flex\",\n  alignItems: \"center\",\n  gap: \"0.5rem\",\n  fontSize: \"0.8125rem\",\n  color: \"#cbd5f5\",\n};\n\nconst checkboxStyle: CSSProperties = {\n  cursor: \"pointer\",\n};\n\nconst submitStyle: CSSProperties = {\n  padding: \"0.375rem 0.75rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #1e3a8a\",\n  background: \"#1e40af\",\n  color: \"#dbeafe\",\n  fontSize: \"0.8125rem\",\n  fontWeight: 600,\n  cursor: \"pointer\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1230,"cache_read_input_tokens":146052,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1230},"output_tokens":62,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"3fc3c40b-0944-44dd-9202-74a9cef80e25","uuid":"96a17947-7156-493c-be42-0548a46de26c"}
