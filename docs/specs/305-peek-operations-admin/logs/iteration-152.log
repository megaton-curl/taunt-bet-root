{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01PQcNY3LJ35kyhSe22m8ZRs","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01CA9A5DqaWQG8VjyhzugPSk","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/actions/peek-mutations.ts","content":"// Next.js Server Actions that wrap the FR-14 mutation runner.\n//\n// These actions are the only client-callable entry point into\n// `runPeekMutation`. Each:\n//   1. Resolves the verified Cloudflare actor via `getPeekActorContext()`\n//      (server-only headers; never trusts browser-supplied identity).\n//   2. Re-runs the runner's role/schema/transaction/audit pipeline so the\n//      `peek.change.applied` / `peek.change.rejected` audit semantics are\n//      identical regardless of whether the call originated from a UI form\n//      or a future direct invocation.\n//   3. Translates the runner's `PeekMutationRunResult` into a\n//      `PeekMutationActionState` that React forms can consume via\n//      `useActionState`. Error reasons (`unauthorized`, `invalid_input`,\n//      `execution_failed`, ...) round-trip so the UI can show\n//      rejection-specific messaging.\n//   4. Calls `revalidatePath` on the source admin route so the page\n//      re-renders the post-mutation database state.\n//\n// Form parsing intentionally lives here (not in the runner): the server\n// action sees a raw `FormData`, coerces named fields into the typed shape\n// the mutation's zod schema expects, and lets the schema decide what\n// passes. Coercion failures (e.g. non-numeric `rateBps`) are surfaced to\n// the runner so the rejection still emits `peek.change.rejected` with\n// `rejectionReason: \"invalid_input\"` — the UI cannot silently drop a\n// failed change.\n\n\"use server\";\n\nimport { revalidatePath } from \"next/cache\";\nimport { headers } from \"next/headers\";\nimport { getPeekActorContext } from \"../access-policy\";\nimport { runPeekMutation } from \"../mutations\";\nimport type {\n  PeekMutationActionId,\n  PeekMutationFailureReason,\n  PeekMutationRunResult,\n} from \"../mutations\";\n\nexport type PeekMutationActionStatus = \"idle\" | \"ok\" | \"error\";\n\nexport type PeekMutationActionState = {\n  status: PeekMutationActionStatus;\n  message: string;\n  reason?: PeekMutationFailureReason | \"no_actor\";\n  fieldErrors?: Record<string, ReadonlyArray<string>>;\n  resourceId?: string | null;\n  // Echoed back so the UI can show a stable \"X.Y was applied\" line even\n  // after the form re-renders; not a security boundary.\n  actionId?: PeekMutationActionId;\n};\n\nexport const PEEK_MUTATION_INITIAL_STATE: PeekMutationActionState = {\n  status: \"idle\",\n  message: \"\",\n};\n\ntype DispatchOptions = {\n  actionId: PeekMutationActionId;\n  rawInput: unknown;\n  route: string;\n};\n\nasync function dispatchMutation(\n  opts: DispatchOptions,\n): Promise<PeekMutationActionState> {\n  const actor = await getPeekActorContext();\n  if (!actor) {\n    return {\n      status: \"error\",\n      message: \"You are not authenticated.\",\n      reason: \"no_actor\",\n      actionId: opts.actionId,\n    };\n  }\n\n  const requestId = (await headers()).get(\"x-request-id\");\n\n  const result: PeekMutationRunResult = await runPeekMutation({\n    actionId: opts.actionId,\n    rawInput: opts.rawInput,\n    actorRole: actor.role,\n    actor: {\n      email: actor.email,\n      route: opts.route,\n      requestId,\n    },\n  });\n\n  if (!result.ok) {\n    return {\n      status: \"error\",\n      message: result.message,\n      reason: result.reason,\n      fieldErrors: result.fieldErrors as\n        | Record<string, ReadonlyArray<string>>\n        | undefined,\n      actionId: opts.actionId,\n    };\n  }\n\n  revalidatePath(opts.route);\n\n  return {\n    status: \"ok\",\n    message: \"Change applied.\",\n    resourceId: result.resourceId,\n    actionId: opts.actionId,\n  };\n}\n\nfunction readString(formData: FormData, key: string): string {\n  const raw = formData.get(key);\n  return typeof raw === \"string\" ? raw : \"\";\n}\n\nfunction readOptionalNumber(\n  formData: FormData,\n  key: string,\n): number | string {\n  const raw = readString(formData, key).trim();\n  if (raw === \"\") return raw;\n  const parsed = Number(raw);\n  // Hand the raw string back when the cast is non-numeric; the zod\n  // schema will reject it with `invalid_input` rather than the UI\n  // silently coercing it to NaN.\n  return Number.isFinite(parsed) ? parsed : raw;\n}\n\nexport async function kolRateUpdateAction(\n  _prev: PeekMutationActionState,\n  formData: FormData,\n): Promise<PeekMutationActionState> {\n  return dispatchMutation({\n    actionId: \"kol_rate.update\",\n    rawInput: {\n      userId: readString(formData, \"userId\"),\n      wallet: readString(formData, \"wallet\"),\n      rateBps: readOptionalNumber(formData, \"rateBps\"),\n    },\n    route: \"/growth/kol\",\n  });\n}\n\nexport async function fraudFlagStatusUpdateAction(\n  _prev: PeekMutationActionState,\n  formData: FormData,\n): Promise<PeekMutationActionState> {\n  return dispatchMutation({\n    actionId: \"fraud_flag.status.update\",\n    rawInput: {\n      flagId: readString(formData, \"flagId\"),\n      nextStatus: readString(formData, \"nextStatus\"),\n    },\n    route: \"/operations/dogpile\",\n  });\n}\n\nexport async function dogpileCancelAction(\n  _prev: PeekMutationActionState,\n  formData: FormData,\n): Promise<PeekMutationActionState> {\n  return dispatchMutation({\n    actionId: \"dogpile.cancel\",\n    rawInput: {\n      eventId: readString(formData, \"eventId\"),\n    },\n    route: \"/operations/dogpile\",\n  });\n}\n\nexport async function rewardConfigUpdateAction(\n  _prev: PeekMutationActionState,\n  formData: FormData,\n): Promise<PeekMutationActionState> {\n  // The mutation schema requires the literal `true` for confirm; the\n  // `<input type=\"checkbox\">` posts the literal string \"true\" only when\n  // the box is checked. Anything else (missing key, \"on\", \"false\") is\n  // rejected by the schema as `invalid_input`.\n  const confirmRaw = readString(formData, \"confirm\");\n  return dispatchMutation({\n    actionId: \"reward_config.update\",\n    rawInput: {\n      key: readString(formData, \"key\"),\n      value: readString(formData, \"value\"),\n      confirm: confirmRaw === \"true\" ? true : confirmRaw,\n    },\n    route: \"/economy/rewards\",\n  });\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":137,"cache_read_input_tokens":138273,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":137},"output_tokens":63,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"3fc3c40b-0944-44dd-9202-74a9cef80e25","uuid":"0ff91ad6-4444-4829-9b48-4214c65f7cb9"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CA9A5DqaWQG8VjyhzugPSk","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/server/actions/peek-mutations.ts"}]},"parent_tool_use_id":null,"session_id":"3fc3c40b-0944-44dd-9202-74a9cef80e25","uuid":"018a5dbd-9a3c-4f80-b7c3-47b8c87a8d7d","timestamp":"2026-04-26T19:30:17.180Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/server/actions/peek-mutations.ts","content":"// Next.js Server Actions that wrap the FR-14 mutation runner.\n//\n// These actions are the only client-callable entry point into\n// `runPeekMutation`. Each:\n//   1. Resolves the verified Cloudflare actor via `getPeekActorContext()`\n//      (server-only headers; never trusts browser-supplied identity).\n//   2. Re-runs the runner's role/schema/transaction/audit pipeline so the\n//      `peek.change.applied` / `peek.change.rejected` audit semantics are\n//      identical regardless of whether the call originated from a UI form\n//      or a future direct invocation.\n//   3. Translates the runner's `PeekMutationRunResult` into a\n//      `PeekMutationActionState` that React forms can consume via\n//      `useActionState`. Error reasons (`unauthorized`, `invalid_input`,\n//      `execution_failed`, ...) round-trip so the UI can show\n//      rejection-specific messaging.\n//   4. Calls `revalidatePath` on the source admin route so the page\n//      re-renders the post-mutation database state.\n//\n// Form parsing intentionally lives here (not in the runner): the server\n// action sees a raw `FormData`, coerces named fields into the typed shape\n// the mutation's zod schema expects, and lets the schema decide what\n// passes. Coercion failures (e.g. non-numeric `rateBps`) are surfaced to\n// the runner so the rejection still emits `peek.change.rejected` with\n// `rejectionReason: \"invalid_input\"` — the UI cannot silently drop a\n// failed change.\n\n\"use server\";\n\nimport { revalidatePath } from \"next/cache\";\nimport { headers } from \"next/headers\";\nimport { getPeekActorContext } from \"../access-policy\";\nimport { runPeekMutation } from \"../mutations\";\nimport type {\n  PeekMutationActionId,\n  PeekMutationFailureReason,\n  PeekMutationRunResult,\n} from \"../mutations\";\n\nexport type PeekMutationActionStatus = \"idle\" | \"ok\" | \"error\";\n\nexport type PeekMutationActionState = {\n  status: PeekMutationActionStatus;\n  message: string;\n  reason?: PeekMutationFailureReason | \"no_actor\";\n  fieldErrors?: Record<string, ReadonlyArray<string>>;\n  resourceId?: string | null;\n  // Echoed back so the UI can show a stable \"X.Y was applied\" line even\n  // after the form re-renders; not a security boundary.\n  actionId?: PeekMutationActionId;\n};\n\nexport const PEEK_MUTATION_INITIAL_STATE: PeekMutationActionState = {\n  status: \"idle\",\n  message: \"\",\n};\n\ntype DispatchOptions = {\n  actionId: PeekMutationActionId;\n  rawInput: unknown;\n  route: string;\n};\n\nasync function dispatchMutation(\n  opts: DispatchOptions,\n): Promise<PeekMutationActionState> {\n  const actor = await getPeekActorContext();\n  if (!actor) {\n    return {\n      status: \"error\",\n      message: \"You are not authenticated.\",\n      reason: \"no_actor\",\n      actionId: opts.actionId,\n    };\n  }\n\n  const requestId = (await headers()).get(\"x-request-id\");\n\n  const result: PeekMutationRunResult = await runPeekMutation({\n    actionId: opts.actionId,\n    rawInput: opts.rawInput,\n    actorRole: actor.role,\n    actor: {\n      email: actor.email,\n      route: opts.route,\n      requestId,\n    },\n  });\n\n  if (!result.ok) {\n    return {\n      status: \"error\",\n      message: result.message,\n      reason: result.reason,\n      fieldErrors: result.fieldErrors as\n        | Record<string, ReadonlyArray<string>>\n        | undefined,\n      actionId: opts.actionId,\n    };\n  }\n\n  revalidatePath(opts.route);\n\n  return {\n    status: \"ok\",\n    message: \"Change applied.\",\n    resourceId: result.resourceId,\n    actionId: opts.actionId,\n  };\n}\n\nfunction readString(formData: FormData, key: string): string {\n  const raw = formData.get(key);\n  return typeof raw === \"string\" ? raw : \"\";\n}\n\nfunction readOptionalNumber(\n  formData: FormData,\n  key: string,\n): number | string {\n  const raw = readString(formData, key).trim();\n  if (raw === \"\") return raw;\n  const parsed = Number(raw);\n  // Hand the raw string back when the cast is non-numeric; the zod\n  // schema will reject it with `invalid_input` rather than the UI\n  // silently coercing it to NaN.\n  return Number.isFinite(parsed) ? parsed : raw;\n}\n\nexport async function kolRateUpdateAction(\n  _prev: PeekMutationActionState,\n  formData: FormData,\n): Promise<PeekMutationActionState> {\n  return dispatchMutation({\n    actionId: \"kol_rate.update\",\n    rawInput: {\n      userId: readString(formData, \"userId\"),\n      wallet: readString(formData, \"wallet\"),\n      rateBps: readOptionalNumber(formData, \"rateBps\"),\n    },\n    route: \"/growth/kol\",\n  });\n}\n\nexport async function fraudFlagStatusUpdateAction(\n  _prev: PeekMutationActionState,\n  formData: FormData,\n): Promise<PeekMutationActionState> {\n  return dispatchMutation({\n    actionId: \"fraud_flag.status.update\",\n    rawInput: {\n      flagId: readString(formData, \"flagId\"),\n      nextStatus: readString(formData, \"nextStatus\"),\n    },\n    route: \"/operations/dogpile\",\n  });\n}\n\nexport async function dogpileCancelAction(\n  _prev: PeekMutationActionState,\n  formData: FormData,\n): Promise<PeekMutationActionState> {\n  return dispatchMutation({\n    actionId: \"dogpile.cancel\",\n    rawInput: {\n      eventId: readString(formData, \"eventId\"),\n    },\n    route: \"/operations/dogpile\",\n  });\n}\n\nexport async function rewardConfigUpdateAction(\n  _prev: PeekMutationActionState,\n  formData: FormData,\n): Promise<PeekMutationActionState> {\n  // The mutation schema requires the literal `true` for confirm; the\n  // `<input type=\"checkbox\">` posts the literal string \"true\" only when\n  // the box is checked. Anything else (missing key, \"on\", \"false\") is\n  // rejected by the schema as `invalid_input`.\n  const confirmRaw = readString(formData, \"confirm\");\n  return dispatchMutation({\n    actionId: \"reward_config.update\",\n    rawInput: {\n      key: readString(formData, \"key\"),\n      value: readString(formData, \"value\"),\n      confirm: confirmRaw === \"true\" ? true : confirmRaw,\n    },\n    route: \"/economy/rewards\",\n  });\n}\n","structuredPatch":[],"originalFile":null,"userModified":false}}
