definition (or an \"unknown key\" hint\n// for rows whose key has not been registered), and the last-updated\n// timestamp.\n//\n// FR-14 wiring: when `canEditRewardConfig` is true the table appends an\n// \"Edit value\" column rendering `RewardConfigMutationForm` per row whose\n// `key` is in the FR-14 allowlist (`editableKeys`) and whose\n// `expectedType` is one of the validated value types. Unregistered keys\n// (`expectedType === \"unknown\"`) and keys outside the allowlist render\n// an empty cell so the operator cannot submit a request the engine will\n// reject.\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekRewardConfigExpectedType,\n  PeekRewardConfigRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { RewardConfigMutationForm } from \"./mutations/reward-config-mutation-form\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type RewardConfigTableProps = {\n  rows: ReadonlyArray<PeekRewardConfigRow>;\n  error?: string | null;\n  canEditRewardConfig?: boolean;\n  editableKeys?: ReadonlyArray<string>;\n};\n\nconst TYPE_TONE: Record<PeekRewardConfigExpectedType, PeekStatusTone> = {\n  integer: \"info\",\n  float: \"info\",\n  ratio: \"info\",\n  lamports: \"info\",\n  unknown: \"warning\",\n};\n\nexport function RewardConfigTable({\n  rows,\n  error = null,\n  canEditRewardConfig = false,\n  editableKeys = [],\n}: RewardConfigTableProps) {\n  const editableKeySet = new Set(editableKeys);\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Reward config unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No reward_config rows.</p>\n        <p style={emptyBodyStyle}>\n          The `reward_config` table has not been seeded yet, so no economy\n          parameters can be displayed.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Key</th>\n            <th style={headerCellStyle(\"left\")}>Type</th>\n            <th style={headerCellStyle(\"right\")}>Value</th>\n            <th style={headerCellStyle(\"left\")}>Definition</th>\n            <th style={headerCellStyle(\"left\")}>Updated</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.key} style={bodyRowStyle}>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.key}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.expectedType}\n                  tone={TYPE_TONE[row.expectedType]}\n                />\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.value}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                {row.definition ?? (\n                  <span style={unknownStyle}>\n                    Unregistered key — extend\n                    PEEK_REWARD_CONFIG_KEY_REGISTRY to document this.\n                  </span>\n                )}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.updatedAt}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst unknownStyle: CSSProperties = {\n  color: \"#fde68a\",\n  fontSize: \"0.8125rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","structuredPatch":[{"oldStart":73,"oldLines":34,"newStart":73,"newLines":58,"lines":["             <th style={headerCellStyle(\"right\")}>Value</th>","             <th style={headerCellStyle(\"left\")}>Definition</th>","             <th style={headerCellStyle(\"left\")}>Updated</th>","+            {canEditRewardConfig ? (","+              <th style={headerCellStyle(\"left\")}>Edit value</th>","+            ) : null}","           </tr>","         </thead>","         <tbody>","-          {rows.map((row) => (","-            <tr key={row.key} style={bodyRowStyle}>","-              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>","-                {row.key}","-              </td>","-              <td style={bodyCellStyle(\"left\")}>","-                <StatusChip","-                  label={row.expectedType}","-                  tone={TYPE_TONE[row.expectedType]}","-                />