{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PPJnmMCf9LAEU2Jr6zm6Qr","type":"tool_result","content":"1\t// Export Route Handler (FR-12).\n2\t//\n3\t// Inherits page-level access from the entity's source route per\n4\t// `PEEK_EXPORT_SOURCE_ROUTES`. The handler:\n5\t//   1. Resolves the actor context from the verified Cloudflare email.\n6\t//   2. Refuses unknown entities or entities without a wired source page.\n7\t//   3. Refuses actors that cannot reach the source page under FR-2 policy.\n8\t//   4. Forwards URL search params verbatim as exporter filters; each exporter\n9\t//      picks only the keys it understands so unknown keys are harmless.\n10\t//   5. Delegates to `runPeekExport` which:\n11\t//        - rejects unfiltered exports for entities that require a filter\n12\t//        - blocks production exports when audit logging is not configured\n13\t//        - emits the `peek.export` audit event BEFORE returning data\n14\t//        - surfaces a structured failure when audit emit itself fails\n15\t//   6. Streams CSV bytes with a deterministic filename via `Content-Disposition`.\n16\t\n17\timport { NextResponse, type NextRequest } from \"next/server\";\n18\timport {\n19\t  getPeekActorContext,\n20\t  isRouteAllowedForRole,\n21\t} from \"../../../src/server/access-policy\";\n22\timport {\n23\t  getPeekExporter,\n24\t  getSourceRouteForExportEntity,\n25\t  runPeekExport,\n26\t  serializePeekCsv,\n27\t  type PeekExportFailureReason,\n28\t} from \"../../../src/server/exports\";\n29\timport type {\n30\t  PeekExportEntity,\n31\t} from \"../../../src/lib/types/peek\";\n32\t\n33\texport const dynamic = \"force-dynamic\";\n34\t\n35\tconst KNOWN_ENTITIES: ReadonlyArray<PeekExportEntity> = [\n36\t  \"users\",\n37\t  \"referrers\",\n38\t  \"kol\",\n39\t  \"claims\",\n40\t  \"rounds\",\n41\t  \"transactions\",\n42\t  \"queue\",\n43\t  \"audit\",\n44\t];\n45\t\n46\tfunction isKnownEntity(value: string): value is PeekExportEntity {\n47\t  return (KNOWN_ENTITIES as ReadonlyArray<string>).includes(value);\n48\t}\n49\t\n50\tfunction statusForFailure(reason: PeekExportFailureReason): number {\n51\t  switch (reason) {\n52\t    case \"unknown_entity\":\n53\t      return 404;\n54\t    case \"no_filters\":\n55\t      return 400;\n56\t    case \"audit_unavailable\":\n57\t      return 503;\n58\t    case \"audit_emit_failed\":\n59\t      return 502;\n60\t    default:\n61\t      return 500;\n62\t  }\n63\t}\n64\t\n65\texport async function GET(\n66\t  request: NextRequest,\n67\t  context: { params: Promise<{ entity: string }> },\n68\t): Promise<Response> {\n69\t  const { entity } = await context.params;\n70\t\n71\t  if (!isKnownEntity(entity)) {\n72\t    return new NextResponse(\"Unknown export entity\", { status: 404 });\n73\t  }\n74\t\n75\t  if (!getPeekExporter(entity)) {\n76\t    return new NextResponse(\"Unknown export entity\", { status: 404 });\n77\t  }\n78\t\n79\t  const sourceRoute = getSourceRouteForExportEntity(entity);\n80\t  if (!sourceRoute) {\n81\t    return new NextResponse(\"Export entity has no source page\", {\n82\t      status: 404,\n83\t    });\n84\t  }\n85\t\n86\t  const actor = await getPeekActorContext();\n87\t  if (!actor) {\n88\t    return new NextResponse(\"Forbidden\", { status: 403 });\n89\t  }\n90\t\n91\t  if (!isRouteAllowedForRole(sourceRoute, actor.role)) {\n92\t    return new NextResponse(\"Forbidden\", { status: 403 });\n93\t  }\n94\t\n95\t  const filters: Record<string, string | null> = {};\n96\t  for (const [key, value] of request.nextUrl.searchParams) {\n97\t    if (filters[key] === undefined) {\n98\t      filters[key] = value;\n99\t    }\n100\t  }\n101\t\n102\t  const result = await runPeekExport({\n103\t    entity,\n104\t    filters,\n105\t    actor: {\n106\t      email: actor.email,\n107\t      route: sourceRoute,\n108\t      requestId: request.headers.get(\"x-request-id\"),\n109\t    },\n110\t  });\n111\t\n112\t  if (!result.ok) {\n113\t    return new NextResponse(result.message, {\n114\t      status: statusForFailure(result.reason),\n115\t    });\n116\t  }\n117\t\n118\t  const csv = serializePeekCsv(result.result.columns, result.result.rows);\n119\t\n120\t  return new NextResponse(csv, {\n121\t    status: 200,\n122\t    headers: {\n123\t      \"Content-Type\": \"text/csv; charset=utf-8\",\n124\t      \"Content-Disposition\": `attachment; filename=\"${result.result.filename}\"`,\n125\t      \"Cache-Control\": \"no-store\",\n126\t    },\n127\t  });\n128\t}\n129\t"}]},"parent_tool_use_id":null,"session_id":"3fc3c40b-0944-44dd-9202-74a9cef80e25","uuid":"001a2a54-4d83-409d-9758-0b7500795e25","timestamp":"2026-04-26T19:26:01.675Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/app/exports/[entity]/route.ts","content":"// Export Route Handler (FR-12).\n//\n// Inherits page-level access from the entity's source route per\n// `PEEK_EXPORT_SOURCE_ROUTES`. The handler:\n//   1. Resolves the actor context from the verified Cloudflare email.\n//   2. Refuses unknown entities or entities without a wired source page.\n//   3. Refuses actors that cannot reach the source page under FR-2 policy.\n//   4. Forwards URL search params verbatim as exporter filters; each exporter\n//      picks only the keys it understands so unknown keys are harmless.\n//   5. Delegates to `runPeekExport` which:\n//        - rejects unfiltered exports for entities that require a filter\n//        - blocks production exports when audit logging is not configured\n//        - emits the `peek.export` audit event BEFORE returning data\n//        - surfaces a structured failure when audit emit itself fails\n//   6. Streams CSV bytes with a deterministic filename via `Content-Disposition`.\n\nimport { NextResponse, type NextRequest } from \"next/server\";\nimport {\n  getPeekActorContext,\n  isRouteAllowedForRole,\n} from \"../../../src/server/access-policy\";\nimport {\n  getPeekExporter,\n  getSourceRouteForExportEntity,\n  runPeekExport,\n  serializePeekCsv,\n  type PeekExportFailureReason,\n} from \"../../../src/server/exports\";\nimport type {\n  PeekExportEntity,\n} from \"../../../src/lib/types/peek\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst KNOWN_ENTITIES: ReadonlyArray<PeekExportEntity> = [\n  \"users\",\n  \"referrers\",\n  \"kol\",\n  \"claims\",\n  \"rounds\",\n  \"transactions\",\n  \"queue\",\n  \"audit\",\n];\n\nfunction isKnownEntity(value: string): value is PeekExportEntity {\n  return (KNOWN_ENTITIES as ReadonlyArray<string>).includes(value);\n}\n\nfunction statusForFailure(reason: PeekExportFailureReason): number {\n  switch (reason) {\n    case \"unknown_entity\":\n      return 404;\n    case \"no_filters\":\n      return 400;\n    case \"audit_unavailable\":\n      return 503;\n    case \"audit_emit_failed\":\n      return 502;\n    default:\n      return 500;\n  }\n}\n\nexport async function GET(\n  request: NextRequest,\n  context: { params: Promise<{ entity: string }> },\n): Promise<Response> {\n  const { entity } = await context.params;\n\n  if (!isKnownEntity(entity)) {\n    return new NextResponse(\"Unknown export entity\", { status: 404 });\n  }\n\n  if (!getPeekExporter(entity)) {\n    return new NextResponse(\"Unknown export entity\", { status: 404 });\n  }\n\n  const sourceRoute = getSourceRouteForExportEntity(entity);\n  if (!sourceRoute) {\n    return new NextResponse(\"Export entity has no source page\", {\n      status: 404,\n    });\n  }\n\n  const actor = await getPeekActorContext();\n  if (!actor) {\n    return new NextResponse(\"Forbidden\", { status: 403 });\n  }\n\n  if (!isRouteAllowedForRole(sourceRoute, actor.role)) {\n    return new NextResponse(\"Forbidden\", { status: 403 });\n  }\n\n  const filters: Record<string, string | null> = {};\n  for (const [key, value] of request.nextUrl.searchParams) {\n    if (filters[key] === undefined) {\n      filters[key] = value;\n    }\n  }\n\n  const result = await runPeekExport({\n    entity,\n    filters,\n    actor: {\n      email: actor.email,\n      route: sourceRoute,\n      requestId: request.headers.get(\"x-request-id\"),\n    },\n  });\n\n  if (!result.ok) {\n    return new NextResponse(result.message, {\n      status: statusForFailure(result.reason),\n    });\n  }\n\n  const csv = serializePeekCsv(result.result.columns, result.result.rows);\n\n  return new NextResponse(csv, {\n    status: 200,\n    headers: {\n      \"Content-Type\": \"text/csv; charset=utf-8\",\n      \"Content-Disposition\": `attachment; filename=\"${result.result.filename}\"`,\n      \"Cache-Control\": \"no-store\",\n    },\n  });\n}\n","numLines":129,"startLine":1,"totalLines":129}}}
