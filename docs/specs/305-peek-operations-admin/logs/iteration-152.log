sitions allowed by the FR-14 matrix; rows whose\n// current status has no allowed next status render an empty cell.\nimport Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekFraudFlagListRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { FraudFlagMutationForm } from \"./mutations/fraud-flag-mutation-form\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type FraudFlagsTableProps = {\n  rows: ReadonlyArray<PeekFraudFlagListRow>;\n  error?: string | null;\n  canTransitionFraudFlag?: boolean;\n};\n\nexport function FraudFlagsTable({\n  rows,\n  error = null,\n  canTransitionFraudFlag = false,\n}: FraudFlagsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Fraud flags unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>\n          No fraud_flags rows match these filters.\n        </p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see open, reviewed, and\n          dismissed flags.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Status</th>\n            <th style={headerCellStyle(\"left\")}>Flag type</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"left\")}>Related</th>\n            <th style={headerCellStyle(\"left\")}>Details</th>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>Resolved</th>\n            <th style={headerCellStyle(\"left\")}>ID</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.status}\n                  tone={fraudStatusTone(row.status)}\n                />\n              </td>\n              <td\n                style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n              >\n                {row.flagType}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <Link href={`/users/${row.userId}`} style={linkStyle}>\n                  {row.username ?? row.userId}\n                </Link>\n                {row.username ? (\n                  <div style={subValueStyle}>{row.userId}</div>\n                ) : null}\n              </td>\n              <td\n                style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n              >\n                {row.wallet ?? \"—\"}\n              </td>\n              <td\n                style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n              >\n                {row.relatedId ?? \"—\"}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                {row.details ? (\n                  <pre style={detailsStyle}>\n                    {JSON.stringify(row.details, null, 2)}\n                  </pre>\n                ) : (\n                  \"—\"\n                )}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>{row.resolvedAt ?? \"—\"}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.id}\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction fraudStatusTone(value: string): PeekStatusTone {\n  if (value === \"open\") return \"warning\";\n  if (value === \"reviewed\") return \"info\";\n  if (value === \"dismissed\") return \"neutral\";\n  return \"neutral\";\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n};\n\nconst detailsStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.5rem\",\n  borderRadius: \"0.5rem\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  fontSize: \"0.75rem\",\n  fontFamily: \"monospace\",\n  whiteSpace: \"pre-wrap\",\n  wordBreak: \"break-word\",\n  maxWidth: \"24rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","structuredPatch":[{"oldStart":65,"oldLines":6,"newStart":65,"newLines":9,"lines":["             <th style={headerCellStyle(\"left\")}>Created</th>","             <th style={headerCellStyle(\"left\")}>Resolved</th>","             <th style={headerCellStyle(\"left\")}>ID</th>","+            {canTransitionFraudFlag ? (","+              <th style={headerCellStyle(\"left\")}>Transition</th>","+            ) : null}","           </tr>","         </thead>","         <tbody>"]}],"userModified":false,"replaceAll":false}}
