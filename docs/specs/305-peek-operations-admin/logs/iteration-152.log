{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SxUNBdySjn1N71yXdnx39A","type":"tool_result","content":"1\t// Fraud flags review table for /operations/dogpile (FR-9).\n2\t//\n3\t// Read-only review queue over `PeekFraudFlagListRow` so an operator can scan\n4\t// open flags, jump to the user-detail page, and inspect the JSONB `details`\n5\t// payload verbatim. Status drives the chip tone (open = warning, reviewed =\n6\t// info, dismissed = neutral). Status transitions live behind the FR-14\n7\t// `fraud_flag.status.update` mutation action id (not yet implemented).\n8\timport Link from \"next/link\";\n9\timport type { CSSProperties } from \"react\";\n10\timport type {\n11\t  PeekFraudFlagListRow,\n12\t  PeekStatusTone,\n13\t} from \"../lib/types/peek\";\n14\timport { StatusChip } from \"./status-chip\";\n15\t\n16\texport type FraudFlagsTableProps = {\n17\t  rows: ReadonlyArray<PeekFraudFlagListRow>;\n18\t  error?: string | null;\n19\t};\n20\t\n21\texport function FraudFlagsTable({ rows, error = null }: FraudFlagsTableProps) {\n22\t  if (error) {\n23\t    return (\n24\t      <div role=\"alert\" style={errorStyle}>\n25\t        Fraud flags unavailable: {error}\n26\t      </div>\n27\t    );\n28\t  }\n29\t\n30\t  if (rows.length === 0) {\n31\t    return (\n32\t      <div role=\"status\" style={emptyStyle}>\n33\t        <p style={emptyTitleStyle}>\n34\t          No fraud_flags rows match these filters.\n35\t        </p>\n36\t        <p style={emptyBodyStyle}>\n37\t          Adjust the filters above or clear them to see open, reviewed, and\n38\t          dismissed flags.\n39\t        </p>\n40\t      </div>\n41\t    );\n42\t  }\n43\t\n44\t  return (\n45\t    <div style={wrapperStyle}>\n46\t      <table style={tableStyle}>\n47\t        <thead>\n48\t          <tr style={headerRowStyle}>\n49\t            <th style={headerCellStyle(\"left\")}>Status</th>\n50\t            <th style={headerCellStyle(\"left\")}>Flag type</th>\n51\t            <th style={headerCellStyle(\"left\")}>User</th>\n52\t            <th style={headerCellStyle(\"left\")}>Wallet</th>\n53\t            <th style={headerCellStyle(\"left\")}>Related</th>\n54\t            <th style={headerCellStyle(\"left\")}>Details</th>\n55\t            <th style={headerCellStyle(\"left\")}>Created</th>\n56\t            <th style={headerCellStyle(\"left\")}>Resolved</th>\n57\t            <th style={headerCellStyle(\"left\")}>ID</th>\n58\t          </tr>\n59\t        </thead>\n60\t        <tbody>\n61\t          {rows.map((row) => (\n62\t            <tr key={row.id} style={bodyRowStyle}>\n63\t              <td style={bodyCellStyle(\"left\")}>\n64\t                <StatusChip\n65\t                  label={row.status}\n66\t                  tone={fraudStatusTone(row.status)}\n67\t                />\n68\t              </td>\n69\t              <td\n70\t                style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n71\t              >\n72\t                {row.flagType}\n73\t              </td>\n74\t              <td style={bodyCellStyle(\"left\")}>\n75\t                <Link href={`/users/${row.userId}`} style={linkStyle}>\n76\t                  {row.username ?? row.userId}\n77\t                </Link>\n78\t                {row.username ? (\n79\t                  <div style={subValueStyle}>{row.userId}</div>\n80\t                ) : null}\n81\t              </td>\n82\t              <td\n83\t                style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n84\t              >\n85\t                {row.wallet ?? \"—\"}\n86\t              </td>\n87\t              <td\n88\t                style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n89\t              >\n90\t                {row.relatedId ?? \"—\"}\n91\t              </td>\n92\t              <td style={bodyCellStyle(\"left\")}>\n93\t                {row.details ? (\n94\t                  <pre style={detailsStyle}>\n95\t                    {JSON.stringify(row.details, null, 2)}\n96\t                  </pre>\n97\t                ) : (\n98\t                  \"—\"\n99\t                )}\n100\t              </td>\n101\t              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n102\t              <td style={bodyCellStyle(\"left\")}>{row.resolvedAt ?? \"—\"}</td>\n103\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n104\t                {row.id}\n105\t              </td>\n106\t            </tr>\n107\t          ))}\n108\t        </tbody>\n109\t      </table>\n110\t    </div>\n111\t  );\n112\t}\n113\t\n114\tfunction fraudStatusTone(value: string): PeekStatusTone {\n115\t  if (value === \"open\") return \"warning\";\n116\t  if (value === \"reviewed\") return \"info\";\n117\t  if (value === \"dismissed\") return \"neutral\";\n118\t  return \"neutral\";\n119\t}\n120\t\n121\tconst wrapperStyle: CSSProperties = {\n122\t  overflowX: \"auto\",\n123\t  border: \"1px solid #1e293b\",\n124\t  borderRadius: \"0.75rem\",\n125\t};\n126\t\n127\tconst tableStyle: CSSProperties = {\n128\t  width: \"100%\",\n129\t  borderCollapse: \"collapse\",\n130\t};\n131\t\n132\tconst headerRowStyle: CSSProperties = {\n133\t  background: \"#111827\",\n134\t  color: \"#94a3b8\",\n135\t};\n136\t\n137\tconst bodyRowStyle: CSSProperties = {\n138\t  borderTop: \"1px solid #1e293b\",\n139\t};\n140\t\n141\tconst linkStyle: CSSProperties = {\n142\t  color: \"#93c5fd\",\n143\t  textDecoration: \"none\",\n144\t};\n145\t\n146\tconst subValueStyle: CSSProperties = {\n147\t  color: \"#64748b\",\n148\t  fontSize: \"0.75rem\",\n149\t};\n150\t\n151\tconst detailsStyle: CSSProperties = {\n152\t  margin: 0,\n153\t  padding: \"0.5rem\",\n154\t  borderRadius: \"0.5rem\",\n155\t  background: \"#0b1220\",\n156\t  color: \"#cbd5f5\",\n157\t  fontSize: \"0.75rem\",\n158\t  fontFamily: \"monospace\",\n159\t  whiteSpace: \"pre-wrap\",\n160\t  wordBreak: \"break-word\",\n161\t  maxWidth: \"24rem\",\n162\t};\n163\t\n164\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n165\t  return {\n166\t    padding: \"0.75rem\",\n167\t    textAlign: align,\n168\t    fontSize: \"0.875rem\",\n169\t    fontWeight: 600,\n170\t  };\n171\t}\n172\t\n173\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n174\t  return {\n175\t    padding: \"0.75rem\",\n176\t    textAlign: align,\n177\t    fontSize: \"0.875rem\",\n178\t    color: \"#e2e8f0\",\n179\t    verticalAlign: \"top\",\n180\t  };\n181\t}\n182\t\n183\tconst errorStyle: CSSProperties = {\n184\t  margin: 0,\n185\t  padding: \"0.75rem 1rem\",\n186\t  borderRadius: \"0.75rem\",\n187\t  background: \"#3f1d1d\",\n188\t  color: \"#fecaca\",\n189\t};\n190\t\n191\tconst emptyStyle: CSSProperties = {\n192\t  padding: \"1.5rem\",\n193\t  borderRadius: \"0.75rem\",\n194\t  border: \"1px dashed #334155\",\n195\t  background: \"#0b1220\",\n196\t  color: \"#cbd5f5\",\n197\t  display: \"grid\",\n198\t  gap: \"0.5rem\",\n199\t};\n200\t\n201\tconst emptyTitleStyle: CSSProperties = {\n202\t  margin: 0,\n203\t  fontSize: \"1rem\",\n204\t  fontWeight: 600,\n205\t};\n206\t\n207\tconst emptyBodyStyle: CSSProperties = {\n208\t  margin: 0,\n209\t  fontSize: \"0.875rem\",\n210\t  color: \"#94a3b8\",\n211\t};\n212\t"}]},"parent_tool_use_id":null,"session_id":"3fc3c40b-0944-44dd-9202-74a9cef80e25","uuid":"6e69e976-c38b-4c5c-971d-4d86f530b8e0","timestamp":"2026-04-26T19:27:31.109Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/fraud-flags-table.tsx","content":"// Fraud flags review table for /operations/dogpile (FR-9).\n//\n// Read-only review queue over `PeekFraudFlagListRow` so an operator can scan\n// open flags, jump to the user-detail page, and inspect the JSONB `details`\n// payload verbatim. Status drives the chip tone (open = warning, reviewed =\n// info, dismissed = neutral). Status transitions live behind the FR-14\n// `fraud_flag.status.update` mutation action id (not yet implemented).\nimport Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekFraudFlagListRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type FraudFlagsTableProps = {\n  rows: ReadonlyArray<PeekFraudFlagListRow>;\n  error?: string | null;\n};\n\nexport function FraudFlagsTable({ rows, error = null }: FraudFlagsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Fraud flags unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>\n          No fraud_flags rows match these filters.\n        </p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see open, reviewed, and\n          dismissed flags.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Status</th>\n            <th style={headerCellStyle(\"left\")}>Flag type</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"left\")}>Related</th>\n            <th style={headerCellStyle(\"left\")}>Details</th>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>Resolved</th>\n            <th style={headerCellStyle(\"left\")}>ID</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.status}\n                  tone={fraudStatusTone(row.status)}\n                />\n              </td>\n              <td\n                style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n              >\n                {row.flagType}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <Link href={`/users/${row.userId}`} style={linkStyle}>\n                  {row.username ?? row.userId}\n                </Link>\n                {row.username ? (\n                  <div style={subValueStyle}>{row.userId}</div>\n                ) : null}\n              </td>\n              <td\n                style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n              >\n                {row.wallet ?? \"—\"}\n              </td>\n              <td\n                style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n              >\n                {row.relatedId ?? \"—\"}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                {row.details ? (\n                  <pre style={detailsStyle}>\n                    {JSON.stringify(row.details, null, 2)}\n                  </pre>\n                ) : (\n                  \"—\"\n                )}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>{row.resolvedAt ?? \"—\"}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.id}\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction fraudStatusTone(value: string): PeekStatusTone {\n  if (value === \"open\") return \"warning\";\n  if (value === \"reviewed\") return \"info\";\n  if (value === \"dismissed\") return \"neutral\";\n  return \"neutral\";\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n};\n\nconst detailsStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.5rem\",\n  borderRadius: \"0.5rem\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  fontSize: \"0.75rem\",\n  fontFamily: \"monospace\",\n  whiteSpace: \"pre-wrap\",\n  wordBreak: \"break-word\",\n  maxWidth: \"24rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":212,"startLine":1,"totalLines":212}}}
