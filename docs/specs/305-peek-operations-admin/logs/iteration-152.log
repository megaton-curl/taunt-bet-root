{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U1RKRY46Zk7nJfsbhbg79W","type":"tool_result","content":"1\t// KOL performance table for /growth/kol (FR-7).\n2\t//\n3\t// Reads `referral_kol_rates` joined with linked performance from\n4\t// `referral_links` + `referral_earnings`. Drill-down per row to user-detail.\n5\timport Link from \"next/link\";\n6\timport type { CSSProperties } from \"react\";\n7\timport type { PeekKolPerformanceRow } from \"../lib/types/peek\";\n8\t\n9\texport type GrowthKolTableProps = {\n10\t  rows: ReadonlyArray<PeekKolPerformanceRow>;\n11\t  error?: string | null;\n12\t};\n13\t\n14\texport function GrowthKolTable({ rows, error = null }: GrowthKolTableProps) {\n15\t  if (error) {\n16\t    return (\n17\t      <div role=\"alert\" style={errorStyle}>\n18\t        KOL table unavailable: {error}\n19\t      </div>\n20\t    );\n21\t  }\n22\t\n23\t  if (rows.length === 0) {\n24\t    return (\n25\t      <div role=\"status\" style={emptyStyle}>\n26\t        <p style={emptyTitleStyle}>No KOL rates configured.</p>\n27\t        <p style={emptyBodyStyle}>\n28\t          No rows in `referral_kol_rates` — KOL pricing has not been applied\n29\t          to any user yet.\n30\t        </p>\n31\t      </div>\n32\t    );\n33\t  }\n34\t\n35\t  return (\n36\t    <div style={wrapperStyle}>\n37\t      <table style={tableStyle}>\n38\t        <thead>\n39\t          <tr style={headerRowStyle}>\n40\t            <th style={headerCellStyle(\"left\")}>User</th>\n41\t            <th style={headerCellStyle(\"left\")}>Wallet</th>\n42\t            <th style={headerCellStyle(\"right\")}>Rate (bps)</th>\n43\t            <th style={headerCellStyle(\"left\")}>Set by</th>\n44\t            <th style={headerCellStyle(\"left\")}>Created</th>\n45\t            <th style={headerCellStyle(\"left\")}>Updated</th>\n46\t            <th style={headerCellStyle(\"right\")}>Referees</th>\n47\t            <th style={headerCellStyle(\"right\")}>Wager (lamports)</th>\n48\t            <th style={headerCellStyle(\"right\")}>Earned (lamports)</th>\n49\t          </tr>\n50\t        </thead>\n51\t        <tbody>\n52\t          {rows.map((row) => (\n53\t            <tr key={row.userId} style={bodyRowStyle}>\n54\t              <td style={bodyCellStyle(\"left\")}>\n55\t                <Link href={`/users/${row.userId}`} style={linkStyle}>\n56\t                  {row.username ?? row.userId}\n57\t                </Link>\n58\t                {row.username ? (\n59\t                  <span style={subValueStyle}> · {row.userId}</span>\n60\t                ) : null}\n61\t              </td>\n62\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n63\t                {row.wallet}\n64\t              </td>\n65\t              <td style={bodyCellStyle(\"right\")}>{row.rateBps}</td>\n66\t              <td style={bodyCellStyle(\"left\")}>{row.setBy}</td>\n67\t              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n68\t              <td style={bodyCellStyle(\"left\")}>{row.updatedAt}</td>\n69\t              <td style={bodyCellStyle(\"right\")}>{row.refereeCount}</td>\n70\t              <td style={bodyCellStyle(\"right\")}>\n71\t                {formatLamports(row.referredWagerLamports)}\n72\t              </td>\n73\t              <td style={bodyCellStyle(\"right\")}>\n74\t                {formatLamports(row.referrerEarnedLamports)}\n75\t              </td>\n76\t            </tr>\n77\t          ))}\n78\t        </tbody>\n79\t      </table>\n80\t    </div>\n81\t  );\n82\t}\n83\t\n84\tfunction formatLamports(value: string): string {\n85\t  if (!value || value === \"0\") return \"0\";\n86\t  const negative = value.startsWith(\"-\");\n87\t  const digits = negative ? value.slice(1) : value;\n88\t  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n89\t  return negative ? `-${grouped}` : grouped;\n90\t}\n91\t\n92\tconst wrapperStyle: CSSProperties = {\n93\t  overflowX: \"auto\",\n94\t  border: \"1px solid #1e293b\",\n95\t  borderRadius: \"0.75rem\",\n96\t};\n97\t\n98\tconst tableStyle: CSSProperties = {\n99\t  width: \"100%\",\n100\t  borderCollapse: \"collapse\",\n101\t};\n102\t\n103\tconst headerRowStyle: CSSProperties = {\n104\t  background: \"#111827\",\n105\t  color: \"#94a3b8\",\n106\t};\n107\t\n108\tconst bodyRowStyle: CSSProperties = {\n109\t  borderTop: \"1px solid #1e293b\",\n110\t};\n111\t\n112\tconst linkStyle: CSSProperties = {\n113\t  color: \"#93c5fd\",\n114\t  textDecoration: \"none\",\n115\t};\n116\t\n117\tconst subValueStyle: CSSProperties = {\n118\t  color: \"#64748b\",\n119\t  fontSize: \"0.75rem\",\n120\t  marginLeft: \"0.25rem\",\n121\t};\n122\t\n123\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n124\t  return {\n125\t    padding: \"0.75rem\",\n126\t    textAlign: align,\n127\t    fontSize: \"0.875rem\",\n128\t    fontWeight: 600,\n129\t  };\n130\t}\n131\t\n132\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n133\t  return {\n134\t    padding: \"0.75rem\",\n135\t    textAlign: align,\n136\t    fontSize: \"0.875rem\",\n137\t  };\n138\t}\n139\t\n140\tconst errorStyle: CSSProperties = {\n141\t  margin: 0,\n142\t  padding: \"0.75rem 1rem\",\n143\t  borderRadius: \"0.75rem\",\n144\t  background: \"#3f1d1d\",\n145\t  color: \"#fecaca\",\n146\t};\n147\t\n148\tconst emptyStyle: CSSProperties = {\n149\t  padding: \"1.5rem\",\n150\t  borderRadius: \"0.75rem\",\n151\t  border: \"1px dashed #334155\",\n152\t  background: \"#0b1220\",\n153\t  color: \"#cbd5f5\",\n154\t  display: \"grid\",\n155\t  gap: \"0.5rem\",\n156\t};\n157\t\n158\tconst emptyTitleStyle: CSSProperties = {\n159\t  margin: 0,\n160\t  fontSize: \"1rem\",\n161\t  fontWeight: 600,\n162\t};\n163\t\n164\tconst emptyBodyStyle: CSSProperties = {\n165\t  margin: 0,\n166\t  fontSize: \"0.875rem\",\n167\t  color: \"#94a3b8\",\n168\t};\n169\t"}]},"parent_tool_use_id":null,"session_id":"3fc3c40b-0944-44dd-9202-74a9cef80e25","uuid":"1be28853-23f3-4f7b-9f7e-db169eae7506","timestamp":"2026-04-26T19:25:43.492Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/growth-kol-table.tsx","content":"// KOL performance table for /growth/kol (FR-7).\n//\n// Reads `referral_kol_rates` joined with linked performance from\n// `referral_links` + `referral_earnings`. Drill-down per row to user-detail.\nimport Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type { PeekKolPerformanceRow } from \"../lib/types/peek\";\n\nexport type GrowthKolTableProps = {\n  rows: ReadonlyArray<PeekKolPerformanceRow>;\n  error?: string | null;\n};\n\nexport function GrowthKolTable({ rows, error = null }: GrowthKolTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        KOL table unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No KOL rates configured.</p>\n        <p style={emptyBodyStyle}>\n          No rows in `referral_kol_rates` — KOL pricing has not been applied\n          to any user yet.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"right\")}>Rate (bps)</th>\n            <th style={headerCellStyle(\"left\")}>Set by</th>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>Updated</th>\n            <th style={headerCellStyle(\"right\")}>Referees</th>\n            <th style={headerCellStyle(\"right\")}>Wager (lamports)</th>\n            <th style={headerCellStyle(\"right\")}>Earned (lamports)</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.userId} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>\n                <Link href={`/users/${row.userId}`} style={linkStyle}>\n                  {row.username ?? row.userId}\n                </Link>\n                {row.username ? (\n                  <span style={subValueStyle}> · {row.userId}</span>\n                ) : null}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.wallet}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>{row.rateBps}</td>\n              <td style={bodyCellStyle(\"left\")}>{row.setBy}</td>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>{row.updatedAt}</td>\n              <td style={bodyCellStyle(\"right\")}>{row.refereeCount}</td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatLamports(row.referredWagerLamports)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatLamports(row.referrerEarnedLamports)}\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction formatLamports(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n  marginLeft: \"0.25rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":169,"startLine":1,"totalLines":169}}}
