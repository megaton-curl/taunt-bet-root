    </p>\n    );\n  }\n\n  const reasonHint = describeFailure(state);\n  const fieldErrorEntries: ReadonlyArray<readonly [string, ReadonlyArray<string>]> =\n    state.fieldErrors\n      ? Object.entries(state.fieldErrors).map(\n          ([k, v]) => [k, v] as const,\n        )\n      : [];\n\n  return (\n    <div role=\"alert\" style={errorStyle}>\n      <p style={errorTitleStyle}>✗ {reasonHint}</p>\n      <p style={errorBodyStyle}>{state.message}</p>\n      {fieldErrorEntries.length > 0 ? (\n        <ul style={errorListStyle}>\n          {fieldErrorEntries.map(([field, errors]) => (\n            <li key={field}>\n              <span style={errorFieldStyle}>{field}:</span>{\" \"}\n              {errors.join(\"; \")}\n            </li>\n          ))}\n        </ul>\n      ) : null}\n    </div>\n  );\n}\n\nfunction describeFailure(state: PeekMutationActionState): string {\n  switch (state.reason) {\n    case \"no_actor\":\n      return \"Not authenticated.\";\n    case \"unauthorized\":\n      return \"You are not authorized to perform this action.\";\n    case \"invalid_input\":\n      return \"The submitted values are invalid.\";\n    case \"execution_failed\":\n      return \"The change could not be applied.\";\n    case \"unknown_action\":\n      return \"Unknown mutation action.\";\n    case \"audit_emit_failed\":\n      return \"Audit logging failed; the change was rolled back.\";\n    default:\n      return \"Mutation failed.\";\n  }\n}\n\nconst successStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.5rem 0.75rem\",\n  borderRadius: \"0.5rem\",\n  background: \"#0c2818\",\n  color: \"#86efac\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.5rem 0.75rem\",\n  borderRadius: \"0.5rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst errorTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  fontWeight: 600,\n};\n\nconst errorBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.8125rem\",\n  color: \"#fcd9d9\",\n};\n\nconst errorListStyle: CSSProperties = {\n  margin: 0,\n  paddingLeft: \"1rem\",\n  fontSize: \"0.75rem\",\n  color: \"#fbcfe8\",\n};\n\nconst errorFieldStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  color: \"#fda4af\",\n};\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01SMH6pDMGjWRWbEDiNkNL3X","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01HNgc8tm9t8FujMk6xND6Wc","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/mutations/kol-rate-mutation-form.tsx","content":"// FR-14 mutation form: create or update a KOL rate row.\n//\n// Rendered inline in `growth-kol-table.tsx` for actors whose role passes\n// the `kol_rate.update` action rule (business or admin). Two editable\n// fields (wallet, rateBps) are pre-populated from the existing row so\n// the operator sees the old/new pair before submission. Submission goes\n// through the `kolRateUpdateAction` server action which re-runs the\n// FR-2 role check and FR-14 audit pipeline; rejection feedback is\n// rendered via `MutationFeedback`.\n\n\"use client\";\n\nimport type { CSSProperties } from \"react\";\nimport { useActionState, useId } from \"react\";\nimport {\n  PEEK_MUTATION_INITIAL_STATE,\n  kolRateUpdateAction,\n} from \"../../server/actions/peek-mutations\";\nimport { MutationFeedback } from \"./mutation-feedback\";\n\nexport type KolRateMutationFormProps = {\n  userId: string;\n  walletCurrent: string;\n  rateBpsCurrent: number;\n};\n\nexport function KolRateMutationForm({\n  userId,\n  walletCurrent,\n  rateBpsCurrent,\n}: KolRateMutationFormProps) {\n  const [state, dispatch, pending] = useActionState(\n    kolRateUpdateAction,\n    PEEK_MUTATION_INITIAL_STATE,\n  );\n  const walletId = useId();\n  const rateId = useId();\n\n  return (\n    <form action={dispatch} style={formStyle} aria-label=\"Update KOL rate\">\n      <input type=\"hidden\" name=\"userId\" value={userId} />\n\n      <div style={fieldRowStyle}>\n        <label htmlFor={walletId} style={labelStyle}>\n          Wallet\n        </label>\n        <div style={oldValueStyle}>old: {walletCurrent}</div>\n        <input\n          id={walletId}\n          name=\"wallet\"\n          type=\"text\"\n          defaultValue={walletCurrent}\n          required\n          style={inputStyle}\n          autoComplete=\"off\"\n          spellCheck={false}\n        />\n      </div>\n\n      <div style={fieldRowStyle}>\n        <label htmlFor={rateId} style={labelStyle}>\n          Rate (bps)\n        </label>\n        <div style={oldValueStyle}>old: {rateBpsCurrent}</div>\n        <input\n          id={rateId}\n          name=\"rateBps\"\n          type=\"number\"\n          min={0}\n          max={10000}\n          step={1}\n          defaultValue={rateBpsCurrent}\n          required\n          style={inputStyle}\n        />\n      </div>\n\n      <button type=\"submit\" disabled={pending} style={submitStyle}>\n        {pending ? \"Applying…\" : \"Apply rate change\"}\n      </button>\n\n      <MutationFeedback state={state} successLabel=\"KOL rate updated.\" />\n    </form>\n  );\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst fieldRowStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst labelStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n  color: \"#94a3b8\",\n};\n\nconst oldValueStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  color: \"#64748b\",\n  fontFamily: \"monospace\",\n};\n\nconst inputStyle: CSSProperties = {\n  padding: \"0.375rem 0.5rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #334155\",\n  background: \"#0f172a\",\n  color: \"#e2e8f0\",\n  fontSize: \"0.8125rem\",\n  fontFamily: \"monospace\",\n};\n\nconst submitStyle: CSSProperties = {\n  padding: \"0.375rem 0.75rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #1e3a8a\",\n  background: \"#1e40af\",\n  color: \"#dbeafe\",\n  fontSize: \"0.8125rem\",\n  fontWeight: 600,\n  cursor: \"pointer\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1857,"cache_read_input_tokens":140899,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1857},"output_tokens":62,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"3fc3c40b-0944-44dd-9202-74a9cef80e25","uuid":"27f52a46-daf2-4b3b-9ff1-eb5137acc369"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HNgc8tm9t8FujMk6xND6Wc","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/components/mutations/kol-rate-mutation-form.tsx"}]},"parent_tool_use_id":null,"session_id":"3fc3c40b-0944-44dd-9202-74a9cef80e25","uuid":"5d4ea5b7-5359-4ee2-af7c-d1c7f9b8b832","timestamp":"2026-04-26T19:30:54.608Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/components/mutations/kol-rate-mutation-form.tsx","content":"// FR-14 mutation form: create or update a KOL rate row.\n//\n// Rendered inline in `growth-kol-table.tsx` for actors whose role passes\n// the `kol_rate.update` action rule (business or admin). Two editable\n// fields (wallet, rateBps) are pre-populated from the existing row so\n// the operator sees the old/new pair before submission. Submission goes\n// through the `kolRateUpdateAction` server action which re-runs the\n// FR-2 role check and FR-14 audit pipeline; rejection feedback is\n// rendered via `MutationFeedback`.\n\n\"use client\";\n\nimport type { CSSProperties } from \"react\";\nimport { useActionState, useId } from \"react\";\nimport {\n  PEEK_MUTATION_INITIAL_STATE,\n  kolRateUpdateAction,\n} from \"../../server/actions/peek-mutations\";\nimport { MutationFeedback } from \"./mutation-feedback\";\n\nexport type KolRateMutationFormProps = {\n  userId: string;\n  walletCurrent: string;\n  rateBpsCurrent: number;\n};\n\nexport function KolRateMutationForm({\n  userId,\n  walletCurrent,\n  rateBpsCurrent,\n}: KolRateMutationFormProps) {\n  const [state, dispatch, pending] = useActionState(\n    kolRateUpdateAction,\n    PEEK_MUTATION_INITIAL_STATE,\n  );\n  const walletId = useId();\n  const rateId = useId();\n\n  return (\n    <form action={dispatch} style={formStyle} aria-label=\"Update KOL rate\">\n      <input type=\"hidden\" name=\"userId\" value={userId} />\n\n      <div style={fieldRowStyle}>\n        <label htmlFor={walletId} style={labelStyle}>\n          Wallet\n        </label>\n        <div style={oldValueStyle}>old: {walletCurrent}</div>\n        <input\n          id={walletId}\n          name=\"wallet\"\n          type=\"text\"\n          defaultValue={walletCurrent}\n          required\n          style={inputStyle}\n          autoComplete=\"off\"\n          spellCheck={false}\n        />\n      </div>\n\n      <div style={fieldRowStyle}>\n        <label htmlFor={rateId} style={labelStyle}>\n          Rate (bps)\n        </label>\n        <div style={oldValueStyle}>old: {rateBpsCurrent}</div>\n        <input\n          id={rateId}\n          name=\"rateBps\"\n          type=\"number\"\n          min={0}\n          max={10000}\n          step={1}\n          defaultValue={rateBpsCurrent}\n          required\n          style={inputStyle}\n        />\n      </div>\n\n      <button type=\"submit\" disabled={pending} style={submitStyle}>\n        {pending ? \"Applying…\" : \"Apply rate change\"}\n      </button>\n\n      <MutationFeedback state={state} successLabel=\"KOL rate updated.\" />\n    </form>\n  );\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst fieldRowStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst labelStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n  color: \"#94a3b8\",\n};\n\nconst oldValueStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  color: \"#64748b\",\n  fontFamily: \"monospace\",\n};\n\nconst inputStyle: CSSProperties = {\n  padding: \"0.375rem 0.5rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #334155\",\n  background: \"#0f172a\",\n  color: \"#e2e8f0\",\n  fontSize: \"0.8125rem\",\n  fontFamily: \"monospace\",\n};\n\nconst submitStyle: CSSProperties = {\n  padding: \"0.375rem 0.75rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #1e3a8a\",\n  background: \"#1e40af\",\n  color: \"#dbeafe\",\n  fontSize: \"0.8125rem\",\n  fontWeight: 600,\n  cursor: \"pointer\",\n};\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_011NV58a3Rwhf9QeyVxxoyXS","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01GKZ6piiqirwzjxuUWc3VD7","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/mutations/fraud-flag-mutation-form.tsx","content":"// FR-14 mutation form: transition a `fraud_flags.status` row.\n//\n// Rendered inline in `fraud-flags-table.tsx` for admin actors. The form\n// reflects the FR-14 allowed-transition matrix client-side so the\n// operator can only request a target status that the server will\n// actually accept. The set of options is derived from the row's current\n// `status`; if the matrix offers no admissible next status (no row\n// currently does, but the contract permits it) the form renders nothing\n// rather than expose a misleading control.\n\n\"use client\";\n\nimport type { CSSProperties } from \"react\";\nimport { useActionState, useId } from \"react\";\nimport {\n  PEEK_MUTATION_INITIAL_STATE,\n  fraudFlagStatusUpdateAction,\n} from \"../../server/actions/peek-mutations\";\nimport { MutationFeedback } from \"./mutation-feedback\";\n\ntype FraudFlagStatus = \"open\" | \"reviewed\" | \"dismissed\";\n\nconst ALLOWED_NEXT: Readonly<Record<FraudFlagStatus, ReadonlyArray<FraudFlagStatus>>> =\n  Object.freeze({\n    open: [\"reviewed\", \"dismissed\"],\n    reviewed: [\"open\", \"dismissed\"],\n    dismissed: [\"open\"],\n  });\n\nexport type FraudFlagMutationFormProps = {\n  flagId: string;\n  currentStatus: string;\n};\n\nfunction isFraudFlagStatus(value: string): value is FraudFlagStatus {\n  return value === \"open\" || value === \"reviewed\" || value === \"dismissed\";\n}\n\nexport function FraudFlagMutationForm({\n  flagId,\n  currentStatus,\n}: FraudFlagMutationFormProps) {\n  const [state, dispatch, pending] = useActionState(\n    fraudFlagStatusUpdateAction,\n    PEEK_MUTATION_INITIAL_STATE,\n  );\n  const selectId = useId();\n\n  if (!isFraudFlagStatus(currentStatus)) {\n    return null;\n  }\n\n  const options = ALLOWED_NEXT[currentStatus];\n  if (options.length === 0) return null;\n\n  return (\n    <form\n      action={dispatch}\n      style={formStyle}\n      aria-label=\"Transition fraud flag status\"\n    >\n      <input type=\"hidden\" name=\"flagId\" value={flagId} />\n\n      <div style={fieldRowStyle}>\n        <label htmlFor={selectId} style={labelStyle}>\n          Next status\n        </label>\n        <div style={oldValueStyle}>old: {currentStatus}</div>\n        <select\n          id={selectId}\n          name=\"nextStatus\"\n          required\n          defaultValue={options[0]}\n          style={inputStyle}\n        >\n          {options.map((opt) => (\n            <option key={opt} value={opt}>\n              {opt}\n            </option>\n          ))}\n        </select>\n      </div>\n\n      <button type=\"submit\" disabled={pending} style={submitStyle}>\n        {pending ? \"Applying…\" : \"Apply status change\"}\n      </button>\n\n      <MutationFeedback state={state} successLabel=\"Fraud flag updated.\" />\n    </form>\n  );\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst fieldRowStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst labelStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n  color: \"#94a3b8\",\n};\n\nconst oldValueStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  color: \"#64748b\",\n  fontFamily: \"monospace\",\n};\n\nconst inputStyle: CSSProperties = {\n  padding: \"0.375rem 0.5rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #334155\",\n  background: \"#0f172a\",\n  color: \"#e2e8f0\",\n  fontSize: \"0.8125rem\",\n  fontFamily: \"monospace\",\n};\n\nconst submitStyle: CSSProperties = {\n  padding: \"0.375rem 0.75rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #1e3a8a\",\n  background: \"#1e40af\",\n  color: \"#dbeafe\",\n  fontSize: \"0.8125rem\",\n  fontWeight: 600,\n  cursor: \"pointer\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1602,"cache_read_input_tokens":142756,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1602},"output_tokens":62,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"3fc3c40b-0944-44dd-9202-74a9cef80e25","uuid":"14c0626d-c705-4197-8fd9-771e32369ed3"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GKZ6piiqirwzjxuUWc3VD7","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/components/mutations/fraud-flag-mutation-form.tsx"}]},"parent_tool_use_id":null,"session_id":"3fc3c40b-0944-44dd-9202-74a9cef80e25","uuid":"b68f707e-6b09-404a-b177-27a58726ff80","timestamp":"2026-04-26T19:31:10.153Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/components/mutations/fraud-flag-mutation-form.tsx","content":"// FR-14 mutation form: transition a `fraud_flags.status` row.\n//\n// Rendered inline in `fraud-flags-table.tsx` for admin actors. The form\n// reflects the FR-14 allowed-transition matrix client-side so the\n// operator can only request a target status that the server will\n// actually accept. The set of options is derived from the row's current\n// `status`; if the matrix offers no admissible next status (no row\n// currently does, but the contract permits it) the form renders nothing\n// rather than expose a misleading control.\n\n\"use client\";\n\nimport type { CSSProperties } from \"react\";\nimport { useActionState, useId } from \"react\";\nimport {\n  PEEK_MUTATION_INITIAL_STATE,\n  fraudFlagStatusUpdateAction,\n} from \"../../server/actions/peek-mutations\";\nimport { MutationFeedback } from \"./mutation-feedback\";\n\ntype FraudFlagStatus = \"open\" | \"reviewed\" | \"dismissed\";\n\nconst ALLOWED_NEXT: Readonly<Record<FraudFlagStatus, ReadonlyArray<FraudFlagStatus>>> =\n  Object.freeze({\n    open: [\"reviewed\", \"dismissed\"],\n    reviewed: [\"open\", \"dismissed\"],\n    dismissed: [\"open\"],\n  });\n\nexport type FraudFlagMutationFormProps = {\n  flagId: string;\n  currentStatus: string;\n};\n\nfunction isFraudFlagStatus(value: string): value is FraudFlagStatus {\n  return value === \"open\" || value === \"reviewed\" || value === \"dismissed\";\n}\n\nexport function FraudFlagMutationForm({\n  flagId,\n  currentStatus,\n}: FraudFlagMutationFormProps) {\n  const [state, dispatch, pending] = useActionState(\n    fraudFlagStatusUpdateAction,\n    PEEK_MUTATION_INITIAL_STATE,\n  );\n  const selectId = useId();\n\n  if (!isFraudFlagStatus(currentStatus)) {\n    return null;\n  }\n\n  const options = ALLOWED_NEXT[currentStatus];\n  if (options.length === 0) return null;\n\n  return (\n    <form\n      action={dispatch}\n      style={formStyle}\n      aria-label=\"Transition fraud flag status\"\n    >\n      <input type=\"hidden\" name=\"flagId\" value={flagId} />\n\n      <div style={fieldRowStyle}>\n        <label htmlFor={selectId} style={labelStyle}>\n          Next status\n        </label>\n        <div style={oldValueStyle}>old: {currentStatus}</div>\n        <select\n          id={selectId}\n          name=\"nextStatus\"\n          required\n          defaultValue={options[0]}\n          style={inputStyle}\n        >\n          {options.map((opt) => (\n            <option key={opt} value={opt}>\n              {opt}\n            </option>\n          ))}\n        </select>\n      </div>\n\n      <button type=\"submit\" disabled={pending} style={submitStyle}>\n        {pending ? \"Applying…\" : \"Apply status change\"}\n      </button>\n\n      <MutationFeedback state={state} successLabel=\"Fraud flag updated.\" />\n    </form>\n  );\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst fieldRowStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst labelStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n  color: \"#94a3b8\",\n};\n\nconst oldValueStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  color: \"#64748b\",\n  fontFamily: \"monospace\",\n};\n\nconst inputStyle: CSSProperties = {\n  padding: \"0.375rem 0.5rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #334155\",\n  background: \"#0f172a\",\n  color: \"#e2e8f0\",\n  fontSize: \"0.8125rem\",\n  fontFamily: \"monospace\",\n};\n\nconst submitStyle: CSSProperties = {\n  padding: \"0.375rem 0.75rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #1e3a8a\",\n  background: \"#1e40af\",\n  color: \"#dbeafe\",\n  fontSize: \"0.8125rem\",\n  fontWeight: 600,\n  cursor: \"pointer\",\n};\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01EJwPsmsBrcDLMAAqERoiJQ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01XZ6sKGecEtae2rg8WnfbBA","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/mutations/dogpile-cancel-mutation-form.tsx","content":"// FR-14 mutation form: cancel a scheduled future `dogpile_events` row.\n//\n// Rendered inline in `dogpile-events-table.tsx` only when the row's\n// status is exactly `scheduled` (the only state the mutation accepts).\n// `active`, `ended`, and `cancelled` rows render nothing — the engine\n// would reject them anyway and the empty cell makes the read-only\n// status visible. The form shows the implicit before/after pair\n// (`scheduled → cancelled`) so the operator confirms the transition\n// before submitting.\n\n\"use client\";\n\nimport type { CSSProperties } from \"react\";\nimport { useActionState } from \"react\";\nimport {\n  PEEK_MUTATION_INITIAL_STATE,\n  dogpileCancelAction,\n} from \"../../server/actions/peek-mutations\";\nimport { MutationFeedback } from \"./mutation-feedback\";\n\nexport type DogpileCancelMutationFormProps = {\n  eventId: string;\n  currentStatus: string;\n};\n\nexport function DogpileCancelMutationForm({\n  eventId,\n  currentStatus,\n}: DogpileCancelMutationFormProps) {\n  const [state, dispatch, pending] = useActionState(\n    dogpileCancelAction,\n    PEEK_MUTATION_INITIAL_STATE,\n  );\n\n  if (currentStatus !== \"scheduled\") {\n    return null;\n  }\n\n  return (\n    <form\n      action={dispatch}\n      style={formStyle}\n      aria-label=\"Cancel scheduled dogpile event\"\n    >\n      <input type=\"hidden\" name=\"eventId\" value={eventId} />\n\n      <div style={diffStyle}>\n        <span style={oldValueStyle}>scheduled</span>\n        <span style={arrowStyle}>→</span>\n        <span style={newValueStyle}>cancelled</span>\n      </div>\n\n      <button type=\"submit\" disabled={pending} style={submitStyle}>\n        {pending ? \"Cancelling…\" : \"Cancel scheduled event\"}\n      </button>\n\n      <MutationFeedback state={state} successLabel=\"Dogpile event cancelled.\" />\n    </form>\n  );\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst diffStyle: CSSProperties = {\n  display: \"flex\",\n  alignItems: \"center\",\n  gap: \"0.5rem\",\n  fontSize: \"0.75rem\",\n  fontFamily: \"monospace\",\n};\n\nconst oldValueStyle: CSSProperties = {\n  color: \"#64748b\",\n};\n\nconst newValueStyle: CSSProperties = {\n  color: \"#fcd34d\",\n};\n\nconst arrowStyle: CSSProperties = {\n  color: \"#475569\",\n};\n\nconst submitStyle: CSSProperties = {\n  padding: \"0.375rem 0.75rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #92400e\",\n  background: \"#b45309\",\n  color: \"#fffbeb\",\n  fontSize: \"0.8125rem\",\n  fontWeight: 600,\n  cursor: \"pointer\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1694,"cache_read_input_tokens":144358,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1694},"output_tokens":62,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"3fc3c40b-0944-44dd-9202-74a9cef80e25","uuid":"1b1f4564-74ec-4160-92a6-4d6f8f534cfd"}
