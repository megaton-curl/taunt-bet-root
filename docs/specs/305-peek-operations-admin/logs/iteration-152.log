{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VXZzFLg5gErLjXCRUe9X7Q","type":"tool_result","content":"1\t// Approved FR-14 mutation: create or update a KOL rate row in\n2\t// `referral_kol_rates`.\n3\t//\n4\t// Scope:\n5\t//   - Identified by `user_id` (TEXT primary key).\n6\t//   - `wallet` is unique across the table; updates that collide will surface\n7\t//     as `execution_failed` via the runner's transaction rollback path.\n8\t//   - `rate_bps` is validated 0..10000 (0%..100%).\n9\t//   - `set_by` is captured server-side as the verified actor email so the row\n10\t//     and the `peek.change.applied` audit record agree on attribution.\n11\t//\n12\t// Diff semantics:\n13\t//   - On create, the audit diff lists `wallet` and `rate_bps` with `before:null`\n14\t//     so the audit row carries the full new state.\n15\t//   - On update, the diff lists only the fields whose values actually changed.\n16\t//   - `set_by` is operator metadata, not part of the user-visible config; it is\n17\t//     not included in the diff.\n18\t//   - `updated_at` is bumped automatically by the UPDATE statement and is not\n19\t//     part of the diff either.\n20\t\n21\timport type { Sql } from \"postgres\";\n22\timport { z } from \"zod\";\n23\timport type { PeekAuditChange } from \"../../lib/types/peek\";\n24\timport type {\n25\t  PeekMutationDefinition,\n26\t  PeekMutationExecuteContext,\n27\t  PeekMutationExecuteResult,\n28\t} from \"./registry\";\n29\t\n30\texport const KOL_RATE_BPS_MIN = 0;\n31\texport const KOL_RATE_BPS_MAX = 10_000;\n32\t\n33\texport const kolRateUpdateInputSchema = z\n34\t  .object({\n35\t    userId: z.string().trim().min(1),\n36\t    wallet: z.string().trim().min(1),\n37\t    rateBps: z.number().int().min(KOL_RATE_BPS_MIN).max(KOL_RATE_BPS_MAX),\n38\t  })\n39\t  .strict();\n40\t\n41\texport type KolRateUpdateInput = z.infer<typeof kolRateUpdateInputSchema>;\n42\t\n43\ttype ExistingKolRow = {\n44\t  userId: string;\n45\t  wallet: string;\n46\t  rateBps: number;\n47\t};\n48\t\n49\tasync function fetchExistingRow(\n50\t  sql: Sql,\n51\t  userId: string,\n52\t): Promise<ExistingKolRow | null> {\n53\t  const rows = await sql<Array<ExistingKolRow>>`\n54\t    select\n55\t      user_id as \"userId\",\n56\t      wallet as \"wallet\",\n57\t      rate_bps as \"rateBps\"\n58\t    from referral_kol_rates\n59\t    where user_id = ${userId}\n60\t    for update\n61\t  `;\n62\t  return rows[0] ?? null;\n63\t}\n64\t\n65\tfunction diffForUpdate(\n66\t  existing: ExistingKolRow,\n67\t  next: { wallet: string; rateBps: number },\n68\t): ReadonlyArray<PeekAuditChange> {\n69\t  const changes: PeekAuditChange[] = [];\n70\t  if (existing.wallet !== next.wallet) {\n71\t    changes.push({\n72\t      field: \"wallet\",\n73\t      before: existing.wallet,\n74\t      after: next.wallet,\n75\t    });\n76\t  }\n77\t  if (existing.rateBps !== next.rateBps) {\n78\t    changes.push({\n79\t      field: \"rate_bps\",\n80\t      before: existing.rateBps,\n81\t      after: next.rateBps,\n82\t    });\n83\t  }\n84\t  return changes;\n85\t}\n86\t\n87\tfunction diffForCreate(next: {\n88\t  wallet: string;\n89\t  rateBps: number;\n90\t}): ReadonlyArray<PeekAuditChange> {\n91\t  return [\n92\t    { field: \"wallet\", before: null, after: next.wallet },\n93\t    { field: \"rate_bps\", before: null, after: next.rateBps },\n94\t  ];\n95\t}\n96\t\n97\tasync function executeKolRateUpdate(\n98\t  ctx: PeekMutationExecuteContext<KolRateUpdateInput>,\n99\t): Promise<PeekMutationExecuteResult> {\n100\t  const { sql, input, actor } = ctx;\n101\t  const { userId, wallet, rateBps } = input;\n102\t  const setBy = actor.email;\n103\t\n104\t  const existing = await fetchExistingRow(sql, userId);\n105\t\n106\t  if (existing) {\n107\t    const changes = diffForUpdate(existing, { wallet, rateBps });\n108\t    await sql`\n109\t      update referral_kol_rates\n110\t      set\n111\t        wallet = ${wallet},\n112\t        rate_bps = ${rateBps},\n113\t        set_by = ${setBy},\n114\t        updated_at = now()\n115\t      where user_id = ${userId}\n116\t    `;\n117\t    return { resourceId: userId, changes };\n118\t  }\n119\t\n120\t  await sql`\n121\t    insert into referral_kol_rates (user_id, wallet, rate_bps, set_by)\n122\t    values (${userId}, ${wallet}, ${rateBps}, ${setBy})\n123\t  `;\n124\t  return { resourceId: userId, changes: diffForCreate({ wallet, rateBps }) };\n125\t}\n126\t\n127\texport const kolRateUpdateMutation: PeekMutationDefinition<KolRateUpdateInput> =\n128\t  {\n129\t    actionId: \"kol_rate.update\",\n130\t    resourceType: \"referral_kol_rates\",\n131\t    schema: kolRateUpdateInputSchema,\n132\t    execute: executeKolRateUpdate as PeekMutationDefinition[\"execute\"],\n133\t  };\n134\t"}]},"parent_tool_use_id":null,"session_id":"3fc3c40b-0944-44dd-9202-74a9cef80e25","uuid":"9e5e61a2-f258-4b42-9130-dfd9606dd322","timestamp":"2026-04-26T19:25:46.684Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/mutations/kol-rate.ts","content":"// Approved FR-14 mutation: create or update a KOL rate row in\n// `referral_kol_rates`.\n//\n// Scope:\n//   - Identified by `user_id` (TEXT primary key).\n//   - `wallet` is unique across the table; updates that collide will surface\n//     as `execution_failed` via the runner's transaction rollback path.\n//   - `rate_bps` is validated 0..10000 (0%..100%).\n//   - `set_by` is captured server-side as the verified actor email so the row\n//     and the `peek.change.applied` audit record agree on attribution.\n//\n// Diff semantics:\n//   - On create, the audit diff lists `wallet` and `rate_bps` with `before:null`\n//     so the audit row carries the full new state.\n//   - On update, the diff lists only the fields whose values actually changed.\n//   - `set_by` is operator metadata, not part of the user-visible config; it is\n//     not included in the diff.\n//   - `updated_at` is bumped automatically by the UPDATE statement and is not\n//     part of the diff either.\n\nimport type { Sql } from \"postgres\";\nimport { z } from \"zod\";\nimport type { PeekAuditChange } from \"../../lib/types/peek\";\nimport type {\n  PeekMutationDefinition,\n  PeekMutationExecuteContext,\n  PeekMutationExecuteResult,\n} from \"./registry\";\n\nexport const KOL_RATE_BPS_MIN = 0;\nexport const KOL_RATE_BPS_MAX = 10_000;\n\nexport const kolRateUpdateInputSchema = z\n  .object({\n    userId: z.string().trim().min(1),\n    wallet: z.string().trim().min(1),\n    rateBps: z.number().int().min(KOL_RATE_BPS_MIN).max(KOL_RATE_BPS_MAX),\n  })\n  .strict();\n\nexport type KolRateUpdateInput = z.infer<typeof kolRateUpdateInputSchema>;\n\ntype ExistingKolRow = {\n  userId: string;\n  wallet: string;\n  rateBps: number;\n};\n\nasync function fetchExistingRow(\n  sql: Sql,\n  userId: string,\n): Promise<ExistingKolRow | null> {\n  const rows = await sql<Array<ExistingKolRow>>`\n    select\n      user_id as \"userId\",\n      wallet as \"wallet\",\n      rate_bps as \"rateBps\"\n    from referral_kol_rates\n    where user_id = ${userId}\n    for update\n  `;\n  return rows[0] ?? null;\n}\n\nfunction diffForUpdate(\n  existing: ExistingKolRow,\n  next: { wallet: string; rateBps: number },\n): ReadonlyArray<PeekAuditChange> {\n  const changes: PeekAuditChange[] = [];\n  if (existing.wallet !== next.wallet) {\n    changes.push({\n      field: \"wallet\",\n      before: existing.wallet,\n      after: next.wallet,\n    });\n  }\n  if (existing.rateBps !== next.rateBps) {\n    changes.push({\n      field: \"rate_bps\",\n      before: existing.rateBps,\n      after: next.rateBps,\n    });\n  }\n  return changes;\n}\n\nfunction diffForCreate(next: {\n  wallet: string;\n  rateBps: number;\n}): ReadonlyArray<PeekAuditChange> {\n  return [\n    { field: \"wallet\", before: null, after: next.wallet },\n    { field: \"rate_bps\", before: null, after: next.rateBps },\n  ];\n}\n\nasync function executeKolRateUpdate(\n  ctx: PeekMutationExecuteContext<KolRateUpdateInput>,\n): Promise<PeekMutationExecuteResult> {\n  const { sql, input, actor } = ctx;\n  const { userId, wallet, rateBps } = input;\n  const setBy = actor.email;\n\n  const existing = await fetchExistingRow(sql, userId);\n\n  if (existing) {\n    const changes = diffForUpdate(existing, { wallet, rateBps });\n    await sql`\n      update referral_kol_rates\n      set\n        wallet = ${wallet},\n        rate_bps = ${rateBps},\n        set_by = ${setBy},\n        updated_at = now()\n      where user_id = ${userId}\n    `;\n    return { resourceId: userId, changes };\n  }\n\n  await sql`\n    insert into referral_kol_rates (user_id, wallet, rate_bps, set_by)\n    values (${userId}, ${wallet}, ${rateBps}, ${setBy})\n  `;\n  return { resourceId: userId, changes: diffForCreate({ wallet, rateBps }) };\n}\n\nexport const kolRateUpdateMutation: PeekMutationDefinition<KolRateUpdateInput> =\n  {\n    actionId: \"kol_rate.update\",\n    resourceType: \"referral_kol_rates\",\n    schema: kolRateUpdateInputSchema,\n    execute: executeKolRateUpdate as PeekMutationDefinition[\"execute\"],\n  };\n","numLines":134,"startLine":1,"totalLines":134}}}
