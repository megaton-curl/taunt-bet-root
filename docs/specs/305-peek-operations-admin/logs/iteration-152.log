{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JC22io89q4SirACTMP7i39","type":"tool_result","content":"1\t// Dogpile events table for /operations/dogpile (FR-9).\n2\t//\n3\t// Read-only dense table over `PeekDogpileEventRow`. Status drives the chip\n4\t// tone so an operator can spot scheduled vs active vs ended/cancelled at a\n5\t// glance. Each row also surfaces the count of game_entries and point_grants\n6\t// whose `created_at` falls inside the dogpile window — the closest\n7\t// operator-meaningful \"linked\" set the spec calls out (FR-9). Editing dogpile\n8\t// events is out of scope here; cancellation lives behind the FR-14\n9\t// `dogpile.cancel` action id (not yet implemented).\n10\timport type { CSSProperties } from \"react\";\n11\timport type {\n12\t  PeekDogpileEventRow,\n13\t  PeekStatusTone,\n14\t} from \"../lib/types/peek\";\n15\timport { StatusChip } from \"./status-chip\";\n16\t\n17\texport type DogpileEventsTableProps = {\n18\t  rows: ReadonlyArray<PeekDogpileEventRow>;\n19\t  error?: string | null;\n20\t};\n21\t\n22\texport function DogpileEventsTable({\n23\t  rows,\n24\t  error = null,\n25\t}: DogpileEventsTableProps) {\n26\t  if (error) {\n27\t    return (\n28\t      <div role=\"alert\" style={errorStyle}>\n29\t        Dogpile events unavailable: {error}\n30\t      </div>\n31\t    );\n32\t  }\n33\t\n34\t  if (rows.length === 0) {\n35\t    return (\n36\t      <div role=\"status\" style={emptyStyle}>\n37\t        <p style={emptyTitleStyle}>\n38\t          No dogpile_events rows match these filters.\n39\t        </p>\n40\t        <p style={emptyBodyStyle}>\n41\t          Adjust the filters above or clear them to see scheduled, active,\n42\t          ended, and cancelled events.\n43\t        </p>\n44\t      </div>\n45\t    );\n46\t  }\n47\t\n48\t  return (\n49\t    <div style={wrapperStyle}>\n50\t      <table style={tableStyle}>\n51\t        <thead>\n52\t          <tr style={headerRowStyle}>\n53\t            <th style={headerCellStyle(\"left\")}>Status</th>\n54\t            <th style={headerCellStyle(\"left\")}>Campaign</th>\n55\t            <th style={headerCellStyle(\"left\")}>Starts</th>\n56\t            <th style={headerCellStyle(\"left\")}>Ends</th>\n57\t            <th style={headerCellStyle(\"right\")}>Multiplier</th>\n58\t            <th style={headerCellStyle(\"right\")}>Game entries</th>\n59\t            <th style={headerCellStyle(\"right\")}>Point grants</th>\n60\t            <th style={headerCellStyle(\"left\")}>Created</th>\n61\t            <th style={headerCellStyle(\"left\")}>ID</th>\n62\t          </tr>\n63\t        </thead>\n64\t        <tbody>\n65\t          {rows.map((row) => (\n66\t            <tr key={row.id} style={bodyRowStyle}>\n67\t              <td style={bodyCellStyle(\"left\")}>\n68\t                <StatusChip\n69\t                  label={row.status}\n70\t                  tone={dogpileStatusTone(row.status)}\n71\t                />\n72\t              </td>\n73\t              <td style={bodyCellStyle(\"left\")}>\n74\t                <div>{row.campaignName ?? \"—\"}</div>\n75\t                {row.campaignType ? (\n76\t                  <div style={subValueStyle}>{row.campaignType}</div>\n77\t                ) : null}\n78\t                {row.campaignId ? (\n79\t                  <div style={{ ...subValueStyle, fontFamily: \"monospace\" }}>\n80\t                    {row.campaignId}\n81\t                  </div>\n82\t                ) : null}\n83\t              </td>\n84\t              <td style={bodyCellStyle(\"left\")}>{row.startsAt}</td>\n85\t              <td style={bodyCellStyle(\"left\")}>{row.endsAt}</td>\n86\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n87\t                {row.multiplier}×\n88\t              </td>\n89\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n90\t                {row.gameEntryCount.toLocaleString(\"en-US\")}\n91\t              </td>\n92\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n93\t                {row.pointGrantCount.toLocaleString(\"en-US\")}\n94\t              </td>\n95\t              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n96\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n97\t                {row.id}\n98\t              </td>\n99\t            </tr>\n100\t          ))}\n101\t        </tbody>\n102\t      </table>\n103\t    </div>\n104\t  );\n105\t}\n106\t\n107\tfunction dogpileStatusTone(value: string): PeekStatusTone {\n108\t  if (value === \"scheduled\") return \"info\";\n109\t  if (value === \"active\") return \"positive\";\n110\t  if (value === \"ended\") return \"neutral\";\n111\t  if (value === \"cancelled\") return \"warning\";\n112\t  return \"neutral\";\n113\t}\n114\t\n115\tconst wrapperStyle: CSSProperties = {\n116\t  overflowX: \"auto\",\n117\t  border: \"1px solid #1e293b\",\n118\t  borderRadius: \"0.75rem\",\n119\t};\n120\t\n121\tconst tableStyle: CSSProperties = {\n122\t  width: \"100%\",\n123\t  borderCollapse: \"collapse\",\n124\t};\n125\t\n126\tconst headerRowStyle: CSSProperties = {\n127\t  background: \"#111827\",\n128\t  color: \"#94a3b8\",\n129\t};\n130\t\n131\tconst bodyRowStyle: CSSProperties = {\n132\t  borderTop: \"1px solid #1e293b\",\n133\t};\n134\t\n135\tconst subValueStyle: CSSProperties = {\n136\t  color: \"#64748b\",\n137\t  fontSize: \"0.75rem\",\n138\t};\n139\t\n140\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n141\t  return {\n142\t    padding: \"0.75rem\",\n143\t    textAlign: align,\n144\t    fontSize: \"0.875rem\",\n145\t    fontWeight: 600,\n146\t  };\n147\t}\n148\t\n149\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n150\t  return {\n151\t    padding: \"0.75rem\",\n152\t    textAlign: align,\n153\t    fontSize: \"0.875rem\",\n154\t    color: \"#e2e8f0\",\n155\t    verticalAlign: \"top\",\n156\t  };\n157\t}\n158\t\n159\tconst errorStyle: CSSProperties = {\n160\t  margin: 0,\n161\t  padding: \"0.75rem 1rem\",\n162\t  borderRadius: \"0.75rem\",\n163\t  background: \"#3f1d1d\",\n164\t  color: \"#fecaca\",\n165\t};\n166\t\n167\tconst emptyStyle: CSSProperties = {\n168\t  padding: \"1.5rem\",\n169\t  borderRadius: \"0.75rem\",\n170\t  border: \"1px dashed #334155\",\n171\t  background: \"#0b1220\",\n172\t  color: \"#cbd5f5\",\n173\t  display: \"grid\",\n174\t  gap: \"0.5rem\",\n175\t};\n176\t\n177\tconst emptyTitleStyle: CSSProperties = {\n178\t  margin: 0,\n179\t  fontSize: \"1rem\",\n180\t  fontWeight: 600,\n181\t};\n182\t\n183\tconst emptyBodyStyle: CSSProperties = {\n184\t  margin: 0,\n185\t  fontSize: \"0.875rem\",\n186\t  color: \"#94a3b8\",\n187\t};\n188\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01GwpxxCj3UiMN4YiDjfsvUM","session_id":"3fc3c40b-0944-44dd-9202-74a9cef80e25","uuid":"38e01689-7b1c-4246-82ff-8b95ca34380d","timestamp":"2026-04-26T19:26:38.879Z"}
