\n  getDogpileFraudOverview,\n  listDogpileEvents,\n  listFraudFlags,\n} from \"../../../src/server/db/queries/get-dogpile-and-fraud\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst ROUTE = \"/operations/dogpile\";\n\nexport default async function OperationsDogpilePage({\n  searchParams,\n}: {\n  searchParams: Promise<Record<string, string | string[] | undefined>>;\n}) {\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n\n  if (!allowed) {\n    return (\n      <main style={mainStyle}>\n        <header>\n          <h1>Operations · Dogpile</h1>\n        </header>\n        <p role=\"alert\" style={errorStyle}>\n          You do not have access to this page.\n        </p>\n      </main>\n    );\n  }\n\n  const params = await searchParams;\n  const dogpileFilters = normalizeDogpileEventFiltersFromSearchParams(params);\n  const fraudFilters = normalizeFraudFlagFiltersFromSearchParams(params);\n\n  let overview: PeekDogpileFraudOverview = {\n    generatedAt: new Date().toISOString(),\n    metrics: [],\n  };\n  let dogpileEvents: ReadonlyArray<PeekDogpileEventRow> = [];\n  let fraudFlags: ReadonlyArray<PeekFraudFlagListRow> = [];\n\n  let overviewError: string | null = null;\n  let dogpileError: string | null = null;\n  let fraudError: string | null = null;\n\n  try {\n    overview = await getDogpileFraudOverview();\n  } catch (error) {\n    overviewError =\n      error instanceof Error\n        ? error.message\n        : \"Dogpile + fraud overview could not be loaded.\";\n  }\n\n  try {\n    dogpileEvents = await listDogpileEvents({ filters: dogpileFilters });\n  } catch (error) {\n    dogpileError =\n      error instanceof Error\n        ? error.message\n        : \"Dogpile events could not be loaded.\";\n  }\n\n  try {\n    fraudFlags = await listFraudFlags({ filters: fraudFilters });\n  } catch (error) {\n    fraudError =\n      error instanceof Error\n        ? error.message\n        : \"Fraud flags could not be loaded.\";\n  }\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <h1>Operations · Dogpile</h1>\n        <p style={leadStyle}>\n          Dogpile lifecycle (scheduled / active / ended / cancelled) and the\n          fraud review queue. Read-only — cancelling a scheduled dogpile event\n          and transitioning a fraud flag both live behind FR-14 mutation\n          action ids that are not yet implemented.\n        </p>\n      </header>\n\n      <section aria-labelledby=\"overview-heading\">\n        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n          Overview\n        </h2>\n        <MetricStrip metrics={overview.metrics} error={overviewError} />\n      </section>\n\n      <section\n        aria-labelledby=\"dogpile-events-heading\"\n        id=\"dogpile-events\"\n        style={sectionStyle}\n      >\n        <h2 id=\"dogpile-events-heading\" style={sectionHeadingStyle}>\n          Dogpile events\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT} rows · sorted newest\n          starts first · server-side capped. Filter by status and a [from, to)\n          starts-at window. Game-entries and point-grants counts reflect the\n          rows whose `created_at` falls inside each event window. Read-only.\n        </p>\n        <DogpileEventsFilterBar filters={dogpileFilters} action={ROUTE} />\n        <DogpileEventsTable rows={dogpileEvents} error={dogpileError} />\n      </section>\n\n      <section\n        aria-labelledby=\"fraud-heading\"\n        id=\"fraud\"\n        style={sectionStyle}\n      >\n        <h2 id=\"fraud-heading\" style={sectionHeadingStyle}>\n          Fraud flags\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_FRAUD_FLAGS_DEFAULT_LIMIT} rows · sorted open first\n          then newest · server-side capped. Filter by status, user, flag type,\n          and a [from, to) created-at window. Read-only — status transitions\n          are guarded by the `fraud_flag.status.update` mutation action.\n        </p>\n        <FraudFlagsFilterBar filters={fraudFilters} action={ROUTE} />\n        <FraudFlagsTable rows={fraudFlags} error={fraudError} />\n      </section>\n    </main>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n","numLines":208,"startLine":1,"totalLines":208}}}
