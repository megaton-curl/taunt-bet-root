{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011AVjmjcfnFWpaEK5cAV4Dn","type":"tool_result","content":"1\t// Approved FR-14 mutation: update the `status` column of a `fraud_flags` row.\n2\t//\n3\t// Scope:\n4\t//   - Identified by the BIGINT `fraud_flags.id` rendered as text.\n5\t//   - Only the `status` column moves; the diff records the before/after pair\n6\t//     so the audit row carries the full state transition.\n7\t//   - `resolved_at` is bumped server-side whenever the flag leaves `open` and\n8\t//     cleared when the flag is reopened. It is operator/derived metadata and\n9\t//     stays out of the audit diff (matches the kol-rate `set_by`/`updated_at`\n10\t//     precedent).\n11\t//\n12\t// Allowed-transition matrix:\n13\t//   open      -> reviewed | dismissed\n14\t//   reviewed  -> open     | dismissed\n15\t//   dismissed -> open\n16\t//\n17\t//   Disallowed:\n18\t//     - dismissed -> reviewed (must reopen first; review is a state for active\n19\t//       investigation, not a re-classification of a closed flag).\n20\t//     - any no-op (X -> X), so audit rows always reflect a real movement.\n21\t//\n22\t// Failure semantics (surfaced through the runner's execute path):\n23\t//   - Unknown flag id        -> thrown error -> result `execution_failed` /\n24\t//     audit `peek.change.rejected` with `rejectionReason` starting\n25\t//     `execution_failed: unknown_flag:`.\n26\t//   - Disallowed transition  -> thrown error -> result `execution_failed` /\n27\t//     audit `peek.change.rejected` with `rejectionReason` starting\n28\t//     `execution_failed: invalid_transition:`.\n29\t//   - Schema validation failures (missing flagId, bad nextStatus, no-op caught\n30\t//     up-front) -> the runner's `invalid_input` path before any DB work.\n31\t//\n32\t// Authorization:\n33\t//   `fraud_flag.status.update` is admin-only per FR-2 `PEEK_ACTION_RULES`.\n34\t//   The runner enforces this before `execute` is called.\n35\t\n36\timport type { Sql } from \"postgres\";\n37\timport { z } from \"zod\";\n38\timport type { PeekAuditChange } from \"../../lib/types/peek\";\n39\timport type {\n40\t  PeekMutationDefinition,\n41\t  PeekMutationExecuteContext,\n42\t  PeekMutationExecuteResult,\n43\t} from \"./registry\";\n44\t\n45\texport const FRAUD_FLAG_STATUSES = [\"open\", \"reviewed\", \"dismissed\"] as const;\n46\texport type FraudFlagStatus = (typeof FRAUD_FLAG_STATUSES)[number];\n47\t\n48\t// (from, to) tuples that are admitted by the transition matrix.\n49\texport const FRAUD_FLAG_ALLOWED_TRANSITIONS: ReadonlyArray<\n50\t  readonly [FraudFlagStatus, FraudFlagStatus]\n51\t> = Object.freeze([\n52\t  [\"open\", \"reviewed\"],\n53\t  [\"open\", \"dismissed\"],\n54\t  [\"reviewed\", \"open\"],\n55\t  [\"reviewed\", \"dismissed\"],\n56\t  [\"dismissed\", \"open\"],\n57\t] as const);\n58\t\n59\texport function isFraudFlagTransitionAllowed(\n60\t  from: FraudFlagStatus,\n61\t  to: FraudFlagStatus,\n62\t): boolean {\n63\t  return FRAUD_FLAG_ALLOWED_TRANSITIONS.some(\n64\t    ([f, t]) => f === from && t === to,\n65\t  );\n66\t}\n67\t\n68\t// `flagId` is the BIGINT primary key serialized as text (matches the existing\n69\t// `get-dogpile-and-fraud.listFraudFlags` view-model contract).\n70\texport const fraudFlagStatusUpdateInputSchema = z\n71\t  .object({\n72\t    flagId: z\n73\t      .string()\n74\t      .trim()\n75\t      .min(1)\n76\t      .regex(/^[0-9]+$/u, \"flagId must be a positive integer\"),\n77\t    nextStatus: z.enum(FRAUD_FLAG_STATUSES),\n78\t  })\n79\t  .strict();\n80\t\n81\texport type FraudFlagStatusUpdateInput = z.infer<\n82\t  typeof fraudFlagStatusUpdateInputSchema\n83\t>;\n84\t\n85\ttype ExistingFraudFlagRow = {\n86\t  id: string;\n87\t  status: FraudFlagStatus;\n88\t};\n89\t\n90\tasync function fetchExistingRow(\n91\t  sql: Sql,\n92\t  flagId: string,\n93\t): Promise<ExistingFraudFlagRow | null> {\n94\t  const rows = await sql<Array<ExistingFraudFlagRow>>`\n95\t    select\n96\t      id::text as \"id\",\n97\t      status as \"status\"\n98\t    from fraud_flags\n99\t    where id::text = ${flagId}\n100\t    for update\n101\t  `;\n102\t  return rows[0] ?? null;\n103\t}\n104\t\n105\tasync function executeFraudFlagStatusUpdate(\n106\t  ctx: PeekMutationExecuteContext<FraudFlagStatusUpdateInput>,\n107\t): Promise<PeekMutationExecuteResult> {\n108\t  const { sql, input } = ctx;\n109\t  const { flagId, nextStatus } = input;\n110\t\n111\t  const existing = await fetchExistingRow(sql, flagId);\n112\t  if (!existing) {\n113\t    throw new Error(`unknown_flag: ${flagId}`);\n114\t  }\n115\t\n116\t  const fromStatus = existing.status;\n117\t  if (!isFraudFlagTransitionAllowed(fromStatus, nextStatus)) {\n118\t    throw new Error(`invalid_transition: ${fromStatus} -> ${nextStatus}`);\n119\t  }\n120\t\n121\t  if (nextStatus === \"open\") {\n122\t    await sql`\n123\t      update fraud_flags\n124\t      set status = ${nextStatus}, resolved_at = null\n125\t      where id::text = ${flagId}\n126\t    `;\n127\t  } else {\n128\t    await sql`\n129\t      update fraud_flags\n130\t      set status = ${nextStatus}, resolved_at = now()\n131\t      where id::text = ${flagId}\n132\t    `;\n133\t  }\n134\t\n135\t  const changes: ReadonlyArray<PeekAuditChange> = [\n136\t    { field: \"status\", before: fromStatus, after: nextStatus },\n137\t  ];\n138\t  return { resourceId: existing.id, changes };\n139\t}\n140\t\n141\texport const fraudFlagStatusUpdateMutation: PeekMutationDefinition<FraudFlagStatusUpdateInput> =\n142\t  {\n143\t    actionId: \"fraud_flag.status.update\",\n144\t    resourceType: \"fraud_flags\",\n145\t    schema: fraudFlagStatusUpdateInputSchema,\n146\t    execute:\n147\t      executeFraudFlagStatusUpdate as PeekMutationDefinition[\"execute\"],\n148\t  };\n149\t"}]},"parent_tool_use_id":null,"session_id":"3fc3c40b-0944-44dd-9202-74a9cef80e25","uuid":"e353aade-8eaa-4eb4-a1e8-4d4644d14588","timestamp":"2026-04-26T19:25:48.824Z","tool_use_result":{"type":"text","file":{"fil