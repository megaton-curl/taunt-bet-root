{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PgdLMLHHa94FqiK7jxcWtJ","type":"tool_result","content":"1\timport type { CSSProperties } from \"react\";\n2\timport { ExportActionLink } from \"../../../src/components/export-action-link\";\n3\timport { GrowthKolTable } from \"../../../src/components/growth-kol-table\";\n4\timport { buildExportHref } from \"../../../src/lib/export-href\";\n5\timport type { PeekKolPerformanceRow } from \"../../../src/lib/types/peek\";\n6\timport {\n7\t  getPeekActorContext,\n8\t  isRouteAllowedForRole,\n9\t} from \"../../../src/server/access-policy\";\n10\timport { listKolPerformance } from \"../../../src/server/db/queries/get-growth-referrals\";\n11\timport { isPeekAuditConfigured } from \"../../../src/server/exports\";\n12\t\n13\texport const dynamic = \"force-dynamic\";\n14\t\n15\tconst ROUTE = \"/growth/kol\";\n16\t\n17\texport default async function GrowthKolPage() {\n18\t  const actor = await getPeekActorContext();\n19\t  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n20\t\n21\t  if (!allowed) {\n22\t    return (\n23\t      <main style={mainStyle}>\n24\t        <header>\n25\t          <h1>Growth · KOL</h1>\n26\t        </header>\n27\t        <p role=\"alert\" style={errorStyle}>\n28\t          You do not have access to this page.\n29\t        </p>\n30\t      </main>\n31\t    );\n32\t  }\n33\t\n34\t  let rows: ReadonlyArray<PeekKolPerformanceRow> = [];\n35\t  let kolError: string | null = null;\n36\t\n37\t  try {\n38\t    rows = await listKolPerformance();\n39\t  } catch (error) {\n40\t    kolError =\n41\t      error instanceof Error\n42\t        ? error.message\n43\t        : \"KOL rates could not be loaded.\";\n44\t  }\n45\t\n46\t  const exportsEnabled =\n47\t    process.env.NODE_ENV !== \"production\" || isPeekAuditConfigured();\n48\t  const kolExportHref = buildExportHref(\"kol\");\n49\t\n50\t  return (\n51\t    <main style={mainStyle}>\n52\t      <header>\n53\t        <h1>Growth 