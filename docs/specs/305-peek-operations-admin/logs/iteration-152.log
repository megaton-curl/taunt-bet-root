{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017N7eXjuKcJa7AN9s9ThsUg","type":"tool_result","content":"1\t// Browser-safe view-model primitives for `peek`.\n2\t//\n3\t// Foundational shapes used across feature pages: metric metadata (FR-4),\n4\t// URL-addressable table filters, pagination, sort, and a small table-row base\n5\t// type that per-feature row types can extend. Per-feature shapes (PeekUserRow,\n6\t// PeekUserDetail, future referral/game/queue/etc. rows) live alongside or\n7\t// extend these primitives.\n8\t\n9\timport type { PeekRole } from \"../access-policy\";\n10\t\n11\t// --- Existing 303-era shapes (kept stable for current callers) ---------------\n12\t\n13\texport type PeekSummary = {\n14\t  totalUsers: number;\n15\t  totalUsersWithCodes: number;\n16\t  totalReferredUsers: number;\n17\t  totalUniqueReferrers: number;\n18\t};\n19\t\n20\texport type PeekUserRow = {\n21\t  userId: string;\n22\t  username: string | null;\n23\t  wallet: string;\n24\t  joinedAt: string;\n25\t  referralCode: string | null;\n26\t  referrerUserId: string | null;\n27\t  referrerCode: string | null;\n28\t  refereeCount: number;\n29\t  telegramUsername: string | null;\n30\t  telegramUserId: string | null;\n31\t};\n32\t\n33\t// --- Expanded user-detail shapes (FR-6) --------------------------------------\n34\t//\n35\t// Per-section row types for the full support/audit user profile. Lamports and\n36\t// numeric/precision-sensitive values arrive as `text` to preserve precision; the\n37\t// UI re-formats at render time. All shapes are browser-safe (no server imports).\n38\t\n39\texport type PeekLinkedAccountRow = {\n40\t  id: string;\n41\t  provider: string;\n42\t  providerAccountId: string;\n43\t  status: string;\n44\t  telegramUsername: string | null;\n45\t  metadataJson: Record<string, unknown> | null;\n46\t  linkedAt: string;\n47\t  updatedAt: string;\n48\t};\n49\t\n50\texport type PeekTelegramLinkTokenRow = {\n51\t  id: string;\n52\t  status: string;\n53\t  telegramUserId: string | null;\n54\t  telegramUsername: string | null;\n55\t  expiresAt: string;\n56\t  redeemedAt: string | null;\n57\t  createdAt: string;\n58\t};\n59\t\n60\texport type PeekKolRate = {"}]},"parent_tool_use_id":null,"session_id":"3fc3c40b-0944-44dd-9202-74a9cef80e25","uuid":"0dc7c509-eaa4-4253-8392-97e1daef8079","timestamp":"2026-04-26T19:29:35.375Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","content":"// Browser-safe view-model primitives for `peek`.\n//\n// Foundational shapes used across feature pages: metric metadata (FR-4),\n// URL-addressable table filters, pagination, sort, and a small table-row base\n// type that per-feature row types can extend. Per-feature shapes (PeekUserRow,\n// PeekUserDetail, future referral/game/queue/etc. rows) live alongside or\n// extend these primitives.\n\nimport type { PeekRole } from \"../access-policy\";\n\n// --- Existing 303-era shapes (kept stable for current callers) ---------------\n\nexport type PeekSummary = {\n  totalUsers: number;\n  totalUsersWithCodes: number;\n  totalReferredUsers: number;\n  totalUniqueReferrers: number;\n};\n\nexport type PeekUserRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  joinedAt: string;\n  referralCode: string | null;\n  referrerUserId: string | null;\n  referrerCode: string | null;\n  refereeCount: number;\n  telegramUsername: string | null;\n  telegramUserId: string | null;\n};\n\n// --- Expanded user-detail shapes (FR-6) --------------------------------------\n//\n// Per-section row types for the full support/audit user profile. Lamports and\n// numeric/precision-sensitive values arrive as `text` to preserve precision; the\n// UI re-formats at render time. All shapes are browser-safe (no server imports).\n\nexport type PeekLinkedAccountRow = {\n  id: string;\n  provider: string;\n  providerAccountId: string;\n  status: string;\n  telegramUsername: string | null;\n  metadataJson: Record<string, unknown> | null;\n  linkedAt: string;\n  updatedAt: string;\n};\n\nexport type PeekTelegramLinkTokenRow = {\n  id: string;\n  status: string;\n  telegramUserId: string | null;\n  telegramUsername: string | null;\n  expiresAt: string;\n  redeemedAt: string | null;\n  createdAt: string;\n};\n\nexport type PeekKolRate = {","numLines":60,"startLine":1,"totalLines":1476}}}
