{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01ANk3JdnMskFhu38sy1xHtE","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_019BSoLNK14cUXQFnGzoRm4y","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/mutations/mutation-feedback.tsx","content":"// Reusable feedback panel for FR-14 mutation forms.\n//\n// Maps the runner-driven `PeekMutationActionState` to operator-friendly\n// status lines:\n//   - Success    → green \"✓ <message>\" line, role=\"status\".\n//   - Failure    → red   \"✗ <message>\" line, role=\"alert\", with\n//                  reason-specific copy (unauthorized / invalid_input /\n//                  execution_failed / unknown_action / audit_emit_failed)\n//                  and per-field error bullets when the runner returned\n//                  `fieldErrors`.\n//   - Idle       → renders nothing; the form footer is silent until the\n//                  operator interacts with it.\n//\n// The panel is a pure presenter — the surrounding `<form>` owns the\n// `useActionState` hook and feeds the state in.\n\n\"use client\";\n\nimport type { CSSProperties } from \"react\";\nimport type { PeekMutationActionState } from \"../../server/actions/peek-mutations\";\n\nexport type MutationFeedbackProps = {\n  state: PeekMutationActionState;\n  successLabel?: string;\n};\n\nexport function MutationFeedback({\n  state,\n  successLabel,\n}: MutationFeedbackProps) {\n  if (state.status === \"idle\") return null;\n\n  if (state.status === \"ok\") {\n    const label = successLabel ?? \"Change applied.\";\n    const detail = state.resourceId ? ` (id ${state.resourceId})` : \"\";\n    return (\n      <p role=\"status\" style={successStyle}>\n        ✓ {label}\n        {detail}\n      </p>\n    );\n  }\n\n  const reasonHint = describeFailure(state);\n  const fieldErrorEntries: ReadonlyArray<readonly [string, ReadonlyArray<string>]> =\n    state.fieldErrors\n      ? Object.entries(state.fieldErrors).map(\n          ([k, v]) => [k, v] as const,\n        )\n      : [];\n\n  return (\n    <div role=\"alert\" style={errorStyle}>\n      <p style={errorTitleStyle}>✗ {reasonHint}</p>\n      <p style={errorBodyStyle}>{state.message}</p>\n      {fieldErrorEntries.length > 0 ? (\n        <ul style={errorListStyle}>\n          {fieldErrorEntries.map(([field, errors]) => (\n            <li key={field}>\n              <span style={errorFieldStyle}>{field}:</span>{\" \"}\n              {errors.join(\"; \")}\n            </li>\n          ))}\n        </ul>\n      ) : null}\n    </div>\n  );\n}\n\nfunction describeFailure(state: PeekMutationActionState): string {\n  switch (state.reason) {\n    case \"no_actor\":\n      return \"Not authenticated.\";\n    case \"unauthorized\":\n      return \"You are not authorized to perform this action.\";\n    case \"invalid_input\":\n      return \"The submitted values are invalid.\";\n    case \"execution_failed\":\n      return \"The change could not be applied.\";\n    case \"unknown_action\":\n      return \"Unknown mutation action.\";\n    case \"audit_emit_failed\":\n      return \"Audit logging failed; the change was rolled back.\";\n    default:\n      return \"Mutation failed.\";\n  }\n}\n\nconst successStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.5rem 0.75rem\",\n  borderRadius: \"0.5rem\",\n  background: \"#0c2818\",\n  color: \"#86efac\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.5rem 0.75rem\",\n  borderRadius: \"0.5rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst errorTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  fontWeight: 600,\n};\n\nconst errorBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.8125rem\",\n  color: \"#fcd9d9\",\n};\n\nconst errorListStyle: CSSProperties = {\n  margin: 0,\n  paddingLeft: \"1rem\",\n  fontSize: \"0.75rem\",\n  color: \"#fbcfe8\",\n};\n\nconst errorFieldStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  color: \"#fda4af\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2489,"cache_read_input_tokens":138410,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2489},"output_tokens":46,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"3fc3c40b-0944-44dd-9202-74a9cef80e25","uuid":"f05d4f25-7708-4db6-b05b-7feb9536e0cf"}
