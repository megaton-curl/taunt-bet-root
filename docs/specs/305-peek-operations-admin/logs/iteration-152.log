{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BcjNXJAkPGtcdwrxSU3MTQ","type":"tool_result","content":"1\t// /operations/dogpile — Dogpile lifecycle + fraud review admin page (FR-9).\n2\t//\n3\t// Reads two migration-011 tables via `get-dogpile-and-fraud.ts` and composes\n4\t// the FR-4 metric strip with two operator surfaces:\n5\t//\n6\t//   - Dogpile events — scheduled / active / ended / cancelled lifecycle rows\n7\t//                       with per-event game_entries + point_grants window\n8\t//                       counts, filtered by status + starts_at range.\n9\t//   - Fraud flags    — read-only review queue (open / reviewed / dismissed)\n10\t//                       linked back to /users/[userId] with the JSONB\n11\t//                       `details` payload rendered verbatim.\n12\t//\n13\t// Both sections are read-only. Cancelling a scheduled dogpile event lives\n14\t// behind the FR-14 `dogpile.cancel` action id; transitioning a fraud flag\n15\t// lives behind the `fraud_flag.status.update` action id; neither mutation is\n16\t// implemented yet.\n17\timport type { CSSProperties } from \"react\";\n18\timport { DogpileEventsTable } from \"../../../src/components/dogpile-events-table\";\n19\timport { FraudFlagsTable } from \"../../../src/components/fraud-flags-table\";\n20\timport { MetricStrip } from \"../../../src/components/metric-strip\";\n21\timport {\n22\t  DogpileEventsFilterBar,\n23\t  FraudFlagsFilterBar,\n24\t} from \"../../../src/components/operations-dogpile-filter-bar\";\n25\timport {\n26\t  normalizeDogpileEventFiltersFromSearchParams,\n27\t  normalizeFraudFlagFiltersFromSearchParams,\n28\t} from \"../../../src/lib/operations-dogpile-search-params\";\n29\timport type {\n30\t  PeekDogpileEventRow,\n31\t  PeekDogpileFraudOverview,\n32\t  PeekFraudFlagListRow,\n33\t} from \"../../../src/lib/types/peek\";\n34\timport {\n35\t  getPeekActorContext,\n36\t  isRouteAllowedForRole,\n37\t} from \"../../../src/server/access-policy\";\n38\timport {\n39\t  PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT,\n40\t  PEEK_FRAUD_FLAGS_DEFAULT_LIMIT,\n41\t  getDogpileFraudOverview,\n42\t  listDogpileEvents,\n43\t  listFraudFlags,\n44\t} from \"../../../src/server/db/queries/get-dogpile-and-fraud\";\n45\t\n46\texport const dynamic = \"force-dynamic\";\n47\t\n48\tconst ROUTE = \"/operations/dogpile\";\n49\t\n50\texport default async function OperationsDogpilePage({\n51\t  searchParams,\n52\t}: {\n53\t  searchParams: Promise<Record<string, string | string[] | undefined>>;\n54\t}) {\n55\t  const actor = await getPeekActorContext();\n56\t  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n57\t\n58\t  if (!allowed) {\n59\t    return (\n60\t      <main style={mainStyle}>\n61\t        <header>\n62\t          <h1>Operations · Dogpile</h1>\n63\t        </header>\n64\t        <p role=\"alert\" style={errorStyle}>\n65\t          You do not have access to this page.\n66\t        </p>\n67\t      </main>\n68\t    );\n69\t  }\n70\t\n71\t  const params = await searchParams;\n72\t  const dogpileFilters = normalizeDogpileEventFiltersFromSearchParams(params);\n73\t  const fraudFilters = normalizeFraudFlagFiltersFromSearchParams(params);\n74\t\n75\t  let overview: PeekDogpileFraudOverview = {\n76\t    generatedAt: new Date().toISOString(),\n77\t    metrics: [],\n78\t  };\n79\t  let dogpileEvents: ReadonlyArray<PeekDogpileEventRow> = [];\n80\t  let fraudFlags: ReadonlyArray<PeekFraudFlagListRow> = [];\n81\t\n82\t  let overviewError: string | null = null;\n83\t  let dogpileError: string | null = null;\n84\t  let fraudError: string | null = null;\n85\t\n86\t  try {\n87\t    overview = await getDogpileFraudOverview();\n88\t  } catch (error) {\n89\t    overviewError =\n90\t      error instanceof Error\n91\t        ? error.message\n92\t        : \"Dogpile + fraud overview could not be loaded.\";\n93\t  }\n94\t\n95\t  try {\n96\t    dogpileEvents = await listDogpileEvents({ filters: dogpileFilters });\n97\t  } catch (error) {\n98\t    dogpileError =\n99\t      error instanceof Error\n100\t        ? error.message\n101\t        : \"Dogpile events could not be loaded.\";\n102\t  }\n103\t\n104\t  try {\n105\t    fraudFlags = await listFraudFlags({ filters: fraudFilters });\n106\t  } catch (error) {\n107\t    fraudError =\n108\t      error instanceof Error\n109\t        ? error.message\n110\t        : \"Fraud flags could not be loaded.\";\n111\t  }\n112\t\n113\t  return (\n114\t    <main style={mainStyle}>\n115\t      <header>\n116\t        <h1>Operations · Dogpile</h1>\n117\t        <p style={leadStyle}>\n118\t          Dogpile lifecycle (scheduled / active / ended / cancelled) and the\n119\t          fraud review queue. Read-only — cancelling a scheduled dogpile event\n120\t          and transitioning a fraud flag both live behind FR-14 mutation\n121\t          action ids that are not yet implemented.\n122\t        </p>\n123\t      </header>\n124\t\n125\t      <section aria-labelledby=\"overview-heading\">\n126\t        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n127\t          Overview\n128\t        </h2>\n129\t        <MetricStrip metrics={overview.metrics} error={overviewError} />\n130\t      </section>\n131\t\n132\t      <section\n133\t        aria-labelledby=\"dogpile-events-heading\"\n134\t        id=\"dogpile-events\"\n135\t        style={sectionStyle}\n136\t      >\n137\t        <h2 id=\"dogpile-events-heading\" style={sectionHeadingStyle}>\n138\t          Dogpile events\n139\t        </h2>\n140\t        <p style={hintStyle}>\n141\t          Default {PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT} rows · sorted newest\n142\t          starts first · server-side capped. Filter by status and a [from, to)\n143\t          starts-at window. Game-entries and point-grants counts reflect the\n144\t          rows whose `created_at` falls inside each event window. Read-only.\n145\t        </p>\n146\t        <DogpileEventsFilterBar filters={dogpileFilters} action={ROUTE} />\n147\t        <DogpileEventsTable rows={dogpileEvents} error={dogpileError} />\n148\t      </section>\n149\t\n150\t      <section\n151\t        aria-labelledby=\"fraud-heading\"\n152\t        id=\"fraud\"\n153\t        style={sectionStyle}\n154\t      >\n155\t        <h2 id=\"fraud-heading\" style={sectionHeadingStyle}>\n156\t          Fraud flags\n157\t        </h2>\n158\t        <p style={hintStyle}>\n159\t          Default {PEEK_FRAUD_FLAGS_DEFAULT_LIMIT} rows · sorted open first\n160\t          then newest · server-side capped. Filter by status, user, flag type,\n161\t          and a [from, to) created-at window. Read-only — status transitions\n162\t          are guarded by the `fraud_flag.status.update` mutation action.\n163\t        </p>\n164\t        <FraudFlagsFilterBar filters={fraudFilters} action={ROUTE} />\n165\t        <FraudFlagsTable rows={fraudFlags} error={fraudError} />\n166\t      </section>\n167\t    </main>\n168\t  );\n169\t}\n170\t\n171\tconst mainStyle: CSSProperties = {\n172\t  display: \"grid\",\n173\t  gap: \"1.5rem\",\n174\t};\n175\t\n176\tconst sectionStyle: CSSProperties = {\n177\t  display: \"grid\",\n178\t  gap: \"0.75rem\",\n179\t};\n180\t\n181\tconst sectionHeadingStyle: CSSProperties = {\n182\t  margin: \"0 0 0.75rem\",\n183\t  fontSize: \"1rem\",\n184\t  fontWeight: 600,\n185\t  color: \"#cbd5f5\",\n186\t  textTransform: \"uppercase\",\n187\t  letterSpacing: \"0.05em\",\n188\t};\n189\t\n190\tconst leadStyle: CSSProperties = {\n191\t  margin: \"0.25rem 0 0\",\n192\t  color: \"#94a3b8\",\n193\t};\n194\t\n195\tconst hintStyle: CSSProperties = {\n196\t  margin: 0,\n197\t  color: \"#94a3b8\",\n198\t  fontSize: \"0.8125rem\",\n199\t};\n200\t\n201\tconst errorStyle: CSSProperties = {\n202\t  margin: 0,\n203\t  padding: \"0.75rem 1rem\",\n204\t  borderRadius: \"0.75rem\",\n205\t  background: \"#3f1d1d\",\n206\t  color: \"#fecaca\",\n207\t};\n208\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_01GwpxxCj3UiMN4YiDjfsvUM","session_id":"3fc3c40b-0944-44dd-9202-74a9cef80e25","uuid":"78a94457-3a81-447c-a2b0-41a01e18b442","timestamp":"2026-04-26T19:26:35.690Z"}
