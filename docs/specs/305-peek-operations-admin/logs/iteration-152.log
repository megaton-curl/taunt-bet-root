{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DPHAcPp1CMetPtEorVxpko","type":"tool_result","content":"1\t// Public surface for the peek mutations module (FR-14).\n2\t//\n3\t// Subsequent FR-14 iterations import `runPeekMutation` to wire the\n4\t// approved mutation actions (KOL rate, fraud-flag status, dogpile cancel,\n5\t// reward-config edit) into route handlers, and import the registry types\n6\t// to register new mutation definitions alongside the framework.\n7\t\n8\texport {\n9\t  PEEK_MUTATIONS,\n10\t  getPeekMutation,\n11\t  type PeekMutationActionId,\n12\t  type PeekMutationActorContext,\n13\t  type PeekMutationDefinition,\n14\t  type PeekMutationExecuteContext,\n15\t  type PeekMutationExecuteResult,\n16\t  type PeekMutationRegistry,\n17\t} from \"./registry\";\n18\texport {\n19\t  runPeekMutation,\n20\t  type PeekMutationAuditWriter,\n21\t  type PeekMutationFailure,\n22\t  type PeekMutationFailureReason,\n23\t  type PeekMutationRunInput,\n24\t  type PeekMutationRunResult,\n25\t  type PeekMutationSuccess,\n26\t} from \"./runner\";\n27\texport {\n28\t  KOL_RATE_BPS_MAX,\n29\t  KOL_RATE_BPS_MIN,\n30\t  kolRateUpdateInputSchema,\n31\t  kolRateUpdateMutation,\n32\t  type KolRateUpdateInput,\n33\t} from \"./kol-rate\";\n34\texport {\n35\t  FRAUD_FLAG_ALLOWED_TRANSITIONS,\n36\t  FRAUD_FLAG_STATUSES,\n37\t  fraudFlagStatusUpdateInputSchema,\n38\t  fraudFlagStatusUpdateMutation,\n39\t  isFraudFlagTransitionAllowed,\n40\t  type FraudFlagStatus,\n41\t  type FraudFlagStatusUpdateInput,\n42\t} from \"./fraud-flag\";\n43\texport {\n44\t  DOGPILE_EVENT_STATUSES,\n45\t  dogpileCancelInputSchema,\n46\t  dogpileCancelMutation,\n47\t  type DogpileCancelInput,\n48\t  type DogpileEventStatus,\n49\t} from \"./dogpile\";\n50\texport {\n51\t  PEEK_REWARD_CONFIG_EDITABLE_KEYS,\n52\t  rewardConfigUpdateInputSchema,\n53\t  rewardConfigUpdateMutation,\n54\t  validateRewardConfigValueForKey,\n55\t  type RewardConfigUpdateInput,\n56\t  type RewardConfigValue