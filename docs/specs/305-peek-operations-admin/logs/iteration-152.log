y elapsed is treated as already-active for cancellation purposes\n//     so the worker promotion-from-scheduled race cannot be circumvented from\n//     the admin UI. (The worker that flips `scheduled` -> `active` runs out\n//     of band; admins should not be able to win that race by hand.)\n//\n// Failure semantics (surfaced through the runner's execute path):\n//   - Unknown event id      -> thrown error -> result `execution_failed` /\n//     audit `peek.change.rejected` with `rejectionReason` starting\n//     `execution_failed: unknown_event:`.\n//   - Non-`scheduled` status -> thrown error -> result `execution_failed` /\n//     audit `peek.change.rejected` with `rejectionReason` starting\n//     `execution_failed: invalid_status: <current>` (`active`, `ended`,\n//     `cancelled`).\n//   - Already-elapsed `starts_at` while still `scheduled` ->\n//     `execution_failed: starts_at_in_past`.\n//   - Schema validation failures (missing/invalid eventId) -> the runner's\n//     `invalid_input` path before any DB work.\n//\n// Authorization:\n//   `dogpile.cancel` is admin-only per FR-2 `PEEK_ACTION_RULES`. The runner\n//   enforces this before `execute` is called.\n\nimport type { Sql } from \"postgres\";\nimport { z } from \"zod\";\nimport type { PeekAuditChange } from \"../../lib/types/peek\";\nimport type {\n  PeekMutationDefinition,\n  PeekMutationExecuteContext,\n  PeekMutationExecuteResult,\n} from \"./registry\";\n\nexport const DOGPILE_EVENT_STATUSES = [\n  \"scheduled\",\n  \"active\",\n  \"ended\",\n  \"cancelled\",\n] as const;\nexport type DogpileEventStatus = (typeof DOGPILE_EVENT_STATUSES)[number];\n\n// `eventId` is the BIGINT primary key serialized as text (matches the\n// existing `get-dogpile-and-fraud.listDogpileEvents` view-model contract).\nexport const dogpileCancelInputSchema = z\n  .object({\n    eventId: z\n      .string()\n      .trim()\n      .min(1)\n      .regex(/^[0-9]+$/u, \"eventId must be a positive integer\"),\n  })\n  .strict();\n\nexport type DogpileCancelInput = z.infer<typeof dogpileCancelInputSchema>;\n\ntype ExistingDogpileRow = {\n  id: string;\n  status: DogpileEventStatus;\n  startsInFuture: boolean;\n};\n\nasync function fetchExistingRow(\n  sql: Sql,\n  eventId: string,\n): Promise<ExistingDogpileRow | null> {\n  const rows = await sql<Array<ExistingDogpileRow>>`\n    select\n      id::text as \"id\",\n      status as \"status\",\n      (starts_at > now()) as \"startsInFuture\"\n    from dogpile_events\n    where id::text = ${eventId}\n    for update\n  `;\n  return rows[0] ?? null;\n}\n\nasync function executeDogpileCancel(\n  ctx: PeekMutationExecuteContext<DogpileCancelInput>,\n): Promise<PeekMutationExecuteResult> {\n  const { sql, input } = ctx;\n  const { eventId } = input;\n\n  const existing = await fetchExistingRow(sql, eventId);\n  if (!existing) {\n    throw new Error(`unknown_event: ${eventId}`);\n  }\n\n  if (existing.status !== \"scheduled\") {\n    throw new Error(`invalid_status: ${existing.status}`);\n  }\n\n  if (!existing.startsInFuture) {\n    throw new Error(\"starts_at_in_past\");\n  }\n\n  await sql`\n    update dogpile_events\n    set status = 'cancelled'\n    where id::text = ${eventId}\n  `;\n\n  const changes: ReadonlyArray<PeekAuditChange> = [\n    { field: \"status\", before: \"scheduled\", after: \"cancelled\" },\n  ];\n  return { resourceId: existing.id, changes };\n}\n\nexport const dogpileCancelMutation: PeekMutationDefinition<DogpileCancelInput> =\n  {\n    actionId: \"dogpile.cancel\",\n    resourceType: \"dogpile_events\",\n    schema: dogpileCancelInputSchema,\n    execute: executeDogpileCancel as PeekMutationDefinition[\"execute\"],\n  };\n","numLines":127,"startLine":1,"totalLines":127}}}
