 try {\n    rows = await listKolPerformance();\n  } catch (error) {\n    kolError =\n      error instanceof Error\n        ? error.message\n        : \"KOL rates could not be loaded.\";\n  }\n\n  const exportsEnabled =\n    process.env.NODE_ENV !== \"production\" || isPeekAuditConfigured();\n  const kolExportHref = buildExportHref(\"kol\");\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <h1>Growth · KOL</h1>\n        <p style={leadStyle}>\n          KOL rate overrides from `referral_kol_rates` joined with the linked\n          performance from `referral_links` and `referral_earnings`. Drill in\n          to the user-detail page to inspect the KOL&apos;s full activity.\n        </p>\n      </header>\n\n      <section\n        aria-labelledby=\"kol-heading\"\n        id=\"kol\"\n        style={sectionStyle}\n      >\n        <div style={sectionHeaderRowStyle}>\n          <h2 id=\"kol-heading\" style={sectionHeadingStyle}>\n            KOL rates\n          </h2>\n          <ExportActionLink\n            href={kolExportHref}\n            label=\"Export CSV\"\n            enabled={exportsEnabled}\n          />\n        </div>\n        <p style={hintStyle}>\n          Default 100 rows · sorted by referrer earnings · server-side capped\n          at 500.\n        </p>\n        <GrowthKolTable rows={rows} error={kolError} />\n      </section>\n    </main>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst sectionHeaderRowStyle: CSSProperties = {\n  display: \"flex\",\n  alignItems: \"center\",\n  justifyContent: \"space-between\",\n  gap: \"0.75rem\",\n  flexWrap: \"wrap\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n","structuredPatch":[{"oldStart":5,"oldLines":6,"newStart":5,"newLines":7,"lines":[" import type { PeekKolPerformanceRow } from \"../../../src/lib/types/peek\";"," import {","   getPeekActorContext,","+  isActionAllowedForRole,","   isRouteAllowedForRole,"," } from \"../../../src/server/access-policy\";"," import { listKolPerformance } from \"../../../src/server/db/queries/get-growth-referrals\";"]}],"userModified":false,"replaceAll":false}}
