{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01EF7p9sccNZNfj6TR1upTBh","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_019rLMW3wSxbQEm2fy1ziJMG","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/challenge-assignments-table.tsx","content":"// Challenge assignments table for /economy/challenges (FR-9).\n//\n// Read-only table over `PeekChallengeAssignmentRow`. Status is rendered as a\n// status chip; progress is rendered with the migration-011 target so an\n// operator can see how far an assignment is from completion. The user cell\n// links to the user-detail page.\nimport Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekChallengeAssignmentRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type ChallengeAssignmentsTableProps = {\n  rows: ReadonlyArray<PeekChallengeAssignmentRow>;\n  error?: string | null;\n};\n\nexport function ChallengeAssignmentsTable({\n  rows,\n  error = null,\n}: ChallengeAssignmentsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Challenge assignments unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>\n          No challenge_assignments rows match these filters.\n        </p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see active and recent\n          assignments.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Assigned</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Challenge</th>\n            <th style={headerCellStyle(\"left\")}>Campaign</th>\n            <th style={headerCellStyle(\"left\")}>Period</th>\n            <th style={headerCellStyle(\"left\")}>Status</th>\n            <th style={headerCellStyle(\"right\")}>Progress</th>\n            <th style={headerCellStyle(\"left\")}>Expires</th>\n            <th style={headerCellStyle(\"left\")}>Completed</th>\n            <th style={headerCellStyle(\"left\")}>ID</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{row.assignedAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <Link href={`/users/${row.userId}`} style={linkStyle}>\n                  {row.username ?? row.userId}\n                </Link>\n                {row.username ? (\n                  <span style={subValueStyle}> · {row.userId}</span>\n                ) : null}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <div>{row.challengeTitle ?? \"—\"}</div>\n                <div style={{ ...subValueStyle, fontFamily: \"monospace\" }}>\n                  {row.challengeId}\n                </div>\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.campaignName ?? \"—\"}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.periodKey}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.status}\n                  tone={assignmentStatusTone(row.status)}\n                />\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.progress.toLocaleString(\"en-US\")}\n                <span style={subValueStyle}>\n                  {\" \"}\n                  / {row.target.toLocaleString(\"en-US\")}\n                </span>\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.expiresAt ?? \"—\"}</td>\n              <td style={bodyCellStyle(\"left\")}>{row.completedAt ?? \"—\"}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.id}\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction assignmentStatusTone(value: string): PeekStatusTone {\n  if (value === \"active\") return \"info\";\n  if (value === \"completed\") return \"positive\";\n  if (value === \"expired\") return \"warning\";\n  return \"neutral\";\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2566,"cache_read_input_tokens":124548,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2566},"output_tokens":61,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"518c908e-6895-4f30-8091-6d36dfcb3b84","uuid":"7f9dda73-c6c6-4255-95cc-9fa6c29c1470"}
