/src/components/bonus-completions-table\";\nimport { CampaignsTable } from \"../../../src/components/campaigns-table\";\nimport { ChallengeAssignmentsTable } from \"../../../src/components/challenge-assignments-table\";\nimport { ChallengesTable } from \"../../../src/components/challenges-table\";\nimport { CompletionBonusesTable } from \"../../../src/components/completion-bonuses-table\";\nimport { MetricStrip } from \"../../../src/components/metric-strip\";\nimport { ProgressEventsTable } from \"../../../src/components/progress-events-table\";\nimport {\n  normalizeBonusCompletionFiltersFromSearchParams,\n  normalizeChallengeAssignmentFiltersFromSearchParams,\n  normalizeChallengeFiltersFromSearchParams,\n  normalizeProgressEventFiltersFromSearchParams,\n} from \"../../../src/lib/economy-challenges-search-params\";\nimport type {\n  PeekBonusCompletionRow,\n  PeekCampaignRow,\n  PeekChallengeAssignmentRow,\n  PeekChallengeRow,\n  PeekChallengesOverview,\n  PeekCompletionBonusRow,\n  PeekProgressEventRow,\n} from \"../../../src/lib/types/peek\";\nimport {\n  getPeekActorContext,\n  isRouteAllowedForRole,\n} from \"../../../src/server/access-policy\";\nimport {\n  PEEK_BONUS_COMPLETIONS_DEFAULT_LIMIT,\n  PEEK_CAMPAIGNS_DEFAULT_LIMIT,\n  PEEK_CHALLENGES_DEFAULT_LIMIT,\n  PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT,\n  PEEK_COMPLETION_BONUSES_DEFAULT_LIMIT,\n  PEEK_PROGRESS_EVENTS_DEFAULT_LIMIT,\n  getChallengesOverview,\n  listBonusCompletions,\n  listCampaigns,\n  listChallengeAssignments,\n  listChallenges,\n  listCompletionBonuses,\n  listProgressEvents,\n} from \"../../../src/server/db/queries/get-challenges\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst ROUTE = \"/economy/challenges\";\n\nexport default async function EconomyChallengesPage({\n  searchParams,\n}: {\n  searchParams: Promise<Record<string, string | string[] | undefined>>;\n}) {\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);