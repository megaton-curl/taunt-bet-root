{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D9NqewAZincLGL1FwX9ced","type":"tool_result","content":"1\timport Link from \"next/link\";\n2\timport type { CSSProperties } from \"react\";\n3\timport type { PeekMetric } from \"../lib/types/peek\";\n4\t\n5\texport type MetricStripProps = {\n6\t  metrics: ReadonlyArray<PeekMetric>;\n7\t  error?: string | null;\n8\t};\n9\t\n10\texport function MetricStrip({ metrics, error = null }: MetricStripProps) {\n11\t  if (error) {\n12\t    return (\n13\t      <div role=\"alert\" style={errorStyle}>\n14\t        Metrics unavailable: {error}\n15\t      </div>\n16\t    );\n17\t  }\n18\t\n19\t  if (metrics.length === 0) {\n20\t    return (\n21\t      <div role=\"status\" style={emptyStyle}>\n22\t        No metrics available for this view.\n23\t      </div>\n24\t    );\n25\t  }\n26\t\n27\t  return (\n28\t    <section\n29\t      aria-label=\"Metric strip\"\n30\t      style={{\n31\t        display: \"grid\",\n32\t        gap: \"1rem\",\n33\t        gridTemplateColumns: \"repeat(auto-fit, minmax(220px, 1fr))\",\n34\t      }}\n35\t    >\n36\t      {metrics.map((metric) => (\n37\t        <article key={metric.id} aria-labelledby={`peek-metric-${metric.id}-label`} style={cardStyle}>\n38\t          <header style={cardHeaderStyle}>\n39\t            <p id={`peek-metric-${metric.id}-label`} style={labelStyle}>\n40\t              {metric.label}\n41\t            </p>\n42\t            <span style={freshnessStyle(metric.freshness)} title={`Freshness: ${metric.freshness}`}>\n43\t              {metric.freshness}\n44\t            </span>\n45\t          </header>\n46\t          <p style={valueStyle}>\n47\t            {metric.valueDisplay}\n48\t            {metric.unit ? <span style={unitStyle}> {metric.unit}</span> : null}\n49\t          </p>\n50\t          <p style={definitionStyle}>{metric.definition}</p>"}]},"parent_tool_use_id":null,"session_id":"518c908e-6895-4f30-8091-6d36dfcb3b84","uuid":"d644176d-894d-43c6-9fb7-88f5ed