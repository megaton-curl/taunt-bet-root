{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_012wQCatNvjjEy4rgX7TfdGc","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01EDXLoJXPeq3QcbAtJJcbiR","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/campaigns-table.tsx","content":"// Campaigns table for /economy/challenges (FR-9).\n//\n// Read-only dense table over `PeekCampaignRow`. Renders campaign type as a\n// status chip and is_active state as a positive/neutral chip so an operator\n// can see at a glance which top-level containers are live. Editing campaigns\n// is out of scope here (FR-9 / FR-14).\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekCampaignRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type CampaignsTableProps = {\n  rows: ReadonlyArray<PeekCampaignRow>;\n  error?: string | null;\n};\n\nexport function CampaignsTable({ rows, error = null }: CampaignsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Campaigns unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No campaigns rows.</p>\n        <p style={emptyBodyStyle}>\n          The `campaigns` table has not been seeded yet, so no challenge or\n          bonus container can be displayed.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Name</th>\n            <th style={headerCellStyle(\"left\")}>Type</th>\n            <th style={headerCellStyle(\"left\")}>State</th>\n            <th style={headerCellStyle(\"left\")}>Starts</th>\n            <th style={headerCellStyle(\"left\")}>Ends</th>\n            <th style={headerCellStyle(\"right\")}>Challenges</th>\n            <th style={headerCellStyle(\"right\")}>Active assignments</th>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>ID</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{row.name}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.campaignType}\n                  tone={campaignTypeTone(row.campaignType)}\n                />\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.isActive ? \"active\" : \"inactive\"}\n                  tone={row.isActive ? \"positive\" : \"neutral\"}\n                />\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.startsAt ?? \"—\"}</td>\n              <td style={bodyCellStyle(\"left\")}>{row.endsAt ?? \"—\"}</td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.challengeCount.toLocaleString(\"en-US\")}\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.activeAssignmentCount.toLocaleString(\"en-US\")}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.id}\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction campaignTypeTone(value: string): PeekStatusTone {\n  if (value === \"daily\") return \"info\";\n  if (value === \"weekly\") return \"info\";\n  if (value === \"onboarding\") return \"positive\";\n  if (value === \"dogpile\") return \"warning\";\n  return \"neutral\";\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3845,"cache_read_input_tokens":118491,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3845},"output_tokens":7,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"518c908e-6895-4f30-8091-6d36dfcb3b84","uuid":"1689f5bc-93eb-4fa2-978e-1eb8a92e1720"}
