ng\"\n        id=\"progress-events\"\n        style={sectionStyle}\n      >\n        <h2 id=\"progress-heading\" style={sectionHeadingStyle}>\n          Progress events\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_PROGRESS_EVENTS_DEFAULT_LIMIT} rows · sorted newest\n          first · server-side capped. Append-only anti-gaming audit pinning\n          each round to its assignment. Read-only.\n        </p>\n        <ProgressEventsFilterBar filters={progressFilters} action={ROUTE} />\n        <ProgressEventsTable rows={progressEvents} error={progressError} />\n      </section>\n\n      <section\n        aria-labelledby=\"completion-bonuses-heading\"\n        id=\"completion-bonuses\"\n        style={sectionStyle}\n      >\n        <h2 id=\"completion-bonuses-heading\" style={sectionHeadingStyle}>\n          Completion bonuses\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_COMPLETION_BONUSES_DEFAULT_LIMIT} rows · sorted active\n          first · read-only. Editing completion-bonus definitions is out of\n          scope.\n        </p>\n        <CompletionBonusesTable\n          rows={completionBonuses}\n          error={completionBonusesError}\n        />\n      </section>\n\n      <section\n        aria-labelledby=\"bonus-completions-heading\"\n        id=\"bonus-completions\"\n        style={sectionStyle}\n      >\n        <h2 id=\"bonus-completions-heading\" style={sectionHeadingStyle}>\n          Bonus completions\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_BONUS_COMPLETIONS_DEFAULT_LIMIT} rows · sorted newest\n          first · server-side capped. Per-player per-period meta-quest payouts.\n          Read-only.\n        </p>\n        <BonusCompletionsFilterBar\n          filters={bonusCompletionFilters}\n          action={ROUTE}\n        />\n        <BonusCompletionsTable\n          rows={bonusCompletions}\n          error={bonusCompletionsError}\n        />\n      </section>\n    </main>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n","structuredPatch":[],"originalFile":null,"userModified":false}}
