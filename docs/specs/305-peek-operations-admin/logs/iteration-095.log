{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YNQHCL8P3STZsrtyVs9MVu","type":"tool_result","content":"1\t// Cross-user point_grants ledger table for /economy/points (FR-9).\n2\t//\n3\t// Append-only ledger. Renders the source-type as a status chip and links the\n4\t// user cell to user-detail. Bigint amounts round-trip as text to preserve\n5\t// precision (FR-4). source_id is shown verbatim because its meaning depends\n6\t// on source_type (round id, challenge id, etc.) and the operator is the audience\n7\t// that knows which is which.\n8\timport Link from \"next/link\";\n9\timport type { CSSProperties } from \"react\";\n10\timport type {\n11\t  PeekPointGrantLedgerRow,\n12\t  PeekStatusTone,\n13\t} from \"../lib/types/peek\";\n14\timport { StatusChip } from \"./status-chip\";\n15\t\n16\texport type PointGrantsTableProps = {\n17\t  rows: ReadonlyArray<PeekPointGrantLedgerRow>;\n18\t  error?: string | null;\n19\t};\n20\t\n21\texport function PointGrantsTable({\n22\t  rows,\n23\t  error = null,\n24\t}: PointGrantsTableProps) {\n25\t  if (error) {\n26\t    return (\n27\t      <div role=\"alert\" style={errorStyle}>\n28\t        Point grants unavailable: {error}\n29\t      </div>\n30\t    );\n31\t  }\n32\t\n33\t  if (rows.length === 0) {\n34\t    return (\n35\t      <div role=\"status\" style={emptyStyle}>\n36\t        <p style={emptyTitleStyle}>No point_grants rows match these filters.</p>\n37\t        <p style={emptyBodyStyle}>\n38\t          Adjust the filters above or clear them to see recent point grants.\n39\t        </p>\n40\t      </div>\n41\t    );\n42\t  }\n43\t\n44\t  return (\n45\t    <div style={wrapperStyle}>\n46\t      <table style={tableStyle}>\n47\t        <thead>\n48\t          <tr style={headerRowStyle}>\n49\t            <th style={headerCellStyle(\"left\")}>Created</th>\n50\t            <th style={headerCellStyle(\"left\")}>User</th>\n51\t            <th style={headerCellStyle(\"left\")}>Wallet</th>\n52\t            <th style={headerCellStyle(\"left\")}>Source type</th>\n53\t            <th style={headerCellStyle(\"left\")}>Source id</th>\n54\t            <th style={headerCellStyle(\"right\")}>Amount</th>\n55\t          </tr>\n56\t        </thead>\n57\t        <tbody>\n58\t          {rows.map((row) => (\n59\t            <tr key={row.id} style={bodyRowStyle}>\n60\t              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n61\t              <td style={bodyCellStyle(\"left\")}>\n62\t                <Link href={`/users/${row.userId}`} style={linkStyle}>\n63\t                  {row.username ?? row.userId}\n64\t                </Link>\n65\t                {row.username ? (\n66\t                  <span style={subValueStyle}> · {row.userId}</span>\n67\t                ) : null}\n68\t              </td>\n69\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n70\t                {row.wallet}\n71\t              </td>\n72\t              <td style={bodyCellStyle(\"left\")}>\n73\t                <StatusChip\n74\t                  label={row.sourceType}\n75\t                  tone={sourceTypeTone(row.sourceType)}\n76\t                />\n77\t              </td>\n78\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n79\t                {row.sourceId}\n80\t              </td>\n81\t              <td\n82\t                style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}\n83\t                title={row.amount}\n84\t              >\n85\t                {formatCount(row.amount)}\n86\t              </td>\n87\t            </tr>\n88\t          ))}\n89\t        </tbody>\n90\t      </table>\n91\t    </div>\n92\t  );\n93\t}\n94\t\n95\tfunction sourceTypeTone(value: string): PeekStatusTone {\n96\t  if (value === \"wager\") return \"neutral\";\n97\t  if (value === \"challenge_completed\") return \"info\";\n98\t  if (value === \"bonus_completed\") return \"info\";\n99\t  if (value === \"crate_points\") return \"positive\";\n100\t  return \"neutral\";\n101\t}\n102\t\n103\tfunction formatCount(value: string): string {\n104\t  if (!value || value === \"0\") return \"0\";\n105\t  const negative = value.startsWith(\"-\");\n106\t  const digits = negative ? value.slice(1) : value;\n107\t  if (!/^[0-9]+$/.test(digits)) return value;\n108\t  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n109\t  return negative ? `-${grouped}` : grouped;\n110\t}\n111\t\n112\tconst wrapperStyle: CSSProperties = {\n113\t  overflowX: \"auto\",\n114\t  border: \"1px solid #1e293b\",\n115\t  borderRadius: \"0.75rem\",\n116\t};\n117\t\n118\tconst tableStyle: CSSProperties = {\n119\t  width: \"100%\",\n120\t  borderCollapse: \"collapse\",\n121\t};\n122\t\n123\tconst headerRowStyle: CSSProperties = {\n124\t  background: \"#111827\",\n125\t  color: \"#94a3b8\",\n126\t};\n127\t\n128\tconst bodyRowStyle: CSSProperties = {\n129\t  borderTop: \"1px solid #1e293b\",\n130\t};\n131\t\n132\tconst linkStyle: CSSProperties = {\n133\t  color: \"#93c5fd\",\n134\t  textDecoration: \"none\",\n135\t};\n136\t\n137\tconst subValueStyle: CSSProperties = {\n138\t  color: \"#64748b\",\n139\t  fontSize: \"0.75rem\",\n140\t  marginLeft: \"0.25rem\",\n141\t};\n142\t\n143\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n144\t  return {\n145\t    padding: \"0.75rem\",\n146\t    textAlign: align,\n147\t    fontSize: \"0.875rem\",\n148\t    fontWeight: 600,\n149\t  };\n150\t}\n151\t\n152\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n153\t  return {\n154\t    padding: \"0.75rem\",\n155\t    textAlign: align,\n156\t    fontSize: \"0.875rem\",\n157\t    color: \"#e2e8f0\",\n158\t    verticalAlign: \"top\",\n159\t  };\n160\t}\n161\t\n162\tconst errorStyle: CSSProperties = {\n163\t  margin: 0,\n164\t  padding: \"0.75rem 1rem\",\n165\t  borderRadius: \"0.75rem\",\n166\t  background: \"#3f1d1d\",\n167\t  color: \"#fecaca\",\n168\t};\n169\t\n170\tconst emptyStyle: CSSProperties = {\n171\t  padding: \"1.5rem\",\n172\t  borderRadius: \"0.75rem\",\n173\t  border: \"1px dashed #334155\",\n174\t  background: \"#0b1220\",\n175\t  color: \"#cbd5f5\",\n176\t  display: \"grid\",\n177\t  gap: \"0.5rem\",\n178\t};\n179\t\n180\tconst emptyTitleStyle: CSSProperties = {\n181\t  margin: 0,\n182\t  fontSize: \"1rem\",\n183\t  fontWeight: 600,\n184\t};\n185\t\n186\tconst emptyBodyStyle: CSSProperties = {\n187\t  margin: 0,\n188\t  fontSize: \"0.875rem\",\n189\t  color: \"#94a3b8\",\n190\t};\n191\t"}]},"parent_tool_use_id":null,"session_id":"518c908e-6895-4f30-8091-6d36dfcb3b84","uuid":"da174492-3967-4c5b-8448-59180cee6c15","timestamp":"2026-04-26T06:03:40.861Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/point-grants-table.tsx","content":"// Cross-user point_grants ledger table for /economy/points (FR-9).\n//\n// Append-only ledger. Renders the source-type as a status chip and links the\n// user cell to user-detail. Bigint amounts round-trip as text to preserve\n// precision (FR-4). source_id is shown verbatim because its meaning depends\n// on source_type (round id, challenge id, etc.) and the operator is the audience\n// that knows which is which.\nimport Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekPointGrantLedgerRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type PointGrantsTableProps = {\n  rows: ReadonlyArray<PeekPointGrantLedgerRow>;\n  error?: string | null;\n};\n\nexport function PointGrantsTable({\n  rows,\n  error = null,\n}: PointGrantsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Point grants unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No point_grants rows match these filters.</p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see recent point grants.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"left\")}>Source type</th>\n            <th style={headerCellStyle(\"left\")}>Source id</th>\n            <th style={headerCellStyle(\"right\")}>Amount</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <Link href={`/users/${row.userId}`} style={linkStyle}>\n                  {row.username ?? row.userId}\n                </Link>\n                {row.username ? (\n                  <span style={subValueStyle}> · {row.userId}</span>\n                ) : null}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.wallet}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.sourceType}\n                  tone={sourceTypeTone(row.sourceType)}\n                />\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.sourceId}\n              </td>\n              <td\n                style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}\n                title={row.amount}\n              >\n                {formatCount(row.amount)}\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction sourceTypeTone(value: string): PeekStatusTone {\n  if (value === \"wager\") return \"neutral\";\n  if (value === \"challenge_completed\") return \"info\";\n  if (value === \"bonus_completed\") return \"info\";\n  if (value === \"crate_points\") return \"positive\";\n  return \"neutral\";\n}\n\nfunction formatCount(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  if (!/^[0-9]+$/.test(digits)) return value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n  marginLeft: \"0.25rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":191,"startLine":1,"totalLines":191}}}
