s });\n  } catch (error) {\n    challengesError =\n      error instanceof Error\n        ? error.message\n        : \"Challenges could not be loaded.\";\n  }\n\n  try {\n    assignments = await listChallengeAssignments({ filters: assignmentFilters });\n  } catch (error) {\n    assignmentsError =\n      error instanceof Error\n        ? error.message\n        : \"Challenge assignments could not be loaded.\";\n  }\n\n  try {\n    progressEvents = await listProgressEvents({ filters: progressFilters });\n  } catch (error) {\n    progressError =\n      error instanceof Error\n        ? error.message\n        : \"Progress events could not be loaded.\";\n  }\n\n  try {\n    completionBonuses = await listCompletionBonuses();\n  } catch (error) {\n    completionBonusesError =\n      error instanceof Error\n        ? error.message\n        : \"Completion bonuses could not be loaded.\";\n  }\n\n  try {\n    bonusCompletions = await listBonusCompletions({\n      filters: bonusCompletionFilters,\n    });\n  } catch (error) {\n    bonusCompletionsError =\n      error instanceof Error\n        ? error.message\n        : \"Bonus completions could not be loaded.\";\n  }\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <h1>Economy · Challenges</h1>\n        <p style={leadStyle}>\n          Campaign, challenge, assignment, progress, and bonus visibility for\n          the migration-011 challenge engine. Read-only — challenge, campaign,\n          and completion-bonus definition editing is out of scope (FR-9 /\n          FR-14).\n        </p>\n      </header>\n\n      <section aria-labelledby=\"overview-heading\">\n        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n          Overview\n        </h2>\n        <MetricStrip metrics={overview.metrics} error={overviewError} />\n      </section>\n\n      <section\n        aria-labelledby=\"campaigns-heading\"\n        id=\"campaigns\"\n        style={sectionStyle}\n      >\n        <h2 id=\"campaigns-heading\" style={sectionHeadingStyle}>\n          Campaigns\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_CAMPAIGNS_DEFAULT_LIMIT} rows · sorted active first ·\n          read-only. Editing campaigns is out of scope.\n        </p>\n        <CampaignsTable rows={campaigns} error={campaignsError} />\n      </section>\n\n      <section\n        aria-labelledby=\"challenges-heading\"\n        id=\"challenges\"\n        style={sectionStyle}\n      >\n        <h2 id=\"challenges-heading\" style={sectionHeadingStyle}>\n          Challenges\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_CHALLENGES_DEFAULT_LIMIT} rows · grouped by campaign +\n          sort order · read-only. Editing challenge definitions is out of\n          scope.\n        </p>\n        <ChallengesFilterBar filters={challengeFilters} action={ROUTE} />\n        <ChallengesTable rows={challenges} error={challengesError} />\n      </section>\n\n      <section\n        aria-labelledby=\"assignments-heading\"\n        id=\"assignments\"\n        style={sectionStyle}\n      >\n        <h2 id=\"assignments-heading\" style={sectionHeadingStyle}>\n          Assignments\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT} rows · sorted\n          newest first · server-side capped. Filter by user, challenge,\n          campaign, period key, status, and a [from, to) assigned-date window.\n          Read-only.\n        </p>\n        <ChallengeAssignmentsFilterBar\n          filters={assignmentFilters}\n          action={ROUTE}\n        />\n        <ChallengeAssignmentsTable\n          rows={assignments}\n          error={assignmentsError}\n        />\n      </section>\n\n      <section\n        aria-labelledby=\"progress-heading\"\n        id=\"progress-events\"\n        style={sectionStyle}\n      >\n        <h2 id=\"progress-heading\" style={sectionHeadingStyle}>\n          Progress events\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_PROGRESS_EVENTS_DEFAULT_LIMIT} rows · sorted newest\n          first · server-side capped. Append-only anti-gaming audit pinning\n          each round to its assignment. Read-only.\n        </p>\n        <ProgressEventsFilterBar filters={progressFilters} action={ROUTE} />\n        <ProgressEventsTable rows={progressEvents} error={progressError} />\n      </section>\n\n      <section\n        aria-labelledby=\"completion-bonuses-heading\"\n        id=\"completion-bonuses\"\n        style={sectionStyle}\n      >\n        <h2 id=\"completion-bonuses-heading\" style={sectionHeadingStyle}>\n          Completion bonuses\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_COMPLETION_BONUSES_DEFAULT_LIMIT} rows · sorted active\n          first · read-only. Editing completion-bonus definitions is out of\n          scope.\n        </p>\n        <CompletionBonusesTable\n          rows={completionBonuses}\n          error={completionBonusesError}\n        />\n      </section>\n\n      <section\n        aria-labelledby=\"bonus-completions-heading\"\n        id=\"bonus-completions\"\n        style={sectionStyle}\n      >\n        <h2 id=\"bonus-completions-heading\" style={sectionHeadingStyle}>\n          Bonus completions\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_BONUS_COMPLETIONS_DEFAULT_LIMIT} rows · sorted newest\n          first · server-side capped. Per-player per-period meta-quest payouts.\n          Read-only.\n        </p>\n        <BonusCompletionsFilterBar\n          filters={bonusCompletionFilters}\n          action={ROUTE}\n        />\n        <BonusCompletionsTable\n          rows={bonusCompletions}\n          error={bonusCompletionsError}\n        />\n      </section>\n    </main>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadi