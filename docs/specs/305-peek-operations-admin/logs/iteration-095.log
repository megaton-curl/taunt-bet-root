ate: PeekEmptyState;\n  error?: string | null;\n};\n\nexport function EmptyState({ state, error = null }: EmptyStateProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Empty state unavailable: {error}\n      </div>\n    );\n  }\n\n  return (\n    <div role=\"status\" style={containerStyle}>\n      <p style={titleStyle}>{state.title}</p>\n      {state.body ? <p style={bodyStyle}>{state.body}</p> : null}\n    </div>\n  );\n}\n\nconst containerStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst titleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst bodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n","numLines":55,"startLine":1,"totalLines":55}}}
