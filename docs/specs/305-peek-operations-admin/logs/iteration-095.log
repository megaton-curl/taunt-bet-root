Style}>\n            <th style={headerCellStyle(\"left\")}>Assigned</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Challenge</th>\n            <th style={headerCellStyle(\"left\")}>Campaign</th>\n            <th style={headerCellStyle(\"left\")}>Period</th>\n            <th style={headerCellStyle(\"left\")}>Status</th>\n            <th style={headerCellStyle(\"right\")}>Progress</th>\n            <th style={headerCellStyle(\"left\")}>Expires</th>\n            <th style={headerCellStyle(\"left\")}>Completed</th>\n            <th style={headerCellStyle(\"left\")}>ID</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{row.assignedAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <Link href={`/users/${row.userId}`} style={linkStyle}>\n                  {row.username ?? row.userId}\n                </Link>\n                {row.username ? (\n                  <span style={subValueStyle}> · {row.userId}</span>\n                ) : null}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <div>{row.challengeTitle ?? \"—\"}</div>\n                <div style={{ ...subValueStyle, fontFamily: \"monospace\" }}>\n                  {row.challengeId}\n                </div>\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.campaignName ?? \"—\"}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.periodKey}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.status}\n                  tone={assignmentStatusTone(row.status)}\n                />\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.progress.toLocaleString(\"en-US\")}\n                <span style={subValueStyle}>\n                  {\" \"}\n                  / {row.target.toLocaleString(\"en-US\")}\n                </span>\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.expiresAt ?? \"—\"}</td>\n              <td style={bodyCellStyle(\"left\")}>{row.completedAt ?? \"—\"}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.id}\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction assignmentStatusTone(value: string): PeekStatusTone {\n  if (value === \"active\") return \"info\";\n  if (value === \"completed\") return \"positive\";\n  if (value === \"expired\") return \"warning\";\n  return \"neutral\";\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","structuredPatch":[],"originalFile":null,"userModified":false}}
