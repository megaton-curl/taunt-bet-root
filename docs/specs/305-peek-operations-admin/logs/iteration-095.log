{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01WQhBwjS529KbCR1enu1xm7","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01ANYTaPR5FiH6iGCwmJDdSD","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/completion-bonuses-table.tsx","content":"// Completion bonuses table for /economy/challenges (FR-9).\n//\n// Read-only dense table over `PeekCompletionBonusRow`. Each row is a\n// meta-quest definition (e.g. \"complete all daily challenges → bonus crate\")\n// annotated with the per-bonus completion count so an operator can see which\n// bonuses are actually paying out. Definition editing is out of scope here\n// (FR-9 / FR-14).\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekCompletionBonusRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type CompletionBonusesTableProps = {\n  rows: ReadonlyArray<PeekCompletionBonusRow>;\n  error?: string | null;\n};\n\nexport function CompletionBonusesTable({\n  rows,\n  error = null,\n}: CompletionBonusesTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Completion bonuses unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No completion_bonuses rows.</p>\n        <p style={emptyBodyStyle}>\n          The `completion_bonuses` table has not been seeded yet, so no\n          meta-quest payouts are configured.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Title</th>\n            <th style={headerCellStyle(\"left\")}>Campaign</th>\n            <th style={headerCellStyle(\"left\")}>State</th>\n            <th style={headerCellStyle(\"right\")}>Required</th>\n            <th style={headerCellStyle(\"left\")}>Reward</th>\n            <th style={headerCellStyle(\"right\")}>Completions</th>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>ID</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>\n                <div>{row.title}</div>\n                {row.description ? (\n                  <div style={subValueStyle}>{row.description}</div>\n                ) : null}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <div>{row.campaignName ?? \"—\"}</div>\n                {row.campaignType ? (\n                  <div style={subValueStyle}>{row.campaignType}</div>\n                ) : null}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.isActive ? \"active\" : \"inactive\"}\n                  tone={row.isActive ? \"positive\" : \"neutral\"}\n                />\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.requiredCount.toLocaleString(\"en-US\")}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.rewardType}\n                  tone={rewardTypeTone(row.rewardType)}\n                />\n                {row.rewardAmount !== null ? (\n                  <span style={subValueStyle}>\n                    {\" \"}\n                    · {row.rewardAmount.toLocaleString(\"en-US\")}\n                  </span>\n                ) : null}\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.completionCount.toLocaleString(\"en-US\")}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.id}\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction rewardTypeTone(value: string): PeekStatusTone {\n  if (value === \"points\") return \"positive\";\n  if (value === \"crate\") return \"warning\";\n  return \"neutral\";\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \