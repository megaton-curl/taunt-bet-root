{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AEWG5eQowcC16pdF131Wk1","type":"tool_result","content":"1\timport type { CSSProperties } from \"react\";\n2\timport type { PeekStatusTone } from \"../lib/types/peek\";\n3\t\n4\texport type StatusChipProps = {\n5\t  label: string | null;\n6\t  tone?: PeekStatusTone;\n7\t  title?: string;\n8\t  error?: string | null;\n9\t};\n10\t\n11\texport function StatusChip({\n12\t  label,\n13\t  tone = \"neutral\",\n14\t  title,\n15\t  error = null,\n16\t}: StatusChipProps) {\n17\t  if (error) {\n18\t    return (\n19\t      <span role=\"alert\" style={errorStyle}>\n20\t        Status unavailable: {error}\n21\t      </span>\n22\t    );\n23\t  }\n24\t\n25\t  if (!label) {\n26\t    return (\n27\t      <span role=\"status\" aria-label=\"status missing\" style={emptyStyle}>\n28\t        —\n29\t      </span>\n30\t    );\n31\t  }\n32\t\n33\t  return (\n34\t    <span\n35\t      role=\"status\"\n36\t      data-tone={tone}\n37\t      title={title}\n38\t      style={chipStyle(tone)}\n39\t    >\n40\t      {label}\n41\t    </span>\n42\t  );\n43\t}\n44\t\n45\tfunction chipStyle(tone: PeekStatusTone): CSSProperties {\n46\t  const tones: Record<PeekStatusTone, { background: string; color: string; border: string }> = {\n47\t    neutral: { background: \"#1f2937\", color: \"#cbd5f5\", border: \"#334155\" },\n48\t    positive: { background: \"#064e3b\", color: \"#a7f3d0\", border: \"#065f46\" },\n49\t    warning: { background: \"#3f3f00\", color: \"#fde68a\", border: \"#b45309\" },\n50\t    negative: { background: \"#3f1d1d\", color: \"#fecaca\", border: \"#991b1b\" },\n51\t    info: { background: \"#1e293b\", color: \"#bfdbfe\", border: \"#1d4ed8\" },\n52\t  };\n53\t  const t = tones[tone];\n54\t  return {\n55\t    display: \"inline-flex\",\n56\t    alignItems: \"center\",\n57\t    fontSize: \"0.6875rem\",\n58\t    fontWeight: 600,\n59\t    textTransform: \"uppercase\",\n60\t    letterSpacing: \"0.05em\",\n61\t    padding: \"0.125rem 0.5rem\",\n62\t    borderRadius: \"9999px\",\n63\t    background: t.background,\n64\t    color: t.color,\n65\t    border: `1px solid ${t.border}`,\n66\t    whiteSpace: \"nowrap\",\n67\t  };\n68\t}\n69\t\n70\tconst emptyStyle: CSSProperties = {\n71\t  display: \"inline-flex\",\n72\t  alignItems: \"center\",\n73\t  fontSize: \"0.75rem\",\n74\t  color: \"#94a3b8\",\n75\t  padding: \"0.125rem 0.25rem\",\n76\t};\n77\t\n78\tconst errorStyle: CSSProperties = {\n79\t  display: \"inline-flex\",\n80\t  alignItems: \"center\",\n81\t  fontSize: \"0.75rem\",\n82\t  padding: \"0.125rem 0.5rem\",\n83\t  borderRadius: \"9999px\",\n84\t  background: \"#3f1d1d\",\n85\t  color: \"#fecaca\",\n86\t  border: \"1px solid #991b1b\",\n87\t};\n88\t"}]},"parent_tool_use_id":null,"session_id":"518c908e-6895-4f30-8091-6d36dfcb3b84","uuid":"ea474c75-4607-4d12-8fd1-328f72907df2","timestamp":"2026-04-26T06:03:38.627Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/status-chip.tsx","content":"import type { CSSProperties } from \"react\";\nimport type { PeekStatusTone } from \"../lib/types/peek\";\n\nexport type StatusChipProps = {\n  label: string | null;\n  tone?: PeekStatusTone;\n  title?: string;\n  error?: string | null;\n};\n\nexport function StatusChip({\n  label,\n  tone = \"neutral\",\n  title,\n  error = null,\n}: StatusChipProps) {\n  if (error) {\n    return (\n      <span role=\"alert\" style={errorStyle}>\n        Status unavailable: {error}\n      </span>\n    );\n  }\n\n  if (!label) {\n    return (\n      <span role=\"status\" aria-label=\"status missing\" style={emptyStyle}>\n        —\n      </span>\n    );\n  }\n\n  return (\n    <span\n      role=\"status\"\n      data-tone={tone}\n      title={title}\n      style={chipStyle(tone)}\n    >\n      {label}\n    </span>\n  );\n}\n\nfunction chipStyle(tone: PeekStatusTone): CSSProperties {\n  const tones: Record<PeekStatusTone, { background: string; color: string; border: string }> = {\n    neutral: { background: \"#1f2937\", color: \"#cbd5f5\", border: \"#334155\" },\n    positive: { background: \"#064e3b\", color: \"#a7f3d0\", border: \"#065f46\" },\n    warning: { background: \"#3f3f00\", color: \"#fde68a\", border: \"#b45309\" },\n    negative: { background: \"#3f1d1d\", color: \"#fecaca\", border: \"#991b1b\" },\n    info: { background: \"#1e293b\", color: \"#bfdbfe\", border: \"#1d4ed8\" },\n  };\n  const t = tones[tone];\n  return {\n    display: \"inline-flex\",\n    alignItems: \"center\",\n    fontSize: \"0.6875rem\",\n    fontWeight: 600,\n    textTransform: \"uppercase\",\n    letterSpacing: \"0.05em\",\n    padding: \"0.125rem 0.5rem\",\n    borderRadius: \"9999px\",\n    background: t.background,\n    color: t.color,\n    border: `1px solid ${t.border}`,\n    whiteSpace: \"nowrap\",\n  };\n}\n\nconst emptyStyle: CSSProperties = {\n  display: \"inline-flex\",\n  alignItems: \"center\",\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n  padding: \"0.125rem 0.25rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  display: \"inline-flex\",\n  alignItems: \"center\",\n  fontSize: \"0.75rem\",\n  padding: \"0.125rem 0.5rem\",\n  borderRadius: \"9999px\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n  border: \"1px solid #991b1b\",\n};\n","numLines":88,"startLine":1,"totalLines":88}}}
