fundings: ReadonlyArray<PeekRewardPoolFundingRow> = [];\n\n  let overviewError: string | null = null;\n  let poolError: string | null = null;\n  let configError: string | null = null;\n  let fundingsError: string | null = null;\n\n  try {\n    overview = await getRewardsOverview();\n  } catch (error) {\n    overviewError =\n      error instanceof Error\n        ? error.message\n        : \"Rewards overview could not be loaded.\";\n  }\n\n  try {\n    pool = await getRewardPool();\n  } catch (error) {\n    poolError =\n      error instanceof Error\n        ? error.message\n        : \"Reward pool singleton could not be loaded.\";\n  }\n\n  try {\n    config = await listRewardConfig();\n  } catch (error) {\n    configError =\n      error instanceof Error\n        ? error.message\n        : \"Reward config rows could not be loaded.\";\n  }\n\n  try {\n    fundings = await listRewardPoolFundings();\n  } catch (error) {\n    fundingsError =\n      error instanceof Error\n        ? error.message\n        : \"Reward pool fundings could not be loaded.\";\n  }\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <h1>Economy · Rewards</h1>\n        <p style={leadStyle}>\n          Reward pool accounting, operator-tunable economy config, and the\n          per-round funding ledger. Drill into a funding row to open universal\n          search for the source round.\n        </p>\n      </header>\n\n      <section aria-labelledby=\"overview-heading\">\n        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n          Overview\n        </h2>\n        <MetricStrip metrics={overview.metrics} error={overviewError} />\n      </section>\n\n      <section aria-labelledby=\"pool-heading\" id=\"pool\" style={sectionStyle}>\n        <h2 id=\"pool-heading\" style={sectionHeadingStyle}>\n          Pool balance\n        </h2>\n        <p style={hintStyle}>\n          Singleton row from `reward_pool` (id = 1) · live read · lamports\n          retain raw u64 precision 