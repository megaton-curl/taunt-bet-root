{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015vaxcb9R6xtWPFMz9UYv1k","type":"tool_result","content":"1\t// Query tests for the FR-9 reward-economy admin reads (`get-rewards.ts`).\n2\t//\n3\t// Mirrors the SQL-mock pattern used in `get-growth-referrals.test.ts` and\n4\t// `get-command-center-attention.test.ts`: a tagged-template stub records each\n5\t// call (joined SQL text + bound values) and dequeues a per-call response so\n6\t// each test can assert which SQL fired, in what order, and with which clamps.\n7\t\n8\timport { describe, expect, it } from \"vitest\";\n9\timport type { Sql } from \"postgres\";\n10\timport {\n11\t  PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS,\n12\t  PEEK_REWARD_CONFIG_KEY_REGISTRY,\n13\t  PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT,\n14\t  PEEK_REWARD_POOL_FUNDINGS_MAX_LIMIT,\n15\t  getRewardPool,\n16\t  getRewardsOverview,\n17\t  listRewardConfig,\n18\t  listRewardPoolFundings,\n19\t} from \"../get-rewards\";\n20\timport {\n21\t  PEEK_REWARDS_OVERVIEW_METRIC_IDS,\n22\t  type PeekRewardsOverviewMetricId,\n23\t} from \"../../../../lib/types/peek\";\n24\t\n25\ttype SqlCall = {\n26\t  text: string;\n27\t  values: ReadonlyArray<unknown>;\n28\t};\n29\t\n30\ttype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n31\t\n32\ttype SqlMock = {\n33\t  sql: Sql;\n34\t  calls: ReadonlyArray<SqlCall>;\n35\t};\n36\t\n37\tfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n38\t  const calls: SqlCall[] = [];\n39\t  let cursor = 0;\n40\t\n41\t  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n42\t    const text = [...strings].join(\"?\");\n43\t    calls.push({ text, values: [...values] });\n44\t    const next = responses[cursor++];\n45\t    if (next instanceof Error) return Promise.reject(next);\n46\t    return Promise.resolve(next ?? []);\n47\t  };\n48\t\n49\t  const sql = fn as unknown as Sql;\n50\t  return { sql, calls };\n51\t}\n52\t\n53\t// `getRewardsOverview` runs two queries in parallel via Promise.all:\n54\t// 0 = reward_pool singleton read, 1 = recent fundings count.\n55\tconst OVERVIEW_ORDER: ReadonlyArray<PeekRewardsOverviewMetricId> = [\n56\t  \"rewards.balance_lamports\",\n57\t  \"rewards.lifetime_funded_lamports\",\n58\t  \"rewards.lifetime_paid_lamports\",\n59\t  \"rewards.recent_fundings\",\n60\t];\n61\t\n62\tdescribe(\"listRewardConfig\", () => {\n63\t  it(\"populated: annotates known keys with definition + expected type from the registry\", async () => {\n64\t    const mock = createSqlMock([\n65\t      [\n66\t        {\n67\t          key: \"points_per_dollar\",\n68\t          value: \"10\",\n69\t          updatedAt: \"2026-04-20T00:00:00.000Z\",\n70\t        },\n71\t        {\n72\t          key: \"reward_pool_fee_share\",\n73\t          value: \"0.25\",\n74\t          updatedAt: \"2026-04-21T00:00:00.000Z\",\n75\t        },\n76\t      ],\n77\t    ]);\n78\t\n79\t    const rows = await listRewardConfig({ sql: mock.sql });\n80\t\n81\t    expect(rows).toHaveLength(2);\n82\t    const byKey = new Map(rows.map((r) => [r.key, r]));\n83\t    const points = byKey.get(\"points_per_dollar\");\n84\t    expect(points?.value).toBe(\"10\");\n85\t    expect(points?.expectedType).toBe(\n86\t      PEEK_REWARD_CONFIG_KEY_REGISTRY.points_per_dollar?.expectedType,\n87\t    );\n88\t    expect(points?.definition).toBe(\n89\t      PEEK_REWARD_CONFIG_KEY_REGISTRY.points_per_dollar?.definition,\n90\t    );\n91\t    const ratio = byKey.get(\"reward_pool_fee_share\");\n92\t    expect(ratio?.expectedType).toBe(\"ratio\");\n93\t    expect(ratio?.definition).not.toBeNull();\n94\t  });\n95\t\n96\t  it(\"populated: unknown keys still surface with definition: null + expectedType: 'unknown'\", async () => {\n97\t    const mock = createSqlMock([\n98\t      [\n99\t        {\n100\t          key: \"experimental_unmapped_key\",\n101\t          value: \"42\",\n102\t          updatedAt: \"2026-04-25T00:00:00.000Z\",\n103\t        },\n104\t      ],\n105\t    ]);\n106\t\n107\t    const rows = await listRewardConfig({ sql: mock.sql });\n108\t\n109\t    expect(rows).toHaveLength(1);\n110\t    expect(rows[0]).toEqual({\n111\t      key: \"experimental_unmapped_key\",\n112\t      value: \"42\",\n113\t      updatedAt: \"2026-04-25T00:00:00.000Z\",\n114\t      definition: null,\n115\t      expectedType: \"unknown\",\n116\t    });\n117\t  });\n118\t\n119\t  it(\"empty: returns an empty array when the table is empty\", async () => {\n120\t    const mock = createSqlMock([[]]);\n121\t    const rows = await listRewardConfig({ sql: mock.sql });\n122\t    expect(rows).toEqual([]);\n123\t  });\n124\t\n125\t  it(\"reads from reward_config ordered by key asc\", async () => {\n126\t    const mock = createSqlMock([[]]);\n127\t    await listRewardConfig({ sql: mock.sql });\n128\t    expect(mock.calls).toHaveLength(1);\n129\t    expect(mock.calls[0].text).toMatch(/from reward_config/i);\n130\t    expect(mock.calls[0].text).toMatch(/order by key asc/i);\n131\t  });\n132\t\n133\t  it(\"load-error: a rejected query propagates\", async () => {\n134\t    const mock = createSqlMock([new Error(\"connection refused\")]);\n135\t    await expect(listRewardConfig({ sql: mock.sql })).rejects.toThrowError(\n136\t      \"connection refused\",\n137\t    );\n138\t  });\n139\t});\n140\t\n141\tdescribe(\"getRewardPool\", () => {\n142\t  it(\"populated: returns the singleton row with all four lamport/timestamp fields\", async () => {\n143\t    const mock = createSqlMock([\n144\t      [\n145\t        {\n146\t          balanceLamports: \"1500000000\",\n147\t          lifetimeFunded: \"9000000000\",\n148\t          lifetimePaid: \"7500000000\",\n149\t          updatedAt: \"2026-04-25T10:00:00.000Z\",\n150\t        },\n151\t      ],\n152\t    ]);\n153\t\n154\t    const pool = await getRewardPool({ sql: mock.sql });\n155\t\n156\t    expect(pool).toEqual({\n157\t      balanceLamports: \"1500000000\",\n158\t      lifetimeFunded: \"9000000000\",\n159\t      lifetimePaid: \"7500000000\",\n160\t      updatedAt: \"2026-04-25T10:00:00.000Z\",\n161\t    });\n162\t  });\n163\t\n164\t  it(\"populated: null/empty lamport columns coerce to '0' via readSum\", async () => {\n165\t    const mock = createSqlMock([\n166\t      [\n167\t        {\n168\t          balanceLamports: null,\n169\t          lifetimeFunded: \"\",\n170\t          lifetimePaid: undefined,\n171\t          updatedAt: \"2026-04-25T10:00:00.000Z\",\n172\t        },\n173\t      ],\n174\t    ]);\n175\t\n176\t    const pool = await getRewardPool({ sql: mock.sql });\n177\t\n178\t    expect(pool).toEqual({\n179\t      balanceLamports: \"0\",\n180\t      lifetimeFunded: \"0\",\n181\t      lifetimePaid: \"0\",\n182\t      updatedAt: \"2026-04-25T10:00:00.000Z\",\n183\t    });\n184\t  });\n185\t\n186\t  it(\"empty (singleton missing): returns null instead of throwing\", async () => {\n187\t    const mock = createSqlMock([[]]);\n188\t    const pool = await getRewardPool({ sql: mock.sql });\n189\t    expect(pool).toBeNull();\n190\t  });\n191\t\n192\t  it(\"reads reward_pool where id = 1 limit 1\", async () => {\n193\t    const mock = createSqlMock([[]]);\n194\t    await getRewardPool({ sql: mock.sql });\n195\t    expect(mock.calls).toHaveLength(1);\n196\t    expect(mock.calls[0].text).toMatch(/from reward_pool/i);\n197\t    expect(mock.calls[0].text).toMatch(/where id = 1/i);\n198\t    expect(mock.calls[0].text).toMatch(/limit 1/i);\n199\t  });\n200\t\n201\t  it(\"load-error: a rejected query propagates\", async () => {\n202\t    const mock = createSqlMock([new Error(\"db down\")]);\n203\t    await expect(getRewardPool({ sql: mock.sql })).rejects.toThrowError(\n204\t      \"db down\",\n205\t    );\n206\t  });\n207\t});\n208\t\n209\tdescribe(\"listRewardPoolFundings\", () => {\n210\t  it(\"default limit: clamps to PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT and reads the ledger\", async () => {\n211\t    const mock = createSqlMock([[]]);\n212\t    await listRewardPoolFundings({ sql: mock.sql });\n213\t\n214\t    expect(mock.calls).toHaveLength(1);\n215\t    const call = mock.calls[0];\n216\t    expect(call.text).toMatch(/from reward_pool_fundings/i);\n217\t    expect(call.text).toMatch(/order by created_at desc, id desc/i);\n218\t    expect(call.values).toContain(PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT);\n219\t  });\n220\t\n221\t  it(\"explicit limit: passes the caller value through clampLimit\", async () => {\n222\t    const mock = createSqlMock([[]]);\n223\t    await listRewardPoolFundings({ sql: mock.sql, limit: 25 });\n224\t    expect(mock.calls[0].values).toContain(25);\n225\t  });\n226\t\n227\t  it(\"limit clamps to MAX when caller asks for more\", async () => {\n228\t    const mock = createSqlMock([[]]);\n229\t    await listRewardPoolFundings({\n230\t      sql: mock.sql,\n231\t      limit: PEEK_REWARD_POOL_FUNDINGS_MAX_LIMIT + 100,\n232\t    });\n233\t    expect(mock.calls[0].values).toContain(\n234\t      PEEK_REWARD_POOL_FUNDINGS_MAX_LIMIT,\n235\t    );\n236\t  });\n237\t\n238\t  it(\"non-positive limit clamps to 1\", async () => {\n239\t    const mock = createSqlMock([[]]);\n240\t    await listRewardPoolFundings({ sql: mock.sql, limit: 0 });\n241\t    expect(mock.calls[0].values).toContain(1);\n242\t  });\n243\t\n244\t  it(\"non-finite limit falls back to the default\", async () => {\n245\t    const mock = createSqlMock([[]]);\n246\t    await listRewardPoolFundings({ sql: mock.sql, limit: Number.NaN });\n247\t    expect(mock.calls[0].values).toContain(\n248\t      PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT,\n249\t    );\n250\t  });\n251\t\n252\t  it(\"populated: returns rows with the funding-source linkage (roundId from reward_pool_fundings.round_id)\", async () => {\n253\t    const row = {\n254\t      id: \"42\",\n255\t      roundId: \"match-abc-123\",\n256\t      feeLamports: \"200000\",\n257\t      fundedLamports: \"150000\",\n258\t      createdAt: \"2026-04-25T10:00:00.000Z\",\n259\t    };\n260\t    const mock = createSqlMock([[row]]);\n261\t\n262\t    const rows = await listRewardPoolFundings({ sql: mock.sql });\n263\t\n264\t    expect(rows).toEqual([row]);\n265\t    // The funding source linkage comes back via the `roundId` field. The\n266\t    // page wires this through universal search (`/?query=<roundId>`); the\n267\t    // query itself just has to surface the column.\n268\t    expect(rows[0].roundId).toBe(\"match-abc-123\");\n269\t  });\n270\t\n271\t  it(\"empty: returns an empty array when no fundings exist\", async () => {\n272\t    const mock = createSqlMock([[]]);\n273\t    const rows = await listRewardPoolFundings({ sql: mock.sql });\n274\t    expect(rows).toEqual([]);\n275\t  });\n276\t\n277\t  it(\"load-error: a rejected query propagates\", async () => {\n278\t    const mock = createSqlMock([new Error(\"query timeout\")]);\n279\t    await expect(\n280\t      listRewardPoolFundings({ sql: mock.sql }),\n281\t    ).rejects.toThrowError(\"query timeout\");\n282\t  });\n283\t});\n284\t\n285\tdescribe(\"getRewardsOverview\", () => {\n286\t  it(\"populated: emits one PeekMetric per FR-4 id with correct values, units, and bookkeeping\", async () => {\n287\t    const mock = createSqlMock([\n288\t      [\n289\t        {\n290\t          balanceLamports: \"1500000000\",\n291\t          lifetimeFunded: \"9000000000\",\n292\t          lifetimePaid: \"7500000000\",\n293\t        },\n294\t      ],\n295\t      [{ value: 7 }],\n296\t    ]);\n297\t    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n298\t\n299\t    const result = await getRewardsOverview({ sql: mock.sql, now });\n300\t\n301\t    expect(result.generatedAt).toBe(\"2026-04-25T10:00:00.000Z\");\n302\t    expect(result.metrics).toHaveLength(4);\n303\t    expect(result.metrics.map((m) => m.id)).toEqual(OVERVIEW_ORDER);\n304\t    for (const id of PEEK_REWARDS_OVERVIEW_METRIC_IDS) {\n305\t      expect(result.metrics.find((m) => m.id === id)).toBeDefined();\n306\t    }\n307\t    for (const metric of result.metrics) {\n308\t      expect(metric.asOf).toBe(\"2026-04-25T10:00:00.000Z\");\n309\t      expect(metric.freshness).toBe(\"live\");\n310\t      expect(metric.label.length).toBeGreaterThan(0);\n311\t      expect(metric.definition.length).toBeGreaterThan(0);\n312\t      expect(metric.source.length).toBeGreaterThan(0);\n313\t      expect(metric.windowLabel.length).toBeGreaterThan(0);\n314\t      expect(metric.drilldownHref).not.toBeNull();\n315\t    }\n316\t\n317\t    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n318\t    expect(byId.get(\"rewards.balance_lamports\")?.value).toBe(\"1500000000\");\n319\t    expect(byId.get(\"rewards.balance_lamports\")?.valueDisplay).toBe(\n320\t      \"1,500,000,000\",\n321\t    );\n322\t    expect(byId.get(\"rewards.balance_lamports\")?.unit).toBe(\"lamports\");\n323\t    expect(byId.get(\"rewards.balance_lamports\")?.drilldownHref).toBe(\n324\t      \"/economy/rewards#pool\",\n325\t    );\n326\t\n327\t    expect(byId.get(\"rewards.lifetime_funded_lamports\")?.value).toBe(\n328\t      \"9000000000\",\n329\t    );\n330\t    expect(\n331\t      byId.get(\"rewards.lifetime_funded_lamports\")?.valueDisplay,\n332\t    ).toBe(\"9,000,000,000\");\n333\t    expect(\n334\t      byId.get(\"rewards.lifetime_funded_lamports\")?.drilldownHref,\n335\t    ).toBe(\"/economy/rewards#fundings\");\n336\t\n337\t    expect(byId.get(\"rewards.lifetime_paid_lamports\")?.value).toBe(\n338\t      \"7500000000\",\n339\t    );\n340\t    expect(byId.get(\"rewards.lifetime_paid_lamports\")?.valueDisplay).toBe(\n341\t      \"7,500,000,000\",\n342\t    );\n343\t\n344\t    expect(byId.get(\"rewards.recent_fundings\")?.value).toBe(7);\n345\t    expect(byId.get(\"rewards.recent_fundings\")?.valueDisplay).toBe(\"7\");\n346\t    expect(byId.get(\"rewards.recent_fundings\")?.unit).toBe(\"events\");\n347\t    expect(byId.get(\"rewards.recent_fundings\")?.drilldownHref).toBe(\n348\t      \"/economy/rewards#fundings\",\n349\t    );\n350\t  });\n351\t\n352\t  it(\"populated (large recent fundings): formats valueDisplay with thousands separator\", async () => {\n353\t    const mock = createSqlMock([\n354\t      [\n355\t        {\n356\t          balanceLamports: \"0\",\n357\t          lifetimeFunded: \"0\",\n358\t          lifetimePaid: \"0\",\n359\t        },\n360\t      ],\n361\t      [{ value: 1234 }],\n362\t    ]);\n363\t    const result = await getRewardsOverview({ sql: mock.sql });\n364\t    const recent = result.metrics.find(\n365\t      (m) => m.id === \"rewards.recent_fundings\",\n366\t    );\n367\t    expect(recent?.value).toBe(1234);\n368\t    expect(recent?.valueDisplay).toBe(\"1,234\");\n369\t  });\n370\t\n371\t  it(\"sparse (singleton missing): every lamport metric coerces to '0' and recent fundings to 0 without dropping a metric\", async () => {\n372\t    const mock = createSqlMock([[], []]);\n373\t\n374\t    const result = await getRewardsOverview({ sql: mock.sql });\n375\t\n376\t    expect(result.metrics).toHaveLength(4);\n377\t    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n378\t    expect(byId.get(\"rewards.balance_lamports\")?.value).toBe(\"0\");\n379\t    expect(byId.get(\"rewards.balance_lamports\")?.valueDisplay).toBe(\"0\");\n380\t    expect(byId.get(\"rewards.lifetime_funded_lamports\")?.value).toBe(\"0\");\n381\t    expect(byId.get(\"rewards.lifetime_paid_lamports\")?.value).toBe(\"0\");\n382\t    expect(byId.get(\"rewards.recent_fundings\")?.value).toBe(0);\n383\t    expect(byId.get(\"rewards.recent_fundings\")?.valueDisplay).toBe(\"0\");\n384\t  });\n385\t\n386\t  it(\"string count coercion: a postgres ::int count served as a string converts to a number\", async () => {\n387\t    const mock = createSqlMock([\n388\t      [\n389\t        {\n390\t          balanceLamports: \"0\",\n391\t          lifetimeFunded: \"0\",\n392\t          lifetimePaid: \"0\",\n393\t        },\n394\t      ],\n395\t      [{ value: \"9\" }],\n396\t    ]);\n397\t    const result = await getRewardsOverview({ sql: mock.sql });\n398\t    const recent = result.metrics.find(\n399\t      (m) => m.id === \"rewards.recent_fundings\",\n400\t    );\n401\t    expect(recent?.value).toBe(9);\n402\t  });\n403\t\n404\t  it(\"recent fundings window: default window label uses PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS and binds the matching `since` timestamp\", async () => {\n405\t    const mock = createSqlMock([\n406\t      [{ balanceLamports: \"0\", lifetimeFunded: \"0\", lifetimePaid: \"0\" }],\n407\t      [{ value: 0 }],\n408\t    ]);\n409\t    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n410\t\n411\t    const result = await getRewardsOverview({ sql: mock.sql, now });\n412\t    const recent = result.metrics.find(\n413\t      (m) => m.id === \"rewards.recent_fundings\",\n414\t    );\n415\t    expect(recent?.windowLabel).toBe(\n416\t      `Last ${PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS}h`,\n417\t    );\n418\t\n419\t    // The fundings query (call index 1) binds the cutoff timestamp.\n420\t    const since = new Date(\n421\t      now.getTime() -\n422\t        PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS * 60 * 60 * 1000,\n423\t    ).toISOString();\n424\t    expect(mock.calls[1].values).toContain(since);\n425\t  });\n426\t\n427\t  it(\"recent fundings window: caller-provided window flows into the window label and the `since` cutoff\", async () => {\n428\t    const mock = createSqlMock([\n429\t      [{ balanceLamports: \"0\", lifetimeFunded: \"0\", lifetimePaid: \"0\" }],\n430\t      [{ value: 0 }],\n431\t    ]);\n432\t    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n433\t\n434\t    const result = await getRewardsOverview({\n435\t      sql: mock.sql,\n436\t      now,\n437\t      recentFundingsWindowHours: 6,\n438\t    });\n439\t    const recent = result.metrics.find(\n440\t      (m) => m.id === \"rewards.recent_fundings\",\n441\t    );\n442\t    expect(recent?.windowLabel).toBe(\"Last 6h\");\n443\t    const since = new Date(\n444\t      now.getTime() - 6 * 60 * 60 * 1000,\n445\t    ).toISOString();\n446\t    expect(mock.calls[1].values).toContain(since);\n447\t  });\n448\t\n449\t  it(\"load-error: a rejected query propagates so the page can render the alert state\", async () => {\n450\t    const mock = createSqlMock([\n451\t      new Error(\"connection refused\"),\n452\t      [{ value: 0 }],\n453\t    ]);\n454\t    await expect(\n455\t      getRewardsOverview({ sql: mock.sql }),\n456\t    ).rejects.toThrowError(\"connection refused\");\n457\t  });\n458\t\n459\t  it(\"queries fire in parallel: the second SQL call sees the second response even though both run via Promise.all\", async () => {\n460\t    const mock = createSqlMock([\n461\t      [{ balanceLamports: \"10\", lifetimeFunded: \"10\", lifetimePaid: \"0\" }],\n462\t      [{ value: 3 }],\n463\t    ]);\n464\t    await getRewardsOverview({ sql: mock.sql });\n465\t    expect(mock.calls).toHaveLength(2);\n466\t    expect(mock.calls[0].text).toMatch(/from reward_pool/i);\n467\t    expect(mock.calls[1].text).toMatch(/from reward_pool_fundings/i);\n468\t  });\n469\t});\n470\t"}]},"parent_tool_use_id":null,"session_id":"7378b447-bdd0-410a-9e39-562cf2836131","uuid":"c22a44a0-da44-4f2d-a4d4-0810d383dc9c","timestamp":"2026-04-26T06:11:37.489Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-rewards.test.ts","content":"// Query tests for the FR-9 reward-economy admin reads (`get-rewards.ts`).\n//\n// Mirrors the SQL-mock pattern used in `get-growth-referrals.test.ts` and\n// `get-command-center-attention.test.ts`: a tagged-template stub records each\n// call (joined SQL text + bound values) and dequeues a per-call response so\n// each test can assert which SQL fired, in what order, and with which clamps.\n\nimport { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS,\n  PEEK_REWARD_CONFIG_KEY_REGISTRY,\n  PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT,\n  PEEK_REWARD_POOL_FUNDINGS_MAX_LIMIT,\n  getRewardPool,\n  getRewardsOverview,\n  listRewardConfig,\n  listRewardPoolFundings,\n} from \"../get-rewards\";\nimport {\n  PEEK_REWARDS_OVERVIEW_METRIC_IDS,\n  type PeekRewardsOverviewMetricId,\n} from \"../../../../lib/types/peek\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\n// `getRewardsOverview` runs two queries in parallel via Promise.all:\n// 0 = reward_pool singleton read, 1 = recent fundings count.\nconst OVERVIEW_ORDER: ReadonlyArray<PeekRewardsOverviewMetricId> = [\n  \"rewards.balance_lamports\",\n  \"rewards.lifetime_funded_lamports\",\n  \"rewards.lifetime_paid_lamports\",\n  \"rewards.recent_fundings\",\n];\n\ndescribe(\"listRewardConfig\", () => {\n  it(\"populated: annotates known keys with definition + expected type from the registry\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          key: \"points_per_dollar\",\n          value: \"10\",\n          updatedAt: \"2026-04-20T00:00:00.000Z\",\n        },\n        {\n          key: \"reward_pool_fee_share\",\n          value: \"0.25\",\n          updatedAt: \"2026-04-21T00:00:00.000Z\",\n        },\n      ],\n    ]);\n\n    const rows = await listRewardConfig({ sql: mock.sql });\n\n    expect(rows).toHaveLength(2);\n    const byKey = new Map(rows.map((r) => [r.key, r]));\n    const points = byKey.get(\"points_per_dollar\");\n    expect(points?.value).toBe(\"10\");\n    expect(points?.expectedType).toBe(\n      PEEK_REWARD_CONFIG_KEY_REGISTRY.points_per_dollar?.expectedType,\n    );\n    expect(points?.definition).toBe(\n      PEEK_REWARD_CONFIG_KEY_REGISTRY.points_per_dollar?.definition,\n    );\n    const ratio = byKey.get(\"reward_pool_fee_share\");\n    expect(ratio?.expectedType).toBe(\"ratio\");\n    expect(ratio?.definition).not.toBeNull();\n  });\n\n  it(\"populated: unknown keys still surface with definition: null + expectedType: 'unknown'\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          key: \"experimental_unmapped_key\",\n          value: \"42\",\n          updatedAt: \"2026-04-25T00:00:00.000Z\",\n        },\n      ],\n    ]);\n\n    const rows = await listRewardConfig({ sql: mock.sql });\n\n    expect(rows).toHaveLength(1);\n    expect(rows[0]).toEqual({\n      key: \"experimental_unmapped_key\",\n      value: \"42\",\n      updatedAt: \"2026-04-25T00:00:00.000Z\",\n      definition: null,\n      expectedType: \"unknown\",\n    });\n  });\n\n  it(\"empty: returns an empty array when the table is empty\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listRewardConfig({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"reads from reward_config ordered by key asc\", async () => {\n    const mock = createSqlMock([[]]);\n    await listRewardConfig({ sql: mock.sql });\n    expect(mock.calls).toHaveLength(1);\n    expect(mock.calls[0].text).toMatch(/from reward_config/i);\n    expect(mock.calls[0].text).toMatch(/order by key asc/i);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"connection refused\")]);\n    await expect(listRewardConfig({ sql: mock.sql })).rejects.toThrowError(\n      \"connection refused\",\n    );\n  });\n});\n\ndescribe(\"getRewardPool\", () => {\n  it(\"populated: returns the singleton row with all four lamport/timestamp fields\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          balanceLamports: \"1500000000\",\n          lifetimeFunded: \"9000000000\",\n          lifetimePaid: \"7500000000\",\n          updatedAt: \"2026-04-25T10:00:00.000Z\",\n        },\n      ],\n    ]);\n\n    const pool = await getRewardPool({ sql: mock.sql });\n\n    expect(pool).toEqual({\n      balanceLamports: \"1500000000\",\n      lifetimeFunded: \"9000000000\",\n      lifetimePaid: \"7500000000\",\n      updatedAt: \"2026-04-25T10:00:00.000Z\",\n    });\n  });\n\n  it(\"populated: null/empty lamport columns coerce to '0' via readSum\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          balanceLamports: null,\n          lifetimeFunded: \"\",\n          lifetimePaid: undefined,\n          updatedAt: \"2026-04-25T10:00:00.000Z\",\n        },\n      ],\n    ]);\n\n    const pool = await getRewardPool({ sql: mock.sql });\n\n    expect(pool).toEqual({\n      balanceLamports: \"0\",\n      lifetimeFunded: \"0\",\n      lifetimePaid: \"0\",\n      updatedAt: \"2026-04-25T10:00:00.000Z\",\n    });\n  });\n\n  it(\"empty (singleton missing): returns null instead of throwing\", async () => {\n    const mock = createSqlMock([[]]);\n    const pool = await getRewardPool({ sql: mock.sql });\n    expect(pool).toBeNull();\n  });\n\n  it(\"reads reward_pool where id = 1 limit 1\", async () => {\n    const mock = createSqlMock([[]]);\n    await getRewardPool({ sql: mock.sql });\n    expect(mock.calls).toHaveLength(1);\n    expect(mock.calls[0].text).toMatch(/from reward_pool/i);\n    expect(mock.calls[0].text).toMatch(/where id = 1/i);\n    expect(mock.calls[0].text).toMatch(/limit 1/i);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"db down\")]);\n    await expect(getRewardPool({ sql: mock.sql })).rejects.toThrowError(\n      \"db down\",\n    );\n  });\n});\n\ndescribe(\"listRewardPoolFundings\", () => {\n  it(\"default limit: clamps to PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT and reads the ledger\", async () => {\n    const mock = createSqlMock([[]]);\n    await listRewardPoolFundings({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expect(call.text).toMatch(/from reward_pool_fundings/i);\n    expect(call.text).toMatch(/order by created_at desc, id desc/i);\n    expect(call.values).toContain(PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT);\n  });\n\n  it(\"explicit limit: passes the caller value through clampLimit\", async () => {\n    const mock = createSqlMock([[]]);\n    await listRewardPoolFundings({ sql: mock.sql, limit: 25 });\n    expect(mock.calls[0].values).toContain(25);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listRewardPoolFundings({\n      sql: mock.sql,\n      limit: PEEK_REWARD_POOL_FUNDINGS_MAX_LIMIT + 100,\n    });\n    expect(mock.calls[0].values).toContain(\n      PEEK_REWARD_POOL_FUNDINGS_MAX_LIMIT,\n    );\n  });\n\n  it(\"non-positive limit clamps to 1\", async () => {\n    const mock = createSqlMock([[]]);\n    await listRewardPoolFundings({ sql: mock.sql, limit: 0 });\n    expect(mock.calls[0].values).toContain(1);\n  });\n\n  it(\"non-finite limit falls back to the default\", async () => {\n    const mock = createSqlMock([[]]);\n    await listRewardPoolFundings({ sql: mock.sql, limit: Number.NaN });\n    expect(mock.calls[0].values).toContain(\n      PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT,\n    );\n  });\n\n  it(\"populated: returns rows with the funding-source linkage (roundId from reward_pool_fundings.round_id)\", async () => {\n    const row = {\n      id: \"42\",\n      roundId: \"match-abc-123\",\n      feeLamports: \"200000\",\n      fundedLamports: \"150000\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n    };\n    const mock = createSqlMock([[row]]);\n\n    const rows = await listRewardPoolFundings({ sql: mock.sql });\n\n    expect(rows).toEqual([row]);\n    // The funding source linkage comes back via the `roundId` field. The\n    // page wires this through universal search (`/?query=<roundId>`); the\n    // query itself just has to surface the column.\n    expect(rows[0].roundId).toBe(\"match-abc-123\");\n  });\n\n  it(\"empty: returns an empty array when no fundings exist\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listRewardPoolFundings({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"query timeout\")]);\n    await expect(\n      listRewardPoolFundings({ sql: mock.sql }),\n    ).rejects.toThrowError(\"query timeout\");\n  });\n});\n\ndescribe(\"getRewardsOverview\", () => {\n  it(\"populated: emits one PeekMetric per FR-4 id with correct values, units, and bookkeeping\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          balanceLamports: \"1500000000\",\n          lifetimeFunded: \"9000000000\",\n          lifetimePaid: \"7500000000\",\n        },\n      ],\n      [{ value: 7 }],\n    ]);\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getRewardsOverview({ sql: mock.sql, now });\n\n    expect(result.generatedAt).toBe(\"2026-04-25T10:00:00.000Z\");\n    expect(result.metrics).toHaveLength(4);\n    expect(result.metrics.map((m) => m.id)).toEqual(OVERVIEW_ORDER);\n    for (const id of PEEK_REWARDS_OVERVIEW_METRIC_IDS) {\n      expect(result.metrics.find((m) => m.id === id)).toBeDefined();\n    }\n    for (const metric of result.metrics) {\n      expect(metric.asOf).toBe(\"2026-04-25T10:00:00.000Z\");\n      expect(metric.freshness).toBe(\"live\");\n      expect(metric.label.length).toBeGreaterThan(0);\n      expect(metric.definition.length).toBeGreaterThan(0);\n      expect(metric.source.length).toBeGreaterThan(0);\n      expect(metric.windowLabel.length).toBeGreaterThan(0);\n      expect(metric.drilldownHref).not.toBeNull();\n    }\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"rewards.balance_lamports\")?.value).toBe(\"1500000000\");\n    expect(byId.get(\"rewards.balance_lamports\")?.valueDisplay).toBe(\n      \"1,500,000,000\",\n    );\n    expect(byId.get(\"rewards.balance_lamports\")?.unit).toBe(\"lamports\");\n    expect(byId.get(\"rewards.balance_lamports\")?.drilldownHref).toBe(\n      \"/economy/rewards#pool\",\n    );\n\n    expect(byId.get(\"rewards.lifetime_funded_lamports\")?.value).toBe(\n      \"9000000000\",\n    );\n    expect(\n      byId.get(\"rewards.lifetime_funded_lamports\")?.valueDisplay,\n    ).toBe(\"9,000,000,000\");\n    expect(\n      byId.get(\"rewards.lifetime_funded_lamports\")?.drilldownHref,\n    ).toBe(\"/economy/rewards#fundings\");\n\n    expect(byId.get(\"rewards.lifetime_paid_lamports\")?.value).toBe(\n      \"7500000000\",\n    );\n    expect(byId.get(\"rewards.lifetime_paid_lamports\")?.valueDisplay).toBe(\n      \"7,500,000,000\",\n    );\n\n    expect(byId.get(\"rewards.recent_fundings\")?.value).toBe(7);\n    expect(byId.get(\"rewards.recent_fundings\")?.valueDisplay).toBe(\"7\");\n    expect(byId.get(\"rewards.recent_fundings\")?.unit).toBe(\"events\");\n    expect(byId.get(\"rewards.recent_fundings\")?.drilldownHref).toBe(\n      \"/economy/rewards#fundings\",\n    );\n  });\n\n  it(\"populated (large recent fundings): formats valueDisplay with thousands separator\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          balanceLamports: \"0\",\n          lifetimeFunded: \"0\",\n          lifetimePaid: \"0\",\n        },\n      ],\n      [{ value: 1234 }],\n    ]);\n    const result = await getRewardsOverview({ sql: mock.sql });\n    const recent = result.metrics.find(\n      (m) => m.id === \"rewards.recent_fundings\",\n    );\n    expect(recent?.value).toBe(1234);\n    expect(recent?.valueDisplay).toBe(\"1,234\");\n  });\n\n  it(\"sparse (singleton missing): every lamport metric coerces to '0' and recent fundings to 0 without dropping a metric\", async () => {\n    const mock = createSqlMock([[], []]);\n\n    const result = await getRewardsOverview({ sql: mock.sql });\n\n    expect(result.metrics).toHaveLength(4);\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"rewards.balance_lamports\")?.value).toBe(\"0\");\n    expect(byId.get(\"rewards.balance_lamports\")?.valueDisplay).toBe(\"0\");\n    expect(byId.get(\"rewards.lifetime_funded_lamports\")?.value).toBe(\"0\");\n    expect(byId.get(\"rewards.lifetime_paid_lamports\")?.value).toBe(\"0\");\n    expect(byId.get(\"rewards.recent_fundings\")?.value).toBe(0);\n    expect(byId.get(\"rewards.recent_fundings\")?.valueDisplay).toBe(\"0\");\n  });\n\n  it(\"string count coercion: a postgres ::int count served as a string converts to a number\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          balanceLamports: \"0\",\n          lifetimeFunded: \"0\",\n          lifetimePaid: \"0\",\n        },\n      ],\n      [{ value: \"9\" }],\n    ]);\n    const result = await getRewardsOverview({ sql: mock.sql });\n    const recent = result.metrics.find(\n      (m) => m.id === \"rewards.recent_fundings\",\n    );\n    expect(recent?.value).toBe(9);\n  });\n\n  it(\"recent fundings window: default window label uses PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS and binds the matching `since` timestamp\", async () => {\n    const mock = createSqlMock([\n      [{ balanceLamports: \"0\", lifetimeFunded: \"0\", lifetimePaid: \"0\" }],\n      [{ value: 0 }],\n    ]);\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getRewardsOverview({ sql: mock.sql, now });\n    const recent = result.metrics.find(\n      (m) => m.id === \"rewards.recent_fundings\",\n    );\n    expect(recent?.windowLabel).toBe(\n      `Last ${PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS}h`,\n    );\n\n    // The fundings query (call index 1) binds the cutoff timestamp.\n    const since = new Date(\n      now.getTime() -\n        PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS * 60 * 60 * 1000,\n    ).toISOString();\n    expect(mock.calls[1].values).toContain(since);\n  });\n\n  it(\"recent fundings window: caller-provided window flows into the window label and the `since` cutoff\", async () => {\n    const mock = createSqlMock([\n      [{ balanceLamports: \"0\", lifetimeFunded: \"0\", lifetimePaid: \"0\" }],\n      [{ value: 0 }],\n    ]);\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getRewardsOverview({\n      sql: mock.sql,\n      now,\n      recentFundingsWindowHours: 6,\n    });\n    const recent = result.metrics.find(\n      (m) => m.id === \"rewards.recent_fundings\",\n    );\n    expect(recent?.windowLabel).toBe(\"Last 6h\");\n    const since = new Date(\n      now.getTime() - 6 * 60 * 60 * 1000,\n    ).toISOString();\n    expect(mock.calls[1].values).toContain(since);\n  });\n\n  it(\"load-error: a rejected query propagates so the page can render the alert state\", async () => {\n    const mock = createSqlMock([\n      new Error(\"connection refused\"),\n      [{ value: 0 }],\n    ]);\n    await expect(\n      getRewardsOverview({ sql: mock.sql }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n\n  it(\"queries fire in parallel: the second SQL call sees the second response even though both run via Promise.all\", async () => {\n    const mock = createSqlMock([\n      [{ balanceLamports: \"10\", lifetimeFunded: \"10\", lifetimePaid: \"0\" }],\n      [{ value: 3 }],\n    ]);\n    await getRewardsOverview({ sql: mock.sql });\n    expect(mock.calls).toHaveLength(2);\n    expect(mock.calls[0].text).toMatch(/from reward_pool/i);\n    expect(mock.calls[1].text).toMatch(/from reward_pool_fundings/i);\n  });\n});\n","numLines":470,"startLine":1,"totalLines":470}}}
