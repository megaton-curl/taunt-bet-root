\n250\t      <label style={fieldStyle}>\n251\t        <span>Created to</span>\n252\t        <input\n253\t          name=\"progFilterTo\"\n254\t          type=\"date\"\n255\t          defaultValue={(filters.createdTo ?? \"\").slice(0, 10)}\n256\t          style={inputStyle}\n257\t        />\n258\t      </label>\n259\t\n260\t      <button type=\"submit\" style={buttonStyle}>\n261\t        Apply filters\n262\t      </button>\n263\t    </form>\n264\t  );\n265\t}\n266\t\n267\texport function BonusCompletionsFilterBar({\n268\t  filters,\n269\t  action = \"/economy/challenges\",\n270\t}: BonusCompletionsFilterBarProps) {\n271\t  return (\n272\t    <form\n273\t      action={action}\n274\t      method=\"get\"\n275\t      role=\"search\"\n276\t      aria-label=\"Filter bonus completions\"\n277\t      style={formStyle}\n278\t    >\n279\t      <label style={fieldStyle}>\n280\t        <span>User ID</span>\n281\t        <input\n282\t          name=\"bcFilterUserId\"\n283\t          type=\"text\"\n284\t          defaultValue={filters.userId ?? \"\"}\n285\t          placeholder=\"user_id\"\n286\t          style={inputStyle}\n287\t        />\n288\t      </label>\n289\t\n290\t      <label style={fieldStyle}>\n291\t        <span>Bonus ID</span>\n292\t        <input\n293\t          name=\"bcFilterBonusId\"\n294\t          type=\"text\"\n295\t          defaultValue={filters.bonusId ?? \"\"}\n296\t          placeholder=\"bonus id\"\n297\t          style={inputStyle}\n298\t        />\n299\t      </label>\n300\t\n301\t      <label style={fieldStyle}>\n302\t        <span>Campaign ID</span>\n303\t        <input\n304\t          name=\"bcFilterCampaignId\"\n305\t          type=\"text\"\n306\t          defaultValue={filters.campaignId ?? \"\"}\n307\t          placeholder=\"campaign id\"\n308\t          style={inputStyle}\n309\t        />\n310\t      </label>\n311\t\n312\t      <label style={fieldStyle}>\n313\t        <span>Period key</span>\n314\t        <input\n315\t          name=\"bcFilterPe