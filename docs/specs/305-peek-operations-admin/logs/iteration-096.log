h).toBeGreaterThanOrEqual(6);\n  });\n\n  it(\"filters: completedFrom/completedTo are cast to timestamptz\", async () => {\n    const mock = createSqlMock([[]]);\n    await listBonusCompletions({\n      sql: mock.sql,\n      filters: { completedFrom: \"2026-04-01\", completedTo: \"2026-04-26\" },\n    });\n    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n  });\n\n  it(\"sparse: an empty result set returns []\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listBonusCompletions({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"db down\")]);\n    await expect(listBonusCompletions({ sql: mock.sql })).rejects.toThrowError(\n      \"db down\",\n    );\n  });\n});\n\ndescribe(\"getChallengesOverview\", () => {\n  function buildPopulatedResponses() {\n    return [\n      [{ value: 4 }],\n      [{ value: 12 }],\n      [{ value: 30 }],\n      [{ value: 7 }],\n      [{ value: 5 }],\n    ];\n  }\n\n  it(\"populated: emits one PeekMetric per FR-4 id with correct values, units, and bookkeeping\", async () => {\n    const mock = createSqlMock(buildPopulatedResponses());\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getChallengesOverview({ sql: mock.sql, now });\n\n    expect(result.generatedAt).toBe(\"2026-04-25T10:00:00.000Z\");\n    expect(result.metrics).toHaveLength(5);\n    expect(result.metrics.map((m) => m.id)).toEqual(OVERVIEW_ORDER);\n    for (const id of PEEK_CHALLENGES_OVERVIEW_METRIC_IDS) {\n      expect(result.metrics.find((m) => m.id === id)).toBeDefined();\n    }\n    for (const metric of result.metrics) {\n      expect(metric.asOf).toBe(\"2026-04-25T10:00:00.000Z\");\n      expect(metric.freshness).toBe(\"live\");\n      expect(metric.label.length).toBeGreaterThan(0);\n      expect(metric.definition.length).toBeGreaterThan(0);\n      expect(metric.source.length).toBeGreaterThan(0);\n      expect(metric.windowLabel.length).toBeGreaterThan(0);\n      expect(metric.drilldownHref).not.toBeNull();\n    }\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"challenges.active_campaigns\")?.value).toBe(4);\n    expect(byId.get(\"challenges.active_campaigns\")?.valueDisplay).toBe(\"4\");\n    expect(byId.get(\"challenges.active_campaigns\")?.unit).toBe(\"campaigns\");\n    expect(byId.get(\"challenges.active_campaigns\")?.source).toBe(\"campaigns\");\n\n    expect(byId.get(\"challenges.active_challenges\")?.value).toBe(12);\n    expect(byId.get(\"challenges.active_challenges\")?.unit).toBe(\"challenges\");\n    expect(byId.get(\"challenges.active_challenges\")?.source).toBe(\"challenges\");\n\n    expect(byId.get(\"challenges.active_assignments\")?.value).toBe(30);\n    expect(byId.get(\"challenges.active_assignments\")?.unit).toBe(\"assignments\");\n    expect(byId.get(\"challenges.active_assignments\")?.source).toBe(\n      \"challenge_assignments\",\n    );\n\n    expect(byId.get(\"challenges.completed_assignments_window\")?.value).toBe(7);\n    expect(byId.get(\"challenges.completed_assignments_window\")?.unit).toBe(\n      \"assignments\",\n    );\n\n    expect(byId.get(\"challenges.bonus_completions_window\")?.value).toBe(5);\n    expect(byId.get(\"challenges.bonus_completions_window\")?.unit).toBe(\n      \"completions\",\n    );\n    expect(byId.get(\"challenges.bonus_completions_window\")?.source).toBe(\n      \"bonus_completions\",\n    );\n  });\n\n  it(\"populated: numeric counts coerce through readInt (string → number)\", async () => {\n    const mock = createSqlMock([\n      [{ value: \"4\" }],\n      [{ value: \"12\" }],\n      [{ value: \"30\" }],\n      [{ value: \"7\" }],\n      [{ value: \"5\" }],\n    ]);\n\n    const result = await getChallengesOverview({ sql: mock.sql });\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"challenges.active_campaigns\")?.value).toBe(4);\n    expect(byId.get(\"challenges.bonus_completions_window\")?.value).toBe(5);\n  });\n\n  it(\"populated (large counts): formats valueDisplay with thousands separator\", async () => {\n    const mock = createSqlMock([\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 12345 }],\n    ]);\n    const result = await getChallengesOverview({ sql: mock.sql });\n    const recent = result.metrics.find(\n      (m) => m.id === \"challenges.bonus_completions_window\",\n    );\n    expect(recent?.value).toBe(12345);\n    expect(recent?.valueDisplay).toBe(\"12,345\");\n  });\n\n  it(\"sparse (every count = 0): every metric still emits with display '0' so the strip never drops a tile\", async () => {\n    const mock = createSqlMock([[], [], [], [], []]);\n\n    const result = await getChallengesOverview({ sql: mock.sql });\n\n    expect(result.metrics).toHaveLength(5);\n    for (const metric of result.metrics) {\n      expect(metric.value).toBe(0);\n      expect(metric.valueDisplay).toBe(\"0\");\n    }\n  });\n\n  it(\"default window: window label uses PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS and binds the matching `since` timestamp\", async () => {\n    const mock = createSqlMock(buildPopulatedResponses());\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getChallengesOverview({ sql: mock.sql, now });\n    const completed = result.metrics.find(\n      (m) => m.id === \"challenges.completed_assignments_window\",\n    );\n    const recent = result.metrics.find(\n      (m) => m.id === \"challenges.bonus_completions_window\",\n    );\n    expect(completed?.windowLabel).toBe(\n      `Last ${PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS}h`,\n    );\n    expect(recent?.windowLabel).toBe(\n      `Last ${PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS}h`,\n    );\n\n    // The completed_assignments and bonus_completions queries (call indexes 3\n    // and 4) bind the cutoff timestamp.\n    const since = new Date(\n      now.getTime() - PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS * 60 * 60 * 1000,\n    ).toISOString();\n    expect(mock.calls[3].values).toContain(since);\n    expect(mock.calls[4].values).toContain(since);\n  });\n\n  it(\"custom windowHours: caller-provided window flows into the label and the `since` cutoff\", async () => {\n    const mock = createSqlMock(buildPopulatedResponses());\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getChallengesOverview({\n      sql: mock.sql,\n      now,\n      windowHours: 6,\n    });\n    const recent = result.metrics.find(\n      (m) => m.id === \"challenges.bonus_completions_window\",\n    );\n    expect(recent?.windowLabel).toBe(\"Last 6h\");\n    const since = new Date(\n      now.getTime() - 6 * 60 * 60 * 1000,\n    ).toISOString();\n    expect(mock.calls[3].values).toContain(since);\n    expect(mock.calls[4].values).toContain(since);\n  });\n\n  it(\"queries fire in parallel: all 5 SQL calls happen via Promise.all in declared order\", async () => {\n    const mock = createSqlMock(buildPopulatedResponses());\n    await getChallengesOverview({ sql: mock.sql });\n    expect(mock.calls).toHaveLength(5);\n    expectReadOnly(mock.calls[0]);\n    expect(mock.calls[0].text).toMatch(/from campaigns/i);\n    expect(mock.calls[0].text).toMatch(/where is_active = true/i);\n    expectReadOnly(mock.calls[1]);\n    expect(mock.calls[1].text).toMatch(/from challenges/i);\n    expect(mock.calls[1].text).toMatch(/where is_active = true/i);\n    expectReadOnly(mock.calls[2]);\n    expect(mock.calls[2].text).toMatch(/from challenge_assignments/i);\n    expect(mock.calls[2].text).toMatch(/where status = 'active'/i);\n    expectReadOnly(mock.calls[3]);\n    expect(mock.calls[3].text).toMatch(/where status = 'completed'/i);\n    expectReadOnly(mock.calls[4]);\n    expect(mock.calls[4].text).toMatch(/from bonus_completions/i);\n  });\n\n  it(\"load-error: a rejected query propagates so the page can render the alert state\", async () => {\n    const mock = createSqlMock([\n      new Error(\"connection refused\"),\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n    await expect(\n      getChallengesOverview({ sql: mock.sql }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":474,"cache_read_input_tokens":136772,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":474},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"7378b447-bdd0-410a-9e39-562cf2836131","uuid":"a8949132-e50a-471a-b665-6ce55585277b"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014DuT6zqhgioX3vPt5g8nst","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-challenges.test.ts"}]},"parent_tool_use_id":null,"session_id":"7378b447-bdd0-410a-9e39-562cf2836131","uuid":"9e722819-4995-4772-8b5c-06035d38292b","timestamp":"2026-04-26T06:13:41.720Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-challenges.test.ts","content":"// Query tests for the FR-9 challenge engine admin reads (`get-challenges.ts`).\n//\n// Mirrors the SQL-mock pattern used in `get-rewards.test.ts` and\n// `get-points-and-crates.test.ts`: a tagged-template stub records each call\n// (joined SQL text + bound values) and dequeues a per-call response so each\n// test can assert which SQL fired, in what order, and with which clamps.\n//\n// The challenge engine views are read-only by spec (FR-9 / FR-14 — challenge\n// and campaign definition editing is out of scope), so these tests assert the\n// queries only emit SELECT statements and never INSERT/UPDATE/DELETE.\n\nimport { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_BONUS_COMPLETIONS_DEFAULT_LIMIT,\n  PEEK_BONUS_COMPLETIONS_MAX_LIMIT,\n  PEEK_CAMPAIGNS_DEFAULT_LIMIT,\n  PEEK_CAMPAIGNS_MAX_LIMIT,\n  PEEK_CHALLENGES_DEFAULT_LIMIT,\n  PEEK_CHALLENGES_MAX_LIMIT,\n  PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS,\n  PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT,\n  PEEK_CHALLENGE_ASSIGNMENTS_MAX_LIMIT,\n  PEEK_COMPLETION_BONUSES_DEFAULT_LIMIT,\n  PEEK_COMPLETION_BONUSES_MAX_LIMIT,\n  PEEK_PROGRESS_EVENTS_DEFAULT_LIMIT,\n  PEEK_PROGRESS_EVENTS_MAX_LIMIT,\n  getChallengesOverview,\n  listBonusCompletions,\n  listCampaigns,\n  listChallengeAssignments,\n  listChallenges,\n  listCompletionBonuses,\n  listProgressEvents,\n} from \"../get-challenges\";\nimport {\n  PEEK_CHALLENGES_OVERVIEW_METRIC_IDS,\n  type PeekChallengesOverviewMetricId,\n} from \"../../../../lib/types/peek\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\nfunction expectReadOnly(call: SqlCall) {\n  // Read-only guarantee: every challenge engine query must be a SELECT only.\n  // Catch a stray INSERT/UPDATE/DELETE before it can ship — FR-9 keeps\n  // challenge/campaign/completion-bonus definitions out of scope (FR-14).\n  expect(call.text).not.toMatch(/\\binsert\\s+into\\b/i);\n  expect(call.text).not.toMatch(/\\bupdate\\s+\\w/i);\n  expect(call.text).not.toMatch(/\\bdelete\\s+from\\b/i);\n  expect(call.text).toMatch(/\\bselect\\b/i);\n}\n\n// `getChallengesOverview` runs five queries in parallel via Promise.all.\nconst OVERVIEW_ORDER: ReadonlyArray<PeekChallengesOverviewMetricId> = [\n  \"challenges.active_campaigns\",\n  \"challenges.active_challenges\",\n  \"challenges.active_assignments\",\n  \"challenges.completed_assignments_window\",\n  \"challenges.bonus_completions_window\",\n];\n\ndescribe(\"listCampaigns\", () => {\n  it(\"default limit: clamps to PEEK_CAMPAIGNS_DEFAULT_LIMIT and reads from campaigns with annotated counts\", async () => {\n    const mock = createSqlMock([[]]);\n    await listCampaigns({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expectReadOnly(call);\n    expect(call.text).toMatch(/from campaigns c/i);\n    // Per-campaign challenge count + active assignment count are joined in.\n    expect(call.text).toMatch(/from challenges/i);\n    expect(call.text).toMatch(/from challenge_assignments ca/i);\n    expect(call.text).toMatch(/where ca\\.status = 'active'/i);\n    expect(call.text).toMatch(\n      /order by c\\.is_active desc, c\\.created_at desc/i,\n    );\n    expect(call.values).toContain(PEEK_CAMPAIGNS_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listCampaigns({\n      sql: mock.sql,\n      limit: PEEK_CAMPAIGNS_MAX_LIMIT + 100,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_CAMPAIGNS_MAX_LIMIT);\n  });\n\n  it(\"non-positive limit clamps to 1\", async () => {\n    const mock = createSqlMock([[]]);\n    await listCampaigns({ sql: mock.sql, limit: -5 });\n    expect(mock.calls[0].values).toContain(1);\n  });\n\n  it(\"non-finite limit falls back to the default\", async () => {\n    const mock = createSqlMock([[]]);\n    await listCampaigns({ sql: mock.sql, limit: Number.NaN });\n    expect(mock.calls[0].values).toContain(PEEK_CAMPAIGNS_DEFAULT_LIMIT);\n  });\n\n  it(\"populated: numeric counts coerce through readInt (string → number)\", async () => {\n    // Postgres ::int cast can come back as a string in the postgres-js driver\n    // depending on the column path; readInt must coerce strings → numbers so\n    // the table can render `toLocaleString` without `NaN`.\n    const mock = createSqlMock([\n      [\n        {\n          id: \"1\",\n          name: \"Daily challenges\",\n          campaignType: \"daily\",\n          startsAt: null,\n          endsAt: null,\n          isActive: true,\n          createdAt: \"2026-04-25T10:00:00.000Z\",\n          challengeCount: \"5\", // string from postgres\n          activeAssignmentCount: 12,\n        },\n      ],\n    ]);\n\n    const rows = await listCampaigns({ sql: mock.sql });\n    expect(rows).toHaveLength(1);\n    expect(rows[0].challengeCount).toBe(5);\n    expect(rows[0].activeAssignmentCount).toBe(12);\n    expect(rows[0].name).toBe(\"Daily challenges\");\n    expect(rows[0].isActive).toBe(true);\n  });\n\n  it(\"sparse: an empty campaigns table returns []\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listCampaigns({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"connection refused\")]);\n    await expect(listCampaigns({ sql: mock.sql })).rejects.toThrowError(\n      \"connection refused\",\n    );\n  });\n});\n\ndescribe(\"listChallenges\", () => {\n  it(\"default limit: clamps to PEEK_CHALLENGES_DEFAULT_LIMIT and reads from challenges joined with campaigns\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallenges({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expectReadOnly(call);\n    expect(call.text).toMatch(/from challenges ch/i);\n    expect(call.text).toMatch(/left join campaigns c on c\\.id = ch\\.campaign_id/i);\n    expect(call.text).toMatch(/order by ch\\.campaign_id asc/i);\n    expect(call.values).toContain(PEEK_CHALLENGES_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallenges({\n      sql: mock.sql,\n      limit: PEEK_CHALLENGES_MAX_LIMIT + 999,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_CHALLENGES_MAX_LIMIT);\n  });\n\n  it(\"filters: empty filters bind null sentinels so both predicates are skipped\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallenges({ sql: mock.sql, filters: {} });\n    const values = mock.calls[0].values;\n    // 2 filters → at least 2 `true` sentinels (one per predicate toggle).\n    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(2);\n  });\n\n  it(\"filters: campaignId binds the value verbatim\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallenges({\n      sql: mock.sql,\n      filters: { campaignId: \"campaign-7\" },\n    });\n    expect(mock.calls[0].values).toContain(\"campaign-7\");\n  });\n\n  it(\"filters: isActive='true' binds boolean true\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallenges({\n      sql: mock.sql,\n      filters: { isActive: \"true\" },\n    });\n    const values = mock.calls[0].values;\n    // Active toggle off (false) + isActive=true bound.\n    expect(values).toContain(true);\n  });\n\n  it(\"filters: isActive='false' binds boolean false\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallenges({\n      sql: mock.sql,\n      filters: { isActive: \"false\" },\n    });\n    expect(mock.calls[0].values).toContain(false);\n  });\n\n  it(\"filters: unknown isActive value normalises to null (predicate skipped)\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallenges({\n      sql: mock.sql,\n      filters: { isActive: \"maybe\" },\n    });\n    const values = mock.calls[0].values;\n    // No bool was bound for the predicate → toggle is `true` (skip).\n    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(2);\n  });\n\n  it(\"filters: whitespace-only campaignId normalises to null\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallenges({\n      sql: mock.sql,\n      filters: { campaignId: \"   \" },\n    });\n    const values = mock.calls[0].values;\n    // The campaignId predicate toggles `true` (skip).\n    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(1);\n  });\n\n  it(\"sparse: an empty result set returns []\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listChallenges({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"query timeout\")]);\n    await expect(listChallenges({ sql: mock.sql })).rejects.toThrowError(\n      \"query timeout\",\n    );\n  });\n});\n\ndescribe(\"listChallengeAssignments\", () => {\n  it(\"default limit: clamps to PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT and reads with player_profiles + challenges + campaigns joined\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallengeAssignments({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expectReadOnly(call);\n    expect(call.text).toMatch(/from challenge_assignments ca/i);\n    expect(call.text).toMatch(/left join challenges ch on ch\\.id = ca\\.challenge_id/i);\n    expect(call.text).toMatch(/left join campaigns c on c\\.id = ch\\.campaign_id/i);\n    expect(call.text).toMatch(\n      /left join player_profiles prof on prof\\.user_id = ca\\.user_id/i,\n    );\n    expect(call.text).toMatch(/order by ca\\.assigned_at desc/i);\n    expect(call.values).toContain(PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallengeAssignments({\n      sql: mock.sql,\n      limit: PEEK_CHALLENGE_ASSIGNMENTS_MAX_LIMIT + 9999,\n    });\n    expect(mock.calls[0].values).toContain(\n      PEEK_CHALLENGE_ASSIGNMENTS_MAX_LIMIT,\n    );\n  });\n\n  it(\"filters: every supported filter (userId, challengeId, campaignId, periodKey, status, assignedFrom, assignedTo) flows into bound values\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallengeAssignments({\n      sql: mock.sql,\n      filters: {\n        userId: \"user-1\",\n        challengeId: \"challenge-7\",\n        campaignId: \"campaign-9\",\n        periodKey: \"2026-04-26\",\n        status: \"active\",\n        assignedFrom: \"2026-04-01\",\n        assignedTo: \"2026-04-26\",\n      },\n    });\n    const values = mock.calls[0].values;\n    expect(values).toContain(\"user-1\");\n    expect(values).toContain(\"challenge-7\");\n    expect(values).toContain(\"campaign-9\");\n    expect(values).toContain(\"2026-04-26\");\n    expect(values).toContain(\"active\");\n    expect(values).toContain(\"2026-04-01\");\n  });\n\n  it(\"filters: status transitions all bind verbatim (active, completed, expired)\", async () => {\n    // Migration-011 status transitions matter to operators — assert each\n    // value passes through to the SQL binding so the URL chip can scope to a\n    // specific lifecycle state.\n    for (const status of [\"active\", \"completed\", \"expired\"]) {\n      const mock = createSqlMock([[]]);\n      await listChallengeAssignments({\n        sql: mock.sql,\n        filters: { status },\n      });\n      expect(mock.calls[0].values).toContain(status);\n    }\n  });\n\n  it(\"filters: empty filters bind null sentinels so all 7 predicates are skipped\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallengeAssignments({ sql: mock.sql, filters: {} });\n    const values = mock.calls[0].values;\n    // 7 filters → 7 `true` sentinels (one per predicate).\n    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(7);\n  });\n\n  it(\"filters: assignedFrom/assignedTo are cast to timestamptz\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallengeAssignments({\n      sql: mock.sql,\n      filters: { assignedFrom: \"2026-04-01\", assignedTo: \"2026-04-26\" },\n    });\n    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n  });\n\n  it(\"filters: whitespace-only filter values normalise to null\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallengeAssignments({\n      sql: mock.sql,\n      filters: {\n        userId: \"   \",\n        challengeId: \"\",\n        statu