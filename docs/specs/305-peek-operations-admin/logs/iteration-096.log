{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017ZxAn2Xy7QXm5YDdsnypwc","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport { render, screen } from \"@testing-library/react\";\n3\timport {\n4\t  PlayerPointsFilterBar,\n5\t  PointGrantsFilterBar,\n6\t} from \"../economy-points-filter-bar\";\n7\timport { PEEK_POINT_GRANT_SOURCE_TYPES } from \"../../lib/economy-search-params\";\n8\timport type {\n9\t  PeekPlayerPointsFilters,\n10\t  PeekPointGrantFilters,\n11\t} from \"../../lib/types/peek\";\n12\t\n13\tconst EMPTY_POINTS_FILTERS: PeekPlayerPointsFilters = {\n14\t  userId: null,\n15\t  wallet: null,\n16\t};\n17\t\n18\tconst POPULATED_POINTS_FILTERS: PeekPlayerPointsFilters = {\n19\t  userId: \"user-1\",\n20\t  wallet: \"WALLET123\",\n21\t};\n22\t\n23\tconst EMPTY_GRANT_FILTERS: PeekPointGrantFilters = {\n24\t  userId: null,\n25\t  sourceType: null,\n26\t  sourceId: null,\n27\t  createdFrom: null,\n28\t  createdTo: null,\n29\t};\n30\t\n31\tconst POPULATED_GRANT_FILTERS: PeekPointGrantFilters = {\n32\t  userId: \"user-9\",\n33\t  sourceType: \"challenge_completed\",\n34\t  sourceId: \"challenge-7\",\n35\t  createdFrom: \"2026-04-01\",\n36\t  createdTo: \"2026-04-26\",\n37\t};\n38\t\n39\tdescribe(\"PlayerPointsFilterBar\", () => {\n40\t  it(\"empty: form posts to /economy/points by default with both inputs blank\", () => {\n41\t    render(<PlayerPointsFilterBar filters={EMPTY_POINTS_FILTERS} />);\n42\t\n43\t    const form = screen.getByRole(\"search\", { name: \"Filter player points\" });\n44\t    expect(form).toHaveAttribute(\"action\", \"/economy/points\");\n45\t    expect(form).toHaveAttribute(\"method\", \"get\");\n46\t\n47\t    expect(\n48\t      (screen.getByLabelText(\"User ID\") as HTMLInputElement).value,\n49\t    ).toBe(\"\");\n50\t    expect(\n51\t      (screen.getByLabelText(\"Wallet\") as HTMLInputElement).value,\n52\t    ).toBe(\"\");\n53\t  });\n54\t\n55\t  it(\"populated: pre-fills inputs with the URL-addressable filter values\", () => {\n56\t    render(<PlayerPointsFilterBar filters={POPULATED_POINTS_FILTERS} />);\n57\t\n58\t    expect(\n59\t      (screen.getByLabelText(\"User ID\") as HTMLInputElement).value,\n60\t    ).toBe(\"user-1\");\n61\t    expect(\n62\t      (screen.getByLabelText(\"Wallet\") as HTMLInputElement).value,\n63\t    ).toBe(\"WALLET123\");\n64\t  });\n65\t\n66\t  it(\"inputs use prefixed names so the points + grants forms can co-exist on /economy/points\", () => {\n67\t    render(<PlayerPointsFilterBar filters={EMPTY_POINTS_FILTERS} />);\n68\t    expect(\n69\t      (screen.getByLabelText(\"User ID\") as HTMLInputElement).name,\n70\t    ).toBe(\"pointsUserId\");\n71\t    expect(\n72\t      (screen.getByLabelText(\"Wallet\") as HTMLInputElement).name,\n73\t    ).toBe(\"pointsWallet\");\n74\t  });\n75\t\n76\t  it(\"custom action overrides the default form target\", () => {\n77\t    render(\n78\t      <PlayerPointsFilterBar\n79\t        filters={EMPTY_POINTS_FILTERS}\n80\t        action=\"/economy/points?embed=1\"\n81\t      />,\n82\t    );\n83\t    const form = screen.getByRole(\"search\", { name: \"Filter player points\" });\n84\t    expect(form).toHaveAttribute(\"action\", \"/economy/points?embed=1\");\n85\t  });\n86\t});\n87\t\n88\tdescribe(\"PointGrantsFilterBar\", () => {\n89\t  it(\"empty: form posts to /economy/points by default with all inputs blank and source-type 'Any' selected\", () => {\n90\t    render(<PointGrantsFilterBar filters={EMPTY_GRANT_FILTERS} />);\n91\t\n92\t    const form = screen.getByRole(\"search\", { name: \"Filter point grants\" });\n93\t    expect(form).toHaveAttribute(\"action\", \"/economy/points\");\n94\t    expect(form).toHaveAttribute(\"method\", \"get\");\n95\t\n96\t    const sourceType = screen.getByLabelText(\n97\t      \"Source type\",\n98\t    ) as HTMLSelectElement;\n99\t    expect(sourceType.value).toBe(\"\");\n100\t\n101\t    // The select must include every published source type plus the \"Any\"\n102\t    // option so an operator can scope the ledger by category.\n103\t    const optionValues = Array.from(sourceType.options).map((o) => o.value);\n104\t    expect(optionValues).toContain(\"\");\n105\t    for (const sourceTypeValue of PEEK_POINT_GRANT_SOURCE_TYPES) {\n106\t      expect(optionValues).toContain(sourceTypeValue);\n107\t    }\n108\t\n109\t    expect(\n110\t      (screen.getByLabelText(\"User ID\") as HTMLInputElement).value,\n111\t    ).toBe(\"\");\n112\t    expect(\n113\t      (screen.getByLabelText(\"Source ID\") as HTMLInputElement).value,\n114\t    ).toBe(\"\");\n115\t    expect(\n116\t      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n117\t    ).toBe(\"\");\n118\t    expect(\n119\t      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n120\t    ).toBe(\"\");\n121\t  });\n122\t\n123\t  it(\"populated: pre-fills every input with the URL-addressable filter values, including the source-type select\", () => {\n124\t    render(<PointGrantsFilterBar filters={POPULATED_GRANT_FILTERS} />);\n125\t\n126\t    expect(\n127\t      (screen.getByLabelText(\"User ID\") as HTMLInputElement).value,\n128\t    ).toBe(\"user-9\");\n129\t    expect(\n130\t      (screen.getByLabelText(\"Source type\") as HTMLSelectElement).value,\n131\t    ).toBe(\"challenge_completed\");\n132\t    expect(\n133\t      (screen.getByLabelText(\"Source ID\") as HTMLInputElement).value,\n134\t    ).toBe(\"challenge-7\");\n135\t    expect(\n136\t      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n137\t    ).toBe(\"2026-04-01\");\n138\t    expect(\n139\t      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n140\t    ).toBe(\"2026-04-26\");\n141\t  });\n142\t\n143\t  it(\"inputs use prefixed names so the grants form can co-exist with the points form on /economy/points\", () => {\n144\t    render(<PointGrantsFilterBar filters={EMPTY_GRANT_FILTERS} />);\n145\t\n146\t    expect(\n147\t      (screen.getByLabelText(\"User ID\") as HTMLInputElement).name,\n148\t    ).toBe(\"grantUserId\");\n149\t    expect(\n150\t      (screen.getByLabelText(\"Source type\") as HTMLSelectElement).name,\n151\t    ).toBe(\"grantSourceType\");\n152\t    expect(\n153\t      (screen.getByLabelText(\"Source ID\") as HTMLInputElement).name,\n154\t    ).toBe(\"grantSourceId\");\n155\t    expect(\n156\t      (screen.getByLabelText(\"Created from\") as HTMLInputElement).name,\n157\t    ).toBe(\"grantFrom\");\n158\t    expect(\n159\t      (screen.getByLabelText(\"Created to\") as HTMLInputElement).name,\n160\t    ).toBe(\"grantTo\");\n161\t  });\n162\t\n163\t  it(\"populated: an ISO timestamp in createdFrom/createdTo is truncated to the YYYY-MM-DD part required by the date input\", () => {\n164\t    render(\n165\t      <PointGrantsFilterBar\n166\t        filters={{\n167\t          ...EMPTY_GRANT_FILTERS,\n168\t          createdFrom: \"2026-04-01T10:00:00.000Z\",\n169\t          createdTo: \"2026-04-26T23:59:59.999Z\",\n170\t        }}\n171\t      />,\n172\t    );\n173\t\n174\t    expect(\n175\t      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n176\t    ).toBe(\"2026-04-01\");\n177\t    expect(\n178\t      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n179\t    ).toBe(\"2026-04-26\");\n180\t  });\n181\t});\n182\t"}]},"parent_tool_use_id":null,"session_id":"7378b447-bdd0-410a-9e39-562cf2836131","uuid":"d5c30dc9-996e-44d8-b1c2-707f39ec80af","timestamp":"2026-04-26T06:11:22.177Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/economy-points-filter-bar.test.tsx","content":"import { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport {\n  PlayerPointsFilterBar,\n  PointGrantsFilterBar,\n} from \"../economy-points-filter-bar\";\nimport { PEEK_POINT_GRANT_SOURCE_TYPES } from \"../../lib/economy-search-params\";\nimport type {\n  PeekPlayerPointsFilters,\n  PeekPointGrantFilters,\n} from \"../../lib/types/peek\";\n\nconst EMPTY_POINTS_FILTERS: PeekPlayerPointsFilters = {\n  userId: null,\n  wallet: null,\n};\n\nconst POPULATED_POINTS_FILTERS: PeekPlayerPointsFilters = {\n  userId: \"user-1\",\n  wallet: \"WALLET123\",\n};\n\nconst EMPTY_GRANT_FILTERS: PeekPointGrantFilters = {\n  userId: null,\n  sourceType: null,\n  sourceId: null,\n  createdFrom: null,\n  createdTo: null,\n};\n\nconst POPULATED_GRANT_FILTERS: PeekPointGrantFilters = {\n  userId: \"user-9\",\n  sourceType: \"challenge_completed\",\n  sourceId: \"challenge-7\",\n  createdFrom: \"2026-04-01\",\n  createdTo: \"2026-04-26\",\n};\n\ndescribe(\"PlayerPointsFilterBar\", () => {\n  it(\"empty: form posts to /economy/points by default with both inputs blank\", () => {\n    render(<PlayerPointsFilterBar filters={EMPTY_POINTS_FILTERS} />);\n\n    const form = screen.getByRole(\"search\", { name: \"Filter player points\" });\n    expect(form).toHaveAttribute(\"action\", \"/economy/points\");\n    expect(form).toHaveAttribute(\"method\", \"get\");\n\n    expect(\n      (screen.getByLabelText(\"User ID\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Wallet\") as HTMLInputElement).value,\n    ).toBe(\"\");\n  });\n\n  it(\"populated: pre-fills inputs with the URL-addressable filter values\", () => {\n    render(<PlayerPointsFilterBar filters={POPULATED_POINTS_FILTERS} />);\n\n    expect(\n      (screen.getByLabelText(\"User ID\") as HTMLInputElement).value,\n    ).toBe(\"user-1\");\n    expect(\n      (screen.getByLabelText(\"Wallet\") as HTMLInputElement).value,\n    ).toBe(\"WALLET123\");\n  });\n\n  it(\"inputs use prefixed names so the points + grants forms can co-exist on /economy/points\", () => {\n    render(<PlayerPointsFilterBar filters={EMPTY_POINTS_FILTERS} />);\n    expect(\n      (screen.getByLabelText(\"User ID\") as HTMLInputElement).name,\n    ).toBe(\"pointsUserId\");\n    expect(\n      (screen.getByLabelText(\"Wallet\") as HTMLInputElement).name,\n    ).toBe(\"pointsWallet\");\n  });\n\n  it(\"custom action overrides the default form target\", () => {\n    render(\n      <PlayerPointsFilterBar\n        filters={EMPTY_POINTS_FILTERS}\n        action=\"/economy/points?embed=1\"\n      />,\n    );\n    const form = screen.getByRole(\"search\", { name: \"Filter player points\" });\n    expect(form).toHaveAttribute(\"action\", \"/economy/points?embed=1\");\n  });\n});\n\ndescribe(\"PointGrantsFilterBar\", () => {\n  it(\"empty: form posts to /economy/points by default with all inputs blank and source-type 'Any' selected\", () => {\n    render(<PointGrantsFilterBar filters={EMPTY_GRANT_FILTERS} />);\n\n    const form = screen.getByRole(\"search\", { name: \"Filter point grants\" });\n    expect(form).toHaveAttribute(\"action\", \"/economy/points\");\n    expect(form).toHaveAttribute(\"method\", \"get\");\n\n    const sourceType = screen.getByLabelText(\n      \"Source type\",\n    ) as HTMLSelectElement;\n    expect(sourceType.value).toBe(\"\");\n\n    // The select must include every published source type plus the \"Any\"\n    // option so an operator can scope the ledger by category.\n    const optionValues = Array.from(sourceType.options).map((o) => o.value);\n    expect(optionValues).toContain(\"\");\n    for (const sourceTypeValue of PEEK_POINT_GRANT_SOURCE_TYPES) {\n      expect(optionValues).toContain(sourceTypeValue);\n    }\n\n    expect(\n      (screen.getByLabelText(\"User ID\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Source ID\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"\");\n  });\n\n  it(\"populated: pre-fills every input with the URL-addressable filter values, including the source-type select\", () => {\n    render(<PointGrantsFilterBar filters={POPULATED_GRANT_FILTERS} />);\n\n    expect(\n      (screen.getByLabelText(\"User ID\") as HTMLInputElement).value,\n    ).toBe(\"user-9\");\n    expect(\n      (screen.getByLabelText(\"Source type\") as HTMLSelectElement).value,\n    ).toBe(\"challenge_completed\");\n    expect(\n      (screen.getByLabelText(\"Source ID\") as HTMLInputElement).value,\n    ).toBe(\"challenge-7\");\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n  });\n\n  it(\"inputs use prefixed names so the grants form can co-exist with the points form on /economy/points\", () => {\n    render(<PointGrantsFilterBar filters={EMPTY_GRANT_FILTERS} />);\n\n    expect(\n      (screen.getByLabelText(\"User ID\") as HTMLInputElement).name,\n    ).toBe(\"grantUserId\");\n    expect(\n      (screen.getByLabelText(\"Source type\") as HTMLSelectElement).name,\n    ).toBe(\"grantSourceType\");\n    expect(\n      (screen.getByLabelText(\"Source ID\") as HTMLInputElement).name,\n    ).toBe(\"grantSourceId\");\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).name,\n    ).toBe(\"grantFrom\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).name,\n    ).toBe(\"grantTo\");\n  });\n\n  it(\"populated: an ISO timestamp in createdFrom/createdTo is truncated to the YYYY-MM-DD part required by the date input\", () => {\n    render(\n      <PointGrantsFilterBar\n        filters={{\n          ...EMPTY_GRANT_FILTERS,\n          createdFrom: \"2026-04-01T10:00:00.000Z\",\n          createdTo: \"2026-04-26T23:59:59.999Z\",\n        }}\n      />,\n    );\n\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n  });\n});\n","numLines":182,"startLine":1,"totalLines":182}}}
