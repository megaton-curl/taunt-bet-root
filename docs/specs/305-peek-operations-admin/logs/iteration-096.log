allengeCount: 2,\n  activeAssignmentCount: 87,\n};\n\ndescribe(\"CampaignsTable\", () => {\n  it(\"populated: renders the operator columns and the type/state chips\", () => {\n    render(<CampaignsTable rows={[ROW_DAILY, ROW_INACTIVE_ONBOARDING]} />);\n\n    for (const header of [\n      \"Name\",\n      \"Type\",\n      \"State\",\n      \"Starts\",\n      \"Ends\",\n      \"Challenges\",\n      \"Active assignments\",\n      \"Created\",\n      \"ID\",\n    ]) {\n      expect(screen.getByText(header)).toBeInTheDocument();\n    }\n\n    expect(screen.getByText(\"Daily challenges\")).toBeInTheDocument();\n    expect(screen.getByText(\"Onboarding crate\")).toBeInTheDocument();\n    expect(screen.getByText(\"daily\")).toBeInTheDocument();\n    expect(screen.getByText(\"onboarding\")).toBeInTheDocument();\n    expect(screen.getByText(\"active\")).toBeInTheDocument();\n    expect(screen.getByText(\"inactive\")).toBeInTheDocument();\n  });\n\n  it(\"populated: counts use thousands separators and null start/end dates render '—'\", () => {\n    render(<CampaignsTable rows={[ROW_DAILY, ROW_INACTIVE_ONBOARDING]} />);\n\n    expect(screen.getByText(\"1,234\")).toBeInTheDocument();\n    // Two rows × two null date columns each → expect at least 2 dashes.\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(2);\n  });\n\n  it(\"populated: dogpile rows render the warning chip variant\", () => {\n    render(<CampaignsTable rows={[ROW_DOGPILE]} />);\n\n    expect(screen.getByText(\"dogpile\")).toBeInTheDocument();\n    expect(screen.getByText(\"Bull-run dogpile\")).toBeInTheDocument();\n  });\n\n  it(\"read-only: no edit affordances rendered (no buttons, no editable inputs)\", () => {\n    render(<CampaignsTable rows={[ROW_DAILY, ROW_DOGPILE]} />);\n\n    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n    expect(screen.queryByRole(\"textbox\")).toBeNull();\n    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n  });\n\n  it(\"empty: renders the operator status block when no campaigns exist\", () => {\n    render(<CampaignsTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"No campaigns rows.\");\n    expect(status).toHaveTextContent(\"campaigns\");\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n    render(\n      <CampaignsTable rows={[ROW_DAILY]} error=\"connection refused\" />,\n    );\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Campaigns unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01SorAQxkcuhin1tABD4mCVr","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01VK2xi8XaNMNL6DBQx1qyCv","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/__tests__/challenges-table.test.tsx","content":"// Component tests for the FR-9 challenges table.\n//\n// Read-only by spec — challenge definition editing is explicitly out of scope\n// (FR-9 / FR-14), so the assertions guarantee there are no buttons / inputs\n// and that the empty/error states match the operator-facing copy.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { ChallengesTable } from \"../challenges-table\";\nimport type { PeekChallengeRow } from \"../../lib/types/peek\";\n\nconst ROW_ACTIVE: PeekChallengeRow = {\n  id: \"100\",\n  campaignId: \"1\",\n  campaignName: \"Daily challenges\",\n  campaignType: \"daily\",\n  title: \"Wager 1 SOL today\",\n  description: \"Wager at least 1 SOL across any game today\",\n  action: \"wager\",\n  scope: \"any\",\n  condition: \"amount_gte\",\n  threshold: 1000000000,\n  rewardType: \"points\",\n  rewardAmount: 500,\n  prerequisiteId: null,\n  sortOrder: 1,\n  isActive: true,\n  createdAt: \"2026-04-25T00:00:00.000Z\",\n};\n\nconst ROW_INACTIVE_CRATE: PeekChallengeRow = {\n  id: \"101\",\n  campaignId: \"2\",\n  campaignName: \"Onboarding crate\",\n  campaignType: \"onboarding\",\n  title: \"First Pot Shot win\",\n  description: null,\n  action: \"win\",\n  scope: \"potshot\",\n  condition: \"count_gte\",\n  threshold: 1,\n  rewardType: \"crate\",\n  rewardAmount: null,\n  prerequisiteId: null,\n  sortOrder: 1,\n  isActive: false,\n  createdAt: \"2026-04-01T00:00:00.000Z\",\n};\n\ndescribe(\"ChallengesTable\", () => {\n  it(\"populated: renders all per-template config columns\", () => {\n    render(<ChallengesTable rows={[ROW_ACTIVE, ROW_INACTIVE_CRATE]} />);\n\n    for (const header of [\n      \"Title\",\n      \"Campaign\",\n      \"State\",\n      \"Action\",\n      \"Scope\",\n      \"Condition\",\n      \"Threshold\",\n      \"Reward\",\n      \"Sort\",\n      \"ID\",\n    ]) {\n      expect(screen.getByText(header)).toBeInTheDocument();\n    }\n\n    expect(screen.getByText(\"Wager 1 SOL today\")).toBeInTheDocument();\n    expect(screen.getByText(\"First Pot Shot win\")).toBeInTheDocument();\n    expect(screen.getByText(\"active\")).toBeInTheDocument();\n    expect(screen.getByText(\"inactive\")).toBeInTheDocument();\n    expect(screen.getByText(\"wager\")).toBeInTheDocument();\n    expect(screen.getByText(\"win\")).toBeInTheDocument();\n    expect(screen.getByText(\"any\")).toBeInTheDocument();\n    expect(screen.getByText(\"potshot\")).toBeInTheDocument();\n    expect(screen.getByText(\"amount_gte\")).toBeInTheDocument();\n    expect(screen.getByText(\"count_gte\")).toBeInTheDocument();\n    expect(screen.getByText(\"points\")).toBeInTheDocument();\n    expect(screen.getByText(\"crate\")).toBeInTheDocument();\n  });\n\n  it(\"populated: integer threshold uses thousands separator and null reward amount renders the chip without a numeric suffix\", () => {\n    render(<ChallengesTable rows={[ROW_ACTIVE, ROW_INACTIVE_CRATE]} />);\n\n    expect(screen.getByText(\"1,000,000,000\")).toBeInTheDocument();\n    // Reward amount on ROW_ACTIVE shows \" · 500\"; null reward on\n    // ROW_INACTIVE_CRATE has no `· <number>` suffix.\n    expect(screen.getByText(/· 500/)).toBeInTheDocument();\n  });\n\n  it(\"populated: description sub-row renders only when present (null description omits the secondary line)\", () => {\n    render(<ChallengesTable rows={[ROW_ACTIVE, ROW_INACTIVE_CRATE]} />);\n\n    expect(\n      screen.getByText(\"Wager at least 1 SOL across any game today\"),\n    ).toBeInTheDocument();\n    // ROW_INACTIVE_CRATE has description: null, so the description text is absent.\n    expect(screen.queryByText(/null/i)).toBeNull();\n  });\n\n  it(\"read-only: no edit affordances rendered\", () => {\n    render(<ChallengesTable rows={[ROW_ACTIVE]} />);\n\n    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n    expect(screen.queryByRole(\"textbox\")).toBeNull();\n    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n  });\n\n  it(\"empty (filtered): renders the filter-aware operator status block\", () => {\n    render(<ChallengesTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"No challenges match these filters.\");\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n    render(<ChallengesTable rows={[ROW_ACTIVE]} error=\"db down\" />);\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Challenges unavailable: db down\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1956,"cache_read_input_tokens":151779,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1956},"output_tokens":62,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"7378b447-bdd0-410a-9e39-562cf2836131","uuid":"9affae6f-de18-45cc-a877-eafa52a3ba98"}
