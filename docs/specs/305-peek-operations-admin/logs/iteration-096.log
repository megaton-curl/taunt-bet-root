{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01B2vuucRoHowhcnkcHPxaPb","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01SKSvRd4bEiLrUB34RVS3Uk","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/__tests__/progress-events-table.test.tsx","content":"// Component tests for the FR-9 progress events table.\n//\n// The progress_events table is an append-only ledger pinning a specific game\n// round to an assignment for anti-gaming audit. Operators paste roundId into\n// universal search to inspect the originating round, so the test asserts the\n// roundId is rendered verbatim.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { ProgressEventsTable } from \"../progress-events-table\";\nimport type { PeekProgressEventRow } from \"../../lib/types/peek\";\n\nconst ROW_FULL: PeekProgressEventRow = {\n  id: \"5001\",\n  assignmentId: \"9001\",\n  challengeId: \"challenge-7\",\n  challengeTitle: \"Wager 5 SOL today\",\n  roundId: \"Mat6h6P12U67TpgWfXFqxL2tFcUCexNfvL59ULQGQ8M\",\n  userId: \"user-1\",\n  username: \"alice\",\n  progressDelta: 12345,\n  createdAt: \"2026-04-26T10:00:00.000Z\",\n};\n\nconst ROW_NULL_USERNAME: PeekProgressEventRow = {\n  id: \"5002\",\n  assignmentId: \"9002\",\n  challengeId: null,\n  challengeTitle: null,\n  roundId: \"round-9\",\n  userId: \"user-2\",\n  username: null,\n  progressDelta: 1,\n  createdAt: \"2026-04-26T11:00:00.000Z\",\n};\n\ndescribe(\"ProgressEventsTable\", () => {\n  it(\"populated: renders the operator columns\", () => {\n    render(<ProgressEventsTable rows={[ROW_FULL]} />);\n\n    for (const header of [\n      \"Created\",\n      \"User\",\n      \"Challenge\",\n      \"Assignment\",\n      \"Round\",\n      \"Δ progress\",\n      \"ID\",\n    ]) {\n      expect(screen.getByText(header)).toBeInTheDocument();\n    }\n  });\n\n  it(\"populated: roundId renders verbatim so an operator can paste it into universal search\", () => {\n    render(<ProgressEventsTable rows={[ROW_FULL]} />);\n\n    expect(\n      screen.getByText(\"Mat6h6P12U67TpgWfXFqxL2tFcUCexNfvL59ULQGQ8M\"),\n    ).toBeInTheDocument();\n  });\n\n  it(\"populated: progress delta uses thousands separators\", () => {\n    render(<ProgressEventsTable rows={[ROW_FULL]} />);\n\n    expect(screen.getByText(\"12,345\")).toBeInTheDocument();\n  });\n\n  it(\"populated: user cell prefers username + drills down to /users/[userId]\", () => {\n    render(<ProgressEventsTable rows={[ROW_FULL]} />);\n\n    const link = screen.getByRole(\"link\", { name: \"alice\" });\n    expect(link).toHaveAttribute(\"href\", \"/users/user-1\");\n  });\n\n  it(\"populated: user cell falls back to userId when username is null\", () => {\n    render(<ProgressEventsTable rows={[ROW_NULL_USERNAME]} />);\n\n    const link = screen.getByRole(\"link\", { name: \"user-2\" });\n    expect(link).toHaveAttribute(\"href\", \"/users/user-2\");\n  });\n\n  it(\"populated: null challenge title/id renders '—' instead of breaking the row\", () => {\n    render(<ProgressEventsTable rows={[ROW_NULL_USERNAME]} />);\n\n    // ROW_NULL_USERNAME has both challengeTitle: null and challengeId: null →\n    // both render '—'.\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(2);\n  });\n\n  it(\"read-only: no edit affordances rendered (append-only ledger)\", () => {\n    render(<ProgressEventsTable rows={[ROW_FULL]} />);\n\n    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n    expect(screen.queryByRole(\"textbox\")).toBeNull();\n    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n  });\n\n  it(\"empty (filtered): renders the filter-aware operator status block\", () => {\n    render(<ProgressEventsTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\n      \"No progress_events rows match these filters.\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n    render(<ProgressEventsTable rows={[ROW_FULL]} error=\"db down\" />);\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Progress events unavailable: db down\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2686,"cache_read_input_tokens":155844,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2686},"output_tokens":61,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"7378b447-bdd0-410a-9e39-562cf2836131","uuid":"451d0442-6eec-4e4c-955e-caad04820be8"}
