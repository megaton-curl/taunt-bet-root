{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SneEsLwZhH175niN4WHRva","type":"tool_result","content":"1\t// Campaigns table for /economy/challenges (FR-9).\n2\t//\n3\t// Read-only dense table over `PeekCampaignRow`. Renders campaign type as a\n4\t// status chip and is_active state as a positive/neutral chip so an operator\n5\t// can see at a glance which top-level containers are live. Editing campaigns\n6\t// is out of scope here (FR-9 / FR-14).\n7\timport type { CSSProperties } from \"react\";\n8\timport type {\n9\t  PeekCampaignRow,\n10\t  PeekStatusTone,\n11\t} from \"../lib/types/peek\";\n12\timport { StatusChip } from \"./status-chip\";\n13\t\n14\texport type CampaignsTableProps = {\n15\t  rows: ReadonlyArray<PeekCampaignRow>;\n16\t  error?: string | null;\n17\t};\n18\t\n19\texport function CampaignsTable({ rows, error = null }: CampaignsTableProps) {\n20\t  if (error) {\n21\t    return (\n22\t      <div role=\"alert\" style={errorStyle}>\n23\t        Campaigns unavailable: {error}\n24\t      </div>\n25\t    );\n26\t  }\n27\t\n28\t  if (rows.length === 0) {\n29\t    return (\n30\t      <div role=\"status\" style={emptyStyle}>\n31\t        <p style={emptyTitleStyle}>No campaigns rows.</p>\n32\t        <p style={emptyBodyStyle}>\n33\t          The `campaigns` table has not been seeded yet, so no challenge or\n34\t          bonus container can be displayed.\n35\t        </p>\n36\t      </div>\n37\t    );\n38\t  }\n39\t\n40\t  return (\n41\t    <div style={wrapperStyle}>\n42\t      <table style={tableStyle}>\n43\t        <thead>\n44\t          <tr style={headerRowStyle}>\n45\t            <th style={headerCellStyle(\"left\")}>Name</th>\n46\t            <th style={headerCellStyle(\"left\")}>Type</th>\n47\t            <th style={headerCellStyle(\"left\")}>State</th>\n48\t            <th style={headerCellStyle(\"left\")}>Starts</th>\n49\t            <th style={headerCellStyle(\"left\")}>Ends</th>\n50\t            <th style={headerCellStyle(\"right\")}>Challenges</th>\n51\t            <th style={headerCellStyle(\"right\")}>Active assignments</th>\n52\t            <th style={headerCellStyle(\"left\")}>Created</th>\n53\t            <th style={headerCellStyle(\"left\")}>ID</th>\n54\t          </tr>\n55\t        </thead>\n56\t        <tbody>\n57\t          {rows.map((row) => (\n58\t            <tr key={row.id} style={bodyRowStyle}>\n59\t              <td style={bodyCellStyle(\"left\")}>{row.name}</td>\n60\t              <td style={bodyCellStyle(\"left\")}>\n61\t                <StatusChip\n62\t                  label={row.campaignType}\n63\t                  tone={campaignTypeTone(row.campaignType)}\n64\t                />\n65\t              </td>\n66\t              <td style={bodyCellStyle(\"left\")}>\n67\t                <StatusChip\n68\t                  label={row.isActive ? \"active\" : \"inactive\"}\n69\t                  tone={row.isActive ? \"positive\" : \"neutral\"}\n70\t                />\n71\t              </td>\n72\t              <td style={bodyCellStyle(\"left\")}>{row.startsAt ?? \"—\"}</td>\n73\t              <td style={bodyCellStyle(\"left\")}>{row.endsAt ?? \"—\"}</td>\n74\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n75\t                {row.challengeCount.toLocaleString(\"en-US\")}\n76\t              </td>\n77\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n78\t                {row.activeAssignmentCount.toLocaleString(\"en-US\")}\n79\t              </td>\n80\t              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n81\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n82\t                {row.id}\n83\t              </td>\n84\t            </tr>\n85\t          ))}\n86\t        </tbody>\n87\t      </table>\n88\t    </div>\n89\t  );\n90\t}\n91\t\n92\tfunction campaignTypeTone(value: string): PeekStatusTone {\n93\t  if (value === \"daily\") return \"info\";\n94\t  if (value === \"weekly\") return \"info\";\n95\t  if (value === \"onboarding\") return \"positive\";\n96\t  if (value === \"dogpile\") return \"warning\";\n97\t  return \"neutral\";\n98\t}\n99\t\n100\tconst wrapperStyle: CSSProperties = {\n101\t  overflowX: \"auto\",\n102\t  border: \"1px solid #1e293b\",\n103\t  borderRadius: \"0.75rem\",\n104\t};\n105\t\n106\tconst tableStyle: CSSProperties = {\n107\t  width: \"100%\",\n108\t  borderCollapse: \"collapse\",\n109\t};\n110\t\n111\tconst headerRowStyle: CSSProperties = {\n112\t  background: \"#111827\",\n113\t  color: \"#94a3b8\",\n114\t};\n115\t\n116\tconst bodyRowStyle: CSSProperties = {\n117\t  borderTop: \"1px solid #1e293b\",\n118\t};\n119\t\n120\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n121\t  return {\n122\t    padding: \"0.75rem\",\n123\t    textAlign: align,\n124\t    fontSize: \"0.875rem\",\n125\t    fontWeight: 600,\n126\t  };\n127\t}\n128\t\n129\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n130\t  return {\n131\t    padding: \"0.75rem\",\n132\t    textAlign: align,\n133\t    fontSize: \"0.875rem\",\n134\t    color: \"#e2e8f0\",\n135\t    verticalAlign: \"top\",\n136\t  };\n137\t}\n138\t\n139\tconst errorStyle: CSSProperties = {\n140\t  margin: 0,\n141\t  padding: \"0.75rem 1rem\",\n142\t  borderRadius: \"0.75rem\",\n143\t  background: \"#3f1d1d\",\n144\t  color: \"#fecaca\",\n145\t};\n146\t\n147\tconst emptyStyle: CSSProperties = {\n148\t  padding: \"1.5rem\",\n149\t  borderRadius: \"0.75rem\",\n150\t  border: \"1px dashed #334155\",\n151\t  background: \"#0b1220\",\n152\t  color: \"#cbd5f5\",\n153\t  display: \"grid\",\n154\t  gap: \"0.5rem\",\n155\t};\n156\t\n157\tconst emptyTitleStyle: CSSProperties = {\n158\t  margin: 0,\n159\t  fontSize: \"1rem\",\n160\t  fontWeight: 600,\n161\t};\n162\t\n163\tconst emptyBodyStyle: CSSProperties = {\n164\t  margin: 0,\n165\t  fontSize: \"0.875rem\",\n166\t  color: \"#94a3b8\",\n167\t};\n168\t"}]},"parent_tool_use_id":null,"session_id":"7378b447-bdd0-410a-9e39-562cf2836131","uuid":"0e49fb9e-d6c1-4b3d-bb8d-bec5a4aa3945","timestamp":"2026-04-26T06:10:52.888Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/campaigns-table.tsx","content":"// Campaigns table for /economy/challenges (FR-9).\n//\n// Read-only dense table over `PeekCampaignRow`. Renders campaign type as a\n// status chip and is_active state as a positive/neutral chip so an operator\n// can see at a glance which top-level containers are live. Editing campaigns\n// is out of scope here (FR-9 / FR-14).\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekCampaignRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type CampaignsTableProps = {\n  rows: ReadonlyArray<PeekCampaignRow>;\n  error?: string | null;\n};\n\nexport function CampaignsTable({ rows, error = null }: CampaignsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Campaigns unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No campaigns rows.</p>\n        <p style={emptyBodyStyle}>\n          The `campaigns` table has not been seeded yet, so no challenge or\n          bonus container can be displayed.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Name</th>\n            <th style={headerCellStyle(\"left\")}>Type</th>\n            <th style={headerCellStyle(\"left\")}>State</th>\n            <th style={headerCellStyle(\"left\")}>Starts</th>\n            <th style={headerCellStyle(\"left\")}>Ends</th>\n            <th style={headerCellStyle(\"right\")}>Challenges</th>\n            <th style={headerCellStyle(\"right\")}>Active assignments</th>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>ID</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{row.name}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.campaignType}\n                  tone={campaignTypeTone(row.campaignType)}\n                />\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.isActive ? \"active\" : \"inactive\"}\n                  tone={row.isActive ? \"positive\" : \"neutral\"}\n                />\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.startsAt ?? \"—\"}</td>\n              <td style={bodyCellStyle(\"left\")}>{row.endsAt ?? \"—\"}</td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.challengeCount.toLocaleString(\"en-US\")}\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.activeAssignmentCount.toLocaleString(\"en-US\")}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.id}\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction campaignTypeTone(value: string): PeekStatusTone {\n  if (value === \"daily\") return \"info\";\n  if (value === \"weekly\") return \"info\";\n  if (value === \"onboarding\") return \"positive\";\n  if (value === \"dogpile\") return \"warning\";\n  return \"neutral\";\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":168,"startLine":1,"totalLines":168}}}
