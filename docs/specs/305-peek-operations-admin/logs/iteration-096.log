{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FTXVhtyqAWqrdaSGTfsUhz","type":"tool_result","content":"1\t// Challenges table for /economy/challenges (FR-9).\n2\t//\n3\t// Read-only dense table over `PeekChallengeRow`. Columns surface the\n4\t// per-challenge configuration that determines what a player has to do (action,\n5\t// scope, condition, threshold) and what they get for it (reward type +\n6\t// amount). Challenge definition editing is explicitly out of scope (FR-9 /\n7\t// FR-14).\n8\timport type { CSSProperties } from \"react\";\n9\timport type {\n10\t  PeekChallengeRow,\n11\t  PeekStatusTone,\n12\t} from \"../lib/types/peek\";\n13\timport { StatusChip } from \"./status-chip\";\n14\t\n15\texport type ChallengesTableProps = {\n16\t  rows: ReadonlyArray<PeekChallengeRow>;\n17\t  error?: string | null;\n18\t};\n19\t\n20\texport function ChallengesTable({ rows, error = null }: ChallengesTableProps) {\n21\t  if (error) {\n22\t    return (\n23\t      <div role=\"alert\" style={errorStyle}>\n24\t        Challenges unavailable: {error}\n25\t      </div>\n26\t    );\n27\t  }\n28\t\n29\t  if (rows.length === 0) {\n30\t    return (\n31\t      <div role=\"status\" style={emptyStyle}>\n32\t        <p style={emptyTitleStyle}>No challenges match these filters.</p>\n33\t        <p style={emptyBodyStyle}>\n34\t          Adjust the filters above or clear them to see challenge templates.\n35\t        </p>\n36\t      </div>\n37\t    );\n38\t  }\n39\t\n40\t  return (\n41\t    <div style={wrapperStyle}>\n42\t      <table style={tableStyle}>\n43\t        <thead>\n44\t          <tr style={headerRowStyle}>\n45\t            <th style={headerCellStyle(\"left\")}>Title</th>\n46\t            <th style={headerCellStyle(\"left\")}>Campaign</th>\n47\t            <th style={headerCellStyle(\"left\")}>State</th>\n48\t            <th style={headerCellStyle(\"left\")}>Action</th>\n49\t            <th style={headerCellStyle(\"left\")}>Scope</th>\n50\t            <th style={headerCellStyle(\"left\")}>Condition</th>\n51\t            <th style={headerCellStyle(\"right\")}>Threshold</th>\n52\t            <th style={headerCellStyle(\"left\")}>Reward</th>\n53\t            <th style={headerCellStyle(\"right\")}>Sort</th>\n54\t            <th style={headerCellStyle(\"left\")}>ID</th>\n55\t          </tr>\n56\t        </thead>\n57\t        <tbody>\n58\t          {rows.map((row) => (\n59\t            <tr key={row.id} style={bodyRowStyle}>\n60\t              <td style={bodyCellStyle(\"left\")}>\n61\t                <div>{row.title}</div>\n62\t                {row.description ? (\n63\t                  <div style={subValueStyle}>{row.description}</div>\n64\t                ) : null}\n65\t              </td>\n66\t              <td style={bodyCellStyle(\"left\")}>\n67\t                <div>{row.campaignName ?? \"—\"}</div>\n68\t                {row.campaignType ? (\n69\t                  <div style={subValueStyle}>{row.campaignType}</div>\n70\t                ) : null}\n71\t              </td>\n72\t              <td style={bodyCellStyle(\"left\")}>\n73\t                <StatusChip\n74\t                  label={row.isActive ? \"active\" : \"inactive\"}\n75\t                  tone={row.isActive ? \"positive\" : \"neutral\"}\n76\t                />\n77\t              </td>\n78\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n79\t                {row.action}\n80\t              </td>\n81\t              <td style={bodyCellStyle(\"left\")}>\n82\t                <StatusChip label={row.scope} tone={scopeTone(row.scope)} />\n83\t              </td>\n84\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n85\t                {row.condition}\n86\t              </td>\n87\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n88\t                {row.threshold.toLocaleString(\"en-US\")}\n89\t              </td>\n90\t              <td style={bodyCellStyle(\"left\")}>\n91\t                <StatusChip\n92\t                  label={row.rewardType}\n93\t                  tone={rewardTypeTone(row.rewardType)}\n94\t                />\n95\t                {row.rewardAmount !== null ? (\n96\t                  <span style={subValueStyle}>\n97\t                    {\" \"}\n98\t                    · {row.rewardAmount.toLocaleString(\"en-US\")}\n99\t                  </span>\n100\t                ) : null}\n101\t              </td>\n102\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n103\t                {row.sortOrder}\n104\t              </td>\n105\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n106\t                {row.id}\n107\t              </td>\n108\t            </tr>\n109\t          ))}\n110\t        </tbody>\n111\t      </table>\n112\t    </div>\n113\t  );\n114\t}\n115\t\n116\tfunction scopeTone(value: string): PeekStatusTone {\n117\t  if (value === \"any\") return \"neutral\";\n118\t  if (value === \"flipyou\") return \"info\";\n119\t  if (value === \"potshot\") return \"info\";\n120\t  if (value === \"closecall\") return \"info\";\n121\t  return \"neutral\";\n122\t}\n123\t\n124\tfunction rewardTypeTone(value: string): PeekStatusTone {\n125\t  if (value === \"points\") return \"positive\";\n126\t  if (value === \"crate\") return \"warning\";\n127\t  return \"neutral\";\n128\t}\n129\t\n130\tconst wrapperStyle: CSSProperties = {\n131\t  overflowX: \"auto\",\n132\t  border: \"1px solid #1e293b\",\n133\t  borderRadius: \"0.75rem\",\n134\t};\n135\t\n136\tconst tableStyle: CSSProperties = {\n137\t  width: \"100%\",\n138\t  borderCollapse: \"collapse\",\n139\t};\n140\t\n141\tconst headerRowStyle: CSSProperties = {\n142\t  background: \"#111827\",\n143\t  color: \"#94a3b8\",\n144\t};\n145\t\n146\tconst bodyRowStyle: CSSProperties = {\n147\t  borderTop: \"1px solid #1e293b\",\n148\t};\n149\t\n150\tconst subValueStyle: CSSProperties = {\n151\t  color: \"#64748b\",\n152\t  fontSize: \"0.75rem\",\n153\t};\n154\t\n155\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n156\t  return {\n157\t    padding: \"0.75rem\",\n158\t    textAlign: align,\n159\t    fontSize: \"0.875rem\",\n160\t    fontWeight: 600,\n161\t  };\n162\t}\n163\t\n164\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n165\t  return {\n166\t    padding: \"0.75rem\",\n167\t    textAlign: align,\n168\t    fontSize: \"0.875rem\",\n169\t    color: \"#e2e8f0\",\n170\t    verticalAlign: \"top\",\n171\t  };\n172\t}\n173\t\n174\tconst errorStyle: CSSProperties = {\n175\t  margin: 0,\n176\t  padding: \"0.75rem 1rem\",\n177\t  borderRadius: \"0.75rem\",\n178\t  background: \"#3f1d1d\",\n179\t  color: \"#fecaca\",\n180\t};\n181\t\n182\tconst emptyStyle: CSSProperties = {\n183\t  padding: \"1.5rem\",\n184\t  borderRadius: \"0.75rem\",\n185\t  border: \"1px dashed #334155\",\n186\t  background: \"#0b1220\",\n187\t  color: \"#cbd5f5\",\n188\t  display: \"grid\",\n189\t  gap: \"0.5rem\",\n190\t};\n191\t\n192\tconst emptyTitleStyle: CSSProperties = {\n193\t  margin: 0,\n194\t  fontSize: \"1rem\",\n195\t  fontWeight: 600,\n196\t};\n197\t\n198\tconst emptyBodyStyle: CSSProperties = {\n199\t  margin: 0,\n200\t  fontSize: \"0.875rem\",\n201\t  color: \"#94a3b8\",\n202\t};\n203\t"}]},"parent_tool_use_id":null,"session_id":"7378b447-bdd0-410a-9e39-562cf2836131","uuid":"2defbe2a-1acf-4a13-9f39-bd2c37c69456","timestamp":"2026-04-26T06:10:55.468Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/challenges-table.tsx","content":"// Challenges table for /economy/challenges (FR-9).\n//\n// Read-only dense table over `PeekChallengeRow`. Columns surface the\n// per-challenge configuration that determines what a player has to do (action,\n// scope, condition, threshold) and what they get for it (reward type +\n// amount). Challenge definition editing is explicitly out of scope (FR-9 /\n// FR-14).\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekChallengeRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type ChallengesTableProps = {\n  rows: ReadonlyArray<PeekChallengeRow>;\n  error?: string | null;\n};\n\nexport function ChallengesTable({ rows, error = null }: ChallengesTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Challenges unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No challenges match these filters.</p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see challenge templates.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Title</th>\n            <th style={headerCellStyle(\"left\")}>Campaign</th>\n            <th style={headerCellStyle(\"left\")}>State</th>\n            <th style={headerCellStyle(\"left\")}>Action</th>\n            <th style={headerCellStyle(\"left\")}>Scope</th>\n            <th style={headerCellStyle(\"left\")}>Condition</th>\n            <th style={headerCellStyle(\"right\")}>Threshold</th>\n            <th style={headerCellStyle(\"left\")}>Reward</th>\n            <th style={headerCellStyle(\"right\")}>Sort</th>\n            <th style={headerCellStyle(\"left\")}>ID</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>\n                <div>{row.title}</div>\n                {row.description ? (\n                  <div style={subValueStyle}>{row.description}</div>\n                ) : null}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <div>{row.campaignName ?? \"—\"}</div>\n                {row.campaignType ? (\n                  <div style={subValueStyle}>{row.campaignType}</div>\n                ) : null}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.isActive ? \"active\" : \"inactive\"}\n                  tone={row.isActive ? \"positive\" : \"neutral\"}\n                />\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.action}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip label={row.scope} tone={scopeTone(row.scope)} />\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.condition}\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.threshold.toLocaleString(\"en-US\")}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.rewardType}\n                  tone={rewardTypeTone(row.rewardType)}\n                />\n                {row.rewardAmount !== null ? (\n                  <span style={subValueStyle}>\n                    {\" \"}\n                    · {row.rewardAmount.toLocaleString(\"en-US\")}\n                  </span>\n                ) : null}\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.sortOrder}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.id}\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction scopeTone(value: string): PeekStatusTone {\n  if (value === \"any\") return \"neutral\";\n  if (value === \"flipyou\") return \"info\";\n  if (value === \"potshot\") return \"info\";\n  if (value === \"closecall\") return \"info\";\n  return \"neutral\";\n}\n\nfunction rewardTypeTone(value: string): PeekStatusTone {\n  if (value === \"points\") return \"positive\";\n  if (value === \"crate\") return \"warning\";\n  return \"neutral\";\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":203,"startLine":1,"totalLines":203}}}
