{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015WZfDR1wFhEgUqZLSN2JFZ","type":"tool_result","content":"1\t// Challenge engine admin queries (FR-9).\n2\t//\n3\t// Backs the upcoming `/economy/challenges` page. Reads six migration-011\n4\t// tables in read-only mode (no challenge or campaign editing — that is\n5\t// explicitly out of scope for FR-9 / FR-14):\n6\t//\n7\t//   - campaigns             — top-level container (daily / weekly /\n8\t//     onboarding / dogpile). `listCampaigns` annotates each row with the\n9\t//     count of associated challenges and active assignments so an operator\n10\t//     can spot misconfigured or empty campaigns.\n11\t//   - challenges            — challenge templates joined with the parent\n12\t//     campaign for context. `listChallenges` supports optional campaignId +\n13\t//     isActive filters.\n14\t//   - challenge_assignments — per-player per-period assignments.\n15\t//     `listChallengeAssignments` filters by userId / challengeId /\n16\t//     campaignId / periodKey / status / assigned date and joins\n17\t//     `player_profiles` + `challenges` + `campaigns` for context.\n18\t//   - progress_events       — append-only progress ledger pinning a\n19\t//     specific game round to an assignment for anti-gaming audit.\n20\t//     `listProgressEvents` filters by assignmentId / challengeId / userId /\n21\t//     roundId / created date.\n22\t//   - completion_bonuses    — meta-quest definitions. `listCompletionBonuses`\n23\t//     annotates each row with completion counts.\n24\t//   - bonus_completions     — per-player per-period bonus completion ledger.\n25\t//     `listBonusCompletions` filters by userId / bonusId / campaignId /\n26\t//     periodKey / completed date.\n27\t//\n28\t// `getChallengesOverview` derives the FR-4 metric strip (active campaigns,\n29\t// active challenges, active assignments, completed assignments and bonus\n30\t// completions in a recent window) from these tables. All queries are bounded\n31\t// server-side (default 100, max 500) and bigint identity ids round-trip as\n32\t// `text` to preserve precision.\n33\t\n34\timport type { Sql } from \"postgres\";\n35\timport {\n36\t  type PeekBonusCompletionFilters,\n37\t  type PeekBonusCompletionRow,\n38\t  type PeekCampaignRow,\n39\t  type PeekChallengeAssignmentFilters,\n40\t  type PeekChallengeAssignmentRow,\n41\t  type PeekChallengeFilters,\n42\t  type PeekChallengeRow,\n43\t  type PeekChallengesOverview,\n44\t  type PeekChallengesOverviewMetricId,\n45\t  type PeekCompletionBonusRow,\n46\t  type PeekMetric,\n47\t  type PeekProgressEventFilters,\n48\t  type PeekProgressEventRow,\n49\t} from \"../../../lib/types/peek\";\n50\timport { getSqlClient } from \"../client\";\n51\t\n52\texport const PEEK_CAMPAIGNS_DEFAULT_LIMIT = 100;\n53\texport const PEEK_CAMPAIGNS_MAX_LIMIT = 500;\n54\texport const PEEK_CHALLENGES_DEFAULT_LIMIT = 100;\n55\texport const PEEK_CHALLENGES_MAX_LIMIT = 500;\n56\texport const PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT = 100;\n57\texport const PEEK_CHALLENGE_ASSIGNMENTS_MAX_LIMIT = 500;\n58\texport const PEEK_PROGRESS_EVENTS_DEFAULT_LIMIT = 100;\n59\texport const PEEK_PROGRESS_EVENTS_MAX_LIMIT = 500;\n60\texport const PEEK_COMPLETION_BONUSES_DEFAULT_LIMIT = 100;\n61\texport const PEEK_COMPLETION_BONUSES_MAX_LIMIT = 500;\n62\texport const PEEK_BONUS_COMPLETIONS_DEFAULT_LIMIT = 100;\n63\texport const PEEK_BONUS_COMPLETIONS_MAX_LIMIT = 500;\n64\texport const PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS = 24;\n65\t\n66\texport type ListCampaignsOptions = {\n67\t  sql?: Sql;\n68\t  limit?: number;\n69\t};\n70\t\n71\texport type ListChallengesOptions = {\n72\t  sql?: Sql;\n73\t  limit?: number;\n74\t  filters?: Partial<PeekChallengeFilters>;\n75\t};\n76\t\n77\texport type ListChallengeAssignmentsOptions = {\n78\t  sql?: Sql;\n79\t  limit?: number;\n80\t  filters?: Partial<PeekChallengeAssignmentFilters>;\n81\t};\n82\t\n83\texport type ListProgressEventsOptions = {\n84\t  sql?: Sql;\n85\t  limit?: number;\n86\t  filters?: Partial<PeekProgressEventFilters>;\n87\t};\n88\t\n89\texport type ListCompletionBonusesOptions = {\n90\t  sql?: Sql;\n91\t  limit?: number;\n92\t};\n93\t\n94\texport type ListBonusCompletionsOptions = {\n95\t  sql?: Sql;\n96\t  limit?: number;\n97\t  filters?: Partial<PeekBonusCompletionFilters>;\n98\t};\n99\t\n100\texport type ChallengesOverviewOptions = {\n101\t  sql?: Sql;\n102\t  now?: Date;\n103\t  windowHours?: number;\n104\t};\n105\t\n106\tfunction clampLimit(\n107\t  raw: number | undefined,\n108\t  fallback: number,\n109\t  max: number,\n110\t): number {\n111\t  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n112\t  const floored = Math.floor(raw);\n113\t  if (floored <= 0) return 1;\n114\t  return Math.min(max, floored);\n115\t}\n116\t\n117\tfunction trimOrNull(value: string | null | undefined): string | null {\n118\t  if (typeof value !== \"string\") return null;\n119\t  const trimmed = value.trim();\n120\t  return trimmed.length > 0 ? trimmed : null;\n121\t}\n122\t\n123\tfunction readInt(value: number | string | null | undefined): number {\n124\t  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n125\t  if (typeof value === \"string\") {\n126\t    const parsed = Number.parseInt(value, 10);\n127\t    return Number.isFinite(parsed) ? parsed : 0;\n128\t  }\n129\t  return 0;\n130\t}\n131\t\n132\tfunction formatCount(count: number): string {\n133\t  return count.toLocaleString(\"en-US\");\n134\t}\n135\t\n136\tfunction parseBoolFilter(value: string | null): boolean | null {\n137\t  if (value === null) return null;\n138\t  if (value === \"true\") return true;\n139\t  if (value === \"false\") return false;\n140\t  return null;\n141\t}\n142\t\n143\texport async function listCampaigns(\n144\t  options: ListCampaignsOptions = {},\n145\t): Promise<ReadonlyArray<PeekCampaignRow>> {\n146\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n147\t  const limit = clampLimit(\n148\t    options.limit,\n149\t    PEEK_CAMPAIGNS_DEFAULT_LIMIT,\n150\t    PEEK_CAMPAIGNS_MAX_LIMIT,\n151\t  );\n152\t\n153\t  const rows = await sql<\n154\t    Array<{\n155\t      id: string;\n156\t      name: string;\n157\t      campaignType: string;\n158\t      startsAt: string | null;\n159\t      endsAt: string | null;\n160\t      isActive: boolean;\n161\t      createdAt: string;\n162\t      challengeCount: number | string;\n163\t      activeAssignmentCount: number | string;\n164\t    }>\n165\t  >`\n166\t    select\n167\t      c.id::text as \"id\",\n168\t      c.name as \"name\",\n169\t      c.campaign_type as \"campaignType\",\n170\t      c.starts_at::text as \"startsAt\",\n171\t      c.ends_at::text as \"endsAt\",\n172\t      c.is_active as \"isActive\",\n173\t      c.created_at::text as \"createdAt\",\n174\t      coalesce(ch_counts.challenge_count, 0)::int as \"challengeCount\",\n175\t      coalesce(asg_counts.active_assignment_count, 0)::int as \"activeAssignmentCount\"\n176\t    from campaigns c\n177\t    left join (\n178\t      select campaign_id, count(*) as challenge_count\n179\t      from challenges\n180\t      group by campaign_id\n181\t    ) ch_counts on ch_counts.campaign_id = c.id\n182\t    left join (\n183\t      select ch.campaign_id, count(*) as active_assignment_count\n184\t      from challenge_assignments ca\n185\t      join challenges ch on ch.id = ca.challenge_id\n186\t      where ca.status = 'active'\n187\t      group by ch.campaign_id\n188\t    ) asg_counts on asg_counts.campaign_id = c.id\n189\t    order by c.is_active desc, c.created_at desc, c.id desc\n190\t    limit ${limit}\n191\t  `;\n192\t\n193\t  return rows.map((row) => ({\n194\t    id: row.id,\n195\t    name: row.name,\n196\t    campaignType: row.campaignType,\n197\t    startsAt: row.startsAt,\n198\t    endsAt: row.endsAt,\n199\t    isActive: row.isActive,\n200\t    createdAt: row.createdAt,\n201\t    challengeCount: readInt(row.challengeCount),\n202\t    activeAssignmentCount: readInt(row.activeAssignmentCount),\n203\t  }));\n204\t}\n205\t\n206\texport async function listChallenges(\n207\t  options: ListChallengesOptions = {},\n208\t): Promise<ReadonlyArray<PeekChallengeRow>> {\n209\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n210\t  const limit = clampLimit(\n211\t    options.limit,\n212\t    PEEK_CHALLENGES_DEFAULT_LIMIT,\n213\t    PEEK_CHALLENGES_MAX_LIMIT,\n214\t  );\n215\t\n216\t  const filters = options.filters ?? {};\n217\t  const campaignId = trimOrNull(filters.campaignId ?? null);\n218\t  const isActive = parseBoolFilter(trimOrNull(filters.isActive ?? null));\n219\t\n220\t  return sql<Array<PeekChallengeRow>>`\n221\t    select\n222\t      ch.id::text as \"id\",\n223\t      ch.campaign_id::text as \"campaignId\",\n224\t      c.name as \"campaignName\",\n225\t      c.campaign_type as \"campaignType\",\n226\t      ch.title as \"title\",\n227\t      ch.description as \"description\",\n228\t      ch.action as \"action\",\n229\t      ch.scope as \"scope\",\n230\t      ch.condition as \"condition\",\n231\t      ch.threshold as \"threshold\",\n232\t      ch.reward_type as \"rewardType\",\n233\t      ch.reward_amount as \"rewardAmount\",\n234\t      ch.prerequisite_id::text as \"prerequisiteId\",\n235\t      ch.sort_order as \"sortOrder\",\n236\t      ch.is_active as \"isActive\",\n237\t      ch.created_at::text as \"createdAt\"\n238\t    from challenges ch\n239\t    left join campaigns c on c.id = ch.campaign_id\n240\t    where\n241\t      (${campaignId === null} or ch.campaign_id::text = ${campaignId ?? \"\"})\n242\t      and (${isActive === null} or ch.is_active = ${isActive ?? false})\n243\t    order by ch.campaign_id asc, ch.sort_order asc, ch.id asc\n244\t    limit ${limit}\n245\t  `;\n246\t}\n247\t\n248\texport async function listChallengeAssignments(\n249\t  options: ListChallengeAssignmentsOptions = {},\n250\t): Promise<ReadonlyArray<PeekChallengeAssignmentRow>> {\n251\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n252\t  const limit = clampLimit(\n253\t    options.limit,\n254\t    PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT,\n255\t    PEEK_CHALLENGE_ASSIGNMENTS_MAX_LIMIT,\n256\t  );\n257\t\n258\t  const filters = options.filters ?? {};\n259\t  const userId = trimOrNull(filters.userId ?? null);\n260\t  const challengeId = trimOrNull(filters.challengeId ?? null);\n261\t  const campaignId = trimOrNull(filters.campaignId ?? null);\n262\t  const periodKey = trimOrNull(filters.periodKey ?? null);\n263\t  const status = trimOrNull(filters.status ?? null);\n264\t  const assignedFrom = trimOrNull(filters.assignedFrom ?? null);\n265\t  const assignedTo = trimOrNull(filters.assignedTo ?? null);\n266\t\n267\t  return sql<Array<PeekChallengeAssignmentRow>>`\n268\t    select\n269\t      ca.id::text as \"id\",\n270\t      ca.user_id as \"userId\",\n271\t      prof.username as \"username\",\n272\t      ca.challenge_id::text as \"challengeId\",\n273\t      ch.title as \"challengeTitle\",\n274\t      ch.campaign_id::text as \"campaignId\",\n275\t      c.name as \"campaignName\",\n276\t      ca.period_key as \"periodKey\",\n277\t      ca.status as \"status\",\n278\t      ca.progress as \"progress\",\n279\t      ca.target as \"target\",\n280\t      ca.assigned_at::text as \"assignedAt\",\n281\t      ca.expires_at::text as \"expiresAt\",\n282\t      ca.completed_at::text as \"completedAt\"\n283\t    from challenge_assignments ca\n284\t    left join challenges ch on ch.id = ca.challenge_id\n285\t    left join campaigns c on c.id = ch.campaign_id\n286\t    left join player_profiles prof on prof.user_id = ca.user_id\n287\t    where\n288\t      (${userId === null} or ca.user_id = ${userId ?? \"\"})\n289\t      and (${challengeId === null} or ca.challenge_id::text = ${challengeId ?? \"\"})\n290\t      and (${campaignId === null} or ch.campaign_id::text = ${campaignId ?? \"\"})\n291\t      and (${periodKey === null} or ca.period_key = ${periodKey ?? \"\"})\n292\t      and (${status === null} or ca.status = ${status ?? \"\"})\n293\t      and (${assignedFrom === null} or ca.assigned_at >= ${assignedFrom ?? \"\"}::timestamptz)\n294\t      and (${assignedTo === null} or ca.assigned_at < ${assignedTo ?? \"\"}::timestamptz)\n295\t    order by ca.assigned_at desc, ca.id desc\n296\t    limit ${limit}\n297\t  `;\n298\t}\n299\t\n300\texport async function listProgressEvents(\n301\t  options: ListProgressEventsOptions = {},\n302\t): Promise<ReadonlyArray<PeekProgressEventRow>> {\n303\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n304\t  const limit = clampLimit(\n305\t    options.limit,\n306\t    PEEK_PROGRESS_EVENTS_DEFAULT_LIMIT,\n307\t    PEEK_PROGRESS_EVENTS_MAX_LIMIT,\n308\t  );\n309\t\n310\t  const filters = options.filters ?? {};\n311\t  const assignmentId = trimOrNull(filters.assignmentId ?? null);\n312\t  const challengeId = trimOrNull(filters.challengeId ?? null);\n313\t  const userId = trimOrNull(filters.userId ?? null);\n314\t  const roundId = trimOrNull(filters.roundId ?? null);\n315\t  const createdFrom = trimOrNull(filters.createdFrom ?? null);\n316\t  const createdTo = trimOrNull(filters.createdTo ?? null);\n317\t\n318\t  return sql<Array<PeekProgressEventRow>>`\n319\t    select\n320\t      pe.id::text as \"id\",\n321\t      pe.assignment_id::text as \"assignmentId\",\n322\t      ca.challenge_id::text as \"challengeId\",\n323\t      ch.title as \"challengeTitle\",\n324\t      pe.round_id as \"roundId\",\n325\t      pe.user_id as \"userId\",\n326\t      prof.username as \"username\",\n327\t      pe.progress_delta as \"progressDelta\",\n328\t      pe.created_at::text as \"createdAt\"\n329\t    from progress_events pe\n330\t    left join challenge_assignments ca on ca.id = pe.assignment_id\n331\t    left join challenges ch on ch.id = ca.challenge_id\n332\t    left join player_profiles prof on prof.user_id = pe.user_id\n333\t    where\n334\t      (${assignmentId === null} or pe.assignment_id::text = ${assignmentId ?? \"\"})\n335\t      and (${challengeId === null} or ca.challenge_id::text = ${challengeId ?? \"\"})\n336\t      and (${userId === null} or pe.user_id = ${userId ?? \"\"})\n337\t      and (${roundId === null} or pe.round_id = ${roundId ?? \"\"})\n338\t      and (${createdFrom === null} or pe.created_at >= ${createdFrom ?? \"\"}::timestamptz)\n339\t      and (${createdTo === null} or pe.created_at < ${createdTo ?? \"\"}::timestamptz)\n340\t    order by pe.created_at desc, pe.id desc\n341\t    limit ${limit}\n342\t  `;\n343\t}\n344\t\n345\texport async function listCompletionBonuses(\n346\t  options: ListCompletionBonusesOptions = {},\n347\t): Promise<ReadonlyArray<PeekCompletionBonusRow>> {\n348\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n349\t  const limit = clampLimit(\n350\t    options.limit,\n351\t    PEEK_COMPLETION_BONUSES_DEFAULT_LIMIT,\n352\t    PEEK_COMPLETION_BONUSES_MAX_LIMIT,\n353\t  );\n354\t\n355\t  const rows = await sql<\n356\t    Array<{\n357\t      id: string;\n358\t      campaignId: string;\n359\t      campaignName: string | null;\n360\t      campaignType: string | null;\n361\t      title: string;\n362\t      description: string | null;\n363\t      requiredCount: number;\n364\t      rewardType: string;\n365\t      rewardAmount: number | null;\n366\t      isActive: boolean;\n367\t      createdAt: string;\n368\t      completionCount: number | string;\n369\t    }>\n370\t  >`\n371\t    select\n372\t      cb.id::text as \"id\",\n373\t      cb.campaign_id::text as \"campaignId\",\n374\t      c.name as \"campaignName\",\n375\t      c.campaign_type as \"campaignType\",\n376\t      cb.title as \"title\",\n377\t      cb.description as \"description\",\n378\t      cb.required_count as \"requiredCount\",\n379\t      cb.reward_type as \"rewardType\",\n380\t      cb.reward_amount as \"rewardAmount\",\n381\t      cb.is_active as \"isActive\",\n382\t      cb.created_at::text as \"createdAt\",\n383\t      coalesce(bc_counts.completion_count, 0)::int as \"completionCount\"\n384\t    from completion_bonuses cb\n385\t    left join campaigns c on c.id = cb.campaign_id\n386\t    left join (\n387\t      select bonus_id, count(*) as completion_count\n388\t      from bonus_completions\n389\t      group by bonus_id\n390\t    ) bc_counts on bc_counts.bonus_id = cb.id\n391\t    order by cb.is_active desc, cb.created_at desc, cb.id desc\n392\t    limit ${limit}\n393\t  `;\n394\t\n395\t  return rows.map((row) => ({\n396\t    id: row.id,\n397\t    campaignId: row.campaignId,\n398\t    campaignName: row.campaignName,\n399\t    campaignType: row.campaignType,\n400\t    title: row.title,\n401\t    description: row.description,\n402\t    requiredCount: readInt(row.requiredCount),\n403\t    rewardType: row.rewardType,\n404\t    rewardAmount:\n405\t      row.rewardAmount === null || row.rewardAmount === undefined\n406\t        ? null\n407\t        : readInt(row.rewardAmount),\n408\t    isActive: row.isActive,\n409\t    createdAt: row.createdAt,\n410\t    completionCount: readInt(row.completionCount),\n411\t  }));\n412\t}\n413\t\n414\texport async function listBonusCompletions(\n415\t  options: ListBonusCompletionsOptions = {},\n416\t): Promise<ReadonlyArray<PeekBonusCompletionRow>> {\n417\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n418\t  const limit = clampLimit(\n419\t    options.limit,\n420\t    PEEK_BONUS_COMPLETIONS_DEFAULT_LIMIT,\n421\t    PEEK_BONUS_COMPLETIONS_MAX_LIMIT,\n422\t  );\n423\t\n424\t  const filters = options.filters ?? {};\n425\t  const userId = trimOrNull(filters.userId ?? null);\n426\t  const bonusId = trimOrNull(filters.bonusId ?? null);\n427\t  const campaignId = trimOrNull(filters.campaignId ?? null);\n428\t  const periodKey = trimOrNull(filters.periodKey ?? null);\n429\t  const completedFrom = trimOrNull(filters.completedFrom ?? null);\n430\t  const completedTo = trimOrNull(filters.completedTo ?? null);\n431\t\n432\t  return sql<Array<PeekBonusCompletionRow>>`\n433\t    select\n434\t      bc.id::text as \"id\",\n435\t      bc.user_id as \"userId\",\n436\t      prof.username as \"username\",\n437\t      bc.bonus_id::text as \"bonusId\",\n438\t      cb.title as \"bonusTitle\",\n439\t      cb.campaign_id::text as \"campaignId\",\n440\t      c.name as \"campaignName\",\n441\t      bc.period_key as \"periodKey\",\n442\t      bc.completed_at::text as \"completedAt\"\n443\t    from bonus_completions bc\n444\t    left join completion_bonuses cb on cb.id = bc.bonus_id\n445\t    left join campaigns c on c.id = cb.campaign_id\n446\t    left join player_profiles prof on prof.user_id = bc.user_id\n447\t    where\n448\t      (${userId === null} or bc.user_id = ${userId ?? \"\"})\n449\t      and (${bonusId === null} or bc.bonus_id::text = ${bonusId ?? \"\"})\n450\t      and (${campaignId === null} or cb.campaign_id::text = ${campaignId ?? \"\"})\n451\t      and (${periodKey === null} or bc.period_key = ${periodKey ?? \"\"})\n452\t      and (${completedFrom === null} or bc.completed_at >= ${completedFrom ?? \"\"}::timestamptz)\n453\t      and (${completedTo === null} or bc.completed_at < ${completedTo ?? \"\"}::timestamptz)\n454\t    order by bc.completed_at desc, bc.id desc\n455\t    limit ${limit}\n456\t  `;\n457\t}\n458\t\n459\ttype MetricBlueprint = {\n460\t  id: PeekChallengesOverviewMetricId;\n461\t  label: string;\n462\t  unit: string | null;\n463\t  source: string;\n464\t  windowLabel: string;\n465\t  definition: string;\n466\t  drilldownHref: string | null;\n467\t};\n468\t\n469\tfunction buildMetric(\n470\t  blueprint: MetricBlueprint,\n471\t  raw: number,\n472\t  display: string,\n473\t  asOf: string,\n474\t): PeekMetric {\n475\t  return {\n476\t    id: blueprint.id,\n477\t    label: blueprint.label,\n478\t    value: raw,\n479\t    valueDisplay: display,\n480\t    unit: blueprint.unit,\n481\t    source: blueprint.source,\n482\t    windowLabel: blueprint.windowLabel,\n483\t    asOf,\n484\t    definition: blueprint.definition,\n485\t    freshness: \"live\",\n486\t    drilldownHref: blueprint.drilldownHref,\n487\t  };\n488\t}\n489\t\n490\texport async function getChallengesOverview(\n491\t  options: ChallengesOverviewOptions = {},\n492\t): Promise<PeekChallengesOverview> {\n493\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n494\t  const now = options.now ?? new Date();\n495\t  const generatedAt = now.toISOString();\n496\t  const windowHours = clampLimit(\n497\t    options.windowHours,\n498\t    PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS,\n499\t    24 * 30,\n500\t  );\n501\t  const since = new Date(now.getTime() - windowHours * 60 * 60 * 1000);\n502\t  const sinceIso = since.toISOString();\n503\t\n504\t  const [\n505\t    activeCampaignsRows,\n506\t    activeChallengesRows,\n507\t    activeAssignmentsRows,\n508\t    completedAssignmentsRows,\n509\t    bonusCompletionsRows,\n510\t  ] = await Promise.all([\n511\t    sql<Array<{ value: number | string }>>`\n512\t      select count(*)::int as \"value\"\n513\t      from campaigns\n514\t      where is_active = true\n515\t    `,\n516\t    sql<Array<{ value: number | string }>>`\n517\t      select count(*)::int as \"value\"\n518\t      from challenges\n519\t      where is_active = true\n520\t    `,\n521\t    sql<Array<{ value: number | string }>>`\n522\t      select count(*)::int as \"value\"\n523\t      from challenge_assignments\n524\t      where status = 'active'\n525\t    `,\n526\t    sql<Array<{ value: number | string }>>`\n527\t      select count(*)::int as \"value\"\n528\t      from challenge_assignments\n529\t      where status = 'completed'\n530\t        and completed_at is not null\n531\t        and completed_at >= ${sinceIso}::timestamptz\n532\t    `,\n533\t    sql<Array<{ value: number | string }>>`\n534\t      select count(*)::int as \"value\"\n535\t      from bonus_completions\n536\t      where completed_at >= ${sinceIso}::timestamptz\n537\t    `,\n538\t  ]);\n539\t\n540\t  const activeCampaigns = readInt(activeCampaignsRows[0]?.value ?? 0);\n541\t  const activeChallenges = readInt(activeChallengesRows[0]?.value ?? 0);\n542\t  const activeAssignments = readInt(activeAssignmentsRows[0]?.value ?? 0);\n543\t  const completedAssignments = readInt(completedAssignmentsRows[0]?.value ?? 0);\n544\t  const bonusCompletions = readInt(bonusCompletionsRows[0]?.value ?? 0);\n545\t\n546\t  const windowLabel = `Last ${windowHours}h`;\n547\t\n548\t  const blueprints: ReadonlyArray<{\n549\t    blueprint: MetricBlueprint;\n550\t    raw: number;\n551\t    display: string;\n552\t  }> = [\n553\t    {\n554\t      blueprint: {\n555\t        id: \"challenges.active_campaigns\",\n556\t        label: \"Active campaigns\",\n557\t        unit: \"campaigns\",\n558\t        source: \"campaigns\",\n559\t        windowLabel: \"Current\",\n560\t        definition:\n561\t          \"Count of campaigns rows with is_active = true — the daily/weekly/onboarding/dogpile containers currently published.\",\n562\t        drilldownHref: \"/economy/challenges#campaigns\",\n563\t      },\n564\t      raw: activeCampaigns,\n565\t      display: formatCount(activeCampaigns),\n566\t    },\n567\t    {\n568\t      blueprint: {\n569\t        id: \"challenges.active_challenges\",\n570\t        label: \"Active challenges\",\n571\t        unit: \"challenges\",\n572\t        source: \"challenges\",\n573\t        windowLabel: \"Current\",\n574\t        definition:\n575\t          \"Count of challenges rows with is_active = true — challenge templates currently eligible for assignment.\",\n576\t        drilldownHref: \"/economy/challenges#challenges\",\n577\t      },\n578\t      raw: activeChallenges,\n579\t      display: formatCount(activeChallenges),\n580\t    },\n581\t    {\n582\t      blueprint: {\n583\t        id: \"challenges.active_assignments\",\n584\t        label: \"Active assignments\",\n585\t        unit: \"assignments\",\n586\t        source: \"challenge_assignments\",\n587\t        windowLabel: \"Current\",\n588\t        definition:\n589\t          \"Count of challenge_assignments rows with status = 'active' — per-player assignments still in progress.\",\n590\t        drilldownHref: \"/economy/challenges?status=active#assignments\",\n591\t      },\n592\t      raw: activeAssignments,\n593\t      display: formatCount(activeAssignments),\n594\t    },\n595\t    {\n596\t      blueprint: {\n597\t        id: \"challenges.completed_assignments_window\",\n598\t        label: \"Completed assignments\",\n599\t        unit: \"assignments\",\n600\t        source: \"challenge_assignments\",\n601\t        windowLabel,\n602\t        definition: `Count of challenge_assignments rows with status = 'completed' and completed_at within the last ${windowHours} hours.`,\n603\t        drilldownHref: \"/economy/challenges?status=completed#assignments\",\n604\t      },\n605\t      raw: completedAssignments,\n606\t      display: formatCount(completedAssignments),\n607\t    },\n608\t    {\n609\t      blueprint: {\n610\t        id: \"challenges.bonus_completions_window\",\n611\t        label: \"Bonus completions\",\n612\t        unit: \"completions\",\n613\t        source: \"bonus_completions\",\n614\t        windowLabel,\n615\t        definition: `Count of bonus_completions rows with completed_at within the last ${windowHours} hours — meta-quest payouts (e.g. complete-all-dailies bonus crate) recently awarded.`,\n616\t        drilldownHref: \"/economy/challenges#bonus-completions\",\n617\t      },\n618\t      raw: bonusCompletions,\n619\t      display: formatCount(bonusCompletions),\n620\t    },\n621\t  ];\n622\t\n623\t  return {\n624\t    generatedAt,\n625\t    metrics: blueprints.map(({ blueprint, raw, display }) =>\n626\t      buildMetric(blueprint, raw, display, generatedAt),\n627\t    ),\n628\t  };\n629\t}\n630\t"}]},"parent_tool_use_id":null,"session_id":"7378b447-bdd0-410a-9e39-562cf2836131","uuid":"43285bd5-2f04-4641-a617-9a403dd264f9","timestamp":"2026-04-26T06:10:37.129Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-challenges.ts","content":"// Challenge engine admin queries (FR-9).\n//\n// Backs the upcoming `/economy/challenges` page. Reads six migration-011\n// tables in read-only mode (no challenge or campaign editing — that is\n// explicitly out of scope for FR-9 / FR-14):\n//\n//   - campaigns             — top-level container (daily / weekly /\n//     onboarding / dogpile). `listCampaigns` annotates each row with the\n//     count of associated challenges and active assignments so an operator\n//     can spot misconfigured or empty campaigns.\n//   - challenges            — challenge templates joined with the parent\n//     campaign for context. `listChallenges` supports optional campaignId +\n//     isActive filters.\n//   - challenge_assignments — per-player per-period assignments.\n//     `listChallengeAssignments` filters by userId / challengeId /\n//     campaignId / periodKey / status / assigned date and joins\n//     `player_profiles` + `challenges` + `campaigns` for context.\n//   - progress_events       — append-only progress ledger pinning a\n//     specific game round to an assignment for anti-gaming audit.\n//     `listProgressEvents` filters by assignmentId / challengeId / userId /\n//     roundId / created date.\n//   - completion_bonuses    — meta-quest definitions. `listCompletionBonuses`\n//     annotates each row with completion counts.\n//   - bonus_completions     — per-player per-period bonus completion ledger.\n//     `listBonusCompletions` filters by userId / bonusId / campaignId /\n//     periodKey / completed date.\n//\n// `getChallengesOverview` derives the FR-4 metric strip (active campaigns,\n// active challenges, active assignments, completed assignments and bonus\n// completions in a recent window) from these tables. All queries are bounded\n// server-side (default 100, max 500) and bigint identity ids round-trip as\n// `text` to preserve precision.\n\nimport type { Sql } from \"postgres\";\nimport {\n  type PeekBonusCompletionFilters,\n  type PeekBonusCompletionRow,\n  type PeekCampaignRow,\n  type PeekChallengeAssignmentFilters,\n  type PeekChallengeAssignmentRow,\n  type PeekChallengeFilters,\n  type PeekChallengeRow,\n  type PeekChallengesOverview,\n  type PeekChallengesOverviewMetricId,\n  type PeekCompletionBonusRow,\n  type PeekMetric,\n  type PeekProgressEventFilters,\n  type PeekProgressEventRow,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_CAMPAIGNS_DEFAULT_LIMIT = 100;\nexport const PEEK_CAMPAIGNS_MAX_LIMIT = 500;\nexport const PEEK_CHALLENGES_DEFAULT_LIMIT = 100;\nexport const PEEK_CHALLENGES_MAX_LIMIT = 500;\nexport const PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT = 100;\nexport const PEEK_CHALLENGE_ASSIGNMENTS_MAX_LIMIT = 500;\nexport const PEEK_PROGRESS_EVENTS_DEFAULT_LIMIT = 100;\nexport const PEEK_PROGRESS_EVENTS_MAX_LIMIT = 500;\nexport const PEEK_COMPLETION_BONUSES_DEFAULT_LIMIT = 100;\nexport const PEEK_COMPLETION_BONUSES_MAX_LIMIT = 500;\nexport const PEEK_BONUS_COMPLETIONS_DEFAULT_LIMIT = 100;\nexport const PEEK_BONUS_COMPLETIONS_MAX_LIMIT = 500;\nexport const PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS = 24;\n\nexport type ListCampaignsOptions = {\n  sql?: Sql;\n  limit?: number;\n};\n\nexport type ListChallengesOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekChallengeFilters>;\n};\n\nexport type ListChallengeAssignmentsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekChallengeAssignmentFilters>;\n};\n\nexport type ListProgressEventsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekProgressEventFilters>;\n};\n\nexport type ListCompletionBonusesOptions = {\n  sql?: Sql;\n  limit?: number;\n};\n\nexport type ListBonusCompletionsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekBonusCompletionFilters>;\n};\n\nexport type ChallengesOverviewOptions = {\n  sql?: Sql;\n  now?: Date;\n  windowHours?: number;\n};\n\nfunction clampLimit(\n  raw: number | undefined,\n  fallback: number,\n  max: number,\n): number {\n  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n  const floored = Math.floor(raw);\n  if (floored <= 0) return 1;\n  return Math.min(max, floored);\n}\n\nfunction trimOrNull(value: string | null | undefined): string | null {\n  if (typeof value !== \"string\") return null;\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nfunction readInt(value: number | string | null | undefined): number {\n  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n  if (typeof value === \"string\") {\n    const parsed = Number.parseInt(value, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\nfunction parseBoolFilter(value: string | null): boolean | null {\n  if (value === null) return null;\n  if (value === \"true\") return true;\n  if (value === \"false\") return false;\n  return null;\n}\n\nexport async function listCampaigns(\n  options: ListCampaignsOptions = {},\n): Promise<ReadonlyArray<PeekCampaignRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_CAMPAIGNS_DEFAULT_LIMIT,\n    PEEK_CAMPAIGNS_MAX_LIMIT,\n  );\n\n  const rows = await sql<\n    Array<{\n      id: string;\n      name: string;\n      campaignType: string;\n      startsAt: string | null;\n      endsAt: string | null;\n      isActive: boolean;\n      createdAt: string;\n      challengeCount: number | string;\n      activeAssignmentCount: number | string;\n    }>\n  >`\n    select\n      c.id::text as \"id\",\n      c.name as \"name\",\n      c.campaign_type as \"campaignType\",\n      c.starts_at::text as \"startsAt\",\n      c.ends_at::text as \"endsAt\",\n      c.is_active as \"isActive\",\n      c.created_at::text as \"createdAt\",\n      coalesce(ch_counts.challenge_count, 0)::int as \"challengeCount\",\n      coalesce(asg_counts.active_assignment_count, 0)::int as \"activeAssignmentCount\"\n    from campaigns c\n    left join (\n      select campaign_id, count(*) as challenge_count\n      from challenges\n      group by campaign_id\n    ) ch_counts on ch_counts.campaign_id = c.id\n    left join (\n      select ch.campaign_id, count(*) as active_assignment_count\n      from challenge_assignments ca\n      join challenges ch on ch.id = ca.challenge_id\n      where ca.status = 'active'\n      group by ch.campaign_id\n    ) asg_counts on asg_counts.campaign_id = c.id\n    order by c.is_active desc, c.created_at desc, c.id desc\n    limit ${limit}\n  `;\n\n  return rows.map((row) => ({\n    id: row.id,\n    name: row.name,\n    campaignType: row.campaignType,\n    startsAt: row.startsAt,\n    endsAt: row.endsAt,\n    isActive: row.isActive,\n    createdAt: row.createdAt,\n    challengeCount: readInt(row.challengeCount),\n    activeAssignmentCount: readInt(row.activeAssignmentCount),\n  }));\n}\n\nexport async function listChallenges(\n  options: ListChallengesOptions = {},\n): Promise<ReadonlyArray<PeekChallengeRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_CHALLENGES_DEFAULT_LIMIT,\n    PEEK_CHALLENGES_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const campaignId = trimOrNull(filters.campaignId ?? null);\n  const isActive = parseBoolFilter(trimOrNull(filters.isActive ?? null));\n\n  return sql<Array<PeekChallengeRow>>`\n    select\n      ch.id::text as \"id\",\n      ch.campaign_id::text as \"campaignId\",\n      c.name as \"campaignName\",\n      c.campaign_type as \"campaignType\",\n      ch.title as \"title\",\n      ch.description as \"description\",\n      ch.action as \"action\",\n      ch.scope as \"scope\",\n      ch.condition as \"condition\",\n      ch.threshold as \"threshold\",\n      ch.reward_type as \"rewardType\",\n      ch.reward_amount as \"rewardAmount\",\n      ch.prerequisite_id::text as \"prerequisiteId\",\n      ch.sort_order as \"sortOrder\",\n      ch.is_active as \"isActive\",\n      ch.created_at::text as \"createdAt\"\n    from challenges ch\n    left join campaigns c on c.id = ch.campaign_id\n    where\n      (${campaignId === null} or ch.campaign_id::text = ${campaignId ?? \"\"})\n      and (${isActive === null} or ch.is_active = ${isActive ?? false})\n    order by ch.campaign_id asc, ch.sort_order asc, ch.id asc\n    limit ${limit}\n  `;\n}\n\nexport async function listChallengeAssignments(\n  options: ListChallengeAssignmentsOptions = {},\n): Promise<ReadonlyArray<PeekChallengeAssignmentRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT,\n    PEEK_CHALLENGE_ASSIGNMENTS_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const userId = trimOrNull(filters.userId ?? null);\n  const challengeId = trimOrNull(filters.challengeId ?? null);\n  const campaignId = trimOrNull(filters.campaignId ?? null);\n  const periodKey = trimOrNull(filters.periodKey ?? null);\n  const status = trimOrNull(filters.status ?? null);\n  const assignedFrom = trimOrNull(filters.assignedFrom ?? null);\n  const assignedTo = trimOrNull(filters.assignedTo ?? null);\n\n  return sql<Array<PeekChallengeAssignmentRow>>`\n    select\n      ca.id::text as \"id\",\n      ca.user_id as \"userId\",\n      prof.username as \"username\",\n      ca.challenge_id::text as \"challengeId\",\n      ch.title as \"challengeTitle\",\n      ch.campaign_id::text as \"campaignId\",\n      c.name as \"campaignName\",\n      ca.period_key as \"periodKey\",\n      ca.status as \"status\",\n      ca.progress as \"progress\",\n      ca.target as \"target\",\n      ca.assigned_at::text as \"assignedAt\",\n      ca.expires_at::text as \"expiresAt\",\n      ca.completed_at::text as \"completedAt\"\n    from challenge_assignments ca\n    left join challenges ch on ch.id = ca.challenge_id\n    left join campaigns c on c.id = ch.campaign_id\n    left join player_profiles prof on prof.user_id = ca.user_id\n    where\n      (${userId === null} or ca.user_id = ${userId ?? \"\"})\n      and (${challengeId === null} or ca.challenge_id::text = ${challengeId ?? \"\"})\n      and (${campaignId === null} or ch.campaign_id::text = ${campaignId ?? \"\"})\n      and (${periodKey === null} or ca.period_key = ${periodKey ?? \"\"})\n      and (${status === null} or ca.status = ${status ?? \"\"})\n      and (${assignedFrom === null} or ca.assigned_at >= ${assignedFrom ?? \"\"}::timestamptz)\n      and (${assignedTo === null} or ca.assigned_at < ${assignedTo ?? \"\"}::timestamptz)\n    order by ca.assigned_at desc, ca.id desc\n    limit ${limit}\n  `;\n}\n\nexport async function listProgressEvents(\n  options: ListProgressEventsOptions = {},\n): Promise<ReadonlyArray<PeekProgressEventRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_PROGRESS_EVENTS_DEFAULT_LIMIT,\n    PEEK_PROGRESS_EVENTS_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const assignmentId = trimOrNull(filters.assignmentId ?? null);\n  const challengeId = trimOrNull(filters.challengeId ?? null);\n  const userId = trimOrNull(filters.userId ?? null);\n  const roundId = trimOrNull(filters.roundId ?? null);\n  const createdFrom = trimOrNull(filters.createdFrom ?? null);\n  const createdTo = trimOrNull(filters.createdTo ?? null);\n\n  return sql<Array<PeekProgressEventRow>>`\n    select\n      pe.id::text as \"id\",\n      pe.assignment_id::text as \"assignmentId\",\n      ca.challenge_id::text as \"challengeId\",\n      ch.title as \"challengeTitle\",\n      pe.round_id as \"roundId\",\n      pe.user_id as \"userId\",\n      prof.username as \"username\",\n      pe.progress_delta as \"progressDelta\",\n      pe.created_at::text as \"createdAt\"\n    from progress_events pe\n    left join challenge_assignments ca on ca.id = pe.assignment_id\n    left join challenges ch on ch.id = ca.challenge_id\n    left join player_profiles prof on prof.user_id = pe.user_id\n    where\n      (${assignmentId === null} or pe.assignment_id::text = ${assignmentId ?? \"\"})\n      and (${challengeId === null} or ca.challenge_id::text = ${challengeId ?? \"\"})\n      and (${userId === null} or pe.user_id = ${userId ?? \"\"})\n      and (${roundId === null} or pe.round_id = ${roundId ?? \"\"})\n      and (${createdFrom === null} or pe.created_at >= ${createdFrom ?? \"\"}::timestamptz)\n      and (${createdTo === null} or pe.created_at < ${createdTo ?? \"\"}::timestamptz)\n    order by pe.created_at desc, pe.id desc\n    limit ${limit}\n  `;\n}\n\nexport async function listCompletionBonuses(\n  options: ListCompletionBonusesOptions = {},\n): Promise<ReadonlyArray<PeekCompletionBonusRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_COMPLETION_BONUSES_DEFAULT_LIMIT,\n    PEEK_COMPLETION_BONUSES_MAX_LIMIT,\n  );\n\n  const rows = await sql<\n    Array<{\n      id: string;\n      campaignId: string;\n      campaignName: string | null;\n      campaignType: string | null;\n      title: string;\n      description: string | null;\n      requiredCount: number;\n      rewardType: string;\n      rewardAmount: number | null;\n      isActive: boolean;\n      createdAt: string;\n      completionCount: number | string;\n    }>\n  >`\n    select\n      cb.id::text as \"id\",\n      cb.campaign_id::text as \"campaignId\",\n      c.name as \"campaignName\",\n      c.campaign_type as \"campaignType\",\n      cb.title as \"title\",\n      cb.description as \"description\",\n      cb.required_count as \"requiredCount\",\n      cb.reward_type as \"rewardType\",\n      cb.reward_amount as \"rewardAmount\",\n      cb.is_active as \"isActive\",\n      cb.created_at::text as \"createdAt\",\n      coalesce(bc_counts.completion_count, 0)::int as \"completionCount\"\n    from completion_bonuses cb\n    left join campaigns c on c.id = cb.campaign_id\n    left join (\n      select bonus_id, count(*) as completion_count\n      from bonus_completions\n      group by bonus_id\n    ) bc_counts on bc_counts.bonus_id = cb.id\n    order by cb.is_active desc, cb.created_at desc, cb.id desc\n    limit ${limit}\n  `;\n\n  return rows.map((row) => ({\n    id: row.id,\n    campaignId: row.campaignId,\n    campaignName: row.campaignName,\n    campaignType: row.campaignType,\n    title: row.title,\n    description: row.description,\n    requiredCount: readInt(row.requiredCount),\n    rewardType: row.rewardType,\n    rewardAmount:\n      row.rewardAmount === null || row.rewardAmount === undefined\n        ? null\n        : readInt(row.rewardAmount),\n    isActive: row.isActive,\n    createdAt: row.createdAt,\n    completionCount: readInt(row.completionCount),\n  }));\n}\n\nexport async function listBonusCompletions(\n  options: ListBonusCompletionsOptions = {},\n): Promise<ReadonlyArray<PeekBonusCompletionRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_BONUS_COMPLETIONS_DEFAULT_LIMIT,\n    PEEK_BONUS_COMPLETIONS_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const userId = trimOrNull(filters.userId ?? null);\n  const bonusId = trimOrNull(filters.bonusId ?? null);\n  const campaignId = trimOrNull(filters.campaignId ?? null);\n  const periodKey = trimOrNull(filters.periodKey ?? null);\n  const completedFrom = trimOrNull(filters.completedFrom ?? null);\n  const completedTo = trimOrNull(filters.completedTo ?? null);\n\n  return sql<Array<PeekBonusCompletionRow>>`\n    select\n      bc.id::text as \"id\",\n      bc.user_id as \"userId\",\n      prof.username as \"username\",\n      bc.bonus_id::text as \"bonusId\",\n      cb.title as \"bonusTitle\",\n      cb.campaign_id::text as \"campaignId\",\n      c.name as \"campaignName\",\n      bc.period_key as \"periodKey\",\n      bc.completed_at::text as \"completedAt\"\n    from bonus_completions bc\n    left join completion_bonuses cb on cb.id = bc.bonus_id\n    left join campaigns c on c.id = cb.campaign_id\n    left join player_profiles prof on prof.user_id = bc.user_id\n    where\n      (${userId === null} or bc.user_id = ${userId ?? \"\"})\n      and (${bonusId === null} or bc.bonus_id::text = ${bonusId ?? \"\"})\n      and (${campaignId === null} or cb.campaign_id::text = ${campaignId ?? \"\"})\n      and (${periodKey === null} or bc.period_key = ${periodKey ?? \"\"})\n      and (${completedFrom === null} or bc.completed_at >= ${completedFrom ?? \"\"}::timestamptz)\n      and (${completedTo === null} or bc.completed_at < ${completedTo ?? \"\"}::timestamptz)\n    order by bc.completed_at desc, bc.id desc\n    limit ${limit}\n  `;\n}\n\ntype MetricBlueprint = {\n  id: PeekChallengesOverviewMetricId;\n  label: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  definition: string;\n  drilldownHref: string | null;\n};\n\nfunction buildMetric(\n  blueprint: MetricBlueprint,\n  raw: number,\n  display: string,\n  asOf: string,\n): PeekMetric {\n  return {\n    id: blueprint.id,\n    label: blueprint.label,\n    value: raw,\n    valueDisplay: display,\n    unit: blueprint.unit,\n    source: blueprint.source,\n    windowLabel: blueprint.windowLabel,\n    asOf,\n    definition: blueprint.definition,\n    freshness: \"live\",\n    drilldownHref: blueprint.drilldownHref,\n  };\n}\n\nexport async function getChallengesOverview(\n  options: ChallengesOverviewOptions = {},\n): Promise<PeekChallengesOverview> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n  const windowHours = clampLimit(\n    options.windowHours,\n    PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS,\n    24 * 30,\n  );\n  const since = new Date(now.getTime() - windowHours * 60 * 60 * 1000);\n  const sinceIso = since.toISOString();\n\n  const [\n    activeCampaignsRows,\n    activeChallengesRows,\n    activeAssignmentsRows,\n    completedAssignmentsRows,\n    bonusCompletionsRows,\n  ] = await Promise.all([\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from campaigns\n      where is_active = true\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from challenges\n      where is_active = true\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from challenge_assignments\n      where status = 'active'\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from challenge_assignments\n      where status = 'completed'\n        and completed_at is not null\n        and completed_at >= ${sinceIso}::timestamptz\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from bonus_completions\n      where completed_at >= ${sinceIso}::timestamptz\n    `,\n  ]);\n\n  const activeCampaigns = readInt(activeCampaignsRows[0]?.value ?? 0);\n  const activeChallenges = readInt(activeChallengesRows[0]?.value ?? 0);\n  const activeAssignments = readInt(activeAssignmentsRows[0]?.value ?? 0);\n  const completedAssignments = readInt(completedAssignmentsRows[0]?.value ?? 0);\n  const bonusCompletions = readInt(bonusCompletionsRows[0]?.value ?? 0);\n\n  const windowLabel = `Last ${windowHours}h`;\n\n  const blueprints: ReadonlyArray<{\n    blueprint: MetricBlueprint;\n    raw: number;\n    display: string;\n  }> = [\n    {\n      blueprint: {\n        id: \"challenges.active_campaigns\",\n        label: \"Active campaigns\",\n        unit: \"campaigns\",\n        source: \"campaigns\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of campaigns rows with is_active = true — the daily/weekly/onboarding/dogpile containers currently published.\",\n        drilldownHref: \"/economy/challenges#campaigns\",\n      },\n      raw: activeCampaigns,\n      display: formatCount(activeCampaigns),\n    },\n    {\n      blueprint: {\n        id: \"challenges.active_challenges\",\n        label: \"Active challenges\",\n        unit: \"challenges\",\n        source: \"challenges\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of challenges rows with is_active = true — challenge templates currently eligible for assignment.\",\n        drilldownHref: \"/economy/challenges#challenges\",\n      },\n      raw: activeChallenges,\n      display: formatCount(activeChallenges),\n    },\n    {\n      blueprint: {\n        id: \"challenges.active_assignments\",\n        label: \"Active assignments\",\n        unit: \"assignments\",\n        source: \"challenge_assignments\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of challenge_assignments rows with status = 'active' — per-player assignments still in progress.\",\n        drilldownHref: \"/economy/challenges?status=active#assignments\",\n      },\n      raw: activeAssignments,\n      display: formatCount(activeAssignments),\n    },\n    {\n      blueprint: {\n        id: \"challenges.completed_assignments_window\",\n        label: \"Completed assignments\",\n        unit: \"assignments\",\n        source: \"challenge_assignments\",\n        windowLabel,\n        definition: `Count of challenge_assignments rows with status = 'completed' and completed_at within the last ${windowHours} hours.`,\n        drilldownHref: \"/economy/challenges?status=completed#assignments\",\n      },\n      raw: completedAssignments,\n      display: formatCount(completedAssignments),\n    },\n    {\n      blueprint: {\n        id: \"challenges.bonus_completions_window\",\n        label: \"Bonus completions\",\n        unit: \"completions\",\n        source: \"bonus_completions\",\n        windowLabel,\n        definition: `Count of bonus_completions rows with completed_at within the last ${windowHours} hours — meta-quest payouts (e.g. complete-all-dailies bonus crate) recently awarded.`,\n        drilldownHref: \"/economy/challenges#bonus-completions\",\n      },\n      raw: bonusCompletions,\n      display: formatCount(bonusCompletions),\n    },\n  ];\n\n  return {\n    generatedAt,\n    metrics: blueprints.map(({ blueprint, raw, display }) =>\n      buildMetric(blueprint, raw, display, generatedAt),\n    ),\n  };\n}\n","numLines":630,"startLine":1,"totalLines":630}}}
