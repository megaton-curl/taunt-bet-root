{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NpsdAsxQscueYezc7PUUH4","type":"tool_result","content":"1\t// Completion bonuses table for /economy/challenges (FR-9).\n2\t//\n3\t// Read-only dense table over `PeekCompletionBonusRow`. Each row is a\n4\t// meta-quest definition (e.g. \"complete all daily challenges → bonus crate\")\n5\t// annotated with the per-bonus completion count so an operator can see which\n6\t// bonuses are actually paying out. Definition editing is out of scope here\n7\t// (FR-9 / FR-14).\n8\timport type { CSSProperties } from \"react\";\n9\timport type {\n10\t  PeekCompletionBonusRow,\n11\t  PeekStatusTone,\n12\t} from \"../lib/types/peek\";\n13\timport { StatusChip } from \"./status-chip\";\n14\t\n15\texport type CompletionBonusesTableProps = {\n16\t  rows: ReadonlyArray<PeekCompletionBonusRow>;\n17\t  error?: string | null;\n18\t};\n19\t\n20\texport function CompletionBonusesTable({\n21\t  rows,\n22\t  error = null,\n23\t}: CompletionBonusesTableProps) {\n24\t  if (error) {\n25\t    return (\n26\t      <div role=\"alert\" style={errorStyle}>\n27\t        Completion bonuses unavailable: {error}\n28\t      </div>\n29\t    );\n30\t  }\n31\t\n32\t  if (rows.length === 0) {\n33\t    return (\n34\t      <div role=\"status\" style={emptyStyle}>\n35\t        <p style={emptyTitleStyle}>No completion_bonuses rows.</p>\n36\t        <p style={emptyBodyStyle}>\n37\t          The `completion_bonuses` table has not been seeded yet, so no\n38\t          meta-quest payouts are configured.\n39\t        </p>\n40\t      </div>\n41\t    );\n42\t  }\n43\t\n44\t  return (\n45\t    <div style={wrapperStyle}>\n46\t      <table style={tableStyle}>\n47\t        <thead>\n48\t          <tr style={headerRowStyle}>\n49\t            <th style={headerCellStyle(\"left\")}>Title</th>\n50\t            <th style={headerCellStyle(\"left\")}>Campaign</th>\n51\t            <th style={headerCellStyle(\"left\")}>State</th>\n52\t            <th style={headerCellStyle(\"right\")}>Required</th>\n53\t            <th style={headerCellStyle(\"left\")}>Reward</th>\n54\t            <th style={headerCellStyle(\"right\")}>Completions</th>\n55\t            <th style={headerCellStyle(\"left\")}>Created</th>\n56\t            <th style={headerCellStyle(\"left\")}>ID</th>\n57\t          </tr>\n58\t        </thead>\n59\t        <tbody>\n60\t          {rows.map((row) => (\n61\t            <tr key={row.id} style={bodyRowStyle}>\n62\t              <td style={bodyCellStyle(\"left\")}>\n63\t                <div>{row.title}</div>\n64\t                {row.description ? (\n65\t                  <div style={subValueStyle}>{row.description}</div>\n66\t                ) : null}\n67\t              </td>\n68\t              <td style={bodyCellStyle(\"left\")}>\n69\t                <div>{row.campaignName ?? \"—\"}</div>\n70\t                {row.campaignType ? (\n71\t                  <div style={subValueStyle}>{row.campaignType}</div>\n72\t                ) : null}\n73\t              </td>\n74\t              <td style={bodyCellStyle(\"left\")}>\n75\t                <StatusChip\n76\t                  label={row.isActive ? \"active\" : \"inactive\"}\n77\t                  tone={row.isActive ? \"positive\" : \"neutral\"}\n78\t                />\n79\t              </td>\n80\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n81\t                {row.requiredCount.toLocaleString(\"en-US\")}\n82\t              </td>\n83\t              <td style={bodyCellStyle(\"left\")}>\n84\t                <StatusChip\n85\t                  label={row.rewardType}\n86\t                  tone={rewardTypeTone(row.rewardType)}\n87\t                />\n88\t                {row.rewardAmount !== null ? (\n89\t                  <span style={subValueStyle}>\n90\t                    {\" \"}\n91\t                    · {row.rewardAmount.toLocaleString(\"en-US\")}\n92\t                  </span>\n93\t                ) : null}\n94\t              </td>\n95\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n96\t                {row.completionCount.toLocaleString(\"en-US\")}\n97\t              </td>\n98\t              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n99\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n100\t                {row.id}\n101\t              </td>\n102\t            </tr>\n103\t          ))}\n104\t        </tbody>\n105\t      </table>\n106\t    </div>\n107\t  );\n108\t}\n109\t\n110\tfunction rewardTypeTone(value: string): PeekStatusTone {\n111\t  if (value === \"points\") return \"positive\";\n112\t  if (value === \"crate\") return \"warning\";\n113\t  return \"neutral\";\n114\t}\n115\t\n116\tconst wrapperStyle: CSSProperties = {\n117\t  overflowX: \"auto\",\n118\t  border: \"1px solid #1e293b\",\n119\t  borderRadius: \"0.75rem\",\n120\t};\n121\t\n122\tconst tableStyle: CSSProperties = {\n123\t  width: \"100%\",\n124\t  borderCollapse: \"collapse\",\n125\t};\n126\t\n127\tconst headerRowStyle: CSSProperties = {\n128\t  background: \"#111827\",\n129\t  color: \"#94a3b8\",\n130\t};\n131\t\n132\tconst bodyRowStyle: CSSProperties = {\n133\t  borderTop: \"1px solid #1e293b\",\n134\t};\n135\t\n136\tconst subValueStyle: CSSProperties = {\n137\t  color: \"#64748b\",\n138\t  fontSize: \"0.75rem\",\n139\t};\n140\t\n141\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n142\t  return {\n143\t    padding: \"0.75rem\",\n144\t    textAlign: align,\n145\t    fontSize: \"0.875rem\",\n146\t    fontWeight: 600,\n147\t  };\n148\t}\n149\t\n150\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n151\t  return {\n152\t    padding: \"0.75rem\",\n153\t    textAlign: align,\n154\t    fontSize: \"0.875rem\",\n155\t    color: \"#e2e8f0\",\n156\t    verticalAlign: \"top\",\n157\t  };\n158\t}\n159\t\n160\tconst errorStyle: CSSProperties = {\n161\t  margin: 0,\n162\t