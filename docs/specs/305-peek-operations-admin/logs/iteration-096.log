 ?? \"\"}\n57\t          placeholder=\"campaign id\"\n58\t          style={inputStyle}\n59\t        />\n60\t      </label>\n61\t\n62\t      <label style={fieldStyle}>\n63\t        <span>Active?</span>\n64\t        <select\n65\t          name=\"chFilterIsActive\"\n66\t          defaultValue={filters.isActive ?? \"\"}\n67\t          style={inputStyle}\n68\t        >\n69\t          <option value=\"\">Any</option>\n70\t          {PEEK_CHALLENGE_IS_ACTIVE_VALUES.map((value) => (\n71\t            <option key={value} value={value}>\n72\t              {value}\n73\t            </option>\n74\t          ))}\n75\t        </select>\n76\t      </label>\n77\t\n78\t      <button type=\"submit\" style={buttonStyle}>\n79\t        Apply filters\n80\t      </button>\n81\t    </form>\n82\t  );\n83\t}\n84\t\n85\texport function ChallengeAssignmentsFilterBar({\n86\t  filters,\n87\t  action = \"/economy/challenges\",\n88\t}: ChallengeAssignmentsFilterBarProps) {\n89\t  return (\n90\t    <form\n91\t      action={action}\n92\t      method=\"get\"\n93\t      role=\"search\"\n94\t      aria-label=\"Filter challenge assignments\"\n95\t      style={formStyle}\n96\t    >\n97\t      <label style={fieldStyle}>\n98\t        <span>User ID</span>\n99\t        <input\n100\t          name=\"asgFilterUserId\"\n101\t          type=\"text\"\n102\t          defaultValue={filters.userId ?? \"\"}\n103\t          placeholder=\"user_id\"\n104\t          style={inputStyle}\n105\t        />\n106\t      </label>\n107\t\n108\t      <label style={fieldStyle}>\n109\t        <span>Challenge ID</span>\n110\t        <input\n111\t          name=\"asgFilterChallengeId\"\n112\t          type=\"text\"\n113\t          defaultValue={filters.challengeId ?? \"\"}\n114\t          placeholder=\"challenge id\"\n115\t          style={inputStyle}\n116\t        />\n117\t      </label>\n118\t\n119\t      <label style={fieldStyle}>\n120\t        <span>Campaign ID</span>\n121\t        <input\n122\t          name=\"asgFilterCampaignId\"\