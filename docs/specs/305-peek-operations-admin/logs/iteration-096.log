tionBonusesTable\", () => {\n  it(\"populated: renders the operator columns and the type/state/reward chips\", () => {\n    render(\n      <CompletionBonusesTable rows={[ROW_ACTIVE, ROW_INACTIVE_POINTS]} />,\n    );\n\n    for (const header of [\n      \"Title\",\n      \"Campaign\",\n      \"State\",\n      \"Required\",\n      \"Reward\",\n      \"Completions\",\n      \"Created\",\n      \"ID\",\n    ]) {\n      expect(screen.getByText(header)).toBeInTheDocument();\n    }\n\n    expect(screen.getByText(\"Complete all dailies\")).toBeInTheDocument();\n    expect(screen.getByText(\"Win 10 rounds\")).toBeInTheDocument();\n    expect(screen.getByText(\"active\")).toBeInTheDocument();\n    expect(screen.getByText(\"inactive\")).toBeInTheDocument();\n    expect(screen.getByText(\"crate\")).toBeInTheDocument();\n    expect(screen.getByText(\"points\")).toBeInTheDocument();\n  });\n\n  it(\"populated: reward amount renders the ' · 500' suffix when present, omits it when null\", () => {\n    render(\n      <CompletionBonusesTable rows={[ROW_ACTIVE, ROW_INACTIVE_POINTS]} />,\n    );\n\n    expect(screen.getByText(/· 500/)).toBeInTheDocument();\n    // ROW_ACTIVE has rewardAmount: null → no `· <number>` suffix on its\n    // crate chip. The numeric \"500\" should appear exactly once across the\n    // rendered output (from ROW_INACTIVE_POINTS).\n    expect(screen.queryAllByText(/^500$/)).toHaveLength(0);\n    expect(screen.queryAllByText(/· null/)).toHaveLength(0);\n  });\n\n  it(\"populated: counts use thousands separators\", () => {\n    render(\n      <CompletionBonusesTable rows={[ROW_ACTIVE, ROW_INACTIVE_POINTS]} />,\n    );\n\n    expect(screen.getByText(\"1,234\")).toBeInTheDocument();\n    // The \"0\" completion count from ROW_INACTIVE_POINTS renders as plain \"0\".\n    expect(screen.getByText(\"0\")).toBeInTheDocument();\n  });\n\n  it(\"populated: description sub-row renders only when present\", () => {\n    render(\n      <CompletionBonusesTable rows={[ROW_ACTIVE, ROW_INACTIVE_POINTS]} />,\n    );\n\n    expect(\n      screen.getByText(\n        \"Complete every daily challenge to receive a bonus crate\",\n      ),\n    ).toBeInTheDocument();\n  });\n\n  it(\"populated: null campaignName renders '—' instead of breaking the cell\", () => {\n    render(<CompletionBonusesTable rows={[ROW_INACTIVE_POINTS]} />);\n\n    expect(screen.getByText(\"—\")).toBeInTheDocument();\n  });\n\n  it(\"read-only: no edit affordances rendered\", () => {\n    render(<CompletionBonusesTable rows={[ROW_ACTIVE]} />);\n\n    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n    expect(screen.queryByRole(\"textbox\")).toBeNull();\n    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n  });\n\n  it(\"empty: renders the operator status block referencing the source table\", () => {\n    render(<CompletionBonusesTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"No completion_bonuses rows.\");\n    expect(status).toHaveTextContent(\"completion_bonuses\");\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n    render(\n      <CompletionBonusesTable rows={[ROW_ACTIVE]} error=\"connection refused\" />,\n    );\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Completion bonuses unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_017oUH5mJXcjEP82zfgPzbuu","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01RruTWx5BBePG2rw4Ki2tKo","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/__tests__/bonus-completions-table.test.tsx","content":"// Component tests for the FR-9 bonus completions table.\n//\n// bonus_completions is the per-player per-period meta-quest payout ledger.\n// The user cell drills down to /users/[userId]; the bonus + campaign columns\n// surface the migration-011 names; and the table is read-only by spec.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { BonusCompletionsTable } from \"../bonus-completions-table\";\nimport type { PeekBonusCompletionRow } from \"../../lib/types/peek\";\n\nconst ROW_FULL: PeekBonusCompletionRow = {\n  id: \"1\",\n  userId: \"user-1\",\n  username: \"alice\",\n  bonusId: \"bonus-7\",\n  bonusTitle: \"Complete all dailies\",\n  campaignId: \"campaign-3\",\n  campaignName: \"Daily challenges\",\n  periodKey: \"2026-04-26\",\n  completedAt: \"2026-04-26T11:00:00.000Z\",\n};\n\nconst ROW_NULL_USERNAME: PeekBonusCompletionRow = {\n  id: \"2\",\n  userId: \"user-2\",\n  username: null,\n  bonusId: \"bonus-9\",\n  bonusTitle: null,\n  campaignId: null,\n  campaignName: null,\n  periodKey: \"2026-04-25\",\n  completedAt: \"2026-04-25T11:00:00.000Z\",\n};\n\ndescribe(\"BonusCompletionsTable\", () => {\n  it(\"populated: renders the operator columns\", () => {\n    render(<BonusCompletionsTable rows={[ROW_FULL]} />);\n\n    for (const header of [\n      \"Completed\",\n      \"User\",\n      \"Bonus\",\n      \"Campaign\",\n      \"Period\",\n      \"ID\",\n    ]) {\n      expect(screen.getByText(header)).toBeInTheDocument();\n    }\n  });\n\n  it(\"populated: user cell prefers username and drills down to /users/[userId]\", () => {\n    render(<BonusCompletionsTable rows={[ROW_FULL]} />);\n\n    const link = screen.getByRole(\"link\", { name: \"alice\" });\n    expect(link).toHaveAttribute(\"href\", \"/users/user-1\");\n  });\n\n  it(\"populated: user cell falls back to userId when username is null\", () => {\n    render(<BonusCompletionsTable rows={[ROW_NULL_USERNAME]} />);\n\n    const link = screen.getByRole(\"link\", { name: \"user-2\" });\n    expect(link).toHaveAttribute(\"href\", \"/users/user-2\");\n  });\n\n  it(\"populated: null bonusTitle/campaignName render '—' instead of breaking the row\", () => {\n    render(<BonusCompletionsTable rows={[ROW_NULL_USERNAME]} />);\n\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(2);\n  });\n\n  it(\"read-only: no edit affordances rendered (append-only ledger)\", () => {\n    render(<BonusCompletionsTable rows={[ROW_FULL]} />);\n\n    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n    expect(screen.queryByRole(\"textbox\")).toBeNull();\n    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n  });\n\n  it(\"empty (filtered): renders the filter-aware operator status block\", () => {\n    render(<BonusCompletionsTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\n      \"No bonus_completions rows match these filters.\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n    render(<BonusCompletionsTable rows={[ROW_FULL]} error=\"db down\" />);\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Bonus completions unavailable: db down\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2225,"cache_read_input_tokens":160373,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2225},"output_tokens":61,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"7378b447-bdd0-410a-9e39-562cf2836131","uuid":"f6a13a5f-9b01-40d1-8b0a-bdd854f48ba5"}
