{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01Dz9PoSU1tD6qC4K2PfB4Px","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015dUWVMZJ5Y1gFuKf43MHWY","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/__tests__/economy-challenges-filter-bar.test.tsx","content":"// Component tests for the FR-9 /economy/challenges filter bars.\n//\n// Four prefixed forms (`chFilter*`, `asgFilter*`, `progFilter*`, `bcFilter*`)\n// share the same /economy/challenges page so each table can be filtered\n// independently while the URL stays shareable. These tests verify:\n//   - the form posts to /economy/challenges via GET\n//   - each input uses its prefixed name (no collision across forms)\n//   - the status + isActive selects expose every allowlisted enum value\n//   - populated filters pre-fill every field\n//   - ISO timestamps in date filters are truncated to YYYY-MM-DD\n//   - the custom action prop overrides the default form target\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport {\n  BonusCompletionsFilterBar,\n  ChallengeAssignmentsFilterBar,\n  ChallengesFilterBar,\n  ProgressEventsFilterBar,\n} from \"../economy-challenges-filter-bar\";\nimport {\n  PEEK_CHALLENGE_ASSIGNMENT_STATUSES,\n  PEEK_CHALLENGE_IS_ACTIVE_VALUES,\n} from \"../../lib/economy-challenges-search-params\";\nimport type {\n  PeekBonusCompletionFilters,\n  PeekChallengeAssignmentFilters,\n  PeekChallengeFilters,\n  PeekProgressEventFilters,\n} from \"../../lib/types/peek\";\n\nconst EMPTY_CH_FILTERS: PeekChallengeFilters = {\n  campaignId: null,\n  isActive: null,\n};\n\nconst POPULATED_CH_FILTERS: PeekChallengeFilters = {\n  campaignId: \"campaign-7\",\n  isActive: \"true\",\n};\n\nconst EMPTY_ASG_FILTERS: PeekChallengeAssignmentFilters = {\n  userId: null,\n  challengeId: null,\n  campaignId: null,\n  periodKey: null,\n  status: null,\n  assignedFrom: null,\n  assignedTo: null,\n};\n\nconst POPULATED_ASG_FILTERS: PeekChallengeAssignmentFilters = {\n  userId: \"user-1\",\n  challengeId: \"challenge-7\",\n  campaignId: \"campaign-3\",\n  periodKey: \"2026-04-26\",\n  status: \"active\",\n  assignedFrom: \"2026-04-01\",\n  assignedTo: \"2026-04-26\",\n};\n\nconst EMPTY_PROG_FILTERS: PeekProgressEventFilters = {\n  assignmentId: null,\n  challengeId: null,\n  userId: null,\n  roundId: null,\n  createdFrom: null,\n  createdTo: null,\n};\n\nconst POPULATED_PROG_FILTERS: PeekProgressEventFilters = {\n  assignmentId: \"asg-1\",\n  challengeId: \"challenge-7\",\n  userId: \"user-9\",\n  roundId: \"round-PDA-x\",\n  createdFrom: \"2026-04-01\",\n  createdTo: \"2026-04-26\",\n};\n\nconst EMPTY_BC_FILTERS: PeekBonusCompletionFilters = {\n  userId: null,\n  bonusId: null,\n  campaignId: null,\n  periodKey: null,\n  completedFrom: null,\n  completedTo: null,\n};\n\nconst POPULATED_BC_FILTERS: PeekBonusCompletionFilters = {\n  userId: \"user-1\",\n  bonusId: \"bonus-9\",\n  campaignId: \"campaign-3\",\n  periodKey: \"2026-04-26\",\n  completedFrom: \"2026-04-01\",\n  completedTo: \"2026-04-26\",\n};\n\ndescribe(\"ChallengesFilterBar\", () => {\n  it(\"empty: form posts to /economy/challenges by default with both inputs blank and 'Any' selected\", () => {\n    render(<ChallengesFilterBar filters={EMPTY_CH_FILTERS} />);\n\n    const form = screen.getByRole(\"search\", { name: \"Filter challenges\" });\n    expect(form).toHaveAttribute(\"action\", \"/economy/challenges\");\n    expect(form).toHaveAttribute(\"method\", \"get\");\n\n    expect(\n      (screen.getByLabelText(\"Campaign ID\") as HTMLInputElement).value,\n    ).toBe(\"\");\n\n    const isActive = screen.getByLabelText(\"Active?\") as HTMLSelectElement;\n    expect(isActive.value).toBe(\"\");\n    const optionValues = Array.from(isActive.options).map((o) => o.value);\n    expect(optionValues).toContain(\"\");\n    for (const value of PEEK_CHALLENGE_IS_ACTIVE_VALUES) {\n      expect(optionValues).toContain(value);\n    }\n  });\n\n  it(\"populated: pre-fills every field including the isActive select\", () => {\n    render(<ChallengesFilterBar filters={POPULATED_CH_FILTERS} />);\n\n    expect(\n      (screen.getByLabelText(\"Campaign ID\") as HTMLInputElement).value,\n    ).toBe(\"campaign-7\");\n    expect(\n      (screen.getByLabelText(\"Active?\") as HTMLSelectElement).value,\n    ).toBe(\"true\");\n  });\n\n  it(\"inputs use the chFilter* prefix so the form can co-exist with the other three\", () => {\n    render(<ChallengesFilterBar filters={EMPTY_CH_FILTERS} />);\n\n    expect(\n      (screen.getByLabelText(\"Campaign ID\") as HTMLInputElement).name,\n    ).toBe(\"chFilterCampaignId\");\n    expect(\n      (screen.getByLabelText(\"Active?\") as HTMLSelectElement).name,\n    ).toBe(\"chFilterIsActive\");\n  });\n\n  it(\"custom action overrides the default form target\", () => {\n    render(\n      <ChallengesFilterBar\n        filters={EMPTY_CH_FILTERS}\n        action=\"/economy/challenges?embed=1\"\n      />,\n    );\n\n    const form = screen.getByRole(\"search\", { name: \"Filter challenges\" });\n    expect(form).toHaveAttribute(\"action\", \"/economy/challenges?embed=1\");\n  });\n});\n\ndescribe(\"ChallengeAssignmentsFilterBar\", () => {\n  it(\"empty: form posts to /economy/challenges with all inputs blank and the status select on 'Any'\", () => {\n    render(\n      <ChallengeAssignmentsFilterBar filters={EMPTY_ASG_FILTERS} />,\n    );\n\n    const form = screen.getByRole(\"search\", {\n      name: \"Filter challenge assignments\",\n    });\n    expect(form).toHaveAttribute(\"action\", \"/economy/challenges\");\n    expect(form).toHaveAttribute(\"method\", \"get\");\n\n    const status = screen.getByLabelText(\"Status\") as HTMLSelectElement;\n    expect(status.value).toBe(\"\");\n    const optionValues = Array.from(status.options).map((o) => o.value);\n    expect(optionValues).toContain(\"\");\n    for (const value of PEEK_CHALLENGE_ASSIGNMENT_STATUSES) {\n      expect(optionValues).toContain(value);\n    }\n  });\n\n  it(\"populated: pre-fills every input including the status select\", () => {\n    render(\n      <ChallengeAssignmentsFilterBar filters={POPULATED_ASG_FILTERS} />,\n    );\n\n    expect(\n      (screen.getByLabelText(\"User ID\") as HTMLInputElement).value,\n    ).toBe(\"user-1\");\n    expect(\n      (screen.getByLabelText(\"Challenge ID\") as HTMLInputElement).value,\n    ).toBe(\"challenge-7\");\n    expect(\n      (screen.getByLabelText(\"Campaign ID\") as HTMLInputElement).value,\n    ).toBe(\"campaign-3\");\n    expect(\n      (screen.getByLabelText(\"Period key\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n    expect(\n      (screen.getByLabelText(\"Status\") as HTMLSelectElement).value,\n    ).toBe(\"active\");\n    expect(\n      (screen.getByLabelText(\"Assigned from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Assigned to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n  });\n\n  it(\"inputs use the asgFilter* prefix so the form can co-exist with the other three\", () => {\n    render(\n      <ChallengeAssignmentsFilterBar filters={EMPTY_ASG_FILTERS} />,\n    );\n\n    expect(\n      (screen.getByLabelText(\"User ID\") as HTMLInputElement).name,\n    ).toBe(\"asgFilterUserId\");\n    expect(\n      (screen.getByLabelText(\"Challenge ID\") as HTMLInputElement).name,\n    ).toBe(\"asgFilterChallengeId\");\n    expect(\n      (screen.getByLabelText(\"Campaign ID\") as HTMLInputElement).name,\n    ).toBe(\"asgFilterCampaignId\");\n    expect(\n      (screen.getByLabelText(\"Period key\") as HTMLInputElement).name,\n    ).toBe(\"asgFilterPeriodKey\");\n    expect(\n      (screen.getByLabelText(\"Status\") as HTMLSelectElement).name,\n    ).toBe(\"asgFilterStatus\");\n    expect(\n      (screen.getByLabelText(\"Assigned from\") as HTMLInputElement).name,\n    ).toBe(\"asgFilterFrom\");\n    expect(\n      (screen.getByLabelText(\"Assigned to\") as HTMLInputElement).name,\n    ).toBe(\"asgFilterTo\");\n  });\n\n  it(\"populated: an ISO timestamp in assignedFrom/assignedTo is truncated to YYYY-MM-DD\", () => {\n    render(\n      <ChallengeAssignmentsFilterBar\n        filters={{\n          ...EMPTY_ASG_FILTERS,\n          assignedFrom: \"2026-04-01T10:00:00.000Z\",\n          assignedTo: \"2026-04-26T23:59:59.999Z\",\n        }}\n      />,\n    );\n\n    expect(\n      (screen.getByLabelText(\"Assigned from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Assigned to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n  });\n\n  it(\"custom action overrides the default form target\", () => {\n    render(\n      <ChallengeAssignmentsFilterBar\n        filters={EMPTY_ASG_FILTERS}\n        action=\"/economy/challenges?embed=1\"\n      />,\n    );\n\n    const form = screen.getByRole(\"search\", {\n      name: \"Filter challenge assignments\",\n    });\n    expect(form).toHaveAttribute(\"action\", \"/economy/challenges?embed=1\");\n  });\n});\n\ndescribe(\"ProgressEventsFilterBar\", () => {\n  it(\"empty: form posts to /economy/challenges with all inputs blank\", () => {\n    render(<ProgressEventsFilterBar filters={EMPTY_PROG_FILTERS} />);\n\n    const form = screen.getByRole(\"search\", {\n      name: \"Filter progress events\",\n    });\n    expect(form).toHaveAttribute(\"action\", \"/economy/challenges\");\n    expect(form).toHaveAttribute(\"method\", \"get\");\n\n    expect(\n      (screen.getByLabelText(\"Assignment ID\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Round ID\") as HTMLInputElement).value,\n    ).toBe(\"\");\n  });\n\n  it(\"populated: pre-fills every input\", () => {\n    render(<ProgressEventsFilterBar filters={POPULATED_PROG_FILTERS} />);\n\n    expect(\n      (screen.getByLabelText(\"Assignment ID\") as HTMLInputE