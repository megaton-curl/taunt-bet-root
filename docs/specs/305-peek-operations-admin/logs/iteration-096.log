T10:00:00.000Z\");\n      expect(metric.freshness).toBe(\"live\");\n      expect(metric.label.length).toBeGreaterThan(0);\n      expect(metric.definition.length).toBeGreaterThan(0);\n      expect(metric.source.length).toBeGreaterThan(0);\n      expect(metric.windowLabel.length).toBeGreaterThan(0);\n      expect(metric.drilldownHref).not.toBeNull();\n    }\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"challenges.active_campaigns\")?.value).toBe(4);\n    expect(byId.get(\"challenges.active_campaigns\")?.valueDisplay).toBe(\"4\");\n    expect(byId.get(\"challenges.active_campaigns\")?.unit).toBe(\"campaigns\");\n    expect(byId.get(\"challenges.active_campaigns\")?.source).toBe(\"campaigns\");\n\n    expect(byId.get(\"challenges.active_challenges\")?.value).toBe(12);\n    expect(byId.get(\"challenges.active_challenges\")?.unit).toBe(\"challenges\");\n    expect(byId.get(\"challenges.active_challenges\")?.source).toBe(\"challenges\");\n\n    expect(byId.get(\"challenges.active_assignments\")?.value).toBe(30);\n    expect(byId.get(\"challenges.active_assignments\")?.unit).toBe(\"assignments\");\n    expect(byId.get(\"challenges.active_assignments\")?.source).toBe(\n      \"challenge_assignments\",\n    );\n\n    expect(byId.get(\"challenges.completed_assignments_window\")?.value).toBe(7);\n    expect(byId.get(\"challenges.completed_assignments_window\")?.unit).toBe(\n      \"assignments\",\n    );\n\n    expect(byId.get(\"challenges.bonus_completions_window\")?.value).toBe(5);\n    expect(byId.get(\"challenges.bonus_completions_window\")?.unit).toBe(\n      \"completions\",\n    );\n    expect(byId.get(\"challenges.bonus_completions_window\")?.source).toBe(\n      \"bonus_completions\",\n    );\n  });\n\n  it(\"populated: numeric counts coerce through readInt (string → number)\", async () => {\n    const mock = createSqlMock([\n      [{ value: \"4\" }],\n      [{ value: \"12\" }],\n      [{ value: \"30\" }],\n      [{ value: \"