{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017LPn3j6SbEzmeTd4WWGdwj","type":"tool_result","content":"1\t// URL-addressable filter params for /economy/challenges (FR-9).\n2\t//\n3\t// Four prefixed param groups co-exist on the same page so each table can be\n4\t// filtered independently while the URL stays shareable:\n5\t//\n6\t//   challenges      — `chFilter*`     (campaign_id, is_active)\n7\t//   assignments     — `asgFilter*`    (user, challenge, campaign, period,\n8\t//                                       status, assigned date range)\n9\t//   progress events — `progFilter*`   (assignment, challenge, user, round,\n10\t//                                       created date range)\n11\t//   bonus completions — `bcFilter*`   (user, bonus, campaign, period,\n12\t//                                       completed date range)\n13\t//\n14\t// Empty / whitespace-only values normalise to `null`. Unknown enum values for\n15\t// `status` and `isActive` normalise to `null` so a stale URL chip cannot lie\n16\t// about the table's filter state.\n17\t\n18\timport type {\n19\t  PeekBonusCompletionFilters,\n20\t  PeekChallengeAssignmentFilters,\n21\t  PeekChallengeFilters,\n22\t  PeekProgressEventFilters,\n23\t} from \"./types/peek\";\n24\t\n25\texport const PEEK_CHALLENGE_ASSIGNMENT_STATUSES: ReadonlyArray<string> = [\n26\t  \"active\",\n27\t  \"completed\",\n28\t  \"expired\",\n29\t];\n30\t\n31\texport const PEEK_CHALLENGE_IS_ACTIVE_VALUES: ReadonlyArray<string> = [\n32\t  \"true\",\n33\t  \"false\",\n34\t];\n35\t\n36\tfunction readSingleValue(value: string | string[] | undefined): string {\n37\t  return Array.isArray(value) ? value[0] ?? \"\" : value ?? \"\";\n38\t}\n39\t\n40\tfunction trimOrNull(value: string): string | null {\n41\t  const trimmed = value.trim();\n42\t  return trimmed.length > 0 ? trimmed : null;\n43\t}\n44\t\n45\tfunction allowlistOrNull(\n46\t  value: string | null,\n47\t  allowed: ReadonlyArray<string>,\n48\t): string | null {\n49\t  if (!value) return null;\n50\t  return allowed.includes(value) ? value : null;\n51\t}\n52\t\n53\texport function normalizeChallengeFiltersFromSearchParams(\n54\t  input: Record<string, string | string[] | undefined>,\n55\t): PeekChallengeFilters {\n56\t  const isActive = trimOrNull(readSingleValue(input.chFilterIsActive));\n57\t  return {\n58\t    campaignId: trimOrNull(readSingleValue(input.chFilterCampaignId)),\n59\t    isActive: allowlistOrNull(isActive, PEEK_CHALLENGE_IS_ACTIVE_VALUES),\n60\t  };\n61\t}\n62\t\n63\texport function normalizeChallengeAssignmentFiltersFromSearchParams(\n64\t  input: Record<string, string | string[] | undefined>,\n65\t): PeekChallengeAssignmentFilters {\n66\t  const status = trimOrNull(readSingleValue(input.asgFilterStatus));\n67\t  return {\n68\t    userId: trimOrNull(readSingleValue(input.asgFilterUserId)),\n69\t    challengeId: trimOrNull(readSingleValue(input.asgFilterChallengeId)),\n70\t    campaignId: trimOrNull(readSingleValue(input.asgFilterCampaignId)),\n71\t    periodKey: trimOrNull(readSingleValue(input.asgFilterPeriodKey)),\n72\t    status: allowlistOrNull(status, PEEK_CHALLENGE_ASSIGNMENT_STATUSES),\n73\t    assignedFrom: trimOrNull(readSingleValue(input.asgFilterFrom)),\n74\t    assignedTo: trimOrNull(readSingleValue(input.asgFilterTo)),\n75\t  };\n76\t}\n77\t\n78\texport function normalizeProgressEventFiltersFromSearchParams(\n79\t  input: Record<string, string | string[] | undefined>,\n80\t): PeekProgressEventFilters {\n81\t  return {\n82\t    assignmentId: trimOrNull(readSingleValue(input.progFilterAssignmentId)),\n83\t    challengeId: trimOrNull(readSingleValue(input.progFilterChallengeId)),\n84\t    userId: trimOrNull(readSingleValue(input.progFilterUserId)),\n85\t    roundId: trimOrNull(readSingleValue(input.progFilterRoundId)),\n86\t    createdFrom: trimOrNull(readSingleValue(input.progFilterFrom)),\n87\t    createdTo: trimOrNull(readSingleValue(input.progFilterTo)),\n88\t  };\n89\t}\n90\t\n91\texport function normalizeBonusCompletionFiltersFromSearchParams(\n92\t  input: Record<string, string | string[] | undefined>,\n93\t): PeekBonusCompletionFilters {\n94\t  return {\n95\t    userId: trimOrNull(readSingleValue(input.bcFilterUserId)),\n96\t    bonusId: trimOrNull(readSingleValue(input.bcFilterBonusId)),\n97\t    campaignId: trimOrNull(readSingleValue(input.bcFilterCampaignId)),\n98\t    periodKey: trimOrNull(readSingleValue(input.bcFilterPeriodKey)),\n99\t    completedFrom: trimOrNull(readSingleValue(input.bcFilterFrom)),\n100\t    completedTo: trimOrNull(readSingleValue(input.bcFilterTo)),\n101\t  };\n102\t}\n103\t"}]},"parent_tool_use_id":null,"session_id":"7378b447-bdd0-410a-9e39-562cf2836131","uuid":"785ae738-bae6-4ac3-821d-e6b800f674c8","timestamp":"2026-04-26T06:11:19.167Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/economy-challenges-search-params.ts","content":"// URL-addressable filter params for /economy/challenges (FR-9).\n//\n// Four prefixed param groups co-exist on the same page so each table can be\n// filtered independently while the URL stays shareable:\n//\n//   challenges      — `chFilter*`     (campaign_id, is_active)\n//   assignments     — `asgFilter*`    (user, challenge, campaign, period,\n//                                       status, assigned date range)\n//   progress events — `progFilter*`   (assignment, challenge, user, round,\n//                                       created date range)\n//   bonus completions — `bcFilter*`   (user, bonus, campaign, period,\n//                                       completed date range)\n//\n// Empty / whitespace-only values normalise to `null`. Unknown enum values for\n// `status` and `isActive` normalise to `null` so a stale URL chip cannot lie\n// about the table's filter state.\n\nimport type {\n  PeekBonusCompletionFilters,\n  PeekChallengeAssignmentFilters,\n  PeekChallengeFilters,\n  PeekProgressEventFilters,\n} from \"./types/peek\";\n\nexport const PEEK_CHALLENGE_ASSIGNMENT_STATUSES: ReadonlyArray<string> = [\n  \"active\",\n  \"completed\",\n  \"expired\",\n];\n\nexport const PEEK_CHALLENGE_IS_ACTIVE_VALUES: ReadonlyArray<string> = [\n  \"true\",\n  \"false\",\n];\n\nfunction readSingleValue(value: string | string[] | undefined): string {\n  return Array.isArray(value) ? value[0] ?? \"\" : value ?? \"\";\n}\n\nfunction trimOrNull(value: string): string | null {\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nfunction allowlistOrNull(\n  value: string | null,\n  allowed: ReadonlyArray<string>,\n): string | null {\n  if (!value) return null;\n  return allowed.includes(value) ? value : null;\n}\n\nexport function normalizeChallengeFiltersFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): PeekChallengeFilters {\n  const isActive = trimOrNull(readSingleValue(input.chFilterIsActive));\n  return {\n    campaignId: trimOrNull(readSingleValue(input.chFilterCampaignId)),\n    isActive: allowlistOrNull(isActive, PEEK_CHALLENGE_IS_ACTIVE_VALUES),\n  };\n}\n\nexport function normalizeChallengeAssignmentFiltersFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): PeekChallengeAssignmentFilters {\n  const status = trimOrNull(readSingleValue(input.asgFilterStatus));\n  return {\n    userId: trimOrNull(readSingleValue(input.asgFilterUserId)),\n    challengeId: trimOrNull(readSingleValue(input.asgFilterChallengeId)),\n    campaignId: trimOrNull(readSingleValue(input.asgFilterCampaignId)),\n    periodKey: trimOrNull(readSingleValue(input.asgFilterPeriodKey)),\n    status: allowlistOrNull(status, PEEK_CHALLENGE_ASSIGNMENT_STATUSES),\n    assignedFrom: trimOrNull(readSingleValue(input.asgFilterFrom)),\n    assignedTo: trimOrNull(readSingleValue(input.asgFilterTo)),\n  };\n}\n\nexport function normalizeProgressEventFiltersFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): PeekProgressEventFilters {\n  return {\n    assignmentId: trimOrNull(readSingleValue(input.progFilterAssignmentId)),\n    challengeId: trimOrNull(readSingleValue(input.progFilterChallengeId)),\n    userId: trimOrNull(readSingleValue(input.progFilterUserId)),\n    roundId: trimOrNull(readSingleValue(input.progFilterRoundId)),\n    createdFrom: trimOrNull(readSingleValue(input.progFilterFrom)),\n    createdTo: trimOrNull(readSingleValue(input.progFilterTo)),\n  };\n}\n\nexport function normalizeBonusCompletionFiltersFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): PeekBonusCompletionFilters {\n  return {\n    userId: trimOrNull(readSingleValue(input.bcFilterUserId)),\n    bonusId: trimOrNull(readSingleValue(input.bcFilterBonusId)),\n    campaignId: trimOrNull(readSingleValue(input.bcFilterCampaignId)),\n    periodKey: trimOrNull(readSingleValue(input.bcFilterPeriodKey)),\n    completedFrom: trimOrNull(readSingleValue(input.bcFilterFrom)),\n    completedTo: trimOrNull(readSingleValue(input.bcFilterTo)),\n  };\n}\n","numLines":103,"startLine":1,"totalLines":103}}}
