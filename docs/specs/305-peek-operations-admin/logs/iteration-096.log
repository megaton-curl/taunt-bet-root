{"content":"Write component tests for challenge tables + filter bar","status":"in_progress","activeForm":"Writing component tests"},{"content":"Run targeted checks (test, lint, typecheck)","status":"pending","activeForm":"Running targeted checks"},{"content":"Update spec checkbox and history","status":"pending","activeForm":"Updating spec/history"}],"verificationNudgeNeeded":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01RucEBsF9ANM9SvxritFDFk","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_014pmVCs66pfANVEos3WDaSY","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/__tests__/campaigns-table.test.tsx","content":"// Component tests for the FR-9 campaigns table.\n//\n// Read-only by spec (FR-9 / FR-14 — challenge / campaign / completion-bonus\n// definition editing is out of scope), so these tests assert there are no\n// edit affordances rendered: no buttons, no editable inputs, and the row\n// structure is just the dense table the operator drills down from.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { CampaignsTable } from \"../campaigns-table\";\nimport type { PeekCampaignRow } from \"../../lib/types/peek\";\n\nconst ROW_DAILY: PeekCampaignRow = {\n  id: \"1\",\n  name: \"Daily challenges\",\n  campaignType: \"daily\",\n  startsAt: \"2026-04-25T00:00:00.000Z\",\n  endsAt: \"2026-12-31T23:59:59.000Z\",\n  isActive: true,\n  createdAt: \"2026-04-01T00:00:00.000Z\",\n  challengeCount: 5,\n  activeAssignmentCount: 1234,\n};\n\nconst ROW_INACTIVE_ONBOARDING: PeekCampaignRow = {\n  id: \"2\",\n  name: \"Onboarding crate\",\n  campaignType: \"onboarding\",\n  startsAt: null,\n  endsAt: null,\n  isActive: false,\n  createdAt: \"2026-03-01T00:00:00.000Z\",\n  challengeCount: 0,\n  activeAssignmentCount: 0,\n};\n\nconst ROW_DOGPILE: PeekCampaignRow = {\n  id: \"3\",\n  name: \"Bull-run dogpile\",\n  campaignType: \"dogpile\",\n  startsAt: \"2026-04-26T10:00:00.000Z\",\n  endsAt: \"2026-04-26T12:00:00.000Z\",\n  isActive: true,\n  createdAt: \"2026-04-26T09:00:00.000Z\",\n  challengeCount: 2,\n  activeAssignmentCount: 87,\n};\n\ndescribe(\"CampaignsTable\", () => {\n  it(\"populated: renders the operator columns and the type/state chips\", () => {\n    render(<CampaignsTable rows={[ROW_DAILY, ROW_INACTIVE_ONBOARDING]} />);\n\n    for (const header of [\n      \"Name\",\n      \"Type\",\n      \"State\",\n      \"Starts\",\n      \"Ends\",\n      \"Challenges\",\n      \"Active assignments\",\n      \"Created\",\n      \"ID\",\n    ]) {\n      expect(screen.getByText(header)).toBeInTheDocument();\n    }\n\n    expect(screen.getByText(\"Daily challenges\")).toBeInTheDocument();\n    expect(screen.getByText(\"Onboarding crate\")).toBeInTheDocument();\n    expect(screen.getByText(\"daily\")).toBeInTheDocument();\n    expect(screen.getByText(\"onboarding\")).toBeInTheDocument();\n    expect(screen.getByText(\"active\")).toBeInTheDocument();\n    expect(screen.getByText(\"inactive\")).toBeInTheDocument();\n  });\n\n  it(\"populated: counts use thousands separators and null start/end dates render '—'\", () => {\n    render(<CampaignsTable rows={[ROW_DAILY, ROW_INACTIVE_ONBOARDING]} />);\n\n    expect(screen.getByText(\"1,234\")).toBeInTheDocument();\n    // Two rows × two null date columns each → expect at least 2 dashes.\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(2);\n  });\n\n  it(\"populated: dogpile rows render the warning chip variant\", () => {\n    render(<CampaignsTable rows={[ROW_DOGPILE]} />);\n\n    expect(screen.getByText(\"dogpile\")).toBeInTheDocument();\n    expect(screen.getByText(\"Bull-run dogpile\")).toBeInTheDocument();\n  });\n\n  it(\"read-only: no edit affordances rendered (no buttons, no editable inputs)\", () => {\n    render(<CampaignsTable rows={[ROW_DAILY, ROW_DOGPILE]} />);\n\n    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n    expect(screen.queryByRole(\"textbox\")).toBeNull();\n    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n  });\n\n  it(\"empty: renders the operator status block when no campaigns exist\", () => {\n    render(<CampaignsTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"No campaigns rows.\");\n    expect(status).toHaveTextContent(\"campaigns\");\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n    render(\n      <CampaignsTable rows={[ROW_DAILY]} error=\"connection refused\" />,\n    );\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Campaigns unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":491,"cache_read_input_tokens":151288,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":491},"output_tokens":62,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"7378b447-bdd0-410a-9e39-562cf2836131","uuid":"853f8009-aeed-4973-8977-9670f94c5042"}
