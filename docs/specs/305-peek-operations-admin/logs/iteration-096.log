1T00:00:00.000Z\",\n};\n\ndescribe(\"ChallengesTable\", () => {\n  it(\"populated: renders all per-template config columns\", () => {\n    render(<ChallengesTable rows={[ROW_ACTIVE, ROW_INACTIVE_CRATE]} />);\n\n    for (const header of [\n      \"Title\",\n      \"Campaign\",\n      \"State\",\n      \"Action\",\n      \"Scope\",\n      \"Condition\",\n      \"Threshold\",\n      \"Reward\",\n      \"Sort\",\n      \"ID\",\n    ]) {\n      expect(screen.getByText(header)).toBeInTheDocument();\n    }\n\n    expect(screen.getByText(\"Wager 1 SOL today\")).toBeInTheDocument();\n    expect(screen.getByText(\"First Pot Shot win\")).toBeInTheDocument();\n    expect(screen.getByText(\"active\")).toBeInTheDocument();\n    expect(screen.getByText(\"inactive\")).toBeInTheDocument();\n    expect(screen.getByText(\"wager\")).toBeInTheDocument();\n    expect(screen.getByText(\"win\")).toBeInTheDocument();\n    expect(screen.getByText(\"any\")).toBeInTheDocument();\n    expect(screen.getByText(\"potshot\")).toBeInTheDocument();\n    expect(screen.getByText(\"amount_gte\")).toBeInTheDocument();\n    expect(screen.getByText(\"count_gte\")).toBeInTheDocument();\n    expect(screen.getByText(\"points\")).toBeInTheDocument();\n    expect(screen.getByText(\"crate\")).toBeInTheDocument();\n  });\n\n  it(\"populated: integer threshold uses thousands separator and null reward amount renders the chip without a numeric suffix\", () => {\n    render(<ChallengesTable rows={[ROW_ACTIVE, ROW_INACTIVE_CRATE]} />);\n\n    expect(screen.getByText(\"1,000,000,000\")).toBeInTheDocument();\n    // Reward amount on ROW_ACTIVE shows \" · 500\"; null reward on\n    // ROW_INACTIVE_CRATE has no `· <number>` suffix.\n    expect(screen.getByText(/· 500/)).toBeInTheDocument();\n  });\n\n  it(\"populated: description sub-row renders only when present (null description omits the secondary line)\", () => {\n    render(<ChallengesTable rows={[ROW_ACTIVE, ROW_INACTIVE_CRATE]} />);\n\n    expect(\n      screen.getByText(\"Wager at least 1 SOL across any game today\"),\n    ).toBeInTheDocument();\n    // ROW_INACTIVE_CRATE has description: null, so the description text is absent.\n    expect(screen.queryByText(/null/i)).toBeNull();\n  });\n\n  it(\"read-only: no edit affordances rendered\", () => {\n    render(<ChallengesTable rows={[ROW_ACTIVE]} />);\n\n    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n    expect(screen.queryByRole(\"textbox\")).toBeNull();\n    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n  });\n\n  it(\"empty (filtered): renders the filter-aware operator status block\", () => {\n    render(<ChallengesTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"No challenges match these filters.\");\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n    render(<ChallengesTable rows={[ROW_ACTIVE]} error=\"db down\" />);\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Challenges unavailable: db down\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01DvCt5LdUZYyLd8Pw8TrTQ2","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01VYshuDFhewQZVE5DiFvvrs","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/__tests__/challenge-assignments-table.test.tsx","content":"// Component tests for the FR-9 challenge assignments table.\n//\n// Asserts the per-status status-chip transitions (active → completed →\n// expired) — operators rely on this column to spot stuck assignments — and\n// the user-detail link with username/userId fallback. Read-only: no edit\n// affordances.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { ChallengeAssignmentsTable } from \"../challenge-assignments-table\";\nimport type { PeekChallengeAssignmentRow } from \"../../lib/types/peek\";\n\nconst ROW_ACTIVE: PeekChallengeAssignmentRow = {\n  id: \"9001\",\n  userId: \"user-1\",\n  username: \"alice\",\n  challengeId: \"challenge-7\",\n  challengeTitle: \"Wager 5 SOL today\",\n  campaignId: \"campaign-3\",\n  campaignName: \"Daily challenges\",\n  periodKey: \"2026-04-26\",\n  status: \"active\",\n  progress: 2,\n  target: 5,\n  assignedAt: \"2026-04-26T00:00:00.000Z\",\n  expiresAt: \"2026-04-27T00:00:00.000Z\",\n  completedAt: null,\n};\n\nconst ROW_COMPLETED: PeekChallengeAssignmentRow = {\n  id: \"9002\",\n  userId: \"user-2\",\n  username: null,\n  challengeId: \"challenge-9\",\n  challengeTitle: null,\n  campaignId: null,\n  campaignName: null,\n  periodKey: \"2026-04-25\",\n  status: \"completed\",\n  progress: 1234,\n  target: 1234,\n  assignedAt: \"2026-04-25T00:00:00.000Z\",\n  expiresAt: null,\n  completedAt: \"2026-04-25T11:00:00.000Z\",\n};\n\nconst ROW_EXPIRED: PeekChallengeAssignmentRow = {\n  id: \"9003\",\n  userId: \"user-3\",\n  username: \"carol\",\n  challengeId: \"challenge-9\",\n  challengeTitle: \"Win 3 rounds\",\n  campaignId: \"campaign-3\",\n  campaignName: \"Daily challenges\",\n  periodKey: \"2026-04-24\",\n  status: \"expired\",\n  progress: 1,\n  target: 3,\n  assignedAt: \"2026-04-24T00:00:00.000Z\",\n  expiresAt: \"2026-04-25T00:00:00.000Z\",\n  completedAt: null,\n};\n\ndescribe(\"ChallengeAssignmentsTable\", () => {\n  it(\"populated: renders the operator columns + status chips for active / completed / expired\", () => {\n    render(\n      <ChallengeAssignmentsTable\n        rows={[ROW_ACTIVE, ROW_COMPLETED, ROW_EXPIRED]}\n      />,\n    );\n\n    for (const header of [\n      \"Assigned\",\n      \"User\",\n      \"Challenge\",\n      \"Campaign\",\n      \"Period\",\n      \"Status\",\n      \"Progress\",\n      \"Expires\",\n      \"Completed\",\n      \"ID\",\n    ]) {\n      expect(screen.getByText(header)).toBeInTheDocument();\n    }\n\n    expect(screen.getByText(\"active\")).toBeInTheDocument();\n    expect(screen.getByText(\"completed\")).toBeInTheDocument();\n    expect(screen.getByText(\"expired\")).toBeInTheDocument();\n  });\n\n  it(\"populated: progress cell uses thousands separators and renders progress / target inline\", () => {\n    render(<ChallengeAssignmentsTable rows={[ROW_COMPLETED]} />);\n\n    expect(screen.getByText(\"1,234\")).toBeInTheDocument();\n    // The target half is rendered as \" / 1,234\" in a sub-element. Use a\n    // regex match because the progress + target sit in adjacent spans.\n    expect(screen.getByText(/\\/ 1,234/)).toBeInTheDocument();\n  });\n\n  it(\"populated: user cell prefers username + drills down to /users/[userId] (verified by the link's href)\", () => {\n    render(<ChallengeAssignmentsTable rows={[ROW_ACTIVE]} />);\n\n    const link = screen.getByRole(\"link\", { name: \"alice\" });\n    expect(link).toHaveAttribute(\"href\", \"/users/user-1\");\n  });\n\n  it(\"populated: user cell falls back to userId when username is null and still drills down\", () => {\n    render(<ChallengeAssignmentsTable rows={[ROW_COMPLETED]} />);\n\n    const link = screen.getByRole(\"link\", { name: \"user-2\" });\n    expect(link).toHaveAttribute(\"href\", \"/users/user-2\");\n  });\n\n  it(\"populated: null expires/completed/challengeTitle/campaignName render '—' instead of breaking the row\", () => {\n    render(<ChallengeAssignmentsTable rows={[ROW_COMPLETED]} />);\n    // Multiple columns (challengeTitle, campaignName, expiresAt) render '—'\n    // for ROW_COMPLETED — assert at least 3 dashes appear.\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(3);\n  });\n\n  it(\"status-transition chips: tone changes are visible by class differences across active/completed/expired\", () => {\n    // Render each row in isolation so the testing-library `getByText` returns\n    // a single match per status label.\n    const { unmount: u1 } = render(\n      <ChallengeAssignmentsTable rows={[ROW_ACTIVE]} />,\n    );\n    const activeChip = screen.getByText(\"active\");\n    expect(activeChip).toBeInTheDocument();\n    u1();\n\n    const { unmount: u2 } = render(\n      <ChallengeAssignmentsTable rows={[ROW_COMPLETED]} />,\n    );\n    const completedChip = screen.getByText(\"completed\");\n    expect(completedChip).toBeInTheDocument();\n    u2();\n\n    render(<ChallengeAssignmentsTable rows={[ROW_EXPIRED]} />);\n    expect(screen.getByText(\"expired\")).toBeInTheDocument();\n  });\n\n  it(\"read-only: no edit affordances rendered\", () => {\n    render(<ChallengeAssignmentsTable rows={[ROW_ACTIVE]} />);\n\n    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n    expect(screen.queryByRole(\"textbox\")).toBeNull();\n    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n  });\n\n  it(\"empty (filtered): renders the filter-aware operator status block\", () => {\n    render(<ChallengeAssignmentsTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\n      \"No challenge_assignments rows match these filters.\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n    render(\n      <ChallengeAssignmentsTable rows={[ROW_ACTIVE]} error=\"db down\" />,\n    );\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Challenge assignments unavailable: db down\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2109,"cache_read_input_tokens":153735,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2109},"output_tokens":61,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"7378b447-bdd0-410a-9e39-562cf2836131","uuid":"69561560-cd24-428c-917b-8bbaf197a31d"}
