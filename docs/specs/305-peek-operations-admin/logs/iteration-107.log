{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LwVWuqVv15CpAPwxZLjLKx","type":"tool_result","content":"1\timport type { CSSProperties } from \"react\";\n2\timport { ExportActionLink } from \"../../../src/components/export-action-link\";\n3\timport { GrowthClaimsFilterBar } from \"../../../src/components/growth-claims-filter-bar\";\n4\timport { GrowthClaimsTable } from \"../../../src/components/growth-claims-table\";\n5\timport { GrowthReferrersTable } from \"../../../src/components/growth-referrers-table\";\n6\timport { MetricStrip } from \"../../../src/components/metric-strip\";\n7\timport { buildExportHref } from \"../../../src/lib/export-href\";\n8\timport { normalizeReferralClaimFiltersFromSearchParams } from \"../../../src/lib/growth-search-params\";\n9\timport type {\n10\t  PeekGrowthClaimRow,\n11\t  PeekGrowthOverview,\n12\t  PeekTopReferrerRow,\n13\t} from \"../../../src/lib/types/peek\";\n14\timport {\n15\t  getPeekActorContext,\n16\t  isRouteAllowedForRole,\n17\t} from \"../../../src/server/access-policy\";\n18\timport {\n19\t  getGrowthReferralOverview,\n20\t  listReferralClaims,\n21\t  listTopReferrers,\n22\t} from \"../../../src/server/db/queries/get-growth-referrals\";\n23\timport { isPeekAuditConfigured } from \"../../../src/server/exports\";\n24\t\n25\texport const dynamic = \"force-dynamic\";\n26\t\n27\tconst ROUTE = \"/growth/referrals\";\n28\t\n29\texport default async function GrowthReferralsPage({\n30\t  searchParams,\n31\t}: {\n32\t  searchParams: Promise<Record<string, string | string[] | undefined>>;\n33\t}) {\n34\t  const actor = await getPeekActorContext();\n35\t  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n36\t\n37\t  if (!allowed) {\n38\t    return (\n39\t      <main style={mainStyle}>\n40\t        <header>\n41\t          <h1>Growth · Referrals</h1>\n42\t        </header>\n43\t        <p role=\"alert\" style={errorStyle}>\n44\t          You do not have access to this page.\n45\t        </p>\n46\t      </main>\n47\t    );\n48\t  }\n49\t\n50\t  const params = await searchParams;\n51\t  const filters = normalizeReferralClaimFiltersFromSearchParams(params);\n52\t\n53\t  let overview: PeekGrowthOverview = {\n54\t    generatedAt: new Date().toISOString(),\n55\t    metrics: [],\n56\t  };\n57\t  let topReferrers: ReadonlyArray<PeekTopReferrerRow> = [];\n58\t  let claims: ReadonlyArray<PeekGrowthClaimRow> = [];\n59\t  let overviewError: string | null = null;\n60\t  let topReferrersError: string | null = null;\n61\t  let claimsError: string | null = null;\n62\t\n63\t  try {\n64\t    overview = await getGrowthReferralOverview();\n65\t  } catch (error) {\n66\t    overviewError =\n67\t      error instanceof Error\n68\t        ? error.message\n69\t        : \"Overview metrics could not be loaded.\";\n70\t  }\n71\t\n72\t  try {\n73\t    topReferrers = await listTopReferrers();\n74\t  } catch (error) {\n75\t    topReferrersError =\n76\t      error instanceof Error\n77\t        ? error.message\n78\t        : \"Top referrers could not be loaded.\";\n79\t  }\n80\t\n81\t  try {\n82\t    claims = await listReferralClaims({ filters });\n83\t  } catch (error) {\n84\t    claimsError =\n85\t      error instanceof Error\n86\t        ? error.message\n87\t        : \"Referral claims could not be loaded.\";\n88\t  }\n89\t\n90\t  const exportsEnabled =\n91\t    process.env.NODE_ENV !== \"production\" || isPeekAuditConfigured();\n92\t  const claimFilterCount = Object.values(filters).filter(\n93\t    (value) => value !== null && value !== \"\",\n94\t  ).length;\n95\t  const claimsExportEnabled = exportsEnabled && claimFilterCount > 0;\n96\t  const claimsExportDisabledReason = !exportsEnabled\n97\t    ? \"Exports are disabled because audit logging is not configured.\"\n98\t    : \"Apply at least one claims filter to enable export.\";\n99\t  const referrersExportHref = buildExportHref(\"referrers\");\n100\t  const claimsExportHref = buildExportHref(\"claims\", filters);\n101\t\n102\t  return (\n103\t    <main style={mainStyle}>\n104\t      <header>\n105\t        <h1>Growth · Referrals</h1>\n106\t        <p style={leadStyle}>\n107\t          Referral overview, top referrers, and claim payout state. Drill into\n108\t          a row to open the user-detail page for that referrer or claimant.\n109\t        </p>\n110\t      </header>\n111\t\n112\t      <section aria-labelledby=\"overview-heading\">\n113\t        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n114\t          Overview\n115\t        </h2>\n116\t        <MetricStrip metrics={overview.metrics} error={overviewError} />\n117\t      </section>\n118\t\n119\t      <section\n120\t        aria-labelledby=\"top-referrers-heading\"\n121\t        id=\"top-referrers\"\n122\t        style={sectionStyle}\n123\t      >\n124\t        <div style={sectionHeaderRowStyle}>\n125\t          <h2 id=\"top-referrers-heading\" style={sectionHeadingStyle}>\n126\t            Top referrers\n127\t          </h2>\n128\t          <ExportActionLink\n129\t            href={referrersExportHref}\n130\t            label=\"Export CSV\"\n131\t            enabled={exportsEnabled}\n132\t          />\n133\t        </div>\n134\t        <p style={hintStyle}>\n135\t          Default 50 rows · sorted by referrer earnings · server-side capped at\n136\t          250.\n137\t        </p>\n138\t        <GrowthReferrersTable\n139\t          rows={topReferrers}\n140\t          error={topReferrersError}\n141\t        />\n142\t      </section>\n143\t\n144\t      <section\n145\t        aria-labelledby=\"claims-heading\"\n146\t        id=\"claims\"\n147\t        style={sectionStyle}\n148\t      >\n149\t        <div style={sectionHeaderRowStyle}>\n150\t          <h2 id=\"claims-heading\" style={sectionHeadingStyle}>\n151\t            Referral claims\n152\t          </h2>\n153\t          <ExportActionLink\n154\t            href={claimsExportHref}\n155\t            label=\"Export filtered CSV\"\n156\t            enabled={claimsExport