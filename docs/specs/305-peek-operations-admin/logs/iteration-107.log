{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01DpnYth9mpT46ggKQi59ARh","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0146jp5FoGkemrgsB3qYFpgf","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/lib/export-href.ts","content":"// Browser-safe export URL builder (FR-12).\n//\n// Pages render export action links pointing at `/exports/{entity}` with the\n// active table filters serialized as URL params. The export Route Handler\n// reads the params verbatim and forwards them to `runPeekExport`; each\n// exporter picks only the keys it understands, so extra params are ignored.\n//\n// Empty / null filter values are skipped so the export href stays clean and\n// `peek.export` audit `filterSummary` only mentions filters that were actually\n// applied.\nimport type { PeekExportEntity } from \"./types/peek\";\n\nexport type ExportHrefFilters = Readonly<\n  Record<string, string | null | undefined>\n>;\n\nexport function buildExportHref(\n  entity: PeekExportEntity,\n  filters: ExportHrefFilters = {},\n): string {\n  const params = new URLSearchParams();\n  for (const [key, value] of Object.entries(filters)) {\n    if (value === null || value === undefined) continue;\n    const trimmed = String(value).trim();\n    if (trimmed === \"\") continue;\n    params.set(key, trimmed);\n  }\n  const query = params.toString();\n  return query ? `/exports/${entity}?${query}` : `/exports/${entity}`;\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":464,"cache_read_input_tokens":107478,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":464},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"71b441dc-11ef-4d53-a5eb-e22ac2dfdbdf","uuid":"573fadea-0d3b-4672-939d-55903a38045d"}
