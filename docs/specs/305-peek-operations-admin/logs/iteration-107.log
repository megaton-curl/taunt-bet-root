{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01Vp55Ew1odXBRZYAUVdaWeA","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_018iK5Z7mjr2A41A8dziNK7M","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/app/exports/[entity]/route.ts","content":"// Export Route Handler (FR-12).\n//\n// Inherits page-level access from the entity's source route per\n// `PEEK_EXPORT_SOURCE_ROUTES`. The handler:\n//   1. Resolves the actor context from the verified Cloudflare email.\n//   2. Refuses unknown entities or entities without a wired source page.\n//   3. Refuses actors that cannot reach the source page under FR-2 policy.\n//   4. Forwards URL search params verbatim as exporter filters; each exporter\n//      picks only the keys it understands so unknown keys are harmless.\n//   5. Delegates to `runPeekExport` which:\n//        - rejects unfiltered exports for entities that require a filter\n//        - blocks production exports when audit logging is not configured\n//        - emits the `peek.export` audit event BEFORE returning data\n//        - surfaces a structured failure when audit emit itself fails\n//   6. Streams CSV bytes with a deterministic filename via `Content-Disposition`.\n\nimport { NextResponse, type NextRequest } from \"next/server\";\nimport {\n  getPeekActorContext,\n  isRouteAllowedForRole,\n} from \"../../../src/server/access-policy\";\nimport {\n  getPeekExporter,\n  getSourceRouteForExportEntity,\n  runPeekExport,\n  serializePeekCsv,\n  type PeekExportFailureReason,\n} from \"../../../src/server/exports\";\nimport type {\n  PeekExportEntity,\n} from \"../../../src/lib/types/peek\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst KNOWN_ENTITIES: ReadonlyArray<PeekExportEntity> = [\n  \"users\",\n  \"referrers\",\n  \"kol\",\n  \"claims\",\n  \"rounds\",\n  \"transactions\",\n  \"queue\",\n  \"audit\",\n];\n\nfunction isKnownEntity(value: string): value is PeekExportEntity {\n  return (KNOWN_ENTITIES as ReadonlyArray<string>).includes(value);\n}\n\nfunction statusForFailure(reason: PeekExportFailureReason): number {\n  switch (reason) {\n    case \"unknown_entity\":\n      return 404;\n    case \"no_filters\":\n      return 400;\n    case \"audit_unavailable\":\n      return 503;\n    case \"audit_emit_failed\":\n      return 502;\n    default:\n      return 500;\n  }\n}\n\nexport async function GET(\n  request: NextRequest,\n  context: { params: Promise<{ entity: string }> },\n): Promise<Response> {\n  const { entity } = await context.params;\n\n  if (!isKnownEntity(entity)) {\n    return new NextResponse(\"Unknown export entity\", { status: 404 });\n  }\n\n  if (!getPeekExporter(entity)) {\n    return new NextResponse(\"Unknown export entity\", { status: 404 });\n  }\n\n  const sourceRoute = getSourceRouteForExportEntity(entity);\n  if (!sourceRoute) {\n    return new NextResponse(\"Export entity has no source page\", {\n      status: 404,\n    });\n  }\n\n  const actor = await getPeekActorContext();\n  if (!actor) {\n    return new NextResponse(\"Forbidden\", { status: 403 });\n  }\n\n  if (!isRouteAllowedForRole(sourceRoute, actor.role)) {\n    return new NextResponse(\"Forbidden\", { status: 403 });\n  }\n\n  const filters: Record<string, string | null> = {};\n  for (const [key, value] of request.nextUrl.searchParams) {\n    if (filters[key] === undefined) {\n      filters[key] = value;\n    }\n  }\n\n  const result = await runPeekExport({\n    entity,\n    filters,\n    actor: {\n      email: actor.email,\n      route: sourceRoute,\n      requestId: request.headers.get(\"x-request-id\"),\n    },\n  });\n\n  if (!result.ok) {\n    return new NextResponse(result.message, {\n      status: statusForFailure(result.reason),\n    });\n  }\n\n  const csv = serializePeekCsv(result.result.columns, result.result.rows);\n\n  return new NextResponse(csv, {\n    status: 200,\n    headers: {\n      \"Content-Type\": \"text/csv; charset=utf-8\",\n      \"Content-Disposition\": `attachment; filename=\"${result.result.filename}\"`,\n      \"Cache-Control\": \"no-store\",\n    },\n  });\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":393,"cache_read_input_tokens":109410,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":393},"output_tokens":71,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"71b441dc-11ef-4d53-a5eb-e22ac2dfdbdf","uuid":"14f659da-f553-4382-8a67-c87e2e3df019"}
