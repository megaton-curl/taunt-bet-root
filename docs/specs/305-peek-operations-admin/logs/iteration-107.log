{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NQVL2DuJkzY9pwMfhNRP8Q","type":"tool_result","content":"1\t// Server-side CSV serialization for peek exports (FR-12).\n2\t//\n3\t// Minimal RFC 4180 emitter: header from `PeekTableColumn.label`, body from\n4\t// `PeekExportRow` keyed by `PeekTableColumn.id`. Quoting is applied to any\n5\t// field that contains `,`, `\"`, `\\r`, or `\\n`; embedded quotes are doubled.\n6\t// Line endings are CRLF so the file opens cleanly in Excel and Google Sheets\n7\t// without locale-specific reinterpretation.\n8\t\n9\timport type { PeekExportRow, PeekTableColumn } from \"../../lib/types/peek\";\n10\t\n11\tconst NEEDS_QUOTING = /[\",\\r\\n]/;\n12\t\n13\tfunction escapeCsvField(value: string): string {\n14\t  if (value === \"\") return \"\";\n15\t  if (NEEDS_QUOTING.test(value)) {\n16\t    return `\"${value.replace(/\"/g, '\"\"')}\"`;\n17\t  }\n18\t  return value;\n19\t}\n20\t\n21\texport function serializePeekCsv(\n22\t  columns: ReadonlyArray<PeekTableColumn>,\n23\t  rows: ReadonlyArray<PeekExportRow>,\n24\t): string {\n25\t  const header = columns.map((c) => escapeCsvField(c.label)).join(\",\");\n26\t  const body = rows.map((row) =>\n27\t    columns.map((c) => escapeCsvField(row[c.id] ?? \"\")).join(\",\"),\n28\t  );\n29\t  return [header, ...body].join(\"\\r\\n\") + \"\\r\\n\";\n30\t}\n31\t"}]},"parent_tool_use_id":null,"session_id":"71b441dc-11ef-4d53-a5eb-e22ac2dfdbdf","uuid":"7e19a884-addf-4a06-97cd-ebcc8aad428e","timestamp":"2026-04-26T07:42:45.032Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/exports/csv.ts","content":"// Server-side CSV serialization for peek exports (FR-12).\n//\n// Minimal RFC 4180 emitter: header from `PeekTableColumn.label`, body from\n// `PeekExportRow` keyed by `PeekTableColumn.id`. Quoting is applied to any\n// field that contains `,`, `\"`, `\\r`, or `\\n`; embedded quotes are doubled.\n// Line endings are CRLF so the file opens cleanly in Excel and Google Sheets\n// without locale-specific reinterpretation.\n\nimport type { PeekExportRow, PeekTableColumn } from \"../../lib/types/peek\";\n\nconst NEEDS_QUOTING = /[\",\\r\\n]/;\n\nfunction escapeCsvField(value: string): string {\n  if (value === \"\") return \"\";\n  if (NEEDS_QUOTING.test(value)) {\n    return `\"${value.replace(/\"/g, '\"\"')}\"`;\n  }\n  return value;\n}\n\nexport function serializePeekCsv(\n  columns: ReadonlyArray<PeekTableColumn>,\n  rows: ReadonlyArray<PeekExportRow>,\n): string {\n  const header = columns.map((c) => escapeCsvField(c.label)).join(\",\");\n  const body = rows.map((row) =>\n    columns.map((c) => escapeCsvField(row[c.id] ?? \"\")).join(\",\"),\n  );\n  return [header, ...body].join(\"\\r\\n\") + \"\\r\\n\";\n}\n","numLines":31,"startLine":1,"totalLines":31}}}
