xport const CLAIM_EXPORT_FILTER_KEYS = [\n43\t  \"status\",\n44\t  \"userId\",\n45\t  \"minAmountLamports\",\n46\t  \"maxAmountLamports\",\n47\t  \"requestedFrom\",\n48\t  \"requestedTo\",\n49\t  \"txSignature\",\n50\t  \"errorContains\",\n51\t] as const satisfies ReadonlyArray<keyof PeekReferralClaimFilters>;\n52\t\n53\tfunction pickClaimFilters(\n54\t  filters: PeekExporterFilters,\n55\t): Partial<PeekReferralClaimFilters> {\n56\t  const out: Partial<PeekReferralClaimFilters> = {};\n57\t  for (const key of CLAIM_EXPORT_FILTER_KEYS) {\n58\t    const raw = filters[key];\n59\t    if (raw !== null && raw !== undefined && raw !== \"\") {\n60\t      out[key] = raw;\n61\t    }\n62\t  }\n63\t  return out;\n64\t}\n65\t\n66\tfunction rowToCsv(row: PeekGrowthClaimRow): Record<string, string> {\n67\t  return {\n68\t    id: row.id,\n69\t    userId: row.userId,\n70\t    username: row.username ?? \"\",\n71\t    wallet: row.wallet,\n72\t    amountLamports: row.amountLamports,\n73\t    status: row.status,\n74\t    retryCount: row.retryCount.toString(),\n75\t    txSignature: row.txSignature ?? \"\",\n76\t    requestedAt: row.requestedAt,\n77\t    processedAt: row.processedAt ?? \"\",\n78\t    error: row.error ?? \"\",\n79\t  };\n80\t}\n81\t\n82\texport const CLAIMS_EXPORTER: PeekExporterDefinition = {\n83\t  entity: \"claims\",\n84\t  resourceType: \"referral_claim\",\n85\t  columns: CLAIM_COLUMNS,\n86\t  maxRowsPerExport: PEEK_GROWTH_CLAIMS_MAX_LIMIT,\n87\t  requireAtLeastOneFilter: true,\n88\t  async fetch(ctx) {\n89\t    const filters = pickClaimFilters(ctx.filters);\n90\t    // Request rowCap + 1 so the runner can detect that the cap was the limiter\n91\t    // (rather than the underlying SQL exhausting). The query module clamps to\n92\t    // its own MAX, but `maxRowsPerExport` already keeps `rowCap` ≤ that max.\n93\t    const rows = await listReferralClaims({\n94\t      sql: ctx.sql,\n95\t      limit: ctx.rowCap + 1,\n96\t      filters,\n97\t    });\n98\t    const rowCapApplied = rows.length > ctx.rowCap;\n99\t    const trimmed = rowCapApplied ? rows.slice(0, ctx.rowCap) : rows;\n100\t    return {\n101\t      rows: trimmed.map(rowToCsv),\n102\t      rowCapApplied,\n103\t    };\n104\t  },\n105\t  buildFilterSlug(filters) {\n106\t    const parts: string[] = [];\n107\t    if (filters.status) parts.push(`status-${slugForFilename(filters.status)}`);\n108\t    if (filters.userId) parts.push(`user-${slugForFilename(filters.userId)}`);\n109\t    if (filters.txSignature) {\n110\t      parts.push(`tx-${slugForFilename(filters.txSignature).slice(0, 12)}`);\n111\t    }\n112\t    if (filters.minAmountLamports) {\n113\t      parts.push(`min-${slugForFilename(filters.minAmountLamports)}`);\n114\t    }\n115\t    if (filters.maxAmountLamports) {\n116\t      parts.push(`max-${slugForFilename(filters.maxAmountLamports)}`);\n117\t    }\n118\t    if (filters.requestedFrom) {\n119\t      parts.push(`from-${slugForFilename(filters.requestedFrom).slice(0, 10)}`);\n120\t    }\n121\t    if (filters.requestedTo) {\n122\t      parts.push(`to-${slugForFilename(filters.requestedTo).slice(0, 10)}`);\n123\t    }\n124\t    return parts.join(\"_\");\n125\t  },\n126\t};\n127\t"}]},"parent_tool_use_id":null,"session_id":"71b441dc-11ef-4d53-a5eb-e22ac2dfdbdf","uuid":"b6f34041-249a-452f-842d-6d990cb5f5da","timestamp":"2026-04-26T07:42:41.679Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/exports/exporters/claims.ts","content":"// Referral claims exporter (FR-7, FR-12).\n//\n// Backs the `claims` export entity used by `/growth/referrals`. The fetch path\n// reuses `listReferralClaims` so the column set matches what the page renders;\n// row limits are honored through the query module's own clamp ceiling so the\n// export cannot exceed `PEEK_GROWTH_CLAIMS_MAX_LIMIT`.\n\nimport {\n  listReferralClaims,\n  PEEK_GROWTH_CLAIMS_MAX_LIMIT,\n} from \"../../db/queries/get-growth-referrals\";\nimport type {\n  PeekGrowthClaimRow,\n  PeekReferralClaimFilters,\n  PeekTableColumn,\n} from \"../../../lib/types/peek\";\nimport type {\n  PeekExporterDefinition,\n  PeekExporterFilters,\n} from \"../registry\";\nimport { slugForFilename } from \"../filename\";\n\nconst CLAIM_COLUMNS: ReadonlyArray<PeekTableColumn> = [\n  { id: \"id\", label: \"Claim id\", align: \"left\", sortable: false },\n  { id: \"userId\", label: \"User id\", align: \"left\", sortable: false },\n  { id: \"username\", label: \"Username\", align: \"left\", sortable: false },\n  { id: \"wallet\", label: \"Wallet\", align: \"left\", sortable: false },\n  {\n    id: \"amountLamports\",\n    label: \"Amount (lamports)\",\n    align: \"right\",\n    sortable: false,\n  },\n  { id: \"status\", label: \"Status\", align: \"left\", sortable: false },\n  { id: \"retryCount\", label: \"Retries\", align: \"right\", sortable: false },\n  { id: \"txSignature\", label: \"Tx signature\", align: \"left\", sortable: false },\n  { id: \"requestedAt\", label: \"Requested\", align: \"left\", sortable: false },\n  { id: \"processedAt\", label: \"Processed\", align: \"left\", sortable: false },\n  { id: \"error\", label: \"Error\", align: \"left\", sortable: false },\n];\n\nexport const CLAIM_EXPORT_FILTER_KEYS = [\n  \"status\",\n  \"userId\",\n  \"minAmountLamports\",\n  \"maxAmountLamports\",\n  \"requestedFrom\",\n  \"requestedTo\",\n  \"txSignature\",\n  \"errorContains\",\n] as const satisfies ReadonlyArray<keyof PeekReferralClaimFilters>;\n\nfunction pickClaimFilters(\n  filters: PeekExporterFilters,\n): Partial<PeekReferralClaimFilters> {\n  const out: Partial<PeekReferralClaimFilters> = {};\n  for (const key of CLAIM_EXPORT_FILTER_KEYS) {\n    const raw = filters[key];\n    if (raw !== null && raw !== undefined && raw !== \"\") {\n      out[key] = raw;\n    }\n  }\n  return out;\n}\n\nfunction rowToCsv(row: PeekGrowthClaimRow): Record<string, string> {\n  return {\n    id: row.id,\n    userId: row.userId,\n    username: row.username ?? \"\",\n    wallet: row.wallet,\n    amountLamports: row.amountLamports,\n    status: row.status,\n    retryCount: row.retryCount.toString(),\n    txSignature: row.txSignature ?? \"\",\n    requestedAt: row.requestedAt,\n    processedAt: row.processedAt ?? \"\",\n    error: row.error ?? \"\",\n  };\n}\n\nexport const CLAIMS_EXPORTER: PeekExporterDefinition = {\n  entity: \"claims\",\n  resourceType: \"referral_claim\",\n  columns: CLAIM_COLUMNS,\n  maxRowsPerExport: PEEK_GROWTH_CLAIMS_MAX_LIMIT,\n  requireAtLeastOneFilter: true,\n  async fetch(ctx) {\n    const filters = pickClaimFilters(ctx.filters);\n    // Request rowCap + 1 so the runner can detect that the cap was the limiter\n    // (rather than the underlying SQL exhausting). The query module clamps to\n    // its own MAX, but `maxRowsPerExport` already keeps `rowCap` ≤ that max.\n    const rows = await listReferralClaims({\n      sql: ctx.sql,\n      limit: ctx.rowCap + 1,\n      filters,\n    });\n    const rowCapApplied = rows.length > ctx.rowCap;\n    const trimmed = rowCapApplied ? rows.slice(0, ctx.rowCap) : rows;\n    return {\n      rows: trimmed.map(rowToCsv),\n      rowCapApplied,\n    };\n  },\n  buildFilterSlug(filters) {\n    const parts: string[] = [];\n    if (filters.status) parts.push(`status-${slugForFilename(filters.status)}`);\n    if (filters.userId) parts.push(`user-${slugForFilename(filters.userId)}`);\n    if (filters.txSignature) {\n      parts.push(`tx-${slugForFilename(filters.txSignature).slice(0, 12)}`);\n    }\n    if (filters.minAmountLamports) {\n      parts.push(`min-${slugForFilename(filters.minAmountLamports)}`);\n    }\n    if (filters.maxAmountLamports) {\n      parts.push(`max-${slugForFilename(filters.maxAmountLamports)}`);\n    }\n    if (filters.requestedFrom) {\n      parts.push(`from-${slugForFilename(filters.requestedFrom).slice(0, 10)}`);\n    }\n    if (filters.requestedTo) {\n      parts.push(`to-${slugForFilename(filters.requestedTo).slice(0, 10)}`);\n    }\n    return parts.join(\"_\");\n  },\n};\n","numLines":127,"startLine":1,"totalLines":127}}}
