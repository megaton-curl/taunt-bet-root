{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01YWaFxWwLvhTt3JEBd7tH67","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_012VEi4MCe8hHXCFg9awXo5R","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/export-action-link.tsx","content":"// Export action UI (FR-12).\n//\n// Renders an enabled `<a download>` when the server signals exports are\n// available, or a disabled affordance with an explanatory tooltip when audit\n// logging is unavailable in production. The component never builds the export\n// URL itself — it just renders what the page passes in — so any access /\n// audit decisions stay on the server.\nimport type { CSSProperties } from \"react\";\n\nexport type ExportActionLinkProps = {\n  href: string;\n  label?: string;\n  enabled: boolean;\n  disabledReason?: string;\n};\n\nexport function ExportActionLink({\n  href,\n  label = \"Export CSV\",\n  enabled,\n  disabledReason,\n}: ExportActionLinkProps) {\n  if (!enabled) {\n    const reason =\n      disabledReason ??\n      \"Exports are disabled because audit logging is not configured.\";\n    return (\n      <span\n        role=\"button\"\n        aria-disabled=\"true\"\n        title={reason}\n        style={disabledStyle}\n        data-testid=\"export-action-disabled\"\n      >\n        {label}\n      </span>\n    );\n  }\n\n  return (\n    <a\n      href={href}\n      download\n      style={enabledStyle}\n      data-testid=\"export-action-enabled\"\n    >\n      {label}\n    </a>\n  );\n}\n\nconst baseStyle: CSSProperties = {\n  display: \"inline-flex\",\n  alignItems: \"center\",\n  gap: \"0.375rem\",\n  padding: \"0.375rem 0.75rem\",\n  borderRadius: \"0.5rem\",\n  fontSize: \"0.8125rem\",\n  fontWeight: 600,\n  textDecoration: \"none\",\n  border: \"1px solid transparent\",\n};\n\nconst enabledStyle: CSSProperties = {\n  ...baseStyle,\n  background: \"#1e3a8a\",\n  borderColor: \"#2563eb\",\n  color: \"#dbeafe\",\n  cursor: \"pointer\",\n};\n\nconst disabledStyle: CSSProperties = {\n  ...baseStyle,\n  background: \"#1f2937\",\n  borderColor: \"#334155\",\n  color: \"#64748b\",\n  cursor: \"not-allowed\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":588,"cache_read_input_tokens":107942,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":588},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"71b441dc-11ef-4d53-a5eb-e22ac2dfdbdf","uuid":"44a08bf9-0969-4cf7-a622-db6d0b35b138"}
