mport {\n  getGrowthReferralOverview,\n  listReferralClaims,\n  listTopReferrers,\n} from \"../../../src/server/db/queries/get-growth-referrals\";\nimport { isPeekAuditConfigured } from \"../../../src/server/exports\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst ROUTE = \"/growth/referrals\";\n\nexport default async function GrowthReferralsPage({\n  searchParams,\n}: {\n  searchParams: Promise<Record<string, string | string[] | undefined>>;\n}) {\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n\n  if (!allowed) {\n    return (\n      <main style={mainStyle}>\n        <header>\n          <h1>Growth · Referrals</h1>\n        </header>\n        <p role=\"alert\" style={errorStyle}>\n          You do not have access to this page.\n        </p>\n      </main>\n    );\n  }\n\n  const params = await searchParams;\n  const filters = normalizeReferralClaimFiltersFromSearchParams(params);\n\n  let overview: PeekGrowthOverview = {\n    generatedAt: new Date().toISOString(),\n    metrics: [],\n  };\n  let topReferrers: ReadonlyArray<PeekTopReferrerRow> = [];\n  let claims: ReadonlyArray<PeekGrowthClaimRow> = [];\n  let overviewError: string | null = null;\n  let topReferrersError: string | null = null;\n  let claimsError: string | null = null;\n\n  try {\n    overview = await getGrowthReferralOverview();\n  } catch (error) {\n    overviewError =\n      error instanceof Error\n        ? error.message\n        : \"Overview metrics could not be loaded.\";\n  }\n\n  try {\n    topReferrers = await listTopReferrers();\n  } catch (error) {\n    topReferrersError =\n      error instanceof Error\n        ? error.message\n        : \"Top referrers could not be loaded.\";\n  }\n\n  try {\n    claims = await listReferralClaims({ filters });\n  } catch (error) {\n    claimsError =\n      error instanceof Error\n        ? error.message\n        : \"Referral claims could not be loaded.\";\n  }\n\n  const exportsEnabled =\n    process.env.NODE_ENV !== \"production\" || isPeekAuditConfigured();\n  const claimFilterCount = Object.values(filters).filter(\n    (value) => value !== null && value !== \"\",\n  ).length;\n  const claimsExportEnabled = exportsEnabled && claimFilterCount > 0;\n  const claimsExportDisabledReason = !exportsEnabled\n    ? \"Exports are disabled because audit logging is not configured.\"\n    : \"Apply at least one claims filter to enable export.\";\n  const referrersExportHref = buildExportHref(\"referrers\");\n  const claimsExportHref = buildExportHref(\"claims\", filters);\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <h1>Growth · Referrals</h1>\n        <p style={leadStyle}>\n          Referral overview, top referrers, and claim payout state. Drill into\n          a row to open the user-detail page for that referrer or claimant.\n        </p>\n      </header>\n\n      <section aria-labelledby=\"overview-heading\">\n        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n          Overview\n        </h2>\n        <MetricStrip metrics={overview.metrics} error={overviewError} />\n      </section>\n\n      <section\n        aria-labelledby=\"top-referrers-heading\"\n        id=\"top-referrers\"\n        style={sectionStyle}\n      >\n        <div style={sectionHeaderRowStyle}>\n          <h2 id=\"top-referrers-heading\" style={sectionHeadingStyle}>\n            Top referrers\n          </h2>\n          <ExportActionLink\n            href={referrersExportHref}\n            label=\"Export CSV\"\n            enabled={exportsEnabled}\n          />\n        </div>\n        <p style={hintStyle}>\n          Default 50 rows · sorted by referrer earnings · server-side capped at\n          250.\n        </p>\n        <GrowthReferrersTable\n          rows={topReferrers}\n          error={topReferrersError}\n        />\n      </section>\n\n      <section\n        aria-labelledby=\"claims-heading\"\n        id=\"claims\"\n        style={sectionStyle}\n      >\n        <div style={sectionHeaderRowStyle}>\n          <h2 id=\"claims-heading\" style={sectionHeadingStyle}>\n            Referral claims\n          </h2>\n          <ExportActionLink\n            href={claimsExportHref}\n            label=\"Export filtered CSV\"\n            enabled={claimsExportEnabled}\n            disabledReason={claimsExportDisabledReason}\n          />\n        </div>\n        <p style={hintStyle}>\n          Filterable by status, user, amount, requested date, tx signature, and\n          error text. URL-addressable so internal investigations can be shared.\n        </p>\n        <GrowthClaimsFilterBar filters={filters} action={ROUTE} />\n        <GrowthClaimsTable rows={claims} error={claimsError} />\n      </section>\n    </main>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n","structuredPatch":[{"oldStart":187,"oldLines":6,"newStart":187,"newLines":14,"lines":["   letterSpacing: \"0.05em\","," };"," ","+const sectionHeaderRowStyle: CSSProperties = {","+  display: \"flex\",","+  alignItems: \"center\",","+  justifyContent: \"space-between\",","+  gap: \"0.75rem\",","+  flexWrap: \"wrap\",","+};","+"," const leadStyle: CSSProperties = {","   margin: \"0.25rem 0 0\",","   color: \"#94a3b8\","]}],"userModified":false,"r