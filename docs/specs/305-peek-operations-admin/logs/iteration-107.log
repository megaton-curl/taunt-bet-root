{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CLCP8tTtdJXxvWftS2XaJh","type":"tool_result","content":"1\t// URL-addressable filter params for /growth/referrals claims table (FR-7).\n2\t//\n3\t// Mirrors the engine `PeekReferralClaimFilters` shape and normalises raw\n4\t// search-param input the page receives from Next.js. Empty / whitespace-only\n5\t// values normalise to `null` so the engine query skips them; the `claimStatus`\n6\t// \"failed\" value is a virtual alias the engine widens to `('failed','error')`.\n7\t\n8\timport type { PeekReferralClaimFilters } from \"./types/peek\";\n9\t\n10\texport const PEEK_REFERRAL_CLAIM_STATUSES: ReadonlyArray<string> = [\n11\t  \"pending\",\n12\t  \"processing\",\n13\t  \"error\",\n14\t  \"completed\",\n15\t  \"failed\",\n16\t];\n17\t\n18\tfunction readSingleValue(\n19\t  value: string | string[] | undefined,\n20\t): string {\n21\t  return Array.isArray(value) ? value[0] ?? \"\" : value ?? \"\";\n22\t}\n23\t\n24\tfunction trimOrNull(value: string): string | null {\n25\t  const trimmed = value.trim();\n26\t  return trimmed.length > 0 ? trimmed : null;\n27\t}\n28\t\n29\texport function normalizeReferralClaimFiltersFromSearchParams(\n30\t  input: Record<string, string | string[] | undefined>,\n31\t): PeekReferralClaimFilters {\n32\t  const status = trimOrNull(readSingleValue(input.claimStatus));\n33\t  return {\n34\t    status:\n35\t      status && PEEK_REFERRAL_CLAIM_STATUSES.includes(status) ? status : null,\n36\t    userId: trimOrNull(readSingleValue(input.claimUserId)),\n37\t    minAmountLamports: trimOrNull(readSingleValue(input.claimMinAmount)),\n38\t    maxAmountLamports: trimOrNull(readSingleValue(input.claimMaxAmount)),\n39\t    requestedFrom: trimOrNull(readSingleValue(input.claimRequestedFrom)),\n40\t    requestedTo: trimOrNull(readSingleValue(input.claimRequestedTo)),\n41\t    txSignature: trimOrNull(readSingleValue(input.claimTxSignature)),\n42\t    errorContains: trimOrNull(readSingleValue(input.claimError)),\n43\t  };\n44\t}\n45\t"}]},"parent_tool_use_id":null,"session_id":"71b441dc-11ef-4d53-a5eb-e22ac2dfdbdf","uuid":"49bff34e-3ab3-4fbd-9a5a-861ffa85b14a","timestamp":"2026-04-26T07:42:54.781Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/growth-search-params.ts","content":"// URL-addressable filter params for /growth/referrals claims table (FR-7).\n//\n// Mirrors the engine `PeekReferralClaimFilters` shape and normalises raw\n// search-param input the page receives from Next.js. Empty / whitespace-only\n// values normalise to `null` so the engine query skips them; the `claimStatus`\n// \"failed\" value is a virtual alias the engine widens to `('failed','error')`.\n\nimport type { PeekReferralClaimFilters } from \"./types/peek\";\n\nexport const PEEK_REFERRAL_CLAIM_STATUSES: ReadonlyArray<string> = [\n  \"pending\",\n  \"processing\",\n  \"error\",\n  \"completed\",\n  \"failed\",\n];\n\nfunction readSingleValue(\n  value: string | string[] | undefined,\n): string {\n  return Array.isArray(value) ? value[0] ?? \"\" : value ?? \"\";\n}\n\nfunction trimOrNull(value: string): string | null {\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nexport function normalizeReferralClaimFiltersFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): PeekReferralClaimFilters {\n  const status = trimOrNull(readSingleValue(input.claimStatus));\n  return {\n    status:\n      status && PEEK_REFERRAL_CLAIM_STATUSES.includes(status) ? status : null,\n    userId: trimOrNull(readSingleValue(input.claimUserId)),\n    minAmountLamports: trimOrNull(readSingleValue(input.claimMinAmount)),\n    maxAmountLamports: trimOrNull(readSingleValue(input.claimMaxAmount)),\n    requestedFrom: trimOrNull(readSingleValue(input.claimRequestedFrom)),\n    requestedTo: trimOrNull(readSingleValue(input.claimRequestedTo)),\n    txSignature: trimOrNull(readSingleValue(input.claimTxSignature)),\n    errorContains: trimOrNull(readSingleValue(input.claimError)),\n  };\n}\n","numLines":45,"startLine":1,"totalLines":45}}}
