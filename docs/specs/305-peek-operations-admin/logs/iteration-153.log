{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019aJp7x54Jw9mx4jBmc6ZDD","type":"tool_result","content":"1\t// Fraud flags review table for /operations/dogpile (FR-9).\n2\t//\n3\t// Review queue over `PeekFraudFlagListRow` so an operator can scan open\n4\t// flags, jump to the user-detail page, and inspect the JSONB `details`\n5\t// payload verbatim. Status drives the chip tone (open = warning, reviewed =\n6\t// info, dismissed = neutral).\n7\t//\n8\t// FR-14 wiring: when `canTransitionFraudFlag` is true the table appends a\n9\t// \"Transition\" column rendering `FraudFlagMutationForm` per row. The form\n10\t// only exposes status transitions allowed by the FR-14 matrix; rows whose\n11\t// current status has no allowed next status render an empty cell.\n12\timport Link from \"next/link\";\n13\timport type { CSSProperties } from \"react\";\n14\timport type {\n15\t  PeekFraudFlagListRow,\n16\t  PeekStatusTone,\n17\t} from \"../lib/types/peek\";\n18\timport { FraudFlagMutationForm } from \"./mutations/fraud-flag-mutation-form\";\n19\timport { StatusChip } from \"./status-chip\";\n20\t\n21\texport type FraudFlagsTableProps = {\n22\t  rows: ReadonlyArray<PeekFraudFlagListRow>;\n23\t  error?: string | null;\n24\t  canTransitionFraudFlag?: boolean;\n25\t};\n26\t\n27\texport function FraudFlagsTable({\n28\t  rows,\n29\t  error = null,\n30\t  canTransitionFraudFlag = false,\n31\t}: FraudFlagsTableProps) {\n32\t  if (error) {\n33\t    return (\n34\t      <div role=\"alert\" style={errorStyle}>\n35\t        Fraud flags unavailable: {error}\n36\t      </div>\n37\t    );\n38\t  }\n39\t\n40\t  if (rows.length === 0) {\n41\t    return (\n42\t      <div role=\"status\" style={emptyStyle}>\n43\t        <p style={emptyTitleStyle}>\n44\t          No fraud_flags rows match these filters.\n45\t        </p>\n46\t        <p style={emptyBodyStyle}>\n47\t          Adjust the filters above or clear them to see open, reviewed, and\n48\t          dismissed flags.\n49\t        </p>\n50\t      </div>\n51\t    );\n52\t  }\n53\t\n54\t  return (\n55\t    <div style={wrapperStyle}>\n56\t      <table style={tableStyle}>\n57\t        <thead>\n58\t          <tr style={headerRowStyle}>\n59\t            <th style={headerCellStyle(\"left\")}>Status</th>\n60\t            <th style={headerCellStyle(\"left\")}>Flag type</th>\n61\t            <th style={headerCellStyle(\"left\")}>User</th>\n62\t            <th style={headerCellStyle(\"left\")}>Wallet</th>\n63\t            <th style={headerCellStyle(\"left\")}>Related</th>\n64\t            <th style={headerCellStyle(\"left\")}>Details</th>\n65\t            <th style={headerCellStyle(\"left\")}>Created</th>\n66\t            <th style={headerCellStyle(\"left\")}>Resolved</th>\n67\t            <th style={headerCellStyle(\"left\")}>ID</th>\n68\t            {canTransitionFraudFlag ? (\n69\t              <th style={headerCellStyle(\"left\")}>Transition</th>\n70\t            ) : null}\n71\t          </tr>\n72\t        </thead>\n73\t        <tbody>\n74\t          {rows.map((row) => (\n75\t            <tr key={row.id} style={bodyRowStyle}>\n76\t              <td style={bodyCellStyle(\"left\")}>\n77\t                <StatusChip\n78\t                  label={row.status}\n79\t                  tone={fraudStatusTone(row.status)}\n80\t                />\n81\t              </td>\n82\t              <td\n83\t                style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n84\t              >\n85\t                {row.flagType}\n86\t              </td>\n87\t              <td style={bodyCellStyle(\"left\")}>\n88\t                <Link href={`/users/${row.userId}`} style={linkStyle}>\n89\t                  {row.username ?? row.userId}\n90\t                </Link>\n91\t                {row.username ? (\n92\t                  <div style={subValueStyle}>{row.userId}</div>\n93\t                ) : null}\n94\t              </td>\n95\t              <td\n96\t                style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n97\t              >\n98\t                {row.wallet ?? \"—\"}\n99\t              </td>\n100\t              <td\n101\t                style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n102\t              >\n103\t                {row.relatedId ?? \"—\"}\n104\t              </td>\n105\t              <td style={bodyCellStyle(\"left\")}>\n106\t                {row.details ? (\n107\t                  <pre style={detailsStyle}>\n108\t                    {JSON.stringify(row.details, null, 2)}\n109\t                  </pre>\n110\t                ) : (\n111\t                  \"—\"\n112\t                )}\n113\t              </td>\n114\t              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n115\t              <td style={bodyCellStyle(\"left\")}>{row.resolvedAt ?? \"—\"}</td>\n116\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n117\t                {row.id}\n118\t              </td>\n119\t              {canTransitionFraudFlag ? (\n120\t                <td style={bodyCellStyle(\"left\")}>\n121\t                  <FraudFlagMutationForm\n122\t                    flagId={row.id}\n123\t                    currentStatus={row.status}\n124\t                  />\n125\t                </td>\n126\t              ) : null}\n127\t            </tr>\n128\t          ))}\n129\t        </tbody>\n130\t      </table>\n131\t    </div>\n132\t  );\n133\t}\n134\t\n135\tfunction fraudStatusTone(value: string): PeekStatusTone {\n136\t  if (value === \"open\") return \"warning\";\n137\t  if (value === \"reviewed\") return \"info\";\n138\t  if (value === \"dismissed\") return \"neutral\";\n139\t  return \"neutral\";\n140\t}\n141\t\n142\tconst wrapperStyle: CSSProperties = {\n143\t  overflowX: \"auto\",\n144\t  border: \"1px solid #1e293b\",\n145\t  borderRadius: \"0.75rem\",\n146\t};\n147\t\n148\tconst tableStyle: CSSProperties = {\n149\t  width: \"100%\",\n150\t  borderCollapse: \"collapse\",\n151\t};\n152\t\n153\tconst headerRowStyle: CSSProperties = {\n154\t  background: \"#111827\",\n155\t  color: \"#94a3b8\",\n156\t};\n157\t\n158\tconst bodyRowStyle: CSSProperties = {\n159\t  borderTop: \"1px solid #1e293b\",\n160\t};\n161\t\n162\tconst linkStyle: CSSProperties = {\n163\t  color: \"#93c5fd\",\n164\t  textDecoration: \"none\",\n165\t};\n166\t\n167\tconst subValueStyle: CSSProperties = {\n168\t  color: \"#64748b\",\n169\t  fontSize: \"0.75rem\",\n170\t};\n171\t\n172\tconst detailsStyle: CSSProperties = {\n173\t  margin: 0,\n174\t  padding: \"0.5rem\",\n175\t  borderRadius: \"0.5rem\",\n176\t  background: \"#0b1220\",\n177\t  color: \"#cbd5f5\",\n178\t  fontSize: \"0.75rem\",\n179\t  fontFamily: \"monospace\",\n180\t  whiteSpace: \"pre-wrap\",\n181\t  wordBreak: \"break-word\",\n182\t  maxWidth: \"24rem\",\n183\t};\n184\t\n185\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n186\t  return {\n187\t    padding: \"0.75rem\",\n188\t    textAlign: align,\n189\t    fontSize: \"0.875rem\",\n190\t    fontWeight: 600,\n191\t  };\n192\t}\n193\t\n194\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n195\t  return {\n196\t    padding: \"0.75rem\",\n197\t    textAlign: align,\n198\t    fontSize: \"0.875rem\",\n199\t    color: \"#e2e8f0\",\n200\t    verticalAlign: \"top\",\n201\t  };\n202\t}\n203\t\n204\tconst errorStyle: CSSProperties = {\n205\t  margin: 0,\n206\t  padding: \"0.75rem 1rem\",\n207\t  borderRadius: \"0.75rem\",\n208\t  background: \"#3f1d1d\",\n209\t  color: \"#fecaca\",\n210\t};\n211\t\n212\tconst emptyStyle: CSSProperties = {\n213\t  padding: \"1.5rem\",\n214\t  borderRadius: \"0.75rem\",\n215\t  border: \"1px dashed #334155\",\n216\t  background: \"#0b1220\",\n217\t  color: \"#cbd5f5\",\n218\t  display: \"grid\",\n219\t  gap: \"0.5rem\",\n220\t};\n221\t\n222\tconst emptyTitleStyle: CSSProperties = {\n223\t  margin: 0,\n224\t  fontSize: \"1rem\",\n225\t  fontWeight: 600,\n226\t};\n227\t\n228\tconst emptyBodyStyle: CSSProperties = {\n229\t  margin: 0,\n230\t  fontSize: \"0.875rem\",\n231\t  color: \"#94a3b8\",\n232\t};\n233\t"}]},"parent_tool_use_id":null,"session_id":"65159f28-4138-4a00-8878-b10db9efe60e","uuid":"bd3adf9c-175b-4ef1-8271-26035356bab7","timestamp":"2026-04-26T19:45:29.764Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/fraud-flags-table.tsx","content":"// Fraud flags review table for /operations/dogpile (FR-9).\n//\n// Review queue over `PeekFraudFlagListRow` so an operator can scan open\n// flags, jump to the user-detail page, and inspect the JSONB `details`\n// payload verbatim. Status drives the chip tone (open = warning, reviewed =\n// info, dismissed = neutral).\n//\n// FR-14 wiring: when `canTransitionFraudFlag` is true the table appends a\n// \"Transition\" column rendering `FraudFlagMutationForm` per row. The form\n// only exposes status transitions allowed by the FR-14 matrix; rows whose\n// current status has no allowed next status render an empty cell.\nimport Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekFraudFlagListRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { FraudFlagMutationForm } from \"./mutations/fraud-flag-mutation-form\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type FraudFlagsTableProps = {\n  rows: ReadonlyArray<PeekFraudFlagListRow>;\n  error?: string | null;\n  canTransitionFraudFlag?: boolean;\n};\n\nexport function FraudFlagsTable({\n  rows,\n  error = null,\n  canTransitionFraudFlag = false,\n}: FraudFlagsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Fraud flags unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>\n          No fraud_flags rows match these filters.\n        </p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see open, reviewed, and\n          dismissed flags.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Status</th>\n            <th style={headerCellStyle(\"left\")}>Flag type</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"left\")}>Related</th>\n            <th style={headerCellStyle(\"left\")}>Details</th>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>Resolved</th>\n            <th style={headerCellStyle(\"left\")}>ID</th>\n            {canTransitionFraudFlag ? (\n              <th style={headerCellStyle(\"left\")}>Transition</th>\n            ) : null}\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.status}\n                  tone={fraudStatusTone(row.status)}\n                />\n              </td>\n              <td\n                style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n              >\n                {row.flagType}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <Link href={`/users/${row.userId}`} style={linkStyle}>\n                  {row.username ?? row.userId}\n                </Link>\n                {row.username ? (\n                  <div style={subValueStyle}>{row.userId}</div>\n                ) : null}\n              </td>\n              <td\n                style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n              >\n                {row.wallet ?? \"—\"}\n              </td>\n              <td\n                style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n              >\n                {row.relatedId ?? \"—\"}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                {row.details ? (\n                  <pre style={detailsStyle}>\n                    {JSON.stringify(row.details, null, 2)}\n                  </pre>\n                ) : (\n                  \"—\"\n                )}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>{row.resolvedAt ?? \"—\"}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.id}\n              </td>\n              {canTransitionFraudFlag ? (\n                <td style={bodyCellStyle(\"left\")}>\n                  <FraudFlagMutationForm\n                    flagId={row.id}\n                    currentStatus={row.status}\n                  />\n                </td>\n              ) : null}\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction fraudStatusTone(value: string): PeekStatusTone {\n  if (value === \"open\") return \"warning\";\n  if (value === \"reviewed\") return \"info\";\n  if (value === \"dismissed\") return \"neutral\";\n  return \"neutral\";\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n};\n\nconst detailsStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.5rem\",\n  borderRadius: \"0.5rem\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  fontSize: \"0.75rem\",\n  fontFamily: \"monospace\",\n  whiteSpace: \"pre-wrap\",\n  wordBreak: \"break-word\",\n  maxWidth: \"24rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":233,"startLine":1,"totalLines":233}}}
