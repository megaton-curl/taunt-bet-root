ue\")).toBeNull();\n    expect(\n      screen.queryByRole(\"form\", { name: \"Edit reward config value\" }),\n    ).toBeNull();\n  });\n\n  it(\"authorized success path: canEditRewardConfig with allowlisted keys renders the form only for rows whose key is in `editableKeys` AND whose expectedType is not 'unknown'\", () => {\n    render(\n      <RewardConfigTable\n        rows={[ROW_KNOWN, ROW_RATIO, ROW_UNKNOWN]}\n        canEditRewardConfig\n        editableKeys={[\"points_per_dollar\", \"experimental_unmapped_key\"]}\n      />,\n    );\n\n    // Column appears.\n    expect(\n      screen.getByRole(\"columnheader\", { name: \"Edit value\" }),\n    ).toBeInTheDocument();\n\n    // Only the allowlisted, registered key gets a form. The other allowlisted\n    // entry is `expectedType: \"unknown\"` and the runner would reject it on\n    // value validation, so the form is suppressed.\n    const forms = screen.getAllByRole(\"form\", {\n      name: \"Edit reward config value\",\n    });\n    expect(forms).toHaveLength(1);\n\n    // The form is the points_per_dollar row (current value 10).\n    expect(screen.getByText(\"old: 10\")).toBeInTheDocument();\n\n    // Ratio row would be valid by type but is not in `editableKeys`, so no form.\n    expect(screen.queryByText(\"old: 0.25\")).toBeNull();\n  });\n\n  it(\"authorized validation error display: the unknown-key warning continues to render so an operator can see why a key has no editor\", () => {\n    // Even when the actor is authorized, FR-14 keeps unregistered keys\n    // out of the editable surface — the registry hint must still render\n    // so an operator understands why the row offers no form.\n    render(\n      <RewardConfigTable\n        rows={[ROW_UNKNOWN]}\n        canEditRewardConfig\n        editableKeys={[\"experimental_unmapped_key\"]}\n      />,\n    );\n\n    expect(\n      screen.getByText(/Unregistered key — extend/i),\n    ).toBeInTheDocument();\n    expect(\n      screen.queryByRole(\"form\", { name: \"Edit reward config value\" }),\n    ).toBeNull();\n  });\n});","originalFile":"import { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { RewardConfigTable } from \"../reward-config-table\";\nimport type { PeekRewardConfigRow } from \"../../lib/types/peek\";\n\nconst ROW_KNOWN: PeekRewardConfigRow = {\n  key: \"points_per_dollar\",\n  value: \"10\",\n  updatedAt: \"2026-04-25T10:00:00.000Z\",\n  definition:\n    \"Points granted per USD-equivalent of wager — drives the wager → points conversion rate.\",\n  expectedType: \"integer\",\n};\n\nconst ROW_RATIO: PeekRewardConfigRow = {\n  key: \"reward_pool_fee_share\",\n  value: \"0.25\",\n  updatedAt: \"2026-04-25T10:00:00.000Z\",\n  definition:\n    \"Fraction of platform fee diverted into the reward pool on each settled round (0..1).\",\n  expectedType: \"ratio\",\n};\n\nconst ROW_UNKNOWN: PeekRewardConfigRow = {\n  key: \"experimental_unmapped_key\",\n  value: \"42\",\n  updatedAt: \"2026-04-25T10:00:00.000Z\",\n  definition: null,\n  expectedType: \"unknown\",\n};\n\ndescribe(\"RewardConfigTable\", () => {\n  it(\"populated: renders the operator columns, the type chip, the value, and the inline definition\", () => {\n    render(<RewardConfigTable rows={[ROW_KNOWN, ROW_RATIO]} />);\n\n    expect(screen.getByText(\"Key\")).toBeInTheDocument();\n    expect(screen.getByText(\"Type\")).toBeInTheDocument();\n    expect(screen.getByText(\"Value\")).toBeInTheDocument();\n    expect(screen.getByText(\"Definition\")).toBeInTheDocument();\n    expect(screen.getByText(\"Updated\")).toBeInTheDocument();\n\n    expect(screen.getByText(\"points_per_dollar\")).toBeInTheDocument();\n    expect(screen.getByText(\"reward_pool_fee_share\")).toBeInTheDocument();\n    expect(screen.getByText(\"integer\")).toBeInTheDocument();\n    expect(screen.getByText(\"ratio\")).toBeInTheDocument();\n    expect(screen.getByText(\"10\")).toBeInTheDocument();\n    expect(screen.getByText(\"0.25\")).toBeInTheDocument();\n    expect(\n      screen.getByText(\n        \"Points granted per USD-equivalent of wager — drives the wager → points conversion rate.\",\n      ),\n    ).toBeInTheDocument();\n  });\n\n  it(\"populated: an unknown key surfaces the warning hint instead of faking a definition\", () => {\n    render(<RewardConfigTable rows={[ROW_UNKNOWN]} />);\n\n    expect(screen.getByText(\"experimental_unmapped_key\")).toBeInTheDocument();\n    expect(screen.getByText(\"unknown\")).toBeInTheDocument();\n    expect(\n      screen.getByText(/Unregistered key — extend/i),\n    ).toBeInTheDocument();\n    // The hint mentions the registry symbol so an operator knows where to add the entry.\n    expect(\n      screen.getByText(/PEEK_REWARD_CONFIG_KEY_REGISTRY/i),\n    ).toBeInTheDocument();\n  });\n\n  it(\"empty: renders an operator status block when no reward_config rows exist\", () => {\n    render(<RewardConfigTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"No reward_config rows.\");\n    expect(status).toHaveTextContent(\"reward_config\");\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert message and hides both the table and the empty status\", () => {\n    render(\n      <RewardConfigTable rows={[ROW_KNOWN]} error=\"connection refused\" />,\n    );\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Reward config unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n","structuredPatch":[{"oldStart":86,"oldLines":4,"newStart":86,"newLines":66,"lines":["     expect(screen.queryByRole(\"table\")).toBeNull();","     expect(screen.queryByRole(\"status\")).toBeNull();","   });","+","+  // FR-14 mutation UI — column visibility is gated by `canEditRewardConfig`,","+  // computed at the page level via `isActionAllowedForRole(\"reward_config.update\", actor.role)`,","+  // and per-row visibility is additionally gated by the FR-14 allowlist","+  // (`PEEK_REWARD_CONFIG_EDITABLE_KEYS`) and the row's `expectedType`.","+  it(\"denied actor hidden: defaults to no 'Edit value' column and renders no edit forms\", () => {","+    render(<RewardConfigTable rows={[ROW_KNOWN, ROW_RATIO, ROW_UNKNOWN]} />);","+","+    expect(screen.queryByText(\"Edit value\")).toBeNull();","+    expect(","+      screen.queryByRole(\"form\", { name: \"Edit reward config value\" }),","+    ).toBeNull();","+  });","+","+  it(\"authorized success path: canEditRewardConfig with allowlisted keys renders the form only for rows whose key is in `editableKeys` AND whose expectedType is not 'unknown'\", () => {","+    render(","+      <RewardConfigTable","+        rows={[ROW_KNOWN, ROW_RATIO, ROW_UNKNOWN]}","+        canEditRewardConfig","+        editableKeys={[\"points_per_dollar\", \"experimental_unmapped_key\"]}","+      />,","+    );","+","+    // Column appears.","+    expect(","+      screen.getByRole(\"columnheader\", { name: \"Edit value\" }),","+    ).toBeInTheDocument();","+","+    // Only the allowlisted, registered key gets a form. The other allowlisted","+    // entry is `expectedType: \"unknown\"` and the runner would reject it on","+    // value validation, so the form is suppressed.","+    const forms = screen.getAllByRole(\"form\", {","+      name: \"Edit reward config value\",","+    });","+    expect(forms).toHaveLength(1);","+","+    // The form is the points_per_dollar row (current value 10).","+    expect(screen.getByText(\"old: 10\")).toBeInTheDocument();","+","+    // Ratio row would be valid by type but is not in `editableKeys`, so no form.","+    expect(screen.queryByText(\"old: 0.25\")).toBeNull();","+  });","+","+  it(\"authorized validation error display: the unknown-key warning continues to render so an operator can see why a key has no editor\", () => {","+    // Even when the actor is authorized, FR-14 keeps unregistered keys","+    // out of the editable surface — the registry hint must still render","+    // so an operator understands why the row offers no form.","+    render(","+      <RewardConfigTable","+        rows={[ROW_UNKNOWN]}","+        canEditRewardConfig","+        editableKeys={[\"experimental_unmapped_key\"]}","+      />,","+    );","+","+    expect(","+      screen.getByText(/Unregistered key — extend/i),","+    ).toBeInTheDocument();","+    expect(","+      screen.queryByRole(\"form\", { name: \"Edit reward config value\" }),","+    ).toBeNull();","+  });"," });"]}],"userModified":false,"replaceAll":false}}
