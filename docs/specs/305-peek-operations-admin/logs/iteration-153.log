{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HCbVhPYKSrPDe9TRLTSQpp","type":"tool_result","content":"1\t// Component tests for the FR-9 dogpile events table.\n2\t//\n3\t// Read-only by spec — every dogpile mutation lives behind the FR-14\n4\t// `dogpile.cancel` action id (declared in `peek/src/server/access-policy.ts`,\n5\t// not yet implemented). These tests assert there are no edit affordances\n6\t// rendered (no buttons, no editable inputs) and that the status chip switches\n7\t// tone for every lifecycle state.\n8\t\n9\timport { describe, expect, it } from \"vitest\";\n10\timport { render, screen } from \"@testing-library/react\";\n11\timport { DogpileEventsTable } from \"../dogpile-events-table\";\n12\timport type { PeekDogpileEventRow } from \"../../lib/types/peek\";\n13\t\n14\tconst ROW_SCHEDULED: PeekDogpileEventRow = {\n15\t  id: \"1\",\n16\t  campaignId: \"c-1\",\n17\t  campaignName: \"Bull-run dogpile\",\n18\t  campaignType: \"dogpile\",\n19\t  startsAt: \"2026-04-26T10:00:00.000Z\",\n20\t  endsAt: \"2026-04-26T12:00:00.000Z\",\n21\t  multiplier: \"2.5\",\n22\t  status: \"scheduled\",\n23\t  createdAt: \"2026-04-26T09:00:00.000Z\",\n24\t  gameEntryCount: 0,\n25\t  pointGrantCount: 0,\n26\t};\n27\t\n28\tconst ROW_ACTIVE: PeekDogpileEventRow = {\n29\t  id: \"2\",\n30\t  campaignId: \"c-2\",\n31\t  campaignName: \"Weekend ramp\",\n32\t  campaignType: \"dogpile\",\n33\t  startsAt: \"2026-04-26T08:00:00.000Z\",\n34\t  endsAt: \"2026-04-26T20:00:00.000Z\",\n35\t  multiplier: \"1.5\",\n36\t  status: \"active\",\n37\t  createdAt: \"2026-04-26T07:30:00.000Z\",\n38\t  gameEntryCount: 1234,\n39\t  pointGrantCount: 5678,\n40\t};\n41\t\n42\tconst ROW_ENDED: PeekDogpileEventRow = {\n43\t  id: \"3\",\n44\t  campaignId: null,\n45\t  campaignName: null,\n46\t  campaignType: null,\n47\t  startsAt: \"2026-04-25T10:00:00.000Z\",\n48\t  endsAt: \"2026-04-25T12:00:00.000Z\",\n49\t  multiplier: \"3.0\",\n50\t  status: \"ended\",\n51\t  createdAt: \"2026-04-25T09:00:00.000Z\",\n52\t  gameEntryCount: 42,\n53\t  pointGrantCount: 99,\n54\t};\n55\t\n56\tconst ROW_CANCELLED: PeekDogpileEventRow = {\n57\t  id: \"4\",\n58\t  campaignId: \"c-4\",\n59\t  campaignName: \"Cancelled experiment\",\n60\t  campaignType: \"dogpile\",\n61\t  startsAt: \"2026-04-27T10:00:00.000Z\",\n62\t  endsAt: \"2026-04-27T12:00:00.000Z\",\n63\t  multiplier: \"2.0\",\n64\t  status: \"cancelled\",\n65\t  createdAt: \"2026-04-26T09:00:00.000Z\",\n66\t  gameEntryCount: 0,\n67\t  pointGrantCount: 0,\n68\t};\n69\t\n70\tdescribe(\"DogpileEventsTable\", () => {\n71\t  it(\"populated: renders the operator columns and every lifecycle status chip\", () => {\n72\t    render(\n73\t      <DogpileEventsTable\n74\t        rows={[ROW_SCHEDULED, ROW_ACTIVE, ROW_ENDED, ROW_CANCELLED]}\n75\t      />,\n76\t    );\n77\t\n78\t    for (const header of [\n79\t      \"Status\",\n80\t      \"Campaign\",\n81\t      \"Starts\",\n82\t      \"Ends\",\n83\t      \"Multiplier\",\n84\t      \"Game entries\",\n85\t      \"Point grants\",\n86\t      \"Created\",\n87\t      \"ID\",\n88\t    ]) {\n89\t      expect(screen.getByText(header)).toBeInTheDocument();\n90\t    }\n91\t\n92\t    // State transition coverage: one chip per lifecycle state.\n93\t    expect(screen.getByText(\"scheduled\")).toBeInTheDocument();\n94\t    expect(screen.getByText(\"active\")).toBeInTheDocument();\n95\t    expect(screen.getByText(\"ended\")).toBeInTheDocument();\n96\t    expect(screen.getByText(\"cancelled\")).toBeInTheDocument();\n97\t  });\n98\t\n99\t  it(\"populated: counts use thousands separators and multiplier renders with the × suffix\", () => {\n100\t    render(<DogpileEventsTable rows={[ROW_ACTIVE]} />);\n101\t\n102\t    expect(screen.getByText(\"1,234\")).toBeInTheDocument();\n103\t    expect(screen.getByText(\"5,678\")).toBeInTheDocument();\n104\t    expect(screen.getByText(\"1.5×\")).toBeInTheDocument();\n105\t  });\n106\t\n107\t  it(\"populated: nullable campaign columns render '—' for the campaign cell\", () => {\n108\t    render(<DogpileEventsTable rows={[ROW_ENDED]} />);\n109\t\n110\t    // Campaign cell renders a single em-dash when the join is sparse.\n111\t    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(1);\n112\t    // No campaign name / type / id fragments leak into the row.\n113\t    expect(screen.queryByText(\"c-3\")).toBeNull();\n114\t  });\n115\t\n116\t  it(\"populated: campaign cell shows name, type, and id when the join hits\", () => {\n117\t    render(<DogpileEventsTable rows={[ROW_ACTIVE]} />);\n118\t\n119\t    expect(screen.getByText(\"Weekend ramp\")).toBeInTheDocument();\n120\t    expect(screen.getByText(\"dogpile\")).toBeInTheDocument();\n121\t    expect(screen.getByText(\"c-2\")).toBeInTheDocument();\n122\t  });\n123\t\n124\t  it(\"read-only: no edit affordances rendered (no buttons, no editable inputs, no checkboxes)\", () => {\n125\t    // FR-14 keeps every dogpile mutation behind `dogpile.cancel`. The table\n126\t    // must not render a cancel button or any other mutating control.\n127\t    render(\n128\t      <DogpileEventsTable\n129\t        rows={[ROW_SCHEDULED, ROW_ACTIVE, ROW_ENDED, ROW_CANCELLED]}\n130\t      />,\n131\t    );\n132\t\n133\t    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n134\t    expect(screen.queryByRole(\"textbox\")).toBeNull();\n135\t    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n136\t    expect(screen.queryByRole(\"link\")).toBeNull();\n137\t  });\n138\t\n139\t  it(\"empty: renders the operator status block when no events exist\", () => {\n140\t    render(<DogpileEventsTable rows={[]} />);\n141\t\n142\t    const status = screen.getByRole(\"status\");\n143\t    expect(status).toHaveTextContent(\n144\t      \"No dogpile_events rows match these filters.\",\n145\t    );\n146\t    expect(screen.queryByRole(\"table\")).toBeNull();\n147\t  });\n148\t\n149\t  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n150\t    render(\n151\t      <DogpileEventsTable\n152\t        rows={[ROW_SCHEDULED]}\n153\t        error=\"connection refused\"\n154\t      />,\n155\t    );\n156\t\n157\t    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n158\t      \"Dogpile events unavailable: connection refused\",\n159\t    );\n160\t    expect(screen.queryByRole(\"table\")).toBeNull();\n161\t    expect(screen.queryByRole(\"status\")).toBeNull();\n162\t  });\n163\t});\n164\t"}]},"parent_tool_use_id":null,"session_id":"65159f28-4138-4a00-8878-b10db9efe60e","uuid":"1bb111c8-781f-42fb-8cc8-8d73cf4034d2","timestamp":"2026-04-26T19:45:39.275Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/dogpile-events-table.test.tsx","content":"// Component tests for the FR-9 dogpile events table.\n//\n// Read-only by spec — every dogpile mutation lives behind the FR-14\n// `dogpile.cancel` action id (declared in `peek/src/server/access-policy.ts`,\n// not yet implemented). These tests assert there are no edit affordances\n// rendered (no buttons, no editable inputs) and that the status chip switches\n// tone for every lifecycle state.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { DogpileEventsTable } from \"../dogpile-events-table\";\nimport type { PeekDogpileEventRow } from \"../../lib/types/peek\";\n\nconst ROW_SCHEDULED: PeekDogpileEventRow = {\n  id: \"1\",\n  campaignId: \"c-1\",\n  campaignName: \"Bull-run dogpile\",\n  campaignType: \"dogpile\",\n  startsAt: \"2026-04-26T10:00:00.000Z\",\n  endsAt: \"2026-04-26T12:00:00.000Z\",\n  multiplier: \"2.5\",\n  status: \"scheduled\",\n  createdAt: \"2026-04-26T09:00:00.000Z\",\n  gameEntryCount: 0,\n  pointGrantCount: 0,\n};\n\nconst ROW_ACTIVE: PeekDogpileEventRow = {\n  id: \"2\",\n  campaignId: \"c-2\",\n  campaignName: \"Weekend ramp\",\n  campaignType: \"dogpile\",\n  startsAt: \"2026-04-26T08:00:00.000Z\",\n  endsAt: \"2026-04-26T20:00:00.000Z\",\n  multiplier: \"1.5\",\n  status: \"active\",\n  createdAt: \"2026-04-26T07:30:00.000Z\",\n  gameEntryCount: 1234,\n  pointGrantCount: 5678,\n};\n\nconst ROW_ENDED: PeekDogpileEventRow = {\n  id: \"3\",\n  campaignId: null,\n  campaignName: null,\n  campaignType: null,\n  startsAt: \"2026-04-25T10:00:00.000Z\",\n  endsAt: \"2026-04-25T12:00:00.000Z\",\n  multiplier: \"3.0\",\n  status: \"ended\",\n  createdAt: \"2026-04-25T09:00:00.000Z\",\n  gameEntryCount: 42,\n  pointGrantCount: 99,\n};\n\nconst ROW_CANCELLED: PeekDogpileEventRow = {\n  id: \"4\",\n  campaignId: \"c-4\",\n  campaignName: \"Cancelled experiment\",\n  campaignType: \"dogpile\",\n  startsAt: \"2026-04-27T10:00:00.000Z\",\n  endsAt: \"2026-04-27T12:00:00.000Z\",\n  multiplier: \"2.0\",\n  status: \"cancelled\",\n  createdAt: \"2026-04-26T09:00:00.000Z\",\n  gameEntryCount: 0,\n  pointGrantCount: 0,\n};\n\ndescribe(\"DogpileEventsTable\", () => {\n  it(\"populated: renders the operator columns and every lifecycle status chip\", () => {\n    render(\n      <DogpileEventsTable\n        rows={[ROW_SCHEDULED, ROW_ACTIVE, ROW_ENDED, ROW_CANCELLED]}\n      />,\n    );\n\n    for (const header of [\n      \"Status\",\n      \"Campaign\",\n      \"Starts\",\n      \"Ends\",\n      \"Multiplier\",\n      \"Game entries\",\n      \"Point grants\",\n      \"Created\",\n      \"ID\",\n    ]) {\n      expect(screen.getByText(header)).toBeInTheDocument();\n    }\n\n    // State transition coverage: one chip per lifecycle state.\n    expect(screen.getByText(\"scheduled\")).toBeInTheDocument();\n    expect(screen.getByText(\"active\")).toBeInTheDocument();\n    expect(screen.getByText(\"ended\")).toBeInTheDocument();\n    expect(screen.getByText(\"cancelled\")).toBeInTheDocument();\n  });\n\n  it(\"populated: counts use thousands separators and multiplier renders with the × suffix\", () => {\n    render(<DogpileEventsTable rows={[ROW_ACTIVE]} />);\n\n    expect(screen.getByText(\"1,234\")).toBeInTheDocument();\n    expect(screen.getByText(\"5,678\")).toBeInTheDocument();\n    expect(screen.getByText(\"1.5×\")).toBeInTheDocument();\n  });\n\n  it(\"populated: nullable campaign columns render '—' for the campaign cell\", () => {\n    render(<DogpileEventsTable rows={[ROW_ENDED]} />);\n\n    // Campaign cell renders a single em-dash when the join is sparse.\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(1);\n    // No campaign name / type / id fragments leak into the row.\n    expect(screen.queryByText(\"c-3\")).toBeNull();\n  });\n\n  it(\"populated: campaign cell shows name, type, and id when the join hits\", () => {\n    render(<DogpileEventsTable rows={[ROW_ACTIVE]} />);\n\n    expect(screen.getByText(\"Weekend ramp\")).toBeInTheDocument();\n    expect(screen.getByText(\"dogpile\")).toBeInTheDocument();\n    expect(screen.getByText(\"c-2\")).toBeInTheDocument();\n  });\n\n  it(\"read-only: no edit affordances rendered (no buttons, no editable inputs, no checkboxes)\", () => {\n    // FR-14 keeps every dogpile mutation behind `dogpile.cancel`. The table\n    // must not render a cancel button or any other mutating control.\n    render(\n      <DogpileEventsTable\n        rows={[ROW_SCHEDULED, ROW_ACTIVE, ROW_ENDED, ROW_CANCELLED]}\n      />,\n    );\n\n    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n    expect(screen.queryByRole(\"textbox\")).toBeNull();\n    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n    expect(screen.queryByRole(\"link\")).toBeNull();\n  });\n\n  it(\"empty: renders the operator status block when no events exist\", () => {\n    render(<DogpileEventsTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\n      \"No dogpile_events rows match these filters.\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n    render(\n      <DogpileEventsTable\n        rows={[ROW_SCHEDULED]}\n        error=\"connection refused\"\n      />,\n    );\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Dogpile events unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n","numLines":164,"startLine":1,"totalLines":164}}}
