{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K8tfShk5rKjt7F7Qi1Hw73","type":"tool_result","content":"1\t// FR-14 mutation form: transition a `fraud_flags.status` row.\n2\t//\n3\t// Rendered inline in `fraud-flags-table.tsx` for admin actors. The form\n4\t// reflects the FR-14 allowed-transition matrix client-side so the\n5\t// operator can only request a target status that the server will\n6\t// actually accept. The set of options is derived from the row's current\n7\t// `status`; if the matrix offers no admissible next status (no row\n8\t// currently does, but the contract permits it) the form renders nothing\n9\t// rather than expose a misleading control.\n10\t\n11\t\"use client\";\n12\t\n13\timport type { CSSProperties } from \"react\";\n14\timport { useActionState, useId } from \"react\";\n15\timport {\n16\t  PEEK_MUTATION_INITIAL_STATE,\n17\t  fraudFlagStatusUpdateAction,\n18\t} from \"../../server/actions/peek-mutations\";\n19\timport { MutationFeedback } from \"./mutation-feedback\";\n20\t\n21\ttype FraudFlagStatus = \"open\" | \"reviewed\" | \"dismissed\";\n22\t\n23\tconst ALLOWED_NEXT: Readonly<Record<FraudFlagStatus, ReadonlyArray<FraudFlagStatus>>> =\n24\t  Object.freeze({\n25\t    open: [\"reviewed\", \"dismissed\"],\n26\t    reviewed: [\"open\", \"dismissed\"],\n27\t    dismissed: [\"open\"],\n28\t  });\n29\t\n30\texport type FraudFlagMutationFormProps = {\n31\t  flagId: string;\n32\t  currentStatus: string;\n33\t};\n34\t\n35\tfunction isFraudFlagStatus(value: string): value is FraudFlagStatus {\n36\t  return value === \"open\" || value === \"reviewed\" || value === \"dismissed\";\n37\t}\n38\t\n39\texport function FraudFlagMutationForm({\n40\t  flagId,\n41\t  currentStatus,\n42\t}: FraudFlagMutationFormProps) {\n43\t  const [state, dispatch, pending] = useActionState(\n44\t    fraudFlagStatusUpdateAction,\n45\t    PEEK_MUTATION_INITIAL_STATE,\n46\t  );\n47\t  const selectId = useId();\n48\t\n49\t  if (!isFraudFlagStatus(currentStatus)) {\n50\t    return null;\n51\t  }\n52\t\n53\t  const options = ALLOWED_NEXT[currentStatus];\n54\t  if (options.length === 0) return null;\n55\t\n56\t  return (\n57\t    <form\n58\t      action={dispatch}\n59\t      style={formStyle}\n60\t      aria-label=\"Transition fraud flag status\"\n61\t    >\n62\t      <input type=\"hidden\" name=\"flagId\" value={flagId} />\n63\t\n64\t      <div style={fieldRowStyle}>\n65\t        <label htmlFor={selectId} style={labelStyle}>\n66\t          Next status\n67\t        </label>\n68\t        <div style={oldValueStyle}>old: {currentStatus}</div>\n69\t        <select\n70\t          id={selectId}\n71\t          name=\"nextStatus\"\n72\t          required\n73\t          defaultValue={options[0]}\n74\t          style={inputStyle}\n75\t        >\n76\t          {options.map((opt) => (\n77\t            <option key={opt} value={opt}>\n78\t              {opt}\n79\t            </option>\n80\t          ))}\n81\t        </select>\n82\t      </div>\n83\t\n84\t      <button type=\"submit\" disabled={pending} style={submitStyle}>\n85\t        {pending ? \"Applying…\" : \"Apply status change\"}\n86\t      </button>\n87\t\n88\t      <MutationFeedback state={state} successLabel=\"Fraud flag updated.\" />\n89\t    </form>\n90\t  );\n91\t}\n92\t\n93\tconst formStyle: CSSProperties = {\n94\t  display: \"grid\",\n95\t  gap: \"0.5rem\",\n96\t};\n97\t\n98\tconst fieldRowStyle: CSSProperties = {\n99\t  display: \"grid\",\n100\t  gap: \"0.25rem\",\n101\t};\n102\t\n103\tconst labelStyle: CSSProperties = {\n104\t  fontSize: \"0.75rem\",\n105\t  textTransform: \"uppercase\",\n106\t  letterSpacing: \"0.05em\",\n107\t  color: \"#94a3b8\",\n108\t};\n109\t\n110\tconst oldValueStyle: CSSProperties = {\n111\t  fontSize: \"0.75rem\",\n112\t  color: \"#64748b\",\n113\t  fontFamily: \"monospace\",\n114\t};\n115\t\n116\tconst inputStyle: CSSProperties = {\n117\t  padding: \"0.375rem 0.5rem\",\n118\t  borderRadius: \"0.375rem\",\n119\t  border: \"1px solid #334155\",\n120\t  background: \"#0f172a\",\n121\t  color: \"#e2e8f0\",\n122\t  fontSize: \"0.8125rem\",\n123\t  fontFamily: \"monospace\",\n124\t};\n125\t\n126\tconst submitStyle: CSSProperties = {\n127\t  padding: \"0.375rem 0.75rem\",\n128\t  borderRadius: \"0.375rem\",\n129\t  border: \"1px solid #1e3a8a\",\n130\t  background: \"#1e40af\",\n131\t  color: \"#dbeafe\",\n132\t  fontSize: \"0.8125rem\",\n133\t  fontWeight: 600,\n134\t  cursor: \"pointer\",\n135\t};\n136\t"}]},"parent_tool_use_id":null,"session_id":"65159f28-4138-4a00-8878-b10db9efe60e","uuid":"4c10a49a-66fe-4420-aaa6-b32ab18a2185","timestamp":"2026-04-26T19:45:12.188Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/mutations/fraud-flag-mutation-form.tsx","content":"// FR-14 mutation form: transition a `fraud_flags.status` row.\n//\n// Rendered inline in `fraud-flags-table.tsx` for admin actors. The form\n// reflects the FR-14 allowed-transition matrix client-side so the\n// operator can only request a target status that the server will\n// actually accept. The set of options is derived from the row's current\n// `status`; if the matrix offers no admissible next status (no row\n// currently does, but the contract permits it) the form renders nothing\n// rather than expose a misleading control.\n\n\"use client\";\n\nimport type { CSSProperties } from \"react\";\nimport { useActionState, useId } from \"react\";\nimport {\n  PEEK_MUTATION_INITIAL_STATE,\n  fraudFlagStatusUpdateAction,\n} from \"../../server/actions/peek-mutations\";\nimport { MutationFeedback } from \"./mutation-feedback\";\n\ntype FraudFlagStatus = \"open\" | \"reviewed\" | \"dismissed\";\n\nconst ALLOWED_NEXT: Readonly<Record<FraudFlagStatus, ReadonlyArray<FraudFlagStatus>>> =\n  Object.freeze({\n    open: [\"reviewed\", \"dismissed\"],\n    reviewed: [\"open\", \"dismissed\"],\n    dismissed: [\"open\"],\n  });\n\nexport type FraudFlagMutationFormProps = {\n  flagId: string;\n  currentStatus: string;\n};\n\nfunction isFraudFlagStatus(value: string): value is FraudFlagStatus {\n  return value === \"open\" || value === \"reviewed\" || value === \"dismissed\";\n}\n\nexport function FraudFlagMutationForm({\n  flagId,\n  currentStatus,\n}: FraudFlagMutationFormProps) {\n  const [state, dispatch, pending] = useActionState(\n    fraudFlagStatusUpdateAction,\n    PEEK_MUTATION_INITIAL_STATE,\n  );\n  const selectId = useId();\n\n  if (!isFraudFlagStatus(currentStatus)) {\n    return null;\n  }\n\n  const options = ALLOWED_NEXT[currentStatus];\n  if (options.length === 0) return null;\n\n  return (\n    <form\n      action={dispatch}\n      style={formStyle}\n      aria-label=\"Transition fraud flag status\"\n    >\n      <input type=\"hidden\" name=\"flagId\" value={flagId} />\n\n      <div style={fieldRowStyle}>\n        <label htmlFor={selectId} style={labelStyle}>\n          Next status\n        </label>\n        <div style={oldValueStyle}>old: {currentStatus}</div>\n        <select\n          id={selectId}\n          name=\"nextStatus\"\n          required\n          defaultValue={options[0]}\n          style={inputStyle}\n        >\n          {options.map((opt) => (\n            <option key={opt} value={opt}>\n              {opt}\n            </option>\n          ))}\n        </select>\n      </div>\n\n      <button type=\"submit\" disabled={pending} style={submitStyle}>\n        {pending ? \"Applying…\" : \"Apply status change\"}\n      </button>\n\n      <MutationFeedback state={state} successLabel=\"Fraud flag updated.\" />\n    </form>\n  );\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst fieldRowStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst labelStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n  color: \"#94a3b8\",\n};\n\nconst oldValueStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  color: \"#64748b\",\n  fontFamily: \"monospace\",\n};\n\nconst inputStyle: CSSProperties = {\n  padding: \"0.375rem 0.5rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #334155\",\n  background: \"#0f172a\",\n  color: \"#e2e8f0\",\n  fontSize: \"0.8125rem\",\n  fontFamily: \"monospace\",\n};\n\nconst submitStyle: CSSProperties = {\n  padding: \"0.375rem 0.75rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #1e3a8a\",\n  background: \"#1e40af\",\n  color: \"#dbeafe\",\n  fontSize: \"0.8125rem\",\n  fontWeight: 600,\n  cursor: \"pointer\",\n};\n","numLines":136,"startLine":1,"totalLines":136}}}
