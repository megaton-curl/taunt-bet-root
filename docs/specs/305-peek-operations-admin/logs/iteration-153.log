{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01Fu46TLrp1sETV8Zk2BkMcb","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011WiQvL32WeXM9u47zN59ue","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/mutations/__tests__/dogpile-cancel-mutation-form.test.tsx","content":"// FR-14 mutation UI — DogpileCancelMutationForm rendered structure.\n//\n// The runner accepts cancellation only for rows whose status is exactly\n// `scheduled` (active/ended/cancelled rows are denied with state guards).\n// The form mirrors that contract: it renders the cancel control only for\n// `scheduled` rows, and renders nothing for every other status so the\n// operator cannot offer a request the engine will reject.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { DogpileCancelMutationForm } from \"../dogpile-cancel-mutation-form\";\n\ndescribe(\"DogpileCancelMutationForm\", () => {\n  it(\"authorized scheduled row: renders the scheduled → cancelled diff, the cancel button, and the hidden eventId\", () => {\n    const { container } = render(\n      <DogpileCancelMutationForm\n        eventId=\"dpe-1\"\n        currentStatus=\"scheduled\"\n      />,\n    );\n\n    expect(\n      screen.getByRole(\"form\", { name: \"Cancel scheduled dogpile event\" }),\n    ).toBeInTheDocument();\n\n    // Old/new diff is visible so the operator confirms the implicit transition.\n    expect(screen.getByText(\"scheduled\")).toBeInTheDocument();\n    expect(screen.getByText(\"cancelled\")).toBeInTheDocument();\n    expect(screen.getByText(\"→\")).toBeInTheDocument();\n\n    const submit = screen.getByRole(\"button\", {\n      name: \"Cancel scheduled event\",\n    });\n    expect(submit).toHaveAttribute(\"type\", \"submit\");\n    expect(submit).not.toBeDisabled();\n\n    const hidden = container.querySelector(\n      \"input[type='hidden'][name='eventId']\",\n    ) as HTMLInputElement | null;\n    expect(hidden?.value).toBe(\"dpe-1\");\n\n    // Idle: no feedback panel until interaction.\n    expect(screen.queryByRole(\"status\")).toBeNull();\n    expect(screen.queryByRole(\"alert\")).toBeNull();\n  });\n\n  for (const status of [\"active\", \"ended\", \"cancelled\", \"anything-else\"]) {\n    it(`denied (status='${status}'): renders nothing so non-cancellable rows expose no control`, () => {\n      const { container } = render(\n        <DogpileCancelMutationForm\n          eventId={`dpe-${status}`}\n          currentStatus={status}\n        />,\n      );\n\n      expect(container.firstChild).toBeNull();\n      expect(screen.queryByRole(\"form\")).toBeNull();\n      expect(screen.queryByRole(\"button\")).toBeNull();\n    });\n  }\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":394,"cache_read_input_tokens":131064,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":394},"output_tokens":66,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"65159f28-4138-4a00-8878-b10db9efe60e","uuid":"4f8ce7a7-dd95-452d-93c1-cc0fc8d9d5bf"}
