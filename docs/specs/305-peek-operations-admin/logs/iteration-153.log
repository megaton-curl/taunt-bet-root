{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016nN3qQj9KhCqYFiUTxqrP4","type":"tool_result","content":"1\t// FR-14 mutation form: edit a single allowlisted `reward_config` row.\n2\t//\n3\t// Rendered inline in `reward-config-table.tsx` for admin actors and\n4\t// only for rows whose `key` is in the allowlist\n5\t// (`PEEK_REWARD_CONFIG_EDITABLE_KEYS`). The form requires an explicit\n6\t// confirmation checkbox (`confirm: true`) because reward-economy edits\n7\t// are economically sensitive — the FR-14 contract treats a missing or\n8\t// false `confirm` as `invalid_input`. The submit button stays disabled\n9\t// until the operator (a) types a value that differs from the existing\n10\t// row's value and (b) checks the confirmation box, so the UI reflects\n11\t// the mutation's \"no-op rejection\" rule before it ships a request.\n12\t\n13\t\"use client\";\n14\t\n15\timport type { CSSProperties } from \"react\";\n16\timport { useActionState, useId, useState } from \"react\";\n17\timport {\n18\t  PEEK_MUTATION_INITIAL_STATE,\n19\t  rewardConfigUpdateAction,\n20\t} from \"../../server/actions/peek-mutations\";\n21\timport { MutationFeedback } from \"./mutation-feedback\";\n22\t\n23\texport type RewardConfigMutationFormProps = {\n24\t  rowKey: string;\n25\t  expectedType: \"integer\" | \"float\" | \"ratio\" | \"lamports\";\n26\t  valueCurrent: string;\n27\t};\n28\t\n29\texport function RewardConfigMutationForm({\n30\t  rowKey,\n31\t  expectedType,\n32\t  valueCurrent,\n33\t}: RewardConfigMutationFormProps) {\n34\t  const [state, dispatch, pending] = useActionState(\n35\t    rewardConfigUpdateAction,\n36\t    PEEK_MUTATION_INITIAL_STATE,\n37\t  );\n38\t  const valueId = useId();\n39\t  const confirmId = useId();\n40\t  const [pendingValue, setPendingValue] = useState(valueCurrent);\n41\t  const [confirmed, setConfirmed] = useState(false);\n42\t\n43\t  const isNoop = pendingValue.trim() === valueCurrent.trim();\n44\t  const canSubmit = !pending && !isNoop && confirmed;\n45\t\n46\t  return (\n47\t    <form\n48\t      action={dispatch}\n49\t      style={formStyle}\n50\t      aria-label=\"Edit reward config value\"\n51\t    >\n52\t      <input type=\"hidden\" name=\"key\" value={rowKey} />\n53\t\n54\t      <div style={fieldRowStyle}>\n55\t        <label htmlFor={valueId} style={labelStyle}>\n56\t          Value ({expectedType})\n57\t        </label>\n58\t        <div style={oldValueStyle}>old: {valueCurrent}</div>\n59\t        <input\n60\t          id={valueId}\n61\t          name=\"value\"\n62\t          type=\"text\"\n63\t          inputMode={\n64\t            expectedType === \"integer\" || expectedType === \"lamports\"\n65\t              ? \"numeric\"\n66\t              : \"decimal\"\n67\t          }\n68\t          defaultValue={valueCurrent}\n69\t          required\n70\t          style={inputStyle}\n71\t          autoComplete=\"off\"\n72\t          spellCheck={false}\n73\t          onChange={(event) => setPendingValue(event.currentTarget.value)}\n74\t        />\n75\t        {isNoop ? (\n76\t          <p style={hintStyle}>New value matches the current value.</p>\n77\t        ) : (\n78\t          <p style={diffHintStyle}>\n79\t            new: <span style={newValueStyle}>{pendingValue}</span>\n80\t          </p>\n81\t        )}\n82\t      </div>\n83\t\n84\t      <label htmlFor={confirmId} style={confirmRowStyle}>\n85\t        <input\n86\t          id={confirmId}\n87\t          type=\"checkbox\"\n88\t          name=\"confirm\"\n89\t          value=\"true\"\n90\t          checked={confirmed}\n91\t          onChange={(event) => setConfirmed(event.currentTarget.checked)}\n92\t          style={checkboxStyle}\n93\t        />\n94\t        <span>\n95\t          I confirm this reward-economy change. (Required by FR-14.)\n96\t        </span>\n97\t      </label>\n98\t\n99\t      <button type=\"submit\" disabled={!canSubmit} style={submitStyle}>\n100\t        {pending ? \"Applying…\" : \"Apply value change\"}\n101\t      </button>\n102\t\n103\t      <MutationFeedback state={state} successLabel=\"Reward config updated.\" />\n104\t    </form>\n105\t  );\n106\t}\n107\t\n108\tconst formStyle: CSSProperties = {\n109\t  display: \"grid\",\n110\t  gap: \"0.5rem\",\n111\t};\n112\t\n113\tconst fieldRowStyle: CSSProperties = {\n114\t  display: \"grid\",\n115\t  gap: \"0.25rem\",\n116\t};\n117\t\n118\tconst labelStyle: CSSProperties = {\n119\t  fontSize: \"0.75rem\",\n120\t  textTransform: \"uppercase\",\n121\t  letterSpacing: \"0.05em\",\n122\t  color: \"#94a3b8\",\n123\t};\n124\t\n125\tconst oldValueStyle: CSSProperties = {\n126\t  fontSize: \"0.75rem\",\n127\t  color: \"#64748b\",\n128\t  fontFamily: \"monospace\",\n129\t};\n130\t\n131\tconst newValueStyle: CSSProperties = {\n132\t  color: \"#fcd34d\",\n133\t};\n134\t\n135\tconst inputStyle: CSSProperties = {\n136\t  padding: \"0.375rem 0.5rem\",\n137\t  borderRadius: \"0.375rem\",\n138\t  border: \"1px solid #334155\",\n139\t  background: \"#0f172a\",\n140\t  color: \"#e2e8f0\",\n141\t  fontSize: \"0.8125rem\",\n142\t  fontFamily: \"monospace\",\n143\t};\n144\t\n145\tconst hintStyle: CSSProperties = {\n146\t  margin: 0,\n147\t  fontSize: \"0.75rem\",\n148\t  color: \"#94a3b8\",\n149\t  fontStyle: \"italic\",\n150\t};\n151\t\n152\tconst diffHintStyle: CSSProperties = {\n153\t  margin: 0,\n154\t  fontSize: \"0.75rem\",\n155\t  color: \"#94a3b8\",\n156\t  fontFamily: \"monospace\",\n157\t};\n158\t\n159\tconst confirmRowStyle: CSSProperties = {\n160\t  display: \"flex\",\n161\t  alignItems: \"center\",\n162\t  gap: \"0.5rem\",\n163\t  fontSize: \"0.8125rem\",\n164\t  color: \"#cbd5f5\",\n165\t};\n166\t\n167\tconst checkboxStyle: CSSProperties = {\n168\t  cursor: \"pointer\",\n169\t};\n170\t\n171\tconst submitStyle: CSSProperties = {\n172\t  padding: \"0.375rem 0.75rem\",\n173\t  borderRadius: \"0.375rem\",\n174\t  border: \"1px solid #1e3a8a\",\n175\t  background: \"#1e40af\",\n176\t  color: \"#dbeafe\",\n177\t  fontSize: \"0.8125rem\",\n178\t  fontWeight: 600,\n179\t  cursor: \"pointer\",\n180\t};\n181\t"}]},"parent_tool_use_id":null,"session_id":"65159f28-4138-4a00-8878-b10db9efe60e","uuid":"853fe6d0-d310-4368-a0ac-0d2f4bf3c288","timestamp":"2026-04-26T19:45:16.717Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/mutations/reward-config-mutation-form.tsx","content":"// FR-14 mutation form: edit a single allowlisted `reward_config` row.\n//\n// Rendered inline in `reward-config-table.tsx` for admin actors and\n// only for rows whose `key` is in the allowlist\n// (`PEEK_REWARD_CONFIG_EDITABLE_KEYS`). The form requires an explicit\n// confirmation checkbox (`confirm: true`) because reward-economy edits\n// are economically sensitive — the FR-14 contract treats a missing or\n// false `confirm` as `invalid_input`. The submit button stays disabled\n// until the operator (a) types a value that differs from the existing\n// row's value and (b) checks the confirmation box, so the UI reflects\n// the mutation's \"no-op rejection\" rule before it ships a request.\n\n\"use client\";\n\nimport type { CSSProperties } from \"react\";\nimport { useActionState, useId, useState } from \"react\";\nimport {\n  PEEK_MUTATION_INITIAL_STATE,\n  rewardConfigUpdateAction,\n} from \"../../server/actions/peek-mutations\";\nimport { MutationFeedback } from \"./mutation-feedback\";\n\nexport type RewardConfigMutationFormProps = {\n  rowKey: string;\n  expectedType: \"integer\" | \"float\" | \"ratio\" | \"lamports\";\n  valueCurrent: string;\n};\n\nexport function RewardConfigMutationForm({\n  rowKey,\n  expectedType,\n  valueCurrent,\n}: RewardConfigMutationFormProps) {\n  const [state, dispatch, pending] = useActionState(\n    rewardConfigUpdateAction,\n    PEEK_MUTATION_INITIAL_STATE,\n  );\n  const valueId = useId();\n  const confirmId = useId();\n  const [pendingValue, setPendingValue] = useState(valueCurrent);\n  const [confirmed, setConfirmed] = useState(false);\n\n  const isNoop = pendingValue.trim() === valueCurrent.trim();\n  const canSubmit = !pending && !isNoop && confirmed;\n\n  return (\n    <form\n      action={dispatch}\n      style={formStyle}\n      aria-label=\"Edit reward config value\"\n    >\n      <input type=\"hidden\" name=\"key\" value={rowKey} />\n\n      <div style={fieldRowStyle}>\n        <label htmlFor={valueId} style={labelStyle}>\n          Value ({expectedType})\n        </label>\n        <div style={oldValueStyle}>old: {valueCurrent}</div>\n        <input\n          id={valueId}\n          name=\"value\"\n          type=\"text\"\n          inputMode={\n            expectedType === \"integer\" || expectedType === \"lamports\"\n              ? \"numeric\"\n              : \"decimal\"\n          }\n          defaultValue={valueCurrent}\n          required\n          style={inputStyle}\n          autoComplete=\"off\"\n          spellCheck={false}\n          onChange={(event) => setPendingValue(event.currentTarget.value)}\n        />\n        {isNoop ? (\n          <p style={hintStyle}>New value matches the current value.</p>\n        ) : (\n          <p style={diffHintStyle}>\n            new: <span style={newValueStyle}>{pendingValue}</span>\n          </p>\n        )}\n      </div>\n\n      <label htmlFor={confirmId} style={confirmRowStyle}>\n        <input\n          id={confirmId}\n          type=\"checkbox\"\n          name=\"confirm\"\n          value=\"true\"\n          checked={confirmed}\n          onChange={(event) => setConfirmed(event.currentTarget.checked)}\n          style={checkboxStyle}\n        />\n        <span>\n          I confirm this reward-economy change. (Required by FR-14.)\n        </span>\n      </label>\n\n      <button type=\"submit\" disabled={!canSubmit} style={submitStyle}>\n        {pending ? \"Applying…\" : \"Apply value change\"}\n      </button>\n\n      <MutationFeedback state={state} successLabel=\"Reward config updated.\" />\n    </form>\n  );\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst fieldRowStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst labelStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n  color: \"#94a3b8\",\n};\n\nconst oldValueStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  color: \"#64748b\",\n  fontFamily: \"monospace\",\n};\n\nconst newValueStyle: CSSProperties = {\n  color: \"#fcd34d\",\n};\n\nconst inputStyle: CSSProperties = {\n  padding: \"0.375rem 0.5rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #334155\",\n  background: \"#0f172a\",\n  color: \"#e2e8f0\",\n  fontSize: \"0.8125rem\",\n  fontFamily: \"monospace\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n  fontStyle: \"italic\",\n};\n\nconst diffHintStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n  fontFamily: \"monospace\",\n};\n\nconst confirmRowStyle: CSSProperties = {\n  display: \"flex\",\n  alignItems: \"center\",\n  gap: \"0.5rem\",\n  fontSize: \"0.8125rem\",\n  color: \"#cbd5f5\",\n};\n\nconst checkboxStyle: CSSProperties = {\n  cursor: \"pointer\",\n};\n\nconst submitStyle: CSSProperties = {\n  padding: \"0.375rem 0.75rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #1e3a8a\",\n  background: \"#1e40af\",\n  color: \"#dbeafe\",\n  fontSize: \"0.8125rem\",\n  fontWeight: 600,\n  cursor: \"pointer\",\n};\n","numLines":181,"startLine":1,"totalLines":181}}}
