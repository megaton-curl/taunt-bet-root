{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011DWndAztTuMnKbnahYH3Rt","type":"tool_result","content":"1\t// Reward config table for /economy/rewards (FR-9).\n2\t//\n3\t// Dense table over `PeekRewardConfigRow`. Each row shows the key, value,\n4\t// expected value type chip, an inline definition (or an \"unknown key\" hint\n5\t// for rows whose key has not been registered), and the last-updated\n6\t// timestamp.\n7\t//\n8\t// FR-14 wiring: when `canEditRewardConfig` is true the table appends an\n9\t// \"Edit value\" column rendering `RewardConfigMutationForm` per row whose\n10\t// `key` is in the FR-14 allowlist (`editableKeys`) and whose\n11\t// `expectedType` is one of the validated value types. Unregistered keys\n12\t// (`expectedType === \"unknown\"`) and keys outside the allowlist render\n13\t// an empty cell so the operator cannot submit a request the engine will\n14\t// reject.\n15\timport type { CSSProperties } from \"react\";\n16\timport type {\n17\t  PeekRewardConfigExpectedType,\n18\t  PeekRewardConfigRow,\n19\t  PeekStatusTone,\n20\t} from \"../lib/types/peek\";\n21\timport { RewardConfigMutationForm } from \"./mutations/reward-config-mutation-form\";\n22\timport { StatusChip } from \"./status-chip\";\n23\t\n24\texport type RewardConfigTableProps = {\n25\t  rows: ReadonlyArray<PeekRewardConfigRow>;\n26\t  error?: string | null;\n27\t  canEditRewardConfig?: boolean;\n28\t  editableKeys?: ReadonlyArray<string>;\n29\t};\n30\t\n31\tconst TYPE_TONE: Record<PeekRewardConfigExpectedType, PeekStatusTone> = {\n32\t  integer: \"info\",\n33\t  float: \"info\",\n34\t  ratio: \"info\",\n35\t  lamports: \"info\",\n36\t  unknown: \"warning\",\n37\t};\n38\t\n39\texport function RewardConfigTable({\n40\t  rows,\n41\t  error = null,\n42\t  canEditRewardConfig = false,\n43\t  editableKeys = [],\n44\t}: RewardConfigTableProps) {\n45\t  const editableKeySet = new Set(editableKeys);\n46\t  if (error) {\n47\t    return (\n48\t      <div role=\"alert\" style={errorStyle}>\n49\t        Reward config unavailable: {error}\n50\t      </div>\n51\t    );\n52\t  }\n53\t\n54\t  if (rows.length === 0) {\n55\t    return (\n56\t      <div role=\"status\" style={emptyStyle}>\n57\t        <p style={emptyTitleStyle}>No reward_config rows.</p>\n58\t        <p style={emptyBodyStyle}>\n59\t          The `reward_config` table has not been seeded yet, so no economy\n60\t          parameters can be displayed.\n61\t        </p>\n62\t      </div>\n63\t    );\n64\t  }\n65\t\n66\t  return (\n67\t    <div style={wrapperStyle}>\n68\t      <table style={tableStyle}>\n69\t        <thead>\n70\t          <tr style={headerRowStyle}>\n71\t            <th style={headerCellStyle(\"left\")}>Key</th>\n72\t            <th style={headerCellStyle(\"left\")}>Type</th>\n73\t            <th style={headerCellStyle(\"right\")}>Value</th>\n74\t            <th style={headerCellStyle(\"left\")}>Definition</th>\n75\t            <th style={headerCellStyle(\"left\")}>Updated</th>\n76\t            {canEditRewardConfig ? (\n77\t              <th style={headerCellStyle(\"left\")}>Edit value</th>\n78\t            ) : null}\n79\t          </tr>\n80\t        </thead>\n81\t        <tbody>\n82\t          {rows.map((row) => {\n83\t            const isEditable =\n84\t              canEditRewardConfig &&\n85\t              editableKeySet.has(row.key) &&\n86\t              row.expectedType !== \"unknown\";\n87\t            return (\n88\t              <tr key={row.key} style={bodyRowStyle}>\n89\t                <td\n90\t                  style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n91\t                >\n92\t                  {row.key}\n93\t                </td>\n94\t                <td style={bodyCellStyle(\"left\")}>\n95\t                  <StatusChip\n96\t                    label={row.expectedType}\n97\t                    tone={TYPE_TONE[row.expectedType]}\n98\t                  />\n99\t                </td>\n100\t                <td\n101\t                  style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}\n102\t                >\n103\t                  {row.value}\n104\t                </td>\n105\t                <td style={bodyCellStyle(\"left\")}>\n106\t                  {row.definition ?? (\n107\t                    <span style={unknownStyle}>\n108\t                      Unregistered key — extend\n109\t                      PEEK_REWARD_CONFIG_KEY_REGISTRY to document this.\n110\t                    </span>\n111\t                  )}\n112\t                </td>\n113\t                <td style={bodyCellStyle(\"left\")}>{row.updatedAt}</td>\n114\t                {canEditRewardConfig ? (\n115\t                  <td style={bodyCellStyle(\"left\")}>\n116\t                    {isEditable && row.expectedType !== \"unknown\" ? (\n117\t                      <RewardConfigMutationForm\n118\t                        rowKey={row.key}\n119\t                        expectedType={row.expectedType}\n120\t                        valueCurrent={row.value}\n121\t                      />\n122\t                    ) : null}\n123\t                  </td>\n124\t                ) : null}\n125\t              </tr>\n126\t            );\n127\t          })}\n128\t        </tbody>\n129\t      </table>\n130\t    </div>\n131\t  );\n132\t}\n133\t\n134\tconst wrapperStyle: CSSProperties = {\n135\t  overflowX: \"auto\",\n136\t  border: \"1px solid #1e293b\",\n137\t  borderRadius: \"0.75rem\",\n138\t};\n139\t\n140\tconst tableStyle: CSSProperties = {\n141\t  width: \"100%\",\n142\t  borderCollapse: \"collapse\",\n143\t};\n144\t\n145\tconst headerRowStyle: CSSProperties = {\n146\t  background: \"#111827\",\n147\t  color: \"#94a3b8\",\n148\t};\n149\t\n150\tconst bodyRowStyle: CSSProperties = {\n151\t  borderTop: \"1px solid #1e293b\",\n152\t};\n153\t\n154\tconst unknownStyle: CSSProperties = {\n155\t  color: \"#fde68a\",\n156\t  fontSize: \"0.8125rem\",\n157\t};\n158\t\n159\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n160\t  return {\n161\t    padding: \"0.75rem\",\n162\t    textAlign: align,\n163\t    fontSize: \"0.875rem\",\n164\t    fontWeight: 600,\n165\t  };\n166\t}\n167\t\n168\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n169\t  return {\n170\t    padding: \"0.75rem\",\n171\t    textAlign: align,\n172\t    fontSize: \"0.875rem\",\n173\t    color: \"#e2e8f0\",\n174\t    verticalAlign: \"top\",\n175\t  };\n176\t}\n177\t\n178\tconst errorStyle: CSSProperties = {\n179\t  margin: 0,\n180\t  padding: \"0.75rem 1rem\",\n181\t  borderRadius: \"0.75rem\",\n182\t  background: \"#3f1d1d\",\n183\t  color: \"#fecaca\",\n184\t};\n185\t\n186\tconst emptyStyle: CSSProperties = {\n187\t  padding: \"1.5rem\",\n188\t  borderRadius: \"0.75rem\",\n189\t  border: \"1px dashed #334155\",\n190\t  background: \"#0b1220\",\n191\t  color: \"#cbd5f5\",\n192\t  display: \"grid\",\n193\t  gap: \"0.5rem\",\n194\t};\n195\t\n196\tconst emptyTitleStyle: CSSProperties = {\n197\t  margin: 0,\n198\t  fontSize: \"1rem\",\n199\t  fontWeight: 600,\n200\t};\n201\t\n202\tconst emptyBodyStyle: CSSProperties = {\n203\t  margin: 0,\n204\t  fontSize: \"0.875rem\",\n205\t  color: \"#94a3b8\",\n206\t};\n207\t"}]},"parent_tool_use_id":null,"session_id":"65159f28-4138-4a00-8878-b10db9efe60e","uuid":"8f46341b-3b57-44a1-8db3-1b9743c065e0","timestamp":"2026-04-26T19:46:30.215Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/reward-config-table.tsx","content":"// Reward config table for /economy/rewards (FR-9).\n//\n// Dense table over `PeekRewardConfigRow`. Each row shows the key, value,\n// expected value type chip, an inline definition (or an \"unknown key\" hint\n// for rows whose key has not been registered), and the last-updated\n// timestamp.\n//\n// FR-14 wiring: when `canEditRewardConfig` is true the table appends an\n// \"Edit value\" column rendering `RewardConfigMutationForm` per row whose\n// `key` is in the FR-14 allowlist (`editableKeys`) and whose\n// `expectedType` is one of the validated value types. Unregistered keys\n// (`expectedType === \"unknown\"`) and keys outside the allowlist render\n// an empty cell so the operator cannot submit a request the engine will\n// reject.\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekRewardConfigExpectedType,\n  PeekRewardConfigRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { RewardConfigMutationForm } from \"./mutations/reward-config-mutation-form\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type RewardConfigTableProps = {\n  rows: ReadonlyArray<PeekRewardConfigRow>;\n  error?: string | null;\n  canEditRewardConfig?: boolean;\n  editableKeys?: ReadonlyArray<string>;\n};\n\nconst TYPE_TONE: Record<PeekRewardConfigExpectedType, PeekStatusTone> = {\n  integer: \"info\",\n  float: \"info\",\n  ratio: \"info\",\n  lamports: \"info\",\n  unknown: \"warning\",\n};\n\nexport function RewardConfigTable({\n  rows,\n  error = null,\n  canEditRewardConfig = false,\n  editableKeys = [],\n}: RewardConfigTableProps) {\n  const editableKeySet = new Set(editableKeys);\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Reward config unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No reward_config rows.</p>\n        <p style={emptyBodyStyle}>\n          The `reward_config` table has not been seeded yet, so no economy\n          parameters can be displayed.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Key</th>\n            <th style={headerCellStyle(\"left\")}>Type</th>\n            <th style={headerCellStyle(\"right\")}>Value</th>\n            <th style={headerCellStyle(\"left\")}>Definition</th>\n            <th style={headerCellStyle(\"left\")}>Updated</th>\n            {canEditRewardConfig ? (\n              <th style={headerCellStyle(\"left\")}>Edit value</th>\n            ) : null}\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => {\n            const isEditable =\n              canEditRewardConfig &&\n              editableKeySet.has(row.key) &&\n              row.expectedType !== \"unknown\";\n            return (\n              <tr key={row.key} style={bodyRowStyle}>\n                <td\n                  style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n                >\n                  {row.key}\n                </td>\n                <td style={bodyCellStyle(\"left\")}>\n                  <StatusChip\n                    label={row.expectedType}\n                    tone={TYPE_TONE[row.expectedType]}\n                  />\n                </td>\n                <td\n                  style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}\n                >\n                  {row.value}\n                </td>\n                <td style={bodyCellStyle(\"left\")}>\n                  {row.definition ?? (\n                    <span style={unknownStyle}>\n                      Unregistered key — extend\n                      PEEK_REWARD_CONFIG_KEY_REGISTRY to document this.\n                    </span>\n                  )}\n                </td>\n                <td style={bodyCellStyle(\"left\")}>{row.updatedAt}</td>\n                {canEditRewardConfig ? (\n                  <td style={bodyCellStyle(\"left\")}>\n                    {isEditable && row.expectedType !== \"unknown\" ? (\n                      <RewardConfigMutationForm\n                        rowKey={row.key}\n                        expectedType={row.expectedType}\n                        valueCurrent={row.value}\n                      />\n                    ) : null}\n                  </td>\n                ) : null}\n              </tr>\n            );\n          })}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst unknownStyle: CSSProperties = {\n  color: \"#fde68a\",\n  fontSize: \"0.8125rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":207,"startLine":1,"totalLines":207}}}
