{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012BJ7ATdiirCbPcXgPyXsMz","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport { render, screen } from \"@testing-library/react\";\n3\timport { RewardConfigTable } from \"../reward-config-table\";\n4\timport type { PeekRewardConfigRow } from \"../../lib/types/peek\";\n5\t\n6\tconst ROW_KNOWN: PeekRewardConfigRow = {\n7\t  key: \"points_per_dollar\",\n8\t  value: \"10\",\n9\t  updatedAt: \"2026-04-25T10:00:00.000Z\",\n10\t  definition:\n11\t    \"Points granted per USD-equivalent of wager — drives the wager → points conversion rate.\",\n12\t  expectedType: \"integer\",\n13\t};\n14\t\n15\tconst ROW_RATIO: PeekRewardConfigRow = {\n16\t  key: \"reward_pool_fee_share\",\n17\t  value: \"0.25\",\n18\t  updatedAt: \"2026-04-25T10:00:00.000Z\",\n19\t  definition:\n20\t    \"Fraction of platform fee diverted into the reward pool on each settled round (0..1).\",\n21\t  expectedType: \"ratio\",\n22\t};\n23\t\n24\tconst ROW_UNKNOWN: PeekRewardConfigRow = {\n25\t  key: \"experimental_unmapped_key\",\n26\t  value: \"42\",\n27\t  updatedAt: \"2026-04-25T10:00:00.000Z\",\n28\t  definition: null,\n29\t  expectedType: \"unknown\",\n30\t};\n31\t\n32\tdescribe(\"RewardConfigTable\", () => {\n33\t  it(\"populated: renders the operator columns, the type chip, the value, and the inline definition\", () => {\n34\t    render(<RewardConfigTable rows={[ROW_KNOWN, ROW_RATIO]} />);\n35\t\n36\t    expect(screen.getByText(\"Key\")).toBeInTheDocument();\n37\t    expect(screen.getByText(\"Type\")).toBeInTheDocument();\n38\t    expect(screen.getByText(\"Value\")).toBeInTheDocument();\n39\t    expect(screen.getByText(\"Definition\")).toBeInTheDocument();\n40\t    expect(screen.getByText(\"Updated\")).toBeInTheDocument();\n41\t\n42\t    expect(screen.getByText(\"points_per_dollar\")).toBeInTheDocument();\n43\t    expect(screen.getByText(\"reward_pool_fee_share\")).toBeInTheDocument();\n44\t    expect(screen.getByText(\"integer\")).toBeInTheDocument();\n45\t    expect(screen.getByText(\"ratio\")).toBeInTheDocument();\n46\t    expect(screen.getByText(\"10\")).toBeInTheDocument();\n47\t    expect(screen.getByText(\"0.25\")).toBeInTheDocument();\n48\t    expect(\n49\t      screen.getByText(\n50\t        \"Points granted per USD-equivalent of wager — drives the wager → points conversion rate.\",\n51\t      ),\n52\t    ).toBeInTheDocument();\n53\t  });\n54\t\n55\t  it(\"populated: an unknown key surfaces the warning hint instead of faking a definition\", () => {\n56\t    render(<RewardConfigTable rows={[ROW_UNKNOWN]} />);\n57\t\n58\t    expect(screen.getByText(\"experimental_unmapped_key\")).toBeInTheDocument();\n59\t    expect(screen.getByText(\"unknown\")).toBeInTheDocument();\n60\t    expect(\n61\t      screen.getByText(/Unregistered key — extend/i),\n62\t    ).toBeInTheDocument();\n63\t    // The hint mentions the registry symbol so an operator knows where to add the entry.\n64\t    expect(\n65\t      screen.getByText(/PEEK_REWARD_CONFIG_KEY_REGISTRY/i),\n66\t    ).toBeInTheDocument();\n67\t  });\n68\t\n69\t  it(\"empty: renders an operator status block when no reward_config rows exist\", () => {\n70\t    render(<RewardConfigTable rows={[]} />);\n71\t\n72\t    const status = screen.getByRole(\"status\");\n73\t    expect(status).toHaveTextContent(\"No reward_config rows.\");\n74\t    expect(status).toHaveTextContent(\"reward_config\");\n75\t    expect(screen.queryByRole(\"table\")).toBeNull();\n76\t  });\n77\t\n78\t  it(\"error: renders an alert message and hides both the table and the empty status\", () => {\n79\t    render(\n80\t      <RewardConfigTable rows={[ROW_KNOWN]} error=\"connection refused\" />,\n81\t    );\n82\t\n83\t    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n84\t      \"Reward config unavailable: connection refused\",\n85\t    );\n86\t    expect(screen.queryByRole(\"table\")).toBeNull();\n87\t    expect(screen.queryByRole(\"status\")).toBeNull();\n88\t  });\n89\t});\n90\t"}]},"parent_tool_use_id":null,"session_id":"65159f28-4138-4a00-8878-b10db9efe60e","uuid":"b8161e65-1d2a-4ab0-b17b-bfc9c50ca11f","timestamp":"2026-04-26T19:47:35.942Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/reward-config-table.test.tsx","content":"import { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { RewardConfigTable } from \"../reward-config-table\";\nimport type { PeekRewardConfigRow } from \"../../lib/types/peek\";\n\nconst ROW_KNOWN: PeekRewardConfigRow = {\n  key: \"points_per_dollar\",\n  value: \"10\",\n  updatedAt: \"2026-04-25T10:00:00.000Z\",\n  definition:\n    \"Points granted per USD-equivalent of wager — drives the wager → points conversion rate.\",\n  expectedType: \"integer\",\n};\n\nconst ROW_RATIO: PeekRewardConfigRow = {\n  key: \"reward_pool_fee_share\",\n  value: \"0.25\",\n  updatedAt: \"2026-04-25T10:00:00.000Z\",\n  definition:\n    \"Fraction of platform fee diverted into the reward pool on each settled round (0..1).\",\n  expectedType: \"ratio\",\n};\n\nconst ROW_UNKNOWN: PeekRewardConfigRow = {\n  key: \"experimental_unmapped_key\",\n  value: \"42\",\n  updatedAt: \"2026-04-25T10:00:00.000Z\",\n  definition: null,\n  expectedType: \"unknown\",\n};\n\ndescribe(\"RewardConfigTable\", () => {\n  it(\"populated: renders the operator columns, the type chip, the value, and the inline definition\", () => {\n    render(<RewardConfigTable rows={[ROW_KNOWN, ROW_RATIO]} />);\n\n    expect(screen.getByText(\"Key\")).toBeInTheDocument();\n    expect(screen.getByText(\"Type\")).toBeInTheDocument();\n    expect(screen.getByText(\"Value\")).toBeInTheDocument();\n    expect(screen.getByText(\"Definition\")).toBeInTheDocument();\n    expect(screen.getByText(\"Updated\")).toBeInTheDocument();\n\n    expect(screen.getByText(\"points_per_dollar\")).toBeInTheDocument();\n    expect(screen.getByText(\"reward_pool_fee_share\")).toBeInTheDocument();\n    expect(screen.getByText(\"integer\")).toBeInTheDocument();\n    expect(screen.getByText(\"ratio\")).toBeInTheDocument();\n    expect(screen.getByText(\"10\")).toBeInTheDocument();\n    expect(screen.getByText(\"0.25\")).toBeInTheDocument();\n    expect(\n      screen.getByText(\n        \"Points granted per USD-equivalent of wager — drives the wager → points conversion rate.\",\n      ),\n    ).toBeInTheDocument();\n  });\n\n  it(\"populated: an unknown key surfaces the warning hint instead of faking a definition\", () => {\n    render(<RewardConfigTable rows={[ROW_UNKNOWN]} />);\n\n    expect(screen.getByText(\"experimental_unmapped_key\")).toBeInTheDocument();\n    expect(screen.getByText(\"unknown\")).toBeInTheDocument();\n    expect(\n      screen.getByText(/Unregistered key — extend/i),\n    ).toBeInTheDocument();\n    // The hint mentions the registry symbol so an operator knows where to add the entry.\n    expect(\n      screen.getByText(/PEEK_REWARD_CONFIG_KEY_REGISTRY/i),\n    ).toBeInTheDocument();\n  });\n\n  it(\"empty: renders an operator status block when no reward_config rows exist\", () => {\n    render(<RewardConfigTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"No reward_config rows.\");\n    expect(status).toHaveTextContent(\"reward_config\");\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert message and hides both the table and the empty status\", () => {\n    render(\n      <RewardConfigTable rows={[ROW_KNOWN]} error=\"connection refused\" />,\n    );\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Reward config unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n","numLines":90,"startLine":1,"totalLines":90}}}
