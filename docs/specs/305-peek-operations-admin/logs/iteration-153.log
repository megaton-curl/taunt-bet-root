    render(\n      <GrowthKolTable\n        rows={[ROW_KOL, ROW_NEW_KOL]}\n        canMutateKolRate\n      />,\n    );\n\n    expect(screen.getByText(\"Edit rate\")).toBeInTheDocument();\n\n    // One mutation form per data row.\n    const forms = screen.getAllByRole(\"form\", { name: \"Update KOL rate\" });\n    expect(forms).toHaveLength(2);\n\n    // Each form pre-populates with the row's current values for the\n    // visual old → new diff before submission.\n    expect(screen.getByText(\"old: wallet-1\")).toBeInTheDocument();\n    expect(screen.getByText(\"old: 250\")).toBeInTheDocument();\n    expect(screen.getByText(\"old: wallet-2\")).toBeInTheDocument();\n    expect(screen.getByText(\"old: 100\")).toBeInTheDocument();\n  });\n});","originalFile":"import { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { GrowthKolTable } from \"../growth-kol-table\";\nimport type { PeekKolPerformanceRow } from \"../../lib/types/peek\";\n\nconst ROW_KOL: PeekKolPerformanceRow = {\n  userId: \"u-1\",\n  username: \"alice\",\n  wallet: \"wallet-1\",\n  rateBps: 250,\n  setBy: \"admin@example.com\",\n  createdAt: \"2026-04-01T00:00:00.000Z\",\n  updatedAt: \"2026-04-10T00:00:00.000Z\",\n  refereeCount: 12,\n  referredWagerLamports: \"8000000\",\n  referrerEarnedLamports: \"200000\",\n};\n\nconst ROW_NEW_KOL: PeekKolPerformanceRow = {\n  userId: \"u-2\",\n  username: null,\n  wallet: \"wallet-2\",\n  rateBps: 100,\n  setBy: \"admin@example.com\",\n  createdAt: \"2026-04-15T00:00:00.000Z\",\n  updatedAt: \"2026-04-15T00:00:00.000Z\",\n  refereeCount: 0,\n  referredWagerLamports: \"0\",\n  referrerEarnedLamports: \"0\",\n};\n\ndescribe(\"GrowthKolTable\", () => {\n  it(\"populated: renders the operator columns, drill-down, formatted lamports, and KOL-side fields\", () => {\n    render(<GrowthKolTable rows={[ROW_KOL, ROW_NEW_KOL]} />);\n\n    expect(screen.getByText(\"User\")).toBeInTheDocument();\n    expect(screen.getByText(\"Wallet\")).toBeInTheDocument();\n    expect(screen.getByText(\"Rate (bps)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Set by\")).toBeInTheDocument();\n    expect(screen.getByText(\"Created\")).toBeInTheDocument();\n    expect(screen.getByText(\"Updated\")).toBeInTheDocument();\n    expect(screen.getByText(\"Referees\")).toBeInTheDocument();\n    expect(screen.getByText(\"Wager (lamports)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Earned (lamports)\")).toBeInTheDocument();\n\n    // Drill-down per row.\n    expect(screen.getByRole(\"link\", { name: \"alice\" })).toHaveAttribute(\n      \"href\",\n      \"/users/u-1\",\n    );\n    // Username-less row falls back to userId as the link label.\n    expect(screen.getByRole(\"link\", { name: \"u-2\" })).toHaveAttribute(\n      \"href\",\n      \"/users/u-2\",\n    );\n\n    // KOL-side fields.\n    expect(screen.getByText(\"250\")).toBeInTheDocument();\n    expect(screen.getByText(\"100\")).toBeInTheDocument();\n    expect(screen.getAllByText(\"admin@example.com\").length).toBe(2);\n\n    // Performance numbers formatted with thousands separator; \"0\" stays bare.\n    expect(screen.getByText(\"8,000,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"200,000\")).toBeInTheDocument();\n  });\n\n  it(\"empty: renders a status block when no KOL rates have been configured\", () => {\n    render(<GrowthKolTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"No KOL rates configured.\");\n    expect(status).toHaveTextContent(\"referral_kol_rates\");\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert message and hides rows\", () => {\n    render(<GrowthKolTable rows={[ROW_KOL]} error=\"connection refused\" />);\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"KOL table unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n","structuredPatch":[{"oldStart":82,"oldLines":4,"newStart":82,"newLines":37,"lines":["     expect(screen.queryByRole(\"table\")).toBeNull();","     expect(screen.queryByRole(\"status\")).toBeNull();","   });","+","+  // FR-14 mutation UI — column visibility is gated by `canMutateKolRate`,","+  // computed at the page level via `isActionAllowedForRole(\"kol_rate.update\", actor.role)`.","+  it(\"denied actor hidden: defaults to no 'Edit rate' column and renders no mutation forms\", () => {","+    render(<GrowthKolTable rows={[ROW_KOL, ROW_NEW_KOL]} />);","+","+    expect(screen.queryByText(\"Edit rate\")).toBeNull();","+    expect(","+      screen.queryByRole(\"form\", { name: \"Update KOL rate\" }),","+    ).toBeNull();","+  });","+","+  it(\"authorized success path: canMutateKolRate adds the 'Edit rate' column with one form per row, pre-populated from the row's current values\", () => {","+    render(","+      <GrowthKolTable","+        rows={[ROW_KOL, ROW_NEW_KOL]}","+        canMutateKolRate","+      />,","+    );","+","+    expect(screen.getByText(\"Edit rate\")).toBeInTheDocument();","+","+    // One mutation form per data row.","+    const forms = screen.getAllByRole(\"form\", { name: \"Update KOL rate\" });","+    expect(forms).toHaveLength(2);","+","+    // Each form pre-populates with the row's current values for the","+    // visual old → new diff before submission.","+    expect(screen.getByText(\"old: wallet-1\")).toBeInTheDocument();","+    expect(screen.getByText(\"old: 250\")).toBeInTheDocument();","+    expect(screen.getByText(\"old: wallet-2\")).toBeInTheDocument();","+    expect(screen.getByText(\"old: 100\")).toBeInTheDocument();","+  });"," });"]}],"userModified":false,"replaceAll":false}}
