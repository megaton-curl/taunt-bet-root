{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01TwXXbXaiYNPEWmUEoceAFu","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01EtBavNnNodSNMCB1r2YEFV","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/mutations/__tests__/mutation-feedback.test.tsx","content":"// FR-14 mutation UI — feedback presenter coverage.\n//\n// `MutationFeedback` is a pure presenter that maps a\n// `PeekMutationActionState` (idle / ok / error + runner failure reason +\n// optional `fieldErrors`) into operator-friendly status / alert lines.\n// These tests pin every reason → copy mapping so a runner contract\n// regression (e.g. a renamed reason code) fails a test rather than ship\n// silently behind a real form.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen, within } from \"@testing-library/react\";\nimport { MutationFeedback } from \"../mutation-feedback\";\nimport type { PeekMutationActionState } from \"../../../server/actions/peek-mutations\";\n\ndescribe(\"MutationFeedback\", () => {\n  it(\"idle: renders nothing so the form footer stays silent until interaction\", () => {\n    const state: PeekMutationActionState = {\n      status: \"idle\",\n      message: \"\",\n    };\n\n    const { container } = render(<MutationFeedback state={state} />);\n    expect(container.firstChild).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n    expect(screen.queryByRole(\"alert\")).toBeNull();\n  });\n\n  it(\"ok: renders a status line with the success label and (when present) the resourceId\", () => {\n    const state: PeekMutationActionState = {\n      status: \"ok\",\n      message: \"Change applied.\",\n      resourceId: \"kol-123\",\n      actionId: \"kol_rate.update\",\n    };\n\n    render(\n      <MutationFeedback state={state} successLabel=\"KOL rate updated.\" />,\n    );\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"✓ KOL rate updated.\");\n    expect(status).toHaveTextContent(\"(id kol-123)\");\n    // Success path never shows an alert.\n    expect(screen.queryByRole(\"alert\")).toBeNull();\n  });\n\n  it(\"ok: omits the resourceId hint when the runner returns null\", () => {\n    const state: PeekMutationActionState = {\n      status: \"ok\",\n      message: \"Change applied.\",\n      resourceId: null,\n    };\n\n    render(<MutationFeedback state={state} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"Change applied.\");\n    expect(status.textContent ?? \"\").not.toMatch(/\\(id /);\n  });\n\n  it(\"ok: defaults to 'Change applied.' when no successLabel prop is supplied\", () => {\n    const state: PeekMutationActionState = {\n      status: \"ok\",\n      message: \"ignored\",\n    };\n\n    render(<MutationFeedback state={state} />);\n\n    expect(screen.getByRole(\"status\")).toHaveTextContent(\"✓ Change applied.\");\n  });\n\n  // Reason-specific copy: every PeekMutationFailureReason and the\n  // peek-mutations \"no_actor\" sentinel must surface a human-readable line.\n  const REASON_CASES: ReadonlyArray<{\n    reason: PeekMutationActionState[\"reason\"];\n    expected: string;\n  }> = [\n    { reason: \"no_actor\", expected: \"Not authenticated.\" },\n    {\n      reason: \"unauthorized\",\n      expected: \"You are not authorized to perform this action.\",\n    },\n    {\n      reason: \"invalid_input\",\n      expected: \"The submitted values are invalid.\",\n    },\n    {\n      reason: \"execution_failed\",\n      expected: \"The change could not be applied.\",\n    },\n    { reason: \"unknown_action\", expected: \"Unknown mutation action.\" },\n    {\n      reason: \"audit_emit_failed\",\n      expected: \"Audit logging failed; the change was rolled back.\",\n    },\n  ];\n\n  for (const { reason, expected } of REASON_CASES) {\n    it(`error: maps reason='${reason}' to the documented copy`, () => {\n      const state: PeekMutationActionState = {\n        status: \"error\",\n        message: \"raw runner message\",\n        reason,\n      };\n\n      render(<MutationFeedback state={state} />);\n\n      const alert = screen.getByRole(\"alert\");\n      expect(alert).toHaveTextContent(expected);\n      // Raw runner message is preserved beside the title for debugging.\n      expect(alert).toHaveTextContent(\"raw runner message\");\n      // Error path never doubles as a success status.\n      expect(screen.queryByRole(\"status\")).toBeNull();\n    });\n  }\n\n  it(\"error: missing reason falls back to a generic 'Mutation failed.' line\", () => {\n    const state: PeekMutationActionState = {\n      status: \"error\",\n      message: \"boom\",\n    };\n\n    render(<MutationFeedback state={state} />);\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\"✗ Mutation failed.\");\n  });\n\n  it(\"error: validation fieldErrors render as a per-field bulleted list\", () => {\n    const state: PeekMutationActionState = {\n      status: \"error\",\n      message: \"schema rejected the input\",\n      reason: \"invalid_input\",\n      fieldErrors: {\n        rateBps: [\"must be between 0 and 10000\"],\n        wallet: [\"required\", \"must be a valid base58 string\"],\n      },\n    };\n\n    render(<MutationFeedback state={state} />);\n\n    const alert = screen.getByRole(\"alert\");\n    expect(alert).toHaveTextContent(\"The submitted values are invalid.\");\n\n    // Field bullets are scoped under the alert so we do not collide with\n    // any sibling content the surrounding form might render.\n    const items = within(alert).getAllByRole(\"listitem\");\n    expect(items).toHaveLength(2);\n\n    expect(items[0]).toHaveTextContent(\"rateBps:\");\n    expect(items[0]).toHaveTextContent(\"must be between 0 and 10000\");\n\n    expect(items[1]).toHaveTextContent(\"wallet:\");\n    expect(items[1]).toHaveTextContent(\"required\");\n    // Multiple errors per field are joined with `; `.\n    expect(items[1]).toHaveTextContent(\"required; must be a valid base58 string\");\n  });\n\n  it(\"error: no fieldErrors → no list rendered (avoids a stray empty <ul>)\", () => {\n    const state: PeekMutationActionState = {\n      status: \"error\",\n      message: \"no fields\",\n      reason: \"execution_failed\",\n    };\n\n    const { container } = render(<MutationFeedback state={state} />);\n\n    expect(container.querySelectorAll(\"ul\").length).toBe(0);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1750,"cache_read_input_tokens":122172,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1750},"output_tokens":49,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"65159f28-4138-4a00-8878-b10db9efe60e","uuid":"5e33eeb9-5ff7-475e-97b5-1ba4de6201fb"}
