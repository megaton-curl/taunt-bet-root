{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TiRfCBbpVDFoa6Emr7g3KA","type":"tool_result","content":"The file /workspaces/rng-utopia/peek/src/components/__tests__/dogpile-events-table.test.tsx has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"65159f28-4138-4a00-8878-b10db9efe60e","uuid":"79b5e24e-b8f4-4282-aa94-dba1333aec72","timestamp":"2026-04-26T19:51:15.030Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/dogpile-events-table.test.tsx","oldString":"  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n    render(\n      <DogpileEventsTable\n        rows={[ROW_SCHEDULED]}\n        error=\"connection refused\"\n      />,\n    );\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Dogpile events unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});","newString":"  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n    render(\n      <DogpileEventsTable\n        rows={[ROW_SCHEDULED]}\n        error=\"connection refused\"\n      />,\n    );\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Dogpile events unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n\n  // FR-14 mutation UI — column visibility is gated by `canCancelDogpile`,\n  // computed at the page level via `isActionAllowedForRole(\"dogpile.cancel\", actor.role)`.\n  it(\"denied actor hidden: defaults to no 'Cancel' column and renders no cancel forms\", () => {\n    render(\n      <DogpileEventsTable\n        rows={[ROW_SCHEDULED, ROW_ACTIVE, ROW_ENDED, ROW_CANCELLED]}\n      />,\n    );\n\n    expect(screen.queryByText(\"Cancel\")).toBeNull();\n    expect(\n      screen.queryByRole(\"form\", { name: \"Cancel scheduled dogpile event\" }),\n    ).toBeNull();\n  });\n\n  it(\"authorized success path: canCancelDogpile adds the 'Cancel' column and shows the cancel form only for scheduled rows (active/ended/cancelled cells render no form)\", () => {\n    render(\n      <DogpileEventsTable\n        rows={[ROW_SCHEDULED, ROW_ACTIVE, ROW_ENDED, ROW_CANCELLED]}\n        canCancelDogpile\n      />,\n    );\n\n    // New column header surfaces.\n    expect(\n      screen.getByRole(\"columnheader\", { name: \"Cancel\" }),\n    ).toBeInTheDocument();\n\n    // Only the scheduled row gets a cancel form — active/ended/cancelled\n    // would all be denied by the runner, so the column is empty for them.\n    const forms = screen.getAllByRole(\"form\", {\n      name: \"Cancel scheduled dogpile event\",\n    });\n    expect(forms).toHaveLength(1);\n\n    // Submit copy on the scheduled row.\n    expect(\n      screen.getByRole(\"button\", { name: \"Cancel scheduled event\" }),\n    ).toBeInTheDocument();\n  });\n});","originalFile":"// Component tests for the FR-9 dogpile events table.\n//\n// Read-only by spec — every dogpile mutation lives behind the FR-14\n// `dogpile.cancel` action id (declared in `peek/src/server/access-policy.ts`,\n// not yet implemented). These tests assert there are no edit affordances\n// rendered (no buttons, no editable inputs) and that the status chip switches\n// tone for every lifecycle state.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { DogpileEventsTable } from \"../dogpile-events-table\";\nimport type { PeekDogpileEventRow } from \"../../lib/types/peek\";\n\nconst ROW_SCHEDULED: PeekDogpileEventRow = {\n  id: \"1\",\n  campaignId: \"c-1\",\n  campaignName: \"Bull-run dogpile\",\n  campaignType: \"dogpile\",\n  startsAt: \"2026-04-26T10:00:00.000Z\",\n  endsAt: \"2026-04-26T12:00:00.000Z\",\n  multiplier: \"2.5\",\n  status: \"scheduled\",\n  createdAt: \"2026-04-26T09:00:00.000Z\",\n  gameEntryCount: 0,\n  pointGrantCount: 0,\n};\n\nconst ROW_ACTIVE: PeekDogpileEventRow = {\n  id: \"2\",\n  campaignId: \"c-2\",\n  campaignName: \"Weekend ramp\",\n  campaignType: \"dogpile\",\n  startsAt: \"2026-04-26T08:00:00.000Z\",\n  endsAt: \"2026-04-26T20:00:00.000Z\",\n  multiplier: \"1.5\",\n  status: \"active\",\n  createdAt: \"2026-04-26T07:30:00.000Z\",\n  gameEntryCount: 1234,\n  pointGrantCount: 5678,\n};\n\nconst ROW_ENDED: PeekDogpileEventRow = {\n  id: \"3\",\n  campaignId: null,\n  campaignName: null,\n  campaignType: null,\n  startsAt: \"2026-04-25T10:00:00.000Z\",\n  endsAt: \"2026-04-25T12:00:00.000Z\",\n  multiplier: \"3.0\",\n  status: \"ended\",\n  createdAt: \"2026-04-25T09:00:00.000Z\",\n  gameEntryCount: 42,\n  pointGrantCount: 99,\n};\n\nconst ROW_CANCELLED: PeekDogpileEventRow = {\n  id: \"4\",\n  campaignId: \"c-4\",\n  campaignName: \"Cancelled experiment\",\n  campaignType: \"dogpile\",\n  startsAt: \"2026-04-27T10:00:00.000Z\",\n  endsAt: \"2026-04-27T12:00:00.000Z\",\n  multiplier: \"2.0\",\n  status: \"cancelled\",\n  createdAt: \"2026-04-26T09:00:00.000Z\",\n  gameEntryCount: 0,\n  pointGrantCount: 0,\n};\n\ndescribe(\"DogpileEventsTable\", () => {\n  it(\"populated: renders the operator columns and every lifecycle status chip\", () => {\n    render(\n      <DogpileEventsTable\n        rows={[ROW_SCHEDULED, ROW_ACTIVE, ROW_ENDED, ROW_CANCELLED]}\n      />,\n    );\n\n    for (const header of [\n      \"Status\",\n      \"Campaign\",\n      \"Starts\",\n      \"Ends\",\n      \"Multiplier\",\n      \"Game entries\",\n      \"Point grants\",\n      \"Created\",\n      \"ID\",\n    ]) {\n      expect(screen.getByText(header)).toBeInTheDocument();\n    }\n\n    // State transition coverage: one chip per lifecycle state.\n    expect(screen.getByText(\"scheduled\")).toBeInTheDocument();\n    expect(screen.getByText(\"active\")).toBeInTheDocument();\n    expect(screen.getByText(\"ended\")).toBeInTheDocument();\n    expect(screen.getByText(\"cancelled\")).toBeInTheDocument();\n  });\n\n  it(\"populated: counts use thousands separators and multiplier renders with the × suffix\", () => {\n    render(<DogpileEventsTable rows={[ROW_ACTIVE]} />);\n\n    expect(screen.getByText(\"1,234\")).toBeInTheDocument();\n    expect(screen.getByText(\"5,678\")).toBeInTheDocument();\n    expect(screen.getByText(\"1.5×\")).toBeInTheDocument();\n  });\n\n  it(\"populated: nullable campaign columns render '—' for the campaign cell\", () => {\n    render(<DogpileEventsTable rows={[ROW_ENDED]} />);\n\n    // Campaign cell renders a single em-dash when the join is sparse.\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(1);\n    // No campaign name / type / id fragments leak into the row.\n    expect(screen.queryByText(\"c-3\")).toBeNull();\n  });\n\n  it(\"populated: campaign cell shows name, type, and id when the join hits\", () => {\n    render(<DogpileEventsTable rows={[ROW_ACTIVE]} />);\n\n    expect(screen.getByText(\"Weekend ramp\")).toBeInTheDocument();\n    expect(screen.getByText(\"dogpile\")).toBeInTheDocument();\n    expect(screen.getByText(\"c-2\")).toBeInTheDocument();\n  });\n\n  it(\"read-only: no edit affordances rendered (no buttons, no editable inputs, no checkboxes)\", () => {\n    // FR-14 keeps every dogpile mutation behind `dogpile.cancel`. The table\n    // must not render a cancel button or any other mutating control.\n    render(\n      <DogpileEventsTable\n        rows={[ROW_SCHEDULED, ROW_ACTIVE, ROW_ENDED, ROW_CANCELLED]}\n      />,\n    );\n\n    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n    expect(screen.queryByRole(\"textbox\")).toBeNull();\n    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n    expect(screen.queryByRole(\"link\")).toBeNull();\n  });\n\n  it(\"empty: renders the operator status block when no events exist\", () => {\n    render(<DogpileEventsTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\n      \"No dogpile_events rows match these filters.\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n    render(\n      <DogpileEventsTable\n        rows={[ROW_SCHEDULED]}\n        error=\"connection refused\"\n      />,\n    );\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Dogpile events unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n","structuredPatch":[{"oldStart":160,"oldLines":4,"newStart":160,"newLines":45,"lines":["     expect(screen.queryByRole(\"table\")).toBeNull();","     expect(screen.queryByRole(\"status\")).toBeNull();","   });","+","+  // FR-14 mutation UI — column visibility is gated by `canCancelDogpile`,","+  // computed at the page level via `isActionAllowedForRole(\"dogpile.cancel\", actor.role)`.","+  it(\"denied actor hidden: defaults to no 'Cancel' column and renders no cancel forms\", () => {","+    render(","+      <DogpileEventsTable","+        rows={[ROW_SCHEDULED, ROW_ACTIVE, ROW_ENDED, ROW_CANCELLED]}","+      />,","+    );","+","+    expect(screen.queryByText(\"Cancel\")).toBeNull();","+    expect(","+      screen.queryByRole(\"form\", { name: \"Cancel scheduled dogpile event\" }),","+    ).toBeNull();","+  });","+","+  it(\"authorized success path: canCancelDogpile adds the 'Cancel' column and shows the cancel form only for scheduled rows (active/ended/cancelled cells render no form)\", () => {","+    render(","+      <DogpileEventsTable","+        rows={[ROW_SCHEDULED, ROW_ACTIVE, ROW_ENDED, ROW_CANCELLED]}","+        canCancelDogpile","+      />,","+    );","+","+    // New column header surfaces.","+    expect(","+      screen.getByRole(\"columnheader\", { name: \"Cancel\" }),","+    ).toBeInTheDocument();","+","+    // Only the scheduled row gets a cancel form — active/ended/cancelled","+    // would all be denied by the runner, so the column is empty for them.","+    const forms = screen.getAllByRole(\"form\", {","+      name: \"Cancel scheduled dogpile event\",","+    });","+    expect(forms).toHaveLength(1);","+","+    // Submit copy on the scheduled row.","+    expect(","+      screen.getByRole(\"button\", { name: \"Cancel scheduled event\" }),","+    ).toBeInTheDocument();","+  });"," });"]}],"userModified":false,"replaceAll":false}}
