{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_017h4s7scM4YADGVKYwPmLmT","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011YxcRuMCr4ADqgCPMPeHdZ","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/mutations/__tests__/kol-rate-mutation-form.test.tsx","content":"// FR-14 mutation UI — KolRateMutationForm rendered structure.\n//\n// Authorized actors render the full form (wallet + rate + submit), the\n// pre-populated inputs come from the row's current values so the operator\n// sees the old → new diff before submission, and the hidden `userId` field\n// is carried through so the runner can resolve the target row. The\n// MutationFeedback footer is silent until the operator interacts with the\n// form (idle state).\n//\n// Authorization itself is enforced by the consumer table (`growth-kol-table`)\n// via the `canMutateKolRate` prop and re-checked server-side by\n// `runPeekMutation`. The form component does not gate visibility — its\n// \"denied actor hidden\" coverage lives in `growth-kol-table.test.tsx`.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { KolRateMutationForm } from \"../kol-rate-mutation-form\";\n\ndescribe(\"KolRateMutationForm\", () => {\n  it(\"authorized: renders editable wallet + rate inputs, submit button, hidden userId, and no feedback while idle\", () => {\n    const { container } = render(\n      <KolRateMutationForm\n        userId=\"u-1\"\n        walletCurrent=\"WalletAbc\"\n        rateBpsCurrent={250}\n      />,\n    );\n\n    // Form is labelled so the table renders accessibly with multiple rows.\n    expect(\n      screen.getByRole(\"form\", { name: \"Update KOL rate\" }),\n    ).toBeInTheDocument();\n\n    // Editable inputs surface old: <current> beside each one for visual diff.\n    expect(screen.getByText(\"old: WalletAbc\")).toBeInTheDocument();\n    expect(screen.getByText(\"old: 250\")).toBeInTheDocument();\n\n    const wallet = screen.getByLabelText(\"Wallet\") as HTMLInputElement;\n    expect(wallet).toBeRequired();\n    expect(wallet).toHaveValue(\"WalletAbc\");\n    expect(wallet.name).toBe(\"wallet\");\n\n    const rate = screen.getByLabelText(\"Rate (bps)\") as HTMLInputElement;\n    expect(rate).toBeRequired();\n    expect(rate).toHaveAttribute(\"type\", \"number\");\n    expect(rate).toHaveAttribute(\"min\", \"0\");\n    expect(rate).toHaveAttribute(\"max\", \"10000\");\n    expect(rate).toHaveValue(250);\n\n    // Submit affordance — initial label, not the pending one.\n    const submit = screen.getByRole(\"button\", { name: \"Apply rate change\" });\n    expect(submit).toHaveAttribute(\"type\", \"submit\");\n    expect(submit).not.toBeDisabled();\n\n    // Hidden userId is carried so the runner can locate the target row.\n    const hidden = container.querySelector(\n      \"input[type='hidden'][name='userId']\",\n    ) as HTMLInputElement | null;\n    expect(hidden).not.toBeNull();\n    expect(hidden?.value).toBe(\"u-1\");\n\n    // Idle: no feedback panel shows up before any interaction.\n    expect(screen.queryByRole(\"status\")).toBeNull();\n    expect(screen.queryByRole(\"alert\")).toBeNull();\n  });\n\n  it(\"authorized: rate input mirrors any non-zero pre-existing rate (regression: defaultValue must round-trip the row's current value)\", () => {\n    render(\n      <KolRateMutationForm\n        userId=\"u-2\"\n        walletCurrent=\"WalletXyz\"\n        rateBpsCurrent={9999}\n      />,\n    );\n\n    expect(screen.getByLabelText(\"Rate (bps)\")).toHaveValue(9999);\n    expect(screen.getByText(\"old: 9999\")).toBeInTheDocument();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":119,"cache_read_input_tokens":127178,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":119},"output_tokens":52,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"65159f28-4138-4a00-8878-b10db9efe60e","uuid":"4c337593-9f2b-4609-b5e8-6b607ccb4298"}
