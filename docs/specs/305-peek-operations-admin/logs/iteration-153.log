tems[0]).toHaveTextContent(\"must be between 0 and 10000\");\n\n    expect(items[1]).toHaveTextContent(\"wallet:\");\n    expect(items[1]).toHaveTextContent(\"required\");\n    // Multiple errors per field are joined with `; `.\n    expect(items[1]).toHaveTextContent(\"required; must be a valid base58 string\");\n  });\n\n  it(\"error: no fieldErrors → no list rendered (avoids a stray empty <ul>)\", () => {\n    const state: PeekMutationActionState = {\n      status: \"error\",\n      message: \"no fields\",\n      reason: \"execution_failed\",\n    };\n\n    const { container } = render(<MutationFeedback state={state} />);\n\n    expect(container.querySelectorAll(\"ul\").length).toBe(0);\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
