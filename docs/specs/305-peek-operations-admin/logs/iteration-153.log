{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015E3o4TdZuAcS9utAbN4WFT","type":"tool_result","content":"1\t// Reusable feedback panel for FR-14 mutation forms.\n2\t//\n3\t// Maps the runner-driven `PeekMutationActionState` to operator-friendly\n4\t// status lines:\n5\t//   - Success    → green \"✓ <message>\" line, role=\"status\".\n6\t//   - Failure    → red   \"✗ <message>\" line, role=\"alert\", with\n7\t//                  reason-specific copy (unauthorized / invalid_input /\n8\t//                  execution_failed / unknown_action / audit_emit_failed)\n9\t//                  and per-field error bullets when the runner returned\n10\t//                  `fieldErrors`.\n11\t//   - Idle       → renders nothing; the form footer is silent until the\n12\t//                  operator interacts with it.\n13\t//\n14\t// The panel is a pure presenter — the surrounding `<form>` owns the\n15\t// `useActionState` hook and feeds the state in.\n16\t\n17\t\"use client\";\n18\t\n19\timport type { CSSProperties } from \"react\";\n20\timport type { PeekMutationActionState } from \"../../server/actions/peek-mutations\";\n21\t\n22\texport type MutationFeedbackProps = {\n23\t  state: PeekMutationActionState;\n24\t  successLabel?: string;\n25\t};\n26\t\n27\texport function MutationFeedback({\n28\t  state,\n29\t  successLabel,\n30\t}: MutationFeedbackProps) {\n31\t  if (state.status === \"idle\") return null;\n32\t\n33\t  if (state.status === \"ok\") {\n34\t    const label = successLabel ?? \"Change applied.\";\n35\t    const detail = state.resourceId ? ` (id ${state.resourceId})` : \"\";\n36\t    return (\n37\t      <p role=\"status\" style={successStyle}>\n38\t        ✓ {label}\n39\t        {detail}\n40\t      </p>\n41\t    );\n42\t  }\n43\t\n44\t  const reasonHint = describeFailure(state);\n45\t  const fieldErrorEntries: ReadonlyArray<readonly [string, ReadonlyArray<string>]> =\n46\t    state.fieldErrors\n47\t      ? Object.entries(state.fieldErrors).map(\n48\t          ([k, v]) => [k, v] as const,\n49\t        )\n50\t      : [];\n51\t\n52\t  return (\n53\t    <div role=\"alert\" style={errorStyle}>\n54\t      <p style={errorTitleStyle}>✗ {reasonHint}</p>\n55\t      <p style={errorBodyStyle}>{state.message}</p>\n56\t      {fieldErrorEntries.length > 0 ? (\n57\t        <ul style={errorListStyle}>\n58\t          {fieldErrorEntries.map(([field, errors]) => (\n59\t            <li key={field}>\n60\t              <span style={errorFieldStyle}>{field}:</span>{\" \"}\n61\t              {errors.join(\"; \")}\n62\t            </li>\n63\t          ))}\n64\t        </ul>\n65\t      ) : null}\n66\t    </div>\n67\t  );\n68\t}\n69\t\n70\tfunction describeFailure(state: PeekMutationActionState): string {\n71\t  switch (state.reason) {\n72\t    case \"no_actor\":\n73\t      return \"Not authenticated.\";\n74\t    case \"unauthorized\":\n75\t      return \"You are not authorized to perform this action.\";\n76\t    case \"invalid_input\":\n77\t      return \"The submitted values are invalid.\";\n78\t    case \"execution_failed\":\n79\t      return \"The change could not be applied.\";\n80\t    case \"unknown_action\":\n81\t      return \"Unknown mutation action.\";\n82\t    case \"audit_emit_failed\":\n83\t      return \"Audit logging failed; the change was rolled back.\";\n84\t    default:\n85\t      return \"Mutation failed.\";\n86\t  }\n87\t}\n88\t\n89\tconst successStyle: CSSProperties = {\n90\t  margin: 0,\n91\t  padding: \"0.5rem 0.75rem\",\n92\t  borderRadius: \"0.5rem\",\n93\t  background: \"#0c2818\",\n94\t  color: \"#86efac\",\n95\t  fontSize: \"0.8125rem\",\n96\t};\n97\t\n98\tconst errorStyle: CSSProperties = {\n99\t  margin: 0,\n100\t  padding: \"0.5rem 0.75rem\",\n101\t  borderRadius: \"0.5rem\",\n102\t  background: \"#3f1d1d\",\n103\t  color: \"#fecaca\",\n104\t  display: \"grid\",\n105\t  gap: \"0.25rem\",\n106\t};\n107\t\n108\tconst errorTitleStyle: CSSProperties = {\n109\t  margin: 0,\n110\t  fontSize: \"0.875rem\",\n111\t  fontWeight: 600,\n112\t};\n113\t\n114\tconst errorBodyStyle: CSSProperties = {\n115\t  margin: 0,\n116\t  fontSize: \"0.8125rem\",\n117\t  color: \"#fcd9d9\",\n118\t};\n119\t\n120\tconst errorListStyle: CSSProperties = {\n121\t  margin: 0,\n122\t  paddingLeft: \"1rem\",\n123\t  fontSize: \"0.75rem\",\n124\t  color: \"#fbcfe8\",\n125\t};\n126\t\n127\tconst errorFieldStyle: CSSProperties = {\n128\t  fontFamily: \"monospace\",\n129\t  color: \"#fda4af\",\n130\t};\n131\t"}]},"parent_tool_use_id":null,"session_id":"65159f28-4138-4a00-8878-b10db9efe60e","uuid":"166bcc11-ef55-4ca6-ac87-1547dd2882cc","timestamp":"2026-04-26T19:45:06.428Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/mutations/mutation-feedback.tsx","content":"// Reusable feedback panel for FR-14 mutation forms.\n//\n// Maps the runner-driven `PeekMutationActionState` to operator-friendly\n// status lines:\n//   - Success    → green \"✓ <message>\" line, role=\"status\".\n//   - Failure    → red   \"✗ <message>\" line, role=\"alert\", with\n//                  reason-specific copy (unauthorized / invalid_input /\n//                  execution_failed / unknown_action / audit_emit_failed)\n//                  and per-field error bullets when the runner returned\n//                  `fieldErrors`.\n//   - Idle       → renders nothing; the form footer is silent until the\n//                  operator interacts with it.\n//\n// The panel is a pure presenter — the surrounding `<form>` owns the\n// `useActionState` hook and feeds the state in.\n\n\"use client\";\n\nimport type { CSSProperties } from \"react\";\nimport type { PeekMutationActionState } from \"../../server/actions/peek-mutations\";\n\nexport type MutationFeedbackProps = {\n  state: PeekMutationActionState;\n  successLabel?: string;\n};\n\nexport function MutationFeedback({\n  state,\n  successLabel,\n}: MutationFeedbackProps) {\n  if (state.status === \"idle\") return null;\n\n  if (state.status === \"ok\") {\n    const label = successLabel ?? \"Change applied.\";\n    const detail = state.resourceId ? ` (id ${state.resourceId})` : \"\";\n    return (\n      <p role=\"status\" style={successStyle}>\n        ✓ {label}\n        {detail}\n      </p>\n    );\n  }\n\n  const reasonHint = describeFailure(state);\n  const fieldErrorEntries: ReadonlyArray<readonly [string, ReadonlyArray<string>]> =\n    state.fieldErrors\n      ? Object.entries(state.fieldErrors).map(\n          ([k, v]) => [k, v] as const,\n        )\n      : [];\n\n  return (\n    <div role=\"alert\" style={errorStyle}>\n      <p style={errorTitleStyle}>✗ {reasonHint}</p>\n      <p style={errorBodyStyle}>{state.message}</p>\n      {fieldErrorEntries.length > 0 ? (\n        <ul style={errorListStyle}>\n          {fieldErrorEntries.map(([field, errors]) => (\n            <li key={field}>\n              <span style={errorFieldStyle}>{field}:</span>{\" \"}\n              {errors.join(\"; \")}\n            </li>\n          ))}\n        </ul>\n      ) : null}\n    </div>\n  );\n}\n\nfunction describeFailure(state: PeekMutationActionState): string {\n  switch (state.reason) {\n    case \"no_actor\":\n      return \"Not authenticated.\";\n    case \"unauthorized\":\n      return \"You are not authorized to perform this action.\";\n    case \"invalid_input\":\n      return \"The submitted values are invalid.\";\n    case \"execution_failed\":\n      return \"The change could not be applied.\";\n    case \"unknown_action\":\n      return \"Unknown mutation action.\";\n    case \"audit_emit_failed\":\n      return \"Audit logging failed; the change was rolled back.\";\n    default:\n      return \"Mutation failed.\";\n  }\n}\n\nconst successStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.5rem 0.75rem\",\n  borderRadius: \"0.5rem\",\n  background: \"#0c2818\",\n  color: \"#86efac\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.5rem 0.75rem\",\n  borderRadius: \"0.5rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst errorTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  fontWeight: 600,\n};\n\nconst errorBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.8125rem\",\n  color: \"#fcd9d9\",\n};\n\nconst errorListStyle: CSSProperties = {\n  margin: 0,\n  paddingLeft: \"1rem\",\n  fontSize: \"0.75rem\",\n  color: \"#fbcfe8\",\n};\n\nconst errorFieldStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  color: \"#fda4af\",\n};\n","numLines":131,"startLine":1,"totalLines":131}}}
