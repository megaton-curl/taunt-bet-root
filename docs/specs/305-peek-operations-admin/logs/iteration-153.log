{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MuFAt4WBum51bA4Kp7jRSL","type":"tool_result","content":"1\t// FR-14 mutation form: create or update a KOL rate row.\n2\t//\n3\t// Rendered inline in `growth-kol-table.tsx` for actors whose role passes\n4\t// the `kol_rate.update` action rule (business or admin). Two editable\n5\t// fields (wallet, rateBps) are pre-populated from the existing row so\n6\t// the operator sees the old/new pair before submission. Submission goes\n7\t// through the `kolRateUpdateAction` server action which re-runs the\n8\t// FR-2 role check and FR-14 audit pipeline; rejection feedback is\n9\t// rendered via `MutationFeedback`.\n10\t\n11\t\"use client\";\n12\t\n13\timport type { CSSProperties } from \"react\";\n14\timport { useActionState, useId } from \"react\";\n15\timport {\n16\t  PEEK_MUTATION_INITIAL_STATE,\n17\t  kolRateUpdateAction,\n18\t} from \"../../server/actions/peek-mutations\";\n19\timport { MutationFeedback } from \"./mutation-feedback\";\n20\t\n21\texport type KolRateMutationFormProps = {\n22\t  userId: string;\n23\t  walletCurrent: string;\n24\t  rateBpsCurrent: number;\n25\t};\n26\t\n27\texport function KolRateMutationForm({\n28\t  userId,\n29\t  walletCurrent,\n30\t  rateBpsCurrent,\n31\t}: KolRateMutationFormProps) {\n32\t  const [state, dispatch, pending] = useActionState(\n33\t    kolRateUpdateAction,\n34\t    PEEK_MUTATION_INITIAL_STATE,\n35\t  );\n36\t  const walletId = useId();\n37\t  const rateId = useId();\n38\t\n39\t  return (\n40\t    <form action={dispatch} style={formStyle} aria-label=\"Update KOL rate\">\n41\t      <input type=\"hidden\" name=\"userId\" value={userId} />\n42\t\n43\t      <div style={fieldRowStyle}>\n44\t        <label htmlFor={walletId} style={labelStyle}>\n45\t          Wallet\n46\t        </label>\n47\t        <div style={oldValueStyle}>old: {walletCurrent}</div>\n48\t        <input\n49\t          id={walletId}\n50\t          name=\"wallet\"\n51\t          type=\"text\"\n52\t          defaultValue={walletCurrent}\n53\t          required\n54\t          style={inputStyle}\n55\t          autoComplete=\"off\"\n56\t          spellCheck={false}\n57\t        />\n58\t      </div>\n59\t\n60\t      <div style={fieldRowStyle}>\n61\t        <label htmlFor={rateId} style={labelStyle}>\n62\t          Rate (bps)\n63\t        </label>\n64\t        <div style={oldValueStyle}>old: {rateBpsCurrent}</div>\n65\t        <input\n66\t          id={rateId}\n67\t          name=\"rateBps\"\n68\t          type=\"number\"\n69\t          min={0}\n70\t          max={10000}\n71\t          step={1}\n72\t          defaultValue={rateBpsCurrent}\n73\t          required\n74\t          style={inputStyle}\n75\t        />\n76\t      </div>\n77\t\n78\t      <button type=\"submit\" disabled={pending} style={submitStyle}>\n79\t        {pending ? \"Applying…\" : \"Apply rate change\"}\n80\t      </button>\n81\t\n82\t      <MutationFeedback state={state} successLabel=\"KOL rate updated.\" />\n83\t    </form>\n84\t  );\n85\t}\n86\t\n87\tconst formStyle: CSSProperties = {\n88\t  display: \"grid\",\n89\t  gap: \"0.5rem\",\n90\t};\n91\t\n92\tconst fieldRowStyle: CSSProperties = {\n93\t  display: \"grid\",\n94\t  gap: \"0.25rem\",\n95\t};\n96\t\n97\tconst labelStyle: CSSProperties = {\n98\t  fontSize: \"0.75rem\",\n99\t  textTransform: \"uppercase\",\n100\t  letterSpacing: \"0.05em\",\n101\t  color: \"#94a3b8\",\n102\t};\n103\t\n104\tconst oldValueStyle: CSSProperties = {\n105\t  fontSize: \"0.75rem\",\n106\t  color: \"#64748b\",\n107\t  fontFamily: \"monospace\",\n108\t};\n109\t\n110\tconst inputStyle: CSSProperties = {\n111\t  padding: \"0.375rem 0.5rem\",\n112\t  borderRadius: \"0.375rem\",\n113\t  border: \"1px solid #334155\",\n114\t  background: \"#0f172a\",\n115\t  color: \"#e2e8f0\",\n116\t  fontSize: \"0.8125rem\",\n117\t  fontFamily: \"monospace\",\n118\t};\n119\t\n120\tconst submitStyle: CSSProperties = {\n121\t  padding: \"0.375rem 0.75rem\",\n122\t  borderRadius: \"0.375rem\",\n123\t  border: \"1px solid #1e3a8a\",\n124\t  background: \"#1e40af\",\n125\t  color: \"#dbeafe\",\n126\t  fontSize: \"0.8125rem\",\n127\t  fontWeight: 600,\n128\t  cursor: \"pointer\",\n129\t};\n130\t"}]},"parent_tool_use_id":null,"session_id":"65159f28-4138-4a00-8878-b10db9efe60e","uuid":"544bfad4-d271-4fb2-9159-b1613b2b7b18","timestamp":"2026-04-26T19:45:09.620Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/mutations/kol-rate-mutation-form.tsx","content":"// FR-14 mutation form: create or update a KOL rate row.\n//\n// Rendered inline in `growth-kol-table.tsx` for actors whose role passes\n// the `kol_rate.update` action rule (business or admin). Two editable\n// fields (wallet, rateBps) are pre-populated from the existing row so\n// the operator sees the old/new pair before submission. Submission goes\n// through the `kolRateUpdateAction` server action which re-runs the\n// FR-2 role check and FR-14 audit pipeline; rejection feedback is\n// rendered via `MutationFeedback`.\n\n\"use client\";\n\nimport type { CSSProperties } from \"react\";\nimport { useActionState, useId } from \"react\";\nimport {\n  PEEK_MUTATION_INITIAL_STATE,\n  kolRateUpdateAction,\n} from \"../../server/actions/peek-mutations\";\nimport { MutationFeedback } from \"./mutation-feedback\";\n\nexport type KolRateMutationFormProps = {\n  userId: string;\n  walletCurrent: string;\n  rateBpsCurrent: number;\n};\n\nexport function KolRateMutationForm({\n  userId,\n  walletCurrent,\n  rateBpsCurrent,\n}: KolRateMutationFormProps) {\n  const [state, dispatch, pending] = useActionState(\n    kolRateUpdateAction,\n    PEEK_MUTATION_INITIAL_STATE,\n  );\n  const walletId = useId();\n  const rateId = useId();\n\n  return (\n    <form action={dispatch} style={formStyle} aria-label=\"Update KOL rate\">\n      <input type=\"hidden\" name=\"userId\" value={userId} />\n\n      <div style={fieldRowStyle}>\n        <label htmlFor={walletId} style={labelStyle}>\n          Wallet\n        </label>\n        <div style={oldValueStyle}>old: {walletCurrent}</div>\n        <input\n          id={walletId}\n          name=\"wallet\"\n          type=\"text\"\n          defaultValue={walletCurrent}\n          required\n          style={inputStyle}\n          autoComplete=\"off\"\n          spellCheck={false}\n        />\n      </div>\n\n      <div style={fieldRowStyle}>\n        <label htmlFor={rateId} style={labelStyle}>\n          Rate (bps)\n        </label>\n        <div style={oldValueStyle}>old: {rateBpsCurrent}</div>\n        <input\n          id={rateId}\n          name=\"rateBps\"\n          type=\"number\"\n          min={0}\n          max={10000}\n          step={1}\n          defaultValue={rateBpsCurrent}\n          required\n          style={inputStyle}\n        />\n      </div>\n\n      <button type=\"submit\" disabled={pending} style={submitStyle}>\n        {pending ? \"Applying…\" : \"Apply rate change\"}\n      </button>\n\n      <MutationFeedback state={state} successLabel=\"KOL rate updated.\" />\n    </form>\n  );\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst fieldRowStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst labelStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n  color: \"#94a3b8\",\n};\n\nconst oldValueStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  color: \"#64748b\",\n  fontFamily: \"monospace\",\n};\n\nconst inputStyle: CSSProperties = {\n  padding: \"0.375rem 0.5rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #334155\",\n  background: \"#0f172a\",\n  color: \"#e2e8f0\",\n  fontSize: \"0.8125rem\",\n  fontFamily: \"monospace\",\n};\n\nconst submitStyle: CSSProperties = {\n  padding: \"0.375rem 0.75rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #1e3a8a\",\n  background: \"#1e40af\",\n  color: \"#dbeafe\",\n  fontSize: \"0.8125rem\",\n  fontWeight: 600,\n  cursor: \"pointer\",\n};\n","numLines":130,"startLine":1,"totalLines":130}}}
