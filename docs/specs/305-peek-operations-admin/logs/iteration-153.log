{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019Pyb6UVDZhUarMGcg3A8AN","type":"tool_result","content":"1\t// Next.js Server Actions that wrap the FR-14 mutation runner.\n2\t//\n3\t// These actions are the only client-callable entry point into\n4\t// `runPeekMutation`. Each:\n5\t//   1. Resolves the verified Cloudflare actor via `getPeekActorContext()`\n6\t//      (server-only headers; never trusts browser-supplied identity).\n7\t//   2. Re-runs the runner's role/schema/transaction/audit pipeline so the\n8\t//      `peek.change.applied` / `peek.change.rejected` audit semantics are\n9\t//      identical regardless of whether the call originated from a UI form\n10\t//      or a future direct invocation.\n11\t//   3. Translates the runner's `PeekMutationRunResult` into a\n12\t//      `PeekMutationActionState` that React forms can consume via\n13\t//      `useActionState`. Error reasons (`unauthorized`, `invalid_input`,\n14\t//      `execution_failed`, ...) round-trip so the UI can show\n15\t//      rejection-specific messaging.\n16\t//   4. Calls `revalidatePath` on the source admin route so the page\n17\t//      re-renders the post-mutation database state.\n18\t//\n19\t// Form parsing intentionally lives here (not in the runner): the server\n20\t// action sees a raw `FormData`, coerces named fields into the typed shape\n21\t// the mutation's zod schema expects, and lets the schema decide what\n22\t// passes. Coercion failures (e.g. non-numeric `rateBps`) are surfaced to\n23\t// the runner so the rejection still emits `peek.change.rejected` with\n24\t// `rejectionReason: \"invalid_input\"` — the UI cannot silently drop a\n25\t// failed change.\n26\t\n27\t\"use server\";\n28\t\n29\timport { revalidatePath } from \"next/cache\";\n30\timport { headers } from \"next/headers\";\n31\timport { getPeekActorContext } from \"../access-policy\";\n32\timport { runPeekMutation } from \"../mutations\";\n33\timport type {\n34\t  PeekMutationActionId,\n35\t  PeekMutationFailureReason,\n36\t  PeekMutationRunResult,\n37\t} from \"../mutations\";\n38\t\n39\texport type PeekMutationActionStatus = \"idle\" | \"ok\" | \"error\";\n40\t\n41\texport type PeekMutationActionState = {\n42\t  status: PeekMutationActionStatus;\n43\t  message: string;\n44\t  reason?: PeekMutationFailureReason | \"no_actor\";\n45\t  fieldErrors?: Record<string, ReadonlyArray<string>>;\n46\t  resourceId?: string | null;\n47\t  // Echoed back so the UI can show a stable \"X.Y was applied\" line even\n48\t  // after the form re-renders; not a security boundary.\n49\t  actionId?: PeekMutationActionId;\n50\t};\n51\t\n52\texport const PEEK_MUTATION_INITIAL_STATE: PeekMutationActionState = {\n53\t  status: \"idle\",\n54\t  message: \"\",\n55\t};\n56\t\n57\ttype DispatchOptions = {\n58\t  actionId: PeekMutationActionId;\n59\t  rawInput: unknown;\n60\t  route: string;\n61\t};\n62\t\n63\tasync function dispatchMutation(\n64\t  opts: DispatchOptions,\n65\t): Promise<PeekMutationActionState> {\n66\t  const actor = await getPeekActorContext();\n67\t  if (!actor) {\n68\t    return {\n69\t      status: \"error\",\n70\t      message: \"You are not authenticated.\",\n71\t      reason: \"no_actor\",\n72\t      actionId: opts.actionId,\n73\t    };\n74\t  }\n75\t\n76\t  const requestId = (await headers()).get(\"x-request-id\");\n77\t\n78\t  const result: PeekMutationRunResult = await runPeekMutation({\n79\t    actionId: opts.actionId,\n80\t    rawInput: opts.rawInput,\n81\t    actorRole: actor.role,\n82\t    actor: {\n83\t      email: actor.email,\n84\t      route: opts.route,\n85\t      requestId,\n86\t    },\n87\t  });\n88\t\n89\t  if (!result.ok) {\n90\t    return {\n91\t      status: \"error\",\n92\t      message: result.message,\n93\t      reason: result.reason,\n94\t      fieldErrors: result.fieldErrors as\n95\t        | Record<string, ReadonlyArray<string>>\n96\t        | undefined,\n97\t      actionId: opts.actionId,\n98\t    };\n99\t  }\n100\t\n101\t  revalidatePath(opts.route);\n102\t\n103\t  return {\n104\t    status: \"ok\",\n105\t    message: \"Change applied.\",\n106\t    resourceId: result.resourceId,\n107\t    actionId: opts.actionId,\n108\t  };\n109\t}\n110\t\n111\tfunction readString(formData: FormData, key: string): string {\n112\t  const raw = formData.get(key);\n113\t  return typeof raw === \"string\" ? raw : \"\";\n114\t}\n115\t\n116\tfunction readOptionalNumber(\n117\t  formData: FormData,\n118\t  key: string,\n119\t): number | string {\n120\t  const raw = readString(formData, key).trim();\n121\t  if (raw === \"\") return raw;\n122\t  const parsed = Number(raw);\n123\t  // Hand the raw string back when the cast is non-numeric; the zod\n124\t  // schema will reject it with `invalid_input` rather than the UI\n125\t  // silently coercing it to NaN.\n126\t  return Number.isFinite(parsed) ? parsed : raw;\n127\t}\n128\t\n129\texport async function kolRateUpdateAction(\n130\t  _prev: PeekMutationActionState,\n131\t  formData: FormData,\n132\t): Promise<PeekMutationActionState> {\n133\t  return dispatchMutation({\n134\t    actionId: \"kol_rate.update\",\n135\t    rawInput: {\n136\t      userId: readString(formData, \"userId\"),\n137\t      wallet: readString(formData, \"wallet\"),\n138\t      rateBps: readOptionalNumber(formData, \"rateBps\"),\n139\t    },\n140\t    route: \"/growth/kol\",\n141\t  });\n142\t}\n143\t\n144\texport async function fraudFlagStatusUpdateAction(\n145\t  _prev: PeekMutationActionState,\n146\t  formData: FormData,\n147\t): Promise<PeekMutationActionState> {\n148\t  return dispatchMutation({\n149\t    actionId: \"fraud_flag.status.update\",\n150\t    rawInput: {\n151\t      flagId: readString(formData, \"flagId\"),\n152\t      nextStatus: readString(formData, \"nextStatus\"),\n153\t    },\n154\t    route: \"/operations/dogpile\",\n155\t  });\n156\t}\n157\t\n158\texport async function dogpileCancelAction(\n159\t  _prev: PeekMutationActionState,\n160\t  formData: FormData,\n161\t): Promise<PeekMutationActionState> {\n162\t  return dispatchMutation({\n163\t    actionId: \"dogpile.cancel\",\n164\t    rawInput: {\n165\t      eventId: readString(formData, \"eventId\"),\n166\t    },\n167\t    route: \"/operations/dogpile\",\n168\t  });\n169\t}\n170\t\n171\texport async function rewardConfigUpdateAction(\n172\t  _prev: PeekMutationActionState,\n173\t  formData: FormData,\n174\t): Promise<PeekMutationActionState> {\n175\t  // The mutation schema requires the literal `true` for confirm; the\n176\t  // `<input type=\"checkbox\">` posts the literal string \"true\" only when\n177\t  // the box is checked. Anything else (missing key, \"on\", \"false\") is\n178\t  // rejected by the schema as `invalid_input`.\n179\t  const confirmRaw = readString(formData, \"confirm\");\n180\t  return dispatchMutation({\n181\t    actionId: \"reward_config.update\",\n182\t    rawInput: {\n183\t      key: readString(formData, \"key\"),\n184\t      value: readString(formData, \"value\"),\n185\t      confirm: confirmRaw === \"true\" ? true : confirmRaw,\n186\t    },\n187\t    route: \"/economy/rewards\",\n188\t  });\n189\t}\n190\t"}]},"parent_tool_use_id":null,"session_id":"65159f28-4138-4a00-8878-b10db9efe60e","uuid":"1276c25c-94d8-4ea0-857d-19fde2213381","timestamp":"2026-04-26T19:45:20.060Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/actions/peek-mutations.ts","content":"// Next.js Server Actions that wrap the FR-14 mutation runner.\n//\n// These actions are the only client-callable entry point into\n// `runPeekMutation`. Each:\n//   1. Resolves the verified Cloudflare actor via `getPeekActorContext()`\n//      (server-only headers; never trusts browser-supplied identity).\n//   2. Re-runs the runner's role/schema/transaction/audit pipeline so the\n//      `peek.change.applied` / `peek.change.rejected` audit semantics are\n//      identical regardless of whether the call originated from a UI form\n//      or a future direct invocation.\n//   3. Translates the runner's `PeekMutationRunResult` into a\n//      `PeekMutationActionState` that React forms can consume via\n//      `useActionState`. Error reasons (`unauthorized`, `invalid_input`,\n//      `execution_failed`, ...) round-trip so the UI can show\n//      rejection-specific messaging.\n//   4. Calls `revalidatePath` on the source admin route so the page\n//      re-renders the post-mutation database state.\n//\n// Form parsing intentionally lives here (not in the runner): the server\n// action sees a raw `FormData`, coerces named fields into the typed shape\n// the mutation's zod schema expects, and lets the schema decide what\n// passes. Coercion failures (e.g. non-numeric `rateBps`) are surfaced to\n// the runner so the rejection still emits `peek.change.rejected` with\n// `rejectionReason: \"invalid_input\"` — the UI cannot silently drop a\n// failed change.\n\n\"use server\";\n\nimport { revalidatePath } from \"next/cache\";\nimport { headers } from \"next/headers\";\nimport { getPeekActorContext } from \"../access-policy\";\nimport { runPeekMutation } from \"../mutations\";\nimport type {\n  PeekMutationActionId,\n  PeekMutationFailureReason,\n  PeekMutationRunResult,\n} from \"../mutations\";\n\nexport type PeekMutationActionStatus = \"idle\" | \"ok\" | \"error\";\n\nexport type PeekMutationActionState = {\n  status: PeekMutationActionStatus;\n  message: string;\n  reason?: PeekMutationFailureReason | \"no_actor\";\n  fieldErrors?: Record<string, ReadonlyArray<string>>;\n  resourceId?: string | null;\n  // Echoed back so the UI can show a stable \"X.Y was applied\" line even\n  // after the form re-renders; not a security boundary.\n  actionId?: PeekMutationActionId;\n};\n\nexport const PEEK_MUTATION_INITIAL_STATE: PeekMutationActionState = {\n  status: \"idle\",\n  message: \"\",\n};\n\ntype DispatchOptions = {\n  actionId: PeekMutationActionId;\n  rawInput: unknown;\n  route: string;\n};\n\nasync function dispatchMutation(\n  opts: DispatchOptions,\n): Promise<PeekMutationActionState> {\n  const actor = await getPeekActorContext();\n  if (!actor) {\n    return {\n      status: \"error\",\n      message: \"You are not authenticated.\",\n      reason: \"no_actor\",\n      actionId: opts.actionId,\n    };\n  }\n\n  const requestId = (await headers()).get(\"x-request-id\");\n\n  const result: PeekMutationRunResult = await runPeekMutation({\n    actionId: opts.actionId,\n    rawInput: opts.rawInput,\n    actorRole: actor.role,\n    actor: {\n      email: actor.email,\n      route: opts.route,\n      requestId,\n    },\n  });\n\n  if (!result.ok) {\n    return {\n      status: \"error\",\n      message: result.message,\n      reason: result.reason,\n      fieldErrors: result.fieldErrors as\n        | Record<string, ReadonlyArray<string>>\n        | undefined,\n      actionId: opts.actionId,\n    };\n  }\n\n  revalidatePath(opts.route);\n\n  return {\n    status: \"ok\",\n    message: \"Change applied.\",\n    resourceId: result.resourceId,\n    actionId: opts.actionId,\n  };\n}\n\nfunction readString(formData: FormData, key: string): string {\n  const raw = formData.get(key);\n  return typeof raw === \"string\" ? raw : \"\";\n}\n\nfunction readOptionalNumber(\n  formData: FormData,\n  key: string,\n): number | string {\n  const raw = readString(formData, key).trim();\n  if (raw === \"\") return raw;\n  const parsed = Number(raw);\n  // Hand the raw string back when the cast is non-numeric; the zod\n  // schema will reject it with `invalid_input` rather than the UI\n  // silently coercing it to NaN.\n  return Number.isFinite(parsed) ? parsed : raw;\n}\n\nexport async function kolRateUpdateAction(\n  _prev: PeekMutationActionState,\n  formData: FormData,\n): Promise<PeekMutationActionState> {\n  return dispatchMutation({\n    actionId: \"kol_rate.update\",\n    rawInput: {\n      userId: readString(formData, \"userId\"),\n      wallet: readString(formData, \"wallet\"),\n      rateBps: readOptionalNumber(formData, \"rateBps\"),\n    },\n    route: \"/growth/kol\",\n  });\n}\n\nexport async function fraudFlagStatusUpdateAction(\n  _prev: PeekMutationActionState,\n  formData: FormData,\n): Promise<PeekMutationActionState> {\n  return dispatchMutation({\n    actionId: \"fraud_flag.status.update\",\n    rawInput: {\n      flagId: readString(formData, \"flagId\"),\n      nextStatus: readString(formData, \"nextStatus\"),\n    },\n    route: \"/operations/dogpile\",\n  });\n}\n\nexport async function dogpileCancelAction(\n  _prev: PeekMutationActionState,\n  formData: FormData,\n): Promise<PeekMutationActionState> {\n  return dispatchMutation({\n    actionId: \"dogpile.cancel\",\n    rawInput: {\n      eventId: readString(formData, \"eventId\"),\n    },\n    route: \"/operations/dogpile\",\n  });\n}\n\nexport async function rewardConfigUpdateAction(\n  _prev: PeekMutationActionState,\n  formData: FormData,\n): Promise<PeekMutationActionState> {\n  // The mutation schema requires the literal `true` for confirm; the\n  // `<input type=\"checkbox\">` posts the literal string \"true\" only when\n  // the box is checked. Anything else (missing key, \"on\", \"false\") is\n  // rejected by the schema as `invalid_input`.\n  const confirmRaw = readString(formData, \"confirm\");\n  return dispatchMutation({\n    actionId: \"reward_config.update\",\n    rawInput: {\n      key: readString(formData, \"key\"),\n      value: readString(formData, \"value\"),\n      confirm: confirmRaw === \"true\" ? true : confirmRaw,\n    },\n    route: \"/economy/rewards\",\n  });\n}\n","numLines":190,"startLine":1,"totalLines":190}}}
