{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NWFZ5ZiVXdpVCQdtpfFJwp","type":"tool_result","content":"1\t// KOL performance table for /growth/kol (FR-7).\n2\t//\n3\t// Reads `referral_kol_rates` joined with linked performance from\n4\t// `referral_links` + `referral_earnings`. Drill-down per row to user-detail.\n5\t//\n6\t// FR-14 wiring: when `canMutateKolRate` is true the table appends an\n7\t// \"Edit rate\" column rendering `KolRateMutationForm` per row. The column\n8\t// is computed at the page level (`isActionAllowedForRole(\"kol_rate.update\",\n9\t// actor.role)`) so non-authorized actors do not see the control at all.\n10\timport Link from \"next/link\";\n11\timport type { CSSProperties } from \"react\";\n12\timport type { PeekKolPerformanceRow } from \"../lib/types/peek\";\n13\timport { KolRateMutationForm } from \"./mutations/kol-rate-mutation-form\";\n14\t\n15\texport type GrowthKolTableProps = {\n16\t  rows: ReadonlyArray<PeekKolPerformanceRow>;\n17\t  error?: string | null;\n18\t  canMutateKolRate?: boolean;\n19\t};\n20\t\n21\texport function GrowthKolTable({\n22\t  rows,\n23\t  error = null,\n24\t  canMutateKolRate = false,\n25\t}: GrowthKolTableProps) {\n26\t  if (error) {\n27\t    return (\n28\t      <div role=\"alert\" style={errorStyle}>\n29\t        KOL table unavailable: {error}\n30\t      </div>\n31\t    );\n32\t  }\n33\t\n34\t  if (rows.length === 0) {\n35\t    return (\n36\t      <div role=\"status\" style={emptyStyle}>\n37\t        <p style={emptyTitleStyle}>No KOL rates configured.</p>\n38\t        <p style={emptyBodyStyle}>\n39\t          No rows in `referral_kol_rates` — KOL pricing has not been applied\n40\t          to any user yet.\n41\t        </p>\n42\t      </div>\n43\t    );\n44\t  }\n45\t\n46\t  return (\n47\t    <div style={wrapperStyle}>\n48\t      <table style={tableStyle}>\n49\t        <thead>\n50\t          <tr style={headerRowStyle}>\n51\t            <th style={headerCellStyle(\"left\")}>User</th>\n52\t            <th style={headerCellStyle(\"left\")}>Wallet</th>\n53\t            <th style={headerCellStyle(\"right\")}>Rate (bps)</th>\n54\t            <th style={headerCellStyle(\"left\")}>Set by</th>\n55\t            <th style={headerCellStyle(\"left\")}>Created</th>\n56\t            <th style={headerCellStyle(\"left\")}>Updated</th>\n57\t            <th style={headerCellStyle(\"right\")}>Referees</th>\n58\t            <th style={headerCellStyle(\"right\")}>Wager (lamports)</th>\n59\t            <th style={headerCellStyle(\"right\")}>Earned (lamports)</th>\n60\t            {canMutateKolRate ? (\n61\t              <th style={headerCellStyle(\"left\")}>Edit rate</th>\n62\t            ) : null}\n63\t          </tr>\n64\t        </thead>\n65\t        <tbody>\n66\t          {rows.map((row) => (\n67\t            <tr key={row.userId} style={bodyRowStyle}>\n68\t              <td style={bodyCellStyle(\"left\")}>\n69\t                <Link href={`/users/${row.userId}`} style={linkStyle}>\n70\t                  {row.username ?? row.userId}\n71\t                </Link>\n72\t                {row.username ? (\n73\t                  <span style={subValueStyle}> · {row.userId}</span>\n74\t                ) : null}\n75\t              </td>\n76\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n77\t                {row.wallet}\n78\t              </td>\n79\t              <td style={bodyCellStyle(\"right\")}>{row.rateBps}</td>\n80\t              <td style={bodyCellStyle(\"left\")}>{row.setBy}</td>\n81\t              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n82\t              <td style={bodyCellStyle(\"left\")}>{row.updatedAt}</td>\n83\t              <td style={bodyCellStyle(\"right\")}>{row.refereeCount}</td>\n84\t              <td style={bodyCellStyle(\"right\")}>\n85\t                {formatLamports(row.referredWagerLamports)}\n86\t              </td>\n87\t              <td style={bodyCellStyle(\"right\")}>\n88\t                {formatLamports(row.referrerEarnedLamports)}\n89\t              </td>\n90\t              {canMutateKolRate ? (\n91\t                <td style={bodyCellStyle(\"left\")}>\n92\t                  <KolRateMutationForm\n93\t                    userId={row.userId}\n94\t                    walletCurrent={row.wallet}\n95\t                    rateBpsCurrent={row.rateBps}\n96\t                  />\n97\t                </td>\n98\t              ) : null}\n99\t            </tr>\n100\t          ))}\n101\t        </tbody>\n102\t      </table>\n103\t    </div>\n104\t  );\n105\t}\n106\t\n107\tfunction formatLamports(value: string): string {\n108\t  if (!value || value === \"0\") return \"0\";\n109\t  const negative = value.startsWith(\"-\");\n110\t  const digits = negative ? value.slice(1) : value;\n111\t  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n112\t  return negative ? `-${grouped}` : grouped;\n113\t}\n114\t\n115\tconst wrapperStyle: CSSProperties = {\n116\t  overflowX: \"auto\",\n117\t  border: \"1px solid #1e293b\",\n118\t  borderRadius: \"0.75rem\",\n119\t};\n120\t\n121\tconst tableStyle: CSSProperties = {\n122\t  width: \"100%\",\n123\t  borderCollapse: \"collapse\",\n124\t};\n125\t\n126\tconst headerRowStyle: CSSProperties = {\n127\t  background: \"#111827\",\n128\t  color: \"#94a3b8\",\n129\t};\n130\t\n131\tconst bodyRowStyle: CSSProperties = {\n132\t  borderTop: \"1px solid #1e293b\",\n133\t};\n134\t\n135\tconst linkStyle: CSSProperties = {\n136\t  color: \"#93c5fd\",\n137\t  textDecoration: \"none\",\n138\t};\n139\t\n140\tconst subValueStyle: CSSProperties = {\n141\t  color: \"#64748b\",\n142\t  fontSize: \"0.75rem\",\n143\t  marginLeft: \"0.25rem\",\n144\t};\n145\t\n146\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n147\t  return {\n148\t    padding: \"0.75rem\",\n149\t    textAlign: align,\n150\t    fontSize: \"0.875rem\",\n151\t    fontWeight: 600,\n152\t  };\n153\t}\n154\t\n155\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n156\t  return {\n157\t    padding: \"0.75rem\",\n158\t    textAlign: align,\n159\t    fontSize: \"0.875rem\",\n160\t  };\n161\t}\n162\t\n163\tconst errorStyle: CSSProperties = {\n164\t  margin: 0,\n165\t  padding: \"0.75rem 1rem\",\n166\t  borderRadius: \"0.75rem\",\n167\t  background: \"#3f1d1d\",\n168\t  color: \"#fecaca\",\n169\t};\n170\t\n171\tconst emptyStyle: CSSProperties = {\n172\t  padding: \"1.5rem\",\n173\t  borderRadius: \"0.75rem\",\n174\t  border: \"1px dashed #334155\",\n175\t  background: \"#0b1220\",\n176\t  color: \"#cbd5f5\",\n177\t  display: \"grid\",\n178\t  gap: \"0.5rem\",\n179\t};\n180\t\n181\tconst emptyTitleStyle: CSSProperties = {\n182\t  margin: 0,\n183\t  fontSize: \"1rem\",\n184\t  fontWeight: 600,\n185\t};\n186\t\n187\tconst emptyBodyStyle: CSSProperties = {\n188\t  margin: 0,\n189\t  fontSize: \"0.875rem\",\n190\t  color: \"#94a3b8\",\n191\t};\n192\t"}]},"parent_tool_use_id":null,"session_id":"65159f28-4138-4a00-8878-b10db9efe60e","uuid":"d8111d76-7e27-4dcc-bab3-75f88ca045fd","timestamp":"2026-04-26T19:45:51.305Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/growth-kol-table.tsx","content":"// KOL performance table for /growth/kol (FR-7).\n//\n// Reads `referral_kol_rates` joined with linked performance from\n// `referral_links` + `referral_earnings`. Drill-down per row to user-detail.\n//\n// FR-14 wiring: when `canMutateKolRate` is true the table appends an\n// \"Edit rate\" column rendering `KolRateMutationForm` per row. The column\n// is computed at the page level (`isActionAllowedForRole(\"kol_rate.update\",\n// actor.role)`) so non-authorized actors do not see the control at all.\nimport Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type { PeekKolPerformanceRow } from \"../lib/types/peek\";\nimport { KolRateMutationForm } from \"./mutations/kol-rate-mutation-form\";\n\nexport type GrowthKolTableProps = {\n  rows: ReadonlyArray<PeekKolPerformanceRow>;\n  error?: string | null;\n  canMutateKolRate?: boolean;\n};\n\nexport function GrowthKolTable({\n  rows,\n  error = null,\n  canMutateKolRate = false,\n}: GrowthKolTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        KOL table unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No KOL rates configured.</p>\n        <p style={emptyBodyStyle}>\n          No rows in `referral_kol_rates` — KOL pricing has not been applied\n          to any user yet.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"right\")}>Rate (bps)</th>\n            <th style={headerCellStyle(\"left\")}>Set by</th>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>Updated</th>\n            <th style={headerCellStyle(\"right\")}>Referees</th>\n            <th style={headerCellStyle(\"right\")}>Wager (lamports)</th>\n            <th style={headerCellStyle(\"right\")}>Earned (lamports)</th>\n            {canMutateKolRate ? (\n              <th style={headerCellStyle(\"left\")}>Edit rate</th>\n            ) : null}\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.userId} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>\n                <Link href={`/users/${row.userId}`} style={linkStyle}>\n                  {row.username ?? row.userId}\n                </Link>\n                {row.username ? (\n                  <span style={subValueStyle}> · {row.userId}</span>\n                ) : null}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.wallet}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>{row.rateBps}</td>\n              <td style={bodyCellStyle(\"left\")}>{row.setBy}</td>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>{row.updatedAt}</td>\n              <td style={bodyCellStyle(\"right\")}>{row.refereeCount}</td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatLamports(row.referredWagerLamports)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatLamports(row.referrerEarnedLamports)}\n              </td>\n              {canMutateKolRate ? (\n                <td style={bodyCellStyle(\"left\")}>\n                  <KolRateMutationForm\n                    userId={row.userId}\n                    walletCurrent={row.wallet}\n                    rateBpsCurrent={row.rateBps}\n                  />\n                </td>\n              ) : null}\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction formatLamports(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n  marginLeft: \"0.25rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":192,"startLine":1,"totalLines":192}}}
