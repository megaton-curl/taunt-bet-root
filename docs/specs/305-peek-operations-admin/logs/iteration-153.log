{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01MGFMkipjJc2qLUNyB1YnFz","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01PKptAts8veXUHEnbNfrKJo","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/mutations/__tests__/fraud-flag-mutation-form.test.tsx","content":"// FR-14 mutation UI — FraudFlagMutationForm rendered structure.\n//\n// The form mirrors the FR-14 allowed-transition matrix client-side so the\n// operator can only request a target status the runner will accept. The\n// option list is derived from the row's `currentStatus`. Unknown statuses\n// (string values outside the matrix) and any future row whose current\n// status leaves no admissible next status both render nothing — the\n// operator is never offered a control the engine would reject.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { FraudFlagMutationForm } from \"../fraud-flag-mutation-form\";\n\nfunction getOptionLabels(): string[] {\n  const select = screen.getByLabelText(\"Next status\") as HTMLSelectElement;\n  return Array.from(select.options).map((opt) => opt.value);\n}\n\ndescribe(\"FraudFlagMutationForm\", () => {\n  it(\"authorized open → reviewed/dismissed: surfaces only the matrix-allowed transitions\", () => {\n    const { container } = render(\n      <FraudFlagMutationForm flagId=\"42\" currentStatus=\"open\" />,\n    );\n\n    expect(\n      screen.getByRole(\"form\", { name: \"Transition fraud flag status\" }),\n    ).toBeInTheDocument();\n    expect(screen.getByText(\"old: open\")).toBeInTheDocument();\n\n    expect(getOptionLabels()).toEqual([\"reviewed\", \"dismissed\"]);\n\n    // Hidden flagId is required for the runner to locate the target row.\n    const hidden = container.querySelector(\n      \"input[type='hidden'][name='flagId']\",\n    ) as HTMLInputElement | null;\n    expect(hidden?.value).toBe(\"42\");\n\n    // Idle feedback panel is silent.\n    expect(screen.queryByRole(\"status\")).toBeNull();\n    expect(screen.queryByRole(\"alert\")).toBeNull();\n  });\n\n  it(\"authorized reviewed → open/dismissed: matrix mirroring stays per-row\", () => {\n    render(<FraudFlagMutationForm flagId=\"43\" currentStatus=\"reviewed\" />);\n\n    expect(screen.getByText(\"old: reviewed\")).toBeInTheDocument();\n    expect(getOptionLabels()).toEqual([\"open\", \"dismissed\"]);\n  });\n\n  it(\"authorized dismissed → open: only the open transition is offered\", () => {\n    render(<FraudFlagMutationForm flagId=\"44\" currentStatus=\"dismissed\" />);\n\n    expect(screen.getByText(\"old: dismissed\")).toBeInTheDocument();\n    expect(getOptionLabels()).toEqual([\"open\"]);\n  });\n\n  it(\"denied (unknown current status): renders nothing rather than expose a misleading control\", () => {\n    // The runner accepts only `open` / `reviewed` / `dismissed`. Any other\n    // string would fall through the matrix and cannot be resolved to a\n    // valid `nextStatus`, so the form must hide itself.\n    const { container } = render(\n      <FraudFlagMutationForm flagId=\"45\" currentStatus=\"purgatory\" />,\n    );\n\n    expect(container.firstChild).toBeNull();\n    expect(screen.queryByRole(\"form\")).toBeNull();\n    expect(screen.queryByRole(\"button\")).toBeNull();\n  });\n\n  it(\"submit button surfaces the initial 'Apply status change' copy and is enabled while idle\", () => {\n    render(<FraudFlagMutationForm flagId=\"46\" currentStatus=\"open\" />);\n\n    const submit = screen.getByRole(\"button\", { name: \"Apply status change\" });\n    expect(submit).toHaveAttribute(\"type\", \"submit\");\n    expect(submit).not.toBeDisabled();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":602,"cache_read_input_tokens":128998,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":602},"output_tokens":66,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"65159f28-4138-4a00-8878-b10db9efe60e","uuid":"5648a60b-c40f-4d32-8efb-8ddfe82eb97c"}
