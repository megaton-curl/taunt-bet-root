{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RLz5MXvgu2QAGXANbQGU9X","type":"tool_result","content":"1\t// Dogpile events table for /operations/dogpile (FR-9).\n2\t//\n3\t// Dense table over `PeekDogpileEventRow`. Status drives the chip tone so an\n4\t// operator can spot scheduled vs active vs ended/cancelled at a glance. Each\n5\t// row also surfaces the count of game_entries and point_grants whose\n6\t// `created_at` falls inside the dogpile window — the closest\n7\t// operator-meaningful \"linked\" set the spec calls out (FR-9).\n8\t//\n9\t// FR-14 wiring: when `canCancelDogpile` is true the table appends a\n10\t// \"Cancel\" column rendering `DogpileCancelMutationForm` per row whose\n11\t// status is exactly `scheduled`. Non-scheduled rows render an empty cell;\n12\t// non-authorized actors do not see the column at all.\n13\timport type { CSSProperties } from \"react\";\n14\timport type {\n15\t  PeekDogpileEventRow,\n16\t  PeekStatusTone,\n17\t} from \"../lib/types/peek\";\n18\timport { DogpileCancelMutationForm } from \"./mutations/dogpile-cancel-mutation-form\";\n19\timport { StatusChip } from \"./status-chip\";\n20\t\n21\texport type DogpileEventsTableProps = {\n22\t  rows: ReadonlyArray<PeekDogpileEventRow>;\n23\t  error?: string | null;\n24\t  canCancelDogpile?: boolean;\n25\t};\n26\t\n27\texport function DogpileEventsTable({\n28\t  rows,\n29\t  error = null,\n30\t  canCancelDogpile = false,\n31\t}: DogpileEventsTableProps) {\n32\t  if (error) {\n33\t    return (\n34\t      <div role=\"alert\" style={errorStyle}>\n35\t        Dogpile events unavailable: {error}\n36\t      </div>\n37\t    );\n38\t  }\n39\t\n40\t  if (rows.length === 0) {\n41\t    return (\n42\t      <div role=\"status\" style={emptyStyle}>\n43\t        <p style={emptyTitleStyle}>\n44\t          No dogpile_events rows match these filters.\n45\t        </p>\n46\t        <p style={emptyBodyStyle}>\n47\t          Adjust the filters above or clear them to see scheduled, active,\n48\t          ended, and cancelled events.\n49\t        </p>\n50\t      </div>\n51\t    );\n52\t  }\n53\t\n54\t  return (\n55\t    <div style={wrapperStyle}>\n56\t      <table style={tableStyle}>\n57\t        <thead>\n58\t          <tr style={headerRowStyle}>\n59\t            <th style={headerCellStyle(\"left\")}>Status</th>\n60\t            <th style={headerCellStyle(\"left\")}>Campaign</th>\n61\t            <th style={headerCellStyle(\"left\")}>Starts</th>\n62\t            <th style={headerCellStyle(\"left\")}>Ends</th>\n63\t            <th style={headerCellStyle(\"right\")}>Multiplier</th>\n64\t            <th style={headerCellStyle(\"right\")}>Game entries</th>\n65\t            <th style={headerCellStyle(\"right\")}>Point grants</th>\n66\t            <th style={headerCellStyle(\"left\")}>Created</th>\n67\t            <th style={headerCellStyle(\"left\")}>ID</th>\n68\t            {canCancelDogpile ? (\n69\t              <th style={headerCellStyle(\"left\")}>Cancel</th>\n70\t            ) : null}\n71\t          </tr>\n72\t        </thead>\n73\t        <tbody>\n74\t          {rows.map((row) => (\n75\t            <tr key={row.id} style={bodyRowStyle}>\n76\t              <td style={bodyCellStyle(\"left\")}>\n77\t                <StatusChip\n78\t                  label={row.status}\n79\t                  tone={dogpileStatusTone(row.status)}\n80\t                />\n81\t              </td>\n82\t              <td style={bodyCellStyle(\"left\")}>\n83\t                <div>{row.campaignName ?? \"—\"}</div>\n84\t                {row.campaignType ? (\n85\t                  <div style={subValueStyle}>{row.campaignType}</div>\n86\t                ) : null}\n87\t                {row.campaignId ? (\n88\t                  <div style={{ ...subValueStyle, fontFamily: \"monospace\" }}>\n89\t                    {row.campaignId}\n90\t                  </div>\n91\t                ) : null}\n92\t              </td>\n93\t              <td style={bodyCellStyle(\"left\")}>{row.startsAt}</td>\n94\t              <td style={bodyCellStyle(\"left\")}>{row.endsAt}</td>\n95\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n96\t                {row.multiplier}×\n97\t              </td>\n98\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n99\t                {row.gameEntryCount.toLocaleString(\"en-US\")}\n100\t              </td>\n101\t              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n102\t                {row.pointGrantCount.toLocaleString(\"en-US\")}\n103\t              </td>\n104\t              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n105\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n106\t                {row.id}\n107\t              </td>\n108\t              {canCancelDogpile ? (\n109\t                <td style={bodyCellStyle(\"left\")}>\n110\t                  <DogpileCancelMutationForm\n111\t                    eventId={row.id}\n112\t                    currentStatus={row.status}\n113\t                  />\n114\t                </td>\n115\t              ) : null}\n116\t            </tr>\n117\t          ))}\n118\t        </tbody>\n119\t      </table>\n120\t    </div>\n121\t  );\n122\t}\n123\t\n124\tfunction dogpileStatusTone(value: string): PeekStatusTone {\n125\t  if (value === \"scheduled\") return \"info\";\n126\t  if (value === \"active\") return \"positive\";\n127\t  if (value === \"ended\") return \"neutral\";\n128\t  if (value === \"cancelled\") return \"warning\";\n129\t  return \"neutral\";\n130\t}\n131\t\n132\tconst wrapperStyle: CSSProperties = {\n133\t  overflowX: \"auto\",\n134\t  border: \"1px solid #1e293b\",\n135\t  borderRadius: \"0.75rem\",\n136\t};\n137\t\n138\tconst tableStyle: CSSProperties = {\n139\t  width: \"100%\",\n140\t  borderCollapse: \"collapse\",\n141\t};\n142\t\n143\tconst headerRowStyle: CSSProperties = {\n144\t  background: \"#111827\",\n145\t  color: \"#94a3b8\",\n146\t};\n147\t\n148\tconst bodyRowStyle: CSSProperties = {\n149\t  borderTop: \"1px solid #1e293b\",\n150\t};\n151\t\n152\tconst subValueStyle: CSSProperties = {\n153\t  color: \"#64748b\",\n154\t  fontSize: \"0.75rem\",\n155\t};\n156\t\n157\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n158\t  return {\n159\t    padding: \"0.75rem\",\n160\t    textAlign: align,\n161\t    fontSize: \"0.875rem\",\n162\t    fontWeight: 600,\n163\t  };\n164\t}\n165\t\n166\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n167\t  return {\n168\t    padding: \"0.75rem\",\n169\t    textAlign: align,\n170\t    fontSize: \"0.875rem\",\n171\t    color: \"#e2e8f0\",\n172\t    verticalAlign: \"top\",\n173\t  };\n174\t}\n175\t\n176\tconst errorStyle: CSSProperties = {\n177\t  margin: 0,\n178\t  padding: \"0.75rem 1rem\",\n179\t  borderRadius: \"0.75rem\",\n180\t  background: \"#3f1d1d\",\n181\t  color: \"#fecaca\",\n182\t};\n183\t\n184\tconst emptyStyle: CSSProperties = {\n185\t  padding: \"1.5rem\",\n186\t  borderRadius: \"0.75rem\",\n187\t  border: \"1px dashed #334155\",\n188\t  background: \"#0b1220\",\n189\t  color: \"#cbd5f5\",\n190\t  display: \"grid\",\n191\t  gap: \"0.5rem\",\n192\t};\n193\t\n194\tconst emptyTitleStyle: CSSProperties = {\n195\t  margin: 0,\n196\t  fontSize: \"1rem\",\n197\t  fontWeight: 600,\n198\t};\n199\t\n200\tconst emptyBodyStyle: CSSProperties = {\n201\t  margin: 0,\n202\t  fontSize: \"0.875rem\",\n203\t  color: \"#94a3b8\",\n204\t};\n205\t"}]},"parent_tool_use_id":null,"session_id":"65159f28-4138-4a00-8878-b10db9efe60e","uuid":"0fc61790-2bd4-4865-a00f-2342ba03c930","timestamp":"2026-04-26T19:45:42.067Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/dogpile-events-table.tsx","content":"// Dogpile events table for /operations/dogpile (FR-9).\n//\n// Dense table over `PeekDogpileEventRow`. Status drives the chip tone so an\n// operator can spot scheduled vs active vs ended/cancelled at a glance. Each\n// row also surfaces the count of game_entries and point_grants whose\n// `created_at` falls inside the dogpile window — the closest\n// operator-meaningful \"linked\" set the spec calls out (FR-9).\n//\n// FR-14 wiring: when `canCancelDogpile` is true the table appends a\n// \"Cancel\" column rendering `DogpileCancelMutationForm` per row whose\n// status is exactly `scheduled`. Non-scheduled rows render an empty cell;\n// non-authorized actors do not see the column at all.\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekDogpileEventRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { DogpileCancelMutationForm } from \"./mutations/dogpile-cancel-mutation-form\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type DogpileEventsTableProps = {\n  rows: ReadonlyArray<PeekDogpileEventRow>;\n  error?: string | null;\n  canCancelDogpile?: boolean;\n};\n\nexport function DogpileEventsTable({\n  rows,\n  error = null,\n  canCancelDogpile = false,\n}: DogpileEventsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Dogpile events unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>\n          No dogpile_events rows match these filters.\n        </p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see scheduled, active,\n          ended, and cancelled events.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Status</th>\n            <th style={headerCellStyle(\"left\")}>Campaign</th>\n            <th style={headerCellStyle(\"left\")}>Starts</th>\n            <th style={headerCellStyle(\"left\")}>Ends</th>\n            <th style={headerCellStyle(\"right\")}>Multiplier</th>\n            <th style={headerCellStyle(\"right\")}>Game entries</th>\n            <th style={headerCellStyle(\"right\")}>Point grants</th>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>ID</th>\n            {canCancelDogpile ? (\n              <th style={headerCellStyle(\"left\")}>Cancel</th>\n            ) : null}\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.status}\n                  tone={dogpileStatusTone(row.status)}\n                />\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <div>{row.campaignName ?? \"—\"}</div>\n                {row.campaignType ? (\n                  <div style={subValueStyle}>{row.campaignType}</div>\n                ) : null}\n                {row.campaignId ? (\n                  <div style={{ ...subValueStyle, fontFamily: \"monospace\" }}>\n                    {row.campaignId}\n                  </div>\n                ) : null}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.startsAt}</td>\n              <td style={bodyCellStyle(\"left\")}>{row.endsAt}</td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.multiplier}×\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.gameEntryCount.toLocaleString(\"en-US\")}\n              </td>\n              <td style={{ ...bodyCellStyle(\"right\"), fontFamily: \"monospace\" }}>\n                {row.pointGrantCount.toLocaleString(\"en-US\")}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.id}\n              </td>\n              {canCancelDogpile ? (\n                <td style={bodyCellStyle(\"left\")}>\n                  <DogpileCancelMutationForm\n                    eventId={row.id}\n                    currentStatus={row.status}\n                  />\n                </td>\n              ) : null}\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction dogpileStatusTone(value: string): PeekStatusTone {\n  if (value === \"scheduled\") return \"info\";\n  if (value === \"active\") return \"positive\";\n  if (value === \"ended\") return \"neutral\";\n  if (value === \"cancelled\") return \"warning\";\n  return \"neutral\";\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":205,"startLine":1,"totalLines":205}}}
