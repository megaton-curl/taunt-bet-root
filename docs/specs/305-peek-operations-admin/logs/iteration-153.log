{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01LFqiBno4YCn2ubBs8NMUE4","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01HuYX3YDnG8EBovXVKq62mK","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/mutations/__tests__/reward-config-mutation-form.test.tsx","content":"// FR-14 mutation UI — RewardConfigMutationForm rendered structure.\n//\n// The form must reflect the runner's two FR-14-specific guards before\n// shipping a request:\n//   1. Confirmation is mandatory — the runner rejects any request whose\n//      `confirm` field is not the literal `true`. The submit button must\n//      stay disabled until the operator checks the confirmation box.\n//   2. No-op writes are rejected by the runner with `execution_failed:\n//      noop_value`. The form mirrors this by disabling submission while\n//      the typed value matches the current value, swapping in a hint that\n//      explains the noop.\n//\n// Together the two gates mean the submit button is enabled iff\n// `value !== valueCurrent` AND `confirm` is checked.\n\nimport { describe, expect, it } from \"vitest\";\nimport { fireEvent, render, screen } from \"@testing-library/react\";\nimport { RewardConfigMutationForm } from \"../reward-config-mutation-form\";\n\ndescribe(\"RewardConfigMutationForm\", () => {\n  it(\"authorized initial render: renders the value input, the confirmation checkbox, the noop hint, and a disabled submit button\", () => {\n    const { container } = render(\n      <RewardConfigMutationForm\n        rowKey=\"points_per_dollar\"\n        expectedType=\"integer\"\n        valueCurrent=\"100\"\n      />,\n    );\n\n    expect(\n      screen.getByRole(\"form\", { name: \"Edit reward config value\" }),\n    ).toBeInTheDocument();\n\n    // Old value is visible adjacent to the input.\n    expect(screen.getByText(\"old: 100\")).toBeInTheDocument();\n\n    // Hidden key carries the row identifier through to the runner.\n    const hidden = container.querySelector(\n      \"input[type='hidden'][name='key']\",\n    ) as HTMLInputElement | null;\n    expect(hidden?.value).toBe(\"points_per_dollar\");\n\n    // Value field is pre-populated with the current value (so the diff\n    // starts at \"no change\") and uses a numeric input mode for integer\n    // keys.\n    const value = screen.getByLabelText(\"Value (integer)\") as HTMLInputElement;\n    expect(value.value).toBe(\"100\");\n    expect(value).toHaveAttribute(\"inputMode\", \"numeric\");\n\n    // Confirmation gate is unchecked by default.\n    const confirmCheckbox = screen.getByRole(\"checkbox\") as HTMLInputElement;\n    expect(confirmCheckbox.name).toBe(\"confirm\");\n    expect(confirmCheckbox.value).toBe(\"true\");\n    expect(confirmCheckbox.checked).toBe(false);\n\n    // Submit is disabled — no value change AND no confirmation.\n    const submit = screen.getByRole(\"button\", { name: \"Apply value change\" });\n    expect(submit).toBeDisabled();\n\n    // Noop hint replaces the new-value diff while the value is unchanged.\n    expect(\n      screen.getByText(\"New value matches the current value.\"),\n    ).toBeInTheDocument();\n  });\n\n  it(\"authorized: typing a different value swaps the noop hint for a 'new:' diff but leaves submit disabled until confirmation is checked\", () => {\n    render(\n      <RewardConfigMutationForm\n        rowKey=\"points_per_dollar\"\n        expectedType=\"integer\"\n        valueCurrent=\"100\"\n      />,\n    );\n\n    const value = screen.getByLabelText(\"Value (integer)\") as HTMLInputElement;\n    fireEvent.change(value, { target: { value: \"250\" } });\n\n    // Diff hint replaces the noop hint.\n    expect(\n      screen.queryByText(\"New value matches the current value.\"),\n    ).toBeNull();\n    // Hint surfaces the typed value alongside `new:`.\n    expect(screen.getByText(/new:/i)).toBeInTheDocument();\n    expect(screen.getByText(\"250\")).toBeInTheDocument();\n\n    // Still disabled — confirmation has not yet been checked.\n    const submit = screen.getByRole(\"button\", { name: \"Apply value change\" });\n    expect(submit).toBeDisabled();\n  });\n\n  it(\"authorized: enabling the confirmation alone (without changing the value) keeps submit disabled — the runner would reject the request as a noop\", () => {\n    render(\n      <RewardConfigMutationForm\n        rowKey=\"points_per_dollar\"\n        expectedType=\"integer\"\n        valueCurrent=\"100\"\n      />,\n    );\n\n    fireEvent.click(screen.getByRole(\"checkbox\"));\n\n    expect(screen.getByRole(\"checkbox\")).toBeChecked();\n    expect(\n      screen.getByRole(\"button\", { name: \"Apply value change\" }),\n    ).toBeDisabled();\n  });\n\n  it(\"authorized: changing the value AND confirming enables submit\", () => {\n    render(\n      <RewardConfigMutationForm\n        rowKey=\"points_per_dollar\"\n        expectedType=\"integer\"\n        valueCurrent=\"100\"\n      />,\n    );\n\n    fireEvent.change(screen.getByLabelText(\"Value (integer)\"), {\n      target: { value: \"250\" },\n    });\n    fireEvent.click(screen.getByRole(\"checkbox\"));\n\n    expect(\n      screen.getByRole(\"button\", { name: \"Apply value change\" }),\n    ).not.toBeDisabled();\n  });\n\n  it(\"authorized: ratio rows render with the decimal inputMode hint so operators are not nudged toward whole-number-only entry\", () => {\n    render(\n      <RewardConfigMutationForm\n        rowKey=\"reward_pool_fee_share\"\n        expectedType=\"ratio\"\n        valueCurrent=\"0.25\"\n      />,\n    );\n\n    const value = screen.getByLabelText(\"Value (ratio)\") as HTMLInputElement;\n    expect(value).toHaveAttribute(\"inputMode\", \"decimal\");\n  });\n\n  it(\"authorized: confirmation copy mentions FR-14 so an operator understands the gate is contractual, not cosmetic\", () => {\n    render(\n      <RewardConfigMutationForm\n        rowKey=\"points_per_dollar\"\n        expectedType=\"integer\"\n        valueCurrent=\"100\"\n      />,\n    );\n\n    expect(\n      screen.getByText(/I confirm this reward-economy change\\./i),\n    ).toBeInTheDocument();\n    expect(screen.getByText(/FR-14/)).toBeInTheDocument();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":402,"cache_read_input_tokens":132566,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":402},"output_tokens":66,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"65159f28-4138-4a00-8878-b10db9efe60e","uuid":"ce774ded-9d62-4b83-9265-1c78db787494"}
