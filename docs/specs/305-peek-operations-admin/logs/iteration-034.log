r-side capped at 250.\n      </p>\n      {children}\n      {totalPages > 1 ? (\n        <nav aria-label=\"Pagination\" style={paginationStyle}>\n          <PageLink\n            disabled={page <= 1}\n            href={pageHref(route, rawParams, page - 1)}\n          >\n            Previous\n          </PageLink>\n          <span style={pageLabelStyle}>\n            Page {page} of {totalPages}\n          </span>\n          <PageLink\n            disabled={page >= totalPages}\n            href={pageHref(route, rawParams, page + 1)}\n          >\n            Next\n          </PageLink>\n        </nav>\n      ) : null}\n    </section>\n  );\n}\n\nfunction pageHref(\n  route: string,\n  rawParams: Record<string, string | string[] | undefined>,\n  page: number,\n): string {\n  const qs = buildRoundsQueryString(rawParams, { page });\n  return qs ? `${route}?${qs}` : route;\n}\n\nfunction PageLink({\n  href,\n  disabled,\n  children,\n}: {\n  href: string;\n  disabled: boolean;\n  children: React.ReactNode;\n}) {\n  if (disabled) {\n    return (\n      <span aria-disabled=\"true\" style={{ ...pageButton, ...pageButtonDisabled }}>\n        {children}\n      </span>\n    );\n  }\n  return (\n    <Link href={href} style={pageButton}>\n      {children}\n    </Link>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst breadcrumbStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n\nconst breadcrumbLinkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst codeStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  color: \"#cbd5f5\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst paginationStyle: CSSProperties = {\n  display: \"flex\",\n  gap: \"0.75rem\",\n  alignItems: \"center\",\n  flexWrap: \"wrap\",\n};\n\nconst pageLabelStyle: CSSProperties = {\n  color: \"#cbd5e1\",\n  fontSize: \"0.875rem\",\n};\n\nconst pageButton: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #334155\",\n  padding: \"0.5rem 0.75rem\",\n  color: \"#e2e8f0\",\n  textDecoration: \"none\",\n  fontSize: \"0.875rem\",\n};\n\nconst pageButtonDisabled: CSSProperties = {\n  color: \"#64748b\",\n  borderColor: \"#1e293b\",\n  cursor: \"not-allowed\",\n};\n","structuredPatch":[],"originalFile":null,"userModified":false}}
