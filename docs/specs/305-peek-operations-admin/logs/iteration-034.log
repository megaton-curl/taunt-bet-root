elText(\"User ID\") as HTMLInputElement).value).toBe(\n      \"u-1\",\n    );\n    expect(\n      (screen.getByLabelText(\"Min amount (lamports)\") as HTMLInputElement)\n        .value,\n    ).toBe(\"1000\");\n    expect(\n      (screen.getByLabelText(\"Max amount (lamports)\") as HTMLInputElement)\n        .value,\n    ).toBe(\"9000\");\n    expect(\n      (screen.getByLabelText(\"Requested from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Requested to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-25\");\n    expect(\n      (screen.getByLabelText(\"Tx signature\") as HTMLInputElement).value,\n    ).toBe(\"5VfYDnXUcS6mWY3cQy4ipcM5LQqM\");\n    expect(\n      (screen.getByLabelText(\"Error contains\") as HTMLInputElement).value,\n    ).toBe(\"timeout\");\n  });\n\n  it(\"custom action: submits to a caller-supplied URL when provided\", () => {\n    render(\n      <GrowthClaimsFilterBar\n        filters={EMPTY_FILTERS}\n        action=\"/growth/referrals?cohort=q1\"\n      />,\n    );\n\n    const form = screen.getByRole(\"search\", { name: \"Filter referral claims\" });\n    expect(form).toHaveAttribute(\"action\", \"/growth/referrals?cohort=q1\");\n  });\n\n  it(\"input names align with normalizeReferralClaimFiltersFromSearchParams\", () => {\n    // Smoke-check the form-name contract: if these change, the page-side\n    // search-params normaliser breaks silently.\n    render(<GrowthClaimsFilterBar filters={EMPTY_FILTERS} />);\n\n    expect(screen.getByLabelText(\"Status\")).toHaveAttribute(\n      \"name\",\n      \"claimStatus\",\n    );\n    expect(screen.getByLabelText(\"User ID\")).toHaveAttribute(\n      \"name\",\n      \"claimUserId\",\n    );\n    expect(screen.getByLabelText(\"Min amount (lamports)\")).toHaveAttribute(\n      \"name\",\n      \"claimMinAmount\",\n    );\n    expect(screen.getByLabelText(\"Max amount (lamports)\")).toHaveAttribute(\n      \"name\",\n      \"claimMaxAmount\",