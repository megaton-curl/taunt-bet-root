200,\n  refundEntries: 12,\n  payoutLamports: \"7500000000\",\n  wins: 600,\n  losses: 588,\n};\n\nconst ROW_POTSHOT_EMPTY: PeekGameOverviewRow = {\n  game: \"potshot\",\n  entries: 0,\n  uniqueUsers: 0,\n  wageredLamports: \"0\",\n  settledEntries: 0,\n  refundEntries: 0,\n  payoutLamports: \"0\",\n  wins: 0,\n  losses: 0,\n};\n\nconst ROW_CLOSECALL: PeekGameOverviewRow = {\n  game: \"closecall\",\n  entries: 42,\n  uniqueUsers: 30,\n  wageredLamports: \"500000\",\n  settledEntries: 40,\n  refundEntries: 1,\n  payoutLamports: \"450000\",\n  wins: 20,\n  losses: 19,\n};","numLines":40,"startLine":1,"totalLines":110}}}
