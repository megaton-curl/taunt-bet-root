 !== \"desc\") {\n62\t    query.set(\"direction\", params.direction);\n63\t  }\n64\t\n65\t  if (page > 1) {\n66\t    query.set(\"page\", String(page));\n67\t  }\n68\t\n69\t  if (params.filters.hasReferrer) {\n70\t    query.set(\"hasReferrer\", \"true\");\n71\t  }\n72\t\n73\t  if (params.filters.hasReferees) {\n74\t    query.set(\"hasReferees\", \"true\");\n75\t  }\n76\t\n77\t  if (params.filters.hasCode) {\n78\t    query.set(\"hasCode\", \"true\");\n79\t  }\n80\t\n81\t  if (params.filters.hasTelegram) {\n82\t    query.set(\"hasTelegram\", \"true\");\n83\t  }\n84\t\n85\t  const queryString = query.toString();\n86\t  return queryString ? `/?${queryString}` : \"/\";\n87\t}\n88\t\n89\tfunction PageLink({\n90\t  children,\n91\t  disabled,\n92\t  href,\n93\t}: {\n94\t  children: ReactNode;\n95\t  disabled: boolean;\n96\t  href: string;\n97\t}) {\n98\t  if (disabled) {\n99\t    return (\n100\t      <span aria-disabled=\"true\" style={{ ...buttonStyle, ...disabledButtonStyle }}>\n101\t        {children}\n102\t      </span>\n103\t    );\n104\t  }\n105\t\n106\t  return (\n107\t    <Link href={href} style={buttonStyle}>\n108\t      {children}\n109\t    </Link>\n110\t  );\n111\t}\n112\t\n113\tconst containerStyle: CSSProperties = {\n114\t  display: \"flex\",\n115\t  gap: \"0.75rem\",\n116\t  justifyContent: \"space-between\",\n117\t  alignItems: \"center\",\n118\t  flexWrap: \"wrap\",\n119\t};\n120\t\n121\tconst metaStyle: CSSProperties = {\n122\t  margin: 0,\n123\t  color: \"#94a3b8\",\n124\t  fontSize: \"0.875rem\",\n125\t};\n126\t\n127\tconst actionsStyle: CSSProperties = {\n128\t  display: \"flex\",\n129\t  gap: \"0.75rem\",\n130\t  alignItems: \"center\",\n131\t  flexWrap: \"wrap\",\n132\t};\n133\t\n134\tconst pageLabelStyle: CSSProperties = {\n135\t  color: \"#cbd5e1\",\n136\t  fontSize: \"0.875rem\",\n137\t};\n138\t\n139\tconst buttonStyle: CSSProperties = {\n140\t  borderRadius: \"0.5rem\",\n141\t  border: \"1px solid #334155\",\n142\t  padding: \"0.5rem 0.75rem\",\n143\t  color: \"#e2e8f0\",\n144\t  textDecoration: \"none\",\n145\t  fontSize: \"0.875rem\",\n146\t};\n147\t\n148\tconst disabledButtonStyle: CSSProperties = {\n149\t  color: \"#64748b\",\n150\t  borderColor: \"#1e293b\",\n151\t  cursor: \"not-allowed\",\n152\t};\n153\t"}]},"parent_tool_use_id":null,"session_id":"07ea83e7-4ecf-4755-98ef-051aea36da1a","uuid":"eb561ab3-89dd-4c44-987c-cd6de81c6244","timestamp":"2026-04-25T13:05:56.693Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/pagination-controls.tsx","content":"import Link from \"next/link\";\nimport type { CSSProperties, ReactNode } from \"react\";\nimport type { PeekSearchParams } from \"../lib/search-params\";\n\nexport function PaginationControls({\n  params,\n  totalCount,\n}: {\n  params: PeekSearchParams;\n  totalCount: number;\n}) {\n  if (totalCount === 0) {\n    return (\n      <section style={containerStyle}>\n        <p style={metaStyle}>No users match the current filters.</p>\n      </section>\n    );\n  }\n\n  const totalPages = Math.max(1, Math.ceil(totalCount / params.pageSize));\n  const startIndex = (params.page - 1) * params.pageSize + 1;\n  const endIndex = Math.min(params.page * params.pageSize, totalCount);\n\n  return (\n    <section style={containerStyle}>\n      <p style={metaStyle}>\n        Showing {startIndex}-{endIndex} of {totalCount}\n      </p>\n      <div style={actionsStyle}>\n        <PageLink\n          disabled={params.page <= 1}\n          href={buildPageHref(params, params.page - 1)}\n        >\n          Previous\n        </PageLink>\n        <span style={pageLabelStyle}>\n          Page {params.page} of {totalPages}\n        </span>\n        <PageLink\n          disabled={params.page >= totalPages}\n          href={buildPageHref(params, params.page + 1)}\n        >\n          Next\n        </PageLink>\n      </div>\n    </section>\n  );\n}\n\nfunction buildPageHref(params: PeekSearchParams, page: number) {\n  const query = new URLSearchParams();\n\n  if (params.query) {\n    query.set(\"query\", params.query);\n  }\n\n  if (params.sort !== \"joinedAt\") {\n    query.set(\"sort\", params.sort);\n  }\n\n  if (params.direction !== \"desc\") {\n    query.set(\"direction\", params.direction);\n  }\n\n  if (page > 1) {\n    query.set(\"page\", String(page));\n  }\n\n  if (params.filters.hasReferrer) {\n    query.set(\"hasReferrer\", \"true\");\n  }\n\n  if (params.filters.hasReferees) {\n    query.set(\"hasReferees\", \"true\");\n  }\n\n  if (params.filters.hasCode) {\n    query.set(\"hasCode\", \"true\");\n  }\n\n  if (params.filters.hasTelegram) {\n    query.set(\"hasTelegram\", \"true\");\n  }\n\n  const queryString = query.toString();\n  return queryString ? `/?${queryString}` : \"/\";\n}\n\nfunction PageLink({\n  children,\n  disabled,\n  href,\n}: {\n  children: ReactNode;\n  disabled: boolean;\n  href: string;\n}) {\n  if (disabled) {\n    return (\n      <span aria-disabled=\"true\" style={{ ...buttonStyle, ...disabledButtonStyle }}>\n        {children}\n      </span>\n    );\n  }\n\n  return (\n    <Link href={href} style={buttonStyle}>\n      {children}\n    </Link>\n  );\n}\n\nconst containerStyle: CSSProperties = {\n  display: \"flex\",\n  gap: \"0.75rem\",\n  justifyContent: \"space-between\",\n  alignItems: \"center\",\n  flexWrap: \"wrap\",\n};\n\nconst metaStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.875rem\",\n};\n\nconst actionsStyle: CSSProperties = {\n  display: \"flex\",\n  gap: \"0.75rem\",\n  alignItems: \"center\",\n  flexWrap: \"wrap\",\n};\n\nconst pageLabelStyle: CSSProperties = {\n  color: \"#cbd5e1\",\n  fontSize: \"0.875rem\",\n};\n\nconst buttonStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #334155\",\n  padding: \"0.5rem 0.75rem\",\n  color: \"#e2e8f0\",\n  textDecoration: \"none\",\n  fontSize: \"0.875rem\",\n};\n\nconst disabledButtonStyle: CSSProperties = {\n  color: \"#64748b\",\n  borderColor: 