{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01DTVZNTgemckVpeSij6qo1V","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01SecWA59obeVD8d8w46AsXY","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/lib/games-search-params.ts","content":"// URL-addressable filter params for /games/[game] (FR-8).\n//\n// Mirrors the engine `PeekRoundFilters` (FlipYou + Pot Shot) and\n// `PeekCloseCallRoundFilters` (Close Call) shapes and normalises raw\n// search-param input the page receives from Next.js. Empty / whitespace-only\n// values normalise to `null` so the engine query skips them.\n\nimport {\n  PEEK_CLOSECALL_OUTCOMES,\n  PEEK_CLOSECALL_PHASES,\n  PEEK_ROUND_PHASES,\n  type PeekCloseCallOutcome,\n  type PeekCloseCallPhase,\n  type PeekCloseCallRoundFilters,\n  type PeekCloseCallRoundStuckFilters,\n  type PeekRoundFilters,\n  type PeekRoundPhase,\n  type PeekRoundStuckFilters,\n} from \"./types/peek\";\n\nexport const PEEK_ROUNDS_DEFAULT_PAGE_SIZE = 50;\n\nfunction readSingleValue(value: string | string[] | undefined): string {\n  return Array.isArray(value) ? value[0] ?? \"\" : value ?? \"\";\n}\n\nfunction trimOrNull(value: string): string | null {\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nfunction readBoolean(value: string | string[] | undefined): boolean {\n  const raw = readSingleValue(value).trim().toLowerCase();\n  return raw === \"1\" || raw === \"true\" || raw === \"on\" || raw === \"yes\";\n}\n\nfunction readPage(value: string | string[] | undefined): number {\n  const raw = trimOrNull(readSingleValue(value));\n  if (!raw) return 1;\n  const parsed = Number.parseInt(raw, 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : 1;\n}\n\nexport function normalizeRoundFiltersFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): PeekRoundFilters {\n  const phaseRaw = trimOrNull(readSingleValue(input.phase));\n  const stuck: PeekRoundStuckFilters = {\n    nonterminalAged: readBoolean(input.stuckAged),\n    highAttempts: readBoolean(input.stuckAttempts),\n    settledWithoutTx: readBoolean(input.stuckNoTx),\n    refunds: readBoolean(input.stuckRefunds),\n  };\n  return {\n    phase:\n      phaseRaw &&\n      (PEEK_ROUND_PHASES as ReadonlyArray<string>).includes(phaseRaw)\n        ? (phaseRaw as PeekRoundPhase)\n        : null,\n    search: trimOrNull(readSingleValue(input.search)),\n    fromDate: trimOrNull(readSingleValue(input.fromDate)),\n    toDate: trimOrNull(readSingleValue(input.toDate)),\n    stuck,\n  };\n}\n\nexport function normalizeCloseCallRoundFiltersFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): PeekCloseCallRoundFilters {\n  const phaseRaw = trimOrNull(readSingleValue(input.phase));\n  const outcomeRaw = trimOrNull(readSingleValue(input.outcome));\n  const stuck: PeekCloseCallRoundStuckFilters = {\n    nonterminalAged: readBoolean(input.stuckAged),\n    settledWithoutTx: readBoolean(input.stuckNoTx),\n    refunds: readBoolean(input.stuckRefunds),\n  };\n  return {\n    phase:\n      phaseRaw &&\n      (PEEK_CLOSECALL_PHASES as ReadonlyArray<string>).includes(phaseRaw)\n        ? (phaseRaw as PeekCloseCallPhase)\n        : null,\n    outcome:\n      outcomeRaw &&\n      (PEEK_CLOSECALL_OUTCOMES as ReadonlyArray<string>).includes(outcomeRaw)\n        ? (outcomeRaw as PeekCloseCallOutcome)\n        : null,\n    search: trimOrNull(readSingleValue(input.search)),\n    fromDate: trimOrNull(readSingleValue(input.fromDate)),\n    toDate: trimOrNull(readSingleValue(input.toDate)),\n    stuck,\n  };\n}\n\nexport function readPageFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): number {\n  return readPage(input.page);\n}\n\n// Builds a query string for pagination links, preserving the active filters so\n// page navigation does not silently drop the operator's filter state.\nexport function buildRoundsQueryString(\n  raw: Record<string, string | string[] | undefined>,\n  override: { page?: number },\n): string {\n  const params = new URLSearchParams();\n  const passthrough = [\n    \"phase\",\n    \"outcome\",\n    \"search\",\n    \"fromDate\",\n    \"toDate\",\n    \"stuckAged\",\n    \"stuckAttempts\",\n    \"stuckNoTx\",\n    \"stuckRefunds\",\n  ] as const;\n  for (const key of passthrough) {\n    const value = trimOrNull(readSingleValue(raw[key]));\n    if (value) params.set(key, value);\n  }\n  if (override.page && override.page > 1) {\n    params.set(\"page\", String(override.page));\n  }\n  return params.toString();\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1534,"cache_read_input_tokens":115264,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1534},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"07ea83e7-4ecf-4755-98ef-051aea36da1a","uuid":"3c70e12b-1b60-480e-834e-b627ceac0630"}
