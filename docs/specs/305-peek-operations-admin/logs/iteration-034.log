cs: [],\n  };\n  let topReferrers: ReadonlyArray<PeekTopReferrerRow> = [];\n  let claims: ReadonlyArray<PeekGrowthClaimRow> = [];\n  let overviewError: string | null = null;\n  let topReferrersError: string | null = null;\n  let claimsError: string | null = null;\n\n  try {\n    overview = await getGrowthReferralOverview();\n  } catch (error) {\n    overviewError =\n      error instanceof Error\n        ? error.message\n        : \"Overview metrics could not be loaded.\";\n  }\n\n  try {\n    topReferrers = await listTopReferrers();\n  } catch (error) {\n    topReferrersError =\n      error instanceof Error\n        ? error.message\n        : \"Top referrers could not be loaded.\";\n  }\n\n  try {\n    claims = await listReferralClaims({ filters });\n  } catch (error) {\n    claimsError =\n      error instanceof Error\n        ? error.message\n        : \"Referral claims could not be loaded.\";\n  }\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <h1>Growth · Referrals</h1>\n        <p style={leadStyle}>\n          Referral overview, top referrers, and claim payout state. Drill into\n          a row to open the user-detail page for that referrer or claimant.\n        </p>\n      </header>\n\n      <section aria-labelledby=\"overview-heading\">\n        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n          Overview\n        </h2>\n        <MetricStrip metrics={overview.metrics} error={overviewError} />\n      </section>\n\n      <section\n        aria-labelledby=\"top-referrers-heading\"\n        id=\"top-referrers\"\n        style={sectionStyle}\n      >\n        <h2 id=\"top-referrers-heading\" style={sectionHeadingStyle}>\n          Top referrers\n        </h2>\n        <p style={hintStyle}>\n          Default 50 rows · sorted by referrer earnings · server-side capped at\n          250.\n        </p>\n        <GrowthReferrersTable\n          rows={topReferrers}\n          error={topReferrersError}\n        />\n      </section>\n\n      <section\n        aria-labelledby=\"claims-heading\"\n        id=\"claims\"\n        style={sectionStyle}\n      >\n        <h2 id=\"claims-heading\" style={sectionHeadingStyle}>\n          Referral claims\n        </h2>\n        <p style={hintStyle}>\n          Filterable by status, user, amount, requested date, tx signature, and\n          error text. URL-addressable so internal investigations can be shared.\n        </p>\n        <GrowthClaimsFilterBar filters={filters} action={ROUTE} />\n        <GrowthClaimsTable rows={claims} error={claimsError} />\n      </section>\n    </main>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n","numLines":178,"startLine":1,"totalLines":178}}}
