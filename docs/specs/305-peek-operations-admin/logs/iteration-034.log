ap((o) => o.value);\n44\t    expect(optionLabels).toContain(\"\");\n45\t    for (const status of PEEK_REFERRAL_CLAIM_STATUSES) {\n46\t      expect(optionLabels).toContain(status);\n47\t    }\n48\t\n49\t    // Every text/number/date input renders empty when its filter is null.\n50\t    expect((screen.getByLabelText(\"User ID\") as HTMLInputElement).value).toBe(\n51\t      \"\",\n52\t    );\n53\t    expect(\n54\t      (screen.getByLabelText(\"Min amount (lamports)\") as HTMLInputElement)\n55\t        .value,\n56\t    ).toBe(\"\");\n57\t    expect(\n58\t      (screen.getByLabelText(\"Max amount (lamports)\") as HTMLInputElement)\n59\t        .value,\n60\t    ).toBe(\"\");\n61\t    expect(\n62\t      (screen.getByLabelText(\"Requested from\") as HTMLInputElement).value,\n63\t    ).toBe(\"\");\n64\t    expect(\n65\t      (screen.getByLabelText(\"Requested to\") as HTMLInputElement).value,\n66\t    ).toBe(\"\");\n67\t    expect(\n68\t      (screen.getByLabelText(\"Tx signature\") as HTMLInputElement).value,\n69\t    ).toBe(\"\");\n70\t    expect(\n71\t      (screen.getByLabelText(\"Error contains\") as HTMLInputElement).value,\n72\t    ).toBe(\"\");\n73\t\n74\t    expect(\n75\t      screen.getByRole(\"button\", { name: \"Apply filters\" }),\n76\t    ).toBeInTheDocument();\n77\t  });\n78\t\n79\t  it(\"populated: every filter value is reflected in the corresponding input\", () => {\n80\t    render(<GrowthClaimsFilterBar filters={POPULATED_FILTERS} />);\n81\t\n82\t    expect((screen.getByLabelText(\"Status\") as HTMLSelectElement).value).toBe(\n83\t      \"pending\",\n84\t    );\n85\t    expect((screen.getByLabelText(\"User ID\") as HTMLInputElement).value).toBe(\n86\t      \"u-1\",\n87\t    );\n88\t    expect(\n89\t      (screen.getByLabelText(\"Min amount (lamports)\") as HTMLInputElement)\n90\t        .value,\n91\t    ).toBe(\"1000\");\n92\t    expect(\n93\t      (screen.getByLabelText(\"Max amount (lamports)\") as HTMLInputElement)\n94\t        .value,\n95\t    ).toBe(\"