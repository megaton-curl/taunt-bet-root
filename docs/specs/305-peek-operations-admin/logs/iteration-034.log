{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01VPEKYV2yKTgknHXK3jcPz8","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Dq7s4PgpcVaX27jE8yoBZh","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/app/games/[game]/page.tsx","content":"// /games/[game] — per-game round audit (FR-8).\n//\n// Handles FlipYou + Pot Shot + Close Call through one [game] param. FlipYou +\n// Pot Shot share the `rounds` table, so the page calls `listRounds({ game })`\n// and renders the shared `GameRoundsTable`. Close Call has its own table and\n// lifecycle (`open` -> `settled`/`refunded` plus a Pyth-driven outcome), so the\n// page calls `listCloseCallRounds()` and renders `CloseCallRoundsTable`.\n//\n// Stuck-state filters cover the four FR-8 operational signals (nonterminal &\n// aged, high settle attempts [FlipYou+Pot Shot only], settled without expected\n// transaction, refunds). Filters are URL-addressable so an admin can share a\n// link to the exact investigation state.\nimport { notFound } from \"next/navigation\";\nimport Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport { CloseCallRoundsTable } from \"../../../src/components/closecall-rounds-table\";\nimport { GameRoundsFilterBar } from \"../../../src/components/game-rounds-filter-bar\";\nimport { GameRoundsTable } from \"../../../src/components/game-rounds-table\";\nimport {\n  buildRoundsQueryString,\n  normalizeCloseCallRoundFiltersFromSearchParams,\n  normalizeRoundFiltersFromSearchParams,\n  readPageFromSearchParams,\n} from \"../../../src/lib/games-search-params\";\nimport {\n  PEEK_GAME_IDS,\n  type PeekCloseCallRoundRow,\n  type PeekGameId,\n  type PeekRoundRow,\n  type PeekRoundsListResult,\n} from \"../../../src/lib/types/peek\";\nimport {\n  getPeekActorContext,\n  isRouteAllowedForRole,\n} from \"../../../src/server/access-policy\";\nimport {\n  listCloseCallRounds,\n  listRounds,\n  PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n} from \"../../../src/server/db/queries/get-game-rounds\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst GAME_LABELS: Record<PeekGameId, string> = {\n  flipyou: \"FlipYou\",\n  potshot: \"Pot Shot\",\n  closecall: \"Close Call\",\n};\n\nfunction isPeekGameId(value: string): value is PeekGameId {\n  return (PEEK_GAME_IDS as ReadonlyArray<string>).includes(value);\n}\n\nexport default async function GameRoundsPage({\n  params,\n  searchParams,\n}: {\n  params: Promise<{ game: string }>;\n  searchParams: Promise<Record<string, string | string[] | undefined>>;\n}) {\n  const { game: gameParam } = await params;\n  if (!isPeekGameId(gameParam)) {\n    notFound();\n  }\n  const game = gameParam as PeekGameId;\n  const route = `/games/${game}`;\n\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(route, actor?.role ?? null);\n\n  if (!allowed) {\n    return (\n      <main style={mainStyle}>\n        <header>\n          <h1>Games · {GAME_LABELS[game]}</h1>\n        </header>\n        <p role=\"alert\" style={errorStyle}>\n          You do not have access to this page.\n        </p>\n      </main>\n    );\n  }\n\n  const rawParams = await searchParams;\n  const page = readPageFromSearchParams(rawParams);\n\n  return game === \"closecall\" ? (\n    <CloseCallView\n      route={route}\n      label={GAME_LABELS[game]}\n      page={page}\n      rawParams={rawParams}\n    />\n  ) : (\n    <RoundsView\n      route={route}\n      label={GAME_LABELS[game]}\n      game={game}\n      page={page}\n      rawParams={rawParams}\n    />\n  );\n}\n\nasync function RoundsView({\n  route,\n  label,\n  game,\n  page,\n  rawParams,\n}: {\n  route: string;\n  label: string;\n  game: \"flipyou\" | \"potshot\";\n  page: number;\n  rawParams: Record<string, string | string[] | undefined>;\n}) {\n  const filters = normalizeRoundFiltersFromSearchParams(rawParams);\n\n  let result: PeekRoundsListResult<PeekRoundRow> = {\n    rows: [],\n    pagination: {\n      page,\n      pageSize: PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n      totalCount: 0,\n      totalPages: 1,\n    },\n  };\n  let error: string | null = null;\n\n  try {\n    result = await listRounds({ game, filters, page });\n  } catch (err) {\n    error =\n      err instanceof Error ? err.message : \"Rounds could not be loaded.\";\n  }\n\n  return (\n    <main style={mainStyle}>\n      <PageHeader route={route} label={label} />\n      <SectionFilters>\n        <GameRoundsFilterBar game={game} filters={filters} action={route} />\n      </SectionFilters>\n      <SectionTable\n        rows={result.rows.length}\n        total={result.pagination.totalCount}\n        page={result.pagination.page}\n        totalPages={result.pagination.totalPages}\n        rawParams={rawParams}\n        route={route}\n      >\n        <GameRoundsTable rows={result.rows} error={error} />\n      </SectionTable>\n    </main>\n  );\n}\n\nasync function CloseCallView({\n  route,\n  label,\n  page,\n  rawParams,\n}: {\n  route: string;\n  label: string;\n  page: number;\n  rawParams: Record<string, string | string[] | undefined>;\n}) {\n  const filters = normalizeCloseCallRoundFiltersFromSearchParams(rawParams);\n\n  let result: PeekRoundsListResult<PeekCloseCallRoundRow> = {\n    rows: [],\n    pagination: {\n      page,\n      pageSize: PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n      totalCount: 0,\n      totalPages: 1,\n    },\n  };\n  let error: string | null = null;\n\n  try {\n    result = await listCloseCallRounds({ filters, page });\n  } catch (err) {\n    error =\n      err instanceof Error ? err.message : \"Rounds could not be loaded.\";\n  }\n\n  return (\n    <main style={mainStyle}>\n      <PageHeader route={route} label={label} />\n      <SectionFilters>\n        <GameRoundsFilterBar\n          game=\"closecall\"\n          filters={filters}\n          action={route}\n        />\n      </SectionFilters>\n      <SectionTable\n        rows={result.rows.length}\n        total={result.pagination.totalCount}\n        page={result.pagination.page}\n        totalPages={result.pagination.totalPages}\n        rawParams={rawParams}\n        route={route}\n      >\n        <CloseCallRoundsTable rows={result.rows} error={error} />\n      </SectionTable>\n    </main>\n  );\n}\n\nfunction PageHeader({ route, label }: { route: string; label: string }) {\n  return (\n    <header>\n      <p style={breadcrumbStyle}>\n        <Link href=\"/games\" style={breadcrumbLinkStyle}>\n          ← Games\n        </Link>\n      </p>\n      <h1>Games · {label}</h1>\n      <p style={leadStyle}>\n        Round-level audit for {label}. Filter by phase, search by pda/match\n        id/creator, narrow by created date, or apply stuck-state filters to\n        find rounds that need attention. Filters are URL-addressable. Source:\n        <code style={codeStyle}> {route}</code>.\n      </p>\n    </header>\n  );\n}\n\nfunction SectionFilters({ children }: { children: React.ReactNode }) {\n  return (\n    <section aria-labelledby=\"filters-heading\" style={sectionStyle}>\n      <h2 id=\"filters-heading\" style={sectionHeadingStyle}>\n        Filters\n      </h2>\n      {children}\n    </section>\n  );\n}\n\nfunction SectionTable({\n  children,\n  rows,\n  total,\n  page,\n  totalPages,\n  rawParams,\n  route,\n}: {\n  children: React.ReactNode;\n  rows: number;\n  total: number;\n  page: number;\n  totalPages: number;\n  rawParams: Record<string, string | string[] | undefined>;\n  route: string;\n}) {\n  return (\n    <section aria-labelledby=\"rounds-heading\" style={sectionStyle}>\n      <h2 id=\"rounds-heading\" style={sectionHeadingStyle}>\n        Rounds\n      </h2>\n      <p style={hintStyle}>\n        {rows} shown · {total} total · sorted by created_at desc · default 50\n        rows · server-side capped at 250.\n      </p>\n      {children}\n      {totalPages > 1 ? (\n        <nav aria-label=\"Pagination\" style={paginationStyle}>\n          <PageLink\n            disabled={page <= 1}\n            href={pageHref(route, rawParams, page - 1)}\n          >\n            Previous\n          </PageLink>\n          <span style={pageLabelStyle}>\n            Page {page} of {totalPages}\n          </span>\n          <PageLink\n            disabled={page >= totalPages}\n            href={pageHref(route, rawParams, page + 1)}\n          >\n            Next\n          </PageLink>\n        </nav>\n      ) : null}\n    </section>\n  );\n}\n\nfunction pageHref(\n  route: string,\n  rawParams: Record<string, string | string[] | undefined>,\n  page: number,\n): string {\n  const qs = buildRoundsQueryString(rawParams, { page });\n  return qs ? `${route}?${qs}` : route;\n}\n\nfunction PageLink({\n  href,\n  disabled,\n  children,\n}: {\n  href: string;\n  disabled: boolean;\n  children: React.ReactNode;\n}) {\n  if (disabled) {\n    return (\n      <span aria-disabled=\"true\" style={{ ...pageButton, ...pageButtonDisabled }}>\n        {children}\n      </span>\n    );\n  }\n  return (\n    <Link href={href} style={pageButton}>\n      {children}\n    </Link>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst breadcrumbStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n\nconst breadcrumbLinkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst codeStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  color: \"#cbd5f5\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst paginationStyle: CSSProperties = {\n  display: \"flex\",\n  gap: \"0.75rem\",\n  alignItems: \"center\",\n  flexWrap: \"wrap\",\n};\n\nconst pageLabelStyle: CSSProperties = {\n  color: \"#cbd5e1\",\n  fontSize: \"0.875rem\",\n};\n\nconst pageButton: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #334155\",\n  padding: \"0.5rem 0.75rem\",\n  color: \"#e2e8f0\",\n  textDecoration: \"none\",\n  fontSize: \"0.875rem\",\n};\n\nconst pageButtonDisabled: CSSProperties = {\n  color: \"#64748b\",\n  borderColor: \"#1e293b\",\n  cursor: \"not-allowed\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":144,"cache_read_input_tokens":127548,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":144},"output_tokens":72,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"07ea83e7-4ecf-4755-98ef-051aea36da1a","uuid":"86f963bd-a8f5-43a8-b777-3d3f1e06184f"}
