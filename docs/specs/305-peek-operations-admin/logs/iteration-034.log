{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ENdzCXjsE7sr3pNb2qrTqH","type":"tool_result","content":"1\t// Top-referrers table for /growth/referrals (FR-7).\n2\t//\n3\t// Dense readonly table over `PeekTopReferrerRow` with drill-down to user\n4\t// detail and an inline empty state.\n5\timport Link from \"next/link\";\n6\timport type { CSSProperties } from \"react\";\n7\timport type { PeekTopReferrerRow } from \"../lib/types/peek\";\n8\t\n9\texport type GrowthReferrersTableProps = {\n10\t  rows: ReadonlyArray<PeekTopReferrerRow>;\n11\t  error?: string | null;\n12\t};\n13\t\n14\texport function GrowthReferrersTable({\n15\t  rows,\n16\t  error = null,\n17\t}: GrowthReferrersTableProps) {\n18\t  if (error) {\n19\t    return (\n20\t      <div role=\"alert\" style={errorStyle}>\n21\t        Top referrers unavailable: {error}\n22\t      </div>\n23\t    );\n24\t  }\n25\t\n26\t  if (rows.length === 0) {\n27\t    return (\n28\t      <div role=\"status\" style={emptyStyle}>\n29\t        <p style={emptyTitleStyle}>No referrers yet.</p>\n30\t        <p style={emptyBodyStyle}>\n31\t          No rows in `referral_links` have produced any referee yet, so no\n32\t          referrer can be ranked.\n33\t        </p>\n34\t      </div>\n35\t    );\n36\t  }\n37\t\n38\t  return (\n39\t    <div style={wrapperStyle}>\n40\t      <table style={tableStyle}>\n41\t        <thead>\n42\t          <tr style={headerRowStyle}>\n43\t            <th style={headerCellStyle(\"left\")}>Referrer</th>\n44\t            <th style={headerCellStyle(\"left\")}>Code</th>\n45\t            <th style={headerCellStyle(\"left\")}>Wallet</th>\n46\t            <th style={headerCellStyle(\"right\")}>Referees</th>\n47\t            <th style={headerCellStyle(\"right\")}>Active</th>\n48\t            <th style={headerCellStyle(\"right\")}>Wager (lamports)</th>\n49\t            <th style={headerCellStyle(\"right\")}>Earned (lamports)</th>\n50\t            <th style={headerCellStyle(\"right\")}>Pending claim (lamports)</th>\n51\t          </tr>\n52\t        </thead>\n53\t        <tbody>\n54\t          {rows.map((row) => (\n55\t            <tr key={row.referrerUserId} style={bodyRowStyle}>\n56\t              <td style={bodyCellStyle(\"left\")}>\n57\t                <Link\n58\t                  href={`/users/${row.referrerUserId}`}\n59\t                  style={linkStyle}\n60\t                >\n61\t                  {row.username ?? row.referrerUserId}\n62\t                </Link>\n63\t                {row.username ? (\n64\t                  <span style={subValueStyle}> · {row.referrerUserId}</span>\n65\t                ) : null}\n66\t              </td>\n67\t              <td style={bodyCellStyle(\"left\")}>{row.referralCode ?? \"—\"}</td>\n68\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n69\t                {row.wallet}\n70\t              </td>\n71\t              <td style={bodyCellStyle(\"right\")}>{row.refereeCount}</td>\n72\t              <td style={bodyCellStyle(\"right\")}>{row.activeRefereeCount}</td>\n73\t              <td style={bodyCellStyle(\"right\")}>\n74\t                {formatLamports(row.referredWagerLamports)}\n75\t              </td>\n76\t              <td style={bodyCellStyle(\"right\")}>\n77\t                {formatLamports(row.referrerEarnedLamports)}\n78\t              </td>\n79\t              <td style={bodyCellStyle(\"right\")}>\n80\t                {formatLamports(row.pendingClaimLamports)}\n81\t              </td>\n82\t            </tr>\n83\t          ))}\n84\t        </tbody>\n85\t      </table>\n86\t    </div>\n87\t  );\n88\t}\n89\t\n90\tfunction formatLamports(value: string): string {\n91\t  if (!value || value === \"0\") return \"0\";\n92\t  const negative = value.startsWith(\"-\");\n93\t  const digits = negative ? value.slice(1) : value;\n94\t  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n95\t  return negative ? `-${grouped}` : grouped;\n96\t}\n97\t\n98\tconst wrapperStyle: CSSProperties = {\n99\t  overflowX: \"auto\",\n100\t  border: \"1px solid #1e293b\",\n101\t  borderRadius: \"0.75rem\",\n102\t};\n103\t\n104\tconst tableStyle: CSSProperties = {\n105\t  width: \"100%\",\n106\t  borderCollapse: \"collapse\",\n107\t};\n108\t\n109\tconst headerRowStyle: CSSProperties = {\n110\t  background: \"#111827\",\n111\t  color: \"#94a3b8\",\n112\t};\n113\t\n114\tconst bodyRowStyle: CSSProperties = {\n115\t  borderTop: \"1px solid #1e293b\",\n116\t};\n117\t\n118\tconst linkStyle: CSSProperties = {\n119\t  color: \"#93c5fd\",\n120\t  textDecoration: \"none\",\n121\t};\n122\t\n123\tconst subValueStyle: CSSProperties = {\n124\t  color: \"#64748b\",\n125\t  fontSize: \"0.75rem\",\n126\t  marginLeft: \"0.25rem\",\n127\t};\n128\t\n129\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n130\t  return {\n131\t    padding: \"0.75rem\",\n132\t    textAlign: align,\n133\t    fontSize: \"0.875rem\",\n134\t    fontWeight: 600,\n135\t  };\n136\t}\n137\t\n138\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n139\t  return {\n140\t    padding: \"0.75rem\",\n141\t    textAlign: align,\n142\t    fontSize: \"0.875rem\",\n143\t  };\n144\t}\n145\t\n146\tconst errorStyle: CSSProperties = {\n147\t  margin: 0,\n148\t  padding: \"0.75rem 1rem\",\n149\t  borderRadius: \"0.75rem\",\n150\t  background: \"#3f1d1d\",\n151\t  color: \"#fecaca\",\n152\t};\n153\t\n154\tconst emptyStyle: CSSProperties = {\n155\t  padding: \"1.5rem\",\n156\t  borderRadius: \"0.75rem\",\n157\t  border: \"1px dashed #334155\",\n158\t  background: \"#0b1220\",\n159\t  color: \"#cbd5f5\",\n160\t  display: \"grid\",\n161\t  gap: \"0.5rem\",\n162\t};\n163\t\n164\tconst emptyTitleStyle: CSSProperties = {\n165\t  margin: 0,\n166\t  fontSize: \"1rem\",\n167\t  fontWeight: 600,\n168\t};\n169\t\n170\tconst emptyBodyStyle: CSSProperties = {\n171\t  margin: 0,\n172\t  fontSize: \"0.875rem\",\n173\t  color: \"#94a3b8\",\n174\t};\n175\t"}]},"parent_tool_use_id":null,"session_id":"07ea83e7-4ecf-4755-98ef-051aea36da1a","uuid":"f51a1dd8-7d3c-4a26-9c99-2b6a0a16494f","timestamp":"2026-04-25T13:05:50.554Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/growth-referrers-table.tsx","content":"// Top-referrers table for /growth/referrals (FR-7).\n//\n// Dense readonly table over `PeekTopReferrerRow` with drill-down to user\n// detail and an inline empty state.\nimport Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type { PeekTopReferrerRow } from \"../lib/types/peek\";\n\nexport type GrowthReferrersTableProps = {\n  rows: ReadonlyArray<PeekTopReferrerRow>;\n  error?: string | null;\n};\n\nexport function GrowthReferrersTable({\n  rows,\n  error = null,\n}: GrowthReferrersTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Top referrers unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No referrers yet.</p>\n        <p style={emptyBodyStyle}>\n          No rows in `referral_links` have produced any referee yet, so no\n          referrer can be ranked.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Referrer</th>\n            <th style={headerCellStyle(\"left\")}>Code</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"right\")}>Referees</th>\n            <th style={headerCellStyle(\"right\")}>Active</th>\n            <th style={headerCellStyle(\"right\")}>Wager (lamports)</th>\n            <th style={headerCellStyle(\"right\")}>Earned (lamports)</th>\n            <th style={headerCellStyle(\"right\")}>Pending claim (lamports)</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.referrerUserId} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>\n                <Link\n                  href={`/users/${row.referrerUserId}`}\n                  style={linkStyle}\n                >\n                  {row.username ?? row.referrerUserId}\n                </Link>\n                {row.username ? (\n                  <span style={subValueStyle}> · {row.referrerUserId}</span>\n                ) : null}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.referralCode ?? \"—\"}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.wallet}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>{row.refereeCount}</td>\n              <td style={bodyCellStyle(\"right\")}>{row.activeRefereeCount}</td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatLamports(row.referredWagerLamports)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatLamports(row.referrerEarnedLamports)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatLamports(row.pendingClaimLamports)}\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction formatLamports(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n  marginLeft: \"0.25rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":175,"startLine":1,"totalLines":175}}}
