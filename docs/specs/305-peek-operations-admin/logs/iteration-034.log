Style(\"left\")}>Outcome</th>\n            <th style={headerCellStyle(\"left\")}>Round ID</th>\n            <th style={headerCellStyle(\"left\")}>PDA</th>\n            <th style={headerCellStyle(\"right\")}>Open price</th>\n            <th style={headerCellStyle(\"right\")}>Close price</th>\n            <th style={headerCellStyle(\"right\")}>Green pool</th>\n            <th style={headerCellStyle(\"right\")}>Red pool</th>\n            <th style={headerCellStyle(\"right\")}>Total fee</th>\n            <th style={headerCellStyle(\"left\")}>Settle tx</th>\n            <th style={headerCellStyle(\"left\")}>Settled</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.pda} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip label={row.phase} tone={phaseTone(row.phase)} />\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip label={row.outcome} tone={outcomeTone(row.outcome)} />\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={row.roundId}>{truncate(row.roundId, 16)}</span>\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={row.pda}>{truncate(row.pda, 12)}</span>\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                <span style={priceStyle}>{formatNumber(row.openPrice)}</span>\n                <span style={subValueStyle}> · expo {row.openPriceExpo}</span>\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {row.closePrice ? formatNumber(row.closePrice) : \"—\"}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(row.greenPoolLamports)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(row.redPoolLamports)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(row.totalFeeLamports)}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.settleTx ? (\n                  <span title={row.settleTx}>{truncate(row.settleTx, 12)}</span>\n                ) : (\n                  \"—\"\n                )}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.settledAt ?? \"—\"}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction phaseTone(phase: PeekCloseCallPhase): PeekStatusTone {\n  if (phase === \"settled\") return \"positive\";\n  if (phase === \"refunded\") return \"warning\";\n  return \"info\";\n}\n\nfunction outcomeTone(outcome: PeekCloseCallOutcome): PeekStatusTone {\n  if (outcome === \"green\") return \"positive\";\n  if (outcome === \"red\") return \"negative\";\n  if (outcome === \"refund\") return \"warning\";\n  return \"neutral\";\n}\n\nfunction truncate(value: string, max: number): string {\n  if (value.length <= max) return value;\n  const head = Math.max(2, Math.floor((max - 1) / 2));\n  const tail = Math.max(2, max - 1 - head);\n  return `${value.slice(0, head)}…${value.slice(-tail)}`;\n}\n\nfunction formatNumber(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyl