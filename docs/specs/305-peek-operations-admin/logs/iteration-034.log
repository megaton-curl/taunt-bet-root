{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_012FWSru9A6zgTcxbNNe6wR9","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TWTgVN1K1vyBvKDrCxEhcV","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/game-rounds-filter-bar.tsx","content":"// URL-addressable rounds filter bar for /games/[game] (FR-8, FR-4).\n//\n// Submits to the same page so filters are shareable. The shape switches on the\n// game id: FlipYou + Pot Shot share the `rounds` table phases and the four\n// stuck-state booleans (`stuckAged`, `stuckAttempts`, `stuckNoTx`,\n// `stuckRefunds`); Close Call replaces `stuckAttempts` with an `outcome`\n// dropdown and uses three stuck flags because `closecall_rounds` has no\n// `settle_attempts` column.\nimport type { CSSProperties } from \"react\";\nimport {\n  PEEK_CLOSECALL_OUTCOMES,\n  PEEK_CLOSECALL_PHASES,\n  PEEK_ROUND_PHASES,\n  type PeekCloseCallRoundFilters,\n  type PeekGameId,\n  type PeekRoundFilters,\n} from \"../lib/types/peek\";\n\nexport type GameRoundsFilterBarProps =\n  | {\n      game: \"flipyou\" | \"potshot\";\n      filters: PeekRoundFilters;\n      action: string;\n    }\n  | {\n      game: \"closecall\";\n      filters: PeekCloseCallRoundFilters;\n      action: string;\n    };\n\nexport function GameRoundsFilterBar(props: GameRoundsFilterBarProps) {\n  const { game, action, filters } = props;\n  const isCloseCall = game === \"closecall\";\n\n  return (\n    <form\n      action={action}\n      method=\"get\"\n      role=\"search\"\n      aria-label={`Filter ${labelForGame(game)} rounds`}\n      style={formStyle}\n    >\n      <label style={fieldStyle}>\n        <span>Phase</span>\n        <select\n          name=\"phase\"\n          defaultValue={filters.phase ?? \"\"}\n          style={inputStyle}\n        >\n          <option value=\"\">Any</option>\n          {(isCloseCall ? PEEK_CLOSECALL_PHASES : PEEK_ROUND_PHASES).map(\n            (phase) => (\n              <option key={phase} value={phase}>\n                {phase}\n              </option>\n            ),\n          )}\n        </select>\n      </label>\n\n      {isCloseCall ? (\n        <label style={fieldStyle}>\n          <span>Outcome</span>\n          <select\n            name=\"outcome\"\n            defaultValue={\n              (filters as PeekCloseCallRoundFilters).outcome ?? \"\"\n            }\n            style={inputStyle}\n          >\n            <option value=\"\">Any</option>\n            {PEEK_CLOSECALL_OUTCOMES.map((outcome) => (\n              <option key={outcome} value={outcome}>\n                {outcome}\n              </option>\n            ))}\n          </select>\n        </label>\n      ) : null}\n\n      <label style={fieldStyle}>\n        <span>Search</span>\n        <input\n          name=\"search\"\n          type=\"text\"\n          defaultValue={filters.search ?? \"\"}\n          placeholder={\n            isCloseCall ? \"pda or round id\" : \"pda, match id, or creator\"\n          }\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Created from</span>\n        <input\n          name=\"fromDate\"\n          type=\"date\"\n          defaultValue={(filters.fromDate ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Created to</span>\n        <input\n          name=\"toDate\"\n          type=\"date\"\n          defaultValue={(filters.toDate ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <fieldset style={fieldsetStyle}>\n        <legend style={legendStyle}>Stuck-state filters</legend>\n        <label style={checkboxRowStyle}>\n          <input\n            type=\"checkbox\"\n            name=\"stuckAged\"\n            value=\"1\"\n            defaultChecked={filters.stuck.nonterminalAged}\n          />\n          <span>Nonterminal &amp; aged</span>\n        </label>\n        {!isCloseCall ? (\n          <label style={checkboxRowStyle}>\n            <input\n              type=\"checkbox\"\n              name=\"stuckAttempts\"\n              value=\"1\"\n              defaultChecked={\n                (filters as PeekRoundFilters).stuck.highAttempts\n              }\n            />\n            <span>High settle attempts</span>\n          </label>\n        ) : null}\n        <label style={checkboxRowStyle}>\n          <input\n            type=\"checkbox\"\n            name=\"stuckNoTx\"\n            value=\"1\"\n            defaultChecked={filters.stuck.settledWithoutTx}\n          />\n          <span>Settled without tx</span>\n        </label>\n        <label style={checkboxRowStyle}>\n          <input\n            type=\"checkbox\"\n            name=\"stuckRefunds\"\n            value=\"1\"\n            defaultChecked={filters.stuck.refunds}\n          />\n          <span>Refunds</span>\n        </label>\n      </fieldset>\n\n      <button type=\"submit\" style={buttonStyle}>\n        Apply filters\n      </button>\n    </form>\n  );\n}\n\nfunction labelForGame(game: PeekGameId): string {\n  if (game === \"flipyou\") return \"FlipYou\";\n  if (game === \"potshot\") return \"Pot Shot\";\n  return \"Close Call\";\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n  gridTemplateColumns: \"repeat(auto-fit, minmax(200px, 1fr))\",\n  alignItems: \"end\",\n};\n\nconst fieldStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.35rem\",\n  fontSize: \"0.875rem\",\n};\n\nconst inputStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #334155\",\n  background: \"#111827\",\n  color: \"#e2e8f0\",\n  padding: \"0.625rem 0.75rem\",\n};\n\nconst fieldsetStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.35rem\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.5rem\",\n  padding: \"0.5rem 0.75rem\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  margin: 0,\n  fontSize: \"0.8125rem\",\n};\n\nconst legendStyle: CSSProperties = {\n  padding: \"0 0.25rem\",\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst checkboxRowStyle: CSSProperties = {\n  display: \"flex\",\n  gap: \"0.5rem\",\n  alignItems: \"center\",\n};\n\nconst buttonStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #475569\",\n  background: \"#1d4ed8\",\n  color: \"#eff6ff\",\n  padding: \"0.75rem 1rem\",\n  fontWeight: 600,\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2063,"cache_read_input_tokens":116798,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2063},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"07ea83e7-4ecf-4755-98ef-051aea36da1a","uuid":"a68361c2-c2da-46e5-b312-9fa09932b6b6"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TWTgVN1K1vyBvKDrCxEhcV","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/components/game-rounds-filter-bar.tsx"}]},"parent_tool_use_id":null,"session_id":"07ea83e7-4ecf-4755-98ef-051aea36da1a","uuid":"84d7c896-54b7-46bd-b948-541002f8c691","timestamp":"2026-04-25T13:07:21.431Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/components/game-rounds-filter-bar.tsx","content":"// URL-addressable rounds filter bar for /games/[game] (FR-8, FR-4).\n//\n// Submits to the same page so filters are shareable. The shape switches on the\n// game id: FlipYou + Pot Shot share the `rounds` table phases and the four\n// stuck-state booleans (`stuckAged`, `stuckAttempts`, `stuckNoTx`,\n// `stuckRefunds`); Close Call replaces `stuckAttempts` with an `outcome`\n// dropdown and uses three stuck flags because `closecall_rounds` has no\n// `settle_attempts` column.\nimport type { CSSProperties } from \"react\";\nimport {\n  PEEK_CLOSECALL_OUTCOMES,\n  PEEK_CLOSECALL_PHASES,\n  PEEK_ROUND_PHASES,\n  type PeekCloseCallRoundFilters,\n  type PeekGameId,\n  type PeekRoundFilters,\n} from \"../lib/types/peek\";\n\nexport type GameRoundsFilterBarProps =\n  | {\n      game: \"flipyou\" | \"potshot\";\n      filters: PeekRoundFilters;\n      action: string;\n    }\n  | {\n      game: \"closecall\";\n      filters: PeekCloseCallRoundFilters;\n      action: string;\n    };\n\nexport function GameRoundsFilterBar(props: GameRoundsFilterBarProps) {\n  const { game, action, filters } = props;\n  const isCloseCall = game === \"closecall\";\n\n  return (\n    <form\n      action={action}\n      method=\"get\"\n      role=\"search\"\n      aria-label={`Filter ${labelForGame(game)} rounds`}\n      style={formStyle}\n    >\n      <label style={fieldStyle}>\n        <span>Phase</span>\n        <select\n          name=\"phase\"\n          defaultValue={filters.phase ?? \"\"}\n          style={inputStyle}\n        >\n          <option value=\"\">Any</option>\n          {(isCloseCall ? PEEK_CLOSECALL_PHASES : PEEK_ROUND_PHASES).map(\n            (phase) => (\n              <option key={phase} value={phase}>\n                {phase}\n              </option>\n            ),\n          )}\n        </select>\n      </label>\n\n      {isCloseCall ? (\n        <label style={fieldStyle}>\n          <span>Outcome</span>\n          <select\n            name=\"outcome\"\n            defaultValue={\n              (filters as PeekCloseCallRoundFilters).outcome ?? \"\"\n            }\n            style={inputStyle}\n          >\n            <option value=\"\">Any</option>\n            {PEEK_CLOSECALL_OUTCOMES.map((outcome) => (\n              <option key={outcome} value={outcome}>\n                {outcome}\n              </option>\n            ))}\n          </select>\n        </label>\n      ) : null}\n\n      <label style={fieldStyle}>\n        <span>Search</span>\n        <input\n          name=\"search\"\n          type=\"text\"\n          defaultValue={filters.search ?? \"\"}\n          placeholder={\n            isCloseCall ? \"pda or round id\" : \"pda, match id, or creator\"\n          }\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Created from</span>\n        <input\n          name=\"fromDate\"\n          type=\"date\"\n          defaultValue={(filters.fromDate ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Created to</span>\n        <input\n          name=\"toDate\"\n          type=\"date\"\n          defaultValue={(filters.toDate ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <fieldset style={fieldsetStyle}>\n        <legend style={legendStyle}>Stuck-state filters</legend>\n        <label style={checkboxRowStyle}>\n          <input\n            type=\"checkbox\"\n            name=\"stuckAged\"\n            value=\"1\"\n            defaultChecked={filters.stuck.nonterminalAged}\n          />\n          <span>Nonterminal &amp; aged</span>\n        </label>\n        {!isCloseCall ? (\n          <label style={checkboxRowStyle}>\n            <input\n              type=\"checkbox\"\n              name=\"stuckAttempts\"\n              value=\"1\"\n              defaultChecked={\n                (filters as PeekRoundFilters).stuck.highAttempts\n              }\n            />\n            <span>High settle attempts</span>\n          </label>\n        ) : null}\n        <label style={checkboxRowStyle}>\n          <input\n            type=\"checkbox\"\n            name=\"stuckNoTx\"\n            value=\"1\"\n            defaultChecked={filters.stuck.settledWithoutTx}\n          />\n          <span>Settled without tx</span>\n        </label>\n        <label style={checkboxRowStyle}>\n          <input\n            type=\"checkbox\"\n            name=\"stuckRefunds\"\n            value=\"1\"\n            defaultChecked={filters.stuck.refunds}\n          />\n          <span>Refunds</span>\n        </label>\n      </fieldset>\n\n      <button type=\"submit\" style={buttonStyle}>\n        Apply filters\n      </button>\n    </form>\n  );\n}\n\nfunction labelForGame(game: PeekGameId): string {\n  if (game === \"flipyou\") return \"FlipYou\";\n  if (game === \"potshot\") return \"Pot Shot\";\n  return \"Close Call\";\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n  gridTemplateColumns: \"repeat(auto-fit, minmax(200px, 1fr))\",\n  alignItems: \"end\",\n};\n\nconst fieldStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.35rem\",\n  fontSize: \"0.875rem\",\n};\n\nconst inputStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #334155\",\n  background: \"#111827\",\n  color: \"#e2e8f0\",\n  padding: \"0.625rem 0.75rem\",\n};\n\nconst fieldsetStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.35rem\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.5rem\",\n  padding: \"0.5rem 0.75rem\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  margin: 0,\n  fontSize: \"0.8125rem\",\n};\n\nconst legendStyle: CSSProperties = {\n  padding: \"0 0.25rem\",\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst checkboxRowStyle: CSSProperties = {\n  display: \"flex\",\n  gap: \"0.5rem\",\n  alignItems: \"center\",\n};\n\nconst buttonStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #475569\",\n  background: \"#1d4ed8\",\n  color: \"#eff6ff\",\n  padding: \"0.75rem 1rem\",\n  fontWeight: 600,\n};\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01EkWZ2RwfURTQpnvvw8CnXi","type":"message","role":"assistant","content":[{"type":"text","text":"Now the rounds tables:"}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2742,"cache_read_input_tokens":118861,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2742},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"07ea83e7-4ecf-4755-98ef-051aea36da1a","uuid":"00278d2f-e1b4-4cbf-960b-d5b595f52a84"}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01EkWZ2RwfURTQpnvvw8CnXi","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Hcv8C2BxWTwnvuij3jcJYb","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/game-rounds-table.tsx","content":"// Per-round table for FlipYou + Pot Shot at /games/[game] (FR-8).\n//\n// Dense readonly table over `PeekRoundRow` from the shared `rounds` table\n// (migration 001). Lamport / slot columns right-aligned with thousands\n// separators. Phase renders as a status chip so refund/settled/stuck states\n// pop visually. Truncates long pubkeys with monospace + `title` for full value\n// on hover so the table stays scannable.\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekRoundPhase,\n  PeekRoundRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type GameRoundsTableProps = {\n  rows: ReadonlyArray<PeekRoundRow>;\n  error?: string | null;\n};\n\nexport function GameRoundsTable({ rows, error = null }: GameRoundsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Rounds unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No rounds match these filters.</p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see recent rounds from the\n          `rounds` table.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>Phase</th>\n            <th style={headerCellStyle(\"left\")}>Match ID</th>\n            <th style={headerCellStyle(\"left\")}>PDA</th>\n            <th style={headerCellStyle(\"left\")}>Creator</th>\n            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>\n            <th style={headerCellStyle(\"right\")}>Target slot</th>\n            <th style={headerCellStyle(\"right\")}>Settle attempts</th>\n            <th style={headerCellStyle(\"left\")}>Result side</th>\n            <th style={headerCellStyle(\"left\")}>Winner</th>\n            <th style={headerCellStyle(\"left\")}>Settle tx</th>\n            <th style={headerCellStyle(\"left\")}>Settled</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.pda} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.phase}\n                  tone={phaseTone(row.phase)}\n                />\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={row.matchId}>{truncate(row.matchId, 16)}</span>\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={row.pda}>{truncate(row.pda, 12)}</span>\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={row.creator}>{truncate(row.creator, 12)}</span>\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(row.amountLamports)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {row.targetSlot ? formatNumber(row.targetSlot) : \"—\"}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>{row.settleAttempts}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                {row.resultSide === null ? \"—\" : row.resultSide}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.winner ? (\n                  <span title={row.winner}>{truncate(row.winner, 12)}</span>\n                ) : (\n                  \"—\"\n                )}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.settleTx ? (\n                  <span title={row.settleTx}>{truncate(row.settleTx, 12)}</span>\n                ) : (\n                  \"—\"\n                )}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.settledAt ?? \"—\"}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction phaseTone(phase: PeekRoundPhase): PeekStatusTone {\n  if (phase === \"settled\") return \"positive\";\n  if (phase === \"expired\") return \"warning\";\n  if (phase === \"settling\") return \"info\";\n  if (phase === \"locked\") return \"info\";\n  return \"neutral\";\n}\n\nfunction truncate(value: string, max: number): string {\n  if (value.length <= max) return value;\n  const head = Math.max(2, Math.floor((max - 1) / 2));\n  const tail = Math.max(2, max - 1 - head);\n  return `${value.slice(0, head)}…${value.slice(-tail)}`;\n}\n\nfunction formatNumber(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2742,"cache_read_input_tokens":118861,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2742},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"07ea83e7-4ecf-4755-98ef-051aea36da1a","uuid":"7e16914f-aaa5-4f92-bc0f-eea956c7497b"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Hcv8C2BxWTwnvuij3jcJYb","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/components/game-rounds-table.tsx"}]},"parent_tool_use_id":null,"session_id":"07ea83e7-4ecf-4755-98ef-051aea36da1a","uuid":"4c92c450-c840-4659-b509-514aec05e6a5","timestamp":"2026-04-25T13:07:47.731Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/components/game-rounds-table.tsx","content":"// Per-round table for FlipYou + Pot Shot at /games/[game] (FR-8).\n//\n// Dense readonly table over `PeekRoundRow` from the shared `rounds` table\n// (migration 001). Lamport / slot columns right-aligned with thousands\n// separators. Phase renders as a status chip so refund/settled/stuck states\n// pop visually. Truncates long pubkeys with monospace + `title` for full value\n// on hover so the table stays scannable.\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekRoundPhase,\n  PeekRoundRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type GameRoundsTableProps = {\n  rows: ReadonlyArray<PeekRoundRow>;\n  error?: string | null;\n};\n\nexport function GameRoundsTable({ rows, error = null }: GameRoundsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Rounds unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No rounds match these filters.</p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see recent rounds from the\n          `rounds` table.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>Phase</th>\n            <th style={headerCellStyle(\"left\")}>Match ID</th>\n            <th style={headerCellStyle(\"left\")}>PDA</th>\n            <th style={headerCellStyle(\"left\")}>Creator</th>\n            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>\n            <th style={headerCellStyle(\"right\")}>Target slot</th>\n            <th style={headerCellStyle(\"right\")}>Settle attempts</th>\n            <th style={headerCellStyle(\"left\")}>Result side</th>\n            <th style={headerCellStyle(\"left\")}>Winner</th>\n            <th style={headerCellStyle(\"left\")}>Settle tx</th>\n            <th style={headerCellStyle(\"left\")}>Settled</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.pda} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.phase}\n                  tone={phaseTone(row.phase)}\n                />\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={row.matchId}>{truncate(row.matchId, 16)}</span>\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={row.pda}>{truncate(row.pda, 12)}</span>\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={row.creator}>{truncate(row.creator, 12)}</span>\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(row.amountLamports)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {row.targetSlot ? formatNumber(row.targetSlot) : \"—\"}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>{row.settleAttempts}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                {row.resultSide === null ? \"—\" : row.resultSide}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.winner ? (\n                  <span title={row.winner}>{truncate(row.winner, 12)}</span>\n                ) : (\n                  \"—\"\n                )}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.settleTx ? (\n                  <span title={row.settleTx}>{truncate(row.settleTx, 12)}</span>\n                ) : (\n                  \"—\"\n                )}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.settledAt ?? \"—\"}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction phaseTone(phase: PeekRoundPhase): PeekStatusTone {\n  if (phase === \"settled\") return \"positive\";\n  if (phase === \"expired\") return \"warning\";\n  if (phase === \"settling\") return \"info\";\n  if (phase === \"locked\") return \"info\";\n  return \"neutral\";\n}\n\nfunction truncate(value: string, max: number): string {\n  if (value.length <= max) return value;\n  const head = Math.max(2, Math.floor((max - 1) / 2));\n  const tail = Math.max(2, max - 1 - head);\n  return `${value.slice(0, head)}…${value.slice(-tail)}`;\n}\n\nfunction formatNumber(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","structuredPatch":[],"originalFile":null,"userModified":false}}
