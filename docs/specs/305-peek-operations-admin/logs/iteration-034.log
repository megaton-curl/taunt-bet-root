{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DDtEBmiNVSi4hHPuhFNv5g","type":"tool_result","content":"1\timport type { CSSProperties } from \"react\";\n2\timport { GrowthClaimsFilterBar } from \"../../../src/components/growth-claims-filter-bar\";\n3\timport { GrowthClaimsTable } from \"../../../src/components/growth-claims-table\";\n4\timport { GrowthReferrersTable } from \"../../../src/components/growth-referrers-table\";\n5\timport { MetricStrip } from \"../../../src/components/metric-strip\";\n6\timport { normalizeReferralClaimFiltersFromSearchParams } from \"../../../src/lib/growth-search-params\";\n7\timport type {\n8\t  PeekGrowthClaimRow,\n9\t  PeekGrowthOverview,\n10\t  PeekTopReferrerRow,\n11\t} from \"../../../src/lib/types/peek\";\n12\timport {\n13\t  getPeekActorContext,\n14\t  isRouteAllowedForRole,\n15\t} from \"../../../src/server/access-policy\";\n16\timport {\n17\t  getGrowthReferralOverview,\n18\t  listReferralClaims,\n19\t  listTopReferrers,\n20\t} from \"../../../src/server/db/queries/get-growth-referrals\";\n21\t\n22\texport const dynamic = \"force-dynamic\";\n23\t\n24\tconst ROUTE = \"/growth/referrals\";\n25\t\n26\texport default async function GrowthReferralsPage({\n27\t  searchParams,\n28\t}: {\n29\t  searchParams: Promise<Record<string, string | string[] | undefined>>;\n30\t}) {\n31\t  const actor = await getPeekActorContext();\n32\t  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n33\t\n34\t  if (!allowed) {\n35\t    return (\n36\t      <main style={mainStyle}>\n37\t        <header>\n38\t          <h1>Growth · Referrals</h1>\n39\t        </header>\n40\t        <p role=\"alert\" style={errorStyle}>\n41\t          You do not have access to this page.\n42\t        </p>\n43\t      </main>\n44\t    );\n45\t  }\n46\t\n47\t  const params = await searchParams;\n48\t  const filters = normalizeReferralClaimFiltersFromSearchParams(params);\n49\t\n50\t  let overview: PeekGrowthOverview = {\n51\t    generatedAt: new Date().toISOString(),\n52\t    metrics: [],\n53\t  };\n54\t  let topReferrers: ReadonlyArray<PeekTopReferrerRow> = [];\n55\t  let claims: ReadonlyArray<PeekGrowthClaimRow> = [];\n56\t  let overviewError: string | null = null;\n57\t  let topReferrersError: string | null = null;\n58\t  let claimsError: string | null = null;\n59\t\n60\t  try {\n61\t    overview = await getGrowthReferralOverview();\n62\t  } catch (error) {\n63\t    overviewError =\n64\t      error instanceof Error\n65\t        ? error.message\n66\t        : \"Overview metrics could not be loaded.\";\n67\t  }\n68\t\n69\t  try {\n70\t    topReferrers = await listTopReferrers();\n71\t  } catch (error) {\n72\t    topReferrersError =\n73\t      error instanceof Error\n74\t        ? error.message\n75\t        : \"Top referrers could not be loaded.\";\n76\t  }\n77\t\n78\t  try {\n79\t    claims = await listReferralClaims({ filters });\n80\t  } catch (error) {\n81\t    claimsError =\n82\t      error instanceof Error\n83\t        ? error.message\n84\t        : \"Referral claims could not be loaded.\";\n85\t  }\n86\t\n87\t  return (\n88\t    <main style={mainStyle}>\n89\t      <header>\n90\t        <h1>Growth · Referrals</h1>\n91\t        <p style={leadStyle}>\n92\t          Referral overview, top referrers, and claim payout state. Drill into\n93\t          a row to open the user-detail page for that referrer or claimant.\n94\t        </p>\n95\t      </header>\n96\t\n97\t      <section aria-labelledby=\"overview-heading\">\n98\t        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n99\t          Overview\n100\t        </h2>\n101\t        <MetricStrip metrics={overview.metrics} error={overviewError} />\n102\t      </section>\n103\t\n104\t      <section\n105\t        aria-labelledby=\"top-referrers-heading\"\n106\t        id=\"top-referrers\"\n107\t        style={sectionStyle}\n108\t      >\n109\t        <h2 id=\"top-referrers-heading\" style={sectionHeadingStyle}>\n110\t          Top referrers\n111\t        </h2>\n112\t        <p style={hintStyle}>\n113\t          Default 50 rows · sorted by referrer earnings · server-side capped at\n114\t          250.\n115\t        </p>\n116\t        <GrowthReferrersTable\n117\t          rows={topReferrers}\n118\t          error={topReferrersError}\n119\t        />\n120\t      </section>\n121\t\n122\t      <section\n123\t        aria-labelledby=\"claims-heading\"\n124\t        id=\"claims\"\n125\t        style={sectionStyle}\n126\t      >\n127\t        <h2 id=\"claims-heading\" style={sectionHeadingStyle}>\n128\t          Referral claims\n129\t        </h2>\n130\t        <p style={hintStyle}>\n131\t          Filterable by status, user, amount, requested date, tx signature, and\n132\t          error text. URL-addressable so internal investigations can be shared.\n133\t        </p>\n134\t        <GrowthClaimsFilterBar filters={filters} action={ROUTE} />\n135\t        <GrowthClaimsTable rows={claims} error={claimsError} />\n136\t      </section>\n137\t    </main>\n138\t  );\n139\t}\n140\t\n141\tconst mainStyle: CSSProperties = {\n142\t  display: \"grid\",\n143\t  gap: \"1.5rem\",\n144\t};\n145\t\n146\tconst sectionStyle: CSSProperties = {\n147\t  display: \"grid\",\n148\t  gap: \"0.75rem\",\n149\t};\n150\t\n151\tconst sectionHeadingStyle: CSSProperties = {\n152\t  margin: \"0 0 0.75rem\",\n153\t  fontSize: \"1rem\",\n154\t  fontWeight: 600,\n155\t  color: \"#cbd5f5\",\n156\t  textTransform: \"uppercase\",\n157\t  letterSpacing: \"0.05em\",\n158\t};\n159\t\n160\tconst leadStyle: CSSProperties = {\n161\t  margin: \"0.25rem 0 0\",\n162\t  color: \"#94a3b8\",\n163\t};\n164\t\n165\tconst hintStyle: CSSProperties = {\n166\t  margin: 0,\n167\t  color: \"#94a3b8\",\n168\t  fontSize: \"0.8125rem\",\n169\t};\n170\t\n171\tconst errorStyle: CSSProperties = {\n172\t  margin: 0,\n173\t  padding: \"0.75rem 1rem\",\n174\t  borderRadius: \"0.75rem\",\n175\t  background: \"#3f1d1d\",\n176\t  color: \"#fecaca\",\n177\t};\n178\t"}]},"pare