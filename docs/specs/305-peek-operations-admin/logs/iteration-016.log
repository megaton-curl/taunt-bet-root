e(\"peek.user.view_sensitive\");\n    expect(items[0].actorEmail).toBe(\"alice@example.com\");\n    expect(items[0].resourceType).toBe(\"user\");\n    expect(items[0].resourceId).toBe(\"u-1\");\n    expect(items[0].route).toBe(\"/users/u-1\");\n    expect(items[0].createdAt).toBe(\"2026-04-25T10:00:00.000Z\");\n    expect(items[1].resourceId).toBeNull();\n  });\n\n  it(\"populated: defaults the limit to RECENT_OPERATOR_EVENTS_DEFAULT_LIMIT\", async () => {\n    const mock = createSqlMock([]);\n\n    await getRecentOperatorEvents({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    expect(mock.calls[0].values).toContain(\n      RECENT_OPERATOR_EVENTS_DEFAULT_LIMIT,\n    );\n  });\n\n  it(\"limit clamp: oversized limits clamp down to RECENT_OPERATOR_EVENTS_MAX_LIMIT\", async () => {\n    const mock = createSqlMock([]);\n\n    await getRecentOperatorEvents({ sql: mock.sql, limit: 9999 });\n\n    expect(mock.calls[0].values).toContain(RECENT_OPERATOR_EVENTS_MAX_LIMIT);\n    expect(mock.calls[0].values).not.toContain(9999);\n  });\n\n  it(\"limit clamp: zero/negative limits clamp up to 1 so the query stays bounded but useful\", async () => {\n    const mockZero = createSqlMock([]);\n    await getRecentOperatorEvents({ sql: mockZero.sql, limit: 0 });\n    expect(mockZero.calls[0].values).toContain(1);\n\n    const mockNeg = createSqlMock([]);\n    await getRecentOperatorEvents({ sql: mockNeg.sql, limit: -5 });\n    expect(mockNeg.calls[0].values).toContain(1);\n  });\n\n  it(\"limit clamp: fractional limits floor to an integer before applying the bound\", async () => {\n    const mock = createSqlMock([]);\n\n    await getRecentOperatorEvents({ sql: mock.sql, limit: 7.9 });\n\n    expect(mock.calls[0].values).toContain(7);\n    expect(mock.calls[0].values).not.toContain(7.9);\n  });\n\n  it(\"empty: returns [] when the table has no rows\", async () => {\n    const mock = createSqlMock([]);\n\n    const items = await getRecentOperatorEvents({ sql: mock.sql });\n\n    expect(items).toEqual([]);\n  });\n\n  it(\"query: orders by created_at desc and projects the activity columns\", async () => {\n    const mock = createSqlMock([]);\n\n    await getRecentOperatorEvents({ sql: mock.sql });\n\n    const text = mock.calls[0].text;\n    expect(text).toMatch(/from operator_events/i);\n    expect(text).toMatch(/order by created_at desc/i);\n    expect(text).toMatch(/payload->>'actorEmail'/);\n    expect(text).toMatch(/payload->>'resourceType'/);\n    expect(text).toMatch(/payload->>'resourceId'/);\n    expect(text).toMatch(/payload->>'route'/);\n  });\n\n  it(\"load-error: a rejected query propagates so the page-level try/catch can render the alert\", async () => {\n    const mock = createSqlMock(new Error(\"connection refused\"));\n\n    await expect(\n      getRecentOperatorEvents({ sql: mock.sql }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n});\n","numLines":148,"startLine":1,"totalLines":148}}}
