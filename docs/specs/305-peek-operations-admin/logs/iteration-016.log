{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XLST9Cdn7C19CwJVt4ZqiB","type":"tool_result","content":"1\t-- 015_linked_accounts.sql — Provider-agnostic linked account ownership.\n2\t\n3\tCREATE TABLE linked_accounts (\n4\t  id                  BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n5\t  user_id             TEXT         NOT NULL,\n6\t  provider            TEXT         NOT NULL,\n7\t  provider_account_id TEXT         NOT NULL,\n8\t  status              TEXT         NOT NULL DEFAULT 'active'\n9\t                        CHECK (status IN ('active', 'revoked')),\n10\t  metadata_json       JSONB        NOT NULL DEFAULT '{}'::jsonb,\n11\t  linked_at           TIMESTAMPTZ  NOT NULL DEFAULT now(),\n12\t  created_at          TIMESTAMPTZ  NOT NULL DEFAULT now(),\n13\t  updated_at          TIMESTAMPTZ  NOT NULL DEFAULT now()\n14\t);\n15\t\n16\t-- One active link per provider account identity.\n17\tCREATE UNIQUE INDEX idx_linked_accounts_provider_account_active\n18\t  ON linked_accounts (provider, provider_account_id)\n19\t  WHERE status = 'active';\n20\t\n21\t-- One active account per user/provider pair.\n22\tCREATE UNIQUE INDEX idx_linked_accounts_user_provider_active\n23\t  ON linked_accounts (user_id, provider)\n24\t  WHERE status = 'active';\n25\t\n26\t-- Common lookup index by user/provider for active linkage checks.\n27\tCREATE INDEX idx_linked_accounts_user_provider\n28\t  ON linked_accounts (user_id, provider)\n29\t  WHERE status = 'active';\n30\t\n31\tDO $$\n32\tBEGIN\n33\t  IF EXISTS (\n34\t    SELECT 1\n35\t    FROM telegram_link_tokens\n36\t    WHERE status = 'redeemed'\n37\t      AND telegram_user_id IS NOT NULL\n38\t    GROUP BY telegram_user_id\n39\t    HAVING COUNT(*) > 1\n40\t  ) THEN\n41\t    RAISE EXCEPTION\n42\t      '015_linked_accounts backfill aborted: duplicate redeemed telegram_user_id values detected';\n43\t  END IF;\n44\tEND $$;\n45\t\n46\t-- Backfill existing Telegram links. Keep source rows for audit/rollback confidence.\n47\tINSERT INTO linked_accounts (\n48\t  user_id,\n49\t  provider,\n50\t  provider_account_id,\n51\t  status,\n52\t  metadata_json,\n53\t  linked_at\n54\t)\n55\tSELECT\n56\t  t.user_id,\n57\t  'telegram' AS provider,\n58\t  t.telegram_user_id,\n59\t  'active' AS status,\n60\t  jsonb_strip_nulls(\n61\t    jsonb_build_object(\n62\t      'telegramUsername', t.telegram_username,\n63\t      'linkedVia', 'token'\n64\t    )\n65\t  ) AS metadata_json,\n66\t  COALESCE(t.redeemed_at, t.created_at) AS linked_at\n67\tFROM telegram_link_tokens t\n68\tWHERE t.status = 'redeemed'\n69\t  AND t.telegram_user_id IS NOT NULL\n70\t;\n71\t"}]},"parent_tool_use_id":null,"session_id":"df309e27-020a-4b6e-bc8f-87e4004ebaf8","uuid":"7ab9b9be-071b-43c1-8cf5-643164f5c424","timestamp":"2026-04-25T11:31:48.908Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/migrations/015_linked_accounts.sql","content":"-- 015_linked_accounts.sql — Provider-agnostic linked account ownership.\n\nCREATE TABLE linked_accounts (\n  id                  BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  user_id             TEXT         NOT NULL,\n  provider            TEXT         NOT NULL,\n  provider_account_id TEXT         NOT NULL,\n  status              TEXT         NOT NULL DEFAULT 'active'\n                        CHECK (status IN ('active', 'revoked')),\n  metadata_json       JSONB        NOT NULL DEFAULT '{}'::jsonb,\n  linked_at           TIMESTAMPTZ  NOT NULL DEFAULT now(),\n  created_at          TIMESTAMPTZ  NOT NULL DEFAULT now(),\n  updated_at          TIMESTAMPTZ  NOT NULL DEFAULT now()\n);\n\n-- One active link per provider account identity.\nCREATE UNIQUE INDEX idx_linked_accounts_provider_account_active\n  ON linked_accounts (provider, provider_account_id)\n  WHERE status = 'active';\n\n-- One active account per user/provider pair.\nCREATE UNIQUE INDEX idx_linked_accounts_user_provider_active\n  ON linked_accounts (user_id, provider)\n  WHERE status = 'active';\n\n-- Common lookup index by user/provider for active linkage checks.\nCREATE INDEX idx_linked_accounts_user_provider\n  ON linked_accounts (user_id, provider)\n  WHERE status = 'active';\n\nDO $$\nBEGIN\n  IF EXISTS (\n    SELECT 1\n    FROM telegram_link_tokens\n    WHERE status = 'redeemed'\n      AND telegram_user_id IS NOT NULL\n    GROUP BY telegram_user_id\n    HAVING COUNT(*) > 1\n  ) THEN\n    RAISE EXCEPTION\n      '015_linked_accounts backfill aborted: duplicate redeemed telegram_user_id values detected';\n  END IF;\nEND $$;\n\n-- Backfill existing Telegram links. Keep source rows for audit/rollback confidence.\nINSERT INTO linked_accounts (\n  user_id,\n  provider,\n  provider_account_id,\n  status,\n  metadata_json,\n  linked_at\n)\nSELECT\n  t.user_id,\n  'telegram' AS provider,\n  t.telegram_user_id,\n  'active' AS status,\n  jsonb_strip_nulls(\n    jsonb_build_object(\n      'telegramUsername', t.telegram_username,\n      'linkedVia', 'token'\n    )\n  ) AS metadata_json,\n  COALESCE(t.redeemed_at, t.created_at) AS linked_at\nFROM telegram_link_tokens t\nWHERE t.status = 'redeemed'\n  AND t.telegram_user_id IS NOT NULL\n;\n","numLines":71,"startLine":1,"totalLines":71}}}
