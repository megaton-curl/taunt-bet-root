{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BagBojqA4DKvSGNwnKVhvN","type":"tool_result","content":"1\t-- 004_closecall_rounds.sql — Close Call pari-mutuel rounds (oracle-resolved, Pyth price).\n2\t\n3\tCREATE TABLE closecall_rounds (\n4\t  round_id        TEXT         PRIMARY KEY,\n5\t  pda             TEXT         UNIQUE NOT NULL,\n6\t  server_key      TEXT         NOT NULL,\n7\t  phase           TEXT         NOT NULL DEFAULT 'open' CHECK (phase IN ('open', 'settled', 'refunded')),\n8\t  open_price      BIGINT       NOT NULL,\n9\t  open_price_expo INT          NOT NULL,\n10\t  close_price     BIGINT,\n11\t  outcome         TEXT         NOT NULL DEFAULT 'pending' CHECK (outcome IN ('pending', 'green', 'red', 'refund')),\n12\t  green_pool      BIGINT       NOT NULL DEFAULT 0,\n13\t  red_pool        BIGINT       NOT NULL DEFAULT 0,\n14\t  total_fee       BIGINT       NOT NULL DEFAULT 0,\n15\t  settle_tx       TEXT,\n16\t  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n17\t  settled_at      TIMESTAMPTZ\n18\t);\n19\t\n20\tCREATE INDEX idx_closecall_rounds_phase ON closecall_rounds (phase);\n21\tCREATE INDEX idx_closecall_rounds_settled_at ON closecall_rounds (settled_at DESC);\n22\tCREATE INDEX idx_cc_rounds_settled ON closecall_rounds (settled_at DESC) WHERE phase = 'settled';\n23\t"}]},"parent_tool_use_id":null,"session_id":"df309e27-020a-4b6e-bc8f-87e4004ebaf8","uuid":"e6036496-bd60-457a-8aea-25c7b45c636f","timestamp":"2026-04-25T11:33:12.695Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/migrations/004_closecall_rounds.sql","content":"-- 004_closecall_rounds.sql — Close Call pari-mutuel rounds (oracle-resolved, Pyth price).\n\nCREATE TABLE closecall_rounds (\n  round_id        TEXT         PRIMARY KEY,\n  pda             TEXT         UNIQUE NOT NULL,\n  server_key      TEXT         NOT NULL,\n  phase           TEXT         NOT NULL DEFAULT 'open' CHECK (phase IN ('open', 'settled', 'refunded')),\n  open_price      BIGINT       NOT NULL,\n  open_price_expo INT          NOT NULL,\n  close_price     BIGINT,\n  outcome         TEXT         NOT NULL DEFAULT 'pending' CHECK (outcome IN ('pending', 'green', 'red', 'refund')),\n  green_pool      BIGINT       NOT NULL DEFAULT 0,\n  red_pool        BIGINT       NOT NULL DEFAULT 0,\n  total_fee       BIGINT       NOT NULL DEFAULT 0,\n  settle_tx       TEXT,\n  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n  settled_at      TIMESTAMPTZ\n);\n\nCREATE INDEX idx_closecall_rounds_phase ON closecall_rounds (phase);\nCREATE INDEX idx_closecall_rounds_settled_at ON closecall_rounds (settled_at DESC);\nCREATE INDEX idx_cc_rounds_settled ON closecall_rounds (settled_at DESC) WHERE phase = 'settled';\n","numLines":23,"startLine":1,"totalLines":23}}}
