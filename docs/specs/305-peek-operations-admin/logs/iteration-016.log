{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XxvDKLRbYzT5H5yyoHtLfW","type":"tool_result","content":"1\timport postgres from \"postgres\";\n2\t\n3\tlet cachedClient: ReturnType<typeof postgres> | null = null;\n4\tconst DEFAULT_CONNECT_TIMEOUT_SECONDS = 5;\n5\t\n6\texport function getDatabaseUrlFromEnv(\n7\t  env: Record<string, string | undefined> = process.env\n8\t) {\n9\t  const databaseUrl = env.DATABASE_URL;\n10\t\n11\t  if (!databaseUrl) {\n12\t    throw new Error(\"DATABASE_URL is required\");\n13\t  }\n14\t\n15\t  return databaseUrl;\n16\t}\n17\t\n18\texport function getConnectTimeoutSecondsFromEnv(\n19\t  env: Record<string, string | undefined> = process.env\n20\t) {\n21\t  const rawValue = env.PEEK_DB_CONNECT_TIMEOUT_SECONDS ?? env.PGCONNECT_TIMEOUT;\n22\t  const parsedValue = rawValue ? Number.parseInt(rawValue, 10) : Number.NaN;\n23\t\n24\t  if (Number.isFinite(parsedValue) && parsedValue > 0) {\n25\t    return parsedValue;\n26\t  }\n27\t\n28\t  return DEFAULT_CONNECT_TIMEOUT_SECONDS;\n29\t}\n30\t\n31\texport function getSqlClient() {\n32\t  if (!cachedClient) {\n33\t    cachedClient = postgres(getDatabaseUrlFromEnv(), {\n34\t      max: 5,\n35\t      prepare: true,\n36\t      connect_timeout: getConnectTimeoutSecondsFromEnv(),\n37\t    });\n38\t  }\n39\t\n40\t  return cachedClient;\n41\t}\n42\t"}]},"parent_tool_use_id":null,"session_id":"df309e27-020a-4b6e-bc8f-87e4004ebaf8","uuid":"69b1a5a6-20b4-4981-98ab-18e28959ae13","timestamp":"2026-04-25T11:32:12.118Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/client.ts","content":"import postgres from \"postgres\";\n\nlet cachedClient: ReturnType<typeof postgres> | null = null;\nconst DEFAULT_CONNECT_TIMEOUT_SECONDS = 5;\n\nexport function getDatabaseUrlFromEnv(\n  env: Record<string, string | undefined> = process.env\n) {\n  const databaseUrl = env.DATABASE_URL;\n\n  if (!databaseUrl) {\n    throw new Error(\"DATABASE_URL is required\");\n  }\n\n  return databaseUrl;\n}\n\nexport function getConnectTimeoutSecondsFromEnv(\n  env: Record<string, string | undefined> = process.env\n) {\n  const rawValue = env.PEEK_DB_CONNECT_TIMEOUT_SECONDS ?? env.PGCONNECT_TIMEOUT;\n  const parsedValue = rawValue ? Number.parseInt(rawValue, 10) : Number.NaN;\n\n  if (Number.isFinite(parsedValue) && parsedValue > 0) {\n    return parsedValue;\n  }\n\n  return DEFAULT_CONNECT_TIMEOUT_SECONDS;\n}\n\nexport function getSqlClient() {\n  if (!cachedClient) {\n    cachedClient = postgres(getDatabaseUrlFromEnv(), {\n      max: 5,\n      prepare: true,\n      connect_timeout: getConnectTimeoutSecondsFromEnv(),\n    });\n  }\n\n  return cachedClient;\n}\n","numLines":42,"startLine":1,"totalLines":42}}}
