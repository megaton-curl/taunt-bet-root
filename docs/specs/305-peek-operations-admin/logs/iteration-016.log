{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YWaTF2Ks2abmNXmSejJAzg","type":"tool_result","content":"280\t// Exports are server-rendered CSVs gated by the same page-level access as the\n281\t// source page, bounded by a server-side row cap, named with a deterministic\n282\t// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n283\t// bytes return. Export rows reuse the table view-model column ids so the export\n284\t// shape stays in lockstep with the rendered table; values are pre-formatted\n285\t// strings so CSV serialization stays straightforward and locale-stable.\n286\t\n287\texport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n288\t\n289\texport type PeekExportEntity =\n290\t  | \"users\"\n291\t  | \"referrers\"\n292\t  | \"kol\"\n293\t  | \"claims\"\n294\t  | \"rounds\"\n295\t  | \"transactions\"\n296\t  | \"queue\"\n297\t  | \"audit\";\n298\t\n299\texport type PeekExportRow = Record<string, string>;\n300\t\n301\texport type PeekExportFilenameInput = {\n302\t  entity: PeekExportEntity;\n303\t  date: string;\n304\t  filterSlug: string;\n305\t};\n306\t\n307\texport type PeekExportResult = {\n308\t  filename: string;\n309\t  rowCount: number;\n310\t  rowCap: number;\n311\t  rowCapApplied: boolean;\n312\t  columns: ReadonlyArray<PeekTableColumn>;\n313\t  rows: ReadonlyArray<PeekExportRow>;\n314\t};\n315\t"}]},"parent_tool_use_id":null,"session_id":"df309e27-020a-4b6e-bc8f-87e4004ebaf8","uuid":"2a5e0ab9-a0e6-47fb-bd55-667980315cab","timestamp":"2026-04-25T11:33:15.445Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","content":"// Exports are server-rendered CSVs gated by the same page-level access as the\n// source page, bounded by a server-side row cap, named with a deterministic\n// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n// bytes return. Export rows reuse the table view-model column ids so the export\n// shape stays in lockstep with the rendered table; values are pre-formatted\n// strings so CSV serialization stays straightforward and locale-stable.\n\nexport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n\nexport type PeekExportEntity =\n  | \"users\"\n  | \"referrers\"\n  | \"kol\"\n  | \"claims\"\n  | \"rounds\"\n  | \"transactions\"\n  | \"queue\"\n  | \"audit\";\n\nexport type PeekExportRow = Record<string, string>;\n\nexport type PeekExportFilenameInput = {\n  entity: PeekExportEntity;\n  date: string;\n  filterSlug: string;\n};\n\nexport type PeekExportResult = {\n  filename: string;\n  rowCount: number;\n  rowCap: number;\n  rowCapApplied: boolean;\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<PeekExportRow>;\n};\n","numLines":36,"startLine":280,"totalLines":315}}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01VXUix6VykUKRZdJUytYKmM","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_014L1LRQXXbwebuwJbmTn9F3","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","old_string":"export type PeekExportResult = {\n  filename: string;\n  rowCount: number;\n  rowCap: number;\n  rowCapApplied: boolean;\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<PeekExportRow>;\n};","new_string":"export type PeekExportResult = {\n  filename: string;\n  rowCount: number;\n  rowCap: number;\n  rowCapApplied: boolean;\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<PeekExportRow>;\n};\n\n// --- Universal search (FR-5) -------------------------------------------------\n//\n// One search entry point that resolves common operational identifiers to typed\n// result groups. Results are grouped by entity type so the UI can section them\n// (user, referral, linked account, round, transaction, queue event). Each\n// result includes enough context to disambiguate similar matches; sensitive\n// values (wallet, Telegram id, tx signature) live in the result's `id`/`label`\n// fields for operator readability and the audit event records only the actor\n// email, query class, and result counts (never the raw query, which the audit\n// writer redacts if it looks like a secret).\n\nexport type PeekSearchEntityType =\n  | \"user\"\n  | \"referral\"\n  | \"linked_account\"\n  | \"round\"\n  | \"transaction\"\n  | \"queue_event\";\n\nexport const PEEK_SEARCH_ENTITY_TYPES: ReadonlyArray<PeekSearchEntityType> = [\n  \"user\",\n  \"referral\",\n  \"linked_account\",\n  \"round\",\n  \"transaction\",\n  \"queue_event\",\n];\n\n// Coarse heuristic classification used only for the `peek.search` audit\n// summary so reviewers can see which class of identifier was searched without\n// inferring it from the (possibly redacted) raw query.\nexport type PeekSearchQueryClass =\n  | \"empty\"\n  | \"free_text\"\n  | \"user_id\"\n  | \"username\"\n  | \"wallet\"\n  | \"referral_code\"\n  | \"telegram_username\"\n  | \"telegram_provider_id\"\n  | \"round_pda\"\n  | \"match_id\"\n  | \"tx_signature\"\n  | \"queue_event_id\";\n\nexport type PeekSearchResult = {\n  entityType: PeekSearchEntityType;\n  id: string;\n  label: string;\n  sublabel: string | null;\n  context: string | null;\n  href: string;\n};\n\nexport type PeekSearchGroup = {\n  entityType: PeekSearchEntityType;\n  results: ReadonlyArray<PeekSearchResult>;\n  truncated: boolean;\n};\n\nexport type PeekSearchResponse = {\n  query: string;\n  queryClass: PeekSearchQueryClass;\n  groups: ReadonlyArray<PeekSearchGroup>;\n  totalResults: number;\n  perGroupLimit: number;\n  generatedAt: string;\n};\n\nexport const PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT = 5;\nexport const PEEK_SEARCH_MAX_PER_GROUP_LIMIT = 25;"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":668,"cache_read_input_tokens":114463,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":668},"output_tokens":65,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"df309e27-020a-4b6e-bc8f-87e4004ebaf8","uuid":"d607cbe7-a395-4d65-89d7-354a97ff1a73"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014L1LRQXXbwebuwJbmTn9F3","type":"tool_result","content":"The file /workspaces/rng-utopia/peek/src/lib/types/peek.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"df309e27-020a-4b6e-bc8f-87e4004ebaf8","uuid":"ab9e2fad-14b5-4c79-be89-1b4564bbb3a5","timestamp":"2026-04-25T11:33:28.733Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","oldString":"export type PeekExportResult = {\n  filename: string;\n  rowCount: number;\n  rowCap: number;\n  rowCapApplied: boolean;\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<PeekExportRow>;\n};","newString":"export type PeekExportResult = {\n  filename: string;\n  rowCount: number;\n  rowCap: number;\n  rowCapApplied: boolean;\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<PeekExportRow>;\n};\n\n// --- Universal search (FR-5) -------------------------------------------------\n//\n// One search entry point that resolves common operational identifiers to typed\n// result groups. Results are grouped by entity type so the UI can section them\n// (user, referral, linked account, round, transaction, queue event). Each\n// result includes enough context to disambiguate similar matches; sensitive\n// values (wallet, Telegram id, tx signature) live in the result's `id`/`label`\n// fields for operator readability and the audit event records only the actor\n// email, query class, and result counts (never the raw query, which the audit\n// writer redacts if it looks like a secret).\n\nexport type PeekSearchEntityType =\n  | \"user\"\n  | \"referral\"\n  | \"linked_account\"\n  | \"round\"\n  | \"transaction\"\n  | \"queue_event\";\n\nexport const PEEK_SEARCH_ENTITY_TYPES: ReadonlyArray<PeekSearchEntityType> = [\n  \"user\",\n  \"referral\",\n  \"linked_account\",\n  \"round\",\n  \"transaction\",\n  \"queue_event\",\n];\n\n// Coarse heuristic classification used only for the `peek.search` audit\n// summary so reviewers can see which class of identifier was searched without\n// inferring it from the (possibly redacted) raw query.\nexport type PeekSearchQueryClass =\n  | \"empty\"\n  | \"free_text\"\n  | \"user_id\"\n  | \"username\"\n  | \"wallet\"\n  | \"referral_code\"\n  | \"telegram_username\"\n  | \"telegram_provider_id\"\n  | \"round_pda\"\n  | \"match_id\"\n  | \"tx_signature\"\n  | \"queue_event_id\";\n\nexport type PeekSearchResult = {\n  entityType: PeekSearchEntityType;\n  id: string;\n  label: string;\n  sublabel: string | null;\n  context: string | null;\n  href: string;\n};\n\nexport type PeekSearchGroup = {\n  entityType: PeekSearchEntityType;\n  results: ReadonlyArray<PeekSearchResult>;\n  truncated: boolean;\n};\n\nexport type PeekSearchResponse = {\n  query: string;\n  queryClass: PeekSearchQueryClass;\n  groups: ReadonlyArray<PeekSearchGroup>;\n  totalResults: number;\n  perGroupLimit: number;\n  generatedAt: string;\n};\n\nexport const PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT = 5;\nexport const PEEK_SEARCH_MAX_PER_GROUP_LIMIT = 25;","originalFile":"// Browser-safe view-model primitives for `peek`.\n//\n// Foundational shapes used across feature pages: metric metadata (FR-4),\n// URL-addressable table filters, pagination, sort, and a small table-row base\n// type that per-feature row types can extend. Per-feature shapes (PeekUserRow,\n// PeekUserDetail, future referral/game/queue/etc. rows) live alongside or\n// extend these primitives.\n\nimport type { PeekRole } from \"../access-policy\";\n\n// --- Existing 303-era shapes (kept stable for current callers) ---------------\n\nexport type PeekSummary = {\n  totalUsers: number;\n  totalUsersWithCodes: number;\n  totalReferredUsers: number;\n  totalUniqueReferrers: number;\n};\n\nexport type PeekUserRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  joinedAt: string;\n  referralCode: string | null;\n  referrerUserId: string | null;\n  referrerCode: string | null;\n  refereeCount: number;\n  telegramUsername: string | null;\n  telegramUserId: string | null;\n};\n\nexport type PeekUserDetail = {\n  user: PeekUserRow;\n  inboundReferral: {\n    referrerUserId: string | null;\n    referrerCode: string | null;\n    linkedAt: string | null;\n  };\n  outboundReferees: Array<{\n    refereeUserId: string;\n    refereeUsername: string | null;\n    createdAt: string;\n  }>;\n  telegram: {\n    state: \"active\" | \"none\";\n    telegramUserId: string | null;\n    telegramUsername: string | null;\n  };\n};\n\n// --- Actor view model (browser-safe) -----------------------------------------\n\nexport type PeekActorView = {\n  email: string;\n  role: PeekRole;\n};\n\n// --- Metric metadata (FR-4) --------------------------------------------------\n//\n// Each metric carries the bookkeeping required by the data-surfacing standard:\n// stable id, label, value, source table/query, time window, \"as of\" timestamp,\n// short definition, optional unit, and optional drill-down link to the filtered\n// detail rows behind the number.\n\nexport type PeekMetricFreshness = \"live\" | \"cached\" | \"manual\" | \"sampled\";\n\nexport type PeekMetric = {\n  id: string;\n  label: string;\n  value: number | string | null;\n  valueDisplay: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  asOf: string | null;\n  definition: string;\n  freshness: PeekMetricFreshness;\n  drilldownHref: string | null;\n};\n\n// --- Pagination primitive ----------------------------------------------------\n\nexport type PeekPagination = {\n  page: number;\n  pageSize: number;\n  totalCount: number;\n  totalPages: number;\n};\n\n// --- Sort primitive ----------------------------------------------------------\n\nexport type PeekSortDirection = \"asc\" | \"desc\";\n\nexport type PeekTableSort = {\n  column: string;\n  direction: PeekSortDirection;\n};\n\n// --- Table filter primitive (URL-addressable) --------------------------------\n\nexport type PeekFilterKind =\n  | \"text\"\n  | \"select\"\n  | \"boolean\"\n  | \"date\"\n  | \"dateRange\";\n\nexport type PeekFilterOption = {\n  value: string;\n  label: string;\n};\n\nexport type PeekTableFilter = {\n  id: string;\n  label: string;\n  kind: PeekFilterKind;\n  value: string | null;\n  options: ReadonlyArray<PeekFilterOption> | null;\n  placeholder: string | null;\n  required: boolean;\n};\n\n// --- Status chip tone (shared) -----------------------------------------------\n\nexport type PeekStatusTone =\n  | \"neutral\"\n  | \"positive\"\n  | \"warning\"\n  | \"negative\"\n  | \"info\";\n\n// --- Empty-state primitive ---------------------------------------------------\n\nexport type PeekEmptyState = {\n  title: string;\n  body: string | null;\n};\n\n// --- Table row + column primitives -------------------------------------------\n//\n// Per-feature row types extend `PeekTableRowBase` for the shared identifier +\n// optional drill-down link, then add feature-specific fields. The shared dense\n// table component reads `columns` for layout and per-row data via the typed\n// row shape supplied by the feature page.\n\nexport type PeekTableColumnAlign = \"left\" | \"right\" | \"center\";\n\nexport type PeekTableColumn = {\n  id: string;\n  label: string;\n  align: PeekTableColumnAlign;\n  sortable: boolean;\n};\n\nexport type PeekTableRowBase = {\n  id: string;\n  href: string | null;\n};\n\nexport type PeekTableViewModel<TRow extends PeekTableRowBase> = {\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<TRow>;\n  pagination: PeekPagination;\n  filters: ReadonlyArray<PeekTableFilter>;\n  sort: PeekTableSort | null;\n  empty: PeekEmptyState;\n};\n\n// --- Command-center attention queue (FR-3, FR-10) ----------------------------\n//\n// The command-center page surfaces a small set of \"needs attention\" metrics so\n// operators see exception states (failed claims, dead queue events, stuck\n// settlements, pending SOL crate payouts, stale active Dogpile events,\n// high-value export activity) before they dig into per-feature pages. Each\n// item is a `PeekMetric` so the metric-strip primitive renders it with the\n// FR-4 bookkeeping (definition, source, time window, \"as of\", drill-down).\n\nexport type PeekCommandCenterAttentionId =\n  | \"failed_claims\"\n  | \"dead_queue_events\"\n  | \"stuck_rounds_flipyou_potshot\"\n  | \"stuck_rounds_closecall\"\n  | \"pending_sol_crate_payouts\"\n  | \"stale_active_dogpile_events\"\n  | \"high_value_exports_24h\";\n\nexport type PeekCommandCenterAttention = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};\n\n// --- Recent operator activity (FR-3 command-center \"high-signal activity\") ---\n//\n// Compact projection of the latest `operator_events` rows for the command-center\n// \"Recent activity\" section. Pulled from the same JSONB payload the audit\n// writer persists, but kept narrow on purpose — the command center surfaces\n// only the few fields needed to recognize what happened, not the full payload.\n// The audit view (`/audit`, later iteration) renders the full bounded table.\n\nexport type PeekRecentActivityItem = {\n  id: string;\n  eventType: string;\n  actorEmail: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  route: string | null;\n  createdAt: string;\n};\n\n// --- Audit event contracts (FR-11) -------------------------------------------\n//\n// Browser-safe view of `operator_events` rows the audit writer produces under\n// `peek.*` event types. The `PeekAuditPayload` shape pins the fields required by\n// FR-11 so the writer (`peek/src/server/audit/**`, next iteration) and the audit\n// view (`/audit`, later iteration) agree on a serialization contract. Secrets\n// (JWTs, access tokens, DB URLs, private keys, raw secrets) must be replaced by\n// `PEEK_AUDIT_REDACTED` before persisting; the audit-view component renders the\n// token verbatim so reviewers can see that a field was redacted (not silently\n// absent).\n\nexport type PeekAuditEventType =\n  | \"peek.search\"\n  | \"peek.user.view_sensitive\"\n  | \"peek.export\"\n  | \"peek.access.denied\"\n  | \"peek.change.applied\"\n  | \"peek.change.rejected\";\n\nexport const PEEK_AUDIT_EVENT_TYPES: ReadonlyArray<PeekAuditEventType> = [\n  \"peek.search\",\n  \"peek.user.view_sensitive\",\n  \"peek.export\",\n  \"peek.access.denied\",\n  \"peek.change.applied\",\n  \"peek.change.rejected\",\n];\n\nexport function isPeekAuditEventType(\n  value: unknown,\n): value is PeekAuditEventType {\n  return (\n    typeof value === \"string\" &&\n    (PEEK_AUDIT_EVENT_TYPES as ReadonlyArray<string>).includes(value)\n  );\n}\n\nexport const PEEK_AUDIT_REDACTED = \"[REDACTED]\";\n\nexport type PeekAuditScalar = string | number | boolean | null;\n\nexport type PeekAuditChange = {\n  field: string;\n  before: PeekAuditScalar;\n  after: PeekAuditScalar;\n};\n\nexport type PeekAuditPayload = {\n  actorEmail: string;\n  route: string | null;\n  actionId: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  filterSummary: string | null;\n  resultCount: number | null;\n  requestId: string | null;\n  rejectionReason: string | null;\n  changes: ReadonlyArray<PeekAuditChange> | null;\n};\n\nexport type PeekAuditEvent = {\n  id: string;\n  eventType: PeekAuditEventType;\n  createdAt: string;\n  payload: PeekAuditPayload;\n};\n\n// --- Export contracts (FR-12) ------------------------------------------------\n//\n// Exports are server-rendered CSVs gated by the same page-level access as the\n// source page, bounded by a server-side row cap, named with a deterministic\n// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n// bytes return. Export rows reuse the table view-model column ids so the export\n// shape stays in lockstep with the rendered table; values are pre-formatted\n// strings so CSV serialization stays straightforward and locale-stable.\n\nexport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n\nexport type PeekExportEntity =\n  | \"users\"\n  | \"referrers\"\n  | \"kol\"\n  | \"claims\"\n  | \"rounds\"\n  | \"transactions\"\n  | \"queue\"\n  | \"audit\";\n\nexport type PeekExportRow = Record<string, string>;\n\nexport type PeekExportFilenameInput = {\n  entity: PeekExportEntity;\n  date: string;\n  filterSlug: string;\n};\n\nexport type PeekExportResult = {\n  filename: string;\n  rowCount: number;\n  rowCap: number;\n  rowCapApplied: boolean;\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<PeekExportRow>;\n};\n","structuredPatch":[{"oldStart":312,"oldLines":3,"newStart":312,"newLines":75,"lines":["   columns: ReadonlyArray<PeekTableColumn>;","   rows: ReadonlyArray<PeekExportRow>;"," };","+","+// --- Universal search (FR-5) -------------------------------------------------","+//","+// One search entry point that resolves common operational identifiers to typed","+// result groups. Results are grouped by entity type so the UI can section them","+// (user, referral, linked account, round, transaction, queue event). Each","+// result includes enough context to disambiguate similar matches; sensitive","+// values (wallet, Telegram id, tx signature) live in the result's `id`/`label`","+// fields for operator readability and the audit event records only the actor","+// email, query class, and result counts (never the raw query, which the audit","+// writer redacts if it looks like a secret).","+","+export type PeekSearchEntityType =","+  | \"user\"","+  | \"referral\"","+  | \"linked_account\"","+  | \"round\"","+  | \"transaction\"","+  | \"queue_event\";","+","+export const PEEK_SEARCH_ENTITY_TYPES: ReadonlyArray<PeekSearchEntityType> = [","+  \"user\",","+  \"referral\",","+  \"linked_account\",","+  \"round\",","+  \"transaction\",","+  \"queue_event\",","+];","+","+// Coarse heuristic classification used only for the `peek.search` audit","+// summary so reviewers can see which class of identifier was searched without","+// inferring it from the (possibly redacted) raw query.","+export type PeekSearchQueryClass =","+  | \"empty\"","+  | \"free_text\"","+  | \"user_id\"","+  | \"username\"","+  | \"wallet\"","+  | \"referral_code\"","+  | \"telegram_username\"","+  | \"telegram_provider_id\"","+  | \"round_pda\"","+  | \"match_id\"","+  | \"tx_signature\"","+  | \"queue_event_id\";","+","+export type PeekSearchResult = {","+  entityType: PeekSearchEntityType;","+  id: string;","+  label: string;","+  sublabel: string | null;","+  context: string | null;","+  href: string;","+};","+","+export type PeekSearchGroup = {","+  entityType: PeekSearchEntityType;","+  results: ReadonlyArray<PeekSearchResult>;","+  truncated: boolean;","+};","+","+export type PeekSearchResponse = {","+  query: string;","+  queryClass: PeekSearchQueryClass;","+  groups: ReadonlyArray<PeekSearchGroup>;","+  totalResults: number;","+  perGroupLimit: number;","+  generatedAt: string;","+};","+","+export const PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT = 5;","+export const PEEK_SEARCH_MAX_PER_GROUP_LIMIT = 25;"]}],"userModified":false,"replaceAll":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01HFPRRauBCXmVPokECDXPXH","type":"message","role":"assistant","content":[{"type":"text","text":"Now create the universal search query module:"}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1251,"cache_read_input_tokens":115131,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1251},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"df309e27-020a-4b6e-bc8f-87e4004ebaf8","uuid":"853d0578-ce1b-4f45-a87b-f516ec6e577a"}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01HFPRRauBCXmVPokECDXPXH","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01ANsAPQYsqBWG4xrRBZefXP","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/db/queries/universal-search.ts","content":"// Universal search query (FR-5).\n//\n// Resolves a single operator-typed query against the operational identifiers\n// admins care about: user_id, username, wallet, referral code, Telegram\n// username, Telegram provider id, round PDA, match id, tx signature, and\n// queue event id. Results are grouped by entity type (user, referral,\n// linked_account, round, transaction, queue_event); each per-group query is\n// bounded server-side. The function emits a `peek.search` audit event by\n// default; tests can inject a no-op or capturing audit handler.\n//\n// Audit payload contract (FR-5 + FR-11):\n// - actorEmail: provided by the caller from the verified Cloudflare Access\n//   email (never trusted from a browser header).\n// - actionId: stable string `peek.search` so audit views can filter.\n// - resourceType: `search` (no resource id — the search is the resource).\n// - filterSummary: a coarse `query_class=<class>` summary; the writer's\n//   redaction layer scrubs any value that looks like a JWT, DB URL, private\n//   key, Bearer header, or cf-access-jwt-assertion line.\n// - resultCount: total results across all groups.\n// - changes: null (search is read-only).\n\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT,\n  PEEK_SEARCH_MAX_PER_GROUP_LIMIT,\n  type PeekSearchEntityType,\n  type PeekSearchGroup,\n  type PeekSearchQueryClass,\n  type PeekSearchResponse,\n  type PeekSearchResult,\n} from \"../../../lib/types/peek\";\nimport { writePeekAuditEvent } from \"../../audit/writer\";\nimport { getSqlClient } from \"../client\";\n\nconst BASE58_PATTERN = /^[1-9A-HJ-NP-Za-km-z]+$/;\nconst HEX_PATTERN = /^[0-9a-fA-F]+$/;\nconst UUID_PATTERN =\n  /^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$/;\nconst USERNAME_PATTERN = /^[A-Za-z0-9_]{3,32}$/;\nconst REFERRAL_CODE_PATTERN = /^[A-Z0-9]{4,12}$/;\n\nexport type PeekSearchAuditFn = (input: {\n  actorEmail: string;\n  query: string;\n  queryClass: PeekSearchQueryClass;\n  totalResults: number;\n  route: string | null;\n  requestId: string | null;\n}) => Promise<void>;\n\nexport type UniversalSearchOptions = {\n  query: string;\n  actorEmail: string;\n  sql?: Sql;\n  perGroupLimit?: number;\n  now?: Date;\n  route?: string | null;\n  requestId?: string | null;\n  audit?: PeekSearchAuditFn | null;\n};\n\n// Heuristic classification used only for audit-event summaries. The function\n// always tries every plausible lookup against the database — the class only\n// labels the search so reviewers can read intent without depending on the\n// (possibly redacted) raw query.\nexport function classifyPeekSearchQuery(raw: string): PeekSearchQueryClass {\n  const trimmed = raw.trim();\n  if (trimmed.length === 0) return \"empty\";\n\n  const cleaned = trimmed.startsWith(\"@\") ? trimmed.slice(1) : trimmed;\n\n  if (UUID_PATTERN.test(cleaned)) return \"free_text\";\n  if (/^\\d+$/.test(cleaned)) {\n    return cleaned.length <= 18 ? \"queue_event_id\" : \"telegram_provider_id\";\n  }\n  if (cleaned.length === 16 && HEX_PATTERN.test(cleaned)) return \"match_id\";\n\n  if (BASE58_PATTERN.test(cleaned)) {\n    if (cleaned.length >= 80) return \"tx_signature\";\n    if (cleaned.length >= 32 && cleaned.length <= 44) return \"round_pda\";\n  }\n\n  if (trimmed.startsWith(\"@\")) return \"telegram_username\";\n\n  if (REFERRAL_CODE_PATTERN.test(cleaned)) return \"referral_code\";\n\n  if (USERNAME_PATTERN.test(cleaned)) return \"username\";\n\n  return \"free_text\";\n}\n\nfunction clampLimit(requested: number | undefined): number {\n  const fallback = requested ?? PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT;\n  if (!Number.isFinite(fallback)) return PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT;\n  const floored = Math.floor(fallback);\n  return Math.max(\n    1,\n    Math.min(PEEK_SEARCH_MAX_PER_GROUP_LIMIT, floored),\n  );\n}\n\nfunction emptyGroups(): ReadonlyArray<PeekSearchGroup> {\n  const entityTypes: ReadonlyArray<PeekSearchEntityType> = [\n    \"user\",\n    \"referral\",\n    \"linked_account\",\n    \"round\",\n    \"transaction\",\n    \"queue_event\",\n  ];\n  return entityTypes.map((entityType) => ({\n    entityType,\n    results: [],\n    truncated: false,\n  }));\n}\n\ntype UserRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  joinedAt: string;\n};\n\ntype ReferralCodeRow = {\n  code: string;\n  userId: string;\n  wallet: string;\n};\n\ntype LinkedAccountRow = {\n  userId: string;\n  provider: string;\n  providerAccountId: string;\n  telegramUsername: string | null;\n  status: string;\n};\n\ntype RoundRow = {\n  pda: string;\n  game: string;\n  matchId: string;\n  phase: string;\n  creator: string | null;\n};\n\ntype TransactionRow = {\n  id: string;\n  txSig: string;\n  game: string;\n  matchId: string;\n  txType: string;\n  wallet: string;\n  amountLamports: string;\n  createdAt: string;\n};\n\ntype QueueEventRow = {\n  id: string;\n  eventType: string;\n  status: string;\n  attempts: number;\n  scheduledAt: string;\n};\n\nasync function searchUsers(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const exact = query;\n  const like = `%${query}%`;\n  const rows = await sql<UserRow[]>`\n    select\n      user_id as \"userId\",\n      username,\n      wallet,\n      created_at::text as \"joinedAt\"\n    from player_profiles\n    where user_id = ${exact}\n       or wallet = ${exact}\n       or lower(username) = lower(${exact})\n       or user_id ilike ${like}\n       or wallet ilike ${like}\n       or coalesce(username, '') ilike ${like}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => ({\n    entityType: \"user\" as const,\n    id: row.userId,\n    label: row.username ?? row.userId,\n    sublabel: row.wallet,\n    context: `joined ${row.joinedAt}`,\n    href: `/users/${encodeURIComponent(row.userId)}`,\n  }));\n}\n\nasync function searchReferralCodes(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const exact = query;\n  const like = `%${query}%`;\n  const rows = await sql<ReferralCodeRow[]>`\n    select\n      code,\n      user_id as \"userId\",\n      wallet\n    from referral_codes\n    where upper(code) = upper(${exact})\n       or code ilike ${like}\n       or user_id = ${exact}\n       or wallet = ${exact}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => ({\n    entityType: \"referral\" as const,\n    id: row.code,\n    label: row.code,\n    sublabel: row.userId,\n    context: `wallet ${row.wallet}`,\n    href: `/users/${encodeURIComponent(row.userId)}`,\n  }));\n}\n\nasync function searchLinkedAccounts(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const trimmed = query.startsWith(\"@\") ? query.slice(1) : query;\n  const exact = trimmed;\n  const like = `%${trimmed}%`;\n  const rows = await sql<LinkedAccountRow[]>`\n    select\n      user_id as \"userId\",\n      provider,\n      provider_account_id as \"providerAccountId\",\n      nullif(metadata_json->>'telegramUsername', '') as \"telegramUsername\",\n      status\n    from linked_accounts\n    where status = 'active'\n      and (\n        provider_account_id = ${exact}\n        or metadata_json->>'telegramUsername' = ${exact}\n        or provider_account_id ilike ${like}\n        or coalesce(metadata_json->>'telegramUsername', '') ilike ${like}\n      )\n    order by linked_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => {\n    const display = row.telegramUsername\n      ? `@${row.telegramUsername}`\n      : row.providerAccountId;\n    return {\n      entityType: \"linked_account\" as const,\n      id: `${row.provider}:${row.providerAccountId}`,\n      label: display,\n      sublabel: row.userId,\n      context: `${row.provider} (${row.status})`,\n      href: `/users/${encodeURIComponent(row.userId)}`,\n    };\n  });\n}\n\nasync function searchRounds(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const exact = query;\n  const flipPotRows = await sql<RoundRow[]>`\n    select\n      pda,\n      game,\n      match_id as \"matchId\",\n      phase,\n      creator\n    from rounds\n    where pda = ${exact}\n       or match_id = ${exact}\n       or creator = ${exact}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  const closeCallRows = await sql<RoundRow[]>`\n    select\n      pda,\n      'closecall'::text as \"game\",\n      round_id as \"matchId\",\n      phase,\n      null::text as \"creator\"\n    from closecall_rounds\n    where pda = ${exact}\n       or round_id = ${exact}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  const combined = [...flipPotRows, ...closeCallRows];\n  return combined.slice(0, limit).map((row) => ({\n    entityType: \"round\" as const,\n    id: row.pda,\n    label: row.matchId,\n    sublabel: `${row.game} • ${row.phase}`,\n    context: row.creator ? `creator ${row.creator}` : null,\n    href: `/games/${encodeURIComponent(row.game)}/rounds/${encodeURIComponent(row.pda)}`,\n  }));\n}\n\nasync function searchTransactions(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const exact = query;\n  const rows = await sql<TransactionRow[]>`\n    select\n      id::text as \"id\",\n      tx_sig as \"txSig\",\n      game,\n      match_id as \"matchId\",\n      tx_type as \"txType\",\n      wallet,\n      amount_lamports::text as \"amountLamports\",\n      created_at::text as \"createdAt\"\n    from transactions\n    where tx_sig = ${exact}\n       or match_id = ${exact}\n       or wallet = ${exact}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => ({\n    entityType: \"transaction\" as const,\n    id: row.id,\n    label: row.txSig,\n    sublabel: `${row.game} • ${row.txType}`,\n    context: `wallet ${row.wallet} • ${row.amountLamports} lamports`,\n    href: `/games/${encodeURIComponent(row.game)}/rounds/${encodeURIComponent(row.matchId)}`,\n  }));\n}\n\nasync function searchQueueEvents(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  if (!/^\\d+$/.test(query)) return [];\n  const numericId = query;\n  const rows = await sql<QueueEventRow[]>`\n    select\n      id::text as \"id\",\n      event_type as \"eventType\",\n      status,\n      attempts,\n      scheduled_at::text as \"scheduledAt\"\n    from event_queue\n    where id::text = ${numericId}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => ({\n    entityType: \"queue_event\" as const,\n    id: row.id,\n    label: `#${row.id}`,\n    sublabel: `${row.eventType} • ${row.status}`,\n    context: `attempts ${row.attempts} • scheduled ${row.scheduledAt}`,\n    href: `/operations/queue?id=${encodeURIComponent(row.id)}`,\n  }));\n}\n\nasync function defaultPeekSearchAudit(input: {\n  actorEmail: string;\n  query: string;\n  queryClass: PeekSearchQueryClass;\n  totalResults: number;\n  route: string | null;\n  requestId: string | null;\n}): Promise<void> {\n  await writePeekAuditEvent({\n    eventType: \"peek.search\",\n    payload: {\n      actorEmail: input.actorEmail,\n      route: input.route,\n      actionId: \"peek.search\",\n      resourceType: \"search\",\n      resourceId: null,\n      filterSummary: `query_class=${input.queryClass}`,\n      resultCount: input.totalResults,\n      requestId: input.requestId,\n      rejectionReason: null,\n      changes: null,\n    },\n  });\n}\n\nexport async function getUniversalSearchResults(\n  options: UniversalSearchOptions,\n): Promise<PeekSearchResponse> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const perGroupLimit = clampLimit(options.perGroupLimit);\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n  const trimmed = options.query.trim();\n  const queryClass = classifyPeekSearchQuery(trimmed);\n\n  if (trimmed.length === 0) {\n    const response: PeekSearchResponse = {\n      query: trimmed,\n      queryClass,\n      groups: emptyGroups(),\n      totalResults: 0,\n      perGroupLimit,\n      generatedAt,\n    };\n    return response;\n  }\n\n  // Run every entity-class query in parallel; per-group LIMIT keeps each query\n  // bounded. Group-level `truncated` is set when the inner query came back\n  // with one more row than `limit`.\n  const [users, referrals, linkedAccounts, rounds, transactions, queueEvents] =\n    await Promise.all([\n      searchUsers(sql, trimmed, perGroupLimit),\n      searchReferralCodes(sql, trimmed, perGroupLimit),\n      searchLinkedAccounts(sql, trimmed, perGroupLimit),\n      searchRounds(sql, trimmed, perGroupLimit),\n      searchTransactions(sql, trimmed, perGroupLimit),\n      searchQueueEvents(sql, trimmed, perGroupLimit),\n    ]);\n\n  const groups: ReadonlyArray<PeekSearchGroup> = [\n    { entityType: \"user\", results: users, truncated: users.length === perGroupLimit },\n    {\n      entityType: \"referral\",\n      results: referrals,\n      truncated: referrals.length === perGroupLimit,\n    },\n    {\n      entityType: \"linked_account\",\n      results: linkedAccounts,\n      truncated: linkedAccounts.length === perGroupLimit,\n    },\n    {\n      entityType: \"round\",\n      results: rounds,\n      truncated: rounds.length === perGroupLimit,\n    },\n    {\n      entityType: \"transaction\",\n      results: transactions,\n      truncated: transactions.length === perGroupLimit,\n    },\n    {\n      entityType: \"queue_event\",\n      results: queueEvents,\n      truncated: queueEvents.length === perGroupLimit,\n    },\n  ];\n\n  const totalResults = groups.reduce(\n    (acc, group) => acc + group.results.length,\n    0,\n  );\n\n  const audit = options.audit === undefined ? defaultPeekSearchAudit : options.audit;\n  if (audit) {\n    try {\n      await audit({\n        actorEmail: options.actorEmail,\n        query: trimmed,\n        queryClass,\n        totalResults,\n        route: options.route ?? null,\n        requestId: options.requestId ?? null,\n      });\n    } catch {\n      // Audit failures must never leak to the caller (FR-11). The writer\n      // already logs server-side; swallow here so the search response still\n      // renders.\n    }\n  }\n\n  return {\n    query: trimmed,\n    queryClass,\n    groups,\n    totalResults,\n    perGroupLimit,\n    generatedAt,\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1251,"cache_read_input_tokens":115131,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1251},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"df309e27-020a-4b6e-bc8f-87e4004ebaf8","uuid":"16d5f24b-81f4-4d29-b1fa-5514a47ed021"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ANsAPQYsqBWG4xrRBZefXP","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/server/db/queries/universal-search.ts"}]},"parent_tool_use_id":null,"session_id":"df309e27-020a-4b6e-bc8f-87e4004ebaf8","uuid":"e2032973-14b4-4c14-82ea-a32dbda926fa","timestamp":"2026-04-25T11:34:24.555Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/universal-search.ts","content":"// Universal search query (FR-5).\n//\n// Resolves a single operator-typed query against the operational identifiers\n// admins care about: user_id, username, wallet, referral code, Telegram\n// username, Telegram provider id, round PDA, match id, tx signature, and\n// queue event id. Results are grouped by entity type (user, referral,\n// linked_account, round, transaction, queue_event); each per-group query is\n// bounded server-side. The function emits a `peek.search` audit event by\n// default; tests can inject a no-op or capturing audit handler.\n//\n// Audit payload contract (FR-5 + FR-11):\n// - actorEmail: provided by the caller from the verified Cloudflare Access\n//   email (never trusted from a browser header).\n// - actionId: stable string `peek.search` so audit views can filter.\n// - resourceType: `search` (no resource id — the search is the resource).\n// - filterSummary: a coarse `query_class=<class>` summary; the writer's\n//   redaction layer scrubs any value that looks like a JWT, DB URL, private\n//   key, Bearer header, or cf-access-jwt-assertion line.\n// - resultCount: total results across all groups.\n// - changes: null (search is read-only).\n\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT,\n  PEEK_SEARCH_MAX_PER_GROUP_LIMIT,\n  type PeekSearchEntityType,\n  type PeekSearchGroup,\n  type PeekSearchQueryClass,\n  type PeekSearchResponse,\n  type PeekSearchResult,\n} from \"../../../lib/types/peek\";\nimport { writePeekAuditEvent } from \"../../audit/writer\";\nimport { getSqlClient } from \"../client\";\n\nconst BASE58_PATTERN = /^[1-9A-HJ-NP-Za-km-z]+$/;\nconst HEX_PATTERN = /^[0-9a-fA-F]+$/;\nconst UUID_PATTERN =\n  /^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$/;\nconst USERNAME_PATTERN = /^[A-Za-z0-9_]{3,32}$/;\nconst REFERRAL_CODE_PATTERN = /^[A-Z0-9]{4,12}$/;\n\nexport type PeekSearchAuditFn = (input: {\n  actorEmail: string;\n  query: string;\n  queryClass: PeekSearchQueryClass;\n  totalResults: number;\n  route: string | null;\n  requestId: string | null;\n}) => Promise<void>;\n\nexport type UniversalSearchOptions = {\n  query: string;\n  actorEmail: string;\n  sql?: Sql;\n  perGroupLimit?: number;\n  now?: Date;\n  route?: string | null;\n  requestId?: string | null;\n  audit?: PeekSearchAuditFn | null;\n};\n\n// Heuristic classification used only for audit-event summaries. The function\n// always tries every plausible lookup against the database — the class only\n// labels the search so reviewers can read intent without depending on the\n// (possibly redacted) raw query.\nexport function classifyPeekSearchQuery(raw: string): PeekSearchQueryClass {\n  const trimmed = raw.trim();\n  if (trimmed.length === 0) return \"empty\";\n\n  const cleaned = trimmed.startsWith(\"@\") ? trimmed.slice(1) : trimmed;\n\n  if (UUID_PATTERN.test(cleaned)) return \"free_text\";\n  if (/^\\d+$/.test(cleaned)) {\n    return cleaned.length <= 18 ? \"queue_event_id\" : \"telegram_provider_id\";\n  }\n  if (cleaned.length === 16 && HEX_PATTERN.test(cleaned)) return \"match_id\";\n\n  if (BASE58_PATTERN.test(cleaned)) {\n    if (cleaned.length >= 80) return \"tx_signature\";\n    if (cleaned.length >= 32 && cleaned.length <= 44) return \"round_pda\";\n  }\n\n  if (trimmed.startsWith(\"@\")) return \"telegram_username\";\n\n  if (REFERRAL_CODE_PATTERN.test(cleaned)) return \"referral_code\";\n\n  if (USERNAME_PATTERN.test(cleaned)) return \"username\";\n\n  return \"free_text\";\n}\n\nfunction clampLimit(requested: number | undefined): number {\n  const fallback = requested ?? PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT;\n  if (!Number.isFinite(fallback)) return PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT;\n  const floored = Math.floor(fallback);\n  return Math.max(\n    1,\n    Math.min(PEEK_SEARCH_MAX_PER_GROUP_LIMIT, floored),\n  );\n}\n\nfunction emptyGroups(): ReadonlyArray<PeekSearchGroup> {\n  const entityTypes: ReadonlyArray<PeekSearchEntityType> = [\n    \"user\",\n    \"referral\",\n    \"linked_account\",\n    \"round\",\n    \"transaction\",\n    \"queue_event\",\n  ];\n  return entityTypes.map((entityType) => ({\n    entityType,\n    results: [],\n    truncated: false,\n  }));\n}\n\ntype UserRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  joinedAt: string;\n};\n\ntype ReferralCodeRow = {\n  code: string;\n  userId: string;\n  wallet: string;\n};\n\ntype LinkedAccountRow = {\n  userId: string;\n  provider: string;\n  providerAccountId: string;\n  telegramUsername: string | null;\n  status: string;\n};\n\ntype RoundRow = {\n  pda: string;\n  game: string;\n  matchId: string;\n  phase: string;\n  creator: string | null;\n};\n\ntype TransactionRow = {\n  id: string;\n  txSig: string;\n  game: string;\n  matchId: string;\n  txType: string;\n  wallet: string;\n  amountLamports: string;\n  createdAt: string;\n};\n\ntype QueueEventRow = {\n  id: string;\n  eventType: string;\n  status: string;\n  attempts: number;\n  scheduledAt: string;\n};\n\nasync function searchUsers(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const exact = query;\n  const like = `%${query}%`;\n  const rows = await sql<UserRow[]>`\n    select\n      user_id as \"userId\",\n      username,\n      wallet,\n      created_at::text as \"joinedAt\"\n    from player_profiles\n    where user_id = ${exact}\n       or wallet = ${exact}\n       or lower(username) = lower(${exact})\n       or user_id ilike ${like}\n       or wallet ilike ${like}\n       or coalesce(username, '') ilike ${like}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => ({\n    entityType: \"user\" as const,\n    id: row.userId,\n    label: row.username ?? row.userId,\n    sublabel: row.wallet,\n    context: `joined ${row.joinedAt}`,\n    href: `/users/${encodeURIComponent(row.userId)}`,\n  }));\n}\n\nasync function searchReferralCodes(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const exact = query;\n  const like = `%${query}%`;\n  const rows = await sql<ReferralCodeRow[]>`\n    select\n      code,\n      user_id as \"userId\",\n      wallet\n    from referral_codes\n    where upper(code) = upper(${exact})\n       or code ilike ${like}\n       or user_id = ${exact}\n       or wallet = ${exact}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => ({\n    entityType: \"referral\" as const,\n    id: row.code,\n    label: row.code,\n    sublabel: row.userId,\n    context: `wallet ${row.wallet}`,\n    href: `/users/${encodeURIComponent(row.userId)}`,\n  }));\n}\n\nasync function searchLinkedAccounts(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const trimmed = query.startsWith(\"@\") ? query.slice(1) : query;\n  const exact = trimmed;\n  const like = `%${trimmed}%`;\n  const rows = await sql<LinkedAccountRow[]>`\n    select\n      user_id as \"userId\",\n      provider,\n      provider_account_id as \"providerAccountId\",\n      nullif(metadata_json->>'telegramUsername', '') as \"telegramUsername\",\n      status\n    from linked_accounts\n    where status = 'active'\n      and (\n        provider_account_id = ${exact}\n        or metadata_json->>'telegramUsername' = ${exact}\n        or provider_account_id ilike ${like}\n        or coalesce(metadata_json->>'telegramUsername', '') ilike ${like}\n      )\n    order by linked_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => {\n    const display = row.telegramUsername\n      ? `@${row.telegramUsername}`\n      : row.providerAccountId;\n    return {\n      entityType: \"linked_account\" as const,\n      id: `${row.provider}:${row.providerAccountId}`,\n      label: display,\n      sublabel: row.userId,\n      context: `${row.provider} (${row.status})`,\n      href: `/users/${encodeURIComponent(row.userId)}`,\n    };\n  });\n}\n\nasync function searchRounds(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const exact = query;\n  const flipPotRows = await sql<RoundRow[]>`\n    select\n      pda,\n      game,\n      match_id as \"matchId\",\n      phase,\n      creator\n    from rounds\n    where pda = ${exact}\n       or match_id = ${exact}\n       or creator = ${exact}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  const closeCallRows = await sql<RoundRow[]>`\n    select\n      pda,\n      'closecall'::text as \"game\",\n      round_id as \"matchId\",\n      phase,\n      null::text as \"creator\"\n    from closecall_rounds\n    where pda = ${exact}\n       or round_id = ${exact}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  const combined = [...flipPotRows, ...closeCallRows];\n  return combined.slice(0, limit).map((row) => ({\n    entityType: \"round\" as const,\n    id: row.pda,\n    label: row.matchId,\n    sublabel: `${row.game} • ${row.phase}`,\n    context: row.creator ? `creator ${row.creator}` : null,\n    href: `/games/${encodeURIComponent(row.game)}/rounds/${encodeURIComponent(row.pda)}`,\n  }));\n}\n\nasync function searchTransactions(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const exact = query;\n  const rows = await sql<TransactionRow[]>`\n    select\n      id::text as \"id\",\n      tx_sig as \"txSig\",\n      game,\n      match_id as \"matchId\",\n      tx_type as \"txType\",\n      wallet,\n      amount_lamports::text as \"amountLamports\",\n      created_at::text as \"createdAt\"\n    from transactions\n    where tx_sig = ${exact}\n       or match_id = ${exact}\n       or wallet = ${exact}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => ({\n    entityType: \"transaction\" as const,\n    id: row.id,\n    label: row.txSig,\n    sublabel: `${row.game} • ${row.txType}`,\n    context: `wallet ${row.wallet} • ${row.amountLamports} lamports`,\n    href: `/games/${encodeURIComponent(row.game)}/rounds/${encodeURIComponent(row.matchId)}`,\n  }));\n}\n\nasync function searchQueueEvents(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  if (!/^\\d+$/.test(query)) return [];\n  const numericId = query;\n  const rows = await sql<QueueEventRow[]>`\n    select\n      id::text as \"id\",\n      event_type as \"eventType\",\n      status,\n      attempts,\n      scheduled_at::text as \"scheduledAt\"\n    from event_queue\n    where id::text = ${numericId}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => ({\n    entityType: \"queue_event\" as const,\n    id: row.id,\n    label: `#${row.id}`,\n    sublabel: `${row.eventType} • ${row.status}`,\n    context: `attempts ${row.attempts} • scheduled ${row.scheduledAt}`,\n    href: `/operations/queue?id=${encodeURIComponent(row.id)}`,\n  }));\n}\n\nasync function defaultPeekSearchAudit(input: {\n  actorEmail: string;\n  query: string;\n  queryClass: PeekSearchQueryClass;\n  totalResults: number;\n  route: string | null;\n  requestId: string | null;\n}): Promise<void> {\n  await writePeekAuditEvent({\n    eventType: \"peek.search\",\n    payload: {\n      actorEmail: input.actorEmail,\n      route: input.route,\n      actionId: \"peek.search\",\n      resourceType: \"search\",\n      resourceId: null,\n      filterSummary: `query_class=${input.queryClass}`,\n      resultCount: input.totalResults,\n      requestId: input.requestId,\n      rejectionReason: null,\n      changes: null,\n    },\n  });\n}\n\nexport async function getUniversalSearchResults(\n  options: UniversalSearchOptions,\n): Promise<PeekSearchResponse> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const perGroupLimit = clampLimit(options.perGroupLimit);\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n  const trimmed = options.query.trim();\n  const queryClass = classifyPeekSearchQuery(trimmed);\n\n  if (trimmed.length === 0) {\n    const response: PeekSearchResponse = {\n      query: trimmed,\n      queryClass,\n      groups: emptyGroups(),\n      totalResults: 0,\n      perGroupLimit,\n      generatedAt,\n    };\n    return response;\n  }\n\n  // Run every entity-class query in parallel; per-group LIMIT keeps each query\n  // bounded. Group-level `truncated` is set when the inner query came back\n  // with one more row than `limit`.\n  const [users, referrals, linkedAccounts, rounds, transactions, queueEvents] =\n    await Promise.all([\n      searchUsers(sql, trimmed, perGroupLimit),\n      searchReferralCodes(sql, trimmed, perGroupLimit),\n      searchLinkedAccounts(sql, trimmed, perGroupLimit),\n      searchRounds(sql, trimmed, perGroupLimit),\n      searchTransactions(sql, trimmed, perGroupLimit),\n      searchQueueEvents(sql, trimmed, perGroupLimit),\n    ]);\n\n  const groups: ReadonlyArray<PeekSearchGroup> = [\n    { entityType: \"user\", results: users, truncated: users.length === perGroupLimit },\n    {\n      entityType: \"referral\",\n      results: referrals,\n      truncated: referrals.length === perGroupLimit,\n    },\n    {\n      entityType: \"linked_account\",\n      results: linkedAccounts,\n      truncated: linkedAccounts.length === perGroupLimit,\n    },\n    {\n      entityType: \"round\",\n      results: rounds,\n      truncated: rounds.length === perGroupLimit,\n    },\n    {\n      entityType: \"transaction\",\n      results: transactions,\n      truncated: transactions.length === perGroupLimit,\n    },\n    {\n      entityType: \"queue_event\",\n      results: queueEvents,\n      truncated: queueEvents.length === perGroupLimit,\n    },\n  ];\n\n  const totalResults = groups.reduce(\n    (acc, group) => acc + group.results.length,\n    0,\n  );\n\n  const audit = options.audit === undefined ? defaultPeekSearchAudit : options.audit;\n  if (audit) {\n    try {\n      await audit({\n        actorEmail: options.actorEmail,\n        query: trimmed,\n        queryClass,\n        totalResults,\n        route: options.route ?? null,\n        requestId: options.requestId ?? null,\n      });\n    } catch {\n      // Audit failures must never leak to the caller (FR-11). The writer\n      // already logs server-side; swallow here so the search response still\n      // renders.\n    }\n  }\n\n  return {\n    query: trimmed,\n    queryClass,\n    groups,\n    totalResults,\n    perGroupLimit,\n    generatedAt,\n  };\n}\n","structuredPatch":[],"originalFile":null,"userModified":false}}
