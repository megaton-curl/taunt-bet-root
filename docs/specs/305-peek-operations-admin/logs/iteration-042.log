      raw: recentFundings,\n377\t      display: formatCount(recentFundings),\n378\t    },\n379\t  ];\n380\t\n381\t  return {\n382\t    generatedAt,\n383\t    metrics: blueprints.map(({ blueprint, raw, display }) =>\n384\t      buildMetric(blueprint, raw, display, generatedAt),\n385\t    ),\n386\t  };\n387\t}\n388\t"}]},"parent_tool_use_id":null,"session_id":"030a79a6-d277-48d4-a7de-fb3a60eda746","uuid":"6c8c007e-e3ac-48b8-bb86-251ff9e94ce3","timestamp":"2026-04-25T15:02:14.240Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-rewards.ts","content":"// Rewards economy admin queries (FR-9).\n//\n// Backs `/economy/rewards`. Reads three migration-011 tables:\n//\n//   - reward_config           — operator-tunable economy parameters\n//     (`listRewardConfig`). Each row is annotated server-side with a\n//     human-readable definition + expected value type from\n//     `PEEK_REWARD_CONFIG_KEY_REGISTRY`. Unknown keys still surface (with\n//     `definition: null`, `expectedType: \"unknown\"`) so an operator\n//     immediately notices when a new key has been seeded but the registry\n//     has not been updated.\n//   - reward_pool             — singleton accounting row (`getRewardPool`).\n//   - reward_pool_fundings    — append-only per-round funding ledger\n//     (`listRewardPoolFundings`). Bounded server-side; default 50, max 250.\n//\n// `getRewardsOverview` derives the FR-4 metric strip (current pool balance,\n// lifetime funded, lifetime paid, recent fundings count) from these tables.\n// Lamport / u64 values round-trip as `text` to preserve precision.\n\nimport type { Sql } from \"postgres\";\nimport {\n  type PeekMetric,\n  type PeekRewardConfigExpectedType,\n  type PeekRewardConfigRow,\n  type PeekRewardPool,\n  type PeekRewardPoolFundingRow,\n  type PeekRewardsOverview,\n  type PeekRewardsOverviewMetricId,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT = 50;\nexport const PEEK_REWARD_POOL_FUNDINGS_MAX_LIMIT = 250;\nexport const PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS = 24;\n\n// Static registry of known reward_config keys (mirrors the seed in\n// backend/migrations/011_challenge_engine.sql and the admin route allowlist\n// in backend/src/routes/admin.ts). Adding a new key in either place should\n// also extend this registry so an operator opening /economy/rewards sees a\n// definition and expected type instead of \"unknown\".\ntype RewardConfigRegistryEntry = {\n  definition: string;\n  expectedType: PeekRewardConfigExpectedType;\n};\n\nexport const PEEK_REWARD_CONFIG_KEY_REGISTRY: Readonly<\n  Record<string, RewardConfigRegistryEntry>\n> = {\n  points_per_dollar: {\n    definition:\n      \"Points granted per USD-equivalent of wager — drives the wager → points conversion rate.\",\n    expectedType: \"integer\",\n  },\n  dogpile_default_multiplier: {\n    definition:\n      \"Default points multiplier applied during active Dogpile events when a campaign override is not set.\",\n    expectedType: \"float\",\n  },\n  reward_pool_fee_share: {\n    definition:\n      \"Fraction of platform fee diverted into the reward pool on each settled round (0..1).\",\n    expectedType: \"ratio\",\n  },\n  points_crate_drop_rate: {\n    definition:\n      \"Probability per eligible action that a points crate drops (0..1).\",\n    expectedType: \"ratio\",\n  },\n  sol_crate_drop_rate: {\n    definition:\n      \"Probability per eligible action that a SOL crate drops (0..1).\",\n    expectedType: \"ratio\",\n  },\n  sol_crate_pool_pct: {\n    definition:\n      \"Fraction of the reward pool used to size a SOL crate payout when it drops (0..1).\",\n    expectedType: \"ratio\",\n  },\n  sol_crate_min_value: {\n    definition:\n      \"Minimum lamport value of a SOL crate payout — below this the drop is skipped.\",\n    expectedType: \"lamports\",\n  },\n  points_crate_min: {\n    definition:\n      \"Minimum points awarded by a points crate (inclusive lower bound of the random range).\",\n    expectedType: \"integer\",\n  },\n  points_crate_max: {\n    definition:\n      \"Maximum points awarded by a points crate (inclusive upper bound of the random range).\",\n    expectedType: \"integer\",\n  },\n  daily_challenge_count: {\n    definition:\n      \"Number of daily challenges assigned to a player per period.\",\n    expectedType: \"integer\",\n  },\n  weekly_challenge_count: {\n    definition:\n      \"Number of weekly challenges assigned to a player per period.\",\n    expectedType: \"integer\",\n  },\n};\n\ntype RewardConfigOptions = { sql?: Sql };\n\ntype RewardPoolOptions = { sql?: Sql };\n\nexport type ListRewardPoolFundingsOptions = {\n  sql?: Sql;\n  limit?: number;\n};\n\nexport type RewardsOverviewOptions = {\n  sql?: Sql;\n  now?: Date;\n  recentFundingsWindowHours?: number;\n};\n\nfunction clampLimit(\n  raw: number | undefined,\n  fallback: number,\n  max: number,\n): number {\n  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n  const floored = Math.floor(raw);\n  if (floored <= 0) return 1;\n  return Math.min(max, floored);\n}\n\nfunction readSum(value: string | null | undefined): string {\n  return typeof value === \"string\" && value.length > 0 ? value : \"0\";\n}\n\nfunction readInt(value: number | string | null | undefined): number {\n  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n  if (typeof value === \"string\") {\n    const parsed = Number.parseInt(value, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\nfunction formatLamports(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nexport async function listRewardConfig(\n  options: RewardConfigOptions = {},\n): Promise<ReadonlyArray<PeekRewardConfigRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n\n  const rows = await sql<\n    Array<{ key: string; value: string; updatedAt: string }>\n  >`\n    select\n      key as \"key\",\n      value as \"value\",\n      updated_at::text as \"updatedAt\"\n    from reward_config\n    order by key asc\n  `;\n\n  return rows.map((row) => {\n    const entry = PEEK_REWARD_CONFIG_KEY_REGISTRY[row.key];\n    return {\n      key: row.key,\n      value: row.value,\n      updatedAt: row.updatedAt,\n      definition: entry?.definition ?? null,\n      expectedType: entry?.expectedType ?? \"unknown\",\n    };\n  });\n}\n\nexport async function getRewardPool(\n  options: RewardPoolOptions = {},\n): Promise<PeekRewardPool | null> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n\n  const [row] = await sql<\n    Array<{\n      balanceLamports: string;\n      lifetimeFunded: string;\n      lifetimePaid: string;\n      updatedAt: string;\n    }>\n  >`\n    select\n      balance_lamports::text as \"balanceLamports\",\n      lifetime_funded::text as \"lifetimeFunded\",\n      lifetime_paid::text as \"lifetimePaid\",\n      updated_at::text as \"updatedAt\"\n    from reward_pool\n    where id = 1\n    limit 1\n  `;\n\n  if (!row) return null;\n\n  return {\n    balanceLamports: readSum(row.balanceLamports),\n    lifetimeFunded: readSum(row.lifetimeFunded),\n    lifetimePaid: readSum(row.lifetimePaid),\n    updatedAt: row.updatedAt,\n  };\n}\n\nexport async function listRewardPoolFundings(\n  options: ListRewardPoolFundingsOptions = {},\n): Promise<ReadonlyArray<PeekRewardPoolFundingRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT,\n    PEEK_REWARD_POOL_FUNDINGS_MAX_LIMIT,\n  );\n\n  return sql<Array<PeekRewardPoolFundingRow>>`\n    select\n      id::text as \"id\",\n      round_id as \"roundId\",\n      fee_lamports::text as \"feeLamports\",\n      funded_lamports::text as \"fundedLamports\",\n      created_at::text as \"createdAt\"\n    from reward_pool_fundings\n    order by created_at desc, id desc\n    limit ${limit}\n  `;\n}\n\ntype MetricBlueprint = {\n  id: PeekRewardsOverviewMetricId;\n  label: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  definition: string;\n  drilldownHref: string | null;\n};\n\nfunction buildMetric(\n  blueprint: MetricBlueprint,\n  raw: number | string,\n  display: string,\n  asOf: string,\n): PeekMetric {\n  return {\n    id: blueprint.id,\n    label: blueprint.label,\n    value: raw,\n    valueDisplay: display,\n    unit: blueprint.unit,\n    source: blueprint.source,\n    windowLabel: blueprint.windowLabel,\n    asOf,\n    definition: blueprint.definition,\n    freshness: \"live\",\n    drilldownHref: blueprint.drilldownHref,\n  };\n}\n\nexport async function getRewardsOverview(\n  options: RewardsOverviewOptions = {},\n): Promise<PeekRewardsOverview> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n  const windowHours = clampLimit(\n    options.recentFundingsWindowHours,\n    PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS,\n    24 * 30,\n  );\n  const since = new Date(now.getTime() - windowHours * 60 * 60 * 1000);\n  const sinceIso = since.toISOString();\n\n  const [poolRows, recentFundingsRows] = await Promise.all([\n    sql<\n      Array<{\n        balanceLamports: string;\n        lifetimeFunded: string;\n        lifetimePaid: string;\n      }>\n    >`\n      select\n        balance_lamports::text as \"balanceLamports\",\n        lifetime_funded::text as \"lifetimeFunded\",\n        lifetime_paid::text as \"lifetimePaid\"\n      from reward_pool\n      where id = 1\n      limit 1\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from reward_pool_fundings\n      where created_at >= ${sinceIso}::timestamptz\n    `,\n  ]);\n\n  const pool = poolRows[0];\n  const balanceLamports = readSum(pool?.balanceLamports);\n  const lifetimeFunded = readSum(pool?.lifetimeFunded);\n  const lifetimePaid = readSum(pool?.lifetimePaid);\n  const recentFundings = readInt(\n    recentFundingsRows.length > 0 ? recentFundingsRows[0]?.value : 0,\n  );\n\n  const windowLabel = `Last ${windowHours}h`;\n\n  const blueprints: ReadonlyArray<{\n    blueprint: MetricBlueprint;\n    raw: number | string;\n    display: string;\n  }> = [\n    {\n      blueprint: {\n        id: \"rewards.balance_lamports\",\n        label: \"Reward pool balance (lamports)\",\n        unit: \"lamports\",\n        source: \"reward_pool\",\n        windowLabel: \"Current\",\n        definition:\n          \"balance_lamports on the singleton reward_pool row — lamports currently held by the pool and available for crate payouts.\",\n        drilldownHref: \"/economy/rewards#pool\",\n      },\n      raw: balanceLamports,\n      display: formatLamports(balanceLamports),\n    },\n    {\n      blueprint: {\n        id: \"rewards.lifetime_funded_lamports\",\n        label: \"Lifetime funded (lamports)\",\n        unit: \"lamports\",\n        source: \"reward_pool\",\n        windowLabel: \"All time\",\n        definition:\n          \"lifetime_funded on the singleton reward_pool row — total lamports ever credited to the pool by reward_pool_fundings.\",\n        drilldownHref: \"/economy/rewards#fundings\",\n      },\n      raw: lifetimeFunded,\n      display: formatLamports(lifetimeFunded),\n    },\n    {\n      blueprint: {\n        id: \"rewards.lifetime_paid_lamports\",\n        label: \"Lifetime paid (lamports)\",\n        unit: \"lamports\",\n        source: \"reward_pool\",\n        windowLabel: \"All time\",\n        definition:\n          \"lifetime_paid on the singleton reward_pool row — total lamports ever paid out from the pool (e.g. SOL crate drops).\",\n        drilldownHref: \"/economy/rewards#pool\",\n      },\n      raw: lifetimePaid,\n      display: formatLamports(lifetimePaid),\n    },\n    {\n      blueprint: {\n        id: \"rewards.recent_fundings\",\n        label: \"Recent fundings\",\n        unit: \"events\",\n        source: \"reward_pool_fundings\",\n        windowLabel,\n        definition: `Count of reward_pool_fundings rows with created_at within the last ${windowHours} hours — one row per source round whose fee fed the pool.`,\n        drilldownHref: \"/economy/rewards#fundings\",\n      },\n      raw: recentFundings,\n      display: formatCount(recentFundings),\n    },\n  ];\n\n  return {\n    generatedAt,\n    metrics: blueprints.map(({ blueprint, raw, display }) =>\n      buildMetric(blueprint, raw, display, generatedAt),\n    ),\n  };\n}\n","numLines":388,"startLine":1,"totalLines":388}}}
