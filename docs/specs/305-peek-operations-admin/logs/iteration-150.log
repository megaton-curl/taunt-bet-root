ces/rng-utopia/peek/src/server/mutations/index.ts","content":"// Public surface for the peek mutations module (FR-14).\n//\n// Subsequent FR-14 iterations import `runPeekMutation` to wire the\n// approved mutation actions (KOL rate, fraud-flag status, dogpile cancel,\n// reward-config edit) into route handlers, and import the registry types\n// to register new mutation definitions alongside the framework.\n\nexport {\n  PEEK_MUTATIONS,\n  getPeekMutation,\n  type PeekMutationActionId,\n  type PeekMutationActorContext,\n  type PeekMutationDefinition,\n  type PeekMutationExecuteContext,\n  type PeekMutationExecuteResult,\n  type PeekMutationRegistry,\n} from \"./registry\";\nexport {\n  runPeekMutation,\n  type PeekMutationAuditWriter,\n  type PeekMutationFailure,\n  type PeekMutationFailureReason,\n  type PeekMutationRunInput,\n  type PeekMutationRunResult,\n  type PeekMutationSuccess,\n} from \"./runner\";\nexport {\n  KOL_RATE_BPS_MAX,\n  KOL_RATE_BPS_MIN,\n  kolRateUpdateInputSchema,\n  kolRateUpdateMutation,\n  type KolRateUpdateInput,\n} from \"./kol-rate\";\nexport {\n  FRAUD_FLAG_ALLOWED_TRANSITIONS,\n  FRAUD_FLAG_STATUSES,\n  fraudFlagStatusUpdateInputSchema,\n  fraudFlagStatusUpdateMutation,\n  isFraudFlagTransitionAllowed,\n  type FraudFlagStatus,\n  type FraudFlagStatusUpdateInput,\n} from \"./fraud-flag\";\nexport {\n  DOGPILE_EVENT_STATUSES,\n  dogpileCancelInputSchema,\n  dogpileCancelMutation,\n  type DogpileCancelInput,\n  type DogpileEventStatus,\n} from \"./dogpile\";\n","numLines":50,"startLine":1,"totalLines":50}}}
