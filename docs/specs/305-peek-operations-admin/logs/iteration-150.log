{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ja8tJGGr351oQustRgPN6E","type":"tool_result","content":"1\t// Rewards economy admin queries (FR-9).\n2\t//\n3\t// Backs `/economy/rewards`. Reads three migration-011 tables:\n4\t//\n5\t//   - reward_config           — operator-tunable economy parameters\n6\t//     (`listRewardConfig`). Each row is annotated server-side with a\n7\t//     human-readable definition + expected value type from\n8\t//     `PEEK_REWARD_CONFIG_KEY_REGISTRY`. Unknown keys still surface (with\n9\t//     `definition: null`, `expectedType: \"unknown\"`) so an operator\n10\t//     immediately notices when a new key has been seeded but the registry\n11\t//     has not been updated.\n12\t//   - reward_pool             — singleton accounting row (`getRewardPool`).\n13\t//   - reward_pool_fundings    — append-only per-round funding ledger\n14\t//     (`listRewardPoolFundings`). Bounded server-side; default 50, max 250.\n15\t//\n16\t// `getRewardsOverview` derives the FR-4 metric strip (current pool balance,\n17\t// lifetime funded, lifetime paid, recent fundings count) from these tables.\n18\t// Lamport / u64 values round-trip as `text` to preserve precision.\n19\t\n20\timport type { Sql } from \"postgres\";\n21\timport {\n22\t  type PeekMetric,\n23\t  type PeekRewardConfigExpectedType,\n24\t  type PeekRewardConfigRow,\n25\t  type PeekRewardPool,\n26\t  type PeekRewardPoolFundingRow,\n27\t  type PeekRewardsOverview,\n28\t  type PeekRewardsOverviewMetricId,\n29\t} from \"../../../lib/types/peek\";\n30\timport { getSqlClient } from \"../client\";\n31\t\n32\texport const PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT = 50;\n33\texport const PEEK_REWARD_POOL_FUNDINGS_MAX_LIMIT = 250;\n34\texport const PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS = 24;\n35\t\n36\t// Static registry of known reward_config keys (mirrors the seed in\n37\t// backend/migrations/011_challenge_engine.sql and the admin route allowlist\n38\t// in backend/src/routes/admin.ts). Adding a new key in either place should\n39\t// also extend this registry so an operator opening /economy/rewards sees a\n40\t// definition and expected type instead of \"unknown\".\n41\ttype RewardConfigRegistryEntry = {\n42\t  definition: string;\n43\t  expectedType: PeekRewardConfigExpectedType;\n44\t};\n45\t\n46\texport const PEEK_REWARD_CONFIG_KEY_REGISTRY: Readonly<\n47\t  Record<string, RewardConfigRegistryEntry>\n48\t> = {\n49\t  points_per_dollar: {\n50\t    definition:\n51\t      \"Points granted per USD-equivalent of wager — drives the wager → points conversion rate.\",\n52\t    expectedType: \"integer\",\n53\t  },\n54\t  dogpile_default_multiplier: {\n55\t    definition:\n56\t      \"Default points multiplier applied during active Dogpile events when a campaign override is not set.\",\n57\t    expectedType: \"float\",\n58\t  },\n59\t  reward_pool_fee_share: {\n60\t    definition:\n61\t      \"Fraction of platform fee diverted into the reward pool on each settled round (0..1).\",\n62\t    expectedType: \"ratio\",\n63\t  },\n64\t  points_crate_drop_rate: {\n65\t    definition:\n66\t      \"Probability per eligible action that a points crate drops (0..1).\",\n67\t    expectedType: \"ratio\",\n68\t  },\n69\t  sol_crate_drop_rate: {\n70\t    definition:\n71\t      \"Probability per eligible action that a SOL crate drops (0..1).\",\n72\t    expectedType: \"ratio\",\n73\t  },\n74\t  sol_crate_pool_pct: {\n75\t    definition:\n76\t      \"Fraction of the reward pool used to size a SOL crate payout when it drops (0..1).\",\n77\t    expectedType: \"ratio\",\n78\t  },\n79\t  sol_crate_min_value: {\n80\t    definition:\n81\t      \"Minimum lamport value of a SOL crate payout — below this the drop is skipped.\",\n82\t    expectedType: \"lamports\",\n83\t  },\n84\t  points_crate_min: {\n85\t    definition:\n86\t      \"Minimum points awarded by a points crate (inclusive lower bound of the random range).\",\n87\t    expectedType: \"integer\",\n88\t  },\n89\t  points_crate_max: {\n90\t    definition:\n91\t      \"Maximum points awarded by a points crate (inclusive upper bound of the random range).\",\n92\t    expectedType: \"integer\",\n93\t  },\n94\t  daily_challenge_count: {\n95\t    definition:\n96\t      \"Number of daily challenges assigned to a player per period.\",\n97\t    expectedType: \"integer\",\n98\t  },\n99\t  weekly_challenge_count: {\n100\t    definition:\n101\t      \"Number of weekly challenges assigned to a player per period.\",\n102\t    expectedType: \"integer\",\n103\t  },\n104\t};\n105\t\n106\ttype RewardConfigOptions = { sql?: Sql };\n107\t\n108\ttype RewardPoolOptions = { sql?: Sql };\n109\t\n110\texport type ListRewardPoolFundingsOptions = {\n111\t  sql?: Sql;\n112\t  limit?: number;\n113\t};\n114\t\n115\texport type RewardsOverviewOptions = {\n116\t  sql?: Sql;\n117\t  now?: Date;\n118\t  recentFundingsWindowHours?: number;\n119\t};\n120\t\n121\tfunction clampLimit(\n122\t  raw: number | undefined,\n123\t  fallback: number,\n124\t  max: number,\n125\t): number {\n126\t  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n127\t  const floored = Math.floor(raw);\n128\t  if (floored <= 0) return 1;\n129\t  return Math.min(max, floored);\n130\t}\n131\t\n132\tfunction readSum(value: string | null | undefined): string {\n133\t  return typeof value === \"string\" && value.length > 0 ? value : \"0\";\n134\t}\n135\t\n136\tfunction readInt(value: number | string | null | undefined): number {\n137\t  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n138\t  if (typeof value === \"string\") {\n139\t    const parsed = Number.parseInt(value, 10);\n140\t    return Number.isFinite(parsed) ? parsed : 0;\n141\t  }\n142\t  return 0;\n143\t}\n144\t\n145\tfunction formatCount(count: number): string {\n146\t  return count.toLocaleString(\"en-US\");\n147\t}\n148\t\n149\tfunction formatLamports(value: string): string {\n150\t  if (!value || value === \"0\") return \"0\";\n151\t  const negative = value.startsWith(\"-\");\n152\t  const digits = negative ? value.slice(1) : value;\n153\t  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n154\t  return negative ? `-${grouped}` : grouped;\n155\t}\n156\t\n157\texport async function listRewardConfig(\n158\t  options: RewardConfigOptions = {},\n159\t): Promise<ReadonlyArray<PeekRewardConfigRow>> {\n160\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n161\t\n162\t  const rows = await sql<\n163\t    Array<{ key: string; value: string; updatedAt: string }>\n164\t  >`\n165\t    select\n166\t      key as \"key\",\n167\t      value as \"value\",\n168\t      updated_at::text as \"updatedAt\"\n169\t    from reward_config\n170\t    order by key asc\n171\t  `;\n172\t\n173\t  return rows.map((row) => {\n174\t    const entry = PEEK_REWARD_CONFIG_KEY_REGISTRY[row.key];\n175\t    return {\n176\t      key: row.key,\n177\t      value: row.value,\n178\t      updatedAt: row.updatedAt,\n179\t      definition: entry?.definition ?? null,\n180\t      expectedType: entry?.expectedType ?? \"unknown\",\n181\t    };\n182\t  });\n183\t}\n184\t\n185\texport async function getRewardPool(\n186\t  options: RewardPoolOptions = {},\n187\t): Promise<PeekRewardPool | null> {\n188\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n189\t\n190\t  const [row] = await sql<\n191\t    Array<{\n192\t      balanceLamports: string;\n193\t      lifetimeFunded: string;\n194\t      lifetimePaid: string;\n195\t      updatedAt: string;\n196\t    }>\n197\t  >`\n198\t    select\n199\t      balance_lamports::text as \"balanceLamports\",\n200\t      lifetime_funded::text as \"lifetimeFunded\","}]},"parent_tool_use_id":null,"session_id":"65481a30-264b-4bb6-adb8-38c4f155c171","uuid":"cac29c53-d4ab-4a86-b9aa-22967f58fa60","timestamp":"2026-04-26T19:12:22.936Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-rewards.ts","content":"// Rewards economy admin queries (FR-9).\n//\n// Backs `/economy/rewards`. Reads three migration-011 tables:\n//\n//   - reward_config           — operator-tunable economy parameters\n//     (`listRewardConfig`). Each row is annotated server-side with a\n//     human-readable definition + expected value type from\n//     `PEEK_REWARD_CONFIG_KEY_REGISTRY`. Unknown keys still surface (with\n//     `definition: null`, `expectedType: \"unknown\"`) so an operator\n//     immediately notices when a new key has been seeded but the registry\n//     has not been updated.\n//   - reward_pool             — singleton accounting row (`getRewardPool`).\n//   - reward_pool_fundings    — append-only per-round funding ledger\n//     (`listRewardPoolFundings`). Bounded server-side; default 50, max 250.\n//\n// `getRewardsOverview` derives the FR-4 metric strip (current pool balance,\n// lifetime funded, lifetime paid, recent fundings count) from these tables.\n// Lamport / u64 values round-trip as `text` to preserve precision.\n\nimport type { Sql } from \"postgres\";\nimport {\n  type PeekMetric,\n  type PeekRewardConfigExpectedType,\n  type PeekRewardConfigRow,\n  type PeekRewardPool,\n  type PeekRewardPoolFundingRow,\n  type PeekRewardsOverview,\n  type PeekRewardsOverviewMetricId,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT = 50;\nexport const PEEK_REWARD_POOL_FUNDINGS_MAX_LIMIT = 250;\nexport const PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS = 24;\n\n// Static registry of known reward_config keys (mirrors the seed in\n// backend/migrations/011_challenge_engine.sql and the admin route allowlist\n// in backend/src/routes/admin.ts). Adding a new key in either place should\n// also extend this registry so an operator opening /economy/rewards sees a\n// definition and expected type instead of \"unknown\".\ntype RewardConfigRegistryEntry = {\n  definition: string;\n  expectedType: PeekRewardConfigExpectedType;\n};\n\nexport const PEEK_REWARD_CONFIG_KEY_REGISTRY: Readonly<\n  Record<string, RewardConfigRegistryEntry>\n> = {\n  points_per_dollar: {\n    definition:\n      \"Points granted per USD-equivalent of wager — drives the wager → points conversion rate.\",\n    expectedType: \"integer\",\n  },\n  dogpile_default_multiplier: {\n    definition:\n      \"Default points multiplier applied during active Dogpile events when a campaign override is not set.\",\n    expectedType: \"float\",\n  },\n  reward_pool_fee_share: {\n    definition:\n      \"Fraction of platform fee diverted into the reward pool on each settled round (0..1).\",\n    expectedType: \"ratio\",\n  },\n  points_crate_drop_rate: {\n    definition:\n      \"Probability per eligible action that a points crate drops (0..1).\",\n    expectedType: \"ratio\",\n  },\n  sol_crate_drop_rate: {\n    definition:\n      \"Probability per eligible action that a SOL crate drops (0..1).\",\n    expectedType: \"ratio\",\n  },\n  sol_crate_pool_pct: {\n    definition:\n      \"Fraction of the reward pool used to size a SOL crate payout when it drops (0..1).\",\n    expectedType: \"ratio\",\n  },\n  sol_crate_min_value: {\n    definition:\n      \"Minimum lamport value of a SOL crate payout — below this the drop is skipped.\",\n    expectedType: \"lamports\",\n  },\n  points_crate_min: {\n    definition:\n      \"Minimum points awarded by a points crate (inclusive lower bound of the random range).\",\n    expectedType: \"integer\",\n  },\n  points_crate_max: {\n    definition:\n      \"Maximum points awarded by a points crate (inclusive upper bound of the random range).\",\n    expectedType: \"integer\",\n  },\n  daily_challenge_count: {\n    definition:\n      \"Number of daily challenges assigned to a player per period.\",\n    expectedType: \"integer\",\n  },\n  weekly_challenge_count: {\n    definition:\n      \"Number of weekly challenges assigned to a player per period.\",\n    expectedType: \"integer\",\n  },\n};\n\ntype RewardConfigOptions = { sql?: Sql };\n\ntype RewardPoolOptions = { sql?: Sql };\n\nexport type ListRewardPoolFundingsOptions = {\n  sql?: Sql;\n  limit?: number;\n};\n\nexport type RewardsOverviewOptions = {\n  sql?: Sql;\n  now?: Date;\n  recentFundingsWindowHours?: number;\n};\n\nfunction clampLimit(\n  raw: number | undefined,\n  fallback: number,\n  max: number,\n): number {\n  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n  const floored = Math.floor(raw);\n  if (floored <= 0) return 1;\n  return Math.min(max, floored);\n}\n\nfunction readSum(value: string | null | undefined): string {\n  return typeof value === \"string\" && value.length > 0 ? value : \"0\";\n}\n\nfunction readInt(value: number | string | null | undefined): number {\n  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n  if (typeof value === \"string\") {\n    const parsed = Number.parseInt(value, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\nfunction formatLamports(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nexport async function listRewardConfig(\n  options: RewardConfigOptions = {},\n): Promise<ReadonlyArray<PeekRewardConfigRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n\n  const rows = await sql<\n    Array<{ key: string; value: string; updatedAt: string }>\n  >`\n    select\n      key as \"key\",\n      value as \"value\",\n      updated_at::text as \"updatedAt\"\n    from reward_config\n    order by key asc\n  `;\n\n  return rows.map((row) => {\n    const entry = PEEK_REWARD_CONFIG_KEY_REGISTRY[row.key];\n    return {\n      key: row.key,\n      value: row.value,\n      updatedAt: row.updatedAt,\n      definition: entry?.definition ?? null,\n      expectedType: entry?.expectedType ?? \"unknown\",\n    };\n  });\n}\n\nexport async function getRewardPool(\n  options: RewardPoolOptions = {},\n): Promise<PeekRewardPool | null> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n\n  const [row] = await sql<\n    Array<{\n      balanceLamports: string;\n      lifetimeFunded: string;\n      lifetimePaid: string;\n      updatedAt: string;\n    }>\n  >`\n    select\n      balance_lamports::text as \"balanceLamports\",\n      lifetime_funded::text as \"lifetimeFunded\",","numLines":200,"startLine":1,"totalLines":388}}}
