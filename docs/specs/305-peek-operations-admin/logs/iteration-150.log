{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K9ucWPAuRgWWunpLGFfa6R","type":"tool_result","content":"1\t// Approved FR-14 mutation: cancel a scheduled future `dogpile_events` row.\n2\t//\n3\t// Scope:\n4\t//   - Identified by the BIGINT `dogpile_events.id` rendered as text.\n5\t//   - Only the `status` column moves; the diff records the before/after pair\n6\t//     (`scheduled` -> `cancelled`) so the audit row carries the full state\n7\t//     transition.\n8\t//\n9\t// State guards (FR-14: \"deny active/ended\"):\n10\t//   - The row's current `status` must be exactly `scheduled`.\n11\t//     `active`, `ended`, and (no-op) `cancelled` are denied.\n12\t//   - The row's `starts_at` must be strictly in the future (`> now()`).\n13\t//     A row whose status is still `scheduled` but whose `starts_at` has\n14\t//     already elapsed is treated as already-active for cancellation purposes\n15\t//     so the worker promotion-from-scheduled race cannot be circumvented from\n16\t//     the admin UI. (The worker that flips `scheduled` -> `active` runs out\n17\t//     of band; admins should not be able to win that race by hand.)\n18\t//\n19\t// Failure semantics (surfaced through the runner's execute path):\n20\t//   - Unknown event id      -> thrown error -> result `execution_failed` /\n21\t//     audit `peek.change.rejected` with `rejectionReason` starting\n22\t//     `execution_failed: unknown_event:`.\n23\t//   - Non-`scheduled` status -> thrown error -> result `execution_failed` /\n24\t//     audit `peek.change.rejected` with `rejectionReason` starting\n25\t//     `execution_failed: invalid_status: <current>` (`active`, `ended`,\n26\t//     `cancelled`).\n27\t//   - Already-elapsed `starts_at` while still `scheduled` ->\n28\t//     `execution_failed: starts_at_in_past`.\n29\t//   - Schema validation failures (missing/invalid eventId) -> the runner's\n30\t//     `invalid_input` path before any DB work.\n31\t//\n32\t// Authorization:\n33\t//   `dogpile.cancel` is admin-only per FR-2 `PEEK_ACTION_RULES`. The runner\n34\t//   enforces this before `execute` is called.\n35\t\n36\timport type { Sql } from \"postgres\";\n37\timport { z } from \"zod\";\n38\timport type { PeekAuditChange } from \"../../lib/types/peek\";\n39\timport type {\n40\t  PeekMutationDefinition,\n41\t  PeekMutationExecuteContext,\n42\t  PeekMutationExecuteResult,\n43\t} from \"./registry\";\n44\t\n45\texport const DOGPILE_EVENT_STATUSES = [\n46\t  \"scheduled\",\n47\t  \"active\",\n48\t  \"ended\",\n49\t  \"cancelled\",\n50\t] as const;\n51\texport type DogpileEventStatus = (typeof DOGPILE_EVENT_STATUSES)[number];\n52\t\n53\t// `eventId` is the BIGINT primary key serialized as text (matches the\n54\t// existing `get-dogpile-and-fraud.listDogpileEvents` view-model contract).\n55\texport const dogpileCancelInputSchema = z\n56\t  .object({\n57\t    eventId: z\n58\t      .string()\n59\t      .trim()\n60\t      .min(1)\n61\t      .regex(/^[0-9]+$/u, \"eventId must be a positive integer\"),\n62\t  })\n63\t  .strict();\n64\t\n65\texport type DogpileCancelInput = z.infer<typeof dogpileCancelInputSchema>;\n66\t\n67\ttype ExistingDogpileRow = {\n68\t  id: string;\n69\t  status: DogpileEventStatus;\n70\t  startsInFuture: boolean;\n71\t};\n72\t\n73\tasync function fetchExistingRow(\n74\t  sql: Sql,\n75\t  eventId: string,\n76\t): Promise<ExistingDogpileRow | null> {\n77\t  const rows = await sql<Array<ExistingDogpileRow>>`\n78\t    select\n79\t      id::text as \"id\",\n80\t      status as \"status\",\n81\t      (starts_at > now()) as \"startsInFuture\"\n82\t    from dogpile_events\n83\t    where id::text = ${eventId}\n84\t    for update\n85\t  `;\n86\t  return rows[0] ?? null;\n87\t}\n88\t\n89\tasync function executeDogpileCancel(\n90\t  ctx: PeekMutationExecuteContext<DogpileCancelInput>,\n91\t): Promise<PeekMutationExecuteResult> {\n92\t  const { sql, input } = ctx;\n93\t  const { eventId } = input;\n94\t\n95\t  const existing = await fetchExistingRow(sql, eventId);\n96\t  if (!existing) {\n97\t    throw new Error(`unknown_event: ${eventId}`);\n98\t  }\n99\t\n100\t  if (existing.status !== \"scheduled\") {\n101\t    throw new Error(`invalid_status: ${existing.status}`);\n102\t  }\n103\t\n104\t  if (!existing.startsInFuture) {\n105\t    throw new Error(\"starts_at_in_past\");\n106\t  }\n107\t\n108\t  await sql`\n109\t    update dogpile_events\n110\t    set status = 'cancelled'\n111\t    where id::text = ${eventId}\n112\t  `;\n113\t\n114\t  const changes: ReadonlyArray<PeekAuditChange> = [\n115\t    { field: \"status\", before: \"scheduled\", after: \"cancelled\" },\n116\t  ];\n117\t  return { resourceId: existing.id, changes };\n118\t}\n119\t\n120\texport const dogpileCancelMutation: PeekMutationDefinition<DogpileCancelInput> =\n121\t  {\n122\t    actionId: \"dogpile.cancel\",\n123\t    resourceType: \"dogpile_events\",\n124\t    schema: dogpileCancelInputSchema,\n125\t    execute: executeDogpileCancel as PeekMutationDefinition[\"execute\"],\n126\t  };\n127\t"}]},"parent_tool_use_id":null,"session_id":"65481a30-264b-4bb6-adb8-38c4f155c171","uuid":"21654fdd-c9fd-4671-9d0a-99291f006483","timestamp":"2026-04-26T19:12:05.137Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/mutations/dogpile.ts","content":"// Approved FR-14 mutation: cancel a scheduled future `dogpile_events` row.\n//\n// Scope:\n//   - Identified by the BIGINT `dogpile_events.id` rendered as text.\n//   - Only the `status` column moves; the diff records the before/after pair\n//     (`scheduled` -> `cancelled`) so the audit row carries the full state\n//     transition.\n//\n// State guards (FR-14: \"deny active/ended\"):\n//   - The row's current `status` must be exactly `scheduled`.\n//     `active`, `ended`, and (no-op) `cancelled` are denied.\n//   - The row's `starts_at` must be strictly in the future (`> now()`).\n//     A row whose status is still `scheduled` but whose `starts_at` has\n//     already elapsed is treated as already-active for cancellation purposes\n//     so the worker promotion-from-scheduled race cannot be circumvented from\n//     the admin UI. (The worker that flips `scheduled` -> `active` runs out\n//     of band; admins should not be able to win that race by hand.)\n//\n// Failure semantics (surfaced through the runner's execute path):\n//   - Unknown event id      -> thrown error -> result `execution_failed` /\n//     audit `peek.change.rejected` with `rejectionReason` starting\n//     `execution_failed: unknown_event:`.\n//   - Non-`scheduled` status -> thrown error -> result `execution_failed` /\n//     audit `peek.change.rejected` with `rejectionReason` starting\n//     `execution_failed: invalid_status: <current>` (`active`, `ended`,\n//     `cancelled`).\n//   - Already-elapsed `starts_at` while still `scheduled` ->\n//     `execution_failed: starts_at_in_past`.\n//   - Schema validation failures (missing/invalid eventId) -> the runner's\n//     `invalid_input` path before any DB work.\n//\n// Authorization:\n//   `dogpile.cancel` is admin-only per FR-2 `PEEK_ACTION_RULES`. The runner\n//   enforces this before `execute` is called.\n\nimport type { Sql } from \"postgres\";\nimport { z } from \"zod\";\nimport type { PeekAuditChange } from \"../../lib/types/peek\";\nimport type {\n  PeekMutationDefinition,\n  PeekMutationExecuteContext,\n  PeekMutationExecuteResult,\n} from \"./registry\";\n\nexport const DOGPILE_EVENT_STATUSES = [\n  \"scheduled\",\n  \"active\",\n  \"ended\",\n  \"cancelled\",\n] as const;\nexport type DogpileEventStatus = (typeof DOGPILE_EVENT_STATUSES)[number];\n\n// `eventId` is the BIGINT primary key serialized as text (matches the\n// existing `get-dogpile-and-fraud.listDogpileEvents` view-model contract).\nexport const dogpileCancelInputSchema = z\n  .object({\n    eventId: z\n      .string()\n      .trim()\n      .min(1)\n      .regex(/^[0-9]+$/u, \"eventId must be a positive integer\"),\n  })\n  .strict();\n\nexport type DogpileCancelInput = z.infer<typeof dogpileCancelInputSchema>;\n\ntype ExistingDogpileRow = {\n  id: string;\n  status: DogpileEventStatus;\n  startsInFuture: boolean;\n};\n\nasync function fetchExistingRow(\n  sql: Sql,\n  eventId: string,\n): Promise<ExistingDogpileRow | null> {\n  const rows = await sql<Array<ExistingDogpileRow>>`\n    select\n      id::text as \"id\",\n      status as \"status\",\n      (starts_at > now()) as \"startsInFuture\"\n    from dogpile_events\n    where id::text = ${eventId}\n    for update\n  `;\n  return rows[0] ?? null;\n}\n\nasync function executeDogpileCancel(\n  ctx: PeekMutationExecuteContext<DogpileCancelInput>,\n): Promise<PeekMutationExecuteResult> {\n  const { sql, input } = ctx;\n  const { eventId } = input;\n\n  const existing = await fetchExistingRow(sql, eventId);\n  if (!existing) {\n    throw new Error(`unknown_event: ${eventId}`);\n  }\n\n  if (existing.status !== \"scheduled\") {\n    throw new Error(`invalid_status: ${existing.status}`);\n  }\n\n  if (!existing.startsInFuture) {\n    throw new Error(\"starts_at_in_past\");\n  }\n\n  await sql`\n    update dogpile_events\n    set status = 'cancelled'\n    where id::text = ${eventId}\n  `;\n\n  const changes: ReadonlyArray<PeekAuditChange> = [\n    { field: \"status\", before: \"scheduled\", after: \"cancelled\" },\n  ];\n  return { resourceId: existing.id, changes };\n}\n\nexport const dogpileCancelMutation: PeekMutationDefinition<DogpileCancelInput> =\n  {\n    actionId: \"dogpile.cancel\",\n    resourceType: \"dogpile_events\",\n    schema: dogpileCancelInputSchema,\n    execute: executeDogpileCancel as PeekMutationDefinition[\"execute\"],\n  };\n","numLines":127,"startLine":1,"totalLines":127}}}
