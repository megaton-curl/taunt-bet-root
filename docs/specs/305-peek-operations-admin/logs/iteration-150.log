{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HpDK1b7kfftdf2yEukYeAR","type":"tool_result","content":"1\t/**\n2\t * Admin API routes — reward config, reward pool, campaign/challenge CRUD,\n3\t * and admin-level management.\n4\t *\n5\t * All routes require X-Admin-Key header matching ADMIN_API_KEY env var.\n6\t */\n7\t\n8\timport { Hono } from \"hono\";\n9\timport type { Db } from \"../db.js\";\n10\t\n11\t// ---------------------------------------------------------------------------\n12\t// Known config keys — reject unknown keys with 400\n13\t// ---------------------------------------------------------------------------\n14\t\n15\tconst VALID_CONFIG_KEYS = new Set([\n16\t  \"points_per_dollar\",\n17\t  \"dogpile_default_multiplier\",\n18\t  \"reward_pool_fee_share\",\n19\t  \"points_crate_drop_rate\",\n20\t  \"sol_crate_drop_rate\",\n21\t  \"sol_crate_pool_pct\",\n22\t  \"sol_crate_min_value\",\n23\t  \"points_crate_min\",\n24\t  \"points_crate_max\",\n25\t  \"daily_challenge_count\",\n26\t  \"weekly_challenge_count\",\n27\t]);\n28\t\n29\t// ---------------------------------------------------------------------------\n30\t// Route factory\n31\t// ---------------------------------------------------------------------------\n32\t\n33\texport interface AdminRoutesDeps {\n34\t  db: Db;\n35\t  adminApiKey: string;\n36\t}\n37\t\n38\texport function createAdminRoutes(deps: AdminRoutesDeps) {\n39\t  const { db, adminApiKey } = deps;\n40\t  const app = new Hono();\n41\t\n42\t  // Admin auth middleware — all routes in this sub-router require X-Admin-Key\n43\t  app.use(\"*\", async (c, next) => {\n44\t    const key = c.req.header(\"X-Admin-Key\");\n45\t    if (!key || key !== adminApiKey) {\n46\t      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n47\t    }\n48\t    await next();\n49\t  });\n50\t\n51\t  // GET /reward-config — all config key-value pairs\n52\t  app.get(\"/reward-config\", async (c) => {\n53\t    const rows = await db.rawSql<{ key: string; value: string; updated_at: string }[]>`\n54\t      SELECT key, value, updated_at FROM reward_config ORDER BY key ASC\n55\t    `;\n56\t    const config: Record<string, { value: string; updatedAt: string }> = {};\n57\t    for (const row of rows) {\n58\t      config[row.key] = { value: row.value, updatedAt: row.updated_at };\n59\t    }\n60\t    return c.json(config);\n61\t  });\n62\t\n63\t  // PUT /reward-config/:key — update a single config value\n64\t  app.put(\"/reward-config/:key\", async (c) => {\n65\t    const key = c.req.param(\"key\");\n66\t\n67\t    if (!VALID_CONFIG_KEYS.has(key)) {\n68\t      return c.json({ error: \"INVALID_KEY\", message: `Unknown config key: ${key}` }, 400);\n69\t    }\n70\t\n71\t    const body = await c.req.json<{ value?: string }>();\n72\t    if (body.value === undefined || body.value === null) {\n73\t      return c.json({ error: \"MISSING_VALUE\", message: \"Request body must include 'value'\" }, 400);\n74\t    }\n75\t\n76\t    await db.rawSql`\n77\t      UPDATE reward_config\n78\t      SET value = ${String(body.value)}, updated_at = now()\n79\t      WHERE key = ${key}\n80\t    `;\n81\t\n82\t    return c.json({ key, value: String(body.value) });\n83\t  });\n84\t\n85\t  // GET /reward-pool — current pool state\n86\t  app.get(\"/reward-pool\", async (c) => {\n87\t    const rows = await db.rawSql<{\n88\t      balance_lamports: string;\n89\t      lifetime_funded: string;\n90\t      lifetime_paid: string;\n91\t      updated_at: string;\n92\t    }[]>`\n93\t      SELECT balance_lamports, lifetime_funded, lifetime_paid, updated_at\n94\t      FROM reward_pool WHERE id = 1\n95\t    `;\n96\t    if (rows.length === 0) {\n97\t      return c.json({ error: \"NOT_FOUND\", message: \"Reward pool not initialized\" }, 500);\n98\t    }\n99\t    const pool = rows[0]!;\n100\t    return c.json({\n101\t      balanceLamports: pool.balance_lamports,\n102\t      lifetimeFunded: pool.lifetime_funded,\n103\t      lifetimePaid: pool.lifetime_paid,\n104\t      updatedAt: pool.updated_at,\n105\t    });\n106\t  });\n107\t\n108\t  // -------------------------------------------------------------------------\n109\t  // Campaign CRUD\n110\t  // -------------------------------------------------------------------------\n111\t\n112\t  const VALID_CAMPAIGN_TYPES = new Set([\"daily\", \"weekly\", \"onboarding\", \"dogpile\"]);\n113\t\n114\t  // POST /campaigns — create a campaign\n115\t  app.post(\"/campaigns\", async (c) => {\n116\t    const body = await c.req.json<{\n117\t      name?: string;\n118\t      campaignType?: string;\n119\t      startsAt?: string | null;\n120\t      endsAt?: string | null;"}]},"parent_tool_use_id":null,"session_id":"65481a30-264b-4bb6-adb8-38c4f155c171","uuid":"c84a9d4a-4c37-487f-b1c5-fc11783230b5","timestamp":"2026-04-26T19:12:43.554Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/src/routes/admin.ts","content":"/**\n * Admin API routes — reward config, reward pool, campaign/challenge CRUD,\n * and admin-level management.\n *\n * All routes require X-Admin-Key header matching ADMIN_API_KEY env var.\n */\n\nimport { Hono } from \"hono\";\nimport type { Db } from \"../db.js\";\n\n// ---------------------------------------------------------------------------\n// Known config keys — reject unknown keys with 400\n// ---------------------------------------------------------------------------\n\nconst VALID_CONFIG_KEYS = new Set([\n  \"points_per_dollar\",\n  \"dogpile_default_multiplier\",\n  \"reward_pool_fee_share\",\n  \"points_crate_drop_rate\",\n  \"sol_crate_drop_rate\",\n  \"sol_crate_pool_pct\",\n  \"sol_crate_min_value\",\n  \"points_crate_min\",\n  \"points_crate_max\",\n  \"daily_challenge_count\",\n  \"weekly_challenge_count\",\n]);\n\n// ---------------------------------------------------------------------------\n// Route factory\n// ---------------------------------------------------------------------------\n\nexport interface AdminRoutesDeps {\n  db: Db;\n  adminApiKey: string;\n}\n\nexport function createAdminRoutes(deps: AdminRoutesDeps) {\n  const { db, adminApiKey } = deps;\n  const app = new Hono();\n\n  // Admin auth middleware — all routes in this sub-router require X-Admin-Key\n  app.use(\"*\", async (c, next) => {\n    const key = c.req.header(\"X-Admin-Key\");\n    if (!key || key !== adminApiKey) {\n      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n    }\n    await next();\n  });\n\n  // GET /reward-config — all config key-value pairs\n  app.get(\"/reward-config\", async (c) => {\n    const rows = await db.rawSql<{ key: string; value: string; updated_at: string }[]>`\n      SELECT key, value, updated_at FROM reward_config ORDER BY key ASC\n    `;\n    const config: Record<string, { value: string; updatedAt: string }> = {};\n    for (const row of rows) {\n      config[row.key] = { value: row.value, updatedAt: row.updated_at };\n    }\n    return c.json(config);\n  });\n\n  // PUT /reward-config/:key — update a single config value\n  app.put(\"/reward-config/:key\", async (c) => {\n    const key = c.req.param(\"key\");\n\n    if (!VALID_CONFIG_KEYS.has(key)) {\n      return c.json({ error: \"INVALID_KEY\", message: `Unknown config key: ${key}` }, 400);\n    }\n\n    const body = await c.req.json<{ value?: string }>();\n    if (body.value === undefined || body.value === null) {\n      return c.json({ error: \"MISSING_VALUE\", message: \"Request body must include 'value'\" }, 400);\n    }\n\n    await db.rawSql`\n      UPDATE reward_config\n      SET value = ${String(body.value)}, updated_at = now()\n      WHERE key = ${key}\n    `;\n\n    return c.json({ key, value: String(body.value) });\n  });\n\n  // GET /reward-pool — current pool state\n  app.get(\"/reward-pool\", async (c) => {\n    const rows = await db.rawSql<{\n      balance_lamports: string;\n      lifetime_funded: string;\n      lifetime_paid: string;\n      updated_at: string;\n    }[]>`\n      SELECT balance_lamports, lifetime_funded, lifetime_paid, updated_at\n      FROM reward_pool WHERE id = 1\n    `;\n    if (rows.length === 0) {\n      return c.json({ error: \"NOT_FOUND\", message: \"Reward pool not initialized\" }, 500);\n    }\n    const pool = rows[0]!;\n    return c.json({\n      balanceLamports: pool.balance_lamports,\n      lifetimeFunded: pool.lifetime_funded,\n      lifetimePaid: pool.lifetime_paid,\n      updatedAt: pool.updated_at,\n    });\n  });\n\n  // -------------------------------------------------------------------------\n  // Campaign CRUD\n  // -------------------------------------------------------------------------\n\n  const VALID_CAMPAIGN_TYPES = new Set([\"daily\", \"weekly\", \"onboarding\", \"dogpile\"]);\n\n  // POST /campaigns — create a campaign\n  app.post(\"/campaigns\", async (c) => {\n    const body = await c.req.json<{\n      name?: string;\n      campaignType?: string;\n      startsAt?: string | null;\n      endsAt?: string | null;","numLines":120,"startLine":1,"totalLines":580}}}
