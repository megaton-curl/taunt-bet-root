eout\",\n    });\n    expect(filters).toEqual({\n      status: \"pending\",\n      userId: \"u-1\",\n      minAmountLamports: \"1000\",\n      maxAmountLamports: \"5000\",\n      requestedFrom: \"2026-04-01\",\n      requestedTo: \"2026-04-25\",\n      txSignature: \"5VfYDnXUcS6mWY3cQy4ipcM5LQqM\",\n      errorContains: \"timeout\",\n    });\n  });\n\n  it(\"status whitelist: rejects unknown values and collapses to null\", () => {\n    const filters = normalizeReferralClaimFiltersFromSearchParams({\n      claimStatus: \"not-a-real-status\",\n    });\n    expect(filters.status).toBeNull();\n  });\n\n  it(\"status whitelist: accepts every published claim status including the failed alias\", () => {\n    for (const status of PEEK_REFERRAL_CLAIM_STATUSES) {\n      const filters = normalizeReferralClaimFiltersFromSearchParams({\n        claimStatus: status,\n      });\n      expect(filters.status).toBe(status);\n    }\n  });\n\n  it(\"array search-params: take the first value (Next.js may parse repeated params as arrays)\", () => {\n    const filters = normalizeReferralClaimFiltersFromSearchParams({\n      claimStatus: [\"pending\", \"completed\"],\n      claimUserId: [\"u-1\", \"u-2\"],\n    });\n    expect(filters.status).toBe(\"pending\");\n    expect(filters.userId).toBe(\"u-1\");\n  });\n\n  it(\"undefined values: treat as missing input\", () => {\n    const filters = normalizeReferralClaimFiltersFromSearchParams({\n      claimStatus: undefined,\n      claimUserId: undefined,\n    });\n    expect(filters.status).toBeNull();\n    expect(filters.userId).toBeNull();\n  });\n});\n","numLines":102,"startLine":1,"totalLines":102}}}
