{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017MxkmLZjwGHbjAaQ6PXA7U","type":"tool_result","content":"1\t// URL-addressable rounds filter bar for /games/[game] (FR-8, FR-4).\n2\t//\n3\t// Submits to the same page so filters are shareable. The shape switches on the\n4\t// game id: FlipYou + Pot Shot share the `rounds` table phases and the four\n5\t// stuck-state booleans (`stuckAged`, `stuckAttempts`, `stuckNoTx`,\n6\t// `stuckRefunds`); Close Call replaces `stuckAttempts` with an `outcome`\n7\t// dropdown and uses three stuck flags because `closecall_rounds` has no\n8\t// `settle_attempts` column.\n9\timport type { CSSProperties } from \"react\";\n10\timport {\n11\t  PEEK_CLOSECALL_OUTCOMES,\n12\t  PEEK_CLOSECALL_PHASES,\n13\t  PEEK_ROUND_PHASES,\n14\t  type PeekCloseCallRoundFilters,\n15\t  type PeekGameId,\n16\t  type PeekRoundFilters,\n17\t} from \"../lib/types/peek\";\n18\t\n19\texport type GameRoundsFilterBarProps =\n20\t  | {\n21\t      game: \"flipyou\" | \"potshot\";\n22\t      filters: PeekRoundFilters;\n23\t      action: string;\n24\t    }\n25\t  | {\n26\t      game: \"closecall\";\n27\t      filters: PeekCloseCallRoundFilters;\n28\t      action: string;\n29\t    };\n30\t\n31\texport function GameRoundsFilterBar(props: GameRoundsFilterBarProps) {\n32\t  const { game, action, filters } = props;\n33\t  const isCloseCall = game === \"closecall\";\n34\t\n35\t  return (\n36\t    <form\n37\t      action={action}\n38\t      method=\"get\"\n39\t      role=\"search\"\n40\t      aria-label={`Filter ${labelForGame(game)} rounds`}\n41\t      style={formStyle}\n42\t    >\n43\t      <label style={fieldStyle}>\n44\t        <span>Phase</span>\n45\t        <select\n46\t          name=\"phase\"\n47\t          defaultValue={filters.phase ?? \"\"}\n48\t          style={inputStyle}\n49\t        >\n50\t          <option value=\"\">Any</option>\n51\t          {(isCloseCall ? PEEK_CLOSECALL_PHASES : PEEK_ROUND_PHASES).map(\n52\t            (phase) => (\n53\t              <option key={phase} value={phase}>\n54\t                {phase}\n55\t              </option>\n56\t            ),\n57\t          )}\n58\t        </select>\n59\t      </label>\n60\t\n61\t      {isCloseCall ? (\n62\t        <label style={fieldStyle}>\n63\t          <span>Outcome</span>\n64\t          <select\n65\t            name=\"outcome\"\n66\t            defaultValue={\n67\t              (filters as PeekCloseCallRoundFilters).outcome ?? \"\"\n68\t            }\n69\t            style={inputStyle}\n70\t          >\n71\t            <option value=\"\">Any</option>\n72\t            {PEEK_CLOSECALL_OUTCOMES.map((outcome) => (\n73\t              <option key={outcome} value={outcome}>\n74\t                {outcome}\n75\t              </option>\n76\t            ))}\n77\t          </select>\n78\t        </label>\n79\t      ) : null}\n80\t\n81\t      <label style={fieldStyle}>\n82\t        <span>Search</span>\n83\t        <input\n84\t          name=\"search\"\n85\t          type=\"text\"\n86\t          defaultValue={filters.search ?? \"\"}\n87\t          placeholder={\n88\t            isCloseCall ? \"pda or round id\" : \"pda, match id, or creator\"\n89\t          }\n90\t          style={inputStyle}\n91\t        />\n92\t      </label>\n93\t\n94\t      <label style={fieldStyle}>\n95\t        <span>Created from</span>\n96\t        <input\n97\t          name=\"fromDate\"\n98\t          type=\"date\"\n99\t          defaultValue={(filters.fromDate ?? \"\").slice(0, 10)}\n100\t          style={inputStyle}\n101\t        />\n102\t      </label>\n103\t\n104\t      <label style={fieldStyle}>\n105\t        <span>Created to</span>\n106\t        <input\n107\t          name=\"toDate\"\n108\t          type=\"date\"\n109\t          defaultValue={(filters.toDate ?? \"\").slice(0, 10)}\n110\t          style={inputStyle}\n111\t        />\n112\t      </label>\n113\t\n114\t      <fieldset style={fieldsetStyle}>\n115\t        <legend style={legendStyle}>Stuck-state filters</le