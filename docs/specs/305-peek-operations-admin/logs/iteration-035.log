{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GSGoBDMi3ZJuJ27NRyJWGE","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport type { Sql } from \"postgres\";\n3\timport { getGamesOverview } from \"../get-games-overview\";\n4\timport {\n5\t  PEEK_GAME_IDS,\n6\t  PEEK_GAME_OVERVIEW_METRIC_IDS,\n7\t  type PeekGameId,\n8\t} from \"../../../../lib/types/peek\";\n9\t\n10\ttype SqlCall = {\n11\t  text: string;\n12\t  values: ReadonlyArray<unknown>;\n13\t};\n14\t\n15\ttype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n16\t\n17\ttype SqlMock = {\n18\t  sql: Sql;\n19\t  calls: ReadonlyArray<SqlCall>;\n20\t};\n21\t\n22\t// SQL mock that tracks every tagged-template call and returns a queued\n23\t// response per call (rows or an Error to reject). Mirrors the pattern used in\n24\t// get-growth-referrals.test.ts and get-command-center-attention.test.ts so the\n25\t// query test surface stays consistent.\n26\tfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n27\t  const calls: SqlCall[] = [];\n28\t  let cursor = 0;\n29\t\n30\t  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n31\t    const text = [...strings].join(\"?\");\n32\t    calls.push({ text, values: [...values] });\n33\t    const next = responses[cursor++];\n34\t    if (next instanceof Error) return Promise.reject(next);\n35\t    return Promise.resolve(next ?? []);\n36\t  };\n37\t\n38\t  const sql = fn as unknown as Sql;\n39\t  return { sql, calls };\n40\t}\n41\t\n42\t// Two queries fire in parallel via Promise.all:\n43\t//   0 — per-game GROUP BY aggregate over `game_entries`\n44\t//   1 — platform-wide DISTINCT user_id count\n45\t\n46\tdescribe(\"getGamesOverview\", () => {\n47\t  it(\"populated: builds per-game rows + 6-metric strip with FR-4 bookkeeping for every advertised id\", async () => {\n48\t    const aggregates = [\n49\t      {\n50\t        game: \"flipyou\" as PeekGameId,\n51\t        entries: 10,\n52\t        unique_users: 7,\n53\t        wagered_lamports: \"2500000000\",\n54\t        settled_entries: 8,\n55\t        refund_entries: 1,\n56\t        payout_lamports: \"1500000000\",\n57\t        wins: 4,\n58\t        losses: 3,\n59\t      },\n60\t      {\n61\t        game: \"potshot\" as PeekGameId,\n62\t        entries: 5,\n63\t        unique_users: 3,\n64\t        wagered_lamports: \"1000000000\",\n65\t        settled_entries: 5,\n66\t        refund_entries: 0,\n67\t        payout_lamports: \"900000000\",\n68\t        wins: 2,\n69\t        losses: 3,\n70\t      },\n71\t      {\n72\t        game: \"closecall\" as PeekGameId,\n73\t        entries: 12,\n74\t        unique_users: 9,\n75\t        wagered_lamports: \"4000000000\",\n76\t        settled_entries: 11,\n77\t        refund_entries: 2,\n78\t        payout_lamports: \"3500000000\",\n79\t        wins: 5,\n80\t        losses: 4,\n81\t      },\n82\t    ];\n83\t    const mock = createSqlMock([aggregates, [{ value: 14 }]]);\n84\t    const now = new Date(\"2026-04-25T12:00:00.000Z\");\n85\t\n86\t    const result = await getGamesOverview({ sql: mock.sql, now });\n87\t\n88\t    expect(result.generatedAt).toBe(\"2026-04-25T12:00:00.000Z\");\n89\t\n90\t    // Per-game rows: stable order matching PEEK_GAME_IDS.\n91\t    expect(result.perGame.map((r) => r.game)).toEqual(PEEK_GAME_IDS);\n92\t    const flipyou = result.perGame.find((r) => r.game === \"flipyou\");\n93\t    expect(flipyou).toMatchObject({\n94\t      entries: 10,\n95\t      uniqueUsers: 7,\n96\t      wageredLamports: \"2500000000\",\n97\t      settledEntries: 8,\n98\t      refundEntries: 1,\n99\t      payoutLamports: \"1500000000\",\n100\t      wins: 4,\n101\t      losses: 3,\n102\t    });\n103\t\n104\t    // Metrics: every advertised PeekGameOverviewMetricId emitted with FR-4\n105\t    // bookkeeping (label, definition, source, windowLabel, asOf, freshness,\n106\t    // drilldownHref).\n107\t    expect(result.metrics).toHaveLength(6);\n108\t    const emittedIds = result.metrics.map((m) => m.id);\n109\t    expect(emittedIds).toEqual([...PEEK_GAME_OVERVIEW_METRIC_IDS]);\n110\t    for (const metric of result.metrics) {\n111\t      expect(metric.asOf).toBe(\"2026-04-25T12:00:00.000Z\");\n112\t      expect(metric.freshness).toBe(\"live\");\n113\t      expect(metric.label.length).toBeGreaterThan(0);\n114\t      expect(metric.definition.length).toBeGreaterThan(0);\n115\t      expect(metric.source).toBe(\"game_entries\");\n116\t      expect(metric.windowLabel).toBe(\"All time\");\n117\t      expect(metric.drilldownHref).toBe(\"/games\");\n118\t    }\n119\t\n120\t    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n121\t    expect(byId.get(\"games.total_entries\")?.value).toBe(27);\n122\t    expect(byId.get(\"games.total_entries\")?.valueDisplay).toBe(\"27\");\n123\t\n124\t    // Unique-players metric reads the platform-wide DISTINCT count, NOT the\n125\t    // sum of per-game distincts (would double-count cross-game players).\n126\t    expect(byId.get(\"games.unique_users\")?.value).toBe(14);\n127\t    expect(byId.get(\"games.unique_users\")?.valueDisplay).toBe(\"14\");\n128\t\n129\t    // Lamport totals: BigInt sum across games preserves u64 precision and\n130\t    // displays with thousands separators.\n131\t    expect(byId.get(\"games.wagered_lamports\")?.value).toBe(\"7500000000\");\n132\t    expect(byId.get(\"games.wagered_lamports\")?.valueDisplay).toBe(\n133\t      \"7,500,000,000\",\n134\t    );\n135\t    expect(byId.get(\"games.payout_lamports\")?.value).toBe(\"5900000000\");\n136\t    expect(byId.get(\"games.payout_lamports\")?.valueDisplay).toBe(\n137\t      \"5,900,000,000\",\n138\t    );\n139\t    expect(byId.get(\"games.settled_entries\")?.value).toBe(24);\n140\t    expect(byId.get(\"games.refund_entries\")?.value).toBe(3);\n141\t    expect(byId.get(\"games.refund_entries\")?.unit).toBe(\"entries\");\n142\t\n143\t    // SQL was emitted twice in parallel (per-game aggregate + DISTINCT count).\n144\t    expect(mock.calls).toHaveLength(2);\n145\t    expect(mock.calls[0].text).toContain(\"from game_entries\");\n146\t    expect(mock.calls[0].text).toContain(\"group by game\");\n147\t    expect(mock.calls[0].text).toContain(\n148\t      \"count(*) filter (where settled_at is not null and is_winner is null)\",\n149\t    );\n150\t    expect(mock.calls[1].text).toContain(\"count(distinct user_id)\");\n151\t  });\n152\t\n153\t  it(\"sparse (no rows): zero-fills every PEEK_GAME_ID and emits zeroed metrics rather than dropping the strip\", async () => {\n154\t    const mock = createSqlMock([[], [{ value: 0 }]]);\n155\t    const now = new Date(\"2026-04-25T12:00:00.000Z\");\n156\t\n157\t    const result = await getGamesOverview({ sql: mock.sql, now });\n158\t\n159\t    expect(result.perGame.map((r) => r.game)).toEqual(PEEK_GAME_IDS);\n160\t    for (const row of result.perGame) {\n161\t      expect(row.entries).toBe(0);\n162\t      expect(row.uniqueUsers).toBe(0);\n163\t      expect(row.wageredLamports).toBe(\"0\");\n164\t      expect(row.settledEntries).toBe(0);\n165\t      expect(row.refundEntries).toBe(0);\n166\t      expect(row.payoutLamports).toBe(\"0\");\n167\t      expect(row.wins).toBe(0);\n168\t      expect(row.losses).toBe(0);\n169\t    }\n170\t\n171\t    expect(result.metrics).toHaveLength(6);\n172\t    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n173\t    expect(byId.get(\"games.total_entries\")?.value).toBe(0);\n174\t    expect(byId.get(\"games.total_entries\")?.valueDisplay).toBe(\"0\");\n175\t    expect(byId.get(\"games.unique_users\")?.value).toBe(0);\n176\t    expect(byId.get(\"games.wagered_lamports\")?.value).toBe(\"0\");\n177\t    expect(byId.get(\"games.wagered_lamports\")?.valueDisplay).toBe(\"0\");\n178\t    expect(byId.get(\"games.payout_lamports\")?.value).toBe(\"0\");\n179\t  });\n180\t\n181\t  it(\"sparse (one game only): zero-fills missing games while preserving the populated row\", async () => {\n182\t    const mock = createSqlMock([\n183\t      [\n184\t        {\n185\t          game: \"potshot\" as PeekGameId,\n186\t          entries: 3,\n187\t          unique_users: 2,\n188\t          wagered_lamports: \"500\",\n189\t          settled_entries: 2,\n190\t          refund_entries: 0,\n191\t          payout_lamports: \"400\",\n192\t          wins: 1,\n193\t          losses: 1,\n194\t        },\n195\t      ],\n196\t      [{ value: 2 }],\n197\t    ]);\n198\t\n199\t    const result = await getGamesOverview({ sql: mock.sql });\n200\t\n201\t    const byGame = new Map(result.perGame.map((r) => [r.game, r]));\n202\t    expect(byGame.get(\"flipyou\")?.entries).toBe(0);\n203\t    expect(byGame.get(\"flipyou\")?.wageredLamports).toBe(\"0\");\n204\t    expect(byGame.get(\"potshot\")?.entries).toBe(3);\n205\t    expect(byGame.get(\"potshot\")?.wageredLamports).toBe(\"500\");\n206\t    expect(byGame.get(\"closecall\")?.entries).toBe(0);\n207\t    expect(byGame.get(\"closecall\")?.payoutLamports).toBe(\"0\");\n208\t\n209\t    const totalEntries = result.metrics.find(\n210\t      (m) => m.id === \"games.total_entries\",\n211\t    );\n212\t    expect(totalEntries?.value).toBe(3);\n213\t    const wagered = result.metrics.find(\n214\t      (m) => m.id === \"games.wagered_lamports\",\n215\t    );\n216\t    expect(wagered?.value).toBe(\"500\");\n217\t  });\n218\t\n219\t  it(\"string count coercion: postgres ::text counts convert to numbers\", async () => {\n220\t    const mock = createSqlMock([\n221\t      [\n222\t        {\n223\t          game: \"flipyou\" as PeekGameId,\n224\t          entries: \"9\",\n225\t          unique_users: \"7\",\n226\t          wagered_lamports: \"100\",\n227\t          settled_entries: \"5\",\n228\t          refund_entries: \"1\",\n229\t          payout_lamports: \"80\",\n230\t          wins: \"3\",\n231\t          losses: \"1\",\n232\t        },\n233\t      ],\n234\t      [{ value: \"7\" }],\n235\t    ]);\n236\t\n237\t    const result = await getGamesOverview(