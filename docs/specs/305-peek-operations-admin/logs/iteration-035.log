{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HqMFrxbJmtKfc1k9ffjZF8","type":"tool_result","content":"1\t// URL-addressable filter params for /games/[game] (FR-8).\n2\t//\n3\t// Mirrors the engine `PeekRoundFilters` (FlipYou + Pot Shot) and\n4\t// `PeekCloseCallRoundFilters` (Close Call) shapes and normalises raw\n5\t// search-param input the page receives from Next.js. Empty / whitespace-only\n6\t// values normalise to `null` so the engine query skips them.\n7\t\n8\timport {\n9\t  PEEK_CLOSECALL_OUTCOMES,\n10\t  PEEK_CLOSECALL_PHASES,\n11\t  PEEK_ROUND_PHASES,\n12\t  type PeekCloseCallOutcome,\n13\t  type PeekCloseCallPhase,\n14\t  type PeekCloseCallRoundFilters,\n15\t  type PeekCloseCallRoundStuckFilters,\n16\t  type PeekRoundFilters,\n17\t  type PeekRoundPhase,\n18\t  type PeekRoundStuckFilters,\n19\t} from \"./types/peek\";\n20\t\n21\texport const PEEK_ROUNDS_DEFAULT_PAGE_SIZE = 50;\n22\t\n23\tfunction readSingleValue(value: string | string[] | undefined): string {\n24\t  return Array.isArray(value) ? value[0] ?? \"\" : value ?? \"\";\n25\t}\n26\t\n27\tfunction trimOrNull(value: string): string | null {\n28\t  const trimmed = value.trim();\n29\t  return trimmed.length > 0 ? trimmed : null;\n30\t}\n31\t\n32\tfunction readBoolean(value: string | string[] | undefined): boolean {\n33\t  const raw = readSingleValue(value).trim().toLowerCase();\n34\t  return raw === \"1\" || raw === \"true\" || raw === \"on\" || raw === \"yes\";\n35\t}\n36\t\n37\tfunction readPage(value: string | string[] | undefined): number {\n38\t  const raw = trimOrNull(readSingleValue(value));\n39\t  if (!raw) return 1;\n40\t  const parsed = Number.parseInt(raw, 10);\n41\t  return Number.isFinite(parsed) && parsed > 0 ? parsed : 1;\n42\t}\n43\t\n44\texport function normalizeRoundFiltersFromSearchParams(\n45\t  input: Record<string, string | string[] | undefined>,\n46\t): PeekRoundFilters {\n47\t  const phaseRaw = trimOrNull(readSingleValue(input.phase));\n48\t  const stuck: PeekRoundStuckFilters = {\n49\t    nonterminalAged: readBoolean(input.stuckAged),\n50\t    highAttempts: readBoolean(input.stuckAttempts),\n51\t    settledWithoutTx: readBoolean(input.stuckNoTx),\n52\t    refunds: readBoolean(input.stuckRefunds),\n53\t  };\n54\t  return {\n55\t    phase:\n56\t      phaseRaw &&\n57\t      (PEEK_ROUND_PHASES as ReadonlyArray<string>).includes(phaseRaw)\n58\t        ? (phaseRaw as PeekRoundPhase)\n59\t        : null,\n60\t    search: trimOrNull(readSingleValue(input.search)),\n61\t    fromDate: trimOrNull(readSingleValue(input.fromDate)),\n62\t    toDate: trimOrNull(readSingleValue(input.toDate)),\n63\t    stuck,\n64\t  };\n65\t}\n66\t\n67\texport function normalizeCloseCallRoundFiltersFromSearchParams(\n68\t  input: Record<string, string | string[] | undefined>,\n69\t): PeekCloseCallRoundFilters {\n70\t  const phaseRaw = trimOrNull(readSingleValue(input.phase));\n71\t  const outcomeRaw = trimOrNull(readSingleValue(input.outcome));\n72\t  const stuck: PeekCloseCallRoundStuckFilters = {\n73\t    nonterminalAged: readBoolean(input.stuckAged),\n74\t    settledWithoutTx: readBoolean(input.stuckNoTx),\n75\t    refunds: readBoolean(input.stuckRefunds),\n76\t  };\n77\t  return {\n78\t    phase:\n79\t      phaseRaw &&\n80\t      (PEEK_CLOSECALL_PHASES as ReadonlyArray<string>).includes(phaseRaw)\n81\t        ? (phaseRaw as PeekCloseCallPhase)\n82\t        : null,\n83\t    outcome:\n84\t      outcomeRaw &&\n85\t      (PEEK_CLOSECALL_OUTCOMES as ReadonlyArray<string>).includes(outcomeRaw)\n86\t        ? (outcomeRaw as PeekCloseCallOutcome)\n87\t        : null,\n88\t    search: trimOrNull(readSingleValue(input.search)),\n89\t    fromDate: trimOrNull(readSingleValue(input.fromDate)),\n90\t    toDate: trimOrNull(readSingleValue(input.toDate)),\n91\t    stuck,\n92\t  };\n93\t}\n94\t\n95\texport function readPageFromSearchParams(\n96\t  input: Record<string, string | string[] | undefined>,\n97\t): number {\n98\t  return readPage(input.page);\n99\t}\n100\t\n101\t// Builds a query string for pagination links, preserving the active filters so\n102\t// page navigation does not silently drop the operator's filter state.\n103\texport function buildRoundsQueryString(\n104\t  raw: Record<string, string | string[] | undefined>,\n105\t  override: { page?: number },\n106\t): string {\n107\t  const params = new URLSearchParams();\n108\t  const passthrough = [\n109\t    \"phase\",\n110\t    \"outcome\",\n111\t    \"search\",\n112\t    \"fromDate\",\n113\t    \"toDate\",\n114\t    \"stuckAged\",\n115\t    \"stuckAttempts\",\n116\t    \"stuckNoTx\",\n117\t    \"stuckRefunds\",\n118\t  ] as const;\n119\t  for (const key of passthrough) {\n120\t    const value = trimOrNull(readSingleValue(raw[key]));\n121\t    if (value) params.set(key, value);\n122\t  }\n123\t  if (override.page && override.page > 1) {\n124\t    params.set(\"page\", String(override.page));\n125\t  }\n126\t  return params.toString();\n127\t}\n128\t"}]},"parent_tool_use_id":null,"session_id":"dd0a8c11-be59-4445-8284-6991f0652708","uuid":"cc44ddd5-4a99-4900-a663-bdc7da24a885","timestamp":"2026-04-25T13:12:39.992Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/games-search-params.ts","content":"// URL-addressable filter params for /games/[game] (FR-8).\n//\n// Mirrors the engine `PeekRoundFilters` (FlipYou + Pot Shot) and\n// `PeekCloseCallRoundFilters` (Close Call) shapes and normalises raw\n// search-param input the page receives from Next.js. Empty / whitespace-only\n// values normalise to `null` so the engine query skips them.\n\nimport {\n  PEEK_CLOSECALL_OUTCOMES,\n  PEEK_CLOSECALL_PHASES,\n  PEEK_ROUND_PHASES,\n  type PeekCloseCallOutcome,\n  type PeekCloseCallPhase,\n  type PeekCloseCallRoundFilters,\n  type PeekCloseCallRoundStuckFilters,\n  type PeekRoundFilters,\n  type PeekRoundPhase,\n  type PeekRoundStuckFilters,\n} from \"./types/peek\";\n\nexport const PEEK_ROUNDS_DEFAULT_PAGE_SIZE = 50;\n\nfunction readSingleValue(value: string | string[] | undefined): string {\n  return Array.isArray(value) ? value[0] ?? \"\" : value ?? \"\";\n}\n\nfunction trimOrNull(value: string): string | null {\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nfunction readBoolean(value: string | string[] | undefined): boolean {\n  const raw = readSingleValue(value).trim().toLowerCase();\n  return raw === \"1\" || raw === \"true\" || raw === \"on\" || raw === \"yes\";\n}\n\nfunction readPage(value: string | string[] | undefined): number {\n  const raw = trimOrNull(readSingleValue(value));\n  if (!raw) return 1;\n  const parsed = Number.parseInt(raw, 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : 1;\n}\n\nexport function normalizeRoundFiltersFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): PeekRoundFilters {\n  const phaseRaw = trimOrNull(readSingleValue(input.phase));\n  const stuck: PeekRoundStuckFilters = {\n    nonterminalAged: readBoolean(input.stuckAged),\n    highAttempts: readBoolean(input.stuckAttempts),\n    settledWithoutTx: readBoolean(input.stuckNoTx),\n    refunds: readBoolean(input.stuckRefunds),\n  };\n  return {\n    phase:\n      phaseRaw &&\n      (PEEK_ROUND_PHASES as ReadonlyArray<string>).includes(phaseRaw)\n        ? (phaseRaw as PeekRoundPhase)\n        : null,\n    search: trimOrNull(readSingleValue(input.search)),\n    fromDate: trimOrNull(readSingleValue(input.fromDate)),\n    toDate: trimOrNull(readSingleValue(input.toDate)),\n    stuck,\n  };\n}\n\nexport function normalizeCloseCallRoundFiltersFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): PeekCloseCallRoundFilters {\n  const phaseRaw = trimOrNull(readSingleValue(input.phase));\n  const outcomeRaw = trimOrNull(readSingleValue(input.outcome));\n  const stuck: PeekCloseCallRoundStuckFilters = {\n    nonterminalAged: readBoolean(input.stuckAged),\n    settledWithoutTx: readBoolean(input.stuckNoTx),\n    refunds: readBoolean(input.stuckRefunds),\n  };\n  return {\n    phase:\n      phaseRaw &&\n      (PEEK_CLOSECALL_PHASES as ReadonlyArray<string>).includes(phaseRaw)\n        ? (phaseRaw as PeekCloseCallPhase)\n        : null,\n    outcome:\n      outcomeRaw &&\n      (PEEK_CLOSECALL_OUTCOMES as ReadonlyArray<string>).includes(outcomeRaw)\n        ? (outcomeRaw as PeekCloseCallOutcome)\n        : null,\n    search: trimOrNull(readSingleValue(input.search)),\n    fromDate: trimOrNull(readSingleValue(input.fromDate)),\n    toDate: trimOrNull(readSingleValue(input.toDate)),\n    stuck,\n  };\n}\n\nexport function readPageFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): number {\n  return readPage(input.page);\n}\n\n// Builds a query string for pagination links, preserving the active filters so\n// page navigation does not silently drop the operator's filter state.\nexport function buildRoundsQueryString(\n  raw: Record<string, string | string[] | undefined>,\n  override: { page?: number },\n): string {\n  const params = new URLSearchParams();\n  const passthrough = [\n    \"phase\",\n    \"outcome\",\n    \"search\",\n    \"fromDate\",\n    \"toDate\",\n    \"stuckAged\",\n    \"stuckAttempts\",\n    \"stuckNoTx\",\n    \"stuckRefunds\",\n  ] as const;\n  for (const key of passthrough) {\n    const value = trimOrNull(readSingleValue(raw[key]));\n    if (value) params.set(key, value);\n  }\n  if (override.page && override.page > 1) {\n    params.set(\"page\", String(override.page));\n  }\n  return params.toString();\n}\n","numLines":128,"startLine":1,"totalLines":128}}}
