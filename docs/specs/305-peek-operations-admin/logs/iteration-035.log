{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PJkgvRP81x8HauJBiAm5xD","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport {\n3\t  PEEK_REFERRAL_CLAIM_STATUSES,\n4\t  normalizeReferralClaimFiltersFromSearchParams,\n5\t} from \"../growth-search-params\";\n6\t\n7\tdescribe(\"normalizeReferralClaimFiltersFromSearchParams\", () => {\n8\t  it(\"empty input: every filter normalises to null\", () => {\n9\t    const filters = normalizeReferralClaimFiltersFromSearchParams({});\n10\t    expect(filters).toEqual({\n11\t      status: null,\n12\t      userId: null,\n13\t      minAmountLamports: null,\n14\t      maxAmountLamports: null,\n15\t      requestedFrom: null,\n16\t      requestedTo: null,\n17\t      txSignature: null,\n18\t      errorContains: null,\n19\t    });\n20\t  });\n21\t\n22\t  it(\"whitespace-only values normalise to null\", () => {\n23\t    const filters = normalizeReferralClaimFiltersFromSearchParams({\n24\t      claimStatus: \"   \",\n25\t      claimUserId: \"   \",\n26\t      claimMinAmount: \"   \",\n27\t      claimMaxAmount: \"   \",\n28\t      claimRequestedFrom: \"   \",\n29\t      claimRequestedTo: \"   \",\n30\t      claimTxSignature: \"   \",\n31\t      claimError: \"   \",\n32\t    });\n33\t    expect(filters).toEqual({\n34\t      status: null,\n35\t      userId: null,\n36\t      minAmountLamports: null,\n37\t      maxAmountLamports: null,\n38\t      requestedFrom: null,\n39\t      requestedTo: null,\n40\t      txSignature: null,\n41\t      errorContains: null,\n42\t    });\n43\t  });\n44\t\n45\t  it(\"populated input: trims values and forwards them through to engine filter shape\", () => {\n46\t    const filters = normalizeReferralClaimFiltersFromSearchParams({\n47\t      claimStatus: \"pending\",\n48\t      claimUserId: \"  u-1 \",\n49\t      claimMinAmount: \" 1000 \",\n50\t      claimMaxAmount: \" 5000 \",\n51\t      claimRequestedFrom: \" 2026-04-01 \",\n52\t      claimRequest