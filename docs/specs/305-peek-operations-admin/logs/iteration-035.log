FilterBar\n        game=\"flipyou\"\n        filters={EMPTY_ROUND_FILTERS}\n        action=\"/games/flipyou\"\n      />,\n    );\n\n    const form = screen.getByRole(\"search\", {\n      name: \"Filter FlipYou rounds\",\n    });\n    expect(form).toHaveAttribute(\"action\", \"/games/flipyou\");\n    expect(form).toHaveAttribute(\"method\", \"get\");\n\n    const phaseSelect = screen.getByLabelText(\"Phase\") as HTMLSelectElement;\n    expect(phaseSelect.value).toBe(\"\");\n    const phaseOptions = Array.from(phaseSelect.options).map((o) => o.value);\n    for (const phase of PEEK_ROUND_PHASES) {\n      expect(phaseOptions).toContain(phase);\n    }\n\n    expect((screen.getByLabelText(\"Search\") as HTMLInputElement).value).toBe(\n      \"\",\n    );\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"\");\n\n    // Stuck-state checkboxes render unchecked.\n    const stuckAged = screen.getByLabelText(\n      \"Nonterminal & aged\",\n    ) as HTMLInputElement;\n    const stuckAttempts = screen.getByLabelText(\n      \"High settle attempts\",\n    ) as HTMLInputElement;\n    const stuckNoTx = screen.getByLabelText(\n      \"Settled without tx\",\n    ) as HTMLInputElement;\n    const stuckRefunds = screen.getByLabelText(\"Refunds\") as HTMLInputElement;\n    expect(stuckAged.checked).toBe(false);\n    expect(stuckAttempts.checked).toBe(false);\n    expect(stuckNoTx.checked).toBe(false);\n    expect(stuckRefunds.checked).toBe(false);\n  });\n\n  it(\"FlipYou: outcome dropdown is NOT rendered (rounds table has no Pyth outcome)\", () => {\n    render(\n      <GameRoundsFilterBar\n        game=\"flipyou\"\n        filters={EMPTY_ROUND_FILTERS}\n        action=\"/games/flipyou\"\n      />,\n    );\n    expect(screen.queryByLabelText(\"Outcome\")).toBeNull();\n  });\n\n  it(\"populated: every FlipYou filter value is reflected in its input\", () => {\n    render(\n      <GameRoundsFilterBar\n        game=\"flipyou\"\n        filters={POPULATED_ROUND_FILTERS}\n        action=\"/games/flipyou\"\n      />,\n    );\n\n    expect((screen.getByLabelText(\"Phase\") as HTMLSelectElement).value).toBe(\n      \"settling\",\n    );\n    expect((screen.getByLabelText(\"Search\") as HTMLInputElement).value).toBe(\n      \"abc\",\n    );\n    expect(\n      (screen.getByLabelText(\"Created from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Created to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-25\");\n    expect(\n      (screen.getByLabelText(\"Nonterminal & aged\") as HTMLInputElement)\n        .checked,\n    ).toBe(true);\n    expect(\n      (screen.getByLabelText(\"High settle attempts\") as HTMLInputElement)\n        .checked,\n    ).toBe(true);\n    expect(\n      (screen.getByLabelText(\"Settled without tx\") as HTMLInputElement)\n        .checked,\n    ).toBe(false);\n    expect(\n      (screen.getByLabelText(\"Refunds\") as HTMLInputElement).checked,\n    ).toBe(false);\n  });\n\n  it(\"Pot Shot: form aria-label uses the Pot Shot human label\", () => {\n    render(\n      <GameRoundsFilterBar\n        game=\"potshot\"\n        filters={EMPTY_ROUND_FILTERS}\n        action=\"/games/potshot\"\n      />,\n    );\n    expect(\n      screen.getByRole(\"search\", { name: \"Filter Pot Shot rounds\" }),\n    ).toBeInTheDocument();\n    // High settle attempts checkbox still renders for Pot Shot (it shares the\n    // `rounds` table with FlipYou).\n    expect(screen.getByLabelText(\"High settle attempts\")).toBeInTheDocument();\n  });\n\n  it(\"input names align with normalizeRoundFiltersFromSearchParams\", () => {\n    render(\n      <GameRoundsFilterBar\n        game=\"flipyou\"\n        filters={EMPTY_ROUND_FILTERS}\n        action=\"/games/flipyou\"\n      />,\n    );\n    expect(screen.getByLabelText(\"Phase\")).toHaveAttribute(\"name\", \"phase\");\n    expect(screen.getByLabelText(\"Search\")).toHaveAttribute(\"name\", \"search\");\n    expect(screen.getByLabelText(\"Created from\")).toHaveAttribute(\n      \"name\",\n      \"fromDate\",\n    );\n    expect(screen.getByLabelText(\"Created to\")).toHaveAttribute(\n      \"name\",\n      \"toDate\",\n    );\n    expect(screen.getByLabelText(\"Nonterminal & aged\")).toHaveAttribute(\n      \"name\",\n      \"stuckAged\",\n    );\n    expect(screen.getByLabelText(\"High settle attempts\")).toHaveAttribute(\n      \"name\",\n      \"stuckAttempts\",\n    );\n    expect(screen.getByLabelText(\"Settled without tx\")).toHaveAttribute(\n      \"name\",\n      \"stuckNoTx\",\n    );\n    expect(screen.getByLabelText(\"Refunds\")).toHaveAttribute(\n      \"name\",\n      \"stuckRefunds\",\n    );\n  });\n});\n\ndescribe(\"GameRoundsFilterBar (Close Call)\", () => {\n  it(\"empty: form submits to the supplied action with method=GET and renders Close Call inputs blank\", () => {\n    render(\n      <GameRoundsFilterBar\n        game=\"closecall\"\n        filters={EMPTY_CC_FILTERS}\n        action=\"/games/closecall\"\n      />,\n    );\n\n    const form = screen.getByRole(\"search\", {\n      name: \"Filter Close Call rounds\",\n    });\n    expect(form).toHaveAttribute(\"action\", \"/games/closecall\");\n\n    const phaseSelect = screen.getByLabelText(\"Phase\") as HTMLSelectElement;\n    const phaseOptions = Array.from(phaseSelect.options).map((o) => o.value);\n    for (const phase of PEEK_CLOSECALL_PHASES) {\n      expect(phaseOptions).toContain(phase);\n    }\n\n    const outcomeSelect = screen.getByLabelText(\n      \"Outcome\",\n    ) as HTMLSelectElement;\n    expect(outcomeSelect.value).toBe(\"\");\n    const outcomeOptions = Array.from(outcomeSelect.options).map(\n      (o) => o.value,\n    );\n    for (const outcome of PEEK_CLOSECALL_OUTCOMES) {\n      expect(outcomeOptions).toContain(outcome);\n    }\n  });\n\n  it(\"Close Call: HIGH-SETTLE-ATTEMPTS checkbox is NOT rendered (closecall_rounds has no settle_attempts column)\", () => {\n    render(\n      <GameRoundsFilterBar\n        game=\"closecall\"\n        filters={EMPTY_CC_FILTERS}\n        action=\"/games/closecall\"\n      />,\n    );\n    expect(screen.queryByLabelText(\"High settle attempts\")).toBeNull();\n\n    // The other three stuck flags still render.\n    expect(screen.getByLabelText(\"Nonterminal & aged\")).toBeInTheDocument();\n    expect(screen.getByLabelText(\"Settled without tx\")).toBeInTheDocument();\n    expect(screen.getByLabelText(\"Refunds\")).toBeInTheDocument();\n  });\n\n  it(\"populated: every Close Call filter value is reflected in its input\", () => {\n    render(\n      <GameRoundsFilterBar\n        game=\"closecall\"\n        filters={POPULATED_CC_FILTERS}\n        action=\"/games/closecall\"\n      />,\n    );\n\n    expect((screen.getByLabelText(\"Phase\") as HTMLSelectElement).value).toBe(\n      \"settled\",\n    );\n    expect((screen.getByLabelText(\"Outcome\") as HTMLSelectElement).value).toBe(\n      \"refund\",\n    );\n    expect((screen.getByLabelText(\"Search\") as HTMLInputElement).value).toBe(\n      \"rd-1\",\n    );\n    expect(\n      (screen.getByLabelText(\"Settled without tx\") as HTMLInputElement)\n        .checked,\n    ).toBe(true);\n    expect(\n      (screen.getByLabelText(\"Refunds\") as HTMLInputElement).checked,\n    ).toBe(true);\n  });\n\n  it(\"Close Call: outcome input name is `outcome` to align with the search-params normaliser\", () => {\n    render(\n      <GameRoundsFilterBar\n        game=\"closecall\"\n        filters={EMPTY_CC_FILTERS}\n        action=\"/games/closecall\"\n      />,\n    );\n    expect(screen.getByLabelText(\"Outcome\")).toHaveAttribute(\n      \"name\",\n      \"outcome\",\n    );\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2524,"cache_read_in