{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01S3QgkdxNKPZz9STcbm3r6B","type":"tool_result","content":"1\t// Per-game round queries (FR-8).\n2\t//\n3\t// Backs `/games/[game]` for FlipYou, Pot Shot, and Close Call.\n4\t//\n5\t// FlipYou + Pot Shot share the `rounds` table (migration 001) and the\n6\t// commit-reveal lifecycle (`created` -> `locked` -> `settling` -> `settled`\n7\t// or `expired`). Close Call uses the separate `closecall_rounds` table\n8\t// (migration 004) with its own `open` -> `settled`/`refunded` lifecycle and\n9\t// a Pyth-driven `outcome` column.\n10\t//\n11\t// Stuck-state filters cover the four operational signals from FR-8:\n12\t//\n13\t//   - nonterminalAged   — phase is in a non-terminal state for longer than\n14\t//                         the configured age threshold (created/locked/\n15\t//                         settling for FlipYou+Pot Shot; open for Close\n16\t//                         Call).\n17\t//   - highAttempts      — settle_attempts above the configured threshold\n18\t//                         (FlipYou+Pot Shot only — `closecall_rounds` has no\n19\t//                         `settle_attempts` column).\n20\t//   - settledWithoutTx  — round is settled but no payout/refund row exists\n21\t//                         in `transactions` for the round's match_id +\n22\t//                         game; the on-chain settlement step did not\n23\t//                         produce the expected ledger record.\n24\t//   - refunds           — phase reflects the refund terminal state\n25\t//                         (`expired` for FlipYou+Pot Shot; `refunded` or\n26\t//                         outcome `refund` for Close Call).\n27\t//\n28\t// Queries are bounded server-side via clamped page size and an explicit\n29\t// total-count query; lamport / u64 sums round-trip as `text` to preserve\n30\t// precision.\n31\t\n32\timport type { Sql } from \"postgres\";\n33\timport {\n34\t  PEEK_ROUNDS_GAME_IDS,\n35\t  type PeekCloseCallOutcome,\n36\t  type PeekCloseCallPhase,\n37\t  type PeekCloseCallRoundFilters,\n38\t  type PeekCloseCallRoundRow,\n39\t  type PeekCloseCallRoundStuckFilters,\n40\t  type PeekPagination,\n41\t  type PeekRoundFilters,\n42\t  type PeekRoundPhase,\n43\t  type PeekRoundRow,\n44\t  type PeekRoundStuckFilters,\n45\t  type PeekRoundsGameId,\n46\t  type PeekRoundsListResult,\n47\t} from \"../../../lib/types/peek\";\n48\timport { getSqlClient } from \"../client\";\n49\t\n50\texport const PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE = 50;\n51\texport const PEEK_GAME_ROUNDS_MAX_PAGE_SIZE = 250;\n52\t\n53\texport type RoundStuckThresholds = {\n54\t  ageMinutes: number;\n55\t  maxSettleAttempts: number;\n56\t};\n57\t\n58\texport const PEEK_ROUND_STUCK_DEFAULTS: RoundStuckThresholds = {\n59\t  ageMinutes: 5,\n60\t  maxSettleAttempts: 3,\n61\t};\n62\t\n63\texport type ListRoundsOptions = {\n64\t  sql?: Sql;\n65\t  game: PeekRoundsGameId;\n66\t  filters?: Partial<PeekRoundFilters>;\n67\t  page?: number;\n68\t  pageSize?: number;\n69\t  thresholds?: Partial<RoundStuckThresholds>;\n70\t};\n71\t\n72\texport type ListCloseCallRoundsOptions = {\n73\t  sql?: Sql;\n74\t  filters?: Partial<PeekCloseCallRoundFilters>;\n75\t  page?: number;\n76\t  pageSize?: number;\n77\t  thresholds?: Partial<RoundStuckThresholds>;\n78\t};\n79\t\n80\tconst EMPTY_STUCK_FILTERS: PeekRoundStuckFilters = {\n81\t  nonterminalAged: false,\n82\t  highAttempts: false,\n83\t  settledWithoutTx: false,\n84\t  refunds: false,\n85\t};\n86\t\n87\tconst EMPTY_CC_STUCK_FILTERS: PeekCloseCallRoundStuckFilters = {\n88\t  nonterminalAged: false,\n89\t  settledWithoutTx: false,\n90\t  refunds: false,\n91\t};\n92\t\n93\tfunction clampPage(value: number | undefined): number {\n94\t  if (typeof value !== \"number\" || !Number.isFinite(value)) return 1;\n95\t  const floored = Math.floor(value);\n96\t  return floored < 1 ? 1 : floored;\n97\t}\n98\t\n99\tfunction clampPageSize(value: number | undefined): number {\n100\t  if (typeof value !== \"number\" || !Number.isFinite(value)) {\n101\t    return PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE;\n102\t  }\n103\t  const floored = Math.floor(value);\n104\t  if (floored <= 0) return 1;\n105\t  return Math.min(PEEK_GAME_ROUNDS_MAX_PAGE_SIZE, floored);\n106\t}\n107\t\n108\tfunction readInt(value: number | string | null | undefined): number {\n109\t  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n110\t  if (typeof value === \"string\") {\n111\t    const parsed = Number.parseInt(value, 10);\n112\t    return Number.isFinite(parsed) ? parsed : 0;\n113\t  }\n114\t  return 0;\n115\t}\n116\t\n117\tfunction buildPagination(\n118\t  page: number,\n119\t  pageSize: number,\n120\t  totalCount: number,\n121\t): PeekPagination {\n122\t  const totalPages = totalCount === 0 ? 1 : Math.ceil(totalCount / pageSize);\n123\t  return { page, pageSize, totalCount, totalPages };\n124\t}\n125\t\n126\tfunction isPeekRoundsGameId(value: string): value is PeekRoundsGameId {\n127\t  return (PEEK_ROUNDS_GAME_IDS as ReadonlyArray<string>).includes(value);\n128\t}\n129\t\n130\t// ---------- FlipYou + Pot Shot -----------------------------------------------\n131\t\n132\ttype RawRoundRow = {\n133\t  pda: string;\n134\t  game: string;\n135\t  matchId: string;\n136\t  phase: string;\n137\t  creator: string;\n138\t  targetSlot: string | null;\n139\t  settleAttempts: number | string;\n140\t  settleTx: string | null;\n141\t  resultSide: number | string | null;\n142\t  winner: string | null;\n143\t  amountLamports: string;\n144\t  createdAt: string;\n145\t  updatedAt: string;\n146\t  settledAt: string | null;\n147\t};\n148\t\n149\tfunction normalizeRoundRow(row: RawRoundRow): PeekRoundRow | null {\n150\t  if (!isPeekRoundsGameId(row.game)) return null;\n151\t  return {\n152\t    game: row.game,\n153\t    pda: row.pda,\n154\t    matchId: row.matchId,\n155\t    phase: row.phase as PeekRoundPhase,\n156\t    creator: row.creator,\n157\t    targetSlot: row.targetSlot,\n158\t    settleAttempts: readInt(row.settleAttempts),\n159\t    settleTx: row.settleTx,\n160\t    resultSide:\n161\t      row.resultSide === null || row.resultSide === undefined\n162\t        ? null\n163\t        : readInt(row.resultSide),\n164\t    winner: row.winner,\n165\t    amountLamports:\n166\t      typeof row.amountLamports === \"string\" ? row.amountLamports : \"0\",\n167\t    createdAt: row.createdAt,\n168\t    updatedAt: row.updatedAt,\n169\t    settledAt: row.settledAt,\n170\t  };\n171\t}\n172\t\n173\texport async function listRounds(\n174\t  options: ListRoundsOptions,\n175\t): Promise<PeekRoundsListResult<PeekRoundRow>> {\n176\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n177\t  const game = options.game;\n178\t  const page = clampPage(options.page);\n179\t  const pageSize = clampPageSize(options.pageSize);\n180\t  const offset = (page - 1) * pageSize;\n181\t  const thresholds: RoundStuckThresholds = {\n182\t    ...PEEK_ROUND_STUCK_DEFAULTS,\n183\t    ...options.thresholds,\n184\t  };\n185\t  const ageInterval = `${thresholds.ageMinutes} minutes`;\n186\t\n187\t  const filters = options.filters ?? {};\n188\t  const phase = filters.phase ?? null;\n189\t  const search = filters.search?.trim() || null;\n190\t  const searchLike = search ? `%${search}%` : null;\n191\t  const fromDate = filters.fromDate?.trim() || null;\n192\t  const toDate = filters.toDate?.trim() || null;\n193\t  const stuck: PeekRoundStuckFilters = {\n194\t    ...EMPTY_STUCK_FILTERS,\n195\t    ...filters.stuck,\n196\t  };\n197\t\n198\t  // The four stuck flags are OR'd together so an operator can stack any\n199\t  // combination without writing four separate queries. When none of the\n200\t  // flags are set, the predicate disappears (`true`).\n201\t  const anyStuck =\n202\t    stuck.nonterminalAged ||\n203\t    stuck.highAttempts ||\n204\t    stuck.settledWithoutTx ||\n205\t    stuck.refunds;\n206\t\n207\t  const [rows, countRows] = await Promise.all([\n208\t    sql<RawRoundRow[]>`\n209\t      select\n210\t        r.pda as \"pda\",\n211\t        r.game as \"game\",\n212\t        r.match_id as \"matchId\",\n213\t        r.phase as \"phase\",\n214\t        r.creator as \"creator\",\n215\t        r.target_slot::text as \"targetSlot\",\n216\t        r.settle_attempts as \"settleAttempts\",\n217\t        r.settle_tx as \"settleTx\",\n218\t        r.result_side as \"resultSide\",\n219\t        r.winner as \"winner\",\n220\t        r.amount_lamports::text as \"amountLamports\",\n221\t        r.created_at::text as \"createdAt\",\n222\t        r.updated_at::text as \"updatedAt\",\n223\t        r.settled_at::text as \"settledAt\"\n224\t      from rounds r\n225\t      where r.game = ${game}\n226\t        and (${phase === null} or r.phase = ${phase ?? \"\"})\n227\t        and (\n228\t          ${searchLike === null}\n229\t          or r.pda ilike ${searchLike ?? \"\"}\n230\t          or r.match_id ilike ${searchLike ?? \"\"}\n231\t          or r.creator ilike ${searchLike ?? \"\"}\n232\t        )\n233\t        and (${fromDate === null} or r.created_at >= ${fromDate ?? \"\"}::timestamptz)\n234\t        and (${toDate === null} or r.created_at < ${toDate ?? \"\"}::timestamptz)\n235\t        and (\n236\t          ${!anyStuck}\n237\t          or (\n238\t            (${stuck.nonterminalAged} and r.phase in ('created','locked','settling') and r.created_at < now() - ${ageInterval}::interval)\n239\t            or (${stuck.highAttempts} and r.settle_attempts > ${thresholds.maxSettleAttempts})\n240\t            or (${stuck.settledWithoutTx} and r.phase = 'settled' and not exists (\n241\t              select 1 from transactions t\n242\t              where t.game = r.game\n243\t                and t.match_id = r.match_id\n244\t                and t.tx_type in ('payout','refund')\n245\t            ))\n246\t            or (${stuck.refunds} and r.phase = 'expired')\n247\t          )\n248\t        )\n249\t      order by r.created_at desc, r.pda asc\n250\t      limit ${pageSize} offset ${offset}\n251\t    `,\n252\t    sql<Array<{ value: number | string }>>`\n253\t      select count(*)::int as \"value\"\n254\t      from rounds r\n255\t      where r.game = ${game}\n256\t        and (${phase === null} or r.phase = ${phase ?? \"\"})\n257\t        and (\n258\t          ${searchLike === null}\n259\t          or r.pda ilike ${searchLike ?? \"\"}\n260\t          or r.match_id ilike ${searchLike ?? \"\"}\n261\t          or r.creator ilike ${searchLike ?? \"\"}\n262\t        )\n263\t        and (${fromDate === null} or r.created_at >= ${fromDate ?? \"\"}::timestamptz)\n264\t        and (${toDate === null} or r.created_at < ${toDate ?? \"\"}::timestamptz)\n265\t        and (\n266\t          ${!anyStuck}\n267\t          or (\n268\t            (${stuck.nonterminalAged} and r.phase in ('created','locked','settling') and r.created_at < now() - ${ageInterval}::interval)\n269\t            or (${stuck.highAttempts} and r.settle_attempts > ${thresholds.maxSettleAttempts})\n270\t            or (${stuck.settledWithoutTx} and r.phase = 'settled' and not exists (\n271\t              select 1 from transactions t\n272\t              where t.game = r.game\n273\t                and t.match_id = r.match_id\n274\t                and t.tx_type in ('payout','refund')\n275\t            ))\n276\t            or (${stuck.refunds} and r.phase = 'expired')\n277\t          )\n278\t        )\n279\t    `,\n280\t  ]);\n281\t\n282\t  const normalized: PeekRoundRow[] = [];\n283\t  for (const row of rows) {\n284\t    const r = normalizeRoundRow(row);\n285\t    if (r) normalized.push(r);\n286\t  }\n287\t\n288\t  const totalCount = readInt(countRows[0]?.value);\n289\t  return {\n290\t    rows: normalized,\n291\t    pagination: buildPagination(page, pageSize, totalCount),\n292\t  };\n293\t}\n294\t\n295\t// ---------- Close Call -------------------------------------------------------\n296\t\n297\ttype RawCloseCallRoundRow = {\n298\t  pda: string;\n299\t  roundId: string;\n300\t  phase: string;\n301\t  outcome: string;\n302\t  openPrice: string;\n303\t  openPriceExpo: number | string;\n304\t  closePrice: string | null;\n305\t  greenPoolLamports: string;\n306\t  redPoolLamports: string;\n307\t  totalFeeLamports: string;\n308\t  settleTx: string | null;\n309\t  createdAt: string;\n310\t  settledAt: string | null;\n311\t};\n312\t\n313\tfunction normalizeCloseCallRow(\n314\t  row: RawCloseCallRoundRow,\n315\t): PeekCloseCallRoundRow {\n316\t  return {\n317\t    pda: row.pda,\n318\t    roundId: row.roundId,\n319\t    phase: row.phase as PeekCloseCallPhase,\n320\t    outcome: row.outcome as PeekCloseCallOutcome,\n321\t    openPrice: typeof row.openPrice === \"string\" ? row.openPrice : \"0\",\n322\t    openPriceExpo: readInt(row.openPriceExpo),\n323\t    closePrice: row.closePrice,\n324\t    greenPoolLamports:\n325\t      typeof row.greenPoolLamports === \"string\" ? row.greenPoolLamports : \"0\",\n326\t    redPoolLamports:\n327\t      typeof row.redPoolLamports === \"string\" ? row.redPoolLamports : \"0\",\n328\t    totalFeeLamports:\n329\t      typeof row.totalFeeLamports === \"string\" ? row.totalFeeLamports : \"0\",\n330\t    settleTx: row.settleTx,\n331\t    createdAt: row.createdAt,\n332\t    settledAt: row.settledAt,\n333\t  };\n334\t}\n335\t\n336\texport async function listCloseCallRounds(\n337\t  options: ListCloseCallRoundsOptions = {},\n338\t): Promise<PeekRoundsListResult<PeekCloseCallRoundRow>> {\n339\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n340\t  const page = clampPage(options.page);\n341\t  const pageSize = clampPageSize(options.pageSize);\n342\t  const offset = (page - 1) * pageSize;\n343\t  const thresholds: RoundStuckThresholds = {\n344\t    ...PEEK_ROUND_STUCK_DEFAULTS,\n345\t    ...options.thresholds,\n346\t  };\n347\t  const ageInterval = `${thresholds.ageMinutes} minutes`;\n348\t\n349\t  const filters = options.filters ?? {};\n350\t  const phase = filters.phase ?? null;\n351\t  const outcome = filters.outcome ?? null;\n352\t  const search = filters.search?.trim() || null;\n353\t  const searchLike = search ? `%${search}%` : null;\n354\t  const fromDate = filters.fromDate?.trim() || null;\n355\t  const toDate = filters.toDate?.trim() || null;\n356\t  const stuck: PeekCloseCallRoundStuckFilters = {\n357\t    ...EMPTY_CC_STUCK_FILTERS,\n358\t    ...filters.stuck,\n359\t  };\n360\t\n361\t  const anyStuck =\n362\t    stuck.nonterminalAged || stuck.settledWithoutTx || stuck.refunds;\n363\t\n364\t  const [rows, countRows] = await Promise.all([\n365\t    sql<RawCloseCallRoundRow[]>`\n366\t      select\n367\t        cc.pda as \"pda\",\n368\t        cc.round_id as \"roundId\",\n369\t        cc.phase as \"phase\",\n370\t        cc.outcome as \"outcome\",\n371\t        cc.open_price::text as \"openPrice\",\n372\t        cc.open_price_expo as \"openPriceExpo\",\n373\t        cc.close_price::text as \"closePrice\",\n374\t        cc.green_pool::text as \"greenPoolLamports\",\n375\t        cc.red_pool::text as \"redPoolLamports\",\n376\t        cc.total_fee::text as \"totalFeeLamports\",\n377\t        cc.settle_tx as \"settleTx\",\n378\t        cc.created_at::text as \"createdAt\",\n379\t        cc.settled_at::text as \"settledAt\"\n380\t      from closecall_rounds cc\n381\t      where (${phase === null} or cc.phase = ${phase ?? \"\"})\n382\t        and (${outcome === null} or cc.outcome = ${outcome ?? \"\"})\n383\t        and (\n384\t          ${searchLike === null}\n385\t          or cc.pda ilike ${searchLike ?? \"\"}\n386\t          or cc.round_id ilike ${searchLike ?? \"\"}\n387\t        )\n388\t        and (${fromDate === null} or cc.created_at >= ${fromDate ?? \"\"}::timestamptz)\n389\t        and (${toDate === null} or cc.created_at < ${toDate ?? \"\"}::timestamptz)\n390\t        and (\n391\t          ${!anyStuck}\n392\t          or (\n393\t            (${stuck.nonterminalAged} and cc.phase = 'open' and cc.created_at < now() - ${ageInterval}::interval)\n394\t            or (${stuck.settledWithoutTx} and cc.phase = 'settled' and not exists (\n395\t              select 1 from transactions t\n396\t              where t.game = 'closecall'\n397\t                and t.match_id = cc.round_id\n398\t                and t.tx_type in ('payout','refund')\n399\t            ))\n400\t            or (${stuck.refunds} and (cc.phase = 'refunded' or cc.outcome = 'refund'))\n401\t          )\n402\t        )\n403\t      order by cc.created_at desc, cc.pda asc\n404\t      limit ${pageSize} offset ${offset}\n405\t    `,\n406\t    sql<Array<{ value: number | string }>>`\n407\t      select count(*)::int as \"value\"\n408\t      from closecall_rounds cc\n409\t      where (${phase === null} or cc.phase = ${phase ?? \"\"})\n410\t        and (${outcome === null} or cc.outcome = ${outcome ?? \"\"})\n411\t        and (\n412\t          ${searchLike === null}\n413\t          or cc.pda ilike ${searchLike ?? \"\"}\n414\t          or cc.round_id ilike ${searchLike ?? \"\"}\n415\t        )\n416\t        and (${fromDate === null} or cc.created_at >= ${fromDate ?? \"\"}::timestamptz)\n417\t        and (${toDate === null} or cc.created_at < ${toDate ?? \"\"}::timestamptz)\n418\t        and (\n419\t          ${!anyStuck}\n420\t          or (\n421\t            (${stuck.nonterminalAged} and cc.phase = 'open' and cc.created_at < now() - ${ageInterval}::interval)\n422\t            or (${stuck.settledWithoutTx} and cc.phase = 'settled' and not exists (\n423\t              select 1 from transactions t\n424\t              where t.game = 'closecall'\n425\t                and t.match_id = cc.round_id\n426\t                and t.tx_type in ('payout','refund')\n427\t            ))\n428\t            or (${stuck.refunds} and (cc.phase = 'refunded' or cc.outcome = 'refund'))\n429\t          )\n430\t        )\n431\t    `,\n432\t  ]);\n433\t\n434\t  const normalized = rows.map(normalizeCloseCallRow);\n435\t  const totalCount = readInt(countRows[0]?.value);\n436\t\n437\t  return {\n438\t    rows: normalized,\n439\t    pagination: buildPagination(page, pageSize, totalCount),\n440\t  };\n441\t}\n442\t"}]},"parent_tool_use_id":null,"session_id":"dd0a8c11-be59-4445-8284-6991f0652708","uuid":"613ed79f-0bca-4451-b32c-e05f06267a0a","timestamp":"2026-04-25T13:12:09.300Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-game-rounds.ts","content":"// Per-game round queries (FR-8).\n//\n// Backs `/games/[game]` for FlipYou, Pot Shot, and Close Call.\n//\n// FlipYou + Pot Shot share the `rounds` table (migration 001) and the\n// commit-reveal lifecycle (`created` -> `locked` -> `settling` -> `settled`\n// or `expired`). Close Call uses the separate `closecall_rounds` table\n// (migration 004) with its own `open` -> `settled`/`refunded` lifecycle and\n// a Pyth-driven `outcome` column.\n//\n// Stuck-state filters cover the four operational signals from FR-8:\n//\n//   - nonterminalAged   — phase is in a non-terminal state for longer than\n//                         the configured age threshold (created/locked/\n//                         settling for FlipYou+Pot Shot; open for Close\n//                         Call).\n//   - highAttempts      — settle_attempts above the configured threshold\n//                         (FlipYou+Pot Shot only — `closecall_rounds` has no\n//                         `settle_attempts` column).\n//   - settledWithoutTx  — round is settled but no payout/refund row exists\n//                         in `transactions` for the round's match_id +\n//                         game; the on-chain settlement step did not\n//                         produce the expected ledger record.\n//   - refunds           — phase reflects the refund terminal state\n//                         (`expired` for FlipYou+Pot Shot; `refunded` or\n//                         outcome `refund` for Close Call).\n//\n// Queries are bounded server-side via clamped page size and an explicit\n// total-count query; lamport / u64 sums round-trip as `text` to preserve\n// precision.\n\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_ROUNDS_GAME_IDS,\n  type PeekCloseCallOutcome,\n  type PeekCloseCallPhase,\n  type PeekCloseCallRoundFilters,\n  type PeekCloseCallRoundRow,\n  type PeekCloseCallRoundStuckFilters,\n  type PeekPagination,\n  type PeekRoundFilters,\n  type PeekRoundPhase,\n  type PeekRoundRow,\n  type PeekRoundStuckFilters,\n  type PeekRoundsGameId,\n  type PeekRoundsListResult,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE = 50;\nexport const PEEK_GAME_ROUNDS_MAX_PAGE_SIZE = 250;\n\nexport type RoundStuckThresholds = {\n  ageMinutes: number;\n  maxSettleAttempts: number;\n};\n\nexport const PEEK_ROUND_STUCK_DEFAULTS: RoundStuckThresholds = {\n  ageMinutes: 5,\n  maxSettleAttempts: 3,\n};\n\nexport type ListRoundsOptions = {\n  sql?: Sql;\n  game: PeekRoundsGameId;\n  filters?: Partial<PeekRoundFilters>;\n  page?: number;\n  pageSize?: number;\n  thresholds?: Partial<RoundStuckThresholds>;\n};\n\nexport type ListCloseCallRoundsOptions = {\n  sql?: Sql;\n  filters?: Partial<PeekCloseCallRoundFilters>;\n  page?: number;\n  pageSize?: number;\n  thresholds?: Partial<RoundStuckThresholds>;\n};\n\nconst EMPTY_STUCK_FILTERS: PeekRoundStuckFilters = {\n  nonterminalAged: false,\n  highAttempts: false,\n  settledWithoutTx: false,\n  refunds: false,\n};\n\nconst EMPTY_CC_STUCK_FILTERS: PeekCloseCallRoundStuckFilters = {\n  nonterminalAged: false,\n  settledWithoutTx: false,\n  refunds: false,\n};\n\nfunction clampPage(value: number | undefined): number {\n  if (typeof value !== \"number\" || !Number.isFinite(value)) return 1;\n  const floored = Math.floor(value);\n  return floored < 1 ? 1 : floored;\n}\n\nfunction clampPageSize(value: number | undefined): number {\n  if (typeof value !== \"number\" || !Number.isFinite(value)) {\n    return PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE;\n  }\n  const floored = Math.floor(value);\n  if (floored <= 0) return 1;\n  return Math.min(PEEK_GAME_ROUNDS_MAX_PAGE_SIZE, floored);\n}\n\nfunction readInt(value: number | string | null | undefined): number {\n  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n  if (typeof value === \"string\") {\n    const parsed = Number.parseInt(value, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction buildPagination(\n  page: number,\n  pageSize: number,\n  totalCount: number,\n): PeekPagination {\n  const totalPages = totalCount === 0 ? 1 : Math.ceil(totalCount / pageSize);\n  return { page, pageSize, totalCount, totalPages };\n}\n\nfunction isPeekRoundsGameId(value: string): value is PeekRoundsGameId {\n  return (PEEK_ROUNDS_GAME_IDS as ReadonlyArray<string>).includes(value);\n}\n\n// ---------- FlipYou + Pot Shot -----------------------------------------------\n\ntype RawRoundRow = {\n  pda: string;\n  game: string;\n  matchId: string;\n  phase: string;\n  creator: string;\n  targetSlot: string | null;\n  settleAttempts: number | string;\n  settleTx: string | null;\n  resultSide: number | string | null;\n  winner: string | null;\n  amountLamports: string;\n  createdAt: string;\n  updatedAt: string;\n  settledAt: string | null;\n};\n\nfunction normalizeRoundRow(row: RawRoundRow): PeekRoundRow | null {\n  if (!isPeekRoundsGameId(row.game)) return null;\n  return {\n    game: row.game,\n    pda: row.pda,\n    matchId: row.matchId,\n    phase: row.phase as PeekRoundPhase,\n    creator: row.creator,\n    targetSlot: row.targetSlot,\n    settleAttempts: readInt(row.settleAttempts),\n    settleTx: row.settleTx,\n    resultSide:\n      row.resultSide === null || row.resultSide === undefined\n        ? null\n        : readInt(row.resultSide),\n    winner: row.winner,\n    amountLamports:\n      typeof row.amountLamports === \"string\" ? row.amountLamports : \"0\",\n    createdAt: row.createdAt,\n    updatedAt: row.updatedAt,\n    settledAt: row.settledAt,\n  };\n}\n\nexport async function listRounds(\n  options: ListRoundsOptions,\n): Promise<PeekRoundsListResult<PeekRoundRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const game = options.game;\n  const page = clampPage(options.page);\n  const pageSize = clampPageSize(options.pageSize);\n  const offset = (page - 1) * pageSize;\n  const thresholds: RoundStuckThresholds = {\n    ...PEEK_ROUND_STUCK_DEFAULTS,\n    ...options.thresholds,\n  };\n  const ageInterval = `${thresholds.ageMinutes} minutes`;\n\n  const filters = options.filters ?? {};\n  const phase = filters.phase ?? null;\n  const search = filters.search?.trim() || null;\n  const searchLike = search ? `%${search}%` : null;\n  const fromDate = filters.fromDate?.trim() || null;\n  const toDate = filters.toDate?.trim() || null;\n  const stuck: PeekRoundStuckFilters = {\n    ...EMPTY_STUCK_FILTERS,\n    ...filters.stuck,\n  };\n\n  // The four stuck flags are OR'd together so an operator can stack any\n  // combination without writing four separate queries. When none of the\n  // flags are set, the predicate disappears (`true`).\n  const anyStuck =\n    stuck.nonterminalAged ||\n    stuck.highAttempts ||\n    stuck.settledWithoutTx ||\n    stuck.refunds;\n\n  const [rows, countRows] = await Promise.all([\n    sql<RawRoundRow[]>`\n      select\n        r.pda as \"pda\",\n        r.game as \"game\",\n        r.match_id as \"matchId\",\n        r.phase as \"phase\",\n        r.creator as \"creator\",\n        r.target_slot::text as \"targetSlot\",\n        r.settle_attempts as \"settleAttempts\",\n        r.settle_tx as \"settleTx\",\n        r.result_side as \"resultSide\",\n        r.winner as \"winner\",\n        r.amount_lamports::text as \"amountLamports\",\n        r.created_at::text as \"createdAt\",\n        r.updated_at::text as \"updatedAt\",\n        r.settled_at::text as \"settledAt\"\n      from rounds r\n      where r.game = ${game}\n        and (${phase === null} or r.phase = ${phase ?? \"\"})\n        and (\n          ${searchLike === null}\n          or r.pda ilike ${searchLike ?? \"\"}\n          or r.match_id ilike ${searchLike ?? \"\"}\n          or r.creator ilike ${searchLike ?? \"\"}\n        )\n        and (${fromDate === null} or r.created_at >= ${fromDate ?? \"\"}::timestamptz)\n        and (${toDate === null} or r.created_at < ${toDate ?? \"\"}::timestamptz)\n        and (\n          ${!anyStuck}\n          or (\n            (${stuck.nonterminalAged} and r.phase in ('created','locked','settling') and r.created_at < now() - ${ageInterval}::interval)\n            or (${stuck.highAttempts} and r.settle_attempts > ${thresholds.maxSettleAttempts})\n            or (${stuck.settledWithoutTx} and r.phase = 'settled' and not exists (\n              select 1 from transactions t\n              where t.game = r.game\n                and t.match_id = r.match_id\n                and t.tx_type in ('payout','refund')\n            ))\n            or (${stuck.refunds} and r.phase = 'expired')\n          )\n        )\n      order by r.created_at desc, r.pda asc\n      limit ${pageSize} offset ${offset}\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from rounds r\n      where r.game = ${game}\n        and (${phase === null} or r.phase = ${phase ?? \"\"})\n        and (\n          ${searchLike === null}\n          or r.pda ilike ${searchLike ?? \"\"}\n          or r.match_id ilike ${searchLike ?? \"\"}\n          or r.creator ilike ${searchLike ?? \"\"}\n        )\n        and (${fromDate === null} or r.created_at >= ${fromDate ?? \"\"}::timestamptz)\n        and (${toDate === null} or r.created_at < ${toDate ?? \"\"}::timestamptz)\n        and (\n          ${!anyStuck}\n          or (\n            (${stuck.nonterminalAged} and r.phase in ('created','locked','settling') and r.created_at < now() - ${ageInterval}::interval)\n            or (${stuck.highAttempts} and r.settle_attempts > ${thresholds.maxSettleAttempts})\n            or (${stuck.settledWithoutTx} and r.phase = 'settled' and not exists (\n              select 1 from transactions t\n              where t.game = r.game\n                and t.match_id = r.match_id\n                and t.tx_type in ('payout','refund')\n            ))\n            or (${stuck.refunds} and r.phase = 'expired')\n          )\n        )\n    `,\n  ]);\n\n  const normalized: PeekRoundRow[] = [];\n  for (const row of rows) {\n    const r = normalizeRoundRow(row);\n    if (r) normalized.push(r);\n  }\n\n  const totalCount = readInt(countRows[0]?.value);\n  return {\n    rows: normalized,\n    pagination: buildPagination(page, pageSize, totalCount),\n  };\n}\n\n// ---------- Close Call -------------------------------------------------------\n\ntype RawCloseCallRoundRow = {\n  pda: string;\n  roundId: string;\n  phase: string;\n  outcome: string;\n  openPrice: string;\n  openPriceExpo: number | string;\n  closePrice: string | null;\n  greenPoolLamports: string;\n  redPoolLamports: string;\n  totalFeeLamports: string;\n  settleTx: string | null;\n  createdAt: string;\n  settledAt: string | null;\n};\n\nfunction normalizeCloseCallRow(\n  row: RawCloseCallRoundRow,\n): PeekCloseCallRoundRow {\n  return {\n    pda: row.pda,\n    roundId: row.roundId,\n    phase: row.phase as PeekCloseCallPhase,\n    outcome: row.outcome as PeekCloseCallOutcome,\n    openPrice: typeof row.openPrice === \"string\" ? row.openPrice : \"0\",\n    openPriceExpo: readInt(row.openPriceExpo),\n    closePrice: row.closePrice,\n    greenPoolLamports:\n      typeof row.greenPoolLamports === \"string\" ? row.greenPoolLamports : \"0\",\n    redPoolLamports:\n      typeof row.redPoolLamports === \"string\" ? row.redPoolLamports : \"0\",\n    totalFeeLamports:\n      typeof row.totalFeeLamports === \"string\" ? row.totalFeeLamports : \"0\",\n    settleTx: row.settleTx,\n    createdAt: row.createdAt,\n    settledAt: row.settledAt,\n  };\n}\n\nexport async function listCloseCallRounds(\n  options: ListCloseCallRoundsOptions = {},\n): Promise<PeekRoundsListResult<PeekCloseCallRoundRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const page = clampPage(options.page);\n  const pageSize = clampPageSize(options.pageSize);\n  const offset = (page - 1) * pageSize;\n  const thresholds: RoundStuckThresholds = {\n    ...PEEK_ROUND_STUCK_DEFAULTS,\n    ...options.thresholds,\n  };\n  const ageInterval = `${thresholds.ageMinutes} minutes`;\n\n  const filters = options.filters ?? {};\n  const phase = filters.phase ?? null;\n  const outcome = filters.outcome ?? null;\n  const search = filters.search?.trim() || null;\n  const searchLike = search ? `%${search}%` : null;\n  const fromDate = filters.fromDate?.trim() || null;\n  const toDate = filters.toDate?.trim() || null;\n  const stuck: PeekCloseCallRoundStuckFilters = {\n    ...EMPTY_CC_STUCK_FILTERS,\n    ...filters.stuck,\n  };\n\n  const anyStuck =\n    stuck.nonterminalAged || stuck.settledWithoutTx || stuck.refunds;\n\n  const [rows, countRows] = await Promise.all([\n    sql<RawCloseCallRoundRow[]>`\n      select\n        cc.pda as \"pda\",\n        cc.round_id as \"roundId\",\n        cc.phase as \"phase\",\n        cc.outcome as \"outcome\",\n        cc.open_price::text as \"openPrice\",\n        cc.open_price_expo as \"openPriceExpo\",\n        cc.close_price::text as \"closePrice\",\n        cc.green_pool::text as \"greenPoolLamports\",\n        cc.red_pool::text as \"redPoolLamports\",\n        cc.total_fee::text as \"totalFeeLamports\",\n        cc.settle_tx as \"settleTx\",\n        cc.created_at::text as \"createdAt\",\n        cc.settled_at::text as \"settledAt\"\n      from closecall_rounds cc\n      where (${phase === null} or cc.phase = ${phase ?? \"\"})\n        and (${outcome === null} or cc.outcome = ${outcome ?? \"\"})\n        and (\n          ${searchLike === null}\n          or cc.pda ilike ${searchLike ?? \"\"}\n          or cc.round_id ilike ${searchLike ?? \"\"}\n        )\n        and (${fromDate === null} or cc.created_at >= ${fromDate ?? \"\"}::timestamptz)\n        and (${toDate === null} or cc.created_at < ${toDate ?? \"\"}::timestamptz)\n        and (\n          ${!anyStuck}\n          or (\n            (${stuck.nonterminalAged} and cc.phase = 'open' and cc.created_at < now() - ${ageInterval}::interval)\n            or (${stuck.settledWithoutTx} and cc.phase = 'settled' and not exists (\n              select 1 from transactions t\n              where t.game = 'closecall'\n                and t.match_id = cc.round_id\n                and t.tx_type in ('payout','refund')\n            ))\n            or (${stuck.refunds} and (cc.phase = 'refunded' or cc.outcome = 'refund'))\n          )\n        )\n      order by cc.created_at desc, cc.pda asc\n      limit ${pageSize} offset ${offset}\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from closecall_rounds cc\n      where (${phase === null} or cc.phase = ${phase ?? \"\"})\n        and (${outcome === null} or cc.outcome = ${outcome ?? \"\"})\n        and (\n          ${searchLike === null}\n          or cc.pda ilike ${searchLike ?? \"\"}\n          or cc.round_id ilike ${searchLike ?? \"\"}\n        )\n        and (${fromDate === null} or cc.created_at >= ${fromDate ?? \"\"}::timestamptz)\n        and (${toDate === null} or cc.created_at < ${toDate ?? \"\"}::timestamptz)\n        and (\n          ${!anyStuck}\n          or (\n            (${stuck.nonterminalAged} and cc.phase = 'open' and cc.created_at < now() - ${ageInterval}::interval)\n            or (${stuck.settledWithoutTx} and cc.phase = 'settled' and not exists (\n              select 1 from transactions t\n              where t.game = 'closecall'\n                and t.match_id = cc.round_id\n                and t.tx_type in ('payout','refund')\n            ))\n            or (${stuck.refunds} and (cc.phase = 'refunded' or cc.outcome = 'refund'))\n          )\n        )\n    `,\n  ]);\n\n  const normalized = rows.map(normalizeCloseCallRow);\n  const totalCount = readInt(countRows[0]?.value);\n\n  return {\n    rows: normalized,\n    pagination: buildPagination(page, pageSize, totalCount),\n  };\n}\n","numLines":442,"startLine":1,"totalLines":442}}}
