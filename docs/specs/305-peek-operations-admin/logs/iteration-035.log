{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_016JY6HT6q9YKJRrpVqX6qxZ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Gna5LseQADQ7K7Wg981xVk","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-game-rounds.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n  PEEK_GAME_ROUNDS_MAX_PAGE_SIZE,\n  PEEK_ROUND_STUCK_DEFAULTS,\n  listCloseCallRounds,\n  listRounds,\n} from \"../get-game-rounds\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\n// SQL mock that records every tagged-template call and returns a queued\n// response per call (rows or an Error to reject). Mirrors the pattern used in\n// get-games-overview.test.ts and get-growth-referrals.test.ts so query test\n// behaviour stays consistent.\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\n// Two queries fire in parallel via Promise.all per call:\n//   0 — paged rows\n//   1 — count(*) for pagination\n\ndescribe(\"listRounds (FlipYou + Pot Shot)\", () => {\n  it(\"populated: shapes rows for FlipYou with u64 strings preserved end-to-end\", async () => {\n    const flipyouRows = [\n      {\n        pda: \"pda-1\",\n        game: \"flipyou\",\n        matchId: \"m-1\",\n        phase: \"settled\",\n        creator: \"creator-1\",\n        targetSlot: \"1234567890\",\n        settleAttempts: 1,\n        settleTx: \"tx-1\",\n        resultSide: 0,\n        winner: \"creator-1\",\n        amountLamports: \"9007199254740992\", // > Number.MAX_SAFE_INTEGER\n        createdAt: \"2026-04-25T10:00:00.000Z\",\n        updatedAt: \"2026-04-25T10:01:00.000Z\",\n        settledAt: \"2026-04-25T10:00:30.000Z\",\n      },\n      {\n        pda: \"pda-2\",\n        game: \"flipyou\",\n        matchId: \"m-2\",\n        phase: \"expired\",\n        creator: \"creator-2\",\n        targetSlot: null,\n        settleAttempts: 4,\n        settleTx: null,\n        resultSide: null,\n        winner: null,\n        amountLamports: \"100000\",\n        createdAt: \"2026-04-25T09:00:00.000Z\",\n        updatedAt: \"2026-04-25T09:30:00.000Z\",\n        settledAt: null,\n      },\n    ];\n    const mock = createSqlMock([flipyouRows, [{ value: 2 }]]);\n\n    const result = await listRounds({ sql: mock.sql, game: \"flipyou\" });\n\n    expect(result.rows).toHaveLength(2);\n    expect(result.rows[0]).toEqual({\n      game: \"flipyou\",\n      pda: \"pda-1\",\n      matchId: \"m-1\",\n      phase: \"settled\",\n      creator: \"creator-1\",\n      targetSlot: \"1234567890\",\n      settleAttempts: 1,\n      settleTx: \"tx-1\",\n      resultSide: 0,\n      winner: \"creator-1\",\n      amountLamports: \"9007199254740992\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      updatedAt: \"2026-04-25T10:01:00.000Z\",\n      settledAt: \"2026-04-25T10:00:30.000Z\",\n    });\n    // Null-friendly columns survive: targetSlot, settleTx, resultSide, winner, settledAt.\n    expect(result.rows[1].targetSlot).toBeNull();\n    expect(result.rows[1].settleTx).toBeNull();\n    expect(result.rows[1].resultSide).toBeNull();\n    expect(result.rows[1].winner).toBeNull();\n    expect(result.rows[1].settledAt).toBeNull();\n\n    expect(result.pagination).toEqual({\n      page: 1,\n      pageSize: PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n      totalCount: 2,\n      totalPages: 1,\n    });\n\n    // Two queries fired in parallel: rows + count.\n    expect(mock.calls).toHaveLength(2);\n    expect(mock.calls[0].text).toContain(\"from rounds r\");\n    expect(mock.calls[0].text).toContain(\"order by r.created_at desc\");\n    expect(mock.calls[0].text).toContain(\"limit \");\n    expect(mock.calls[0].text).toContain(\" offset \");\n    expect(mock.calls[1].text).toContain(\"count(*)::int\");\n    // Game predicate is bound to the requested game id.\n    expect(mock.calls[0].values).toContain(\"flipyou\");\n    expect(mock.calls[1].values).toContain(\"flipyou\");\n  });\n\n  it(\"works for potshot game id (same SQL, different game predicate)\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          pda: \"pda-ps\",\n          game: \"potshot\",\n          matchId: \"m-ps\",\n          phase: \"created\",\n          creator: \"creator-ps\",\n          targetSlot: \"777\",\n          settleAttempts: 0,\n          settleTx: null,\n          resultSide: null,\n          winner: null,\n          amountLamports: \"5000000\",\n          createdAt: \"2026-04-25T10:00:00.000Z\",\n          updatedAt: \"2026-04-25T10:00:00.000Z\",\n          settledAt: null,\n        },\n      ],\n      [{ value: 1 }],\n    ]);\n\n    const result = await listRounds({ sql: mock.sql, game: \"potshot\" });\n\n    expect(result.rows).toHaveLength(1);\n    expect(result.rows[0].game).toBe(\"potshot\");\n    expect(mock.calls[0].values).toContain(\"potshot\");\n    expect(mock.calls[1].values).toContain(\"potshot\");\n  });\n\n  it(\"filters out rows whose game id is not a member of PEEK_ROUNDS_GAME_IDS so out-of-band data cannot leak\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          pda: \"pda-1\",\n          game: \"flipyou\",\n          matchId: \"m-1\",\n          phase: \"settled\",\n          creator: \"c-1\",\n          targetSlot: null,\n          settleAttempts: 0,\n          settleTx: null,\n          resultSide: null,\n          winner: null,\n          amountLamports: \"0\",\n          createdAt: \"2026-04-25T10:00:00.000Z\",\n          updatedAt: \"2026-04-25T10:00:00.000Z\",\n          settledAt: null,\n        },\n        {\n          // Out-of-band game id (e.g. a future migration row); must not surface.\n          pda: \"pda-bogus\",\n          game: \"crash\",\n          matchId: \"m-bogus\",\n          phase: \"settled\",\n          creator: \"c-bogus\",\n          targetSlot: null,\n          settleAttempts: 0,\n          settleTx: null,\n          resultSide: null,\n          winner: null,\n          amountLamports: \"0\",\n          createdAt: \"2026-04-25T10:00:00.000Z\",\n          updatedAt: \"2026-04-25T10:00:00.000Z\",\n          settledAt: null,\n        },\n      ],\n      [{ value: 2 }],\n    ]);\n\n    const result = await listRounds({ sql: mock.sql, game: \"flipyou\" });\n\n    expect(result.rows.map((r) => r.pda)).toEqual([\"pda-1\"]);\n    expect(result.rows[0].game).toBe(\"flipyou\");\n  });\n\n  it(\"sparse: empty SQL response yields empty rows + zero count + 1 logical page\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    const result = await listRounds({ sql: mock.sql, game: \"flipyou\" });\n\n    expect(result.rows).toEqual([]);\n    expect(result.pagination).toEqual({\n      page: 1,\n      pageSize: PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n      totalCount: 0,\n      totalPages: 1,\n    });\n  });\n\n  it(\"phase filter: when filter set the phase value is bound; when unset the predicate skips\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n    await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      filters: { phase: \"settling\" },\n    });\n    expect(mock.calls[0].values).toContain(\"settling\");\n    // The \"no phase filter\" branch is encoded as a boolean literal in the\n    // template; when phase is set, the literal must be `false` so the SQL\n    // requires an exact phase match.\n    expect(mock.calls[0].values).toContain(false);\n\n    const mock2 = createSqlMock([[], [{ value: 0 }]]);\n    await listRounds({ sql: mock2.sql, game: \"flipyou\" });\n    // When unset, the boolean literal flips to `true` (skip predicate).\n    expect(mock2.calls[0].values).toContain(true);\n  });\n\n  it(\"search filter: trims whitespace and forwards a LIKE wildcard so partial pdas/match ids/creators match\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      filters: { search: \"  abc  \" },\n    });\n\n    // Bound with wildcards so partial matches work.\n    expect(mock.calls[0].values).toContain(\"%abc%\");\n    expect(mock.calls[1].values).toContain(\"%abc%\");\n  });\n\n  it(\"date filters: forwards trimmed ISO strings to the SQL bound parameters\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n    await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      filters: {\n        fromDate: \"2026-04-01\",\n        toDate: \"2026-04-25\",\n      },\n    });\n    expect(mock.calls[0].values).toContain(\"2026-04-01\");\n    expect(mock.calls[0].values).toContain(\"2026-04-25\");\n  });\n\n  it(\"stuck filter: nonterminalAged binds the age interval and a `true` flag; other stuck predicates are `false`\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      filters: {\n        stuck: {\n          nonterminalAged: true,\n          highAttempts: false,\n          settledWithoutTx: false,\n          refunds: false,\n        },\n      },\n    });\n\n    // Default age threshold (5 minutes) is bound as a postgres interval string.\n    expect(mock.calls[0].values).toContain(\n      `${PEEK_ROUND_STUCK_DEFAULTS.ageMinutes} minutes`,\n    );\n    // Booleans for the four stuck flags get bound directly.\n    const trueCount = mock.calls[0].values.filter((v) => v === true).length;\n    const falseCount = mock.calls[0].values.filter((v) => v === false).length;\n    expect(trueCount).toBeGreaterThan(0);\n    expect(falseCount).toBeGreaterThan(0);\n  });\n\n  it(\"stuck filter: highAttempts binds the maxSettleAttempts threshold (overridable per-call)\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      filters: {\n        stuck: {\n          nonterminalAged: false,\n          highAttempts: true,\n          settledWithoutTx: false,\n          refunds: false,\n        },\n      },\n      thresholds: { maxSettleAttempts: 7 },\n    });\n\n    expect(mock.calls[0].values).toContain(7);\n    expect(mock.calls[0].text).toContain(\"r.settle_attempts >\");\n  });\n\n  it(\"stuck filter: settledWithoutTx emits the correlated NOT EXISTS subquery against transactions\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      filters: {\n        stuck: {\n          nonterminalAged: false,\n          highAttempts: false,\n          settledWithoutTx: true,\n          refunds: false,\n        },\n      },\n    });\n\n    expect(mock.calls[0].text).toContain(\"not exists\");\n    expect(mock.calls[0].text).toContain(\"from transactions t\");\n    expect(mock.calls[0].text).toContain(\"t.tx_type in ('payout','refund')\");\n  });\n\n  it(\"stuck filter: refunds maps to phase = 'expired' for FlipYou + Pot Shot\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      filters: {\n        stuck: {\n          nonterminalAged: false,\n          highAttempts: false,\n          settledWithoutTx: false,\n          refunds: true,\n        },\n      },\n    });\n\n    expect(mock.calls[0].text).toContain(\"r.phase = 'expired'\");\n  });\n\n  it(\"no stuck flags set: predicate short-circuits to a `true` literal so all rows pass\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n    await listRounds({ sql: mock.sql, game: \"flipyou\" });\n    // The negation of \"any stuck flag set\" is `true` when none are set; the\n    // template binds that boolean directly.\n    expect(mock.calls[0].values).toContain(true);\n  });\n\n  it(\"pagination: page/pageSize bound to limit + offset; totalPages = ceil(totalCount / pageSize)\", async () => {\n    const mock = createSqlMock([[], [{ value: 75 }]]);\n    const result = await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      page: 2,\n      pageSize: 25,\n    });\n\n    expect(result.pagination).toEqual({\n      page: 2,\n      pageSize: 25,\n      totalCount: 75,\n      totalPages: 3,\n    });\n    // limit, offset bound. Offset should be (page-1)*pageSize = 25.\n    expect(mock.calls[0].values).toContain(25);\n    expect(mock.calls[0].values).toContain(25); // pageSize too\n  });\n\n  it(\"pagination: clamps invalid page to 1 and clamps oversize pageSize to PEEK_GAME_ROUNDS_MAX_PAGE_SIZE\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    const result = await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      page: -3,\n      pageSize: 99999,\n    });\n\n    expect(result.pagination.page).toBe(1);\n    expect(result.pagination.pageSize).toBe(PEEK_GAME_ROUNDS_MAX_PAGE_SIZE);\n  });\n\n  it(\"string count coercion: postgres ::text counts convert to numbers\", async () => {\n    const mock = createSqlMock([[], [{ value: \"42\" }]]);\n    const result = await listRounds({ sql: mock.sql, game: \"flipyou\" });\n    expect(result.pagination.totalCount).toBe(42);\n  });\n\n  it(\"settleAttempts string coercion: numeric string from postgres still parses to integer\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          pda: \"pda-1\",\n          game: \"flipyou\",\n          matchId: \"m-1\",\n          phase: \"settling\",\n          creator: \"c-1\",\n          targetSlot: null,\n          settleAttempts: \"5\",\n          settleTx: null,\n          resultSide: \"1\",\n          winner: null,\n          amountLamports: \"0\",\n          createdAt: \"2026-04-25T10:00:00.000Z\",\n          updatedAt: \"2026-04-25T10:00:00.000Z\",\n          settledAt: null,\n        },\n      ],\n      [{ value: 1 }],\n    ]);\n\n    const result = await listRounds({ sql: mock.sql, game: \"flipyou\" });\n    expect(result.rows[0].settleAttempts).toBe(5);\n    expect(result.rows[0].resultSide).toBe(1);\n  });\n\n  it(\"load-error: a rejected paged-rows query propagates so the page can render the alert state\", async () => {\n    const mock = createSqlMock([\n      new Error(\"connection refused\"),\n      [{ value: 0 }],\n    ]);\n    await expect(\n      listRounds({ sql: mock.sql, game: \"flipyou\" }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n\n  it(\"load-error: a rejected count query also propagates\", async () => {\n    const mock = createSqlMock([[], new Error(\"statement timeout\")]);\n    await expect(\n      listRounds({ sql: mock.sql, game: \"flipyou\" }),\n    ).rejects.toThrowError(\"statement timeout\");\n  });\n});\n\ndescribe(\"listCloseCallRounds\", () => {\n  it(\"populated: shapes Close Call rows and preserves u64 prices/pools as text\", async () => {\n    const ccRows = [\n      {\n        pda: \"cc-pda-1\",\n        roundId: \"rd-1\",\n        phase: \"settled\",\n        outcome: \"green\",\n        openPrice: \"65000000000\",\n        openPriceExpo: -8,\n        closePrice: \"66000000000\",\n        greenPoolLamports: \"1000000\",\n        redPoolLamports: \"750000\",\n        totalFeeLamports: \"50000\",\n        settleTx: \"cc-tx-1\",\n        createdAt: \"2026-04-25T10:00:00.000Z\",\n        settledAt: \"2026-04-25T10:05:00.000Z\",\n      },\n      {\n        pda: \"cc-pda-2\",\n        roundId: \"rd-2\",\n        phase: \"open\",\n        outcome: \"pending\",\n        openPrice: \"65000000000\",\n        openPriceExpo: -8,\n        closePrice: null,\n        greenPoolLamports: \"0\",\n        redPoolLamports: \"0\",\n        totalFeeLamports: \"0\",\n        settleTx: null,\n        createdAt: \"2026-04-25T10:00:00.000Z\",\n        settledAt: null,\n      },\n    ];\n    const mock = createSqlMock([ccRows, [{ value: 2 }]]);\n\n    const result = await listCloseCallRounds({ sql: mock.sql });\n\n    expect(result.rows).toHaveLength(2);\n    expect(result.rows[0]).toEqual({\n      pda: \"cc-pda-1\",\n      roundId: \"rd-1\",\n      phase: \"settled\",\n      outcome: \"green\",\n      openPrice: \"65000000000\",\n      openPriceExpo: -8,\n      closePrice: \"66000000000\",\n      greenPoolLamports: \"1000000\",\n      redPoolLamports: \"750000\",\n      totalFeeLamports: \"50000\",\n      settleTx: \"cc-tx-1\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: \"2026-04-25T10:05:00.000Z\",\n    });\n    // Null-friendly: closePrice/settleTx/settledAt all survive.\n    expect(result.rows[1].closePrice).toBeNull();\n    expect(result.rows[1].settleTx).toBeNull();\n    expect(result.rows[1].settledAt).toBeNull();\n\n    expect(result.pagination).toEqual({\n      page: 1,\n      pageSize: PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n      totalCount: 2,\n      totalPages: 1,\n    });\n\n    expect(mock.calls).toHaveLength(2);\n    expect(mock.calls[0].text).toContain(\"from closecall_rounds cc\");\n    expect(mock.calls[0].text).toContain(\"order by cc.created_at desc\");\n    expect(mock.calls[1].text).toContain(\"count(*)::int\");\n  });\n\n  it(\"phase + outcome filters: both bind through to SQL parameters when set\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listCloseCallRounds({\n      sql: mock.sql,\n      filters: { phase: \"settled\", outcome: \"red\" },\n    });\n\n    expect(mock.calls[0].values).toContain(\"settled\");\n    expect(mock.calls[0].values).toContain(\"red\");\n  });\n\n  it(\"stuck filter: settledWithoutTx hard-codes the closecall game in the NOT EXISTS subquery\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listCloseCallRounds({\n      sql: mock.sql,\n      filters: {\n        stuck: {\n          nonterminalAged: false,\n          settledWithoutTx: true,\n          refunds: false,\n        },\n      },\n    });\n\n    expect(mock.calls[0].text).toContain(\"not exists\");\n    // Hard-coded as 'closecall' (no `r.game` join column on closecall_rounds).\n    expect(mock.calls[0].text).toContain(\"t.game = 'closecall'\");\n    expect(mock.calls[0].text).toContain(\"t.match_id = cc.round_id\");\n  });\n\n  it(\"stuck filter: refunds matches phase = 'refunded' OR outcome = 'refund' so a settled-with-refund-outcome row is captured\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listCloseCallRounds({\n      sql: mock.sql,\n      filters: {\n        stuck: {\n          nonterminalAged: false,\n          settledWithoutTx: false,\n          refunds: true,\n        },\n      },\n    });\n\n    expect(mock.calls[0].text).toContain(\"cc.phase = 'refunded'\");\n    expect(mock.calls[0].text).toContain(\"cc.outcome = 'refund'\");\n  });\n\n  it(\"stuck filter: nonterminalAged binds the age interval and matches phase = 'open'\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listCloseCallRounds({\n      sql: mock.sql,\n      filters: {\n        stuck: {\n          nonterminalAged: true,\n          settledWithoutTx: false,\n          refunds: false,\n        },\n      },\n      thresholds: { ageMinutes: 30, maxSettleAttempts: 3 },\n    });\n\n    expect(mock.calls[0].values).toContain(\"30 minutes\");\n    expect(mock.calls[0].text).toContain(\"cc.phase = 'open'\");\n  });\n\n  it(\"sparse: empty result returns 1 logical page\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n    const result = await listCloseCallRounds({ sql: mock.sql });\n    expect(result.rows).toEqual([]);\n    expect(result.pagination.totalPages).toBe(1);\n  });\n\n  it(\"openPriceExpo string coercion: '-8' string parses to integer -8\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          pda: \"cc-pda-x\",\n          roundId: \"rd-x\",\n          phase: \"open\",\n          outcome: \"pending\",\n          openPrice: \"1\",\n          openPriceExpo: \"-8\",\n          closePrice: null,\n          greenPoolLamports: \"0\",\n          redPoolLamports: \"0\",\n          totalFeeLamports: \"0\",\n          settleTx: null,\n          createdAt: \"2026-04-25T10:00:00.000Z\",\n          settledAt: null,\n        },\n      ],\n      [{ value: 1 }],\n    ]);\n\n    const result = await listCloseCallRounds({ sql: mock.sql });\n    expect(result.rows[0].openPriceExpo).toBe(-8);\n  });\n\n  it(\"load-error: a rejected paged-rows query propagates\", async () => {\n    const mock = createSqlMock([\n      new Error(\"connection refused\"),\n      [{ value: 0 }],\n    ]);\n    await expect(listCloseCallRounds({ sql: mock.sql })).rejects.toThrowError(\n      \"connection refused\",\n    );\n  });\n\n  it(\"load-error: a rejected count query propagates\", async () => {\n    const mock = createSqlMock([[], new Error(\"statement timeout\")]);\n    await expect(listCloseCallRounds({ sql: mock.sql })).rejects.toThrowError(\n      \"statement timeout\",\n    );\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1679,"cache_read_input_tokens":114679,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1679},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"dd0a8c11-be59-4445-8284-6991f0652708","uuid":"1ce569a4-f9f5-4180-ae97-bde73626b89e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Gna5LseQADQ7K7Wg981xVk","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-game-rounds.test.ts"}]},"parent_tool_use_id":null,"session_id":"dd0a8c11-be59-4445-8284-6991f0652708","uuid":"16f6d24c-f280-4671-ad10-2a974ec90d20","timestamp":"2026-04-25T13:14:46.997Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-game-rounds.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n  PEEK_GAME_ROUNDS_MAX_PAGE_SIZE,\n  PEEK_ROUND_STUCK_DEFAULTS,\n  listCloseCallRounds,\n  listRounds,\n} from \"../get-game-rounds\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\n// SQL mock that records every tagged-template call and returns a queued\n// response per call (rows or an Error to reject). Mirrors the pattern used in\n// get-games-overview.test.ts and get-growth-referrals.test.ts so query test\n// behaviour stays consistent.\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\n// Two queries fire in parallel via Promise.all per call:\n//   0 — paged rows\n//   1 — count(*) for pagination\n\ndescribe(\"listRounds (FlipYou + Pot Shot)\", () => {\n  it(\"populated: shapes rows for FlipYou with u64 strings preserved end-to-end\", async () => {\n    const flipyouRows = [\n      {\n        pda: \"pda-1\",\n        game: \"flipyou\",\n        matchId: \"m-1\",\n        phase: \"settled\",\n        creator: \"creator-1\",\n        targetSlot: \"1234567890\",\n        settleAttempts: 1,\n        settleTx: \"tx-1\",\n        resultSide: 0,\n        winner: \"creator-1\",\n        amountLamports: \"9007199254740992\", // > Number.MAX_SAFE_INTEGER\n        createdAt: \"2026-04-25T10:00:00.000Z\",\n        updatedAt: \"2026-04-25T10:01:00.000Z\",\n        settledAt: \"2026-04-25T10:00:30.000Z\",\n      },\n      {\n        pda: \"pda-2\",\n        game: \"flipyou\",\n        matchId: \"m-2\",\n        phase: \"expired\",\n        creator: \"creator-2\",\n        targetSlot: null,\n        settleAttempts: 4,\n        settleTx: null,\n        resultSide: null,\n        winner: null,\n        amountLamports: \"100000\",\n        createdAt: \"2026-04-25T09:00:00.000Z\",\n        updatedAt: \"2026-04-25T09:30:00.000Z\",\n        settledAt: null,\n      },\n    ];\n    const mock = createSqlMock([flipyouRows, [{ value: 2 }]]);\n\n    const result = await listRounds({ sql: mock.sql, game: \"flipyou\" });\n\n    expect(result.rows).toHaveLength(2);\n    expect(result.rows[0]).toEqual({\n      game: \"flipyou\",\n      pda: \"pda-1\",\n      matchId: \"m-1\",\n      phase: \"settled\",\n      creator: \"creator-1\",\n      targetSlot: \"1234567890\",\n      settleAttempts: 1,\n      settleTx: \"tx-1\",\n      resultSide: 0,\n      winner: \"creator-1\",\n      amountLamports: \"9007199254740992\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      updatedAt: \"2026-04-25T10:01:00.000Z\",\n      settledAt: \"2026-04-25T10:00:30.000Z\",\n    });\n    // Null-friendly columns survive: targetSlot, settleTx, resultSide, winner, settledAt.\n    expect(result.rows[1].targetSlot).toBeNull();\n    expect(result.rows[1].settleTx).toBeNull();\n    expect(result.rows[1].resultSide).toBeNull();\n    expect(result.rows[1].winner).toBeNull();\n    expect(result.rows[1].settledAt).toBeNull();\n\n    expect(result.pagination).toEqual({\n      page: 1,\n      pageSize: PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n      totalCount: 2,\n      totalPages: 1,\n    });\n\n    // Two queries fired in parallel: rows + count.\n    expect(mock.calls).toHaveLength(2);\n    expect(mock.calls[0].text).toContain(\"from rounds r\");\n    expect(mock.calls[0].text).toContain(\"order by r.created_at desc\");\n    expect(mock.calls[0].text).toContain(\"limit \");\n    expect(mock.calls[0].text).toContain(\" offset \");\n    expect(mock.calls[1].text).toContain(\"count(*)::int\");\n    // Game predicate is bound to the requested game id.\n    expect(mock.calls[0].values).toContain(\"flipyou\");\n    expect(mock.calls[1].values).toContain(\"flipyou\");\n  });\n\n  it(\"works for potshot game id (same SQL, different game predicate)\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          pda: \"pda-ps\",\n          game: \"potshot\",\n          matchId: \"m-ps\",\n          phase: \"created\",\n          creator: \"creator-ps\",\n          targetSlot: \"777\",\n          settleAttempts: 0,\n          settleTx: null,\n          resultSide: null,\n          winner: null,\n          amountLamports: \"5000000\",\n          createdAt: \"2026-04-25T10:00:00.000Z\",\n          updatedAt: \"2026-04-25T10:00:00.000Z\",\n          settledAt: null,\n        },\n      ],\n      [{ value: 1 }],\n    ]);\n\n    const result = await listRounds({ sql: mock.sql, game: \"potshot\" });\n\n    expect(result.rows).toHaveLength(1);\n    expect(result.rows[0].game).toBe(\"potshot\");\n    expect(mock.calls[0].values).toContain(\"potshot\");\n    expect(mock.calls[1].values).toContain(\"potshot\");\n  });\n\n  it(\"filters out rows whose game id is not a member of PEEK_ROUNDS_GAME_IDS so out-of-band data cannot leak\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          pda: \"pda-1\",\n          game: \"flipyou\",\n          matchId: \"m-1\",\n          phase: \"settled\",\n          creator: \"c-1\",\n          targetSlot: null,\n          settleAttempts: 0,\n          settleTx: null,\n          resultSide: null,\n          winner: null,\n          amountLamports: \"0\",\n          createdAt: \"2026-04-25T10:00:00.000Z\",\n          updatedAt: \"2026-04-25T10:00:00.000Z\",\n          settledAt: null,\n        },\n        {\n          // Out-of-band game id (e.g. a future migration row); must not surface.\n          pda: \"pda-bogus\",\n          game: \"crash\",\n          matchId: \"m-bogus\",\n          phase: \"settled\",\n          creator: \"c-bogus\",\n          targetSlot: null,\n          settleAttempts: 0,\n          settleTx: null,\n          resultSide: null,\n          winner: null,\n          amountLamports: \"0\",\n          createdAt: \"2026-04-25T10:00:00.000Z\",\n          updatedAt: \"2026-04-25T10:00:00.000Z\",\n          settledAt: null,\n        },\n      ],\n      [{ value: 2 }],\n    ]);\n\n    const result = await listRounds({ sql: mock.sql, game: \"flipyou\" });\n\n    expect(result.rows.map((r) => r.pda)).toEqual([\"pda-1\"]);\n    expect(result.rows[0].game).toBe(\"flipyou\");\n  });\n\n  it(\"sparse: empty SQL response yields empty rows + zero count + 1 logical page\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    const result = await listRounds({ sql: mock.sql, game: \"flipyou\" });\n\n    expect(result.rows).toEqual([]);\n    expect(result.pagination).toEqual({\n      page: 1,\n      pageSize: PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n      totalCount: 0,\n      totalPages: 1,\n    });\n  });\n\n  it(\"phase filter: when filter set the phase value is bound; when unset the predicate skips\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n    await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      filters: { phase: \"settling\" },\n    });\n    expect(mock.calls[0].values).toContain(\"settling\");\n    // The \"no phase filter\" branch is encoded as a boolean literal in the\n    // template; when phase is set, the literal must be `false` so the SQL\n    // requires an exact phase match.\n    expect(mock.calls[0].values).toContain(false);\n\n    const mock2 = createSqlMock([[], [{ value: 0 }]]);\n    await listRounds({ sql: mock2.sql, game: \"flipyou\" });\n    // When unset, the boolean literal flips to `true` (skip predicate).\n    expect(mock2.calls[0].values).toContain(true);\n  });\n\n  it(\"search filter: trims whitespace and forwards a LIKE wildcard so partial pdas/match ids/creators match\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      filters: { search: \"  abc  \" },\n    });\n\n    // Bound with wildcards so partial matches work.\n    expect(mock.calls[0].values).toContain(\"%abc%\");\n    expect(mock.calls[1].values).toContain(\"%abc%\");\n  });\n\n  it(\"date filters: forwards trimmed ISO strings to the SQL bound parameters\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n    await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      filters: {\n        fromDate: \"2026-04-01\",\n        toDate: \"2026-04-25\",\n      },\n    });\n    expect(mock.calls[0].values).toContain(\"2026-04-01\");\n    expect(mock.calls[0].values).toContain(\"2026-04-25\");\n  });\n\n  it(\"stuck filter: nonterminalAged binds the age interval and a `true` flag; other stuck predicates are `false`\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      filters: {\n        stuck: {\n          nonterminalAged: true,\n          highAttempts: false,\n          settledWithoutTx: false,\n          refunds: false,\n  