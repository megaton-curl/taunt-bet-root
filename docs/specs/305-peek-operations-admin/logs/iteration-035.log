{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TE6Ls2cgb611tCyUeSvxq3","type":"tool_result","content":"1\t// Per-round table for Close Call at /games/[game] (FR-8).\n2\t//\n3\t// Dense readonly table over `PeekCloseCallRoundRow` from `closecall_rounds`\n4\t// (migration 004). Pyth open/close prices keep their u64 precision via the\n5\t// engine's `::text` casting; the UI re-applies `openPriceExpo` (a Pyth signed\n6\t// exponent) only as a small sublabel so reviewers see the raw integer\n7\t// alongside the human-readable value. Pools and total fee are lamports.\n8\timport type { CSSProperties } from \"react\";\n9\timport type {\n10\t  PeekCloseCallOutcome,\n11\t  PeekCloseCallPhase,\n12\t  PeekCloseCallRoundRow,\n13\t  PeekStatusTone,\n14\t} from \"../lib/types/peek\";\n15\timport { StatusChip } from \"./status-chip\";\n16\t\n17\texport type CloseCallRoundsTableProps = {\n18\t  rows: ReadonlyArray<PeekCloseCallRoundRow>;\n19\t  error?: string | null;\n20\t};\n21\t\n22\texport function CloseCallRoundsTable({\n23\t  rows,\n24\t  error = null,\n25\t}: CloseCallRoundsTableProps) {\n26\t  if (error) {\n27\t    return (\n28\t      <div role=\"alert\" style={errorStyle}>\n29\t        Rounds unavailable: {error}\n30\t      </div>\n31\t    );\n32\t  }\n33\t\n34\t  if (rows.length === 0) {\n35\t    return (\n36\t      <div role=\"status\" style={emptyStyle}>\n37\t        <p style={emptyTitleStyle}>No rounds match these filters.</p>\n38\t        <p style={emptyBodyStyle}>\n39\t          Adjust the filters above or clear them to see recent rounds from\n40\t          `closecall_rounds`.\n41\t        </p>\n42\t      </div>\n43\t    );\n44\t  }\n45\t\n46\t  return (\n47\t    <div style={wrapperStyle}>\n48\t      <table style={tableStyle}>\n49\t        <thead>\n50\t          <tr style={headerRowStyle}>\n51\t            <th style={headerCellStyle(\"left\")}>Created</th>\n52\t            <th style={headerCellStyle(\"left\")}>Phase</th>\n53\t            <th style={headerCellStyle(\"left\")}>Outcome</th>\n54\t            <th style={headerCellStyle(\"left\")}>Round ID</th>\n55\t            <th style={headerCellStyle(\"left\")}>PDA</th>\n56\t            <th style={headerCellStyle(\"right\")}>Open price</th>\n57\t            <th style={headerCellStyle(\"right\")}>Close price</th>\n58\t            <th style={headerCellStyle(\"right\")}>Green pool</th>\n59\t            <th style={headerCellStyle(\"right\")}>Red pool</th>\n60\t            <th style={headerCellStyle(\"right\")}>Total fee</th>\n61\t            <th style={headerCellStyle(\"left\")}>Settle tx</th>\n62\t            <th style={headerCellStyle(\"left\")}>Settled</th>\n63\t          </tr>\n64\t        </thead>\n65\t        <tbody>\n66\t          {rows.map((row) => (\n67\t            <tr key={row.pda} style={bodyRowStyle}>\n68\t              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n69\t              <td style={bodyCellStyle(\"left\")}>\n70\t                <StatusChip label={row.phase} tone={phaseTone(row.phase)} />\n71\t              </td>\n72\t              <td style={bodyCellStyle(\"left\")}>\n73\t                <StatusChip label={row.outcome} tone={outcomeTone(row.outcome)} />\n74\t              </td>\n75\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n76\t                <span title={row.roundId}>{truncate(row.roundId, 16)}</span>\n77\t              </td>\n78\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n79\t                <span title={row.pda}>{truncate(row.pda, 12)}</span>\n80\t              </td>\n81\t              <td style={bodyCellStyle(\"right\")}>\n82\t                <span style={priceStyle}>{formatNumber(row.openPrice)}</span>\n83\t                <span style={subValueStyle}> · expo {row.openPriceExpo}</span>\n84\t              </td>\n85\t              <td style={bodyCellStyle(\"right\")}>\n86\t                {row.closePrice ? formatNumber(row.closePrice) : \"—\"}\n87\t              </td>\n88\t              <td style={bodyCellStyle(\"right\")}>\n89\t                {formatNumber(row.greenPoolLamports)}\n90\t              </td>\n91\t              <td style={bodyCellStyle(\"right\")}>\n92\t                {formatNumber(row.redPoolLamports)}\n93\t              </td>\n94\t              <td style={bodyCellStyle(\"right\")}>\n95\t                {formatNumber(row.totalFeeLamports)}\n96\t              </td>\n97\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n98\t                {row.settleTx ? (\n99\t                  <span title={row.settleTx}>{truncate(row.settleTx, 12)}</span>\n100\t                ) : (\n101\t                  \"—\"\n102\t                )}\n103\t              </td>\n104\t              <td style={bodyCellStyle(\"left\")}>{row.settledAt ?? \"—\"}</td>\n105\t            </tr>\n106\t          ))}\n107\t        </tbody>\n108\t      </table>\n109\t    </div>\n110\t  );\n111\t}\n112\t\n113\tfunction phaseTone(phase: PeekCloseCallPhase): PeekStatusTone {\n114\t  if (phase === \"settled\") return \"positive\";\n115\t  if (phase === \"refunded\") return \"warning\";\n116\t  return \"info\";\n117\t}\n118\t\n119\tfunction outcomeTone(outcome: PeekCloseCallOutcome): PeekStatusTone {\n120\t  if (outcome === \"green\") return \"positive\";\n121\t  if (outcome === \"red\") return \"negative\";\n122\t  if (outcome === \"refund\") return \"warning\";\n123\t  return \"neutral\";\n124\t}\n125\t\n126\tfunction truncate(value: string, max: number): string {\n127\t  if (value.length <= max) return value;\n128\t  const head = Math.max(2, Math.floor((max - 1) / 2));\n129\t  const tail = Math.max(2, max - 1 - head);\n130\t  return `${value.slice(0, head)}…${value.slice(-tail)}`;\n131\t}\n132\t\n133\tfunction formatNumber(value: string): string {\n134\t  if (!value || value === \"0\") return \"0\";\n135\t  const negative = value.startsWith(\"-\");\n136\t  const digits = negative ? value.slice(1) : value;\n137\t  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n138\t  return negative ? `-${grouped}` : grouped;\n139\t}\n140\t\n141\tconst wrapperStyle: CSSProperties = {\n142\t  overflowX: \"auto\",\n143\t  border: \"1px solid #1e293b\",\n144\t  borderRadius: \"0.75rem\",\n145\t};\n146\t\n147\tconst tableStyle: CSSProperties = {\n148\t  width: \"100%\",\n149\t  borderCollapse: \"collapse\",\n150\t};\n151\t\n152\tconst headerRowStyle: CSSProperties = {\n153\t  background: \"#111827\",\n154\t  color: \"#94a3b8\",\n155\t};\n156\t\n157\tconst bodyRowStyle: CSSProperties = {\n158\t  borderTop: \"1px solid #1e293b\",\n159\t};\n160\t\n161\tconst priceStyle: CSSProperties = {\n162\t  color: \"#e2e8f0\",\n163\t};\n164\t\n165\tconst subValueStyle: CSSProperties = {\n166\t  color: \"#64748b\",\n167\t  fontSize: \"0.75rem\",\n168\t  marginLeft: \"0.25rem\",\n169\t};\n170\t\n171\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n172\t  return {\n173\t    padding: \"0.75rem\",\n174\t    textAlign: align,\n175\t    fontSize: \"0.875rem\",\n176\t    fontWeight: 600,\n177\t  };\n178\t}\n179\t\n180\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n181\t  return {\n182\t    padding: \"0.75rem\",\n183\t    textAlign: align,\n184\t    fontSize: \"0.875rem\",\n185\t  };\n186\t}\n187\t\n188\tconst errorStyle: CSSProperties = {\n189\t  margin: 0,\n190\t  padding: \"0.75rem 1rem\",\n191\t  borderRadius: \"0.75rem\",\n192\t  background: \"#3f1d1d\",\n193\t  color: \"#fecaca\",\n194\t};\n195\t\n196\tconst emptyStyle: CSSProperties = {\n197\t  padding: \"1.5rem\",\n198\t  borderRadius: \"0.75rem\",\n199\t  border: \"1px dashed #334155\",\n200\t  background: \"#0b1220\",\n201\t  color: \"#cbd5f5\",\n202\t  display: \"grid\",\n203\t  gap: \"0.5rem\",\n204\t};\n205\t\n206\tconst emptyTitleStyle: CSSProperties = {\n207\t  margin: 0,\n208\t  fontSize: \"1rem\",\n209\t  fontWeight: 600,\n210\t};\n211\t\n212\tconst emptyBodyStyle: CSSProperties = {\n213\t  margin: 0,\n214\t  fontSize: \"0.875rem\",\n215\t  color: \"#94a3b8\",\n216\t};\n217\t"}]},"parent_tool_use_id":null,"session_id":"dd0a8c11-be59-4445-8284-6991f0652708","uuid":"7394a318-77a7-41ba-9fd7-26670775e0eb","timestamp":"2026-04-25T13:12:34.186Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/closecall-rounds-table.tsx","content":"// Per-round table for Close Call at /games/[game] (FR-8).\n//\n// Dense readonly table over `PeekCloseCallRoundRow` from `closecall_rounds`\n// (migration 004). Pyth open/close prices keep their u64 precision via the\n// engine's `::text` casting; the UI re-applies `openPriceExpo` (a Pyth signed\n// exponent) only as a small sublabel so reviewers see the raw integer\n// alongside the human-readable value. Pools and total fee are lamports.\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekCloseCallOutcome,\n  PeekCloseCallPhase,\n  PeekCloseCallRoundRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type CloseCallRoundsTableProps = {\n  rows: ReadonlyArray<PeekCloseCallRoundRow>;\n  error?: string | null;\n};\n\nexport function CloseCallRoundsTable({\n  rows,\n  error = null,\n}: CloseCallRoundsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Rounds unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No rounds match these filters.</p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see recent rounds from\n          `closecall_rounds`.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>Phase</th>\n            <th style={headerCellStyle(\"left\")}>Outcome</th>\n            <th style={headerCellStyle(\"left\")}>Round ID</th>\n            <th style={headerCellStyle(\"left\")}>PDA</th>\n            <th style={headerCellStyle(\"right\")}>Open price</th>\n            <th style={headerCellStyle(\"right\")}>Close price</th>\n            <th style={headerCellStyle(\"right\")}>Green pool</th>\n            <th style={headerCellStyle(\"right\")}>Red pool</th>\n            <th style={headerCellStyle(\"right\")}>Total fee</th>\n            <th style={headerCellStyle(\"left\")}>Settle tx</th>\n            <th style={headerCellStyle(\"left\")}>Settled</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.pda} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip label={row.phase} tone={phaseTone(row.phase)} />\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip label={row.outcome} tone={outcomeTone(row.outcome)} />\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={row.roundId}>{truncate(row.roundId, 16)}</span>\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={row.pda}>{truncate(row.pda, 12)}</span>\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                <span style={priceStyle}>{formatNumber(row.openPrice)}</span>\n                <span style={subValueStyle}> · expo {row.openPriceExpo}</span>\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {row.closePrice ? formatNumber(row.closePrice) : \"—\"}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(row.greenPoolLamports)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(row.redPoolLamports)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(row.totalFeeLamports)}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.settleTx ? (\n                  <span title={row.settleTx}>{truncate(row.settleTx, 12)}</span>\n                ) : (\n                  \"—\"\n                )}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.settledAt ?? \"—\"}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction phaseTone(phase: PeekCloseCallPhase): PeekStatusTone {\n  if (phase === \"settled\") return \"positive\";\n  if (phase === \"refunded\") return \"warning\";\n  return \"info\";\n}\n\nfunction outcomeTone(outcome: PeekCloseCallOutcome): PeekStatusTone {\n  if (outcome === \"green\") return \"positive\";\n  if (outcome === \"red\") return \"negative\";\n  if (outcome === \"refund\") return \"warning\";\n  return \"neutral\";\n}\n\nfunction truncate(value: string, max: number): string {\n  if (value.length <= max) return value;\n  const head = Math.max(2, Math.floor((max - 1) / 2));\n  const tail = Math.max(2, max - 1 - head);\n  return `${value.slice(0, head)}…${value.slice(-tail)}`;\n}\n\nfunction formatNumber(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst priceStyle: CSSProperties = {\n  color: \"#e2e8f0\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n  marginLeft: \"0.25rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":217,"startLine":1,"totalLines":217}}}
