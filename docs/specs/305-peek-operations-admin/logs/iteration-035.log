Refunds`); Close Call replaces `stuckAttempts` with an `outcome`\n// dropdown and uses three stuck flags because `closecall_rounds` has no\n// `settle_attempts` column.\nimport type { CSSProperties } from \"react\";\nimport {\n  PEEK_CLOSECALL_OUTCOMES,\n  PEEK_CLOSECALL_PHASES,\n  PEEK_ROUND_PHASES,\n  type PeekCloseCallRoundFilters,\n  type PeekGameId,\n  type PeekRoundFilters,\n} from \"../lib/types/peek\";\n\nexport type GameRoundsFilterBarProps =\n  | {\n      game: \"flipyou\" | \"potshot\";\n      filters: PeekRoundFilters;\n      action: string;\n    }\n  | {\n      game: \"closecall\";\n      filters: PeekCloseCallRoundFilters;\n      action: string;\n    };\n\nexport function GameRoundsFilterBar(props: GameRoundsFilterBarProps) {\n  const { game, action, filters } = props;\n  const isCloseCall = game === \"closecall\";\n\n  return (\n    <form\n      action={action}\n      method=\"get\"\n      role=\"search\"\n      aria-label={`Filter ${labelForGame(game)} rounds`}\n      style={formStyle}\n    >\n      <label style={fieldStyle}>\n        <span>Phase</span>\n        <select\n          name=\"phase\"\n          defaultValue={filters.phase ?? \"\"}\n          style={inputStyle}\n        >\n          <option value=\"\">Any</option>\n          {(isCloseCall ? PEEK_CLOSECALL_PHASES : PEEK_ROUND_PHASES).map(\n            (phase) => (\n              <option key={phase} value={phase}>\n                {phase}\n              </option>\n            ),\n          )}\n        </select>\n      </label>\n\n      {isCloseCall ? (\n        <label style={fieldStyle}>\n          <span>Outcome</span>\n          <select\n            name=\"outcome\"\n            defaultValue={\n              (filters as PeekCloseCallRoundFilters).outcome ?? \"\"\n            }\n            style={inputStyle}\n          >\n            <option value=\"\">Any</option>\n            {PEEK_CLOSECALL_OUTCOMES.map((outcome) => (\n              <option key={outcome} value={outcome}>\n                {outcome}\n              </option>\n            ))}\n          </select>\n        </label>\n      ) : null}\n\n      <label style={fieldStyle}>\n        <span>Search</span>\n        <input\n          name=\"search\"\n          type=\"text\"\n          defaultValue={filters.search ?? \"\"}\n          placeholder={\n            isCloseCall ? \"pda or round id\" : \"pda, match id, or creator\"\n          }\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Created from</span>\n        <input\n          name=\"fromDate\"\n          type=\"date\"\n          defaultValue={(filters.fromDate ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Created to</span>\n        <input\n          name=\"toDate\"\n          type=\"date\"\n          defaultValue={(filters.toDate ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <fieldset style={fieldsetStyle}>\n        <legend style={legendStyle}>Stuck-state filters</legend>\n        <label style={checkboxRowStyle}>\n          <input\n            type=\"checkbox\"\n            name=\"stuckAged\"\n            value=\"1\"\n            defaultChecked={filters.stuck.nonterminalAged}\n          />\n          <span>Nonterminal &amp; aged</span>\n        </label>\n        {!isCloseCall ? (\n          <label style={checkboxRowStyle}>\n            <input\n              type=\"checkbox\"\n              name=\"stuckAttempts\"\n              value=\"1\"\n              defaultChecked={\n                (filters as PeekRoundFilters).stuck.highAttempts\n              }\n            />\n            <span>High settle attempts</span>\n          </label>\n        ) : null}\n        <label style={checkboxRowStyle}>\n          <input\n            type=\"checkbox\"\n            name=\"stuckNoTx\"\n            value=\"1\"\n            defaultChecked={filters.stuck.settledWithoutTx}\n          />\n          <span>Settled without tx</span>\n        </label>\n        <label style={checkboxRowStyle}>\n          <input\n            type=\"checkbox\"\n            name=\"stuckRefunds\"\n            value=\"1\"\n            defaultChecked={filters.stuck.refunds}\n          />\n          <span>Refunds</span>\n        </label>\n      </fieldset>\n\n      <button type=\"submit\" style={buttonStyle}>\n        Apply filters\n      </button>\n    </form>\n  );\n}\n\nfunction labelForGame(game: PeekGameId): string {\n  if (game === \"flipyou\") return \"FlipYou\";\n  if (game === \"potshot\") return \"Pot Shot\";\n  return \"Close Call\";\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n  gridTemplateColumns: \"repeat(auto-fit, minmax(200px, 1fr))\",\n  alignItems: \"end\",\n};\n\nconst fieldStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.35rem\",\n  fontSize: \"0.875rem\",\n};\n\nconst inputStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #334155\",\n  background: \"#111827\",\n  color: \"#e2e8f0\",\n  padding: \"0.625rem 0.75rem\",\n};\n\nconst fieldsetStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.35rem\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.5rem\",\n  padding: \"0.5rem 0.75rem\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  margin: 0,\n  fontSize: \"0.8125rem\",\n};\n\nconst legendStyle: CSSProperties = {\n  padding: \"0 0.25rem\",\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst checkboxRowStyle: CSSProperties = {\n  display: \"flex\",\n  gap: \"0.5rem\",\n  alignItems: \"center\",\n};\n\nconst buttonStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #475569\",\n  background: \"#1d4ed8\",\n  color: \"#eff6ff\",\n  padding: \"0.75rem 1rem\",\n  fontWeight: 600,\n};\n","numLines":226,"startLine":1,"totalLines":226}}}
