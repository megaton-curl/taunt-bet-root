FFFFFFFFFF\",\n  matchId: \"match-ccccccccccccccccccccccccccccccc\",\n  phase: \"settling\",\n  creator: \"GGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGGG\",\n  targetSlot: \"999\",\n  settleAttempts: 2,\n  settleTx: null,\n  resultSide: null,\n  winner: null,\n  amountLamports: \"0\",\n  createdAt: \"2026-04-25T11:00:00.000Z\",\n  updatedAt: \"2026-04-25T11:01:00.000Z\",\n  settledAt: null,\n};\n\ndescribe(\"GameRoundsTable\", () => {\n  it(\"populated: renders all FR-8 columns with formatted lamports + null fallbacks\", () => {\n    render(\n      <GameRoundsTable rows={[ROW_SETTLED, ROW_EXPIRED, ROW_SETTLING]} />,\n    );\n\n    // Column headers per FR-8 acceptance criteria.\n    for (const header of [\n      \"Created\",\n      \"Phase\",\n      \"Match ID\",\n      \"PDA\",\n      \"Creator\",\n      \"Amount (lamports)\",\n      \"Target slot\",\n      \"Settle attempts\",\n      \"Result side\",\n      \"Winner\",\n      \"Settle tx\",\n      \"Settled\",\n    ]) {\n      expect(screen.getByText(header)).toBeInTheDocument();\n    }\n\n    // Lamport / target slot formatted with thousands separators.\n    expect(screen.getByText(\"8,000,000,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"100,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"1,234,567,890\")).toBeInTheDocument();\n    expect(screen.getByText(\"0\")).toBeInTheDocument();\n\n    // Null target slot, settle tx, winner, settled-at all render the\n    // em-dash placeholder.\n    const dashes = screen.getAllByText(\"—\");\n    expect(dashes.length).toBeGreaterThanOrEqual(4);\n\n    // Settle attempts: numeric, not formatted with separators (it's a small\n    // integer, never u64).\n    expect(screen.getByText(\"4\")).toBeInTheDocument();\n    expect(screen.getByText(\"2\")).toBeInTheDocument();\n\n    // Long pubkeys truncate with the unicode ellipsis but keep the full\n    // value in `title=` for hover audit.\n    const truncatedSettleTx = screen\n      .getAllByTitle(ROW_SETTLED.settleTx!)\n      .find((el) => el.textContent?.includes(\"…\"));\n    expect(truncatedSettleTx).toBeDefined();\n  });\n\n  it(\"populated: phase column renders through StatusChip with the right tone per phase\", () => {\n    render(\n      <GameRoundsTable rows={[ROW_SETTLED, ROW_EXPIRED, ROW_SETTLING]} />,\n    );\n\n    // StatusChip renders the phase as text within the chip.\n    expect(screen.getByText(\"settled\")).toBeInTheDocument();\n    expect(screen.getByText(\"expired\")).toBeInTheDocument();\n    expect(screen.getByText(\"settling\")).toBeInTheDocument();\n  });\n\n  it(\"sparse: zero rows renders the operator empty state pointing at the rounds table\", () => {\n    render(<GameRoundsTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"No rounds match these filters.\");\n    expect(status).toHaveTextContent(\"`rounds`\");\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and suppresses both the table and the empty status\", () => {\n    render(\n      <GameRoundsTable rows={[ROW_SETTLED]} error=\"connection refused\" />,\n    );\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Rounds unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n\n  it(\"refund row (FR-8 stuck-state): expired phase still renders a row + chip with all expected null placeholders\", () => {\n    render(<GameRoundsTable rows={[ROW_EXPIRED]} />);\n\n    // Phase chip shows the refund-equivalent state.\n    expect(screen.getByText(\"expired\")).toBeInTheDocument();\n    // Settle-tx, winner, settled-at, target-slot are all null on a refunded\n    // round; each renders an em-dash.\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(4);\n    // Settle attempts > default threshold (3) — operator can spot the\n    // stuck-state via the integer column without needing the filter.\n    expect(screen.getByText(\"4\")).toBeInTheDocument();\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
