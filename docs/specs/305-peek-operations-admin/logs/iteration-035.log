{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Gyv6kVTsL7CwTsuzsuCNfM","type":"tool_result","content":"1\t// Per-round table for FlipYou + Pot Shot at /games/[game] (FR-8).\n2\t//\n3\t// Dense readonly table over `PeekRoundRow` from the shared `rounds` table\n4\t// (migration 001). Lamport / slot columns right-aligned with thousands\n5\t// separators. Phase renders as a status chip so refund/settled/stuck states\n6\t// pop visually. Truncates long pubkeys with monospace + `title` for full value\n7\t// on hover so the table stays scannable.\n8\timport type { CSSProperties } from \"react\";\n9\timport type {\n10\t  PeekRoundPhase,\n11\t  PeekRoundRow,\n12\t  PeekStatusTone,\n13\t} from \"../lib/types/peek\";\n14\timport { StatusChip } from \"./status-chip\";\n15\t\n16\texport type GameRoundsTableProps = {\n17\t  rows: ReadonlyArray<PeekRoundRow>;\n18\t  error?: string | null;\n19\t};\n20\t\n21\texport function GameRoundsTable({ rows, error = null }: GameRoundsTableProps) {\n22\t  if (error) {\n23\t    return (\n24\t      <div role=\"alert\" style={errorStyle}>\n25\t        Rounds unavailable: {error}\n26\t      </div>\n27\t    );\n28\t  }\n29\t\n30\t  if (rows.length === 0) {\n31\t    return (\n32\t      <div role=\"status\" style={emptyStyle}>\n33\t        <p style={emptyTitleStyle}>No rounds match these filters.</p>\n34\t        <p style={emptyBodyStyle}>\n35\t          Adjust the filters above or clear them to see recent rounds from the\n36\t          `rounds` table.\n37\t        </p>\n38\t      </div>\n39\t    );\n40\t  }\n41\t\n42\t  return (\n43\t    <div style={wrapperStyle}>\n44\t      <table style={tableStyle}>\n45\t        <thead>\n46\t          <tr style={headerRowStyle}>\n47\t            <th style={headerCellStyle(\"left\")}>Created</th>\n48\t            <th style={headerCellStyle(\"left\")}>Phase</th>\n49\t            <th style={headerCellStyle(\"left\")}>Match ID</th>\n50\t            <th style={headerCellStyle(\"left\")}>PDA</th>\n51\t            <th style={headerCellStyle(\"left\")}>Creator</th>\n52\t            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>\n53\t            <th style={headerCellStyle(\"right\")}>Target slot</th>\n54\t            <th style={headerCellStyle(\"right\")}>Settle attempts</th>\n55\t            <th style={headerCellStyle(\"left\")}>Result side</th>\n56\t            <th style={headerCellStyle(\"left\")}>Winner</th>\n57\t            <th style={headerCellStyle(\"left\")}>Settle tx</th>\n58\t            <th style={headerCellStyle(\"left\")}>Settled</th>\n59\t          </tr>\n60\t        </thead>\n61\t        <tbody>\n62\t          {rows.map((row) => (\n63\t            <tr key={row.pda} style={bodyRowStyle}>\n64\t              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n65\t              <td style={bodyCellStyle(\"left\")}>\n66\t                <StatusChip\n67\t                  label={row.phase}\n68\t                  tone={phaseTone(row.phase)}\n69\t                />\n70\t              </td>\n71\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n72\t                <span title={row.matchId}>{truncate(row.matchId, 16)}</span>\n73\t              </td>\n74\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n75\t                <span title={row.pda}>{truncate(row.pda, 12)}</span>\n76\t              </td>\n77\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n78\t                <span title={row.creator}>{truncate(row.creator, 12)}</span>\n79\t              </td>\n80\t              <td style={bodyCellStyle(\"right\")}>\n81\t                {formatNumber(row.amountLamports)}\n82\t              </td>\n83\t              <td style={bodyCellStyle(\"right\")}>\n84\t                {row.targetSlot ? formatNumber(row.targetSlot) : \"—\"}\n85\t              </td>\n86\t              <td style={bodyCellStyle(\"right\")}>{row.settleAttempts}</td>\n87\t              <td style={bodyCellStyle(\"left\")}>\n88\t                {row.resultSide === null ? \"—\" : row.resultSide}\n89\t              </td>\n90\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n91\t                {row.winner ? (\n92\t                  <span title={row.winner}>{truncate(row.winner, 12)}</span>\n93\t                ) : (\n94\t                  \"—\"\n95\t                )}\n96\t              </td>\n97\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n98\t                {row.settleTx ? (\n99\t                  <span title={row.settleTx}>{truncate(row.settleTx, 12)}</span>\n100\t                ) : (\n101\t                  \"—\"\n102\t                )}\n103\t              </td>\n104\t              <td style={bodyCellStyle(\"left\")}>{row.settledAt ?? \"—\"}</td>\n105\t            </tr>\n106\t          ))}\n107\t        </tbody>\n108\t      </table>\n109\t    </div>\n110\t  );\n111\t}\n112\t\n113\tfunction phaseTone(phase: PeekRoundPhase): PeekStatusTone {\n114\t  if (phase === \"settled\") return \"positive\";\n115\t  if (phase === \"expired\") return \"warning\";\n116\t  if (phase === \"settling\") return \"info\";\n117\t  if (phase === \"locked\") return \"info\";\n118\t  return \"neutral\";\n119\t}\n120\t\n121\tfunction truncate(value: string, max: number): string {\n122\t  if (value.length <= max) return value;\n123\t  const head = Math.max(2, Math.floor((max - 1) / 2));\n124\t  const tail = Math.max(2, max - 1 - head);\n125\t  return `${value.slice(0, head)}…${value.slice(-tail)}`;\n126\t}\n127\t\n128\tfunction formatNumber(value: string): string {\n129\t  if (!value || value === \"0\") return \"0\";\n130\t  const negative = value.startsWith(\"-\");\n131\t  const digits = negative ? value.slice(1) : value;\n132\t  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n133\t  return negative ? `-${grouped}` : grouped;\n134\t}\n135\t\n136\tconst wrapperStyle: CSSProperties = {\n137\t  overflowX: \"auto\",\n138\t  border: \"1px solid #1e293b\",\n139\t  borderRadius: \"0.75rem\",\n140\t};\n141\t\n142\tconst tableStyle: CSSProperties = {\n143\t  width: \"100%\",\n144\t  borderCollapse: \"collapse\",\n145\t};\n146\t\n147\tconst headerRowStyle: CSSProperties = {\n148\t  background: \"#111827\",\n149\t  color: \"#94a3b8\",\n150\t};\n151\t\n152\tconst bodyRowStyle: CSSProperties = {\n153\t  borderTop: \"1px solid #1e293b\",\n154\t};\n155\t\n156\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n157\t  return {\n158\t    padding: \"0.75rem\",\n159\t    textAlign: align,\n160\t    fontSize: \"0.875rem\",\n161\t    fontWeight: 600,\n162\t  };\n163\t}\n164\t\n165\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n166\t  return {\n167\t    padding: \"0.75rem\",\n168\t    textAlign: align,\n169\t    fontSize: \"0.875rem\",\n170\t  };\n171\t}\n172\t\n173\tconst errorStyle: CSSProperties = {\n174\t  margin: 0,\n175\t  padding: \"0.75rem 1rem\",\n176\t  borderRadius: \"0.75rem\",\n177\t  background: \"#3f1d1d\",\n178\t  color: \"#fecaca\",\n179\t};\n180\t\n181\tconst emptyStyle: CSSProperties = {\n182\t  padding: \"1.5rem\",\n183\t  borderRadius: \"0.75rem\",\n184\t  border: \"1px dashed #334155\",\n185\t  background: \"#0b1220\",\n186\t  color: \"#cbd5f5\",\n187\t  display: \"grid\",\n188\t  gap: \"0.5rem\",\n189\t};\n190\t\n191\tconst emptyTitleStyle: CSSProperties = {\n192\t  margin: 0,\n193\t  fontSize: \"1rem\",\n194\t  fontWeight: 600,\n195\t};\n196\t\n197\tconst emptyBodyStyle: CSSProperties = {\n198\t  margin: 0,\n199\t  fontSize: \"0.875rem\",\n200\t  color: \"#94a3b8\",\n201\t};\n202\t"}]},"parent_tool_use_id":null,"session_id":"dd0a8c11-be59-4445-8284-6991f0652708","uuid":"582b7216-1ae7-4f1a-9d70-dcccde9b0093","timestamp":"2026-04-25T13:12:31.559Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/game-rounds-table.tsx","content":"// Per-round table for FlipYou + Pot Shot at /games/[game] (FR-8).\n//\n// Dense readonly table over `PeekRoundRow` from the shared `rounds` table\n// (migration 001). Lamport / slot columns right-aligned with thousands\n// separators. Phase renders as a status chip so refund/settled/stuck states\n// pop visually. Truncates long pubkeys with monospace + `title` for full value\n// on hover so the table stays scannable.\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekRoundPhase,\n  PeekRoundRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type GameRoundsTableProps = {\n  rows: ReadonlyArray<PeekRoundRow>;\n  error?: string | null;\n};\n\nexport function GameRoundsTable({ rows, error = null }: GameRoundsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Rounds unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No rounds match these filters.</p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see recent rounds from the\n          `rounds` table.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>Phase</th>\n            <th style={headerCellStyle(\"left\")}>Match ID</th>\n            <th style={headerCellStyle(\"left\")}>PDA</th>\n            <th style={headerCellStyle(\"left\")}>Creator</th>\n            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>\n            <th style={headerCellStyle(\"right\")}>Target slot</th>\n            <th style={headerCellStyle(\"right\")}>Settle attempts</th>\n            <th style={headerCellStyle(\"left\")}>Result side</th>\n            <th style={headerCellStyle(\"left\")}>Winner</th>\n            <th style={headerCellStyle(\"left\")}>Settle tx</th>\n            <th style={headerCellStyle(\"left\")}>Settled</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.pda} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.phase}\n                  tone={phaseTone(row.phase)}\n                />\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={row.matchId}>{truncate(row.matchId, 16)}</span>\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={row.pda}>{truncate(row.pda, 12)}</span>\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={row.creator}>{truncate(row.creator, 12)}</span>\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(row.amountLamports)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {row.targetSlot ? formatNumber(row.targetSlot) : \"—\"}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>{row.settleAttempts}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                {row.resultSide === null ? \"—\" : row.resultSide}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.winner ? (\n                  <span title={row.winner}>{truncate(row.winner, 12)}</span>\n                ) : (\n                  \"—\"\n                )}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.settleTx ? (\n                  <span title={row.settleTx}>{truncate(row.settleTx, 12)}</span>\n                ) : (\n                  \"—\"\n                )}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.settledAt ?? \"—\"}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction phaseTone(phase: PeekRoundPhase): PeekStatusTone {\n  if (phase === \"settled\") return \"positive\";\n  if (phase === \"expired\") return \"warning\";\n  if (phase === \"settling\") return \"info\";\n  if (phase === \"locked\") return \"info\";\n  return \"neutral\";\n}\n\nfunction truncate(value: string, max: number): string {\n  if (value.length <= max) return value;\n  const head = Math.max(2, Math.floor((max - 1) / 2));\n  const tail = Math.max(2, max - 1 - head);\n  return `${value.slice(0, head)}…${value.slice(-tail)}`;\n}\n\nfunction formatNumber(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":202,"startLine":1,"totalLines":202}}}
