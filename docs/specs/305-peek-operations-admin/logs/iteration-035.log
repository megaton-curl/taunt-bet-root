ocument();\n56\t    expect(screen.getByText(\"Wallet\")).toBeInTheDocument();\n57\t    expect(screen.getByText(\"Amount (lamports)\")).toBeInTheDocument();\n58\t    expect(screen.getByText(\"Status\")).toBeInTheDocument();\n59\t    expect(screen.getByText(\"Retries\")).toBeInTheDocument();\n60\t    expect(screen.getByText(\"Tx signature\")).toBeInTheDocument();\n61\t    expect(screen.getByText(\"Processed\")).toBeInTheDocument();\n62\t    expect(screen.getByText(\"Error\")).toBeInTheDocument();\n63\t\n64\t    // Drill-down per row, including userId fallback when username is null.\n65\t    expect(screen.getByRole(\"link\", { name: \"alice\" })).toHaveAttribute(\n66\t      \"href\",\n67\t      \"/users/u-1\",\n68\t    );\n69\t    expect(screen.getByRole(\"link\", { name: \"u-2\" })).toHaveAttribute(\n70\t      \"href\",\n71\t      \"/users/u-2\",\n72\t    );\n73\t    expect(screen.getByRole(\"link\", { name: \"carol\" })).toHaveAttribute(\n74\t      \"href\",\n75\t      \"/users/u-3\",\n76\t    );\n77\t\n78\t    // Lamport formatting.\n79\t    expect(screen.getByText(\"100,000\")).toBeInTheDocument();\n80\t    expect(screen.getByText(\"5,000,000\")).toBeInTheDocument();"}]},"parent_tool_use_id":null,"session_id":"dd0a8c11-be59-4445-8284-6991f0652708","uuid":"fa9749cb-4b53-4e6f-8638-4346c06727a3","timestamp":"2026-04-25T13:13:22.723Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/growth-claims-table.test.tsx","content":"import { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { GrowthClaimsTable } from \"../growth-claims-table\";\nimport type { PeekGrowthClaimRow } from \"../../lib/types/peek\";\n\nconst ROW_PENDING: PeekGrowthClaimRow = {\n  id: \"c-1\",\n  userId: \"u-1\",\n  username: \"alice\",\n  wallet: \"wallet-1\",\n  amountLamports: \"100000\",\n  status: \"pending\",\n  retryCount: 0,\n  txSignature: null,\n  error: null,\n  requestedAt: \"2026-04-25T10:00:00.000Z\",\n  processedAt: null,\n};\n\nconst ROW_COMPLETED: PeekGrowthClaimRow = {\n  id: \"c-2\",\n  userId: \"u-2\",\n  username: null,\n  wallet: \"wallet-2\",\n  amountLamports: \"5000000\",\n  status: \"completed\",\n  retryCount: 1,\n  txSignature: \"5VfYDnXUcS6mWY3cQy4ipcM5LQqM\",\n  error: null,\n  requestedAt: \"2026-04-24T10:00:00.000Z\",\n  processedAt: \"2026-04-24T11:00:00.000Z\",\n};\n\nconst ROW_FAILED: PeekGrowthClaimRow = {\n  id: \"c-3\",\n  userId: \"u-3\",\n  username: \"carol\",\n  wallet: \"wallet-3\",\n  amountLamports: \"250000\",\n  status: \"failed\",\n  retryCount: 3,\n  txSignature: null,\n  error: \"tx simulation failed\",\n  requestedAt: \"2026-04-23T10:00:00.000Z\",\n  processedAt: \"2026-04-23T11:00:00.000Z\",\n};\n\ndescribe(\"GrowthClaimsTable\", () => {\n  it(\"populated: renders all operator columns, formatted lamports, drill-down, and the right status tone per row\", () => {\n    render(\n      <GrowthClaimsTable rows={[ROW_PENDING, ROW_COMPLETED, ROW_FAILED]} />,\n    );\n\n    expect(screen.getByText(\"Requested\")).toBeInTheDocument();\n    expect(screen.getByText(\"User\")).toBeInTheDocument();\n    expect(screen.getByText(\"Wallet\")).toBeInTheDocument();\n    expect(screen.getByText(\"Amount (lamports)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Status\")).toBeInTheDocument();\n    expect(screen.getByText(\"Retries\")).toBeInTheDocument();\n    expect(screen.getByText(\"Tx signature\")).toBeInTheDocument();\n    expect(screen.getByText(\"Processed\")).toBeInTheDocument();\n    expect(screen.getByText(\"Error\")).toBeInTheDocument();\n\n    // Drill-down per row, including userId fallback when username is null.\n    expect(screen.getByRole(\"link\", { name: \"alice\" })).toHaveAttribute(\n      \"href\",\n      \"/users/u-1\",\n    );\n    expect(screen.getByRole(\"link\", { name: \"u-2\" })).toHaveAttribute(\n      \"href\",\n      \"/users/u-2\",\n    );\n    expect(screen.getByRole(\"link\", { name: \"carol\" })).toHaveAttribute(\n      \"href\",\n      \"/users/u-3\",\n    );\n\n    // Lamport formatting.\n    expect(screen.getByText(\"100,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"5,000,000\")).toBeInTheDocument();","numLines":80,"startLine":1,"totalLines":124}}}
