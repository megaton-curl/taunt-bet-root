{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GP6XyfgqDoveoW7ifZSLKA","type":"tool_result","content":"1\t// Query tests for the FR-9 points + crates economy admin reads\n2\t// (`get-points-and-crates.ts`).\n3\t//\n4\t// Mirrors the SQL-mock pattern from `get-rewards.test.ts` and\n5\t// `get-growth-referrals.test.ts`: a tagged-template stub records each call\n6\t// (joined SQL text + bound values) and dequeues a per-call response so each\n7\t// test can assert which SQL fired, in what order, and with which clamps.\n8\t\n9\timport { describe, expect, it } from \"vitest\";\n10\timport type { Sql } from \"postgres\";\n11\timport {\n12\t  PEEK_CRATE_DROPS_DEFAULT_LIMIT,\n13\t  PEEK_CRATE_DROPS_MAX_LIMIT,\n14\t  PEEK_PLAYER_POINTS_DEFAULT_LIMIT,\n15\t  PEEK_PLAYER_POINTS_MAX_LIMIT,\n16\t  PEEK_POINT_GRANTS_DEFAULT_LIMIT,\n17\t  PEEK_POINT_GRANTS_MAX_LIMIT,\n18\t  listCrateDrops,\n19\t  listPlayerPoints,\n20\t  listPointGrants,\n21\t} from \"../get-points-and-crates\";\n22\t\n23\ttype SqlCall = {\n24\t  text: string;\n25\t  values: ReadonlyArray<unknown>;\n26\t};\n27\t\n28\ttype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n29\t\n30\ttype SqlMock = {\n31\t  sql: Sql;\n32\t  calls: ReadonlyArray<SqlCall>;\n33\t};\n34\t\n35\tfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n36\t  const calls: SqlCall[] = [];\n37\t  let cursor = 0;\n38\t\n39\t  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n40\t    const text = [...strings].join(\"?\");\n41\t    calls.push({ text, values: [...values] });\n42\t    const next = responses[cursor++];\n43\t    if (next instanceof Error) return Promise.reject(next);\n44\t    return Promise.resolve(next ?? []);\n45\t  };\n46\t\n47\t  const sql = fn as unknown as Sql;\n48\t  return { sql, calls };\n49\t}\n50\t\n51\tdescribe(\"listPlayerPoints\", () => {\n52\t  it(\"default limit: clamps to PEEK_PLAYER_POINTS_DEFAULT_LIMIT and reads from player_points joined with player_profiles\", async () => {\n53\t    const mock = createSqlMock([[]]);\n54\t    await listPlayerPoints({ sql: mock.sql });\n55\t\n56\t    expect(mock.calls).toHaveLength(1);\n57\t    const call = mock.calls[0];\n58\t    expect(call.text).toMatch(/from player_points pp/i);\n59\t    expect(call.text).toMatch(\n60\t      /left join player_profiles prof on prof\\.user_id = pp\\.user_id/i,\n61\t    );\n62\t    expect(call.text).toMatch(/order by pp\\.balance desc, pp\\.user_id asc/i);\n63\t    expect(call.values).toContain(PEEK_PLAYER_POINTS_DEFAULT_LIMIT);\n64\t  });\n65\t\n66\t  it(\"explicit limit: passes the caller value through clampLimit\", async () => {\n67\t    const mock = createSqlMock([[]]);\n68\t    await listPlayerPoints({ sql: mock.sql, limit: 25 });\n69\t    expect(mock.calls[0].values).toContain(25);\n70\t  });\n71\t\n72\t  it(\"limit clamps to MAX when caller asks for more\", async () => {\n73\t    const mock = createSqlMock([[]]);\n74\t    await listPlayerPoints({\n75\t      sql: mock.sql,\n76\t      limit: PEEK_PLAYER_POINTS_MAX_LIMIT + 100,\n77\t    });\n78\t    expect(mock.calls[0].values).toContain(PEEK_PLAYER_POINTS_MAX_LIMIT);\n79\t  });\n80\t\n81\t  it(\"non-positive limit clamps to 1\", async () => {\n82\t    const mock = createSqlMock([[]]);\n83\t    await listPlayerPoints({ sql: mock.sql, limit: 0 });\n84\t    expect(mock.calls[0].values).toContain(1);\n85\t  });\n86\t\n87\t  it(\"non-finite limit falls back to the default\", async () => {\n88\t    const mock = createSqlMock([[]]);\n89\t    await listPlayerPoints({ sql: mock.sql, limit: Number.NaN });\n90\t    expect(mock.calls[0].values).toContain(PEEK_PLAYER_POINTS_DEFAULT_LIMIT);\n91\t  });\n92\t\n93\t  it(\"filters: empty filters bind null sentinels so the where-clause skips both predicates\", async () => {\n94\t    const mock = createSqlMock([[]]);\n95\t    await listPlayerPoints({ sql: mock.sql, filters: {} });\n96\t\n97\t    // The query uses (${userId === null} or pp.user_id = ${userId ?? \"\"}) so\n98\t    // when both are null, two `true` sentinels and two empty-string placeholders\n99\t    // are bound.\n100\t    expect(mock.calls[0].values).toContain(true);"}]},"parent_tool_use_id":null,"session_id":"0cbf8989-e666-4653-9e0d-3f545ba95bca","uuid":"0a3fb923-35f0-4c35-85c6-17afc471440b","timestamp":"2026-04-26T06:23:08.204Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-points-and-crates.test.ts","content":"// Query tests for the FR-9 points + crates economy admin reads\n// (`get-points-and-crates.ts`).\n//\n// Mirrors the SQL-mock pattern from `get-rewards.test.ts` and\n// `get-growth-referrals.test.ts`: a tagged-template stub records each call\n// (joined SQL text + bound values) and dequeues a per-call response so each\n// test can assert which SQL fired, in what order, and with which clamps.\n\nimport { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_CRATE_DROPS_DEFAULT_LIMIT,\n  PEEK_CRATE_DROPS_MAX_LIMIT,\n  PEEK_PLAYER_POINTS_DEFAULT_LIMIT,\n  PEEK_PLAYER_POINTS_MAX_LIMIT,\n  PEEK_POINT_GRANTS_DEFAULT_LIMIT,\n  PEEK_POINT_GRANTS_MAX_LIMIT,\n  listCrateDrops,\n  listPlayerPoints,\n  listPointGrants,\n} from \"../get-points-and-crates\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\ndescribe(\"listPlayerPoints\", () => {\n  it(\"default limit: clamps to PEEK_PLAYER_POINTS_DEFAULT_LIMIT and reads from player_points joined with player_profiles\", async () => {\n    const mock = createSqlMock([[]]);\n    await listPlayerPoints({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expect(call.text).toMatch(/from player_points pp/i);\n    expect(call.text).toMatch(\n      /left join player_profiles prof on prof\\.user_id = pp\\.user_id/i,\n    );\n    expect(call.text).toMatch(/order by pp\\.balance desc, pp\\.user_id asc/i);\n    expect(call.values).toContain(PEEK_PLAYER_POINTS_DEFAULT_LIMIT);\n  });\n\n  it(\"explicit limit: passes the caller value through clampLimit\", async () => {\n    const mock = createSqlMock([[]]);\n    await listPlayerPoints({ sql: mock.sql, limit: 25 });\n    expect(mock.calls[0].values).toContain(25);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listPlayerPoints({\n      sql: mock.sql,\n      limit: PEEK_PLAYER_POINTS_MAX_LIMIT + 100,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_PLAYER_POINTS_MAX_LIMIT);\n  });\n\n  it(\"non-positive limit clamps to 1\", async () => {\n    const mock = createSqlMock([[]]);\n    await listPlayerPoints({ sql: mock.sql, limit: 0 });\n    expect(mock.calls[0].values).toContain(1);\n  });\n\n  it(\"non-finite limit falls back to the default\", async () => {\n    const mock = createSqlMock([[]]);\n    await listPlayerPoints({ sql: mock.sql, limit: Number.NaN });\n    expect(mock.calls[0].values).toContain(PEEK_PLAYER_POINTS_DEFAULT_LIMIT);\n  });\n\n  it(\"filters: empty filters bind null sentinels so the where-clause skips both predicates\", async () => {\n    const mock = createSqlMock([[]]);\n    await listPlayerPoints({ sql: mock.sql, filters: {} });\n\n    // The query uses (${userId === null} or pp.user_id = ${userId ?? \"\"}) so\n    // when both are null, two `true` sentinels and two empty-string placeholders\n    // are bound.\n    expect(mock.calls[0].values).toContain(true);","numLines":100,"startLine":1,"totalLines":344}}}
