{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01RvSF4rd9ytsHk4q7gCdCTZ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_017FgQ9B3bdnntftwCSCqfeF","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","old_string":"export type PeekChallengesOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};","new_string":"export type PeekChallengesOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};\n\n// --- Dogpile + fraud admin (FR-9) --------------------------------------------\n//\n// Browser-safe view models for the upcoming `/operations/dogpile` page and the\n// fraud-review surface. Reads two migration-011 tables in read-only mode (no\n// dogpile or fraud-flag editing — that lives behind the FR-14 mutation\n// framework, with `dogpile.cancel` and `fraud_flag.status.update` action ids\n// already declared in `peek/src/server/access-policy.ts`):\n//\n//   - dogpile_events       — scheduled / active / ended / cancelled lifecycle\n//     rows. Listed with the parent campaign (campaign_id is nullable so the\n//     join is a left join) plus per-event counts of `game_entries` and\n//     `point_grants` whose `created_at` falls within the dogpile window —\n//     these are the rows whose multiplier the worker applied (or would have\n//     applied), so they are the operator-readable \"linked\" set.\n//   - fraud_flags          — read-only review queue with status\n//     ('open' / 'reviewed' / 'dismissed'). Listed with `player_profiles` for\n//     username + wallet context. The JSONB `details` column is preserved\n//     verbatim so the operator can paste the full body into a paste bin.\n//\n// All bigint identity ids round-trip as `text` to preserve precision (FR-4).\n// Status values stay loosely typed (string) so the migration's CHECK\n// constraints remain the single source of truth — passing an unknown value\n// just returns no rows.\n\nexport type PeekDogpileStatus =\n  | \"scheduled\"\n  | \"active\"\n  | \"ended\"\n  | \"cancelled\";\n\nexport const PEEK_DOGPILE_STATUSES: ReadonlyArray<PeekDogpileStatus> = [\n  \"scheduled\",\n  \"active\",\n  \"ended\",\n  \"cancelled\",\n];\n\nexport type PeekDogpileEventRow = {\n  id: string;\n  campaignId: string | null;\n  campaignName: string | null;\n  campaignType: string | null;\n  startsAt: string;\n  endsAt: string;\n  multiplier: string;\n  status: string;\n  createdAt: string;\n  gameEntryCount: number;\n  pointGrantCount: number;\n};\n\nexport type PeekDogpileEventFilters = {\n  status: string | null;\n  startsFrom: string | null;\n  startsTo: string | null;\n};\n\nexport type PeekFraudFlagListRow = {\n  id: string;\n  userId: string;\n  username: string | null;\n  wallet: string | null;\n  flagType: string;\n  status: string;\n  relatedId: string | null;\n  details: Record<string, unknown> | null;\n  createdAt: string;\n  resolvedAt: string | null;\n};\n\nexport type PeekFraudFlagFilters = {\n  status: string | null;\n  userId: string | null;\n  flagType: string | null;\n  createdFrom: string | null;\n  createdTo: string | null;\n};\n\nexport type PeekDogpileFraudOverviewMetricId =\n  | \"dogpile.scheduled\"\n  | \"dogpile.active\"\n  | \"dogpile.ended_window\"\n  | \"dogpile.cancelled_window\"\n  | \"fraud.open_flags\";\n\nexport const PEEK_DOGPILE_FRAUD_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekDogpileFraudOverviewMetricId> =\n  [\n    \"dogpile.scheduled\",\n    \"dogpile.active\",\n    \"dogpile.ended_window\",\n    \"dogpile.cancelled_window\",\n    \"fraud.open_flags\",\n  ];\n\nexport type PeekDogpileFraudOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2025,"cache_read_input_tokens":126191,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2025},"output_tokens":48,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"0cbf8989-e666-4653-9e0d-3f545ba95bca","uuid":"838e1608-e755-4d80-98eb-f6b5b9a69dda"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017FgQ9B3bdnntftwCSCqfeF","type":"tool_result","content":"The file /workspaces/rng-utopia/peek/src/lib/types/peek.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"0cbf8989-e666-4653-9e0d-3f545ba95bca","uuid":"b9cd22c0-e814-4000-94b1-bfcd96beea75","timestamp":"2026-04-26T06:23:38.764Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","oldString":"export type PeekChallengesOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};","newString":"export type PeekChallengesOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};\n\n// --- Dogpile + fraud admin (FR-9) --------------------------------------------\n//\n// Browser-safe view models for the upcoming `/operations/dogpile` page and the\n// fraud-review surface. Reads two migration-011 tables in read-only mode (no\n// dogpile or fraud-flag editing — that lives behind the FR-14 mutation\n// framework, with `dogpile.cancel` and `fraud_flag.status.update` action ids\n// already declared in `peek/src/server/access-policy.ts`):\n//\n//   - dogpile_events       — scheduled / active / ended / cancelled lifecycle\n//     rows. Listed with the parent campaign (campaign_id is nullable so the\n//     join is a left join) plus per-event counts of `game_entries` and\n//     `point_grants` whose `created_at` falls within the dogpile window —\n//     these are the rows whose multiplier the worker applied (or would have\n//     applied), so they are the operator-readable \"linked\" set.\n//   - fraud_flags          — read-only review queue with status\n//     ('open' / 'reviewed' / 'dismissed'). Listed with `player_profiles` for\n//     username + wallet context. The JSONB `details` column is preserved\n//     verbatim so the operator can paste the full body into a paste bin.\n//\n// All bigint identity ids round-trip as `text` to preserve precision (FR-4).\n// Status values stay loosely typed (string) so the migration's CHECK\n// constraints remain the single source of truth — passing an unknown value\n// just returns no rows.\n\nexport type PeekDogpileStatus =\n  | \"scheduled\"\n  | \"active\"\n  | \"ended\"\n  | \"cancelled\";\n\nexport const PEEK_DOGPILE_STATUSES: ReadonlyArray<PeekDogpileStatus> = [\n  \"scheduled\",\n  \"active\",\n  \"ended\",\n  \"cancelled\",\n];\n\nexport type PeekDogpileEventRow = {\n  id: string;\n  campaignId: string | null;\n  campaignName: string | null;\n  campaignType: string | null;\n  startsAt: string;\n  endsAt: string;\n  multiplier: string;\n  status: string;\n  createdAt: string;\n  gameEntryCount: number;\n  pointGrantCount: number;\n};\n\nexport type PeekDogpileEventFilters = {\n  status: string | null;\n  startsFrom: string | null;\n  startsTo: string | null;\n};\n\nexport type PeekFraudFlagListRow = {\n  id: string;\n  userId: string;\n  username: string | null;\n  wallet: string | null;\n  flagType: string;\n  status: string;\n  relatedId: string | null;\n  details: Record<string, unknown> | null;\n  createdAt: string;\n  resolvedAt: string | null;\n};\n\nexport type PeekFraudFlagFilters = {\n  status: string | null;\n  userId: string | null;\n  flagType: string | null;\n  createdFrom: string | null;\n  createdTo: string | null;\n};\n\nexport type PeekDogpileFraudOverviewMetricId =\n  | \"dogpile.scheduled\"\n  | \"dogpile.active\"\n  | \"dogpile.ended_window\"\n  | \"dogpile.cancelled_window\"\n  | \"fraud.open_flags\";\n\nexport const PEEK_DOGPILE_FRAUD_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekDogpileFraudOverviewMetricId> =\n  [\n    \"dogpile.scheduled\",\n    \"dogpile.active\",\n    \"dogpile.ended_window\",\n    \"dogpile.cancelled_window\",\n    \"fraud.open_flags\",\n  ];\n\nexport type PeekDogpileFraudOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};","originalFile":"// Browser-safe view-model primitives for `peek`.\n//\n// Foundational shapes used across feature pages: metric metadata (FR-4),\n// URL-addressable table filters, pagination, sort, and a small table-row base\n// type that per-feature row types can extend. Per-feature shapes (PeekUserRow,\n// PeekUserDetail, future referral/game/queue/etc. rows) live alongside or\n// extend these primitives.\n\nimport type { PeekRole } from \"../access-policy\";\n\n// --- Existing 303-era shapes (kept stable for current callers) ---------------\n\nexport type PeekSummary = {\n  totalUsers: number;\n  totalUsersWithCodes: number;\n  totalReferredUsers: number;\n  totalUniqueReferrers: number;\n};\n\nexport type PeekUserRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  joinedAt: string;\n  referralCode: string | null;\n  referrerUserId: string | null;\n  referrerCode: string | null;\n  refereeCount: number;\n  telegramUsername: string | null;\n  telegramUserId: string | null;\n};\n\n// --- Expanded user-detail shapes (FR-6) --------------------------------------\n//\n// Per-section row types for the full support/audit user profile. Lamports and\n// numeric/precision-sensitive values arrive as `text` to preserve precision; the\n// UI re-formats at render time. All shapes are browser-safe (no server imports).\n\nexport type PeekLinkedAccountRow = {\n  id: string;\n  provider: string;\n  providerAccountId: string;\n  status: string;\n  telegramUsername: string | null;\n  metadataJson: Record<string, unknown> | null;\n  linkedAt: string;\n  updatedAt: string;\n};\n\nexport type PeekTelegramLinkTokenRow = {\n  id: string;\n  status: string;\n  telegramUserId: string | null;\n  telegramUsername: string | null;\n  expiresAt: string;\n  redeemedAt: string | null;\n  createdAt: string;\n};\n\nexport type PeekKolRate = {\n  rateBps: number;\n  setBy: string;\n  createdAt: string;\n  updatedAt: string;\n};\n\nexport type PeekReferralEarningsSummary = {\n  earningsCount: number;\n  totalReferrerEarnedLamports: string;\n  totalRefereeRebateLamports: string;\n  lastEarnedAt: string | null;\n};\n\nexport type PeekReferralClaimRow = {\n  id: string;\n  amountLamports: string;\n  status: string;\n  retryCount: number;\n  txSignature: string | null;\n  error: string | null;\n  requestedAt: string;\n  processedAt: string | null;\n};\n\nexport type PeekPointGrantRow = {\n  id: string;\n  sourceType: string;\n  sourceId: string;\n  amount: string;\n  createdAt: string;\n};\n\nexport type PeekPlayerPoints = {\n  balance: string;\n  lifetimeEarned: string;\n  updatedAt: string | null;\n};\n\nexport type PeekCrateDropRow = {\n  id: string;\n  triggerType: string;\n  triggerId: string;\n  crateType: string;\n  contentsAmount: string;\n  status: string;\n  createdAt: string;\n  grantedAt: string | null;\n};\n\nexport type PeekChallengeAssignmentSummary = {\n  active: number;\n  completed: number;\n  expired: number;\n  total: number;\n};\n\nexport type PeekGameEntryRow = {\n  id: string;\n  game: string;\n  roundPda: string;\n  matchId: string;\n  amountLamports: string;\n  side: string | null;\n  isWinner: boolean | null;\n  payoutLamports: string;\n  createdAt: string;\n  settledAt: string | null;\n};\n\nexport type PeekTransactionRow = {\n  id: string;\n  game: string;\n  matchId: string;\n  txType: string;\n  amountLamports: string;\n  txSig: string;\n  createdAt: string;\n};\n\nexport type PeekFraudFlagRow = {\n  id: string;\n  flagType: string;\n  status: string;\n  relatedId: string | null;\n  createdAt: string;\n  resolvedAt: string | null;\n};\n\nexport type PeekUserQueueEventRow = {\n  id: string;\n  eventType: string;\n  status: string;\n  attempts: number;\n  maxAttempts: number;\n  scheduledAt: string;\n  createdAt: string;\n  error: string | null;\n};\n\nexport type PeekUserAttentionFlags = {\n  failedClaim: boolean;\n  deadQueueEvent: boolean;\n  activeFraudFlag: boolean;\n  pendingSolCratePayout: boolean;\n  suspiciousReferralLoop: boolean;\n};\n\nexport type PeekUserDetailUser = PeekUserRow & {\n  avatarUrl: string | null;\n  heatMultiplier: string;\n  profilePointsBalance: string;\n};\n\nexport type PeekUserDetail = {\n  user: PeekUserDetailUser;\n  inboundReferral: {\n    referrerUserId: string | null;\n    referrerCode: string | null;\n    linkedAt: string | null;\n  };\n  outboundReferees: Array<{\n    refereeUserId: string;\n    refereeUsername: string | null;\n    createdAt: string;\n  }>;\n  telegram: {\n    state: \"active\" | \"none\";\n    telegramUserId: string | null;\n    telegramUsername: string | null;\n  };\n  linkedAccounts: ReadonlyArray<PeekLinkedAccountRow>;\n  recentTelegramLinkTokens: ReadonlyArray<PeekTelegramLinkTokenRow>;\n  kolRate: PeekKolRate | null;\n  referralEarnings: PeekReferralEarningsSummary;\n  recentReferralClaims: ReadonlyArray<PeekReferralClaimRow>;\n  points: PeekPlayerPoints;\n  recentPointGrants: ReadonlyArray<PeekPointGrantRow>;\n  recentCrateDrops: ReadonlyArray<PeekCrateDropRow>;\n  challengeSummary: PeekChallengeAssignmentSummary;\n  recentGameEntries: ReadonlyArray<PeekGameEntryRow>;\n  recentTransactions: ReadonlyArray<PeekTransactionRow>;\n  fraudFlags: ReadonlyArray<PeekFraudFlagRow>;\n  recentUserQueueEvents: ReadonlyArray<PeekUserQueueEventRow>;\n  attention: PeekUserAttentionFlags;\n};\n\n// --- Actor view model (browser-safe) -----------------------------------------\n\nexport type PeekActorView = {\n  email: string;\n  role: PeekRole;\n};\n\n// --- Metric metadata (FR-4) --------------------------------------------------\n//\n// Each metric carries the bookkeeping required by the data-surfacing standard:\n// stable id, label, value, source table/query, time window, \"as of\" timestamp,\n// short definition, optional unit, and optional drill-down link to the filtered\n// detail rows behind the number.\n\nexport type PeekMetricFreshness = \"live\" | \"cached\" | \"manual\" | \"sampled\";\n\nexport type PeekMetric = {\n  id: string;\n  label: string;\n  value: number | string | null;\n  valueDisplay: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  asOf: string | null;\n  definition: string;\n  freshness: PeekMetricFreshness;\n  drilldownHref: string | null;\n};\n\n// --- Pagination primitive ----------------------------------------------------\n\nexport type PeekPagination = {\n  page: number;\n  pageSize: number;\n  totalCount: number;\n  totalPages: number;\n};\n\n// --- Sort primitive ----------------------------------------------------------\n\nexport type PeekSortDirection = \"asc\" | \"desc\";\n\nexport type PeekTableSort = {\n  column: string;\n  direction: PeekSortDirection;\n};\n\n// --- Table filter primitive (URL-addressable) --------------------------------\n\nexport type PeekFilterKind =\n  | \"text\"\n  | \"select\"\n  | \"boolean\"\n  | \"date\"\n  | \"dateRange\";\n\nexport type PeekFilterOption = {\n  value: string;\n  label: string;\n};\n\nexport type PeekTableFilter = {\n  id: string;\n  label: string;\n  kind: PeekFilterKind;\n  value: string | null;\n  options: ReadonlyArray<PeekFilterOption> | null;\n  placeholder: string | null;\n  required: boolean;\n};\n\n// --- Status chip tone (shared) -----------------------------------------------\n\nexport type PeekStatusTone =\n  | \"neutral\"\n  | \"positive\"\n  | \"warning\"\n  | \"negative\"\n  | \"info\";\n\n// --- Empty-state primitive ---------------------------------------------------\n\nexport type PeekEmptyState = {\n  title: string;\n  body: string | null;\n};\n\n// --- Table row + column primitives -------------------------------------------\n//\n// Per-feature row types extend `PeekTableRowBase` for the shared identifier +\n// optional drill-down link, then add feature-specific fields. The shared dense\n// table component reads `columns` for layout and per-row data via the typed\n// row shape supplied by the feature page.\n\nexport type PeekTableColumnAlign = \"left\" | \"right\" | \"center\";\n\nexport type PeekTableColumn = {\n  id: string;\n  label: string;\n  align: PeekTableColumnAlign;\n  sortable: boolean;\n};\n\nexport type PeekTableRowBase = {\n  id: string;\n  href: string | null;\n};\n\nexport type PeekTableViewModel<TRow extends PeekTableRowBase> = {\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<TRow>;\n  pagination: PeekPagination;\n  filters: ReadonlyArray<PeekTableFilter>;\n  sort: PeekTableSort | null;\n  empty: PeekEmptyState;\n};\n\n// --- Command-center attention queue (FR-3, FR-10) ----------------------------\n//\n// The command-center page surfaces a small set of \"needs attention\" metrics so\n// operators see exception states (failed claims, dead queue events, stuck\n// settlements, pending SOL crate payouts, stale active Dogpile events,\n// high-value export activity) before they dig into per-feature pages. Each\n// item is a `PeekMetric` so the metric-strip primitive renders it with the\n// FR-4 bookkeeping (definition, source, time window, \"as of\", drill-down).\n\nexport type PeekCommandCenterAttentionId =\n  | \"failed_claims\"\n  | \"dead_queue_events\"\n  | \"stuck_rounds_flipyou_potshot\"\n  | \"stuck_rounds_closecall\"\n  | \"pending_sol_crate_payouts\"\n  | \"stale_active_dogpile_events\"\n  | \"high_value_exports_24h\";\n\nexport type PeekCommandCenterAttention = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};\n\n// --- Recent operator activity (FR-3 command-center \"high-signal activity\") ---\n//\n// Compact projection of the latest `operator_events` rows for the command-center\n// \"Recent activity\" section. Pulled from the same JSONB payload the audit\n// writer persists, but kept narrow on purpose — the command center surfaces\n// only the few fields needed to recognize what happened, not the full payload.\n// The audit view (`/audit`, later iteration) renders the full bounded table.\n\nexport type PeekRecentActivityItem = {\n  id: string;\n  eventType: string;\n  actorEmail: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  route: string | null;\n  createdAt: string;\n};\n\n// --- Audit event contracts (FR-11) -------------------------------------------\n//\n// Browser-safe view of `operator_events` rows the audit writer produces under\n// `peek.*` event types. The `PeekAuditPayload` shape pins the fields required by\n// FR-11 so the writer (`peek/src/server/audit/**`, next iteration) and the audit\n// view (`/audit`, later iteration) agree on a serialization contract. Secrets\n// (JWTs, access tokens, DB URLs, private keys, raw secrets) must be replaced by\n// `PEEK_AUDIT_REDACTED` before persisting; the audit-view component renders the\n// token verbatim so reviewers can see that a field was redacted (not silently\n// absent).\n\nexport type PeekAuditEventType =\n  | \"peek.search\"\n  | \"peek.user.view_sensitive\"\n  | \"peek.export\"\n  | \"peek.access.denied\"\n  | \"peek.change.applied\"\n  | \"peek.change.rejected\";\n\nexport const PEEK_AUDIT_EVENT_TYPES: ReadonlyArray<PeekAuditEventType> = [\n  \"peek.search\",\n  \"peek.user.view_sensitive\",\n  \"peek.export\",\n  \"peek.access.denied\",\n  \"peek.change.applied\",\n  \"peek.change.rejected\",\n];\n\nexport function isPeekAuditEventType(\n  value: unknown,\n): value is PeekAuditEventType {\n  return (\n    typeof value === \"string\" &&\n    (PEEK_AUDIT_EVENT_TYPES as ReadonlyArray<string>).includes(value)\n  );\n}\n\nexport const PEEK_AUDIT_REDACTED = \"[REDACTED]\";\n\nexport type PeekAuditScalar = string | number | boolean | null;\n\nexport type PeekAuditChange = {\n  field: string;\n  before: PeekAuditScalar;\n  after: PeekAuditScalar;\n};\n\nexport type PeekAuditPayload = {\n  actorEmail: string;\n  route: string | null;\n  actionId: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  filterSummary: string | null;\n  resultCount: number | null;\n  requestId: string | null;\n  rejectionReason: string | null;\n  changes: ReadonlyArray<PeekAuditChange> | null;\n};\n\nexport type PeekAuditEvent = {\n  id: string;\n  eventType: PeekAuditEventType;\n  createdAt: string;\n  payload: PeekAuditPayload;\n};\n\n// --- Export contracts (FR-12) ------------------------------------------------\n//\n// Exports are server-rendered CSVs gated by the same page-level access as the\n// source page, bounded by a server-side row cap, named with a deterministic\n// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n// bytes return. Export rows reuse the table view-model column ids so the export\n// shape stays in lockstep with the rendered table; values are pre-formatted\n// strings so CSV serialization stays straightforward and locale-stable.\n\nexport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n\nexport type PeekExportEntity =\n  | \"users\"\n  | \"referrers\"\n  | \"kol\"\n  | \"claims\"\n  | \"rounds\"\n  | \"transactions\"\n  | \"queue\"\n  | \"audit\";\n\nexport type PeekExportRow = Record<string, string>;\n\nexport type PeekExportFilenameInput = {\n  entity: PeekExportEntity;\n  date: string;\n  filterSlug: string;\n};\n\nexport type PeekExportResult = {\n  filename: string;\n  rowCount: number;\n  rowCap: number;\n  rowCapApplied: boolean;\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<PeekExportRow>;\n};\n\n// --- Universal search (FR-5) -------------------------------------------------\n//\n// One search entry point that resolves common operational identifiers to typed\n// result groups. Results are grouped by entity type so the UI can section them\n// (user, referral, linked account, round, transaction, queue event). Each\n// result includes enough context to disambiguate similar matches; sensitive\n// values (wallet, Telegram id, tx signature) live in the result's `id`/`label`\n// fields for operator readability and the audit event records only the actor\n// email, query class, and result counts (never the raw query, which the audit\n// writer redacts if it looks like a secret).\n\nexport type PeekSearchEntityType =\n  | \"user\"\n  | \"referral\"\n  | \"linked_account\"\n  | \"round\"\n  | \"transaction\"\n  | \"queue_event\";\n\nexport const PEEK_SEARCH_ENTITY_TYPES: ReadonlyArray<PeekSearchEntityType> = [\n  \"user\",\n  \"referral\",\n  \"linked_account\",\n  \"round\",\n  \"transaction\",\n  \"queue_event\",\n];\n\n// Coarse heuristic classification used only for the `peek.search` audit\n// summary so reviewers can see which class of identifier was searched without\n// inferring it from the (possibly redacted) raw query.\nexport type PeekSearchQueryClass =\n  | \"empty\"\n  | \"free_text\"\n  | \"user_id\"\n  | \"username\"\n  | \"wallet\"\n  | \"referral_code\"\n  | \"telegram_username\"\n  | \"telegram_provider_id\"\n  | \"round_pda\"\n  | \"match_id\"\n  | \"tx_signature\"\n  | \"queue_event_id\";\n\nexport type PeekSearchResult = {\n  entityType: PeekSearchEntityType;\n  id: string;\n  label: string;\n  sublabel: string | null;\n  context: string | null;\n  href: string;\n};\n\nexport type PeekSearchGroup = {\n  entityType: PeekSearchEntityType;\n  results: ReadonlyArray<PeekSearchResult>;\n  truncated: boolean;\n};\n\nexport type PeekSearchResponse = {\n  query: string;\n  queryClass: PeekSearchQueryClass;\n  groups: ReadonlyArray<PeekSearchGroup>;\n  totalResults: number;\n  perGroupLimit: number;\n  generatedAt: string;\n};\n\nexport const PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT = 5;\nexport const PEEK_SEARCH_MAX_PER_GROUP_LIMIT = 25;\n\n// --- Growth + referral admin (FR-7) ------------------------------------------\n//\n// Browser-safe view models for `/growth/referrals` and `/growth/kol`. The\n// engine queries surface (a) overview metrics that fit the FR-4 metric\n// bookkeeping, (b) top-referrer rows that combine `referral_links`,\n// `referral_codes`, `referral_earnings`, and pending `referral_claims` per\n// referrer, (c) KOL rows that join `referral_kol_rates` with linked\n// performance from `referral_links`/`referral_earnings`, (d) claim rows for\n// the filterable `/growth/referrals` claims table, and (e) a one-hop\n// referral-graph node that lets the UI navigate from a user-detail page to\n// the inbound referrer or any outbound referee and back.\n//\n// All numeric/precision-sensitive values arrive as `text` to preserve u64\n// lamport precision; the UI formats at render time.\n\nexport type PeekGrowthOverviewMetricId =\n  | \"growth.referrers\"\n  | \"growth.referred_users\"\n  | \"growth.activated_referred_users\"\n  | \"growth.referrer_earnings_lamports\"\n  | \"growth.referee_rebates_lamports\"\n  | \"growth.pending_claims_lamports\"\n  | \"growth.failed_claims\"\n  | \"growth.kol_count\";\n\nexport const PEEK_GROWTH_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekGrowthOverviewMetricId> =\n  [\n    \"growth.referrers\",\n    \"growth.referred_users\",\n    \"growth.activated_referred_users\",\n    \"growth.referrer_earnings_lamports\",\n    \"growth.referee_rebates_lamports\",\n    \"growth.pending_claims_lamports\",\n    \"growth.failed_claims\",\n    \"growth.kol_count\",\n  ];\n\nexport type PeekGrowthOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};\n\nexport type PeekTopReferrerRow = {\n  referrerUserId: string;\n  username: string | null;\n  wallet: string;\n  referralCode: string | null;\n  refereeCount: number;\n  activeRefereeCount: number;\n  referredWagerLamports: string;\n  referrerEarnedLamports: string;\n  pendingClaimLamports: string;\n};\n\nexport type PeekKolPerformanceRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  rateBps: number;\n  setBy: string;\n  createdAt: string;\n  updatedAt: string;\n  refereeCount: number;\n  referredWagerLamports: string;\n  referrerEarnedLamports: string;\n};\n\n// Status filter values mirror the migration check constraint:\n// 'pending' | 'processing' | 'error' | 'completed' | 'failed'. Treated as a\n// loose `string` here so the UI can pass through a \"failed_or_error\" virtual\n// alias without a contract change. Extends the per-user\n// `PeekReferralClaimRow` with the `userId`/`username`/`wallet` columns the\n// /growth/referrals claims table needs to render and link rows back to user\n// detail.\nexport type PeekGrowthClaimRow = PeekReferralClaimRow & {\n  userId: string;\n  username: string | null;\n  wallet: string;\n};\n\nexport type PeekReferralClaimFilters = {\n  status: string | null;\n  userId: string | null;\n  minAmountLamports: string | null;\n  maxAmountLamports: string | null;\n  requestedFrom: string | null;\n  requestedTo: string | null;\n  txSignature: string | null;\n  errorContains: string | null;\n};\n\nexport type PeekReferralGraphRefereeRow = {\n  refereeUserId: string;\n  refereeUsername: string | null;\n  refereeWallet: string;\n  createdAt: string;\n};\n\nexport type PeekReferralGraphInboundReferrer = {\n  referrerUserId: string | null;\n  referrerUsername: string | null;\n  referrerWallet: string | null;\n  referrerCode: string | null;\n  linkedAt: string | null;\n};\n\nexport type PeekReferralGraphNode = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  referralCode: string | null;\n  inboundReferrer: PeekReferralGraphInboundReferrer;\n  outboundReferees: ReadonlyArray<PeekReferralGraphRefereeRow>;\n};\n\n// --- Games overview (FR-8) ---------------------------------------------------\n//\n// Browser-safe view models for `/games`. The engine query reads the single\n// source of truth `game_entries` (migration 007) and produces (a) a small set\n// of platform-wide FR-4 metrics for the overview strip and (b) per-game rows\n// with the operational counters the spec calls out: entries, unique users,\n// wagered lamports, settled entries, refund entries, payout lamports, wins,\n// losses. Lamport sums round-trip as `text` to preserve u64 precision; the UI\n// formats at render time.\n//\n// `PeekGameId` mirrors the migration's CHECK constraint on `game_entries.game`\n// (`'flipyou' | 'potshot' | 'closecall'`). Deferred games (Crash, Game of\n// Trades, Chart the Course, Slots Utopia, Tug of Earn) are documented\n// placeholders rendered by the page; they intentionally are not part of the\n// data shape because they have no persisted source yet (system invariant 13).\n\nexport type PeekGameId = \"flipyou\" | \"potshot\" | \"closecall\";\n\nexport const PEEK_GAME_IDS: ReadonlyArray<PeekGameId> = [\n  \"flipyou\",\n  \"potshot\",\n  \"closecall\",\n];\n\nexport type PeekGameOverviewRow = {\n  game: PeekGameId;\n  entries: number;\n  uniqueUsers: number;\n  wageredLamports: string;\n  settledEntries: number;\n  refundEntries: number;\n  payoutLamports: string;\n  wins: number;\n  losses: number;\n};\n\nexport type PeekGameOverviewMetricId =\n  | \"games.total_entries\"\n  | \"games.unique_users\"\n  | \"games.wagered_lamports\"\n  | \"games.settled_entries\"\n  | \"games.refund_entries\"\n  | \"games.payout_lamports\";\n\nexport const PEEK_GAME_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekGameOverviewMetricId> =\n  [\n    \"games.total_entries\",\n    \"games.unique_users\",\n    \"games.wagered_lamports\",\n    \"games.settled_entries\",\n    \"games.refund_entries\",\n    \"games.payout_lamports\",\n  ];\n\nexport type PeekGameOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n  perGame: ReadonlyArray<PeekGameOverviewRow>;\n};\n\n// --- Per-game round detail (FR-8) --------------------------------------------\n//\n// Browser-safe view models for the round-detail surfaces backing\n// `/games/[game]`. Two distinct shapes because the underlying tables differ:\n//\n//   - FlipYou and Pot Shot share the `rounds` table (migration 001) — the\n//     CHECK constraint pins phase to one of five lifecycle states. Lamport\n//     and slot values are u64-precision and round-trip as `text`.\n//   - Close Call uses the separate `closecall_rounds` table (migration 004)\n//     with its own three-phase lifecycle and a Pyth-driven outcome column.\n//\n// `stuck-state filters` cover the four operational signals the spec calls\n// out: nonterminal-aged (created/locked/settling past the age threshold for\n// FlipYou/Pot Shot; open past the age threshold for Close Call), high settle\n// attempts (FlipYou/Pot Shot only — `closecall_rounds` has no\n// `settle_attempts`), settled rounds without an expected payout/refund\n// transaction in `transactions`, and refunds (phase `expired` for FlipYou/\n// Pot Shot; phase `refunded` or outcome `refund` for Close Call).\n\nexport type PeekRoundPhase =\n  | \"created\"\n  | \"locked\"\n  | \"settling\"\n  | \"settled\"\n  | \"expired\";\n\nexport const PEEK_ROUND_PHASES: ReadonlyArray<PeekRoundPhase> = [\n  \"created\",\n  \"locked\",\n  \"settling\",\n  \"settled\",\n  \"expired\",\n];\n\nexport type PeekRoundsGameId = Extract<PeekGameId, \"flipyou\" | \"potshot\">;\n\nexport const PEEK_ROUNDS_GAME_IDS: ReadonlyArray<PeekRoundsGameId> = [\n  \"flipyou\",\n  \"potshot\",\n];\n\nexport type PeekRoundRow = {\n  game: PeekRoundsGameId;\n  pda: string;\n  matchId: string;\n  phase: PeekRoundPhase;\n  creator: string;\n  targetSlot: string | null;\n  settleAttempts: number;\n  settleTx: string | null;\n  resultSide: number | null;\n  winner: string | null;\n  amountLamports: string;\n  createdAt: string;\n  updatedAt: string;\n  settledAt: string | null;\n};\n\nexport type PeekCloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n\nexport const PEEK_CLOSECALL_PHASES: ReadonlyArray<PeekCloseCallPhase> = [\n  \"open\",\n  \"settled\",\n  \"refunded\",\n];\n\nexport type PeekCloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n\nexport const PEEK_CLOSECALL_OUTCOMES: ReadonlyArray<PeekCloseCallOutcome> = [\n  \"pending\",\n  \"green\",\n  \"red\",\n  \"refund\",\n];\n\nexport type PeekCloseCallRoundRow = {\n  pda: string;\n  roundId: string;\n  phase: PeekCloseCallPhase;\n  outcome: PeekCloseCallOutcome;\n  openPrice: string;\n  openPriceExpo: number;\n  closePrice: string | null;\n  greenPoolLamports: string;\n  redPoolLamports: string;\n  totalFeeLamports: string;\n  settleTx: string | null;\n  createdAt: string;\n  settledAt: string | null;\n};\n\nexport type PeekRoundStuckFilters = {\n  nonterminalAged: boolean;\n  highAttempts: boolean;\n  settledWithoutTx: boolean;\n  refunds: boolean;\n};\n\nexport type PeekRoundFilters = {\n  phase: PeekRoundPhase | null;\n  search: string | null;\n  fromDate: string | null;\n  toDate: string | null;\n  stuck: PeekRoundStuckFilters;\n};\n\nexport type PeekCloseCallRoundStuckFilters = Omit<\n  PeekRoundStuckFilters,\n  \"highAttempts\"\n>;\n\nexport type PeekCloseCallRoundFilters = {\n  phase: PeekCloseCallPhase | null;\n  outcome: PeekCloseCallOutcome | null;\n  search: string | null;\n  fromDate: string | null;\n  toDate: string | null;\n  stuck: PeekCloseCallRoundStuckFilters;\n};\n\nexport type PeekRoundsListResult<TRow> = {\n  rows: ReadonlyArray<TRow>;\n  pagination: PeekPagination;\n};\n\n// --- Round detail (FR-8) -----------------------------------------------------\n//\n// Browser-safe view models for `/games/[game]/rounds/[roundId]`. The detail\n// joins the round summary (FlipYou/Pot Shot from `rounds`, Close Call from\n// `closecall_rounds`) with all participating `game_entries` and the related\n// `transactions` rows for the round (matched by `match_id` + `game`, where\n// `match_id` is `closecall_rounds.round_id` for the Close Call branch).\n//\n// Entries and transactions carry the operator-readable identity context the\n// detail page renders alongside each row (wallet always; user id + username\n// when the player has a `player_profiles` row). Lamport amounts and slot\n// values stay as `text` to preserve u64 precision.\n\nexport type PeekRoundEntryRow = {\n  id: string;\n  userId: string;\n  username: string | null;\n  wallet: string;\n  amountLamports: string;\n  side: string | null;\n  isWinner: boolean | null;\n  payoutLamports: string;\n  createdAt: string;\n  settledAt: string | null;\n};\n\nexport type PeekRoundTransactionRow = {\n  id: string;\n  userId: string | null;\n  username: string | null;\n  wallet: string;\n  txType: string;\n  amountLamports: string;\n  txSig: string;\n  createdAt: string;\n};\n\nexport type PeekRoundDetail =\n  | {\n      game: PeekRoundsGameId;\n      round: PeekRoundRow;\n      entries: ReadonlyArray<PeekRoundEntryRow>;\n      transactions: ReadonlyArray<PeekRoundTransactionRow>;\n    }\n  | {\n      game: \"closecall\";\n      round: PeekCloseCallRoundRow;\n      entries: ReadonlyArray<PeekRoundEntryRow>;\n      transactions: ReadonlyArray<PeekRoundTransactionRow>;\n    };\n\n// --- Economy: rewards (FR-9) -------------------------------------------------\n//\n// Browser-safe view models for `/economy/rewards`. Reads three migration-011\n// tables:\n//\n//   - reward_config           — operator-tunable economy parameters; each row\n//     is annotated server-side with a human-readable definition and an\n//     expected-value type from a static registry so the page can show what a\n//     key means without an extra docs lookup.\n//   - reward_pool             — singleton accounting row (balance, lifetime\n//     funded, lifetime paid, updated_at).\n//   - reward_pool_fundings    — append-only ledger of per-round funding events\n//     keyed on round_id (the source round whose fee fed the pool).\n//\n// Lamport / u64 values round-trip as `text` to preserve precision (FR-4).\n// Unknown reward_config keys still surface (with `definition: null` and\n// `expectedType: \"unknown\"`) so an operator immediately notices when a new\n// key has been seeded but the registry has not been updated.\n\nexport type PeekRewardConfigExpectedType =\n  | \"integer\"\n  | \"float\"\n  | \"ratio\"\n  | \"lamports\"\n  | \"unknown\";\n\nexport type PeekRewardConfigRow = {\n  key: string;\n  value: string;\n  updatedAt: string;\n  definition: string | null;\n  expectedType: PeekRewardConfigExpectedType;\n};\n\nexport type PeekRewardPool = {\n  balanceLamports: string;\n  lifetimeFunded: string;\n  lifetimePaid: string;\n  updatedAt: string;\n};\n\nexport type PeekRewardPoolFundingRow = {\n  id: string;\n  roundId: string;\n  feeLamports: string;\n  fundedLamports: string;\n  createdAt: string;\n};\n\nexport type PeekRewardsOverviewMetricId =\n  | \"rewards.balance_lamports\"\n  | \"rewards.lifetime_funded_lamports\"\n  | \"rewards.lifetime_paid_lamports\"\n  | \"rewards.recent_fundings\";\n\nexport const PEEK_REWARDS_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekRewardsOverviewMetricId> =\n  [\n    \"rewards.balance_lamports\",\n    \"rewards.lifetime_funded_lamports\",\n    \"rewards.lifetime_paid_lamports\",\n    \"rewards.recent_fundings\",\n  ];\n\nexport type PeekRewardsOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};\n\n// --- Points + crates ledger admin (FR-9) -------------------------------------\n//\n// Browser-safe view models for `/economy/points` and `/economy/crates`. Reads\n// three migration-011 tables:\n//\n//   - player_points     — per-user points balance + lifetime earned, listed\n//     across users and joined with `player_profiles` for username context.\n//   - point_grants      — append-only point-grant ledger; the cross-user row\n//     extends the per-user `PeekPointGrantRow` with the user identity columns\n//     the operator-facing list needs.\n//   - crate_drops       — per-user crate ledger with status (`pending`,\n//     `granted`, `failed`); the cross-user row extends `PeekCrateDropRow` with\n//     the same user identity columns.\n//\n// All bigint counters round-trip as `text` to preserve precision (FR-4). The\n// status / type / source-type values are loosely typed (string) so the UI can\n// pass through the same value the migration's CHECK constraints already\n// enforce server-side without a second source of truth here.\n\nexport type PeekPlayerPointsRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  balance: string;\n  lifetimeEarned: string;\n  updatedAt: string;\n};\n\nexport type PeekPlayerPointsFilters = {\n  userId: string | null;\n  wallet: string | null;\n};\n\nexport type PeekPointGrantLedgerRow = PeekPointGrantRow & {\n  userId: string;\n  username: string | null;\n  wallet: string;\n};\n\nexport type PeekPointGrantFilters = {\n  userId: string | null;\n  sourceType: string | null;\n  sourceId: string | null;\n  createdFrom: string | null;\n  createdTo: string | null;\n};\n\n// `wallet` is nullable because `crate_drops` has no wallet column of its own\n// and the join falls back to `player_profiles.wallet`; an orphaned crate_drop\n// (extremely rare — there is no FK constraint, but every drop is created\n// alongside a profile) renders with `wallet: null` rather than a fake \"\".\nexport type PeekCrateDropLedgerRow = PeekCrateDropRow & {\n  userId: string;\n  username: string | null;\n  wallet: string | null;\n};\n\nexport type PeekCrateDropFilters = {\n  userId: string | null;\n  crateType: string | null;\n  status: string | null;\n  triggerType: string | null;\n  createdFrom: string | null;\n  createdTo: string | null;\n};\n\n// --- Challenge engine admin (FR-9) -------------------------------------------\n//\n// Browser-safe view models for the upcoming `/economy/challenges` page. Reads\n// the migration-011 challenge engine tables in read-only mode (no challenge or\n// campaign editing — that is explicitly out of scope for FR-9 / FR-14):\n//\n//   - campaigns            — top-level container (daily / weekly / onboarding /\n//     dogpile). Listed with active/inactive flag + active assignment counts.\n//   - challenges           — challenge templates (data, not code). Listed with\n//     campaign name + reward shape; prerequisite chain is preserved via\n//     `prerequisiteId` for chained onboarding-style sequences.\n//   - challenge_assignments — per-player per-period assignments. Filterable by\n//     userId / challengeId / periodKey / status / created date.\n//   - progress_events      — append-only progress ledger that pinned a specific\n//     game round to an assignment. Filterable by assignmentId / userId /\n//     roundId / created date for anti-gaming audit.\n//   - completion_bonuses   — meta-quest definitions (e.g. \"complete all daily\n//     challenges → bonus crate\").\n//   - bonus_completions    — per-player per-period bonus completion ledger.\n//     Filterable by userId / bonusId / periodKey / completed date.\n//\n// All bigint identity ids round-trip as `text` to preserve precision (FR-4).\n// Status / scope / reward-type / campaign-type values are loosely typed\n// (string) so the UI passes through whatever the migration's CHECK constraints\n// already enforce server-side without a second source of truth here.\n\nexport type PeekCampaignRow = {\n  id: string;\n  name: string;\n  campaignType: string;\n  startsAt: string | null;\n  endsAt: string | null;\n  isActive: boolean;\n  createdAt: string;\n  challengeCount: number;\n  activeAssignmentCount: number;\n};\n\nexport type PeekChallengeRow = {\n  id: string;\n  campaignId: string;\n  campaignName: string | null;\n  campaignType: string | null;\n  title: string;\n  description: string | null;\n  action: string;\n  scope: string;\n  condition: string;\n  threshold: number;\n  rewardType: string;\n  rewardAmount: number | null;\n  prerequisiteId: string | null;\n  sortOrder: number;\n  isActive: boolean;\n  createdAt: string;\n};\n\nexport type PeekChallengeFilters = {\n  campaignId: string | null;\n  isActive: string | null;\n};\n\nexport type PeekChallengeAssignmentRow = {\n  id: string;\n  userId: string;\n  username: string | null;\n  challengeId: string;\n  challengeTitle: string | null;\n  campaignId: string | null;\n  campaignName: string | null;\n  periodKey: string;\n  status: string;\n  progress: number;\n  target: number;\n  assignedAt: string;\n  expiresAt: string | null;\n  completedAt: string | null;\n};\n\nexport type PeekChallengeAssignmentFilters = {\n  userId: string | null;\n  challengeId: string | null;\n  campaignId: string | null;\n  periodKey: string | null;\n  status: string | null;\n  assignedFrom: string | null;\n  assignedTo: string | null;\n};\n\nexport type PeekProgressEventRow = {\n  id: string;\n  assignmentId: string;\n  challengeId: string | null;\n  challengeTitle: string | null;\n  roundId: string;\n  userId: string;\n  username: string | null;\n  progressDelta: number;\n  createdAt: string;\n};\n\nexport type PeekProgressEventFilters = {\n  assignmentId: string | null;\n  challengeId: string | null;\n  userId: string | null;\n  roundId: string | null;\n  createdFrom: string | null;\n  createdTo: string | null;\n};\n\nexport type PeekCompletionBonusRow = {\n  id: string;\n  campaignId: string;\n  campaignName: string | null;\n  campaignType: string | null;\n  title: string;\n  description: string | null;\n  requiredCount: number;\n  rewardType: string;\n  rewardAmount: number | null;\n  isActive: boolean;\n  createdAt: string;\n  completionCount: number;\n};\n\nexport type PeekBonusCompletionRow = {\n  id: string;\n  userId: string;\n  username: string | null;\n  bonusId: string;\n  bonusTitle: string | null;\n  campaignId: string | null;\n  campaignName: string | null;\n  periodKey: string;\n  completedAt: string;\n};\n\nexport type PeekBonusCompletionFilters = {\n  userId: string | null;\n  bonusId: string | null;\n  campaignId: string | null;\n  periodKey: string | null;\n  completedFrom: string | null;\n  completedTo: string | null;\n};\n\nexport type PeekChallengesOverviewMetricId =\n  | \"challenges.active_campaigns\"\n  | \"challenges.active_challenges\"\n  | \"challenges.active_assignments\"\n  | \"challenges.completed_assignments_window\"\n  | \"challenges.bonus_completions_window\";\n\nexport const PEEK_CHALLENGES_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekChallengesOverviewMetricId> =\n  [\n    \"challenges.active_campaigns\",\n    \"challenges.active_challenges\",\n    \"challenges.active_assignments\",\n    \"challenges.completed_assignments_window\",\n    \"challenges.bonus_completions_window\",\n  ];\n\nexport type PeekChallengesOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};\n","structuredPatch":[{"oldStart":1191,"oldLines":3,"newStart":1191,"newLines":102,"lines":["   generatedAt: string;","   metrics: ReadonlyArray<PeekMetric>;"," };","+","+// --- Dogpile + fraud admin (FR-9) --------------------------------------------","+//","+// Browser-safe view models for the upcoming `/operations/dogpile` page and the","+// fraud-review surface. Reads two migration-011 tables in read-only mode (no","+// dogpile or fraud-flag editing — that lives behind the FR-14 mutation","+// framework, with `dogpile.cancel` and `fraud_flag.status.update` action ids","+// already declared in `peek/src/server/access-policy.ts`):","+//","+//   - dogpile_events       — scheduled / active / ended / cancelled lifecycle","+//     rows. Listed with the parent campaign (campaign_id is nullable so the","+//     join is a left join) plus per-event counts of `game_entries` and","+//     `point_grants` whose `created_at` falls within the dogpile window —","+//     these are the rows whose multiplier the worker applied (or would have","+//     applied), so they are the operator-readable \"linked\" set.","+//   - fraud_flags          — read-only review queue with status","+//     ('open' / 'reviewed' / 'dismissed'). Listed with `player_profiles` for","+//     username + wallet context. The JSONB `details` column is preserved","+//     verbatim so the operator can paste the full body into a paste bin.","+//","+// All bigint identity ids round-trip as `text` to preserve precision (FR-4).","+// Status values stay loosely typed (string) so the migration's CHECK","+// constraints remain the single source of truth — passing an unknown value","+// just returns no rows.","+","+export type PeekDogpileStatus =","+  | \"scheduled\"","+  | \"active\"","+  | \"ended\"","+  | \"cancelled\";","+","+export const PEEK_DOGPILE_STATUSES: ReadonlyArray<PeekDogpileStatus> = [","+  \"scheduled\",","+  \"active\",","+  \"ended\",","+  \"cancelled\",","+];","+","+export type PeekDogpileEventRow = {","+  id: string;","+  campaignId: string | null;","+  campaignName: string | null;","+  campaignType: string | null;","+  startsAt: string;","+  endsAt: string;","+  multiplier: string;","+  status: string;","+  createdAt: string;","+  gameEntryCount: number;","+  pointGrantCount: number;","+};","+","+export type PeekDogpileEventFilters = {","+  status: string | null;","+  startsFrom: string | null;","+  startsTo: string | null;","+};","+","+export type PeekFraudFlagListRow = {","+  id: string;","+  userId: string;","+  username: string | null;","+  wallet: string | null;","+  flagType: string;","+  status: string;","+  relatedId: string | null;","+  details: Record<string, unknown> | null;","+  createdAt: string;","+  resolvedAt: string | null;","+};","+","+export type PeekFraudFlagFilters = {","+  status: string | null;","+  userId: string | null;","+  flagType: string | null;","+  createdFrom: string | null;","+  createdTo: string | null;","+};","+","+export type PeekDogpileFraudOverviewMetricId =","+  | \"dogpile.scheduled\"","+  | \"dogpile.active\"","+  | \"dogpile.ended_window\"","+  | \"dogpile.cancelled_window\"","+  | \"fraud.open_flags\";","+","+export const PEEK_DOGPILE_FRAUD_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekDogpileFraudOverviewMetricId> =","+  [","+    \"dogpile.scheduled\",","+    \"dogpile.active\",","+    \"dogpile.ended_window\",","+    \"dogpile.cancelled_window\",","+    \"fraud.open_flags\",","+  ];","+","+export type PeekDogpileFraudOverview = {","+  generatedAt: string;","+  metrics: ReadonlyArray<PeekMetric>;","+};"]}],"userModified":false,"replaceAll":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01WuqqQHHr4A7BLb4gZvkkNt","type":"message","role":"assistant","content":[{"type":"text","text":"Now create the query module."}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1658,"cache_read_input_tokens":128216,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1658},"output_tokens":7,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"0cbf8989-e666-4653-9e0d-3f545ba95bca","uuid":"2c41f5a3-497e-4d03-bd87-be29a6789246"}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01WuqqQHHr4A7BLb4gZvkkNt","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_014YYckMcrimm5HWWrcMJn9j","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/db/queries/get-dogpile-and-fraud.ts","content":"// Dogpile + fraud admin queries (FR-9).\n//\n// Backs the upcoming `/operations/dogpile` page and the fraud-review surface.\n// Reads two migration-011 tables in read-only mode (no dogpile or fraud-flag\n// editing — that lives behind the FR-14 mutation framework; `dogpile.cancel`\n// and `fraud_flag.status.update` action ids are already declared in\n// `peek/src/server/access-policy.ts`):\n//\n//   - dogpile_events  — `listDogpileEvents` returns the scheduled / active /\n//     ended / cancelled lifecycle rows joined with the parent `campaigns` row\n//     (campaign_id is nullable so the join is a left join). Each row is\n//     annotated with the count of `game_entries` and `point_grants` whose\n//     `created_at` falls within the event's `[starts_at, ends_at)` window —\n//     this is the operator-readable \"linked\" set the spec calls out\n//     (FR-9 line 327: \"linked campaigns/game_entries/point_grants\"). There\n//     is no FK from those ledger tables to `dogpile_events`; the worker\n//     applies the multiplier purely based on the time window\n//     (`backend/src/queue/handlers/points-grant.ts`), so a window-based\n//     count is the closest operator-meaningful link.\n//\n//   - fraud_flags     — `listFraudFlags` returns the open / reviewed /\n//     dismissed review queue joined with `player_profiles` for username +\n//     wallet context. The JSONB `details` column round-trips verbatim so the\n//     operator-facing UI can show whatever metadata the writer attached.\n//     Read-only — every status transition is gated by the\n//     `fraud_flag.status.update` mutation action (FR-14, not yet built).\n//\n// `getDogpileFraudOverview` produces the FR-4 metric strip for the page:\n// scheduled, active, ended-in-window, cancelled-in-window, open fraud flags.\n//\n// All queries are bounded server-side (default 100, max 500). Bigint identity\n// ids round-trip as `text` to preserve precision; the dogpile multiplier is\n// returned as `text` because it is stored as `NUMERIC(4,2)` and the UI\n// formats it at render time.\n\nimport type { Sql } from \"postgres\";\nimport {\n  type PeekDogpileEventFilters,\n  type PeekDogpileEventRow,\n  type PeekDogpileFraudOverview,\n  type PeekDogpileFraudOverviewMetricId,\n  type PeekFraudFlagFilters,\n  type PeekFraudFlagListRow,\n  type PeekMetric,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT = 100;\nexport const PEEK_DOGPILE_EVENTS_MAX_LIMIT = 500;\nexport const PEEK_FRAUD_FLAGS_DEFAULT_LIMIT = 100;\nexport const PEEK_FRAUD_FLAGS_MAX_LIMIT = 500;\nexport const PEEK_DOGPILE_FRAUD_OVERVIEW_WINDOW_HOURS = 24;\n\nexport type ListDogpileEventsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekDogpileEventFilters>;\n};\n\nexport type ListFraudFlagsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekFraudFlagFilters>;\n};\n\nexport type DogpileFraudOverviewOptions = {\n  sql?: Sql;\n  now?: Date;\n  windowHours?: number;\n};\n\nfunction clampLimit(\n  raw: number | undefined,\n  fallback: number,\n  max: number,\n): number {\n  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n  const floored = Math.floor(raw);\n  if (floored <= 0) return 1;\n  return Math.min(max, floored);\n}\n\nfunction trimOrNull(value: string | null | undefined): string | null {\n  if (typeof value !== \"string\") return null;\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nfunction readInt(value: number | string | null | undefined): number {\n  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n  if (typeof value === \"string\") {\n    const parsed = Number.parseInt(value, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\nexport async function listDogpileEvents(\n  options: ListDogpileEventsOptions = {},\n): Promise<ReadonlyArray<PeekDogpileEventRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT,\n    PEEK_DOGPILE_EVENTS_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const status = trimOrNull(filters.status ?? null);\n  const startsFrom = trimOrNull(filters.startsFrom ?? null);\n  const startsTo = trimOrNull(filters.startsTo ?? null);\n\n  const rows = await sql<\n    Array<{\n      id: string;\n      campaignId: string | null;\n      campaignName: string | null;\n      campaignType: string | null;\n      startsAt: string;\n      endsAt: string;\n      multiplier: string;\n      status: string;\n      createdAt: string;\n      gameEntryCount: number | string;\n      pointGrantCount: number | string;\n    }>\n  >`\n    select\n      d.id::text as \"id\",\n      d.campaign_id::text as \"campaignId\",\n      c.name as \"campaignName\",\n      c.campaign_type as \"campaignType\",\n      d.starts_at::text as \"startsAt\",\n      d.ends_at::text as \"endsAt\",\n      d.multiplier::text as \"multiplier\",\n      d.status as \"status\",\n      d.created_at::text as \"createdAt\",\n      (\n        select count(*)::int\n        from game_entries ge\n        where ge.created_at >= d.starts_at\n          and ge.created_at < d.ends_at\n      ) as \"gameEntryCount\",\n      (\n        select count(*)::int\n        from point_grants pg\n        where pg.created_at >= d.starts_at\n          and pg.created_at < d.ends_at\n      ) as \"pointGrantCount\"\n    from dogpile_events d\n    left join campaigns c on c.id = d.campaign_id\n    where\n      (${status === null} or d.status = ${status ?? \"\"})\n      and (${startsFrom === null} or d.starts_at >= ${startsFrom ?? \"\"}::timestamptz)\n      and (${startsTo === null} or d.starts_at < ${startsTo ?? \"\"}::timestamptz)\n    order by d.starts_at desc, d.id desc\n    limit ${limit}\n  `;\n\n  return rows.map((row) => ({\n    id: row.id,\n    campaignId: row.campaignId,\n    campaignName: row.campaignName,\n    campaignType: row.campaignType,\n    startsAt: row.startsAt,\n    endsAt: row.endsAt,\n    multiplier: row.multiplier,\n    status: row.status,\n    createdAt: row.createdAt,\n    gameEntryCount: readInt(row.gameEntryCount),\n    pointGrantCount: readInt(row.pointGrantCount),\n  }));\n}\n\nexport async function listFraudFlags(\n  options: ListFraudFlagsOptions = {},\n): Promise<ReadonlyArray<PeekFraudFlagListRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_FRAUD_FLAGS_DEFAULT_LIMIT,\n    PEEK_FRAUD_FLAGS_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const status = trimOrNull(filters.status ?? null);\n  const userId = trimOrNull(filters.userId ?? null);\n  const flagType = trimOrNull(filters.flagType ?? null);\n  const createdFrom = trimOrNull(filters.createdFrom ?? null);\n  const createdTo = trimOrNull(filters.createdTo ?? null);\n\n  const rows = await sql<\n    Array<{\n      id: string;\n      userId: string;\n      username: string | null;\n      wallet: string | null;\n      flagType: string;\n      status: string;\n      relatedId: string | null;\n      details: Record<string, unknown> | null;\n      createdAt: string;\n      resolvedAt: string | null;\n    }>\n  >`\n    select\n      f.id::text as \"id\",\n      f.user_id as \"userId\",\n      prof.username as \"username\",\n      prof.wallet as \"wallet\",\n      f.flag_type as \"flagType\",\n      f.status as \"status\",\n      f.related_id as \"relatedId\",\n      f.details as \"details\",\n      f.created_at::text as \"createdAt\",\n      f.resolved_at::text as \"resolvedAt\"\n    from fraud_flags f\n    left join player_profiles prof on prof.user_id = f.user_id\n    where\n      (${status === null} or f.status = ${status ?? \"\"})\n      and (${userId === null} or f.user_id = ${userId ?? \"\"})\n      and (${flagType === null} or f.flag_type = ${flagType ?? \"\"})\n      and (${createdFrom === null} or f.created_at >= ${createdFrom ?? \"\"}::timestamptz)\n      and (${createdTo === null} or f.created_at < ${createdTo ?? \"\"}::timestamptz)\n    order by\n      case f.status when 'open' then 0 when 'reviewed' then 1 else 2 end,\n      f.created_at desc,\n      f.id desc\n    limit ${limit}\n  `;\n\n  return rows.map((row) => ({\n    id: row.id,\n    userId: row.userId,\n    username: row.username,\n    wallet: row.wallet,\n    flagType: row.flagType,\n    status: row.status,\n    relatedId: row.relatedId,\n    details: row.details,\n    createdAt: row.createdAt,\n    resolvedAt: row.resolvedAt,\n  }));\n}\n\ntype MetricBlueprint = {\n  id: PeekDogpileFraudOverviewMetricId;\n  label: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  definition: string;\n  drilldownHref: string | null;\n};\n\nfunction buildMetric(\n  blueprint: MetricBlueprint,\n  raw: number,\n  display: string,\n  asOf: string,\n): PeekMetric {\n  return {\n    id: blueprint.id,\n    label: blueprint.label,\n    value: raw,\n    valueDisplay: display,\n    unit: blueprint.unit,\n    source: blueprint.source,\n    windowLabel: blueprint.windowLabel,\n    asOf,\n    definition: blueprint.definition,\n    freshness: \"live\",\n    drilldownHref: blueprint.drilldownHref,\n  };\n}\n\nexport async function getDogpileFraudOverview(\n  options: DogpileFraudOverviewOptions = {},\n): Promise<PeekDogpileFraudOverview> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n  const windowHours = clampLimit(\n    options.windowHours,\n    PEEK_DOGPILE_FRAUD_OVERVIEW_WINDOW_HOURS,\n    24 * 30,\n  );\n  const since = new Date(now.getTime() - windowHours * 60 * 60 * 1000);\n  const sinceIso = since.toISOString();\n\n  const [\n    scheduledRows,\n    activeRows,\n    endedWindowRows,\n    cancelledWindowRows,\n    openFraudRows,\n  ] = await Promise.all([\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from dogpile_events\n      where status = 'scheduled'\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from dogpile_events\n      where status = 'active'\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from dogpile_events\n      where status = 'ended'\n        and ends_at >= ${sinceIso}::timestamptz\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from dogpile_events\n      where status = 'cancelled'\n        and created_at >= ${sinceIso}::timestamptz\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from fraud_flags\n      where status = 'open'\n    `,\n  ]);\n\n  const scheduled = readInt(scheduledRows[0]?.value ?? 0);\n  const active = readInt(activeRows[0]?.value ?? 0);\n  const endedWindow = readInt(endedWindowRows[0]?.value ?? 0);\n  const cancelledWindow = readInt(cancelledWindowRows[0]?.value ?? 0);\n  const openFraud = readInt(openFraudRows[0]?.value ?? 0);\n\n  const windowLabel = `Last ${windowHours}h`;\n\n  const blueprints: ReadonlyArray<{\n    blueprint: MetricBlueprint;\n    raw: number;\n    display: string;\n  }> = [\n    {\n      blueprint: {\n        id: \"dogpile.scheduled\",\n        label: \"Scheduled events\",\n        unit: \"events\",\n        source: \"dogpile_events\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of dogpile_events rows with status = 'scheduled' — events booked but not yet active.\",\n        drilldownHref: \"/operations/dogpile?status=scheduled\",\n      },\n      raw: scheduled,\n      display: formatCount(scheduled),\n    },\n    {\n      blueprint: {\n        id: \"dogpile.active\",\n        label: \"Active events\",\n        unit: \"events\",\n        source: \"dogpile_events\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of dogpile_events rows with status = 'active' — events currently applying their multiplier to point grants.\",\n        drilldownHref: \"/operations/dogpile?status=active\",\n      },\n      raw: active,\n      display: formatCount(active),\n    },\n    {\n      blueprint: {\n        id: \"dogpile.ended_window\",\n        label: \"Ended events\",\n        unit: \"events\",\n        source: \"dogpile_events\",\n        windowLabel,\n        definition: `Count of dogpile_events rows with status = 'ended' whose ends_at falls within the last ${windowHours} hours.`,\n        drilldownHref: \"/operations/dogpile?status=ended\",\n      },\n      raw: endedWindow,\n      display: formatCount(endedWindow),\n    },\n    {\n      blueprint: {\n        id: \"dogpile.cancelled_window\",\n        label: \"Cancelled events\",\n        unit: \"events\",\n        source: \"dogpile_events\",\n        windowLabel,\n        definition: `Count of dogpile_events rows with status = 'cancelled' created within the last ${windowHours} hours — events the operator stopped before they could apply.`,\n        drilldownHref: \"/operations/dogpile?status=cancelled\",\n      },\n      raw: cancelledWindow,\n      display: formatCount(cancelledWindow),\n    },\n    {\n      blueprint: {\n        id: \"fraud.open_flags\",\n        label: \"Open fraud flags\",\n        unit: \"flags\",\n        source: \"fraud_flags\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of fraud_flags rows with status = 'open' — review queue awaiting an admin decision.\",\n        drilldownHref: \"/operations/dogpile?fraudStatus=open#fraud\",\n      },\n      raw: openFraud,\n      display: formatCount(openFraud),\n    },\n  ];\n\n  return {\n    generatedAt,\n    metrics: blueprints.map(({ blueprint, raw, display }) =>\n      buildMetric(blueprint, raw, display, generatedAt),\n    ),\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1658,"cache_read_input_tokens":128216,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1658},"output_tokens":7,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"0cbf8989-e666-4653-9e0d-3f545ba95bca","uuid":"5bf44d33-39ae-4466-9539-0d5727a08010"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014YYckMcrimm5HWWrcMJn9j","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/server/db/queries/get-dogpile-and-fraud.ts"}]},"parent_tool_use_id":null,"session_id":"0cbf8989-e666-4653-9e0d-3f545ba95bca","uuid":"5a6eac87-d4b9-46b9-955a-a67c5093aadb","timestamp":"2026-04-26T06:24:28.511Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-dogpile-and-fraud.ts","content":"// Dogpile + fraud admin queries (FR-9).\n//\n// Backs the upcoming `/operations/dogpile` page and the fraud-review surface.\n// Reads two migration-011 tables in read-only mode (no dogpile or fraud-flag\n// editing — that lives behind the FR-14 mutation framework; `dogpile.cancel`\n// and `fraud_flag.status.update` action ids are already declared in\n// `peek/src/server/access-policy.ts`):\n//\n//   - dogpile_events  — `listDogpileEvents` returns the scheduled / active /\n//     ended / cancelled lifecycle rows joined with the parent `campaigns` row\n//     (campaign_id is nullable so the join is a left join). Each row is\n//     annotated with the count of `game_entries` and `point_grants` whose\n//     `created_at` falls within the event's `[starts_at, ends_at)` window —\n//     this is the operator-readable \"linked\" set the spec calls out\n//     (FR-9 line 327: \"linked campaigns/game_entries/point_grants\"). There\n//     is no FK from those ledger tables to `dogpile_events`; the worker\n//     applies the multiplier purely based on the time window\n//     (`backend/src/queue/handlers/points-grant.ts`), so a window-based\n//     count is the closest operator-meaningful link.\n//\n//   - fraud_flags     — `listFraudFlags` returns the open / reviewed /\n//     dismissed review queue joined with `player_profiles` for username +\n//     wallet context. The JSONB `details` column round-trips verbatim so the\n//     operator-facing UI can show whatever metadata the writer attached.\n//     Read-only — every status transition is gated by the\n//     `fraud_flag.status.update` mutation action (FR-14, not yet built).\n//\n// `getDogpileFraudOverview` produces the FR-4 metric strip for the page:\n// scheduled, active, ended-in-window, cancelled-in-window, open fraud flags.\n//\n// All queries are bounded server-side (default 100, max 500). Bigint identity\n// ids round-trip as `text` to preserve precision; the dogpile multiplier is\n// returned as `text` because it is stored as `NUMERIC(4,2)` and the UI\n// formats it at render time.\n\nimport type { Sql } from \"postgres\";\nimport {\n  type PeekDogpileEventFilters,\n  type PeekDogpileEventRow,\n  type PeekDogpileFraudOverview,\n  type PeekDogpileFraudOverviewMetricId,\n  type PeekFraudFlagFilters,\n  type PeekFraudFlagListRow,\n  type PeekMetric,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT = 100;\nexport const PEEK_DOGPILE_EVENTS_MAX_LIMIT = 500;\nexport const PEEK_FRAUD_FLAGS_DEFAULT_LIMIT = 100;\nexport const PEEK_FRAUD_FLAGS_MAX_LIMIT = 500;\nexport const PEEK_DOGPILE_FRAUD_OVERVIEW_WINDOW_HOURS = 24;\n\nexport type ListDogpileEventsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekDogpileEventFilters>;\n};\n\nexport type ListFraudFlagsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekFraudFlagFilters>;\n};\n\nexport type DogpileFraudOverviewOptions = {\n  sql?: Sql;\n  now?: Date;\n  windowHours?: number;\n};\n\nfunction clampLimit(\n  raw: number | undefined,\n  fallback: number,\n  max: number,\n): number {\n  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n  const floored = Math.floor(raw);\n  if (floored <= 0) return 1;\n  return Math.min(max, floored);\n}\n\nfunction trimOrNull(value: string | null | undefined): string | null {\n  if (typeof value !== \"string\") return null;\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nfunction readInt(value: number | string | null | undefined): number {\n  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n  if (typeof value === \"string\") {\n    const parsed = Number.parseInt(value, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\nexport async function listDogpileEvents(\n  options: ListDogpileEventsOptions = {},\n): Promise<ReadonlyArray<PeekDogpileEventRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT,\n    PEEK_DOGPILE_EVENTS_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const status = trimOrNull(filters.status ?? null);\n  const startsFrom = trimOrNull(filters.startsFrom ?? null);\n  const startsTo = trimOrNull(filters.startsTo ?? null);\n\n  const rows = await sql<\n    Array<{\n      id: string;\n      campaignId: string | null;\n      campaignName: string | null;\n      campaignType: string | null;\n      startsAt: string;\n      endsAt: string;\n      multiplier: string;\n      status: string;\n      createdAt: string;\n      gameEntryCount: number | string;\n      pointGrantCount: number | string;\n    }>\n  >`\n    select\n      d.id::text as \"id\",\n      d.campaign_id::text as \"campaignId\",\n      c.name as \"campaignName\",\n      c.campaign_type as \"campaignType\",\n      d.starts_at::text as \"startsAt\",\n      d.ends_at::text as \"endsAt\",\n      d.multiplier::text as \"multiplier\",\n      d.status as \"status\",\n      d.created_at::text as \"createdAt\",\n      (\n        select count(*)::int\n        from game_entries ge\n        where ge.created_at >= d.starts_at\n          and ge.created_at < d.ends_at\n      ) as \"gameEntryCount\",\n      (\n        select count(*)::int\n        from point_grants pg\n        where pg.created_at >= d.starts_at\n          and pg.created_at < d.ends_at\n      ) as \"pointGrantCount\"\n    from dogpile_events d\n    left join campaigns c on c.id = d.campaign_id\n    where\n      (${status === null} or d.status = ${status ?? \"\"})\n      and (${startsFrom === null} or d.starts_at >= ${startsFrom ?? \"\"}::timestamptz)\n      and (${startsTo === null} or d.starts_at < ${startsTo ?? \"\"}::timestamptz)\n    order by d.starts_at desc, d.id desc\n    limit ${limit}\n  `;\n\n  return rows.map((row) => ({\n    id: row.id,\n    campaignId: row.campaignId,\n    campaignName: row.campaignName,\n    campaignType: row.campaignType,\n    startsAt: row.startsAt,\n    endsAt: row.endsAt,\n    multiplier: row.multiplier,\n    status: row.status,\n    createdAt: row.createdAt,\n    gameEntryCount: readInt(row.gameEntryCount),\n    pointGrantCount: readInt(row.pointGrantCount),\n  }));\n}\n\nexport async function listFraudFlags(\n  options: ListFraudFlagsOptions = {},\n): Promise<ReadonlyArray<PeekFraudFlagListRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_FRAUD_FLAGS_DEFAULT_LIMIT,\n    PEEK_FRAUD_FLAGS_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const status = trimOrNull(filters.status ?? null);\n  const userId = trimOrNull(filters.userId ?? null);\n  const flagType = trimOrNull(filters.flagType ?? null);\n  const createdFrom = trimOrNull(filters.createdFrom ?? null);\n  const createdTo = trimOrNull(filters.createdTo ?? null);\n\n  const rows = await sql<\n    Array<{\n      id: string;\n      userId: string;\n      username: string | null;\n      wallet: string | null;\n      flagType: string;\n      status: string;\n      relatedId: string | null;\n      details: Record<string, unknown> | null;\n      createdAt: string;\n      resolvedAt: string | null;\n    }>\n  >`\n    select\n      f.id::text as \"id\",\n      f.user_id as \"userId\",\n      prof.username as \"username\",\n      prof.wallet as \"wallet\",\n      f.flag_type as \"flagType\",\n      f.status as \"status\",\n      f.related_id as \"relatedId\",\n      f.details as \"details\",\n      f.created_at::text as \"createdAt\",\n      f.resolved_at::text as \"resolvedAt\"\n    from fraud_flags f\n    left join player_profiles prof on prof.user_id = f.user_id\n    where\n      (${status === null} or f.status = ${status ?? \"\"})\n      and (${userId === null} or f.user_id = ${userId ?? \"\"})\n      and (${flagType === null} or f.flag_type = ${flagType ?? \"\"})\n      and (${createdFrom === null} or f.created_at >= ${createdFrom ?? \"\"}::timestamptz)\n      and (${createdTo === null} or f.created_at < ${createdTo ?? \"\"}::timestamptz)\n    order by\n      case f.status when 'open' then 0 when 'reviewed' then 1 else 2 end,\n      f.created_at desc,\n      f.id desc\n    limit ${limit}\n  `;\n\n  return rows.map((row) => ({\n    id: row.id,\n    userId: row.userId,\n    username: row.username,\n    wallet: row.wallet,\n    flagType: row.flagType,\n    status: row.status,\n    relatedId: row.relatedId,\n    details: row.details,\n    createdAt: row.createdAt,\n    resolvedAt: row.resolvedAt,\n  }));\n}\n\ntype MetricBlueprint = {\n  id: PeekDogpileFraudOverviewMetricId;\n  label: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  definition: string;\n  drilldownHref: string | null;\n};\n\nfunction buildMetric(\n  blueprint: MetricBlueprint,\n  raw: number,\n  display: string,\n  asOf: string,\n): PeekMetric {\n  return {\n    id: blueprint.id,\n    label: blueprint.label,\n    value: raw,\n    valueDisplay: display,\n    unit: blueprint.unit,\n    source: blueprint.source,\n    windowLabel: blueprint.windowLabel,\n    asOf,\n    definition: blueprint.definition,\n    freshness: \"live\",\n    drilldownHref: blueprint.drilldownHref,\n  };\n}\n\nexport async function getDogpileFraudOverview(\n  options: DogpileFraudOverviewOptions = {},\n): Promise<PeekDogpileFraudOverview> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n  const windowHours = clampLimit(\n    options.windowHours,\n    PEEK_DOGPILE_FRAUD_OVERVIEW_WINDOW_HOURS,\n    24 * 30,\n  );\n  const since = new Date(now.getTime() - windowHours * 60 * 60 * 1000);\n  const sinceIso = since.toISOString();\n\n  const [\n    scheduledRows,\n    activeRows,\n    endedWindowRows,\n    cancelledWindowRows,\n    openFraudRows,\n  ] = await Promise.all([\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from dogpile_events\n      where status = 'scheduled'\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from dogpile_events\n      where status = 'active'\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from dogpile_events\n      where status = 'ended'\n        and ends_at >= ${sinceIso}::timestamptz\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from dogpile_events\n      where status = 'cancelled'\n        and created_at >= ${sinceIso}::timestamptz\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from fraud_flags\n      where status = 'open'\n    `,\n  ]);\n\n  const scheduled = readInt(scheduledRows[0]?.value ?? 0);\n  const active = readInt(activeRows[0]?.value ?? 0);\n  const endedWindow = readInt(endedWindowRows[0]?.value ?? 0);\n  const cancelledWindow = readInt(cancelledWindowRows[0]?.value ?? 0);\n  const openFraud = readInt(openFraudRows[0]?.value ?? 0);\n\n  const windowLabel = `Last ${windowHours}h`;\n\n  const blueprints: ReadonlyArray<{\n    blueprint: MetricBlueprint;\n    raw: number;\n    display: string;\n  }> = [\n    {\n      blueprint: {\n        id: \"dogpile.scheduled\",\n        label: \"Scheduled events\",\n        unit: \"events\",\n        source: \"dogpile_events\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of dogpile_events rows with status = 'scheduled' — events booked but not yet active.\",\n        drilldownHref: \"/operations/dogpile?status=scheduled\",\n      },\n      raw: scheduled,\n      display: formatCount(scheduled),\n    },\n    {\n      blueprint: {\n        id: \"dogpile.active\",\n        label: \"Active events\",\n        unit: \"events\",\n        source: \"dogpile_events\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of dogpile_events rows with status = 'active' — events currently applying their multiplier to point grants.\",\n        drilldownHref: \"/operations/dogpile?status=active\",\n      },\n      raw: active,\n      display: formatCount(active),\n    },\n    {\n      blueprint: {\n        id: \"dogpile.ended_window\",\n        label: \"Ended events\",\n        unit: \"events\",\n        source: \"dogpile_events\",\n        windowLabel,\n        definition: `Count of dogpile_events rows with status = 'ended' whose ends_at falls within the last ${windowHours} hours.`,\n        drilldownHref: \"/operations/dogpile?status=ended\",\n      },\n      raw: endedWindow,\n      display: formatCount(endedWindow),\n    },\n    {\n      blueprint: {\n        id: \"dogpile.cancelled_window\",\n        label: \"Cancelled events\",\n        unit: \"events\",\n        source: \"dogpile_events\",\n        windowLabel,\n        definition: `Count of dogpile_events rows with status = 'cancelled' created within the last ${windowHours} hours — events the operator stopped before they could apply.`,\n        drilldownHref: \"/operations/dogpile?status=cancelled\",\n      },\n      raw: cancelledWindow,\n      display: formatCount(cancelledWindow),\n    },\n    {\n      blueprint: {\n        id: \"fraud.open_flags\",\n        label: \"Open fraud flags\",\n        unit: \"flags\",\n        source: \"fraud_flags\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of fraud_flags rows with status = 'open' — review queue awaiting an admin decision.\",\n        drilldownHref: \"/operations/dogpile?fraudStatus=open#fraud\",\n      },\n      raw: openFraud,\n      display: formatCount(openFraud),\n    },\n  ];\n\n  return {\n    generatedAt,\n    metrics: blueprints.map(({ blueprint, raw, display }) =>\n      buildMetric(blueprint, raw, display, generatedAt),\n    ),\n  };\n}\n","structuredPatch":[],"originalFile":null,"userModified":false}}
