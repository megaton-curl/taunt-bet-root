{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0161VTeQFHvNgkYZNYPnmbYu","type":"tool_result","content":"145\t  created_at      TIMESTAMPTZ NOT NULL DEFAULT now(),\n146\t  granted_at      TIMESTAMPTZ,\n147\t  UNIQUE (user_id, trigger_type, trigger_id)\n148\t);\n149\t\n150\tCREATE INDEX idx_crate_drops_user ON crate_drops (user_id, created_at DESC);\n151\tCREATE INDEX idx_crate_drops_pending ON crate_drops (status) WHERE status = 'pending';\n152\t\n153\t-- Fraud flags\n154\tCREATE TABLE fraud_flags (\n155\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n156\t  user_id         TEXT NOT NULL,\n157\t  flag_type       TEXT NOT NULL,\n158\t  details         JSONB NOT NULL DEFAULT '{}',\n159\t  related_id      TEXT,\n160\t  status          TEXT NOT NULL DEFAULT 'open' CHECK (status IN ('open', 'reviewed', 'dismissed')),\n161\t  created_at      TIMESTAMPTZ NOT NULL DEFAULT now(),\n162\t  resolved_at     TIMESTAMPTZ\n163\t);\n164\t\n165\t-- Dogpile event schedule and state\n166\tCREATE TABLE dogpile_events (\n167\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n168\t  campaign_id     BIGINT REFERENCES campaigns(id),\n169\t  starts_at       TIMESTAMPTZ NOT NULL,\n170\t  ends_at         TIMESTAMPTZ NOT NULL,\n171\t  multiplier      NUMERIC(4,2) NOT NULL DEFAULT 2.0,\n172\t  status          TEXT NOT NULL DEFAULT 'scheduled' CHECK (status IN ('scheduled', 'active', 'ended', 'cancelled')),\n173\t  created_at      TIMESTAMPTZ NOT NULL DEFAULT now()\n174\t);\n175\t\n176\tCREATE INDEX idx_dogpile_active ON dogpile_events (status, starts_at, ends_at) WHERE status IN ('scheduled', 'active');\n177\t\n178\t-- ============================================================\n179\t-- Seed data"}]},"parent_tool_use_id":null,"session_id":"0cbf8989-e666-4653-9e0d-3f545ba95bca","uuid":"f62ad1bc-2a01-483f-ada3-a2fda7a8b204","timestamp":"2026-04-26T06:21:09.740Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/migrations/011_challenge_engine.sql","content":"  created_at      TIMESTAMPTZ NOT NULL DEFAULT now(),\n  granted_at      TIMESTAMPTZ,\n  UNIQUE (user_id, trigger_type, trigger_id)\n);\n\nCREATE INDEX idx_crate_drops_user ON crate_drops (user_id, created_at DESC);\nCREATE INDEX idx_crate_drops_pending ON crate_drops (status) WHERE status = 'pending';\n\n-- Fraud flags\nCREATE TABLE fraud_flags (\n  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  user_id         TEXT NOT NULL,\n  flag_type       TEXT NOT NULL,\n  details         JSONB NOT NULL DEFAULT '{}',\n  related_id      TEXT,\n  status          TEXT NOT NULL DEFAULT 'open' CHECK (status IN ('open', 'reviewed', 'dismissed')),\n  created_at      TIMESTAMPTZ NOT NULL DEFAULT now(),\n  resolved_at     TIMESTAMPTZ\n);\n\n-- Dogpile event schedule and state\nCREATE TABLE dogpile_events (\n  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  campaign_id     BIGINT REFERENCES campaigns(id),\n  starts_at       TIMESTAMPTZ NOT NULL,\n  ends_at         TIMESTAMPTZ NOT NULL,\n  multiplier      NUMERIC(4,2) NOT NULL DEFAULT 2.0,\n  status          TEXT NOT NULL DEFAULT 'scheduled' CHECK (status IN ('scheduled', 'active', 'ended', 'cancelled')),\n  created_at      TIMESTAMPTZ NOT NULL DEFAULT now()\n);\n\nCREATE INDEX idx_dogpile_active ON dogpile_events (status, starts_at, ends_at) WHERE status IN ('scheduled', 'active');\n\n-- ============================================================\n-- Seed data","numLines":35,"startLine":145,"totalLines":239}}}
