e\") return true;\n  if (value === \"false\") return false;\n  return null;\n}\n\nexport async function listCampaigns(\n  options: ListCampaignsOptions = {},\n): Promise<ReadonlyArray<PeekCampaignRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_CAMPAIGNS_DEFAULT_LIMIT,\n    PEEK_CAMPAIGNS_MAX_LIMIT,\n  );\n\n  const rows = await sql<\n    Array<{\n      id: string;\n      name: string;\n      campaignType: string;\n      startsAt: string | null;\n      endsAt: string | null;\n      isActive: boolean;\n      createdAt: string;\n      challengeCount: number | string;\n      activeAssignmentCount: number | string;\n    }>\n  >`\n    select\n      c.id::text as \"id\",\n      c.name as \"name\",\n      c.campaign_type as \"campaignType\",\n      c.starts_at::text as \"startsAt\",\n      c.ends_at::text as \"endsAt\",\n      c.is_active as \"isActive\",\n      c.created_at::text as \"createdAt\",\n      coalesce(ch_counts.challenge_count, 0)::int as \"challengeCount\",\n      coalesce(asg_counts.active_assignment_count, 0)::int as \"activeAssignmentCount\"\n    from campaigns c\n    left join (\n      select campaign_id, count(*) as challenge_count\n      from challenges\n      group by campaign_id\n    ) ch_counts on ch_counts.campaign_id = c.id\n    left join (\n      select ch.campaign_id, count(*) as active_assignment_count\n      from challenge_assignments ca\n      join challenges ch on ch.id = ca.challenge_id\n      where ca.status = 'active'\n      group by ch.campaign_id\n    ) asg_counts on asg_counts.campaign_id = c.id\n    order by c.is_active desc, c.created_at desc, c.id desc\n    limit ${limit}\n  `;\n\n  return rows.map((row) => ({\n    id: row.id,\n    name: row.name,\n    campaignType: row.campaignType,\n    startsAt: row.startsAt,\n    endsAt: row.endsAt,\n    isActive: row.isActive,\n    createdAt: row.createdAt,\n    challengeCount: readInt(row.challengeCount),\n    a