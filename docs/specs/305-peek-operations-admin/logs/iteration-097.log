{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ACu2owWpfvxEvzCsUdNmbY","type":"tool_result","content":"100\texport type ChallengesOverviewOptions = {\n101\t  sql?: Sql;\n102\t  now?: Date;\n103\t  windowHours?: number;\n104\t};\n105\t\n106\tfunction clampLimit(\n107\t  raw: number | undefined,\n108\t  fallback: number,\n109\t  max: number,\n110\t): number {\n111\t  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n112\t  const floored = Math.floor(raw);\n113\t  if (floored <= 0) return 1;\n114\t  return Math.min(max, floored);\n115\t}\n116\t\n117\tfunction trimOrNull(value: string | null | undefined): string | null {\n118\t  if (typeof value !== \"string\") return null;\n119\t  const trimmed = value.trim();\n120\t  return trimmed.length > 0 ? trimmed : null;\n121\t}\n122\t\n123\tfunction readInt(value: number | string | null | undefined): number {\n124\t  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n125\t  if (typeof value === \"string\") {\n126\t    const parsed = Number.parseInt(value, 10);\n127\t    return Number.isFinite(parsed) ? parsed : 0;\n128\t  }\n129\t  return 0;\n130\t}\n131\t\n132\tfunction formatCount(count: number): string {\n133\t  return count.toLocaleString(\"en-US\");\n134\t}\n135\t\n136\tfunction parseBoolFilter(value: string | null): boolean | null {\n137\t  if (value === null) return null;\n138\t  if (value === \"true\") return true;\n139\t  if (value === \"false\") return false;\n140\t  return null;\n141\t}\n142\t\n143\texport async function listCampaigns(\n144\t  options: ListCampaignsOptions = {},\n145\t): Promise<ReadonlyArray<PeekCampaignRow>> {\n146\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n147\t  const limit = clampLimit(\n148\t    options.limit,\n149\t    PEEK_CAMPAIGNS_DEFAULT_LIMIT,\n150\t    PEEK_CAMPAIGNS_MAX_LIMIT,\n151\t  );\n152\t\n153\t  const rows = await sql<\n154\t    Array<{\n155\t      id: string;\n156\t      name: string;\n157\t      campaignType: string;\n158\t      startsAt: string | null;\n159\t      endsAt: string | null;\n160\t      isActive: boolean;\n161\t      createdAt: string;\n162\t      challengeCount: number | string;\n163\t      activeAssignmentCount: number | string;\n164\t    }>\n165\t  >`\n166\t    select\n167\t      c.id::text as \"id\",\n168\t      c.name as \"name\",\n169\t      c.campaign_type as \"campaignType\",\n170\t      c.starts_at::text as \"startsAt\",\n171\t      c.ends_at::text as \"endsAt\",\n172\t      c.is_active as \"isActive\",\n173\t      c.created_at::text as \"createdAt\",\n174\t      coalesce(ch_counts.challenge_count, 0)::int as \"challengeCount\",\n175\t      coalesce(asg_counts.active_assignment_count, 0)::int as \"activeAssignmentCount\"\n176\t    from campaigns c\n177\t    left join (\n178\t      select campaign_id, count(*) as challenge_count\n179\t      from challenges\n180\t      group by campaign_id\n181\t    ) ch_counts on ch_counts.campaign_id = c.id\n182\t    left join (\n183\t      select ch.campaign_id, count(*) as active_assignment_count\n184\t      from challenge_assignments ca\n185\t      join challenges ch on ch.id = ca.challenge_id\n186\t      where ca.status = 'active'\n187\t      group by ch.campaign_id\n188\t    ) asg_counts on asg_counts.campaign_id = c.id\n189\t    order by c.is_active desc, c.created_at desc, c.id desc\n190\t    limit ${limit}\n191\t  `;\n192\t\n193\t  return rows.map((row) => ({\n194\t    id: row.id,\n195\t    name: row.name,\n196\t    campaignType: row.campaignType,\n197\t    startsAt: row.startsAt,\n198\t    endsAt: row.endsAt,\n199\t    isActive: row.isActive,\n200\t    createdAt: row.createdAt,\n201\t    challengeCount: readInt(row.challengeCount),\n202\t    activeAssignmentCount: readInt(row.activeAssignmentCount),\n203\t  }));\n204\t}\n205\t\n206\texport async function listChallenges(\n207\t  options: ListChallengesOptions = {},\n208\t): Promise<ReadonlyArray<PeekChallengeRow>> {\n209\t  cons