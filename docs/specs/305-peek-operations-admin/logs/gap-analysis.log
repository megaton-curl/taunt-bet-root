  } catch (error) {\n99\t    overviewError =\n100\t      error instanceof Error\n101\t        ? error.message\n102\t        : \"Dogpile + fraud overview could not be loaded.\";\n103\t  }\n104\t\n105\t  try {\n106\t    dogpileEvents = await listDogpileEvents({ filters: dogpileFilters });\n107\t  } catch (error) {\n108\t    dogpileError =\n109\t      error instanceof Error\n110\t        ? error.message\n111\t        : \"Dogpile events could not be loaded.\";\n112\t  }\n113\t\n114\t  try {\n115\t    fraudFlags = await listFraudFlags({ filters: fraudFilters });\n116\t  } catch (error) {\n117\t    fraudError =\n118\t      error instanceof Error\n119\t        ? error.message\n120\t        : \"Fraud flags could not be loaded.\";\n121\t  }\n122\t\n123\t  return (\n124\t    <main style={mainStyle}>\n125\t      <header>\n126\t        <h1>Operations · Dogpile</h1>\n127\t        <p style={leadStyle}>\n128\t          Dogpile lifecycle (scheduled / active / ended / cancelled) and the\n129\t          fraud review queue. Cancelling a scheduled dogpile event and\n130\t          transitioning a fraud flag are guarded by the FR-14 mutation\n131\t          actions and visible only to admins.\n132\t        </p>\n133\t      </header>\n134\t\n135\t      <section aria-labelledby=\"overview-heading\">\n136\t        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n137\t          Overview\n138\t        </h2>\n139\t        <MetricStrip metrics={overview.metrics} error={overviewError} />\n140\t      </section>\n141\t\n142\t      <section\n143\t        aria-labelledby=\"dogpile-events-heading\"\n144\t        id=\"dogpile-events\"\n145\t        style={sectionStyle}\n146\t      >\n147\t        <h2 id=\"dogpile-events-heading\" style={sectionHeadingStyle}>\n148\t          Dogpile events\n149\t        </h2>\n150\t        <p style={hintStyle}>\n151\t          Default {PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT} rows · sorted newest\n152\t          starts first · server-side capped. Filter by status and a [from, to)\n153\t          starts-at window. Game-entries and point-grants counts reflect the\n154\t          rows whose `created_at` falls inside each event window. Admins can\n155\t          cancel a scheduled future event via the `dogpile.cancel` mutation.\n156\t        </p>\n157\t        <DogpileEventsFilterBar filters={dogpileFilters} action={ROUTE} />\n158\t        <DogpileEventsTable\n159\t          rows={dogpileEvents}\n160\t          error={dogpileError}\n161\t          canCancelDogpile={canCancelDogpile}\n162\t        />\n163\t      </section>\n164\t\n165\t      <section\n166\t        aria-labelledby=\"fraud-heading\"\n167\t        id=\"fraud\"\n168\t        style={sectionStyle}\n169\t      >\n170\t        <h2 id=\"fraud-heading\" style={sectionHeadingStyle}>\n171\t          Fraud flags\n172\t        </h2>\n173\t        <p style={hintStyle}>\n174\t          Default {PEEK_FRAUD_FLAGS_DEFAULT_LIMIT} rows · sorted open first\n175\t          then newest · server-side capped. Filter by status, user, flag type,\n176\t          and a [from, to) created-at window. Admins can transition status via\n177\t          the `fraud_flag.status.update` mutation; only matrix-allowed next\n178\t          states are offered.\n179\t        </p>\n180\t        <FraudFlagsFilterBar filters={fraudFilters} action={ROUTE} />\n181\t        <FraudFlagsTable\n182\t          rows={fraudFlags}\n183\t          error={fraudError}\n184\t          canTransitionFraudFlag={canTransitionFraudFlag}\n185\t        />\n186\t      </section>\n187\t    </main>\n188\t  );\n189\t}\n190\t\n191\tconst mainStyle: CSSProperties = {\n192\t  display: \"grid\",\n193\t  gap: \"1.5rem\",\n194\t};\n195\t\n196\tconst sectionStyle: CSSProperties = {\n197\t  display: \"grid\",\n198\t  gap: \"0.75rem\",\n199\t};\n200\t\n201\tconst sectionHeadingStyle: CSSProperties = {\n202\t  margin: \"0 0 0.75rem\",\n203\t  fontSize: \"1rem\",\n204\t  fontWeight: 600,\n205\t  color: \"#cbd5f5\",\n206\t  textTransform: \"uppercase\",\n207\t  letterSpacing: \"0.05em\",\n208\t};\n209\t\n210\tconst leadStyle: CSSProperties = {\n211\t  margin: \"0.25rem 0 0\",\n212\t  color: \"#94a3b8\",\n213\t};\n214\t\n215\tconst hintStyle: CSSProperties = {\n216\t  margin: 0,\n217\t  color: \"#94a3b8\",\n218\t  fontSize: \"0.8125rem\",\n219\t};\n220\t\n221\tconst errorStyle: CSSProperties = {\n222\t  margin: 0,\n223\t  padding: \"0.75rem 1rem\",\n224\t  borderRadius: \"0.75rem\",\n225\t  background: \"#3f1d1d\",\n226\t  color: \"#fecaca\",\n227\t};\n228\t"}]},"parent_tool_use_id":null,"session_id":"c96f606c-1699-40ed-983c-99b59a054786","uuid":"f9fd374a-8caf-42d3-9af7-22917bd67d7a","timestamp":"2026-04-26T20:38:25.019Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/app/operations/dogpile/page.tsx","content":"// /operations/dogpile — Dogpile lifecycle + fraud review admin page (FR-9).\n//\n// Reads two migration-011 tables via `get-dogpile-and-fraud.ts` and composes\n// the FR-4 metric strip with two operator surfaces:\n//\n//   - Dogpile events — scheduled / active / ended / cancelled lifecycle rows\n//                       with per-event game_entries + point_grants window\n//                       counts, filtered by status + starts_at range.\n//   - Fraud flags    — read-only review queue (open / reviewed / dismissed)\n//                       linked back to /users/[userId] with the JSONB\n//                       `details` payload rendered verbatim.\n//\n// Both sections are read-only. Cancelling a scheduled dogpile event lives\n// behind the FR-14 `dogpile.cancel` action id; transitioning a fraud flag\n// lives behind the `fraud_flag.status.update` action id; neither mutation is\n// implemented yet.\nimport type { CSSProperties } from \"react\";\nimport { DogpileEventsTable } from \"../../../src/components/dogpile-events-table\";\nimport { FraudFlagsTable } from \"../../../src/components/fraud-flags-table\";\nimport { MetricStrip } from \"../../../src/components/metric-strip\";\nimport {\n  DogpileEventsFilterBar,\n  FraudFlagsFilterBar,\n} from \"../../../src/components/operations-dogpile-filter-bar\";\nimport {\n  normalizeDogpileEventFiltersFromSearchParams,\n  normalizeFraudFlagFiltersFromSearchParams,\n} from \"../../../src/lib/operations-dogpile-search-params\";\nimport type {\n  PeekDogpileEventRow,\n  PeekDogpileFraudOverview,\n  PeekFraudFlagListRow,\n} from \"../../../src/lib/types/peek\";\nimport {\n  getPeekActorContext,\n  isActionAllowedForRole,\n  isRouteAllowedForRole,\n} from \"../../../src/server/access-policy\";\nimport {\n  PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT,\n  PEEK_FRAUD_FLAGS_DEFAULT_LIMIT,\n  getDogpileFraudOverview,\n  listDogpileEvents,\n  listFraudFlags,\n} from \"../../../src/server/db/queries/get-dogpile-and-fraud\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst ROUTE = \"/operations/dogpile\";\n\nexport default async function OperationsDogpilePage({\n  searchParams,\n}: {\n  searchParams: Promise<Record<string, string | string[] | undefined>>;\n}) {\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n\n  if (!allowed) {\n    return (\n      <main style={mainStyle}>\n        <header>\n          <h1>Operations · Dogpile</h1>\n        </header>\n        <p role=\"alert\" style={errorStyle}>\n          You do not have access to this page.\n        </p>\n      </main>\n    );\n  }\n\n  const params = await searchParams;\n  const dogpileFilters = normalizeDogpileEventFiltersFromSearchParams(params);\n  const fraudFilters = normalizeFraudFlagFiltersFromSearchParams(params);\n\n  const canCancelDogpile = isActionAllowedForRole(\n    \"dogpile.cancel\",\n    actor?.role ?? null,\n  );\n  const canTransitionFraudFlag = isActionAllowedForRole(\n    \"fraud_flag.status.update\",\n    actor?.role ?? null,\n  );\n\n  let overview: PeekDogpileFraudOverview = {\n    generatedAt: new Date().toISOString(),\n    metrics: [],\n  };\n  let dogpileEvents: ReadonlyArray<PeekDogpileEventRow> = [];\n  let fraudFlags: ReadonlyArray<PeekFraudFlagListRow> = [];\n\n  let overviewError: string | null = null;\n  let dogpileError: string | null = null;\n  let fraudError: string | null = null;\n\n  try {\n    overview = await getDogpileFraudOverview();\n  } catch (error) {\n    overviewError =\n      error instanceof Error\n        ? error.message\n        : \"Dogpile + fraud overview could not be loaded.\";\n  }\n\n  try {\n    dogpileEvents = await listDogpileEvents({ filters: dogpileFilters });\n  } catch (error) {\n    dogpileError =\n      error instanceof Error\n        ? error.message\n        : \"Dogpile events could not be loaded.\";\n  }\n\n  try {\n    fraudFlags = await listFraudFlags({ filters: fraudFilters });\n  } catch (error) {\n    fraudError =\n      error instanceof Error\n        ? error.message\n        : \"Fraud flags could not be loaded.\";\n  }\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <h1>Operations · Dogpile</h1>\n        <p style={leadStyle}>\n          Dogpile lifecycle (scheduled / active / ended / cancelled) and the\n          fraud review queue. Cancelling a scheduled dogpile event and\n          transitioning a fraud flag are guarded by the FR-14 mutation\n          actions and visible only to admins.\n        </p>\n      </header>\n\n      <section aria-labelledby=\"overview-heading\">\n        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n          Overview\n        </h2>\n        <MetricStrip metrics={overview.metrics} error={overviewError} />\n      </section>\n\n      <section\n        aria-labelledby=\"dogpile-events-heading\"\n        id=\"dogpile-events\"\n        style={sectionStyle}\n      >\n        <h2 id=\"dogpile-events-heading\" style={sectionHeadingStyle}>\n          Dogpile events\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT} rows · sorted newest\n          starts first · server-side capped. Filter by status and a [from, to)\n          starts-at window. Game-entries and point-grants counts reflect the\n          rows whose `created_at` falls inside each event window. Admins can\n          cancel a scheduled future event via the `dogpile.cancel` mutation.\n        </p>\n        <DogpileEventsFilterBar filters={dogpileFilters} action={ROUTE} />\n        <DogpileEventsTable\n          rows={dogpileEvents}\n          error={dogpileError}\n          canCancelDogpile={canCancelDogpile}\n        />\n      </section>\n\n      <section\n        aria-labelledby=\"fraud-heading\"\n        id=\"fraud\"\n        style={sectionStyle}\n      >\n        <h2 id=\"fraud-heading\" style={sectionHeadingStyle}>\n          Fraud flags\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_FRAUD_FLAGS_DEFAULT_LIMIT} rows · sorted open first\n          then newest · server-side capped. Filter by status, user, flag type,\n          and a [from, to) created-at window. Admins can transition status via\n          the `fraud_flag.status.update` mutation; only matrix-allowed next\n          states are offered.\n        </p>\n        <FraudFlagsFilterBar filters={fraudFilters} action={ROUTE} />\n        <FraudFlagsTable\n          rows={fraudFlags}\n          error={fraudError}\n          canTransitionFraudFlag={canTransitionFraudFlag}\n        />\n      </section>\n    </main>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};