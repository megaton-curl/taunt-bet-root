{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AL35eHt1tSTbRmxe68ZnLw","type":"tool_result","content":"1\t// Command-center attention queue query (FR-3, FR-10).\n2\t//\n3\t// Returns a small set of bounded \"needs attention\" metrics that the command\n4\t// center renders at the top of `/`. Each metric carries the FR-4 bookkeeping\n5\t// (id, label, value, source table, time window, \"as of\", definition,\n6\t// freshness, drill-down href) so the metric-strip primitive can render it\n7\t// without per-page hardcoding.\n8\t//\n9\t// Bounded queries: every query returns a single integer count. No row-level\n10\t// data crosses the wire here; per-feature pages provide the row drill-downs.\n11\t\n12\timport type {\n13\t  PeekCommandCenterAttention,\n14\t  PeekCommandCenterAttentionId,\n15\t  PeekMetric,\n16\t} from \"../../../lib/types/peek\";\n17\timport type { Sql } from \"postgres\";\n18\timport { getSqlClient } from \"../client\";\n19\t\n20\t// Thresholds — tuned for an operator console, not a fairness oracle. Tests can\n21\t// override via the `options` argument so age/limit assertions stay\n22\t// deterministic.\n23\texport type CommandCenterThresholds = {\n24\t  stuckRoundsAgeMinutes: number;\n25\t  stuckRoundsMaxSettleAttempts: number;\n26\t  stuckCloseCallAgeMinutes: number;\n27\t  exportWindowHours: number;\n28\t  exportRowCountThreshold: number;\n29\t};\n30\t\n31\texport const COMMAND_CENTER_DEFAULTS: CommandCenterThresholds = {\n32\t  stuckRoundsAgeMinutes: 5,\n33\t  stuckRoundsMaxSettleAttempts: 3,\n34\t  stuckCloseCallAgeMinutes: 5,\n35\t  exportWindowHours: 24,\n36\t  exportRowCountThreshold: 1000,\n37\t};\n38\t\n39\texport type CommandCenterOptions = {\n40\t  sql?: Sql;\n41\t  thresholds?: Partial<CommandCenterThresholds>;\n42\t  now?: Date;\n43\t};\n44\t\n45\ttype AttentionRow = { value: number };\n46\t\n47\tfunction readCount(rows: ReadonlyArray<AttentionRow> | undefined): number {\n48\t  if (!rows || rows.length === 0) {\n49\t    return 0;\n50\t  }\n51\t  const raw = rows[0]?.value;\n52\t  if (typeof raw === \"number\" && Number.isFinite(raw)) {\n53\t    return raw;\n54\t  }\n55\t  if (typeof raw === \"string\") {\n56\t    const parsed = Number.parseInt(raw, 10);\n57\t    return Number.isFinite(parsed) ? parsed : 0;\n58\t  }\n59\t  return 0;\n60\t}\n61\t\n62\tfunction formatCount(count: number): string {\n63\t  return count.toLocaleString(\"en-US\");\n64\t}\n65\t\n66\ttype MetricBlueprint = {\n67\t  id: PeekCommandCenterAttentionId;\n68\t  label: string;\n69\t  unit: string | null;\n70\t  source: string;\n71\t  windowLabel: string;\n72\t  definition: string;\n73\t  drilldownHref: string | null;\n74\t};\n75\t\n76\tfunction makeMetric(\n77\t  blueprint: MetricBlueprint,\n78\t  count: number,\n79\t  asOf: string,\n80\t): PeekMetric {\n81\t  return {\n82\t    id: blueprint.id,\n83\t    label: blueprint.label,\n84\t    value: count,\n85\t    valueDisplay: formatCount(count),\n86\t    unit: blueprint.unit,\n87\t    source: blueprint.source,\n88\t    windowLabel: blueprint.windowLabel,\n89\t    asOf,\n90\t    definition: blueprint.definition,\n91\t    freshness: \"live\",\n92\t    drilldownHref: blueprint.drilldownHref,\n93\t  };\n94\t}\n95\t\n96\texport async function getCommandCenterAttention(\n97\t  options: CommandCenterOptions = {},\n98\t): Promise<PeekCommandCenterAttention> {\n99\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n100\t  const thresholds: CommandCenterThresholds = {\n101\t    ...COMMAND_CENTER_DEFAULTS,\n102\t    ...options.thresholds,\n103\t  };\n104\t  const now = options.now ?? new Date();\n105\t  const generatedAt = now.toISOString();\n106\t\n107\t  const stuckRoundsAgeInterval = `${thresholds.stuckRoundsAgeMinutes} minutes`;\n108\t  const stuckCloseCallAgeInterval = `${thresholds.stuckCloseCallAgeMinutes} minutes`;\n109\t  const exportWindowInterval = `${thresholds.exportWindowHours} hours`;\n110\t\n111\t  const [\n112\t    failedClaimsRows,\n113\t    deadQueueEventsRows,\n114\t    stuckRoundsRows,\n115\t    stuckCloseCallRows,\n116\t    pendingSolCrateRows,\n117\t    staleActiveDogpileRows,\n118\t    highValueExportsRows,\n119\t  ] = await Promise.all([\n120\t    sql<AttentionRow[]>`\n121\t      select count(*)::int as \"value\"\n122\t      from referral_claims\n123\t      where status in ('failed', 'error')\n124\t    `,\n125\t    sql<AttentionRow[]>`\n126\t      select count(*)::int as \"value\"\n127\t      from event_queue\n128\t      where status = 'dead'\n129\t    `,\n130\t    sql<AttentionRow[]>`\n131\t      select count(*)::int as \"value\"\n132\t      from rounds\n133\t      where phase in ('created', 'locked', 'settling')\n134\t        and (\n135\t          created_at < now() - ${stuckRoundsAgeInterval}::interval\n136\t          or settle_attempts > ${thresholds.stuckRoundsMaxSettleAttempts}\n137\t        )\n138\t    `,\n139\t    sql<AttentionRow[]>`\n140\t      select count(*)::int as \"value\"\n141\t      from closecall_rounds\n142\t      where phase = 'open'\n143\t        and created_at < now() - ${stuckCloseCallAgeInterval}::interval\n144\t    `,\n145\t    sql<AttentionRow[]>`\n146\t      select count(*)::int as \"value\"\n147\t      from crate_drops\n148\t      where crate_type = 'sol'\n149\t        and status = 'pending'\n150\t    `,\n151\t    sql<AttentionRow[]>`\n152\t      select count(*)::int as \"value\"\n153\t      from dogpile_events\n154\t      where status = 'active'\n155\t        and ends_at < now()\n156\t    `,\n157\t    sql<AttentionRow[]>`\n158\t      select count(*)::int as \"value\"\n159\t      from operator_events\n160\t      where event_type = 'peek.export'\n161\t        and created_at > now() - ${exportWindowInterval}::interval\n162\t        and coalesce((payload->>'resultCount')::int, 0)\n163\t            > ${thresholds.exportRowCountThreshold}\n164\t    `,\n165\t  ]);\n166\t\n167\t  const blueprints: ReadonlyArray<{\n168\t    blueprint: MetricBlueprint;\n169\t    rows: ReadonlyArray<AttentionRow>;\n170\t  }> = [\n171\t    {\n172\t      blueprint: {\n173\t        id: \"failed_claims\",\n174\t        label: \"Failed referral claims\",\n175\t        unit: \"claims\",\n176\t        source: \"referral_claims\",\n177\t        windowLabel: \"All time\",\n178\t        definition:\n179\t          \"Referral claims with status 'failed' or 'error' that have not been recovered.\",\n180\t        drilldownHref: \"/growth/referrals?claimStatus=failed\",\n181\t      },\n182\t      rows: failedClaimsRows,\n183\t    },\n184\t    {\n185\t      blueprint: {\n186\t        id: \"dead_queue_events\",\n187\t        label: \"Dead queue events\",\n188\t        unit: \"events\",\n189\t        source: \"event_queue\",\n190\t        windowLabel: \"All time\",\n191\t        definition:\n192\t          \"Event-queue rows in 'dead' status — past max attempts and not retried.\",\n193\t        drilldownHref: \"/operations/queue?status=dead\",\n194\t      },\n195\t      rows: deadQueueEventsRows,\n196\t    },\n197\t    {\n198\t      blueprint: {\n199\t        id: \"stuck_rounds_flipyou_potshot\",\n200\t        label: \"Stuck Flip You / Pot Shot rounds\",\n201\t        unit: \"rounds\",\n202\t        source: \"rounds\",\n203\t        windowLabel: `Older than ${thresholds.stuckRoundsAgeMinutes}m or settle_attempts > ${thresholds.stuckRoundsMaxSettleAttempts}`,\n204\t        definition:\n205\t          \"Rounds in nonterminal phases (created/locked/settling) past the age threshold or with elevated settle attempts.\",\n206\t        drilldownHref: \"/games?stuck=true\",\n207\t      },\n208\t      rows: stuckRoundsRows,\n209\t    },\n210\t    {\n211\t      blueprint: {\n212\t        id: \"stuck_rounds_closecall\",\n213\t        label: \"Stuck Close Call rounds\",\n214\t        unit: \"rounds\",\n215\t        source: \"closecall_rounds\",\n216\t        windowLabel: `Open phase older than ${thresholds.stuckCloseCallAgeMinutes}m`,\n217\t        definition:\n218\t          \"Close Call rounds still in 'open' phase past the age threshold; rounds settle on minute boundaries via Pyth.\",\n219\t        drilldownHref: \"/games/closecall?stuck=true\",\n220\t      },\n221\t      rows: stuckCloseCallRows,\n222\t    },\n223\t    {\n224\t      blueprint: {\n225\t        id: \"pending_sol_crate_payouts\",\n226\t        label: \"Pending SOL crate payouts\",\n227\t        unit: \"crates\",\n228\t        source: \"crate_drops\",\n229\t        windowLabel: \"All time\",\n230\t        definition:\n231\t          \"SOL-denominated crate drops in 'pending' status — payout has not been delivered on-chain.\",\n232\t        drilldownHref: \"/economy/rewards?crateType=sol&status=pending\",\n233\t      },\n234\t      rows: pendingSolCrateRows,\n235\t    },\n236\t    {\n237\t      blueprint: {\n238\t        id: \"stale_active_dogpile_events\",\n239\t        label: \"Stale active Dogpile events\",\n240\t        unit: \"events\",\n241\t        source: \"dogpile_events\",\n242\t        windowLabel: \"Active past end time\",\n243\t        definition:\n244\t          \"Dogpile events still in 'active' status whose ends_at has already passed; they should have transitioned to 'ended'.\",\n245\t        drilldownHref: \"/operations/dogpile?status=active\",\n246\t      },\n247\t      rows: staleActiveDogpileRows,\n248\t    },\n249\t    {\n250\t      blueprint: {\n251\t        id: \"high_value_exports_24h\",\n252\t        label: \"High-value exports (24h)\",\n253\t        unit: \"exports\",\n254\t        source: \"operator_events\",\n255\t        windowLabel: `Last ${thresholds.exportWindowHours}h`,\n256\t        definition: `peek.export operator events in the last ${thresholds.exportWindowHours}h whose resultCount exceeds ${thresholds.exportRowCountThreshold} rows.`,\n257\t        drilldownHref: \"/audit?eventType=peek.export\",\n258\t      },\n259\t      rows: highValueExportsRows,\n260\t    },\n261\t  ];\n262\t\n263\t  const metrics: PeekMetric[] = blueprints.map(({ blueprint, rows }) =>\n264\t    makeMetric(blueprint, readCount(rows), generatedAt),\n265\t  );\n266\t\n267\t  return {\n268\t    generatedAt,\n269\t    metrics,\n270\t  };\n271\t}\n272\t"}]},"parent_tool_use_id":null,"session_id":"63c99812-1bf4-4690-a26d-7ff1bda5689f","uuid":"3c62f5f5-505a-4f2b-a678-c3bc9be40644","timestamp":"2026-04-25T14:11:57.210Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-command-center-attention.ts","content":"// Command-center attention queue query (FR-3, FR-10).\n//\n// Returns a small set of bounded \"needs attention\" metrics that the command\n// center renders at the top of `/`. Each metric carries the FR-4 bookkeeping\n// (id, label, value, source table, time window, \"as of\", definition,\n// freshness, drill-down href) so the metric-strip primitive can render it\n// without per-page hardcoding.\n//\n// Bounded queries: every query returns a single integer count. No row-level\n// data crosses the wire here; per-feature pages provide the row drill-downs.\n\nimport type {\n  PeekCommandCenterAttention,\n  PeekCommandCenterAttentionId,\n  PeekMetric,\n} from \"../../../lib/types/peek\";\nimport type { Sql } from \"postgres\";\nimport { getSqlClient } from \"../client\";\n\n// Thresholds — tuned for an operator console, not a fairness oracle. Tests can\n// override via the `options` argument so age/limit assertions stay\n// deterministic.\nexport type CommandCenterThresholds = {\n  stuckRoundsAgeMinutes: number;\n  stuckRoundsMaxSettleAttempts: number;\n  stuckCloseCallAgeMinutes: number;\n  exportWindowHours: number;\n  exportRowCountThreshold: number;\n};\n\nexport const COMMAND_CENTER_DEFAULTS: CommandCenterThresholds = {\n  stuckRoundsAgeMinutes: 5,\n  stuckRoundsMaxSettleAttempts: 3,\n  stuckCloseCallAgeMinutes: 5,\n  exportWindowHours: 24,\n  exportRowCountThreshold: 1000,\n};\n\nexport type CommandCenterOptions = {\n  sql?: Sql;\n  thresholds?: Partial<CommandCenterThresholds>;\n  now?: Date;\n};\n\ntype AttentionRow = { value: number };\n\nfunction readCount(rows: ReadonlyArray<AttentionRow> | undefined): number {\n  if (!rows || rows.length === 0) {\n    return 0;\n  }\n  const raw = rows[0]?.value;\n  if (typeof raw === \"number\" && Number.isFinite(raw)) {\n    return raw;\n  }\n  if (typeof raw === \"string\") {\n    const parsed = Number.parseInt(raw, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\ntype MetricBlueprint = {\n  id: PeekCommandCenterAttentionId;\n  label: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  definition: string;\n  drilldownHref: string | null;\n};\n\nfunction makeMetric(\n  blueprint: MetricBlueprint,\n  count: number,\n  asOf: string,\n): PeekMetric {\n  return {\n    id: blueprint.id,\n    label: blueprint.label,\n    value: count,\n    valueDisplay: formatCount(count),\n    unit: blueprint.unit,\n    source: blueprint.source,\n    windowLabel: blueprint.windowLabel,\n    asOf,\n    definition: blueprint.definition,\n    freshness: \"live\",\n    drilldownHref: blueprint.drilldownHref,\n  };\n}\n\nexport async function getCommandCenterAttention(\n  options: CommandCenterOptions = {},\n): Promise<PeekCommandCenterAttention> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const thresholds: CommandCenterThresholds = {\n    ...COMMAND_CENTER_DEFAULTS,\n    ...options.thresholds,\n  };\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n\n  const stuckRoundsAgeInterval = `${thresholds.stuckRoundsAgeMinutes} minutes`;\n  const stuckCloseCallAgeInterval = `${thresholds.stuckCloseCallAgeMinutes} minutes`;\n  const exportWindowInterval = `${thresholds.exportWindowHours} hours`;\n\n  const [\n    failedClaimsRows,\n    deadQueueEventsRows,\n    stuckRoundsRows,\n    stuckCloseCallRows,\n    pendingSolCrateRows,\n    staleActiveDogpileRows,\n    highValueExportsRows,\n  ] = await Promise.all([\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from referral_claims\n      where status in ('failed', 'error')\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from event_queue\n      where status = 'dead'\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from rounds\n      where phase in ('created', 'locked', 'settling')\n        and (\n          created_at < now() - ${stuckRoundsAgeInterval}::interval\n          or settle_attempts > ${thresholds.stuckRoundsMaxSettleAttempts}\n        )\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from closecall_rounds\n      where phase = 'open'\n        and created_at < now() - ${stuckCloseCallAgeInterval}::interval\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from crate_drops\n      where crate_type = 'sol'\n        and status = 'pending'\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from dogpile_events\n      where status = 'active'\n        and ends_at < now()\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from operator_events\n      where event_type = 'peek.export'\n        and created_at > now() - ${exportWindowInterval}::interval\n        and coalesce((payload->>'resultCount')::int, 0)\n            > ${thresholds.exportRowCountThreshold}\n    `,\n  ]);\n\n  const blueprints: ReadonlyArray<{\n    blueprint: MetricBlueprint;\n    rows: ReadonlyArray<AttentionRow>;\n  }> = [\n    {\n      blueprint: {\n        id: \"failed_claims\",\n        label: \"Failed referral claims\",\n        unit: \"claims\",\n        source: \"referral_claims\",\n        windowLabel: \"All time\",\n        definition:\n          \"Referral claims with status 'failed' or 'error' that have not been recovered.\",\n        drilldownHref: \"/growth/referrals?claimStatus=failed\",\n      },\n      rows: failedClaimsRows,\n    },\n    {\n      blueprint: {\n        id: \"dead_queue_events\",\n        label: \"Dead queue events\",\n        unit: \"events\",\n        source: \"event_queue\",\n        windowLabel: \"All time\",\n        definition:\n          \"Event-queue rows in 'dead' status — past max attempts and not retried.\",\n        drilldownHref: \"/operations/queue?status=dead\",\n      },\n      rows: deadQueueEventsRows,\n    },\n    {\n      blueprint: {\n        id: \"stuck_rounds_flipyou_potshot\",\n        label: \"Stuck Flip You / Pot Shot rounds\",\n        unit: \"rounds\",\n        source: \"rounds\",\n        windowLabel: `Older than ${thresholds.stuckRoundsAgeMinutes}m or settle_attempts > ${thresholds.stuckRoundsMaxSettleAttempts}`,\n        definition:\n          \"Rounds in nonterminal phases (created/locked/settling) past the age threshold or with elevated settle attempts.\",\n        drilldownHref: \"/games?stuck=true\",\n      },\n      rows: stuckRoundsRows,\n    },\n    {\n      blueprint: {\n        id: \"stuck_rounds_closecall\",\n        label: \"Stuck Close Call rounds\",\n        unit: \"rounds\",\n        source: \"closecall_rounds\",\n        windowLabel: `Open phase older than ${thresholds.stuckCloseCallAgeMinutes}m`,\n        definition:\n          \"Close Call rounds still in 'open' phase past the age threshold; rounds settle on minute boundaries via Pyth.\",\n        drilldownHref: \"/games/closecall?stuck=true\",\n      },\n      rows: stuckCloseCallRows,\n    },\n    {\n      blueprint: {\n        id: \"pending_sol_crate_payouts\",\n        label: \"Pending SOL crate payouts\",\n        unit: \"crates\",\n        source: \"crate_drops\",\n        windowLabel: \"All time\",\n        definition:\n          \"SOL-denominated crate drops in 'pending' status — payout has not been delivered on-chain.\",\n        drilldownHref: \"/economy/rewards?crateType=sol&status=pending\",\n      },\n      rows: pendingSolCrateRows,\n    },\n    {\n      blueprint: {\n        id: \"stale_active_dogpile_events\",\n        label: \"Stale active Dogpile events\",\n        unit: \"events\",\n        source: \"dogpile_events\",\n        windowLabel: \"Active past end time\",\n        definition:\n          \"Dogpile events still in 'active' status whose ends_at has already passed; they should have transitioned to 'ended'.\",\n        drilldownHref: \"/operations/dogpile?status=active\",\n      },\n      rows: staleActiveDogpileRows,\n    },\n    {\n      blueprint: {\n        id: \"high_value_exports_24h\",\n        label: \"High-value exports (24h)\",\n        unit: \"exports\",\n        source: \"operator_events\",\n        windowLabel: `Last ${thresholds.exportWindowHours}h`,\n        definition: `peek.export operator events in the last ${thresholds.exportWindowHours}h whose resultCount exceeds ${thresholds.exportRowCountThreshold} rows.`,\n        drilldownHref: \"/audit?eventType=peek.export\",\n      },\n      rows: highValueExportsRows,\n    },\n  ];\n\n  const metrics: PeekMetric[] = blueprints.map(({ blueprint, rows }) =>\n    makeMetric(blueprint, readCount(rows), generatedAt),\n  );\n\n  return {\n    generatedAt,\n    metrics,\n  };\n}\n","numLines":272,"startLine":1,"totalLines":272}}}
