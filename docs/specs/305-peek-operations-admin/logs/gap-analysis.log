{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01USJM6yuUg5nWCv931bWR6c","type":"tool_result","content":"1\t// Server-only local role policy for peek (FR-2).\n2\t//\n3\t// Cloudflare Access decides who can reach the app; this module resolves a\n4\t// verified Cloudflare email to a single effective local role (`business` or\n5\t// `admin`) and exposes a server-side actor context. Browser headers are never\n6\t// trusted: the verified email comes only from the trusted middleware-set\n7\t// `VERIFIED_ACCESS_EMAIL_HEADER`, which the proxy strips and re-sets on every\n8\t// request.\n9\timport { headers } from \"next/headers\";\n10\timport { VERIFIED_ACCESS_EMAIL_HEADER } from \"./cloudflare-access\";\n11\timport type { PeekRole } from \"../lib/access-policy\";\n12\t\n13\texport type { PeekRole } from \"../lib/access-policy\";\n14\t\n15\texport type PeekRolePolicyEntry = {\n16\t  match: string;\n17\t  role: PeekRole;\n18\t};\n19\t\n20\texport type PeekRolePolicy = ReadonlyArray<PeekRolePolicyEntry>;\n21\t\n22\texport type PeekActorContext = {\n23\t  email: string;\n24\t  role: PeekRole;\n25\t};\n26\t\n27\tconst PEEK_ACCESS_POLICY_ENV = \"PEEK_ACCESS_POLICY\";\n28\t\n29\tconst EMAIL_PATTERN = /^[^\\s@]+@[^\\s@]+$/;\n30\t\n31\texport function parsePeekRolePolicy(raw: unknown): PeekRolePolicy {\n32\t  if (!Array.isArray(raw)) {\n33\t    return [];\n34\t  }\n35\t\n36\t  const entries: PeekRolePolicyEntry[] = [];\n37\t  const seen = new Set<string>();\n38\t\n39\t  for (const item of raw) {\n40\t    if (!item || typeof item !== \"object\") continue;\n41\t\n42\t    const role = (item as { role?: unknown }).role;\n43\t    if (role !== \"business\" && role !== \"admin\") continue;\n44\t\n45\t    const matchRaw = (item as { match?: unknown }).match;\n46\t    if (typeof matchRaw !== \"string\") continue;\n47\t\n48\t    const match = matchRaw.trim().toLowerCase();\n49\t    if (!match) continue;\n50\t\n51\t    if (match.startsWith(\"*@\")) {\n52\t      const domain = match.slice(2);\n53\t      if (!domain || !/^[^\\s@*]+$/.test(domain)) continue;\n54\t    } else if (!EMAIL_PATTERN.test(match)) {\n55\t      continue;\n56\t    }\n57\t\n58\t    const dedupeKey = `${match}::${role}`;\n59\t    if (seen.has(dedupeKey)) continue;\n60\t    seen.add(dedupeKey);\n61\t\n62\t    entries.push({ match, role });\n63\t  }\n64\t\n65\t  return entries;\n66\t}\n67\t\n68\texport function loadPeekRolePolicyFromEnv(): PeekRolePolicy {\n69\t  const raw = process.env[PEEK_ACCESS_POLICY_ENV]?.trim();\n70\t  if (!raw) return [];\n71\t  let parsed: unknown;\n72\t  try {\n73\t    parsed = JSON.parse(raw);\n74\t  } catch {\n75\t    return [];\n76\t  }\n77\t  return parsePeekRolePolicy(parsed);\n78\t}\n79\t\n80\texport function normalizeActorEmail(value: string | null | undefined): string | null {\n81\t  if (!value) return null;\n82\t  const email = value.trim().toLowerCase();\n83\t  if (!EMAIL_PATTERN.test(email)) return null;\n84\t  return email;\n85\t}\n86\t\n87\texport function resolveRoleForEmail(\n88\t  email: string | null | undefined,\n89\t  policy: PeekRolePolicy,\n90\t): PeekRole | null {\n91\t  const normalized = normalizeActorEmail(email);\n92\t  if (!normalized) return null;\n93\t\n94\t  const emailDomain = normalized.split(\"@\")[1] ?? \"\";\n95\t\n96\t  let resolved: PeekRole | null = null;\n97\t\n98\t  for (const entry of policy) {\n99\t    const matched = entry.match.startsWith(\"*@\")\n100\t      ? entry.match.slice(2) === emailDomain\n101\t      : entry.match === normalized;\n102\t    if (!matched) continue;\n103\t\n104\t    if (entry.role === \"admin\") {\n105\t      return \"admin\";\n106\t    }\n107\t    if (!resolved) {\n108\t      resolved = entry.role;\n109\t    }\n110\t  }\n111\t\n112\t  return resolved;\n113\t}\n114\t\n115\texport async function getPeekActorContext(): Promise<PeekActorContext | null> {\n116\t  const requestHeaders = await headers();\n117\t  const headerEmail = requestHeaders.get(VERIFIED_ACCESS_EMAIL_HEADER);\n118\t  const email = normalizeActorEmail(headerEmail);\n119\t  if (!email) return null;\n120\t\n121\t  const role = resolveRoleForEmail(email, loadPeekRolePolicyFromEnv());\n122\t  if (!role) return null;\n123\t\n124\t  return { email, role };\n125\t}\n126\t\n127\t// --- Route + action authorization (FR-2) -----------------------------------\n128\t//\n129\t// Page authorization is keyed by route prefix: the most specific prefix wins.\n130\t// Mutation/action authorization is keyed by stable action id and fails closed\n131\t// for unknown ids. Unknown route prefixes fall back to the documented default\n132\t// (read-only — any resolved peek role), per System Invariant #6.\n133\t\n134\texport type PeekRouteRule = {\n135\t  prefix: string;\n136\t  roles: ReadonlyArray<PeekRole>;\n137\t};\n138\t\n139\texport type PeekActionRule = {\n140\t  actionId: string;\n141\t  roles: ReadonlyArray<PeekRole>;\n142\t};\n143\t\n144\tconst ALL_ROLES: ReadonlyArray<PeekRole> = [\"business\", \"admin\"];\n145\t\n146\t// Default for unknown routes: any resolved peek role (read-only access).\n147\t// Sensitive routes must be enumerated below.\n148\texport const PEEK_DEFAULT_ROUTE_ROLES: ReadonlyArray<PeekRole> = ALL_ROLES;\n149\t\n150\texport const PEEK_ROUTE_RULES: ReadonlyArray<PeekRouteRule> = [\n151\t  { prefix: \"/audit\", roles: [\"admin\"] },\n152\t];\n153\t\n154\texport const PEEK_ACTION_RULES: ReadonlyArray<PeekActionRule> = [\n155\t  { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n156\t  { actionId: \"fraud_flag.status.update\", roles: [\"admin\"] },\n157\t  { actionId: \"dogpile.cancel\", roles: [\"admin\"] },\n158\t  { actionId: \"reward_config.update\", roles: [\"admin\"] },\n159\t];\n160\t\n161\tfunction normalizeRoutePath(path: string): string {\n162\t  if (!path) return \"/\";\n163\t  const withoutQuery = path.split(\"?\")[0]?.split(\"#\")[0] ?? path;\n164\t  if (!withoutQuery.startsWith(\"/\")) return `/${withoutQuery}`;\n165\t  if (withoutQuery