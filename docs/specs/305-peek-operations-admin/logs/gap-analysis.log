{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ASH1C8mALgK4bAii5hQnrW","type":"tool_result","content":"1\t// Games overview admin queries (FR-8).\n2\t//\n3\t// Backs `/games`: cross-game `game_entries` aggregations per game, plus a\n4\t// small platform-wide metric strip suitable for the FR-4 metric primitive.\n5\t// The single source of truth is `game_entries` (migration 007): one row per\n6\t// participation, UPSERT'd at settlement. The migration documents the refund\n7\t// convention used here:\n8\t//\n9\t//   \"Refunded entries: is_winner = NULL, payout_lamports = amount_lamports.\"\n10\t//\n11\t// Per-game counters:\n12\t//   entries          — all game_entries rows for the game\n13\t//   uniqueUsers      — distinct user_id values\n14\t//   wageredLamports  — sum(amount_lamports)\n15\t//   settledEntries   — rows with settled_at IS NOT NULL\n16\t//   refundEntries    — settled rows with is_winner IS NULL (refund sentinel)\n17\t//   payoutLamports   — sum(payout_lamports)\n18\t//   wins             — rows with is_winner = TRUE\n19\t//   losses           — rows with is_winner = FALSE\n20\t//\n21\t// Bounded: a single grouped query — no row-level data crosses the wire here.\n22\t// Deferred games (Crash, Game of Trades, Chart the Course, Slots Utopia, Tug\n23\t// of Earn) are not part of the data shape; the `/games` page renders them as\n24\t// documented placeholders only (system invariant 13).\n25\t\n26\timport type { Sql } from \"postgres\";\n27\timport {\n28\t  PEEK_GAME_IDS,\n29\t  type PeekGameId,\n30\t  type PeekGameOverview,\n31\t  type PeekGameOverviewMetricId,\n32\t  type PeekGameOverviewRow,\n33\t  type PeekMetric,\n34\t} from \"../../../lib/types/peek\";\n35\timport { getSqlClient } from \"../client\";\n36\t\n37\texport type GamesOverviewOptions = {\n38\t  sql?: Sql;\n39\t  now?: Date;\n40\t};\n41\t\n42\ttype AggregateRow = {\n43\t  game: PeekGameId;\n44\t  entries: number | string;\n45\t  unique_users: number | string;\n46\t  wagered_lamports: string;\n47\t  settled_entries: number | string;\n48\t  refund_entries: number | string;\n49\t  payout_lamports: string;\n50\t  wins: number | string;\n51\t  losses: number | string;\n52\t};\n53\t\n54\ttype CountRow = { value: number | string };\n55\t\n56\tfunction readInt(value: number | string | null | undefined): number {\n57\t  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n58\t  if (typeof value === \"string\") {\n59\t    const parsed = Number.parseInt(value, 10);\n60\t    return Number.isFinite(parsed) ? parsed : 0;\n61\t  }\n62\t  return 0;\n63\t}\n64\t\n65\tfunction readSum(value: string | null | undefined): string {\n66\t  return typeof value === \"string\" && value.length > 0 ? value : \"0\";\n67\t}\n68\t\n69\tfunction formatCount(count: number): string {\n70\t  return count.toLocaleString(\"en-US\");\n71\t}\n72\t\n73\tfunction formatLamports(value: string): string {\n74\t  if (!value || value === \"0\") return \"0\";\n75\t  const negative = value.startsWith(\"-\");\n76\t  const digits = negative ? value.slice(1) : value;\n77\t  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n78\t  return negative ? `-${grouped}` : grouped;\n79\t}\n80\t"}]},"parent_tool_use_id":null,"session_id":"63c99812-1bf4-4690-a26d-7ff1bda5689f","uuid":"8f03b5f0-0225-4270-8565-ab2c0b24ea04","timestamp":"2026-04-25T14:12:14.058Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-games-overview.ts","content":"// Games overview admin queries (FR-8).\n//\n// Backs `/games`: cross-game `game_entries` aggregations per game, plus a\n// small platform-wide metric strip suitable for the FR-4 metric primitive.\n// The single source of truth is `game_entries` (migration 007): one row per\n// participation, UPSERT'd at settlement. The migration documents the refund\n// convention used here:\n//\n//   \"Refunded entries: is_winner = NULL, payout_lamports = amount_lamports.\"\n//\n// Per-game counters:\n//   entries          — all game_entries rows for the game\n//   uniqueUsers      — distinct user_id values\n//   wageredLamports  — sum(amount_lamports)\n//   settledEntries   — rows with settled_at IS NOT NULL\n//   refundEntries    — settled rows with is_winner IS NULL (refund sentinel)\n//   payoutLamports   — sum(payout_lamports)\n//   wins             — rows with is_winner = TRUE\n//   losses           — rows with is_winner = FALSE\n//\n// Bounded: a single grouped query — no row-level data crosses the wire here.\n// Deferred games (Crash, Game of Trades, Chart the Course, Slots Utopia, Tug\n// of Earn) are not part of the data shape; the `/games` page renders them as\n// documented placeholders only (system invariant 13).\n\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_GAME_IDS,\n  type PeekGameId,\n  type PeekGameOverview,\n  type PeekGameOverviewMetricId,\n  type PeekGameOverviewRow,\n  type PeekMetric,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport type GamesOverviewOptions = {\n  sql?: Sql;\n  now?: Date;\n};\n\ntype AggregateRow = {\n  game: PeekGameId;\n  entries: number | string;\n  unique_users: number | string;\n  wagered_lamports: string;\n  settled_entries: number | string;\n  refund_entries: number | string;\n  payout_lamports: string;\n  wins: number | string;\n  losses: number | string;\n};\n\ntype CountRow = { value: number | string };\n\nfunction readInt(value: number | string | null | undefined): number {\n  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n  if (typeof value === \"string\") {\n    const parsed = Number.parseInt(value, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction readSum(value: string | null | undefined): string {\n  return typeof value === \"string\" && value.length > 0 ? value : \"0\";\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\nfunction formatLamports(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n","numLines":80,"startLine":1,"totalLines":310}}}
