{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EQaHRWonSWQQYt8XFdAdbF","type":"tool_result","content":"1\t// /operations/dogpile — Dogpile lifecycle + fraud review admin page (FR-9).\n2\t//\n3\t// Reads two migration-011 tables via `get-dogpile-and-fraud.ts` and composes\n4\t// the FR-4 metric strip with two operator surfaces:\n5\t//\n6\t//   - Dogpile events — scheduled / active / ended / cancelled lifecycle rows\n7\t//                       with per-event game_entries + point_grants window\n8\t//                       counts, filtered by status + starts_at range.\n9\t//   - Fraud flags    — read-only review queue (open / reviewed / dismissed)\n10\t//                       linked back to /users/[userId] with the JSONB\n11\t//                       `details` payload rendered verbatim.\n12\t//\n13\t// Both sections are read-only. Cancelling a scheduled dogpile event lives\n14\t// behind the FR-14 `dogpile.cancel` action id; transitioning a fraud flag\n15\t// lives behind the `fraud_flag.status.update` action id; neither mutation is\n16\t// implemented yet.\n17\timport type { CSSProperties } from \"react\";\n18\timport { DogpileEventsTable } from \"../../../src/components/dogpile-events-table\";\n19\timport { FraudFlagsTable } from \"../../../src/components/fraud-flags-table\";\n20\timport { MetricStrip } from \"../../../src/components/metric-strip\";\n21\timport {\n22\t  DogpileEventsFilterBar,\n23\t  FraudFlagsFilterBar,\n24\t} from \"../../../src/components/operations-dogpile-filter-bar\";\n25\timport {\n26\t  normalizeDogpileEventFiltersFromSearchParams,\n27\t  normalizeFraudFlagFiltersFromSearchParams,\n28\t} from \"../../../src/lib/operations-dogpile-search-params\";\n29\timport type {\n30\t  PeekDogpileEventRow,\n31\t  PeekDogpileFraudOverview,\n32\t  PeekFraudFlagListRow,\n33\t} from \"../../../src/lib/types/peek\";\n34\timport {\n35\t  getPeekActorContext,\n36\t  isActionAllowedForRole,\n37\t  isRouteAllowedForRole,\n38\t} from \".