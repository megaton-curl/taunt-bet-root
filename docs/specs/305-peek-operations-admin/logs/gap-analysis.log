ius: \"0.75rem\",\n361\t  background: \"#3f1d1d\",\n362\t  color: \"#fecaca\",\n363\t};\n364\t"}]},"parent_tool_use_id":null,"session_id":"c96f606c-1699-40ed-983c-99b59a054786","uuid":"e7b6dfe0-052a-4514-9957-9a9045afa132","timestamp":"2026-04-26T20:38:22.205Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/app/economy/challenges/page.tsx","content":"// /economy/challenges — challenge engine admin page (FR-9).\n//\n// Reads six migration-011 tables via `get-challenges.ts` and composes the\n// FR-4 metric strip with five operator surfaces:\n//\n//   - Campaigns           — top-level containers (daily / weekly / onboarding /\n//                            dogpile) with per-campaign challenge + active\n//                            assignment counts so empty / stalled campaigns\n//                            stand out.\n//   - Challenges          — per-template configuration (action, scope,\n//                            condition, threshold, reward), filterable by\n//                            campaign + isActive.\n//   - Assignments         — per-player per-period assignments with status,\n//                            progress vs. target, and link to user-detail.\n//   - Progress events     — append-only progress ledger pinning each game\n//                            round to an assignment for anti-gaming audit.\n//   - Completion bonuses  — meta-quest definitions + per-bonus completion\n//                            counts.\n//   - Bonus completions   — per-player per-period meta-quest completions.\n//\n// Every section is read-only. Challenge / campaign / completion-bonus\n// definition editing is explicitly out of scope (FR-9, FR-14) and the page\n// surfaces that boundary in the lead copy + the per-section read-only hint.\nimport type { CSSProperties } from \"react\";\nimport {\n  BonusCompletionsFilterBar,\n  ChallengeAssignmentsFilterBar,\n  ChallengesFilterBar,\n  ProgressEventsFilterBar,\n} from \"../../../src/components/e