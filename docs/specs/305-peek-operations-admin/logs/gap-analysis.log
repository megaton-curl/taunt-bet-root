   date window. URL-addressable (`auditFilter*`).\n//   - Filtered table — bounded list (default 100 rows, server-capped at 500).\n//                      Redacted payload values render the `PEEK_AUDIT_REDACTED`\n//                      sentinel verbatim so reviewers can see that a field was\n//                      redacted (not silently absent).\n//\n// Read-only — `operator_events` is append-only by contract and the admin UI\n// never edits or deletes audit rows.\nimport type { CSSProperties } from \"react\";\nimport { AuditEventsFilterBar } from \"../../src/components/audit-events-filter-bar\";\nimport { AuditEventsTable } from \"../../src/components/audit-events-table\";\nimport { MetricStrip } from \"../../src/components/metric-strip\";\nimport { normalizeAuditFiltersFromSearchParams } from \"../../src/lib/audit-search-params\";\nimport type {\n  PeekAuditEvent,\n  PeekAuditEventTypeCount,\n  PeekAuditOverview,\n} from \"../../src/lib/types/peek\";\nimport {\n  getPeekActorContext,\n  isRouteAllowedForRole,\n} from \"../../src/server/access-policy\";\nimport {\n  PEEK_AUDIT_DEFAULT_LIMIT,\n  getAuditOverview,\n  listAuditEvents,\n} from \"../../src/server/db/queries/get-audit-events\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst ROUTE = \"/audit\";\n\nexport default async function AuditPage({\n  searchParams,\n}: {\n  searchParams: Promise<Record<string, string | string[] | undefined>>;\n}) {\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n\n  if (!allowed) {\n    return (\n      <main style={mainStyle}>\n        <header>\n          <h1>Audit · operator_events</h1>\n        </header>\n        <p role=\"alert\" style={errorStyle}>\n          You do not have access to this page. /audit is restricted to admin\n          actors.\n        </p>\n      </main>\n    );\n  }\n\n  const params = await searchParams;\n  const filters = normalizeAuditFiltersFromSearchParams(params);\n\n  let overview: PeekAuditOverview = {\n    generatedAt: new Date().toISOString(),\n    metrics: [],\n    eventTypeCounts: [],\n  };\n  let rows: ReadonlyArray<PeekAuditEvent> = [];\n\n  let overviewError: string | null = null;\n  let rowsError: string | null = null;\n\n  try {\n    overview = await getAuditOverview();\n  } catch (error) {\n    overviewError =\n      error instanceof Error\n        ? error.message\n        : \"Audit overview could not be loaded.\";\n  }\n\n  try {\n    rows = await listAuditEvents({ filters });\n  } catch (error) {\n    rowsError =\n      error instanceof Error\n        ? error.message\n        : \"Audit events could not be loaded.\";\n  }\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <h1>Audit · operator_events</h1>\n        <p style={leadStyle}>\n          Read-only view of <code>operator_events</code> filtered to{\" \"}\n          <code>peek.*</code> events. Payload values are pre-redacted at write\n          time; the <code>{\"[REDACTED]\"}</code> marker renders verbatim so\n          reviewers can see when a secret-shaped field was scrubbed. Restricted\n          to admin actors via the FR-2 route policy.\n        </p>\n      </header>\n\n      <section aria-labelledby=\"overview-heading\">\n        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n          Overview\n        </h2>\n        <MetricStrip metrics={overview.metrics} error={overviewError} />\n      </section>\n\n      <section aria-labelledby=\"breakdown-heading\" style={sectionStyle}>\n        <h2 id=\"breakdown-heading\" style={sectionHeadingStyle}>\n          Event type breakdown\n        </h2>\n        <BreakdownCard\n          rows={overview.eventTypeCounts}\n          empty=\"No peek.* events recorded in this window yet.\"\n        />\n      </section>\n\n      <section aria-labelledby=\"rows-heading\" id=\"rows\" style={sectionStyle}>\n        <h2 id=\"rows-heading\" style={sectionHeadingStyle}>\n          Filtered events\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_AUDIT_DEFAULT_LIMIT} rows · sorted newest first ·\n          server-side capped. Filter by event type, actor email, resource id,\n          route, and created date window.\n        </p>\n        <AuditEventsFilterBar filters={filters} action={ROUTE} />\n        <AuditEventsTable rows={rows} error={rowsError} />\n      </section>\n    </main>\n  );\n}\n\ntype BreakdownCardProps = {\n  rows: ReadonlyArray<PeekAuditEventTypeCount>;\n  empty: string;\n};\n\nfunction BreakdownCard({ rows, empty }: BreakdownCardProps) {\n  if (rows.length === 0 || rows.every((row) => row.count === 0)) {\n    return (\n      <article style={breakdownCardStyle}>\n        <p style={breakdownEmptyStyle}>{empty}</p>\n      </article>\n    );\n  }\n\n  return (\n    <article style={breakdownCardStyle}>\n      <ul style={breakdownListStyle}>\n        {rows.map((row) => (\n          <li key={row.eventType} style={breakdownRowStyle}>\n            <span style={breakdownLeftStyle}>{row.eventType}</span>\n            <span style={breakdownRightStyle}>\n              {row.count.toLocaleString(\"en-US\")}\n            </span>\n          </li>\n        ))}\n      </ul>\n    </article>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst breakdownCardStyle: CSSProperties = {\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n  padding: \"1rem\",\n  background: \"#111827\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst breakdownEmptyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.8125rem\",\n  color: \"#94a3b8\",\n};\n\nconst breakdownListStyle: CSSProperties = {\n  margin: 0,\n  padding: 0,\n  listStyle: \"none\",\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst breakdownRowStyle: CSSProperties = {\n  display: \"flex\",\n  justifyContent: \"space-between\",\n  fontSize: \"0.8125rem\",\n  color: \"#e2e8f0\",\n};\n\nconst breakdownLeftStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  color: \"#cbd5f5\",\n};\n\nconst breakdownRightStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  color: \"#94a3b8\",\n};\n","numLines":253,"startLine":1,"totalLines":253}}}
