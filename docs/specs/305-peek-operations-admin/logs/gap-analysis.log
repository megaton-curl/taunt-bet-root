{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017W36UURn9fT4z1WA9VkXUM","type":"tool_result","content":"1\timport type {\n2\t  PeekChallengeAssignmentSummary,\n3\t  PeekCrateDropRow,\n4\t  PeekFraudFlagRow,\n5\t  PeekGameEntryRow,\n6\t  PeekKolRate,\n7\t  PeekLinkedAccountRow,\n8\t  PeekPlayerPoints,\n9\t  PeekPointGrantRow,\n10\t  PeekReferralClaimRow,\n11\t  PeekReferralEarningsSummary,\n12\t  PeekTelegramLinkTokenRow,\n13\t  PeekTransactionRow,\n14\t  PeekUserAttentionFlags,\n15\t  PeekUserDetail,\n16\t  PeekUserQueueEventRow,\n17\t} from \"../../../lib/types/peek\";\n18\timport { writePeekAuditEvent } from \"../../audit/writer\";\n19\timport { getSqlClient } from \"../client\";\n20\t\n21\texport const PEEK_USER_DETAIL_RECENT_LIMIT = 25;\n22\texport const PEEK_USER_DETAIL_TOKEN_LIMIT = 10;\n23\t\n24\ttype Sql = ReturnType<typeof getSqlClient>;\n25\t\n26\texport type PeekUserDetailAuditFn = (input: {\n27\t  actorEmail: string;\n28\t  userId: string;\n29\t  route: string | null;\n30\t  requestId: string | null;\n31\t}) => Promise<void>;\n32\t\n33\ttype GetPeekUserDetailOptions = {\n34\t  sql?: Sql;\n35\t  recentLimit?: number;\n36\t  tokenLimit?: number;\n37\t  actorEmail?: string | null;\n38\t  route?: string | null;\n39\t  requestId?: string | null;\n40\t  audit?: PeekUserDetailAuditFn | null;\n41\t};\n42\t\n43\tasync function defaultPeekUserDetailAudit(input: {\n44\t  actorEmail: string;\n45\t  userId: string;\n46\t  route: string | null;\n47\t  requestId: string | null;\n48\t}): Promise<void> {\n49\t  await writePeekAuditEvent({\n50\t    eventType: \"peek.user.view_sensitive\",\n51\t    payload: {\n52\t      actorEmail: input.actorEmail,\n53\t      route: input.route,\n54\t      actionId: \"peek.user.view_sensitive\",\n55\t      resourceType: \"user\",\n56\t      resourceId: input.userId,\n57\t      filterSummary: null,\n58\t      resultCount: 1,\n59\t      requestId: input.requestId,\n60\t      rejectionReason: null,\n61\t      changes: null,\n62\t    },\n63\t  });\n64\t}\n65\t\n66\texport function formatUserHeading(user: {\n67\t  userId: string;\n68\t  username: string | null;\n69\t}) {\n70\t  return user.username ?? user.userId;\n71\t}\n72\t\n73\texport async function getPeekUserDetail(\n74\t  userId: string,\n75\t  options: GetPeekUserDetailOptions = {},\n76\t): Promise<PeekUserDetail | null> {\n77\t  const sql = options.sql ?? getSqlClient();\n78\t  const recentLimit = clampPositiveInt(\n79\t    options.recentLimit,\n80\t    PEEK_USER_DETAIL_RECENT_LIMIT,\n81\t  );\n82\t  const tokenLimit = clampPositiveInt(\n83\t    options.tokenLimit,\n84\t    PEEK_USER_DETAIL_TOKEN_LIMIT,\n85\t  );\n86\t\n87\t  // Identity + linked-account telegram view (preserved as queries[0] so the\n88\t  // 303-era listing/detail tests continue to assert the same SQL contract).\n89\t  const [user] = await sql<\n90\t    Array<{\n91\t      userId: string;\n92\t      username: string | null;\n93\t      wallet: string;\n94\t      joinedAt: string;\n95\t      avatarUrl: string | null;\n96\t      heatMultiplier: string;\n97\t      profilePointsBalance: string;\n98\t      referralCode: string | null;\n99\t      referrerUserId: string | null;\n100\t      referrerCode: string | null;"}]},"parent_tool_use_id":null,"session_id":"63c99812-1bf4-4690-a26d-7ff1bda5689f","uuid":"cf8623e2-56bd-49d9-b869-3d573e0731ac","timestamp":"2026-04-25T14:12:02.849Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-peek-user-detail.ts","content":"import type {\n  PeekChallengeAssignmentSummary,\n  PeekCrateDropRow,\n  PeekFraudFlagRow,\n  PeekGameEntryRow,\n  PeekKolRate,\n  PeekLinkedAccountRow,\n  PeekPlayerPoints,\n  PeekPointGrantRow,\n  PeekReferralClaimRow,\n  PeekReferralEarningsSummary,\n  PeekTelegramLinkTokenRow,\n  PeekTransactionRow,\n  PeekUserAttentionFlags,\n  PeekUserDetail,\n  PeekUserQueueEventRow,\n} from \"../../../lib/types/peek\";\nimport { writePeekAuditEvent } from \"../../audit/writer\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_USER_DETAIL_RECENT_LIMIT = 25;\nexport const PEEK_USER_DETAIL_TOKEN_LIMIT = 10;\n\ntype Sql = ReturnType<typeof getSqlClient>;\n\nexport type PeekUserDetailAuditFn = (input: {\n  actorEmail: string;\n  userId: string;\n  route: string | null;\n  requestId: string | null;\n}) => Promise<void>;\n\ntype GetPeekUserDetailOptions = {\n  sql?: Sql;\n  recentLimit?: number;\n  tokenLimit?: number;\n  actorEmail?: string | null;\n  route?: string | null;\n  requestId?: string | null;\n  audit?: PeekUserDetailAuditFn | null;\n};\n\nasync function defaultPeekUserDetailAudit(input: {\n  actorEmail: string;\n  userId: string;\n  route: string | null;\n  requestId: string | null;\n}): Promise<void> {\n  await writePeekAuditEvent({\n    eventType: \"peek.user.view_sensitive\",\n    payload: {\n      actorEmail: input.actorEmail,\n      route: input.route,\n      actionId: \"peek.user.view_sensitive\",\n      resourceType: \"user\",\n      resourceId: input.userId,\n      filterSummary: null,\n      resultCount: 1,\n      requestId: input.requestId,\n      rejectionReason: null,\n      changes: null,\n    },\n  });\n}\n\nexport function formatUserHeading(user: {\n  userId: string;\n  username: string | null;\n}) {\n  return user.username ?? user.userId;\n}\n\nexport async function getPeekUserDetail(\n  userId: string,\n  options: GetPeekUserDetailOptions = {},\n): Promise<PeekUserDetail | null> {\n  const sql = options.sql ?? getSqlClient();\n  const recentLimit = clampPositiveInt(\n    options.recentLimit,\n    PEEK_USER_DETAIL_RECENT_LIMIT,\n  );\n  const tokenLimit = clampPositiveInt(\n    options.tokenLimit,\n    PEEK_USER_DETAIL_TOKEN_LIMIT,\n  );\n\n  // Identity + linked-account telegram view (preserved as queries[0] so the\n  // 303-era listing/detail tests continue to assert the same SQL contract).\n  const [user] = await sql<\n    Array<{\n      userId: string;\n      username: str