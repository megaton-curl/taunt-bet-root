getPeekActorContext();\n43\t  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n44\t\n45\t  if (!allowed) {\n46\t    return (\n47\t      <main style={mainStyle}>\n48\t        <header>\n49\t          <h1>Economy · Rewards</h1>\n50\t        </header>\n51\t        <p role=\"alert\" style={errorStyle}>\n52\t          You do not have access to this page.\n53\t        </p>\n54\t      </main>\n55\t    );\n56\t  }\n57\t\n58\t  let overview: PeekRewardsOverview = {\n59\t    generatedAt: new Date().toISOString(),\n60\t    metrics: [],\n61\t  };\n62\t  let pool: PeekRewardPool | null = null;\n63\t  let config: ReadonlyArray<PeekRewardConfigRow> = [];\n64\t  let fundings: ReadonlyArray<PeekRewardPoolFundingRow> = [];\n65\t\n66\t  let overviewError: string | null = null;\n67\t  let poolError: string | null = null;\n68\t  let configError: string | null = null;\n69\t  let fundingsError: string | null = null;\n70\t\n71\t  try {\n72\t    overview = await getRewardsOverview();\n73\t  } catch (error) {\n74\t    overviewError =\n75\t      error instanceof Error\n76\t        ? error.message\n77\t        : \"Rewards overview could not be loaded.\";\n78\t  }\n79\t\n80\t  try {"}]},"parent_tool_use_id":null,"session_id":"63c99812-1bf4-4690-a26d-7ff1bda5689f","uuid":"ad644124-ea10-416b-bca6-3f755d261a89","timestamp":"2026-04-25T14:13:02.148Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/app/economy/rewards/page.tsx","content":"// /economy/rewards — reward economy admin page (FR-9).\n//\n// Reads the migration-011 reward-economy tables via `get-rewards.ts` and\n// composes the FR-4 metric strip + the three FR-9 surfaces:\n//\n//   - Pool balance card    — singleton `reward_pool` accounting row\n//   - Reward config table  — operator-tunable economy parameters\n//   - Recent fundings      — append-only `reward_pool_fundings` ledger with\n//                            drill-down to the source round (universal-search\n//                     