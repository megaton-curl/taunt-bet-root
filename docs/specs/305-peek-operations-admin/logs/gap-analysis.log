{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Dkn6vkbsSnB3GKbJGoCP5C","type":"tool_result","content":"1\t// Per-game round queries (FR-8).\n2\t//\n3\t// Backs `/games/[game]` for FlipYou, Pot Shot, and Close Call.\n4\t//\n5\t// FlipYou + Pot Shot share the `rounds` table (migration 001) and the\n6\t// commit-reveal lifecycle (`created` -> `locked` -> `settling` -> `settled`\n7\t// or `expired`). Close Call uses the separate `closecall_rounds` table\n8\t// (migration 004) with its own `open` -> `settled`/`refunded` lifecycle and\n9\t// a Pyth-driven `outcome` column.\n10\t//\n11\t// Stuck-state filters cover the four operational signals from FR-8:\n12\t//\n13\t//   - nonterminalAged   — phase is in a non-terminal state for longer than\n14\t//                         the configured age threshold (created/locked/\n15\t//                         settling for FlipYou+Pot Shot; open for Close\n16\t//                         Call).\n17\t//   - highAttempts      — settle_attempts above the configured threshold\n18\t//                         (FlipYou+Pot Shot only — `closecall_rounds` has no\n19\t//                         `settle_attempts` column).\n20\t//   - settledWithoutTx  — round is settled but no payout/refund row exists\n21\t//                         in `transactions` for the round's match_id +\n22\t//                         game; the on-chain settlement step did not\n23\t//                         produce the expected ledger record.\n24\t//   - refunds           — phase reflects the refund terminal state\n25\t//                         (`expired` for FlipYou+Pot Shot; `refunded` or\n26\t//                         outcome `refund` for Close Call).\n27\t//\n28\t// Queries are bounded server-side via clamped page size and an explicit\n29\t// total-count query; lamport / u64 sums round-trip as `text` to preserve\n30\t// precision.\n31\t\n32\timport type { Sql } from \"postgres\";\n33\timport {\n34\t  PEEK_ROUNDS_GAME_IDS,\n35\t  type PeekCloseCallOutcome,\n36\t  type PeekCloseCallPhase,\n37\t  type PeekCloseCallRoundFilters,\n38\t  type PeekCloseCallRoundRow,\n39\t  type PeekCloseCallRoundStuckFilters,\n40\t  type PeekPagination,\n41\t  type PeekRoundFilters,\n42\t  type PeekRoundPhase,\n43\t  type PeekRoundRow,\n44\t  type PeekRoundStuckFilters,\n45\t  type PeekRoundsGameId,\n46\t  type PeekRoundsListResult,\n47\t} from \"../../../lib/types/peek\";\n48\timport { getSqlClient } from \"../client\";\n49\t\n50\texport const PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE = 50;\n51\texport const PEEK_GAME_ROUNDS_MAX_PAGE_SIZE = 250;\n52\t\n53\texport type RoundStuckThresholds = {\n54\t  ageMinutes: number;\n55\t  maxSettleAttempts: number;\n56\t};\n57\t\n58\texport const PEEK_ROUND_STUCK_DEFAULTS: RoundStuckThresholds = {\n59\t  ageMinutes: 5,\n60\t  maxSettleAttempts: 3,\n61\t};\n62\t\n63\texport type ListRoundsOptions = {\n64\t  sql?: Sql;\n65\t  game: PeekRoundsGameId;\n66\t  filters?: Partial<PeekRoundFilters>;\n67\t  page?: number;\n68\t  pageSize?: number;\n69\t  thresholds?: Partial<RoundStuckThresholds>;\n70\t};\n71\t\n72\texport type ListCloseCallRoundsOptions = {\n73\t  sql?: Sql;\n74\t  filters?: Partial<PeekCloseCallRoundFilters>;\n75\t  page?: number;\n76\t  pageSize?: number;\n77\t  thresholds?: Partial<RoundStuckThresholds>;\n78\t};\n79\t\n80\tconst EMPTY_STUCK_FILTERS: PeekRoundStuckFilters = {"}]},"parent_tool_use_id":null,"session_id":"63c99812-1bf4-4690-a26d-7ff1bda5689f","uuid":"5c52fdf0-9cea-4ce0-b747-c22ab4890564","timestamp":"2026-04-25T14:12:18.715Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-game-rounds.ts","content":"// Per-game round queries (FR-8).\n//\n// Backs `/games/[game]` for FlipYou, Pot Shot, and Close Call.\n//\n// FlipYou + Pot Shot share the `rounds` table (migration 001) and the\n// commit-reveal lifecycle (`created` -> `locked` -> `settling` -> `settled`\n// or `expired`). Close Call uses the separate `closecall