{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E4U5Pb3PaP5sz2RoNF7k7p","type":"tool_result","content":"430\t  payload: PeekAuditPayload;\n431\t};\n432\t\n433\t// --- Export contracts (FR-12) ------------------------------------------------\n434\t//\n435\t// Exports are server-rendered CSVs gated by the same page-level access as the\n436\t// source page, bounded by a server-side row cap, named with a deterministic\n437\t// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n438\t// bytes return. Export rows reuse the table view-model column ids so the export\n439\t// shape stays in lockstep with the rendered table; values are pre-formatted\n440\t// strings so CSV serialization stays straightforward and locale-stable.\n441\t\n442\texport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n443\t\n444\texport type PeekExportEntity =\n445\t  | \"users\"\n446\t  | \"referrers\"\n447\t  | \"kol\"\n448\t  | \"claims\"\n449\t  | \"rounds\"\n450\t  | \"transactions\"\n451\t  | \"queue\"\n452\t  | \"audit\";\n453\t\n454\texport type PeekExportRow = Record<string, string>;\n455\t\n456\texport type PeekExportFilenameInput = {\n457\t  entity: PeekExportEntity;\n458\t  date: string;\n459\t  filterSlug: string;\n460\t};\n461\t\n462\texport type PeekExportResult = {\n463\t  filename: string;\n464\t  rowCount: number;\n465\t  rowCap: number;\n466\t  rowCapApplied: boolean;\n467\t  columns: ReadonlyArray<PeekTableColumn>;\n468\t  rows: ReadonlyArray<PeekExportRow>;\n469\t};\n470\t\n471\t// --- Universal search (FR-5) -------------------------------------------------\n472\t//\n473\t// One search entry point that resolves common operational identifiers to typed\n474\t// result groups. Results are grouped by entity type so the UI can section them\n475\t// (user, referral, linked account, round, transaction, queue event). Each\n476\t// result includes enough context to disambiguate similar matches; sensitive\n477\t// values (wallet, Telegram id, 