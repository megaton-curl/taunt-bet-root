{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015H45bN9DSHxhVXGmUe6BSt","type":"tool_result","content":"1\timport type { CSSProperties } from \"react\";\n2\timport { MetricStrip } from \"../src/components/metric-strip\";\n3\timport { PaginationControls } from \"../src/components/pagination-controls\";\n4\timport { RecentActivityList } from \"../src/components/recent-activity-list\";\n5\timport { SummaryStrip } from \"../src/components/summary-strip\";\n6\timport { UniversalSearchResults } from \"../src/components/universal-search-results\";\n7\timport { UsersTable } from \"../src/components/users-table\";\n8\timport { normalizePeekSearchParams } from \"../src/lib/search-params\";\n9\timport type {\n10\t  PeekCommandCenterAttention,\n11\t  PeekRecentActivityItem,\n12\t  PeekSearchResponse,\n13\t  PeekSummary,\n14\t  PeekUserRow,\n15\t} from \"../src/lib/types/peek\";\n16\timport { getPeekActorContext } from \"../src/server/access-policy\";\n17\timport { countPeekUsers } from \"../src/server/db/queries/count-peek-users\";\n18\timport { getCommandCenterAttention } from \"../src/server/db/queries/get-command-center-attention\";\n19\timport { getPeekSummary } from \"../src/server/db/queries/get-peek-summary\";\n20\timport { getRecentOperatorEvents } from \"../src/server/db/queries/get-recent-operator-events\";\n21\timport { listPeekUsers } from \"../src/server/db/queries/list-peek-users\";\n22\timport { getUniversalSearchResults } from \"../src/server/db/queries/universal-search\";\n23\t\n24\texport const dynamic = \"force-dynamic\";\n25\t\n26\texport default async function HomePage({\n27\t  searchParams,\n28\t}: {\n29\t  searchParams: Promise<Record<string, string | string[] | undefined>>;\n30\t}) {\n31\t  const initialParams = normalizePeekSearchParams(await searchParams);\n32\t  let summary: PeekSummary = {\n33\t    totalUsers: 0,\n34\t    totalUsersWithCodes: 0,\n35\t    totalReferredUsers: 0,\n36\t    totalUniqueReferrers: 0,\n37\t  };\n38\t  let attention: PeekCommandCenterAttention = {\n39\t    generatedAt: new Date().toISOString(),\n40\t    metrics: [],\n41\t  };\n42\t  let recentActivity: PeekRecentActivityItem[] = [];\n43\t  let users: PeekUserRow[] = [];\n44\t  let totalCount = 0;\n45\t  let loadError: string | null = null;\n46\t  let attentionError: string | null = null;\n47\t  let activityError: string | null = null;\n48\t  let searchResponse: PeekSearchResponse | null = null;\n49\t  let searchError: string | null = null;\n50\t  let params = initialParams;\n51\t\n52\t  try {\n53\t    [summary, totalCount] = await Promise.all([\n54\t      getPeekSummary(),\n55\t      countPeekUsers(initialParams),\n56\t    ]);\n57\t\n58\t    if (totalCount > 0) {\n59\t      const totalPages = Math.max(1, Math.ceil(totalCount / initialParams.pageSize));\n60\t      params = {\n61\t        ...initialParams,\n62\t        page: Math.min(initialParams.page, totalPages),\n63\t      };\n64\t    }\n65\t\n66\t    users = await listPeekUsers(params);\n67\t  } catch (error) {\n68\t    loadError =\n69\t      error instanceof Error\n70\t        ? error.message\n71\t        : \"Peek could not load data from the database.\";\n72\t  }\n73\t\n74\t  try {\n75\t    attention = await getCommandCenterAttention();\n76\t  } catch (error) {\n77\t    attentionError =\n78\t      error instanceof Error\n79\t        ? error.message\n80\t        : \"Attention queue could not be loaded.\";\n81\t  }\n82\t\n83\t  try {\n84\t    recentActivity = await getRecentOperatorEvents();\n85\t  } catch (error) {\n86\t    activityError =\n87\t      error instanceof Error\n88\t        ? error.message\n89\t        : \"Recent activity could not be loaded.\";\n90\t  }\n91\t\n92\t  if (initialParams.query.trim().length > 0) {\n93\t    try {\n94\t      const actor = await getPeekActorContext();\n95\t      searchResponse = await getUniversalSearchResults({\n96\t        query: initialParams.query,\n97\t        actorEmail: actor?.email ?? \"\",\n98\t        route: \"/\",\n99\t        audit: actor?.email ? undefined : null,\n100\t      });\n101\t    } catch (error) {\n102\t      searchError =\n103\t        error instanceof Error\n104\t          ? error.message\n105\t          : \"Search could not be completed.\";\n106\t    }\n107\t  }\n108\t\n109\t  return (\n110\t    <main style={{ display: \"grid\", gap: \"1.5rem\" }}>\n111\t      <header>\n112\t        <h1>Command center</h1>\n113\t        <p style={{ margin: \"0.25rem 0 0\", color: \"#94a3b8\" }}>\n114\t          Search, attention queue, platform summary, recent activity, and users.\n115\t        </p>\n116\t      </header>\n117\t\n118\t      <section aria-labelledby=\"global-search-heading\">\n119\t        <h2 id=\"global-search-heading\" style={sectionHeadingStyle}>\n120\t          Global search\n121\t        </h2>\n122\t        <form\n123\t          action=\"/\"\n124\t          method=\"get\"\n125\t          role=\"search\"\n126\t          style={{ display: \"flex\", gap: \"0.5rem\", alignItems: \"stretch\" }}\n127\t        >\n128\t          <input\n129\t            aria-label=\"Global search\"\n130\t            defaultValue={params.query}\n131\t            name=\"query\"\n132\t            placeholder=\"user id, username, wallet, referral code, Telegram, round PDA, tx signature\"\n133\t            style={{ ...inputStyle, flex: 1 }}\n134\t            type=\"search\"\n135\t          />\n136\t          <button style={buttonStyle} type=\"submit\">\n137\t            Search\n138\t          </button>\n139\t        </form>\n140\t        {initialParams.query.trim().length > 0 ? (\n141\t          <div style={{ marginTop: \"1rem\" }}>\n142\t            <UniversalSearchResults\n143\t              error={searchError}\n144\t              response={searchResponse}\n145\t            />\n146\t          </div>\n147\t        ) : null}\n148\t      </section>\n149\t\n150\t      <section aria-labelledby=\"attention-heading\">\n151\t        <h2 id=\"attention-heading\" style={sectionHeadingStyle}>\n152\t          Attention queue\n153\t        </h2>\n154\t        <MetricStrip metrics={attention.metrics} error={attentionError} />\n155\t      </section>\n156\t\n157\t      <section aria-labelledby=\"summary-heading\">\n158\t        <h2 id=\"summary-heading\" style={sectionHeadingStyle}>\n159\t          Platform summary\n160\t        </h2>\n161\t        <SummaryStrip summary={summary} />\n162\t      </section>\n163\t\n164\t      <section aria-labelledby=\"activity-heading\">\n165\t        <h2 id=\"activity-heading\" style={sectionHeadingStyle}>\n166\t          Recent activity\n167\t        </h2>\n168\t        <RecentActivityList error={activityError} items={recentActivity} />\n169\t      </section>\n170\t\n171\t      <section aria-labelledby=\"users-heading\" style={{ display: \"grid\", gap: \"1rem\" }}>\n172\t        <h2 id=\"users-heading\" style={sectionHeadingStyle}>\n173\t          Users\n174\t        </h2>\n175\t        {loadError ? (\n176\t          <p\n177\t            style={{\n178\t              margin: 0,\n179\t              padding: \"0.75rem 1rem\",\n180\t              borderRadius: \"0.75rem\",\n181\t              background: \"#3f1d1d\",\n182\t              color: \"#fecaca\",\n183\t            }}\n184\t            role=\"alert\"\n185\t          >\n186\t            Data unavailable: {loadError}\n187\t          </p>\n188\t        ) : null}\n189\t        <form\n190\t          style={{\n191\t            display: \"grid\",\n192\t            gap: \"0.75rem\",\n193\t            gridTemplateColumns: \"repeat(auto-fit, minmax(180px, 1fr))\",\n194\t            alignItems: \"end\",\n195\t          }}\n196\t        >\n197\t          <input name=\"query\" type=\"hidden\" value={params.query} />\n198\t\n199\t          <label style={fieldStyle}>\n200\t            <span>Sort</span>\n201\t            <select defaultValue={params.sort} name=\"sort\" style={inputStyle}>\n202\t              <option value=\"joinedAt\">Joined</option>\n203\t              <option 