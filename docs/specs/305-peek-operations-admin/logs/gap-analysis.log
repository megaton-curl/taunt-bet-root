sNoop = pendingValue.trim() === valueCurrent.trim();\n  const canSubmit = !pending && !isNoop && confirmed;\n\n  return (\n    <form\n      action={dispatch}\n      style={formStyle}\n      aria-label=\"Edit reward config value\"\n    >\n      <input type=\"hidden\" name=\"key\" value={rowKey} />\n\n      <div style={fieldRowStyle}>\n        <label htmlFor={valueId} style={labelStyle}>\n          Value ({expectedType})\n        </label>\n        <div style={oldValueStyle}>old: {valueCurrent}</div>\n        <input\n          id={valueId}\n          name=\"value\"\n          type=\"text\"\n          inputMode={\n            expectedType === \"integer\" || expectedType === \"lamports\"\n              ? \"numeric\"\n              : \"decimal\"\n          }\n          defaultValue={valueCurrent}\n          required\n          style={inputStyle}\n          autoComplete=\"off\"\n          spellCheck={false}\n          onChange={(event) => setPendingValue(event.currentTarget.value)}\n        />\n        {isNoop ? (\n          <p style={hintStyle}>New value matches the current value.</p>\n        ) : (\n          <p style={diffHintStyle}>\n            new: <span style={newValueStyle}>{pendingValue}</span>\n          </p>\n        )}\n      </div>\n\n      <label htmlFor={confirmId} style={confirmRowStyle}>\n        <input\n          id={confirmId}\n          type=\"checkbox\"\n          name=\"confirm\"\n          value=\"true\"\n          checked={confirmed}\n          onChange={(event) => setConfirmed(event.currentTarget.checked)}\n          style={checkboxStyle}\n        />\n        <span>\n          I confirm this reward-economy change. (Required by FR-14.)\n        </span>\n      </label>\n\n      <button type=\"submit\" disabled={!canSubmit} style={submitStyle}>\n        {pending ? \"Applying…\" : \"Apply value change\"}\n      </button>\n\n      <MutationFeedback state={state} successLabel=\"Reward config updated.\" />\n    </form>\n  );\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst fieldRowStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst labelStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n  color: \"#94a3b8\",\n};\n\nconst oldValueStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  color: \"#64748b\",\n  fontFamily: \"monospace\",\n};\n\nconst newValueStyle: CSSProperties = {\n  color: \"#fcd34d\",\n};\n\nconst inputStyle: CSSProperties = {\n  padding: \"0.375rem 0.5rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #334155\",\n  background: \"#0f172a\",\n  color: \"#e2e8f0\",\n  fontSize: \"0.8125rem\",\n  fontFamily: \"monospace\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n  fontStyle: \"italic\",\n};\n\nconst diffHintStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n  fontFamily: \"monospace\",\n};\n\nconst confirmRowStyle: CSSProperties = {\n  display: \"flex\",\n  alignItems: \"center\",\n  gap: \"0.5rem\",\n  fontSize: \"0.8125rem\",\n  color: \"#cbd5f5\",\n};\n\nconst checkboxStyle: CSSProperties = {\n  cursor: \"pointer\",\n};\n\nconst submitStyle: CSSProperties = {\n  padding: \"0.375rem 0.75rem\",\n  borderRadius: \"0.375rem\",\n  border: \"1px solid #1e3a8a\",\n  background: \"#1e40af\",\n  color: \"#dbeafe\",\n  fontSize: \"0.8125rem\",\n  fontWeight: 600,\n  cursor: \"pointer\",\n};\n","numLines":181,"startLine":1,"totalLines":181}}}
