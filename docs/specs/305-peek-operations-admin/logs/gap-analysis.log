(sql, userId, tokenLimit),\n    fetchKolRate(sql, userId),\n    fetchReferralEarnings(sql, userId),\n    fetchRecentReferralClaims(sql, userId, recentLimit),\n    fetchPlayerPoints(sql, userId),\n    fetchRecentPointGrants(sql, userId, recentLimit),\n    fetchRecentCrateDrops(sql, userId, recentLimit),\n    fetchChallengeSummary(sql, userId),\n    fetchRecentGameEntries(sql, userId, recentLimit),\n    fetchRecentTransactions(sql, userId, recentLimit),\n    fetchFraudFlags(sql, userId, recentLimit),\n    fetchRecentUserQueueEvents(sql, userId, wallet, recentLimit),\n    fetchSelfReferralIndicator(sql, userId),\n  ]);\n\n  const attention = computeAttention({\n    recentReferralClaims,\n    recentUserQueueEvents,\n    fraudFlags,\n    recentCrateDrops,\n    selfReferralRow,\n  });\n\n  // FR-11: emit a `peek.user.view_sensitive` audit event when an authorized\n  // operator opens this user-detail page. The handler is opt-in via\n  // `actorEmail`; an empty actor or an explicit `audit: null` skips emission.\n  // Audit failures are caught here so the page still renders even if the\n  // writer's DB insert fails (the writer logs the underlying error).\n  const audit =\n    options.audit === undefined ? defaultPeekUserDetailAudit : options.audit;\n  if (audit && options.actorEmail) {\n    try {\n      await audit({\n        actorEmail: options.actorEmail,\n        userId,\n        route: options.route ?? null,\n        requestId: options.requestId ?? null,\n      });\n    } catch {\n      // Audit failures must never leak to the caller (FR-11). The writer\n      // already logs server-side; swallow here so the user-detail page still\n      // renders.\n    }\n  }\n\n  return {\n    user: {\n      userId: user.userId,\n      username: user.username,\n      wallet: user.wallet,\n      joinedAt: user.joinedAt,\n      referralCode: user.referralCode,\n      referrerUserId: user.referrerUserId,\n      referrerCode: user.referrerCode,\n      refereeCount: user.refereeCount,\n      telegramUsername: user.telegramUsername,\n      telegramUserId: user.telegramUserId,\n      avatarUrl: user.avatarUrl,\n      heatMultiplier: user.heatMultiplier,\n      profilePointsBalance: user.profilePointsBalance,\n    },\n    inboundReferral: {\n      referrerUserId: user.referrerUserId,\n      referrerCode: user.referrerCode,\n      linkedAt: user.linkedAt,\n    },\n    outboundReferees,\n    telegram: {\n      state: user.telegramLinkState,\n      telegramUserId: user.telegramUserId,\n      telegramUsername: user.telegramUsername,\n    },\n    linkedAccounts,\n    recentTelegramLinkTokens,\n    kolRate,\n    referralEarnings,\n    recentReferralClaims,\n    points,\n    recentPointGrants,\n    recentCrateDrops,\n    challengeSummary,\n    recentGameEntries,\n    recentTransactions,\n    fraudFlags,\n    recentUserQueueEvents,\n    attention,\n  };\n}\n\nfunction clampPositiveInt(value: number | undefined, fallback: number): number {\n  if (typeof value !== \"number\" || !Number.isFinite(value)) return fallback;\n  const floored = Math.floor(value);\n  if (floored <= 0) return 1;\n  return floored;\n}\n\nasync function fetchOutboundReferees(\n  sql: Sql,\n  userId: string,\n): Promise<PeekUserDetail[\"outboundReferees\"]> {\n  return sql<\n    Array<{\n      refereeUserId: string;\n      refereeUsername: string | null;\n      createdAt: string;\n    }>\n  >`\n    select\n      rl.referee_user_id as \"refereeUserId\",\n      pp.username as \"refereeUsername\",\n      rl.created_at::text as \"createdAt\"\n    from referral_links rl\n    left join player_profiles pp on pp.user_id = rl.referee_user_id\n    where rl.referrer_user_id = ${userId}\n    order by rl.created_at desc\n  `;\n}\n\nasync function fetchLinkedAccounts(\n  sql: Sql,\n  userId: string,\n): Promise<ReadonlyArray<PeekLinkedAccountRow>> {\n  return sql<Array<PeekLinkedAccountRow>>`\n    select\n      id::text as \"id\",\n      provider,\n      provider_account_id as \"providerAccountId\",\n  