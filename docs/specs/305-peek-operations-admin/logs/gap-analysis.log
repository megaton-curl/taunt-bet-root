{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y1ySeWLCbSacaXcBbqLR6a","type":"tool_result","content":"1\t// /audit — Operator audit admin page (FR-11).\n2\t//\n3\t// Reads `operator_events` (migration 002) filtered to the `peek.*` event types\n4\t// the FR-11 audit writer emits, via `get-audit-events.ts`. The page is admin-\n5\t// only via the FR-2 page-level allowlist (`PEEK_ROUTE_RULES` in\n6\t// `src/server/access-policy.ts`); a request from a non-admin actor renders an\n7\t// access-denied panel without any audit content.\n8\t//\n9\t// Layout:\n10\t//   - Metric strip   — total / exports / access denied / changes applied /\n11\t//                      changes rejected over the rolling 24h window. Each\n12\t//                      metric drills back into this same page with the\n13\t//                      matching `eventType` filter.\n14\t//   - Filter bar     — event type, actor email, resource id, route, created\n15\t//                      date window. URL-addressable (`auditFilter*`).\n16\t//   - Filtered table — bounded list (default 100 rows, server-capped at 500).\n17\t//                      Redacted payload values render the `PEEK_AUDIT_REDACTED`\n18\t//                      sentinel verbatim so reviewers can see that a field was\n19\t//                      redacted (not silently absent).\n20\t//\n21\t// Read-only — `operator_events` is append-only by contract and the admin UI\n22\t// never edits or deletes audit rows.\n23\timport type { CSSProperties } from \"react\";\n24\timport { AuditEventsFilterBar } from \"../../src/components/audit-events-filter-bar\";\n25\timport { AuditEventsTable } from \"../../src/components/audit-events-table\";\n26\timport { MetricStrip } from \"../../src/components/metric-strip\";\n27\timport { normalizeAuditFiltersFromSearchParams } from \"../../src/lib/audit-search-params\";\n28\timport type {\n29\t  PeekAuditEvent,\n30\t  PeekAuditEventTypeCount,\n31\t  PeekAuditOverview,\n32\t} from \"../../src/lib/types/peek\";\n33\timport {\n34\t  getPeekActorContext,\n35\t  isRouteAllowedForRole,\n36\t} from \"../../src/server/access-policy\";\n37\timport {\n38\t  PEEK_AUDIT_DEFAULT_LIMIT,\n39\t  getAuditOverview,\n40\t  listAuditEvents,\n41\t} from \"../../src/server/db/queries/get-audit-events\";\n42\t\n43\texport const dynamic = \"force-dynamic\";\n44\t\n45\tconst ROUTE = \"/audit\";\n46\t\n47\texport default async function AuditPage({\n48\t  searchParams,\n49\t}: {\n50\t  searchParams: Promise<Record<string, string | string[] | undefined>>;\n51\t}) {\n52\t  const actor = await getPeekActorContext();\n53\t  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n54\t\n55\t  if (!allowed) {\n56\t    return (\n57\t      <main style={mainStyle}>\n58\t        <header>\n59\t          <h1>Audit · operator_events</h1>\n60\t        </header>\n61\t        <p role=\"alert\" style={errorStyle}>\n62\t          You do not have access to this page. /audit is restricted to admin\n63\t          actors.\n64\t        </p>\n65\t      </main>\n66\t    );\n67\t  }\n68\t\n69\t  const params = await searchParams;\n70\t  const filters = normalizeAuditFiltersFromSearchParams(params);\n71\t\n72\t  let overview: PeekAuditOverview = {\n73\t    generatedAt: new Date().toISOString(),\n74\t    metrics: [],\n75\t    eventTypeCounts: [],\n76\t  };\n77\t  let rows: ReadonlyArray<PeekAuditEvent> = [];\n78\t\n79\t  let overviewError: string | null = null;\n80\t  let rowsError: string | null = null;\n81\t\n82\t  try {\n83\t    overview = await getAuditOverview();\n84\t  } catch (error) {\n85\t    overviewError =\n86\t      error instanceof Error\n87\t        ? error.message\n88\t        : \"Audit overview could not be loaded.\";\n89\t  }\n90\t\n91\t  try {\n92\t    rows = await listAuditEvents({ filters });\n93\t  } catch (error) {\n94\t    rowsError =\n95\t      error instanceof Error\n96\t        ? error.message\n97\t        : \"Audit events could not be loaded.\";\n98\t  }\n99\t\n100\t  return (\n101\t    <main style={mainStyle}>\n102\t      <header>\n103\t        <h1>Audit · operator_events</h1>\n104\t        <p style={leadStyle}>\n105\t          Read-only view of <code>operator_events</code> filtered to{\" \"}\n106\t          <code>peek.*</code> events. Payload values are pre-redacted at write\n107\t          time; the <code>{\"[REDACTED]\"}</code> marker renders verbatim so\n108\t          reviewers can see when a secret-shaped field was scrubbed. Restricted\n109\t          to admin actors via the FR-2 route policy.\n110\t        </p>\n111\t      </header>\n112\t\n113\t      <section aria-labelledby=\"overview-heading\">\n114\t        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n115\t          Overview\n116\t        </h2>\n117\t        <MetricStrip metrics={overview.metrics} error={overviewError} />\n118\t      </section>\n119\t\n120\t      <section aria-labelledby=\"breakdown-heading\" style={sectionStyle}>\n121\t        <h2 id=\"breakdown-heading\" style={sectionHeadingStyle}>\n122\t          Event type breakdown\n123\t        </h2>\n124\t        <BreakdownCard\n125\t          rows={overview.eventTypeCounts}\n126\t          empty=\"No peek.* events recorded in this window yet.\"\n127\t        />\n128\t      </section>\n129\t\n130\t      <section aria-labelledby=\"rows-heading\" id=\"rows\" style={sectionStyle}>\n131\t        <h2 id=\"rows-heading\" style={sectionHeadingStyle}>\n132\t          Filtered events\n133\t        </h2>\n134\t        <p style={hintStyle}>\n135\t          Default {PEEK_AUDIT_DEFAULT_LIMIT} rows · sorted newest first ·\n136\t          server-side capped. Filter by event type, actor email, resource id,\n137\t          route, and created date window.\n138\t        </p>\n139\t        <AuditEventsFilterBar filters={filters} action={ROUTE} />\n140\t        <AuditEventsTable rows={rows} error={rowsError} />\n141\t      </section>\n142\t    </main>\n143\t  );\n144\t}\n145\t\n146\ttype BreakdownCardProps = {\n147\t  rows: ReadonlyArray<PeekAuditEventTypeCount>;\n148\t  empty: string;\n149\t};\n150\t\n151\tfunction BreakdownCard({ rows, empty }: BreakdownCardProps) {\n152\t  if (rows.length === 0 || rows.every((row) => row.count === 0)) {\n153\t    return (\n154\t      <article style={breakdownCardStyle}>\n155\t        <p style={breakdownEmptyStyle}>{empty}</p>\n156\t      </article>\n157\t    );\n158\t  }\n159\t\n160\t  return (\n161\t    <article style={breakdownCardStyle}>\n162\t      <ul style={breakdownListStyle}>\n163\t        {rows.map((row) => (\n164\t          <li key={row.eventType} style={breakdownRowStyle}>\n165\t            <span style={breakdownLeftStyle}>{row.eventType}</span>\n166\t            <span style={breakdownRightStyle}>\n167\t              {row.count.toLocaleString(\"en-US\")}\n168\t            </span>\n169\t          </li>\n170\t        ))}\n171\t      </ul>\n172\t    </article>\n173\t  );\n174\t}\n175\t\n176\tconst mainStyle: CSSProperties = {\n177\t  display: \"grid\",\n178\t  gap: \"1.5rem\",\n179\t};\n180\t\n181\tconst sectionStyle: CSSProperties = {\n182\t  display: \"grid\",\n183\t  gap: \"0.75rem\",\n184\t};\n185\t\n186\tconst sectionHeadingStyle: CSSProperties = {\n187\t  margin: \"0 0 0.75rem\",\n188\t  fontSize: \"1rem\",\n189\t  fontWeight: 600,\n190\t  color: \"#cbd5f5\",\n191\t  textTransform: \"uppercase\",\n192\t  letterSpacing: \"0.05em\",\n193\t};\n194\t\n195\tconst leadStyle: CSSProperties = {\n196\t  margin: \"0.25rem 0 0\",\n197\t  color: \"#94a3b8\",\n198\t};\n199\t\n200\tconst hintStyle: CSSProperties = {\n201\t  margin: 0,\n202\t  color: \"#94a3b8\",\n203\t  fontSize: \"0.8125rem\",\n204\t};\n205\t\n206\tconst errorStyle: CSSProperties = {\n207\t  margin: 0,\n208\t  padding: \"0.75rem 1rem\",\n209\t  borderRadius: \"0.75rem\",\n210\t  background: \"#3f1d1d\",\n211\t  color: \"#fecaca\",\n212\t};\n213\t\n214\tconst breakdownCardStyle: CSSProperties = {\n215\t  border: \"1px solid #1e293b\",\n216\t  borderRadius: \"0.75rem\",\n