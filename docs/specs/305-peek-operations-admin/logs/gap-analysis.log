 !isNoop && confirmed;\n45\t\n46\t  return (\n47\t    <form\n48\t      action={dispatch}\n49\t      style={formStyle}\n50\t      aria-label=\"Edit reward config value\"\n51\t    >\n52\t      <input type=\"hidden\" name=\"key\" value={rowKey} />\n53\t\n54\t      <div style={fieldRowStyle}>\n55\t        <label htmlFor={valueId} style={labelStyle}>\n56\t          Value ({expectedType})\n57\t        </label>\n58\t        <div style={oldValueStyle}>old: {valueCurrent}</div>\n59\t        <input\n60\t          id={valueId}\n61\t          name=\"value\"\n62\t          type=\"text\"\n63\t          inputMode={\n64\t            expectedType === \"integer\" || expectedType === \"lamports\"\n65\t              ? \"numeric\"\n66\t              : \"decimal\"\n67\t          }\n68\t          defaultValue={valueCurrent}\n69\t          required\n70\t          style={inputStyle}\n71\t          autoComplete=\"off\"\n72\t          spellCheck={false}\n73\t          onChange={(event) => setPendingValue(event.currentTarget.value)}\n74\t        />\n75\t        {isNoop ? (\n76\t          <p style={hintStyle}>New value matches the current value.</p>\n77\t        ) : (\n78\t          <p style={diffHintStyle}>\n79\t            new: <span style={newValueStyle}>{pendingValue}</span>\n80\t          </p>\n81\t        )}\n82\t      </div>\n83\t\n84\t      <label htmlFor={confirmId} style={confirmRowStyle}>\n85\t        <input\n86\t          id={confirmId}\n87\t          type=\"checkbox\"\n88\t          name=\"confirm\"\n89\t          value=\"true\"\n90\t          checked={confirmed}\n91\t          onChange={(event) => setConfirmed(event.currentTarget.checked)}\n92\t          style={checkboxStyle}\n93\t        />\n94\t        <span>\n95\t          I confirm this reward-economy change. (Required by FR-14.)\n96\t        </span>\n97\t      </label>\n98\t\n99\t      <button type=\"submit\" disabled={!canSubmit} style={submitStyle}>\n100\t        {pending ? \"Applying…\" : \"Apply value change\"}\n101\t      </button>\n102\t\n103\t      <MutationFeedback state={state} successLabel=\"Reward config updated.\" />\n104\t    </form>\n105\t  );\n106\t}\n107\t\n108\tconst formStyle: CSSProperties = {\n109\t  display: \"grid\",\n110\t  gap: \"0.5rem\",\n111\t};\n112\t\n113\tconst fieldRowStyle: CSSProperties = {\n114\t  display: \"grid\",\n115\t  gap: \"0.25rem\",\n116\t};\n117\t\n118\tconst labelStyle: CSSProperties = {\n119\t  fontSize: \"0.75rem\",\n120\t  textTransform: \"uppercase\",\n121\t  letterSpacing: \"0.05em\",\n122\t  color: \"#94a3b8\",\n123\t};\n124\t\n125\tconst oldValueStyle: CSSProperties = {\n126\t  fontSize: \"0.75rem\",\n127\t  color: \"#64748b\",\n128\t  fontFamily: \"monospace\",\n129\t};\n130\t\n131\tconst newValueStyle: CSSProperties = {\n132\t  color: \"#fcd34d\",\n133\t};\n134\t\n135\tconst inputStyle: CSSProperties = {\n136\t  padding: \"0.375rem 0.5rem\",\n137\t  borderRadius: \"0.375rem\",\n138\t  border: \"1px solid #334155\",\n139\t  background: \"#0f172a\",\n140\t  color: \"#e2e8f0\",\n141\t  fontSize: \"0.8125rem\",\n142\t  fontFamily: \"monospace\",\n143\t};\n144\t\n145\tconst hintStyle: CSSProperties = {\n146\t  margin: 0,\n147\t  fontSize: \"0.75rem\",\n148\t  color: \"#94a3b8\",\n149\t  fontStyle: \"italic\",\n150\t};\n151\t\n152\tconst diffHintStyle: CSSProperties = {\n153\t  margin: 0,\n154\t  fontSize: \"0.75rem\",\n155\t  color: \"#94a3b8\",\n156\t  fontFamily: \"monospace\",\n157\t};\n158\t\n159\tconst confirmRowStyle: CSSProperties = {\n160\t  display: \"flex\",\n161\t  alignItems: \"center\",\n162\t  gap: \"0.5rem\",\n163\t  fontSize: \"0.8125rem\",\n164\t  color: \"#cbd5f5\",\n165\t};\n166\t\n167\tconst checkboxStyle: CSSProperties = {\n168\t  cursor: \"pointer\",\n169\t};\n170\t\n171\tconst submitStyle: CSSProperties = {\n172\t  padding: \"0.375rem 0.75rem\",\n173\t  borderRadius: \"0.375rem\",\n174\t  border: \"1px solid #1e3a8a\",\n175\t  background: \"#1e40af\",\n176\t  color: \"#dbeafe\",\n177\t  fontSize: \"0.8125rem\",\n178