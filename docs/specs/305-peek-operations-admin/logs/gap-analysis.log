{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012SMeyueqsRS3UGyJipoFgu","type":"tool_result","content":"1\t// Export action UI (FR-12).\n2\t//\n3\t// Renders an enabled `<a download>` when the server signals exports are\n4\t// available, or a disabled affordance with an explanatory tooltip when audit\n5\t// logging is unavailable in production. The component never builds the export\n6\t// URL itself — it just renders what the page passes in — so any access /\n7\t// audit decisions stay on the server.\n8\timport type { CSSProperties } from \"react\";\n9\t\n10\texport type ExportActionLinkProps = {\n11\t  href: string;\n12\t  label?: string;\n13\t  enabled: boolean;\n14\t  disabledReason?: string;\n15\t};\n16\t\n17\texport function ExportActionLink({\n18\t  href,\n19\t  label = \"Export CSV\",\n20\t  enabled,\n21\t  disabledReason,\n22\t}: ExportActionLinkProps) {\n23\t  if (!enabled) {\n24\t    const reason =\n25\t      disabledReason ??\n26\t      \"Exports are disabled because audit logging is not configured.\";\n27\t    return (\n28\t      <span\n29\t        role=\"button\"\n30\t        aria-disabled=\"true\"\n31\t        title={reason}\n32\t        style={disabledStyle}\n33\t        data-testid=\"export-action-disabled\"\n34\t      >\n35\t        {label}\n36\t      </span>\n37\t    );\n38\t  }\n39\t\n40\t  return (\n41\t    <a\n42\t      href={href}\n43\t      download\n44\t      style={enabledStyle}\n45\t      data-testid=\"export-action-enabled\"\n46\t    >\n47\t      {label}\n48\t    </a>\n49\t  );\n50\t}\n51\t\n52\tconst baseStyle: CSSProperties = {\n53\t  display: \"inline-flex\",\n54\t  alignItems: \"center\",\n55\t  gap: \"0.375rem\",\n56\t  padding: \"0.375rem 0.75rem\",\n57\t  borderRadius: \"0.5rem\",\n58\t  fontSize: \"0.8125rem\",\n59\t  fontWeight: 600,\n60\t  textDecoration: \"none\",\n61\t  border: \"1px solid transparent\",\n62\t};\n63\t\n64\tconst enabledStyle: CSSProperties = {\n65\t  ...baseStyle,\n66\t  background: \"#1e3a8a\",\n67\t  borderColor: \"#2563eb\",\n68\t  color: \"#dbeafe\",\n69\t  cursor: \"pointer\",\n70\t};\n71\t\n72\tconst disabledStyle: CSSProperties = {\n73\t  ...baseStyle,\n74\t  background: \"#1f2937\",\n75\t  borderColor: \"#334155\",\n76\t  color: \"#64748b\",\n77\t  cursor: \"not-allowed\",\n78\t};\n79\t"}]},"parent_tool_use_id":null,"session_id":"c96f606c-1699-40ed-983c-99b59a054786","uuid":"9feaee3a-cae3-4bec-89ad-453643bff033","timestamp":"2026-04-26T20:38:43.734Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/export-action-link.tsx","content":"// Export action UI (FR-12).\n//\n// Renders an enabled `<a download>` when the server signals exports are\n// available, or a disabled affordance with an explanatory tooltip when audit\n// logging is unavailable in production. The component never builds the export\n// URL itself — it just renders what the page passes in — so any access /\n// audit decisions stay on the server.\nimport type { CSSProperties } from \"react\";\n\nexport type ExportActionLinkProps = {\n  href: string;\n  label?: string;\n  enabled: boolean;\n  disabledReason?: string;\n};\n\nexport function ExportActionLink({\n  href,\n  label = \"Export CSV\",\n  enabled,\n  disabledReason,\n}: ExportActionLinkProps) {\n  if (!enabled) {\n    const reason =\n      disabledReason ??\n      \"Exports are disabled because audit logging is not configured.\";\n    return (\n      <span\n        role=\"button\"\n        aria-disabled=\"true\"\n        title={reason}\n        style={disabledStyle}\n        data-testid=\"export-action-disabled\"\n      >\n        {label}\n      </span>\n    );\n  }\n\n  return (\n    <a\n      href={href}\n      download\n      style={enabledStyle}\n      data-testid=\"export-action-enabled\"\n    >\n      {label}\n    </a>\n  );\n}\n\nconst baseStyle: CSSProperties = {\n  display: \"inline-flex\",\n  alignItems: \"center\",\n  gap: \"0.375rem\",\n  padding: \"0.375rem 0.75rem\",\n  borderRadius: \"0.5rem\",\n  fontSize: \"0.8125rem\",\n  fontWeight: 600,\n  textDecoration: \"none\",\n  border: \"1px solid transparent\",\n};\n\nconst enabledStyle: CSSProperties = {\n  ...baseStyle,\n  background: \"#1e3a8a\",\n  borderColor: \"#2563eb\",\n  color: \"#dbeafe\",\n  cursor: \"pointer\",\n};\n\nconst disabledStyle: CSSProperties = {\n  ...baseStyle,\n  background: \"#1f2937\",\n  borderColor: \"#334155\",\n  color: \"#64748b\",\n  cursor: \"not-allowed\",\n};\n","numLines":79,"startLine":1,"totalLines":79}}}
