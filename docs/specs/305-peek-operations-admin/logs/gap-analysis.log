res `confirm: true`. A missing/false `confirm` is\n//   rejected as `invalid_input` so the operator UI cannot silently apply\n//   a reward-economy change.\n//\n// No-op rejection:\n//   If the new `value` matches the row's existing `value`, the mutation is\n//   rejected (`execution_failed: noop_value`) so the audit row reflects a\n//   real movement.\n//\n// Failure semantics (surfaced through the runner's execute path):\n//   - Unknown key                -> `execution_failed: unknown_key:`.\n//     Note: the schema layer rejects un-allowlisted keys ahead of execute,\n//     so this surfaces only when a key listed in the registry is missing\n//     from the database.\n//   - No-op (value unchanged)    -> `execution_failed: noop_value`.\n//   - Schema validation failures (missing key/value, disallowed key,\n//     malformed value, missing confirmation) -> the runner's\n//     `invalid_input` path before any DB work.\n//\n// Authorization:\n//   `reward_config.update` is admin-only per FR-2 `PEEK_ACTION_RULES`.\n//   The runner enforces this before `execute` is called.\n\nimport type { Sql } from \"postgres\";\nimport { z } from \"zod\";\nimport type { PeekAuditChange } from \"../../lib/types/peek\";\nimport {\n  PEEK_REWARD_CONFIG_KEY_REGISTRY,\n} from \"../db/queries/get-rewards\";\nimport type {\n  PeekMutationDefinition,\n  PeekMutationExecuteContext,\n  PeekMutationExecuteResult,\n} from \"./registry\";\n\n// Editable keys are the registered keys whose expected type is known.\n// `Object.keys` on a frozen registry preserves insertion order; the result\n// is reused both for the schema enum and for runtime allowlist checks.\nexport const PEEK_REWARD_CONFIG_EDITABLE_KEYS: ReadonlyArray<string> =\n  Object.freeze(\n    Object.entries(PEEK_REWARD_CONFIG_KEY_REGISTRY)\n      .filter(([, entry]) => entry.expectedType !== \"unknown\")\n      .map(([key]) => key),\n  );\n\nfunction isEditableKey(key: string): boolean {\n  return PEEK_REWARD_CONFIG_EDITABLE_KEYS.includes(key);\n}\n\nconst INTEGER_PATTERN = /^-?[0-9]+$/u;\nconst LAMPORTS_PATTERN = /^[0-9]+$/u;\n\nexport type RewardConfigValueValidationResult =\n  | { ok: true }\n  | { ok: false; reason: string };\n\nexport function validateRewardConfigValueForKey(\n  key: string,\n  value: string,\n): RewardConfigValueValidationResult {\n  const entry = PEEK_REWARD_CONFIG_KEY_REGISTRY[key];\n  if (!entry) {\n    return { ok: false, reason: \"unknown_key\" };\n  }\n  switch (entry.expectedType) {\n    case \"integer\": {\n      if (!INTEGER_PATTERN.test(value)) {\n        return { ok: false, reason: \"expected_integer\" };\n      }\n      return { ok: true };\n    }\n    case \"lamports\": {\n      if (!LAMPORTS_PATTERN.test(value)) {\n        return { ok: false, reason: \"expected_lamports\" };\n      }\n      return { ok: true };\n    }\n    case \"float\": {\n      const parsed = Number(value);\n      if (!Number.isFinite(parsed)) {\n        return { ok: false, reason: \"expected_float\" };\n      }\n      // Reject pure-integer text so operators do not silently fill a float\n      // slot with a non-decimal value (e.g. \"2\" where \"2.0\" was intended).\n      if (INTEGER_PATTERN.test(value)) {\n        return { ok: false, reason: \"expected_float_with_decimal\" };\n      }\n      return { ok: true };\n    }\n    case \"ratio\": {\n      const parsed = Number(value);\n      if (!Number.isFinite(parsed)) {\n        return { ok: false, reason: \"expected_ratio\" };\n      }\n      if (parsed < 0 || parsed > 1) {\n        return { ok: false, reason: \"ratio_out_of_range\" };\n      }\n      return { ok: true };\n    }\n    case \"unknown\":\n    default: {\n      return { ok: false, reason: \"unknown_expected_type\" };\n    }\n  }\n}\n\nexport const rewardConfigUpdateInputSchema = z\n  .object({\n    key: z\n      .string()\n      .trim()\n      .min(1)\n      .refine(isEditableKey, {\n        message: \"key is not in the reward_config edit allowlist\",\n      }),\n    value: z.string().trim().min(1),\n    confirm: z.literal(true, {\n      message: \"confirm must be true to apply a reward_config change\",\n    }),\n  })\n  .strict()\n  .superRefine((data, ctx) => {\n    const result = validateRewardConfigValueForKey(data.key, data.value);\n    if (!result.ok) {\n      ctx.addIssue({\n        code: z.ZodIssueCode.custom,\n        path: [\"value\"],\n        message: result.reason,\n      });\n    }\n  });\n\nexport type RewardConfigUpdateInput = z.infer<\n  typeof rewardConfigUpdateInputSchema\n>;\n\ntype ExistingRewardConfigRow = {\n  key: string;\n  value: string;\n};\n\nasync function fetchExistingRow(\n  sql: Sql,\n  key: string,\n): Promise<ExistingRewardConfigRow | null> {\n  const rows = await sql<Array<ExistingRewardConfigRow>>`\n    select\n      key as \"key\",\n      value as \"value\"\n    from reward_config\n    where key = ${key}\n    for update\n  `;\n  return rows[0] ?? null;\n}\n\nasync function executeRewardConfigUpdate(\n  ctx: PeekMutationExecuteContext<RewardConfigUpdateInput>,\n): Promise<PeekMutationExecuteResult> {\n  const { sql, input } = ctx;\n  const { key, value } = input;\n\n  const existing = await fetchExistingRow(sql, key);\n  if (!existing) {\n    throw new Error(`unknown_key: ${key}`);\n  }\n\n  if (existing.value === value) {\n    throw new Error(\"noop_value\");\n  }\n\n  await sql`\n    update reward_config\n    set value = ${value}, updated_at = now()\n    where key = ${key}\n  `;\n\n  const changes: ReadonlyArray<PeekAuditChange> = [\n    { field: \"value\", before: existing.value, after: value },\n  ];\n  return { resourceId: existing.key, changes };\n}\n\nexport const rewardConfigUpdateMutation: PeekMutationDefinition<RewardConfigUpdateInput> =\n  {\n    actionId: \"reward_config.update\",\n    resourceType: \"reward_config\",\n    schema: rewardConfigUpdateInputSchema,\n    execute:\n      executeRewardConfigUpdate as PeekMutationDefinition[\"execute\"],\n  };\n","numLines":218,"startLine":1,"totalLines":218}}}
