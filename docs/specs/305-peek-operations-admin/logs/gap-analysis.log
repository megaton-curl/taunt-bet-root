{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AgmyA8ti4e6YVnMxFhB4jk","type":"tool_result","content":"1\t// /economy/challenges — challenge engine admin page (FR-9).\n2\t//\n3\t// Reads six migration-011 tables via `get-challenges.ts` and composes the\n4\t// FR-4 metric strip with five operator surfaces:\n5\t//\n6\t//   - Campaigns           — top-level containers (daily / weekly / onboarding /\n7\t//                            dogpile) with per-campaign challenge + active\n8\t//                            assignment counts so empty / stalled campaigns\n9\t//                            stand out.\n10\t//   - Challenges          — per-template configuration (action, scope,\n11\t//                            condition, threshold, reward), filterable by\n12\t//                            campaign + isActive.\n13\t//   - Assignments         — per-player per-period assignments with status,\n14\t//                            progress vs. target, and link to user-detail.\n15\t//   - Progress events     — append-only progress ledger pinning each game\n16\t//                            round to an assignment for anti-gaming audit.\n17\t//   - Completion bonuses  — meta-quest definitions + per-bonus completion\n18\t//                            counts.\n19\t//   - Bonus completions   — per-player per-period meta-quest completions.\n20\t//\n21\t// Every section is read-only. Challenge / campaign / completion-bonus\n22\t// definition editing is explicitly out of scope (FR-9, FR-14) and the page\n23\t// surfaces that boundary in the lead copy + the per-section read-only hint.\n24\timport type { CSSProperties } from \"react\";\n25\timport {\n26\t  BonusCompletionsFilterBar,\n27\t  ChallengeAssignmentsFilterBar,\n28\t  ChallengesFilterBar,\n29\t  ProgressEventsFilterBar,\n30\t} from \"../../../src/components/economy-challenges-filter-bar\";\n31\timport { BonusCompletionsTable } from \"../../../src/components/bonus-completions-table\";\n32\timport { CampaignsTable } from \"../../../src/components/campaigns-table\";\n33\timport { ChallengeAssignmentsTable } from \"../../../src/components/challenge-assignments-table\";\n34\timport { ChallengesTable } from \"../../../src/components/challenges-table\";\n35\timport { CompletionBonusesTable } from \"../../../src/components/completion-bonuses-table\";\n36\timport { MetricStrip } from \"../../../src/components/metric-strip\";\n37\timport { ProgressEventsTable } from \"../../../src/components/progress-events-table\";\n38\timport {\n39\t  normalizeBonusCompletionFiltersFromSearchParams,\n40\t  normalizeChallengeAssignmentFiltersFromSearchParams,\n41\t  normalizeChallengeFiltersFromSearchParams,\n42\t  normalizeProgressEventFiltersFromSearchParams,\n43\t} from \"../../../src/lib/economy-challenges-search-params\";\n44\timport type {\n45\t  PeekBonusCompletionRow,\n46\t  PeekCampaignRow,\n47\t  PeekChallengeAssignmentRow,\n48\t  PeekChallengeRow,\n49\t  PeekChallengesOverview,\n50\t  PeekCompletionBonusRow,\n51\t  PeekProgressEventRow,\n52\t} from \"../../../src/lib/types/peek\";\n53\timport {\n54\t  getPeekActorContext,\n55\t  isRouteAllowedForRole,\n56\t} from \"../../../src/server/access-policy\";\n57\timport {\n58\t  PEEK_BONUS_COMPLETIONS_DEFAULT_LIMIT,\n59\t  PEEK_CAMPAIGNS_DEFAULT_LIMIT,\n60\t  PEEK_CHALLENGES_DEFAULT_LIMIT,\n61\t  PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT,\n62\t  PEEK_COMPLETION_BONUSES_DEFAULT_LIMIT,\n63\t  PEEK_PROGRESS_EVENTS_DEFAULT_LIMIT,\n64\t  getChallengesOverview,\n65\t  listBonusCompletions,\n66\t  listCampaigns,\n67\t  listChallengeAssignments,\n68\t  listChallenges,\n69\t  listCompletionBonuses,\n70\t  listProgressEvents,\n71\t} from \"../../../src/server/db/queries/get-challenges\";\n72\t\n73\texport const dynamic = \"force-dynamic\";\n74\t\n75\tconst ROUTE = \"/economy/challenges\";\n76\t\n77\texport default async function EconomyChallengesPage({\n78\t  searchParams,\n79\t}: {\n80\t  searchParams: Promise<Record<string, string | string[] | undefined>>;\n81\t}) {\n82\t  const actor = await getPeekActorContext();\n83\t  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n84\t\n85\t  if (!allowed) {\n86\t    return (\n87\t      <main style={mainStyle}>\n88\t        <header>\n89\t          <h1>Economy · Challenges</h1>\n90\t        </header>\n91\t        <p role=\"alert\" style={errorStyle}>\n92\t          You do not have access to this page.\n93\t        </p>\n94\t      </main>\n95\t    );\n96\t  }\n97\t\n98\t  const params = await searchParams;\n99\t  const challengeFilters = normalizeChallengeFiltersFromSearchParams(params);\n100\t  const assignmentFilters =\n101\t    normalizeChallengeAssignmentFiltersFromSearchParams(params);\n102\t  const progressFilters = normalizeProgressEventFiltersFromSearchParams(params);\n103\t  const bonusCompletionFilters =\n104\t    normalizeBonusCompletionFiltersFromSearchParams(params);\n105\t\n106\t  let overview: PeekChallengesOverview = {\n107\t    generatedAt: new Date().toISOString(),\n108\t    metrics: [],\n109\t  };\n110\t  let campaigns: ReadonlyArray<PeekCampaignRow> = [];\n111\t  let challenges: ReadonlyArray<PeekChallengeRow> = [];\n112\t  let assignments: ReadonlyArray<PeekChallengeAssignmentRow> = [];\n113\t  let progressEvents: ReadonlyArray<PeekProgressEventRow> = [];\n114\t  let completionBonuses: ReadonlyArray<PeekCompletionBonusRow> = [];\n115\t  let bonusCompletions: ReadonlyArray<PeekBonusCompletionRow> = [];\n116\t\n117\t  let overviewError: string | null = null;\n118\t  let campaignsError: string | null = null;\n119\t  let challengesError: string | null = null;\n120\t  let assignmentsError: string | null = null;\n121\t  let progressError: string | null = null;\n122\t  let completionBonusesError: string | null = null;\n123\t  let bonusCompletionsError: string | null = null;\n124\t\n125\t  try {\n126\t    overview = await getChallengesOverview();\n127\t  } catch (error) {\n128\t    overviewError =\n129\t      error instanceof Error\n1