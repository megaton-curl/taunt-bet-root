{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WTnJ2t6ZbxaE2WVgLC7si3","type":"tool_result","content":"1\t// Rewards economy admin queries (FR-9).\n2\t//\n3\t// Backs `/economy/rewards`. Reads three migration-011 tables:\n4\t//\n5\t//   - reward_config           — operator-tunable economy parameters\n6\t//     (`listRewardConfig`). Each row is annotated server-side with a\n7\t//     human-readable definition + expected value type from\n8\t//     `PEEK_REWARD_CONFIG_KEY_REGISTRY`. Unknown keys still surface (with\n9\t//     `definition: null`, `expectedType: \"unknown\"`) so an operator\n10\t//     immediately notices when a new key has been seeded but the registry\n11\t//     has not been updated.\n12\t//   - reward_pool             — singleton accounting row (`getRewardPool`).\n13\t//   - reward_pool_fundings    — append-only per-round funding ledger\n14\t//     (`listRewardPoolFundings`). Bounded server-side; default 50, max 250.\n15\t//\n16\t// `getRewardsOverview` derives the FR-4 metric strip (current pool balance,\n17\t// lifetime funded, lifetime paid, recent fundings count) from these tables.\n18\t// Lamport / u64 values round-trip as `text` to preserve precision.\n19\t\n20\timport type { Sql } from \"postgres\";\n21\timport {\n22\t  type PeekMetric,\n23\t  type PeekRewardConfigExpectedType,\n24\t  type PeekRewardConfigRow,\n25\t  type PeekRewardPool,\n26\t  type PeekRewardPoolFundingRow,\n27\t  type PeekRewardsOverview,\n28\t  type PeekRewardsOverviewMetricId,\n29\t} from \"../../../lib/types/peek\";\n30\timport { getSqlClient } from \"../client\";\n31\t\n32\texport const PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT = 50;\n33\texport const PEEK_REWARD_POOL_FUNDINGS_MAX_LIMIT = 250;\n34\texport const PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS = 24;\n35\t\n36\t// Static registry of known reward_config keys (mirrors the seed in\n37\t// backend/migrations/011_challenge_engine.sql and the admin route allowlist\n38\t// in backend/src/routes/admin.ts). Adding a new key in either place should\n39\t// also extend this registry so an operator opening /economy/rewards sees a\n40\t// definition and expected type instead of \"unknown\".\n41\ttype RewardConfigRegistryEntry = {\n42\t  definition: string;\n43\t  expectedType: PeekRewardConfigExpectedType;\n44\t};\n45\t\n46\texport const PEEK_REWARD_CONFIG_KEY_REGISTRY: Readonly<\n47\t  Record<string, RewardConfigRegistryEntry>\n48\t> = {\n49\t  points_per_dollar: {\n50\t    definition:\n51\t      \"Points granted per USD-equivalent of wager — drives the wager → points conversion rate.\",\n52\t    expectedType: \"integer\",\n53\t  },\n54\t  dogpile_default_multiplier: {\n55\t    definition:\n56\t      \"Default points multiplier applied during active Dogpile events when a campaign override is not set.\",\n57\t    expectedType: \"float\",\n58\t  },\n59\t  reward_pool_fee_share: {\n60\t    definition:\n61\t      \"Fraction of platform fee diverted into the reward pool on each settled round (0..1).\",\n62\t    expectedType: \"ratio\",\n63\t  },\n64\t  points_crate_drop_rate: {\n65\t    definition:\n66\t      \"Probability per eligible action that a points crate drops (0..1).\",\n67\t    expectedType: \"ratio\",\n68\t  },\n69\t  sol_crate_drop_rate: {\n70\t    definition:\n71\t      \"Probability per eligible action that a SOL crate drops (0..1).\",\n72\t    expectedType: \"ratio\",\n73\t  },\n74\t  sol_crate_pool_pct: {\n75\t    definition:\n76\t      \"Fraction of the reward pool used to size a SOL crate payout when it drops (0..1).\",\n77\t    expectedType: \"ratio\",\n78\t  },\n79\t  sol_crate_min_value: {\n80\t    definition:"}]},"parent_tool_use_id":null,"session_id":"63c99812-1bf4-4690-a26d-7ff1bda5689f","uuid":"d0730e65-ef40-48a8-b496-b201e44b061a","timestamp":"2026-04-25T14:12:08.920Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-rewards.ts","content":"// Rewards economy admin queries (FR-9).\n//\n// Backs `/economy/rewards`. Reads three migration-011 tables:\n//\n//   - reward_config           — operator-tunable economy parameters\n//     (`listRewardConfig`). Each row is annotated server-side with a\n//     human-readable definition + expected value type from\n//     `PEEK_REWARD_CONFIG_KEY_REGISTRY`. Unknown keys still surface (with\n//     `definition: null`, `expectedType: \"unknown\"`) so an operator\n//     immediately notices when a new key has been seeded but the registry\n//     has not been updated.\n//   - reward_pool             — singleton accounting row (`getRewardPool`).\n//   - reward_pool_fundings    — append-only per-round funding ledger\n//     (`listRewardPoolFundings`). Bounded server-side; default 50, max 250.\n//\n// `getRewardsOverview` derives the FR-4 metric strip (current pool balance,\n// lifetime funded, lifetime paid, recent fundings count) from these tables.\n// Lamport / u64 values round-trip as `text` to preserve precision.\n\nimport type { Sql } from \"postgres\";\nimport {\n  type PeekMetric,\n  type PeekRewardConfigExpectedType,\n  type PeekRewardConfigRow,\n  type PeekRewardPool,\n  type PeekRewardPoolFundingRow,\n  type PeekRewardsOverview,\n  type PeekRewardsOverviewMetricId,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT = 50;\nexport const PEEK_REWARD_POOL_FUNDINGS_MAX_LIMIT = 250;\nexport const PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS = 24;\n\n// Static registry of known reward_config keys (mirrors the seed in\n// backend/migrations/011_challenge_engine.sql and the admin route allowlist\n// in backend/src/routes/admin.ts). Adding a new key in either place should\n// also extend this registry so an operator opening /economy/rewards sees a\n// definition and expected type instead of \"unknown\".\ntype RewardConfigRegistryEntry = {\n  definition: string;\n  expectedType: PeekRewardConfigExpectedType;\n};\n\nexport const PEEK_REWARD_CONFIG_KEY_REGISTRY: Readonly<\n  Record<string, RewardConfigRegistryEntry>\n> = {\n  points_per_dollar: {\n    definition:\n      \"Points granted per USD-equivalent of wager — drives the wager → points conversion rate.\",\n    expectedType: \"integer\",\n  },\n  dogpile_default_multiplier: {\n    definition:\n      \"Default points multiplier applied during active Dogpile events when a campaign override is not set.\",\n    expectedType: \"float\",\n  },\n  reward_pool_fee_share: {\n    definition:\n      \"Fraction of platform fee diverted into the reward pool on each settled round (0..1).\",\n    expectedType: \"ratio\",\n  },\n  points_crate_drop_rate: {\n    definition:\n      \"Probability per eligible action that a points crate drops (0..1).\",\n    expectedType: \"ratio\",\n  },\n  sol_crate_drop_rate: {\n    definition:\n      \"Probability per eligible action that a SOL crate drops (0..1).\",\n    expectedType: \"ratio\",\n  },\n  sol_crate_pool_pct: {\n    definition:\n      \"Fraction of the reward pool used to size a SOL crate payout when it drops (0..1).\",\n    expectedType: \"ratio\",\n  },\n  sol_crate_min_value: {\n    definition:","numLines":80,"startLine":1,"totalLines":388}}}
