{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AfnsZCB1Y8fgn3Zrh6QATu","type":"tool_result","content":"// Server-only admin-shell nav model (FR-3).\n//\n// The full nav (Users, Growth, Games, Economy, Operations, Audit, Access) is\n// declared once here and resolved against the route-prefix policy in\n// `access-policy.ts`. The layout filters the list against the resolved actor\n// role before passing it to the AdminShell so the shell itself stays a pure\n// presentational component.\nimport { isRouteAllowedForRole } from \"./access-policy\";\nimport type { PeekRole } from \"../lib/access-policy\";\nimport type { AdminShellNavItem } from \"../components/admin-shell\";\n\nexport const PEEK_ADMIN_SHELL_NAV: ReadonlyArray<AdminShellNavItem> = [\n  { id: \"users\", label: \"Users\", href: \"/users\" },\n  { id: \"growth\", label: \"Growth\", href: \"/growth/referrals\" },\n  { id: \"games\", label: \"Games\", href: \"/games\" },\n  { id: \"economy\", label: \"Economy\", href: \"/economy/rewards\" },\n  { id: \"operations\", label: \"Operations\", href: \"/operations/queue\" },\n  { id: \"audit\", label: \"Audit\", href: \"/audit\" },\n  { id: \"access\", label: \"Access\", href: \"/access\" },\n];\n\nexport function getVisibleNavItemsForRole(\n  role: PeekRole | null,\n  items: ReadonlyArray<AdminShellNavItem> = PEEK_ADMIN_SHELL_NAV,\n): ReadonlyArray<AdminShellNavItem> {\n  if (!role) return [];\n  return items.filter((item) => isRouteAllowedForRole(item.href, role));\n}","is_error":false}]},"parent_tool_use_id":null,"session_id":"c96f606c-1699-40ed-983c-99b59a054786","uuid":"c853a4c0-cac1-4506-af19-62eea3f6bb7a","timestamp":"2026-04-26T20:38:28.664Z","tool_use_result":{"stdout":"// Server-only admin-shell nav model (FR-3).\n//\n// The full nav (Users, Growth, Games, Economy, Operations, Audit, Access) is\n// declared once here and resolved against the route-prefix policy in\n// `access-policy.ts`. The layout filters the list against the resolved actor\n// role before passing it to the AdminShell so the shell itself stays a pure\n// presentational component.\nimport { isRouteAllowedForRole } from \"./access-policy\";\nimport type { PeekRole } from \"../lib/access-policy\";\nimport type { AdminShellNavItem } from \"../components/admin-shell\";\n\nexport const PEEK_ADMIN_SHELL_NAV: ReadonlyArray<AdminShellNavItem> = [\n  { id: \"users\", label: \"Users\", href: \"/users\" },\n  { id: \"growth\", label: \"Growth\", href: \"/growth/referrals\" },\n  { id: \"games\", label: \"Games\", href: \"/games\" },\n  { id: \"economy\", label: \"Economy\", href: \"/economy/rewards\" },\n  { id: \"operations\", label: \"Operations\", href: \"/operations/queue\" },\n  { id: \"audit\", label: \"Audit\", href: \"/audit\" },\n  { id: \"access\", label: \"Access\", href: \"/access\" },\n];\n\nexport function getVisibleNavItemsForRole(\n  role: PeekRole | null,\n  items: ReadonlyArray<AdminShellNavItem> = PEEK_ADMIN_SHELL_NAV,\n): ReadonlyArray<AdminShellNavItem> {\n  if (!role) return [];\n  return items.filter((item) => isRouteAllowedForRole(item.href, role));\n}","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
