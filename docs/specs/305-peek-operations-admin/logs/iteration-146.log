{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019FHPBkyMB4k8UHJLPsXRce","type":"tool_result","content":"140\t  actionId: string;\n141\t  roles: ReadonlyArray<PeekRole>;\n142\t};\n143\t\n144\tconst ALL_ROLES: ReadonlyArray<PeekRole> = [\"business\", \"admin\"];\n145\t\n146\t// Default for unknown routes: any resolved peek role (read-only access).\n147\t// Sensitive routes must be enumerated below.\n148\texport const PEEK_DEFAULT_ROUTE_ROLES: ReadonlyArray<PeekRole> = ALL_ROLES;\n149\t\n150\texport const PEEK_ROUTE_RULES: ReadonlyArray<PeekRouteRule> = [\n151\t  { prefix: \"/audit\", roles: [\"admin\"] },\n152\t];\n153\t\n154\texport const PEEK_ACTION_RULES: ReadonlyArray<PeekActionRule> = [\n155\t  { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n156\t  { actionId: \"fraud_flag.status.update\", roles: [\"admin\"] },\n157\t  { actionId: \"dogpile.cancel\", roles: [\"admin\"] },\n158\t  { actionId: \"reward_config.update\", roles: [\"admin\"] },\n159\t];\n160\t\n161\tfunction normalizeRoutePath(path: string): string {\n162\t  if (!path) return \"/\";\n163\t  const withoutQuery = path.split(\"?\")[0]?.split(\"#\")[0] ?? path;\n164\t  if (!withoutQuery.startsWith(\"/\")) return `/${withoutQuery}`;\n165\t  if (withoutQuery.length > 1 && withoutQuery.endsWith(\"/\")) {\n166\t    return withoutQuery.slice(0, -1);\n167\t  }\n168\t  return withoutQuery;\n169\t}\n170\t\n171\tfunction prefixMatches(prefix: string, path: string): boolean {\n172\t  if (prefix === \"/\") return true;\n173\t  if (path === prefix) return true;\n174\t  return path.startsWith(`${prefix}/`);\n175\t}\n176\t\n177\texport function getRequiredRolesForRoute(\n178\t  path: string,\n179\t  rules: ReadonlyArray<PeekRouteRule> = PEEK_ROUTE_RULES,\n180\t): ReadonlyArray<PeekRole> {\n181\t  const normalized = normalizeRoutePath(path);\n182\t  let best: PeekRouteRule | null = null;\n183\t  for (const rule of rules) {\n184\t    if (!prefixMatches(rule.prefix, normalized)) continue;\n185\t    if (!best || rule.prefix.length > best.prefix.length) {\n186\t      best = rule;\n187\t    }\n188\t  }\n189\t  return best ? best.roles : PEEK_DEFAULT_ROUTE_ROLES;\n190\t}\n191\t\n192\texport function isRouteAllowedForRole(\n193\t  path: string,\n194\t  role: PeekRole | null | undefined,\n195\t  rules: ReadonlyArray<PeekRouteRule> = PEEK_ROUTE_RULES,\n196\t): boolean {\n197\t  if (!role) return false;\n198\t  return getRequiredRolesForRoute(path, rules).includes(role);\n199\t}\n200\t\n201\texport function getRequiredRolesForAction(\n202\t  actionId: string,\n203\t  rules: ReadonlyArray<PeekActionRule> = PEEK_ACTION_RULES,\n204\t): ReadonlyArray<PeekRole> | null {\n205\t  const rule = rules.find((entry) => entry.actionId === actionId);\n206\t  return rule ? rule.roles : null;\n207\t}\n208\t\n209\texport function isActionAllowedForRole(\n210\t  actionId: string,\n211\t  role: PeekRole | null | undefined,\n212\t  rules: ReadonlyArray<PeekActionRule> = PEEK_ACTION_RULES,\n213\t): boolean {\n214\t  if (!role) return false;\n215\t  const required = getRequiredRolesForAction(actionId, rules);\n216\t  if (!required) return false;\n217\t  return required.includes(role);\n218\t}\n219\t"}]},"parent_tool_use_id":null,"session_id":"4de5a64f-41df-4f36-abe8-b663a1d849a0","uuid":"e14199e2-86d7-4561-98e9-d521a4ff87c4","timestamp":"2026-04-26T15:26:29.170Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/access-policy.ts","content":"  actionId: string;\n  roles: ReadonlyArray<PeekRole>;\n};\n\nconst ALL_ROLES: ReadonlyArray<PeekRole> = [\"business\", \"admin\"];\n\n// Default for unknown routes: any resolved peek role (read-only access).\n// Sensitive routes must be enumerated below.\nexport const PEEK_DEFAULT_ROUTE_ROLES: ReadonlyArray<PeekRole> = ALL_ROLES;\n\nexport const PEEK_ROUTE_RULES: ReadonlyArray<PeekRouteRule> = [\n  { prefix: \"/audit\", roles: [\"admin\"] },\n];\n\nexport const PEEK_ACTION_RULES: ReadonlyArray<PeekActionRule> = [\n  { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n  { actionId: \"fraud_flag.status.update\", roles: [\"admin\"] },\n  { actionId: \"dogpile.cancel\", roles: [\"admin\"] },\n  { actionId: \"reward_config.update\", roles: [\"admin\"] },\n];\n\nfunction normalizeRoutePath(path: string): string {\n  if (!path) return \"/\";\n  const withoutQuery = path.split(\"?\")[0]?.split(\"#\")[0] ?? path;\n  if (!withoutQuery.startsWith(\"/\")) return `/${withoutQuery}`;\n  if (withoutQuery.length > 1 && withoutQuery.endsWith(\"/\")) {\n    return withoutQuery.slice(0, -1);\n  }\n  return withoutQuery;\n}\n\nfunction prefixMatches(prefix: string, path: string): boolean {\n  if (prefix === \"/\") return true;\n  if (path === prefix) return true;\n  return path.startsWith(`${prefix}/`);\n}\n\nexport function getRequiredRolesForRoute(\n  path: string,\n  rules: ReadonlyArray<PeekRouteRule> = PEEK_ROUTE_RULES,\n): ReadonlyArray<PeekRole> {\n  const normalized = normalizeRoutePath(path);\n  let best: PeekRouteRule | null = null;\n  for (const rule of rules) {\n    if (!prefixMatches(rule.prefix, normalized)) continue;\n    if (!best || rule.prefix.length > best.prefix.length) {\n      best = rule;\n    }\n  }\n  return best ? best.roles : PEEK_DEFAULT_ROUTE_ROLES;\n}\n\nexport function isRouteAllowedForRole(\n  path: string,\n  role: PeekRole | null | undefined,\n  rules: ReadonlyArray<PeekRouteRule> = PEEK_ROUTE_RULES,\n): boolean {\n  if (!role) return false;\n  return getRequiredRolesForRoute(path, rules).includes(role);\n}\n\nexport function getRequiredRolesForAction(\n  actionId: string,\n  rules: ReadonlyArray<PeekActionRule> = PEEK_ACTION_RULES,\n): ReadonlyArray<PeekRole> | null {\n  const rule = rules.find((entry) => entry.actionId === actionId);\n  return rule ? rule.roles : null;\n}\n\nexport function isActionAllowedForRole(\n  actionId: string,\n  role: PeekRole | null | undefined,\n  rules: ReadonlyArray<PeekActionRule> = PEEK_ACTION_RULES,\n): boolean {\n  if (!role) return false;\n  const required = getRequiredRolesForAction(actionId, rules);\n  if (!required) return false;\n  return required.includes(role);\n}\n","numLines":80,"startLine":140,"totalLines":219}}}
