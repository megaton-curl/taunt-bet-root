{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RbJb5Dsbwzq7cmUtagsTTM","type":"tool_result","content":"1\t// Approved mutation registry (FR-14).\n2\t//\n3\t// The runner consumes a frozen registry keyed by stable action id. Each\n4\t// definition declares the FR-2 access-policy action id, the audit\n5\t// `resourceType` to record on `peek.change.applied`, a zod input schema, and\n6\t// an `execute` callback that runs inside a transaction (`sql.begin`) and\n7\t// returns the audit-friendly resource id + before/after change list.\n8\t//\n9\t// Adding a new approved mutation is a four-line change: import the\n10\t// definition, add it to the `entries` list, register the matching action id\n11\t// in `peek/src/server/access-policy.ts` (`PEEK_ACTION_RULES`) so the role\n12\t// check has a rule to find, and ship the matching frontend wiring iteration.\n13\t//\n14\t// Approved mutations land one at a time. The first registered mutation is\n15\t// `kol_rate.update` (referral_kol_rates create/update); fraud flag status,\n16\t// dogpile cancel, and reward config edit ship in subsequent FR-14 iterations.\n17\t\n18\timport type { Sql } from \"postgres\";\n19\timport type { ZodTypeAny } from \"zod\";\n20\timport type { PeekAuditChange } from \"../../lib/types/peek\";\n21\timport { kolRateUpdateMutation } from \"./kol-rate\";\n22\t\n23\texport type PeekMutationActionId = string;\n24\t\n25\texport type PeekMutationActorContext = {\n26\t  email: string;\n27\t  route: string | null;\n28\t  requestId?: string | null;\n29\t};\n30\t\n31\texport type PeekMutationExecuteContext<TInput> = {\n32\t  input: TInput;\n33\t  sql: Sql;\n34\t  actor: PeekMutationActorContext;\n35\t};\n36\t\n37\texport type PeekMutationExecuteResult = {\n38\t  // Audit identifier for the row the mutation touched. `null` when the\n39\t  // mutation creates a new row whose id is not separately surfaced.\n40\t  resourceId: string | null;\n41\t  // Before/after diff persisted to the `peek.change.applied` audit payload.\n42\t  // `null` when the mutation does not produce a field-level diff (e.g.\n43\t  // a pure create).\n44\t  changes: ReadonlyArray<PeekAuditChange> | null;\n45\t};\n46\t\n47\texport type PeekMutationDefinition<TInput = unknown> = {\n48\t  actionId: PeekMutationActionId;\n49\t  resourceType: string;\n50\t  schema: ZodTypeAny;\n51\t  execute: (\n52\t    ctx: PeekMutationExecuteContext<TInput>,\n53\t  ) => Promise<PeekMutationExecuteResult>;\n54\t};\n55\t\n56\texport type PeekMutationRegistry = Readonly<\n57\t  Record<PeekMutationActionId, PeekMutationDefinition>\n58\t>;\n59\t\n60\tconst entries: ReadonlyArray<PeekMutationDefinition> = [\n61\t  kolRateUpdateMutation as PeekMutationDefinition,\n62\t];\n63\t\n64\texport const PEEK_MUTATIONS: PeekMutationRegistry = Object.freeze(\n65\t  entries.reduce<Record<string, PeekMutationDefinition>>((acc, def) => {\n66\t    acc[def.actionId] = def;\n67\t    return acc;\n68\t  }, {}),\n69\t);\n70\t\n71\texport function getPeekMutation(\n72\t  actionId: PeekMutationActionId,\n73\t  registry: PeekMutationRegistry = PEEK_MUTATIONS,\n74\t): PeekMutationDefinition | null {\n75\t  return registry[actionId] ?? null;\n76\t}\n77\t"}]},"parent_tool_use_id":null,"session_id":"4de5a64f-41df-4f36-abe8-b663a1d849a0","uuid":"a5754921-1e76-454a-9c42-d7bf69a5f987","timestamp":"2026-04-26T15:26:13.584Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/mutations/registry.ts","content":"// Approved mutation registry (FR-14).\n//\n// The runner consumes a frozen registry keyed by stable action id. Each\n// definition declares the FR-2 access-policy action id, the audit\n// `resourceType` to record on `peek.change.applied`, a zod input schema, and\n// an `execute` callback that runs inside a transaction (`sql.begin`) and\n// returns the audit-friendly resource id + before/after change list.\n//\n// Adding a new approved mutation is a four-line change: import the\n// definition, add it to the `entries` list, register the matching action id\n// in `peek/src/server/access-policy.ts` (`PEEK_ACTION_RULES`) so the role\n// check has a rule to find, and ship the matching frontend wiring iteration.\n//\n// Approved mutations land one at a time. The first registered mutation is\n// `kol_rate.update` (referral_kol_rates create/update); fraud flag status,\n// dogpile cancel, and reward config edit ship in subsequent FR-14 iterations.\n\nimport type { Sql } from \"postgres\";\nimport type { ZodTypeAny } from \"zod\";\nimport type { PeekAuditChange } from \"../../lib/types/peek\";\nimport { kolRateUpdateMutation } from \"./kol-rate\";\n\nexport type PeekMutationActionId = string;\n\nexport type PeekMutationActorContext = {\n  email: string;\n  route: string | null;\n  requestId?: string | null;\n};\n\nexport type PeekMutationExecuteContext<TInput> = {\n  input: TInput;\n  sql: Sql;\n  actor: PeekMutationActorContext;\n};\n\nexport type PeekMutationExecuteResult = {\n  // Audit identifier for the row the mutation touched. `null` when the\n  // mutation creates a new row whose id is not separately surfaced.\n  resourceId: string | null;\n  // Before/after diff persisted to the `peek.change.applied` audit payload.\n  // `null` when the mutation does not produce a field-level diff (e.g.\n  // a pure create).\n  changes: ReadonlyArray<PeekAuditChange> | null;\n};\n\nexport type PeekMutationDefinition<TInput = unknown> = {\n  actionId: PeekMutationActionId;\n  resourceType: string;\n  schema: ZodTypeAny;\n  execute: (\n    ctx: PeekMutationExecuteContext<TInput>,\n  ) => Promise<PeekMutationExecuteResult>;\n};\n\nexport type PeekMutationRegistry = Readonly<\n  Record<PeekMutationActionId, PeekMutationDefinition>\n>;\n\nconst entries: ReadonlyArray<PeekMutationDefinition> = [\n  kolRateUpdateMutation as PeekMutationDefinition,\n];\n\nexport const PEEK_MUTATIONS: PeekMutationRegistry = Object.freeze(\n  entries.reduce<Record<string, PeekMutationDefinition>>((acc, def) => {\n    acc[def.actionId] = def;\n    return acc;\n  }, {}),\n);\n\nexport function getPeekMutation(\n  actionId: PeekMutationActionId,\n  registry: PeekMutationRegistry = PEEK_MUTATIONS,\n): PeekMutationDefinition | null {\n  return registry[actionId] ?? null;\n}\n","numLines":77,"startLine":1,"totalLines":77}}}
