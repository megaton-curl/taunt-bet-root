{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01UEd5zhfft8oRiygCmxCaBv","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01YWFfGMMuSdiVPHREzYh7L2","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/peek/src/server/mutations/__tests__/kol-rate.test.ts","old_string":"const REGISTRY: PeekMutationRegistry = Object.freeze({\n  \"kol_rate.update\": kolRateUpdateMutation,\n});","new_string":"const REGISTRY: PeekMutationRegistry = Object.freeze({\n  \"kol_rate.update\": kolRateUpdateMutation as unknown as PeekMutationRegistry[string],\n});"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":729,"cache_read_input_tokens":110138,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":729},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"4de5a64f-41df-4f36-abe8-b663a1d849a0","uuid":"c510dd35-55fa-4503-b71b-862a568ec968"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YWFfGMMuSdiVPHREzYh7L2","type":"tool_result","content":"The file /workspaces/rng-utopia/peek/src/server/mutations/__tests__/kol-rate.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"4de5a64f-41df-4f36-abe8-b663a1d849a0","uuid":"273bf9da-b2f1-426f-bae3-fc786d50cf81","timestamp":"2026-04-26T15:28:23.184Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/peek/src/server/mutations/__tests__/kol-rate.test.ts","oldString":"const REGISTRY: PeekMutationRegistry = Object.freeze({\n  \"kol_rate.update\": kolRateUpdateMutation,\n});","newString":"const REGISTRY: PeekMutationRegistry = Object.freeze({\n  \"kol_rate.update\": kolRateUpdateMutation as unknown as PeekMutationRegistry[string],\n});","originalFile":"import { describe, expect, it, vi } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport type { PeekActionRule } from \"../../access-policy\";\nimport type { PeekAuditWriteResult } from \"../../audit/writer\";\nimport type {\n  PeekAuditChange,\n  PeekAuditPayload,\n} from \"../../../lib/types/peek\";\nimport {\n  KOL_RATE_BPS_MAX,\n  KOL_RATE_BPS_MIN,\n  kolRateUpdateInputSchema,\n  kolRateUpdateMutation,\n} from \"../kol-rate\";\nimport {\n  runPeekMutation,\n  type PeekMutationAuditWriter,\n  type PeekMutationRunResult,\n} from \"../runner\";\nimport {\n  type PeekMutationActorContext,\n  type PeekMutationRegistry,\n} from \"../registry\";\n\n// ---------------------------------------------------------------------------\n// Test scaffolding\n// ---------------------------------------------------------------------------\n\ntype AuditCall = {\n  eventType: string;\n  payload: PeekAuditPayload;\n  sql: Sql | undefined;\n};\n\nfunction createAuditWriter(): {\n  writer: PeekMutationAuditWriter;\n  calls: AuditCall[];\n} {\n  const calls: AuditCall[] = [];\n  const writer: PeekMutationAuditWriter = vi.fn(async (input, options) => {\n    calls.push({\n      eventType: input.eventType,\n      payload: input.payload,\n      sql: options?.sql,\n    });\n    const result: PeekAuditWriteResult = { ok: true };\n    return result;\n  });\n  return { writer, calls };\n}\n\n// `Sql` mock that emulates `postgres`'s tagged-template + `sql.begin` API just\n// enough for the kol-rate mutation. The mutation only issues:\n//   1. a `select ... for update` to read the existing row, and\n//   2. either `update referral_kol_rates ...` or\n//      `insert into referral_kol_rates ...`\n// so tests can identify each call by inspecting the leading SQL fragment.\n\ntype SqlCall = {\n  fragments: ReadonlyArray<string>;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ExistingRow = {\n  userId: string;\n  wallet: string;\n  rateBps: number;\n};\n\nfunction createSqlMock(options: {\n  existingRow?: ExistingRow | null;\n  failOnInsert?: Error;\n} = {}): {\n  sql: Sql;\n  txCalls: SqlCall[];\n  beginCalls: number;\n  rolledBack: boolean;\n} {\n  const txCalls: SqlCall[] = [];\n  let beginCalls = 0;\n  let rolledBack = false;\n\n  const txSql = ((\n    fragments: TemplateStringsArray,\n    ...values: ReadonlyArray<unknown>\n  ) => {\n    const frags = Array.from(fragments);\n    txCalls.push({ fragments: frags, values });\n    const head = (frags[0] ?? \"\").trim().toLowerCase();\n    if (head.startsWith(\"select\")) {\n      // SELECT ... FOR UPDATE → return [existingRow] or [].\n      return Promise.resolve(\n        options.existingRow ? [options.existingRow] : [],\n      );\n    }\n    if (head.startsWith(\"insert\") && options.failOnInsert) {\n      return Promise.reject(options.failOnInsert);\n    }\n    // UPDATE / INSERT → resolve to an empty array (postgres pattern).\n    return Promise.resolve([]);\n  }) as unknown as Sql;\n\n  const sql = {\n    async begin<T>(callback: (tx: Sql) => Promise<T>): Promise<T> {\n      beginCalls += 1;\n      try {\n        return await callback(txSql);\n      } catch (err) {\n        rolledBack = true;\n        throw err;\n      }\n    },\n  } as unknown as Sql;\n\n  return {\n    sql,\n    txCalls,\n    get beginCalls() {\n      return beginCalls;\n    },\n    get rolledBack() {\n      return rolledBack;\n    },\n  } as ReturnType<typeof createSqlMock>;\n}\n\nconst ACTOR: PeekMutationActorContext = Object.freeze({\n  email: \"alice@example.com\",\n  route: \"/growth/kol\",\n  requestId: \"req-kol-1\",\n});\n\nconst ACTION_RULES: ReadonlyArray<PeekActionRule> = [\n  { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n];\n\nconst REGISTRY: PeekMutationRegistry = Object.freeze({\n  \"kol_rate.update\": kolRateUpdateMutation,\n});\n\nfunction findCall(\n  txCalls: ReadonlyArray<SqlCall>,\n  prefix: string,\n): SqlCall | undefined {\n  return txCalls.find((call) =>\n    (call.fragments[0] ?? \"\").trim().toLowerCase().startsWith(prefix),\n  );\n}\n\n// ---------------------------------------------------------------------------\n// Schema-level tests (FR-14 \"rate validation\")\n// ---------------------------------------------------------------------------\n\ndescribe(\"kolRateUpdateInputSchema\", () => {\n  it(\"accepts a valid input shape\", () => {\n    const parsed = kolRateUpdateInputSchema.safeParse({\n      userId: \"user-1\",\n      wallet: \"WaLLeT11111111111111111111111111111111111111\",\n      rateBps: 1500,\n    });\n    expect(parsed.success).toBe(true);\n  });\n\n  it(\"rejects a negative rateBps\", () => {\n    const parsed = kolRateUpdateInputSchema.safeParse({\n      userId: \"user-1\",\n      wallet: \"wallet\",\n      rateBps: -1,\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects rateBps above KOL_RATE_BPS_MAX (10000)\", () => {\n    const parsed = kolRateUpdateInputSchema.safeParse({\n      userId: \"user-1\",\n      wallet: \"wallet\",\n      rateBps: KOL_RATE_BPS_MAX + 1,\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects a non-integer rateBps\", () => {\n    const parsed = kolRateUpdateInputSchema.safeParse({\n      userId: \"user-1\",\n      wallet: \"wallet\",\n      rateBps: 100.5,\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects empty userId / wallet (after trim)\", () => {\n    const a = kolRateUpdateInputSchema.safeParse({\n      userId: \"  \",\n      wallet: \"wallet\",\n      rateBps: 100,\n    });\n    const b = kolRateUpdateInputSchema.safeParse({\n      userId: \"user-1\",\n      wallet: \"  \",\n      rateBps: 100,\n    });\n    expect(a.success).toBe(false);\n    expect(b.success).toBe(false);\n  });\n\n  it(\"trims whitespace from userId and wallet\", () => {\n    const parsed = kolRateUpdateInputSchema.parse({\n      userId: \"  user-1 \",\n      wallet: \"  wallet-x  \",\n      rateBps: 250,\n    });\n    expect(parsed.userId).toBe(\"user-1\");\n    expect(parsed.wallet).toBe(\"wallet-x\");\n  });\n\n  it(\"accepts the boundary values 0 and 10000\", () => {\n    expect(\n      kolRateUpdateInputSchema.safeParse({\n        userId: \"user-1\",\n        wallet: \"wallet\",\n        rateBps: KOL_RATE_BPS_MIN,\n      }).success,\n    ).toBe(true);\n    expect(\n      kolRateUpdateInputSchema.safeParse({\n        userId: \"user-1\",\n        wallet: \"wallet\",\n        rateBps: KOL_RATE_BPS_MAX,\n      }).success,\n    ).toBe(true);\n  });\n\n  it(\"rejects unknown extra fields (strict)\", () => {\n    const parsed = kolRateUpdateInputSchema.safeParse({\n      userId: \"user-1\",\n      wallet: \"wallet\",\n      rateBps: 100,\n      smuggled: \"value\",\n    });\n    expect(parsed.success).toBe(false);\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Definition wiring\n// ---------------------------------------------------------------------------\n\ndescribe(\"kolRateUpdateMutation definition\", () => {\n  it(\"registers the FR-14 actionId and resourceType expected by the audit log\", () => {\n    expect(kolRateUpdateMutation.actionId).toBe(\"kol_rate.update\");\n    expect(kolRateUpdateMutation.resourceType).toBe(\"referral_kol_rates\");\n  });\n});\n\n// ---------------------------------------------------------------------------\n// End-to-end runner tests (FR-14 create / update / unauthorized / audit)\n// ---------------------------------------------------------------------------\n\ndescribe(\"kol_rate.update via runPeekMutation\", () => {\n  it(\"creates a row when no existing record matches userId and emits an applied audit with full new state\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({ existingRow: null });\n\n    const result: PeekMutationRunResult = await runPeekMutation({\n      actionId: \"kol_rate.update\",\n      rawInput: {\n        userId: \"user-1\",\n        wallet: \"WaLLeT-1\",\n        rateBps: 750,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(true);\n    if (!result.ok) return;\n    expect(result.actionId).toBe(\"kol_rate.update\");\n    expect(result.resourceId).toBe(\"user-1\");\n    expect(result.changes).toEqual([\n      { field: \"wallet\", before: null, after: \"WaLLeT-1\" },\n      { field: \"rate_bps\", before: null, after: 750 },\n    ] as ReadonlyArray<PeekAuditChange>);\n\n    // Transaction was opened and committed.\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(false);\n\n    // SELECT ... FOR UPDATE was issued, then INSERT (no UPDATE).\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    expect(findCall(sqlMock.txCalls, \"insert\")).toBeDefined();\n    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n\n    // INSERT carries userId + wallet + rateBps + actor email as set_by.\n    const insertCall = findCall(sqlMock.txCalls, \"insert\");\n    expect(insertCall?.values).toEqual([\n      \"user-1\",\n      \"WaLLeT-1\",\n      750,\n      ACTOR.email,\n    ]);\n\n    // Exactly one audit event: peek.change.applied on the in-tx Sql.\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n    expect(audit.calls[0]?.payload).toMatchObject({\n      actorEmail: ACTOR.email,\n      route: ACTOR.route,\n      actionId: \"kol_rate.update\",\n      resourceType: \"referral_kol_rates\",\n      resourceId: \"user-1\",\n      filterSummary: null,\n      resultCount: null,\n      requestId: ACTOR.requestId,\n      rejectionReason: null,\n    });\n    expect(audit.calls[0]?.payload.changes).toEqual([\n      { field: \"wallet\", before: null, after: \"WaLLeT-1\" },\n      { field: \"rate_bps\", before: null, after: 750 },\n    ]);\n  });\n\n  it(\"updates an existing row, diffs only the fields that actually changed, and skips set_by/updated_at in the audit diff\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: {\n        userId: \"user-1\",\n        wallet: \"WaLLeT-old\",\n        rateBps: 1000,\n      },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"kol_rate.update\",\n      rawInput: {\n        userId: \"user-1\",\n        // wallet unchanged → must not appear in diff.\n        wallet: \"WaLLeT-old\",\n        rateBps: 1500,\n      },\n      actorRole: \"business\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(true);\n    if (!result.ok) return;\n    expect(result.resourceId).toBe(\"user-1\");\n    expect(result.changes).toEqual([\n      { field: \"rate_bps\", before: 1000, after: 1500 },\n    ]);\n\n    // SELECT + UPDATE (no INSERT).\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    expect(findCall(sqlMock.txCalls, \"update\")).toBeDefined();\n    expect(findCall(sqlMock.txCalls, \"insert\")).toBeUndefined();\n\n    const updateCall = findCall(sqlMock.txCalls, \"update\");\n    // UPDATE binds wallet, rate_bps, set_by, then user_id.\n    expect(updateCall?.values).toEqual([\n      \"WaLLeT-old\",\n      1500,\n      ACTOR.email,\n      \"user-1\",\n    ]);\n\n    // Audit diff excludes set_by and updated_at — operator metadata, not config.\n    const changes = audit.calls[0]?.payload.changes ?? [];\n    const fields = changes.map((c) => c.field);\n    expect(fields).not.toContain(\"set_by\");\n    expect(fields).not.toContain(\"updated_at\");\n    expect(fields).toEqual([\"rate_bps\"]);\n  });\n\n  it(\"emits an applied audit with an empty diff when the update is a no-op (same wallet + same rate)\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: {\n        userId: \"user-1\",\n        wallet: \"WaLLeT-x\",\n        rateBps: 1500,\n      },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"kol_rate.update\",\n      rawInput: {\n        userId: \"user-1\",\n        wallet: \"WaLLeT-x\",\n        rateBps: 1500,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(true);\n    if (!result.ok) return;\n    expect(result.changes).toEqual([]);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n    expect(audit.calls[0]?.payload.changes).toEqual([]);\n  });\n\n  it(\"rejects an invalid rateBps via the schema with peek.change.rejected and never opens a transaction\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock();\n\n    const result = await runPeekMutation({\n      actionId: \"kol_rate.update\",\n      rawInput: {\n        userId: \"user-1\",\n        wallet: \"WaLLeT-1\",\n        rateBps: KOL_RATE_BPS_MAX + 1,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"invalid_input\");\n      expect(result.fieldErrors?.rateBps?.length).toBeGreaterThan(0);\n    }\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(sqlMock.txCalls).toHaveLength(0);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n    expect(audit.calls[0]?.payload.actionId).toBe(\"kol_rate.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"referral_kol_rates\");\n    expect(audit.calls[0]?.payload.changes).toBeNull();\n  });\n\n  it(\"rejects an unauthorized actor role with peek.change.rejected and never queries the DB\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock();\n\n    // Tighten action rule so business is denied.\n    const adminOnly: ReadonlyArray<PeekActionRule> = [\n      { actionId: \"kol_rate.update\", roles: [\"admin\"] },\n    ];\n\n    const result = await runPeekMutation({\n      actionId: \"kol_rate.update\",\n      rawInput: {\n        userId: \"user-1\",\n        wallet: \"WaLLeT-1\",\n        rateBps: 1500,\n      },\n      actorRole: \"business\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: adminOnly,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(sqlMock.txCalls).toHaveLength(0);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n    expect(audit.calls[0]?.payload.actionId).toBe(\"kol_rate.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"referral_kol_rates\");\n  });\n\n  it(\"rolls back and emits peek.change.rejected when the INSERT collides with the wallet UNIQUE constraint\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: null,\n      failOnInsert: new Error(\n        'duplicate key value violates unique constraint \"referral_kol_rates_wallet_key\"',\n      ),\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"kol_rate.update\",\n      rawInput: {\n        userId: \"user-1\",\n        wallet: \"WaLLeT-collides\",\n        rateBps: 1500,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"execution_failed\");\n      expect(result.message).toContain(\"duplicate key\");\n    }\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(true);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n      /^execution_failed: /,\n    );\n    expect(audit.calls[0]?.payload.actionId).toBe(\"kol_rate.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"referral_kol_rates\");\n  });\n});\n","structuredPatch":[{"oldStart":135,"oldLines":7,"newStart":135,"newLines":7,"lines":[" ];"," "," const REGISTRY: PeekMutationRegistry = Object.freeze({","-  \"kol_rate.update\": kolRateUpdateMutation,","+  \"kol_rate.update\": kolRateUpdateMutation as unknown as PeekMutationRegistry[string],"," });"," "," function findCall("]}],"userModified":false,"replaceAll":false}}
