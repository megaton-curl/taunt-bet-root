{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017ThVSwci4QcUB6hfCy6K2T","type":"tool_result","content":"370\t// FR-11 so the writer (`peek/src/server/audit/**`, next iteration) and the audit\n371\t// view (`/audit`, later iteration) agree on a serialization contract. Secrets\n372\t// (JWTs, access tokens, DB URLs, private keys, raw secrets) must be replaced by\n373\t// `PEEK_AUDIT_REDACTED` before persisting; the audit-view component renders the\n374\t// token verbatim so reviewers can see that a field was redacted (not silently\n375\t// absent).\n376\t\n377\texport type PeekAuditEventType =\n378\t  | \"peek.search\"\n379\t  | \"peek.user.view_sensitive\"\n380\t  | \"peek.export\"\n381\t  | \"peek.access.denied\"\n382\t  | \"peek.change.applied\"\n383\t  | \"peek.change.rejected\";\n384\t\n385\texport const PEEK_AUDIT_EVENT_TYPES: ReadonlyArray<PeekAuditEventType> = [\n386\t  \"peek.search\",\n387\t  \"peek.user.view_sensitive\",\n388\t  \"peek.export\",\n389\t  \"peek.access.denied\",\n390\t  \"peek.change.applied\",\n391\t  \"peek.change.rejected\",\n392\t];\n393\t\n394\texport function isPeekAuditEventType(\n395\t  value: unknown,\n396\t): value is PeekAuditEventType {\n397\t  return (\n398\t    typeof value === \"string\" &&\n399\t    (PEEK_AUDIT_EVENT_TYPES as ReadonlyArray<string>).includes(value)\n400\t  );\n401\t}\n402\t\n403\texport const PEEK_AUDIT_REDACTED = \"[REDACTED]\";\n404\t\n405\texport type PeekAuditScalar = string | number | boolean | null;\n406\t\n407\texport type PeekAuditChange = {\n408\t  field: string;\n409\t  before: PeekAuditScalar;\n410\t  after: PeekAuditScalar;\n411\t};\n412\t\n413\texport type PeekAuditPayload = {\n414\t  actorEmail: string;\n415\t  route: string | null;\n416\t  actionId: string | null;\n417\t  resourceType: string | null;\n418\t  resourceId: string | null;\n419\t  filterSummary: string | null;\n420\t  resultCount: number | null;\n421\t  requestId: string | null;\n422\t  rejectionReason: string | null;\n423\t  changes: ReadonlyArray<PeekAuditChange> | null;\n424\t};\n425\t\n426\texport type PeekAuditEvent = {\n427\t  id: string;\n428\t  eventType: PeekAuditEventType;\n429\t  createdAt: string;\n430\t  payload: PeekAuditPayload;\n431\t};\n432\t\n433\t// --- Audit log query contracts (FR-11 audit view) ----------------------------\n434\t//\n435\t// `/audit` reads `operator_events` filtered to the `peek.*` event types. The\n436\t// filter shape is the FR-11 spec line \"filters by event type, actor email,\n437\t// resource id, route, and date\" plus the bounded-list discipline shared with\n438\t// the queue page (`PeekEventQueueFilters`). All values arrive as URL params and\n439\t// are normalised server-side: unknown event types fall back to \"any peek.*\",\n440\t// trimmed strings normalise to `null`, and date filters are bound as ISO\n441\t// strings cast to `timestamptz` server-side.\n442\t\n443\texport type PeekAuditFilters = {\n444\t  eventType: PeekAuditEventType | null;\n445\t  actorEmail: string | null;\n446\t  resourceId: string | null;\n447\t  route: string | null;\n448\t  createdFrom: string | null;\n449\t  createdTo: string | null;\n450\t};\n451\t\n452\texport type PeekAuditEventTypeCount = {\n453\t  eventType: PeekAuditEventType;\n454\t  count: number;\n455\t};\n456\t\n457\texport type PeekAuditOverviewMetricId =\n458\t  | \"audit.total_24h\"\n459\t  | \"audit.exports_24h\"\n460\t  | \"audit.access_denied_24h\"\n461\t  | \"audit.changes_applied_24h\"\n462\t  | \"audit.changes_rejected_24h\";\n463\t\n464\texport type PeekAuditOverview = {\n465\t  generatedAt: string;\n466\t  metrics: ReadonlyArray<PeekMetric>;\n467\t  eventTypeCounts: ReadonlyArray<PeekAuditEventTypeCount>;\n468\t};\n469\t\n470\t// --- Export contracts (FR-12) ------------------------------------------------\n471\t//\n472\t// Exports are server-rendered CSVs gated by the same page-level access as the\n473\t// source page, bounded by a server-side row cap, named with a deterministic\n474\t// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n475\t// bytes return. Export rows reuse the table view-model column ids so the export\n476\t// shape stays in lockstep with the rendered table; values are pre-formatted\n477\t// strings so CSV serialization stays straightforward and locale-stable.\n478\t\n479\texport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n480\t\n481\texport type PeekExportEntity =\n482\t  | \"users\"\n483\t  | \"referrers\"\n484\t  | \"kol\"\n485\t  | \"claims\"\n486\t  | \"rounds\"\n487\t  | \"transactions\"\n488\t  | \"queue\"\n489\t  | \"audit\";"}]},"parent_tool_use_id":null,"session_id":"4de5a64f-41df-4f36-abe8-b663a1d849a0","uuid":"90d76410-fae6-4053-b1eb-658a523f2b28","timestamp":"2026-04-26T15:26:32.532Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","content":"// FR-11 so the writer (`peek/src/server/audit/**`, next iteration) and the audit\n// view (`/audit`, later iteration) agree on a serialization contract. Secrets\n// (JWTs, access tokens, DB URLs, private keys, raw secrets) must be replaced by\n// `PEEK_AUDIT_REDACTED` before persisting; the audit-view component renders the\n// token verbatim so reviewers can see that a field was redacted (not silently\n// absent).\n\nexport type PeekAuditEventType =\n  | \"peek.search\"\n  | \"peek.user.view_sensitive\"\n  | \"peek.export\"\n  | \"peek.access.denied\"\n  | \"peek.change.applied\"\n  | \"peek.change.rejected\";\n\nexport const PEEK_AUDIT_EVENT_TYPES: ReadonlyArray<PeekAuditEventType> = [\n  \"peek.search\",\n  \"peek.user.view_sensitive\",\n  \"peek.export\",\n  \"peek.access.denied\",\n  \"peek.change.applied\",\n  \"peek.change.rejected\",\n];\n\nexport function isPeekAuditEventType(\n  value: unknown,\n): value is PeekAuditEventType {\n  return (\n    typeof value === \"string\" &&\n    (PEEK_AUDIT_EVENT_TYPES as ReadonlyArray<string>).includes(value)\n  );\n}\n\nexport const PEEK_AUDIT_REDACTED = \"[REDACTED]\";\n\nexport type PeekAuditScalar = string | number | boolean | null;\n\nexport type PeekAuditChange = {\n  field: string;\n  before: PeekAuditScalar;\n  after: PeekAuditScalar;\n};\n\nexport type PeekAuditPayload = {\n  actorEmail: string;\n  route: string | null;\n  actionId: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  filterSummary: string | null;\n  resultCount: number | null;\n  requestId: string | null;\n  rejectionReason: string | null;\n  changes: ReadonlyArray<PeekAuditChange> | null;\n};\n\nexport type PeekAuditEvent = {\n  id: string;\n  eventType: PeekAuditEventType;\n  createdAt: string;\n  payload: PeekAuditPayload;\n};\n\n// --- Audit log query contracts (FR-11 audit view) ----------------------------\n//\n// `/audit` reads `operator_events` filtered to the `peek.*` event types. The\n// filter shape is the FR-11 spec line \"filters by event type, actor email,\n// resource id, route, and date\" plus the bounded-list discipline shared with\n// the queue page (`PeekEventQueueFilters`). All values arrive as URL params and\n// are normalised server-side: unknown event types fall back to \"any peek.*\",\n// trimmed strings normalise to `null`, and date filters are bound as ISO\n// strings cast to `timestamptz` server-side.\n\nexport type PeekAuditFilters = {\n  eventType: PeekAuditEventType | null;\n  actorEmail: string | null;\n  resourceId: string | null;\n  route: string | null;\n  createdFrom: string | null;\n  createdTo: string | null;\n};\n\nexport type PeekAuditEventTypeCount = {\n  eventType: PeekAuditEventType;\n  count: number;\n};\n\nexport type PeekAuditOverviewMetricId =\n  | \"audit.total_24h\"\n  | \"audit.exports_24h\"\n  | \"audit.access_denied_24h\"\n  | \"audit.changes_applied_24h\"\n  | \"audit.changes_rejected_24h\";\n\nexport type PeekAuditOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n  eventTypeCounts: ReadonlyArray<PeekAuditEventTypeCount>;\n};\n\n// --- Export contracts (FR-12) ------------------------------------------------\n//\n// Exports are server-rendered CSVs gated by the same page-level access as the\n// source page, bounded by a server-side row cap, named with a deterministic\n// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n// bytes return. Export rows reuse the table view-model column ids so the export\n// shape stays in lockstep with the rendered table; values are pre-formatted\n// strings so CSV serialization stays straightforward and locale-stable.\n\nexport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n\nexport type PeekExportEntity =\n  | \"users\"\n  | \"referrers\"\n  | \"kol\"\n  | \"claims\"\n  | \"rounds\"\n  | \"transactions\"\n  | \"queue\"\n  | \"audit\";","numLines":120,"startLine":370,"totalLines":1476}}}
