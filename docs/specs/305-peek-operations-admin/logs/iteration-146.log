{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018u9sNq66YWcLpBSRZYMVv2","type":"tool_result","content":"1\timport { describe, expect, it, vi } from \"vitest\";\n2\timport type { Sql } from \"postgres\";\n3\timport { z } from \"zod\";\n4\timport type { PeekActionRule } from \"../../access-policy\";\n5\timport type { PeekAuditWriteResult } from \"../../audit/writer\";\n6\timport {\n7\t  PEEK_AUDIT_REDACTED,\n8\t  type PeekAuditChange,\n9\t  type PeekAuditPayload,\n10\t} from \"../../../lib/types/peek\";\n11\timport {\n12\t  runPeekMutation,\n13\t  type PeekMutationAuditWriter,\n14\t  type PeekMutationRunResult,\n15\t} from \"../runner\";\n16\timport {\n17\t  type PeekMutationActorContext,\n18\t  type PeekMutationDefinition,\n19\t  type PeekMutationRegistry,\n20\t} from \"../registry\";\n21\t\n22\t// ---------------------------------------------------------------------------\n23\t// Mocks\n24\t// ---------------------------------------------------------------------------\n25\t\n26\ttype AuditCall = {\n27\t  eventType: string;\n28\t  payload: PeekAuditPayload;\n29\t  sql: Sql | undefined;\n30\t};\n31\t\n32\tfunction createAuditWriter(\n33\t  result: PeekAuditWriteResult | ((call: AuditCall) => PeekAuditWriteResult) = {\n34\t    ok: true,\n35\t  },\n36\t): { writer: PeekMutationAuditWriter; calls: AuditCall[] } {\n37\t  const calls: AuditCall[] = [];\n38\t  const writer: PeekMutationAuditWriter = vi.fn(async (input, options) => {\n39\t    const call: AuditCall = {\n40\t      eventType: input.eventType,\n41\t      payload: input.payload,\n42\t      sql: options?.sql,\n43\t    };\n44\t    calls.push(call);\n45\t    return typeof result === \"function\" ? result(call) : result;\n46\t  });\n47\t  return { writer, calls };\n48\t}\n49\t\n50\ttype SqlMock = {\n51\t  sql: Sql;\n52\t  txSql: Sql;\n53\t  beginCalls: number;\n54\t  rolledBack: boolean;\n55\t};\n56\t\n57\tfunction createSqlMock(): SqlMock {\n58\t  // The transactional Sql is a sentinel object so tests can verify that the\n59\t  // applied-audit insert was issued with the same `Sql` `sql.begin` handed to\n60\t  // the execute callback (i.e. the audit row commits with the mutation row).\n61\t  const txSql = { __sql: \"tx\" } as unknown as Sql;\n62\t  let beginCalls = 0;\n63\t  let rolledBack = false;\n64\t  const sql = {\n65\t    async begin<T>(callback: (tx: Sql) => Promise<T>): Promise<T> {\n66\t      beginCalls += 1;\n67\t      try {\n68\t        return await callback(txSql);\n69\t      } catch (err) {\n70\t        rolledBack = true;\n71\t        throw err;\n72\t      }\n73\t    },\n74\t  } as unknown as Sql;\n75\t  return {\n76\t    sql,\n77\t    txSql,\n78\t    get beginCalls() {\n79\t      return beginCalls;\n80\t    },\n81\t    get rolledBack() {\n82\t      return rolledBack;\n83\t    },\n84\t  } as SqlMock;\n85\t}\n86\t\n87\tconst ACTOR: PeekMutationActorContext = Object.freeze({\n88\t  email: \"alice@example.com\",\n89\t  route: \"/growth/kol\",\n90\t  requestId: \"req-1\",\n91\t});\n92\t\n93\tfunction makeMutation(\n94\t  overrides: Partial<PeekMutationDefinition> & {\n95\t    onExecute?: PeekMutationDefinition[\"execute\"];\n96\t  } = {},\n97\t): PeekMutationDefinition {\n98\t  const schema =\n99\t    overrides.schema ??\n100\t    z.object({\n101\t      rateBps: z.number().int().min(0).max(10000),\n102\t    });\n103\t  const actionId = overrides.actionId ?? \"kol_rate.update\";\n104\t  const resourceType = overrides.resourceType ?? \"referral_kol_rates\";\n105\t  const execute: PeekMutationDefinition[\"execute\"] =\n106\t    overrides.onExecute ??\n107\t    (async () => ({\n108\t      resourceId: \"kol-7\",\n109\t      changes: [\n110\t        { field: \"rate_bps\", before: 1000, after: 1500 },\n111\t      ] as ReadonlyArray<PeekAuditChange>,\n112\t    }));\n113\t  return { actionId, resourceType, schema, execute };\n114\t}\n115\t\n116\tfunction makeRegistry(\n117\t  ...defs: ReadonlyArray<PeekMutationDefinition>\n118\t): PeekMutationRegistry {\n119\t  const map: Record<string, PeekMutationDefinition> = {};\n120\t  for (const def of defs) map[def.actionId] = def;\n121\t  return Object.freeze(map);\n122\t}\n123\t\n124\t// ---------------------------------------------------------------------------\n125\t// Tests\n126\t// ---------------------------------------------------------------------------\n127\t\n128\tdescribe(\"runPeekMutation\", () => {\n129\t  describe(\"authorized success\", () => {\n130\t    it(\"runs execute inside a transaction and emits peek.change.applied\", async () => {\n131\t      const audit = createAuditWriter();\n132\t      const sqlMock = createSqlMock();\n133\t      const executeFn = vi.fn<PeekMutationDefinition[\"execute\"]>(async () => ({\n134\t        resourceId: \"kol-7\",\n135\t        changes: [\n136\t          { field: \"rate_bps\", before: 1000, after: 1500 },\n137\t        ] as ReadonlyArray<PeekAuditChange>,\n138\t      }));\n139\t      const definition = makeMutation({ onExecute: executeFn });\n140\t      const registry = makeRegistry(definition);\n141\t      const actionRules: ReadonlyArray<PeekActionRule> = [\n142\t        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n143\t      ];\n144\t\n145\t      const result: PeekMutationRunResult = await runPeekMutation({\n146\t        actionId: \"kol_rate.update\",\n147\t        rawInput: { rateBps: 1500 },\n148\t        actorRole: \"business\",\n149\t        actor: ACTOR,\n150\t        sql: sqlMock.sql,\n151\t        registry,\n152\t        actionRules,\n153\t        auditWriter: audit.writer,\n154\t      });\n155\t\n156\t      expect(result).toEqual({\n157\t        ok: true,\n158\t        actionId: \"kol_rate.update\",\n159\t        resourceId: \"kol-7\",\n160\t        changes: [{ field: \"rate_bps\", before: 1000, after: 1500 }],\n161\t      });\n162\t      expect(sqlMock.beginCalls).toBe(1);\n163\t      expect(sqlMock.rolledBack).toBe(false);\n164\t      expect(executeFn).toHaveBeenCalledTimes(1);\n165\t\n166\t      // Execute received the parsed input + transactional sql.\n167\t      const executeArg = executeFn.mock.calls[0]?.[0];\n168\t      expect(executeArg?.input).toEqual({ rateBps: 1500 });\n169\t      expect(executeArg?.sql).toBe(sqlMock.txSql);\n170\t      expect(executeArg?.actor).toBe(ACTOR);\n171\t\n172\t      // Exactly one audit emit: peek.change.applied on the transactional sql.\n173\t      expect(audit.calls).toHaveLength(1);\n174\t      expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n175\t      expect(audit.calls[0]?.sql).toBe(sqlMock.txSql);\n176\t    });\n177\t\n178\t    it(\"populates the applied payload with FR-14 fields and forwards the before/after diff\", async () => {\n179\t      const audit = createAuditWriter();\n180\t      const sqlMock = createSqlMock();\n181\t      const definition = makeMutation();\n182\t      const registry = makeRegistry(definition);\n183\t      const actionRules: ReadonlyArray<PeekActionRule> = [\n184\t        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n185\t      ];\n186\t\n187\t      await runPeekMutation({\n188\t        actionId: \"kol_rate.update\",\n189\t        rawInput: { rateBps: 1500 },\n190\t        actorRole: \"admin\",\n191\t        actor: ACTOR,\n192\t        sql: sqlMock.sql,\n193\t        registry,\n194\t        actionRules,\n195\t        auditWriter: audit.writer,\n196\t      });\n197\t\n198\t      const payload = audit.calls[0]?.payload;\n199\t      expect(payload).toEqual({\n200\t        actorEmail: \"alice@example.com\",\n201\t        route: \"/growth/kol\",\n202\t        actionId: \"kol_rate.update\",\n203\t        resourceType: \"referral_kol_rates\",\n204\t        resourceId: \"kol-7\",\n205\t        filterSummary: null,\n206\t        resultCount: null,\n207\t        requestId: \"req-1\",\n208\t        rejectionReason: null,\n209\t        changes: [{ field: \"rate_bps\", before: 1000, after: 1500 }],\n210\t      });\n211\t    });\n212\t\n213\t    it(\"supports mutations whose execute returns null resourceId / null changes (pure create)\", async () => {\n214\t      const audit = createAuditWriter();\n215\t      const sqlMock = createSqlMock();\n216\t      const definition = makeMutation({\n217\t        onExecute: async () => ({ resourceId: null, changes: null }),\n218\t      });\n219\t      const registry = makeRegistry(definition);\n220\t      const actionRules: ReadonlyArray<PeekActionRule> = [\n221\t        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n222\t      ];\n223\t\n224\t      const result = await runPeekMutation({\n225\t        actionId: \"kol_rate.update\",\n226\t        rawInput: { rateBps: 0 },\n227\t        actorRole: \"admin\",\n228\t        actor: ACTOR,\n229\t        sql: sqlMock.sql,\n230\t        registry,\n231\t        actionRules,\n232\t        auditWriter: audit.writer,\n233\t      });\n234\t\n235\t      expect(result).toEqual({\n236\t        ok: true,\n237\t        actionId: \"kol_rate.update\",\n238\t        resourceId: null,\n239\t        changes: null,\n240\t      });\n241\t      expect(audit.calls[0]?.payload.resourceId).toBeNull();\n242\t      expect(audit.calls[0]?.payload.changes).toBeNull();\n243\t    });\n244\t  });\n245\t\n246\t  describe(\"unauthorized denial\", () => {\n247\t    it(\"rejects when no action rule matches the actor role and emits peek.change.rejected\", async () => {\n248\t      const audit = createAuditWriter();\n249\t      const sqlMock = createSqlMock();\n250\t      const executeFn = vi.fn();\n251\t      const definition = makeMutation({ onExecute: executeFn });\n252\t      const registry = makeRegistry(definition);\n253\t      // Action exists but requires admin; actor has business.\n254\t      const actionRules: ReadonlyArray<PeekActionRule> = [\n255\t        { actionId: \"kol_rate.update\", roles: [\"admin\"] },\n256\t      ];\n257\t\n258\t      const result = await runPeekMutation({\n259\t        actionId: \"kol_rate.update\",\n260\t        rawInput: { rateBps: 1500 },\n261\t        actorRole: \"business\",\n262\t        actor: ACTOR,\n263\t        sql: sqlMock.sql,\n264\t        registry,\n265\t        actionRules,\n266\t        auditWriter: audit.writer,\n267\t      });\n268\t\n269\t      expect(result).toMatchObject({ ok: false, reason: \"unauthorized\" });\n270\t      expect(executeFn).not.toHaveBeenCalled();\n271\t      expect(sqlMock.beginCalls).toBe(0);\n272\t\n273\t      expect(audit.calls).toHaveLength(1);\n274\t      expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n275\t      expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n276\t      expect(audit.calls[0]?.payload.resourceType).toBe(\"referral_kol_rates\");\n277\t      expect(audit.calls[0]?.payload.changes).toBeNull();\n278\t      // Rejected audit row writes on the main connection, not a transactional sql.\n279\t      expect(audit.calls[0]?.sql).toBe(sqlMock.sql);\n280\t    });\n281\t\n282\t    it(\"rejects when actor has no resolved role at all\", async () => {\n283\t      const audit = createAuditWriter();\n284\t      const sqlMock = createSqlMock();\n285\t      const definition = makeMutation();\n286\t      const registry = makeRegistry(definition);\n287\t      const actionRules: ReadonlyArray<PeekActionRule> = [\n288\t        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n289\t      ];\n290\t\n291\t      const result = await runPeekMutation({\n292\t        actionId: \"kol_rate.update\",\n293\t        rawInput: { rateBps: 1500 },\n294\t        actorRole: null,\n295\t        actor: ACTOR,\n296\t        sql: sqlMock.sql,\n297\t        registry,\n298\t        actionRules,\n299\t        auditWriter: audit.writer,\n300\t      });\n301\t\n302\t      expect(result.ok).toBe(false);\n303\t      if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n304\t      expect(audit.calls).toHaveLength(1);\n305\t      expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n306\t    });\n307\t  });\n308\t\n309\t  describe(\"unknown action\", () => {\n310\t    it(\"emits peek.change.rejected with rejectionReason=unknown_action and does not open a transaction\", async () => {\n311\t      const audit = createAuditWriter();\n312\t      const sqlMock = createSqlMock();\n313\t      const registry: PeekMutationRegistry = Object.freeze({});\n314\t\n315\t      const result = await runPeekMutation({\n316\t        actionId: \"kol_rate.update\",\n317\t        rawInput: { rateBps: 1500 },\n318\t        actorRole: \"admin\",\n319\t        actor: ACTOR,\n320\t        sql: sqlMock.sql,\n321\t        registry,\n322\t        actionRules: [],\n323\t        auditWriter: audit.writer,\n324\t      });\n325\t\n326\t      expect(result).toMatchObject({ ok: false, reason: \"unknown_action\" });\n327\t      expect(sqlMock.beginCalls).toBe(0);\n328\t\n329\t      expect(audit.calls).toHaveLength(1);\n330\t      const audited = audit.calls[0]!;\n331\t      expect(audited.eventType).toBe(\"peek.change.rejected\");\n332\t      expect(audited.payload.rejectionReason).toBe(\"unknown_action\");\n333\t      // The runner did not have a definition, so resourceType is null (not leaked).\n334\t      expect(audited.payload.resourceType).toBeNull();\n335\t      expect(audited.payload.actionId).toBe(\"kol_rate.update\");\n336\t      expect(audited.payload.changes).toBeNull();\n337\t    });\n338\t  });\n339\t\n340\t  describe(\"validation failure\", () => {\n341\t    it(\"rejects invalid input, surfaces field errors, does not run execute, and emits peek.change.rejected\", async () => {\n342\t      const audit = createAuditWriter();\n343\t      const sqlMock = createSqlMock();\n344\t      const executeFn = vi.fn();\n345\t      const definition = makeMutation({ onExecute: executeFn });\n346\t      const registry = makeRegistry(definition);\n347\t      const actionRules: ReadonlyArray<PeekActionRule> = [\n348\t        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n349\t      ];\n350\t\n351\t      const result = await runPeekMutation({\n352\t        actionId: \"kol_rate.update\",\n353\t        rawInput: { rateBps: -1 },\n354\t        actorRole: \"admin\",\n355\t        actor: ACTOR,\n356\t        sql: sqlMock.sql,\n357\t        registry,\n358\t        actionRules,\n359\t        auditWriter: audit.writer,\n360\t      });\n361\t\n362\t      expect(result.ok).toBe(false);\n363\t      if (!result.ok) {\n364\t        expect(result.reason).toBe(\"invalid_input\");\n365\t        expect(result.message).toBe(\"Input failed validation.\");\n366\t        expect(result.fieldErrors).toBeDefined();\n367\t        expect(result.fieldErrors?.rateBps?.length).toBeGreaterThan(0);\n368\t      }\n369\t\n370\t      expect(executeFn).not.toHaveBeenCalled();\n371\t      expect(sqlMock.beginCalls).toBe(0);\n372\t      expect(audit.calls).toHaveLength(1);\n373\t      expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n374\t      expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n375\t    });\n376\t\n377\t    it(\"does not echo raw input or field-level errors into the audit payload\", async () => {\n378\t      // FR-14: rejected mutation attempts log actor email, action id, resource\n379\t      // type/id, rejection reason, and no submitted secrets. Field errors stay\n380\t      // in the response (so the UI can render them) but never reach the audit\n381\t      // record (so a malicious payload can't smuggle secrets through validation\n382\t      // errors).\n383\t      const audit = createAuditWriter();\n384\t      const sqlMock = createSqlMock();\n385\t      const definition = makeMutation({\n386\t        // Schema demanding a nonempty token field; fail by sending the empty\n387\t        // string with a JWT-shaped submission alongside it.\n388\t        schema: z.object({\n389\t          token: z.string().min(1),\n390\t        }),\n391\t      });\n392\t      const registry = makeRegistry(definition);\n393\t      const actionRules: ReadonlyArray<PeekActionRule> = [\n394\t        { actionId: \"kol_rate.update\", roles: [\"admin\"] },\n395\t      ];\n396\t\n397\t      const sensitive = {\n398\t        token: \"\",\n399\t        smuggled:\n400\t          \"eyJhbGciOiJSUzI1NiJ9.eyJzdWIiOiJzZWNyZXQifQ.signaturesignaturesignature\",\n401\t      };\n402\t\n403\t      await runPeekMutation({\n404\t        actionId: \"kol_rate.update\",\n405\t        rawInput: sensitive,\n406\t        actorRole: \"admin\",\n407\t        actor: ACTOR,\n408\t        sql: sqlMock.sql,\n409\t        registry,\n410\t        actionRules,\n411\t        auditWriter: audit.writer,\n412\t      });\n413\t\n414\t      const serialized = JSON.stringify(audit.calls[0]?.payload ?? {});\n415\t      expect(serialized).not.toContain(sensitive.smuggled);\n416\t      expect(audit.calls[0]?.payload.changes).toBeNull();\n417\t    });\n418\t  });\n419\t\n420\t  describe(\"transaction rollback (execution_failed)\", () => {\n421\t    it(\"rolls back when execute throws and emits peek.change.rejected on the main connection\", async () => {\n422\t      const audit = createAuditWriter();\n423\t      const sqlMock = createSqlMock();\n424\t      const definition = makeMutation({\n425\t        onExecute: async () => {\n426\t          throw new Error(\"DB constraint violated\");\n427\t        },\n428\t      });\n429\t      const registry = makeRegistry(definition);\n430\t      const actionRules: ReadonlyArray<PeekActionRule> = [\n431\t        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n432\t      ];\n433\t\n434\t      const result = await runPeekMutation({\n435\t        actionId: \"kol_rate.update\",\n436\t        rawInput: { rateBps: 1500 },\n437\t        actorRole: \"admin\",\n438\t        actor: ACTOR,\n439\t        sql: sqlMock.sql,\n440\t        registry,\n441\t        actionRules,\n442\t        auditWriter: audit.writer,\n443\t      });\n444\t\n445\t      expect(result.ok).toBe(false);\n446\t      if (!result.ok) {\n447\t        expect(result.reason).toBe(\"execution_failed\");\n448\t        expect(result.message).toContain(\"DB constraint violated\");\n449\t      }\n450\t\n451\t      // Transaction was opened and rolled back.\n452\t      expect(sqlMock.beginCalls).toBe(1);\n453\t      expect(sqlMock.rolledBack).toBe(true);\n454\t\n455\t      // No applied-audit row landed (since the tx rolled back).\n456\t      expect(audit.calls).toHaveLength(1);\n457\t      expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n458\t      expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n459\t        /^execution_failed: /,\n460\t      );\n461\t      // Rejected audit row writes on the main connection, not the rolled-back tx.\n462\t      expect(audit.calls[0]?.sql).toBe(sqlMock.sql);\n463\t    });\n464\t  });\n465\t\n466\t  describe(\"audit emit failure inside the transaction\", () => {\n467\t    it(\"rolls back the mutation, surfaces audit_emit_failed, and writes peek.change.rejected on the main connection\", async () => {\n468\t      const sqlMock = createSqlMock();\n469\t      const calls: AuditCall[] = [];\n470\t      // First (in-tx) write fails; second (post-rollback) rejection succeeds.\n471\t      const writer: PeekMutationAuditWriter = vi.fn(async (input, options) => {\n472\t        const call: AuditCall = {\n473\t          eventType: input.eventType,\n474\t          payload: input.payload,\n475\t          sql: options?.sql,\n476\t        };\n477\t        calls.push(call);\n478\t        const result: PeekAuditWriteResult =\n479\t          calls.length === 1\n480\t            ? { ok: false, reason: \"insert_failed\" }\n481\t            : { ok: true };\n482\t        return result;\n483\t      });\n484\t\n485\t      const executeFn = vi.fn(async () => ({\n486\t        resourceId: \"kol-7\",\n487\t        changes: [\n488\t          { field: \"rate_bps\", before: 1000, after: 1500 },\n489\t        ] as ReadonlyArray<PeekAuditChange>,\n490\t      }));\n491\t      const definition = makeMutation({ onExecute: executeFn });\n492\t      const registry = makeRegistry(definition);\n493\t      const actionRules: ReadonlyArray<PeekActionRule> = [\n494\t        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n495\t      ];\n496\t\n497\t      const result = await runPeekMutation({\n498\t        actionId: \"kol_rate.update\",\n499\t        rawInput: { rateBps: 1500 },\n500\t        actorRole: \"admin\",\n501\t        actor: ACTOR,\n502\t        sql: sqlMock.sql,\n503\t        registry,\n504\t        actionRules,\n505\t        auditWriter: writer,\n506\t      });\n507\t\n508\t      expect(result.ok).toBe(false);\n509\t      if (!result.ok) {\n510\t        expect(result.reason).toBe(\"audit_emit_failed\");\n511\t        expect(result.message).toContain(\"Audit emission failed\");\n512\t        expect(result.message).toContain(\"insert_failed\");\n513\t      }\n514\t\n515\t      expect(executeFn).toHaveBeenCalledTimes(1);\n516\t      expect(sqlMock.beginCalls).toBe(1);\n517\t      expect(sqlMock.rolledBack).toBe(true);\n518\t\n519\t      // Two audit writes: applied (in tx, failed) + rejected (on main connection).\n520\t      expect(calls).toHaveLength(2);\n521\t      expect(calls[0]?.eventType).toBe(\"peek.change.applied\");\n522\t      expect(calls[0]?.sql).toBe(sqlMock.txSql);\n523\t      expect(calls[1]?.eventType).toBe(\"peek.change.rejected\");\n524\t      expect(calls[1]?.sql).toBe(sqlMock.sql);\n525\t      expect(calls[1]?.payload.rejectionReason).toMatch(\n526\t        /^peek_audit_emit_failed:insert_failed/,\n527\t      );\n528\t    });\n529\t  });\n530\t\n531\t  describe(\"audit payload safety\", () => {\n532\t    it(\"never echoes secrets pulled from execute changes verbatim — relies on the audit writer's redactor downstream\", async () => {\n533\t      // The runner forwards changes verbatim; the audit writer redacts before\n534\t      // persisting. To prove that contract is intact, this test routes the\n535\t      // applied payload through the production writer's redaction by importing\n536\t      // its redactor and asserting that the runner-emitted payload, when sent\n537\t      // through it, has secrets stripped without losing the diff structure.\n538\t      const { redactPayload } = await import(\"../../audit/redact\");\n539\t      const audit = createAuditWriter();\n540\t      const sqlMock = createSqlMock();\n541\t      const definition = makeMutation({\n542\t        onExecute: async () => ({\n543\t          resourceId: \"kol-7\",\n544\t          changes: [\n545\t            { field: \"rate_bps\", before: 1000, after: 1500 },\n546\t            {\n547\t              field: \"set_by\",\n548\t              before: \"alice@example.com\",\n549\t              after:\n550\t                \"eyJhbGciOiJSUzI1NiJ9.eyJzdWIiOiJsZWFrIn0.signaturesignaturesignature\",\n551\t            },\n552\t          ] as ReadonlyArray<PeekAuditChange>,\n553\t        }),\n554\t      });\n555\t      const registry = makeRegistry(definition);\n556\t      const actionRules: ReadonlyArray<PeekActionRule> = [\n557\t        { actionId: \"kol_rate.update\", roles: [\"admin\"] },\n558\t      ];\n559\t\n560\t      await runPeekMutation({\n561\t        actionId: \"kol_rate.update\",\n562\t        rawInput: { rateBps: 1500 },\n563\t        actorRole: \"admin\",\n564\t        actor: ACTOR,\n565\t        sql: sqlMock.sql,\n566\t        registry,\n567\t        actionRules,\n568\t        auditWriter: audit.writer,\n569\t      });\n570\t\n571\t      const safe = redactPayload(audit.calls[0]!.payload);\n572\t      const safeChanges = safe.changes!;\n573\t      expect(safeChanges[0]).toEqual({\n574\t        field: \"rate_bps\",\n575\t        before: 1000,\n576\t        after: 1500,\n577\t      });\n578\t      expect(safeChanges[1]?.after).toBe(PEEK_AUDIT_REDACTED);\n579\t      expect(JSON.stringify(safe)).not.toContain(\"eyJhbGciOiJSUzI1NiJ9\");\n580\t    });\n581\t  });\n582\t});\n583\t"}]},"parent_tool_use_id":null,"session_id":"4de5a64f-41df-4f36-abe8-b663a1d849a0","uuid":"471a8814-eb5e-4c5e-92b8-d3571d3e0320","timestamp":"2026-04-26T15:26:11.131Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/mutations/__tests__/runner.test.ts","content":"import { describe, expect, it, vi } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport { z } from \"zod\";\nimport type { PeekActionRule } from \"../../access-policy\";\nimport type { PeekAuditWriteResult } from \"../../audit/writer\";\nimport {\n  PEEK_AUDIT_REDACTED,\n  type PeekAuditChange,\n  type PeekAuditPayload,\n} from \"../../../lib/types/peek\";\nimport {\n  runPeekMutation,\n  type PeekMutationAuditWriter,\n  type PeekMutationRunResult,\n} from \"../runner\";\nimport {\n  type PeekMutationActorContext,\n  type PeekMutationDefinition,\n  type PeekMutationRegistry,\n} from \"../registry\";\n\n// ---------------------------------------------------------------------------\n// Mocks\n// ---------------------------------------------------------------------------\n\ntype AuditCall = {\n  eventType: string;\n  payload: PeekAuditPayload;\n  sql: Sql | undefined;\n};\n\nfunction createAuditWriter(\n  result: PeekAuditWriteResult | ((call: AuditCall) => PeekAuditWriteResult) = {\n    ok: true,\n  },\n): { writer: PeekMutationAuditWriter; calls: AuditCall[] } {\n  const calls: AuditCall[] = [];\n  const writer: PeekMutationAuditWriter = vi.fn(async (input, options) => {\n    const call: AuditCall = {\n      eventType: input.eventType,\n      payload: input.payload,\n      sql: options?.sql,\n    };\n    calls.push(call);\n    return typeof result === \"function\" ? result(call) : result;\n  });\n  return { writer, calls };\n}\n\ntype SqlMock = {\n  sql: Sql;\n  txSql: Sql;\n  beginCalls: number;\n  rolledBack: boolean;\n};\n\nfunction createSqlMock(): SqlMock {\n  // The transactional Sql is a sentinel object so tests can verify that the\n  // applied-audit insert was issued with the same `Sql` `sql.begin` handed to\n  // the execute callback (i.e. the audit row commits with the mutation row).\n  const txSql = { __sql: \"tx\" } as unknown as Sql;\n  let beginCalls = 0;\n  let rolledBack = false;\n  const sql = {\n    async begin<T>(callback: (tx: Sql) => Promise<T>): Promise<T> {\n      beginCalls += 1;\n      try {\n        return await callback(txSql);\n      } catch (err) {\n        rolledBack = true;\n        throw err;\n      }\n    },\n  } as unknown as Sql;\n  return {\n    sql,\n    txSql,\n    get beginCalls() {\n      return beginCalls;\n    },\n    get rolledBack() {\n      return rolledBack;\n    },\n  } as SqlMock;\n}\n\nconst ACTOR: PeekMutationActorContext = Object.freeze({\n  email: \"alice@example.com\",\n  route: \"/growth/kol\",\n  requestId: \"req-1\",\n});\n\nfunction makeMutation(\n  overrides: Partial<PeekMutationDefinition> & {\n    onExecute?: PeekMutationDefinition[\"execute\"];\n  } = {},\n): PeekMutationDefinition {\n  const schema =\n    overrides.schema ??\n    z.object({\n      rateBps: z.number().int().min(0).max(10000),\n    });\n  const actionId = overrides.actionId ?? \"kol_rate.update\";\n  const resourceType = overrides.resourceType ?? \"referral_kol_rates\";\n  const execute: PeekMutationDefinition[\"execute\"] =\n    overrides.onExecute ??\n    (async () => ({\n      resourceId: \"kol-7\",\n      changes: [\n        { field: \"rate_bps\", before: 1000, after: 1500 },\n      ] as ReadonlyArray<PeekAuditChange>,\n    }));\n  return { actionId, resourceType, schema, execute };\n}\n\nfunction makeRegistry(\n  ...defs: ReadonlyArray<PeekMutationDefinition>\n): PeekMutationRegistry {\n  const map: Record<string, PeekMutationDefinition> = {};\n  for (const def of defs) map[def.actionId] = def;\n  return Object.freeze(map);\n}\n\n// ---------------------------------------------------------------------------\n// Tests\n// ---------------------------------------------------------------------------\n\ndescribe(\"runPeekMutation\", () => {\n  describe(\"authorized success\", () => {\n    it(\"runs execute inside a transaction and emits peek.change.applied\", async () => {\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const executeFn = vi.fn<PeekMutationDefinition[\"execute\"]>(async () => ({\n        resourceId: \"kol-7\",\n        changes: [\n          { field: \"rate_bps\", before: 1000, after: 1500 },\n        ] as ReadonlyArray<PeekAuditChange>,\n      }));\n      const definition = makeMutation({ onExecute: executeFn });\n      const registry = makeRegistry(definition);\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n      ];\n\n      const result: PeekMutationRunResult = await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: 1500 },\n        actorRole: \"business\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: audit.writer,\n      });\n\n      expect(result).toEqual({\n        ok: true,\n        actionId: \"kol_rate.update\",\n        resourceId: \"kol-7\",\n        changes: [{ field: \"rate_bps\", before: 1000, after: 1500 }],\n      });\n      expect(sqlMock.beginCalls).toBe(1);\n      expect(sqlMock.rolledBack).toBe(false);\n      expect(executeFn).toHaveBeenCalledTimes(1);\n\n      // Execute received the parsed input + transactional sql.\n      const executeArg = executeFn.mock.calls[0]?.[0];\n      expect(executeArg?.input).toEqual({ rateBps: 1500 });\n      expect(executeArg?.sql).toBe(sqlMock.txSql);\n      expect(executeArg?.actor).toBe(ACTOR);\n\n      // Exactly one audit emit: peek.change.applied on the transactional sql.\n      expect(audit.calls).toHaveLength(1);\n      expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n      expect(audit.calls[0]?.sql).toBe(sqlMock.txSql);\n    });\n\n    it(\"populates the applied payload with FR-14 fields and forwards the before/after diff\", async () => {\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const definition = makeMutation();\n      const registry = makeRegistry(definition);\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n      ];\n\n      await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: 1500 },\n        actorRole: \"admin\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: audit.writer,\n      });\n\n      const payload = audit.calls[0]?.payload;\n      expect(payload).toEqual({\n        actorEmail: \"alice@example.com\",\n        route: \"/growth/kol\",\n        actionId: \"kol_rate.update\",\n        resourceType: \"referral_kol_rates\",\n        resourceId: \"kol-7\",\n        filterSummary: null,\n        resultCount: null,\n        requestId: \"req-1\",\n        rejectionReason: null,\n        changes: [{ field: \"rate_bps\", before: 1000, after: 1500 }],\n      });\n    });\n\n    it(\"supports mutations whose execute returns null resourceId / null changes (pure create)\", async () => {\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const definition = makeMutation({\n        onExecute: async () => ({ resourceId: null, changes: null }),\n      });\n      const registry = makeRegistry(definition);\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n      ];\n\n      const result = await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: 0 },\n        actorRole: \"admin\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: audit.writer,\n      });\n\n      expect(result).toEqual({\n        ok: true,\n        actionId: \"kol_rate.update\",\n        resourceId: null,\n        changes: null,\n      });\n      expect(audit.calls[0]?.payload.resourceId).toBeNull();\n      expect(audit.calls[0]?.payload.changes).toBeNull();\n    });\n  });\n\n  describe(\"unauthorized denial\", () => {\n    it(\"rejects when no action rule matches the actor role and emits peek.change.rejected\", async () => {\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const executeFn = vi.fn();\n      const definition = makeMutation({ onExecute: executeFn });\n      const registry = makeRegistry(definition);\n      // Action exists but requires admin; actor has business.\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"admin\"] },\n      ];\n\n      const result = await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: 1500 },\n        actorRole: \"business\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: audit.writer,\n      });\n\n      expect(result).toMatchObject({ ok: false, reason: \"unauthorized\" });\n      expect(executeFn).not.toHaveBeenCalled();\n      expect(sqlMock.beginCalls).toBe(0);\n\n      expect(audit.calls).toHaveLength(1);\n      expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n      expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n      expect(audit.calls[0]?.payload.resourceType).toBe(\"referral_kol_rates\");\n      expect(audit.calls[0]?.payload.changes).toBeNull();\n      // Rejected audit row writes on the main connection, not a transactional sql.\n      expect(audit.calls[0]?.sql).toBe(sqlMock.sql);\n    });\n\n    it(\"rejects when actor has no resolved role at all\", async () => {\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const definition = makeMutation();\n      const registry = makeRegistry(definition);\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n      ];\n\n      const result = await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: 1500 },\n        actorRole: null,\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: audit.writer,\n      });\n\n      expect(result.ok).toBe(false);\n      if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n      expect(audit.calls).toHaveLength(1);\n      expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n    });\n  });\n\n  describe(\"unknown action\", () => {\n    it(\"emits peek.change.rejected with rejectionReason=unknown_action and does not open a transaction\", async () => {\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const registry: PeekMutationRegistry = Object.freeze({});\n\n      const result = await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: 1500 },\n        actorRole: \"admin\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules: [],\n        auditWriter: audit.writer,\n      });\n\n      expect(result).toMatchObject({ ok: false, reason: \"unknown_action\" });\n      expect(sqlMock.beginCalls).toBe(0);\n\n      expect(audit.calls).toHaveLength(1);\n      const audited = audit.calls[0]!;\n      expect(audited.eventType).toBe(\"peek.change.rejected\");\n      expect(audited.payload.rejectionReason).toBe(\"unknown_action\");\n      // The runner did not have a definition, so resourceType is null (not leaked).\n      expect(audited.payload.resourceType).toBeNull();\n      expect(audited.payload.actionId).toBe(\"kol_rate.update\");\n      expect(audited.payload.changes).toBeNull();\n    });\n  });\n\n  describe(\"validation failure\", () => {\n    it(\"rejects invalid input, surfaces field errors, does not run execute, and emits peek.change.rejected\", async () => {\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const executeFn = vi.fn();\n      const definition = makeMutation({ onExecute: executeFn });\n      const registry = makeRegistry(definition);\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n      ];\n\n      const result = await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: -1 },\n        actorRole: \"admin\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: audit.writer,\n      });\n\n      expect(result.ok).toBe(false);\n      if (!result.ok) {\n        expect(result.reason).toBe(\"invalid_input\");\n        expect(result.message).toBe(\"Input failed validation.\");\n        expect(result.fieldErrors).toBeDefined();\n        expect(result.fieldErrors?.rateBps?.length).toBeGreaterThan(0);\n      }\n\n      expect(executeFn).not.toHaveBeenCalled();\n      expect(sqlMock.beginCalls).toBe(0);\n      expect(audit.calls).toHaveLength(1);\n      expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n      expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n    });\n\n    it(\"does not echo raw input or field-level errors into the audit payload\", async () => {\n      // FR-14: rejected mutation attempts log actor email, action id, resource\n      // type/id, rejection reason, and no submitted secrets. Field errors stay\n      // in the response (so the UI can render them) but never reach the audit\n      // record (so a malicious payload can't smuggle secrets through validation\n      // errors).\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const definition = makeMutation({\n        // Schema demanding a nonempty token field; fail by sending the empty\n        // string with a JWT-shaped submission alongside it.\n        schema: z.object({\n          token: z.string().min(1),\n        }),\n      });\n      const registry = makeRegistry(definition);\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"admin\"] },\n      ];\n\n      const sensitive = {\n        token: \"\",\n        smuggled:\n          \"eyJhbGciOiJSUzI1NiJ9.eyJzdWIiOiJzZWNyZXQifQ.signaturesignaturesignature\",\n      };\n\n      await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: sensitive,\n        actorRole: \"admin\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: audit.writer,\n      });\n\n      const serialized = JSON.stringify(audit.calls[0]?.payload ?? {});\n      expect(serialized).not.toContain(sensitive.smuggled);\n      expect(audit.calls[0]?.payload.changes).toBeNull();\n    });\n  });\n\n  describe(\"transaction rollback (execution_failed)\", () => {\n    it(\"rolls back when execute throws and emits peek.change.rejected on the main connection\", async () => {\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const definition = makeMutation({\n        onExecute: async () => {\n          throw new Error(\"DB constraint violated\");\n        },\n      });\n      const registry = makeRegistry(definition);\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n      ];\n\n      const result = await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: 1500 },\n        actorRole: \"admin\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: audit.writer,\n      });\n\n      expect(result.ok).toBe(false);\n      if (!result.ok) {\n        expect(result.reason).toBe(\"execution_failed\");\n        expect(result.message).toContain(\"DB constraint violated\");\n      }\n\n      // Transaction was opened and rolled back.\n      expect(sqlMock.beginCalls).toBe(1);\n      expect(sqlMock.rolledBack).toBe(true);\n\n      // No applied-audit row landed (since the tx rolled back).\n      expect(audit.calls).toHaveLength(1);\n      expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n      expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n        /^execution_failed: /,\n      );\n      // Rejected audit row writes on the main connection, not the rolled-back tx.\n      expect(audit.calls[0]?.sql).toBe(sqlMock.sql);\n    });\n  });\n\n  describe(\"audit emit failure inside the transaction\", () => {\n    it(\"rolls back the mutation, surfaces audit_emit_failed, and writes peek.change.rejected on the main connection\", async () => {\n      const sqlMock = createSqlMock();\n      const calls: AuditCall[] = [];\n      // First (in-tx) write fails; second (post-rollback) rejection succeeds.\n      const writer: PeekMutationAuditWriter = vi.fn(async (input, options) => {\n        const call: AuditCall = {\n          eventType: input.eventType,\n          payload: input.payload,\n          sql: options?.sql,\n        };\n        calls.push(call);\n        const result: PeekAuditWriteResult =\n          calls.length === 1\n            ? { ok: false, reason: \"insert_failed\" }\n            : { ok: true };\n        return result;\n      });\n\n      const executeFn = vi.fn(async () => ({\n        resourceId: \"kol-7\",\n        changes: [\n          { field: \"rate_bps\", before: 1000, after: 1500 },\n        ] as ReadonlyArray<PeekAuditChange>,\n      }));\n      const definition = makeMutation({ onExecute: executeFn });\n      const registry = makeRegistry(definition);\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n      ];\n\n      const result = await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: 1500 },\n        actorRole: \"admin\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: writer,\n      });\n\n      expect(result.ok).toBe(false);\n      if (!result.ok) {\n        expect(result.reason).toBe(\"audit_emit_failed\");\n        expect(result.message).toContain(\"Audit emission failed\");\n        expect(result.message).toContain(\"insert_failed\");\n      }\n\n      expect(executeFn).toHaveBeenCalledTimes(1);\n      expect(sqlMock.beginCalls).toBe(1);\n      expect(sqlMock.rolledBack).toBe(true);\n\n      // Two audit writes: applied (in tx, failed) + rejected (on main connection).\n      expect(calls).toHaveLength(2);\n      expect(calls[0]?.eventType).toBe(\"peek.change.applied\");\n      expect(calls[0]?.sql).toBe(sqlMock.txSql);\n      expect(calls[1]?.eventType).toBe(\"peek.change.rejected\");\n      expect(calls[1]?.sql).toBe(sqlMock.sql);\n      expect(calls[1]?.payload.rejectionReason).toMatch(\n        /^peek_audit_emit_failed:insert_failed/,\n      );\n    });\n  });\n\n  describe(\"audit payload safety\", () => {\n    it(\"never echoes secrets pulled from execute changes verbatim — relies on the audit writer's redactor downstream\", async () => {\n      // The runner forwards changes verbatim; the audit writer redacts before\n      // persisting. To prove that contract is intact, this test routes the\n      // applied payload through the production writer's redaction by importing\n      // its redactor and asserting that the runner-emitted payload, when sent\n      // through it, has secrets stripped without losing the diff structure.\n      const { redactPayload } = await import(\"../../audit/redact\");\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const definition = makeMutation({\n        onExecute: async () => ({\n          resourceId: \"kol-7\",\n          changes: [\n            { field: \"rate_bps\", before: 1000, after: 1500 },\n            {\n              field: \"set_by\",\n              before: \"alice@example.com\",\n              after:\n                \"eyJhbGciOiJSUzI1NiJ9.eyJzdWIiOiJsZWFrIn0.signaturesignaturesignature\",\n            },\n          ] as ReadonlyArray<PeekAuditChange>,\n        }),\n      });\n      const registry = makeRegistry(definition);\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"admin\"] },\n      ];\n\n      await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: 1500 },\n        actorRole: \"admin\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: audit.writer,\n      });\n\n      const safe = redactPayload(audit.calls[0]!.payload);\n      const safeChanges = safe.changes!;\n      expect(safeChanges[0]).toEqual({\n        field: \"rate_bps\",\n        before: 1000,\n        after: 1500,\n      });\n      expect(safeChanges[1]?.after).toBe(PEEK_AUDIT_REDACTED);\n      expect(JSON.stringify(safe)).not.toContain(\"eyJhbGciOiJSUzI1NiJ9\");\n    });\n  });\n});\n","numLines":583,"startLine":1,"totalLines":583}}}
