{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016r3hjsHn447aPm8bLP9oa1","type":"tool_result","content":"1\t// Server-side mutation runner (FR-14).\n2\t//\n3\t// Orchestrates a single approved peek mutation end to end:\n4\t//   1. Look up the registered definition for the requested action id.\n5\t//      Unknown ids fail closed (`unknown_action`) with a `peek.change.rejected`\n6\t//      audit event so unrecognised mutation attempts are still reviewable.\n7\t//   2. Authorize the actor through `isActionAllowedForRole` against the\n8\t//      FR-2 `PEEK_ACTION_RULES`. Denials emit `peek.change.rejected`.\n9\t//   3. Validate the raw caller input against the mutation's zod schema.\n10\t//      Validation failures emit `peek.change.rejected` (per FR-14 \"denied or\n11\t//      validation-failed mutation writes peek.change.rejected\") with the\n12\t//      field-level errors surfaced to the caller — never echoed into audit.\n13\t//   4. Run the mutation inside `sql.begin(...)` so multi-statement work\n14\t//      commits or rolls back together. The `peek.change.applied` audit row\n15\t//      is written with the same transactional `Sql` so the persisted change\n16\t//      and its audit record either both land or neither does.\n17\t//   5. On any thrown error from `execute`, the transaction rolls back and\n18\t//      `peek.change.rejected` is emitted on the main connection so the\n19\t//      attempt still leaves a trail. Audit-emit failure inside the\n20\t//      transaction throws and rolls the mutation back, surfacing as\n21\t//      `audit_emit_failed` to the caller.\n22\t//\n23\t// The runner is dependency-injectable: callers can pass a mock `Sql`,\n24\t// a custom registry, custom action rules, and a custom audit emitter\n25\t// (no network/DB I/O is required to unit-test it).\n26\t\n27\timport type { Sql } from \"postgres\";\n28\timport {\n29\t  isActionAllowedForRole,\n30\t  PEEK_ACTION_RULES,\n31\t  type PeekActionRule,\n32\t  type PeekRole,\n33\t} from \"../access-policy\";\n34\timport {\n35\t  writePeekAuditEvent,\n36\t  type PeekAuditWriteResult,\n37\t} from \"../audit/writer\";\n38\timport { getSqlClient } from \"../db/client\";\n39\timport type { PeekAuditChange } from \"../../lib/types/peek\";\n40\timport {\n41\t  getPeekMutation,\n42\t  PEEK_MUTATIONS,\n43\t  type PeekMutationActionId,\n44\t  type PeekMutationActorContext,\n45\t  type PeekMutationDefinition,\n46\t  type PeekMutationRegistry,\n47\t} from \"./registry\";\n48\t\n49\texport type PeekMutationFailureReason =\n50\t  | \"unknown_action\"\n51\t  | \"unauthorized\"\n52\t  | \"invalid_input\"\n53\t  | \"execution_failed\"\n54\t  | \"audit_emit_failed\";\n55\t\n56\texport type PeekMutationSuccess = {\n57\t  ok: true;\n58\t  actionId: PeekMutationActionId;\n59\t  resourceId: string | null;\n60\t  changes: ReadonlyArray<PeekAuditChange> | null;\n61\t};\n62\t\n63\texport type PeekMutationFailure = {\n64\t  ok: false;\n65\t  reason: PeekMutationFailureReason;\n66\t  message: string;\n67\t  fieldErrors?: Readonly<Record<string, ReadonlyArray<string>>>;\n68\t};\n69\t\n70\texport type PeekMutationRunResult = PeekMutationSuccess | PeekMutationFailure;\n71\t\n72\texport type PeekMutationAuditWriter = (\n73\t  input: Parameters<typeof writePeekAuditEvent>[0],\n74\t  options?: Parameters<typeof writePeekAuditEvent>[1],\n75\t) => Promise<PeekAuditWriteResult>;\n76\t\n77\texport type PeekMutationRunInput = {\n78\t  actionId: PeekMutationActionId;\n79\t  rawInput: unknown;\n80\t  actorRole: PeekRole | null;\n81\t  actor: PeekMutationActorContext;\n82\t  sql?: Sql;\n83\t  registry?: PeekMutationRegistry;\n84\t  actionRules?: ReadonlyArray<PeekActionRule>;\n85\t  auditWriter?: PeekMutationAuditWriter;\n86\t};\n87\t\n88\tconst AUDIT_FAILURE_PREFIX = \"peek_audit_emit_failed:\";\n89\t\n90\tfunction buildAppliedPayload(\n91\t  input: PeekMutationRunInput,\n92\t  definition: PeekMutationDefinition,\n93\t  resourceId: string | null,\n94\t  changes: ReadonlyArray<PeekAuditChange> | null,\n95\t) {\n96\t  return {\n97\t    eventType: \"peek.change.applied\" as const,\n98\t    payload: {\n99\t      actorEmail: input.actor.email,\n100\t      route: input.actor.route ?? null,\n101\t      actionId: input.actionId,\n102\t      resourceType: definition.resourceType,\n103\t      resourceId,\n104\t      filterSummary: null,\n105\t      resultCount: null,\n106\t      requestId: input.actor.requestId ?? null,\n107\t      rejectionReason: null,\n108\t      changes,\n109\t    },\n110\t  };\n111\t}\n112\t\n113\tfunction buildRejectedPayload(\n114\t  input: PeekMutationRunInput,\n115\t  definition: PeekMutationDefinition | null,\n116\t  rejectionReason: string,\n117\t  resourceId: string | null,\n118\t) {\n119\t  return {\n120\t    eventType: \"peek.change.rejected\" as const,\n121\t    payload: {\n122\t      actorEmail: input.actor.email,\n123\t      route: input.actor.route ?? null,\n124\t      actionId: input.actionId,\n125\t      resourceType: definition ? definition.resourceType : null,\n126\t      resourceId,\n127\t      filterSummary: null,\n128\t      resultCount: null,\n129\t      requestId: input.actor.requestId ?? null,\n130\t      rejectionReason,\n131\t      changes: null,\n132\t    },\n133\t  };\n134\t}\n135\t\n136\tfunction flattenFieldErrors(error: {\n137\t  flatten?: () => { fieldErrors?: Record<string, string[] | undefined> };\n138\t}): Readonly<Record<string, ReadonlyArray<string>>> {\n139\t  if (typeof error.flatten !== \"function\") return {};\n140\t  const flat = error.flatten();\n141\t  const fieldErrors = flat.fieldErrors ?? {};\n142\t  const out: Record<string, ReadonlyArray<string>> = {};\n143\t  for (const [key, value] of Object.entries(fieldErrors)) {\n144\t    if (Array.isArray(value) && value.length > 0) out[key] = value;\n145\t  }\n146\t  return out;\n147\t}\n148\t\n149\texport async function runPeekMutation(\n150\t  input: PeekMutationRunInput,\n151\t): Promise<PeekMutationRunResult> {\n152\t  const registry = input.registry ?? PEEK_MUTATIONS;\n153\t  const sql = input.sql ?? (getSqlClient() as unknown as Sql);\n154\t  const writer = input.auditWriter ?? writePeekAuditEvent;\n155\t  const actionRules = input.actionRules ?? PEEK_ACTION_RULES;\n156\t\n157\t  const definition = getPeekMutation(input.actionId, registry);\n158\t  if (!definition) {\n159\t    await writer(buildRejectedPayload(input, null, \"unknown_action\", null), {\n160\t      sql,\n161\t    });\n162\t    return {\n163\t      ok: false,\n164\t      reason: \"unknown_action\",\n165\t      message: `No registered mutation for action \"${input.actionId}\".`,\n166\t    };\n167\t  }\n168\t\n169\t  if (!isActionAllowedForRole(input.actionId, input.actorRole, actionRules)) {\n170\t    await writer(\n171\t      buildRejectedPayload(input, definition, \"unauthorized\", null),\n172\t      { sql },\n173\t    );\n174\t    return {\n175\t      ok: false,\n176\t      reason: \"unauthorized\",\n177\t      message: `Actor is not authorized to perform action \"${input.actionId}\".`,\n178\t    };\n179\t  }\n180\t\n181\t  const parsed = definition.schema.safeParse(input.rawInput);\n182\t  if (!parsed.success) {\n183\t    const fieldErrors = flattenFieldErrors(parsed.error);\n184\t    await writer(\n185\t      buildRejectedPayload(input, definition, \"invalid_input\", null),\n186\t      { sql },\n187\t    );\n188\t    return {\n189\t      ok: false,\n190\t      reason: \"invalid_input\",\n191\t      message: \"Input failed validation.\",\n192\t      fieldErrors,\n193\t    };\n194\t  }\n195\t\n196\t  let executeResult: { resourceId: string | null; changes: ReadonlyArray<PeekAuditChange> | null } | null = null;\n197\t  let runtimeError: Error | null = null;\n198\t\n199\t  try {\n200\t    executeResult = await sql.begin(async (sqlTx) => {\n201\t      const result = await definition.execute({\n202\t        input: parsed.data,\n203\t        sql: sqlTx as unknown as Sql,\n204\t        actor: input.actor,\n205\t      });\n206\t      const auditResult = await writer(\n207\t        buildAppliedPayload(\n208\t          input,\n209\t          definition,\n210\t          result.resourceId,\n211\t          result.changes,\n212\t        ),\n213\t        { sql: sqlTx as unknown as Sql },\n214\t      );\n215\t      if (!auditResult.ok) {\n216\t        // Throw to trigger transaction rollback so we never leave a\n217\t        // committed mutation without its audit record.\n218\t        throw new Error(`${AUDIT_FAILURE_PREFIX}${auditResult.reason}`);\n219\t      }\n220\t      return { resourceId: result.resourceId, changes: result.changes };\n221\t    }) as { resourceId: string | null; changes: ReadonlyArray<PeekAuditChange> | null };\n222\t  } catch (error) {\n223\t    runtimeError = error instanceof Error ? error : new Error(\"unknown\");\n224\t  }\n225\t\n226\t  if (runtimeError) {\n227\t    const isAuditFailure = runtimeError.message.startsWith(AUDIT_FAILURE_PREFIX);\n228\t    const rejectionReason = isAuditFailure\n229\t      ? runtimeError.message\n230\t      : `execution_failed: ${runtimeError.message}`;\n231\t    await writer(\n232\t      buildRejectedPayload(input, definition, rejectionReason, null),\n233\t      { sql },\n234\t    );\n235\t    return {\n236\t      ok: false,\n237\t      reason: isAuditFailure ? \"audit_emit_failed\" : \"execution_failed\",\n238\t      message: isAuditFailure\n239\t        ? `Audit emission failed (${runtimeError.message.slice(AUDIT_FAILURE_PREFIX.length)}); mutation was rolled back.`\n240\t        : runtimeError.message,\n241\t    };\n242\t  }\n243\t\n244\t  if (!executeResult) {\n245\t    // Defensive: sql.begin should always either return or throw.\n246\t    return {\n247\t      ok: false,\n248\t      reason: \"execution_failed\",\n249\t      message: \"Mutation transaction returned no result.\",\n250\t    };\n251\t  }\n252\t\n253\t  return {\n254\t    ok: true,\n255\t    actionId: input.actionId,\n256\t    resourceId: executeResult.resourceId,\n257\t    changes: executeResult.changes,\n258\t  };\n259\t}\n260\t"}]},"parent_tool_use_id":null,"session_id":"4de5a64f-41df-4f36-abe8-b663a1d849a0","uuid":"6d2b97a0-1384-4c2e-9e12-6ceaa03552ad","timestamp":"2026-04-26T15:26:07.992Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/mutations/runner.ts","content":"// Server-side mutation runner (FR-14).\n//\n// Orchestrates a single approved peek mutation end to end:\n//   1. Look up the registered definition for the requested action id.\n//      Unknown ids fail closed (`unknown_action`) with a `peek.change.rejected`\n//      audit event so unrecognised mutation attempts are still reviewable.\n//   2. Authorize the actor through `isActionAllowedForRole` against the\n//      FR-2 `PEEK_ACTION_RULES`. Denials emit `peek.change.rejected`.\n//   3. Validate the raw caller input against the mutation's zod schema.\n//      Validation failures emit `peek.change.rejected` (per FR-14 \"denied or\n//      validation-failed mutation writes peek.change.rejected\") with the\n//      field-level errors surfaced to the caller — never echoed into audit.\n//   4. Run the mutation inside `sql.begin(...)` so multi-statement work\n//      commits or rolls back together. The `peek.change.applied` audit row\n//      is written with the same transactional `Sql` so the persisted change\n//      and its audit record either both land or neither does.\n//   5. On any thrown error from `execute`, the transaction rolls back and\n//      `peek.change.rejected` is emitted on the main connection so the\n//      attempt still leaves a trail. Audit-emit failure inside the\n//      transaction throws and rolls the mutation back, surfacing as\n//      `audit_emit_failed` to the caller.\n//\n// The runner is dependency-injectable: callers can pass a mock `Sql`,\n// a custom registry, custom action rules, and a custom audit emitter\n// (no network/DB I/O is required to unit-test it).\n\nimport type { Sql } from \"postgres\";\nimport {\n  isActionAllowedForRole,\n  PEEK_ACTION_RULES,\n  type PeekActionRule,\n  type PeekRole,\n} from \"../access-policy\";\nimport {\n  writePeekAuditEvent,\n  type PeekAuditWriteResult,\n} from \"../audit/writer\";\nimport { getSqlClient } from \"../db/client\";\nimport type { PeekAuditChange } from \"../../lib/types/peek\";\nimport {\n  getPeekMutation,\n  PEEK_MUTATIONS,\n  type PeekMutationActionId,\n  type PeekMutationActorContext,\n  type PeekMutationDefinition,\n  type PeekMutationRegistry,\n} from \"./registry\";\n\nexport type PeekMutationFailureReason =\n  | \"unknown_action\"\n  | \"unauthorized\"\n  | \"invalid_input\"\n  | \"execution_failed\"\n  | \"audit_emit_failed\";\n\nexport type PeekMutationSuccess = {\n  ok: true;\n  actionId: PeekMutationActionId;\n  resourceId: string | null;\n  changes: ReadonlyArray<PeekAuditChange> | null;\n};\n\nexport type PeekMutationFailure = {\n  ok: false;\n  reason: PeekMutationFailureReason;\n  message: string;\n  fieldErrors?: Readonly<Record<string, ReadonlyArray<string>>>;\n};\n\nexport type PeekMutationRunResult = PeekMutationSuccess | PeekMutationFailure;\n\nexport type PeekMutationAuditWriter = (\n  input: Parameters<typeof writePeekAuditEvent>[0],\n  options?: Parameters<typeof writePeekAuditEvent>[1],\n) => Promise<PeekAuditWriteResult>;\n\nexport type PeekMutationRunInput = {\n  actionId: PeekMutationActionId;\n  rawInput: unknown;\n  actorRole: PeekRole | null;\n  actor: PeekMutationActorContext;\n  sql?: Sql;\n  registry?: PeekMutationRegistry;\n  actionRules?: ReadonlyArray<PeekActionRule>;\n  auditWriter?: PeekMutationAuditWriter;\n};\n\nconst AUDIT_FAILURE_PREFIX = \"peek_audit_emit_failed:\";\n\nfunction buildAppliedPayload(\n  input: PeekMutationRunInput,\n  definition: PeekMutationDefinition,\n  resourceId: string | null,\n  changes: ReadonlyArray<PeekAuditChange> | null,\n) {\n  return {\n    eventType: \"peek.change.applied\" as const,\n    payload: {\n      actorEmail: input.actor.email,\n      route: input.actor.route ?? null,\n      actionId: input.actionId,\n      resourceType: definition.resourceType,\n      resourceId,\n      filterSummary: null,\n      resultCount: null,\n      requestId: input.actor.requestId ?? null,\n      rejectionReason: null,\n      changes,\n    },\n  };\n}\n\nfunction buildRejectedPayload(\n  input: PeekMutationRunInput,\n  definition: PeekMutationDefinition | null,\n  rejectionReason: string,\n  resourceId: string | null,\n) {\n  return {\n    eventType: \"peek.change.rejected\" as const,\n    payload: {\n      actorEmail: input.actor.email,\n      route: input.actor.route ?? null,\n      actionId: input.actionId,\n      resourceType: definition ? definition.resourceType : null,\n      resourceId,\n      filterSummary: null,\n      resultCount: null,\n      requestId: input.actor.requestId ?? null,\n      rejectionReason,\n      changes: null,\n    },\n  };\n}\n\nfunction flattenFieldErrors(error: {\n  flatten?: () => { fieldErrors?: Record<string, string[] | undefined> };\n}): Readonly<Record<string, ReadonlyArray<string>>> {\n  if (typeof error.flatten !== \"function\") return {};\n  const flat = error.flatten();\n  const fieldErrors = flat.fieldErrors ?? {};\n  const out: Record<string, ReadonlyArray<string>> = {};\n  for (const [key, value] of Object.entries(fieldErrors)) {\n    if (Array.isArray(value) && value.length > 0) out[key] = value;\n  }\n  return out;\n}\n\nexport async function runPeekMutation(\n  input: PeekMutationRunInput,\n): Promise<PeekMutationRunResult> {\n  const registry = input.registry ?? PEEK_MUTATIONS;\n  const sql = input.sql ?? (getSqlClient() as unknown as Sql);\n  const writer = input.auditWriter ?? writePeekAuditEvent;\n  const actionRules = input.actionRules ?? PEEK_ACTION_RULES;\n\n  const definition = getPeekMutation(input.actionId, registry);\n  if (!definition) {\n    await writer(buildRejectedPayload(input, null, \"unknown_action\", null), {\n      sql,\n    });\n    return {\n      ok: false,\n      reason: \"unknown_action\",\n      message: `No registered mutation for action \"${input.actionId}\".`,\n    };\n  }\n\n  if (!isActionAllowedForRole(input.actionId, input.actorRole, actionRules)) {\n    await writer(\n      buildRejectedPayload(input, definition, \"unauthorized\", null),\n      { sql },\n    );\n    return {\n      ok: false,\n      reason: \"unauthorized\",\n      message: `Actor is not authorized to perform action \"${input.actionId}\".`,\n    };\n  }\n\n  const parsed = definition.schema.safeParse(input.rawInput);\n  if (!parsed.success) {\n    const fieldErrors = flattenFieldErrors(parsed.error);\n    await writer(\n      buildRejectedPayload(input, definition, \"invalid_input\", null),\n      { sql },\n    );\n    return {\n      ok: false,\n      reason: \"invalid_input\",\n      message: \"Input failed validation.\",\n      fieldErrors,\n    };\n  }\n\n  let executeResult: { resourceId: string | null; changes: ReadonlyArray<PeekAuditChange> | null } | null = null;\n  let runtimeError: Error | null = null;\n\n  try {\n    executeResult = await sql.begin(async (sqlTx) => {\n      const result = await definition.execute({\n        input: parsed.data,\n        sql: sqlTx as unknown as Sql,\n        actor: input.actor,\n      });\n      const auditResult = await writer(\n        buildAppliedPayload(\n          input,\n          definition,\n          result.resourceId,\n          result.changes,\n        ),\n        { sql: sqlTx as unknown as Sql },\n      );\n      if (!auditResult.ok) {\n        // Throw to trigger transaction rollback so we never leave a\n        // committed mutation without its audit record.\n        throw new Error(`${AUDIT_FAILURE_PREFIX}${auditResult.reason}`);\n      }\n      return { resourceId: result.resourceId, changes: result.changes };\n    }) as { resourceId: string | null; changes: ReadonlyArray<PeekAuditChange> | null };\n  } catch (error) {\n    runtimeError = error instanceof Error ? error : new Error(\"unknown\");\n  }\n\n  if (runtimeError) {\n    const isAuditFailure = runtimeError.message.startsWith(AUDIT_FAILURE_PREFIX);\n    const rejectionReason = isAuditFailure\n      ? runtimeError.message\n      : `execution_failed: ${runtimeError.message}`;\n    await writer(\n      buildRejectedPayload(input, definition, rejectionReason, null),\n      { sql },\n    );\n    return {\n      ok: false,\n      reason: isAuditFailure ? \"audit_emit_failed\" : \"execution_failed\",\n      message: isAuditFailure\n        ? `Audit emission failed (${runtimeError.message.slice(AUDIT_FAILURE_PREFIX.length)}); mutation was rolled back.`\n        : runtimeError.message,\n    };\n  }\n\n  if (!executeResult) {\n    // Defensive: sql.begin should always either return or throw.\n    return {\n      ok: false,\n      reason: \"execution_failed\",\n      message: \"Mutation transaction returned no result.\",\n    };\n  }\n\n  return {\n    ok: true,\n    actionId: input.actionId,\n    resourceId: executeResult.resourceId,\n    changes: executeResult.changes,\n  };\n}\n","numLines":260,"startLine":1,"totalLines":260}}}
