{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ViJxEXzqK5ooLTeoaoj4a2","type":"tool_result","content":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-command-center-attention.test.ts\n/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-game-rounds.test.ts\n/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-games-overview.test.ts\n/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-growth-referrals.test.ts\n/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-peek-user-detail.test.ts\n/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-recent-operator-events.test.ts\n/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/telegram-linked-queries.test.ts\n/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/universal-search.test.ts","is_error":false}]},"parent_tool_use_id":null,"session_id":"e3ee47e7-eefe-4e12-a068-a08216780c1e","uuid":"12a5c4c4-a866-47e6-92c3-285b6f63fbba","timestamp":"2026-04-25T13:35:25.994Z","tool_use_result":{"stdout":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-command-center-attention.test.ts\n/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-game-rounds.test.ts\n/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-games-overview.test.ts\n/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-growth-referrals.test.ts\n/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-peek-user-detail.test.ts\n/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-recent-operator-events.test.ts\n/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/telegram-linked-queries.test.ts\n/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/universal-search.test.ts","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01Vjg8eUgRd1DW6bwtKReZgm","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TiRMxZPzq22Lb4sanyvEsL","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-round-detail.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport { getRoundDetail } from \"../get-round-detail\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\n// SQL mock that records every tagged-template call and returns a queued\n// response per call. Mirrors the pattern from get-game-rounds.test.ts so\n// query test behaviour stays consistent across the FR-8 surface.\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\n// FlipYou + Pot Shot fire 1 lookup query then entries + transactions in\n// parallel; Close Call follows the same pattern. The mock gets responses\n// queued in order (round, entries, transactions) when the round is found.\n\ndescribe(\"getRoundDetail — FlipYou + Pot Shot (rounds table)\", () => {\n  it(\"full: shapes round summary + entries + transactions for a settled FlipYou round\", async () => {\n    const round = {\n      pda: \"pda-1\",\n      game: \"flipyou\",\n      matchId: \"m-1\",\n      phase: \"settled\",\n      creator: \"creator-1\",\n      targetSlot: \"1234567890\",\n      settleAttempts: 1,\n      settleTx: \"tx-settle-1\",\n      resultSide: 0,\n      winner: \"creator-1\",\n      // > Number.MAX_SAFE_INTEGER so we verify u64 strings survive end-to-end.\n      amountLamports: \"9007199254740992\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      updatedAt: \"2026-04-25T10:01:00.000Z\",\n      settledAt: \"2026-04-25T10:00:30.000Z\",\n    };\n    const entries = [\n      {\n        id: 11,\n        userId: \"u-1\",\n        username: \"alice\",\n        wallet: \"wal-1\",\n        amountLamports: \"9007199254740992\",\n        side: \"0\",\n        isWinner: true,\n        payoutLamports: \"18000000000000000\",\n        createdAt: \"2026-04-25T10:00:05.000Z\",\n        settledAt: \"2026-04-25T10:00:30.000Z\",\n      },\n      {\n        id: \"12\",\n        userId: \"u-2\",\n        username: null,\n        wallet: \"wal-2\",\n        amountLamports: \"9007199254740992\",\n        side: \"1\",\n        isWinner: false,\n        payoutLamports: \"0\",\n        createdAt: \"2026-04-25T10:00:06.000Z\",\n        settledAt: null,\n      },\n    ];\n    const transactions = [\n      {\n        id: 21,\n        userId: \"u-1\",\n        username: \"alice\",\n        wallet: \"wal-1\",\n        txType: \"payout\",\n        amountLamports: \"18000000000000000\",\n        txSig: \"tx-sig-1\",\n        createdAt: \"2026-04-25T10:00:30.000Z\",\n      },\n    ];\n    const mock = createSqlMock([[round], entries, transactions]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"flipyou\",\n      roundId: \"pda-1\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game === \"closecall\") throw new Error(\"expected flipyou\");\n\n    expect(result.game).toBe(\"flipyou\");\n    expect(result.round).toEqual({\n      game: \"flipyou\",\n      pda: \"pda-1\",\n      matchId: \"m-1\",\n      phase: \"settled\",\n      creator: \"creator-1\",\n      targetSlot: \"1234567890\",\n      settleAttempts: 1,\n      settleTx: \"tx-settle-1\",\n      resultSide: 0,\n      winner: \"creator-1\",\n      amountLamports: \"9007199254740992\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      updatedAt: \"2026-04-25T10:01:00.000Z\",\n      settledAt: \"2026-04-25T10:00:30.000Z\",\n    });\n\n    expect(result.entries).toHaveLength(2);\n    expect(result.entries[0]).toEqual({\n      id: \"11\",\n      userId: \"u-1\",\n      username: \"alice\",\n      wallet: \"wal-1\",\n      amountLamports: \"9007199254740992\",\n      side: \"0\",\n      isWinner: true,\n      payoutLamports: \"18000000000000000\",\n      createdAt: \"2026-04-25T10:00:05.000Z\",\n      settledAt: \"2026-04-25T10:00:30.000Z\",\n    });\n    // Numeric id from postgres (`bigint` returned as number) coerces to text.\n    expect(result.entries[0].id).toBe(\"11\");\n    // Already-string id stays as-is.\n    expect(result.entries[1].id).toBe(\"12\");\n    // Null-friendly columns survive: username, settledAt, isWinner=false stays.\n    expect(result.entries[1].username).toBeNull();\n    expect(result.entries[1].settledAt).toBeNull();\n    expect(result.entries[1].isWinner).toBe(false);\n\n    expect(result.transactions).toHaveLength(1);\n    expect(result.transactions[0]).toEqual({\n      id: \"21\",\n      userId: \"u-1\",\n      username: \"alice\",\n      wallet: \"wal-1\",\n      txType: \"payout\",\n      amountLamports: \"18000000000000000\",\n      txSig: \"tx-sig-1\",\n      createdAt: \"2026-04-25T10:00:30.000Z\",\n    });\n\n    // Verify the SQL calls fired in the expected order + with the expected\n    // joins.\n    expect(mock.calls).toHaveLength(3);\n    expect(mock.calls[0].text).toContain(\"from rounds r\");\n    expect(mock.calls[0].values).toContain(\"pda-1\");\n    expect(mock.calls[0].values).toContain(\"flipyou\");\n    expect(mock.calls[1].text).toContain(\"from game_entries ge\");\n    expect(mock.calls[1].text).toContain(\"left join player_profiles\");\n    expect(mock.calls[1].values).toContain(\"pda-1\");\n    expect(mock.calls[2].text).toContain(\"from transactions t\");\n    expect(mock.calls[2].values).toContain(\"flipyou\");\n    expect(mock.calls[2].values).toContain(\"m-1\");\n  });\n\n  it(\"works for potshot game id (same SQL, different game predicate)\", async () => {\n    const round = {\n      pda: \"pda-ps\",\n      game: \"potshot\",\n      matchId: \"m-ps\",\n      phase: \"created\",\n      creator: \"creator-ps\",\n      targetSlot: \"777\",\n      settleAttempts: 0,\n      settleTx: null,\n      resultSide: null,\n      winner: null,\n      amountLamports: \"5000000\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      updatedAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: null,\n    };\n    const mock = createSqlMock([[round], [], []]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"potshot\",\n      roundId: \"pda-ps\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game === \"closecall\") throw new Error(\"expected potshot\");\n    expect(result.game).toBe(\"potshot\");\n    expect(result.round.game).toBe(\"potshot\");\n    expect(mock.calls[0].values).toContain(\"potshot\");\n    expect(mock.calls[2].values).toContain(\"potshot\");\n  });\n\n  it(\"sparse: entries + transactions both empty → empty arrays, no fabricated rows\", async () => {\n    const round = {\n      pda: \"pda-sparse\",\n      game: \"flipyou\",\n      matchId: \"m-sparse\",\n      phase: \"created\",\n      creator: \"creator-x\",\n      targetSlot: null,\n      settleAttempts: 0,\n      settleTx: null,\n      resultSide: null,\n      winner: null,\n      amountLamports: \"100000\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      updatedAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: null,\n    };\n    const mock = createSqlMock([[round], [], []]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"flipyou\",\n      roundId: \"pda-sparse\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game === \"closecall\") throw new Error(\"expected flipyou\");\n    expect(result.entries).toEqual([]);\n    expect(result.transactions).toEqual([]);\n    // Null-friendly round columns survive.\n    expect(result.round.targetSlot).toBeNull();\n    expect(result.round.settleTx).toBeNull();\n    expect(result.round.resultSide).toBeNull();\n    expect(result.round.winner).toBeNull();\n    expect(result.round.settledAt).toBeNull();\n  });\n\n  it(\"refunded: phase = 'expired' surfaces with a refund transaction\", async () => {\n    const round = {\n      pda: \"pda-refund\",\n      game: \"flipyou\",\n      matchId: \"m-refund\",\n      phase: \"expired\",\n      creator: \"creator-r\",\n      targetSlot: null,\n      settleAttempts: 4,\n      settleTx: null,\n      resultSide: null,\n      winner: null,\n      amountLamports: \"1000000\",\n      createdAt: \"2026-04-25T09:00:00.000Z\",\n      updatedAt: \"2026-04-25T09:30:00.000Z\",\n      settledAt: null,\n    };\n    const refundTx = {\n      id: 99,\n      userId: \"u-1\",\n      username: \"alice\",\n      wallet: \"wal-1\",\n      txType: \"refund\",\n      amountLamports: \"1000000\",\n      txSig: \"refund-sig\",\n      createdAt: \"2026-04-25T09:30:00.000Z\",\n    };\n    const mock = createSqlMock([[round], [], [refundTx]]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"flipyou\",\n      roundId: \"pda-refund\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game === \"closecall\") throw new Error(\"expected flipyou\");\n    expect(result.round.phase).toBe(\"expired\");\n    expect(result.round.winner).toBeNull();\n    expect(result.transactions).toHaveLength(1);\n    expect(result.transactions[0].txType).toBe(\"refund\");\n  });\n\n  it(\"stuck: nonterminal phase + high settle attempts + no winner round-trip through the view model\", async () => {\n    const round = {\n      pda: \"pda-stuck\",\n      game: \"flipyou\",\n      matchId: \"m-stuck\",\n      phase: \"settling\",\n      creator: \"creator-s\",\n      targetSlot: \"999\",\n      settleAttempts: \"12\", // postgres-style string for INT — must coerce.\n      settleTx: null,\n      resultSide: null,\n      winner: null,\n      amountLamports: \"2000000\",\n      createdAt: \"2026-04-25T08:00:00.000Z\",\n      updatedAt: \"2026-04-25T09:00:00.000Z\",\n      settledAt: null,\n    };\n    const mock = createSqlMock([[round], [], []]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"flipyou\",\n      roundId: \"pda-stuck\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game === \"closecall\") throw new Error(\"expected flipyou\");\n    expect(result.round.phase).toBe(\"settling\");\n    expect(result.round.settleAttempts).toBe(12);\n    expect(result.round.winner).toBeNull();\n    expect(result.round.settleTx).toBeNull();\n  });\n\n  it(\"returns null when the round is not found in the rounds table\", async () => {\n    const mock = createSqlMock([[]]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"flipyou\",\n      roundId: \"missing\",\n    });\n\n    expect(result).toBeNull();\n    // Only the round lookup fired; no entries / transactions queries.\n    expect(mock.calls).toHaveLength(1);\n  });\n\n  it(\"filters out rows whose game id is not in PEEK_ROUNDS_GAME_IDS so out-of-band data cannot leak\", async () => {\n    // Defense-in-depth: even if a future migration row carries `game = 'crash'`\n    // and somehow matches the WHERE clause, the normalizer rejects it.\n    const round = {\n      pda: \"pda-bogus\",\n      game: \"crash\",\n      matchId: \"m-bogus\",\n      phase: \"settled\",\n      creator: \"creator-b\",\n      targetSlot: null,\n      settleAttempts: 0,\n      settleTx: null,\n      resultSide: null,\n      winner: null,\n      amountLamports: \"0\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      updatedAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: null,\n    };\n    const mock = createSqlMock([[round]]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"flipyou\",\n      roundId: \"pda-bogus\",\n    });\n\n    expect(result).toBeNull();\n  });\n\n  it(\"entries with null isWinner stay null (not coerced to false)\", async () => {\n    const round = {\n      pda: \"pda-x\",\n      game: \"flipyou\",\n      matchId: \"m-x\",\n      phase: \"created\",\n      creator: \"creator-x\",\n      targetSlot: null,\n      settleAttempts: 0,\n      settleTx: null,\n      resultSide: null,\n      winner: null,\n      amountLamports: \"0\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      updatedAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: null,\n    };\n    const entries = [\n      {\n        id: 1,\n        userId: \"u-1\",\n        username: null,\n        wallet: \"w-1\",\n        amountLamports: \"1\",\n        side: null,\n        isWinner: null, // pre-settlement state\n        payoutLamports: \"0\",\n        createdAt: \"2026-04-25T10:00:01.000Z\",\n        settledAt: null,\n      },\n    ];\n    const mock = createSqlMock([[round], entries, []]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"flipyou\",\n      roundId: \"pda-x\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game === \"closecall\") throw new Error(\"expected flipyou\");\n    expect(result.entries[0].isWinner).toBeNull();\n    expect(result.entries[0].side).toBeNull();\n  });\n\n  it(\"transactions with null user_id keep userId null (no fabricated link)\", async () => {\n    const round = {\n      pda: \"pda-y\",\n      game: \"flipyou\",\n      matchId: \"m-y\",\n      phase: \"settled\",\n      creator: \"creator-y\",\n      targetSlot: null,\n      settleAttempts: 0,\n      settleTx: \"tx-y\",\n      resultSide: 0,\n      winner: \"creator-y\",\n      amountLamports: \"0\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      updatedAt: \"2026-04-25T10:00:01.000Z\",\n      settledAt: \"2026-04-25T10:00:01.000Z\",\n    };\n    const transactions = [\n      {\n        id: 1,\n        userId: null,\n        username: null,\n        wallet: \"w-anon\",\n        txType: \"payout\",\n        amountLamports: \"1\",\n        txSig: \"sig-anon\",\n        createdAt: \"2026-04-25T10:00:02.000Z\",\n      },\n    ];\n    const mock = createSqlMock([[round], [], transactions]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"flipyou\",\n      roundId: \"pda-y\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game === \"closecall\") throw new Error(\"expected flipyou\");\n    expect(result.transactions[0].userId).toBeNull();\n    expect(result.transactions[0].username).toBeNull();\n  });\n\n  it(\"propagates a rejected round lookup query so the page can render the alert state\", async () => {\n    const mock = createSqlMock([new Error(\"connection refused\")]);\n    await expect(\n      getRoundDetail({ sql: mock.sql, game: \"flipyou\", roundId: \"pda-1\" }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n\n  it(\"propagates a rejected entries query (Promise.all bubbles the error)\", async () => {\n    const round = {\n      pda: \"pda-1\",\n      game: \"flipyou\",\n      matchId: \"m-1\",\n      phase: \"settled\",\n      creator: \"c\",\n      targetSlot: null,\n      settleAttempts: 0,\n      settleTx: null,\n      resultSide: null,\n      winner: null,\n      amountLamports: \"0\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      updatedAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: null,\n    };\n    const mock = createSqlMock([\n      [round],\n      new Error(\"statement timeout\"),\n      [],\n    ]);\n    await expect(\n      getRoundDetail({ sql: mock.sql, game: \"flipyou\", roundId: \"pda-1\" }),\n    ).rejects.toThrowError(\"statement timeout\");\n  });\n});\n\ndescribe(\"getRoundDetail — Close Call (closecall_rounds table)\", () => {\n  it(\"full: shapes round summary + entries + transactions for a settled green round\", async () => {\n    const round = {\n      pda: \"cc-pda-1\",\n      roundId: \"rd-1\",\n      phase: \"settled\",\n      outcome: \"green\",\n      openPrice: \"65000000000\",\n      openPriceExpo: -8,\n      closePrice: \"66000000000\",\n      greenPoolLamports: \"1000000\",\n      redPoolLamports: \"750000\",\n      totalFeeLamports: \"50000\",\n      settleTx: \"cc-tx-1\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: \"2026-04-25T10:05:00.000Z\",\n    };\n    const entries = [\n      {\n        id: 1,\n        userId: \"u-cc-1\",\n        username: \"carol\",\n        wallet: \"cc-w-1\",\n        amountLamports: \"500000\",\n        side: \"green\",\n        isWinner: true,\n        payoutLamports: \"950000\",\n        createdAt: \"2026-04-25T10:00:30.000Z\",\n        settledAt: \"2026-04-25T10:05:00.000Z\",\n      },\n    ];\n    const transactions = [\n      {\n        id: 1,\n        userId: \"u-cc-1\",\n        username: \"carol\",\n        wallet: \"cc-w-1\",\n        txType: \"payout\",\n        amountLamports: \"950000\",\n        txSig: \"cc-sig-1\",\n        createdAt: \"2026-04-25T10:05:00.000Z\",\n      },\n    ];\n    const mock = createSqlMock([[round], entries, transactions]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"closecall\",\n      roundId: \"cc-pda-1\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game !== \"closecall\") throw new Error(\"expected closecall\");\n\n    expect(result.round).toEqual({\n      pda: \"cc-pda-1\",\n      roundId: \"rd-1\",\n      phase: \"settled\",\n      outcome: \"green\",\n      openPrice: \"65000000000\",\n      openPriceExpo: -8,\n      closePrice: \"66000000000\",\n      greenPoolLamports: \"1000000\",\n      redPoolLamports: \"750000\",\n      totalFeeLamports: \"50000\",\n      settleTx: \"cc-tx-1\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: \"2026-04-25T10:05:00.000Z\",\n    });\n\n    expect(result.entries).toHaveLength(1);\n    expect(result.entries[0].side).toBe(\"green\");\n    expect(result.transactions).toHaveLength(1);\n\n    // Close Call resolves transactions through round_id (not match_id), and\n    // hard-codes the closecall game predicate.\n    expect(mock.calls[0].text).toContain(\"from closecall_rounds cc\");\n    expect(mock.calls[0].values).toContain(\"cc-pda-1\");\n    expect(mock.calls[1].text).toContain(\"from game_entries ge\");\n    expect(mock.calls[1].values).toContain(\"cc-pda-1\");\n    expect(mock.calls[2].text).toContain(\"from transactions t\");\n    expect(mock.calls[2].values).toContain(\"closecall\");\n    expect(mock.calls[2].values).toContain(\"rd-1\");\n  });\n\n  it(\"sparse: open round with empty pools and no entries / transactions\", async () => {\n    const round = {\n      pda: \"cc-pda-2\",\n      roundId: \"rd-2\",\n      phase: \"open\",\n      outcome: \"pending\",\n      openPrice: \"65000000000\",\n      openPriceExpo: -8,\n      closePrice: null,\n      greenPoolLamports: \"0\",\n      redPoolLamports: \"0\",\n      totalFeeLamports: \"0\",\n      settleTx: null,\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: null,\n    };\n    const mock = createSqlMock([[round], [], []]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"closecall\",\n      roundId: \"cc-pda-2\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game !== \"closecall\") throw new Error(\"expected closecall\");\n    expect(result.round.phase).toBe(\"open\");\n    expect(result.round.outcome).toBe(\"pending\");\n    expect(result.round.closePrice).toBeNull();\n    expect(result.round.settleTx).toBeNull();\n    expect(result.round.settledAt).toBeNull();\n    expect(result.entries).toEqual([]);\n    expect(result.transactions).toEqual([]);\n  });\n\n  it(\"refunded: phase = 'refunded' + outcome = 'refund' + refund transaction round-trip\", async () => {\n    const round = {\n      pda: \"cc-pda-3\",\n      roundId: \"rd-3\",\n      phase: \"refunded\",\n      outcome: \"refund\",\n      openPrice: \"65000000000\",\n      openPriceExpo: -8,\n      closePrice: null,\n      greenPoolLamports: \"1000\",\n      redPoolLamports: \"0\",\n      totalFeeLamports: \"0\",\n      settleTx: null,\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: \"2026-04-25T10:01:00.000Z\",\n    };\n    const refundTx = {\n      id: 1,\n      userId: null,\n      username: null,\n      wallet: \"cc-w-3\",\n      txType: \"refund\",\n      amountLamports: \"1000\",\n      txSig: \"cc-refund-sig\",\n      createdAt: \"2026-04-25T10:01:00.000Z\",\n    };\n    const mock = createSqlMock([[round], [], [refundTx]]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"closecall\",\n      roundId: \"cc-pda-3\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game !== \"closecall\") throw new Error(\"expected closecall\");\n    expect(result.round.phase).toBe(\"refunded\");\n    expect(result.round.outcome).toBe(\"refund\");\n    expect(result.transactions[0].txType).toBe(\"refund\");\n    expect(result.transactions[0].userId).toBeNull();\n  });\n\n  it(\"stuck: open round past expected lifecycle stays openable through the view model\", async () => {\n    // The stuck-state surfacing happens in the list query / filters; the\n    // detail query should still return the open round so an operator can\n    // drill in from the stuck filter and inspect it.\n    const round = {\n      pda: \"cc-pda-4\",\n      roundId: \"rd-4\",\n      phase: \"open\",\n      outcome: \"pending\",\n      openPrice: \"65000000000\",\n      openPriceExpo: -8,\n      closePrice: null,\n      greenPoolLamports: \"5000\",\n      redPoolLamports: \"5000\",\n      totalFeeLamports: \"0\",\n      settleTx: null,\n      createdAt: \"2026-04-25T08:00:00.000Z\", // 2h old in test fixture\n      settledAt: null,\n    };\n    const mock = createSqlMock([[round], [], []]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"closecall\",\n      roundId: \"cc-pda-4\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game !== \"closecall\") throw new Error(\"expected closecall\");\n    expect(result.round.phase).toBe(\"open\");\n    expect(result.entries).toEqual([]);\n    expect(result.transactions).toEqual([]);\n  });\n\n  it(\"returns null when the round is not found in closecall_rounds\", async () => {\n    const mock = createSqlMock([[]]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"closecall\",\n      roundId: \"missing-cc\",\n    });\n\n    expect(result).toBeNull();\n    expect(mock.calls).toHaveLength(1);\n  });\n\n  it(\"openPriceExpo string coercion: '-8' string parses to integer -8\", async () => {\n    const round = {\n      pda: \"cc-pda-x\",\n      roundId: \"rd-x\",\n      phase: \"open\",\n      outcome: \"pending\",\n      openPrice: \"1\",\n      openPriceExpo: \"-8\",\n      closePrice: null,\n      greenPoolLamports: \"0\",\n      redPoolLamports: \"0\",\n      totalFeeLamports: \"0\",\n      settleTx: null,\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: null,\n    };\n    const mock = createSqlMock([[round], [], []]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"closecall\",\n      roundId: \"cc-pda-x\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game !== \"closecall\") throw new Error(\"expected closecall\");\n    expect(result.round.openPriceExpo).toBe(-8);\n  });\n\n  it(\"propagates a rejected round lookup query\", async () => {\n    const mock = createSqlMock([new Error(\"connection refused\")]);\n    await expect(\n      getRoundDetail({ sql: mock.sql, game: \"closecall\", roundId: \"cc\" }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":529,"cache_read_input_tokens":126429,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":529},"output_tokens":69,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"e3ee47e7-eefe-4e12-a068-a08216780c1e","uuid":"7952a5b9-d414-42ad-9db7-c8816a77927e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TiRMxZPzq22Lb4sanyvEsL","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-round-detail.test.ts"}]},"parent_tool_use_id":null,"session_id":"e3ee47e7-eefe-4e12-a068-a08216780c1e","uuid":"347a66cb-d973-4ee7-8152-26bbd2e3f87a","timestamp":"2026-04-25T13:36:50.269Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-round-detail.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport { getRoundDetail } from \"../get-round-detail\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\n// SQL mock that records every tagged-template call and returns a queued\n// response per call. Mirrors the pattern from get-game-rounds.test.ts so\n// query test behaviour stays consistent across the FR-8 surface.\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\n// FlipYou + Pot Shot fire 1 lookup query then entries + transactions in\n// parallel; Close Call follows the same pattern. The mock gets responses\n// queued in order (round, entries, transactions) when the round is found.\n\ndescribe(\"getRoundDetail — FlipYou + Pot Shot (rounds table)\", () => {\n  it(\"full: shapes round summary + entries + transactions for a settled FlipYou round\", async () => {\n    const round = {\n      pda: \"pda-1\",\n      game: \"flipyou\",\n      matchId: \"m-1\",\n      phase: \"settled\",\n      creator: \"creator-1\",\n      targetSlot: \"1234567890\",\n      settleAttempts: 1,\n      settleTx: \"tx-settle-1\",\n      resultSide: 0,\n      winner: \"creator-1\",\n      // > Number.MAX_SAFE_INTEGER so we verify u64 strings survive end-to-end.\n      amountLamports: \"9007199254740992\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      updatedAt: \"2026-04-25T10:01:00.000Z\",\n      settledAt: \"2026-04-25T10:00:30.000Z\",\n    };\n    const entries = [\n      {\n        id: 11,\n        userId: \"u-1\",\n        username: \"alice\",\n        wallet: \"wal-1\",\n        amountLamports: \"9007199254740992\",\n        side: \"0\",\n        isWinner: true,\n        payoutLamports: \"18000000000000000\",\n        createdAt: \"2026-04-25T10:00:05.000Z\",\n        settledAt: \"2026-04-25T10:00:30.000Z\",\n      },\n      {\n        id: \"12\",\n        userId: \"u-2\",\n        username: null,\n        wallet: \"wal-2\",\n        amountLamports: \"9007199254740992\",\n        side: \"1\",\n        isWinner: false,\n        payoutLamports: \"0\",\n        createdAt: \"2026-04-25T10:00:06.000Z\",\n        settledAt: null,\n      },\n    ];\n    const transactions = [\n      {\n        id: 21,\n        userId: \"u-1\",\n        username: \"alice\",\n        wallet: \"wal-1\",\n        txType: \"payout\",\n        amountLamports: \"18000000000000000\",\n        txSig: \"tx-sig-1\",\n        createdAt: \"2026-04-25T10:00:30.000Z\",\n      },\n    ];\n    const mock = createSqlMock([[round], entries, transactions]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"flipyou\",\n      roundId: \"pda-1\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game === \"closecall\") throw new Error(\"expected flipyou\");\n\n    expect(result.game).toBe(\"flipyou\");\n    expect(result.round).toEqual({\n      game: \"flipyou\",\n      pda: \"pda-1\",\n      matchId: \"m-1\",\n      phase: \"settled\",\n      creator: \"creator-1\",\n      targetSlot: \"1234567890\",\n      settleAttempts: 1,\n      settleTx: \"tx-settle-1\",\n      resultSide: 0,\n      winner: \"creator-1\",\n      amountLamports: \"9007199254740992\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      updatedAt: \"2026-04-25T10:01:00.000Z\",\n      settledAt: \"2026-04-25T10:00:30.000Z\",\n    });\n\n    expect(result.entries).toHaveLength(2);\n    expect(result.entries[0]).toEqual({\n      id: \"11\",\n      userId: \"u-1\",\n      username: \"alice\",\n      wallet: \"wal-1\",\n      amountLamports: \"9007199254740992\",\n      side: \"0\",\n      isWinner: true,\n      payoutLamports: \"18000000000000000\",\n      createdAt: \"2026-04-25T10:00:05.000Z\",\n      settledAt: \"2026-04-25T10:00:30.000Z\",\n    });\n    // Numeric id from postgres (`bigint` returned as number) coerces to text.\n    expect(result.entries[0].id).toBe(\"11\");\n    // Already-string id stays as-is.\n    expect(result.entries[1].id).toBe(\"12\");\n    // Null-friendly columns survive: username, settledAt, isWinner=false stays.\n    expect(result.entries[1].username).toBeNull();\n    expect(result.entries[1].settledAt).toBeNull();\n    expect(result.entries[1].isWinner).toBe(false);\n\n    expect(result.transactions).toHaveLength(1);\n    expect(result.transactions[0]).toEqual({\n      id: \"21\",\n      userId: \"u-1\",\n      username: \"alice\",\n      wallet: \"wal-1\",\n      txType: \"payout\",\n      amountLamports: \"18000000000000000\",\n      txSig: \"tx-sig-1\",\n      createdAt: \"2026-04-25T10:00:30.000Z\",\n    });\n\n    // Verify the SQL calls fired in the expected order + with the expected\n    // joins.\n    expect(mock.calls).toHaveLength(3);\n    expect(mock.calls[0].text).toContain(\"from rounds r\");\n    expect(mock.calls[0].values).toContain(\"pda-1\");\n    expect(mock.calls[0].values).toContain(\"flipyou\");\n    expect(mock.calls[1].text).toContain(\"from game_entries ge\");\n    expect(mock.calls[1].text).toContain(\"left join player_profiles\");\n    expect(mock.calls[1].values).toContain(\"pda-1\");\n    expect(mock.calls[2].text).toContain(\"from transactions t\");\n    expect(mock.calls[2].values).toContain(\"flipyou\");\n    expect(mock.calls[2].values).toContain(\"m-1\");\n  });\n\n  it(\"works for potshot game id (same SQL, different game predicate)\", async () => {\n    const round = {\n      pda: \"pda-ps\",\n      game: \"potshot\",\n      matchId: \"m-ps\",\n      phase: \"created\",\n      creator: \"creator-ps\",\n      targetSlot: \"777\",\n      settleAttempts: 0,\n      settleTx: null,\n      resultSide: null,\n      winner: null,\n      amountLamports: \"5000000\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      updatedAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: null,\n    };\n    const mock = createSqlMock([[round], [], []]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"potshot\",\n      roundId: \"pda-ps\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game === \"closecall\") throw new Error(\"expected potshot\");\n    expect(result.game).toBe(\"potshot\");\n    expect(result.round.game).toBe(\"potshot\");\n    expect(mock.calls[0].values).toContain(\"potshot\");\n    expect(mock.calls[2].values).toContain(\"potshot\");\n  });\n\n  it(\"sparse: entries + transactions both empty → empty arrays, no fabricated rows\", async () => {\n    const round = {\n      pda: \"pda-sparse\",\n      game: \"flipyou\",\n      matchId: \"m-sparse\",\n      phase: \"created\",\n      creator: \"creator-x\",\n      targetSlot: null,\n      settleAttempts: 0,\n      settleTx: null,\n      resultSide: null,\n      winner: null,\n      amountLamports: \"100000\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      updatedAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: null,\n    };\n    const mock = createSqlMock([[round], [], []]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"flipyou\",\n      roundId: \"pda-sparse\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game === \"closecall\") throw new Error(\"expected flipyou\");\n    expect(result.entries).toEqual([]);\n    expect(result.transactions).toEqual([]);\n    // Null-friendly round columns survive.\n    expect(result.round.targetSlot).toBeNull();\n    expect(result.round.settleTx).toBeNull();\n    expect(result.round.resultSide).toBeNull();\n    expect(result.round.winner).toBeNull();\n    expect(result.round.settledAt).toBeNull();\n  });\n\n  it(\"refunded: phase = 'expired' surfaces with a refund transaction\", async () => {\n    const round = {\n      pda: \"pda-refund\",\n      game: \"flipyou\",\n      matchId: \"m-refund\",\n      phase: \"expired\",\n      creator: \"creator-r\",\n      targetSlot: null,\n      settleAttempts: 4,\n      settleTx: null,\n      resultSide: null,\n      winner: null,\n      amountLamports: \"1000000\",\n      createdAt: \"2026-04-25T09:00:00.000Z\",\n      updatedAt: \"2026-04-25T09:30:00.000Z\",\n      settledAt: null,\n    };\n    const refundTx = {\n      id: 99,\n      userId: \"u-1\",\n      username: \"alice\",\n      wallet: \"wal-1\",\n      txType: \"refund\",\n      amountLamports: \"1000000\",\n      txSig: \"refund-sig\",\n      createdAt: \"2026-04-25T09:30:00.000Z\",\n    };\n    const mock = createSqlMock([[round], [], [refundTx]]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"flipyou\",\n      roundId: \"pda-refund\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game === \"closecall\") throw new Error(\"expected flipyou\");\n    expect(result.round.phase).toBe(\"expired\");\n    expect(result.round.winner).toBeNull();\n    expect(result.transactions).toHaveLength(1);\n    expect(result.transactions[0].txType).toBe(\"refund\");\n  });\n\n  it(\"stuck: nonterminal phase + high settle attempts + no winner round-trip through the view model\", async () => {\n    const round = {\n      pda: \"pda-stuck\",\n      game: \"flipyou\",\n      matchId: \"m-stuck\",\n      phase: \"settling\",\n      creator: \"creator-s\",\n      targetSlot: \"999\",\n      settleAttempts: \"12\", // postgres-style string for INT — must coerce.\n      settleTx: null,\n      resultSide: null,\n      winner: null,\n      amountLamports: \"2000000\",\n      createdAt: \"2026-04-25T08:00:00.000Z\",\n      updatedAt: \"2026-04-25T09:00:00.000Z\",\n      settledAt: null,\n    };\n    const mock = createSqlMock([[round], [], []]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"flipyou\",\n      roundId: \"pda-stuck\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game === \"closecall\") throw new Error(\"expected flipyou\");\n    expect(result.round.phase).toBe(\"settling\");\n    expect(result.round.settleAttempts).toBe(12);\n    expect(result.round.winner).toBeNull();\n    expect(result.round.settleTx).toBeNull();\n  });\n\n  it(\"returns null when the round is not found in the rounds table\", async () => {\n    const mock = createSqlMock([[]]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"flipyou\",\n      roundId: \"missing\",\n    });\n\n    expect(result).toBeNull();\n    // Only the round lookup fired; no entries / transactions queries.\n    expect(mock.calls).toHaveLength(1);\n  });\n\n  it(\"filters out rows whose game id is not in PEEK_ROUNDS_GAME_IDS so out-of-band data cannot leak\", async () => {\n    // Defense-in-depth: even if a future migration row carries `game = 'crash'`\n    // and somehow matches the WHERE clause, the normalizer rejects it.\n    const round = {\n      pda: \"pda-bogus\",\n      game: \"crash\",\n      matchId: \"m-bogus\",\n      phase: \"settled\",\n      creator: \"creator-b\",\n      targetSlot: null,\n      settleAttempts: 0,\n      settleTx: null,\n      resultSide: null,\n      winner: null,\n      amountLamports: \"0\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      updatedAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: null,\n    };\n    const mock = createSqlMock([[round]]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"flipyou\",\n      roundId: \"pda-bogus\",\n    });\n\n    expect(result).toBeNull();\n  });\n\n  it(\"entries with null isWinner stay null (not coerced to false)\", async () => {\n    const round = {\n      pda: \"pda-x\",\n      game: \"flipyou\",\n      matchId: \"m-x\",\n      phase: \"created\",\n      creator: \"creator-x\",\n      targetSlot: null,\n      settleAttempts: 0,\n      settleTx: null,\n      resultSide: null,\n      winner: null,\n      amountLamports: \"0\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      updatedAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: null,\n    };\n    const entries = [\n      {\n        id: 1,\n        userId: \"u-1\",\n        username: null,\n        wallet: \"w-1\",\n        amountLamports: \"1\",\n        side: null,\n        isWinner: null, // pre-settlement state\n        payoutLamports: \"0\",\n        createdAt: \"2026-04-25T10:00:01.000Z\",\n        settledAt: null,\n      },\n    ];\n    const mock = createSqlMock([[round], entries, []]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"flipyou\",\n      roundId: \"pda-x\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game === \"closecall\") throw new Error(\"expected flipyou\");\n    expect(result.entries[0].isWinner).toBeNull();\n    expect(result.entries[0].side).toBeNull();\n  });\n\n  it(\"transactions with null user_id keep userId null (no fabricated link)\", async () => {\n    const round = {\n      pda: \"pda-y\",\n      game: \"flipyou\",\n      matchId: \"m-y\",\n      phase: \"settled\",\n      creator: \"creator-y\",\n      targetSlot: null,\n      settleAttempts: 0,\n      settleTx: \"tx-y\",\n      resultSide: 0,\n      winner: \"creator-y\",\n      amountLamports: \"0\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      updatedAt: \"2026-04-25T10:00:01.000Z\",\n      settledAt: \"2026-04-25T10:00:01.000Z\",\n    };\n    const transactions = [\n      {\n        id: 1,\n        userId: null,\n        username: null,\n        wallet: \"w-anon\",\n        txType: \"payout\",\n        amountLamports: \"1\",\n        txSig: \"sig-anon\",\n        createdAt: \"2026-04-25T10:00:02.000Z\",\n      },\n    ];\n    const mock = createSqlMock([[round], [], transactions]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"flipyou\",\n      roundId: \"pda-y\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game === \"closecall\") throw new Error(\"expected flipyou\");\n    expect(result.transactions[0].userId).toBeNull();\n    expect(result.transactions[0].username).toBeNull();\n  });\n\n  it(\"propagates a rejected round lookup query so the page can render the alert state\", async () => {\n    const mock = createSqlMock([new Error(\"connection refused\")]);\n    await expect(\n      getRoundDetail({ sql: mock.sql, game: \"flipyou\", roundId: \"pda-1\" }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n\n  it(\"propagates a rejected entries query (Promise.all bubbles the error)\", async () => {\n    const round = {\n      pda: \"pda-1\",\n      game: \"flipyou\",\n      matchId: \"m-1\",\n      phase: \"settled\",\n      creator: \"c\",\n      targetSlot: null,\n      settleAttempts: 0,\n      settleTx: null,\n      resultSide: null,\n      winner: null,\n      amountLamports: \"0\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      updatedAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: null,\n    };\n    const mock = createSqlMock([\n      [round],\n      new Error(\"statement timeout\"),\n      [],\n    ]);\n    await expect(\n      getRoundDetail({ sql: mock.sql, game: \"flipyou\", roundId: \"pda-1\" }),\n    ).rejects.toThrowError(\"statement timeout\");\n  });\n});\n\ndescribe(\"getRoundDetail — Close Call (closecall_rounds table)\", () => {\n  it(\"full: shapes round summary + entries + transactions for a settled green round\", async () => {\n    const round = {\n      pda: \"cc-pda-1\",\n      roundId: \"rd-1\",\n      phase: \"settled\",\n      outcome: \"green\",\n      openPrice: \"65000000000\",\n      openPriceExpo: -8,\n      closePrice: \"66000000000\",\n      greenPoolLamports: \"1000000\",\n      redPoolLamports: \"750000\",\n      totalFeeLamports: \"50000\",\n      settleTx: \"cc-tx-1\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: \"2026-04-25T10:05:00.000Z\",\n    };\n    const entries = [\n      {\n        id: 1,\n        userId: \"u-cc-1\",\n        username: \"carol\",\n        wallet: \"cc-w-1\",\n        amountLamports: \"500000\",\n        side: \"green\",\n        isWinner: true,\n        payoutLamports: \"950000\",\n        createdAt: \"2026-04-25T10:00:30.000Z\",\n        settledAt: \"2026-04-25T10:05:00.000Z\",\n      },\n    ];\n    const transactions = [\n      {\n        id: 1,\n        userId: \"u-cc-1\",\n        username: \"carol\",\n        wallet: \"cc-w-1\",\n        txType: \"payout\",\n        amountLamports: \"950000\",\n        txSig: \"cc-sig-1\",\n        createdAt: \"2026-04-25T10:05:00.000Z\",\n      },\n    ];\n    const mock = createSqlMock([[round], entries, transactions]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"closecall\",\n      roundId: \"cc-pda-1\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game !== \"closecall\") throw new Error(\"expected closecall\");\n\n    expect(result.round).toEqual({\n      pda: \"cc-pda-1\",\n      roundId: \"rd-1\",\n      phase: \"settled\",\n      outcome: \"green\",\n      openPrice: \"65000000000\",\n      openPriceExpo: -8,\n      closePrice: \"66000000000\",\n      greenPoolLamports: \"1000000\",\n      redPoolLamports: \"750000\",\n      totalFeeLamports: \"50000\",\n      settleTx: \"cc-tx-1\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: \"2026-04-25T10:05:00.000Z\",\n    });\n\n    expect(result.entries).toHaveLength(1);\n    expect(result.entries[0].side).toBe(\"green\");\n    expect(result.transactions).toHaveLength(1);\n\n    // Close Call resolves transactions through round_id (not match_id), and\n    // hard-codes the closecall game predicate.\n    expect(mock.calls[0].text).toContain(\"from closecall_rounds cc\");\n    expect(mock.calls[0].values).toContain(\"cc-pda-1\");\n    expect(mock.calls[1].text).toContain(\"from game_entries ge\");\n    expect(mock.calls[1].values).toContain(\"cc-pda-1\");\n    expect(mock.calls[2].text).toContain(\"from transactions t\");\n    expect(mock.calls[2].values).toContain(\"closecall\");\n    expect(mock.calls[2].values).toContain(\"rd-1\");\n  });\n\n  it(\"sparse: open round with empty pools and no entries / transactions\", async () => {\n    const round = {\n      pda: \"cc-pda-2\",\n      roundId: \"rd-2\",\n      phase: \"open\",\n      outcome: \"pending\",\n      openPrice: \"65000000000\",\n      openPriceExpo: -8,\n      closePrice: null,\n      greenPoolLamports: \"0\",\n      redPoolLamports: \"0\",\n      totalFeeLamports: \"0\",\n      settleTx: null,\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: null,\n    };\n    const mock = createSqlMock([[round], [], []]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"closecall\",\n      roundId: \"cc-pda-2\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game !== \"closecall\") throw new Error(\"expected closecall\");\n    expect(result.round.phase).toBe(\"open\");\n    expect(result.round.outcome).toBe(\"pending\");\n    expect(result.round.closePrice).toBeNull();\n    expect(result.round.settleTx).toBeNull();\n    expect(result.round.settledAt).toBeNull();\n    expect(result.entries).toEqual([]);\n    expect(result.transactions).toEqual([]);\n  });\n\n  it(\"refunded: phase = 'refunded' + outcome = 'refund' + refund transaction round-trip\", async () => {\n    const round = {\n      pda: \"cc-pda-3\",\n      roundId: \"rd-3\",\n      phase: \"refunded\",\n      outcome: \"refund\",\n      openPrice: \"65000000000\",\n      openPriceExpo: -8,\n      closePrice: null,\n      greenPoolLamports: \"1000\",\n      redPoolLamports: \"0\",\n      totalFeeLamports: \"0\",\n      settleTx: null,\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: \"2026-04-25T10:01:00.000Z\",\n    };\n    const refundTx = {\n      id: 1,\n      userId: null,\n      username: null,\n      wallet: \"cc-w-3\",\n      txType: \"refund\",\n      amountLamports: \"1000\",\n      txSig: \"cc-refund-sig\",\n      createdAt: \"2026-04-25T10:01:00.000Z\",\n    };\n    const mock = createSqlMock([[round], [], [refundTx]]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"closecall\",\n      roundId: \"cc-pda-3\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game !== \"closecall\") throw new Error(\"expected closecall\");\n    expect(result.round.phase).toBe(\"refunded\");\n    expect(result.round.outcome).toBe(\"refund\");\n    expect(result.transactions[0].txType).toBe(\"refund\");\n    expect(result.transactions[0].userId).toBeNull();\n  });\n\n  it(\"stuck: open round past expected lifecycle stays openable through the view model\", async () => {\n    // The stuck-state surfacing happens in the list query / filters; the\n    // detail query should still return the open round so an operator can\n    // drill in from the stuck filter and inspect it.\n    const round = {\n      pda: \"cc-pda-4\",\n      roundId: \"rd-4\",\n      phase: \"open\",\n      outcome: \"pending\",\n      openPrice: \"65000000000\",\n      openPriceExpo: -8,\n      closePrice: null,\n      greenPoolLamports: \"5000\",\n      redPoolLamports: \"5000\",\n      totalFeeLamports: \"0\",\n      settleTx: null,\n      createdAt: \"2026-04-25T08:00:00.000Z\", // 2h old in test fixture\n      settledAt: null,\n    };\n    const mock = createSqlMock([[round], [], []]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"closecall\",\n      roundId: \"cc-pda-4\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game !== \"closecall\") throw new Error(\"expected closecall\");\n    expect(result.round.phase).toBe(\"open\");\n    expect(result.entries).toEqual([]);\n    expect(result.transactions).toEqual([]);\n  });\n\n  it(\"returns null when the round is not found in closecall_rounds\", async () => {\n    const mock = createSqlMock([[]]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"closecall\",\n      roundId: \"missing-cc\",\n    });\n\n    expect(result).toBeNull();\n    expect(mock.calls).toHaveLength(1);\n  });\n\n  it(\"openPriceExpo string coercion: '-8' string parses to integer -8\", async () => {\n    const round = {\n      pda: \"cc-pda-x\",\n      roundId: \"rd-x\",\n      phase: \"open\",\n      outcome: \"pending\",\n      openPrice: \"1\",\n      openPriceExpo: \"-8\",\n      closePrice: null,\n      greenPoolLamports: \"0\",\n      redPoolLamports: \"0\",\n      totalFeeLamports: \"0\",\n      settleTx: null,\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: null,\n    };\n    const mock = createSqlMock([[round], [], []]);\n\n    const result = await getRoundDetail({\n      sql: mock.sql,\n      game: \"closecall\",\n      roundId: \"cc-pda-x\",\n    });\n\n    expect(result).not.toBeNull();\n    if (!result || result.game !== \"closecall\") throw new Error(\"expected closecall\");\n    expect(result.round.openPriceExpo).toBe(-8);\n  });\n\n  it(\"propagates a rejected round lookup query\", async () => {\n    const mock = createSqlMock([new Error(\"connection refused\")]);\n    await expect(\n      getRoundDetail({ sql: mock.sql, game: \"closecall\", roundId: \"cc\" }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
