{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ENnmmurwDso4sBmiF6XVHi","type":"tool_result","content":"1\timport type { CSSProperties } from \"react\";\n2\timport type { PeekStatusTone } from \"../lib/types/peek\";\n3\t\n4\texport type StatusChipProps = {\n5\t  label: string | null;\n6\t  tone?: PeekStatusTone;\n7\t  title?: string;\n8\t  error?: string | null;\n9\t};\n10\t\n11\texport function StatusChip({\n12\t  label,\n13\t  tone = \"neutral\",\n14\t  title,\n15\t  error = null,\n16\t}: StatusChipProps) {\n17\t  if (error) {\n18\t    return (\n19\t      <span role=\"alert\" style={errorStyle}>\n20\t        Status unavailable: {error}\n21\t      </span>\n22\t    );\n23\t  }\n24\t\n25\t  if (!label) {\n26\t    return (\n27\t      <span role=\"status\" aria-label=\"status missing\" style={emptyStyle}>\n28\t        —\n29\t      </span>\n30\t    );\n31\t  }\n32\t\n33\t  return (\n34\t    <span\n35\t      role=\"status\"\n36\t      data-tone={tone}\n37\t      title={title}\n38\t      style={chipStyle(tone)}\n39\t    >\n40\t      {label}"}]},"parent_tool_use_id":null,"session_id":"e3ee47e7-eefe-4e12-a068-a08216780c1e","uuid":"7f60e6d8-ff1c-4945-b2b6-74e32b82c102","timestamp":"2026-04-25T13:33:55.767Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/status-chip.tsx","content":"import type { CSSProperties } from \"react\";\nimport type { PeekStatusTone } from \"../lib/types/peek\";\n\nexport type StatusChipProps = {\n  label: string | null;\n  tone?: PeekStatusTone;\n  title?: string;\n  error?: string | null;\n};\n\nexport function StatusChip({\n  label,\n  tone = \"neutral\",\n  title,\n  error = null,\n}: StatusChipProps) {\n  if (error) {\n    return (\n      <span role=\"alert\" style={errorStyle}>\n        Status unavailable: {error}\n      </span>\n    );\n  }\n\n  if (!label) {\n    return (\n      <span role=\"status\" aria-label=\"status missing\" style={emptyStyle}>\n        —\n      </span>\n    );\n  }\n\n  return (\n    <span\n      role=\"status\"\n      data-tone={tone}\n      title={title}\n      style={chipStyle(tone)}\n    >\n      {label}","numLines":40,"startLine":1,"totalLines":88}}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01S8zbYChJbfMc8Qc9Xpz2Zk","type":"message","role":"assistant","content":[{"type":"text","text":"Now create the extracted view component. I'll move the inline render code from `page.tsx` to a new `round-detail-view.tsx`:"}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":526,"cache_read_input_tokens":117178,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":526},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"e3ee47e7-eefe-4e12-a068-a08216780c1e","uuid":"a6eca78a-ac19-4544-ac8e-abb969c750b5"}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01S8zbYChJbfMc8Qc9Xpz2Zk","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Q19dxecXbGeDw6WUqanKpF","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/round-detail-view.tsx","content":"// Round-detail view (FR-8). Server-renderable, props-only component used by\n// `/games/[game]/rounds/[roundId]/page.tsx`. Lives in `src/components` so it\n// can be tested directly with @testing-library/react against a synthetic\n// `PeekRoundDetail` without spinning up the whole route.\n\nimport Link from \"next/link\";\nimport type { CSSProperties, ReactNode } from \"react\";\nimport { StatusChip } from \"./status-chip\";\nimport type {\n  PeekCloseCallOutcome,\n  PeekCloseCallPhase,\n  PeekCloseCallRoundRow,\n  PeekGameId,\n  PeekRoundDetail,\n  PeekRoundEntryRow,\n  PeekRoundPhase,\n  PeekRoundRow,\n  PeekRoundTransactionRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\n\nexport type RoundDetailViewProps = {\n  detail: PeekRoundDetail;\n};\n\nexport function RoundDetailView({ detail }: RoundDetailViewProps) {\n  return (\n    <>\n      <Section heading=\"Round summary\" headingId=\"round-summary-heading\">\n        {detail.game === \"closecall\" ? (\n          <CloseCallSummary round={detail.round} />\n        ) : (\n          <RoundSummary round={detail.round} />\n        )}\n      </Section>\n\n      <Section heading=\"Entries\" headingId=\"entries-heading\">\n        <p style={hintStyle}>\n          {detail.entries.length} participant\n          {detail.entries.length === 1 ? \"\" : \"s\"} from{\" \"}\n          <code style={codeStyle}>game_entries</code> · sorted oldest first.\n        </p>\n        <EntriesTable entries={detail.entries} game={detail.game} />\n      </Section>\n\n      <Section heading=\"Transactions\" headingId=\"transactions-heading\">\n        <p style={hintStyle}>\n          {detail.transactions.length} on-chain SOL movement\n          {detail.transactions.length === 1 ? \"\" : \"s\"} from{\" \"}\n          <code style={codeStyle}>transactions</code> · sorted oldest first.\n        </p>\n        <TransactionsTable transactions={detail.transactions} />\n      </Section>\n    </>\n  );\n}\n\nfunction RoundSummary({ round }: { round: PeekRoundRow }) {\n  return (\n    <dl style={summaryGridStyle}>\n      <SummaryItem label=\"Phase\">\n        <StatusChip label={round.phase} tone={phaseTone(round.phase)} />\n      </SummaryItem>\n      <SummaryItem label=\"Match ID\">\n        <Mono title={round.matchId}>{round.matchId}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"PDA\">\n        <Mono title={round.pda}>{round.pda}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"Creator\">\n        <Mono title={round.creator}>{round.creator}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"Amount (lamports)\">\n        {formatNumber(round.amountLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Target slot\">\n        {round.targetSlot ? formatNumber(round.targetSlot) : \"—\"}\n      </SummaryItem>\n      <SummaryItem label=\"Settle attempts\">\n        {String(round.settleAttempts)}\n      </SummaryItem>\n      <SummaryItem label=\"Result side\">\n        {round.resultSide === null ? \"—\" : String(round.resultSide)}\n      </SummaryItem>\n      <SummaryItem label=\"Winner\">\n        {round.winner ? <Mono title={round.winner}>{round.winner}</Mono> : \"—\"}\n      </SummaryItem>\n      <SummaryItem label=\"Settle tx\">\n        {round.settleTx ? (\n          <Mono title={round.settleTx}>{round.settleTx}</Mono>\n        ) : (\n          \"—\"\n        )}\n      </SummaryItem>\n      <SummaryItem label=\"Created\">{round.createdAt}</SummaryItem>\n      <SummaryItem label=\"Updated\">{round.updatedAt}</SummaryItem>\n      <SummaryItem label=\"Settled\">{round.settledAt ?? \"—\"}</SummaryItem>\n    </dl>\n  );\n}\n\nfunction CloseCallSummary({ round }: { round: PeekCloseCallRoundRow }) {\n  return (\n    <dl style={summaryGridStyle}>\n      <SummaryItem label=\"Phase\">\n        <StatusChip label={round.phase} tone={closeCallPhaseTone(round.phase)} />\n      </SummaryItem>\n      <SummaryItem label=\"Outcome\">\n        <StatusChip\n          label={round.outcome}\n          tone={closeCallOutcomeTone(round.outcome)}\n        />\n      </SummaryItem>\n      <SummaryItem label=\"Round ID\">\n        <Mono title={round.roundId}>{round.roundId}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"PDA\">\n        <Mono title={round.pda}>{round.pda}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"Open price\">\n        {formatNumber(round.openPrice)}\n        <span style={subValueStyle}> · expo {round.openPriceExpo}</span>\n      </SummaryItem>\n      <SummaryItem label=\"Close price\">\n        {round.closePrice ? formatNumber(round.closePrice) : \"—\"}\n      </SummaryItem>\n      <SummaryItem label=\"Green pool (lamports)\">\n        {formatNumber(round.greenPoolLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Red pool (lamports)\">\n        {formatNumber(round.redPoolLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Total fee (lamports)\">\n        {formatNumber(round.totalFeeLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Settle tx\">\n        {round.settleTx ? (\n          <Mono title={round.settleTx}>{round.settleTx}</Mono>\n        ) : (\n          \"—\"\n        )}\n      </SummaryItem>\n      <SummaryItem label=\"Created\">{round.createdAt}</SummaryItem>\n      <SummaryItem label=\"Settled\">{round.settledAt ?? \"—\"}</SummaryItem>\n    </dl>\n  );\n}\n\nfunction EntriesTable({\n  entries,\n  game,\n}: {\n  entries: ReadonlyArray<PeekRoundEntryRow>;\n  game: PeekGameId;\n}) {\n  if (entries.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No entries recorded for this round.</p>\n        <p style={emptyBodyStyle}>\n          The <code style={codeStyle}>game_entries</code> table has no rows\n          joined to this round PDA. This is normal for rounds that were created\n          but never joined.\n        </p>\n      </div>\n    );\n  }\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>\n            <th style={headerCellStyle(\"left\")}>\n              {game === \"closecall\" ? \"Side\" : \"Side\"}\n            </th>\n            <th style={headerCellStyle(\"left\")}>Winner</th>\n            <th style={headerCellStyle(\"right\")}>Payout (lamports)</th>\n            <th style={headerCellStyle(\"left\")}>Settled</th>\n          </tr>\n        </thead>\n        <tbody>\n          {entries.map((entry) => (\n            <tr key={entry.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{entry.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <Link\n                  href={`/users/${entry.userId}`}\n                  style={linkStyle}\n                  title={entry.userId}\n                >\n                  {entry.username ?? truncate(entry.userId, 12)}\n                </Link>\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={entry.wallet}>{truncate(entry.wallet, 12)}</span>\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(entry.amountLamports)}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{entry.side ?? \"—\"}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                {entry.isWinner === null ? \"—\" : entry.isWinner ? \"yes\" : \"no\"}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(entry.payoutLamports)}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{entry.settledAt ?? \"—\"}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction TransactionsTable({\n  transactions,\n}: {\n  transactions: ReadonlyArray<PeekRoundTransactionRow>;\n}) {\n  if (transactions.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No transactions recorded for this round.</p>\n        <p style={emptyBodyStyle}>\n          The <code style={codeStyle}>transactions</code> table has no rows\n          joined to this round. Settled rounds without transaction rows are an\n          attention state surfaced by the stuck-state filters on{\" \"}\n          <code style={codeStyle}>/games/[game]</code>.\n        </p>\n      </div>\n    );\n  }\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>Type</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>\n            <th style={headerCellStyle(\"left\")}>Tx signature</th>\n          </tr>\n        </thead>\n        <tbody>\n          {transactions.map((tx) => (\n            <tr key={tx.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{tx.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip label={tx.txType} tone=\"info\" />\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                {tx.userId ? (\n                  <Link\n                    href={`/users/${tx.userId}`}\n                    style={linkStyle}\n                    title={tx.userId}\n                  >\n                    {tx.username ?? truncate(tx.userId, 12)}\n                  </Link>\n                ) : (\n                  \"—\"\n                )}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={tx.wallet}>{truncate(tx.wallet, 12)}</span>\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(tx.amountLamports)}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={tx.txSig}>{truncate(tx.txSig, 16)}</span>\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction Section({\n  heading,\n  headingId,\n  children,\n}: {\n  heading: string;\n  headingId: string;\n  children: ReactNode;\n}) {\n  return (\n    <section aria-labelledby={headingId} style={sectionStyle}>\n      <h2 id={headingId} style={sectionHeadingStyle}>\n        {heading}\n      </h2>\n      {children}\n    </section>\n  );\n}\n\nfunction SummaryItem({\n  label,\n  children,\n}: {\n  label: string;\n  children: ReactNode;\n}) {\n  return (\n    <div style={summaryItemStyle}>\n      <dt style={summaryLabelStyle}>{label}</dt>\n      <dd style={summaryValueStyle}>{children}</dd>\n    </div>\n  );\n}\n\nfunction Mono({ title, children }: { title: string; children: ReactNode }) {\n  return (\n    <span style={{ fontFamily: \"monospace\" }} title={title}>\n      {typeof children === \"string\" ? truncate(children, 16) : children}\n    </span>\n  );\n}\n\nfunction phaseTone(phase: PeekRoundPhase): PeekStatusTone {\n  if (phase === \"settled\") return \"positive\";\n  if (phase === \"expired\") return \"warning\";\n  if (phase === \"settling\") return \"info\";\n  if (phase === \"locked\") return \"info\";\n  return \"neutral\";\n}\n\nfunction closeCallPhaseTone(phase: PeekCloseCallPhase): PeekStatusTone {\n  if (phase === \"settled\") return \"positive\";\n  if (phase === \"refunded\") return \"warning\";\n  return \"info\";\n}\n\nfunction closeCallOutcomeTone(outcome: PeekCloseCallOutcome): PeekStatusTone {\n  if (outcome === \"green\") return \"positive\";\n  if (outcome === \"red\") return \"negative\";\n  if (outcome === \"refund\") return \"warning\";\n  return \"neutral\";\n}\n\nfunction truncate(value: string, max: number): string {\n  if (value.length <= max) return value;\n  const head = Math.max(2, Math.floor((max - 1) / 2));\n  const tail = Math.max(2, max - 1 - head);\n  return `${value.slice(0, head)}…${value.slice(-tail)}`;\n}\n\nfunction formatNumber(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst codeStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  color: \"#cbd5f5\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n  marginLeft: \"0.25rem\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst summaryGridStyle: CSSProperties = {\n  display: \"grid\",\n  gridTemplateColumns: \"repeat(auto-fit, minmax(220px, 1fr))\",\n  gap: \"0.75rem\",\n  margin: 0,\n  padding: \"1rem\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n  background: \"#0b1220\",\n};\n\nconst summaryItemStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst summaryLabelStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst summaryValueStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#e2e8f0\",\n};\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n  };\n}\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":526,"cache_read_input_tokens":117178,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":526},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"e3ee47e7-eefe-4e12-a068-a08216780c1e","uuid":"7c125dfc-4081-4980-8221-085e96cef1f3"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q19dxecXbGeDw6WUqanKpF","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/components/round-detail-view.tsx"}]},"parent_tool_use_id":null,"session_id":"e3ee47e7-eefe-4e12-a068-a08216780c1e","uuid":"336b264e-e302-45a3-b69e-1ff71485d198","timestamp":"2026-04-25T13:34:53.540Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/components/round-detail-view.tsx","content":"// Round-detail view (FR-8). Server-renderable, props-only component used by\n// `/games/[game]/rounds/[roundId]/page.tsx`. Lives in `src/components` so it\n// can be tested directly with @testing-library/react against a synthetic\n// `PeekRoundDetail` without spinning up the whole route.\n\nimport Link from \"next/link\";\nimport type { CSSProperties, ReactNode } from \"react\";\nimport { StatusChip } from \"./status-chip\";\nimport type {\n  PeekCloseCallOutcome,\n  PeekCloseCallPhase,\n  PeekCloseCallRoundRow,\n  PeekGameId,\n  PeekRoundDetail,\n  PeekRoundEntryRow,\n  PeekRoundPhase,\n  PeekRoundRow,\n  PeekRoundTransactionRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\n\nexport type RoundDetailViewProps = {\n  detail: PeekRoundDetail;\n};\n\nexport function RoundDetailView({ detail }: RoundDetailViewProps) {\n  return (\n    <>\n      <Section heading=\"Round summary\" headingId=\"round-summary-heading\">\n        {detail.game === \"closecall\" ? (\n          <CloseCallSummary round={detail.round} />\n        ) : (\n          <RoundSummary round={detail.round} />\n        )}\n      </Section>\n\n      <Section heading=\"Entries\" headingId=\"entries-heading\">\n        <p style={hintStyle}>\n          {detail.entries.length} participant\n          {detail.entries.length === 1 ? \"\" : \"s\"} from{\" \"}\n          <code style={codeStyle}>game_entries</code> · sorted oldest first.\n        </p>\n        <EntriesTable entries={detail.entries} game={detail.game} />\n      </Section>\n\n      <Section heading=\"Transactions\" headingId=\"transactions-heading\">\n        <p style={hintStyle}>\n          {detail.transactions.length} on-chain SOL movement\n          {detail.transactions.length === 1 ? \"\" : \"s\"} from{\" \"}\n          <code style={codeStyle}>transactions</code> · sorted oldest first.\n        </p>\n        <TransactionsTable transactions={detail.transactions} />\n      </Section>\n    </>\n  );\n}\n\nfunction RoundSummary({ round }: { round: PeekRoundRow }) {\n  return (\n    <dl style={summaryGridStyle}>\n      <SummaryItem label=\"Phase\">\n        <StatusChip label={round.phase} tone={phaseTone(round.phase)} />\n      </SummaryItem>\n      <SummaryItem label=\"Match ID\">\n        <Mono title={round.matchId}>{round.matchId}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"PDA\">\n        <Mono title={round.pda}>{round.pda}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"Creator\">\n        <Mono title={round.creator}>{round.creator}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"Amount (lamports)\">\n        {formatNumber(round.amountLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Target slot\">\n        {round.targetSlot ? formatNumber(round.targetSlot) : \"—\"}\n      </SummaryItem>\n      <SummaryItem label=\"Settle attempts\">\n        {String(round.settleAttempts)}\n      </SummaryItem>\n      <SummaryItem label=\"Result side\">\n        {round.resultSide === null ? \"—\" : String(round.resultSide)}\n      </SummaryItem>\n      <SummaryItem label=\"Winner\">\n        {round.winner ? <Mono title={round.winner}>{round.winner}</Mono> : \"—\"}\n      </SummaryItem>\n      <SummaryItem label=\"Settle tx\">\n        {round.settleTx ? (\n          <Mono title={round.settleTx}>{round.settleTx}</Mono>\n        ) : (\n          \"—\"\n        )}\n      </SummaryItem>\n      <SummaryItem label=\"Created\">{round.createdAt}</SummaryItem>\n      <SummaryItem label=\"Updated\">{round.updatedAt}</SummaryItem>\n      <SummaryItem label=\"Settled\">{round.settledAt ?? \"—\"}</SummaryItem>\n    </dl>\n  );\n}\n\nfunction CloseCallSummary({ round }: { round: PeekCloseCallRoundRow }) {\n  return (\n    <dl style={summaryGridStyle}>\n      <SummaryItem label=\"Phase\">\n        <StatusChip label={round.phase} tone={closeCallPhaseTone(round.phase)} />\n      </SummaryItem>\n      <SummaryItem label=\"Outcome\">\n        <StatusChip\n          label={round.outcome}\n          tone={closeCallOutcomeTone(round.outcome)}\n        />\n      </SummaryItem>\n      <SummaryItem label=\"Round ID\">\n        <Mono title={round.roundId}>{round.roundId}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"PDA\">\n        <Mono title={round.pda}>{round.pda}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"Open price\">\n        {formatNumber(round.openPrice)}\n        <span style={subValueStyle}> · expo {round.openPriceExpo}</span>\n      </SummaryItem>\n      <SummaryItem label=\"Close price\">\n        {round.closePrice ? formatNumber(round.closePrice) : \"—\"}\n      </SummaryItem>\n      <SummaryItem label=\"Green pool (lamports)\">\n        {formatNumber(round.greenPoolLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Red pool (lamports)\">\n        {formatNumber(round.redPoolLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Total fee (lamports)\">\n        {formatNumber(round.totalFeeLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Settle tx\">\n        {round.settleTx ? (\n          <Mono title={round.settleTx}>{round.settleTx}</Mono>\n        ) : (\n          \"—\"\n        )}\n      </SummaryItem>\n      <SummaryItem label=\"Created\">{round.createdAt}</SummaryItem>\n      <SummaryItem label=\"Settled\">{round.settledAt ?? \"—\"}</SummaryItem>\n    </dl>\n  );\n}\n\nfunction EntriesTable({\n  entries,\n  game,\n}: {\n  entries: ReadonlyArray<PeekRoundEntryRow>;\n  game: PeekGameId;\n}) {\n  if (entries.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No entries recorded for this round.</p>\n        <p style={emptyBodyStyle}>\n          The <code style={codeStyle}>game_entries</code> table has no rows\n          joined to this round PDA. This is normal for rounds that were created\n          but never joined.\n        </p>\n      </div>\n    );\n  }\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>\n            <th style={headerCellStyle(\"left\")}>\n              {game === \"closecall\" ? \"Side\" : \"Side\"}\n            </th>\n            <th style={headerCellStyle(\"left\")}>Winner</th>\n            <th style={headerCellStyle(\"right\")}>Payout (lamports)</th>\n            <th style={headerCellStyle(\"left\")}>Settled</th>\n          </tr>\n        </thead>\n        <tbody>\n          {entries.map((entry) => (\n            <tr key={entry.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{entry.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <Link\n                  href={`/users/${entry.userId}`}\n                  style={linkStyle}\n                  title={entry.userId}\n                >\n                  {entry.username ?? truncate(entry.userId, 12)}\n                </Link>\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={entry.wallet}>{truncate(entry.wallet, 12)}</span>\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(entry.amountLamports)}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{entry.side ?? \"—\"}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                {entry.isWinner === null ? \"—\" : entry.isWinner ? \"yes\" : \"no\"}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(entry.payoutLamports)}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{entry.settledAt ?? \"—\"}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction TransactionsTable({\n  transactions,\n}: {\n  transactions: ReadonlyArray<PeekRoundTransactionRow>;\n}) {\n  if (transactions.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No transactions recorded for this round.</p>\n        <p style={emptyBodyStyle}>\n          The <code style={codeStyle}>transactions</code> table has no rows\n          joined to this round. Settled rounds without transaction rows are an\n          attention state surfaced by the stuck-state filters on{\" \"}\n          <code style={codeStyle}>/games/[game]</code>.\n        </p>\n      </div>\n    );\n  }\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>Type</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>\n            <th style={headerCellStyle(\"left\")}>Tx signature</th>\n          </tr>\n        </thead>\n        <tbody>\n          {transactions.map((tx) => (\n            <tr key={tx.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{tx.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip label={tx.txType} tone=\"info\" />\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                {tx.userId ? (\n                  <Link\n                    href={`/users/${tx.userId}`}\n                    style={linkStyle}\n                    title={tx.userId}\n                  >\n                    {tx.username ?? truncate(tx.userId, 12)}\n                  </Link>\n                ) : (\n                  \"—\"\n                )}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={tx.wallet}>{truncate(tx.wallet, 12)}</span>\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(tx.amountLamports)}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={tx.txSig}>{truncate(tx.txSig, 16)}</span>\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction Section({\n  heading,\n  headingId,\n  children,\n}: {\n  heading: string;\n  headingId: string;\n  children: ReactNode;\n}) {\n  return (\n    <section aria-labelledby={headingId} style={sectionStyle}>\n      <h2 id={headingId} style={sectionHeadingStyle}>\n        {heading}\n      </h2>\n      {children}\n    </section>\n  );\n}\n\nfunction SummaryItem({\n  label,\n  children,\n}: {\n  label: string;\n  children: ReactNode;\n}) {\n  return (\n    <div style={summaryItemStyle}>\n      <dt style={summaryLabelStyle}>{label}</dt>\n      <dd style={summaryValueStyle}>{children}</dd>\n    </div>\n  );\n}\n\nfunction Mono({ title, children }: { title: string; children: ReactNode }) {\n  return (\n    <span style={{ fontFamily: \"monospace\" }} title={title}>\n      {typeof children === \"string\" ? truncate(children, 16) : children}\n    </span>\n  );\n}\n\nfunction phaseTone(phase: PeekRoundPhase): PeekStatusTone {\n  if (phase === \"settled\") return \"positive\";\n  if (phase === \"expired\") return \"warning\";\n  if (phase === \"settling\") return \"info\";\n  if (phase === \"locked\") return \"info\";\n  return \"neutral\";\n}\n\nfunction closeCallPhaseTone(phase: PeekCloseCallPhase): PeekStatusTone {\n  if (phase === \"settled\") return \"positive\";\n  if (phase === \"refunded\") return \"warning\";\n  return \"info\";\n}\n\nfunction closeCallOutcomeTone(outcome: PeekCloseCallOutcome): PeekStatusTone {\n  if (outcome === \"green\") return \"positive\";\n  if (outcome === \"red\") return \"negative\";\n  if (outcome === \"refund\") return \"warning\";\n  return \"neutral\";\n}\n\nfunction truncate(value: string, max: number): string {\n  if (value.length <= max) return value;\n  const head = Math.max(2, Math.floor((max - 1) / 2));\n  const tail = Math.max(2, max - 1 - head);\n  return `${value.slice(0, head)}…${value.slice(-tail)}`;\n}\n\nfunction formatNumber(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst codeStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  color: \"#cbd5f5\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n  marginLeft: \"0.25rem\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst summaryGridStyle: CSSProperties = {\n  display: \"grid\",\n  gridTemplateColumns: \"repeat(auto-fit, minmax(220px, 1fr))\",\n  gap: \"0.75rem\",\n  margin: 0,\n  padding: \"1rem\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n  background: \"#0b1220\",\n};\n\nconst summaryItemStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst summaryLabelStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst summaryValueStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#e2e8f0\",\n};\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n  };\n}\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","structuredPatch":[],"originalFile":null,"userModified":false}}
