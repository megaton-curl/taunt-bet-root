{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R5FVmrpiwEWuBko5g6CqSb","type":"tool_result","content":"1\t// Round detail query (FR-8).\n2\t//\n3\t// Backs `/games/[game]/rounds/[roundId]`. Resolves the round summary by `pda`\n4\t// in the appropriate table — `rounds` for FlipYou + Pot Shot, `closecall_rounds`\n5\t// for Close Call — then joins the per-round `game_entries` and `transactions`\n6\t// rows so the operator can audit who participated and which on-chain SOL\n7\t// movements settled the round.\n8\t//\n9\t// `match_id` resolution differs by table: FlipYou + Pot Shot rounds carry it\n10\t// in `rounds.match_id`; Close Call uses the `round_id` PK as the match id in\n11\t// `transactions`. Entries match on `round_pda` directly (no per-game pivot).\n12\t//\n13\t// Returns `null` if the round is not found in the table for the given game id.\n14\t// All numeric/precision-sensitive values arrive as `text` to preserve u64\n15\t// precision; the UI formats at render time.\n16\t\n17\timport type { Sql } from \"postgres\";\n18\timport {\n19\t  PEEK_ROUNDS_GAME_IDS,\n20\t  type PeekCloseCallOutcome,\n21\t  type PeekCloseCallPhase,\n22\t  type PeekCloseCallRoundRow,\n23\t  type PeekGameId,\n24\t  type PeekRoundDetail,\n25\t  type PeekRoundEntryRow,\n26\t  type PeekRoundPhase,\n27\t  type PeekRoundRow,\n28\t  type PeekRoundTransactionRow,\n29\t  type PeekRoundsGameId,\n30\t} from \"../../../lib/types/peek\";\n31\timport { getSqlClient } from \"../client\";\n32\t\n33\texport type GetRoundDetailOptions = {\n34\t  sql?: Sql;\n35\t  game: PeekGameId;\n36\t  // Stable on-chain round identifier used as the URL param. For all 3 games\n37\t  // this is the `pda` (rounds.pda PK for FlipYou/Pot Shot, closecall_rounds.pda\n38\t  // unique-not-null for Close Call) so route paths stay uniform across games.\n39\t  roundId: string;\n40\t};\n41\t\n42\tfunction readInt(value: number | string | null | undefined): number {\n43\t  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n44\t  if (typeof value === \"string\") {\n45\t    const parsed = Number.parseInt(value, 10);\n46\t    return Number.isFinite(parsed) ? parsed : 0;\n47\t  }\n48\t  return 0;\n49\t}\n50\t\n51\tfunction isPeekRoundsGameId(value: string): value is PeekRoundsGameId {\n52\t  return (PEEK_ROUNDS_GAME_IDS as ReadonlyArray<string>).includes(value);\n53\t}\n54\t\n55\t// ---------- Round summary (FlipYou + Pot Shot) -------------------------------\n56\t\n57\ttype RawRoundRow = {\n58\t  pda: string;\n59\t  game: string;\n60\t  matchId: string;\n61\t  phase: string;\n62\t  creator: string;\n63\t  targetSlot: string | null;\n64\t  settleAttempts: number | string;\n65\t  settleTx: string | null;\n66\t  resultSide: number | string | null;\n67\t  winner: string | null;\n68\t  amountLamports: string;\n69\t  createdAt: string;\n70\t  updatedAt: string;\n71\t  settledAt: string | null;\n72\t};\n73\t\n74\tfunction normalizeRoundRow(row: RawRoundRow): PeekRoundRow | null {\n75\t  if (!isPeekRoundsGameId(row.game)) return null;\n76\t  return {\n77\t    game: row.game,\n78\t    pda: row.pda,\n79\t    matchId: row.matchId,\n80\t    phase: row.phase as PeekRoundPhase,\n81\t    creator: row.creator,\n82\t    targetSlot: row.targetSlot,\n83\t    settleAttempts: readInt(row.settleAttempts),\n84\t    settleTx: row.settleTx,\n85\t    resultSide:\n86\t      row.resultSide === null || row.resultSide === undefined\n87\t        ? null\n88\t        : readInt(row.resultSide),\n89\t    winner: row.winner,\n90\t    amountLamports:\n91\t      typeof row.amountLamports === \"string\" ? row.amountLamports : \"0\",\n92\t    createdAt: row.createdAt,\n93\t    updatedAt: row.updatedAt,\n94\t    settledAt: row.settledAt,\n95\t  };\n96\t}\n97\t\n98\t// ---------- Round summary (Close Call) ---------------------------------------\n99\t\n100\ttype RawCloseCallRoundRow = {\n101\t  pda: string;\n102\t  roundId: string;\n103\t  phase: string;\n104\t  outcome: string;\n105\t  openPrice: string;\n106\t  openPriceExpo: number | string;\n107\t  closePrice: string | null;\n108\t  greenPoolLamports: string;\n109\t  redPoolLamports: string;\n110\t  totalFeeLamports: string;\n111\t  settleTx: string | null;\n112\t  createdAt: string;\n113\t  settledAt: string | null;\n114\t};\n115\t\n116\tfunction normalizeCloseCallRow(\n117\t  row: RawCloseCallRoundRow,\n118\t): PeekCloseCallRoundRow {\n119\t  return {\n120\t    pda: row.pda,\n121\t    roundId: row.roundId,\n122\t    phase: row.phase as PeekCloseCallPhase,\n123\t    outcome: row.outcome as PeekCloseCallOutcome,\n124\t    openPrice: typeof row.openPrice === \"string\" ? row.openPrice : \"0\",\n125\t    openPriceExpo: readInt(row.openPriceExpo),\n126\t    closePrice: row.closePrice,\n127\t    greenPoolLamports:\n128\t      typeof row.greenPoolLamports === \"string\" ? row.greenPoolLamports : \"0\",\n129\t    redPoolLamports:\n130\t      typeof row.redPoolLamports === \"string\" ? row.redPoolLamports : \"0\",\n131\t    totalFeeLamports:\n132\t      typeof row.totalFeeLamports === \"string\" ? row.totalFeeLamports : \"0\",\n133\t    settleTx: row.settleTx,\n134\t    createdAt: row.createdAt,\n135\t    settledAt: row.settledAt,\n136\t  };\n137\t}\n138\t\n139\t// ---------- Entries + transactions (shared shapes) ---------------------------\n140\t\n141\ttype RawEntryRow = {\n142\t  id: string | number;\n143\t  userId: string;\n144\t  username: string | null;\n145\t  wallet: string;\n146\t  amountLamports: string;\n147\t  side: string | null;\n148\t  isWinner: boolean | null;\n149\t  payoutLamports: string;\n150\t  createdAt: string;\n151\t  settledAt: string | null;\n152\t};\n153\t\n154\tfunction normalizeEntryRow(row: RawEntryRow): PeekRoundEntryRow {\n155\t  return {\n156\t    id: typeof row.id === \"string\" ? row.id : String(row.id),\n157\t    userId: row.userId,\n158\t    username: row.username,\n159\t    wallet: row.wallet,\n160\t    amountLamports:\n161\t      typeof row.amountLamports === \"string\" ? row.amountLamports : \"0\",\n162\t    side: row.side,\n163\t    isWinner: row.isWinner,\n164\t    payoutLamports:\n165\t      typeof row.payoutLamports === \"string\" ? row.payoutLamports : \"0\",\n166\t    createdAt: row.createdAt,\n167\t    settledAt: row.settledAt,\n168\t  };\n169\t}\n170\t\n171\ttype RawTransactionRow = {\n172\t  id: string | number;\n173\t  userId: string | null;\n174\t  username: string | null;\n175\t  wallet: string;\n176\t  txType: string;\n177\t  amountLamports: string;\n178\t  txSig: string;\n179\t  createdAt: string;\n180\t};\n181\t\n182\tfunction normalizeTransactionRow(\n183\t  row: RawTransactionRow,\n184\t): PeekRoundTransactionRow {\n185\t  return {\n186\t    id: typeof row.id === \"string\" ? row.id : String(row.id),\n187\t    userId: row.userId,\n188\t    username: row.username,\n189\t    wallet: row.wallet,\n190\t    txType: row.txType,\n191\t    amountLamports:\n192\t      typeof row.amountLamports === \"string\" ? row.amountLamports : \"0\",\n193\t    txSig: row.txSig,\n194\t    createdAt: row.createdAt,\n195\t  };\n196\t}\n197\t\n198\t// ---------- Public API -------------------------------------------------------\n199\t\n200\texport async function getRoundDetail(\n201\t  options: GetRoundDetailOptions,\n202\t): Promise<PeekRoundDetail | null> {\n203\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n204\t  const { game, roundId } = options;\n205\t\n206\t  if (game === \"closecall\") {\n207\t    const ccRows = await sql<RawCloseCallRoundRow[]>`\n208\t      select\n209\t        cc.pda as \"pda\",\n210\t        cc.round_id as \"roundId\",\n211\t        cc.phase as \"phase\",\n212\t        cc.outcome as \"outcome\",\n213\t        cc.open_price::text as \"openPrice\",\n214\t        cc.open_price_expo as \"openPriceExpo\",\n215\t        cc.close_price::text as \"closePrice\",\n216\t        cc.green_pool::text as \"greenPoolLamports\",\n217\t        cc.red_pool::text as \"redPoolLamports\",\n218\t        cc.total_fee::text as \"totalFeeLamports\",\n219\t        cc.settle_tx as \"settleTx\",\n220\t        cc.created_at::text as \"createdAt\",\n221\t        cc.settled_at::text as \"settledAt\"\n222\t      from closecall_rounds cc\n223\t      where cc.pda = ${roundId}\n224\t      limit 1\n225\t    `;\n226\t    if (ccRows.length === 0) return null;\n227\t    const round = normalizeCloseCallRow(ccRows[0]);\n228\t\n229\t    const [entries, transactions] = await Promise.all([\n230\t      fetchEntries(sql, round.pda),\n231\t      fetchTransactions(sql, \"closecall\", round.roundId),\n232\t    ]);\n233\t\n234\t    return { game: \"closecall\", round, entries, transactions };\n235\t  }\n236\t\n237\t  // FlipYou + Pot Shot.\n238\t  if (!isPeekRoundsGameId(game)) return null;\n239\t\n240\t  const rRows = await sql<RawRoundRow[]>`\n241\t    select\n242\t      r.pda as \"pda\",\n243\t      r.game as \"game\",\n244\t      r.match_id as \"matchId\",\n245\t      r.phase as \"phase\",\n246\t      r.creator as \"creator\",\n247\t      r.target_slot::text as \"targetSlot\",\n248\t      r.settle_attempts as \"settleAttempts\",\n249\t      r.settle_tx as \"settleTx\",\n250\t      r.result_side as \"resultSide\",\n251\t      r.winner as \"winner\",\n252\t      r.amount_lamports::text as \"amountLamports\",\n253\t      r.created_at::text as \"createdAt\",\n254\t      r.updated_at::text as \"updatedAt\",\n255\t      r.settled_at::text as \"settledAt\"\n256\t    from rounds r\n257\t    where r.pda = ${roundId}\n258\t      and r.game = ${game}\n259\t    limit 1\n260\t  `;\n261\t  if (rRows.length === 0) return null;\n262\t  const round = normalizeRoundRow(rRows[0]);\n263\t  if (!round) return null;\n264\t\n265\t  const [entries, transactions] = await Promise.all([\n266\t    fetchEntries(sql, round.pda),\n267\t    fetchTransactions(sql, round.game, round.matchId),\n268\t  ]);\n269\t\n270\t  return { game: round.game, round, entries, transactions };\n271\t}\n272\t\n273\tasync function fetchEntries(\n274\t  sql: Sql,\n275\t  roundPda: string,\n276\t): Promise<ReadonlyArray<PeekRoundEntryRow>> {\n277\t  const rows = await sql<RawEntryRow[]>`\n278\t    select\n279\t      ge.id::text as \"id\",\n280\t      ge.user_id as \"userId\",\n281\t      pp.username as \"username\",\n282\t      ge.wallet as \"wallet\",\n283\t      ge.amount_lamports::text as \"amountLamports\",\n284\t      ge.side as \"side\",\n285\t      ge.is_winner as \"isWinner\",\n286\t      ge.payout_lamports::text as \"payoutLamports\",\n287\t      ge.created_at::text as \"createdAt\",\n288\t      ge.settled_at::text as \"settledAt\"\n289\t    from game_entries ge\n290\t    left join player_profiles pp on pp.user_id = ge.user_id\n291\t    where ge.round_pda = ${roundPda}\n292\t    order by ge.created_at asc, ge.id asc\n293\t  `;\n294\t  return rows.map(normalizeEntryRow);\n295\t}\n296\t\n297\tasync function fetchTransactions(\n298\t  sql: Sql,\n299\t  game: PeekGameId,\n300\t  matchId: string,\n301\t): Promise<ReadonlyArray<PeekRoundTransactionRow>> {\n302\t  const rows = await sql<RawTransactionRow[]>`\n303\t    select\n304\t      t.id::text as \"id\",\n305\t      t.user_id as \"userId\",\n306\t      pp.username as \"username\",\n307\t      t.wallet as \"wallet\",\n308\t      t.tx_type as \"txType\",\n309\t      t.amount_lamports::text as \"amountLamports\",\n310\t      t.tx_sig as \"txSig\",\n311\t      t.created_at::text as \"createdAt\"\n312\t    from transactions t\n313\t    left join player_profiles pp on pp.user_id = t.user_id\n314\t    where t.game = ${game}\n315\t      and t.match_id = ${matchId}\n316\t    order by t.created_at asc, t.id asc\n317\t  `;\n318\t  return rows.map(normalizeTransactionRow);\n319\t}\n320\t"}]},"parent_tool_use_id":null,"session_id":"e3ee47e7-eefe-4e12-a068-a08216780c1e","uuid":"72dad6a7-f798-47b0-bf1a-0bf254ea7d5d","timestamp":"2026-04-25T13:31:15.261Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-round-detail.ts","content":"// Round detail query (FR-8).\n//\n// Backs `/games/[game]/rounds/[roundId]`. Resolves the round summary by `pda`\n// in the appropriate table — `rounds` for FlipYou + Pot Shot, `closecall_rounds`\n// for Close Call — then joins the per-round `game_entries` and `transactions`\n// rows so the operator can audit who participated and which on-chain SOL\n// movements settled the round.\n//\n// `match_id` resolution differs by table: FlipYou + Pot Shot rounds carry it\n// in `rounds.match_id`; Close Call uses the `round_id` PK as the match id in\n// `transactions`. Entries match on `round_pda` directly (no per-game pivot).\n//\n// Returns `null` if the round is not found in the table for the given game id.\n// All numeric/precision-sensitive values arrive as `text` to preserve u64\n// precision; the UI formats at render time.\n\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_ROUNDS_GAME_IDS,\n  type PeekCloseCallOutcome,\n  type PeekCloseCallPhase,\n  type PeekCloseCallRoundRow,\n  type PeekGameId,\n  type PeekRoundDetail,\n  type PeekRoundEntryRow,\n  type PeekRoundPhase,\n  type PeekRoundRow,\n  type PeekRoundTransactionRow,\n  type PeekRoundsGameId,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport type GetRoundDetailOptions = {\n  sql?: Sql;\n  game: PeekGameId;\n  // Stable on-chain round identifier used as the URL param. For all 3 games\n  // this is the `pda` (rounds.pda PK for FlipYou/Pot Shot, closecall_rounds.pda\n  // unique-not-null for Close Call) so route paths stay uniform across games.\n  roundId: string;\n};\n\nfunction readInt(value: number | string | null | undefined): number {\n  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n  if (typeof value === \"string\") {\n    const parsed = Number.parseInt(value, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction isPeekRoundsGameId(value: string): value is PeekRoundsGameId {\n  return (PEEK_ROUNDS_GAME_IDS as ReadonlyArray<string>).includes(value);\n}\n\n// ---------- Round summary (FlipYou + Pot Shot) -------------------------------\n\ntype RawRoundRow = {\n  pda: string;\n  game: string;\n  matchId: string;\n  phase: string;\n  creator: string;\n  targetSlot: string | null;\n  settleAttempts: number | string;\n  settleTx: string | null;\n  resultSide: number | string | null;\n  winner: string | null;\n  amountLamports: string;\n  createdAt: string;\n  updatedAt: string;\n  settledAt: string | null;\n};\n\nfunction normalizeRoundRow(row: RawRoundRow): PeekRoundRow | null {\n  if (!isPeekRoundsGameId(row.game)) return null;\n  return {\n    game: row.game,\n    pda: row.pda,\n    matchId: row.matchId,\n    phase: row.phase as PeekRoundPhase,\n    creator: row.creator,\n    targetSlot: row.targetSlot,\n    settleAttempts: readInt(row.settleAttempts),\n    settleTx: row.settleTx,\n    resultSide:\n      row.resultSide === null || row.resultSide === undefined\n        ? null\n        : readInt(row.resultSide),\n    winner: row.winner,\n    amountLamports:\n      typeof row.amountLamports === \"string\" ? row.amountLamports : \"0\",\n    createdAt: row.createdAt,\n    updatedAt: row.updatedAt,\n    settledAt: row.settledAt,\n  };\n}\n\n// ---------- Round summary (Close Call) ---------------------------------------\n\ntype RawCloseCallRoundRow = {\n  pda: string;\n  roundId: string;\n  phase: string;\n  outcome: string;\n  openPrice: string;\n  openPriceExpo: number | string;\n  closePrice: string | null;\n  greenPoolLamports: string;\n  redPoolLamports: string;\n  totalFeeLamports: string;\n  settleTx: string | null;\n  createdAt: string;\n  settledAt: string | null;\n};\n\nfunction normalizeCloseCallRow(\n  row: RawCloseCallRoundRow,\n): PeekCloseCallRoundRow {\n  return {\n    pda: row.pda,\n    roundId: row.roundId,\n    phase: row.phase as PeekCloseCallPhase,\n    outcome: row.outcome as PeekCloseCallOutcome,\n    openPrice: typeof row.openPrice === \"string\" ? row.openPrice : \"0\",\n    openPriceExpo: readInt(row.openPriceExpo),\n    closePrice: row.closePrice,\n    greenPoolLamports:\n      typeof row.greenPoolLamports === \"string\" ? row.greenPoolLamports : \"0\",\n    redPoolLamports:\n      typeof row.redPoolLamports === \"string\" ? row.redPoolLamports : \"0\",\n    totalFeeLamports:\n      typeof row.totalFeeLamports === \"string\" ? row.totalFeeLamports : \"0\",\n    settleTx: row.settleTx,\n    createdAt: row.createdAt,\n    settledAt: row.settledAt,\n  };\n}\n\n// ---------- Entries + transactions (shared shapes) ---------------------------\n\ntype RawEntryRow = {\n  id: string | number;\n  userId: string;\n  username: string | null;\n  wallet: string;\n  amountLamports: string;\n  side: string | null;\n  isWinner: boolean | null;\n  payoutLamports: string;\n  createdAt: string;\n  settledAt: string | null;\n};\n\nfunction normalizeEntryRow(row: RawEntryRow): PeekRoundEntryRow {\n  return {\n    id: typeof row.id === \"string\" ? row.id : String(row.id),\n    userId: row.userId,\n    username: row.username,\n    wallet: row.wallet,\n    amountLamports:\n      typeof row.amountLamports === \"string\" ? row.amountLamports : \"0\",\n    side: row.side,\n    isWinner: row.isWinner,\n    payoutLamports:\n      typeof row.payoutLamports === \"string\" ? row.payoutLamports : \"0\",\n    createdAt: row.createdAt,\n    settledAt: row.settledAt,\n  };\n}\n\ntype RawTransactionRow = {\n  id: string | number;\n  userId: string | null;\n  username: string | null;\n  wallet: string;\n  txType: string;\n  amountLamports: string;\n  txSig: string;\n  createdAt: string;\n};\n\nfunction normalizeTransactionRow(\n  row: RawTransactionRow,\n): PeekRoundTransactionRow {\n  return {\n    id: typeof row.id === \"string\" ? row.id : String(row.id),\n    userId: row.userId,\n    username: row.username,\n    wallet: row.wallet,\n    txType: row.txType,\n    amountLamports:\n      typeof row.amountLamports === \"string\" ? row.amountLamports : \"0\",\n    txSig: row.txSig,\n    createdAt: row.createdAt,\n  };\n}\n\n// ---------- Public API -------------------------------------------------------\n\nexport async function getRoundDetail(\n  options: GetRoundDetailOptions,\n): Promise<PeekRoundDetail | null> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const { game, roundId } = options;\n\n  if (game === \"closecall\") {\n    const ccRows = await sql<RawCloseCallRoundRow[]>`\n      select\n        cc.pda as \"pda\",\n        cc.round_id as \"roundId\",\n        cc.phase as \"phase\",\n        cc.outcome as \"outcome\",\n        cc.open_price::text as \"openPrice\",\n        cc.open_price_expo as \"openPriceExpo\",\n        cc.close_price::text as \"closePrice\",\n        cc.green_pool::text as \"greenPoolLamports\",\n        cc.red_pool::text as \"redPoolLamports\",\n        cc.total_fee::text as \"totalFeeLamports\",\n        cc.settle_tx as \"settleTx\",\n        cc.created_at::text as \"createdAt\",\n        cc.settled_at::text as \"settledAt\"\n      from closecall_rounds cc\n      where cc.pda = ${roundId}\n      limit 1\n    `;\n    if (ccRows.length === 0) return null;\n    const round = normalizeCloseCallRow(ccRows[0]);\n\n    const [entries, transactions] = await Promise.all([\n      fetchEntries(sql, round.pda),\n      fetchTransactions(sql, \"closecall\", round.roundId),\n    ]);\n\n    return { game: \"closecall\", round, entries, transactions };\n  }\n\n  // FlipYou + Pot Shot.\n  if (!isPeekRoundsGameId(game)) return null;\n\n  const rRows = await sql<RawRoundRow[]>`\n    select\n      r.pda as \"pda\",\n      r.game as \"game\",\n      r.match_id as \"matchId\",\n      r.phase as \"phase\",\n      r.creator as \"creator\",\n      r.target_slot::text as \"targetSlot\",\n      r.settle_attempts as \"settleAttempts\",\n      r.settle_tx as \"settleTx\",\n      r.result_side as \"resultSide\",\n      r.winner as \"winner\",\n      r.amount_lamports::text as \"amountLamports\",\n      r.created_at::text as \"createdAt\",\n      r.updated_at::text as \"updatedAt\",\n      r.settled_at::text as \"settledAt\"\n    from rounds r\n    where r.pda = ${roundId}\n      and r.game = ${game}\n    limit 1\n  `;\n  if (rRows.length === 0) return null;\n  const round = normalizeRoundRow(rRows[0]);\n  if (!round) return null;\n\n  const [entries, transactions] = await Promise.all([\n    fetchEntries(sql, round.pda),\n    fetchTransactions(sql, round.game, round.matchId),\n  ]);\n\n  return { game: round.game, round, entries, transactions };\n}\n\nasync function fetchEntries(\n  sql: Sql,\n  roundPda: string,\n): Promise<ReadonlyArray<PeekRoundEntryRow>> {\n  const rows = await sql<RawEntryRow[]>`\n    select\n      ge.id::text as \"id\",\n      ge.user_id as \"userId\",\n      pp.username as \"username\",\n      ge.wallet as \"wallet\",\n      ge.amount_lamports::text as \"amountLamports\",\n      ge.side as \"side\",\n      ge.is_winner as \"isWinner\",\n      ge.payout_lamports::text as \"payoutLamports\",\n      ge.created_at::text as \"createdAt\",\n      ge.settled_at::text as \"settledAt\"\n    from game_entries ge\n    left join player_profiles pp on pp.user_id = ge.user_id\n    where ge.round_pda = ${roundPda}\n    order by ge.created_at asc, ge.id asc\n  `;\n  return rows.map(normalizeEntryRow);\n}\n\nasync function fetchTransactions(\n  sql: Sql,\n  game: PeekGameId,\n  matchId: string,\n): Promise<ReadonlyArray<PeekRoundTransactionRow>> {\n  const rows = await sql<RawTransactionRow[]>`\n    select\n      t.id::text as \"id\",\n      t.user_id as \"userId\",\n      pp.username as \"username\",\n      t.wallet as \"wallet\",\n      t.tx_type as \"txType\",\n      t.amount_lamports::text as \"amountLamports\",\n      t.tx_sig as \"txSig\",\n      t.created_at::text as \"createdAt\"\n    from transactions t\n    left join player_profiles pp on pp.user_id = t.user_id\n    where t.game = ${game}\n      and t.match_id = ${matchId}\n    order by t.created_at asc, t.id asc\n  `;\n  return rows.map(normalizeTransactionRow);\n}\n","numLines":320,"startLine":1,"totalLines":320}}}
