{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01VTpYzNEDNyrSpzZd2EFxDW","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01SpQd2gcm3P7bFjD3YP5GUq","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/__tests__/round-detail-view.test.tsx","content":"import { describe, expect, it } from \"vitest\";\nimport { render, screen, within } from \"@testing-library/react\";\nimport { RoundDetailView } from \"../round-detail-view\";\nimport type {\n  PeekCloseCallRoundRow,\n  PeekRoundDetail,\n  PeekRoundEntryRow,\n  PeekRoundRow,\n  PeekRoundTransactionRow,\n} from \"../../lib/types/peek\";\n\nfunction flipyouRound(overrides: Partial<PeekRoundRow> = {}): PeekRoundRow {\n  return {\n    game: \"flipyou\",\n    pda: \"pda-flipyou-1\",\n    matchId: \"match-flipyou-1\",\n    phase: \"settled\",\n    creator: \"creator-flipyou-1\",\n    targetSlot: \"1234567890\",\n    settleAttempts: 1,\n    settleTx: \"tx-settle-flipyou\",\n    resultSide: 0,\n    winner: \"creator-flipyou-1\",\n    amountLamports: \"9007199254740992\",\n    createdAt: \"2026-04-25T10:00:00.000Z\",\n    updatedAt: \"2026-04-25T10:01:00.000Z\",\n    settledAt: \"2026-04-25T10:00:30.000Z\",\n    ...overrides,\n  };\n}\n\nfunction potshotRound(overrides: Partial<PeekRoundRow> = {}): PeekRoundRow {\n  return {\n    ...flipyouRound(),\n    game: \"potshot\",\n    pda: \"pda-potshot-1\",\n    matchId: \"match-potshot-1\",\n    creator: \"creator-potshot-1\",\n    winner: \"creator-potshot-1\",\n    settleTx: \"tx-settle-potshot\",\n    ...overrides,\n  };\n}\n\nfunction closecallRound(\n  overrides: Partial<PeekCloseCallRoundRow> = {},\n): PeekCloseCallRoundRow {\n  return {\n    pda: \"pda-cc-1\",\n    roundId: \"rd-1\",\n    phase: \"settled\",\n    outcome: \"green\",\n    openPrice: \"65000000000\",\n    openPriceExpo: -8,\n    closePrice: \"66000000000\",\n    greenPoolLamports: \"1000000\",\n    redPoolLamports: \"750000\",\n    totalFeeLamports: \"50000\",\n    settleTx: \"cc-tx-1\",\n    createdAt: \"2026-04-25T10:00:00.000Z\",\n    settledAt: \"2026-04-25T10:05:00.000Z\",\n    ...overrides,\n  };\n}\n\nfunction entry(overrides: Partial<PeekRoundEntryRow> = {}): PeekRoundEntryRow {\n  return {\n    id: \"entry-1\",\n    userId: \"user-id-aaaaaaaaaaaaaaaaaa\",\n    username: \"alice\",\n    wallet: \"wallet-aaaaaaaaaaaaaaaaaa\",\n    amountLamports: \"9007199254740992\",\n    side: \"0\",\n    isWinner: true,\n    payoutLamports: \"18000000000000000\",\n    createdAt: \"2026-04-25T10:00:05.000Z\",\n    settledAt: \"2026-04-25T10:00:30.000Z\",\n    ...overrides,\n  };\n}\n\nfunction tx(\n  overrides: Partial<PeekRoundTransactionRow> = {},\n): PeekRoundTransactionRow {\n  return {\n    id: \"tx-1\",\n    userId: \"user-id-aaaaaaaaaaaaaaaaaa\",\n    username: \"alice\",\n    wallet: \"wallet-aaaaaaaaaaaaaaaaaa\",\n    txType: \"payout\",\n    amountLamports: \"18000000000000000\",\n    txSig: \"txsig-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\",\n    createdAt: \"2026-04-25T10:00:30.000Z\",\n    ...overrides,\n  };\n}\n\ndescribe(\"RoundDetailView — FlipYou (full)\", () => {\n  it(\"renders all round summary fields, entries table, and transactions table\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound(),\n      entries: [entry()],\n      transactions: [tx()],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    // Summary section is present + uses the right heading id.\n    expect(\n      screen.getByRole(\"heading\", { name: /round summary/i }),\n    ).toBeInTheDocument();\n    expect(screen.getByText(\"Phase\")).toBeInTheDocument();\n    expect(screen.getByText(\"Match ID\")).toBeInTheDocument();\n    expect(screen.getByText(\"PDA\")).toBeInTheDocument();\n    expect(screen.getByText(\"Creator\")).toBeInTheDocument();\n    expect(screen.getByText(\"Amount (lamports)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Target slot\")).toBeInTheDocument();\n    expect(screen.getByText(\"Settle attempts\")).toBeInTheDocument();\n    expect(screen.getByText(\"Result side\")).toBeInTheDocument();\n    expect(screen.getByText(\"Winner\")).toBeInTheDocument();\n    expect(screen.getByText(\"Settle tx\")).toBeInTheDocument();\n    expect(screen.getByText(\"Created\")).toBeInTheDocument();\n    expect(screen.getByText(\"Updated\")).toBeInTheDocument();\n    expect(screen.getByText(\"Settled\")).toBeInTheDocument();\n\n    // Phase status chip renders with the literal label.\n    expect(screen.getAllByText(\"settled\").length).toBeGreaterThan(0);\n\n    // u64 lamport amount > Number.MAX_SAFE_INTEGER renders with thousands\n    // separators and preserves the underlying digits.\n    expect(screen.getByText(\"9,007,199,254,740,992\")).toBeInTheDocument();\n\n    // Entries section header + count hint.\n    expect(\n      screen.getByRole(\"heading\", { name: /entries/i }),\n    ).toBeInTheDocument();\n    expect(\n      screen.getByText(/1 participant/i, { selector: \"p\" }),\n    ).toBeInTheDocument();\n\n    // Transactions section header + count hint (singular \"movement\").\n    expect(\n      screen.getByRole(\"heading\", { name: /transactions/i }),\n    ).toBeInTheDocument();\n    expect(\n      screen.getByText(/1 on-chain SOL movement/i, { selector: \"p\" }),\n    ).toBeInTheDocument();\n\n    // Entry user link points at /users/[userId] with FR-6 drill-down.\n    const userLinks = screen.getAllByRole(\"link\", { name: \"alice\" });\n    expect(userLinks.length).toBeGreaterThan(0);\n    expect(userLinks[0]).toHaveAttribute(\n      \"href\",\n      \"/users/user-id-aaaaaaaaaaaaaaaaaa\",\n    );\n  });\n\n  it(\"formats lamports with thousands separators while preserving '0' literal for measured zeros\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound({\n        amountLamports: \"0\",\n        targetSlot: \"0\",\n      }),\n      entries: [\n        entry({\n          amountLamports: \"0\",\n          payoutLamports: \"0\",\n          isWinner: false,\n        }),\n      ],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    // Multiple \"0\" cells (amount, target slot, entry amount, entry payout, etc.)\n    expect(screen.getAllByText(\"0\").length).toBeGreaterThan(0);\n  });\n\n  it(\"renders em-dashes for null target slot, settle tx, result side, winner, and settled at\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound({\n        targetSlot: null,\n        settleTx: null,\n        resultSide: null,\n        winner: null,\n        settledAt: null,\n        phase: \"created\",\n      }),\n      entries: [],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    // 5 nullable fields → at least 5 em-dashes inside the summary alone.\n    // Use a count assertion instead of an exact integer to stay resilient\n    // to additional null fields that other states may add.\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(5);\n  });\n\n  it(\"renders the entries empty state when entries are empty\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound(),\n      entries: [],\n      transactions: [tx()],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(\n      screen.getByText(\"No entries recorded for this round.\"),\n    ).toBeInTheDocument();\n    expect(\n      screen.getByText(/the .*game_entries.* table has no rows/i),\n    ).toBeInTheDocument();\n    // Pluralised participant count when zero.\n    expect(\n      screen.getByText(/0 participants/i, { selector: \"p\" }),\n    ).toBeInTheDocument();\n  });\n\n  it(\"renders the transactions empty state and points operators at the stuck-state filters\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound(),\n      entries: [entry()],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(\n      screen.getByText(\"No transactions recorded for this round.\"),\n    ).toBeInTheDocument();\n    expect(\n      screen.getByText(/stuck-state filters/i),\n    ).toBeInTheDocument();\n    // Pluralised count when zero.\n    expect(\n      screen.getByText(/0 on-chain SOL movements/i, { selector: \"p\" }),\n    ).toBeInTheDocument();\n  });\n\n  it(\"renders both empty states when entries + transactions are both empty (sparse round)\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound({\n        phase: \"created\",\n        winner: null,\n        resultSide: null,\n        settleTx: null,\n        settledAt: null,\n      }),\n      entries: [],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(\n      screen.getByText(\"No entries recorded for this round.\"),\n    ).toBeInTheDocument();\n    expect(\n      screen.getByText(\"No transactions recorded for this round.\"),\n    ).toBeInTheDocument();\n  });\n\n  it(\"entries table: renders 'yes' / 'no' / '—' for isWinner across rows\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound(),\n      entries: [\n        entry({ id: \"e-yes\", isWinner: true }),\n        entry({ id: \"e-no\", isWinner: false }),\n        entry({ id: \"e-pending\", isWinner: null, settledAt: null }),\n      ],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(screen.getByText(\"yes\")).toBeInTheDocument();\n    expect(screen.getByText(\"no\")).toBeInTheDocument();\n    // The pending entry contributes an em-dash to the Winner cell.\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThan(0);\n  });\n\n  it(\"entries: renders the truncated user id (12-char window) when the player has no username\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound(),\n      entries: [\n        entry({\n          username: null,\n          userId: \"user-id-aaaaaaaaaaaaaaaaaa\",\n        }),\n      ],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    // Truncate(value, 12) inserts a unicode ellipsis so a long user id never\n    // renders in full inside the table cell.\n    const link = screen.getByRole(\"link\", { name: /…/ });\n    expect(link).toHaveAttribute(\n      \"href\",\n      \"/users/user-id-aaaaaaaaaaaaaaaaaa\",\n    );\n    // Full id stays in title= for hover audit.\n    expect(link).toHaveAttribute(\"title\", \"user-id-aaaaaaaaaaaaaaaaaa\");\n  });\n});\n\ndescribe(\"RoundDetailView — Pot Shot\", () => {\n  it(\"renders Pot Shot rounds through the same shared summary + tables\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"potshot\",\n      round: potshotRound(),\n      entries: [entry()],\n      transactions: [tx()],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(\n      screen.getByRole(\"heading\", { name: /round summary/i }),\n    ).toBeInTheDocument();\n    expect(screen.getAllByText(\"settled\").length).toBeGreaterThan(0);\n    expect(screen.getByText(\"Match ID\")).toBeInTheDocument();\n    // Same heading IDs / FR-6 drill-down.\n    const userLinks = screen.getAllByRole(\"link\", { name: \"alice\" });\n    expect(userLinks[0]).toHaveAttribute(\n      \"href\",\n      \"/users/user-id-aaaaaaaaaaaaaaaaaa\",\n    );\n  });\n});\n\ndescribe(\"RoundDetailView — Close Call\", () => {\n  it(\"renders the Close Call summary with phase + outcome chips and the Pyth expo sublabel\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"closecall\",\n      round: closecallRound(),\n      entries: [\n        entry({ side: \"green\", payoutLamports: \"950000\" }),\n      ],\n      transactions: [tx({ txType: \"payout\" })],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    // Close Call summary has Outcome + Round ID + price columns the shared\n    // FlipYou summary does not.\n    expect(screen.getByText(\"Outcome\")).toBeInTheDocument();\n    expect(screen.getByText(\"Round ID\")).toBeInTheDocument();\n    expect(screen.getByText(\"Open price\")).toBeInTheDocument();\n    expect(screen.getByText(\"Close price\")).toBeInTheDocument();\n    expect(screen.getByText(\"Green pool (lamports)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Red pool (lamports)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Total fee (lamports)\")).toBeInTheDocument();\n\n    // Pyth expo sublabel.\n    expect(screen.getByText(/expo -8/i)).toBeInTheDocument();\n\n    // Phase + outcome chips both render their label values.\n    expect(screen.getAllByText(\"settled\").length).toBeGreaterThan(0);\n    expect(screen.getAllByText(\"green\").length).toBeGreaterThan(0);\n\n    // Lamport pool / price values format with thousands separators.\n    expect(screen.getByText(\"65,000,000,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"66,000,000,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"1,000,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"750,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"50,000\")).toBeInTheDocument();\n  });\n\n  it(\"renders the open + pending state with em-dashes for closePrice / settleTx / settledAt\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"closecall\",\n      round: closecallRound({\n        phase: \"open\",\n        outcome: \"pending\",\n        closePrice: null,\n        settleTx: null,\n        settledAt: null,\n      }),\n      entries: [],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(screen.getAllByText(\"open\").length).toBeGreaterThan(0);\n    expect(screen.getAllByText(\"pending\").length).toBeGreaterThan(0);\n    // 3 nullable summary fields → at least 3 em-dashes.\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(3);\n  });\n\n  it(\"renders the refunded + refund composite state (FR-8 refund signal)\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"closecall\",\n      round: closecallRound({\n        phase: \"refunded\",\n        outcome: \"refund\",\n        closePrice: null,\n        settleTx: null,\n      }),\n      entries: [],\n      transactions: [\n        tx({ txType: \"refund\", amountLamports: \"1000\" }),\n      ],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(screen.getAllByText(\"refunded\").length).toBeGreaterThan(0);\n    expect(screen.getAllByText(\"refund\").length).toBeGreaterThan(0);\n    expect(\n      screen.getByText(\"No entries recorded for this round.\"),\n    ).toBeInTheDocument();\n    // 1,000 (lamport-formatted) appears in the transactions table.\n    expect(screen.getByText(\"1,000\")).toBeInTheDocument();\n  });\n\n  it(\"transactions: renders em-dash for tx with null user_id (no fabricated user link)\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"closecall\",\n      round: closecallRound(),\n      entries: [],\n      transactions: [\n        tx({\n          id: \"tx-anon\",\n          userId: null,\n          username: null,\n        }),\n      ],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    // The transactions table renders \"—\" for the User cell when userId is\n    // null. Other cells (round summary) may also have em-dashes; we just\n    // assert at least one and that no user link is rendered for `alice`.\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThan(0);\n    expect(screen.queryByRole(\"link\", { name: \"alice\" })).not.toBeInTheDocument();\n  });\n});\n\ndescribe(\"RoundDetailView — stuck states across all 3 games\", () => {\n  it(\"FlipYou: settling phase + high settle attempts + no winner stays auditable\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound({\n        phase: \"settling\",\n        settleAttempts: 12,\n        settleTx: null,\n        resultSide: null,\n        winner: null,\n        settledAt: null,\n      }),\n      entries: [],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(screen.getAllByText(\"settling\").length).toBeGreaterThan(0);\n    // Settle attempts = 12 renders as the literal \"12\".\n    expect(screen.getByText(\"12\")).toBeInTheDocument();\n    // No transactions for a settling round → the empty state explains the\n    // attention surface explicitly.\n    expect(\n      screen.getByText(\"No transactions recorded for this round.\"),\n    ).toBeInTheDocument();\n  });\n\n  it(\"FlipYou: expired (refund) phase surfaces with refund transaction\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound({\n        phase: \"expired\",\n        winner: null,\n        resultSide: null,\n        settleTx: null,\n        settledAt: null,\n      }),\n      entries: [],\n      transactions: [\n        tx({ id: \"refund-1\", txType: \"refund\", amountLamports: \"1000000\" }),\n      ],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(screen.getAllByText(\"expired\").length).toBeGreaterThan(0);\n    expect(screen.getAllByText(\"refund\").length).toBeGreaterThan(0);\n    expect(screen.getByText(\"1,000,000\")).toBeInTheDocument();\n  });\n\n  it(\"Pot Shot: settling phase with empty entries + transactions renders both empty states\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"potshot\",\n      round: potshotRound({\n        phase: \"settling\",\n        settleAttempts: 5,\n        winner: null,\n        resultSide: null,\n        settleTx: null,\n        settledAt: null,\n      }),\n      entries: [],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(\n      screen.getByText(\"No entries recorded for this round.\"),\n    ).toBeInTheDocument();\n    expect(\n      screen.getByText(\"No transactions recorded for this round.\"),\n    ).toBeInTheDocument();\n    expect(screen.getAllByText(\"settling\").length).toBeGreaterThan(0);\n  });\n\n  it(\"Close Call: settled with a settled-without-tx attention pattern (no transactions)\", () => {\n    // This is the operator-visible state behind the FR-8\n    // `settledWithoutTx` stuck-state filter on `/games/closecall`.\n    const detail: PeekRoundDetail = {\n      game: \"closecall\",\n      round: closecallRound({\n        phase: \"settled\",\n        outcome: \"green\",\n      }),\n      entries: [\n        entry({\n          id: \"e-1\",\n          side: \"green\",\n          isWinner: true,\n          payoutLamports: \"950000\",\n        }),\n      ],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    // Settled phase + green outcome chips render normally.\n    expect(screen.getAllByText(\"settled\").length).toBeGreaterThan(0);\n    expect(screen.getAllByText(\"green\").length).toBeGreaterThan(0);\n    // No transactions → empty-state hint pointing at the stuck filters.\n    expect(\n      screen.getByText(/stuck-state filters/i),\n    ).toBeInTheDocument();\n  });\n});\n\ndescribe(\"RoundDetailView — section structure (FR-3 anchored sections)\", () => {\n  it(\"each section uses an aria-labelledby heading id so anchored navigation works\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound(),\n      entries: [],\n      transactions: [],\n    };\n\n    const { container } = render(<RoundDetailView detail={detail} />);\n\n    const sections = container.querySelectorAll(\"section[aria-labelledby]\");\n    // 3 sections: round summary, entries, transactions.\n    expect(sections.length).toBe(3);\n    const ids = Array.from(sections).map((s) =>\n      s.getAttribute(\"aria-labelledby\"),\n    );\n    expect(ids).toEqual([\n      \"round-summary-heading\",\n      \"entries-heading\",\n      \"transactions-heading\",\n    ]);\n\n    // Each labelled-by id resolves to a real heading inside that section.\n    for (const section of Array.from(sections)) {\n      const id = section.getAttribute(\"aria-labelledby\");\n      if (!id) continue;\n      const heading = within(section as HTMLElement).getByRole(\"heading\");\n      expect(heading).toHaveAttribute(\"id\", id);\n    }\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":388,"cache_read_input_tokens":137203,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":388},"output_tokens":38,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"e3ee47e7-eefe-4e12-a068-a08216780c1e","uuid":"d6bc87f7-df65-4f18-aecf-c8372184acf8"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SpQd2gcm3P7bFjD3YP5GUq","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/components/__tests__/round-detail-view.test.tsx"}]},"parent_tool_use_id":null,"session_id":"e3ee47e7-eefe-4e12-a068-a08216780c1e","uuid":"efd4b8f4-ebac-49ba-a494-65a66b791419","timestamp":"2026-04-25T13:38:25.668Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/round-detail-view.test.tsx","content":"import { describe, expect, it } from \"vitest\";\nimport { render, screen, within } from \"@testing-library/react\";\nimport { RoundDetailView } from \"../round-detail-view\";\nimport type {\n  PeekCloseCallRoundRow,\n  PeekRoundDetail,\n  PeekRoundEntryRow,\n  PeekRoundRow,\n  PeekRoundTransactionRow,\n} from \"../../lib/types/peek\";\n\nfunction flipyouRound(overrides: Partial<PeekRoundRow> = {}): PeekRoundRow {\n  return {\n    game: \"flipyou\",\n    pda: \"pda-flipyou-1\",\n    matchId: \"match-flipyou-1\",\n    phase: \"settled\",\n    creator: \"creator-flipyou-1\",\n    targetSlot: \"1234567890\",\n    settleAttempts: 1,\n    settleTx: \"tx-settle-flipyou\",\n    resultSide: 0,\n    winner: \"creator-flipyou-1\",\n    amountLamports: \"9007199254740992\",\n    createdAt: \"2026-04-25T10:00:00.000Z\",\n    updatedAt: \"2026-04-25T10:01:00.000Z\",\n    settledAt: \"2026-04-25T10:00:30.000Z\",\n    ...overrides,\n  };\n}\n\nfunction potshotRound(overrides: Partial<PeekRoundRow> = {}): PeekRoundRow {\n  return {\n    ...flipyouRound(),\n    game: \"potshot\",\n    pda: \"pda-potshot-1\",\n    matchId: \"match-potshot-1\",\n    creator: \"creator-potshot-1\",\n    winner: \"creator-potshot-1\",\n    settleTx: \"tx-settle-potshot\",\n    ...overrides,\n  };\n}\n\nfunction closecallRound(\n  overrides: Partial<PeekCloseCallRoundRow> = {},\n): PeekCloseCallRoundRow {\n  return {\n    pda: \"pda-cc-1\",\n    roundId: \"rd-1\",\n    phase: \"settled\",\n    outcome: \"green\",\n    openPrice: \"65000000000\",\n    openPriceExpo: -8,\n    closePrice: \"66000000000\",\n    greenPoolLamports: \"1000000\",\n    redPoolLamports: \"750000\",\n    totalFeeLamports: \"50000\",\n    settleTx: \"cc-tx-1\",\n    createdAt: \"2026-04-25T10:00:00.000Z\",\n    settledAt: \"2026-04-25T10:05:00.000Z\",\n    ...overrides,\n  };\n}\n\nfunction entry(overrides: Partial<PeekRoundEntryRow> = {}): PeekRoundEntryRow {\n  return {\n    id: \"entry-1\",\n    userId: \"user-id-aaaaaaaaaaaaaaaaaa\",\n    username: \"alice\",\n    wallet: \"wallet-aaaaaaaaaaaaaaaaaa\",\n    amountLamports: \"9007199254740992\",\n    side: \"0\",\n    isWinner: true,\n    payoutLamports: \"18000000000000000\",\n    createdAt: \"2026-04-25T10:00:05.000Z\",\n    settledAt: \"2026-04-25T10:00:30.000Z\",\n    ...overrides,\n  };\n}\n\nfunction tx(\n  overrides: Partial<PeekRoundTransactionRow> = {},\n): PeekRoundTransactionRow {\n  return {\n    id: \"tx-1\",\n    userId: \"user-id-aaaaaaaaaaaaaaaaaa\",\n    username: \"alice\",\n    wallet: \"wallet-aaaaaaaaaaaaaaaaaa\",\n    txType: \"payout\",\n    amountLamports: \"18000000000000000\",\n    txSig: \"txsig-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\",\n    createdAt: \"2026-04-25T10:00:30.000Z\",\n    ...overrides,\n  };\n}\n\ndescribe(\"RoundDetailView — FlipYou (full)\", () => {\n  it(\"renders all round summary fields, entries table, and transactions table\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound(),\n      entries: [entry()],\n      transactions: [tx()],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    // Summary section is present + uses the right heading id.\n    expect(\n      screen.getByRole(\"heading\", { name: /round summary/i }),\n    ).toBeInTheDocument();\n    expect(screen.getByText(\"Phase\")).toBeInTheDocument();\n    expect(screen.getByText(\"Match ID\")).toBeInTheDocument();\n    expect(screen.getByText(\"PDA\")).toBeInTheDocument();\n    expect(screen.getByText(\"Creator\")).toBeInTheDocument();\n    expect(screen.getByText(\"Amount (lamports)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Target slot\")).toBeInTheDocument();\n    expect(screen.getByText(\"Settle attempts\")).toBeInTheDocument();\n    expect(screen.getByText(\"Result side\")).toBeInTheDocument();\n    expect(screen.getByText(\"Winner\")).toBeInTheDocument();\n    expect(screen.getByText(\"Settle tx\")).toBeInTheDocument();\n    expect(screen.getByText(\"Created\")).toBeInTheDocument();\n    expect(screen.getByText(\"Updated\")).toBeInTheDocument();\n    expect(screen.getByText(\"Settled\")).toBeInTheDocument();\n\n    // Phase status chip renders with the literal label.\n    expect(screen.getAllByText(\"settled\").length).toBeGreaterThan(0);\n\n    // u64 lamport amount > Number.MAX_SAFE_INTEGER renders with thousands\n    // separators and preserves the underlying digits.\n    expect(screen.getByText(\"9,007,199,254,740,992\")).toBeInTheDocument();\n\n    // Entries section header + count hint.\n    expect(\n      screen.getByRole(\"heading\", { name: /entries/i }),\n    ).toBeInTheDocument();\n    expect(\n      screen.getByText(/1 participant/i, { selector: \"p\" }),\n    ).toBeInTheDocument();\n\n    // Transactions section header + count hint (singular \"movement\").\n    expect(\n      screen.getByRole(\"heading\", { name: /transactions/i }),\n    ).toBeInTheDocument();\n    expect(\n      screen.getByText(/1 on-chain SOL movement/i, { selector: \"p\" }),\n    ).toBeInTheDocument();\n\n    // Entry user link points at /users/[userId] with FR-6 drill-down.\n    const userLinks = screen.getAllByRole(\"link\", { name: \"alice\" });\n    expect(userLinks.length).toBeGreaterThan(0);\n    expect(userLinks[0]).toHaveAttribute(\n      \"href\",\n      \"/users/user-id-aaaaaaaaaaaaaaaaaa\",\n    );\n  });\n\n  it(\"formats lamports with thousands separators while preserving '0' literal for measured zeros\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound({\n        amountLamports: \"0\",\n        targetSlot: \"0\",\n      }),\n      entries: [\n        entry({\n          amountLamports: \"0\",\n          payoutLamports: \"0\",\n          isWinner: false,\n        }),\n      ],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    // Multiple \"0\" cells (amount, target slot, entry amount, entry payout, etc.)\n    expect(screen.getAllByText(\"0\").length).toBeGreaterThan(0);\n  });\n\n  it(\"renders em-dashes for null target slot, settle tx, result side, winner, and settled at\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound({\n        targetSlot: null,\n        settleTx: null,\n        resultSide: null,\n        winner: null,\n        settledAt: null,\n        phase: \"created\",\n      }),\n      entries: [],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    // 5 nullable fields → at least 5 em-dashes inside the summary alone.\n    // Use a count assertion instead of an exact integer to stay resilient\n    // to additional null fields that other states may add.\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(5);\n  });\n\n  it(\"renders the entries empty state when entries are empty\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound(),\n      entries: [],\n      transactions: [tx()],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(\n      screen.getByText(\"No entries recorded for this round.\"),\n    ).toBeInTheDocument();\n    expect(\n      screen.getByText(/the .*game_entries.* table has no rows/i),\n    ).toBeInTheDocument();\n    // Pluralised participant count when zero.\n    expect(\n      screen.getByText(/0 participants/i, { selector: \"p\" }),\n    ).toBeInTheDocument();\n  });\n\n  it(\"renders the transactions empty state and points operators at the stuck-state filters\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound(),\n      entries: [entry()],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(\n      screen.getByText(\"No transactions recorded for this round.\"),\n    ).toBeInTheDocument();\n    expect(\n      screen.getByText(/stuck-state filters/i),\n    ).toBeInTheDocument();\n    // Pluralised count when zero.\n    expect(\n      screen.getByText(/0 on-chain SOL movements/i, { selector: \"p\" }),\n    ).toBeInTheDocument();\n  });\n\n  it(\"renders both empty states when entries + transactions are both empty (sparse round)\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound({\n        phase: \"created\",\n        winner: null,\n        resultSide: null,\n        settleTx: null,\n        settledAt: null,\n      }),\n      entries: [],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(\n      screen.getByText(\"No entries recorded for this round.\"),\n    ).toBeInTheDocument();\n    expect(\n      screen.getByText(\"No transactions recorded for this round.\"),\n    ).toBeInTheDocument();\n  });\n\n  it(\"entries table: renders 'yes' / 'no' / '—' for isWinner across rows\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound(),\n      entries: [\n        entry({ id: \"e-yes\", isWinner: true }),\n        entry({ id: \"e-no\", isWinner: false }),\n        entry({ id: \"e-pending\", isWinner: null, settledAt: null }),\n      ],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(screen.getByText(\"yes\")).toBeInTheDocument();\n    expect(screen.getByText(\"no\")).toBeInTheDocument();\n    // The pending entry contributes an em-dash to the Winner cell.\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThan(0);\n  });\n\n  it(\"entries: renders the truncated user id (12-char window) when the player has no username\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound(),\n      entries: [\n        entry({\n          username: null,\n          userId: \"user-id-aaaaaaaaaaaaaaaaaa\",\n        }),\n      ],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    // Truncate(value, 12) inserts a unicode ellipsis so a long user id never\n    // renders in full inside the table cell.\n    const link = screen.getByRole(\"link\", { name: /…/ });\n    expect(link).toHaveAttribute(\n      \"href\",\n      \"/users/user-id-aaaaaaaaaaaaaaaaaa\",\n    );\n    // Full id stays in title= for hover audit.\n    expect(link).toHaveAttribute(\"title\", \"user-id-aaaaaaaaaaaaaaaaaa\");\n  });\n});\n\ndescribe(\"RoundDetailView — Pot Shot\", () => {\n  it(\"renders Pot Shot rounds through the same shared summary + tables\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"potshot\",\n      round: potshotRound(),\n      entries: [entry()],\n      transactions: [tx()],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(\n      screen.getByRole(\"heading\", { name: /round summary/i }),\n    ).toBeInTheDocument();\n    expect(screen.getAllByText(\"settled\").length).toBeGreaterThan(0);\n    expect(screen.getByText(\"Match ID\")).toBeInTheDocument();\n    // Same heading IDs / FR-6 drill-down.\n    const userLinks = screen.getAllByRole(\"link\", { name: \"alice\" });\n    expect(userLinks[0]).toHaveAttribute(\n      \"href\",\n      \"/users/user-id-aaaaaaaaaaaaaaaaaa\",\n    );\n  });\n});\n\ndescribe(\"RoundDetailView — Close Call\", () => {\n  it(\"renders the Close Call summary with phase + outcome chips and the Pyth expo sublabel\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"closecall\",\n      round: closecallRound(),\n      entries: [\n        entry({ side: \"green\", payoutLamports: \"950000\" }),\n      ],\n      transactions: [tx({ txType: \"payout\" })],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    // Close Call summary has Outcome + Round ID + price columns the shared\n    // FlipYou summary does not.\n    expect(screen.getByText(\"Outcome\")).toBeInTheDocument();\n    expect(screen.getByText(\"Round ID\")).toBeInTheDocument();\n    expect(screen.getByText(\"Open price\")).toBeInTheDocument();\n    expect(screen.getByText(\"Close price\")).toBeInTheDocument();\n    expect(screen.getByText(\"Green pool (lamports)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Red pool (lamports)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Total fee (lamports)\")).toBeInTheDocument();\n\n    // Pyth expo sublabel.\n    expect(screen.getByText(/expo -8/i)).toBeInTheDocument();\n\n    // Phase + outcome chips both render their label values.\n    expect(screen.getAllByText(\"settled\").length).toBeGreaterThan(0);\n    expect(screen.getAllByText(\"green\").length).toBeGreaterThan(0);\n\n    // Lamport pool / price values format with thousands separators.\n    expect(screen.getByText(\"65,000,000,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"66,000,000,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"1,000,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"750,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"50,000\")).toBeInTheDocument();\n  });\n\n  it(\"renders the open + pending state with em-dashes for closePrice / settleTx / settledAt\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"closecall\",\n      round: closecallRound({\n        phase: \"open\",\n        outcome: \"pending\",\n        closePrice: null,\n        settleTx: null,\n        settledAt: null,\n      }),\n      entries: [],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(screen.getAllByText(\"open\").length).toBeGreaterThan(0);\n    expect(screen.getAllByText(\"pending\").length).toBeGreaterThan(0);\n    // 3 nullable summary fields → at least 3 em-dashes.\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(3);\n  });\n\n  it(\"renders the refunded + refund composite state (FR-8 refund signal)\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"closecall\",\n      round: closecallRound({\n        phase: \"refunded\",\n        outcome: \"refund\",\n        closePrice: null,\n        settleTx: null,\n      }),\n      entries: [],\n      transactions: [\n        tx({ txType: \"refund\", amountLamports: \"1000\" }),\n      ],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(screen.getAllByText(\"refunded\").length).toBeGreaterThan(0);\n    expect(screen.getAllByText(\"refund\").length).toBeGreaterThan(0);\n    expect(\n      screen.getByText(\"No entries recorded for this round.\"),\n    ).toBeInTheDocument();\n    // 1,000 (lamport-formatted) appears in the transactions table.\n    expect(screen.getByText(\"1,000\")).toBeInTheDocument();\n  });\n\n  it(\"transactions: renders em-dash for tx with null user_id (no fabricated user link)\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"closecall\",\n      round: closecallRound(),\n      entries: [],\n      transactions: [\n        tx({\n          id: \"tx-anon\",\n          userId: null,\n          username: null,\n        }),\n      ],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    // The transactions table renders \"—\" for the User cell when userId is\n    // null. Other cells (round summary) may also have em-dashes; we just\n    // assert at least one and that no user link is rendered for `alice`.\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThan(0);\n    expect(screen.queryByRole(\"link\", { name: \"alice\" })).not.toBeInTheDocument();\n  });\n});\n\ndescribe(\"RoundDetailView — stuck states across all 3 games\", () => {\n  it(\"FlipYou: settling phase + high settle attempts + no winner stays auditable\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound({\n        phase: \"settling\",\n        settleAttempts: 12,\n        settleTx: null,\n        resultSide: null,\n        winner: null,\n        settledAt: null,\n      }),\n      entries: [],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(screen.getAllByText(\"settling\").length).toBeGreaterThan(0);\n    // Settle attempts = 12 renders as the literal \"12\".\n    expect(screen.getByText(\"12\")).toBeInTheDocument();\n    // No transactions for a settling round → the empty state explains the\n    // attention surface explicitly.\n    expect(\n      screen.getByText(\"No transactions recorded for this round.\"),\n    ).toBeInTheDocument();\n  });\n\n  it(\"FlipYou: expired (refund) phase surfaces with refund transaction\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound({\n        phase: \"expired\",\n        winner: null,\n        resultSide: null,\n        settleTx: null,\n        settledAt: null,\n      }),\n      entries: [],\n      transactions: [\n        tx({ id: \"refund-1\", txType: \"refund\", amountLamports: \"1000000\" }),\n      ],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(screen.getAllByText(\"expired\").length).toBeGreaterThan(0);\n    expect(screen.getAllByText(\"refund\").length).toBeGreaterThan(0);\n    expect(screen.getByText(\"1,000,000\")).toBeInTheDocument();\n  });\n\n  it(\"Pot Shot: settling phase with empty entries + transactions renders both empty states\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"potshot\",\n      round: potshotRound({\n        phase: \"settling\",\n        settleAttempts: 5,\n        winner: null,\n        resultSide: null,\n        settleTx: null,\n        settledAt: null,\n      }),\n      entries: [],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    expect(\n      screen.getByText(\"No entries recorded for this round.\"),\n    ).toBeInTheDocument();\n    expect(\n      screen.getByText(\"No transactions recorded for this round.\"),\n    ).toBeInTheDocument();\n    expect(screen.getAllByText(\"settling\").length).toBeGreaterThan(0);\n  });\n\n  it(\"Close Call: settled with a settled-without-tx attention pattern (no transactions)\", () => {\n    // This is the operator-visible state behind the FR-8\n    // `settledWithoutTx` stuck-state filter on `/games/closecall`.\n    const detail: PeekRoundDetail = {\n      game: \"closecall\",\n      round: closecallRound({\n        phase: \"settled\",\n        outcome: \"green\",\n      }),\n      entries: [\n        entry({\n          id: \"e-1\",\n          side: \"green\",\n          isWinner: true,\n          payoutLamports: \"950000\",\n        }),\n      ],\n      transactions: [],\n    };\n\n    render(<RoundDetailView detail={detail} />);\n\n    // Settled phase + green outcome chips render normally.\n    expect(screen.getAllByText(\"settled\").length).toBeGreaterThan(0);\n    expect(screen.getAllByText(\"green\").length).toBeGreaterThan(0);\n    // No transactions → empty-state hint pointing at the stuck filters.\n    expect(\n      screen.getByText(/stuck-state filters/i),\n    ).toBeInTheDocument();\n  });\n});\n\ndescribe(\"RoundDetailView — section structure (FR-3 anchored sections)\", () => {\n  it(\"each section uses an aria-labelledby heading id so anchored navigation works\", () => {\n    const detail: PeekRoundDetail = {\n      game: \"flipyou\",\n      round: flipyouRound(),\n      entries: [],\n      transactions: [],\n    };\n\n    const { container } = render(<RoundDetailView detail={detail} />);\n\n    const sections = container.querySelectorAll(\"section[aria-labelledby]\");\n    // 3 sections: round summary, entries, transactions.\n    expect(sections.length).toBe(3);\n    const ids = Array.from(sections).map((s) =>\n      s.getAttribute(\"aria-labelledby\"),\n    );\n    expect(ids).toEqual([\n      \"round-summary-heading\",\n      \"entries-heading\",\n      \"transactions-heading\",\n    ]);\n\n    // Each labelled-by id resolves to a real heading inside that section.\n    for (const section of Array.from(sections)) {\n      const id = section.getAttribute(\"aria-labelledby\");\n      if (!id) continue;\n      const heading = within(section as HTMLElement).getByRole(\"heading\");\n      expect(heading).toHaveAttribute(\"id\", id);\n    }\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
