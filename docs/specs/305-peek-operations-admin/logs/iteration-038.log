{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N7SRNTap3wsbtFe2TzRCNK","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport type { Sql } from \"postgres\";\n3\timport {\n4\t  PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n5\t  PEEK_GAME_ROUNDS_MAX_PAGE_SIZE,\n6\t  PEEK_ROUND_STUCK_DEFAULTS,\n7\t  listCloseCallRounds,\n8\t  listRounds,\n9\t} from \"../get-game-rounds\";\n10\t\n11\ttype SqlCall = {\n12\t  text: string;\n13\t  values: ReadonlyArray<unknown>;\n14\t};\n15\t\n16\ttype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n17\t\n18\ttype SqlMock = {\n19\t  sql: Sql;\n20\t  calls: ReadonlyArray<SqlCall>;\n21\t};\n22\t\n23\t// SQL mock that records every tagged-template call and returns a queued\n24\t// response per call (rows or an Error to reject). Mirrors the pattern used in\n25\t// get-games-overview.test.ts and get-growth-referrals.test.ts so query test\n26\t// behaviour stays consistent.\n27\tfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n28\t  const calls: SqlCall[] = [];\n29\t  let cursor = 0;\n30\t\n31\t  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n32\t    const text = [...strings].join(\"?\");\n33\t    calls.push({ text, values: [...values] });\n34\t    const next = responses[cursor++];\n35\t    if (next instanceof Error) return Promise.reject(next);\n36\t    return Promise.resolve(next ?? []);\n37\t  };\n38\t\n39\t  const sql = fn as unknown as Sql;\n40\t  return { sql, calls };\n41\t}\n42\t\n43\t// Two queries fire in parallel via Promise.all per call:\n44\t//   0 — paged rows\n45\t//   1 — count(*) for pagination\n46\t\n47\tdescribe(\"listRounds (FlipYou + Pot Shot)\", () => {\n48\t  it(\"populated: shapes rows for FlipYou with u64 strings preserved end-to-end\", async () => {\n49\t    const flipyouRows = [\n50\t      {\n51\t        pda: \"pda-1\",\n52\t        game: \"flipyou\",\n53\t        matchId: \"m-1\",\n54\t        phase: \"settled\",\n55\t        creator: \"creator-1\",\n56\t        targetSlot: \"1234567890\",\n57\t        settleAttempts: 1,\n58\t        settleTx: \"tx-1\",\n59\t        resultSide: 0,\n60\t        winner: \"creator-1\",\n61\t        amountLamports: \"9007199254740992\", // > Number.MAX_SAFE_INTEGER\n62\t        createdAt: \"2026-04-25T10:00:00.000Z\",\n63\t        updatedAt: \"2026-04-25T10:01:00.000Z\",\n64\t        settledAt: \"2026-04-25T10:00:30.000Z\",\n65\t      },\n66\t      {\n67\t        pda: \"pda-2\",\n68\t        game: \"flipyou\",\n69\t        matchId: \"m-2\",\n70\t        phase: \"expired\",\n71\t        creator: \"creator-2\",\n72\t        targetSlot: null,\n73\t        settleAttempts: 4,\n74\t        settleTx: null,\n75\t        resultSide: null,\n76\t        winner: null,\n77\t        amountLamports: \"100000\",\n78\t        createdAt: \"2026-04-25T09:00:00.000Z\",\n79\t        updatedAt: \"2026-04-25T09:30:00.000Z\",\n80\t        settledAt: null,\n81\t      },\n82\t    ];\n83\t    const mock = createSqlMock([flipyouRows, [{ value: 2 }]]);\n84\t\n85\t    const result = await listRounds({ sql: mock.sql, game: \"flipyou\" });\n86\t\n87\t    expect(result.rows).toHaveLength(2);\n88\t    expect(result.rows[0]).toEqual({\n89\t      game: \"flipyou\",\n90\t      pda: \"pda-1\",\n91\t      matchId: \"m-1\",\n92\t      phase: \"settled\",\n93\t      creator: \"creator-1\",\n94\t      targetSlot: \"1234567890\",\n95\t      settleAttempts: 1,\n96\t      settleTx: \"tx-1\",\n97\t      resultSide: 0,\n98\t      winner: \"creator-1\",\n99\t      amountLamports: \"9007199254740992\",\n100\t      createdAt: \"2026-04-25T10:00:00.000Z\",\n101\t      updatedAt: \"2026-04-25T10:01:00.000Z\",\n102\t      settledAt: \"2026-04-25T10:00:30.000Z\",\n103\t    });\n104\t    // Null-friendly columns survive: targetSlot, settleTx, resultSide, winner, settledAt.\n105\t    expect(result.rows[1].targetSlot).toBeNull();\n106\t    expect(result.rows[1].settleTx).toBeNull();\n107\t    expect(result.rows[1].resultSide).toBeNull();\n108\t    expect(result.rows[1].winner).toBeNull();\n109\t    expect(result.rows[1].settledAt).toBeNull();\n110\t\n111\t    expect(result.pagination).toEqual({\n112\t      page: 1,\n113\t      pageSize: PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n114\t      totalCount: 2,\n115\t      totalPages: 1,\n116\t    });\n117\t\n118\t    // Two queries fired in parallel: rows + count.\n119\t    expect(mock.calls).toHaveLength(2);\n120\t    expect(mock.calls[0].text).toContain(\"from rounds r\");\n121\t    expect(mock.calls[0].text).toContain(\"order by r.created_at desc\");\n122\t    expect(mock.calls[0].text).toContain(\"limit \");\n123\t    expect(mock.calls[0].text).toContain(\" offset \");\n124\t    expect(mock.calls[1].text).toContain(\"count(*)::int\");\n125\t    // Game predicate is bound to the requested game id.\n126\t    expect(mock.calls[0].values).toContain(\"flipyou\");\n127\t    expect(mock.calls[1].values).toContain(\"flipyou\");\n128\t  });\n129\t\n130\t  it(\"works for potshot game id (same SQL, different game predicate)\", async () => {\n131\t    const mock = createSqlMock([\n132\t      [\n133\t        {\n134\t          pda: \"pda-ps\",\n135\t          game: \"potshot\",\n136\t          matchId: \"m-ps\",\n137\t          phase: \"created\",\n138\t          creator: \"creator-ps\",\n139\t          targetSlot: \"777\",\n140\t          settleAttempts: 0,\n141\t          settleTx: null,\n142\t          resultSide: null,\n143\t          winner: null,\n144\t          amountLamports: \"5000000\",\n145\t          createdAt: \"2026-04-25T10:00:00.000Z\",\n146\t          updatedAt: \"2026-04-25T10:00:00.000Z\",\n147\t          settledAt: null,\n148\t        },\n149\t      ],\n150\t      [{ value: 1 }],\n151\t    ]);\n152\t\n153\t    const result = await listRounds({ sql: mock.sql, game: \"potshot\" });\n154\t\n155\t    expect(result.rows).toHaveLength(1);\n156\t    expect(result.rows[0].game).toBe(\"potshot\");\n157\t    expect(mock.calls[0].values).toContain(\"potshot\");\n158\t    expect(mock.calls[1].values).toContain(\"potshot\");\n159\t  });\n160\t\n161\t  it(\"filters out rows whose game id is not a member of PEEK_ROUNDS_GAME_IDS so out-of-band data cannot leak\", async () => {\n162\t    const mock = createSqlMock([\n163\t      [\n164\t        {\n165\t          pda: \"pda-1\",\n166\t          game: \"flipyou\",\n167\t          matchId: \"m-1\",\n168\t          phase: \"settled\",\n169\t          creator: \"c-1\",\n170\t          targetSlot: null,\n171\t          settleAttempts: 0,\n172\t          settleTx: null,\n173\t          resultSide: null,\n174\t          winner: null,\n175\t          amountLamports: \"0\",\n176\t          createdAt: \"2026-04-25T10:00:00.000Z\",\n177\t          updatedAt: \"2026-04-25T10:00:00.000Z\",\n178\t          settledAt: null,\n179\t        },\n180\t        {\n181\t          // Out-of-band game id (e.g. a future migration row); must not surface.\n182\t          pda: \"pda-bogus\",\n183\t          game: \"crash\",\n184\t          matchId: \"m-bogus\",\n185\t          phase: \"settled\",\n186\t          creator: \"c-bogus\",\n187\t          targetSlot: null,\n188\t          settleAttempts: 0,\n189\t          settleTx: null,\n190\t          resultSide: null,\n191\t          winner: null,\n192\t          amountLamports: \"0\",\n193\t          createdAt: \"2026-04-25T10:00:00.000Z\",\n194\t          updatedAt: \"2026-04-25T10:00:00.000Z\",\n195\t          settledAt: null,\n196\t        },\n197\t      ],\n198\t      [{ value: 2 }],\n199\t    ]);\n200\t\n201\t    const result = await listRounds({ sql: mock.sql, game: \"flipyou\" });\n202\t\n203\t    expect(result.rows.map((r) => r.pda)).toEqual([\"pda-1\"]);\n204\t    expect(result.rows[0].game).toBe(\"flipyou\");\n205\t  });\n206\t\n207\t  it(\"sparse: empty SQL response yields empty rows + zero count + 1 logical page\", async () => {\n208\t    const mock = createSqlMock([[], [{ value: 0 }]]);\n209\t\n210\t    const result = await listRounds({ sql: mock.sql, game: \"flipyou\" });\n211\t\n212\t    expect(result.rows).toEqual([]);\n213\t    expect(result.pagination).toEqual({\n214\t      page: 1,\n215\t      pageSize: PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n216\t      totalCount: 0,\n217\t      totalPages: 1,\n218\t    });\n219\t  });\n220\t\n221\t  it(\"phase filter: when filter set the phase value is bound; when unset the predicate skips\", async () => {\n222\t    const mock = createSqlMock([[], [{ value: 0 }]]);\n223\t    await listRounds({\n224\t      sql: mock.sql,\n225\t      game: \"flipyou\",\n226\t      filters: { phase: \"settling\" },\n227\t    });\n228\t    expect(mock.calls[0].values).toContain(\"settling\");\n229\t    // The \"no phase filter\" branch is encoded as a boolean literal in the\n230\t    // template; when phase is set, the literal must be `false` so the SQL\n231\t    // requires an exact phase match.\n232\t    expect(mock.calls[0].values).toContain(false);\n233\t\n234\t    const mock2 = createSqlMock([[], [{ value: 0 }]]);\n235\t    await listRounds({ sql: mock2.sql, game: \"flipyou\" });\n236\t    // When unset, the boolean literal flips to `true` (skip predicate).\n237\t    expect(mock2.calls[0].values).toContain(true);\n238\t  });\n239\t\n240\t  it(\"search filter: trims whitespace and forwards a LIKE wildcard so partial pdas/match ids/creators match\", async () => {\n241\t    const mock = createSqlMock([[], [{ value: 0 }]]);\n242\t\n243\t    await listRounds({\n244\t      sql: mock.sql,\n245\t      game: \"flipyou\",\n246\t      filters: { search: \"  abc  \" },\n247\t    });\n248\t\n249\t    // Bound with wildcards so partial matches work.\n250\t    expect(mock.calls[0].values).toContain(\"%abc%\");\n251\t    expect(mock.calls[1].values).toContain(\"%abc%\");\n252\t  });\n253\t\n254\t  it(\"date filters: forwards trimmed ISO strings to the SQL bound parameters\", async () => {\n255\t    const mock = createSqlMock([[], [{ value: 0 }]]);\n256\t    await listRounds({\n257\t      sql: mock.sql,\n258\t      game: \"flipyou\",\n259\t      filters: {\n260\t        fromDate: \"2026-04-01\",\n261\t        toDate: \"2026-04-25\",\n262\t      },\n263\t    });\n264\t    expect(mock.calls[0].values).toContain(\"2026-04-01\");\n265\t    expect(mock.calls[0].values).toContain(\"2026-04-25\");\n266\t  });\n267\t\n268\t  it(\"stuck filter: nonterminalAged binds the age interval and a `true` flag; other stuck predicates are `false`\", async () => {\n269\t    const mock = createSqlMock([[], [{ value: 0 }]]);\n270\t\n271\t    await listRounds({\n272\t      sql: mock.sql,\n273\t      game: \"flipyou\",\n274\t      filters: {\n275\t        stuck: {\n276\t          nonterminalAged: true,\n277\t          highAttempts: false,\n278\t          settledWithoutTx: false,\n279\t          refunds: false,\n280\t        },\n281\t      },\n282\t    });\n283\t\n284\t    // Default age threshold (5 minutes) is bound as a postgres interval string.\n285\t    expect(mock.calls[0].values).toContain(\n286\t      `${PEEK_ROUND_STUCK_DEFAULTS.ageMinutes} minutes`,\n287\t    );\n288\t    // Booleans for the four stuck flags get bound directly.\n289\t    const trueCount = mock.calls[0].values.filter((v) => v === true).length;\n290\t    const falseCount = mock.calls[0].values.filter((v) => v === false).length;\n291\t    expect(trueCount).toBeGreaterThan(0);\n292\t    expect(falseCount).toBeGreaterThan(0);\n293\t  });\n294\t\n295\t  it(\"stuck filter: highAttempts binds the maxSettleAttempts threshold (overridable per-call)\", async () => {\n296\t    const mock = createSqlMock([[], [{ value: 0 }]]);\n297\t\n298\t    await listRounds({\n299\t      sql: mock.sql,\n300\t      game: \"flipyou\",\n301\t      filters: {\n302\t        stuck: {\n303\t          nonterminalAged: false,\n304\t          highAttempts: true,\n305\t          settledWithoutTx: false,\n306\t          refunds: false,\n307\t        },\n308\t      },\n309\t      thresholds: { maxSettleAttempts: 7 },\n310\t    });\n311\t\n312\t    expect(mock.calls[0].values).toContain(7);\n313\t    expect(mock.calls[0].text).toContain(\"r.settle_attempts >\");\n314\t  });\n315\t\n316\t  it(\"stuck filter: settledWithoutTx emits the correlated NOT EXISTS subquery against transactions\", async () => {\n317\t    const mock = createSqlMock([[], [{ value: 0 }]]);\n318\t\n319\t    await listRounds({\n320\t      sql: mock.sql,\n321\t      game: \"flipyou\",\n322\t      filters: {\n323\t        stuck: {\n324\t          nonterminalAged: false,\n325\t          highAttempts: false,\n326\t          settledWithoutTx: true,\n327\t          refunds: false,\n328\t        },\n329\t      },\n330\t    });\n331\t\n332\t    expect(mock.calls[0].text).toContain(\"not exists\");\n333\t    expect(mock.calls[0].text).toContain(\"from transactions t\");\n334\t    expect(mock.calls[0].text).toContain(\"t.tx_type in ('payout','refund')\");\n335\t  });\n336\t\n337\t  it(\"stuck filter: refunds maps to phase = 'expired' for FlipYou + Pot Shot\", async () => {\n338\t    const mock = createSqlMock([[], [{ value: 0 }]]);\n339\t\n340\t    await listRounds({\n341\t      sql: mock.sql,\n342\t      game: \"flipyou\",\n343\t      filters: {\n344\t        stuck: {\n345\t          nonterminalAged: false,\n346\t          highAttempts: false,\n347\t          settledWithoutTx: false,\n348\t          refunds: true,\n349\t        },\n350\t      },\n351\t    });\n352\t\n353\t    expect(mock.calls[0].text).toContain(\"r.phase = 'expired'\");\n354\t  });\n355\t\n356\t  it(\"no stuck flags set: predicate short-circuits to a `true` literal so all rows pass\", async () => {\n357\t    const mock = createSqlMock([[], [{ value: 0 }]]);\n358\t    await listRounds({ sql: mock.sql, game: \"flipyou\" });\n359\t    // The negation of \"any stuck flag set\" is `true` when none are set; the\n360\t    // template binds that boolean directly.\n361\t    expect(mock.calls[0].values).toContain(true);\n362\t  });\n363\t\n364\t  it(\"pagination: page/pageSize bound to limit + offset; totalPages = ceil(totalCount / pageSize)\", async () => {\n365\t    const mock = createSqlMock([[], [{ value: 75 }]]);\n366\t    const result = await listRounds({\n367\t      sql: mock.sql,\n368\t      game: \"flipyou\",\n369\t      page: 2,\n370\t      pageSize: 25,\n371\t    });\n372\t\n373\t    expect(result.pagination).toEqual({\n374\t      page: 2,\n375\t      pageSize: 25,\n376\t      totalCount: 75,\n377\t      totalPages: 3,\n378\t    });\n379\t    // limit, offset bound. Offset should be (page-1)*pageSize = 25.\n380\t    expect(mock.calls[0].values).toContain(25);\n381\t    expect(mock.calls[0].values).toContain(25); // pageSize too\n382\t  });\n383\t\n384\t  it(\"pagination: clamps invalid page to 1 and clamps oversize pageSize to PEEK_GAME_ROUNDS_MAX_PAGE_SIZE\", async () => {\n385\t    const mock = createSqlMock([[], [{ value: 0 }]]);\n386\t\n387\t    const result = await listRounds({\n388\t      sql: mock.sql,\n389\t      game: \"flipyou\",\n390\t      page: -3,\n391\t      pageSize: 99999,\n392\t    });\n393\t\n394\t    expect(result.pagination.page).toBe(1);\n395\t    expect(result.pagination.pageSize).toBe(PEEK_GAME_ROUNDS_MAX_PAGE_SIZE);\n396\t  });\n397\t\n398\t  it(\"string count coercion: postgres ::text counts convert to numbers\", async () => {\n399\t    const mock = createSqlMock([[], [{ value: \"42\" }]]);\n400\t    const result = await listRounds({ sql: mock.sql, game: \"flipyou\" });\n401\t    expect(result.pagination.totalCount).toBe(42);\n402\t  });\n403\t\n404\t  it(\"settleAttempts string coercion: numeric string from postgres still parses to integer\", async () => {\n405\t    const mock = createSqlMock([\n406\t      [\n407\t        {\n408\t          pda: \"pda-1\",\n409\t          game: \"flipyou\",\n410\t          matchId: \"m-1\",\n411\t          phase: \"settling\",\n412\t          creator: \"c-1\",\n413\t          targetSlot: null,\n414\t          settleAttempts: \"5\",\n415\t          settleTx: null,\n416\t          resultSide: \"1\",\n417\t          winner: null,\n418\t          amountLamports: \"0\",\n419\t          createdAt: \"2026-04-25T10:00:00.000Z\",\n420\t          updatedAt: \"2026-04-25T10:00:00.000Z\",\n421\t          settledAt: null,\n422\t        },\n423\t      ],\n424\t      [{ value: 1 }],\n425\t    ]);\n426\t\n427\t    const result = await listRounds({ sql: mock.sql, game: \"flipyou\" });\n428\t    expect(result.rows[0].settleAttempts).toBe(5);\n429\t    expect(result.rows[0].resultSide).toBe(1);\n430\t  });\n431\t\n432\t  it(\"load-error: a rejected paged-rows query propagates so the page can render the alert state\", async () => {\n433\t    const mock = createSqlMock([\n434\t      new Error(\"connection refused\"),\n435\t      [{ value: 0 }],\n436\t    ]);\n437\t    await expect(\n438\t      listRounds({ sql: mock.sql, game: \"flipyou\" }),\n439\t    ).rejects.toThrowError(\"connection refused\");\n440\t  });\n441\t\n442\t  it(\"load-error: a rejected count query also propagates\", async () => {\n443\t    const mock = createSqlMock([[], new Error(\"statement timeout\")]);\n444\t    await expect(\n445\t      listRounds({ sql: mock.sql, game: \"flipyou\" }),\n446\t    ).rejects.toThrowError(\"statement timeout\");\n447\t  });\n448\t});\n449\t\n450\tdescribe(\"listCloseCallRounds\", () => {\n451\t  it(\"populated: shapes Close Call rows and preserves u64 prices/pools as text\", async () => {\n452\t    const ccRows = [\n453\t      {\n454\t        pda: \"cc-pda-1\",\n455\t        roundId: \"rd-1\",\n456\t        phase: \"settled\",\n457\t        outcome: \"green\",\n458\t        openPrice: \"65000000000\",\n459\t        openPriceExpo: -8,\n460\t        closePrice: \"66000000000\",\n461\t        greenPoolLamports: \"1000000\",\n462\t        redPoolLamports: \"750000\",\n463\t        totalFeeLamports: \"50000\",\n464\t        settleTx: \"cc-tx-1\",\n465\t        createdAt: \"2026-04-25T10:00:00.000Z\",\n466\t        settledAt: \"2026-04-25T10:05:00.000Z\",\n467\t      },\n468\t      {\n469\t        pda: \"cc-pda-2\",\n470\t        roundId: \"rd-2\",\n471\t        phase: \"open\",\n472\t        outcome: \"pending\",\n473\t        openPrice: \"65000000000\",\n474\t        openPriceExpo: -8,\n475\t        closePrice: null,\n476\t        greenPoolLamports: \"0\",\n477\t        redPoolLamports: \"0\",\n478\t        totalFeeLamports: \"0\",\n479\t        settleTx: null,\n480\t        createdAt: \"2026-04-25T10:00:00.000Z\",\n481\t        settledAt: null,\n482\t      },\n483\t    ];\n484\t    const mock = createSqlMock([ccRows, [{ value: 2 }]]);\n485\t\n486\t    const result = await listCloseCallRounds({ sql: mock.sql });\n487\t\n488\t    expect(result.rows).toHaveLength(2);\n489\t    expect(result.rows[0]).toEqual({\n490\t      pda: \"cc-pda-1\",\n491\t      roundId: \"rd-1\",\n492\t      phase: \"settled\",\n493\t      outcome: \"green\",\n494\t      openPrice: \"65000000000\",\n495\t      openPriceExpo: -8,\n496\t      closePrice: \"66000000000\",\n497\t      greenPoolLamports: \"1000000\",\n498\t      redPoolLamports: \"750000\",\n499\t      totalFeeLamports: \"50000\",\n500\t      settleTx: \"cc-tx-1\",\n501\t      createdAt: \"2026-04-25T10:00:00.000Z\",\n502\t      settledAt: \"2026-04-25T10:05:00.000Z\",\n503\t    });\n504\t    // Null-friendly: closePrice/settleTx/settledAt all survive.\n505\t    expect(result.rows[1].closePrice).toBeNull();\n506\t    expect(result.rows[1].settleTx).toBeNull();\n507\t    expect(result.rows[1].settledAt).toBeNull();\n508\t\n509\t    expect(result.pagination).toEqual({\n510\t      page: 1,\n511\t      pageSize: PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n512\t      totalCount: 2,\n513\t      totalPages: 1,\n514\t    });\n515\t\n516\t    expect(mock.calls).toHaveLength(2);\n517\t    expect(mock.calls[0].text).toContain(\"from closecall_rounds cc\");\n518\t    expect(mock.calls[0].text).toContain(\"order by cc.created_at desc\");\n519\t    expect(mock.calls[1].text).toContain(\"count(*)::int\");\n520\t  });\n521\t\n522\t  it(\"phase + outcome filters: both bind through to SQL parameters when set\", async () => {\n523\t    const mock = createSqlMock([[], [{ value: 0 }]]);\n524\t\n525\t    await listCloseCallRounds({\n526\t      sql: mock.sql,\n527\t      filters: { phase: \"settled\", outcome: \"red\" },\n528\t    });\n529\t\n530\t    expect(mock.calls[0].values).toContain(\"settled\");\n531\t    expect(mock.calls[0].values).toContain(\"red\");\n532\t  });\n533\t\n534\t  it(\"stuck filter: settledWithoutTx hard-codes the closecall game in the NOT EXISTS subquery\", async () => {\n535\t    const mock = createSqlMock([[], [{ value: 0 }]]);\n536\t\n537\t    await listCloseCallRounds({\n538\t      sql: mock.sql,\n539\t      filters: {\n540\t        stuck: {\n541\t          nonterminalAged: false,\n542\t          settledWithoutTx: true,\n543\t          refunds: false,\n544\t        },\n545\t      },\n546\t    });\n547\t\n548\t    expect(mock.calls[0].text).toContain(\"not exists\");\n549\t    // Hard-coded as 'closecall' (no `r.game` join column on closecall_rounds).\n550\t    expect(mock.calls[0].text).toContain(\"t.game = 'closecall'\");\n551\t    expect(mock.calls[0].text).toContain(\"t.match_id = cc.round_id\");\n552\t  });\n553\t\n554\t  it(\"stuck filter: refunds matches phase = 'refunded' OR outcome = 'refund' so a settled-with-refund-outcome row is captured\", async () => {\n555\t    const mock = createSqlMock([[], [{ value: 0 }]]);\n556\t\n557\t    await listCloseCallRounds({\n558\t      sql: mock.sql,\n559\t      filters: {\n560\t        stuck: {\n561\t          nonterminalAged: false,\n562\t          settledWithoutTx: false,\n563\t          refunds: true,\n564\t        },\n565\t      },\n566\t    });\n567\t\n568\t    expect(mock.calls[0].text).toContain(\"cc.phase = 'refunded'\");\n569\t    expect(mock.calls[0].text).toContain(\"cc.outcome = 'refund'\");\n570\t  });\n571\t\n572\t  it(\"stuck filter: nonterminalAged binds the age interval and matches phase = 'open'\", async () => {\n573\t    const mock = createSqlMock([[], [{ value: 0 }]]);\n574\t\n575\t    await listCloseCallRounds({\n576\t      sql: mock.sql,\n577\t      filters: {\n578\t        stuck: {\n579\t          nonterminalAged: true,\n580\t          settledWithoutTx: false,\n581\t          refunds: false,\n582\t        },\n583\t      },\n584\t      thresholds: { ageMinutes: 30, maxSettleAttempts: 3 },\n585\t    });\n586\t\n587\t    expect(mock.calls[0].values).toContain(\"30 minutes\");\n588\t    expect(mock.calls[0].text).toContain(\"cc.phase = 'open'\");\n589\t  });\n590\t\n591\t  it(\"sparse: empty result returns 1 logical page\", async () => {\n592\t    const mock = createSqlMock([[], [{ value: 0 }]]);\n593\t    const result = await listCloseCallRounds({ sql: mock.sql });\n594\t    expect(result.rows).toEqual([]);\n595\t    expect(result.pagination.totalPages).toBe(1);\n596\t  });\n597\t\n598\t  it(\"openPriceExpo string coercion: '-8' string parses to integer -8\", async () => {\n599\t    const mock = createSqlMock([\n600\t      [\n601\t        {\n602\t          pda: \"cc-pda-x\",\n603\t          roundId: \"rd-x\",\n604\t          phase: \"open\",\n605\t          outcome: \"pending\",\n606\t          openPrice: \"1\",\n607\t          openPriceExpo: \"-8\",\n608\t          closePrice: null,\n609\t          greenPoolLamports: \"0\",\n610\t          redPoolLamports: \"0\",\n611\t          totalFeeLamports: \"0\",\n612\t          settleTx: null,\n613\t          createdAt: \"2026-04-25T10:00:00.000Z\",\n614\t          settledAt: null,\n615\t        },\n616\t      ],\n617\t      [{ value: 1 }],\n618\t    ]);\n619\t\n620\t    const result = await listCloseCallRounds({ sql: mock.sql });\n621\t    expect(result.rows[0].openPriceExpo).toBe(-8);\n622\t  });\n623\t\n624\t  it(\"load-error: a rejected paged-rows query propagates\", async () => {\n625\t    const mock = createSqlMock([\n626\t      new Error(\"connection refused\"),\n627\t      [{ value: 0 }],\n628\t    ]);\n629\t    await expect(listCloseCallRounds({ sql: mock.sql })).rejects.toThrowError(\n630\t      \"connection refused\",\n631\t    );\n632\t  });\n633\t\n634\t  it(\"load-error: a rejected count query propagates\", async () => {\n635\t    const mock = createSqlMock([[], new Error(\"statement timeout\")]);\n636\t    await expect(listCloseCallRounds({ sql: mock.sql })).rejects.toThrowError(\n637\t      \"statement timeout\",\n638\t    );\n639\t  });\n640\t});\n641\t"}]},"parent_tool_use_id":null,"session_id":"e3ee47e7-eefe-4e12-a068-a08216780c1e","uuid":"50c857eb-8c7f-4af1-8036-6b459d15d924","timestamp":"2026-04-25T13:31:18.207Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-game-rounds.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n  PEEK_GAME_ROUNDS_MAX_PAGE_SIZE,\n  PEEK_ROUND_STUCK_DEFAULTS,\n  listCloseCallRounds,\n  listRounds,\n} from \"../get-game-rounds\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\n// SQL mock that records every tagged-template call and returns a queued\n// response per call (rows or an Error to reject). Mirrors the pattern used in\n// get-games-overview.test.ts and get-growth-referrals.test.ts so query test\n// behaviour stays consistent.\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\n// Two queries fire in parallel via Promise.all per call:\n//   0 — paged rows\n//   1 — count(*) for pagination\n\ndescribe(\"listRounds (FlipYou + Pot Shot)\", () => {\n  it(\"populated: shapes rows for FlipYou with u64 strings preserved end-to-end\", async () => {\n    const flipyouRows = [\n      {\n        pda: \"pda-1\",\n        game: \"flipyou\",\n        matchId: \"m-1\",\n        phase: \"settled\",\n        creator: \"creator-1\",\n        targetSlot: \"1234567890\",\n        settleAttempts: 1,\n        settleTx: \"tx-1\",\n        resultSide: 0,\n        winner: \"creator-1\",\n        amountLamports: \"9007199254740992\", // > Number.MAX_SAFE_INTEGER\n        createdAt: \"2026-04-25T10:00:00.000Z\",\n        updatedAt: \"2026-04-25T10:01:00.000Z\",\n        settledAt: \"2026-04-25T10:00:30.000Z\",\n      },\n      {\n        pda: \"pda-2\",\n        game: \"flipyou\",\n        matchId: \"m-2\",\n        phase: \"expired\",\n        creator: \"creator-2\",\n        targetSlot: null,\n        settleAttempts: 4,\n        settleTx: null,\n        resultSide: null,\n        winner: null,\n        amountLamports: \"100000\",\n        createdAt: \"2026-04-25T09:00:00.000Z\",\n        updatedAt: \"2026-04-25T09:30:00.000Z\",\n        settledAt: null,\n      },\n    ];\n    const mock = createSqlMock([flipyouRows, [{ value: 2 }]]);\n\n    const result = await listRounds({ sql: mock.sql, game: \"flipyou\" });\n\n    expect(result.rows).toHaveLength(2);\n    expect(result.rows[0]).toEqual({\n      game: \"flipyou\",\n      pda: \"pda-1\",\n      matchId: \"m-1\",\n      phase: \"settled\",\n      creator: \"creator-1\",\n      targetSlot: \"1234567890\",\n      settleAttempts: 1,\n      settleTx: \"tx-1\",\n      resultSide: 0,\n      winner: \"creator-1\",\n      amountLamports: \"9007199254740992\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      updatedAt: \"2026-04-25T10:01:00.000Z\",\n      settledAt: \"2026-04-25T10:00:30.000Z\",\n    });\n    // Null-friendly columns survive: targetSlot, settleTx, resultSide, winner, settledAt.\n    expect(result.rows[1].targetSlot).toBeNull();\n    expect(result.rows[1].settleTx).toBeNull();\n    expect(result.rows[1].resultSide).toBeNull();\n    expect(result.rows[1].winner).toBeNull();\n    expect(result.rows[1].settledAt).toBeNull();\n\n    expect(result.pagination).toEqual({\n      page: 1,\n      pageSize: PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n      totalCount: 2,\n      totalPages: 1,\n    });\n\n    // Two queries fired in parallel: rows + count.\n    expect(mock.calls).toHaveLength(2);\n    expect(mock.calls[0].text).toContain(\"from rounds r\");\n    expect(mock.calls[0].text).toContain(\"order by r.created_at desc\");\n    expect(mock.calls[0].text).toContain(\"limit \");\n    expect(mock.calls[0].text).toContain(\" offset \");\n    expect(mock.calls[1].text).toContain(\"count(*)::int\");\n    // Game predicate is bound to the requested game id.\n    expect(mock.calls[0].values).toContain(\"flipyou\");\n    expect(mock.calls[1].values).toContain(\"flipyou\");\n  });\n\n  it(\"works for potshot game id (same SQL, different game predicate)\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          pda: \"pda-ps\",\n          game: \"potshot\",\n          matchId: \"m-ps\",\n          phase: \"created\",\n          creator: \"creator-ps\",\n          targetSlot: \"777\",\n          settleAttempts: 0,\n          settleTx: null,\n          resultSide: null,\n          winner: null,\n          amountLamports: \"5000000\",\n          createdAt: \"2026-04-25T10:00:00.000Z\",\n          updatedAt: \"2026-04-25T10:00:00.000Z\",\n          settledAt: null,\n        },\n      ],\n      [{ value: 1 }],\n    ]);\n\n    const result = await listRounds({ sql: mock.sql, game: \"potshot\" });\n\n    expect(result.rows).toHaveLength(1);\n    expect(result.rows[0].game).toBe(\"potshot\");\n    expect(mock.calls[0].values).toContain(\"potshot\");\n    expect(mock.calls[1].values).toContain(\"potshot\");\n  });\n\n  it(\"filters out rows whose game id is not a member of PEEK_ROUNDS_GAME_IDS so out-of-band data cannot leak\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          pda: \"pda-1\",\n          game: \"flipyou\",\n          matchId: \"m-1\",\n          phase: \"settled\",\n          creator: \"c-1\",\n          targetSlot: null,\n          settleAttempts: 0,\n          settleTx: null,\n          resultSide: null,\n          winner: null,\n          amountLamports: \"0\",\n          createdAt: \"2026-04-25T10:00:00.000Z\",\n          updatedAt: \"2026-04-25T10:00:00.000Z\",\n          settledAt: null,\n        },\n        {\n          // Out-of-band game id (e.g. a future migration row); must not surface.\n          pda: \"pda-bogus\",\n          game: \"crash\",\n          matchId: \"m-bogus\",\n          phase: \"settled\",\n          creator: \"c-bogus\",\n          targetSlot: null,\n          settleAttempts: 0,\n          settleTx: null,\n          resultSide: null,\n          winner: null,\n          amountLamports: \"0\",\n          createdAt: \"2026-04-25T10:00:00.000Z\",\n          updatedAt: \"2026-04-25T10:00:00.000Z\",\n          settledAt: null,\n        },\n      ],\n      [{ value: 2 }],\n    ]);\n\n    const result = await listRounds({ sql: mock.sql, game: \"flipyou\" });\n\n    expect(result.rows.map((r) => r.pda)).toEqual([\"pda-1\"]);\n    expect(result.rows[0].game).toBe(\"flipyou\");\n  });\n\n  it(\"sparse: empty SQL response yields empty rows + zero count + 1 logical page\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    const result = await listRounds({ sql: mock.sql, game: \"flipyou\" });\n\n    expect(result.rows).toEqual([]);\n    expect(result.pagination).toEqual({\n      page: 1,\n      pageSize: PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n      totalCount: 0,\n      totalPages: 1,\n    });\n  });\n\n  it(\"phase filter: when filter set the phase value is bound; when unset the predicate skips\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n    await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      filters: { phase: \"settling\" },\n    });\n    expect(mock.calls[0].values).toContain(\"settling\");\n    // The \"no phase filter\" branch is encoded as a boolean literal in the\n    // template; when phase is set, the literal must be `false` so the SQL\n    // requires an exact phase match.\n    expect(mock.calls[0].values).toContain(false);\n\n    const mock2 = createSqlMock([[], [{ value: 0 }]]);\n    await listRounds({ sql: mock2.sql, game: \"flipyou\" });\n    // When unset, the boolean literal flips to `true` (skip predicate).\n    expect(mock2.calls[0].values).toContain(true);\n  });\n\n  it(\"search filter: trims whitespace and forwards a LIKE wildcard so partial pdas/match ids/creators match\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      filters: { search: \"  abc  \" },\n    });\n\n    // Bound with wildcards so partial matches work.\n    expect(mock.calls[0].values).toContain(\"%abc%\");\n    expect(mock.calls[1].values).toContain(\"%abc%\");\n  });\n\n  it(\"date filters: forwards trimmed ISO strings to the SQL bound parameters\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n    await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      filters: {\n        fromDate: \"2026-04-01\",\n        toDate: \"2026-04-25\",\n      },\n    });\n    expect(mock.calls[0].values).toContain(\"2026-04-01\");\n    expect(mock.calls[0].values).toContain(\"2026-04-25\");\n  });\n\n  it(\"stuck filter: nonterminalAged binds the age interval and a `true` flag; other stuck predicates are `false`\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      filters: {\n        stuck: {\n          nonterminalAged: true,\n          highAttempts: false,\n          settledWithoutTx: false,\n          refunds: false,\n        },\n      },\n    });\n\n    // Default age threshold (5 minutes) is bound as a postgres interval string.\n    expect(mock.calls[0].values).toContain(\n      `${PEEK_ROUND_STUCK_DEFAULTS.ageMinutes} minutes`,\n    );\n    // Booleans for the four stuck flags get bound directly.\n    const trueCount = mock.calls[0].values.filter((v) => v === true).length;\n    const falseCount = mock.calls[0].values.filter((v) => v === false).length;\n    expect(trueCount).toBeGreaterThan(0);\n    expect(falseCount).toBeGreaterThan(0);\n  });\n\n  it(\"stuck filter: highAttempts binds the maxSettleAttempts threshold (overridable per-call)\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      filters: {\n        stuck: {\n          nonterminalAged: false,\n          highAttempts: true,\n          settledWithoutTx: false,\n          refunds: false,\n        },\n      },\n      thresholds: { maxSettleAttempts: 7 },\n    });\n\n    expect(mock.calls[0].values).toContain(7);\n    expect(mock.calls[0].text).toContain(\"r.settle_attempts >\");\n  });\n\n  it(\"stuck filter: settledWithoutTx emits the correlated NOT EXISTS subquery against transactions\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      filters: {\n        stuck: {\n          nonterminalAged: false,\n          highAttempts: false,\n          settledWithoutTx: true,\n          refunds: false,\n        },\n      },\n    });\n\n    expect(mock.calls[0].text).toContain(\"not exists\");\n    expect(mock.calls[0].text).toContain(\"from transactions t\");\n    expect(mock.calls[0].text).toContain(\"t.tx_type in ('payout','refund')\");\n  });\n\n  it(\"stuck filter: refunds maps to phase = 'expired' for FlipYou + Pot Shot\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      filters: {\n        stuck: {\n          nonterminalAged: false,\n          highAttempts: false,\n          settledWithoutTx: false,\n          refunds: true,\n        },\n      },\n    });\n\n    expect(mock.calls[0].text).toContain(\"r.phase = 'expired'\");\n  });\n\n  it(\"no stuck flags set: predicate short-circuits to a `true` literal so all rows pass\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n    await listRounds({ sql: mock.sql, game: \"flipyou\" });\n    // The negation of \"any stuck flag set\" is `true` when none are set; the\n    // template binds that boolean directly.\n    expect(mock.calls[0].values).toContain(true);\n  });\n\n  it(\"pagination: page/pageSize bound to limit + offset; totalPages = ceil(totalCount / pageSize)\", async () => {\n    const mock = createSqlMock([[], [{ value: 75 }]]);\n    const result = await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      page: 2,\n      pageSize: 25,\n    });\n\n    expect(result.pagination).toEqual({\n      page: 2,\n      pageSize: 25,\n      totalCount: 75,\n      totalPages: 3,\n    });\n    // limit, offset bound. Offset should be (page-1)*pageSize = 25.\n    expect(mock.calls[0].values).toContain(25);\n    expect(mock.calls[0].values).toContain(25); // pageSize too\n  });\n\n  it(\"pagination: clamps invalid page to 1 and clamps oversize pageSize to PEEK_GAME_ROUNDS_MAX_PAGE_SIZE\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    const result = await listRounds({\n      sql: mock.sql,\n      game: \"flipyou\",\n      page: -3,\n      pageSize: 99999,\n    });\n\n    expect(result.pagination.page).toBe(1);\n    expect(result.pagination.pageSize).toBe(PEEK_GAME_ROUNDS_MAX_PAGE_SIZE);\n  });\n\n  it(\"string count coercion: postgres ::text counts convert to numbers\", async () => {\n    const mock = createSqlMock([[], [{ value: \"42\" }]]);\n    const result = await listRounds({ sql: mock.sql, game: \"flipyou\" });\n    expect(result.pagination.totalCount).toBe(42);\n  });\n\n  it(\"settleAttempts string coercion: numeric string from postgres still parses to integer\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          pda: \"pda-1\",\n          game: \"flipyou\",\n          matchId: \"m-1\",\n          phase: \"settling\",\n          creator: \"c-1\",\n          targetSlot: null,\n          settleAttempts: \"5\",\n          settleTx: null,\n          resultSide: \"1\",\n          winner: null,\n          amountLamports: \"0\",\n          createdAt: \"2026-04-25T10:00:00.000Z\",\n          updatedAt: \"2026-04-25T10:00:00.000Z\",\n          settledAt: null,\n        },\n      ],\n      [{ value: 1 }],\n    ]);\n\n    const result = await listRounds({ sql: mock.sql, game: \"flipyou\" });\n    expect(result.rows[0].settleAttempts).toBe(5);\n    expect(result.rows[0].resultSide).toBe(1);\n  });\n\n  it(\"load-error: a rejected paged-rows query propagates so the page can render the alert state\", async () => {\n    const mock = createSqlMock([\n      new Error(\"connection refused\"),\n      [{ value: 0 }],\n    ]);\n    await expect(\n      listRounds({ sql: mock.sql, game: \"flipyou\" }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n\n  it(\"load-error: a rejected count query also propagates\", async () => {\n    const mock = createSqlMock([[], new Error(\"statement timeout\")]);\n    await expect(\n      listRounds({ sql: mock.sql, game: \"flipyou\" }),\n    ).rejects.toThrowError(\"statement timeout\");\n  });\n});\n\ndescribe(\"listCloseCallRounds\", () => {\n  it(\"populated: shapes Close Call rows and preserves u64 prices/pools as text\", async () => {\n    const ccRows = [\n      {\n        pda: \"cc-pda-1\",\n        roundId: \"rd-1\",\n        phase: \"settled\",\n        outcome: \"green\",\n        openPrice: \"65000000000\",\n        openPriceExpo: -8,\n        closePrice: \"66000000000\",\n        greenPoolLamports: \"1000000\",\n        redPoolLamports: \"750000\",\n        totalFeeLamports: \"50000\",\n        settleTx: \"cc-tx-1\",\n        createdAt: \"2026-04-25T10:00:00.000Z\",\n        settledAt: \"2026-04-25T10:05:00.000Z\",\n      },\n      {\n        pda: \"cc-pda-2\",\n        roundId: \"rd-2\",\n        phase: \"open\",\n        outcome: \"pending\",\n        openPrice: \"65000000000\",\n        openPriceExpo: -8,\n        closePrice: null,\n        greenPoolLamports: \"0\",\n        redPoolLamports: \"0\",\n        totalFeeLamports: \"0\",\n        settleTx: null,\n        createdAt: \"2026-04-25T10:00:00.000Z\",\n        settledAt: null,\n      },\n    ];\n    const mock = createSqlMock([ccRows, [{ value: 2 }]]);\n\n    const result = await listCloseCallRounds({ sql: mock.sql });\n\n    expect(result.rows).toHaveLength(2);\n    expect(result.rows[0]).toEqual({\n      pda: \"cc-pda-1\",\n      roundId: \"rd-1\",\n      phase: \"settled\",\n      outcome: \"green\",\n      openPrice: \"65000000000\",\n      openPriceExpo: -8,\n      closePrice: \"66000000000\",\n      greenPoolLamports: \"1000000\",\n      redPoolLamports: \"750000\",\n      totalFeeLamports: \"50000\",\n      settleTx: \"cc-tx-1\",\n      createdAt: \"2026-04-25T10:00:00.000Z\",\n      settledAt: \"2026-04-25T10:05:00.000Z\",\n    });\n    // Null-friendly: closePrice/settleTx/settledAt all survive.\n    expect(result.rows[1].closePrice).toBeNull();\n    expect(result.rows[1].settleTx).toBeNull();\n    expect(result.rows[1].settledAt).toBeNull();\n\n    expect(result.pagination).toEqual({\n      page: 1,\n      pageSize: PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n      totalCount: 2,\n      totalPages: 1,\n    });\n\n    expect(mock.calls).toHaveLength(2);\n    expect(mock.calls[0].text).toContain(\"from closecall_rounds cc\");\n    expect(mock.calls[0].text).toContain(\"order by cc.created_at desc\");\n    expect(mock.calls[1].text).toContain(\"count(*)::int\");\n  });\n\n  it(\"phase + outcome filters: both bind through to SQL parameters when set\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listCloseCallRounds({\n      sql: mock.sql,\n      filters: { phase: \"settled\", outcome: \"red\" },\n    });\n\n    expect(mock.calls[0].values).toContain(\"settled\");\n    expect(mock.calls[0].values).toContain(\"red\");\n  });\n\n  it(\"stuck filter: settledWithoutTx hard-codes the closecall game in the NOT EXISTS subquery\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listCloseCallRounds({\n      sql: mock.sql,\n      filters: {\n        stuck: {\n          nonterminalAged: false,\n          settledWithoutTx: true,\n          refunds: false,\n        },\n      },\n    });\n\n    expect(mock.calls[0].text).toContain(\"not exists\");\n    // Hard-coded as 'closecall' (no `r.game` join column on closecall_rounds).\n    expect(mock.calls[0].text).toContain(\"t.game = 'closecall'\");\n    expect(mock.calls[0].text).toContain(\"t.match_id = cc.round_id\");\n  });\n\n  it(\"stuck filter: refunds matches phase = 'refunded' OR outcome = 'refund' so a settled-with-refund-outcome row is captured\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listCloseCallRounds({\n      sql: mock.sql,\n      filters: {\n        stuck: {\n          nonterminalAged: false,\n          settledWithoutTx: false,\n          refunds: true,\n        },\n      },\n    });\n\n    expect(mock.calls[0].text).toContain(\"cc.phase = 'refunded'\");\n    expect(mock.calls[0].text).toContain(\"cc.outcome = 'refund'\");\n  });\n\n  it(\"stuck filter: nonterminalAged binds the age interval and matches phase = 'open'\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n\n    await listCloseCallRounds({\n      sql: mock.sql,\n      filters: {\n        stuck: {\n          nonterminalAged: true,\n          settledWithoutTx: false,\n          refunds: false,\n        },\n      },\n      thresholds: { ageMinutes: 30, maxSettleAttempts: 3 },\n    });\n\n    expect(mock.calls[0].values).toContain(\"30 minutes\");\n    expect(mock.calls[0].text).toContain(\"cc.phase = 'open'\");\n  });\n\n  it(\"sparse: empty result returns 1 logical page\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n    const result = await listCloseCallRounds({ sql: mock.sql });\n    expect(result.rows).toEqual([]);\n    expect(result.pagination.totalPages).toBe(1);\n  });\n\n  it(\"openPriceExpo string coercion: '-8' string parses to integer -8\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          pda: \"cc-pda-x\",\n          roundId: \"rd-x\",\n          phase: \"open\",\n          outcome: \"pending\",\n          openPrice: \"1\",\n          openPriceExpo: \"-8\",\n          closePrice: null,\n          greenPoolLamports: \"0\",\n          redPoolLamports: \"0\",\n          totalFeeLamports: \"0\",\n          settleTx: null,\n          createdAt: \"2026-04-25T10:00:00.000Z\",\n          settledAt: null,\n        },\n      ],\n      [{ value: 1 }],\n    ]);\n\n    const result = await listCloseCallRounds({ sql: mock.sql });\n    expect(result.rows[0].openPriceExpo).toBe(-8);\n  });\n\n  it(\"load-error: a rejected paged-rows query propagates\", async () => {\n    const mock = createSqlMock([\n      new Error(\"connection refused\"),\n      [{ value: 0 }],\n    ]);\n    await expect(listCloseCallRounds({ sql: mock.sql })).rejects.toThrowError(\n      \"connection refused\",\n    );\n  });\n\n  it(\"load-error: a rejected count query propagates\", async () => {\n    const mock = createSqlMock([[], new Error(\"statement timeout\")]);\n    await expect(listCloseCallRounds({ sql: mock.sql })).rejects.toThrowError(\n      \"statement timeout\",\n    );\n  });\n});\n","numLines":641,"startLine":1,"totalLines":641}}}
