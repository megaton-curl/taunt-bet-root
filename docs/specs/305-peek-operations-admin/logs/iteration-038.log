      </SummaryItem>","-      <SummaryItem label=\"Green pool (lamports)\">","-        {formatNumber(round.greenPoolLamports)}","-      </SummaryItem>","-      <SummaryItem label=\"Red pool (lamports)\">","-        {formatNumber(round.redPoolLamports)}","-      </SummaryItem>","-      <SummaryItem label=\"Total fee (lamports)\">","-        {formatNumber(round.totalFeeLamports)}","-      </SummaryItem>","-      <SummaryItem label=\"Settle tx\">","-        {round.settleTx ? (","-          <Mono title={round.settleTx}>{round.settleTx}</Mono>","-        ) : (","-          \"—\"","-        )}","-      </SummaryItem>","-      <SummaryItem label=\"Created\">{round.createdAt}</SummaryItem>","-      <SummaryItem label=\"Settled\">{round.settledAt ?? \"—\"}</SummaryItem>","-    </dl>","-  );","-}","-","-function EntriesTable({","-  entries,","-  game,","-}: {","-  entries: ReadonlyArray<PeekRoundEntryRow>;","-  game: PeekGameId;","-}) {","-  if (entries.length === 0) {","-    return (","-      <div role=\"status\" style={emptyStyle}>","-        <p style={emptyTitleStyle}>No entries recorded for this round.</p>","-        <p style={emptyBodyStyle}>","-          The <code style={codeStyle}>game_entries</code> table has no rows","-          joined to this round PDA. This is normal for rounds that were created","-          but never joined.","-        </p>","-      </div>","-    );","-  }","-  return (","-    <div style={wrapperStyle}>","-      <table style={tableStyle}>","-        <thead>","-          <tr style={headerRowStyle}>","-            <th style={headerCellStyle(\"left\")}>Created</th>","-            <th style={headerCellStyle(\"left\")}>User</th>","-            <th style={headerCellStyle(\"left\")}>Wallet</th>","-            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>","-            <th style={headerCellStyle(\"left\")}>","-              {game === \"closecall\" ? \"Side\" : \"Side\"}","-            </th>","-            <th style={headerCellStyle(\"left\")}>Winner</th>","-            <th style={headerCellStyle(\"right\")}>Payout (lamports)</th>","-            <th style={headerCellStyle(\"left\")}>Settled</th>","-          </tr>","-        </thead>","-        <tbody>","-          {entries.map((entry) => (","-            <tr key={entry.id} style={bodyRowStyle}>","-              <td style={bodyCellStyle(\"left\")}>{entry.createdAt}</td>","-              <td style={bodyCellStyle(\"left\")}>","-                <Link","-                  href={`/users/${entry.userId}`}","-                  style={linkStyle}","-                  title={entry.userId}","-                >","-                  {entry.username ?? truncate(entry.userId, 12)}","-                </Link>","-              </td>","-              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>","-                <span title={entry.wallet}>{truncate(entry.wallet, 12)}</span>","-              </td>","-              <td style={bodyCellStyle(\"right\")}>","-                {formatNumber(entry.amountLamports)}","-              </td>","-              <td style={bodyCellStyle(\"left\")}>{entry.side ?? \"—\"}</td>","-              <td style={bodyCellStyle(\"left\")}>","-                {entry.isWinner === null ? \"—\" : entry.isWinner ? \"yes\" : \"no\"}","-              </td>","-              <td style={bodyCellStyle(\"right\")}>","-                {formatNumber(entry.payoutLamports)}","-              </td>","-              <td style={bodyCellStyle(\"left\")}>{entry.settledAt ?? \"—\"}</td>","-            </tr>","-          ))}","-        </tbody>","-      </table>","-    </div>","-  );","-}","-","-function TransactionsTable({","-  transactions,","-}: {","-  transactions: ReadonlyArray<PeekRoundTransactionRow>;","-}) {","-  if (transactions.length === 0) {","-    return (","-      <div role=\"status\" style={emptyStyle}>","-        <p style={emptyTitleStyle}>No transactions recorded for this round.</p>","-        <p style={emptyBodyStyle}>","-          The <code style={codeStyle}>transactions</code> table has no rows","-          joined to this round. Settled rounds without transaction rows are an","-          attention state surfaced by the stuck-state filters on{\" \"}","-          <code style={codeStyle}>/games/[game]</code>.","-        </p>","-      </div>","-    );","-  }","-  return (","-    <div style={wrapperStyle}>","-      <table style={tableStyle}>","-        <thead>","-          <tr style={headerRowStyle}>","-            <th style={headerCellStyle(\"left\")}>Created</th>","-            <th style={headerCellStyle(\"left\")}>Type</th>","-            <th style={headerCellStyle(\"left\")}>User</th>","-            <th style={headerCellStyle(\"left\")}>Wallet</th>","-            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>","-            <th style={headerCellStyle(\"left\")}>Tx signature</th>","-          </tr>","-        </thead>","-        <tbody>","-          {transactions.map((tx) => (","-            <tr key={tx.id} style={bodyRowStyle}>","-              <td style={bodyCellStyle(\"left\")}>{tx.createdAt}</td>","-              <td style={bodyCellStyle(\"left\")}>","-                <StatusChip label={tx.txType} tone=\"info\" />","-              </td>","-              <td style={bodyCellStyle(\"left\")}>","-                {tx.userId ? (","-                  <Link","-                    href={`/users/${tx.userId}`}","-                    style={linkStyle}","-                    title={tx.userId}","-                  >","-                    {tx.username ?? truncate(tx.userId, 12)}","-                  </Link>","-                ) : (","-                  \"—\"","-                )}","-              </td>","-              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>","-                <span title={tx.wallet}>{truncate(tx.wallet, 12)}</span>","-              </td>","-              <td style={bodyCellStyle(\"right\")}>","-                {formatNumber(tx.amountLa