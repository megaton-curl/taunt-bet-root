{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B2xEUYEHJavhjmjdogfwGv","type":"tool_result","content":"1\t// /games/[game]/rounds/[roundId] — round-level participant + transaction audit\n2\t// (FR-8).\n3\t//\n4\t// Resolves the URL `roundId` against the round's on-chain `pda` (the same key\n5\t// shape for FlipYou, Pot Shot, and Close Call). Renders the round summary,\n6\t// then the per-round entries from `game_entries` and the per-round\n7\t// `transactions` rows so an operator can confirm who participated and which\n8\t// on-chain SOL movements settled the round. Read-only.\n9\timport { notFound } from \"next/navigation\";\n10\timport Link from \"next/link\";\n11\timport type { CSSProperties, ReactNode } from \"react\";\n12\timport { StatusChip } from \"../../../../../src/components/status-chip\";\n13\timport {\n14\t  PEEK_GAME_IDS,\n15\t  type PeekCloseCallOutcome,\n16\t  type PeekCloseCallPhase,\n17\t  type PeekCloseCallRoundRow,\n18\t  type PeekGameId,\n19\t  type PeekRoundDetail,\n20\t  type PeekRoundEntryRow,\n21\t  type PeekRoundPhase,\n22\t  type PeekRoundRow,\n23\t  type PeekRoundTransactionRow,\n24\t  type PeekStatusTone,\n25\t} from \"../../../../../src/lib/types/peek\";\n26\timport {\n27\t  getPeekActorContext,\n28\t  isRouteAllowedForRole,\n29\t} from \"../../../../../src/server/access-policy\";\n30\timport { getRoundDetail } from \"../../../../../src/server/db/queries/get-round-detail\";\n31\t\n32\texport const dynamic = \"force-dynamic\";\n33\t\n34\tconst GAME_LABELS: Record<PeekGameId, string> = {\n35\t  flipyou: \"FlipYou\",\n36\t  potshot: \"Pot Shot\",\n37\t  closecall: \"Close Call\",\n38\t};\n39\t\n40\tfunction isPeekGameId(value: string): value is PeekGameId {\n41\t  return (PEEK_GAME_IDS as ReadonlyArray<string>).includes(value);\n42\t}\n43\t\n44\texport default async function RoundDetailPage({\n45\t  params,\n46\t}: {\n47\t  params: Promise<{ game: string; roundId: string }>;\n48\t}) {\n49\t  const { game: gameParam, roundId } = await params;\n50\t  if (!isPeekGameId(gameParam)) {\n51\t    notFound();\n52\t  }\n53\t  const game = gameParam as PeekGameId;\n54\t  const route = `/games/${game}/rounds/${roundId}`;\n55\t\n56\t  const actor = await getPeekActorContext();\n57\t  const allowed = isRouteAllowedForRole(route, actor?.role ?? null);\n58\t\n59\t  if (!allowed) {\n60\t    return (\n61\t      <main style={mainStyle}>\n62\t        <header>\n63\t          <h1>\n64\t            Games · {GAME_LABELS[game]} · Round\n65\t          </h1>\n66\t        </header>\n67\t        <p role=\"alert\" style={errorStyle}>\n68\t          You do not have access to this page.\n69\t        </p>\n70\t      </main>\n71\t    );\n72\t  }\n73\t\n74\t  let detail: PeekRoundDetail | null = null;\n75\t  let loadError: string | null = null;\n76\t\n77\t  try {\n78\t    detail = await getRoundDetail({ game, roundId });\n79\t  } catch (err) {\n80\t    loadError =\n81\t      err instanceof Error ? err.message : \"Round detail could not be loaded.\";\n82\t  }\n83\t\n84\t  if (!loadError && !detail) {\n85\t    notFound();\n86\t  }\n87\t\n88\t  return (\n89\t    <main style={mainStyle}>\n90\t      <header>\n91\t        <p style={breadcrumbStyle}>\n92\t          <Link href=\"/games\" style={breadcrumbLinkStyle}>\n93\t            ← Games\n94\t          </Link>\n95\t          {\" · \"}\n96\t          <Link\n97\t            href={`/games/${game}`}\n98\t            style={breadcrumbLinkStyle}\n99\t          >\n100\t            {GAME_LABELS[game]}\n101\t          </Link>\n102\t        </p>\n103\t        <h1>Round audit · {GAME_LABELS[game]}</h1>\n104\t        <p style={leadStyle}>\n105\t          Round identifier (pda):{\" \"}\n106\t          <code style={codeStyle}>{roundId}</code>. Sources:{\" \"}\n107\t          <code style={codeStyle}>\n108\t            {game === \"closecall\" ? \"closecall_rounds\" : \"rounds\"}\n109\t          </code>\n110\t          {\", \"}\n111\t          <code style={codeStyle}>game_entries</code>,{\" \"}\n112\t          <code style={codeStyle}>transactions</code>.\n113\t        </p>\n114\t      </header>\n115\t\n116\t      {loadError ? (\n117\t        <p role=\"alert\" style={errorStyle}>\n118\t          Round detail unavailable: {loadError}\n119\t        </p>\n120\t      ) : detail ? (\n121\t        <RoundDetailSections detail={detail} />\n122\t      ) : null}\n123\t    </main>\n124\t  );\n125\t}\n126\t\n127\tfunction RoundDetailSections({ detail }: { detail: PeekRoundDetail }) {\n128\t  return (\n129\t    <>\n130\t      <Section heading=\"Round summary\" headingId=\"round-summary-heading\">\n131\t        {detail.game === \"closecall\" ? (\n132\t          <CloseCallSummary round={detail.round} />\n133\t        ) : (\n134\t          <RoundSummary round={detail.round} />\n135\t        )}\n136\t      </Section>\n137\t\n138\t      <Section heading=\"Entries\" headingId=\"entries-heading\">\n139\t        <p style={hintStyle}>\n140\t          {detail.entries.length} participant\n141\t          {detail.entries.length === 1 ? \"\" : \"s\"} from{\" \"}\n142\t          <code style={codeStyle}>game_entries</code> · sorted oldest first.\n143\t        </p>\n144\t        <EntriesTable entries={detail.entries} game={detail.game} />\n145\t      </Section>\n146\t\n147\t      <Section heading=\"Transactions\" headingId=\"transactions-heading\">\n148\t        <p style={hintStyle}>\n149\t          {detail.transactions.length} on-chain SOL movement\n150\t          {detail.transactions.length === 1 ? \"\" : \"s\"} from{\" \"}\n151\t          <code style={codeStyle}>transactions</code> · sorted oldest first.\n152\t        </p>\n153\t        <TransactionsTable transactions={detail.transactions} />\n154\t      </Section>\n155\t    </>\n156\t  );\n157\t}\n158\t\n159\tfunction RoundSummary({ round }: { round: PeekRoundRow }) {\n160\t  return (\n161\t    <dl style={summaryGridStyle}>\n162\t      <SummaryItem label=\"Phase\">\n163\t        <StatusChip label={round.phase} tone={phaseTone(round.phase)} />\n164\t      </SummaryItem>\n165\t      <SummaryItem label=\"Match ID\">\n166\t        <Mono title={round.matchId}>{round.matchId}</Mono>\n167\t      </SummaryItem>\n168\t      <SummaryItem label=\"PDA\">\n169\t        <Mono title={round.pda}>{round.pda}</Mono>\n170\t      </SummaryItem>\n171\t      <SummaryItem label=\"Creator\">\n172\t        <Mono title={round.creator}>{round.creator}</Mono>\n173\t      </SummaryItem>\n174\t      <SummaryItem label=\"Amount (lamports)\">\n175\t        {formatNumber(round.amountLamports)}\n176\t      </SummaryItem>\n177\t      <SummaryItem label=\"Target slot\">\n178\t        {round.targetSlot ? formatNumber(round.targetSlot) : \"—\"}\n179\t      </SummaryItem>\n180\t      <SummaryItem label=\"Settle attempts\">\n181\t        {String(round.settleAttempts)}\n182\t      </SummaryItem>\n183\t      <SummaryItem label=\"Result side\">\n184\t        {round.resultSide === null ? \"—\" : String(round.resultSide)}\n185\t      </SummaryItem>\n186\t      <SummaryItem label=\"Winner\">\n187\t        {round.winner ? <Mono title={round.winner}>{round.winner}</Mono> : \"—\"}\n188\t      </SummaryItem>\n189\t      <SummaryItem label=\"Settle tx\">\n190\t        {round.settleTx ? (\n191\t          <Mono title={round.settleTx}>{round.settleTx}</Mono>\n192\t        ) : (\n193\t          \"—\"\n194\t        )}\n195\t      </SummaryItem>\n196\t      <SummaryItem label=\"Created\">{round.createdAt}</SummaryItem>\n197\t      <SummaryItem label=\"Updated\">{round.updatedAt}</SummaryItem>\n198\t      <SummaryItem label=\"Settled\">{round.settledAt ?? \"—\"}</SummaryItem>\n199\t    </dl>\n200\t  );\n201\t}\n202\t\n203\tfunction CloseCallSummary({ round }: { round: PeekCloseCallRoundRow }) {\n204\t  return (\n205\t    <dl style={summaryGridStyle}>\n206\t      <SummaryItem label=\"Phase\">\n207\t        <StatusChip label={round.phase} tone={closeCallPhaseTone(round.phase)} />\n208\t      </SummaryItem>\n209\t      <SummaryItem label=\"Outcome\">\n210\t        <StatusChip\n211\t          label={round.outcome}\n212\t          tone={closeCallOutcomeTone(round.outcome)}\n213\t        />\n214\t      </SummaryItem>\n215\t      <SummaryItem label=\"Round ID\">\n216\t        <Mono title={round.roundId}>{round.roundId}</Mono>\n217\t      </SummaryItem>\n218\t      <SummaryItem label=\"PDA\">\n219\t        <Mono title={round.pda}>{round.pda}</Mono>\n220\t      </SummaryItem>\n221\t      <SummaryItem label=\"Open price\">\n222\t        {formatNumber(round.openPrice)}\n223\t        <span style={subValueStyle}> · expo {round.openPriceExpo}</span>\n224\t      </SummaryItem>\n225\t      <SummaryItem label=\"Close price\">\n226\t        {round.closePrice ? formatNumber(round.closePrice) : \"—\"}\n227\t      </SummaryItem>\n228\t      <SummaryItem label=\"Green pool (lamports)\">\n229\t        {formatNumber(round.greenPoolLamports)}\n230\t      </SummaryItem>\n231\t      <SummaryItem label=\"Red pool (lamports)\">\n232\t        {formatNumber(round.redPoolLamports)}\n233\t      </SummaryItem>\n234\t      <SummaryItem label=\"Total fee (lamports)\">\n235\t        {formatNumber(round.totalFeeLamports)}\n236\t      </SummaryItem>\n237\t      <SummaryItem label=\"Settle tx\">\n238\t        {round.settleTx ? (\n239\t          <Mono title={round.settleTx}>{round.settleTx}</Mono>\n240\t        ) : (\n241\t          \"—\"\n242\t        )}\n243\t      </SummaryItem>\n244\t      <SummaryItem label=\"Created\">{round.createdAt}</SummaryItem>\n245\t      <SummaryItem label=\"Settled\">{round.settledAt ?? \"—\"}</SummaryItem>\n246\t    </dl>\n247\t  );\n248\t}\n249\t\n250\tfunction EntriesTable({\n251\t  entries,\n252\t  game,\n253\t}: {\n254\t  entries: ReadonlyArray<PeekRoundEntryRow>;\n255\t  game: PeekGameId;\n256\t}) {\n257\t  if (entries.length === 0) {\n258\t    return (\n259\t      <div role=\"status\" style={emptyStyle}>\n260\t        <p style={emptyTitleStyle}>No entries recorded for this round.</p>\n261\t        <p style={emptyBodyStyle}>\n262\t          The <code style={codeStyle}>game_entries</code> table has no rows\n263\t          joined to this round PDA. This is normal for rounds that were created\n264\t          but never joined.\n265\t        </p>\n266\t      </div>\n267\t    );\n268\t  }\n269\t  return (\n270\t    <div style={wrapperStyle}>\n271\t      <table style={tableStyle}>\n272\t        <thead>\n273\t          <tr style={headerRowStyle}>\n274\t            <th style={headerCellStyle(\"left\")}>Created</th>\n275\t            <th style={headerCellStyle(\"left\")}>User</th>\n276\t            <th style={headerCellStyle(\"left\")}>Wallet</th>\n277\t            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>\n278\t            <th style={headerCellStyle(\"left\")}>\n279\t              {game === \"closecall\" ? \"Side\" : \"Side\"}\n280\t            </th>\n281\t            <th style={headerCellStyle(\"left\")}>Winner</th>\n282\t            <th style={headerCellStyle(\"right\")}>Payout (lamports)</th>\n283\t            <th style={headerCellStyle(\"left\")}>Settled</th>\n284\t          </tr>\n285\t        </thead>\n286\t        <tbody>\n287\t          {entries.map((entry) => (\n288\t            <tr key={entry.id} style={bodyRowStyle}>\n289\t              <td style={bodyCellStyle(\"left\")}>{entry.createdAt}</td>\n290\t              <td style={bodyCellStyle(\"left\")}>\n291\t                <Link\n292\t                  href={`/users/${entry.userId}`}\n293\t                  style={linkStyle}\n294\t                  title={entry.userId}\n295\t                >\n296\t                  {entry.username ?? truncate(entry.userId, 12)}\n297\t                </Link>\n298\t              </td>\n299\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n300\t                <span title={entry.wallet}>{truncate(entry.wallet, 12)}</span>\n301\t              </td>\n302\t              <td style={bodyCellStyle(\"right\")}>\n303\t                {formatNumber(entry.amountLamports)}\n304\t              </td>\n305\t              <td style={bodyCellStyle(\"left\")}>{entry.side ?? \"—\"}</td>\n306\t              <td style={bodyCellStyle(\"left\")}>\n307\t                {entry.isWinner === null ? \"—\" : entry.isWinner ? \"yes\" : \"no\"}\n308\t              </td>\n309\t              <td style={bodyCellStyle(\"right\")}>\n310\t                {formatNumber(entry.payoutLamports)}\n311\t              </td>\n312\t              <td style={bodyCellStyle(\"left\")}>{entry.settledAt ?? \"—\"}</td>\n313\t            </tr>\n314\t          ))}\n315\t        </tbody>\n316\t      </table>\n317\t    </div>\n318\t  );\n319\t}\n320\t\n321\tfunction TransactionsTable({\n322\t  transactions,\n323\t}: {\n324\t  transactions: ReadonlyArray<PeekRoundTransactionRow>;\n325\t}) {\n326\t  if (transactions.length === 0) {\n327\t    return (\n328\t      <div role=\"status\" style={emptyStyle}>\n329\t        <p style={emptyTitleStyle}>No transactions recorded for this round.</p>\n330\t        <p style={emptyBodyStyle}>\n331\t          The <code style={codeStyle}>transactions</code> table has no rows\n332\t          joined to this round. Settled rounds without transaction rows are an\n333\t          attention state surfaced by the stuck-state filters on{\" \"}\n334\t          <code style={codeStyle}>/games/[game]</code>.\n335\t        </p>\n336\t      </div>\n337\t    );\n338\t  }\n339\t  return (\n340\t    <div style={wrapperStyle}>\n341\t      <table style={tableStyle}>\n342\t        <thead>\n343\t          <tr style={headerRowStyle}>\n344\t            <th style={headerCellStyle(\"left\")}>Created</th>\n345\t            <th style={headerCellStyle(\"left\")}>Type</th>\n346\t            <th style={headerCellStyle(\"left\")}>User</th>\n347\t            <th style={headerCellStyle(\"left\")}>Wallet</th>\n348\t            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>\n349\t            <th style={headerCellStyle(\"left\")}>Tx signature</th>\n350\t          </tr>\n351\t        </thead>\n352\t        <tbody>\n353\t          {transactions.map((tx) => (\n354\t            <tr key={tx.id} style={bodyRowStyle}>\n355\t              <td style={bodyCellStyle(\"left\")}>{tx.createdAt}</td>\n356\t              <td style={bodyCellStyle(\"left\")}>\n357\t                <StatusChip label={tx.txType} tone=\"info\" />\n358\t              </td>\n359\t              <td style={bodyCellStyle(\"left\")}>\n360\t                {tx.userId ? (\n361\t                  <Link\n362\t                    href={`/users/${tx.userId}`}\n363\t                    style={linkStyle}\n364\t                    title={tx.userId}\n365\t                  >\n366\t                    {tx.username ?? truncate(tx.userId, 12)}\n367\t                  </Link>\n368\t                ) : (\n369\t                  \"—\"\n370\t                )}\n371\t              </td>\n372\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n373\t                <span title={tx.wallet}>{truncate(tx.wallet, 12)}</span>\n374\t              </td>\n375\t              <td style={bodyCellStyle(\"right\")}>\n376\t                {formatNumber(tx.amountLamports)}\n377\t              </td>\n378\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n379\t                <span title={tx.txSig}>{truncate(tx.txSig, 16)}</span>\n380\t              </td>\n381\t            </tr>\n382\t          ))}\n383\t        </tbody>\n384\t      </table>\n385\t    </div>\n386\t  );\n387\t}\n388\t\n389\tfunction Section({\n390\t  heading,\n391\t  headingId,\n392\t  children,\n393\t}: {\n394\t  heading: string;\n395\t  headingId: string;\n396\t  children: ReactNode;\n397\t}) {\n398\t  return (\n399\t    <section aria-labelledby={headingId} style={sectionStyle}>\n400\t      <h2 id={headingId} style={sectionHeadingStyle}>\n401\t        {heading}\n402\t      </h2>\n403\t      {children}\n404\t    </section>\n405\t  );\n406\t}\n407\t\n408\tfunction SummaryItem({\n409\t  label,\n410\t  children,\n411\t}: {\n412\t  label: string;\n413\t  children: ReactNode;\n414\t}) {\n415\t  return (\n416\t    <div style={summaryItemStyle}>\n417\t      <dt style={summaryLabelStyle}>{label}</dt>\n418\t      <dd style={summaryValueStyle}>{children}</dd>\n419\t    </div>\n420\t  );\n421\t}\n422\t\n423\tfunction Mono({ title, children }: { title: string; children: ReactNode }) {\n424\t  return (\n425\t    <span style={{ fontFamily: \"monospace\" }} title={title}>\n426\t      {typeof children === \"string\" ? truncate(children, 16) : children}\n427\t    </span>\n428\t  );\n429\t}\n430\t\n431\tfunction phaseTone(phase: PeekRoundPhase): PeekStatusTone {\n432\t  if (phase === \"settled\") return \"positive\";\n433\t  if (phase === \"expired\") return \"warning\";\n434\t  if (phase === \"settling\") return \"info\";\n435\t  if (phase === \"locked\") return \"info\";\n436\t  return \"neutral\";\n437\t}\n438\t\n439\tfunction closeCallPhaseTone(phase: PeekCloseCallPhase): PeekStatusTone {\n440\t  if (phase === \"settled\") return \"positive\";\n441\t  if (phase === \"refunded\") return \"warning\";\n442\t  return \"info\";\n443\t}\n444\t\n445\tfunction closeCallOutcomeTone(outcome: PeekCloseCallOutcome): PeekStatusTone {\n446\t  if (outcome === \"green\") return \"positive\";\n447\t  if (outcome === \"red\") return \"negative\";\n448\t  if (outcome === \"refund\") return \"warning\";\n449\t  return \"neutral\";\n450\t}\n451\t\n452\tfunction truncate(value: string, max: number): string {\n453\t  if (value.length <= max) return value;\n454\t  const head = Math.max(2, Math.floor((max - 1) / 2));\n455\t  const tail = Math.max(2, max - 1 - head);\n456\t  return `${value.slice(0, head)}…${value.slice(-tail)}`;\n457\t}\n458\t\n459\tfunction formatNumber(value: string): string {\n460\t  if (!value || value === \"0\") return \"0\";\n461\t  const negative = value.startsWith(\"-\");\n462\t  const digits = negative ? value.slice(1) : value;\n463\t  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n464\t  return negative ? `-${grouped}` : grouped;\n465\t}\n466\t\n467\tconst mainStyle: CSSProperties = {\n468\t  display: \"grid\",\n469\t  gap: \"1.5rem\",\n470\t};\n471\t\n472\tconst sectionStyle: CSSProperties = {\n473\t  display: \"grid\",\n474\t  gap: \"0.75rem\",\n475\t};\n476\t\n477\tconst sectionHeadingStyle: CSSProperties = {\n478\t  margin: \"0 0 0.75rem\",\n479\t  fontSize: \"1rem\",\n480\t  fontWeight: 600,\n481\t  color: \"#cbd5f5\",\n482\t  textTransform: \"uppercase\",\n483\t  letterSpacing: \"0.05em\",\n484\t};\n485\t\n486\tconst breadcrumbStyle: CSSProperties = {\n487\t  margin: 0,\n488\t  fontSize: \"0.875rem\",\n489\t  color: \"#94a3b8\",\n490\t};\n491\t\n492\tconst breadcrumbLinkStyle: CSSProperties = {\n493\t  color: \"#93c5fd\",\n494\t  textDecoration: \"none\",\n495\t};\n496\t\n497\tconst leadStyle: CSSProperties = {\n498\t  margin: \"0.25rem 0 0\",\n499\t  color: \"#94a3b8\",\n500\t};\n501\t\n502\tconst codeStyle: CSSProperties = {\n503\t  fontFamily: \"monospace\",\n504\t  color: \"#cbd5f5\",\n505\t};\n506\t\n507\tconst subValueStyle: CSSProperties = {\n508\t  color: \"#64748b\",\n509\t  fontSize: \"0.75rem\",\n510\t  marginLeft: \"0.25rem\",\n511\t};\n512\t\n513\tconst hintStyle: CSSProperties = {\n514\t  margin: 0,\n515\t  color: \"#94a3b8\",\n516\t  fontSize: \"0.8125rem\",\n517\t};\n518\t\n519\tconst errorStyle: CSSProperties = {\n520\t  margin: 0,\n521\t  padding: \"0.75rem 1rem\",\n522\t  borderRadius: \"0.75rem\",\n523\t  background: \"#3f1d1d\",\n524\t  color: \"#fecaca\",\n525\t};\n526\t\n527\tconst summaryGridStyle: CSSProperties = {\n528\t  display: \"grid\",\n529\t  gridTemplateColumns: \"repeat(auto-fit, minmax(220px, 1fr))\",\n530\t  gap: \"0.75rem\",\n531\t  margin: 0,\n532\t  padding: \"1rem\",\n533\t  border: \"1px solid #1e293b\",\n534\t  borderRadius: \"0.75rem\",\n535\t  background: \"#0b1220\",\n536\t};\n537\t\n538\tconst summaryItemStyle: CSSProperties = {\n539\t  display: \"grid\",\n540\t  gap: \"0.25rem\",\n541\t};\n542\t\n543\tconst summaryLabelStyle: CSSProperties = {\n544\t  margin: 0,\n545\t  fontSize: \"0.75rem\",\n546\t  color: \"#94a3b8\",\n547\t  textTransform: \"uppercase\",\n548\t  letterSpacing: \"0.05em\",\n549\t};\n550\t\n551\tconst summaryValueStyle: CSSProperties = {\n552\t  margin: 0,\n553\t  fontSize: \"0.875rem\",\n554\t  color: \"#e2e8f0\",\n555\t};\n556\t\n557\tconst wrapperStyle: CSSProperties = {\n558\t  overflowX: \"auto\",\n559\t  border: \"1px solid #1e293b\",\n560\t  borderRadius: \"0.75rem\",\n561\t};\n562\t\n563\tconst tableStyle: CSSProperties = {\n564\t  width: \"100%\",\n565\t  borderCollapse: \"collapse\",\n566\t};\n567\t\n568\tconst headerRowStyle: CSSProperties = {\n569\t  background: \"#111827\",\n570\t  color: \"#94a3b8\",\n571\t};\n572\t\n573\tconst bodyRowStyle: CSSProperties = {\n574\t  borderTop: \"1px solid #1e293b\",\n575\t};\n576\t\n577\tconst linkStyle: CSSProperties = {\n578\t  color: \"#93c5fd\",\n579\t  textDecoration: \"none\",\n580\t};\n581\t\n582\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n583\t  return {\n584\t    padding: \"0.75rem\",\n585\t    textAlign: align,\n586\t    fontSize: \"0.875rem\",\n587\t    fontWeight: 600,\n588\t  };\n589\t}\n590\t\n591\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n592\t  return {\n593\t    padding: \"0.75rem\",\n594\t    textAlign: align,\n595\t    fontSize: \"0.875rem\",\n596\t  };\n597\t}\n598\t\n599\tconst emptyStyle: CSSProperties = {\n600\t  padding: \"1.5rem\",\n601\t  borderRadius: \"0.75rem\",\n602\t  border: \"1px dashed #334155\",\n603\t  background: \"#0b1220\",\n604\t  color: \"#cbd5f5\",\n605\t  display: \"grid\",\n606\t  gap: \"0.5rem\",\n607\t};\n608\t\n609\tconst emptyTitleStyle: CSSProperties = {\n610\t  margin: 0,\n611\t  fontSize: \"1rem\",\n612\t  fontWeight: 600,\n613\t};\n614\t\n615\tconst emptyBodyStyle: CSSProperties = {\n616\t  margin: 0,\n617\t  fontSize: \"0.875rem\",\n618\t  color: \"#94a3b8\",\n619\t};\n620\t"}]},"parent_tool_use_id":null,"session_id":"e3ee47e7-eefe-4e12-a068-a08216780c1e","uuid":"0480c979-5c7e-4490-a6cd-7bc1da28b620","timestamp":"2026-04-25T13:31:40.406Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/app/games/[game]/rounds/[roundId]/page.tsx","content":"// /games/[game]/rounds/[roundId] — round-level participant + transaction audit\n// (FR-8).\n//\n// Resolves the URL `roundId` against the round's on-chain `pda` (the same key\n// shape for FlipYou, Pot Shot, and Close Call). Renders the round summary,\n// then the per-round entries from `game_entries` and the per-round\n// `transactions` rows so an operator can confirm who participated and which\n// on-chain SOL movements settled the round. Read-only.\nimport { notFound } from \"next/navigation\";\nimport Link from \"next/link\";\nimport type { CSSProperties, ReactNode } from \"react\";\nimport { StatusChip } from \"../../../../../src/components/status-chip\";\nimport {\n  PEEK_GAME_IDS,\n  type PeekCloseCallOutcome,\n  type PeekCloseCallPhase,\n  type PeekCloseCallRoundRow,\n  type PeekGameId,\n  type PeekRoundDetail,\n  type PeekRoundEntryRow,\n  type PeekRoundPhase,\n  type PeekRoundRow,\n  type PeekRoundTransactionRow,\n  type PeekStatusTone,\n} from \"../../../../../src/lib/types/peek\";\nimport {\n  getPeekActorContext,\n  isRouteAllowedForRole,\n} from \"../../../../../src/server/access-policy\";\nimport { getRoundDetail } from \"../../../../../src/server/db/queries/get-round-detail\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst GAME_LABELS: Record<PeekGameId, string> = {\n  flipyou: \"FlipYou\",\n  potshot: \"Pot Shot\",\n  closecall: \"Close Call\",\n};\n\nfunction isPeekGameId(value: string): value is PeekGameId {\n  return (PEEK_GAME_IDS as ReadonlyArray<string>).includes(value);\n}\n\nexport default async function RoundDetailPage({\n  params,\n}: {\n  params: Promise<{ game: string; roundId: string }>;\n}) {\n  const { game: gameParam, roundId } = await params;\n  if (!isPeekGameId(gameParam)) {\n    notFound();\n  }\n  const game = gameParam as PeekGameId;\n  const route = `/games/${game}/rounds/${roundId}`;\n\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(route, actor?.role ?? null);\n\n  if (!allowed) {\n    return (\n      <main style={mainStyle}>\n        <header>\n          <h1>\n            Games · {GAME_LABELS[game]} · Round\n          </h1>\n        </header>\n        <p role=\"alert\" style={errorStyle}>\n          You do not have access to this page.\n        </p>\n      </main>\n    );\n  }\n\n  let detail: PeekRoundDetail | null = null;\n  let loadError: string | null = null;\n\n  try {\n    detail = await getRoundDetail({ game, roundId });\n  } catch (err) {\n    loadError =\n      err instanceof Error ? err.message : \"Round detail could not be loaded.\";\n  }\n\n  if (!loadError && !detail) {\n    notFound();\n  }\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <p style={breadcrumbStyle}>\n          <Link href=\"/games\" style={breadcrumbLinkStyle}>\n            ← Games\n          </Link>\n          {\" · \"}\n          <Link\n            href={`/games/${game}`}\n            style={breadcrumbLinkStyle}\n          >\n            {GAME_LABELS[game]}\n          </Link>\n        </p>\n        <h1>Round audit · {GAME_LABELS[game]}</h1>\n        <p style={leadStyle}>\n          Round identifier (pda):{\" \"}\n          <code style={codeStyle}>{roundId}</code>. Sources:{\" \"}\n          <code style={codeStyle}>\n            {game === \"closecall\" ? \"closecall_rounds\" : \"rounds\"}\n          </code>\n          {\", \"}\n          <code style={codeStyle}>game_entries</code>,{\" \"}\n          <code style={codeStyle}>transactions</code>.\n        </p>\n      </header>\n\n      {loadError ? (\n        <p role=\"alert\" style={errorStyle}>\n          Round detail unavailable: {loadError}\n        </p>\n      ) : detail ? (\n        <RoundDetailSections detail={detail} />\n      ) : null}\n    </main>\n  );\n}\n\nfunction RoundDetailSections({ detail }: { detail: PeekRoundDetail }) {\n  return (\n    <>\n      <Section heading=\"Round summary\" headingId=\"round-summary-heading\">\n        {detail.game === \"closecall\" ? (\n          <CloseCallSummary round={detail.round} />\n        ) : (\n          <RoundSummary round={detail.round} />\n        )}\n      </Section>\n\n      <Section heading=\"Entries\" headingId=\"entries-heading\">\n        <p style={hintStyle}>\n          {detail.entries.length} participant\n          {detail.entries.length === 1 ? \"\" : \"s\"} from{\" \"}\n          <code style={codeStyle}>game_entries</code> · sorted oldest first.\n        </p>\n        <EntriesTable entries={detail.entries} game={detail.game} />\n      </Section>\n\n      <Section heading=\"Transactions\" headingId=\"transactions-heading\">\n        <p style={hintStyle}>\n          {detail.transactions.length} on-chain SOL movement\n          {detail.transactions.length === 1 ? \"\" : \"s\"} from{\" \"}\n          <code style={codeStyle}>transactions</code> · sorted oldest first.\n        </p>\n        <TransactionsTable transactions={detail.transactions} />\n      </Section>\n    </>\n  );\n}\n\nfunction RoundSummary({ round }: { round: PeekRoundRow }) {\n  return (\n    <dl style={summaryGridStyle}>\n      <SummaryItem label=\"Phase\">\n        <StatusChip label={round.phase} tone={phaseTone(round.phase)} />\n      </SummaryItem>\n      <SummaryItem label=\"Match ID\">\n        <Mono title={round.matchId}>{round.matchId}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"PDA\">\n        <Mono title={round.pda}>{round.pda}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"Creator\">\n        <Mono title={round.creator}>{round.creator}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"Amount (lamports)\">\n        {formatNumber(round.amountLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Target slot\">\n        {round.targetSlot ? formatNumber(round.targetSlot) : \"—\"}\n      </SummaryItem>\n      <SummaryItem label=\"Settle attempts\">\n        {String(round.settleAttempts)}\n      </SummaryItem>\n      <SummaryItem label=\"Result side\">\n        {round.resultSide === null ? \"—\" : String(round.resultSide)}\n      </SummaryItem>\n      <SummaryItem label=\"Winner\">\n        {round.winner ? <Mono title={round.winner}>{round.winner}</Mono> : \"—\"}\n      </SummaryItem>\n      <SummaryItem label=\"Settle tx\">\n        {round.settleTx ? (\n          <Mono title={round.settleTx}>{round.settleTx}</Mono>\n        ) : (\n          \"—\"\n        )}\n      </SummaryItem>\n      <SummaryItem label=\"Created\">{round.createdAt}</SummaryItem>\n      <SummaryItem label=\"Updated\">{round.updatedAt}</SummaryItem>\n      <SummaryItem label=\"Settled\">{round.settledAt ?? \"—\"}</SummaryItem>\n    </dl>\n  );\n}\n\nfunction CloseCallSummary({ round }: { round: PeekCloseCallRoundRow }) {\n  return (\n    <dl style={summaryGridStyle}>\n      <SummaryItem label=\"Phase\">\n        <StatusChip label={round.phase} tone={closeCallPhaseTone(round.phase)} />\n      </SummaryItem>\n      <SummaryItem label=\"Outcome\">\n        <StatusChip\n          label={round.outcome}\n          tone={closeCallOutcomeTone(round.outcome)}\n        />\n      </SummaryItem>\n      <SummaryItem label=\"Round ID\">\n        <Mono title={round.roundId}>{round.roundId}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"PDA\">\n        <Mono title={round.pda}>{round.pda}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"Open price\">\n        {formatNumber(round.openPrice)}\n        <span style={subValueStyle}> · expo {round.openPriceExpo}</span>\n      </SummaryItem>\n      <SummaryItem label=\"Close price\">\n        {round.closePrice ? formatNumber(round.closePrice) : \"—\"}\n      </SummaryItem>\n      <SummaryItem label=\"Green pool (lamports)\">\n        {formatNumber(round.greenPoolLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Red pool (lamports)\">\n        {formatNumber(round.redPoolLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Total fee (lamports)\">\n        {formatNumber(round.totalFeeLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Settle tx\">\n        {round.settleTx ? (\n          <Mono title={round.settleTx}>{round.settleTx}</Mono>\n        ) : (\n          \"—\"\n        )}\n      </SummaryItem>\n      <SummaryItem label=\"Created\">{round.createdAt}</SummaryItem>\n      <SummaryItem label=\"Settled\">{round.settledAt ?? \"—\"}</SummaryItem>\n    </dl>\n  );\n}\n\nfunction EntriesTable({\n  entries,\n  game,\n}: {\n  entries: ReadonlyArray<PeekRoundEntryRow>;\n  game: PeekGameId;\n}) {\n  if (entries.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No entries recorded for this round.</p>\n        <p style={emptyBodyStyle}>\n          The <code style={codeStyle}>game_entries</code> table has no rows\n          joined to this round PDA. This is normal for rounds that were created\n          but never joined.\n        </p>\n      </div>\n    );\n  }\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>\n            <th style={headerCellStyle(\"left\")}>\n              {game === \"closecall\" ? \"Side\" : \"Side\"}\n            </th>\n            <th style={headerCellStyle(\"left\")}>Winner</th>\n            <th style={headerCellStyle(\"right\")}>Payout (lamports)</th>\n            <th style={headerCellStyle(\"left\")}>Settled</th>\n          </tr>\n        </thead>\n        <tbody>\n          {entries.map((entry) => (\n            <tr key={entry.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{entry.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <Link\n                  href={`/users/${entry.userId}`}\n                  style={linkStyle}\n                  title={entry.userId}\n                >\n                  {entry.username ?? truncate(entry.userId, 12)}\n                </Link>\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={entry.wallet}>{truncate(entry.wallet, 12)}</span>\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(entry.amountLamports)}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{entry.side ?? \"—\"}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                {entry.isWinner === null ? \"—\" : entry.isWinner ? \"yes\" : \"no\"}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(entry.payoutLamports)}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{entry.settledAt ?? \"—\"}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction TransactionsTable({\n  transactions,\n}: {\n  transactions: ReadonlyArray<PeekRoundTransactionRow>;\n}) {\n  if (transactions.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No transactions recorded for this round.</p>\n        <p style={emptyBodyStyle}>\n          The <code style={codeStyle}>transactions</code> table has no rows\n          joined to this round. Settled rounds without transaction rows are an\n          attention state surfaced by the stuck-state filters on{\" \"}\n          <code style={codeStyle}>/games/[game]</code>.\n        </p>\n      </div>\n    );\n  }\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>Type</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>\n            <th style={headerCellStyle(\"left\")}>Tx signature</th>\n          </tr>\n        </thead>\n        <tbody>\n          {transactions.map((tx) => (\n            <tr key={tx.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{tx.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip label={tx.txType} tone=\"info\" />\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                {tx.userId ? (\n                  <Link\n                    href={`/users/${tx.userId}`}\n                    style={linkStyle}\n                    title={tx.userId}\n                  >\n                    {tx.username ?? truncate(tx.userId, 12)}\n                  </Link>\n                ) : (\n                  \"—\"\n                )}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={tx.wallet}>{truncate(tx.wallet, 12)}</span>\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(tx.amountLamports)}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={tx.txSig}>{truncate(tx.txSig, 16)}</span>\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction Section({\n  heading,\n  headingId,\n  children,\n}: {\n  heading: string;\n  headingId: string;\n  children: ReactNode;\n}) {\n  return (\n    <section aria-labelledby={headingId} style={sectionStyle}>\n      <h2 id={headingId} style={sectionHeadingStyle}>\n        {heading}\n      </h2>\n      {children}\n    </section>\n  );\n}\n\nfunction SummaryItem({\n  label,\n  children,\n}: {\n  label: string;\n  children: ReactNode;\n}) {\n  return (\n    <div style={summaryItemStyle}>\n      <dt style={summaryLabelStyle}>{label}</dt>\n      <dd style={summaryValueStyle}>{children}</dd>\n    </div>\n  );\n}\n\nfunction Mono({ title, children }: { title: string; children: ReactNode }) {\n  return (\n    <span style={{ fontFamily: \"monospace\" }} title={title}>\n      {typeof children === \"string\" ? truncate(children, 16) : children}\n    </span>\n  );\n}\n\nfunction phaseTone(phase: PeekRoundPhase): PeekStatusTone {\n  if (phase === \"settled\") return \"positive\";\n  if (phase === \"expired\") return \"warning\";\n  if (phase === \"settling\") return \"info\";\n  if (phase === \"locked\") return \"info\";\n  return \"neutral\";\n}\n\nfunction closeCallPhaseTone(phase: PeekCloseCallPhase): PeekStatusTone {\n  if (phase === \"settled\") return \"positive\";\n  if (phase === \"refunded\") return \"warning\";\n  return \"info\";\n}\n\nfunction closeCallOutcomeTone(outcome: PeekCloseCallOutcome): PeekStatusTone {\n  if (outcome === \"green\") return \"positive\";\n  if (outcome === \"red\") return \"negative\";\n  if (outcome === \"refund\") return \"warning\";\n  return \"neutral\";\n}\n\nfunction truncate(value: string, max: number): string {\n  if (value.length <= max) return value;\n  const head = Math.max(2, Math.floor((max - 1) / 2));\n  const tail = Math.max(2, max - 1 - head);\n  return `${value.slice(0, head)}…${value.slice(-tail)}`;\n}\n\nfunction formatNumber(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst breadcrumbStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n\nconst breadcrumbLinkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst codeStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  color: \"#cbd5f5\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n  marginLeft: \"0.25rem\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst summaryGridStyle: CSSProperties = {\n  display: \"grid\",\n  gridTemplateColumns: \"repeat(auto-fit, minmax(220px, 1fr))\",\n  gap: \"0.75rem\",\n  margin: 0,\n  padding: \"1rem\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n  background: \"#0b1220\",\n};\n\nconst summaryItemStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst summaryLabelStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst summaryValueStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#e2e8f0\",\n};\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n  };\n}\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":620,"startLine":1,"totalLines":620}}}
