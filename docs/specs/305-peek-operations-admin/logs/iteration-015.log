= [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) {\n      return Promise.reject(next);\n    }\n    return Promise.resolve(next ?? []);\n  };\n\n  // Cast through unknown — only the tagged-template surface is exercised here.\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\nconst ALL_IDS: ReadonlyArray<PeekCommandCenterAttentionId> = [\n  \"failed_claims\",\n  \"dead_queue_events\",\n  \"stuck_rounds_flipyou_potshot\",\n  \"stuck_rounds_closecall\",\n  \"pending_sol_crate_payouts\",\n  \"stale_active_dogpile_events\",\n  \"high_value_exports_24h\",\n];\n\ndescribe(\"getCommandCenterAttention\", () => {\n  it(\"populated: returns one PeekMetric per attention id with FR-4 bookkeeping\", async () => {\n    const mock = createSqlMock([\n      [{ value: 3 }],\n      [{ value: 1 }],\n      [{ value: 5 }],\n      [{ value: 2 }],\n      [{ value: 4 }],\n      [{ value: 6 }],\n      [{ value: 7 }],\n    ]);\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getCommandCenterAttention({ sql: mock.sql, now });\n\n    expect(result.generatedAt).toBe(\"2026-04-25T10:00:00.000Z\");\n    expect(result.metrics).toHaveLength(7);\n    expect(result.metrics.map((m) => m.id)).toEqual(ALL_IDS);\n\n    for (const metric of result.metrics) {\n      expect(metric.asOf).toBe(\"2026-04-25T10:00:00.000Z\");\n      expect(metric.freshness).toBe(\"live\");\n      expect(metric.label.length).toBeGreaterThan(0);\n      expect(metric.definition.length).toBeGreaterThan(0);\n      expect(metric.source.length).toBeGreaterThan(0);\n      expect(metric.windowLabel.length).toBeGreaterThan(0);\n      expect(metric.drilldownHref).not.toBeNull();\n    }\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"failed_claims\")?.value).toBe(3);\n    expect(byId.get(\"failed_claims\")?.valueDisplay).toBe(\"3\");\n    expect(byId.get(\"failed_claims\")?.source).toBe(\"referral_claims\");\n    expect(byId.get(\"dead_queue_events\")?.value).toBe(1);\n    expect(byId.get(\"stuck_rounds_flipyou_potshot\")?.value).toBe(5);\n    expect(byId.get(\"stuck_rounds_closecall\")?.value).toBe(2);\n    expect(byId.get(\"pending_sol_crate_payouts\")?.value).toBe(4);\n    expect(byId.get(\"stale_active_dogpile_events\")?.value).toBe(6);\n    expect(byId.get(\"high_value_exports_24h\")?.value).toBe(7);\n    expect(byId.get(\"high_value_exports_24h\")?.source).toBe(\"operator_events\");\n  });\n\n  it(\"populated (large counts): formats valueDisplay with a thousands separator\", async () => {\n    const mock = createSqlMock([\n      [{ value: 1234 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n\n    const result = await getCommandCenterAttention({ sql: mock.sql });\n\n    const failed = result.metrics.find((m) => m.id === \"failed_claims\");\n    expect(failed?.value).toBe(1234);\n    expect(failed?.valueDisplay).toBe(\"1,234\");\n  });\n\n  it(\"populated (string count): coerces a postgres ::text count to a number\", async () => {\n    // postgres-js can return numeric counts as strings depending on driver\n    // configuration; the query module must coerce them back to numbers.\n    const mock = createSqlMock([\n      [{ value: \"12\" }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n\n    const result = await getCommandCenterAttention({ sql: mock.sql });\n\n    const failed = result.metrics.find((m) => m.id === \"failed_claims\");\n    expect(failed?.value).toBe(12);\n    expect(failed?.valueDisplay).toBe(\"12\");\n  });\n\n  it(\"sparse: every empty row coerces to a zero count without dropping the metric\", async () => {\n    const mock = createSqlMock([[], [], [], [], [], [], []]);\n\n    const result = await getCommandCenterAttention({ sql: mock.sql });\n\n    expect(result.metrics).toHaveLength(7);\n    for (const metric of result.metrics) {\n      expect(metric.value).toBe(0);\n      expect(metric.valueDisplay).toBe(\"0\");\n    }\n  });\n\n  it(\"threshold overrides: surface in the windowLabel and definition copy\", async () => {\n    const mock = createSqlMock([[], [], [], [], [], [], []]);\n\n    const result = await getCommandCenterAttention({\n      sql: mock.sql,\n      thresholds: {\n        stuckRoundsAgeMinutes: 10 as 5,\n        stuckRoundsMaxSettleAttempts: 6 as 3,\n        stuckCloseCallAgeMinutes: 7 as 5,\n        exportWindowHours: 12 as 24,\n        exportRowCountThreshold: 250 as 1000,\n      },\n    });\n\n    const stuck = result.metrics.find(\n      (m) => m.id === \"stuck_rounds_flipyou_potshot\",\n    );\n    expect(stuck?.windowLabel).toContain(\"10m\");\n    expect(stuck?.windowLabel).toContain(\"> 6\");\n\n    const cc = result.metrics.find((m) => m.id === \"stuck_rounds_closecall\");\n    expect(cc?.windowLabel).toContain(\"7m\");\n\n    const exports = result.metrics.find((m) => m.id === \"high_value_exports_24h\");\n    expect(exports?.windowLabel).toContain(\"Last 12h\");\n    expect(exports?.definition).toContain(\"12h\");\n    expect(exports?.definition).toContain(\"250\");\n  });\n\n  it(\"default thresholds: match the published COMMAND_CENTER_DEFAULTS\", async () => {\n    const mock = createSqlMock([[], [], [], [], [], [], []]);\n\n    const result = await getCommandCenterAttention({ sql: mock.sql });\n\n    const stuck = result.metrics.find(\n      (m) => m.id === \"stuck_rounds_flipyou_potshot\",\n    );\n    expect(stuck?.windowLabel).toContain(\n      `${COMMAND_CENTER_DEFAULTS.stuckRoundsAgeMinutes}m`,\n    );\n    expect(stuck?.windowLabel).toContain(\n      `> ${COMMAND_CENTER_DEFAULTS.stuckRoundsMaxSettleAttempts}`,\n    );\n\n    const exports = result.metrics.find((m) => m.id === \"high_value_exports_24h\");\n    expect(exports?.windowLabel).toContain(\n      `Last ${COMMAND_CENTER_DEFAULTS.exportWindowHours}h`,\n    );\n  });\n\n  it(\"load-error: a rejected query propagates so the caller can render the alert state\", async () => {\n    // Promise.all rejects on the first failure; the page-level try/catch\n    // surfaces the error as `attentionError`. The query module must not\n    // silently swallow the failure.\n    const mock = createSqlMock([\n      [{ value: 0 }],\n      new Error(\"connection refused\"),\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n\n    await expect(\n      getCommandCenterAttention({ sql: mock.sql }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n\n  it(\"query bounded: every SQL call returns a single integer count, never row data\", async () => {\n    const mock = createSqlMock([\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n\n    await getCommandCenterAttention({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(7);\n    for (const call of mock.calls) {\n      // Every command-center query is a count(*) projection — never row data.\n      expect(call.text).toMatch(/select\\s+count\\(\\*\\)::int as \"value\"/i);\n    }\n  });\n});\n","structuredPatch":[{"oldStart":147,"oldLines":11,"newStart":147,"newLines":11,"lines":["     const result = await getCommandCenterAttention({","       sql: mock.sql,","       thresholds: {","-        stuckRoundsAgeMinutes: 10 as 5,","-        stuckRoundsMaxSettleAttempts: 6 as 3,","-        stuckCloseCallAgeMinutes: 7 as 5,","-        exportWindowHours: 12 as 24,","-        exportRowCountThreshold: 250 as 1000,","+        stuckRoundsAgeMinutes: 10,","+        stuckRoundsMaxSettleAttempts: 6,","+        stuckCloseCallAgeMinutes: 7,","+        exportWindowHours: 12,","+        exportRowCountThreshold: 250,","       },","     });"," "]}],"userModified":false,"replaceAll":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01AAX2tuH3P3NVQATxF4PirS","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01QD3chvTw6gZpNyw3a3oBk7","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/peek/src/server/db/queries/get-command-center-attention.ts","old_string":"// Thresholds — tuned for an operator console, not a fairness oracle. Tests can\n// override via the `options` argument so age/limit assertions stay\n// deterministic.\nexport const COMMAND_CENTER_DEFAULTS = {\n  stuckRoundsAgeMinutes: 5,\n  stuckRoundsMaxSettleAttempts: 3,\n  stuckCloseCallAgeMinutes: 5,\n  exportWindowHours: 24,\n  exportRowCountThreshold: 1000,\n} as const;\n\nexport type CommandCenterThresholds = typeof COMMAND_CENTER_DEFAULTS;","new_string":"// Thresholds — tuned for an operator console, not a fairness oracle. Tests can\n// override via the `options` argument so age/limit assertions stay\n// deterministic.\nexport type CommandCenterThresholds = {\n  stuckRoundsAgeMinutes: number;\n  stuckRoundsMaxSettleAttempts: number;\n  stuckCloseCallAgeMinutes: number;\n  exportWindowHours: number;\n  exportRowCountThreshold: number;\n};\n\nexport const COMMAND_CENTER_DEFAULTS: CommandCenterThresholds = {\n  stuckRoundsAgeMinutes: 5,\n  stuckRoundsMaxSettleAttempts: 3,\n  stuckCloseCallAgeMinutes: 5,\n  exportWindowHours: 24,\n  exportRowCountThreshold: 1000,\n};"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1201,"cache_read_input_tokens":124098,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1201},"output_tokens":69,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"19c9a51e-3972-4bff-bc15-86d90691364e","uuid":"8c6251e8-f5e3-487c-9181-096f23ec15ff"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QD3chvTw6gZpNyw3a3oBk7","type":"tool_result","content":"The file /workspaces/rng-utopia/peek/src/server/db/queries/get-command-center-attention.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"19c9a51e-3972-4bff-bc15-86d90691364e","uuid":"e003aad3-73ec-42f1-ba11-ba7b85559cd0","timestamp":"2026-04-25T11:29:19.360Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-command-center-attention.ts","oldString":"// Thresholds — tuned for an operator console, not a fairness oracle. Tests can\n// override via the `options` argument so age/limit assertions stay\n// deterministic.\nexport const COMMAND_CENTER_DEFAULTS = {\n  stuckRoundsAgeMinutes: 5,\n  stuckRoundsMaxSettleAttempts: 3,\n  stuckCloseCallAgeMinutes: 5,\n  exportWindowHours: 24,\n  exportRowCountThreshold: 1000,\n} as const;\n\nexport type CommandCenterThresholds = typeof COMMAND_CENTER_DEFAULTS;","newString":"// Thresholds — tuned for an operator console, not a fairness oracle. Tests can\n// override via the `options` argument so age/limit assertions stay\n// deterministic.\nexport type CommandCenterThresholds = {\n  stuckRoundsAgeMinutes: number;\n  stuckRoundsMaxSettleAttempts: number;\n  stuckCloseCallAgeMinutes: number;\n  exportWindowHours: number;\n  exportRowCountThreshold: number;\n};\n\nexport const COMMAND_CENTER_DEFAULTS: CommandCenterThresholds = {\n  stuckRoundsAgeMinutes: 5,\n  stuckRoundsMaxSettleAttempts: 3,\n  stuckCloseCallAgeMinutes: 5,\n  exportWindowHours: 24,\n  exportRowCountThreshold: 1000,\n};","originalFile":"// Command-center attention queue query (FR-3, FR-10).\n//\n// Returns a small set of bounded \"needs attention\" metrics that the command\n// center renders at the top of `/`. Each metric carries the FR-4 bookkeeping\n// (id, label, value, source table, time window, \"as of\", definition,\n// freshness, drill-down href) so the metric-strip primitive can render it\n// without per-page hardcoding.\n//\n// Bounded queries: every query returns a single integer count. No row-level\n// data crosses the wire here; per-feature pages provide the row drill-downs.\n\nimport type {\n  PeekCommandCenterAttention,\n  PeekCommandCenterAttentionId,\n  PeekMetric,\n} from \"../../../lib/types/peek\";\nimport type { Sql } from \"postgres\";\nimport { getSqlClient } from \"../client\";\n\n// Thresholds — tuned for an operator console, not a fairness oracle. Tests can\n// override via the `options` argument so age/limit assertions stay\n// deterministic.\nexport const COMMAND_CENTER_DEFAULTS = {\n  stuckRoundsAgeMinutes: 5,\n  stuckRoundsMaxSettleAttempts: 3,\n  stuckCloseCallAgeMinutes: 5,\n  exportWindowHours: 24,\n  exportRowCountThreshold: 1000,\n} as const;\n\nexport type CommandCenterThresholds = typeof COMMAND_CENTER_DEFAULTS;\n\nexport type CommandCenterOptions = {\n  sql?: Sql;\n  thresholds?: Partial<CommandCenterThresholds>;\n  now?: Date;\n};\n\ntype AttentionRow = { value: number };\n\nfunction readCount(rows: ReadonlyArray<AttentionRow> | undefined): number {\n  if (!rows || rows.length === 0) {\n    return 0;\n  }\n  const raw = rows[0]?.value;\n  if (typeof raw === \"number\" && Number.isFinite(raw)) {\n    return raw;\n  }\n  if (typeof raw === \"string\") {\n    const parsed = Number.parseInt(raw, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\ntype MetricBlueprint = {\n  id: PeekCommandCenterAttentionId;\n  label: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  definition: string;\n  drilldownHref: string | null;\n};\n\nfunction makeMetric(\n  blueprint: MetricBlueprint,\n  count: number,\n  asOf: string,\n): PeekMetric {\n  return {\n    id: blueprint.id,\n    label: blueprint.label,\n    value: count,\n    valueDisplay: formatCount(count),\n    unit: blueprint.unit,\n    source: blueprint.source,\n    windowLabel: blueprint.windowLabel,\n    asOf,\n    definition: blueprint.definition,\n    freshness: \"live\",\n    drilldownHref: blueprint.drilldownHref,\n  };\n}\n\nexport async function getCommandCenterAttention(\n  options: CommandCenterOptions = {},\n): Promise<PeekCommandCenterAttention> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const thresholds: CommandCenterThresholds = {\n    ...COMMAND_CENTER_DEFAULTS,\n    ...options.thresholds,\n  };\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n\n  const stuckRoundsAgeInterval = `${thresholds.stuckRoundsAgeMinutes} minutes`;\n  const stuckCloseCallAgeInterval = `${thresholds.stuckCloseCallAgeMinutes} minutes`;\n  const exportWindowInterval = `${thresholds.exportWindowHours} hours`;\n\n  const [\n    failedClaimsRows,\n    deadQueueEventsRows,\n    stuckRoundsRows,\n    stuckCloseCallRows,\n    pendingSolCrateRows,\n    staleActiveDogpileRows,\n    highValueExportsRows,\n  ] = await Promise.all([\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from referral_claims\n      where status in ('failed', 'error')\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from event_queue\n      where status = 'dead'\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from rounds\n      where phase in ('created', 'locked', 'settling')\n        and (\n          created_at < now() - ${stuckRoundsAgeInterval}::interval\n          or settle_attempts > ${thresholds.stuckRoundsMaxSettleAttempts}\n        )\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from closecall_rounds\n      where phase = 'open'\n        and created_at < now() - ${stuckCloseCallAgeInterval}::interval\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from crate_drops\n      where crate_type = 'sol'\n        and status = 'pending'\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from dogpile_events\n      where status = 'active'\n        and ends_at < now()\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from operator_events\n      where event_type = 'peek.export'\n        and created_at > now() - ${exportWindowInterval}::interval\n        and coalesce((payload->>'resultCount')::int, 0)\n            > ${thresholds.exportRowCountThreshold}\n    `,\n  ]);\n\n  const blueprints: ReadonlyArray<{\n    blueprint: MetricBlueprint;\n    rows: ReadonlyArray<AttentionRow>;\n  }> = [\n    {\n      blueprint: {\n        id: \"failed_claims\",\n        label: \"Failed referral claims\",\n        unit: \"claims\",\n        source: \"referral_claims\",\n        windowLabel: \"All time\",\n        definition:\n          \"Referral claims with status 'failed' or 'error' that have not been recovered.\",\n        drilldownHref: \"/growth/referrals?claimStatus=failed\",\n      },\n      rows: failedClaimsRows,\n    },\n    {\n      blueprint: {\n        id: \"dead_queue_events\",\n        label: \"Dead queue events\",\n        unit: \"events\",\n        source: \"event_queue\",\n        windowLabel: \"All time\",\n        definition:\n          \"Event-queue rows in 'dead' status — past max attempts and not retried.\",\n        drilldownHref: \"/operations/queue?status=dead\",\n      },\n      rows: deadQueueEventsRows,\n    },\n    {\n      blueprint: {\n        id: \"stuck_rounds_flipyou_potshot\",\n        label: \"Stuck Flip You / Pot Shot rounds\",\n        unit: \"rounds\",\n        source: \"rounds\",\n        windowLabel: `Older than ${thresholds.stuckRoundsAgeMinutes}m or settle_attempts > ${thresholds.stuckRoundsMaxSettleAttempts}`,\n        definition:\n          \"Rounds in nonterminal phases (created/locked/settling) past the age threshold or with elevated settle attempts.\",\n        drilldownHref: \"/games?stuck=true\",\n      },\n      rows: stuckRoundsRows,\n    },\n    {\n      blueprint: {\n        id: \"stuck_rounds_closecall\",\n        label: \"Stuck Close Call rounds\",\n        unit: \"rounds\",\n        source: \"closecall_rounds\",\n        windowLabel: `Open phase older than ${thresholds.stuckCloseCallAgeMinutes}m`,\n        definition:\n          \"Close Call rounds still in 'open' phase past the age threshold; rounds settle on minute boundaries via Pyth.\",\n        drilldownHref: \"/games/closecall?stuck=true\",\n      },\n      rows: stuckCloseCallRows,\n    },\n    {\n      blueprint: {\n        id: \"pending_sol_crate_payouts\",\n        label: \"Pending SOL crate payouts\",\n        unit: \"crates\",\n        source: \"crate_drops\",\n        windowLabel: \"All time\",\n        definition:\n          \"SOL-denominated crate drops in 'pending' status — payout has not been delivered on-chain.\",\n        drilldownHref: \"/economy/rewards?crateType=sol&status=pending\",\n      },\n      rows: pendingSolCrateRows,\n    },\n    {\n      blueprint: {\n        id: \"stale_active_dogpile_events\",\n        label: \"Stale active Dogpile events\",\n        unit: \"events\",\n        source: \"dogpile_events\",\n        windowLabel: \"Active past end time\",\n        definition:\n          \"Dogpile events still in 'active' status whose ends_at has already passed; they should have transitioned to 'ended'.\",\n        drilldownHref: \"/operations/dogpile?status=active\",\n      },\n      rows: staleActiveDogpileRows,\n    },\n    {\n      blueprint: {\n        id: \"high_value_exports_24h\",\n        label: \"High-value exports (24h)\",\n        unit: \"exports\",\n        source: \"operator_events\",\n        windowLabel: `Last ${thresholds.exportWindowHours}h`,\n        definition: `peek.export operator events in the last ${thresholds.exportWindowHours}h whose resultCount exceeds ${thresholds.exportRowCountThreshold} rows.`,\n        drilldownHref: \"/audit?eventType=peek.export\",\n      },\n      rows: highValueExportsRows,\n    },\n  ];\n\n  const metrics: PeekMetric[] = blueprints.map(({ blueprint, rows }) =>\n    makeMetric(blueprint, readCount(rows), generatedAt),\n  );\n\n  return {\n    generatedAt,\n    metrics,\n  };\n}\n","structuredPatch":[{"oldStart":20,"oldLines":16,"newStart":20,"newLines":22,"lines":[" // Thresholds — tuned for an operator console, not a fairness oracle. Tests can"," // override via the `options` argument so age/limit assertions stay"," // deterministic.","-export const COMMAND_CENTER_DEFAULTS = {","+export type CommandCenterThresholds = {","+  stuckRoundsAgeMinutes: number;","+  stuckRoundsMaxSettleAttempts: number;","+  stuckCloseCallAgeMinutes: number;","+  exportWindowHours: number;","+  exportRowCountThreshold: number;","+};","+","+export const COMMAND_CENTER_DEFAULTS: CommandCenterThresholds = {","   stuckRoundsAgeMinutes: 5,","   stuckRoundsMaxSettleAttempts: 3,","   stuckCloseCallAgeMinutes: 5,","   exportWindowHours: 24,","   exportRowCountThreshold: 1000,","-} as const;","+};"," ","-export type CommandCenterThresholds = typeof COMMAND_CENTER_DEFAULTS;","-"," export type CommandCenterOptions = {","   sql?: Sql;","   thresholds?: Partial<CommandCenterThresholds>;"]}],"userModified":false,"replaceAll":false}}
