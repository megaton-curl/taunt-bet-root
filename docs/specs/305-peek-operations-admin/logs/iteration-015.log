{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CPRTUSdZMjsQaXY93Yg9Rm","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport { render, screen, within } from \"@testing-library/react\";\n3\timport { MetricStrip } from \"../metric-strip\";\n4\timport type { PeekMetric } from \"../../lib/types/peek\";\n5\t\n6\tconst fundedMetric: PeekMetric = {\n7\t  id: \"reward-pool-balance\",\n8\t  label: \"Reward pool balance\",\n9\t  value: 1_234_000_000,\n10\t  valueDisplay: \"1.234\",\n11\t  unit: \"SOL\",\n12\t  source: \"reward_pool\",\n13\t  windowLabel: \"Current\",\n14\t  asOf: \"2026-04-25T10:00:00.000Z\",\n15\t  definition: \"Sum of unpaid SOL in the reward pool.\",\n16\t  freshness: \"live\",\n17\t  drilldownHref: \"/economy/rewards#pool\",\n18\t};\n19\t\n20\tconst sparseMetric: PeekMetric = {\n21\t  id: \"failed-claims\",\n22\t  label: \"Failed claims\",\n23\t  value: null,\n24\t  valueDisplay: \"0\",\n25\t  unit: null,\n26\t  source: \"referral_claims\",\n27\t  windowLabel: \"Last 24h\",\n28\t  asOf: null,\n29\t  definition: \"Claims with status = failed in the last 24 hours.\",\n30\t  freshness: \"cached\",\n31\t  drilldownHref: null,\n32\t};\n33\t\n34\tdescribe(\"MetricStrip\", () => {\n35\t  it(\"populated: shows label, value, definition, source, window, as-of, freshness, and drilldown link\", () => {\n36\t    render(<MetricStrip metrics={[fundedMetric]} />);\n37\t\n38\t    const card = screen.getByLabelText(\"Reward pool balance\");\n39\t    expect(within(card).getByText(\"Reward pool balance\")).toBeInTheDocument();\n40\t    expect(within(card).getByText(\"1.234\")).toBeInTheDocument();\n41\t    expect(within(card).getByText(\"SOL\")).toBeInTheDocument();\n42\t    expect(within(card).getByText(\"Sum of unpaid SOL in the reward pool.\")).toBeInTheDocument();\n43\t    expect(within(card).getByText(\"reward_pool\")).toBeInTheDocument();\n44\t    expect(within(card).getByText(\"Current\")).toBeInTheDocument();\n45\t    expect(within(card).getByText(\"2026-04-25T10:00:00.000Z\")).toBeInTheDocument();\n46\t    expect(within(card).getByText(\"live\")).toBeInTheDocument();\n47\t    const link = within(card).getByRole(\"link\", { name: /View rows/ });\n48\t    expect(link).toHaveAttribute(\"href\", \"/economy/rewards#pool\");\n49\t  });\n50\t\n51\t  it(\"populated sparse-data variant: renders dash for missing as-of and no drilldown link when href is null\", () => {\n52\t    render(<MetricStrip metrics={[sparseMetric]} />);\n53\t\n54\t    const card = screen.getByLabelText(\"Failed claims\");\n55\t    expect(within(card).getByText(\"0\")).toBeInTheDocument();\n56\t    expect(within(card).getByText(\"—\")).toBeInTheDocument();\n57\t    expect(within(card).queryByRole(\"link\")).toBeNull();\n58\t    expect(within(card).getByText(\"cached\")).toBeInTheDocument();\n59\t  });\n60\t\n61\t  it(\"sparse: renders an empty status when no metrics are provided\", () => {\n62\t    render(<MetricStrip metrics={[]} />);\n63\t\n64\t    expect(screen.getByRole(\"status\")).toHaveTextContent(\"No metrics available for this view.\");\n65\t    expect(screen.queryByRole(\"region\")).toBeNull();\n66\t  });\n67\t\n68\t  it(\"error: renders an alert and not the metric grid\", () => {\n69\t    render(<MetricStrip metrics={[fundedMetric]} error=\"query timeout\" />);\n70\t\n71\t    expect(screen.getByRole(\"alert\")).toHaveTextContent(\"Metrics unavailable: query timeout\");\n72\t    expect(screen.queryByLabelText(\"Reward pool balance\")).toBeNull();\n73\t  });\n74\t});\n75\t"}]},"parent_tool_use_id":null,"session_id":"19c9a51e-3972-4bff-bc15-86d90691364e","uuid":"b3109844-3d6e-4833-be40-e31a06896ad0","timestamp":"2026-04-25T11:25:33.237Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/metric-strip.test.tsx","content":"import { describe, expect, it } from \"vitest\";\nimport { render, screen, within } from \"@testing-library/react\";\nimport { MetricStrip } from \"../metric-strip\";\nimport type { PeekMetric } from \"../../lib/types/peek\";\n\nconst fundedMetric: PeekMetric = {\n  id: \"reward-pool-balance\",\n  label: \"Reward pool balance\",\n  value: 1_234_000_000,\n  valueDisplay: \"1.234\",\n  unit: \"SOL\",\n  source: \"reward_pool\",\n  windowLabel: \"Current\",\n  asOf: \"2026-04-25T10:00:00.000Z\",\n  definition: \"Sum of unpaid SOL in the reward pool.\",\n  freshness: \"live\",\n  drilldownHref: \"/economy/rewards#pool\",\n};\n\nconst sparseMetric: PeekMetric = {\n  id: \"failed-claims\",\n  label: \"Failed claims\",\n  value: null,\n  valueDisplay: \"0\",\n  unit: null,\n  source: \"referral_claims\",\n  windowLabel: \"Last 24h\",\n  asOf: null,\n  definition: \"Claims with status = failed in the last 24 hours.\",\n  freshness: \"cached\",\n  drilldownHref: null,\n};\n\ndescribe(\"MetricStrip\", () => {\n  it(\"populated: shows label, value, definition, source, window, as-of, freshness, and drilldown link\", () => {\n    render(<MetricStrip metrics={[fundedMetric]} />);\n\n    const card = screen.getByLabelText(\"Reward pool balance\");\n    expect(within(card).getByText(\"Reward pool balance\")).toBeInTheDocument();\n    expect(within(card).getByText(\"1.234\")).toBeInTheDocument();\n    expect(within(card).getByText(\"SOL\")).toBeInTheDocument();\n    expect(within(card).getByText(\"Sum of unpaid SOL in the reward pool.\")).toBeInTheDocument();\n    expect(within(card).getByText(\"reward_pool\")).toBeInTheDocument();\n    expect(within(card).getByText(\"Current\")).toBeInTheDocument();\n    expect(within(card).getByText(\"2026-04-25T10:00:00.000Z\")).toBeInTheDocument();\n    expect(within(card).getByText(\"live\")).toBeInTheDocument();\n    const link = within(card).getByRole(\"link\", { name: /View rows/ });\n    expect(link).toHaveAttribute(\"href\", \"/economy/rewards#pool\");\n  });\n\n  it(\"populated sparse-data variant: renders dash for missing as-of and no drilldown link when href is null\", () => {\n    render(<MetricStrip metrics={[sparseMetric]} />);\n\n    const card = screen.getByLabelText(\"Failed claims\");\n    expect(within(card).getByText(\"0\")).toBeInTheDocument();\n    expect(within(card).getByText(\"—\")).toBeInTheDocument();\n    expect(within(card).queryByRole(\"link\")).toBeNull();\n    expect(within(card).getByText(\"cached\")).toBeInTheDocument();\n  });\n\n  it(\"sparse: renders an empty status when no metrics are provided\", () => {\n    render(<MetricStrip metrics={[]} />);\n\n    expect(screen.getByRole(\"status\")).toHaveTextContent(\"No metrics available for this view.\");\n    expect(screen.queryByRole(\"region\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and not the metric grid\", () => {\n    render(<MetricStrip metrics={[fundedMetric]} error=\"query timeout\" />);\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\"Metrics unavailable: query timeout\");\n    expect(screen.queryByLabelText(\"Reward pool balance\")).toBeNull();\n  });\n});\n","numLines":75,"startLine":1,"totalLines":75}}}
