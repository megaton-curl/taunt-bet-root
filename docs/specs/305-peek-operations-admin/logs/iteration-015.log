{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01CB15c1bt7uhSZ9ubYGUxMj","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_018LcbVY2wHoPDoe6BuVjVim","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-recent-operator-events.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  RECENT_OPERATOR_EVENTS_DEFAULT_LIMIT,\n  RECENT_OPERATOR_EVENTS_MAX_LIMIT,\n  getRecentOperatorEvents,\n} from \"../get-recent-operator-events\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype Row = {\n  id: string;\n  eventType: string;\n  actorEmail: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  route: string | null;\n  createdAt: string;\n};\n\ntype Response = ReadonlyArray<Row> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\nfunction createSqlMock(response: Response): SqlMock {\n  const calls: SqlCall[] = [];\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    if (response instanceof Error) return Promise.reject(response);\n    return Promise.resolve(response);\n  };\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\ndescribe(\"getRecentOperatorEvents\", () => {\n  it(\"populated: shapes rows into PeekRecentActivityItem and preserves order\", async () => {\n    const mock = createSqlMock([\n      {\n        id: \"1\",\n        eventType: \"peek.user.view_sensitive\",\n        actorEmail: \"alice@example.com\",\n        resourceType: \"user\",\n        resourceId: \"u-1\",\n        route: \"/users/u-1\",\n        createdAt: \"2026-04-25T10:00:00.000Z\",\n      },\n      {\n        id: \"2\",\n        eventType: \"peek.export\",\n        actorEmail: \"biz@example.com\",\n        resourceType: \"export\",\n        resourceId: null,\n        route: \"/growth/referrals/export\",\n        createdAt: \"2026-04-25T09:55:00.000Z\",\n      },\n    ]);\n\n    const items = await getRecentOperatorEvents({ sql: mock.sql });\n\n    expect(items).toHaveLength(2);\n    expect(items[0].id).toBe(\"1\");\n    expect(items[0].eventType).toBe(\"peek.user.view_sensitive\");\n    expect(items[0].actorEmail).toBe(\"alice@example.com\");\n    expect(items[0].resourceType).toBe(\"user\");\n    expect(items[0].resourceId).toBe(\"u-1\");\n    expect(items[0].route).toBe(\"/users/u-1\");\n    expect(items[0].createdAt).toBe(\"2026-04-25T10:00:00.000Z\");\n    expect(items[1].resourceId).toBeNull();\n  });\n\n  it(\"populated: defaults the limit to RECENT_OPERATOR_EVENTS_DEFAULT_LIMIT\", async () => {\n    const mock = createSqlMock([]);\n\n    await getRecentOperatorEvents({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    expect(mock.calls[0].values).toContain(\n      RECENT_OPERATOR_EVENTS_DEFAULT_LIMIT,\n    );\n  });\n\n  it(\"limit clamp: oversized limits clamp down to RECENT_OPERATOR_EVENTS_MAX_LIMIT\", async () => {\n    const mock = createSqlMock([]);\n\n    await getRecentOperatorEvents({ sql: mock.sql, limit: 9999 });\n\n    expect(mock.calls[0].values).toContain(RECENT_OPERATOR_EVENTS_MAX_LIMIT);\n    expect(mock.calls[0].values).not.toContain(9999);\n  });\n\n  it(\"limit clamp: zero/negative limits clamp up to 1 so the query stays bounded but useful\", async () => {\n    const mockZero = createSqlMock([]);\n    await getRecentOperatorEvents({ sql: mockZero.sql, limit: 0 });\n    expect(mockZero.calls[0].values).toContain(1);\n\n    const mockNeg = createSqlMock([]);\n    await getRecentOperatorEvents({ sql: mockNeg.sql, limit: -5 });\n    expect(mockNeg.calls[0].values).toContain(1);\n  });\n\n  it(\"limit clamp: fractional limits floor to an integer before applying the bound\", async () => {\n    const mock = createSqlMock([]);\n\n    await getRecentOperatorEvents({ sql: mock.sql, limit: 7.9 });\n\n    expect(mock.calls[0].values).toContain(7);\n    expect(mock.calls[0].values).not.toContain(7.9);\n  });\n\n  it(\"empty: returns [] when the table has no rows\", async () => {\n    const mock = createSqlMock([]);\n\n    const items = await getRecentOperatorEvents({ sql: mock.sql });\n\n    expect(items).toEqual([]);\n  });\n\n  it(\"query: orders by created_at desc and projects the activity columns\", async () => {\n    const mock = createSqlMock([]);\n\n    await getRecentOperatorEvents({ sql: mock.sql });\n\n    const text = mock.calls[0].text;\n    expect(text).toMatch(/from operator_events/i);\n    expect(text).toMatch(/order by created_at desc/i);\n    expect(text).toMatch(/payload->>'actorEmail'/);\n    expect(text).toMatch(/payload->>'resourceType'/);\n    expect(text).toMatch(/payload->>'resourceId'/);\n    expect(text).toMatch(/payload->>'route'/);\n  });\n\n  it(\"load-error: a rejected query propagates so the page-level try/catch can render the alert\", async () => {\n    const mock = createSqlMock(new Error(\"connection refused\"));\n\n    await expect(\n      getRecentOperatorEvents({ sql: mock.sql }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3842,"cache_read_input_tokens":115406,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3842},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"19c9a51e-3972-4bff-bc15-86d90691364e","uuid":"d6ac21db-2159-409f-954f-456c31e2c76d"}
