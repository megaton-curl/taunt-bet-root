{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DxF5sxCcJxLe3cFDsx5Mfy","type":"tool_result","content":"1\timport type { CSSProperties } from \"react\";\n2\timport Link from \"next/link\";\n3\timport { MetricStrip } from \"../src/components/metric-strip\";\n4\timport { PaginationControls } from \"../src/components/pagination-controls\";\n5\timport { SummaryStrip } from \"../src/components/summary-strip\";\n6\timport { UsersTable } from \"../src/components/users-table\";\n7\timport { normalizePeekSearchParams } from \"../src/lib/search-params\";\n8\timport type {\n9\t  PeekCommandCenterAttention,\n10\t  PeekRecentActivityItem,\n11\t  PeekSummary,\n12\t  PeekUserRow,\n13\t} from \"../src/lib/types/peek\";\n14\timport { countPeekUsers } from \"../src/server/db/queries/count-peek-users\";\n15\timport { getCommandCenterAttention } from \"../src/server/db/queries/get-command-center-attention\";\n16\timport { getPeekSummary } from \"../src/server/db/queries/get-peek-summary\";\n17\timport { getRecentOperatorEvents } from \"../src/server/db/queries/get-recent-operator-events\";\n18\timport { listPeekUsers } from \"../src/server/db/queries/list-peek-users\";\n19\t\n20\texport const dynamic = \"force-dynamic\";\n21\t\n22\texport default async function HomePage({\n23\t  searchParams,\n24\t}: {\n25\t  searchParams: Promise<Record<string, string | string[] | undefined>>;\n26\t}) {\n27\t  const initialParams = normalizePeekSearchParams(await searchParams);\n28\t  let summary: PeekSummary = {\n29\t    totalUsers: 0,\n30\t    totalUsersWithCodes: 0,\n31\t    totalReferredUsers: 0,\n32\t    totalUniqueReferrers: 0,\n33\t  };\n34\t  let attention: PeekCommandCenterAttention = {\n35\t    generatedAt: new Date().toISOString(),\n36\t    metrics: [],\n37\t  };\n38\t  let recentActivity: PeekRecentActivityItem[] = [];\n39\t  let users: PeekUserRow[] = [];\n40\t  let totalCount = 0;\n41\t  let loadError: string | null = null;\n42\t  let attentionError: string | null = null;\n43\t  let activityError: string | null = null;\n44\t  let params = initialParams;\n45\t\n46\t  try {\n47\t    [summary, totalCount] = await Promise.all([\n48\t      getPeekSummary(),\n49\t      countPeekUsers(initialParams),\n50\t    ]);\n51\t\n52\t    if (totalCount > 0) {\n53\t      const totalPages = Math.max(1, Math.ceil(totalCount / initialParams.pageSize));\n54\t      params = {\n55\t        ...initialParams,\n56\t        page: Math.min(initialParams.page, totalPages),\n57\t      };\n58\t    }\n59\t\n60\t    users = await listPeekUsers(params);\n61\t  } catch (error) {\n62\t    loadError =\n63\t      error instanceof Error\n64\t        ? error.message\n65\t        : \"Peek could not load data from the database.\";\n66\t  }\n67\t\n68\t  try {\n69\t    attention = await getCommandCenterAttention();\n70\t  } catch (error) {\n71\t    attentionError =\n72\t      error instanceof Error\n73\t        ? error.message\n74\t        : \"Attention queue could not be loaded.\";\n75\t  }\n76\t\n77\t  try {\n78\t    recentActivity = await getRecentOperatorEvents();\n79\t  } catch (error) {\n80\t    activityError =\n81\t      error instanceof Error\n82\t        ? error.message\n83\t        : \"Recent activity could not be loaded.\";\n84\t  }\n85\t\n86\t  return (\n87\t    <main style={{ display: \"grid\", gap: \"1.5rem\" }}>\n88\t      <header>\n89\t        <h1>Command center</h1>\n90\t        <p style={{ margin: \"0.25rem 0 0\", color: \"#94a3b8\" }}>\n91\t          Search, attention queue, platform summary, recent activity, and users.\n92\t        </p>\n93\t      </header>\n94\t\n95\t      <section aria-labelledby=\"global-search-heading\">\n96\t        <h2 id=\"global-search-heading\" style={sectionHeadingStyle}>\n97\t          Global search\n98\t        </h2>\n99\t        <form\n100\t          action=\"/\"\n101\t          method=\"get\"\n102\t          role=\"search\"\n103\t          style={{ display: \"flex\", gap: \"0.5rem\", alignItems: \"stretch\" }}\n104\t        >\n105\t          <input\n106\t            aria-label=\"Global search\"\n107\t            defaultValue={params.query}\n108\t            name=\"query\"\n109\t            placeholder=\"user id, username, wallet, referral code, Telegram, round PDA, tx signature\"\n110\t            style={{ ...inputStyle, flex: 1 }}\n111\t            type=\"search\"\n112\t          />\n113\t          <button style={buttonStyle} type=\"submit\">\n114\t            Search\n115\t          </button>\n116\t        </form>\n117\t      </section>\n118\t\n119\t      <section aria-labelledby=\"attention-heading\">\n120\t        <h2 id=\"attention-heading\" style={sectionHeadingStyle}>\n121\t          Attention queue\n122\t        </h2>\n123\t        <MetricStrip metrics={attention.metrics} error={attentionError} />\n124\t      </section>\n125\t\n126\t      <section aria-labelledby=\"summary-heading\">\n127\t        <h2 id=\"summary-heading\" style={sectionHeadingStyle}>\n128\t          Platform summary\n129\t        </h2>\n130\t        <SummaryStrip summary={summary} />\n131\t      </section>\n132\t\n133\t      <section aria-labelledby=\"activity-heading\">\n134\t        <h2 id=\"activity-heading\" style={sectionHeadingStyle}>\n135\t          Recent activity\n136\t        </h2>\n137\t        <RecentActivityList error={activityError} items={recentActivity} />\n138\t      </section>\n139\t\n140\t      <section aria-labelledby=\"users-heading\" style={{ display: \"grid\", gap: \"1rem\" }}>\n141\t        <h2 id=\"users-heading\" style={sectionHeadingStyle}>\n142\t          Users\n143\t        </h2>\n144\t        {loadError ? (\n145\t          <p\n146\t            style={{\n147\t              margin: 0,\n148\t              padding: \"0.75rem 1rem\",\n149\t              borderRadius: \"0.75rem\",\n150\t              background: \"#3f1d1d\",\n151\t              color: \"#fecaca\",\n152\t            }}\n153\t            role=\"alert\"\n154\t          >\n155\t            Data unavailable: {loadEr