{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018iVATPkCVYDoELd9eB1wgT","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport {\n3\t  getConnectTimeoutSecondsFromEnv,\n4\t  getDatabaseUrlFromEnv,\n5\t} from \"../../client\";\n6\t\n7\tdescribe(\"getDatabaseUrlFromEnv\", () => {\n8\t  it(\"returns the configured DATABASE_URL\", () => {\n9\t    expect(\n10\t      getDatabaseUrlFromEnv({\n11\t        DATABASE_URL: \"postgres://postgres:postgres@localhost:5432/taunt_bet\",\n12\t      })\n13\t    ).toBe(\"postgres://postgres:postgres@localhost:5432/taunt_bet\");\n14\t  });\n15\t\n16\t  it(\"defaults to a short connect timeout for unreachable databases\", () => {\n17\t    expect(getConnectTimeoutSecondsFromEnv({})).toBe(5);\n18\t  });\n19\t\n20\t  it(\"accepts an explicit connect timeout override\", () => {\n21\t    expect(\n22\t      getConnectTimeoutSecondsFromEnv({\n23\t        PEEK_DB_CONNECT_TIMEOUT_SECONDS: \"9\",\n24\t      })\n25\t    ).toBe(9);\n26\t  });\n27\t\n28\t  it(\"falls back to PGCONNECT_TIMEOUT when the peek-specific override is unset\", () => {\n29\t    expect(\n30\t      getConnectTimeoutSecondsFromEnv({\n31\t        PGCONNECT_TIMEOUT: \"7\",\n32\t      })\n33\t    ).toBe(7);\n34\t  });\n35\t\n36\t  it(\"ignores invalid timeout values\", () => {\n37\t    expect(\n38\t      getConnectTimeoutSecondsFromEnv({\n39\t        PEEK_DB_CONNECT_TIMEOUT_SECONDS: \"0\",\n40\t      })\n41\t    ).toBe(5);\n42\t\n43\t    expect(\n44\t      getConnectTimeoutSecondsFromEnv({\n45\t        PEEK_DB_CONNECT_TIMEOUT_SECONDS: \"abc\",\n46\t      })\n47\t    ).toBe(5);\n48\t  });\n49\t});\n50\t"}]},"parent_tool_use_id":null,"session_id":"19c9a51e-3972-4bff-bc15-86d90691364e","uuid":"4396c1c6-9c1f-4497-ac1a-f2fef8fea316","timestamp":"2026-04-25T11:25:27.099Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-peek-summary.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport {\n  getConnectTimeoutSecondsFromEnv,\n  getDatabaseUrlFromEnv,\n} from \"../../client\";\n\ndescribe(\"getDatabaseUrlFromEnv\", () => {\n  it(\"returns the configured DATABASE_URL\", () => {\n    expect(\n      getDatabaseUrlFromEnv({\n        DATABASE_URL: \"postgres://postgres:postgres@localhost:5432/taunt_bet\",\n      })\n    ).toBe(\"postgres://postgres:postgres@localhost:5432/taunt_bet\");\n  });\n\n  it(\"defaults to a short connect timeout for unreachable databases\", () => {\n    expect(getConnectTimeoutSecondsFromEnv({})).toBe(5);\n  });\n\n  it(\"accepts an explicit connect timeout override\", () => {\n    expect(\n      getConnectTimeoutSecondsFromEnv({\n        PEEK_DB_CONNECT_TIMEOUT_SECONDS: \"9\",\n      })\n    ).toBe(9);\n  });\n\n  it(\"falls back to PGCONNECT_TIMEOUT when the peek-specific override is unset\", () => {\n    expect(\n      getConnectTimeoutSecondsFromEnv({\n        PGCONNECT_TIMEOUT: \"7\",\n      })\n    ).toBe(7);\n  });\n\n  it(\"ignores invalid timeout values\", () => {\n    expect(\n      getConnectTimeoutSecondsFromEnv({\n        PEEK_DB_CONNECT_TIMEOUT_SECONDS: \"0\",\n      })\n    ).toBe(5);\n\n    expect(\n      getConnectTimeoutSecondsFromEnv({\n        PEEK_DB_CONNECT_TIMEOUT_SECONDS: \"abc\",\n      })\n    ).toBe(5);\n  });\n});\n","numLines":50,"startLine":1,"totalLines":50}}}
