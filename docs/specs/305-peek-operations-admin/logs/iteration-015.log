{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01FW94HKLcfprHD5BstJsWXN","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01EvVbFzQHpdEQqSU3pnCDUi","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/recent-activity-list.tsx","content":"// Recent activity list (FR-3 command-center \"high-signal activity\").\n//\n// Browser-safe presentational component for the latest `operator_events` rows\n// projected into `PeekRecentActivityItem` shape. Renders a dense list with the\n// fields an operator scans first (time, event type, actor email, route +\n// resource label). Empty state is operator-readable; non-null `error` renders\n// `role=\"alert\"` and suppresses the list.\n\nimport type { CSSProperties } from \"react\";\nimport Link from \"next/link\";\nimport type { PeekRecentActivityItem } from \"../lib/types/peek\";\n\nexport type RecentActivityListProps = {\n  items: ReadonlyArray<PeekRecentActivityItem>;\n  error: string | null;\n};\n\nexport function RecentActivityList({ items, error }: RecentActivityListProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorBoxStyle}>\n        Recent activity unavailable: {error}\n      </div>\n    );\n  }\n\n  if (items.length === 0) {\n    return (\n      <div role=\"status\" style={emptyBoxStyle}>\n        No recent operator activity recorded yet.\n      </div>\n    );\n  }\n\n  return (\n    <ul aria-label=\"Recent operator activity\" style={listStyle}>\n      {items.map((item) => {\n        const resourceLabel =\n          item.resourceType && item.resourceId\n            ? `${item.resourceType}:${item.resourceId}`\n            : item.resourceType ?? item.resourceId ?? null;\n        return (\n          <li key={item.id} style={itemStyle}>\n            <span style={timeStyle}>{item.createdAt}</span>\n            <span style={typeStyle}>{item.eventType}</span>\n            <span style={actorStyle}>{item.actorEmail ?? \"—\"}</span>\n            <span style={resourceStyle}>\n              {item.route ? (\n                <Link href={item.route} style={routeStyle}>\n                  {item.route}\n                </Link>\n              ) : null}\n              {resourceLabel ? (\n                <span style={resourceLabelStyle}>{resourceLabel}</span>\n              ) : null}\n            </span>\n          </li>\n        );\n      })}\n    </ul>\n  );\n}\n\nconst listStyle: CSSProperties = {\n  margin: 0,\n  padding: 0,\n  listStyle: \"none\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n  background: \"#0b1220\",\n  display: \"grid\",\n};\n\nconst itemStyle: CSSProperties = {\n  display: \"grid\",\n  gridTemplateColumns:\n    \"minmax(200px, auto) minmax(140px, auto) minmax(160px, 1fr) minmax(200px, 2fr)\",\n  gap: \"0.75rem\",\n  padding: \"0.5rem 0.75rem\",\n  borderTop: \"1px solid #111827\",\n  fontSize: \"0.8125rem\",\n  color: \"#cbd5f5\",\n};\n\nconst timeStyle: CSSProperties = {\n  color: \"#94a3b8\",\n  fontFamily: \"monospace\",\n};\n\nconst typeStyle: CSSProperties = {\n  fontWeight: 600,\n};\n\nconst actorStyle: CSSProperties = {\n  color: \"#cbd5f5\",\n};\n\nconst resourceStyle: CSSProperties = {\n  display: \"flex\",\n  gap: \"0.5rem\",\n  alignItems: \"center\",\n  flexWrap: \"wrap\",\n};\n\nconst routeStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst resourceLabelStyle: CSSProperties = {\n  color: \"#94a3b8\",\n  fontFamily: \"monospace\",\n};\n\nconst emptyBoxStyle: CSSProperties = {\n  padding: \"1rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px solid #1e293b\",\n  background: \"#0b1220\",\n  color: \"#94a3b8\",\n  fontSize: \"0.875rem\",\n};\n\nconst errorBoxStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{