{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HQe9zhapmrjae6JLFiaCNK","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport { render, screen, within } from \"@testing-library/react\";\n3\timport {\n4\t  AdminShell,\n5\t  type AdminShellNavItem,\n6\t} from \"../admin-shell\";\n7\t\n8\tconst ALL_NAV_ITEMS: ReadonlyArray<AdminShellNavItem> = [\n9\t  { id: \"users\", label: \"Users\", href: \"/users\" },\n10\t  { id: \"growth\", label: \"Growth\", href: \"/growth/referrals\" },\n11\t  { id: \"games\", label: \"Games\", href: \"/games\" },\n12\t  { id: \"economy\", label: \"Economy\", href: \"/economy/rewards\" },\n13\t  { id: \"operations\", label: \"Operations\", href: \"/operations/queue\" },\n14\t  { id: \"audit\", label: \"Audit\", href: \"/audit\" },\n15\t  { id: \"access\", label: \"Access\", href: \"/access\" },\n16\t];\n17\t\n18\tconst BUSINESS_NAV_ITEMS: ReadonlyArray<AdminShellNavItem> = ALL_NAV_ITEMS.filter(\n19\t  (item) => item.id !== \"audit\",\n20\t);\n21\t\n22\tdescribe(\"AdminShell\", () => {\n23\t  it(\"populated (admin): renders brand, every nav link, actor email, and the resolved role badge\", () => {\n24\t    render(\n25\t      <AdminShell\n26\t        actor={{ email: \"alice@example.com\", role: \"admin\" }}\n27\t        navItems={ALL_NAV_ITEMS}\n28\t      >\n29\t        <p>page content</p>\n30\t      </AdminShell>,\n31\t    );\n32\t\n33\t    expect(screen.getByText(\"Peek\")).toBeInTheDocument();\n34\t\n35\t    const nav = screen.getByRole(\"navigation\", { name: \"Primary\" });\n36\t    const labels = within(nav)\n37\t      .getAllByRole(\"link\")\n38\t      .map((link) => link.textContent);\n39\t    expect(labels).toEqual([\n40\t      \"Users\",\n41\t      \"Growth\",\n42\t      \"Games\",\n43\t      \"Economy\",\n44\t      \"Operations\",\n45\t      \"Audit\",\n46\t      \"Access\",\n47\t    ]);\n48\t    expect(within(nav).getByRole(\"link\", { name: \"Audit\" })).toHaveAttribute(\n49\t      \"href\",\n50\t      \"/audit\",\n51\t    );\n52\t\n53\t    const identity = screen.getByLabelText(\"Verified actor\");\n54\t    expect(identity).toHaveTextContent(\"alice@example.com\");\n55\t\n56\t    const roleBadge = screen.getByLabelText(\"Resolved role: admin\");\n57\t    expect(roleBadge).toHaveTextContent(\"admin\");\n58\t    expect(roleBadge).toHaveAttribute(\"data-role\", \"admin\");\n59\t\n60\t    expect(screen.getByText(\"page content\")).toBeInTheDocument();\n61\t  });\n62\t\n63\t  it(\"populated (business): hides Audit when caller did not include it in navItems\", () => {\n64\t    render(\n65\t      <AdminShell\n66\t        actor={{ email: \"biz@example.com\", role: \"business\" }}\n67\t        navItems={BUSINESS_NAV_ITEMS}\n68\t      >\n69\t        <p>page content</p>\n70\t      </AdminShell>,\n71\t    );\n72\t\n73\t    const nav = screen.getByRole(\"navigation\", { name: \"Primary\" });\n74\t    const labels = within(nav)\n75\t      .getAllByRole(\"link\")\n76\t      .map((link) => link.textContent);\n77\t    expect(labels).toEqual([\n78\t      \"Users\",\n79\t      \"Growth\",\n80\t      \"Games\",\n81\t      \"Economy\",\n82\t      \"Operations\",\n83\t      \"Access\",\n84\t    ]);\n85\t    expect(within(nav).queryByRole(\"link\", { name: \"Audit\" })).toBeNull();\n86\t\n87\t    const roleBadge = screen.getByLabelText(\"Resolved role: business\");\n88\t    expect(roleBadge).toHaveAttribute(\"data-role\", \"business\");\n89\t  });\n90\t\n91\t  it(\"no-role: renders the access-denied alert without echoing the verified email or rendering nav/children\", () => {\n92\t    render(\n93\t      <AdminShell\n94\t        actor={null}\n95\t        navItems={[]}\n96\t        accessIssue=\"no-role\"\n97\t      >\n98\t        <p data-testid=\"hidden-children\">page content</p>\n99\t      </AdminShell>,\n100\t    );\n101\t\n102\t    const alert = screen.getByRole(\"alert\", { name: \"Access denied\" });\n103\t    expect(alert).toHaveTextContent(\"Local role not assigned\");\n104\t    expect(alert).toHaveTextContent(\n105\t      \"no local peek role is configured for it\",\n106\t    );\n107\t\n108\t    expect(alert.textContent ?? \"\").not.toContain(\"@\");\n109\t\n110\t    expect(screen.queryByRole(\"navigation\", { name: \"Primary\" })).toBeNull();\n111\t    expect(screen.queryByLabelText(\"Verified actor\")).toBeNull();\n112\t    expect(screen.queryByTestId(\"hidden-children\")).toBeNull();\n113\t  });\n114\t\n115\t  it(\"no-identity: renders a generic missing-identity alert and suppresses nav/identity/children\", () => {\n116\t    render(\n117\t      <AdminShell\n118\t        actor={null}\n119\t        navItems={[]}\n120\t        accessIssue=\"no-identity\"\n121\t      >\n122\t        <p data-testid=\"hidden-children\">page content</p>\n123\t      </AdminShell>,\n124\t    );\n125\t\n126\t    const alert = screen.getByRole(\"alert\", { name: \"Access denied\" });\n127\t    expect(alert).toHaveTextContent(\"Access not available\");\n128\t    expect(alert).toHaveTextContent(\"Cloudflare Access did not deliver\");\n129\t\n130\t    expect(alert.textContent ?? \"\").not.toContain(\"@\");\n131\t\n132\t    expect(screen.queryByRole(\"navigation\", { name: \"Primary\" })).toBeNull();\n133\t    expect(screen.queryByLabelText(\"Verified actor\")).toBeNull();\n134\t    expect(screen.queryByTestId(\"hidden-children\")).toBeNull();\n135\t  });\n136\t\n137\t  it(\"no-role with stale actor: still suppresses identity and nav so denied state never leaks the verified email\", () => {\n138\t    render(\n139\t      <AdminShell\n140\t        actor={{ email: \"alice@example.com\", role: \"admin\" }}\n141\t        navItems={ALL_NAV_ITEMS}\n142\t        accessIssue=\"no-role\"\n143\t      >\n144\t        <p data-testid=\"hidden-children\">page content</p>\n145\t      </AdminShell>,\n146\t    );\n147\t\n148\t    expect(screen.queryByLabelText(\"Verified actor\")).toBeNull();\n149\t    expect(screen.queryByText(\"alice@example.com\")).toBeNull();\n150\t    expect(screen.queryByRole(\"navigation\", { name: \"Primary\" })).toBeNull();\n151\t    expect(screen.queryByTestId(\"hidden-children\")).toBeNull();\n152\t    expect(screen.getByRole(\"alert\", { name: \"Access denied\" })).toBeInTheDocument();\n153\t  });\n154\t\n155\t  it(\"populated with empty navItems: renders identity but no primary nav (defensive for unconfigured nav)\", () => {\n156\t    render(\n157\t      <AdminShell\n158\t        actor={{ email: \"biz@example.com\", role: \"business\" }}\n159\t        navItems={[]}\n160\t      >\n161\t        <p data-testid=\"page-children\">page content</p>\n162\t      </AdminShell>,\n163\t    );\n164\t\n165\t    expect(screen.queryByRole(\"navigation\", { name: \"Primary\" })).toBeNull();\n166\t    expect(screen.getByLabelText(\"Verified actor\")).toHaveTextContent(\n167\t      \"biz@example.com\",\n168\t    );\n169\t    expect(screen.getByTestId(\"page-children\")).toBeInTheDocument();\n170\t  });\n171\t});\n172\t"}]},"parent_tool_use_id":null,"session_id":"19c9a51e-3972-4bff-bc15-86d90691364e","uuid":"51dbe616-8750-45ba-9c31-a0b27bf2a4cd","timestamp":"2026-04-25T11:25:40.162Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/admin-shell.test.tsx","content":"import { describe, expect, it } from \"vitest\";\nimport { render, screen, within } from \"@testing-library/react\";\nimport {\n  AdminShell,\n  type AdminShellNavItem,\n} from \"../admin-shell\";\n\nconst ALL_NAV_ITEMS: ReadonlyArray<AdminShellNavItem> = [\n  { id: \"users\", label: \"Users\", href: \"/users\" },\n  { id: \"growth\", label: \"Growth\", href: \"/growth/referrals\" },\n  { id: \"games\", label: \"Games\", href: \"/games\" },\n  { id: \"economy\", label: \"Economy\", href: \"/economy/rewards\" },\n  { id: \"operations\", label: \"Operations\", href: \"/operations/queue\" },\n  { id: \"audit\", label: \"Audit\", href: \"/audit\" },\n  { id: \"access\", label: \"Access\", href: \"/access\" },\n];\n\nconst BUSINESS_NAV_ITEMS: ReadonlyArray<AdminShellNavItem> = ALL_NAV_ITEMS.filter(\n  (item) => item.id !== \"audit\",\n);\n\ndescribe(\"AdminShell\", () => {\n  it(\"populated (admin): renders brand, every nav link, actor email, and the resolved role badge\", () => {\n    render(\n      <AdminShell\n        actor={{ email: \"alice@example.com\", role: \"admin\" }}\n        navItems={ALL_NAV_ITEMS}\n      >\n        <p>page content</p>\n      </AdminShell>,\n    );\n\n    expect(screen.getByText(\"Peek\")).toBeInTheDocument();\n\n    const nav = screen.getByRole(\"navigation\", { name: \"Primary\" });\n    const labels = within(nav)\n      .getAllByRole(\"link\")\n      .map((link) => link.textContent);\n    expect(labels).toEqual([\n      \"Users\",\n      \"Growth\",\n      \"Games\",\n      \"Economy\",\n      \"Operations\",\n      \"Audit\",\n      \"Access\",\n    ]);\n    expect(within(nav).getByRole(\"link\", { name: \"Audit\" })).toHaveAttribute(\n      \"href\",\n      \"/audit\",\n    );\n\n    const identity = screen.getByLabelText(\"Verified actor\");\n    expect(identity).toHaveTextContent(\"alice@example.com\");\n\n    const roleBadge = screen.getByLabelText(\"Resolved role: admin\");\n    expect(roleBadge).toHaveTextContent(\"admin\");\n    expect(roleBadge).toHaveAttribute(\"data-role\", \"admin\");\n\n    expect(screen.getByText(\"page content\")).toBeInTheDocument();\n  });\n\n  it(\"populated (business): hides Audit when caller did not include it in navItems\", () => {\n    render(\n      <AdminShell\n        actor={{ email: \"biz@example.com\", role: \"business\" }}\n        navItems={BUSINESS_NAV_ITEMS}\n      >\n        <p>page content</p>\n      </AdminShell>,\n    );\n\n    const nav = screen.getByRole(\"navigation\", { name: \"Primary\" });\n    const labels = within(nav)\n      .getAllByRole(\"link\")\n      .map((link) => link.textContent);\n    expect(labels).toEqual([\n      \"Users\",\n      \"Growth\",\n      \"Games\",\n      \"Economy\",\n      \"Operations\",\n      \"Access\",\n    ]);\n    expect(within(nav).queryByRole(\"link\", { name: \"Audit\" })).toBeNull();\n\n    const roleBadge = screen.getByLabelText(\"Resolved role: business\");\n    expect(roleBadge).toHaveAttribute(\"data-role\", \"business\");\n  });\n\n  it(\"no-role: renders the access-denied alert without echoing the verified email or rendering nav/children\", () => {\n    render(\n      <AdminShell\n        actor={null}\n        navItems={[]}\n        accessIssue=\"no-role\"\n      >\n        <p data-testid=\"hidden-children\">page content</p>\n      </AdminShell>,\n    );\n\n    const alert = screen.getByRole(\"alert\", { name: \"Access denied\" });\n    expect(alert).toHaveTextContent(\"Local role not assigned\");\n    expect(alert).toHaveTextContent(\n      \"no local peek role is configured for it\",\n    );\n\n    expect(alert.textContent ?? \"\").not.toContain(\"@\");\n\n    expect(screen.queryByRole(\"navigation\", { name: \"Primary\" })).toBeNull();\n    expect(screen.queryByLabelText(\"Verified actor\")).toBeNull();\n    expect(screen.queryByTestId(\"hidden-children\")).toBeNull();\n  });\n\n  it(\"no-identity: renders a generic missing-identity alert and suppresses nav/identity/children\", () => {\n    render(\n      <AdminShell\n        actor={null}\n        navItems={[]}\n        accessIssue=\"no-identity\"\n      >\n        <p data-testid=\"hidden-children\">page content</p>\n      </AdminShell>,\n    );\n\n    const alert = screen.getByRole(\"alert\", { name: \"Access denied\" });\n    expect(alert).toHaveTextContent(\"Access not available\");\n    expect(alert).toHaveTextContent(\"Cloudflare Access did not deliver\");\n\n    expect(alert.textContent ?? \"\").not.toContain(\"@\");\n\n    expect(screen.queryByRole(\"navigation\", { name: \"Primary\" })).toBeNull();\n    expect(screen.queryByLabelText(\"Verified actor\")).toBeNull();\n    expect(screen.queryByTestId(\"hidden-children\")).toBeNull();\n  });\n\n  it(\"no-role with stale actor: still suppresses identity and nav so denied state never leaks the verified email\", () => {\n    render(\n      <AdminShell\n        actor={{ email: \"alice@example.com\", role: \"admin\" }}\n        navItems={ALL_NAV_ITEMS}\n        accessIssue=\"no-role\"\n      >\n        <p data-testid=\"hidden-children\">page content</p>\n      </AdminShell>,\n    );\n\n    expect(screen.queryByLabelText(\"Verified actor\")).toBeNull();\n    expect(screen.queryByText(\"alice@example.com\")).toBeNull();\n    expect(screen.queryByRole(\"navigation\", { name: \"Primary\" })).toBeNull();\n    expect(screen.queryByTestId(\"hidden-children\")).toBeNull();\n    expect(screen.getByRole(\"alert\", { name: \"Access denied\" })).toBeInTheDocument();\n  });\n\n  it(\"populated with empty navItems: renders identity but no primary nav (defensive for unconfigured nav)\", () => {\n    render(\n      <AdminShell\n        actor={{ email: \"biz@example.com\", role: \"business\" }}\n        navItems={[]}\n      >\n        <p data-testid=\"page-children\">page content</p>\n      </AdminShell>,\n    );\n\n    expect(screen.queryByRole(\"navigation\", { name: \"Primary\" })).toBeNull();\n    expect(screen.getByLabelText(\"Verified actor\")).toHaveTextContent(\n      \"biz@example.com\",\n    );\n    expect(screen.getByTestId(\"page-children\")).toBeInTheDocument();\n  });\n});\n","numLines":172,"startLine":1,"totalLines":172}}}
