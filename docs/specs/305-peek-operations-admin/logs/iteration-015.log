tSize: \"0.875rem\",\n};\n\nconst errorBoxStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};","newString":"const buttonStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #475569\",\n  background: \"#1d4ed8\",\n  color: \"#eff6ff\",\n  padding: \"0.75rem 1rem\",\n  fontWeight: 600,\n};","originalFile":"import type { CSSProperties } from \"react\";\nimport { MetricStrip } from \"../src/components/metric-strip\";\nimport { PaginationControls } from \"../src/components/pagination-controls\";\nimport { RecentActivityList } from \"../src/components/recent-activity-list\";\nimport { SummaryStrip } from \"../src/components/summary-strip\";\nimport { UsersTable } from \"../src/components/users-table\";\nimport { normalizePeekSearchParams } from \"../src/lib/search-params\";\nimport type {\n  PeekCommandCenterAttention,\n  PeekRecentActivityItem,\n  PeekSummary,\n  PeekUserRow,\n} from \"../src/lib/types/peek\";\nimport { countPeekUsers } from \"../src/server/db/queries/count-peek-users\";\nimport { getCommandCenterAttention } from \"../src/server/db/queries/get-command-center-attention\";\nimport { getPeekSummary } from \"../src/server/db/queries/get-peek-summary\";\nimport { getRecentOperatorEvents } from \"../src/server/db/queries/get-recent-operator-events\";\nimport { listPeekUsers } from \"../src/server/db/queries/list-peek-users\";\n\nexport const dynamic = \"force-dynamic\";\n\nexport default async function HomePage({\n  searchParams,\n}: {\n  searchParams: Promise<Record<string, string | string[] | undefined>>;\n}) {\n  const initialParams = normalizePeekSearchParams(await searchParams);\n  let summary: PeekSummary = {\n    totalUsers: 0,\n    totalUsersWithCodes: 0,\n    totalReferredUsers: 0,\n    totalUniqueReferrers: 0,\n  };\n  let attention: PeekCommandCenterAttention = {\n    generatedAt: new Date().toISOString(),\n    metrics: [],\n  };\n  let recentActivity: PeekRecentActivityItem[] = [];\n  let users: PeekUserRow[] = [];\n  let totalCount = 0;\n  let loadError: string | null = null;\n  let attentionError: string | null = null;\n  let activityError: string | null = null;\n  let params = initialParams;\n\n  try {\n    [summary, totalCount] = await Promise.all([\n      getPeekSummary(),\n      countPeekUsers(initialParams),\n    ]);\n\n    if (totalCount > 0) {\n      const totalPages = Math.max(1, Math.ceil(totalCount / initialParams.pageSize));\n      params = {\n        ...initialParams,\n        page: Math.min(initialParams.page, totalPages),\n      };\n    }\n\n    users = await listPeekUsers(params);\n  } catch (error) {\n    loadError =\n      error instanceof Error\n        ? error.message\n        : \"Peek could not load data from the database.\";\n  }\n\n  try {\n    attention = await getCommandCenterAttention();\n  } catch (error) {\n    attentionError =\n      error instanceof Error\n        ? error.message\n        : \"Attention queue could not be loaded.\";\n  }\n\n  try {\n    recentActivity = await getRecentOperatorEvents();\n  } catch (error) {\n    activityError =\n      error instanceof Error\n        ? error.message\n        : \"Recent activity could not be loaded.\";\n  }\n\n  return (\n    <main style={{ display: \"grid\", gap: \"1.5rem\" }}>\n      <header>\n        <h1>Command center</h1>\n        <p style={{ margin: \"0.25rem 0 0\", color: \"#94a3b8\" }}>\n          Search, attention queue, platform summary, recent activity, and users.\n        </p>\n      </header>\n\n      <section aria-labelledby=\"global-search-heading\">\n        <h2 id=\"global-search-heading\" style={sectionHeadingStyle}>\n          Global search\n        </h2>\n        <form\n          action=\"/\"\n          method=\"get\"\n          role=\"search\"\n          style={{ display: \"flex\", gap: \"0.5rem\", alignItems: \"stretch\" }}\n        >\n          <input\n            aria-label=\"Global search\"\n            defaultValue={params.query}\n            name=\"query\"\n            placeholder=\"user id, username, wallet, referral code, Telegram, round PDA, tx signature\"\n            style={{ ...inputStyle, flex: 1 }}\n            type=\"search\"\n          />\n          <button style={buttonStyle} type=\"submit\">\n            Search\n          </button>\n        </form>\n      </section>\n\n      <section aria-labelledby=\"attention-heading\">\n        <h2 id=\"attention-heading\" style={sectionHeadingStyle}>\n          Attention queue\n        </h2>\n        <MetricStrip metrics={attention.metrics} error={attentionError} />\n      </section>\n\n      <section aria-labelledby=\"summary-heading\">\n        <h2 id=\"summary-heading\" style={sectionHeadingStyle}>\n          Platform summary\n        </h2>\n        <SummaryStrip summary={summary} />\n      </section>\n\n      <section aria-labelledby=\"activity-heading\">\n        <h2 id=\"activity-heading\" style={sectionHeadingStyle}>\n          Recent activity\n        </h2>\n        <RecentActivityList error={activityError} items={recentActivity} />\n      </section>\n\n      <section aria-labelledby=\"users-heading\" style={{ display: \"grid\", gap: \"1rem\" }}>\n        <h2 id=\"users-heading\" style={sectionHeadingStyle}>\n          Users\n        </h2>\n        {loadError ? (\n          <p\n            style={{\n              margin: 0,\n              padding: \"0.75rem 1rem\",\n              borderRadius: \"0.75rem\",\n              background: \"#3f1d1d\",\n              color: \"#fecaca\",\n            }}\n            role=\"alert\"\n          >\n            Data unavailable: {loadError}\n          </p>\n        ) : null}\n        <form\n          style={{\n            display: \"grid\",\n            gap: \"0.75rem\",\n            gridTemplateColumns: \"repeat(auto-fit, minmax(180px, 1fr))\",\n            alignItems: \"end\",\n          }}\n        >\n          <input name=\"query\" type=\"hidden\" value={params.query} />\n\n          <label style={fieldStyle}>\n            <span>Sort</span>\n            <select defaultValue={params.sort} name=\"sort\" style={inputStyle}>\n              <option value=\"joinedAt\">Joined</option>\n              <option value=\"refereeCount\">Referee count</option>\n            </select>\n          </label>\n\n          <label style={fieldStyle}>\n            <span>Direction</span>\n            <select defaultValue={params.direction} name=\"direction\" style={inputStyle}>\n              <option value=\"desc\">Newest first</option>\n              <option value=\"asc\">Oldest first</option>\n            </select>\n          </label>\n\n          <label style={checkboxStyle}>\n            <input defaultChecked={params.filters.hasReferrer} name=\"hasReferrer\" type=\"checkbox\" value=\"true\" />\n            <span>Has referrer</span>\n          </label>\n\n          <label style={checkboxStyle}>\n            <input defaultChecked={params.filters.hasReferees} name=\"hasReferees\" type=\"checkbox\" value=\"true\" />\n            <span>Has referees</span>\n          </label>\n\n          <label style={checkboxStyle}>\n            <input defaultChecked={params.filters.hasCode} name=\"hasCode\" type=\"checkbox\" value=\"true\" />\n            <span>Has code</span>\n          </label>\n\n          <label style={checkboxStyle}>\n            <input\n              defaultChecked={params.filters.hasTelegram}\n              name=\"hasTelegram\"\n              type=\"checkbox\"\n              value=\"true\"\n            />\n            <span>Has Telegram</span>\n          </label>\n\n          <button style={buttonStyle} type=\"submit\">\n            Apply\n          </button>\n        </form>\n        {!loadError ? <PaginationControls params={params} totalCount={totalCount} /> : null}\n        <UsersTable users={users} />\n        {!loadError && totalCount > params.pageSize ? (\n          <PaginationControls params={params} totalCount={totalCount} />\n        ) : null}\n      </section>\n    </main>\n  );\n}\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst fieldStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.35rem\",\n  fontSize: \"0.875rem\",\n};\n\nconst checkboxStyle: CSSProperties = {\n  display: \"flex\",\n  gap: \"0.5rem\",\n  alignItems: \"center\",\n  fontSize: \"0.875rem\",\n};\n\nconst inputStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #334155\",\n  background: \"#111827\",\n  color: \"#e2e8f0\",\n  padding: \"0.625rem 0.75rem\",\n};\n\nconst buttonStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #475569\",\n  background: \"#1d4ed8\",\n  color: \"#eff6ff\",\n  padding: \"0.75rem 1rem\",\n  fontWeight: 600,\n};\n\nconst activityListStyle: CSSProperties = {\n  margin: 0,\n  padding: 0,\n  listStyle: \"none\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n  background: \"#0b1220\",\n  display: \"grid\",\n};\n\nconst activityItemStyle: CSSProperties = {\n  display: \"grid\",\n  gridTemplateColumns: \"minmax(200px, auto) minmax(140px, auto) minmax(160px, 1fr) minmax(200px, 2fr)\",\n  gap: \"0.75rem\",\n  padding: \"0.5rem 0.75rem\",\n  borderTop: \"1px solid #111827\",\n  fontSize: \"0.8125rem\",\n  color: \"#cbd5f5\",\n};\n\nconst activityTimeStyle: CSSProperties = {\n  color: \"#94a3b8\",\n  fontFamily: \"monospace\",\n};\n\nconst activityTypeStyle: CSSProperties = {\n  fontWeight: 600,\n};\n\nconst activityActorStyle: CSSProperties = {\n  color: \"#cbd5f5\",\n};\n\nconst activityResourceStyle: CSSProperties = {\n  display: \"flex\",\n  gap: \"0.5rem\",\n  alignItems: \"center\",\n  flexWrap: \"wrap\",\n};\n\nconst activityRouteStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst activityResourceLabelStyle: CSSProperties = {\n  color: \"#94a3b8\",\n  fontFamily: \"monospace\",\n};\n\nconst emptyBoxStyle: CSSProperties = {\n  padding: \"1rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px solid #1e293b\",\n  background: \"#0b1220\",\n  color: \"#94a3b8\",\n  fontSize: \"0.875rem\",\n};\n\nconst errorBoxStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n","structuredPatch":[{"oldStart":258,"oldLines":70,"newStart":258,"newLines":3,"lines":["   padding: \"0.75rem 1rem\",","   fontWeight: 600,"," };","-","-const activityListStyle: CSSProperties = {","-  margin: 0,","-  padding: 0,","-  listStyle: \"none\",","-  border: \"1px solid #1e293b\",","-  borderRadius: \"0.75rem\",","-  background: \"#0b1220\",","-  display: \"grid\",","-};","-","-const activityItemStyle: CSSProperties = {","-  display: \"grid\",","-  gridTemplateColumns: \"minmax(200px, auto) minmax(140px, auto) minmax(160px, 1fr) minmax(200px, 2fr)\",","-  gap: \"0.75rem\",","-  padding: \"0.5rem 0.75rem\",","-  borderTop: \"1px solid #111827\",","-  fontSize: \"0.8125rem\",","-  color: \"#cbd5f5\",","-};","-","-const activityTimeStyle: CSSProperties = {","-  color: \"#94a3b8\",","-  fontFamily: \"monospace\",","-};","-","-const activityTypeStyle: CSSProperties = {","-  fontWeight: 600,","-};","-","-const activityActorStyle: CSSProperties = {","-  color: \"#cbd5f5\",","-};","-","-const activityResourceStyle: CSSProperties = {","-  display: \"flex\",","-  gap: \"0.5rem\",","-  alignItems: \"center\",","-  flexWrap: \"wrap\",","-};","-","-const activityRouteStyle: CSSProperties = {","-  color: \"#93c5fd\",","-  textDecoration: \"none\",","-};","-","-const activityResourceLabelStyle: CSSProperties = {","-  color: \"#94a3b8\",","-  fontFamily: \"monospace\",","-};","-","-const emptyBoxStyle: CSSProperties = {","-  padding: \"1rem\",","-  borderRadius: \"0.75rem\",","-  border: \"1px solid #1e293b\",","-  backg