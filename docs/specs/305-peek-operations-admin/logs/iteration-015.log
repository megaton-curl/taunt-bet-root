{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RGx36KBfz4vJMvbLZ7Xfsa","type":"tool_result","content":"1\t// Command-center attention queue query (FR-3, FR-10).\n2\t//\n3\t// Returns a small set of bounded \"needs attention\" metrics that the command\n4\t// center renders at the top of `/`. Each metric carries the FR-4 bookkeeping\n5\t// (id, label, value, source table, time window, \"as of\", definition,\n6\t// freshness, drill-down href) so the metric-strip primitive can render it\n7\t// without per-page hardcoding.\n8\t//\n9\t// Bounded queries: every query returns a single integer count. No row-level\n10\t// data crosses the wire here; per-feature pages provide the row drill-downs.\n11\t\n12\timport type {\n13\t  PeekCommandCenterAttention,\n14\t  PeekCommandCenterAttentionId,\n15\t  PeekMetric,\n16\t} from \"../../../lib/types/peek\";\n17\timport type { Sql } from \"postgres\";\n18\timport { getSqlClient } from \"../client\";\n19\t\n20\t// Thresholds — tuned for an operator console, not a fairness oracle. Tests can\n21\t// override via the `options` argument so age/limit assertions stay\n22\t// deterministic.\n23\texport const COMMAND_CENTER_DEFAULTS = {\n24\t  stuckRoundsAgeMinutes: 5,\n25\t  stuckRoundsMaxSettleAttempts: 3,\n26\t  stuckCloseCallAgeMinutes: 5,\n27\t  exportWindowHours: 24,\n28\t  exportRowCountThreshold: 1000,\n29\t} as const;\n30\t\n31\texport type CommandCenterThresholds = typeof COMMAND_CENTER_DEFAULTS;\n32\t\n33\texport type CommandCenterOptions = {\n34\t  sql?: Sql;\n35\t  thresholds?: Partial<CommandCenterThresholds>;\n36\t  now?: Date;\n37\t};\n38\t\n39\ttype AttentionRow = { value: number };\n40\t\n41\tfunction readCount(rows: ReadonlyArray<AttentionRow> | undefined): number {\n42\t  if (!rows || rows.length === 0) {\n43\t    return 0;\n44\t  }\n45\t  const raw = rows[0]?.value;\n46\t  if (typeof raw === \"number\" && Number.isFinite(raw)) {\n47\t    return raw;\n48\t  }\n49\t  if (typeof raw === \"string\") {\n50\t    const parsed = Number.parseInt(raw, 10);\n51\t    return Number.isFinite(parsed) ? parsed : 0;\n52\t  }\n53\t  return 0;\n54\t}\n55\t\n56\tfunction formatCount(count: number): string {\n57\t  return count.toLocaleString(\"en-US\");\n58\t}\n59\t\n60\ttype MetricBlueprint = {\n61\t  id: PeekCommandCenterAttentionId;\n62\t  label: string;\n63\t  unit: string | null;\n64\t  source: string;\n65\t  windowLabel: string;\n66\t  definition: string;\n67\t  drilldownHref: string | null;\n68\t};\n69\t\n70\tfunction makeMetric(\n71\t  blueprint: MetricBlueprint,\n72\t  count: number,\n73\t  asOf: string,\n74\t): PeekMetric {\n75\t  return {\n76\t    id: blueprint.id,\n77\t    label: blueprint.label,\n78\t    value: count,\n79\t    valueDisplay: formatCount(count),\n80\t    unit: blueprint.unit,\n81\t    source: blueprint.source,\n82\t    windowLabel: blueprint.windowLabel,\n83\t    asOf,\n84\t    definition: blueprint.definition,\n85\t    freshness: \"live\",\n86\t    drilldownHref: blueprint.drilldownHref,\n87\t  };\n88\t}\n89\t\n90\texport async function getCommandCenterAttention(\n91\t  options: CommandCenterOptions = {},\n92\t): Promise<PeekCommandCenterAttention> {\n93\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n94\t  const thresholds: CommandCenterThresholds = {\n95\t    ...COMMAND_CENTER_DEFAULTS,\n96\t    ...options.thresholds,\n97\t  };\n98\t  const now = options.now ?? new Date();\n99\t  const generatedAt = now.toISOString();\n100\t\n101\t  const stuckRoundsAgeInterval = `${thresholds.stuckRoundsAgeMinutes} minutes`;\n102\t  const stuckCloseCallAgeInterval = `${thresholds.stuckCloseCallAgeMinutes} minutes`;\n103\t  const exportWindowInterval = `${thresholds.exportWindowHours} hours`;\n104\t\n105\t  const [\n106\t    failedClaimsRows,\n107\t    deadQueueEventsRows,\n108\t    stuckRoundsRows,\n109\t    stuckCloseCallRows,\n110\t    pendingSolCrateRows,\n111\t    staleActiveDogpileRows,\n112\t    highValueExportsRows,\n113\t  ] = await Promise.all([\n114\t    sql<AttentionRow[]>`\n115\t      select count(*)::int as \"value\"\n116\t      from referral_claims\n117\t      where status in ('failed', 'error')\n118\t    `,\n119\t    sql<AttentionRow[]>`\n120\t      select count(*)::int as \"value\"\n121\t      from event_queue\n122\t      where status = 'dead'\n123\t    `,\n124\t    sql<AttentionRow[]>`\n125\t      select count(*)::int as \"value\"\n126\t      from rounds\n127\t      where phase in ('created', 'locked', 'settling')\n128\t        and (\n129\t          created_at < now() - ${stuckRoundsAgeInterval}::interval\n130\t          or settle_attempts > ${thresholds.stuckRoundsMaxSettleAttempts}\n131\t        )\n132\t    `,\n133\t    sql<AttentionRow[]>`\n134\t      select count(*)::int as \"value\"\n135\t      from closecall_rounds\n136\t      where phase = 'open'\n137\t        and created_at < now() - ${stuckCloseCallAgeInterval}::interval\n138\t    `,\n139\t    sql<AttentionRow[]>`\n140\t      select count(*)::int as \"value\"\n141\t      from crate_drops\n142\t      where crate_type = 'sol'\n143\t        and status = 'pending'\n144\t    `,\n145\t    sql<AttentionRow[]>`\n146\t      select count(*)::int as \"value\"\n147\t      from dogpile_events\n148\t      where status = 'active'\n149\t        and ends_at < now()\n150\t    `,\n151\t    sql<AttentionRow[]>`\n152\t      select count(*)::int as \"value\"\n153\t      from operator_events\n154\t      where event_type = 'peek.export'\n155\t        and created_at > now() - ${exportWindowInterval}::interval\n156\t        and coalesce((payload->>'resultCount')::int, 0)\n157\t            > ${thresholds.exportRowCountThreshold}\n158\t    `,\n159\t  ]);\n160\t\n161\t  const blueprints: ReadonlyArray<{\n162\t    blueprint: MetricBlueprint;\n163\t    rows: ReadonlyArray<AttentionRow>;\n164\t  }> = [\n165\t    {\n166\t      blueprint: {\n167\t        id: \"failed_claims\",\n168\t        label: \"Failed referral claims\",\n169\t        unit: \"claims\",\n170\t        source: \"referral_claims\",\n171\t        windowLabel: \"All time\",\n172\t        definition:\n173\t          \"Referral claims with status 'failed' or 'error' that have not been recovered.\",\n174\t        drilldownHref: \"/growth/referrals?claimStatus=failed\",\n175\t      },\n176\t      rows: failedClaimsRows,\n177\t    },\n178\t    {\n179\t      blueprint: {\n180\t        id: \"dead_queue_events\",\n181\t        label: \"Dead queue events\",\n182\t        unit: \"events\",\n183\t        source: \"event_queue\",\n184\t        windowLabel: \"All time\",\n185\t        definition:\n186\t          \"Event-queue rows in 'dead' status — past max attempts and not retried.\",\n187\t        drilldownHref: \"/operations/queue?status=dead\",\n188\t      },\n189\t      rows: deadQueueEventsRows,\n190\t    },\n191\t    {\n192\t      blueprint: {\n193\t        id: \"stuck_rounds_flipyou_potshot\",\n194\t        label: \"Stuck Flip You / Pot Shot rounds\",\n195\t        unit: \"rounds\",\n196\t        source: \"rounds\",\n197\t        windowLabel: `Older than ${thresholds.stuckRoundsAgeMinutes}m or settle_attempts > ${thresholds.stuckRoundsMaxSettleAttempts}`,\n198\t        definition:\n199\t          \"Rounds in nonterminal phases (created/locked/settling) past the age threshold or with elevated settle attempts.\",\n200\t        drilldownHref: \"/games?stuck=true\",\n201\t      },\n202\t      rows: stuckRoundsRows,\n203\t    },\n204\t    {\n205\t      blueprint: {\n206\t        id: \"stuck_rounds_closecall\",\n207\t        label: \"Stuck Close Call rounds\",\n208\t        unit: \"rounds\",\n209\t        source: \"closecall_rounds\",\n210\t        windowLabel: `Open phase older than ${thresholds.stuckCloseCallAgeMinutes}m`,\n211\t        definition:\n212\t          \"Close Call rounds still in 'open' phase past the age threshold; rounds settle on minute boundaries via Pyth.\",\n213\t        drilldownHref: \"/games/closecall?stuck=true\",\n214\t      },\n215\t      rows: stuckCloseCallRows,\n216\t    },\n217\t    {\n218\t      blueprint: {\n219\t        id: \"pending_sol_crate_payouts\",\n220\t        label: \"Pending SOL crate payouts\",\n221\t        unit: \"crates\",\n222\t        source: \"crate_drops\",\n223\t        windowLabel: \"All time\",\n224\t        definition:\n225\t          \"SOL-denominated crate drops in 'pending' status — payout has not been delivered on-chain.\",\n226\t        drilldownHref: \"/economy/rewards?crateType=sol&status=pending\",\n227\t      },\n228\t      rows: pendingSolCrateRows,\n229\t    },\n230\t    {\n231\t      blueprint: {\n232\t        id: \"stale_active_dogpile_events\",\n233\t        label: \"Stale active Dogpile events\",\n234\t        unit: \"events\",\n235\t        source: \"dogpile_events\",\n236\t        windowLabel: \"Active past end time\",\n237\t        definition:\n238\t          \"Dogpile events still in 'active' status whose ends_at has already passed; they should have transitioned to 'ended'.\",\n239\t        drilldownHref: \"/operations/dogpile?status=active\",\n240\t      },\n241\t      rows: staleActiveDogpileRows,\n242\t    },\n243\t    {\n244\t      blueprint: {\n245\t        id: \"high_value_exports_24h\",\n246\t        label: \"High-value exports (24h)\",\n247\t        unit: \"exports\",\n248\t        source: \"operator_events\",\n249\t        windowLabel: `Last ${thresholds.exportWindowHours}h`,\n250\t        definition: `peek.export operator events in the last ${thresholds.exportWindowHours}h whose resultCount exceeds ${thresholds.exportRowCountThreshold} rows.`,\n251\t        drilldownHref: \"/audit?eventType=peek.export\",\n252\t      },\n253\t      rows: highValueExportsRows,\n254\t    },\n255\t  ];\n256\t\n257\t  const metrics: PeekMetric[] = blueprints.map(({ blueprint, rows }) =>\n258\t    makeMetric(blueprint, readCount(rows), generatedAt),\n259\t  );\n260\t\n261\t  return {\n262\t    generatedAt,\n263\t    metrics,\n264\t  };\n265\t}\n266\t"}]},"parent_tool_use_id":null,"session_id":"19c9a51e-3972-4bff-bc15-86d90691364e","uuid":"f1907427-7b6b-4cf9-950d-4c1e98c4b610","timestamp":"2026-04-25T11:25:09.709Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-command-center-attention.ts","content":"// Command-center attention queue query (FR-3, FR-10).\n//\n// Returns a small set of bounded \"needs attention\" metrics that the command\n// center renders at the top of `/`. Each metric carries the FR-4 bookkeeping\n// (id, label, value, source table, time window, \"as of\", definition,\n// freshness, drill-down href) so the metric-strip primitive can render it\n// without per-page hardcoding.\n//\n// Bounded queries: every query returns a single integer count. No row-level\n// data crosses the wire here; per-feature pages provide the row drill-downs.\n\nimport type {\n  PeekCommandCenterAttention,\n  PeekCommandCenterAttentionId,\n  PeekMetric,\n} from \"../../../lib/types/peek\";\nimport type { Sql } from \"postgres\";\nimport { getSqlClient } from \"../client\";\n\n// Thresholds — tuned for an operator console, not a fairness oracle. Tests can\n// override via the `options` argument so age/limit assertions stay\n// deterministic.\nexport const COMMAND_CENTER_DEFAULTS = {\n  stuckRoundsAgeMinutes: 5,\n  stuckRoundsMaxSettleAttempts: 3,\n  stuckCloseCallAgeMinutes: 5,\n  exportWindowHours: 24,\n  exportRowCountThreshold: 1000,\n} as const;\n\nexport type CommandCenterThresholds = typeof COMMAND_CENTER_DEFAULTS;\n\nexport type CommandCenterOptions = {\n  sql?: Sql;\n  thresholds?: Partial<CommandCenterThresholds>;\n  now?: Date;\n};\n\ntype AttentionRow = { value: number };\n\nfunction readCount(rows: ReadonlyArray<AttentionRow> | undefined): number {\n  if (!rows || rows.length === 0) {\n    return 0;\n  }\n  const raw = rows[0]?.value;\n  if (typeof raw === \"number\" && Number.isFinite(raw)) {\n    return raw;\n  }\n  if (typeof raw === \"string\") {\n    const parsed = Number.parseInt(raw, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\ntype MetricBlueprint = {\n  id: PeekCommandCenterAttentionId;\n  label: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  definition: string;\n  drilldownHref: string | null;\n};\n\nfunction makeMetric(\n  blueprint: MetricBlueprint,\n  count: number,\n  asOf: string,\n): PeekMetric {\n  return {\n    id: blueprint.id,\n    label: blueprint.label,\n    value: count,\n    valueDisplay: formatCount(count),\n    unit: blueprint.unit,\n    source: blueprint.source,\n    windowLabel: blueprint.windowLabel,\n    asOf,\n    definition: blueprint.definition,\n    freshness: \"live\",\n    drilldownHref: blueprint.drilldownHref,\n  };\n}\n\nexport async function getCommandCenterAttention(\n  options: CommandCenterOptions = {},\n): Promise<PeekCommandCenterAttention> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const thresholds: CommandCenterThresholds = {\n    ...COMMAND_CENTER_DEFAULTS,\n    ...options.thresholds,\n  };\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n\n  const stuckRoundsAgeInterval = `${thresholds.stuckRoundsAgeMinutes} minutes`;\n  const stuckCloseCallAgeInterval = `${thresholds.stuckCloseCallAgeMinutes} minutes`;\n  const exportWindowInterval = `${thresholds.exportWindowHours} hours`;\n\n  const [\n    failedClaimsRows,\n    deadQueueEventsRows,\n    stuckRoundsRows,\n    stuckCloseCallRows,\n    pendingSolCrateRows,\n    staleActiveDogpileRows,\n    highValueExportsRows,\n  ] = await Promise.all([\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from referral_claims\n      where status in ('failed', 'error')\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from event_queue\n      where status = 'dead'\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from rounds\n      where phase in ('created', 'locked', 'settling')\n        and (\n          created_at < now() - ${stuckRoundsAgeInterval}::interval\n          or settle_attempts > ${thresholds.stuckRoundsMaxSettleAttempts}\n        )\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from closecall_rounds\n      where phase = 'open'\n        and created_at < now() - ${stuckCloseCallAgeInterval}::interval\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from crate_drops\n      where crate_type = 'sol'\n        and status = 'pending'\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from dogpile_events\n      where status = 'active'\n        and ends_at < now()\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from operator_events\n      where event_type = 'peek.export'\n        and created_at > now() - ${exportWindowInterval}::interval\n        and coalesce((payload->>'resultCount')::int, 0)\n            > ${thresholds.exportRowCountThreshold}\n    `,\n  ]);\n\n  const blueprints: ReadonlyArray<{\n    blueprint: MetricBlueprint;\n    rows: ReadonlyArray<AttentionRow>;\n  }> = [\n    {\n      blueprint: {\n        id: \"failed_claims\",\n        label: \"Failed referral claims\",\n        unit: \"claims\",\n        source: \"referral_claims\",\n        windowLabel: \"All time\",\n        definition:\n          \"Referral claims with status 'failed' or 'error' that have not been recovered.\",\n        drilldownHref: \"/growth/referrals?claimStatus=failed\",\n      },\n      rows: failedClaimsRows,\n    },\n    {\n      blueprint: {\n        id: \"dead_queue_events\",\n        label: \"Dead queue events\",\n        unit: \"events\",\n        source: \"event_queue\",\n        windowLabel: \"All time\",\n        definition:\n          \"Event-queue rows in 'dead' status — past max attempts and not retried.\",\n        drilldownHref: \"/operations/queue?status=dead\",\n      },\n      rows: deadQueueEventsRows,\n    },\n    {\n      blueprint: {\n        id: \"stuck_rounds_flipyou_potshot\",\n        label: \"Stuck Flip You / Pot Shot rounds\",\n        unit: \"rounds\",\n        source: \"rounds\",\n        windowLabel: `Older than ${thresholds.stuckRoundsAgeMinutes}m or settle_attempts > ${thresholds.stuckRoundsMaxSettleAttempts}`,\n        definition:\n          \"Rounds in nonterminal phases (created/locked/settling) past the age threshold or with elevated settle attempts.\",\n        drilldownHref: \"/games?stuck=true\",\n      },\n      rows: stuckRoundsRows,\n    },\n    {\n      blueprint: {\n        id: \"stuck_rounds_closecall\",\n        label: \"Stuck Close Call rounds\",\n        unit: \"rounds\",\n        source: \"closecall_rounds\",\n        windowLabel: `Open phase older than ${thresholds.stuckCloseCallAgeMinutes}m`,\n        definition:\n          \"Close Call rounds still in 'open' phase past the age threshold; rounds settle on minute boundaries via Pyth.\",\n        drilldownHref: \"/games/closecall?stuck=true\",\n      },\n      rows: stuckCloseCallRows,\n    },\n    {\n      blueprint: {\n        id: \"pending_sol_crate_payouts\",\n        label: \"Pending SOL crate payouts\",\n        unit: \"crates\",\n        source: \"crate_drops\",\n        windowLabel: \"All time\",\n        definition:\n          \"SOL-denominated crate drops in 'pending' status — payout has not been delivered on-chain.\",\n        drilldownHref: \"/economy/rewards?crateType=sol&status=pending\",\n      },\n      rows: pendingSolCrateRows,\n    },\n    {\n      blueprint: {\n        id: \"stale_active_dogpile_events\",\n        label: \"Stale active Dogpile events\",\n        unit: \"events\",\n        source: \"dogpile_events\",\n        windowLabel: \"Active past end time\",\n        definition:\n          \"Dogpile events still in 'active' status whose ends_at has already passed; they should have transitioned to 'ended'.\",\n        drilldownHref: \"/operations/dogpile?status=active\",\n      },\n      rows: staleActiveDogpileRows,\n    },\n    {\n      blueprint: {\n        id: \"high_value_exports_24h\",\n        label: \"High-value exports (24h)\",\n        unit: \"exports\",\n        source: \"operator_events\",\n        windowLabel: `Last ${thresholds.exportWindowHours}h`,\n        definition: `peek.export operator events in the last ${thresholds.exportWindowHours}h whose resultCount exceeds ${thresholds.exportRowCountThreshold} rows.`,\n        drilldownHref: \"/audit?eventType=peek.export\",\n      },\n      rows: highValueExportsRows,\n    },\n  ];\n\n  const metrics: PeekMetric[] = blueprints.map(({ blueprint, rows }) =>\n    makeMetric(blueprint, readCount(rows), generatedAt),\n  );\n\n  return {\n    generatedAt,\n    metrics,\n  };\n}\n","numLines":266,"startLine":1,"totalLines":266}}}
