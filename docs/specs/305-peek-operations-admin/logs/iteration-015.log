{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01Rtq4kYgr7Lv4U6eshzf7Zy","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01CuG6WC85kLHPG97Ti8cfpu","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/__tests__/recent-activity-list.test.tsx","content":"import { describe, expect, it } from \"vitest\";\nimport { render, screen, within } from \"@testing-library/react\";\nimport { RecentActivityList } from \"../recent-activity-list\";\nimport type { PeekRecentActivityItem } from \"../../lib/types/peek\";\n\nconst populated: ReadonlyArray<PeekRecentActivityItem> = [\n  {\n    id: \"1\",\n    eventType: \"peek.user.view_sensitive\",\n    actorEmail: \"alice@example.com\",\n    resourceType: \"user\",\n    resourceId: \"u-1\",\n    route: \"/users/u-1\",\n    createdAt: \"2026-04-25T10:00:00.000Z\",\n  },\n  {\n    id: \"2\",\n    eventType: \"peek.export\",\n    actorEmail: \"biz@example.com\",\n    resourceType: \"export\",\n    resourceId: null,\n    route: \"/growth/referrals/export\",\n    createdAt: \"2026-04-25T10:05:00.000Z\",\n  },\n];\n\nconst sparseItem: PeekRecentActivityItem = {\n  id: \"3\",\n  eventType: \"peek.access.denied\",\n  actorEmail: null,\n  resourceType: null,\n  resourceId: null,\n  route: null,\n  createdAt: \"2026-04-25T10:10:00.000Z\",\n};\n\ndescribe(\"RecentActivityList\", () => {\n  it(\"populated: renders one row per item with time, event type, actor, route link, and resource label\", () => {\n    render(<RecentActivityList items={populated} error={null} />);\n\n    const list = screen.getByRole(\"list\", { name: \"Recent operator activity\" });\n    const items = within(list).getAllByRole(\"listitem\");\n    expect(items).toHaveLength(2);\n\n    const first = items[0];\n    expect(first).toHaveTextContent(\"2026-04-25T10:00:00.000Z\");\n    expect(first).toHaveTextContent(\"peek.user.view_sensitive\");\n    expect(first).toHaveTextContent(\"alice@example.com\");\n    expect(within(first).getByRole(\"link\", { name: \"/users/u-1\" })).toHaveAttribute(\n      \"href\",\n      \"/users/u-1\",\n    );\n    expect(first).toHaveTextContent(\"user:u-1\");\n\n    const second = items[1];\n    expect(second).toHaveTextContent(\"peek.export\");\n    expect(within(second).getByRole(\"link\", { name: \"/growth/referrals/export\" })).toHaveAttribute(\n      \"href\",\n      \"/growth/referrals/export\",\n    );\n    expect(second).toHaveTextContent(\"export\");\n    expect(within(second).queryByText(/user:/)).toBeNull();\n  });\n\n  it(\"sparse: missing actor renders an em-dash, missing route renders no link, missing resource renders no label\", () => {\n    render(<RecentActivityList items={[sparseItem]} error={null} />);\n\n    const list = screen.getByRole(\"list\", { name: \"Recent operator activity\" });\n    const item = within(list).getAllByRole(\"listitem\")[0];\n    expect(item).toHaveTextContent(\"peek.access.denied\");\n    expect(item).toHaveTextContent(\"—\");\n    expect(within(item).queryByRole(\"link\")).toBeNull();\n  });\n\n  it(\"empty: renders the operator empty status when items is empty\", () => {\n    render(<RecentActivityList items={[]} error={null} />);\n\n    expect(screen.getByRole(\"status\")).toHaveTextContent(\n      \"No recent operator activity recorded yet.\",\n    );\n    expect(screen.queryByRole(\"list\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and suppresses both the list and the empty state\", () => {\n    render(<RecentActivityList items={populated} error=\"query timeout\" />);\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Recent activity unavailable: query timeout\",\n    );\n    expect(screen.queryByRole(\"list\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1101,"cache_read_input_tokens":112776,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1101},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"19c9a51e-3972-4bff-bc15-86d90691364e","uuid":"00cdf646-4aae-4b79-93b6-c2d4367053b2"}
