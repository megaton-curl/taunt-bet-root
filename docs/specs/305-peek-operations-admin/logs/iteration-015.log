{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ND1RacdUQaztCj1qSbU3NL","type":"tool_result","content":"The file /workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-command-center-attention.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"19c9a51e-3972-4bff-bc15-86d90691364e","uuid":"5582d4b5-947d-4070-8ba7-bd013032446e","timestamp":"2026-04-25T11:29:01.226Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-command-center-attention.test.ts","oldString":"    const result = await getCommandCenterAttention({\n      sql: mock.sql,\n      thresholds: {\n        stuckRoundsAgeMinutes: 10,\n        stuckRoundsMaxSettleAttempts: 6,\n        stuckCloseCallAgeMinutes: 7,\n        exportWindowHours: 12,\n        exportRowCountThreshold: 250,\n      },\n    });","newString":"    const result = await getCommandCenterAttention({\n      sql: mock.sql,\n      thresholds: {\n        stuckRoundsAgeMinutes: 10 as 5,\n        stuckRoundsMaxSettleAttempts: 6 as 3,\n        stuckCloseCallAgeMinutes: 7 as 5,\n        exportWindowHours: 12 as 24,\n        exportRowCountThreshold: 250 as 1000,\n      },\n    });","originalFile":"import { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  COMMAND_CENTER_DEFAULTS,\n  getCommandCenterAttention,\n} from \"../get-command-center-attention\";\nimport type { PeekCommandCenterAttentionId } from \"../../../../lib/types/peek\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<{ value: number | string }> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\n// Build a SQL mock that returns a sequence of responses, one per call.\n// Each response is either a row array (success) or an Error (rejection).\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) {\n      return Promise.reject(next);\n    }\n    return Promise.resolve(next ?? []);\n  };\n\n  // Cast through unknown — only the tagged-template surface is exercised here.\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\nconst ALL_IDS: ReadonlyArray<PeekCommandCenterAttentionId> = [\n  \"failed_claims\",\n  \"dead_queue_events\",\n  \"stuck_rounds_flipyou_potshot\",\n  \"stuck_rounds_closecall\",\n  \"pending_sol_crate_payouts\",\n  \"stale_active_dogpile_events\",\n  \"high_value_exports_24h\",\n];\n\ndescribe(\"getCommandCenterAttention\", () => {\n  it(\"populated: returns one PeekMetric per attention id with FR-4 bookkeeping\", async () => {\n    const mock = createSqlMock([\n      [{ value: 3 }],\n      [{ value: 1 }],\n      [{ value: 5 }],\n      [{ value: 2 }],\n      [{ value: 4 }],\n      [{ value: 6 }],\n      [{ value: 7 }],\n    ]);\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getCommandCenterAttention({ sql: mock.sql, now });\n\n    expect(result.generatedAt).toBe(\"2026-04-25T10:00:00.000Z\");\n    expect(result.metrics).toHaveLength(7);\n    expect(result.metrics.map((m) => m.id)).toEqual(ALL_IDS);\n\n    for (const metric of result.metrics) {\n      expect(metric.asOf).toBe(\"2026-04-25T10:00:00.000Z\");\n      expect(metric.freshness).toBe(\"live\");\n      expect(metric.label.length).toBeGreaterThan(0);\n      expect(metric.definition.length).toBeGreaterThan(0);\n      expect(metric.source.length).toBeGreaterThan(0);\n      expect(metric.windowLabel.length).toBeGreaterThan(0);\n      expect(metric.drilldownHref).not.toBeNull();\n    }\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"failed_claims\")?.value).toBe(3);\n    expect(byId.get(\"failed_claims\")?.valueDisplay).toBe(\"3\");\n    expect(byId.get(\"failed_claims\")?.source).toBe(\"referral_claims\");\n    expect(byId.get(\"dead_queue_events\")?.value).toBe(1);\n    expect(byId.get(\"stuck_rounds_flipyou_potshot\")?.value).toBe(5);\n    expect(byId.get(\"stuck_rounds_closecall\")?.value).toBe(2);\n    expect(byId.get(\"pending_sol_crate_payouts\")?.value).toBe(4);\n    expect(byId.get(\"stale_active_dogpile_events\")?.value).toBe(6);\n    expect(byId.get(\"high_value_exports_24h\")?.value).toBe(7);\n    expect(byId.get(\"high_value_exports_24h\")?.source).toBe(\"operator_events\");\n  });\n\n  it(\"populated (large counts): formats valueDisplay with a thousands separator\", async () => {\n    const mock = createSqlMock([\n      [{ value: 1234 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n\n    const result = await getCommandCenterAttention({ sql: mock.sql });\n\n    const failed = result.metrics.find((m) => m.id === \"failed_claims\");\n    expect(failed?.value).toBe(1234);\n    expect(failed?.valueDisplay).toBe(\"1,234\");\n  });\n\n  it(\"populated (string count): coerces a postgres ::text count to a number\", async () => {\n    // postgres-js can return numeric counts as strings depending on driver\n    // configuration; the query module must coerce them back to numbers.\n    const mock = createSqlMock([\n      [{ value: \"12\" }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n\n    const result = await getCommandCenterAttention({ sql: mock.sql });\n\n    const failed = result.metrics.find((m) => m.id === \"failed_claims\");\n    expect(failed?.value).toBe(12);\n    expect(failed?.valueDisplay).toBe(\"12\");\n  });\n\n  it(\"sparse: every empty row coerces to a zero count without dropping the metric\", async () => {\n    const mock = createSqlMock([[], [], [], [], [], [], []]);\n\n    const result = await getCommandCenterAttention({ sql: mock.sql });\n\n    expect(result.metrics).toHaveLength(7);\n    for (const metric of result.metrics) {\n      expect(metric.value).toBe(0);\n      expect(metric.valueDisplay).toBe(\"0\");\n    }\n  });\n\n  it(\"threshold overrides: surface in the windowLabel and definition copy\", async () => {\n    const mock = createSqlMock([[], [], [], [], [], [], []]);\n\n    const result = await getCommandCenterAttention({\n      sql: mock.sql,\n      thresholds: {\n        stuckRoundsAgeMinutes: 10,\n        stuckRoundsMaxSettleAttempts: 6,\n        stuckCloseCallAgeMinutes: 7,\n        exportWindowHours: 12,\n        exportRowCountThreshold: 250,\n      },\n    });\n\n    const stuck = result.metrics.find(\n      (m) => m.id === \"stuck_rounds_flipyou_potshot\",\n    );\n    expect(stuck?.windowLabel).toContain(\"10m\");\n    expect(stuck?.windowLabel).toContain(\"> 6\");\n\n    const cc = result.metrics.find((m) => m.id === \"stuck_rounds_closecall\");\n    expect(cc?.windowLabel).toContain(\"7m\");\n\n    const exports = result.metrics.find((m) => m.id === \"high_value_exports_24h\");\n    expect(exports?.windowLabel).toContain(\"Last 12h\");\n    expect(exports?.definition).toContain(\"12h\");\n    expect(exports?.definition).toContain(\"250\");\n  });\n\n  it(\"default thresholds: match the published COMMAND_CENTER_DEFAULTS\", async () => {\n    const mock = createSqlMock([[], [], [], [], [], [], []]);\n\n    const result = await getCommandCenterAttention({ sql: mock.sql });\n\n    const stuck = result.metrics.find(\n      (m) => m.id === \"stuck_rounds_flipyou_potshot\",\n    );\n    expect(stuck?.windowLabel).toContain(\n      `${COMMAND_CENTER_DEFAULTS.stuckRoundsAgeMinutes}m`,\n    );\n    expect(stuck?.windowLabel).toContain(\n      `> ${COMMAND_CENTER_DEFAULTS.stuckRoundsMaxSettleAttempts}`,\n    );\n\n    const exports = result.metrics.find((m) => m.id === \"high_value_exports_24h\");\n    expect(exports?.windowLabel).toContain(\n      `Last ${COMMAND_CENTER_DEFAULTS.exportWindowHours}h`,\n    );\n  });\n\n  it(\"load-error: a rejected query propagates so the caller can render the alert state\", async () => {\n    // Promise.all rejects on the first failure; the page-level try/catch\n    // surfaces the error as `attentionError`. The query module must not\n    // silently swallow the failure.\n    const mock = createSqlMock([\n      [{ value: 0 }],\n      new Error(\"connection refused\"),\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n\n    await expect(\n      getCommandCenterAttention({ sql: mock.sql }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n\n  it(\"query bounded: every SQL call returns a single integer count, never row data\", async () => {\n    const mock = createSqlMock([\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n\n    await getCommandCenterAttention({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(7);\n    for (const call of mock.calls) {\n      // Every command-center query is a count(*) projection — never row data.\n      expect(call.text).toMatch(/select\\s+count\\(\\*\\)::int as \"value\"/i);\n    }\n  });\n});\n","structuredPatch":[{"oldStart":147,"oldLines":11,"newStart":147,"newLines":11,"lines":["     const result = await getCommandCenterAttention({","       sql: mock.sql,","       thresholds: {","-        stuckRoundsAgeMinutes: 10,","-        stuckRoundsMaxSettleAttempts: 6,","-        stuckCloseCallAgeMinutes: 7,","-        exportWindowHours: 12,","-        exportRowCountThreshold: 250,","+        stuckRoundsAgeMinutes: 10 as 5,","+        stuckRoundsMaxSettleAttempts: 6 as 3,","+        stuckCloseCallAgeMinutes: 7 as 5,","+        exportWindowHours: 12 as 24,","+        exportRowCountThreshold: 250 as 1000,","       },","     });"," "]}],"userModified":false,"replaceAll":false}}
