{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013cd2yMs7eA8ot111fA4DZU","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport { normalizePeekSearchParams } from \"../../../../lib/search-params\";\n3\t\n4\tdescribe(\"normalizePeekSearchParams\", () => {\n5\t  it(\"defaults sort and page size for the users-first screen\", () => {\n6\t    expect(normalizePeekSearchParams({})).toEqual({\n7\t      query: \"\",\n8\t      sort: \"joinedAt\",\n9\t      direction: \"desc\",\n10\t      page: 1,\n11\t      pageSize: 50,\n12\t      filters: {\n13\t        hasReferrer: false,\n14\t        hasReferees: false,\n15\t        hasCode: false,\n16\t        hasTelegram: false,\n17\t      },\n18\t    });\n19\t  });\n20\t\n21\t  it(\"clamps invalid page values back to the first page\", () => {\n22\t    expect(normalizePeekSearchParams({ page: \"0\" }).page).toBe(1);\n23\t    expect(normalizePeekSearchParams({ page: \"-3\" }).page).toBe(1);\n24\t    expect(normalizePeekSearchParams({ page: \"abc\" }).page).toBe(1);\n25\t    expect(normalizePeekSearchParams({ page: \"4\" }).page).toBe(4);\n26\t  });\n27\t\n28\t  it(\"parses the telegram checkbox as a boolean filter\", () => {\n29\t    expect(normalizePeekSearchParams({ hasTelegram: \"true\" }).filters.hasTelegram).toBe(true);\n30\t    expect(normalizePeekSearchParams({ hasTelegram: \"false\" }).filters.hasTelegram).toBe(false);\n31\t    expect(normalizePeekSearchParams({}).filters.hasTelegram).toBe(false);\n32\t  });\n33\t});\n34\t"}]},"parent_tool_use_id":null,"session_id":"19c9a51e-3972-4bff-bc15-86d90691364e","uuid":"ec44c383-518f-42a9-974e-2f68714a95a3","timestamp":"2026-04-25T11:25:29.223Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/list-peek-users.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport { normalizePeekSearchParams } from \"../../../../lib/search-params\";\n\ndescribe(\"normalizePeekSearchParams\", () => {\n  it(\"defaults sort and page size for the users-first screen\", () => {\n    expect(normalizePeekSearchParams({})).toEqual({\n      query: \"\",\n      sort: \"joinedAt\",\n      direction: \"desc\",\n      page: 1,\n      pageSize: 50,\n      filters: {\n        hasReferrer: false,\n        hasReferees: false,\n        hasCode: false,\n        hasTelegram: false,\n      },\n    });\n  });\n\n  it(\"clamps invalid page values back to the first page\", () => {\n    expect(normalizePeekSearchParams({ page: \"0\" }).page).toBe(1);\n    expect(normalizePeekSearchParams({ page: \"-3\" }).page).toBe(1);\n    expect(normalizePeekSearchParams({ page: \"abc\" }).page).toBe(1);\n    expect(normalizePeekSearchParams({ page: \"4\" }).page).toBe(4);\n  });\n\n  it(\"parses the telegram checkbox as a boolean filter\", () => {\n    expect(normalizePeekSearchParams({ hasTelegram: \"true\" }).filters.hasTelegram).toBe(true);\n    expect(normalizePeekSearchParams({ hasTelegram: \"false\" }).filters.hasTelegram).toBe(false);\n    expect(normalizePeekSearchParams({}).filters.hasTelegram).toBe(false);\n  });\n});\n","numLines":34,"startLine":1,"totalLines":34}}}
