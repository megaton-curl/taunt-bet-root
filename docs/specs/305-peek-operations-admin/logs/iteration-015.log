l = null;\n42\t  let attentionError: string | null = null;\n43\t  let activityError: string | null = null;\n44\t  let params = initialParams;\n45\t\n46\t  try {\n47\t    [summary, totalCount] = await Promise.all([\n48\t      getPeekSummary(),\n49\t      countPeekUsers(initialParams),\n50\t    ]);\n51\t\n52\t    if (totalCount > 0) {\n53\t      const totalPages = Math.max(1, Math.ceil(totalCount / initialParams.pageSize));\n54\t      params = {\n55\t        ...initialParams,\n56\t        page: Math.min(initialParams.page, totalPages),\n57\t      };\n58\t    }\n59\t\n60\t    users = await listPeekUsers(params);\n61\t  } catch (error) {\n62\t    loadError =\n63\t      error instanceof Error\n64\t        ? error.message\n65\t        : \"Peek could not load data from the database.\";\n66\t  }\n67\t\n68\t  try {\n69\t    attention = await getCommandCenterAttention();\n70\t  } catch (error) {\n71\t    attentionError =\n72\t      error instanceof Error\n73\t        ? error.message\n74\t        : \"Attention queue could not be loaded.\";\n75\t  }\n76\t\n77\t  try {\n78\t    recentActivity = await getRecentOperatorEvents();\n79\t  } catch (error) {\n80\t    activityError =\n81\t      error instanceof Error\n82\t        ? error.message\n83\t        : \"Recent activity could not be loaded.\";\n84\t  }\n85\t\n86\t  return (\n87\t    <main style={{ display: \"grid\", gap: \"1.5rem\" }}>\n88\t      <header>\n89\t        <h1>Command center</h1>\n90\t        <p style={{ margin: \"0.25rem 0 0\", color: \"#94a3b8\" }}>\n91\t          Search, attention queue, platform summary, recent activity, and users.\n92\t        </p>\n93\t      </header>\n94\t\n95\t      <section aria-labelledby=\"global-search-heading\">\n96\t        <h2 id=\"global-search-heading\" style={sectionHeadingStyle}>\n97\t          Global search\n98\t        </h2>\n99\t        <form\n100\t          action=\"/\""}]},"parent_tool_use_id":null,"session_id":"19c9a51e-3972-4bff-bc15-86d90691364e","uuid":"7c56e1e6-829a-484f-