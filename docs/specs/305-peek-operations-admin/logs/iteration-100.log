count(*)::int as \"value\"\n      from event_queue eq\n      where eq.created_at <= ${boundary.olderThanIso}::timestamptz\n        and (${youngerOpen} or eq.created_at > ${youngerThan ?? \"\"}::timestamptz)\n    `;\n  });\n\n  const [\n    statusRows,\n    typeRows,\n    atMaxAttemptsRows,\n    agedPendingRows,\n    ...ageBucketResponses\n  ] = await Promise.all([\n    sql<Array<{ status: string; value: number | string }>>`\n      select eq.status as \"status\", count(*)::int as \"value\"\n      from event_queue eq\n      group by eq.status\n    `,\n    sql<Array<{ eventType: string; value: number | string }>>`\n      select eq.event_type as \"eventType\", count(*)::int as \"value\"\n      from event_queue eq\n      group by eq.event_type\n      order by count(*) desc, eq.event_type asc\n      limit ${typeCountLimit}\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from event_queue eq\n      where eq.status in ('pending', 'processing', 'failed', 'dead')\n        and eq.attempts >= eq.max_attempts\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from event_queue eq\n      where eq.status = 'pending'\n        and eq.created_at <= ${agedPendingThresholdIso}::timestamptz\n    `,\n    ...ageBucketQueries,\n  ]);"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":8435,"cache_read_input_tokens":131985,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":8435},"output_tokens":54,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"6775cf18-4dba-4172-859b-2630d02f912a","uuid":"9e8c30a6-cca0-4786-9616-e291e5b04535"}
