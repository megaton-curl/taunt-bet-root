{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01161GediTg88XSxMcNjqiFm","type":"tool_result","content":"1\t// Query tests for the FR-9 reward-economy admin reads (`get-rewards.ts`).\n2\t//\n3\t// Mirrors the SQL-mock pattern used in `get-growth-referrals.test.ts` and\n4\t// `get-command-center-attention.test.ts`: a tagged-template stub records each\n5\t// call (joined SQL text + bound values) and dequeues a per-call response so\n6\t// each test can assert which SQL fired, in what order, and with which clamps.\n7\t\n8\timport { describe, expect, it } from \"vitest\";\n9\timport type { Sql } from \"postgres\";\n10\timport {\n11\t  PEEK_REWARDS_RECENT_FUNDINGS_WINDOW_HOURS,\n12\t  PEEK_REWARD_CONFIG_KEY_REGISTRY,\n13\t  PEEK_REWARD_POOL_FUNDINGS_DEFAULT_LIMIT,\n14\t  PEEK_REWARD_POOL_FUNDINGS_MAX_LIMIT,\n15\t  getRewardPool,\n16\t  getRewardsOverview,\n17\t  listRewardConfig,\n18\t  listRewardPoolFundings,\n19\t} from \"../get-rewards\";\n20\timport {\n21\t  PEEK_REWARDS_OVERVIEW_METRIC_IDS,\n22\t  type PeekRewardsOverviewMetricId,\n23\t} from \"../../../../lib/types/peek\";\n24\t\n25\ttype SqlCall = {\n26\t  text: string;\n27\t  values: ReadonlyArray<unknown>;\n28\t};\n29\t\n30\ttype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n31\t\n32\ttype SqlMock = {\n33\t  sql: Sql;\n34\t  calls: ReadonlyArray<SqlCall>;\n35\t};\n36\t\n37\tfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n38\t  const calls: SqlCall[] = [];\n39\t  let cursor = 0;\n40\t\n41\t  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n42\t    const text = [...strings].join(\"?\");\n43\t    calls.push({ text, values: [...values] });\n44\t    const next = responses[cursor++];\n45\t    if (next instanceof Error) return Promise.reject(next);\n46\t    return Promise.resolve(next ?? []);\n47\t  };\n48\t\n49\t  const sql = fn as unknown as Sql;\n50\t  return { sql, calls };\n51\t}\n52\t\n53\t// `getRewardsOverview` runs two queries in parallel via Promise.all:\n54\t// 0 = reward_pool singleton read, 1 = recent fundings count.\n55\tconst OVERVIEW_ORDER: ReadonlyArray<PeekRewardsOverviewMetricId> = [\n56\t  \"rewards.balance_lamports\",\n57\t  \"rewards.lifetime_funded_lamports\",\n58\t  \"rewards.lifetime_paid_lamports\",\n59\t  \"rewards.recent_fundings\",\n60\t];\n61\t\n62\tdescribe(\"listRewardConfig\", () => {\n63\t  it(\"populated: annotates known keys with definition + expected type from the registry\", async () => {\n64\t    const mock = createSqlMock([\n65\t      [\n66\t        {\n67\t          key: \"points_per_dollar\",\n68\t          value: \"10\",\n69\t          updatedAt: \"2026-04-20T00:00:00.000Z\",\n70\t        },\n71\t        {\n72\t          key: \"reward_pool_fee_share\",\n73\t          value: \"0.25\",\n74\t          updatedAt: \"2026-04-21T00:00:00.000Z\",\n75\t        },\n76\t      ],\n77\t    ]);\n78\t\n79\t    const rows = await listRewardConfig({ sql: mock.sql });\n80\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_011XHou3pWm96eV1HWw8J3vA","session_id":"6775cf18-4dba-4172-859b-2630d02f912a","uuid":"2b4b6ff1-3a42-42e6-ad7c-714843ca0f5f","timestamp":"2026-04-26T06:43:48.122Z"}
