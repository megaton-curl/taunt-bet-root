{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015jDzPhUXAkokpMsEHPmaq6","type":"tool_result","content":"1\t// Secret-redaction helpers for the peek audit writer (FR-11).\n2\t//\n3\t// Audit payloads must never persist JWTs, access tokens, DB connection URLs,\n4\t// private keys, or other raw secrets. The writer always passes the caller's\n5\t// payload through `redactPayload` before insertion; if a value matches a known\n6\t// secret pattern it is replaced with the `PEEK_AUDIT_REDACTED` sentinel. The\n7\t// audit-view UI renders that sentinel verbatim so reviewers see that a field\n8\t// was redacted rather than silently absent.\n9\t\n10\timport {\n11\t  PEEK_AUDIT_REDACTED,\n12\t  type PeekAuditChange,\n13\t  type PeekAuditPayload,\n14\t  type PeekAuditScalar,\n15\t} from \"../../lib/types/peek\";\n16\t\n17\tconst JWT_PATTERN = /\\beyJ[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\b/;\n18\tconst DB_URL_PATTERN =\n19\t  /\\b(?:postgres(?:ql)?|mysql|mongodb(?:\\+srv)?|redis|amqps?)(?:\\+[a-z0-9]+)?:\\/\\/[^\\s]+/i;\n20\tconst PRIVATE_KEY_PATTERN = /-----BEGIN [A-Z0-9 ]*PRIVATE KEY-----/;\n21\tconst BEARER_PATTERN = /\\bBearer\\s+[A-Za-z0-9._~+/=-]{8,}/i;\n22\tconst CF_ACCESS_HEADER_PATTERN = /\\bcf-access-jwt-assertion\\s*[:=]/i;\n23\t\n24\texport function looksLikeSecret(value: string): boolean {\n25\t  if (!value) return false;\n26\t  return (\n27\t    JWT_PATTERN.test(value) ||\n28\t    DB_URL_PATTERN.test(value) ||\n29\t    PRIVATE_KEY_PATTERN.test(value) ||\n30\t    BEARER_PATTERN.test(value) ||\n31\t    CF_ACCESS_HEADER_PATTERN.test(value)\n32\t  );\n33\t}\n34\t\n35\texport function redactScalar(value: PeekAuditScalar): PeekAuditScalar {\n36\t  if (typeof value !== \"string\") return value;\n37\t  return looksLikeSecret(value) ? PEEK_AUDIT_REDACTED : value;\n38\t}\n39\t\n40\texport function redactNullableString(value: string | null): string | null {\n41\t  if (value === null) return null;\n42\t  return looksLikeSecret(value) ? PEEK_AUDIT_REDACTED : value;\n43\t}\n44\t\n45\texport function redactChange(change: PeekAuditChange): PeekAuditChange {\n46\t  return {\n47\t    field: change.field,\n48\t    before: redactScalar(change.before),\n49\t    after: redactScalar(change.after),\n50\t  };\n51\t}\n52\t\n53\texport function redactPayload(payload: PeekAuditPayload): PeekAuditPayload {\n54\t  return {\n55\t    actorEmail: payload.actorEmail,\n56\t    route: redactNullableString(payload.route),\n57\t    actionId: redactNullableString(payload.actionId),\n58\t    resourceType: redactNullableString(payload.resourceType),\n59\t    resourceId: redactNullableString(payload.resourceId),\n60\t    filterSummary: redactNullableString(payload.filterSummary),\n61\t    resultCount: payload.resultCount,\n62\t    requestId: redactNullableString(payload.requestId),\n63\t    rejectionReason: redactNullableString(payload.rejectionReason),\n64\t    changes: payload.changes ? payload.changes.map(redactChange) : null,\n65\t  };\n66\t}\n67\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_011XHou3pWm96eV1HWw8J3vA","session_id":"6775cf18-4dba-4172-859b-2630d02f912a","uuid":"6ed97767-e046-472d-beea-340ee8fc8a22","timestamp":"2026-04-26T06:43:38.897Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FFnQ9smAstcLF6e6SNTcZq","type":"tool_result","content":"1\t// Browser-safe view-model primitives for `peek`.\n2\t//\n3\t// Foundational shapes used across feature pages: metric metadata (FR-4),\n4\t// URL-addressable table filters, pagination, sort, and a small table-row base\n5\t// type that per-feature row types can extend. Per-feature shapes (PeekUserRow,\n6\t// PeekUserDetail, future referral/game/queue/etc. rows) live alongside or\n7\t// extend these primitives.\n8\t\n9\timport type { PeekRole } from \"../access-policy\";\n10\t\n11\t// --- Existing 303-era shapes (kept stable for current callers) ---------------\n12\t\n13\texport type PeekSummary = {\n14\t  totalUsers: number;\n15\t  totalUsersWithCodes: number;\n16\t  totalReferredUsers: number;\n17\t  totalUniqueReferrers: number;\n18\t};\n19\t\n20\texport type PeekUserRow = {\n21\t  userId: string;\n22\t  username: string | null;\n23\t  wallet: string;\n24\t  joinedAt: string;\n25\t  referralCode: string | null;\n26\t  referrerUserId: string | null;\n27\t  referrerCode: string | null;\n28\t  refereeCount: number;\n29\t  telegramUsername: string | null;\n30\t  telegramUserId: string | null;\n31\t};\n32\t\n33\t// --- Expanded user-detail shapes (FR-6) --------------------------------------\n34\t//\n35\t// Per-section row types for the full support/audit user profile. Lamports and\n36\t// numeric/precision-sensitive values arrive as `text` to preserve precision; the\n37\t// UI re-formats at render time. All shapes are browser-safe (no server imports).\n38\t\n39\texport type PeekLinkedAccountRow = {\n40\t  id: string;\n41\t  provider: string;\n42\t  providerAccountId: string;\n43\t  status: string;\n44\t  telegramUsername: string | null;\n45\t  metadataJson: Record<string, unknown> | null;\n46\t  linkedAt: string;\n47\t  updatedAt: string;\n48\t};\n49\t\n50\texport type PeekTelegramLinkTokenRow = {\n51\t  id: string;\n52\t  status: string;\n53\t  telegramUserId: string | null;\n54\t  telegramUsername: string | null;\n55\t  expiresAt: string;\n56\t  redeemedAt: string | null;\n57\t  createdAt: string;\n58\t};\n59\t\n60\texport type PeekKolRate = {\n61\t  rateBps: number;\n62\t  setBy: string;\n63\t  createdAt: string;\n64\t  updatedAt: string;\n65\t};\n66\t\n67\texport type PeekReferralEarningsSummary = {\n68\t  earningsCount: number;\n69\t  totalReferrerEarnedLamports: string;\n70\t  totalRefereeRebateLamports: string;\n71\t  lastEarnedAt: string | null;\n72\t};\n73\t\n74\texport type PeekReferralClaimRow = {\n75\t  id: string;\n76\t  amountLamports: string;\n77\t  status: string;\n78\t  retryCount: number;\n79\t  txSignature: string | null;\n80\t  error: string | null;\n81\t  requestedAt: string;\n82\t  processedAt: string | null;\n83\t};\n84\t\n85\texport type PeekPointGrantRow = {\n86\t  id: string;\n87\t  sourceType: string;\n88\t  sourceId: string;\n89\t  amount: string;\n90\t  createdAt: string;\n91\t};\n92\t\n93\texport type PeekPlayerPoints = {\n94\t  balance: string;\n95\t  lifetimeEarned: string;\n96\t  updatedAt: string | null;\n97\t};\n98\t\n99\texport type PeekCrateDropRow = {\n100\t  id: string;\n101\t  triggerType: string;\n102\t  triggerId: string;\n103\t  crateType: string;\n104\t  contentsAmount: string;\n105\t  status: string;\n106\t  createdAt: string;\n107\t  grantedAt: string | null;\n108\t};\n109\t\n110\texport type PeekChallengeAssignmentSummary = {\n111\t  active: number;\n112\t  completed: number;\n113\t  expired: number;\n114\t  total: number;\n115\t};\n116\t\n117\texport type PeekGameEntryRow = {\n118\t  id: string;\n119\t  game: string;\n120\t  roundPda: string;\n121\t  matchId: string;\n122\t  amountLamports: string;\n123\t  side: string | null;\n124\t  isWinner: boolean | null;\n125\t  payoutLamports: string;\n126\t  createdAt: string;\n127\t  settledAt: string | null;\n128\t};\n129\t\n130\texport type PeekTransactionRow = {\n131\t  id: string;\n132\t  game: string;\n133\t  matchId: string;\n134\t  txType: string;\n135\t  amountLamports: string;\n136\t  txSig: string;\n137\t  createdAt: string;\n138\t};\n139\t\n140\texport type PeekFraudFlagRow = {\n141\t  id: string;\n142\t  flagType: string;\n143\t  status: string;\n144\t  relatedId: string | null;\n145\t  createdAt: string;\n146\t  resolvedAt: string | null;\n147\t};\n148\t\n149\texport type PeekUserQueueEventRow = {\n150\t  id: string;\n151\t  eventType: string;\n152\t  status: string;\n153\t  attempts: number;\n154\t  maxAttempts: number;\n155\t  scheduledAt: string;\n156\t  createdAt: string;\n157\t  error: string | null;\n158\t};\n159\t\n160\texport type PeekUserAttentionFlags = {\n161\t  failedClaim: boolean;\n162\t  deadQueueEvent: boolean;\n163\t  activeFraudFlag: boolean;\n164\t  pendingSolCratePayout: boolean;\n165\t  suspiciousReferralLoop: boolean;\n166\t};\n167\t\n168\texport type PeekUserDetailUser = PeekUserRow & {\n169\t  avatarUrl: string | null;\n170\t  heatMultiplier: string;\n171\t  profilePointsBalance: string;\n172\t};\n173\t\n174\texport type PeekUserDetail = {\n175\t  user: PeekUserDetailUser;\n176\t  inboundReferral: {\n177\t    referrerUserId: string | null;\n178\t    referrerCode: string | null;\n179\t    linkedAt: string | null;\n180\t  };\n181\t  outboundReferees: Array<{\n182\t    refereeUserId: string;\n183\t    refereeUsername: string | null;\n184\t    createdAt: string;\n185\t  }>;\n186\t  telegram: {\n187\t    state: \"active\" | \"none\";\n188\t    telegramUserId: string | null;\n189\t    telegramUsername: string | null;\n190\t  };\n191\t  linkedAccounts: ReadonlyArray<PeekLinkedAccountRow>;\n192\t  recentTelegramLinkTokens: ReadonlyArray<PeekTelegramLinkTokenRow>;\n193\t  kolRate: PeekKolRate | null;\n194\t  referralEarnings: PeekReferralEarningsSummary;\n195\t  recentReferralClaims: ReadonlyArray<PeekReferralClaimRow>;\n196\t  points: PeekPlayerPoints;\n197\t  recentPointGrants: ReadonlyArray<PeekPointGrantRow>;\n198\t  recentCrateDrops: ReadonlyArray<PeekCrateDropRow>;\n199\t  challengeSummary: PeekChallengeAssignmentSummary;\n200\t  recentGameEntries: ReadonlyArray<PeekGameEntryRow>;\n201\t  recentTransactions: ReadonlyArray<PeekTransactionRow>;\n202\t  fraudFlags: ReadonlyArray<PeekFraudFlagRow>;\n203\t  recentUserQueueEvents: ReadonlyArray<PeekUserQueueEventRow>;\n204\t  attention: PeekUserAttentionFlags;\n205\t};\n206\t\n207\t// --- Actor view model (browser-safe) -----------------------------------------\n208\t\n209\texport type PeekActorView = {\n210\t  email: string;\n211\t  role: PeekRole;\n212\t};\n213\t\n214\t// --- Metric metadata (FR-4) --------------------------------------------------\n215\t//\n216\t// Each metric carries the bookkeeping required by the data-surfacing standard:\n217\t// stable id, label, value, source table/query, time window, \"as of\" timestamp,\n218\t// short definition, optional unit, and optional drill-down link to the filtered\n219\t// detail rows behind the number.\n220\t\n221\texport type PeekMetricFreshness = \"live\" | \"cached\" | \"manual\" | \"sampled\";\n222\t\n223\texport type PeekMetric = {\n224\t  id: string;\n225\t  label: string;\n226\t  value: number | string | null;\n227\t  valueDisplay: string;\n228\t  unit: string | null;\n229\t  source: string;\n230\t  windowLabel: string;\n231\t  asOf: string | null;\n232\t  definition: string;\n233\t  freshness: PeekMetricFreshness;\n234\t  drilldownHref: string | null;\n235\t};\n236\t\n237\t// --- Pagination primitive ----------------------------------------------------\n238\t\n239\texport type PeekPagination = {\n240\t  page: number;\n241\t  pageSize: number;\n242\t  totalCount: number;\n243\t  totalPages: number;\n244\t};\n245\t\n246\t// --- Sort primitive ----------------------------------------------------------\n247\t\n248\texport type PeekSortDirection = \"asc\" | \"desc\";\n249\t\n250\texport type PeekTableSort = {\n251\t  column: string;\n252\t  direction: PeekSortDirection;\n253\t};\n254\t\n255\t// --- Table filter primitive (URL-addressable) --------------------------------\n256\t\n257\texport type PeekFilterKind =\n258\t  | \"text\"\n259\t  | \"select\"\n260\t  | \"boolean\"\n261\t  | \"date\"\n262\t  | \"dateRange\";\n263\t\n264\texport type PeekFilterOption = {\n265\t  value: string;\n266\t  label: string;\n267\t};\n268\t\n269\texport type PeekTableFilter = {\n270\t  id: string;\n271\t  label: string;\n272\t  kind: PeekFilterKind;\n273\t  value: string | null;\n274\t  options: ReadonlyArray<PeekFilterOption> | null;\n275\t  placeholder: string | null;\n276\t  required: boolean;\n277\t};\n278\t\n279\t// --- Status chip tone (shared) -----------------------------------------------\n280\t\n281\texport type PeekStatusTone =\n282\t  | \"neutral\"\n283\t  | \"positive\"\n284\t  | \"warning\"\n285\t  | \"negative\"\n286\t  | \"info\";\n287\t\n288\t// --- Empty-state primitive ---------------------------------------------------\n289\t\n290\texport type PeekEmptyState = {\n291\t  title: string;\n292\t  body: string | null;\n293\t};\n294\t\n295\t// --- Table row + column primitives -------------------------------------------\n296\t//\n297\t// Per-feature row types extend `PeekTableRowBase` for the shared identifier +\n298\t// optional drill-down link, then add feature-specific fields. The shared dense\n299\t// table component reads `columns` for layout and per-row data via the typed\n300\t// row shape supplied by the feature page.\n301\t\n302\texport type PeekTableColumnAlign = \"left\" | \"right\" | \"center\";\n303\t\n304\texport type PeekTableColumn = {\n305\t  id: string;\n306\t  label: string;\n307\t  align: PeekTableColumnAlign;\n308\t  sortable: boolean;\n309\t};\n310\t\n311\texport type PeekTableRowBase = {\n312\t  id: string;\n313\t  href: string | null;\n314\t};\n315\t\n316\texport type PeekTableViewModel<TRow extends PeekTableRowBase> = {\n317\t  columns: ReadonlyArray<PeekTableColumn>;\n318\t  rows: ReadonlyArray<TRow>;\n319\t  pagination: PeekPagination;\n320\t  filters: ReadonlyArray<PeekTableFilter>;\n321\t  sort: PeekTableSort | null;\n322\t  empty: PeekEmptyState;\n323\t};\n324\t\n325\t// --- Command-center attention queue (FR-3, FR-10) ----------------------------\n326\t//\n327\t// The command-center page surfaces a small set of \"needs attention\" metrics so\n328\t// operators see exception states (failed claims, dead queue events, stuck\n329\t// settlements, pending SOL crate payouts, stale active Dogpile events,\n330\t// high-value export activity) before they dig into per-feature pages. Each\n331\t// item is a `PeekMetric` so the metric-strip primitive renders it with the\n332\t// FR-4 bookkeeping (definition, source, time window, \"as of\", drill-down).\n333\t\n334\texport type PeekCommandCenterAttentionId =\n335\t  | \"failed_claims\"\n336\t  | \"dead_queue_events\"\n337\t  | \"stuck_rounds_flipyou_potshot\"\n338\t  | \"stuck_rounds_closecall\"\n339\t  | \"pending_sol_crate_payouts\"\n340\t  | \"stale_active_dogpile_events\"\n341\t  | \"high_value_exports_24h\";\n342\t\n343\texport type PeekCommandCenterAttention = {\n344\t  generatedAt: string;\n345\t  metrics: ReadonlyArray<PeekMetric>;\n346\t};\n347\t\n348\t// --- Recent operator activity (FR-3 command-center \"high-signal activity\") ---\n349\t//\n350\t// Compact projection of the latest `operator_events` rows for the command-center\n351\t// \"Recent activity\" section. Pulled from the same JSONB payload the audit\n352\t// writer persists, but kept narrow on purpose — the command center surfaces\n353\t// only the few fields needed to recognize what happened, not the full payload.\n354\t// The audit view (`/audit`, later iteration) renders the full bounded table.\n355\t\n356\texport type PeekRecentActivityItem = {\n357\t  id: string;\n358\t  eventType: string;\n359\t  actorEmail: string | null;\n360\t  resourceType: string | null;\n361\t  resourceId: string | null;\n362\t  route: string | null;\n363\t  createdAt: string;\n364\t};\n365\t\n366\t// --- Audit event contracts (FR-11) -------------------------------------------\n367\t//\n368\t// Browser-safe view of `operator_events` rows the audit writer produces under\n369\t// `peek.*` event types. The `PeekAuditPayload` shape pins the fields required by\n370\t// FR-11 so the writer (`peek/src/server/audit/**`, next iteration) and the audit\n371\t// view (`/audit`, later iteration) agree on a serialization contract. Secrets\n372\t// (JWTs, access tokens, DB URLs, private keys, raw secrets) must be replaced by\n373\t// `PEEK_AUDIT_REDACTED` before persisting; the audit-view component renders the\n374\t// token verbatim so reviewers can see that a field was redacted (not silently\n375\t// absent).\n376\t\n377\texport type PeekAuditEventType =\n378\t  | \"peek.search\"\n379\t  | \"peek.user.view_sensitive\"\n380\t  | \"peek.export\"\n381\t  | \"peek.access.denied\"\n382\t  | \"peek.change.applied\"\n383\t  | \"peek.change.rejected\";\n384\t\n385\texport const PEEK_AUDIT_EVENT_TYPES: ReadonlyArray<PeekAuditEventType> = [\n386\t  \"peek.search\",\n387\t  \"peek.user.view_sensitive\",\n388\t  \"peek.export\",\n389\t  \"peek.access.denied\",\n390\t  \"peek.change.applied\",\n391\t  \"peek.change.rejected\",\n392\t];\n393\t\n394\texport function isPeekAuditEventType(\n395\t  value: unknown,\n396\t): value is PeekAuditEventType {\n397\t  return (\n398\t    typeof value === \"string\" &&\n399\t    (PEEK_AUDIT_EVENT_TYPES as ReadonlyArray<string>).includes(value)\n400\t  );\n401\t}\n402\t\n403\texport const PEEK_AUDIT_REDACTED = \"[REDACTED]\";\n404\t\n405\texport type PeekAuditScalar = string | number | boolean | null;\n406\t\n407\texport type PeekAuditChange = {\n408\t  field: string;\n409\t  before: PeekAuditScalar;\n410\t  after: PeekAuditScalar;\n411\t};\n412\t\n413\texport type PeekAuditPayload = {\n414\t  actorEmail: string;\n415\t  route: string | null;\n416\t  actionId: string | null;\n417\t  resourceType: string | null;\n418\t  resourceId: string | null;\n419\t  filterSummary: string | null;\n420\t  resultCount: number | null;\n421\t  requestId: string | null;\n422\t  rejectionReason: string | null;\n423\t  changes: ReadonlyArray<PeekAuditChange> | null;\n424\t};\n425\t\n426\texport type PeekAuditEvent = {\n427\t  id: string;\n428\t  eventType: PeekAuditEventType;\n429\t  createdAt: string;\n430\t  payload: PeekAuditPayload;\n431\t};\n432\t\n433\t// --- Export contracts (FR-12) ------------------------------------------------\n434\t//\n435\t// Exports are server-rendered CSVs gated by the same page-level access as the\n436\t// source page, bounded by a server-side row cap, named with a deterministic\n437\t// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n438\t// bytes return. Export rows reuse the table view-model column ids so the export\n439\t// shape stays in lockstep with the rendered table; values are pre-formatted\n440\t// strings so CSV serialization stays straightforward and locale-stable.\n441\t\n442\texport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n443\t\n444\texport type PeekExportEntity =\n445\t  | \"users\"\n446\t  | \"referrers\"\n447\t  | \"kol\"\n448\t  | \"claims\"\n449\t  | \"rounds\"\n450\t  | \"transactions\"\n451\t  | \"queue\"\n452\t  | \"audit\";\n453\t\n454\texport type PeekExportRow = Record<string, string>;\n455\t\n456\texport type PeekExportFilenameInput = {\n457\t  entity: PeekExportEntity;\n458\t  date: string;\n459\t  filterSlug: string;\n460\t};\n461\t\n462\texport type PeekExportResult = {\n463\t  filename: string;\n464\t  rowCount: number;\n465\t  rowCap: number;\n466\t  rowCapApplied: boolean;\n467\t  columns: ReadonlyArray<PeekTableColumn>;\n468\t  rows: ReadonlyArray<PeekExportRow>;\n469\t};\n470\t\n471\t// --- Universal search (FR-5) -------------------------------------------------\n472\t//\n473\t// One search entry point that resolves common operational identifiers to typed\n474\t// result groups. Results are grouped by entity type so the UI can section them\n475\t// (user, referral, linked account, round, transaction, queue event). Each\n476\t// result includes enough context to disambiguate similar matches; sensitive\n477\t// values (wallet, Telegram id, tx signature) live in the result's `id`/`label`\n478\t// fields for operator readability and the audit event records only the actor\n479\t// email, query class, and result counts (never the raw query, which the audit\n480\t// writer redacts if it looks like a secret).\n481\t\n482\texport type PeekSearchEntityType =\n483\t  | \"user\"\n484\t  | \"referral\"\n485\t  | \"linked_account\"\n486\t  | \"round\"\n487\t  | \"transaction\"\n488\t  | \"queue_event\";\n489\t\n490\texport const PEEK_SEARCH_ENTITY_TYPES: ReadonlyArray<PeekSearchEntityType> = [\n491\t  \"user\",\n492\t  \"referral\",\n493\t  \"linked_account\",\n494\t  \"round\",\n495\t  \"transaction\",\n496\t  \"queue_event\",\n497\t];\n498\t\n499\t// Coarse heuristic classification used only for the `peek.search` audit\n500\t// summary so reviewers can see which class of identifier was searched without\n501\t// inferring it from the (possibly redacted) raw query.\n502\texport type PeekSearchQueryClass =\n503\t  | \"empty\"\n504\t  | \"free_text\"\n505\t  | \"user_id\"\n506\t  | \"username\"\n507\t  | \"wallet\"\n508\t  | \"referral_code\"\n509\t  | \"telegram_username\"\n510\t  | \"telegram_provider_id\"\n511\t  | \"round_pda\"\n512\t  | \"match_id\"\n513\t  | \"tx_signature\"\n514\t  | \"queue_event_id\";\n515\t\n516\texport type PeekSearchResult = {\n517\t  entityType: PeekSearchEntityType;\n518\t  id: string;\n519\t  label: string;\n520\t  sublabel: string | null;\n521\t  context: string | null;\n522\t  href: string;\n523\t};\n524\t\n525\texport type PeekSearchGroup = {\n526\t  entityType: PeekSearchEntityType;\n527\t  results: ReadonlyArray<PeekSearchResult>;\n528\t  truncated: boolean;\n529\t};\n530\t\n531\texport type PeekSearchResponse = {\n532\t  query: string;\n533\t  queryClass: PeekSearchQueryClass;\n534\t  groups: ReadonlyArray<PeekSearchGroup>;\n535\t  totalResults: number;\n536\t  perGroupLimit: number;\n537\t  generatedAt: string;\n538\t};\n539\t\n540\texport const PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT = 5;\n541\texport const PEEK_SEARCH_MAX_PER_GROUP_LIMIT = 25;\n542\t\n543\t// --- Growth + referral admin (FR-7) ------------------------------------------\n544\t//\n545\t// Browser-safe view models for `/growth/referrals` and `/growth/kol`. The\n546\t// engine queries surface (a) overview metrics that fit the FR-4 metric\n547\t// bookkeeping, (b) top-referrer rows that combine `referral_links`,\n548\t// `referral_codes`, `referral_earnings`, and pending `referral_claims` per\n549\t// referrer, (c) KOL rows that join `referral_kol_rates` with linked\n550\t// performance from `referral_links`/`referral_earnings`, (d) claim rows for\n551\t// the filterable `/growth/referrals` claims table, and (e) a one-hop\n552\t// referral-graph node that lets the UI navigate from a user-detail page to\n553\t// the inbound referrer or any outbound referee and back.\n554\t//\n555\t// All numeric/precision-sensitive values arrive as `text` to preserve u64\n556\t// lamport precision; the UI formats at render time.\n557\t\n558\texport type PeekGrowthOverviewMetricId =\n559\t  | \"growth.referrers\"\n560\t  | \"growth.referred_users\"\n561\t  | \"growth.activated_referred_users\"\n562\t  | \"growth.referrer_earnings_lamports\"\n563\t  | \"growth.referee_rebates_lamports\"\n564\t  | \"growth.pending_claims_lamports\"\n565\t  | \"growth.failed_claims\"\n566\t  | \"growth.kol_count\";\n567\t\n568\texport const PEEK_GROWTH_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekGrowthOverviewMetricId> =\n569\t  [\n570\t    \"growth.referrers\",\n571\t    \"growth.referred_users\",\n572\t    \"growth.activated_referred_users\",\n573\t    \"growth.referrer_earnings_lamports\",\n574\t    \"growth.referee_rebates_lamports\",\n575\t    \"growth.pending_claims_lamports\",\n576\t    \"growth.failed_claims\",\n577\t    \"growth.kol_count\",\n578\t  ];\n579\t\n580\texport type PeekGrowthOverview = {\n581\t  generatedAt: string;\n582\t  metrics: ReadonlyArray<PeekMetric>;\n583\t};\n584\t\n585\texport type PeekTopReferrerRow = {\n586\t  referrerUserId: string;\n587\t  username: string | null;\n588\t  wallet: string;\n589\t  referralCode: string | null;\n590\t  refereeCount: number;\n591\t  activeRefereeCount: number;\n592\t  referredWagerLamports: string;\n593\t  referrerEarnedLamports: string;\n594\t  pendingClaimLamports: string;\n595\t};\n596\t\n597\texport type PeekKolPerformanceRow = {\n598\t  userId: string;\n599\t  username: string | null;\n600\t  wallet: string;\n601\t  rateBps: number;\n602\t  setBy: string;\n603\t  createdAt: string;\n604\t  updatedAt: string;\n605\t  refereeCount: number;\n606\t  referredWagerLamports: string;\n607\t  referrerEarnedLamports: string;\n608\t};\n609\t\n610\t// Status filter values mirror the migration check constraint:\n611\t// 'pending' | 'processing' | 'error' | 'completed' | 'failed'. Treated as a\n612\t// loose `string` here so the UI can pass through a \"failed_or_error\" virtual\n613\t// alias without a contract change. Extends the per-user\n614\t// `PeekReferralClaimRow` with the `userId`/`username`/`wallet` columns the\n615\t// /growth/referrals claims table needs to render and link rows back to user\n616\t// detail.\n617\texport type PeekGrowthClaimRow = PeekReferralClaimRow & {\n618\t  userId: string;\n619\t  username: string | null;\n620\t  wallet: string;\n621\t};\n622\t\n623\texport type PeekReferralClaimFilters = {\n624\t  status: string | null;\n625\t  userId: string | null;\n626\t  minAmountLamports: string | null;\n627\t  maxAmountLamports: string | null;\n628\t  requestedFrom: string | null;\n629\t  requestedTo: string | null;\n630\t  txSignature: string | null;\n631\t  errorContains: string | null;\n632\t};\n633\t\n634\texport type PeekReferralGraphRefereeRow = {\n635\t  refereeUserId: string;\n636\t  refereeUsername: string | null;\n637\t  refereeWallet: string;\n638\t  createdAt: string;\n639\t};\n640\t\n641\texport type PeekReferralGraphInboundReferrer = {\n642\t  referrerUserId: string | null;\n643\t  referrerUsername: string | null;\n644\t  referrerWallet: string | null;\n645\t  referrerCode: string | null;\n646\t  linkedAt: string | null;\n647\t};\n648\t\n649\texport type PeekReferralGraphNode = {\n650\t  userId: string;\n651\t  username: string | null;\n652\t  wallet: string;\n653\t  referralCode: string | null;\n654\t  inboundReferrer: PeekReferralGraphInboundReferrer;\n655\t  outboundReferees: ReadonlyArray<PeekReferralGraphRefereeRow>;\n656\t};\n657\t\n658\t// --- Games overview (FR-8) ---------------------------------------------------\n659\t//\n660\t// Browser-safe view models for `/games`. The engine query reads the single\n661\t// source of truth `game_entries` (migration 007) and produces (a) a small set\n662\t// of platform-wide FR-4 metrics for the overview strip and (b) per-game rows\n663\t// with the operational counters the spec calls out: entries, unique users,\n664\t// wagered lamports, settled entries, refund entries, payout lamports, wins,\n665\t// losses. Lamport sums round-trip as `text` to preserve u64 precision; the UI\n666\t// formats at render time.\n667\t//\n668\t// `PeekGameId` mirrors the migration's CHECK constraint on `game_entries.game`\n669\t// (`'flipyou' | 'potshot' | 'closecall'`). Deferred games (Crash, Game of\n670\t// Trades, Chart the Course, Slots Utopia, Tug of Earn) are documented\n671\t// placeholders rendered by the page; they intentionally are not part of the\n672\t// data shape because they have no persisted source yet (system invariant 13).\n673\t\n674\texport type PeekGameId = \"flipyou\" | \"potshot\" | \"closecall\";\n675\t\n676\texport const PEEK_GAME_IDS: ReadonlyArray<PeekGameId> = [\n677\t  \"flipyou\",\n678\t  \"potshot\",\n679\t  \"closecall\",\n680\t];\n681\t\n682\texport type PeekGameOverviewRow = {\n683\t  game: PeekGameId;\n684\t  entries: number;\n685\t  uniqueUsers: number;\n686\t  wageredLamports: string;\n687\t  settledEntries: number;\n688\t  refundEntries: number;\n689\t  payoutLamports: string;\n690\t  wins: number;\n691\t  losses: number;\n692\t};\n693\t\n694\texport type PeekGameOverviewMetricId =\n695\t  | \"games.total_entries\"\n696\t  | \"games.unique_users\"\n697\t  | \"games.wagered_lamports\"\n698\t  | \"games.settled_entries\"\n699\t  | \"games.refund_entries\"\n700\t  | \"games.payout_lamports\";\n701\t\n702\texport const PEEK_GAME_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekGameOverviewMetricId> =\n703\t  [\n704\t    \"games.total_entries\",\n705\t    \"games.unique_users\",\n706\t    \"games.wagered_lamports\",\n707\t    \"games.settled_entries\",\n708\t    \"games.refund_entries\",\n709\t    \"games.payout_lamports\",\n710\t  ];\n711\t\n712\texport type PeekGameOverview = {\n713\t  generatedAt: string;\n714\t  metrics: ReadonlyArray<PeekMetric>;\n715\t  perGame: ReadonlyArray<PeekGameOverviewRow>;\n716\t};\n717\t\n718\t// --- Per-game round detail (FR-8) --------------------------------------------\n719\t//\n720\t// Browser-safe view models for the round-detail surfaces backing\n721\t// `/games/[game]`. Two distinct shapes because the underlying tables differ:\n722\t//\n723\t//   - FlipYou and Pot Shot share the `rounds` table (migration 001) — the\n724\t//     CHECK constraint pins phase to one of five lifecycle states. Lamport\n725\t//     and slot values are u64-precision and round-trip as `text`.\n726\t//   - Close Call uses the separate `closecall_rounds` table (migration 004)\n727\t//     with its own three-phase lifecycle and a Pyth-driven outcome column.\n728\t//\n729\t// `stuck-state filters` cover the four operational signals the spec calls\n730\t// out: nonterminal-aged (created/locked/settling past the age threshold for\n731\t// FlipYou/Pot Shot; open past the age threshold for Close Call), high settle\n732\t// attempts (FlipYou/Pot Shot only — `closecall_rounds` has no\n733\t// `settle_attempts`), settled rounds without an expected payout/refund\n734\t// transaction in `transactions`, and refunds (phase `expired` for FlipYou/\n735\t// Pot Shot; phase `refunded` or outcome `refund` for Close Call).\n736\t\n737\texport type PeekRoundPhase =\n738\t  | \"created\"\n739\t  | \"locked\"\n740\t  | \"settling\"\n741\t  | \"settled\"\n742\t  | \"expired\";\n743\t\n744\texport const PEEK_ROUND_PHASES: ReadonlyArray<PeekRoundPhase> = [\n745\t  \"created\",\n746\t  \"locked\",\n747\t  \"settling\",\n748\t  \"settled\",\n749\t  \"expired\",\n750\t];\n751\t\n752\texport type PeekRoundsGameId = Extract<PeekGameId, \"flipyou\" | \"potshot\">;\n753\t\n754\texport const PEEK_ROUNDS_GAME_IDS: ReadonlyArray<PeekRoundsGameId> = [\n755\t  \"flipyou\",\n756\t  \"potshot\",\n757\t];\n758\t\n759\texport type PeekRoundRow = {\n760\t  game: PeekRoundsGameId;\n761\t  pda: string;\n762\t  matchId: string;\n763\t  phase: PeekRoundPhase;\n764\t  creator: string;\n765\t  targetSlot: string | null;\n766\t  settleAttempts: number;\n767\t  settleTx: string | null;\n768\t  resultSide: number | null;\n769\t  winner: string | null;\n770\t  amountLamports: string;\n771\t  createdAt: string;\n772\t  updatedAt: string;\n773\t  settledAt: string | null;\n774\t};\n775\t\n776\texport type PeekCloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n777\t\n778\texport const PEEK_CLOSECALL_PHASES: ReadonlyArray<PeekCloseCallPhase> = [\n779\t  \"open\",\n780\t  \"settled\",\n781\t  \"refunded\",\n782\t];\n783\t\n784\texport type PeekCloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n785\t\n786\texport const PEEK_CLOSECALL_OUTCOMES: ReadonlyArray<PeekCloseCallOutcome> = [\n787\t  \"pending\",\n788\t  \"green\",\n789\t  \"red\",\n790\t  \"refund\",\n791\t];\n792\t\n793\texport type PeekCloseCallRoundRow = {\n794\t  pda: string;\n795\t  roundId: string;\n796\t  phase: PeekCloseCallPhase;\n797\t  outcome: PeekCloseCallOutcome;\n798\t  openPrice: string;\n799\t  openPriceExpo: number;\n800\t  closePrice: string | null;\n801\t  greenPoolLamports: string;\n802\t  redPoolLamports: string;\n803\t  totalFeeLamports: string;\n804\t  settleTx: string | null;\n805\t  createdAt: string;\n806\t  settledAt: string | null;\n807\t};\n808\t\n809\texport type PeekRoundStuckFilters = {\n810\t  nonterminalAged: boolean;\n811\t  highAttempts: boolean;\n812\t  settledWithoutTx: boolean;\n813\t  refunds: boolean;\n814\t};\n815\t\n816\texport type PeekRoundFilters = {\n817\t  phase: PeekRoundPhase | null;\n818\t  search: string | null;\n819\t  fromDate: string | null;\n820\t  toDate: string | null;\n821\t  stuck: PeekRoundStuckFilters;\n822\t};\n823\t\n824\texport type PeekCloseCallRoundStuckFilters = Omit<\n825\t  PeekRoundStuckFilters,\n826\t  \"highAttempts\"\n827\t>;\n828\t\n829\texport type PeekCloseCallRoundFilters = {\n830\t  phase: PeekCloseCallPhase | null;\n831\t  outcome: PeekCloseCallOutcome | null;\n832\t  search: string | null;\n833\t  fromDate: string | null;\n834\t  toDate: string | null;\n835\t  stuck: PeekCloseCallRoundStuckFilters;\n836\t};\n837\t\n838\texport type PeekRoundsListResult<TRow> = {\n839\t  rows: ReadonlyArray<TRow>;\n840\t  pagination: PeekPagination;\n841\t};\n842\t\n843\t// --- Round detail (FR-8) -----------------------------------------------------\n844\t//\n845\t// Browser-safe view models for `/games/[game]/rounds/[roundId]`. The detail\n846\t// joins the round summary (FlipYou/Pot Shot from `rounds`, Close Call from\n847\t// `closecall_rounds`) with all participating `game_entries` and the related\n848\t// `transactions` rows for the round (matched by `match_id` + `game`, where\n849\t// `match_id` is `closecall_rounds.round_id` for the Close Call branch).\n850\t//\n851\t// Entries and transactions carry the operator-readable identity context the\n852\t// detail page renders alongside each row (wallet always; user id + username\n853\t// when the player has a `player_profiles` row). Lamport amounts and slot\n854\t// values stay as `text` to preserve u64 precision.\n855\t\n856\texport type PeekRoundEntryRow = {\n857\t  id: string;\n858\t  userId: string;\n859\t  username: string | null;\n860\t  wallet: string;\n861\t  amountLamports: string;\n862\t  side: string | null;\n863\t  isWinner: boolean | null;\n864\t  payoutLamports: string;\n865\t  createdAt: string;\n866\t  settledAt: string | null;\n867\t};\n868\t\n869\texport type PeekRoundTransactionRow = {\n870\t  id: string;\n871\t  userId: string | null;\n872\t  username: string | null;\n873\t  wallet: string;\n874\t  txType: string;\n875\t  amountLamports: string;\n876\t  txSig: string;\n877\t  createdAt: string;\n878\t};\n879\t\n880\texport type PeekRoundDetail =\n881\t  | {\n882\t      game: PeekRoundsGameId;\n883\t      round: PeekRoundRow;\n884\t      entries: ReadonlyArray<PeekRoundEntryRow>;\n885\t      transactions: ReadonlyArray<PeekRoundTransactionRow>;\n886\t    }\n887\t  | {\n888\t      game: \"closecall\";\n889\t      round: PeekCloseCallRoundRow;\n890\t      entries: ReadonlyArray<PeekRoundEntryRow>;\n891\t      transactions: ReadonlyArray<PeekRoundTransactionRow>;\n892\t    };\n893\t\n894\t// --- Economy: rewards (FR-9) -------------------------------------------------\n895\t//\n896\t// Browser-safe view models for `/economy/rewards`. Reads three migration-011\n897\t// tables:\n898\t//\n899\t//   - reward_config           — operator-tunable economy parameters; each row\n900\t//     is annotated server-side with a human-readable definition and an\n901\t//     expected-value type from a static registry so the page can show what a\n902\t//     key means without an extra docs lookup.\n903\t//   - reward_pool             — singleton accounting row (balance, lifetime\n904\t//     funded, lifetime paid, updated_at).\n905\t//   - reward_pool_fundings    — append-only ledger of per-round funding events\n906\t//     keyed on round_id (the source round whose fee fed the pool).\n907\t//\n908\t// Lamport / u64 values round-trip as `text` to preserve precision (FR-4).\n909\t// Unknown reward_config keys still surface (with `definition: null` and\n910\t// `expectedType: \"unknown\"`) so an operator immediately notices when a new\n911\t// key has been seeded but the registry has not been updated.\n912\t\n913\texport type PeekRewardConfigExpectedType =\n914\t  | \"integer\"\n915\t  | \"float\"\n916\t  | \"ratio\"\n917\t  | \"lamports\"\n918\t  | \"unknown\";\n919\t\n920\texport type PeekRewardConfigRow = {\n921\t  key: string;\n922\t  value: string;\n923\t  updatedAt: string;\n924\t  definition: string | null;\n925\t  expectedType: PeekRewardConfigExpectedType;\n926\t};\n927\t\n928\texport type PeekRewardPool = {\n929\t  balanceLamports: string;\n930\t  lifetimeFunded: string;\n931\t  lifetimePaid: string;\n932\t  updatedAt: string;\n933\t};\n934\t\n935\texport type PeekRewardPoolFundingRow = {\n936\t  id: string;\n937\t  roundId: string;\n938\t  feeLamports: string;\n939\t  fundedLamports: string;\n940\t  createdAt: string;\n941\t};\n942\t\n943\texport type PeekRewardsOverviewMetricId =\n944\t  | \"rewards.balance_lamports\"\n945\t  | \"rewards.lifetime_funded_lamports\"\n946\t  | \"rewards.lifetime_paid_lamports\"\n947\t  | \"rewards.recent_fundings\";\n948\t\n949\texport const PEEK_REWARDS_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekRewardsOverviewMetricId> =\n950\t  [\n951\t    \"rewards.balance_lamports\",\n952\t    \"rewards.lifetime_funded_lamports\",\n953\t    \"rewards.lifetime_paid_lamports\",\n954\t    \"rewards.recent_fundings\",\n955\t  ];\n956\t\n957\texport type PeekRewardsOverview = {\n958\t  generatedAt: string;\n959\t  metrics: ReadonlyArray<PeekMetric>;\n960\t};\n961\t\n962\t// --- Points + crates ledger admin (FR-9) -------------------------------------\n963\t//\n964\t// Browser-safe view models for `/economy/points` and `/economy/crates`. Reads\n965\t// three migration-011 tables:\n966\t//\n967\t//   - player_points     — per-user points balance + lifetime earned, listed\n968\t//     across users and joined with `player_profiles` for username context.\n969\t//   - point_grants      — append-only point-grant ledger; the cross-user row\n970\t//     extends the per-user `PeekPointGrantRow` with the user identity columns\n971\t//     the operator-facing list needs.\n972\t//   - crate_drops       — per-user crate ledger with status (`pending`,\n973\t//     `granted`, `failed`); the cross-user row extends `PeekCrateDropRow` with\n974\t//     the same user identity columns.\n975\t//\n976\t// All bigint counters round-trip as `text` to preserve precision (FR-4). The\n977\t// status / type / source-type values are loosely typed (string) so the UI can\n978\t// pass through the same value the migration's CHECK constraints already\n979\t// enforce server-side without a second source of truth here.\n980\t\n981\texport type PeekPlayerPointsRow = {\n982\t  userId: string;\n983\t  username: string | null;\n984\t  wallet: string;\n985\t  balance: string;\n986\t  lifetimeEarned: string;\n987\t  updatedAt: string;\n988\t};\n989\t\n990\texport type PeekPlayerPointsFilters = {\n991\t  userId: string | null;\n992\t  wallet: string | null;\n993\t};\n994\t\n995\texport type PeekPointGrantLedgerRow = PeekPointGrantRow & {\n996\t  userId: string;\n997\t  username: string | null;\n998\t  wallet: string;\n999\t};\n1000\t\n1001\texport type PeekPointGrantFilters = {\n1002\t  userId: string | null;\n1003\t  sourceType: string | null;\n1004\t  sourceId: string | null;\n1005\t  createdFrom: string | null;\n1006\t  createdTo: string | null;\n1007\t};\n1008\t\n1009\t// `wallet` is nullable because `crate_drops` has no wallet column of its own\n1010\t// and the join falls back to `player_profiles.wallet`; an orphaned crate_drop\n1011\t// (extremely rare — there is no FK constraint, but every drop is created\n1012\t// alongside a profile) renders with `wallet: null` rather than a fake \"\".\n1013\texport type PeekCrateDropLedgerRow = PeekCrateDropRow & {\n1014\t  userId: string;\n1015\t  username: string | null;\n1016\t  wallet: string | null;\n1017\t};\n1018\t\n1019\texport type PeekCrateDropFilters = {\n1020\t  userId: string | null;\n1021\t  crateType: string | null;\n1022\t  status: string | null;\n1023\t  triggerType: string | null;\n1024\t  createdFrom: string | null;\n1025\t  createdTo: string | null;\n1026\t};\n1027\t\n1028\t// --- Challenge engine admin (FR-9) -------------------------------------------\n1029\t//\n1030\t// Browser-safe view models for the upcoming `/economy/challenges` page. Reads\n1031\t// the migration-011 challenge engine tables in read-only mode (no challenge or\n1032\t// campaign editing — that is explicitly out of scope for FR-9 / FR-14):\n1033\t//\n1034\t//   - campaigns            — top-level container (daily / weekly / onboarding /\n1035\t//     dogpile). Listed with active/inactive flag + active assignment counts.\n1036\t//   - challenges           — challenge templates (data, not code). Listed with\n1037\t//     campaign name + reward shape; prerequisite chain is preserved via\n1038\t//     `prerequisiteId` for chained onboarding-style sequences.\n1039\t//   - challenge_assignments — per-player per-period assignments. Filterable by\n1040\t//     userId / challengeId / periodKey / status / created date.\n1041\t//   - progress_events      — append-only progress ledger that pinned a specific\n1042\t//     game round to an assignment. Filterable by assignmentId / userId /\n1043\t//     roundId / created date for anti-gaming audit.\n1044\t//   - completion_bonuses   — meta-quest definitions (e.g. \"complete all daily\n1045\t//     challenges → bonus crate\").\n1046\t//   - bonus_completions    — per-player per-period bonus completion ledger.\n1047\t//     Filterable by userId / bonusId / periodKey / completed date.\n1048\t//\n1049\t// All bigint identity ids round-trip as `text` to preserve precision (FR-4).\n1050\t// Status / scope / reward-type / campaign-type values are loosely typed\n1051\t// (string) so the UI passes through whatever the migration's CHECK constraints\n1052\t// already enforce server-side without a second source of truth here.\n1053\t\n1054\texport type PeekCampaignRow = {\n1055\t  id: string;\n1056\t  name: string;\n1057\t  campaignType: string;\n1058\t  startsAt: string | null;\n1059\t  endsAt: string | null;\n1060\t  isActive: boolean;\n1061\t  createdAt: string;\n1062\t  challengeCount: number;\n1063\t  activeAssignmentCount: number;\n1064\t};\n1065\t\n1066\texport type PeekChallengeRow = {\n1067\t  id: string;\n1068\t  campaignId: string;\n1069\t  campaignName: string | null;\n1070\t  campaignType: string | null;\n1071\t  title: string;\n1072\t  description: string | null;\n1073\t  action: string;\n1074\t  scope: string;\n1075\t  condition: string;\n1076\t  threshold: number;\n1077\t  rewardType: string;\n1078\t  rewardAmount: number | null;\n1079\t  prerequisiteId: string | null;\n1080\t  sortOrder: number;\n1081\t  isActive: boolean;\n1082\t  createdAt: string;\n1083\t};\n1084\t\n1085\texport type PeekChallengeFilters = {\n1086\t  campaignId: string | null;\n1087\t  isActive: string | null;\n1088\t};\n1089\t\n1090\texport type PeekChallengeAssignmentRow = {\n1091\t  id: string;\n1092\t  userId: string;\n1093\t  username: string | null;\n1094\t  challengeId: string;\n1095\t  challengeTitle: string | null;\n1096\t  campaignId: string | null;\n1097\t  campaignName: string | null;\n1098\t  periodKey: string;\n1099\t  status: string;\n1100\t  progress: number;\n1101\t  target: number;\n1102\t  assignedAt: string;\n1103\t  expiresAt: string | null;\n1104\t  completedAt: string | null;\n1105\t};\n1106\t\n1107\texport type PeekChallengeAssignmentFilters = {\n1108\t  userId: string | null;\n1109\t  challengeId: string | null;\n1110\t  campaignId: string | null;\n1111\t  periodKey: string | null;\n1112\t  status: string | null;\n1113\t  assignedFrom: string | null;\n1114\t  assignedTo: string | null;\n1115\t};\n1116\t\n1117\texport type PeekProgressEventRow = {\n1118\t  id: string;\n1119\t  assignmentId: string;\n1120\t  challengeId: string | null;\n1121\t  challengeTitle: string | null;\n1122\t  roundId: string;\n1123\t  userId: string;\n1124\t  username: string | null;\n1125\t  progressDelta: number;\n1126\t  createdAt: string;\n1127\t};\n1128\t\n1129\texport type PeekProgressEventFilters = {\n1130\t  assignmentId: string | null;\n1131\t  challengeId: string | null;\n1132\t  userId: string | null;\n1133\t  roundId: string | null;\n1134\t  createdFrom: string | null;\n1135\t  createdTo: string | null;\n1136\t};\n1137\t\n1138\texport type PeekCompletionBonusRow = {\n1139\t  id: string;\n1140\t  campaignId: string;\n1141\t  campaignName: string | null;\n1142\t  campaignType: string | null;\n1143\t  title: string;\n1144\t  description: string | null;\n1145\t  requiredCount: number;\n1146\t  rewardType: string;\n1147\t  rewardAmount: number | null;\n1148\t  isActive: boolean;\n1149\t  createdAt: string;\n1150\t  completionCount: number;\n1151\t};\n1152\t\n1153\texport type PeekBonusCompletionRow = {\n1154\t  id: string;\n1155\t  userId: string;\n1156\t  username: string | null;\n1157\t  bonusId: string;\n1158\t  bonusTitle: string | null;\n1159\t  campaignId: string | null;\n1160\t  campaignName: string | null;\n1161\t  periodKey: string;\n1162\t  completedAt: string;\n1163\t};\n1164\t\n1165\texport type PeekBonusCompletionFilters = {\n1166\t  userId: string | null;\n1167\t  bonusId: string | null;\n1168\t  campaignId: string | null;\n1169\t  periodKey: string | null;\n1170\t  completedFrom: string | null;\n1171\t  completedTo: string | null;\n1172\t};\n1173\t\n1174\texport type PeekChallengesOverviewMetricId =\n1175\t  | \"challenges.active_campaigns\"\n1176\t  | \"challenges.active_challenges\"\n1177\t  | \"challenges.active_assignments\"\n1178\t  | \"challenges.completed_assignments_window\"\n1179\t  | \"challenges.bonus_completions_window\";\n1180\t\n1181\texport const PEEK_CHALLENGES_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekChallengesOverviewMetricId> =\n1182\t  [\n1183\t    \"challenges.active_campaigns\",\n1184\t    \"challenges.active_challenges\",\n1185\t    \"challenges.active_assignments\",\n1186\t    \"challenges.completed_assignments_window\",\n1187\t    \"challenges.bonus_completions_window\",\n1188\t  ];\n1189\t\n1190\texport type PeekChallengesOverview = {\n1191\t  generatedAt: string;\n1192\t  metrics: ReadonlyArray<PeekMetric>;\n1193\t};\n1194\t\n1195\t// --- Dogpile + fraud admin (FR-9) --------------------------------------------\n1196\t//\n1197\t// Browser-safe view models for the upcoming `/operations/dogpile` page and the\n1198\t// fraud-review surface. Reads two migration-011 tables in read-only mode (no\n1199\t// dogpile or fraud-flag editing — that lives behind the FR-14 mutation\n1200\t// framework, with `dogpile.cancel` and `fraud_flag.status.update` action ids\n1201\t// already declared in `peek/src/server/access-policy.ts`):\n1202\t//\n1203\t//   - dogpile_events       — scheduled / active / ended / cancelled lifecycle\n1204\t//     rows. Listed with the parent campaign (campaign_id is nullable so the\n1205\t//     join is a left join) plus per-event counts of `game_entries` and\n1206\t//     `point_grants` whose `created_at` falls within the dogpile window —\n1207\t//     these are the rows whose multiplier the worker applied (or would have\n1208\t//     applied), so they are the operator-readable \"linked\" set.\n1209\t//   - fraud_flags          — read-only review queue with status\n1210\t//     ('open' / 'reviewed' / 'dismissed'). Listed with `player_profiles` for\n1211\t//     username + wallet context. The JSONB `details` column is preserved\n1212\t//     verbatim so the operator can paste the full body into a paste bin.\n1213\t//\n1214\t// All bigint identity ids round-trip as `text` to preserve precision (FR-4).\n1215\t// Status values stay loosely typed (string) so the migration's CHECK\n1216\t// constraints remain the single source of truth — passing an unknown value\n1217\t// just returns no rows.\n1218\t\n1219\texport type PeekDogpileStatus =\n1220\t  | \"scheduled\"\n1221\t  | \"active\"\n1222\t  | \"ended\"\n1223\t  | \"cancelled\";\n1224\t\n1225\texport const PEEK_DOGPILE_STATUSES: ReadonlyArray<PeekDogpileStatus> = [\n1226\t  \"scheduled\",\n1227\t  \"active\",\n1228\t  \"ended\",\n1229\t  \"cancelled\",\n1230\t];\n1231\t\n1232\texport type PeekDogpileEventRow = {\n1233\t  id: string;\n1234\t  campaignId: string | null;\n1235\t  campaignName: string | null;\n1236\t  campaignType: string | null;\n1237\t  startsAt: string;\n1238\t  endsAt: string;\n1239\t  multiplier: string;\n1240\t  status: string;\n1241\t  createdAt: string;\n1242\t  gameEntryCount: number;\n1243\t  pointGrantCount: number;\n1244\t};\n1245\t\n1246\texport type PeekDogpileEventFilters = {\n1247\t  status: string | null;\n1248\t  startsFrom: string | null;\n1249\t  startsTo: string | null;\n1250\t};\n1251\t\n1252\texport type PeekFraudFlagListRow = {\n1253\t  id: string;\n1254\t  userId: string;\n1255\t  username: string | null;\n1256\t  wallet: string | null;\n1257\t  flagType: string;\n1258\t  status: string;\n1259\t  relatedId: string | null;\n1260\t  details: Record<string, unknown> | null;\n1261\t  createdAt: string;\n1262\t  resolvedAt: string | null;\n1263\t};\n1264\t\n1265\texport type PeekFraudFlagFilters = {\n1266\t  status: string | null;\n1267\t  userId: string | null;\n1268\t  flagType: string | null;\n1269\t  createdFrom: string | null;\n1270\t  createdTo: string | null;\n1271\t};\n1272\t\n1273\texport type PeekDogpileFraudOverviewMetricId =\n1274\t  | \"dogpile.scheduled\"\n1275\t  | \"dogpile.active\"\n1276\t  | \"dogpile.ended_window\"\n1277\t  | \"dogpile.cancelled_window\"\n1278\t  | \"fraud.open_flags\";\n1279\t\n1280\texport const PEEK_DOGPILE_FRAUD_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekDogpileFraudOverviewMetricId> =\n1281\t  [\n1282\t    \"dogpile.scheduled\",\n1283\t