{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018TtGLVAofs64dBs8hJ1JMT","type":"tool_result","content":"1\t// Query tests for the FR-9 dogpile + fraud admin reads\n2\t// (`get-dogpile-and-fraud.ts`).\n3\t//\n4\t// Mirrors the SQL-mock pattern used in `get-challenges.test.ts`,\n5\t// `get-rewards.test.ts`, and `get-points-and-crates.test.ts`: a tagged-template\n6\t// stub records each call (joined SQL text + bound values) and dequeues a\n7\t// per-call response so each test can assert which SQL fired, in what order,\n8\t// and with which clamps.\n9\t//\n10\t// Both surfaces (dogpile_events, fraud_flags) are read-only by spec — every\n11\t// dogpile or fraud-flag mutation lives behind the FR-14 `dogpile.cancel` and\n12\t// `fraud_flag.status.update` action ids, declared in\n13\t// `peek/src/server/access-policy.ts:154-159` but unimplemented. These tests\n14\t// guarantee the queries only emit SELECT statements and never INSERT / UPDATE\n15\t// / DELETE.\n16\t//\n17\t// State-transition coverage: every `PEEK_DOGPILE_STATUSES` value\n18\t// (scheduled / active / ended / cancelled) and every `fraud_flags.status`\n19\t// migration value (open / reviewed / dismissed) flows through to the SQL\n20\t// binding so the operator can scope the URL to a specific lifecycle state.\n21\t\n22\timport { describe, expect, it } from \"vitest\";\n23\timport type { Sql } from \"postgres\";\n24\timport {\n25\t  PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT,\n26\t  PEEK_DOGPILE_EVENTS_MAX_LIMIT,\n27\t  PEEK_DOGPILE_FRAUD_OVERVIEW_WINDOW_HOURS,\n28\t  PEEK_FRAUD_FLAGS_DEFAULT_LIMIT,\n29\t  PEEK_FRAUD_FLAGS_MAX_LIMIT,\n30\t  getDogpileFraudOverview,\n31\t  listDogpileEvents,\n32\t  listFraudFlags,\n33\t} from \"../get-dogpile-and-fraud\";\n34\timport {\n35\t  PEEK_DOGPILE_FRAUD_OVERVIEW_METRIC_IDS,\n36\t  PEEK_DOGPILE_STATUSES,\n37\t  type PeekDogpileFraudOverviewMetricId,\n38\t} from \"../../../../lib/types/peek\";\n39\t\n40\ttype SqlCall = {\n41\t  text: string;\n42\t  values: ReadonlyArray<unknown>;\n43\t};\n44\t\n45\ttype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n46\t\n47\ttype SqlMock = {\n48\t  sql: Sql;\n49\t  calls: ReadonlyArray<SqlCall>;\n50\t};\n51\t\n52\tfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n53\t  const calls: SqlCall[] = [];\n54\t  let cursor = 0;\n55\t\n56\t  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n57\t    const text = [...strings].join(\"?\");\n58\t    calls.push({ text, values: [...values] });\n59\t    const next = responses[cursor++];\n60\t    if (next instanceof Error) return Promise.reject(next);\n61\t    return Promise.resolve(next ?? []);\n62\t  };\n63\t\n64\t  const sql = fn as unknown as Sql;\n65\t  return { sql, calls };\n66\t}\n67\t\n68\tfunction expectReadOnly(call: SqlCall) {\n69\t  // Read-only guarantee: every dogpile + fraud query must be SELECT only.\n70\t  // FR-14 keeps every dogpile_events or fraud_flags write behind a mutation\n71\t  // action id, none of which are implemented yet.\n72\t  expect(call.text).not.toMatch(/\\binsert\\s+into\\b/i);\n73\t  expect(call.text).not.toMatch(/\\bupdate\\s+\\w/i);\n74\t  expect(call.text).not.toMatch(/\\bdelete\\s+from\\b/i);\n75\t  expect(call.text).toMatch(/\\bselect\\b/i);\n76\t}\n77\t\n78\tconst FRAUD_FLAG_STATUSES: ReadonlyArray<string> = [\n79\t  \"open\",\n80\t  \"reviewed\",\n81\t  \"dismissed\",\n82\t];\n83\t\n84\t// `getDogpileFraudOverview` runs five queries in parallel via Promise.all.\n85\tconst OVERVIEW_ORDER: ReadonlyArray<PeekDogpileFraudOverviewMetricId> = [\n86\t  \"dogpile.scheduled\",\n87\t  \"dogpile.active\",\n88\t  \"dogpile.ended_window\",\n89\t  \"dogpile.cancelled_window\",\n90\t  \"fraud.open_flags\",\n91\t];\n92\t\n93\tdescribe(\"listDogpileEvents\", () => {\n94\t  it(\"default limit: clamps to PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT and reads from dogpile_events with the campaigns left join\", async () => {\n95\t    const mock = createSqlMock([[]]);\n96\t    await listDogpileEvents({ sql: mock.sql });\n97\t\n98\t    expect(mock.calls).toHaveLength(1);\n99\t    const call = mock.calls[0];\n100\t    expectReadOnly(call);\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_011XHou3pWm96eV1HWw8J3vA","session_id":"6775cf18-4dba-4172-859b-2630d02f912a","uuid":"3a2a89af-16ae-418f-b528-8109505ca5a7","timestamp":"2026-04-26T06:43:46.002Z"}
