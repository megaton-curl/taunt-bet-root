.event_type asc\n      limit ${typeCountLimit}\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from event_queue eq\n      where eq.status in ('pending', 'processing', 'failed', 'dead')\n        and eq.attempts >= eq.max_attempts\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from event_queue eq\n      where eq.status = 'pending'\n        and eq.created_at <= ${agedPendingThresholdIso}::timestamptz\n    `,\n    sql<Array<{ id: string; value: number | string }>>`\n      select bucket.id as \"id\", count(eq.id)::int as \"value\"\n      from (values\n        ${\n          // The values list mirrors PEEK_EVENT_QUEUE_AGE_BUCKETS so a future\n          // bucket addition only requires touching the lib/types definition.\n          // postgres.js spreads the inner array into a comma-joined VALUES row\n          // tuple list when the templated value is an Array of Arrays.\n          sql(\n            ageBucketBoundaries.map((b) => [\n              b.id,\n              b.olderThanIso,\n              b.youngerThanIso,\n            ]),\n          )\n        }\n      ) as bucket(id, older_than, younger_than)\n      left join event_queue eq\n        on eq.created_at <= bucket.older_than::timestamptz\n        and (bucket.younger_than is null or eq.created_at > bucket.younger_than::timestamptz)\n      group by bucket.id\n    `,\n  ]);\n\n  // Status counts: project the migration's full status set so a missing status\n  // shows as a 0 row rather than silently disappearing.\n  const statusCountByValue = new Map<string, number>();\n  for (const row of statusRows) {\n    statusCountByValue.set(row.status, readInt(row.value));\n  }\n  const statusCounts: ReadonlyArray<PeekEventQueueStatusCount> =\n    PEEK_EVENT_QUEUE_STATUSES.map((status) => ({\n      status,\n      count: statusCountByValue.get(status) ?? 0,\n    }));\n\n  const typeCounts: ReadonlyArray<PeekEventQueueTypeCount>