{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KdXFjng1YUtifboEModbem","type":"tool_result","content":"1\t// KOL performance table for /growth/kol (FR-7).\n2\t//\n3\t// Reads `referral_kol_rates` joined with linked performance from\n4\t// `referral_links` + `referral_earnings`. Drill-down per row to user-detail.\n5\timport Link from \"next/link\";\n6\timport type { CSSProperties } from \"react\";\n7\timport type { PeekKolPerformanceRow } from \"../lib/types/peek\";\n8\t\n9\texport type GrowthKolTableProps = {\n10\t  rows: ReadonlyArray<PeekKolPerformanceRow>;\n11\t  error?: string | null;\n12\t};\n13\t\n14\texport function GrowthKolTable({ rows, error = null }: GrowthKolTableProps) {\n15\t  if (error) {\n16\t    return (\n17\t      <div role=\"alert\" style={errorStyle}>\n18\t        KOL table unavailable: {error}\n19\t      </div>\n20\t    );\n21\t  }\n22\t\n23\t  if (rows.length === 0) {\n24\t    return (\n25\t      <div role=\"status\" style={emptyStyle}>\n26\t        <p style={emptyTitleStyle}>No KOL rates configured.</p>\n27\t        <p style={emptyBodyStyle}>\n28\t          No rows in `referral_kol_rates` — KOL pricing has not been applied\n29\t          to any user yet.\n30\t        </p>\n31\t      </div>\n32\t    );\n33\t  }\n34\t\n35\t  return (\n36\t    <div style={wrapperStyle}>\n37\t      <table style={tableStyle}>\n38\t        <thead>\n39\t          <tr style={headerRowStyle}>\n40\t            <th style={headerCellStyle(\"left\")}>User</th>\n41\t            <th style={headerCellStyle(\"left\")}>Wallet</th>\n42\t            <th style={headerCellStyle(\"right\")}>Rate (bps)</th>\n43\t            <th style={headerCellStyle(\"left\")}>Set by</th>\n44\t            <th style={headerCellStyle(\"left\")}>Created</th>\n45\t            <th style={headerCellStyle(\"left\")}>Updated</th>\n46\t            <th style={headerCellStyle(\"right\")}>Referees</th>\n47\t            <th style={headerCellStyle(\"right\")}>Wager (lamports)</th>\n48\t            <th style={headerCellStyle(\"right\")}>Earned (lamports)</th>\n49\t          </tr>\n50\t        </thead>\n51\t        <tbody>\n52\t          {rows.map((row) => (\n53\t            <tr key={row.userId} style={bodyRowStyle}>\n54\t              <td style={bodyCellStyle(\"left\")}>\n55\t                <Link href={`/users/${row.userId}`} style={linkStyle}>\n56\t                  {row.username ?? row.userId}\n57\t                </Link>\n58\t                {row.username ? (\n59\t                  <span style={subValueStyle}> · {row.userId}</span>\n60\t                ) : null}\n61\t              </td>\n62\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n63\t                {row.wallet}\n64\t              </td>\n65\t              <td style={bodyCellStyle(\"right\")}>{row.rateBps}</td>\n66\t              <td style={bodyCellStyle(\"left\")}>{row.setBy}</td>\n67\t              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n68\t              <td style={bodyCellStyle(\"left\")}>{row.updatedAt}</td>\n69\t              <td style={bodyCellStyle(\"right\")}>{row.refereeCount}</td>\n70\t              <td style={bodyCellStyle(\"right\")}>\n71\t                {formatLamports(row.referredWagerLamports)}\n72\t              </td>\n73\t              <td style={bodyCellStyle(\"right\")}>\n74\t                {formatLamports(row.referrerEarnedLamports)}\n75\t              </td>\n76\t            </tr>\n77\t          ))}\n78\t        </tbody>\n79\t      </table>\n80\t    </div>\n81\t  );\n82\t}\n83\t\n84\tfunction formatLamports(value: string): string {\n85\t  if (!value || value === \"0\") return \"0\";\n86\t  const negative = value.startsWith(\"-\");\n87\t  const digits = negative ? value.slice(1) : value;\n88\t  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n89\t  return negative ? `-${grouped}` : grouped;\n90\t}\n91\t\n92\tconst wrapperStyle: CSSProperties = {\n93\t  overflowX: \"auto\",\n94\t  border: \"