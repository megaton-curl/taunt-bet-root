bel: \"Operations\", href: \"/operations/queue\" },\n  { id: \"audit\", label: \"Audit\", href: \"/audit\" },\n  { id: \"access\", label: \"Access\", href: \"/access\" },\n];\n\nconst BUSINESS_NAV_ITEMS: ReadonlyArray<AdminShellNavItem> = ALL_NAV_ITEMS.filter(\n  (item) => item.id !== \"audit\",\n);\n\ndescribe(\"AdminShell\", () => {\n  it(\"populated (admin): renders brand, every nav link, actor email, and the resolved role badge\", () => {\n    render(\n      <AdminShell\n        actor={{ email: \"alice@example.com\", role: \"admin\" }}\n        navItems={ALL_NAV_ITEMS}\n      >\n        <p>page content</p>\n      </AdminShell>,\n    );\n\n    expect(screen.getByText(\"Peek\")).toBeInTheDocument();\n\n    const nav = screen.getByRole(\"navigation\", { name: \"Primary\" });\n    const labels = within(nav)\n      .getAllByRole(\"link\")\n      .map((link) => link.textContent);\n    expect(labels).toEqual([\n      \"Users\",\n      \"Growth\",\n      \"Games\",\n      \"Economy\",\n      \"Operations\",\n      \"Audit\",\n      \"Access\",\n    ]);\n    expect(within(nav).getByRole(\"link\", { name: \"Audit\" })).toHaveAttribute(\n      \"href\",\n      \"/audit\",\n    );\n\n    const identity = screen.getByLabelText(\"Verified actor\");\n    expect(identity).toHaveTextContent(\"alice@example.com\");\n\n    const roleBadge = screen.getByLabelText(\"Resolved role: admin\");\n    expect(roleBadge).toHaveTextContent(\"admin\");\n    expect(roleBadge).toHaveAttribute(\"data-role\", \"admin\");\n\n    expect(screen.getByText(\"page content\")).toBeInTheDocument();\n  });\n\n  it(\"populated (business): hides Audit when caller did not include it in navItems\", () => {\n    render(\n      <AdminShell\n        actor={{ email: \"biz@example.com\", role: \"business\" }}\n        navItems={BUSINESS_NAV_ITEMS}\n      >\n        <p>page content</p>\n      </AdminShell>,\n    );\n\n    const nav = screen.getByRole(\"navigation\", { name: \"Primary\" });\n    const labels = withi