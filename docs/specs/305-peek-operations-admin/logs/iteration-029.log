{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AfCWGVPzj32rMJ9ctC2zph","type":"tool_result","content":"1\timport type { CSSProperties } from \"react\";\n2\timport { GrowthClaimsFilterBar } from \"../../../src/components/growth-claims-filter-bar\";\n3\timport { GrowthClaimsTable } from \"../../../src/components/growth-claims-table\";\n4\timport { GrowthReferrersTable } from \"../../../src/components/growth-referrers-table\";\n5\timport { MetricStrip } from \"../../../src/components/metric-strip\";\n6\timport { normalizeReferralClaimFiltersFromSearchParams } from \"../../../src/lib/growth-search-params\";\n7\timport type {\n8\t  PeekGrowthClaimRow,\n9\t  PeekGrowthOverview,\n10\t  PeekTopReferrerRow,\n11\t} from \"../../../src/lib/types/peek\";\n12\timport {\n13\t  getPeekActorContext,\n14\t  isRouteAllowedForRole,\n15\t} from \"../../../src/server/access-policy\";\n16\timport {\n17\t  getGrowthReferralOverview,\n18\t  listReferralClaims,\n19\t  listTopReferrers,\n20\t} from \"../../../src/server/db/queries/get-growth-referrals\";\n21\t\n22\texport const dynamic = \"force-dynamic\";\n23\t\n24\tconst ROUTE = \"/growth/referrals\";\n25\t\n26\texport default async function GrowthReferralsPage({\n27\t  searchParams,\n28\t}: {\n29\t  searchParams: Promise<Record<string, string | string[] | undefined>>;\n30\t}) {\n31\t  const actor = await getPeekActorContext();\n32\t  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n33\t\n34\t  if (!allowed) {\n35\t    return (\n36\t      <main style={mainStyle}>\n37\t        <header>\n38\t          <h1>Growth · Referrals</h1>\n39\t        </header>\n40\t        <p role=\"alert\" style={errorStyle}>\n41\t          You do not have access to this page.\n42\t        </p>\n43\t      </main>\n44\t    );\n45\t  }\n46\t\n47\t  const params = await searchParams;\n48\t  const filters = normalizeReferralClaimFiltersFromSearchParams(params);\n49\t\n50\t  let overview: PeekGrowthOverview = {\n51\t    gene