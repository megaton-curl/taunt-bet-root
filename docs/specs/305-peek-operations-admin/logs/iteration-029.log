ocument();\n    expect(screen.getByText(\"Updated\")).toBeInTheDocument();\n    expect(screen.getByText(\"Referees\")).toBeInTheDocument();\n    expect(screen.getByText(\"Wager (lamports)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Earned (lamports)\")).toBeInTheDocument();\n\n    // Drill-down per row.\n    expect(screen.getByRole(\"link\", { name: \"alice\" })).toHaveAttribute(\n      \"href\",\n      \"/users/u-1\",\n    );\n    // Username-less row falls back to userId as the link label.\n    expect(screen.getByRole(\"link\", { name: \"u-2\" })).toHaveAttribute(\n      \"href\",\n      \"/users/u-2\",\n    );\n\n    // KOL-side fields.\n    expect(screen.getByText(\"250\")).toBeInTheDocument();\n    expect(screen.getByText(\"100\")).toBeInTheDocument();\n    expect(screen.getAllByText(\"admin@example.com\").length).toBe(2);\n\n    // Performance numbers formatted with thousands separator; \"0\" stays bare.\n    expect(screen.getByText(\"8,000,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"200,000\")).toBeInTheDocument();\n  });\n\n  it(\"empty: renders a status block when no KOL rates have been configured\", () => {\n    render(<GrowthKolTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"No KOL rates configured.\");\n    expect(status).toHaveTextContent(\"referral_kol_rates\");\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert message and hides rows\", () => {\n    render(<GrowthKolTable rows={[ROW_KOL]} error=\"connection refused\" />);\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"KOL table unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
