{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01PkM2CrcC6sxWpyKR2QJrz7","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01XGg4ssY6CjUvxRodGrQiT4","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-growth-referrals.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_GROWTH_CLAIMS_DEFAULT_LIMIT,\n  PEEK_GROWTH_CLAIMS_MAX_LIMIT,\n  PEEK_GROWTH_KOL_DEFAULT_LIMIT,\n  PEEK_GROWTH_KOL_MAX_LIMIT,\n  PEEK_GROWTH_TOP_REFERRERS_DEFAULT_LIMIT,\n  PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT,\n  getGrowthReferralOverview,\n  getReferralGraphNode,\n  listKolPerformance,\n  listReferralClaims,\n  listTopReferrers,\n} from \"../get-growth-referrals\";\nimport {\n  PEEK_GROWTH_OVERVIEW_METRIC_IDS,\n  type PeekGrowthOverviewMetricId,\n} from \"../../../../lib/types/peek\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\n// SQL mock that tracks every tagged-template call and returns a queued\n// response per call (rows or an Error to reject). Mirrors the pattern used\n// in get-command-center-attention.test.ts so behaviour stays consistent\n// across query test modules.\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\n// Eight overview queries fire in parallel via Promise.all. Order:\n// 0 referrers, 1 referredUsers, 2 activatedReferred, 3 referrerEarnings,\n// 4 refereeRebates, 5 pendingClaimsLamports, 6 failedClaims, 7 kolCount.\nconst OVERVIEW_ORDER: ReadonlyArray<PeekGrowthOverviewMetricId> = [\n  \"growth.referrers\",\n  \"growth.referred_users\",\n  \"growth.activated_referred_users\",\n  \"growth.referrer_earnings_lamports\",\n  \"growth.referee_rebates_lamports\",\n  \"growth.pending_claims_lamports\",\n  \"growth.failed_claims\",\n  \"growth.kol_count\",\n];\n\ndescribe(\"getGrowthReferralOverview\", () => {\n  it(\"populated: emits one PeekMetric per FR-4 id with correct values, units, and bookkeeping\", async () => {\n    const mock = createSqlMock([\n      [{ value: 5 }],\n      [{ value: 12 }],\n      [{ value: 7 }],\n      [{ value: \"1500000000\" }],\n      [{ value: \"750000000\" }],\n      [{ value: \"300000000\" }],\n      [{ value: 2 }],\n      [{ value: 3 }],\n    ]);\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getGrowthReferralOverview({ sql: mock.sql, now });\n\n    expect(result.generatedAt).toBe(\"2026-04-25T10:00:00.000Z\");\n    expect(result.metrics).toHaveLength(8);\n    expect(result.metrics.map((m) => m.id)).toEqual(OVERVIEW_ORDER);\n    // Every advertised id from the type union is emitted.\n    for (const id of PEEK_GROWTH_OVERVIEW_METRIC_IDS) {\n      expect(result.metrics.find((m) => m.id === id)).toBeDefined();\n    }\n    for (const metric of result.metrics) {\n      expect(metric.asOf).toBe(\"2026-04-25T10:00:00.000Z\");\n      expect(metric.freshness).toBe(\"live\");\n      expect(metric.label.length).toBeGreaterThan(0);\n      expect(metric.definition.length).toBeGreaterThan(0);\n      expect(metric.source.length).toBeGreaterThan(0);\n      expect(metric.windowLabel.length).toBeGreaterThan(0);\n      expect(metric.drilldownHref).not.toBeNull();\n    }\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"growth.referrers\")?.value).toBe(5);\n    expect(byId.get(\"growth.referrers\")?.valueDisplay).toBe(\"5\");\n    expect(byId.get(\"growth.referrers\")?.unit).toBe(\"users\");\n    expect(byId.get(\"growth.referred_users\")?.value).toBe(12);\n    expect(byId.get(\"growth.activated_referred_users\")?.value).toBe(7);\n    expect(byId.get(\"growth.referrer_earnings_lamports\")?.value).toBe(\n      \"1500000000\",\n    );\n    expect(byId.get(\"growth.referrer_earnings_lamports\")?.valueDisplay).toBe(\n      \"1,500,000,000\",\n    );\n    expect(byId.get(\"growth.referrer_earnings_lamports\")?.unit).toBe(\n      \"lamports\",\n    );\n    expect(byId.get(\"growth.referee_rebates_lamports\")?.value).toBe(\n      \"750000000\",\n    );\n    expect(byId.get(\"growth.pending_claims_lamports\")?.value).toBe(\n      \"300000000\",\n    );\n    expect(byId.get(\"growth.pending_claims_lamports\")?.drilldownHref).toBe(\n      \"/growth/referrals?claimStatus=pending\",\n    );\n    expect(byId.get(\"growth.failed_claims\")?.value).toBe(2);\n    expect(byId.get(\"growth.failed_claims\")?.drilldownHref).toBe(\n      \"/growth/referrals?claimStatus=failed\",\n    );\n    expect(byId.get(\"growth.kol_count\")?.value).toBe(3);\n    expect(byId.get(\"growth.kol_count\")?.drilldownHref).toBe(\"/growth/kol\");\n  });\n\n  it(\"populated (large counts): formats valueDisplay with thousands separator\", async () => {\n    const mock = createSqlMock([\n      [{ value: 1234 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n    const result = await getGrowthReferralOverview({ sql: mock.sql });\n    const referrers = result.metrics.find((m) => m.id === \"growth.referrers\");\n    expect(referrers?.value).toBe(1234);\n    expect(referrers?.valueDisplay).toBe(\"1,234\");\n  });\n\n  it(\"sparse: every empty row coerces to a zero/0-string value without dropping the metric\", async () => {\n    const mock = createSqlMock([[], [], [], [], [], [], [], []]);\n\n    const result = await getGrowthReferralOverview({ sql: mock.sql });\n\n    expect(result.metrics).toHaveLength(8);\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"growth.referrers\")?.value).toBe(0);\n    expect(byId.get(\"growth.referrers\")?.valueDisplay).toBe(\"0\");\n    expect(byId.get(\"growth.referrer_earnings_lamports\")?.value).toBe(\"0\");\n    expect(byId.get(\"growth.referrer_earnings_lamports\")?.valueDisplay).toBe(\n      \"0\",\n    );\n    expect(byId.get(\"growth.failed_claims\")?.value).toBe(0);\n  });\n\n  it(\"string count coercion: a postgres ::text count converts to a number\", async () => {\n    const mock = createSqlMock([\n      [{ value: \"9\" }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n    ]);\n\n    const result = await getGrowthReferralOverview({ sql: mock.sql });\n    const referrers = result.metrics.find((m) => m.id === \"growth.referrers\");\n    expect(referrers?.value).toBe(9);\n  });\n\n  it(\"load-error: a rejected query propagates so the page can render the alert state\", async () => {\n    const mock = createSqlMock([\n      [{ value: 0 }],\n      new Error(\"connection refused\"),\n      [{ value: 0 }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n\n    await expect(\n      getGrowthReferralOverview({ sql: mock.sql }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n});\n\ndescribe(\"listTopReferrers\", () => {\n  it(\"default limit: clamps to PEEK_GROWTH_TOP_REFERRERS_DEFAULT_LIMIT and reads from referral_links\", async () => {\n    const mock = createSqlMock([[]]);\n    await listTopReferrers({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expect(call.text).toMatch(/from referral_links rl/i);\n    expect(call.text).toMatch(/left join player_profiles pp/i);\n    expect(call.text).toMatch(/left join referral_codes rc/i);\n    expect(call.text).toMatch(/left join \\(\\s*select distinct user_id from game_entries/i);\n    expect(call.values).toContain(PEEK_GROWTH_TOP_REFERRERS_DEFAULT_LIMIT);\n  });\n\n  it(\"explicit limit: passes the caller value through clampLimit\", async () => {\n    const mock = createSqlMock([[]]);\n    await listTopReferrers({ sql: mock.sql, limit: 10 });\n    expect(mock.calls[0].values).toContain(10);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listTopReferrers({\n      sql: mock.sql,\n      limit: PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT + 1000,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT);\n  });\n\n  it(\"non-positive limit clamps to 1\", async () => {\n    const mock = createSqlMock([[]]);\n    await listTopReferrers({ sql: mock.sql, limit: 0 });\n    expect(mock.calls[0].values).toContain(1);\n  });\n\n  it(\"populated: returns the rows the driver yields\", async () => {\n    const row = {\n      referrerUserId: \"u-1\",\n      username: \"alice\",\n      wallet: \"wallet-1\",\n      referralCode: \"ALICE\",\n      refereeCount: 4,\n      activeRefereeCount: 2,\n      referredWagerLamports: \"10000\",\n      referrerEarnedLamports: \"500\",\n      pendingClaimLamports: \"0\",\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listTopReferrers({ sql: mock.sql });\n    expect(rows).toEqual([row]);\n  });\n\n  it(\"empty: returns an empty array when no referrers exist\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listTopReferrers({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n});\n\ndescribe(\"listKolPerformance\", () => {\n  it(\"default limit + reads referral_kol_rates joined with performance aggregates\", async () => {\n    const mock = createSqlMock([[]]);\n    await listKolPerformance({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expect(call.text).toMatch(/from referral_kol_rates kol/i);\n    expect(call.text).toMatch(/left join player_profiles pp/i);\n    expect(call.text).toMatch(/from referral_links/i);\n    expect(call.text).toMatch(/from referral_earnings/i);\n    expect(call.values).toContain(PEEK_GROWTH_KOL_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listKolPerformance({\n      sql: mock.sql,\n      limit: PEEK_GROWTH_KOL_MAX_LIMIT + 1,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_GROWTH_KOL_MAX_LIMIT);\n  });\n\n  it(\"populated: returns the rows the driver yields\", async () => {\n    const row = {\n      userId: \"u-2\",\n      username: null,\n      wallet: \"wallet-2\",\n      rateBps: 250,\n      setBy: \"admin@example.com\",\n      createdAt: \"2026-04-01T00:00:00Z\",\n      updatedAt: \"2026-04-10T00:00:00Z\",\n      refereeCount: 0,\n      referredWagerLamports: \"0\",\n      referrerEarnedLamports: \"0\",\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listKolPerformance({ sql: mock.sql });\n    expect(rows).toEqual([row]);\n  });\n\n  it(\"empty: returns an empty array when no KOL rates configured\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listKolPerformance({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n});\n\ndescribe(\"listReferralClaims\", () => {\n  it(\"default limit and no filters: reads referral_claims with all skip-flags true\", async () => {\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expect(call.text).toMatch(/from referral_claims rc/i);\n    expect(call.text).toMatch(/left join player_profiles pp/i);\n    // status === null and isFailedAlias === false: see the (${status === null} or …) skip-flag template.\n    // The values array carries the skip-flags + the empty-fallback bound parameters.\n    expect(call.values).toContain(true); // status === null skip-flag\n    expect(call.values).toContain(false); // isFailedAlias\n    expect(call.values).toContain(PEEK_GROWTH_CLAIMS_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({\n      sql: mock.sql,\n      limit: PEEK_GROWTH_CLAIMS_MAX_LIMIT + 1,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_GROWTH_CLAIMS_MAX_LIMIT);\n  });\n\n  it(\"status filter (concrete value): passes the trimmed status through and is not the failed alias\", async () => {\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({\n      sql: mock.sql,\n      filters: { status: \"pending\" },\n    });\n    expect(mock.calls[0].values).toContain(\"pending\");\n  });\n\n  it(\"status filter ('failed'): widens via the failed-alias skip-flag\", async () => {\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({\n      sql: mock.sql,\n      filters: { status: \"failed\" },\n    });\n    // status='failed' triggers isFailedAlias=true; the SQL widens to ('failed','error').\n    expect(mock.calls[0].values).toContain(true); // isFailedAlias\n    // The status is still bound (template requires a concrete fallback param).\n    expect(mock.calls[0].values).toContain(\"failed\");\n  });\n\n  it(\"userId filter: trims whitespace + binds the user id\", async () => {\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({\n      sql: mock.sql,\n      filters: { userId: \"  u-1  \" },\n    });\n    expect(mock.calls[0].values).toContain(\"u-1\");\n  });\n\n  it(\"amount range filter: binds min and max separately as bigint-castable strings\", async () => {\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({\n      sql: mock.sql,\n      filters: {\n        minAmountLamports: \"1000\",\n        maxAmountLamports: \"5000\",\n      },\n    });\n    expect(mock.calls[0].values).toContain(\"1000\");\n    expect(mock.calls[0].values).toContain(\"5000\");\n  });\n\n  it(\"requestedFrom/To filter: binds both ISO timestamps\", async () => {\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({\n      sql: mock.sql,\n      filters: {\n        requestedFrom: \"2026-04-01\",\n        requestedTo: \"2026-04-25\",\n      },\n    });\n    expect(mock.calls[0].values).toContain(\"2026-04-01\");\n    expect(mock.calls[0].values).toContain(\"2026-04-25\");\n  });\n\n  it(\"txSignature filter: binds the exact signature\", async () => {\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({\n      sql: mock.sql,\n      filters: { txSignature: \"5VfYDnXUcS6mWY3cQy4ipcM5LQqM\" },\n    });\n    expect(mock.calls[0].values).toContain(\"5VfYDnXUcS6mWY3cQy4ipcM5LQqM\");\n  });\n\n  it(\"errorContains filter: wraps with %…% for ILIKE matching\", async () => {\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({\n      sql: mock.sql,\n      filters: { errorContains: \"timeout\" },\n    });\n    expect(mock.calls[0].values).toContain(\"%timeout%\");\n  });\n\n  it(\"populated: returns the rows the driver yields\", async () => {\n    const row = {\n      id: \"c-1\",\n      userId: \"u-1\",\n      username: \"alice\",\n      wallet: \"wallet-1\",\n      amountLamports: \"100\",\n      status: \"pending\",\n      retryCount: 0,\n      txSignature: null,\n      error: null,\n      requestedAt: \"2026-04-25T00:00:00Z\",\n      processedAt: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listReferralClaims({ sql: mock.sql });\n    expect(rows).toEqual([row]);\n  });\n\n  it(\"empty: returns an empty array when nothing matches the filter\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listReferralClaims({\n      sql: mock.sql,\n      filters: { status: \"completed\" },\n    });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"empty-string filter values normalise to no-filter (skip-flag true)\", async () => {\n    // The query module treats empty-after-trim filter strings as \"no filter\".\n    // The skip-flag template still records the boolean true regardless of how\n    // many filters are skipped, but no concrete user value gets bound for that\n    // dimension — they fall back to the placeholder default.\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({\n      sql: mock.sql,\n      filters: {\n        userId: \"\",\n        minAmountLamports: \"   \",\n        txSignature: \"\",\n        errorContains: \"\",\n      },\n    });\n    expect(mock.calls).toHaveLength(1);\n    // No user-id-shaped string is bound — the only string values bound are the\n    // fallback empties from `userId ?? \"\"` etc. The point is no SQL injection\n    // through unintended parameters.\n    expect(mock.calls[0].values).not.toContain(\"   \");\n  });\n});\n\ndescribe(\"getReferralGraphNode\", () => {\n  it(\"returns null when the user does not exist\", async () => {\n    const mock = createSqlMock([[], []]);\n    const result = await getReferralGraphNode(\"missing\", { sql: mock.sql });\n    expect(result).toBeNull();\n    // Only the centre query runs when the user is missing — referees query is skipped.\n    expect(mock.calls).toHaveLength(1);\n  });\n\n  it(\"populated: returns inbound referrer + outbound referees\", async () => {\n    const center = {\n      userId: \"u-1\",\n      username: \"alice\",\n      wallet: \"wallet-1\",\n      referralCode: \"ALICE\",\n      referrerUserId: \"u-0\",\n      referrerUsername: \"mentor\",\n      referrerWallet: \"wallet-0\",\n      referrerCode: \"MENTOR\",\n      linkedAt: \"2026-04-01T00:00:00Z\",\n    };\n    const referees = [\n      {\n        refereeUserId: \"u-2\",\n        refereeUsername: \"bob\",\n        refereeWallet: \"wallet-2\",\n        createdAt: \"2026-04-05T00:00:00Z\",\n      },\n    ];\n    const mock = createSqlMock([[center], referees]);\n\n    const result = await getReferralGraphNode(\"u-1\", { sql: mock.sql });\n\n    expect(result).not.toBeNull();\n    expect(result?.userId).toBe(\"u-1\");\n    expect(result?.username).toBe(\"alice\");\n    expect(result?.referralCode).toBe(\"ALICE\");\n    expect(result?.inboundReferrer).toEqual({\n      referrerUserId: \"u-0\",\n      referrerUsername: \"mentor\",\n      referrerWallet: \"wallet-0\",\n      referrerCode: \"MENTOR\",\n      linkedAt: \"2026-04-01T00:00:00Z\",\n    });\n    expect(result?.outboundReferees).toEqual(referees);\n  });\n\n  it(\"populated (no inbound + no outbound): inbound fields are null and referees are []\", async () => {\n    const center = {\n      userId: \"u-1\",\n      username: \"alice\",\n      wallet: \"wallet-1\",\n      referralCode: null,\n      referrerUserId: null,\n      referrerUsername: null,\n      referrerWallet: null,\n      referrerCode: null,\n      linkedAt: null,\n    };\n    const mock = createSqlMock([[center], []]);\n\n    const result = await getReferralGraphNode(\"u-1\", { sql: mock.sql });\n\n    expect(result?.inboundReferrer).toEqual({\n      referrerUserId: null,\n      referrerUsername: null,\n      referrerWallet: null,\n      referrerCode: null,\n      linkedAt: null,\n    });\n    expect(result?.outboundReferees).toEqual([]);\n  });\n\n  it(\"referee limit: clamps to default 200 when no override provided\", async () => {\n    const center = {\n      userId: \"u-1\",\n      username: \"alice\",\n      wallet: \"wallet-1\",\n      referralCode: null,\n      referrerUserId: null,\n      referrerUsername: null,\n      referrerWallet: null,\n      referrerCode: null,\n      linkedAt: null,\n    };\n    const mock = createSqlMock([[center], []]);\n    await getReferralGraphNode(\"u-1\", { sql: mock.sql });\n    // Second call (referees query) carries the limit binding.\n    expect(mock.calls).toHaveLength(2);\n    expect(mock.calls[1].values).toContain(200);\n  });\n\n  it(\"referee limit: clamps to MAX 1000 when caller asks for more\", async () => {\n    const center = {\n      userId: \"u-1\",\n      username: \"alice\",\n      wallet: \"wallet-1\",\n      referralCode: null,\n      referrerUserId: null,\n      referrerUsername: null,\n      referrerWallet: null,\n      referrerCode: null,\n      linkedAt: null,\n    };\n    const mock = createSqlMock([[center], []]);\n    await getReferralGraphNode(\"u-1\", { sql: mock.sql, refereeLimit: 5000 });\n    expect(mock.calls[1].values).toContain(1000);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1227,"cache_read_input_tokens":111052,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1227},"output_tokens":34,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"f014256d-9d47-4402-8be9-ca20fa6014a1","uuid":"99e2f7e5-33e4-42e7-b216-e5970ef14ce1"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XGg4ssY6CjUvxRodGrQiT4","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-growth-referrals.test.ts"}]},"parent_tool_use_id":null,"session_id":"f014256d-9d47-4402-8be9-ca20fa6014a1","uuid":"98a577f7-44a7-4e91-966d-9c1fd5e24e2d","timestamp":"2026-04-25T12:33:58.029Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-growth-referrals.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_GROWTH_CLAIMS_DEFAULT_LIMIT,\n  PEEK_GROWTH_CLAIMS_MAX_LIMIT,\n  PEEK_GROWTH_KOL_DEFAULT_LIMIT,\n  PEEK_GROWTH_KOL_MAX_LIMIT,\n  PEEK_GROWTH_TOP_REFERRERS_DEFAULT_LIMIT,\n  PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT,\n  getGrowthReferralOverview,\n  getReferralGraphNode,\n  listKolPerformance,\n  listReferralClaims,\n  listTopReferrers,\n} from \"../get-growth-referrals\";\nimport {\n  PEEK_GROWTH_OVERVIEW_METRIC_IDS,\n  type PeekGrowthOverviewMetricId,\n} from \"../../../../lib/types/peek\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\n// SQL mock that tracks every tagged-template call and returns a queued\n// response per call (rows or an Error to reject). Mirrors the pattern used\n// in get-command-center-attention.test.ts so behaviour stays consistent\n// across query test modules.\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\n// Eight overview queries fire in parallel via Promise.all. Order:\n// 0 referrers, 1 referredUsers, 2 activatedReferred, 3 referrerEarnings,\n// 4 refereeRebates, 5 pendingClaimsLamports, 6 failedClaims, 7 kolCount.\nconst OVERVIEW_ORDER: ReadonlyArray<PeekGrowthOverviewMetricId> = [\n  \"growth.referrers\",\n  \"growth.referred_users\",\n  \"growth.activated_referred_users\",\n  \"growth.referrer_earnings_lamports\",\n  \"growth.referee_rebates_lamports\",\n  \"growth.pending_claims_lamports\",\n  \"growth.failed_claims\",\n  \"growth.kol_count\",\n];\n\ndescribe(\"getGrowthReferralOverview\", () => {\n  it(\"populated: emits one PeekMetric per FR-4 id with correct values, units, and bookkeeping\", async () => {\n    const mock = createSqlMock([\n      [{ value: 5 }],\n      [{ value: 12 }],\n      [{ value: 7 }],\n      [{ value: \"1500000000\" }],\n      [{ value: \"750000000\" }],\n      [{ value: \"300000000\" }],\n      [{ value: 2 }],\n      [{ value: 3 }],\n    ]);\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getGrowthReferralOverview({ sql: mock.sql, now });\n\n    expect(result.generatedAt).toBe(\"2026-04-25T10:00:00.000Z\");\n    expect(result.metrics).toHaveLength(8);\n    expect(result.metrics.map((m) => m.id)).toEqual(OVERVIEW_ORDER);\n    // Every advertised id from the type union is emitted.\n    for (const id of PEEK_GROWTH_OVERVIEW_METRIC_IDS) {\n      expect(result.metrics.find((m) => m.id === id)).toBeDefined();\n    }\n    for (const metric of result.metrics) {\n      expect(metric.asOf).toBe(\"2026-04-25T10:00:00.000Z\");\n      expect(metric.freshness).toBe(\"live\");\n      expect(metric.label.length).toBeGreaterThan(0);\n      expect(metric.definition.length).toBeGreaterThan(0);\n      expect(metric.source.length).toBeGreaterThan(0);\n      expect(metric.windowLabel.length).toBeGreaterThan(0);\n      expect(metric.drilldownHref).not.toBeNull();\n    }\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"growth.referrers\")?.value).toBe(5);\n    expect(byId.get(\"growth.referrers\")?.valueDisplay).toBe(\"5\");\n    expect(byId.get(\"growth.referrers\")?.unit).toBe(\"users\");\n    expect(byId.get(\"growth.referred_users\")?.value).toBe(12);\n    expect(byId.get(\"growth.activated_referred_users\")?.value).toBe(7);\n    expect(byId.get(\"growth.referrer_earnings_lamports\")?.value).toBe(\n      \"1500000000\",\n    );\n    expect(byId.get(\"growth.referrer_earnings_lamports\")?.valueDisplay).toBe(\n      \"1,500,000,000\",\n    );\n    expect(byId.get(\"growth.referrer_earnings_lamports\")?.unit).toBe(\n      \"lamports\",\n    );\n    expect(byId.get(\"growth.referee_rebates_lamports\")?.value).toBe(\n      \"750000000\",\n    );\n    expect(byId.get(\"growth.pending_claims_lamports\")?.value).toBe(\n      \"300000000\",\n    );\n    expect(byId.get(\"growth.pending_claims_lamports\")?.drilldownHref).toBe(\n      \"/growth/referrals?claimStatus=pending\",\n    );\n    expect(byId.get(\"growth.failed_claims\")?.value).toBe(2);\n    expect(byId.get(\"growth.failed_claims\")?.drilldownHref).toBe(\n      \"/growth/referrals?claimStatus=failed\",\n    );\n    expect(byId.get(\"growth.kol_count\")?.value).toBe(3);\n    expect(byId.get(\"growth.kol_count\")?.drilldownHref).toBe(\"/growth/kol\");\n  });\n\n  it(\"populated (large counts): formats valueDisplay with thousands separator\", async () => {\n    const mock = createSqlMock([\n      [{ value: 1234 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n    const result = await getGrowthReferralOverview({ sql: mock.sql });\n    const referrers = result.metrics.find((m) => m.id === \"growth.referrers\");\n    expect(referrers?.value).toBe(1234);\n    expect(referrers?.valueDisplay).toBe(\"1,234\");\n  });\n\n  it(\"sparse: every empty row coerces to a zero/0-string value without dropping the metric\", async () => {\n    const mock = createSqlMock([[], [], [], [], [], [], [], []]);\n\n    const result = await getGrowthReferralOverview({ sql: mock.sql });\n\n    expect(result.metrics).toHaveLength(8);\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"growth.referrers\")?.value).toBe(0);\n    expect(byId.get(\"growth.referrers\")?.valueDisplay).toBe(\"0\");\n    expect(byId.get(\"growth.referrer_earnings_lamports\")?.value).toBe(\"0\");\n    expect(byId.get(\"growth.referrer_earnings_lamports\")?.valueDisplay).toBe(\n      \"0\",\n    );\n    expect(byId.get(\"growth.failed_claims\")?.value).toBe(0);\n  });\n\n  it(\"string count coercion: a postgres ::text count converts to a number\", async () => {\n    const mock = createSqlMock([\n      [{ value: \"9\" }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n    ]);\n\n    const result = await getGrowthReferralOverview({ sql: mock.sql });\n    const referrers = result.metrics.find((m) => m.id === \"growth.referrers\");\n    expect(referrers?.value).toBe(9);\n  });\n\n  it(\"load-error: a rejected query propagates so the page can render the alert state\", async () => {\n    const mock = createSqlMock([\n      [{ value: 0 }],\n      new Error(\"connection refused\"),\n      [{ value: 0 }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n      [{ value: \"0\" }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n\n    await expect(\n      getGrowthReferralOverview({ sql: mock.sql }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n});\n\ndescribe(\"listTopReferrers\", () => {\n  it(\"default limit: clamps to PEEK_GROWTH_TOP_REFERRERS_DEFAULT_LIMIT and reads from referral_links\", async () => {\n    const mock = createSqlMock([[]]);\n    await listTopReferrers({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expect(call.text).toMatch(/from referral_links rl/i);\n    expect(call.text).toMatch(/left join player_profiles pp/i);\n    expect(call.text).toMatch(/left join referral_codes rc/i);\n    expect(call.text).toMatch(/left join \\(\\s*select distinct user_id from game_entries/i);\n    expect(call.values).toContain(PEEK_GROWTH_TOP_REFERRERS_DEFAULT_LIMIT);\n  });\n\n  it(\"explicit limit: passes the caller value through clampLimit\", async () => {\n    const mock = createSqlMock([[]]);\n    await listTopReferrers({ sql: mock.sql, limit: 10 });\n    expect(mock.calls[0].values).toContain(10);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listTopReferrers({\n      sql: mock.sql,\n      limit: PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT + 1000,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT);\n  });\n\n  it(\"non-positive limit clamps to 1\", async () => {\n    const mock = createSqlMock([[]]);\n    await listTopReferrers({ sql: mock.sql, limit: 0 });\n    expect(mock.calls[0].values).toContain(1);\n  });\n\n  it(\"populated: returns the rows the driver yields\", async () => {\n    const row = {\n      referrerUserId: \"u-1\",\n      username: \"alice\",\n      wallet: \"wallet-1\",\n      referralCode: \"ALICE\",\n      refereeCount: 4,\n      activeRefereeCount: 2,\n      referredWagerLamports: \"10000\",\n      referrerEarnedLamports: \"500\",\n      pendingClaimLamports: \"0\",\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listTopReferrers({ sql: mock.sql });\n    expect(rows).toEqual([row]);\n  });\n\n  it(\"empty: returns an empty array when no referrers exist\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listTopReferrers({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n});\n\ndescribe(\"listKolPerformance\", () => {\n  it(\"default limit + reads referral_kol_rates joined with performance aggregates\", async () => {\n    const mock = createSqlMock([[]]);\n    await listKolPerformance({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expect(call.text).toMatch(/from referral_kol_rates kol/i);\n    expect(call.text).toMatch(/left join player_profiles pp/i);\n    expect(call.text).toMatch(/from referral_links/i);\n    expect(call.text).toMatch(/from referral_earnings/i);\n    expect(call.values).toContain(PEEK_GROWTH_KOL_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listKolPerformance({\n      sql: mock.sql,\n      limit: PEEK_GROWTH_KOL_MAX_LIMIT + 1,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_GROWTH_KOL_MAX_LIMIT);\n  });\n\n  it(\"populated: returns the rows the driver yields\", async () => {\n    const row = {\n      userId: \"u-2\",\n      username: null,\n      wallet: \"wallet-2\",\n      rateBps: 250,\n      setBy: \"admin@example.com\",\n      createdAt: \"2026-04-01T00:00:00Z\",\n      updatedAt: \"2026-04-10T00:00:00Z\",\n      refereeCount: 0,\n      referredWagerLamports: \"0\",\n      referrerEarnedLamports: \"0\",\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listKolPerformance({ sql: mock.sql });\n    expect(rows).toEqual([row]);\n  });\n\n  it(\"empty: returns an empty array when no KOL rates configured\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listKolPerformance({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n});\n\ndescribe(\"listReferralClaims\", () => {\n  it(\"default limit and no filters: reads referral_claims with all skip-flags true\", async () => {\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expect(call.text).toMatch(/from referral_claims rc/i);\n    expect(call.text).toMatch(/left join player_profiles pp/i);\n    // status === null and isFailedAlias === false: see the (${status === null} or …) skip-flag template.\n    // The values array carries the skip-flags + the empty-fallback bound parameters.\n    expect(call.values).toContain(true); // status === null skip-flag\n    expect(call.values).toContain(false); // isFailedAlias\n    expect(call.values).toContain(PEEK_GROWTH_CLAIMS_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({\n      sql: mock.sql,\n      limit: PEEK_GROWTH_CLAIMS_MAX_LIMIT + 1,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_GROWTH_CLAIMS_MAX_LIMIT);\n  });\n\n  it(\"status filter (concrete value): passes the trimmed status through and is not the failed alias\", async () => {\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({\n      sql: mock.sql,\n      filters: { status: \"pending\" },\n    });\n    expect(mock.calls[0].values).toContain(\"pending\");\n  });\n\n  it(\"status filter ('failed'): widens via the failed-alias skip-flag\", async () => {\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({\n      sql: mock.sql,\n      filters: { status: \"failed\" },\n    });\n    // status='failed' triggers isFailedAlias=true; the SQL widens to ('failed','error').\n    expect(mock.calls[0].values).toContain(true); // isFailedAlias\n    // The status is still bound (template requires a concrete fallback param).\n    expect(mock.calls[0].values).toContain(\"failed\");\n  });\n\n  it(\"userId filter: trims whitespace + binds the user id\", async () => {\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({\n      sql: mock.sql,\n      filters: { userId: \"  u-1  \" },\n    });\n    expect(mock.calls[0].values).toContain(\"u-1\");\n  });\n\n  it(\"amount range filter: binds min and max separately as bigint-castable strings\", async () => {\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({\n      sql: mock.sql,\n      filters: {\n        minAmountLamports: \"1000\",\n        maxAmountLamports: \"5000\",\n      },\n    });\n    expect(mock.calls[0].values).toContain(\"1000\");\n    expect(mock.calls[0].values).toContain(\"5000\");\n  });\n\n  it(\"requestedFrom/To filter: binds both ISO timestamps\", async () => {\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({\n      sql: mock.sql,\n      filters: {\n        requestedFrom: \"2026-04-01\",\n        requestedTo: \"2026-04-25\",\n      },\n    });\n    expect(mock.calls[0].values).toContain(\"2026-04-01\");\n    expect(mock.calls[0].values).toContain(\"2026-04-25\");\n  });\n\n  it(\"txSignature filter: binds the exact signature\", async () => {\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({\n      sql: mock.sql,\n      filters: { txSignature: \"5VfYDnXUcS6mWY3cQy4ipcM5LQqM\" },\n    });\n    expect(mock.calls[0].values).toContain(\"5VfYDnXUcS6mWY3cQy4ipcM5LQqM\");\n  });\n\n  it(\"errorContains filter: wraps with %…% for ILIKE matching\", async () => {\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({\n      sql: mock.sql,\n      filters: { errorContains: \"timeout\" },\n    });\n    expect(mock.calls[0].values).toContain(\"%timeout%\");\n  });\n\n  it(\"populated: returns the rows the driver yields\", async () => {\n    const row = {\n      id: \"c-1\",\n      userId: \"u-1\",\n      username: \"alice\",\n      wallet: \"wallet-1\",\n      amountLamports: \"100\",\n      status: \"pending\",\n      retryCount: 0,\n      txSignature: null,\n      error: null,\n      requestedAt: \"2026-04-25T00:00:00Z\",\n      processedAt: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listReferralClaims({ sql: mock.sql });\n    expect(rows).toEqual([row]);\n  });\n\n  it(\"empty: returns an empty array when nothing matches the filter\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listReferralClaims({\n      sql: mock.sql,\n      filters: { status: \"completed\" },\n    });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"empty-string filter values normalise to no-filter (skip-flag true)\", async () => {\n    // The query module treats empty-after-trim filter strings as \"no filter\".\n    // The skip-flag template still records the boolean true regardless of how\n    // many filters are skipped, but no concrete user value gets bound for that\n    // dimension — they fall back to the placeholder default.\n    const mock = createSqlMock([[]]);\n    await listReferralClaims({\n      sql: mock.sql,\n      filters: {\n        userId: \"\",\n        minAmountLamports: \"   \",\n        txSignature: \"\",\n        errorContains: \"\",\n      },\n    });\n    expect(mock.calls).toHaveLength(1);\n    // No user-id-shaped string is bound — the only string values bound are the\n    // fallback empties from `userId ?? \"\"` etc. The point is no SQL injection\n    // through unintended parameters.\n    expect(mock.calls[0].values).not.toContain(\"   \");\n  });\n});\n\ndescribe(\"getReferralGraphNode\", () => {\n  it(\"returns null when the user does not exist\", async () => {\n    const mock = createSqlMock([[], []]);\n    const result = await getReferralGraphNode(\"missing\", { sql: mock.sql });\n    expect(result).toBeNull();\n    // Only the centre query runs when the user is missing — referees query is skipped.\n    expect(mock.calls).toHaveLength(1);\n  });\n\n  it(\"populated: returns inbound referrer + outbound referees\", async () => {\n    const center = {\n      userId: \"u-1\",\n      username: \"alice\",\n      wallet: \"wallet-1\",\n      referralCode: \"ALICE\",\n      referrerUserId: \"u-0\",\n      referrerUsername: \"mentor\",\n      referrerWallet: \"wallet-0\",\n      referrerCode: \"MENTOR\",\n      linkedAt: \"2026-04-01T00:00:00Z\",\n    };\n    const referees = [\n      {\n        refereeUserId: \"u-2\",\n        refereeUsername: \"bob\",\n        refereeWallet: \"wallet-2\",\n        createdAt: \"2026-04-05T00:00:00Z\",\n      },\n    ];\n    const mock = createSqlMock([[center], referees]);\n\n    const result = await getReferralGraphNode(\"u-1\", { sql: mock.sql });\n\n    expect(result).not.toBeNull();\n    expect(result?.userId).toBe(\"u-1\");\n    expect(result?.username).toBe(\"alice\");\n    expect(result?.referralCode).toBe(\"ALICE\");\n    expect(result?.inboundReferrer).toEqual({\n      referrerUserId: \"u-0\",\n      referrerUsername: \"mentor\",\n      referrerWallet: \"wallet-0\",\n      referrerCode: \"MENTOR\",\n      linkedAt: \"2026-04-01T00:00:00Z\",\n    });\n    expect(result?.outboundReferees).toEqual(referees);\n  });\n\n  it(\"populated (no inbound + no outbound): inbound fields are null and referees are []\", async () => {\n    const center = {\n      userId: \"u-1\",\n      username: \"alice\",\n      wallet: \"wallet-1\",\n      referralCode: null,\n      referrerUserId: null,\n      referrerUsername: null,\n      referrerWallet: null,\n      referrerCode: null,\n      linkedAt: null,\n    };\n    const mock = createSqlMock([[center], []]);\n\n    const result = await getReferralGraphNode(\"u-1\", { sql: mock.sql });\n\n    expect(result?.inboundReferrer).toEqual({\n      referrerUserId: null,\n      referrerUsername: null,\n      referrerWallet: null,\n      referrerCode: null,\n      linkedAt: null,\n    });\n    expect(result?.outboundReferees).toEqual([]);\n  });\n\n  it(\"referee limit: clamps to default 200 when no override provided\", async () => {\n    const center = {\n      userId: \"u-1\",\n      username: \"alice\",\n      wallet: \"wallet-1\",\n      referralCode: null,\n      referrerUserId: null,\n      referrerUsername: null,\n      referrerWallet: null,\n      referrerCode: null,\n      linkedAt: null,\n    };\n    const mock = createSqlMock([[center], []]);\n    await getReferralGraphNode(\"u-1\", { sql: mock.sql });\n    // Second call (referees query) carries the limit binding.\n    expect(mock.calls).toHaveLength(2);\n    expect(mock.calls[1].values).toContain(200);\n  });\n\n  it(\"referee limit: clamps to MAX 1000 when caller asks for more\", async () => {\n    const center = {\n      userId: \"u-1\",\n      username: \"alice\",\n      wallet: \"wallet-1\",\n      referralCode: null,\n      referrerUserId: null,\n      referrerUsername: null,\n      referrerWallet: null,\n      referrerCode: null,\n      linkedAt: null,\n    };\n    const mock = createSqlMock([[center], []]);\n    await getReferralGraphNode(\"u-1\", { sql: mock.sql, refereeLimit: 5000 });\n    expect(mock.calls[1].values).toContain(1000);\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
