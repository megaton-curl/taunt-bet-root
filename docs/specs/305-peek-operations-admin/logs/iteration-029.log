der(\n      <GrowthClaimsTable rows={[ROW_PENDING, ROW_COMPLETED, ROW_FAILED]} />,\n    );\n\n    expect(screen.getByText(\"Requested\")).toBeInTheDocument();\n    expect(screen.getByText(\"User\")).toBeInTheDocument();\n    expect(screen.getByText(\"Wallet\")).toBeInTheDocument();\n    expect(screen.getByText(\"Amount (lamports)\")).toBeInTheDocument();\n    expect(screen.getByText(\"Status\")).toBeInTheDocument();\n    expect(screen.getByText(\"Retries\")).toBeInTheDocument();\n    expect(screen.getByText(\"Tx signature\")).toBeInTheDocument();\n    expect(screen.getByText(\"Processed\")).toBeInTheDocument();\n    expect(screen.getByText(\"Error\")).toBeInTheDocument();\n\n    // Drill-down per row, including userId fallback when username is null.\n    expect(screen.getByRole(\"link\", { name: \"alice\" })).toHaveAttribute(\n      \"href\",\n      \"/users/u-1\",\n    );\n    expect(screen.getByRole(\"link\", { name: \"u-2\" })).toHaveAttribute(\n      \"href\",\n      \"/users/u-2\",\n    );\n    expect(screen.getByRole(\"link\", { name: \"carol\" })).toHaveAttribute(\n      \"href\",\n      \"/users/u-3\",\n    );\n\n    // Lamport formatting.\n    expect(screen.getByText(\"100,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"5,000,000\")).toBeInTheDocument();\n    expect(screen.getByText(\"250,000\")).toBeInTheDocument();\n\n    // Status chips render the literal status text.\n    expect(screen.getByText(\"pending\")).toBeInTheDocument();\n    expect(screen.getByText(\"completed\")).toBeInTheDocument();\n    expect(screen.getByText(\"failed\")).toBeInTheDocument();\n\n    // Error column renders the failure message.\n    expect(screen.getByText(\"tx simulation failed\")).toBeInTheDocument();\n\n    // Tx signature column renders the signature for completed; the others get an em-dash.\n    expect(\n      screen.getByText(\"5VfYDnXUcS6mWY3cQy4ipcM5LQqM\"),\n    ).toBeInTheDocument();\n  });\n\n  it(\"empty: renders a status block telling the operator how to recover\", () => {\n    render(<GrowthClaimsTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"No claims match these filters.\");\n    expect(status).toHaveTextContent(\"Adjust the filters above\");\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert message and hides the rows\", () => {\n    render(<GrowthClaimsTable rows={[ROW_PENDING]} error=\"query timeout\" />);\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Claims unavailable: query timeout\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n\n  it(\"sparse: missing tx signature, processed_at, and error each render an em-dash\", () => {\n    render(<GrowthClaimsTable rows={[ROW_PENDING]} />);\n\n    // Three em-dash cells: tx signature, processed_at, error.\n    const dashes = screen.getAllByText(\"—\");\n    expect(dashes.length).toBeGreaterThanOrEqual(3);\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
