{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VWG5VYUk7KpNhkXAywkM9N","type":"tool_result","content":"540\texport const PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT = 5;\n541\texport const PEEK_SEARCH_MAX_PER_GROUP_LIMIT = 25;\n542\t\n543\t// --- Growth + referral admin (FR-7) ------------------------------------------\n544\t//\n545\t// Browser-safe view models for `/growth/referrals` and `/growth/kol`. The\n546\t// engine queries surface (a) overview metrics that fit the FR-4 metric\n547\t// bookkeeping, (b) top-referrer rows that combine `referral_links`,\n548\t// `referral_codes`, `referral_earnings`, and pending `referral_claims` per\n549\t// referrer, (c) KOL rows that join `referral_kol_rates` with linked\n550\t// performance from `referral_links`/`referral_earnings`, (d) claim rows for\n551\t// the filterable `/growth/referrals` claims table, and (e) a one-hop\n552\t// referral-graph node that lets the UI navigate from a user-detail page to\n553\t// the inbound referrer or any outbound referee and back.\n554\t//\n555\t// All numeric/precision-sensitive values arrive as `text` to preserve u64\n556\t// lamport precision; the UI formats at render time.\n557\t\n558\texport type PeekGrowthOverviewMetricId =\n559\t  | \"growth.referrers\"\n560\t  | \"growth.referred_users\"\n561\t  | \"growth.activated_referred_users\"\n562\t  | \"growth.referrer_earnings_lamports\"\n563\t  | \"growth.referee_rebates_lamports\"\n564\t  | \"growth.pending_claims_lamports\"\n565\t  | \"growth.failed_claims\"\n566\t  | \"growth.kol_count\";\n567\t\n568\texport const PEEK_GROWTH_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekGrowthOverviewMetricId> =\n569\t  [\n570\t    \"growth.referrers\",\n571\t    \"growth.referred_users\",\n572\t    \"growth.activated_referred_users\",\n573\t    \"growth.referrer_earnings_lamports\",\n574\t    \"growth.referee_rebates_lamports\",\n575\t    \"growth.pending_claims_lamports\",\n576\t    \"growth.failed_claims\",\n577\t    \"growth.kol_count\",\n578\t  ];\n579\t\n580\texport type PeekGrowthOverview = {\n581\t  generatedAt: string;\n582\t  metrics: ReadonlyArray<PeekMetric>;\n583\t};\n584\t\n585\texport type PeekTopReferrerRow = {\n586\t  referrerUserId: string;\n587\t  username: string | null;\n588\t  wallet: string;\n589\t  referralCode: string | null;\n590\t  refereeCount: number;\n591\t  activeRefereeCount: number;\n592\t  referredWagerLamports: string;\n593\t  referrerEarnedLamports: string;\n594\t  pendingClaimLamports: string;\n595\t};\n596\t\n597\texport type PeekKolPerformanceRow = {\n598\t  userId: string;\n599\t  username: string | null;\n600\t  wallet: string;\n601\t  rateBps: number;\n602\t  setBy: string;\n603\t  createdAt: string;\n604\t  updatedAt: string;\n605\t  refereeCount: number;\n606\t  referredWagerLamports: string;\n607\t  referrerEarnedLamports: string;\n608\t};\n609\t\n610\t// Status filter values mirror the migration check constraint:\n611\t// 'pending' | 'processing' | 'error' | 'completed' | 'failed'. Treated as a\n612\t// loose `string` here so the UI can pass through a \"failed_or_error\" virtual\n613\t// alias without a contract change. Extends the per-user\n614\t// `PeekReferralClaimRow` with the `userId`/`username`/`wallet` columns the\n615\t// /growth/referrals claims table needs to render and link rows back to user\n616\t// detail.\n617\texport type PeekGrowthClaimRow = PeekReferralClaimRow & {\n618\t  userId: string;\n619\t  username: string | null;\n620\t  wallet: string;\n621\t};\n622\t\n623\texport type PeekReferralClaimFilters = {\n624\t  status: string | null;\n625\t  userId: string | null;\n626\t  minAmountLamports: string | null;\n627\t  maxAmountLamports: string | null;\n628\t  requestedFrom: string | null;\n629\t  requestedTo: string | null;\n630\t  txSignature: string | null;\n631\t  errorContains: string | null;\n632\t};\n633\t\n634\texport type PeekReferralGraphRefereeRow = {\n635\t  refereeUserId: string;\n636\t  refereeUsername: string | null;\n637\