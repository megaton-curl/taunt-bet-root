{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JZEA1SvgdCWR1do7ZxFr1n","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport { render, screen, within } from \"@testing-library/react\";\n3\timport { PeekTable } from \"../peek-table\";\n4\timport type { PeekTableViewModel } from \"../../lib/types/peek\";\n5\t\n6\ttype Row = {\n7\t  id: string;\n8\t  href: string | null;\n9\t  username: string;\n10\t  refereeCount: number;\n11\t};\n12\t\n13\tfunction buildViewModel(rows: Row[]): PeekTableViewModel<Row> {\n14\t  return {\n15\t    columns: [\n16\t      { id: \"username\", label: \"Username\", align: \"left\", sortable: true },\n17\t      { id: \"refereeCount\", label: \"Referees\", align: \"right\", sortable: true },\n18\t      { id: \"joinedAt\", label: \"Joined\", align: \"left\", sortable: false },\n19\t    ],\n20\t    rows,\n21\t    pagination: { page: 1, pageSize: 25, totalCount: rows.length, totalPages: 1 },\n22\t    filters: [],\n23\t    sort: { column: \"refereeCount\", direction: \"desc\" },\n24\t    empty: {\n25\t      title: \"No users match these filters.\",\n26\t      body: \"Adjust filters or expand the date window to see more.\",\n27\t    },\n28\t  };\n29\t}\n30\t\n31\tdescribe(\"PeekTable\", () => {\n32\t  it(\"populated: renders columns, rows, sort indicator, and sortable header link\", () => {\n33\t    const viewModel = buildViewModel([\n34\t      { id: \"u_1\", href: \"/users/u_1\", username: \"alice\", refereeCount: 4 },\n35\t      { id: \"u_2\", href: null, username: \"bob\", refereeCount: 1 },\n36\t    ]);\n37\t\n38\t    render(\n39\t      <PeekTable\n40\t        viewModel={viewModel}\n41\t        renderCell={(row, columnId) => {\n42\t          if (columnId === \"username\") return row.username;\n43\t          if (columnId === \"refereeCount\") return row.refereeCount;\n44\t          return \"—\";\n45\t        }}\n46\t        buildSortHref={(columnId, direction) => `/?sort=${columnId}&direction=${direction}`}\n47\t      />,\n48\t    );\n49\t\n50\t    const usernameHeader = screen.getByRole(\"columnheader\", { name: /Username/ });\n51\t    const refereeHeader = screen.getByRole(\"columnheader\", { name: /Referees/ });\n52\t\n53\t    // Sortable headers render as links toggling next direction.\n54\t    const usernameLink = within(usernameHeader).getByRole(\"link\", { name: /Username/ });\n55\t    expect(usernameLink).toHaveAttribute(\"href\", \"/?sort=username&direction=desc\");\n56\t\n57\t    // Referees is currently sorted desc — clicking flips to asc.\n58\t    const refereeLink = within(refereeHeader).getByRole(\"link\", { name: /Referees/ });\n59\t    expect(refereeLink).toHaveAttribute(\"href\", \"/?sort=refereeCount&direction=asc\");\n60\t    expect(refereeHeader).toHaveAttribute(\"aria-sort\", \"descending\");\n61\t    expect(refereeHeader.textContent).toContain(\"▼\");\n62\t\n63\t    // Non-sortable header renders plain.\n64\t    const joinedHeader = screen.getByRole(\"columnheader\", { name: /Joined/ });\n65\t    expect(within(joinedHeader).queryByRole(\"link\")).toBeNull();\n66\t\n67\t    // Rows render via renderCell.\n68\t    expect(screen.getByText(\"alice\")).toBeInTheDocument();\n69\t    expect(screen.getByText(\"bob\")).toBeInTheDocument();\n70\t    expect(screen.getByText(\"4\")).toBeInTheDocument();\n71\t    expect(screen.getByText(\"1\")).toBeInTheDocument();\n72\t  });\n73\t\n74\t  it(\"sparse: renders empty state with operator copy when there are zero rows\", () => {\n75\t    const viewModel = buildViewModel([]);\n76\t\n77\t    render(<PeekTable viewModel={viewModel} renderCell={() => null} />);\n78\t\n79\t    const status = screen.getByRole(\"status\");\n80\t    expect(status).toHaveTextContent(\"No users match these filters.\");\n81\t    expect(status).toHaveTextContent(\"Adjust filters or expand the date window\");\n82\t    expect(screen.queryByRole(\"table\")).toBeNull();\n83\t  });\n84\t\n85\t  it(\"error: renders the error message instead of rows or empty state\", () => {\n86\t    const viewModel = buildViewModel([\n87\t      { id: \"u_1\", href: null, username: \"alice\", refereeCount: 1 },\n88\t    ]);\n89\t\n90\t    render(\n91\t      <PeekTable\n92\t        viewModel={viewModel}\n93\t        renderCell={() => \"should not render\"}\n94\t        error=\"connection refused\"\n95\t      />,\n96\t    );\n97\t\n98\t    expect(screen.getByRole(\"alert\")).toHaveTextContent(\"Data unavailable: connection refused\");\n99\t    expect(screen.queryByRole(\"table\")).toBeNull();\n100\t    expect(screen.queryByRole(\"status\")).toBeNull();\n101\t  });\n102\t});\n103\t"}]},"parent_tool_use_id":null,"session_id":"f014256d-9d47-4402-8be9-ca20fa6014a1","uuid":"e4c8b7c9-86be-4954-ad06-f434969a3de3","timestamp":"2026-04-25T12:31:28.746Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/peek-table.test.tsx","content":"import { describe, expect, it } from \"vitest\";\nimport { render, screen, within } from \"@testing-library/react\";\nimport { PeekTable } from \"../peek-table\";\nimport type { PeekTableViewModel } from \"../../lib/types/peek\";\n\ntype Row = {\n  id: string;\n  href: string | null;\n  username: string;\n  refereeCount: number;\n};\n\nfunction buildViewModel(rows: Row[]): PeekTableViewModel<Row> {\n  return {\n    columns: [\n      { id: \"username\", label: \"Username\", align: \"left\", sortable: true },\n      { id: \"refereeCount\", label: \"Referees\", align: \"right\", sortable: true },\n      { id: \"joinedAt\", label: \"Joined\", align: \"left\", sortable: false },\n    ],\n    rows,\n    pagination: { page: 1, pageSize: 25, totalCount: rows.length, totalPages: 1 },\n    filters: [],\n    sort: { column: \"refereeCount\", direction: \"desc\" },\n    empty: {\n      title: \"No users match these filters.\",\n      body: \"Adjust filters or expand the date window to see more.\",\n    },\n  };\n}\n\ndescribe(\"PeekTable\", () => {\n  it(\"populated: renders columns, rows, sort indicator, and sortable header link\", () => {\n    const viewModel = buildViewModel([\n      { id: \"u_1\", href: \"/users/u_1\", username: \"alice\", refereeCount: 4 },\n      { id: \"u_2\", href: null, username: \"bob\", refereeCount: 1 },\n    ]);\n\n    render(\n      <PeekTable\n        viewModel={viewModel}\n        renderCell={(row, columnId) => {\n          if (columnId === \"username\") return row.username;\n          if (columnId === \"refereeCount\") return row.refereeCount;\n          return \"—\";\n        }}\n        buildSortHref={(columnId, direction) => `/?sort=${columnId}&direction=${direction}`}\n      />,\n    );\n\n    const usernameHeader = screen.getByRole(\"columnheader\", { name: /Username/ });\n    const refereeHeader = screen.getByRole(\"columnheader\", { name: /Referees/ });\n\n    // Sortable headers render as links toggling next direction.\n    const usernameLink = within(usernameHeader).getByRole(\"link\", { name: /Username/ });\n    expect(usernameLink).toHaveAttribute(\"href\", \"/?sort=username&direction=desc\");\n\n    // Referees is currently sorted desc — clicking flips to asc.\n    const refereeLink = within(refereeHeader).getByRole(\"link\", { name: /Referees/ });\n    expect(refereeLink).toHaveAttribute(\"href\", \"/?sort=refereeCount&direction=asc\");\n    expect(refereeHeader).toHaveAttribute(\"aria-sort\", \"descending\");\n    expect(refereeHeader.textContent).toContain(\"▼\");\n\n    // Non-sortable header renders plain.\n    const joinedHeader = screen.getByRole(\"columnheader\", { name: /Joined/ });\n    expect(within(joinedHeader).queryByRole(\"link\")).toBeNull();\n\n    // Rows render via renderCell.\n    expect(screen.getByText(\"alice\")).toBeInTheDocument();\n    expect(screen.getByText(\"bob\")).toBeInTheDocument();\n    expect(screen.getByText(\"4\")).toBeInTheDocument();\n    expect(screen.getByText(\"1\")).toBeInTheDocument();\n  });\n\n  it(\"sparse: renders empty state with operator copy when there are zero rows\", () => {\n    const viewModel = buildViewModel([]);\n\n    render(<PeekTable viewModel={viewModel} renderCell={() => null} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"No users match these filters.\");\n    expect(status).toHaveTextContent(\"Adjust filters or expand the date window\");\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders the error message instead of rows or empty state\", () => {\n    const viewModel = buildViewModel([\n      { id: \"u_1\", href: null, username: \"alice\", refereeCount: 1 },\n    ]);\n\n    render(\n      <PeekTable\n        viewModel={viewModel}\n        renderCell={() => \"should not render\"}\n        error=\"connection refused\"\n      />,\n    );\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\"Data unavailable: connection refused\");\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n","numLines":103,"startLine":1,"totalLines":103}}}
