ers\n111\t        </h2>\n112\t        <p style={hintStyle}>\n113\t          Default 50 rows · sorted by referrer earnings · server-side capped at\n114\t          250.\n115\t        </p>\n116\t        <GrowthReferrersTable\n117\t          rows={topReferrers}\n118\t          error={topReferrersError}\n119\t        />\n120\t      </section>\n121\t\n122\t      <section\n123\t        aria-labelledby=\"claims-heading\"\n124\t        id=\"claims\"\n125\t        style={sectionStyle}\n126\t      >\n127\t        <h2 id=\"claims-heading\" style={sectionHeadingStyle}>\n128\t          Referral claims\n129\t        </h2>\n130\t        <p style={hintStyle}>\n131\t          Filterable by status, user, amount, requested date, tx signature, and\n132\t          error text. URL-addressable so internal investigations can be shared.\n133\t        </p>\n134\t        <GrowthClaimsFilterBar filters={filters} action={ROUTE} />\n135\t        <GrowthClaimsTable rows={claims} error={claimsError} />\n136\t      </section>\n137\t    </main>\n138\t  );\n139\t}\n140\t\n141\tconst mainStyle: CSSProperties = {\n142\t  display: \"grid\",\n143\t  gap: \"1.5rem\",\n144\t};\n145\t\n146\tconst sectionStyle: CSSProperties = {\n147\t  display: \"grid\",\n148\t  gap: \"0.75rem\",\n149\t};\n150\t\n151\tconst sectionHeadingStyle: CSSProperties = {\n152\t  margin: \"0 0 0.75rem\",\n153\t  fontSize: \"1rem\",\n154\t  fontWeight: 600,\n155\t  color: \"#cbd5f5\",\n156\t  textTransform: \"uppercase\",\n157\t  letterSpacing: \"0.05em\",\n158\t};\n159\t\n160\tconst leadStyle: CSSProperties = {\n161\t  margin: \"0.25rem 0 0\",\n162\t  color: \"#94a3b8\",\n163\t};\n164\t\n165\tconst hintStyle: CSSProperties = {\n166\t  margin: 0,\n167\t  color: \"#94a3b8\",\n168\t  fontSize: \"0.8125rem\",\n169\t};\n170\t\n171\tconst errorStyle: CSSProperties = {\n172\t  margin: 0,\n173\t  padding: \"0.75rem 1rem\",\n174\t  borderRadius: \"0.75rem\",\n175\t  background: \"#3f1d1d\",\n176\t  color: \"#fecaca\",\n177\t};\n178\t"}]},"pare