{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01GRPGX3ubNWjqMoDsaF81pt","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FmhFRvsjyrSdyoscDzagW3","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/db/queries/get-challenges.ts","content":"// Challenge engine admin queries (FR-9).\n//\n// Backs the upcoming `/economy/challenges` page. Reads six migration-011\n// tables in read-only mode (no challenge or campaign editing — that is\n// explicitly out of scope for FR-9 / FR-14):\n//\n//   - campaigns             — top-level container (daily / weekly /\n//     onboarding / dogpile). `listCampaigns` annotates each row with the\n//     count of associated challenges and active assignments so an operator\n//     can spot misconfigured or empty campaigns.\n//   - challenges            — challenge templates joined with the parent\n//     campaign for context. `listChallenges` supports optional campaignId +\n//     isActive filters.\n//   - challenge_assignments — per-player per-period assignments.\n//     `listChallengeAssignments` filters by userId / challengeId /\n//     campaignId / periodKey / status / assigned date and joins\n//     `player_profiles` + `challenges` + `campaigns` for context.\n//   - progress_events       — append-only progress ledger pinning a\n//     specific game round to an assignment for anti-gaming audit.\n//     `listProgressEvents` filters by assignmentId / challengeId / userId /\n//     roundId / created date.\n//   - completion_bonuses    — meta-quest definitions. `listCompletionBonuses`\n//     annotates each row with completion counts.\n//   - bonus_completions     — per-player per-period bonus completion ledger.\n//     `listBonusCompletions` filters by userId / bonusId / campaignId /\n//     periodKey / completed date.\n//\n// `getChallengesOverview` derives the FR-4 metric strip (active campaigns,\n// active challenges, active assignments, completed assignments and bonus\n// completions in a recent window) from these tables. All queries are bounded\n// server-side (default 100, max 500) and bigint identity ids round-trip as\n// `text` to preserve precision.\n\nimport type { Sql } from \"postgres\";\nimport {\n  type PeekBonusCompletionFilters,\n  type PeekBonusCompletionRow,\n  type PeekCampaignRow,\n  type PeekChallengeAssignmentFilters,\n  type PeekChallengeAssignmentRow,\n  type PeekChallengeFilters,\n  type PeekChallengeRow,\n  type PeekChallengesOverview,\n  type PeekChallengesOverviewMetricId,\n  type PeekCompletionBonusRow,\n  type PeekMetric,\n  type PeekProgressEventFilters,\n  type PeekProgressEventRow,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_CAMPAIGNS_DEFAULT_LIMIT = 100;\nexport const PEEK_CAMPAIGNS_MAX_LIMIT = 500;\nexport const PEEK_CHALLENGES_DEFAULT_LIMIT = 100;\nexport const PEEK_CHALLENGES_MAX_LIMIT = 500;\nexport const PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT = 100;\nexport const PEEK_CHALLENGE_ASSIGNMENTS_MAX_LIMIT = 500;\nexport const PEEK_PROGRESS_EVENTS_DEFAULT_LIMIT = 100;\nexport const PEEK_PROGRESS_EVENTS_MAX_LIMIT = 500;\nexport const PEEK_COMPLETION_BONUSES_DEFAULT_LIMIT = 100;\nexport const PEEK_COMPLETION_BONUSES_MAX_LIMIT = 500;\nexport const PEEK_BONUS_COMPLETIONS_DEFAULT_LIMIT = 100;\nexport const PEEK_BONUS_COMPLETIONS_MAX_LIMIT = 500;\nexport const PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS = 24;\n\nexport type ListCampaignsOptions = {\n  sql?: Sql;\n  limit?: number;\n};\n\nexport type ListChallengesOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekChallengeFilters>;\n};\n\nexport type ListChallengeAssignmentsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekChallengeAssignmentFilters>;\n};\n\nexport type ListProgressEventsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekProgressEventFilters>;\n};\n\nexport type ListCompletionBonusesOptions = {\n  sql?: Sql;\n  limit?: number;\n};\n\nexport type ListBonusCompletionsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekBonusCompletionFilters>;\n};\n\nexport type ChallengesOverviewOptions = {\n  sql?: Sql;\n  now?: Date;\n  windowHours?: number;\n};\n\nfunction clampLimit(\n  raw: number | undefined,\n  fallback: number,\n  max: number,\n): number {\n  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n  const floored = Math.floor(raw);\n  if (floored <= 0) return 1;\n  return Math.min(max, floored);\n}\n\nfunction trimOrNull(value: string | null | undefined): string | null {\n  if (typeof value !== \"string\") return null;\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nfunction readInt(value: number | string | null | undefined): number {\n  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n  if (typeof value === \"string\") {\n    const parsed = Number.parseInt(value, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\nfunction parseBoolFilter(value: string | null): boolean | null {\n  if (value === null) return null;\n  if (value === \"true\") return true;\n  if (value === \"false\") return false;\n  return null;\n}\n\nexport async function listCampaigns(\n  options: ListCampaignsOptions = {},\n): Promise<ReadonlyArray<PeekCampaignRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_CAMPAIGNS_DEFAULT_LIMIT,\n    PEEK_CAMPAIGNS_MAX_LIMIT,\n  );\n\n  const rows = await sql<\n    Array<{\n      id: string;\n      name: string;\n      campaignType: string;\n      startsAt: string | null;\n      endsAt: string | null;\n      isActive: boolean;\n      createdAt: string;\n      challengeCount: number | string;\n      activeAssignmentCount: number | string;\n    }>\n  >`\n    select\n      c.id::text as \"id\",\n      c.name as \"name\",\n      c.campaign_type as \"campaignType\",\n      c.starts_at::text as \"startsAt\",\n      c.ends_at::text as \"endsAt\",\n      c.is_active as \"isActive\",\n      c.created_at::text as \"createdAt\",\n      coalesce(ch_counts.challenge_count, 0)::int as \"challengeCount\",\n      coalesce(asg_counts.active_assignment_count, 0)::int as \"activeAssignmentCount\"\n    from campaigns c\n    left join (\n      select campaign_id, count(*) as challenge_count\n      from challenges\n      group by campaign_id\n    ) ch_counts on ch_counts.campaign_id = c.id\n    left join (\n      select ch.campaign_id, count(*) as active_assignment_count\n      from challenge_assignments ca\n      join challenges ch on ch.id = ca.challenge_id\n      where ca.status = 'active'\n      group by ch.campaign_id\n    ) asg_counts on asg_counts.campaign_id = c.id\n    order by c.is_active desc, c.created_at desc, c.id desc\n    limit ${limit}\n  `;\n\n  return rows.map((row) => ({\n    id: row.id,\n    name: row.name,\n    campaignType: row.campaignType,\n    startsAt: row.startsAt,\n    endsAt: row.endsAt,\n    isActive: row.isActive,\n    createdAt: row.createdAt,\n    challengeCount: readInt(row.challengeCount),\n    activeAssignmentCount: readInt(row.activeAssignmentCount),\n  }));\n}\n\nexport async function listChallenges(\n  options: ListChallengesOptions = {},\n): Promise<ReadonlyArray<PeekChallengeRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_CHALLENGES_DEFAULT_LIMIT,\n    PEEK_CHALLENGES_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const campaignId = trimOrNull(filters.campaignId ?? null);\n  const isActive = parseBoolFilter(trimOrNull(filters.isActive ?? null));\n\n  return sql<Array<PeekChallengeRow>>`\n    select\n      ch.id::text as \"id\",\n      ch.campaign_id::text as \"campaignId\",\n      c.name as \"campaignName\",\n      c.campaign_type as \"campaignType\",\n      ch.title as \"title\",\n      ch.description as \"description\",\n      ch.action as \"action\",\n      ch.scope as \"scope\",\n      ch.condition as \"condition\",\n      ch.threshold as \"threshold\",\n      ch.reward_type as \"rewardType\",\n      ch.reward_amount as \"rewardAmount\",\n      ch.prerequisite_id::text as \"prerequisiteId\",\n      ch.sort_order as \"sortOrder\",\n      ch.is_active as \"isActive\",\n      ch.created_at::text as \"createdAt\"\n    from challenges ch\n    left join campaigns c on c.id = ch.campaign_id\n    where\n      (${campaignId === null} or ch.campaign_id::text = ${campaignId ?? \"\"})\n      and (${isActive === null} or ch.is_active = ${isActive ?? false})\n    order by ch.campaign_id asc, ch.sort_order asc, ch.id asc\n    limit ${limit}\n  `;\n}\n\nexport async function listChallengeAssignments(\n  options: ListChallengeAssignmentsOptions = {},\n): Promise<ReadonlyArray<PeekChallengeAssignmentRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT,\n    PEEK_CHALLENGE_ASSIGNMENTS_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const userId = trimOrNull(filters.userId ?? null);\n  const challengeId = trimOrNull(filters.challengeId ?? null);\n  const campaignId = trimOrNull(filters.campaignId ?? null);\n  const periodKey = trimOrNull(filters.periodKey ?? null);\n  const status = trimOrNull(filters.status ?? null);\n  const assignedFrom = trimOrNull(filters.assignedFrom ?? null);\n  const assignedTo = trimOrNull(filters.assignedTo ?? null);\n\n  return sql<Array<PeekChallengeAssignmentRow>>`\n    select\n      ca.id::text as \"id\",\n      ca.user_id as \"userId\",\n      prof.username as \"username\",\n      ca.challenge_id::text as \"challengeId\",\n      ch.title as \"challengeTitle\",\n      ch.campaign_id::text as \"campaignId\",\n      c.name as \"campaignName\",\n      ca.period_key as \"periodKey\",\n      ca.status as \"status\",\n      ca.progress as \"progress\",\n      ca.target as \"target\",\n      ca.assigned_at::text as \"assignedAt\",\n      ca.expires_at::text as \"expiresAt\",\n      ca.completed_at::text as \"completedAt\"\n    from challenge_assignments ca\n    left join challenges ch on ch.id = ca.challenge_id\n    left join campaigns c on c.id = ch.campaign_id\n    left join player_profiles prof on prof.user_id = ca.user_id\n    where\n      (${userId === null} or ca.user_id = ${userId ?? \"\"})\n      and (${challengeId === null} or ca.challenge_id::text = ${challengeId ?? \"\"})\n      and (${campaignId === null} or ch.campaign_id::text = ${campaignId ?? \"\"})\n      and (${periodKey === null} or ca.period_key = ${periodKey ?? \"\"})\n      and (${status === null} or ca.status = ${status ?? \"\"})\n      and (${assignedFrom === null} or ca.assigned_at >= ${assignedFrom ?? \"\"}::timestamptz)\n      and (${assignedTo === null} or ca.assigned_at < ${assignedTo ?? \"\"}::timestamptz)\n    order by ca.assigned_at desc, ca.id desc\n    limit ${limit}\n  `;\n}\n\nexport async function listProgressEvents(\n  options: ListProgressEventsOptions = {},\n): Promise<ReadonlyArray<PeekProgressEventRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_PROGRESS_EVENTS_DEFAULT_LIMIT,\n    PEEK_PROGRESS_EVENTS_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const assignmentId = trimOrNull(filters.assignmentId ?? null);\n  const challengeId = trimOrNull(filters.challengeId ?? null);\n  const userId = trimOrNull(filters.userId ?? null);\n  const roundId = trimOrNull(filters.roundId ?? null);\n  const createdFrom = trimOrNull(filters.createdFrom ?? null);\n  const createdTo = trimOrNull(filters.createdTo ?? null);\n\n  return sql<Array<PeekProgressEventRow>>`\n    select\n      pe.id::text as \"id\",\n      pe.assignment_id::text as \"assignmentId\",\n      ca.challenge_id::text as \"challengeId\",\n      ch.title as \"challengeTitle\",\n      pe.round_id as \"roundId\",\n      pe.user_id as \"userId\",\n      prof.username as \"username\",\n      pe.progress_delta as \"progressDelta\",\n      pe.created_at::text as \"createdAt\"\n    from progress_events pe\n    left join challenge_assignments ca on ca.id = pe.assignment_id\n    left join challenges ch on ch.id = ca.challenge_id\n    left join player_profiles prof on prof.user_id = pe.user_id\n    where\n      (${assignmentId === null} or pe.assignment_id::text = ${assignmentId ?? \"\"})\n      and (${challengeId === null} or ca.challenge_id::text = ${challengeId ?? \"\"})\n      and (${userId === null} or pe.user_id = ${userId ?? \"\"})\n      and (${roundId === null} or pe.round_id = ${roundId ?? \"\"})\n      and (${createdFrom === null} or pe.created_at >= ${createdFrom ?? \"\"}::timestamptz)\n      and (${createdTo === null} or pe.created_at < ${createdTo ?? \"\"}::timestamptz)\n    order by pe.created_at desc, pe.id desc\n    limit ${limit}\n  `;\n}\n\nexport async function listCompletionBonuses(\n  options: ListCompletionBonusesOptions = {},\n): Promise<ReadonlyArray<PeekCompletionBonusRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_COMPLETION_BONUSES_DEFAULT_LIMIT,\n    PEEK_COMPLETION_BONUSES_MAX_LIMIT,\n  );\n\n  const rows = await sql<\n    Array<{\n      id: string;\n      campaignId: string;\n      campaignName: string | null;\n      campaignType: string | null;\n      title: string;\n      description: string | null;\n      requiredCount: number;\n      rewardType: string;\n      rewardAmount: number | null;\n      isActive: boolean;\n      createdAt: string;\n      completionCount: number | string;\n    }>\n  >`\n    select\n      cb.id::text as \"id\",\n      cb.campaign_id::text as \"campaignId\",\n      c.name as \"campaignName\",\n      c.campaign_type as \"campaignType\",\n      cb.title as \"title\",\n      cb.description as \"description\",\n      cb.required_count as \"requiredCount\",\n      cb.reward_type as \"rewardType\",\n      cb.reward_amount as \"rewardAmount\",\n      cb.is_active as \"isActive\",\n      cb.created_at::text as \"createdAt\",\n      coalesce(bc_counts.completion_count, 0)::int as \"completionCount\"\n    from completion_bonuses cb\n    left join campaigns c on c.id = cb.campaign_id\n    left join (\n      select bonus_id, count(*) as completion_count\n      from bonus_completions\n      group by bonus_id\n    ) bc_counts on bc_counts.bonus_id = cb.id\n    order by cb.is_active desc, cb.created_at desc, cb.id desc\n    limit ${limit}\n  `;\n\n  return rows.map((row) => ({\n    id: row.id,\n    campaignId: row.campaignId,\n    campaignName: row.campaignName,\n    campaignType: row.campaignType,\n    title: row.title,\n    description: row.description,\n    requiredCount: readInt(row.requiredCount),\n    rewardType: row.rewardType,\n    rewardAmount:\n      row.rewardAmount === null || row.rewardAmount === undefined\n        ? null\n        : readInt(row.rewardAmount),\n    isActive: row.isActive,\n    createdAt: row.createdAt,\n    completionCount: readInt(row.completionCount),\n  }));\n}\n\nexport async function listBonusCompletions(\n  options: ListBonusCompletionsOptions = {},\n): Promise<ReadonlyArray<PeekBonusCompletionRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_BONUS_COMPLETIONS_DEFAULT_LIMIT,\n    PEEK_BONUS_COMPLETIONS_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const userId = trimOrNull(filters.userId ?? null);\n  const bonusId = trimOrNull(filters.bonusId ?? null);\n  const campaignId = trimOrNull(filters.campaignId ?? null);\n  const periodKey = trimOrNull(filters.periodKey ?? null);\n  const completedFrom = trimOrNull(filters.completedFrom ?? null);\n  const completedTo = trimOrNull(filters.completedTo ?? null);\n\n  return sql<Array<PeekBonusCompletionRow>>`\n    select\n      bc.id::text as \"id\",\n      bc.user_id as \"userId\",\n      prof.username as \"username\",\n      bc.bonus_id::text as \"bonusId\",\n      cb.title as \"bonusTitle\",\n      cb.campaign_id::text as \"campaignId\",\n      c.name as \"campaignName\",\n      bc.period_key as \"periodKey\",\n      bc.completed_at::text as \"completedAt\"\n    from bonus_completions bc\n    left join completion_bonuses cb on cb.id = bc.bonus_id\n    left join campaigns c on c.id = cb.campaign_id\n    left join player_profiles prof on prof.user_id = bc.user_id\n    where\n      (${userId === null} or bc.user_id = ${userId ?? \"\"})\n      and (${bonusId === null} or bc.bonus_id::text = ${bonusId ?? \"\"})\n      and (${campaignId === null} or cb.campaign_id::text = ${campaignId ?? \"\"})\n      and (${periodKey === null} or bc.period_key = ${periodKey ?? \"\"})\n      and (${completedFrom === null} or bc.completed_at >= ${completedFrom ?? \"\"}::timestamptz)\n      and (${completedTo === null} or bc.completed_at < ${completedTo ?? \"\"}::timestamptz)\n    order by bc.completed_at desc, bc.id desc\n    limit ${limit}\n  `;\n}\n\ntype MetricBlueprint = {\n  id: PeekChallengesOverviewMetricId;\n  label: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  definition: string;\n  drilldownHref: string | null;\n};\n\nfunction buildMetric(\n  blueprint: MetricBlueprint,\n  raw: number,\n  display: string,\n  asOf: string,\n): PeekMetric {\n  return {\n    id: blueprint.id,\n    label: blueprint.label,\n    value: raw,\n    valueDisplay: display,\n    unit: blueprint.unit,\n    source: blueprint.source,\n    windowLabel: blueprint.windowLabel,\n    asOf,\n    definition: blueprint.definition,\n    freshness: \"live\",\n    drilldownHref: blueprint.drilldownHref,\n  };\n}\n\nexport async function getChallengesOverview(\n  options: ChallengesOverviewOptions = {},\n): Promise<PeekChallengesOverview> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n  const windowHours = clampLimit(\n    options.windowHours,\n    PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS,\n    24 * 30,\n  );\n  const since = new Date(now.getTime() - windowHours * 60 * 60 * 1000);\n  const sinceIso = since.toISOString();\n\n  const [\n    activeCampaignsRows,\n    activeChallengesRows,\n    activeAssignmentsRows,\n    completedAssignmentsRows,\n    bonusCompletionsRows,\n  ] = await Promise.all([\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from campaigns\n      where is_active = true\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from challenges\n      where is_active = true\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from challenge_assignments\n      where status = 'active'\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from challenge_assignments\n      where status = 'completed'\n        and completed_at is not null\n        and completed_at >= ${sinceIso}::timestamptz\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from bonus_completions\n      where completed_at >= ${sinceIso}::timestamptz\n    `,\n  ]);\n\n  const activeCampaigns = readInt(activeCampaignsRows[0]?.value ?? 0);\n  const activeChallenges = readInt(activeChallengesRows[0]?.value ?? 0);\n  const activeAssignments = readInt(activeAssignmentsRows[0]?.value ?? 0);\n  const completedAssignments = readInt(completedAssignmentsRows[0]?.value ?? 0);\n  const bonusCompletions = readInt(bonusCompletionsRows[0]?.value ?? 0);\n\n  const windowLabel = `Last ${windowHours}h`;\n\n  const blueprints: ReadonlyArray<{\n    blueprint: MetricBlueprint;\n    raw: number;\n    display: string;\n  }> = [\n    {\n      blueprint: {\n        id: \"challenges.active_campaigns\",\n        label: \"Active campaigns\",\n        unit: \"campaigns\",\n        source: \"campaigns\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of campaigns rows with is_active = true — the daily/weekly/onboarding/dogpile containers currently published.\",\n        drilldownHref: \"/economy/challenges#campaigns\",\n      },\n      raw: activeCampaigns,\n      display: formatCount(activeCampaigns),\n    },\n    {\n      blueprint: {\n        id: \"challenges.active_challenges\",\n        label: \"Active challenges\",\n        unit: \"challenges\",\n        source: \"challenges\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of challenges rows with is_active = true — challenge templates currently eligible for assignment.\",\n        drilldownHref: \"/economy/challenges#challenges\",\n      },\n      raw: activeChallenges,\n      display: formatCount(activeChallenges),\n    },\n    {\n      blueprint: {\n        id: \"challenges.active_assignments\",\n        label: \"Active assignments\",\n        unit: \"assignments\",\n        source: \"challenge_assignments\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of challenge_assignments rows with status = 'active' — per-player assignments still in progress.\",\n        drilldownHref: \"/economy/challenges?status=active#assignments\",\n      },\n      raw: activeAssignments,\n      display: formatCount(activeAssignments),\n    },\n    {\n      blueprint: {\n        id: \"challenges.completed_assignments_window\",\n        label: \"Completed assignments\",\n        unit: \"assignments\",\n        source: \"challenge_assignments\",\n        windowLabel,\n        definition: `Count of challenge_assignments rows with status = 'completed' and completed_at within the last ${windowHours} hours.`,\n        drilldownHref: \"/economy/challenges?status=completed#assignments\",\n      },\n      raw: completedAssignments,\n      display: formatCount(completedAssignments),\n    },\n    {\n      blueprint: {\n        id: \"challenges.bonus_completions_window\",\n        label: \"Bonus completions\",\n        unit: \"completions\",\n        source: \"bonus_completions\",\n        windowLabel,\n        definition: `Count of bonus_completions rows with completed_at within the last ${windowHours} hours — meta-quest payouts (e.g. complete-all-dailies bonus crate) recently awarded.`,\n        drilldownHref: \"/economy/challenges#bonus-completions\",\n      },\n      raw: bonusCompletions,\n      display: formatCount(bonusCompletions),\n    },\n  ];\n\n  return {\n    generatedAt,\n    metrics: blueprints.map(({ blueprint, raw, display }) =>\n      buildMetric(blueprint, raw, display, generatedAt),\n    ),\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2278,"cache_read_input_tokens":105372,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2278},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"46882648-0e9b-4738-9ccc-199f68b4eb3c","uuid":"cd920796-7451-4160-b1b9-d8aa81b97694"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FmhFRvsjyrSdyoscDzagW3","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/server/db/queries/get-challenges.ts"}]},"parent_tool_use_id":null,"session_id":"46882648-0e9b-4738-9ccc-199f68b4eb3c","uuid":"527402f1-65b0-48a9-8dcd-922dfba87b82","timestamp":"2026-04-26T05:59:32.061Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-challenges.ts","content":"// Challenge engine admin queries (FR-9).\n//\n// Backs the upcoming `/economy/challenges` page. Reads six migration-011\n// tables in read-only mode (no challenge or campaign editing — that is\n// explicitly out of scope for FR-9 / FR-14):\n//\n//   - campaigns             — top-level container (daily / weekly /\n//     onboarding / dogpile). `listCampaigns` annotates each row with the\n//     count of associated challenges and active assignments so an operator\n//     can spot misconfigured or empty campaigns.\n//   - challenges            — challenge templates joined with the parent\n//     campaign for context. `listChallenges` supports optional campaignId +\n//     isActive filters.\n//   - challenge_assignments — per-player per-period assignments.\n//     `listChallengeAssignments` filters by userId / challengeId /\n//     campaignId / periodKey / status / assigned date and joins\n//     `player_profiles` + `challenges` + `campaigns` for context.\n//   - progress_events       — append-only progress ledger pinning a\n//     specific game round to an assignment for anti-gaming audit.\n//     `listProgressEvents` filters by assignmentId / challengeId / userId /\n//     roundId / created date.\n//   - completion_bonuses    — meta-quest definitions. `listCompletionBonuses`\n//     annotates each row with completion counts.\n//   - bonus_completions     — per-player per-period bonus completion ledger.\n//     `listBonusCompletions` filters by userId / bonusId / campaignId /\n//     periodKey / completed date.\n//\n// `getChallengesOverview` derives the FR-4 metric strip (active campaigns,\n// active challenges, active assignments, completed assignments and bonus\n// completions in a recent window) from these tables. All queries are bounded\n// server-side (default 100, max 500) and bigint identity ids round-trip as\n// `text` to preserve precision.\n\nimport type { Sql } from \"postgres\";\nimport {\n  type PeekBonusCompletionFilters,\n  type PeekBonusCompletionRow,\n  type PeekCampaignRow,\n  type PeekChallengeAssignmentFilters,\n  type PeekChallengeAssignmentRow,\n  type PeekChallengeFilters,\n  type PeekChallengeRow,\n  type PeekChallengesOverview,\n  type PeekChallengesOverviewMetricId,\n  type PeekCompletionBonusRow,\n  type PeekMetric,\n  type PeekProgressEventFilters,\n  type PeekProgressEventRow,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_CAMPAIGNS_DEFAULT_LIMIT = 100;\nexport const PEEK_CAMPAIGNS_MAX_LIMIT = 500;\nexport const PEEK_CHALLENGES_DEFAULT_LIMIT = 100;\nexport const PEEK_CHALLENGES_MAX_LIMIT = 500;\nexport const PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT = 100;\nexport const PEEK_CHALLENGE_ASSIGNMENTS_MAX_LIMIT = 500;\nexport const PEEK_PROGRESS_EVENTS_DEFAULT_LIMIT = 100;\nexport const PEEK_PROGRESS_EVENTS_MAX_LIMIT = 500;\nexport const PEEK_COMPLETION_BONUSES_DEFAULT_LIMIT = 100;\nexport const PEEK_COMPLETION_BONUSES_MAX_LIMIT = 500;\nexport const PEEK_BONUS_COMPLETIONS_DEFAULT_LIMIT = 100;\nexport const PEEK_BONUS_COMPLETIONS_MAX_LIMIT = 500;\nexport const PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS = 24;\n\nexport type ListCampaignsOptions = {\n  sql?: Sql;\n  limit?: number;\n};\n\nexport type ListChallengesOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekChallengeFilters>;\n};\n\nexport type ListChallengeAssignmentsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekChallengeAssignmentFilters>;\n};\n\nexport type ListProgressEventsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekProgressEventFilters>;\n};\n\nexport type ListCompletionBonusesOptions = {\n  sql?: Sql;\n  limit?: number;\n};\n\nexport type ListBonusCompletionsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekBonusCompletionFilters>;\n};\n\nexport type ChallengesOverviewOptions = {\n  sql?: Sql;\n  now?: Date;\n  windowHours?: number;\n};\n\nfunction clampLimit(\n  raw: number | undefined,\n  fallback: number,\n  max: number,\n): number {\n  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n  const floored = Math.floor(raw);\n  if (floored <= 0) return 1;\n  return Math.min(max, floored);\n}\n\nfunction trimOrNull(value: string | null | undefined): string | null {\n  if (typeof value !== \"string\") return null;\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nfunction readInt(value: number | string | null | undefined): number {\n  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n  if (typeof value === \"string\") {\n    const parsed = Number.parseInt(value, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\nfunction parseBoolFilter(value: string | null): boolean | null {\n  if (value === null) return null;\n  if (value === \"true\") return true;\n  if (value === \"false\") return false;\n  return null;\n}\n\nexport async function listCampaigns(\n  options: ListCampaignsOptions = {},\n): Promise<ReadonlyArray<PeekCampaignRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_CAMPAIGNS_DEFAULT_LIMIT,\n    PEEK_CAMPAIGNS_MAX_LIMIT,\n  );\n\n  const rows = await sql<\n    Array<{\n      id: string;\n      name: string;\n      campaignType: string;\n      startsAt: string | null;\n      endsAt: string | null;\n      isActive: boolean;\n      createdAt: string;\n      challengeCount: number | string;\n      activeAssignmentCount: number | string;\n    }>\n  >`\n    select\n      c.id::text as \"id\",\n      c.name as \"name\",\n      c.campaign_type as \"campaignType\",\n      c.starts_at::text as \"startsAt\",\n      c.ends_at::text as \"endsAt\",\n      c.is_active as \"isActive\",\n      c.created_at::text as \"createdAt\",\n      coalesce(ch_counts.challenge_count, 0)::int as \"challengeCount\",\n      coalesce(asg_counts.active_assignment_count, 0)::int as \"activeAssignmentCount\"\n    from campaigns c\n    left join (\n      select campaign_id, count(*) as challenge_count\n      from challenges\n      group by campaign_id\n    ) ch_counts on ch_counts.campaign_id = c.id\n    left join (\n      select ch.campaign_id, count(*) as active_assignment_count\n      from challenge_assignments ca\n      join challenges ch on ch.id = ca.challenge_id\n      where ca.status = 'active'\n      group by ch.campaign_id\n    ) asg_counts on asg_counts.campaign_id = c.id\n    order by c.is_active desc, c.created_at desc, c.id desc\n    limit ${limit}\n  `;\n\n  return rows.map((row) => ({\n    id: row.id,\n    name: row.name,\n    campaignType: row.campaignType,\n    startsAt: row.startsAt,\n    endsAt: row.endsAt,\n    isActive: row.isActive,\n    createdAt: row.createdAt,\n    challengeCount: readInt(row.challengeCount),\n    activeAssignmentCount: readInt(row.activeAssignmentCount),\n  }));\n}\n\nexport async function listChallenges(\n  options: ListChallengesOptions = {},\n): Promise<ReadonlyArray<PeekChallengeRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_CHALLENGES_DEFAULT_LIMIT,\n    PEEK_CHALLENGES_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const campaignId = trimOrNull(filters.campaignId ?? null);\n  const isActive = parseBoolFilter(trimOrNull(filters.isActive ?? null));\n\n  return sql<Array<PeekChallengeRow>>`\n    select\n      ch.id::text as \"id\",\n      ch.campaign_id::text as \"campaignId\",\n      c.name as \"campaignName\",\n      c.campaign_type as \"campaignType\",\n      ch.title as \"title\",\n      ch.description as \"description\",\n      ch.action as \"action\",\n      ch.scope as \"scope\",\n      ch.condition as \"condition\",\n      ch.threshold as \"threshold\",\n      ch.reward_type as \"rewardType\",\n      ch.reward_amount as \"rewardAmount\",\n      ch.prerequisite_id::text as \"prerequisiteId\",\n      ch.sort_order as \"sortOrder\",\n      ch.is_active as \"isActive\",\n      ch.created_at::text as \"createdAt\"\n    from challenges ch\n    left join campaigns c on c.id = ch.campaign_id\n    where\n      (${campaignId === null} or ch.campaign_id::text = ${campaignId ?? \"\"})\n      and (${isActive === null} or ch.is_active = ${isActive ?? false})\n    order by ch.campaign_id asc, ch.sort_order asc, ch.id asc\n    limit ${limit}\n  `;\n}\n\nexport async function listChallengeAssignments(\n  options: ListChallengeAssignmentsOptions = {},\n): Promise<ReadonlyArray<PeekChallengeAssignmentRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT,\n    PEEK_CHALLENGE_ASSIGNMENTS_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const userId = trimOrNull(filters.userId ?? null);\n  const challengeId = trimOrNull(filters.challengeId ?? null);\n  const campaignId = trimOrNull(filters.campaignId ?? null);\n  const periodKey = trimOrNull(filters.periodKey ?? null);\n  const status = trimOrNull(filters.status ?? null);\n  const assignedFrom = trimOrNull(filters.assignedFrom ?? null);\n  const assignedTo = trimOrNull(filters.assignedTo ?? null);\n\n  return sql<Array<PeekChallengeAssignmentRow>>`\n    select\n      ca.id::text as \"id\",\n      ca.user_id as \"userId\",\n      prof.username as \"username\",\n      ca.challenge_id::text as \"challengeId\",\n      ch.title as \"challengeTitle\",\n      ch.campaign_id::text as \"campaignId\",\n      c.name as \"campaignName\",\n      ca.period_key as \"periodKey\",\n      ca.status as \"status\",\n      ca.progress as \"progress\",\n      ca.target as \"target\",\n      ca.assigned_at::text as \"assignedAt\",\n      ca.expires_at::text as \"expiresAt\",\n      ca.completed_at::text as \"completedAt\"\n    from challenge_assignments ca\n    left join challenges ch on ch.id = ca.challenge_id\n    left join campaigns c on c.id = ch.campaign_id\n    left join player_profiles prof on prof.user_id = ca.user_id\n    where\n      (${userId === null} or ca.user_id = ${userId ?? \"\"})\n      and (${challengeId === null} or ca.challenge_id::text = ${challengeId ?? \"\"})\n      and (${campaignId === null} or ch.campaign_id::text = ${campaignId ?? \"\"})\n      and (${periodKey === null} or ca.period_key = ${periodKey ?? \"\"})\n      and (${status === null} or ca.status = ${status ?? \"\"})\n      and (${assignedFrom === null} or ca.assigned_at >= ${assignedFrom ?? \"\"}::timestamptz)\n      and (${assignedTo === null} or ca.assigned_at < ${assignedTo ?? \"\"}::timestamptz)\n    order by ca.assigned_at desc, ca.id desc\n    limit ${limit}\n  `;\n}\n\nexport async function listProgressEvents(\n  options: ListProgressEventsOptions = {},\n): Promise<ReadonlyArray<PeekProgressEventRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_PROGRESS_EVENTS_DEFAULT_LIMIT,\n    PEEK_PROGRESS_EVENTS_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const assignmentId = trimOrNull(filters.assignmentId ?? null);\n  const challengeId = trimOrNull(filters.challengeId ?? null);\n  const userId = trimOrNull(filters.userId ?? null);\n  const roundId = trimOrNull(filters.roundId ?? null);\n  const createdFrom = trimOrNull(filters.createdFrom ?? null);\n  const createdTo = trimOrNull(filters.createdTo ?? null);\n\n  return sql<Array<PeekProgressEventRow>>`\n    select\n      pe.id::text as \"id\",\n      pe.assignment_id::text as \"assignmentId\",\n      ca.challenge_id::text as \"challengeId\",\n      ch.title as \"challengeTitle\",\n      pe.round_id as \"roundId\",\n      pe.user_id as \"userId\",\n      prof.username as \"username\",\n      pe.progress_delta as \"progressDelta\",\n      pe.created_at::text as \"createdAt\"\n    from progress_events pe\n    left join challenge_assignments ca on ca.id = pe.assignment_id\n    left join challenges ch on ch.id = ca.challenge_id\n    left join player_profiles prof on prof.user_id = pe.user_id\n    where\n      (${assignmentId === null} or pe.assignment_id::text = ${assignmentId ?? \"\"})\n      and (${challengeId === null} or ca.challenge_id::text = ${challengeId ?? \"\"})\n      and (${userId === null} or pe.user_id = ${userId ?? \"\"})\n      and (${roundId === null} or pe.round_id = ${roundId ?? \"\"})\n      and (${createdFrom === null} or pe.created_at >= ${createdFrom ?? \"\"}::timestamptz)\n      and (${createdTo === null} or pe.created_at < ${createdTo ?? \"\"}::timestamptz)\n    order by pe.created_at desc, pe.id desc\n    limit ${limit}\n  `;\n}\n\nexport async function listCompletionBonuses(\n  options: ListCompletionBonusesOptions = {},\n): Promise<ReadonlyArray<PeekCompletionBonusRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_COMPLETION_BONUSES_DEFAULT_LIMIT,\n    PEEK_COMPLETION_BONUSES_MAX_LIMIT,\n  );\n\n  const rows = await sql<\n    Array<{\n      id: string;\n      campaignId: string;\n      campaignName: string | null;\n      campaignType: string | null;\n      title: string;\n      description: string | null;\n      requiredCount: number;\n      rewardType: string;\n      rewardAmount: number | null;\n      isActive: boolean;\n      createdAt: string;\n      completionCount: number | string;\n    }>\n  >`\n    select\n      cb.id::text as \"id\",\n      cb.campaign_id::text as \"campaignId\",\n      c.name as \"campaignName\",\n      c.campaign_type as \"campaignType\",\n      cb.title as \"title\",\n      cb.description as \"description\",\n      cb.required_count as \"requiredCount\",\n      cb.reward_type as \"rewardType\",\n      cb.reward_amount as \"rewardAmount\",\n      cb.is_active as \"isActive\",\n      cb.created_at::text as \"createdAt\",\n      coalesce(bc_counts.completion_count, 0)::int as \"completionCount\"\n    from completion_bonuses cb\n    left join campaigns c on c.id = cb.campaign_id\n    left join (\n      select bonus_id, count(*) as completion_count\n      from bonus_completions\n      group by bonus_id\n    ) bc_counts on bc_counts.bonus_id = cb.id\n    order by cb.is_active desc, cb.created_at desc, cb.id desc\n    limit ${limit}\n  `;\n\n  return rows.map((row) => ({\n    id: row.id,\n    campaignId: row.campaignId,\n    campaignName: row.campaignName,\n    campaignType: row.campaignType,\n    title: row.title,\n    description: row.description,\n    requiredCount: readInt(row.requiredCount),\n    rewardType: row.rewardType,\n    rewardAmount:\n      row.rewardAmount === null || row.rewardAmount === undefined\n        ? null\n        : readInt(row.rewardAmount),\n    isActive: row.isActive,\n    createdAt: row.createdAt,\n    completionCount: readInt(row.completionCount),\n  }));\n}\n\nexport async function listBonusCompletions(\n  options: ListBonusCompletionsOptions = {},\n): Promise<ReadonlyArray<PeekBonusCompletionRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_BONUS_COMPLETIONS_DEFAULT_LIMIT,\n    PEEK_BONUS_COMPLETIONS_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const userId = trimOrNull(filters.userId ?? null);\n  const bonusId = trimOrNull(filters.bonusId ?? null);\n  const campaignId = trimOrNull(filters.campaignId ?? null);\n  const periodKey = trimOrNull(filters.periodKey ?? null);\n  const completedFrom = trimOrNull(filters.completedFrom ?? null);\n  const completedTo = trimOrNull(filters.completedTo ?? null);\n\n  return sql<Array<PeekBonusCompletionRow>>`\n    select\n      bc.id::text as \"id\",\n      bc.user_id as \"userId\",\n      prof.username as \"username\",\n      bc.bonus_id::text as \"bonusId\",\n      cb.title as \"bonusTitle\",\n      cb.campaign_id::text as \"campaignId\",\n      c.name as \"campaignName\",\n      bc.period_key as \"periodKey\",\n      bc.completed_at::text as \"completedAt\"\n    from bonus_completions bc\n    left join completion_bonuses cb on cb.id = bc.bonus_id\n    left join campaigns c on c.id = cb.campaign_id\n    left join player_profiles prof on prof.user_id = bc.user_id\n    where\n      (${userId === null} or bc.user_id = ${userId ?? \"\"})\n      and (${bonusId === null} or bc.bonus_id::text = ${bonusId ?? \"\"})\n      and (${campaignId === null} or cb.campaign_id::text = ${campaignId ?? \"\"})\n      and (${periodKey === null} or bc.period_key = ${periodKey ?? \"\"})\n      and (${completedFrom === null} or bc.completed_at >= ${completedFrom ?? \"\"}::timestamptz)\n      and (${completedTo === null} or bc.completed_at < ${completedTo ?? \"\"}::timestamptz)\n    order by bc.completed_at desc, bc.id desc\n    limit ${limit}\n  `;\n}\n\ntype MetricBlueprint = {\n  id: PeekChallengesOverviewMetricId;\n  label: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  definition: string;\n  drilldownHref: string | null;\n};\n\nfunction buildMetric(\n  blueprint: MetricBlueprint,\n  raw: number,\n  display: string,\n  asOf: string,\n): PeekMetric {\n  return {\n    id: blueprint.id,\n    label: blueprint.label,\n    value: raw,\n    valueDisplay: display,\n    unit: blueprint.unit,\n    source: blueprint.source,\n    windowLabel: blueprint.windowLabel,\n    asOf,\n    definition: blueprint.definition,\n    freshness: \"live\",\n    drilldownHref: blueprint.drilldownHref,\n  };\n}\n\nexport async function getChallengesOverview(\n  options: ChallengesOverviewOptions = {},\n): Promise<PeekChallengesOverview> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n  const windowHours = clampLimit(\n    options.windowHours,\n    PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS,\n    24 * 30,\n  );\n  const since = new Date(now.getTime() - windowHours * 60 * 60 * 1000);\n  const sinceIso = since.toISOString();\n\n  const [\n    activeCampaignsRows,\n    activeChallengesRows,\n    activeAssignmentsRows,\n    completedAssignmentsRows,\n    bonusCompletionsRows,\n  ] = await Promise.all([\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from campaigns\n      where is_active = true\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from challenges\n      where is_active = true\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from challenge_assignments\n      where status = 'active'\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from challenge_assignments\n      where status = 'completed'\n        and completed_at is not null\n        and completed_at >= ${sinceIso}::timestamptz\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from bonus_completions\n      where completed_at >= ${sinceIso}::timestamptz\n    `,\n  ]);\n\n  const activeCampaigns = readInt(activeCampaignsRows[0]?.value ?? 0);\n  const activeChallenges = readInt(activeChallengesRows[0]?.value ?? 0);\n  const activeAssignments = readInt(activeAssignmentsRows[0]?.value ?? 0);\n  const completedAssignments = readInt(completedAssignmentsRows[0]?.value ?? 0);\n  const bonusCompletions = readInt(bonusCompletionsRows[0]?.value ?? 0);\n\n  const windowLabel = `Last ${windowHours}h`;\n\n  const blueprints: ReadonlyArray<{\n    blueprint: MetricBlueprint;\n    raw: number;\n    display: string;\n  }> = [\n    {\n      blueprint: {\n        id: \"challenges.active_campaigns\",\n        label: \"Active campaigns\",\n        unit: \"campaigns\",\n        source: \"campaigns\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of campaigns rows with is_active = true — the daily/weekly/onboarding/dogpile containers currently published.\",\n        drilldownHref: \"/economy/challenges#campaigns\",\n      },\n      raw: activeCampaigns,\n      display: formatCount(activeCampaigns),\n    },\n    {\n      blueprint: {\n        id: \"challenges.active_challenges\",\n        label: \"Active challenges\",\n        unit: \"challenges\",\n        source: \"challenges\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of challenges rows with is_active = true — challenge templates currently eligible for assignment.\",\n        drilldownHref: \"/economy/challenges#challenges\",\n      },\n      raw: activeChallenges,\n      display: formatCount(activeChallenges),\n    },\n    {\n      blueprint: {\n        id: \"challenges.active_assignments\",\n        label: \"Active assignments\",\n        unit: \"assignments\",\n        source: \"challenge_assignments\",\n        windowLabel: \"Current\",\n        definition:\n          \"Count of challenge_assignments rows with status = 'active' — per-player assignments still in progress.\",\n        drilldownHref: \"/economy/challenges?status=active#assignments\",\n      },\n      raw: activeAssignments,\n      display: formatCount(activeAssignments),\n    },\n    {\n      blueprint: {\n        id: \"challenges.completed_assignments_window\",\n        label: \"Completed assignments\",\n        unit: \"assignments\",\n        source: \"challenge_assignments\",\n        windowLabel,\n        definition: `Count of challenge_assignments rows with status = 'completed' and completed_at within the last ${windowHours} hours.`,\n        drilldownHref: \"/economy/challenges?status=completed#assignments\",\n      },\n      raw: completedAssignments,\n      display: formatCount(completedAssignments),\n    },\n    {\n      blueprint: {\n        id: \"challenges.bonus_completions_window\",\n        label: \"Bonus completions\",\n        unit: \"completions\",\n        source: \"bonus_completions\",\n        windowLabel,\n        definition: `Count of bonus_completions rows with completed_at within the last ${windowHours} hours — meta-quest payouts (e.g. complete-all-dailies bonus crate) recently awarded.`,\n        drilldownHref: \"/economy/challenges#bonus-completions\",\n      },\n      raw: bonusCompletions,\n      display: formatCount(bonusCompletions),\n    },\n  ];\n\n  return {\n    generatedAt,\n    metrics: blueprints.map(({ blueprint, raw, display }) =>\n      buildMetric(blueprint, raw, display, generatedAt),\n    ),\n  };\n}\n","structuredPatch":[],"originalFile":null,"userModified":false}}
