{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GjBUUv76qeHUR1AkviEF2v","type":"tool_result","content":"913\texport type PeekRewardConfigExpectedType =\n914\t  | \"integer\"\n915\t  | \"float\"\n916\t  | \"ratio\"\n917\t  | \"lamports\"\n918\t  | \"unknown\";\n919\t\n920\texport type PeekRewardConfigRow = {\n921\t  key: string;\n922\t  value: string;\n923\t  updatedAt: string;\n924\t  definition: string | null;\n925\t  expectedType: PeekRewardConfigExpectedType;\n926\t};\n927\t\n928\texport type PeekRewardPool = {\n929\t  balanceLamports: string;\n930\t  lifetimeFunded: string;\n931\t  lifetimePaid: string;\n932\t  updatedAt: string;\n933\t};\n934\t\n935\texport type PeekRewardPoolFundingRow = {\n936\t  id: string;\n937\t  roundId: string;\n938\t  feeLamports: string;\n939\t  fundedLamports: string;\n940\t  createdAt: string;\n941\t};\n942\t\n943\texport type PeekRewardsOverviewMetricId =\n944\t  | \"rewards.balance_lamports\"\n945\t  | \"rewards.lifetime_funded_lamports\"\n946\t  | \"rewards.lifetime_paid_lamports\"\n947\t  | \"rewards.recent_fundings\";\n948\t\n949\texport const PEEK_REWARDS_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekRewardsOverviewMetricId> =\n950\t  [\n951\t    \"rewards.balance_lamports\",\n952\t    \"rewards.lifetime_funded_lamports\",\n953\t    \"rewards.lifetime_paid_lamports\",\n954\t    \"rewards.recent_fundings\",\n955\t  ];\n956\t\n957\texport type PeekRewardsOverview = {\n958\t  generatedAt: string;\n959\t  metrics: ReadonlyArray<PeekMetric>;\n960\t};\n961\t\n962\t// --- Points + crates ledger admin (FR-9) -------------------------------------\n963\t//\n964\t// Browser-safe view models for `/economy/points` and `/economy/crates`. Reads\n965\t// three migration-011 tables:\n966\t//\n967\t//   - player_points     — per-user points balance + lifetime earned, listed\n968\t//     across users and joined with `player_profiles` for username context.\n969\t//   - point_grants      — append-only point-grant ledger; the cross-user row\n970\t//     extends the per-user `PeekPointGrantRow` with the user identity columns\n971\t//     the operator-facing list needs.\n972\t//   - crate_drops       — per-user crate ledger with status (`pending`,\n973\t//     `granted`, `failed`); the cross-user row extends `PeekCrateDropRow` with\n974\t//     the same user identity columns.\n975\t//\n976\t// All bigint counters round-trip as `text` to preserve precision (FR-4). The\n977\t// status / type / source-type values are loosely typed (string) so the UI can\n978\t// pass through the same value the migration's CHECK constraints already\n979\t// enforce server-side without a second source of truth here.\n980\t\n981\texport type PeekPlayerPointsRow = {\n982\t  userId: string;\n983\t  username: string | null;\n984\t  wallet: string;\n985\t  balance: string;\n986\t  lifetimeEarned: string;\n987\t  updatedAt: string;\n988\t};\n989\t\n990\texport type PeekPlayerPointsFilters = {\n991\t  userId: string | null;\n992\t  wallet: string | null;"}]},"parent_tool_use_id":null,"session_id":"46882648-0e9b-4738-9ccc-199f68b4eb3c","uuid":"8e24f0f4-1beb-467f-9446-4df0a394358b","timestamp":"2026-04-26T05:57:57.309Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","content":"export type PeekRewardConfigExpectedType =\n  | \"integer\"\n  | \"float\"\n  | \"ratio\"\n  | \"lamports\"\n  | \"unknown\";\n\nexport type PeekRewardConfigRow = {\n  key: string;\n  value: string;\n  updatedAt: string;\n  definition: string | null;\n  expectedType: PeekRewardConfigExpectedType;\n};\n\nexport type PeekRewardPool = {\n  balanceLamports: string;\n  lifetimeFunded: string;\n  lifetimePaid: string;\n  updatedAt: string;\n};\n\nexport type PeekRewardPoolFundingRow = {\n  id: string;\n  roundId: string;\n  feeLamports: string;\n  fundedLamports: string;\n  createdAt: string;\n};\n\nexport type PeekRewardsOverviewMetricId =\n  | \"rewards.balance_lamports\"\n  | \"rewards.lifetime_funded_lamports\"\n  | \"rewards.lifetime_paid_lamports\"\n  | \"rewards.recent_fundings\";\n\nexport const PEEK_REWARDS_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekRewardsOverviewMetricId> =\n  [\n    \"rewards.balance_lamports\",\n    \"rewards.lifetime_funded_lamports\",\n    \"rewards.lifetime_paid_lamports\",\n    \"rewards.recent_fundings\",\n  ];\n\nexport type PeekRewardsOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};\n\n// --- Points + crates ledger admin (FR-9) -------------------------------------\n//\n// Browser-safe view models for `/economy/points` and `/economy/crates`. Reads\n// three migration-011 tables:\n//\n//   - player_points     — per-user points balance + lifetime earned, listed\n//     across users and joined with `player_profiles` for username context.\n//   - point_grants      — append-only point-grant ledger; the cross-user row\n//     extends the per-user `PeekPointGrantRow` with the user identity columns\n//     the operator-facing list needs.\n//   - crate_drops       — per-user crate ledger with status (`pending`,\n//     `granted`, `failed`); the cross-user row extends `PeekCrateDropRow` with\n//     the same user identity columns.\n//\n// All bigint counters round-trip as `text` to preserve precision (FR-4). The\n// status / type / source-type values are loosely typed (string) so the UI can\n// pass through the same value the migration's CHECK constraints already\n// enforce server-side without a second source of truth here.\n\nexport type PeekPlayerPointsRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  balance: string;\n  lifetimeEarned: string;\n  updatedAt: string;\n};\n\nexport type PeekPlayerPointsFilters = {\n  userId: string | null;\n  wallet: string | null;","numLines":80,"startLine":913,"totalLines":1027}}}
