earn\",\n54\t    label: \"Tug of Earn\",\n55\t    reason: \"Spec-only; awaiting persisted data source.\",\n56\t  },\n57\t];\n58\t\n59\texport default async function GamesOverviewPage() {\n60\t  const actor = await getPeekActorContext();\n61\t  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n62\t\n63\t  if (!allowed) {\n64\t    return (\n65\t      <main style={mainStyle}>\n66\t        <header>\n67\t          <h1>Games</h1>\n68\t        </header>\n69\t        <p role=\"alert\" style={errorStyle}>\n70\t          You do not have access to this page.\n71\t        </p>\n72\t      </main>\n73\t    );\n74\t  }\n75\t\n76\t  let overview: PeekGameOverview = {\n77\t    generatedAt: new Date().toISOString(),\n78\t    metrics: [],\n79\t    perGame: [],\n80\t  };\n81\t  let overviewError: string | null = null;\n82\t  let perGame: ReadonlyArray<PeekGameOverviewRow> = [];\n83\t\n84\t  try {\n85\t    overview = await getGamesOverview();\n86\t    perGame = overview.perGame;\n87\t  } catch (error) {\n88\t    overviewError =\n89\t      error instanceof Error\n90\t        ? error.message\n91\t        : \"Games overview could not be loaded.\";\n92\t  }\n93\t\n94\t  return (\n95\t    <main style={mainStyle}>\n96\t      <header>\n97\t        <h1>Games</h1>\n98\t        <p style={leadStyle}>\n99\t          Cross-game activity from `game_entries` across FlipYou, Pot Shot, and\n100\t          Close Call. Deferred games appear as documented placeholders until\n101\t          their persisted data sources land.\n102\t        </p>\n103\t      </header>\n104\t\n105\t      <section aria-labelledby=\"overview-heading\">\n106\t        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n107\t          Overview\n108\t        </h2>\n109\t        <MetricStrip metrics={overview.metrics} error={overviewError} />\n110\t      </section>\n111\t\n112\t      <section\n113\t        aria-labelledby=\"per-game-heading\"\n114\t        id=\"per-game\"\n115\t        style={sectionStyle}\n116\t      >\n117\t        <h2 id=\"per-game-heading\" style={sectionHeadingStyle}>\n118\t          Per-game activity\n119\t        </h2>\n120\t        <p style={hintStyle}>\n121\t          One row per active game · counters from `game_entries` · all-time.\n122\t        </p>\n123\t        <GamesOverviewTable rows={perGame} error={overviewError} />\n124\t      </section>\n125\t\n126\t      <section\n127\t        aria-labelledby=\"deferred-heading\"\n128\t        id=\"deferred\"\n129\t        style={sectionStyle}\n130\t      >\n131\t        <h2 id=\"deferred-heading\" style={sectionHeadingStyle}>\n132\t          Deferred games\n133\t        </h2>\n134\t        <p style={hintStyle}>\n135\t          Listed for visibility only; no persisted data source yet, so no\n136\t          counters are computed (System Invariant 13).\n137\t        </p>\n138\t        <ul style={deferredListStyle}>\n139\t          {DEFERRED_GAMES.map((game) => (\n140\t            <li key={game.id} style={deferredItemStyle}>\n141\t              <span style={deferredLabelStyle}>{game.label}</span>\n142\t              <span style={deferredReasonStyle}>{game.reason}</span>\n143\t            </li>\n144\t          ))}\n145\t        </ul>\n146\t      </section>\n147\t    </main>\n148\t  );\n149\t}\n150\t\n151\tconst mainStyle: CSSProperties = {\n152\t  display: \"grid\",\n153\t  gap: \"1.5rem\",\n154\t};\n155\t\n156\tconst sectionStyle: CSSProperties = {\n157\t  display: \"grid\",\n158\t  gap: \"0.75rem\",\n159\t};\n160\t\n161\tconst sectionHeadingStyle: CSSProperties = {\n162\t  margin: \"0 0 0.75rem\",\n163\t  fontSize: \"1rem\",\n164\t  fontWeight: 600,\n165\t  color: \"#cbd5f5\",\n166\t  textTransform: \"uppercase\",\n167\t  letterSpacing: \"0.05em\",\n168\t};\n169\t\n170\tconst leadStyle: CSSProperties = {\n171\t  margin: \"0.25rem 0 0\",\n172\t  color: \"#94a3b8\",\n173\t};\n174\t\n175\tconst hintStyle: CSSProperties = {\n176\t  margin: 0,\n177\t  color: \"#94a3b8\",\n178\t  fontSize: \"0.8125rem\",\n179\t};\n180\t\n181\tconst errorStyle: CSSProperties = {\n182\t  margin: 0,\n183\t  padding: \"0.75rem 1rem\",\n184\t  borderRadius: \"0.75rem\",\n185\t  background: \"#3f1d1d\",\n186\t  color: \"#fecaca\",\n187\t};\n188\t\n189\tconst deferredListStyle: CSSProperties = {\n190\t  margin: 0,\n191\t  padding: 0,\n192\t  listStyle: \"none\",\n193\t  display: \"grid\",\n194\t  gap: \"0.5rem\",\n195\t};\n196\t\n197\tconst deferredItemStyle: CSSProperties = {\n198\t  display: \"flex\",\n199\t  flexWrap: \"wrap\",\n200\t  alignItems: \"baseline\",\n201\t  gap: \"0.5rem\",\n202\t  padding: \"0.625rem 0.875rem\",\n203\t  borderRadius: \"0.5rem\",\n204\t  border: \"1px dashed #334155\",\n205\t  background: \"#0b1220\",\n206\t};\n207\t\n208\tconst deferredLabelStyle: CSSProperties = {\n209\t  fontWeight: 600,\n210\t  color: \"#cbd5f5\",\n211\t};\n212\t\n213\tconst deferredReasonStyle: CSSProperties = {\n214\t  color: \"#94a3b8\",\n215\t  fontSize: \"0.8125rem\",\n216\t};\n217\t"}]},"parent_tool_use_id":null,"session_id":"d8601274-731d-45e4-bbc0-4bd6247d591a","uuid":"602f51e3-0c7d-4737-b6b1-12ec256066be","timestamp":"2026-04-25T12:50:34.062Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/app/games/page.tsx","content":"// /games — cross-game activity overview (FR-8).\n//\n// Reads `getGamesOverview()` (iteration 30) and renders a 6-metric strip plus\n// the per-game `game_entries` counters table. Deferred games (Crash, Game of\n// Trades, Chart the Course, Slots Utopia, Tug of Earn) appear only as\n// documented placeholders per System Invariant 13: they have no persisted\n// source yet, so we do not fabricate empty data rows for them.\nimport type { CSSProperties } from \"react\";\nimport { GamesOverviewTable } from \"../../src/components/games-overview-table\";\nimport { MetricStrip } from \"../../src/components/metric-strip\";\nimport type {\n  PeekGameOverview,\n  PeekGameOverviewRow,\n} from \"../../src/lib/types/peek\";\nimport {\n  getPeekActorContext,\n  isRouteAllowedForRole,\n} from \"../../src/server/access-policy\";\nimport { getGamesOverview } from \"../../src/server/db/queries/get-games-overview\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst ROUTE = \"/games\";\n\ntype DeferredGame = {\n  id: string;\n  label: string;\n  reason: string;\n};\n\nconst DEFERRED_GAMES: ReadonlyArray<DeferredGame> = [\n  {\n    id: \"crash\",\n    label: \"Crash\",\n    reason: \"Phase-2 deferred; no persisted rounds table yet.\",\n  },\n  {\n    id: \"game_of_trades\",\n    label: \"Game of Trades\",\n    reason: \"Spec-only; awaiting persisted data source.\",\n  },\n  {\n    id: \"chart_the_course\",\n    label: \"Chart the Course\",\n    reason: \"Spec-only; awaiting persisted data source.\",\n  },\n  {\n    id: \"slots_utopia\",\n    label: \"Slots Utopia\",\n    reason: \"Spec-only; awaiting persisted data source.\",\n  },\n  {\n    id: \"tug_of_earn\",\n    label: \"Tug of Earn\",\n    reason: \"Spec-only; awaiting persisted data source.\",\n  },\n];\n\nexport default async function GamesOverviewPage() {\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n\n  if (!allowed) {\n    return (\n      <main style={mainStyle}>\n        <header>\n          <h1>Games</h1>\n        </header>\n        <p role=\"alert\" style={errorStyle}>\n          You do not have access to this page.\n        </p>\n      </main>\n    );\n  }\n\n  let overview: PeekGameOverview = {\n    generatedAt: new Date().toISOString(),\n    metrics: [],\n    perGame: [],\n  };\n  let overviewError: string | null = null;\n  let perGame: ReadonlyArray<PeekGameOverviewRow> = [];\n\n  try {\n    overview = await getGamesOverview();\n    perGame = overview.perGame;\n  } catch (error) {\n    overviewError =\n      error instanceof Error\n        ? error.message\n        : \"Games overview could not be loaded.\";\n  }\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <h1>Games</h1>\n        <p style={leadStyle}>\n          Cross-game activity from `game_entries` across FlipYou, Pot Shot, and\n          Close Call. Deferred games appear as documented placeholders until\n          their persisted data sources land.\n        </p>\n      </header>\n\n      <section aria-labelledby=\"overview-heading\">\n        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n          Overview\n        </h2>\n        <MetricStrip metrics={overview.metrics} error={overviewError} />\n      </section>\n\n      <section\n        aria-labelledby=\"per-game-heading\"\n        id=\"per-game\"\n        style={sectionStyle}\n      >\n        <h2 id=\"per-game-heading\" style={sectionHeadingStyle}>\n          Per-game activity\n        </h2>\n        <p style={hintStyle}>\n          One row per active game · counters from `game_entries` · all-time.\n        </p>\n        <GamesOverviewTable rows={perGame} error={overviewError} />\n      </section>\n\n      <section\n        aria-labelledby=\"deferred-heading\"\n        id=\"deferred\"\n        style={sectionStyle}\n      >\n        <h2 id=\"deferred-heading\" style={sectionHeadingStyle}>\n          Deferred games\n        </h2>\n        <p style={hintStyle}>\n          Listed for visibility only; no persisted data source yet, so no\n          counters are computed (System Invariant 13).\n        </p>\n        <ul style={deferredListStyle}>\n          {DEFERRED_GAMES.map((game) => (\n            <li key={game.id} style={deferredItemStyle}>\n              <span style={deferredLabelStyle}>{game.label}</span>\n              <span style={deferredReasonStyle}>{game.reason}</span>\n            </li>\n          ))}\n        </ul>\n      </section>\n    </main>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst deferredListStyle: CSSProperties = {\n  margin: 0,\n  padding: 0,\n  listStyle: \"none\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst deferredItemStyle: CSSProperties = {\n  display: \"flex\",\n  flexWrap: \"wrap\",\n  alignItems: \"baseline\",\n  gap: \"0.5rem\",\n  padding: \"0.625rem 0.875rem\",\n  borderRadius: \"0.5rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n};\n\nconst deferredLabelStyle: CSSProperties = {\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n};\n\nconst deferredReasonStyle: CSSProperties = {\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n","numLines":217,"startLine":1,"totalLines":217}}}
