aveTextContent(\n      \"Top referrers unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n\n  it(\"populated: shows the userId sub-label only when username is present\", () => {\n    render(<GrowthReferrersTable rows={[ROW_ALICE, ROW_NO_USERNAME]} />);\n\n    const aliceRow = screen.getByRole(\"link\", { name: \"alice\" }).closest(\"tr\")!;\n    expect(within(aliceRow).getByText(/u-1/)).toBeInTheDocument();\n\n    const fallbackRow = screen\n      .getByRole(\"link\", { name: \"u-2\" })\n      .closest(\"tr\")!;\n    // The id is the link label itself; no separate sub-label should follow.\n    expect(within(fallbackRow).queryByText(/· u-2/)).toBeNull();\n  });\n});\n","numLines":99,"startLine":1,"totalLines":99}}}
