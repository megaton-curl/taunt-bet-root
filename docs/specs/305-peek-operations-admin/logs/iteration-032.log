{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017cHpQ2mEofWNUqNg4t58cd","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport { render, screen, within } from \"@testing-library/react\";\n3\timport { GrowthReferrersTable } from \"../growth-referrers-table\";\n4\timport type { PeekTopReferrerRow } from \"../../lib/types/peek\";\n5\t\n6\tconst ROW_ALICE: PeekTopReferrerRow = {\n7\t  referrerUserId: \"u-1\",\n8\t  username: \"alice\",\n9\t  wallet: \"wallet-1\",\n10\t  referralCode: \"ALICE\",\n11\t  refereeCount: 4,\n12\t  activeRefereeCount: 2,\n13\t  referredWagerLamports: \"1500000\",\n14\t  referrerEarnedLamports: \"75000\",\n15\t  pendingClaimLamports: \"0\",\n16\t};\n17\t\n18\tconst ROW_NO_USERNAME: PeekTopReferrerRow = {\n19\t  referrerUserId: \"u-2\",\n20\t  username: null,\n21\t  wallet: \"wallet-2\",\n22\t  referralCode: null,\n23\t  refereeCount: 1,\n24\t  activeRefereeCount: 0,\n25\t  referredWagerLamports: \"0\",\n26\t  referrerEarnedLamports: \"0\",\n27\t  pendingClaimLamports: \"0\",\n28\t};\n29\t\n30\tdescribe(\"GrowthReferrersTable\", () => {\n31\t  it(\"populated: renders the operator columns, drill-down link, formatted lamports, and row data\", () => {\n32\t    render(<GrowthReferrersTable rows={[ROW_ALICE, ROW_NO_USERNAME]} />);\n33\t\n34\t    expect(screen.getByText(\"Referrer\")).toBeInTheDocument();\n35\t    expect(screen.getByText(\"Code\")).toBeInTheDocument();\n36\t    expect(screen.getByText(\"Wallet\")).toBeInTheDocument();\n37\t    expect(screen.getByText(\"Referees\")).toBeInTheDocument();\n38\t    expect(screen.getByText(\"Active\")).toBeInTheDocument();\n39\t    expect(screen.getByText(\"Wager (lamports)\")).toBeInTheDocument();\n40\t    expect(screen.getByText(\"Earned (lamports)\")).toBeInTheDocument();\n41\t    expect(screen.getByText(\"Pending claim (lamports)\")).toBeInTheDocument();\n42\t\n43\t    // Drill-down link per row.\n44\t    const aliceLink = screen.getByRole(\"link\", { name: \"alice\" });\n45\t    expect(aliceLink).toHaveAttribute(\"href\", \"/users/u-1\");\n46\t\n47\t    // Username-less row falls back to userId as the link label.\n48\t    const fallbackLink = screen.getByRole(\"link\", { name: \"u-2\" });\n49\t    expect(fallbackLink).toHaveAttribute(\"href\", \"/users/u-2\");\n50\t\n51\t    // Lamport formatting groups thousands; \"0\" stays bare.\n52\t    expect(screen.getByText(\"1,500,000\")).toBeInTheDocument();\n53\t    expect(screen.getByText(\"75,000\")).toBeInTheDocument();\n54\t\n55\t    // Wallet renders verbatim.\n56\t    expect(screen.getByText(\"wallet-1\")).toBeInTheDocument();\n57\t    expect(screen.getByText(\"wallet-2\")).toBeInTheDocument();\n58\t\n59\t    // Missing referral code renders an em-dash.\n60\t    const codeCells = screen.getAllByText(\"—\");\n61\t    expect(codeCells.length).toBeGreaterThan(0);\n62\t  });\n63\t\n64\t  it(\"empty: renders a status block explaining that referral_links is empty\", () => {\n65\t    render(<GrowthReferrersTable rows={[]} />);\n66\t\n67\t    const status = screen.getByRole(\"status\");\n68\t    expect(status).toHaveTextContent(\"No referrers yet.\");\n69\t    expect(status).toHaveTextContent(\"referral_links\");\n70\t    expect(screen.queryByRole(\"table\")).toBeNull();\n71\t  });\n72\t\n73\t  it(\"error: renders an alert with the error message and suppresses the table + empty state\", () => {\n74\t    render(\n75\t      <GrowthReferrersTable rows={[ROW_ALICE]} error=\"connection refused\" />,\n76\t    );\n77\t\n78\t    const alert = screen.getByRole(\"alert\");\n79\t    expect(alert).toHaveTextContent(\n80\t      \"Top referrers unavailable: connection refused\",\n81\t    );\n82\t    expect(screen.queryByRole(\"table\")).toBeNull();\n83\t    expect(screen.queryByRole(\"status\")).toBeNull();\n84\t  });\n85\t\n86\t  it(\"populated: shows the userId sub-label only when username is present\", () => {\n87\t    render(<GrowthReferrersTable rows={[ROW_ALICE, 