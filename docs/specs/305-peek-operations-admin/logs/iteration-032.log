(6);\n    const emittedIds = result.metrics.map((m) => m.id);\n    expect(emittedIds).toEqual([...PEEK_GAME_OVERVIEW_METRIC_IDS]);\n    for (const metric of result.metrics) {\n      expect(metric.asOf).toBe(\"2026-04-25T12:00:00.000Z\");\n      expect(metric.freshness).toBe(\"live\");\n      expect(metric.label.length).toBeGreaterThan(0);\n      expect(metric.definition.length).toBeGreaterThan(0);\n      expect(metric.source).toBe(\"game_entries\");\n      expect(metric.windowLabel).toBe(\"All time\");\n      expect(metric.drilldownHref).toBe(\"/games\");\n    }\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"games.total_entries\")?.value).toBe(27);\n    expect(byId.get(\"games.total_entries\")?.valueDisplay).toBe(\"27\");\n\n    // Unique-players metric reads the platform-wide DISTINCT count, NOT the\n    // sum of per-game distincts (would double-count cross-game players).\n    expect(byId.get(\"games.unique_users\")?.value).toBe(14);\n    expect(byId.get(\"games.unique_users\")?.valueDisplay).toBe(\"14\");\n\n    // Lamport totals: BigInt sum across games preserves u64 precision and\n    // displays with thousands separators.\n    expect(byId.get(\"games.wagered_lamports\")?.value).toBe(\"7500000000\");\n    expect(byId.get(\"games.wagered_lamports\")?.valueDisplay).toBe(\n      \"7,500,000,000\",\n    );\n    expect(byId.get(\"games.payout_lamports\")?.value).toBe(\"5900000000\");\n    expect(byId.get(\"games.payout_lamports\")?.valueDisplay).toBe(\n      \"5,900,000,000\",\n    );\n    expect(byId.get(\"games.settled_entries\")?.value).toBe(24);\n    expect(byId.get(\"games.refund_entries\")?.value).toBe(3);\n    expect(byId.get(\"games.refund_entries\")?.unit).toBe(\"entries\");\n\n    // SQL was emitted twice in parallel (per-game aggregate + DISTINCT count).\n    expect(mock.calls).toHaveLength(2);\n    expect(mock.calls[0].text).toContain(\"from game_entries\");\n    expect(mock.calls[0].text).toContain(\"group by game\");\n    expect(mock.calls[0].text).toContain(\n      \"count(*) filter (where settled_at is not null and is_winner is null)\",\n    );\n    expect(mock.calls[1].text).toContain(\"count(distinct user_id)\");\n  });\n\n  it(\"sparse (no rows): zero-fills every PEEK_GAME_ID and emits zeroed metrics rather than dropping the strip\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n    const now = new Date(\"2026-04-25T12:00:00.000Z\");\n\n    const result = await getGamesOverview({ sql: mock.sql, now });\n\n    expect(result.perGame.map((r) => r.game)).toEqual(PEEK_GAME_IDS);\n    for (const row of result.perGame) {\n      expect(row.entries).toBe(0);\n      expect(row.uniqueUsers).toBe(0);\n      expect(row.wageredLamports).toBe(\"0\");\n      expect(row.settledEntries).toBe(0);\n      expect(row.refundEntries).toBe(0);\n      expect(row.payoutLamports).toBe(\"0\");\n      expect(row.wins).toBe(0);\n      expect(row.losses).toBe(0);\n    }\n\n    expect(result.metrics).toHaveLength(6);\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"games.total_entries\")?.value).toBe(0);\n    expect(byId.get(\"games.total_entries\")?.valueDisplay).toBe(\"0\");\n    expect(byId.get(\"games.unique_users\")?.value).toBe(0);\n    expect(byId.get(\"games.wagered_lamports\")?.value).toBe(\"0\");\n    expect(byId.get(\"games.wagered_lamports\")?.valueDisplay).toBe(\"0\");\n    expect(byId.get(\"games.payout_lamports\")?.value).toBe(\"0\");\n  });\n\n  it(\"sparse (one game only): zero-fills missing games while preserving the populated row\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          game: \"potshot\" as PeekGameId,\n          entries: 3,\n          unique_users: 2,\n          wagered_lamports: \"500\",\n          settled_entries: 2,\n          refund_entries: 0,\n          payout_lamports: \"400\",\n          wins: 1,\n          losses: 1,\n        },\n      ],\n      [{ value: 2 }],\n    ]);\n\n    const result = await getGamesOverview({ sql: mock.sql });\n\n    const byGame = new Map(result.perGame.map((r) => [r.game, r]));\n    expect(byGame.get(\"flipyou\")?.entries).toBe(0);\n    expect(byGame.get(\"flipyou\")?.wageredLamports).toBe(\"0\");\n    expect(byGame.get(\"potshot\")?.entries).toBe(3);\n    expect(byGame.get(\"potshot\")?.wageredLamports).toBe(\"500\");\n    expect(byGame.get(\"closecall\")?.entries).toBe(0);\n    expect(byGame.get(\"closecall\")?.payoutLamports).toBe(\"0\");\n\n    const totalEntries = result.metrics.find(\n      (m) => m.id === \"games.total_entries\",\n    );\n    expect(totalEntries?.value).toBe(3);\n    const wagered = result.metrics.find(\n      (m) => m.id === \"games.wagered_lamports\",\n    );\n    expect(wagered?.value).toBe(\"500\");\n  });\n\n  it(\"string count coercion: postgres ::text counts convert to numbers\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          game: \"flipyou\" as PeekGameId,\n          entries: \"9\",\n          unique_users: \"7\",\n          wagered_lamports: \"100\",\n          settled_entries: \"5\",\n          refund_entries: \"1\",\n          payout_lamports: \"80\",\n          wins: \"3\",\n          losses: \"1\",\n        },\n      ],\n      [{ value: \"7\" }],\n    ]);\n\n    const result = await getGamesOverview({ sql: mock.sql });\n    const flipyou = result.perGame.find((r) => r.game === \"flipyou\");\n    expect(flipyou?.entries).toBe(9);\n    expect(flipyou?.uniqueUsers).toBe(7);\n    expect(flipyou?.settledEntries).toBe(5);\n    expect(flipyou?.refundEntries).toBe(1);\n    expect(flipyou?.wins).toBe(3);\n    expect(flipyou?.losses).toBe(1);\n\n    const uniqueUsers = result.metrics.find(\n      (m) => m.id === \"games.unique_users\",\n    );\n    expect(uniqueUsers?.value).toBe(7);\n  });\n\n  it(\"filters out unknown game ids the DB might return so deferred/out-of-band games cannot leak into the UI\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          game: \"flipyou\" as PeekGameId,\n          entries: 1,\n          unique_users: 1,\n          wagered_lamports: \"10\",\n          settled_entries: 1,\n          refund_entries: 0,\n          payout_lamports: \"10\",\n          wins: 1,\n          losses: 0,\n        },\n        {\n          // Not a member of PEEK_GAME_IDS — must be ignored.\n          game: \"crash\" as unknown as PeekGameId,\n          entries: 999,\n          unique_users: 999,\n          wagered_lamports: \"999999\",\n          settled_entries: 999,\n          refund_entries: 0,\n          payout_lamports: \"0\",\n          wins: 999,\n          losses: 0,\n        },\n      ],\n      [{ value: 1 }],\n    ]);\n\n    const result = await getGamesOverview({ sql: mock.sql });\n\n    expect(result.perGame.map((r) => r.game)).toEqual(PEEK_GAME_IDS);\n    expect(result.perGame.find((r) => r.game === \"flipyou\")?.entries).toBe(1);\n    // The bogus \"crash\" row's 999s never bleed into totals.\n    const totalEntries = result.metrics.find(\n      (m) => m.id === \"games.total_entries\",\n    );\n    expect(totalEntries?.value).toBe(1);\n  });\n\n  it(\"BigInt sum: lamport totals across games preserve u64 precision beyond Number.MAX_SAFE_INTEGER\", async () => {\n    // Two near-MAX_SAFE_INTEGER per-game lamport sums. Naive Number addition\n    // would round; BigInt sum must keep every digit.\n    const big = \"9007199254740992\"; // Number.MAX_SAFE_INTEGER + 1\n    const mock = createSqlMock([\n      [\n        {\n          game: \"flipyou\" as PeekGameId,\n          entries: 1,\n          unique_users: 1,\n          wagered_lamports: big,\n          settled_entries: 0,\n          refund_entries: 0,\n          payout_lamports: \"0\",\n          wins: 0,\n          losses: 0,\n        },\n        {\n          game: \"potshot\" as PeekGameId,\n          entries: 1,\n          unique_users: 1,\n          wagered_lamports: big,\n          settled_entries: 0,\n          refund_entries: 0,\n          payout_lamports: \"0\",\n          wins: 0,\n          losses: 0,\n        },\n      ],\n      [{ value: 2 }],\n    ]);\n\n    const result = await getGamesOverview({ sql: mock.sql });\n    const wagered = result.metrics.find(\n      (m) => m.id === \"games.wagered_lamports\",\n    );\n    expect(wagered?.value).toBe(\"18014398509481984\");\n    expect(wagered?.valueDisplay).toBe(\"18,014,398,509,481,984\");\n  });\n\n  it(\"load-error: a rejected aggregate query propagates so the page can render the alert state\", async () => {\n    const mock = createSqlMock([\n      new Error(\"connection refused\"),\n      [{ value: 0 }],\n    ]);\n\n    await expect(getGamesOverview({ sql: mock.sql })).rejects.toThrowError(\n      \"connection refused\",\n    );\n  });\n\n  it(\"load-error: a rejected unique-users query also propagates\", async () => {\n    const mock = createSqlMock([[], new Error(\"statement timeout\")]);\n\n    await expect(getGamesOverview({ sql: mock.sql })).rejects.toThrowError(\n      \"statement timeout\",\n    );\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
