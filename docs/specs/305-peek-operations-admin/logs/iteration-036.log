es: null,\n62\t    },\n63\t  });\n64\t}\n65\t\n66\texport function formatUserHeading(user: {\n67\t  userId: string;\n68\t  username: string | null;\n69\t}) {\n70\t  return user.username ?? user.userId;\n71\t}\n72\t\n73\texport async function getPeekUserDetail(\n74\t  userId: string,\n75\t  options: GetPeekUserDetailOptions = {},\n76\t): Promise<PeekUserDetail | null> {\n77\t  const sql = options.sql ?? getSqlClient();\n78\t  const recentLimit = clampPositiveInt(\n79\t    options.recentLimit,\n80\t    PEEK_USER_DETAIL_RECENT_LIMIT,"}]},"parent_tool_use_id":null,"session_id":"e6cdaeb2-c1ea-4e16-a7ec-e37acda8812c","uuid":"4b7d0998-7a2a-4fe3-ba8a-897feef3d5c0","timestamp":"2026-04-25T13:21:29.031Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-peek-user-detail.ts","content":"import type {\n  PeekChallengeAssignmentSummary,\n  PeekCrateDropRow,\n  PeekFraudFlagRow,\n  PeekGameEntryRow,\n  PeekKolRate,\n  PeekLinkedAccountRow,\n  PeekPlayerPoints,\n  PeekPointGrantRow,\n  PeekReferralClaimRow,\n  PeekReferralEarningsSummary,\n  PeekTelegramLinkTokenRow,\n  PeekTransactionRow,\n  PeekUserAttentionFlags,\n  PeekUserDetail,\n  PeekUserQueueEventRow,\n} from \"../../../lib/types/peek\";\nimport { writePeekAuditEvent } from \"../../audit/writer\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_USER_DETAIL_RECENT_LIMIT = 25;\nexport const PEEK_USER_DETAIL_TOKEN_LIMIT = 10;\n\ntype Sql = ReturnType<typeof getSqlClient>;\n\nexport type PeekUserDetailAuditFn = (input: {\n  actorEmail: string;\n  userId: string;\n  route: string | null;\n  requestId: string | null;\n}) => Promise<void>;\n\ntype GetPeekUserDetailOptions = {\n  sql?: Sql;\n  recentLimit?: number;\n  tokenLimit?: number;\n  actorEmail?: string | null;\n  route?: string | null;\n  requestId?: string | null;\n  audit?: PeekUserDetailAuditFn | null;\n};\n\nasync function defaultPeekUserDetailAudit(input: {\n  actorEmail: string;\n  userId: st