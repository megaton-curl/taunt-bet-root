{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FANx9rVeWU1TjbjDgydVfV","type":"tool_result","content":"1\t-- 008_transactions.sql — Real on-chain SOL movements (deposit/payout/refund).\n2\t\n3\tCREATE TABLE transactions (\n4\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n5\t  user_id         TEXT,\n6\t  wallet          TEXT         NOT NULL,\n7\t  game            TEXT         NOT NULL CHECK (game IN ('flipyou', 'potshot', 'closecall')),\n8\t  match_id        TEXT         NOT NULL,\n9\t  tx_type         TEXT         NOT NULL CHECK (tx_type IN ('deposit', 'payout', 'refund')),\n10\t  amount_lamports BIGINT       NOT NULL,\n11\t  tx_sig          TEXT         NOT NULL,\n12\t  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n13\t);\n14\t\n15\tCREATE INDEX idx_tx_wallet_created ON transactions (wallet, created_at DESC);\n16\tCREATE INDEX idx_tx_match_id ON transactions (match_id);\n17\tCREATE INDEX idx_tx_user_created ON transactions (user_id, created_at DESC) WHERE user_id IS NOT NULL;\n18\tCREATE UNIQUE INDEX uq_tx_wallet_match_type_sig ON transactions (wallet, match_id, tx_type, tx_sig);\n19\t"}]},"parent_tool_use_id":null,"session_id":"e6cdaeb2-c1ea-4e16-a7ec-e37acda8812c","uuid":"863becdc-9ea7-4964-b61b-6ca24dd6d250","timestamp":"2026-04-25T13:21:16.075Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/migrations/008_transactions.sql","content":"-- 008_transactions.sql — Real on-chain SOL movements (deposit/payout/refund).\n\nCREATE TABLE transactions (\n  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  user_id         TEXT,\n  wallet          TEXT         NOT NULL,\n  game            TEXT         NOT NULL CHECK (game IN ('flipyou', 'potshot', 'closecall')),\n  match_id        TEXT         NOT NULL,\n  tx_type         TEXT         NOT NULL CHECK (tx_type IN ('deposit', 'payout', 'refund')),\n  amount_lamports BIGINT       NOT NULL,\n  tx_sig          TEXT         NOT NULL,\n  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n);\n\nCREATE INDEX idx_tx_wallet_created ON transactions (wallet, created_at DESC);\nCREATE INDEX idx_tx_match_id ON transactions (match_id);\nCREATE INDEX idx_tx_user_created ON transactions (user_id, created_at DESC) WHERE user_id IS NOT NULL;\nCREATE UNIQUE INDEX uq_tx_wallet_match_type_sig ON transactions (wallet, match_id, tx_type, tx_sig);\n","numLines":19,"startLine":1,"totalLines":19}}}
