{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BqAokpFp7bCoR6XwmksGNZ","type":"tool_result","content":"1\t// Browser-safe view-model primitives for `peek`.\n2\t//\n3\t// Foundational shapes used across feature pages: metric metadata (FR-4),\n4\t// URL-addressable table filters, pagination, sort, and a small table-row base\n5\t// type that per-feature row types can extend. Per-feature shapes (PeekUserRow,\n6\t// PeekUserDetail, future referral/game/queue/etc. rows) live alongside or\n7\t// extend these primitives.\n8\t\n9\timport type { PeekRole } from \"../access-policy\";\n10\t\n11\t// --- Existing 303-era shapes (kept stable for current callers) ---------------\n12\t\n13\texport type PeekSummary = {\n14\t  totalUsers: number;\n15\t  totalUsersWithCodes: number;\n16\t  totalReferredUsers: number;\n17\t  totalUniqueReferrers: number;\n18\t};\n19\t\n20\texport type PeekUserRow = {\n21\t  userId: string;\n22\t  username: string | null;\n23\t  wallet: string;\n24\t  joinedAt: string;\n25\t  referralCode: string | null;\n26\t  referrerUserId: string | null;\n27\t  referrerCode: string | null;\n28\t  refereeCount: number;\n29\t  telegramUsername: string | null;\n30\t  telegramUserId: string | null;\n31\t};\n32\t\n33\texport type PeekUserDetail = {\n34\t  user: PeekUserRow;\n35\t  inboundReferral: {\n36\t    referrerUserId: string | null;\n37\t    referrerCode: string | null;\n38\t    linkedAt: string | null;\n39\t  };\n40\t  outboundReferees: Array<{\n41\t    refereeUserId: string;\n42\t    refereeUsername: string | null;\n43\t    createdAt: string;\n44\t  }>;\n45\t  telegram: {\n46\t    state: \"active\" | \"none\";\n47\t    telegramUserId: string | null;\n48\t    telegramUsername: string | null;\n49\t  };\n50\t};\n51\t\n52\t// --- Actor view model (browser-safe) -----------------------------------------\n53\t\n54\texport type PeekActorView = {\n55\t  email: string;\n56\t  role: PeekRole;\n57\t};\n58\t\n59\t// --- Metric metadata (FR-4) --------------------------------------------------\n60\t//\n61\t// Each metric carries the bookkeeping required by the data-surfacing standard:\n62\t// stable id, label, value, source table/query, time window, \"as of\" timestamp,\n63\t// short definition, optional unit, and optional drill-down link to the filtered\n64\t// detail rows behind the number.\n65\t\n66\texport type PeekMetricFreshness = \"live\" | \"cached\" | \"manual\" | \"sampled\";\n67\t\n68\texport type PeekMetric = {\n69\t  id: string;\n70\t  label: string;\n71\t  value: number | string | null;\n72\t  valueDisplay: string;\n73\t  unit: string | null;\n74\t  source: string;\n75\t  windowLabel: string;\n76\t  asOf: string | null;\n77\t  definition: string;\n78\t  freshness: PeekMetricFreshness;\n79\t  drilldownHref: string | null;\n80\t};\n81\t\n82\t// --- Pagination primitive ----------------------------------------------------\n83\t\n84\texport type PeekPagination = {\n85\t  page: number;\n86\t  pageSize: number;\n87\t  totalCount: number;\n88\t  totalPages: number;\n89\t};\n90\t\n91\t// --- Sort primitive ----------------------------------------------------------\n92\t\n93\texport type PeekSortDirection = \"asc\" | \"desc\";\n94\t\n95\texport type PeekTableSort = {\n96\t  column: string;\n97\t  direction: PeekSortDirection;\n98\t};\n99\t\n100\t// --- Table filter primitive (URL-addressable) --------------------------------\n101\t\n102\texport type PeekFilterKind =\n103\t  | \"text\"\n104\t  | \"select\"\n105\t  | \"boolean\"\n106\t  | \"date\"\n107\t  | \"dateRange\";\n108\t\n109\texport type PeekFilterOption = {\n110\t  value: string;\n111\t  label: string;\n112\t};\n113\t\n114\texport type PeekTableFilter = {\n115\t  id: string;\n116\t  label: string;\n117\t  kind: PeekFilterKind;\n118\t  value: string | null;\n119\t  options: ReadonlyArray<PeekFilterOption> | null;\n120\t  placeholder: string | null;\n121\t  required: boolean;\n122\t};\n123\t\n124\t// --- Status chip tone (shared) -----------------------------------------------\n125\t\n126\texport type PeekStatusTone =\n127\t  | \"neutral\"\n128\t  | \"positive\"\n129\t  | \"warning\"\n130\t  | \"negative\"\n131\t  | \"info\";\n132\t\n133\t// --- Empty-state primitive ---------------------------------------------------\n134\t\n135\texport type PeekEmptyState = {\n136\t  title: string;\n137\t  body: string | null;\n138\t};\n139\t\n140\t// --- Table row + column primitives -------------------------------------------\n141\t//\n142\t// Per-feature row types extend `PeekTableRowBase` for the shared identifier +\n143\t// optional drill-down link, then add feature-specific fields. The shared dense\n144\t// table component reads `columns` for layout and per-row data via the typed\n145\t// row shape supplied by the feature page.\n146\t\n147\texport type PeekTableColumnAlign = \"left\" | \"right\" | \"center\";\n148\t\n149\texport type PeekTableColumn = {\n150\t  id: string;\n151\t  label: string;\n152\t  align: PeekTableColumnAlign;\n153\t  sortable: boolean;\n154\t};\n155\t\n156\texport type PeekTableRowBase = {\n157\t  id: string;\n158\t  href: string | null;\n159\t};\n160\t\n161\texport type PeekTableViewModel<TRow extends PeekTableRowBase> = {\n162\t  columns: ReadonlyArray<PeekTableColumn>;\n163\t  rows: ReadonlyArray<TRow>;\n164\t  pagination: PeekPagination;\n165\t  filters: ReadonlyArray<PeekTableFilter>;\n166\t  sort: PeekTableSort | null;\n167\t  empty: PeekEmptyState;\n168\t};\n169\t\n170\t// --- Command-center attention queue (FR-3, FR-10) ----------------------------\n171\t//\n172\t// The command-center page surfaces a small set of \"needs attention\" metrics so\n173\t// operators see exception states (failed claims, dead queue events, stuck\n174\t// settlements, pending SOL crate payouts, stale active Dogpile events,\n175\t// high-value export activity) before they dig into per-feature pages. Each\n176\t// item is a `PeekMetric` so the metric-strip primitive renders it with the\n177\t// FR-4 bookkeeping (definition, source, time window, \"as of\", drill-down).\n178\t\n179\texport type PeekCommandCenterAttentionId =\n180\t  | \"failed_claims\"\n181\t  | \"dead_queue_events\"\n182\t  | \"stuck_rounds_flipyou_potshot\"\n183\t  | \"stuck_rounds_closecall\"\n184\t  | \"pending_sol_crate_payouts\"\n185\t  | \"stale_active_dogpile_events\"\n186\t  | \"high_value_exports_24h\";\n187\t\n188\texport type PeekCommandCenterAttention = {\n189\t  generatedAt: string;\n190\t  metrics: ReadonlyArray<PeekMetric>;\n191\t};\n192\t\n193\t// --- Recent operator activity (FR-3 command-center \"high-signal activity\") ---\n194\t//\n195\t// Compact projection of the latest `operator_events` rows for the command-center\n196\t// \"Recent activity\" section. Pulled from the same JSONB payload the audit\n197\t// writer persists, but kept narrow on purpose ŌĆö the command center surfaces\n198\t// only the few fields needed to recognize what happened, not the full payload.\n199\t// The audit view (`/audit`, later iteration) renders the full bounded table.\n200\t\n201\texport type PeekRecentActivityItem = {\n202\t  id: string;\n203\t  eventType: string;\n204\t  actorEmail: string | null;\n205\t  resourceType: string | null;\n206\t  resourceId: string | null;\n207\t  route: string | null;\n208\t  createdAt: string;\n209\t};\n210\t\n211\t// --- Audit event contracts (FR-11) -------------------------------------------\n212\t//\n213\t// Browser-safe view of `operator_events` rows the audit writer produces under\n214\t// `peek.*` event types. The `PeekAuditPayload` shape pins the fields required by\n215\t// FR-11 so the writer (`peek/src/server/audit/**`, next iteration) and the audit\n216\t// view (`/audit`, later iteration) agree on a serialization contract. Secrets\n217\t// (JWTs, access tokens, DB URLs, private keys, raw secrets) must be replaced by\n218\t// `PEEK_AUDIT_REDACTED` before persisting; the audit-view component renders the\n219\t// token verbatim so reviewers can see that a field was redacted (not silently\n220\t// absent).\n221\t\n222\texport type PeekAuditEventType =\n223\t  | \"peek.search\"\n224\t  | \"peek.user.view_sensitive\"\n225\t  | \"peek.export\"\n226\t  | \"peek.access.denied\"\n227\t  | \"peek.change.applied\"\n228\t  | \"peek.change.rejected\";\n229\t\n230\texport const PEEK_AUDIT_EVENT_TYPES: ReadonlyArray<PeekAuditEventType> = [\n231\t  \"peek.search\",\n232\t  \"peek.user.view_sensitive\",\n233\t  \"peek.export\",\n234\t  \"peek.access.denied\",\n235\t  \"peek.change.applied\",\n236\t  \"peek.change.rejected\",\n237\t];\n238\t\n239\texport function isPeekAuditEventType(\n240\t  value: unknown,\n241\t): value is PeekAuditEventType {\n242\t  return (\n243\t    typeof value === \"string\" &&\n244\t    (PEEK_AUDIT_EVENT_TYPES as ReadonlyArray<string>).includes(value)\n245\t  );\n246\t}\n247\t\n248\texport const PEEK_AUDIT_REDACTED = \"[REDACTED]\";\n249\t\n250\texport type PeekAuditScalar = string | number | boolean | null;\n251\t\n252\texport type PeekAuditChange = {\n253\t  field: string;\n254\t  before: PeekAuditScalar;\n255\t  after: PeekAuditScalar;\n256\t};\n257\t\n258\texport type PeekAuditPayload = {\n259\t  actorEmail: string;\n260\t  route: string | null;\n261\t  actionId: string | null;\n262\t  resourceType: string | null;\n263\t  resourceId: string | null;\n264\t  filterSummary: string | null;\n265\t  resultCount: number | null;\n266\t  requestId: string | null;\n267\t  rejectionReason: string | null;\n268\t  changes: ReadonlyArray<PeekAuditChange> | null;\n269\t};\n270\t\n271\texport type PeekAuditEvent = {\n272\t  id: string;\n273\t  eventType: PeekAuditEventType;\n274\t  createdAt: string;\n275\t  payload: PeekAuditPayload;\n276\t};\n277\t\n278\t// --- Export contracts (FR-12) ------------------------------------------------\n279\t//\n280\t// Exports are server-rendered CSVs gated by the same page-level access as the\n281\t// source page, bounded by a server-side row cap, named with a deterministic\n282\t// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n283\t// bytes return. Export rows reuse the table view-model column ids so the export\n284\t// shape stays in lockstep with the rendered table; values are pre-formatted\n285\t// strings so CSV serialization stays straightforward and locale-stable.\n286\t\n287\texport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n288\t\n289\texport type PeekExportEntity =\n290\t  | \"users\"\n291\t  | \"referrers\"\n292\t  | \"kol\"\n293\t  | \"claims\"\n294\t  | \"rounds\"\n295\t  | \"transactions\"\n296\t  | \"queue\"\n297\t  | \"audit\";\n298\t\n299\texport type PeekExportRow = Record<string, string>;\n300\t\n301\texport type PeekExportFilenameInput = {\n302\t  entity: PeekExportEntity;\n303\t  date: string;\n304\t  filterSlug: string;\n305\t};\n306\t\n307\texport type PeekExportResult = {\n308\t  filename: string;\n309\t  rowCount: number;\n310\t  rowCap: number;\n311\t  rowCapApplied: boolean;\n312\t  columns: ReadonlyArray<PeekTableColumn>;\n313\t  rows: ReadonlyArray<PeekExportRow>;\n314\t};\n315\t\n316\t// --- Universal search (FR-5) -------------------------------------------------\n317\t//\n318\t// One search entry point that resolves common operational identifiers to typed\n319\t// result groups. Results are grouped by entity type so the UI can section them\n320\t// (user, referral, linked account, round, transaction, queue event). Each\n321\t// result includes enough context to disambiguate similar matches; sensitive\n322\t// values (wallet, Telegram id, tx signature) live in the result's `id`/`label`\n323\t// fields for operator readability and the audit event records only the actor\n324\t// email, query class, and result counts (never the raw query, which the audit\n325\t// writer redacts if it looks like a secret).\n326\t\n327\texport type PeekSearchEntityType =\n328\t  | \"user\"\n329\t  | \"referral\"\n330\t  | \"linked_account\"\n331\t  | \"round\"\n332\t  | \"transaction\"\n333\t  | \"queue_event\";\n334\t\n335\texport const PEEK_SEARCH_ENTITY_TYPES: ReadonlyArray<PeekSearchEntityType> = [\n336\t  \"user\",\n337\t  \"referral\",\n338\t  \"linked_account\",\n339\t  \"round\",\n340\t  \"transaction\",\n341\t  \"queue_event\",\n342\t];\n343\t\n344\t// Coarse heuristic classification used only for the `peek.search` audit\n345\t// summary so reviewers can see which class of identifier was searched without\n346\t// inferring it from the (possibly redacted) raw query.\n347\texport type PeekSearchQueryClass =\n348\t  | \"empty\"\n349\t  | \"free_text\"\n350\t  | \"user_id\"\n351\t  | \"username\"\n352\t  | \"wallet\"\n353\t  | \"referral_code\"\n354\t  | \"telegram_username\"\n355\t  | \"telegram_provider_id\"\n356\t  | \"round_pda\"\n357\t  | \"match_id\"\n358\t  | \"tx_signature\"\n359\t  | \"queue_event_id\";\n360\t\n361\texport type PeekSearchResult = {\n362\t  entityType: PeekSearchEntityType;\n363\t  id: string;\n364\t  label: string;\n365\t  sublabel: string | null;\n366\t  context: string | null;\n367\t  href: string;\n368\t};\n369\t\n370\texport type PeekSearchGroup = {\n371\t  entityType: PeekSearchEntityType;\n372\t  results: ReadonlyArray<PeekSearchResult>;\n373\t  truncated: boolean;\n374\t};\n375\t\n376\texport type PeekSearchResponse = {\n377\t  query: string;\n378\t  queryClass: PeekSearchQueryClass;\n379\t  groups: ReadonlyArray<PeekSearchGroup>;\n380\t  totalResults: number;\n381\t  perGroupLimit: number;\n382\t  generatedAt: string;\n383\t};\n384\t\n385\texport const PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT = 5;\n386\texport const PEEK_SEARCH_MAX_PER_GROUP_LIMIT = 25;\n387\t"}]},"parent_tool_use_id":null,"session_id":"a7a6576f-78d4-407f-81cd-207cf72e4e2a","uuid":"55056c07-a05c-4f4d-9355-05ef8ac7c663","timestamp":"2026-04-25T11:49:04.463Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","content":"// Browser-safe view-model primitives for `peek`.\n//\n// Foundational shapes used across feature pages: metric metadata (FR-4),\n// URL-addressable table filters, pagination, sort, and a small table-row base\n// type that per-feature row types can extend. Per-feature shapes (PeekUserRow,\n// PeekUserDetail, future referral/game/queue/etc. rows) live alongside or\n// extend these primitives.\n\nimport type { PeekRole } from \"../access-policy\";\n\n// --- Existing 303-era shapes (kept stable for current callers) ---------------\n\nexport type PeekSummary = {\n  totalUsers: number;\n  totalUsersWithCodes: number;\n  totalReferredUsers: number;\n  totalUniqueReferrers: number;\n};\n\nexport type PeekUserRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  joinedAt: string;\n  referralCode: string | null;\n  referrerUserId: string | null;\n  referrerCode: string | null;\n  refereeCount: number;\n  telegramUsername: string | null;\n  telegramUserId: string | null;\n};\n\nexport type PeekUserDetail = {\n  user: PeekUserRow;\n  inboundReferral: {\n    referrerUserId: string | null;\n    referrerCode: string | null;\n    linkedAt: string | null;\n  };\n  outboundReferees: Array<{\n    refereeUserId: string;\n    refereeUsername: string | null;\n    createdAt: string;\n  }>;\n  telegram: {\n    state: \"active\" | \"none\";\n    telegramUserId: string | null;\n    telegramUsername: string | null;\n  };\n};\n\n// --- Actor view model (browser-safe) -----------------------------------------\n\nexport type PeekActorView = {\n  email: string;\n  role: PeekRole;\n};\n\n// --- Metric metadata (FR-4) --------------------------------------------------\n//\n// Each metric carries the bookkeeping required by the data-surfacing standard:\n// stable id, label, value, source table/query, time window, \"as of\" timestamp,\n// short definition, optional unit, and optional drill-down link to the filtered\n// detail rows behind the number.\n\nexport type PeekMetricFreshness = \"live\" | \"cached\" | \"manual\" | \"sampled\";\n\nexport type PeekMetric = {\n  id: string;\n  label: string;\n  value: number | string | null;\n  valueDisplay: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  asOf: string | null;\n  definition: string;\n  freshness: PeekMetricFreshness;\n  drilldownHref: string | null;\n};\n\n// --- Pagination primitive ----------------------------------------------------\n\nexport type PeekPagination = {\n  page: number;\n  pageSize: number;\n  totalCount: number;\n  totalPages: number;\n};\n\n// --- Sort primitive ----------------------------------------------------------\n\nexport type PeekSortDirection = \"asc\" | \"desc\";\n\nexport type PeekTableSort = {\n  column: string;\n  direction: PeekSortDirection;\n};\n\n// --- Table filter primitive (URL-addressable) --------------------------------\n\nexport type PeekFilterKind =\n  | \"text\"\n  | \"select\"\n  | \"boolean\"\n  | \"date\"\n  | \"dateRange\";\n\nexport type PeekFilterOption = {\n  value: string;\n  label: string;\n};\n\nexport type PeekTableFilter = {\n  id: string;\n  label: string;\n  kind: PeekFilterKind;\n  value: string | null;\n  options: ReadonlyArray<PeekFilterOption> | null;\n  placeholder: string | null;\n  required: boolean;\n};\n\n// --- Status chip tone (shared) -----------------------------------------------\n\nexport type PeekStatusTone =\n  | \"neutral\"\n  | \"positive\"\n  | \"warning\"\n  | \"negative\"\n  | \"info\";\n\n// --- Empty-state primitive ---------------------------------------------------\n\nexport type PeekEmptyState = {\n  title: string;\n  body: string | null;\n};\n\n// --- Table row + column primitives -------------------------------------------\n//\n// Per-feature row types extend `PeekTableRowBase` for the shared identifier +\n// optional drill-down link, then add feature-specific fields. The shared dense\n// table component reads `columns` for layout and per-row data via the typed\n// row shape supplied by the feature page.\n\nexport type PeekTableColumnAlign = \"left\" | \"right\" | \"center\";\n\nexport type PeekTableColumn = {\n  id: string;\n  label: string;\n  align: PeekTableColumnAlign;\n  sortable: boolean;\n};\n\nexport type PeekTableRowBase = {\n  id: string;\n  href: string | null;\n};\n\nexport type PeekTableViewModel<TRow extends PeekTableRowBase> = {\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<TRow>;\n  pagination: PeekPagination;\n  filters: ReadonlyArray<PeekTableFilter>;\n  sort: PeekTableSort | null;\n  empty: PeekEmptyState;\n};\n\n// --- Command-center attention queue (FR-3, FR-10) ----------------------------\n//\n// The command-center page surfaces a small set of \"needs attention\" metrics so\n// operators see exception states (failed claims, dead queue events, stuck\n// settlements, pending SOL crate payouts, stale active Dogpile events,\n// high-value export activity) before they dig into per-feature pages. Each\n// item is a `PeekMetric` so the metric-strip primitive renders it with the\n// FR-4 bookkeeping (definition, source, time window, \"as of\", drill-down).\n\nexport type PeekCommandCenterAttentionId =\n  | \"failed_claims\"\n  | \"dead_queue_events\"\n  | \"stuck_rounds_flipyou_potshot\"\n  | \"stuck_rounds_closecall\"\n  | \"pending_sol_crate_payouts\"\n  | \"stale_active_dogpile_events\"\n  | \"high_value_exports_24h\";\n\nexport type PeekCommandCenterAttention = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};\n\n// --- Recent operator activity (FR-3 command-center \"high-signal activity\") ---\n//\n// Compact projection of the latest `operator_events` rows for the command-center\n// \"Recent activity\" section. Pulled from the same JSONB payload the audit\n// writer persists, but kept narrow on purpose ŌĆö the command center surfaces\n// only the few fields needed to recognize what happened, not the full payload.\n// The audit view (`/audit`, later iteration) renders the full bounded table.\n\nexport type PeekRecentActivityItem = {\n  id: string;\n  eventType: string;\n  actorEmail: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  route: string | null;\n  createdAt: string;\n};\n\n// --- Audit event contracts (FR-11) -------------------------------------------\n//\n// Browser-safe view of `operator_events` rows the audit writer produces under\n// `peek.*` event types. The `PeekAuditPayload` shape pins the fields required by\n// FR-11 so the writer (`peek/src/server/audit/**`, next iteration) and the audit\n// view (`/audit`, later iteration) agree on a serialization contract. Secrets\n// (JWTs, access tokens, DB URLs, private keys, raw secrets) must be replaced by\n// `PEEK_AUDIT_REDACTED` before persisting; the audit-view component renders the\n// token verbatim so reviewers can see that a field was redacted (not silently\n// absent).\n\nexport type PeekAuditEventType =\n  | \"peek.search\"\n  | \"peek.user.view_sensitive\"\n  | \"peek.export\"\n  | \"peek.access.denied\"\n  | \"peek.change.applied\"\n  | \"peek.change.rejected\";\n\nexport const PEEK_AUDIT_EVENT_TYPES: ReadonlyArray<PeekAuditEventType> = [\n  \"peek.search\",\n  \"peek.user.view_sensitive\",\n  \"peek.export\",\n  \"peek.access.denied\",\n  \"peek.change.applied\",\n  \"peek.change.rejected\",\n];\n\nexport function isPeekAuditEventType(\n  value: unknown,\n): value is PeekAuditEventType {\n  return (\n    typeof value === \"string\" &&\n    (PEEK_AUDIT_EVENT_TYPES as ReadonlyArray<string>).includes(value)\n  );\n}\n\nexport const PEEK_AUDIT_REDACTED = \"[REDACTED]\";\n\nexport type PeekAuditScalar = string | number | boolean | null;\n\nexport type PeekAuditChange = {\n  field: string;\n  before: PeekAuditScalar;\n  after: PeekAuditScalar;\n};\n\nexport type PeekAuditPayload = {\n  actorEmail: string;\n  route: string | null;\n  actionId: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  filterSummary: string | null;\n  resultCount: number | null;\n  requestId: string | null;\n  rejectionReason: string | null;\n  changes: ReadonlyArray<PeekAuditChange> | null;\n};\n\nexport type PeekAuditEvent = {\n  id: string;\n  eventType: PeekAuditEventType;\n  createdAt: string;\n  payload: PeekAuditPayload;\n};\n\n// --- Export contracts (FR-12) ------------------------------------------------\n//\n// Exports are server-rendered CSVs gated by the same page-level access as the\n// source page, bounded by a server-side row cap, named with a deterministic\n// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n// bytes return. Export rows reuse the table view-model column ids so the export\n// shape stays in lockstep with the rendered table; values are pre-formatted\n// strings so CSV serialization stays straightforward and locale-stable.\n\nexport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n\nexport type PeekExportEntity =\n  | \"users\"\n  | \"referrers\"\n  | \"kol\"\n  | \"claims\"\n  | \"rounds\"\n  | \"transactions\"\n  | \"queue\"\n  | \"audit\";\n\nexport type PeekExportRow = Record<string, string>;\n\nexport type PeekExportFilenameInput = {\n  entity: PeekExportEntity;\n  date: string;\n  filterSlug: string;\n};\n\nexport type PeekExportResult = {\n  filename: string;\n  rowCount: number;\n  rowCap: number;\n  rowCapApplied: boolean;\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<PeekExportRow>;\n};\n\n// --- Universal search (FR-5) -------------------------------------------------\n//\n// One search entry point that resolves common operational identifiers to typed\n// result groups. Results are grouped by entity type so the UI can section them\n// (user, referral, linked account, round, transaction, queue event). Each\n// result includes enough context to disambiguate similar matches; sensitive\n// values (wallet, Telegram id, tx signature) live in the result's `id`/`label`\n// fields for operator readability and the audit event records only the actor\n// email, query class, and result counts (never the raw query, which the audit\n// writer redacts if it looks like a secret).\n\nexport type PeekSearchEntityType =\n  | \"user\"\n  | \"referral\"\n  | \"linked_account\"\n  | \"round\"\n  | \"transaction\"\n  | \"queue_event\";\n\nexport const PEEK_SEARCH_ENTITY_TYPES: ReadonlyArray<PeekSearchEntityType> = [\n  \"user\",\n  \"referral\",\n  \"linked_account\",\n  \"round\",\n  \"transaction\",\n  \"queue_event\",\n];\n\n// Coarse heuristic classification used only for the `peek.search` audit\n// summary so reviewers can see which class of identifier was searched without\n// inferring it from the (possibly redacted) raw query.\nexport type PeekSearchQueryClass =\n  | \"empty\"\n  | \"free_text\"\n  | \"user_id\"\n  | \"username\"\n  | \"wallet\"\n  | \"referral_code\"\n  | \"telegram_username\"\n  | \"telegram_provider_id\"\n  | \"round_pda\"\n  | \"match_id\"\n  | \"tx_signature\"\n  | \"queue_event_id\";\n\nexport type PeekSearchResult = {\n  entityType: PeekSearchEntityType;\n  id: string;\n  label: string;\n  sublabel: string | null;\n  context: string | null;\n  href: string;\n};\n\nexport type PeekSearchGroup = {\n  entityType: PeekSearchEntityType;\n  results: ReadonlyArray<PeekSearchResult>;\n  truncated: boolean;\n};\n\nexport type PeekSearchResponse = {\n  query: string;\n  queryClass: PeekSearchQueryClass;\n  groups: ReadonlyArray<PeekSearchGroup>;\n  totalResults: number;\n  perGroupLimit: number;\n  generatedAt: string;\n};\n\nexport const PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT = 5;\nexport const PEEK_SEARCH_MAX_PER_GROUP_LIMIT = 25;\n","numLines":387,"startLine":1,"totalLines":387}}}
