ounts\");\n64\t    expect(queries[0]).toContain(\"provider = 'telegram'\");\n65\t    expect(queries[0]).toContain(\"status = 'active'\");\n66\t    expect(queries[0]).not.toContain(\"from telegram_link_tokens\");\n67\t  });\n68\t\n69\t  it(\"counts users with the linked-account telegram filter\", async () => {\n70\t    const { queries, sql } = createSqlMock([{ total: 0 }]);\n71\t    getSqlClientMock.mockReturnValue(sql);\n72\t\n73\t    const { countPeekUsers } = await import(\"../count-peek-users\");\n74\t\n75\t    await countPeekUsers({\n76\t      ...defaultParams,\n77\t      filters: {\n78\t        ...defaultParams.filters,\n79\t        hasTelegram: true,\n80\t      },\n81\t    });\n82\t\n83\t    expect(queries[0]).toContain(\"from linked_accounts\");\n84\t    expect(queries[0]).toContain(\"provider = 'telegram'\");\n85\t    expect(queries[0]).not.toContain(\"telegram_link_tokens\");\n86\t  });\n87\t\n88\t  it(\"loads user detail telegram data from linked_accounts\", async () => {\n89\t    const { queries, sql } = createSqlMock(\n90\t      [\n91\t        {\n92\t          userId: \"usr_1\",\n93\t          username: \"alice\",\n94\t          wallet: \"wallet_1\",\n95\t          joinedAt: \"2026-01-01T00:00:00.000Z\",\n96\t          referralCode: \"alice-code\",\n97\t          referrerUserId: null,\n98\t          referrerCode: null,\n99\t          refereeCount: 0,\n100\t          telegramLinkState: \"active\",\n101\t          linkedAt: null,\n102\t          telegramUserId: \"tg_123\",\n103\t          telegramUsername: \"alice_tg\",\n104\t        },\n105\t      ],\n106\t      []\n107\t    );\n108\t\n109\t    getSqlClientMock.mockReturnValue(sql);\n110\t\n111\t    const { getPeekUserDetail } = await import(\"../get-peek-user-detail\");\n112\t\n113\t    await getPeekUserDetail(\"usr_1\");\n114\t\n115\t    expect(queries[0]).toContain(\"from linked_accounts\");\n116\t    expect(queries[0]).toContain(\"provider = 'telegram'\");\n117\t    expect(queries[0]).toContain(\"status = 'active'\");\n118\t    expect(queries[0]).not.toContain(\"telegram_link_tokens\");\n119\t  });\n120\t});\n121\t"}]},"parent_tool_use_id":null,"session_id":"a7a6576f-78d4-407f-81cd-207cf72e4e2a","uuid":"193b87c7-8f75-4889-8f32-6edbe56b3659","timestamp":"2026-04-25T11:50:14.704Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/telegram-linked-queries.test.ts","content":"import { beforeEach, describe, expect, it, vi } from \"vitest\";\nimport type { PeekSearchParams } from \"../../../../lib/search-params\";\n\nconst getSqlClientMock = vi.fn();\n\nvi.mock(\"../../client\", () => ({\n  getSqlClient: getSqlClientMock,\n}));\n\nfunction createSqlMock(...responses: unknown[][]) {\n  const queries: string[] = [];\n  let responseIndex = 0;\n  const sql = Object.assign(\n    (strings: TemplateStringsArray) => {\n    queries.push(strings.join(\" \"));\n      const response = responses[responseIndex] ?? [];\n      responseIndex += 1;\n      return Promise.resolve(response);\n    },\n    {\n      unsafe(value: string) {\n        return value;\n      },\n    }\n  ) as unknown as ReturnType<typeof getSqlClientMock>;\n\n  return { queries, sql };\n}\n\nconst defaultParams: PeekSearchParams = {\n  query: \"\",\n  sort: \"joinedAt\",\n  direction: \"desc\",\n  page: 1,\n  pageSize: 50,\n  filters: {\n    hasReferrer: false,\n    hasReferees: false,\n    hasCode: false,\n    hasTelegram: false,\n  },\n};\n\ndescribe(\"peek telegram linked-account queries\", () => {\n  beforeEach(() => {\n    getSqlClientMock.mockReset();\n  });\n\n  it(\"lists users from linked_accounts instead of telegram_link_tokens\", async () => {\n    const { queries, sql } = createSqlMock([]);\n    getSqlClientMock.mockReturnValue(sql);\n\n    const { listPeekUsers } = await import(\"../list-peek-users\");\n\n    await listPeekUsers({\n      ...defaultParams,\n      filters: {\n        ...defaultParams.filters,\n        hasTelegram: true,\n      },\n    });\n\n    expect(queries[0]).toContain(\"from linked_accounts\");\n    expect(queries[0]).toContain(\"provider = 'telegram'\");\n    expect(queries[0]).toContain(\"status = 'active'\");\n    expect(queries[0]).not.toContain(\"from telegram_link_tokens\");\n  });\n\n  it(\"counts users with the linked-account telegram filter\", async () => {\n    const { queries, sql } = createSqlMock([{ total: 0 }]);\n    getSqlClientMock.mockReturnValue(sql);\n\n    const { countPeekUsers } = await import(\"../count-peek-users\");\n\n    await countPeekUsers({\n      ...defaultParams,\n      filters: {\n        ...defaultParams.filters,\n        hasTelegram: true,\n      },\n    });\n\n    expect(queries[0]).toContain(\"from linked_accounts\");\n    expect(queries[0]).toContain(\"provider = 'telegram'\");\n    expect(queries[0]).not.toContain(\"telegram_link_tokens\");\n  });\n\n  it(\"loads user detail telegram data from linked_accounts\", async () => {\n    const { queries, sql } = createSqlMock(\n      [\n        {\n          userId: \"usr_1\",\n          username: \"alice\",\n          wallet: \"wallet_1\",\n          joinedAt: \"2026-01-01T00:00:00.000Z\",\n          referralCode: \"alice-code\",\n          referrerUserId: null,\n          referrerCode: null,\n          refereeCount: 0,\n          telegramLinkState: \"active\",\n          linkedAt: null,\n          telegramUserId: \"tg_123\",\n          telegramUsername: \"alice_tg\",\n        },\n      ],\n      []\n    );\n\n    getSqlClientMock.mockReturnValue(sql);\n\n    const { getPeekUserDetail } = await import(\"../get-peek-user-detail\");\n\n    await getPeekUserDetail(\"usr_1\");\n\n    expect(queries[0]).toContain(\"from linked_accounts\");\n    expect(queries[0]).toContain(\"provider = 'telegram'\");\n    expect(queries[0]).toContain(\"status = 'active'\");\n    expect(queries[0]).not.toContain(\"telegram_link_tokens\");\n  });\n});\n","numLines":121,"startLine":1,"totalLines":121}}}
