dAt\"","+    from linked_accounts","+    where user_id = ${userId}","+    order by linked_at desc","+  `;","+}","+","+async function fetchRecentTelegramLinkTokens(","+  sql: Sql,","+  userId: string,","+  limit: number,","+): Promise<ReadonlyArray<PeekTelegramLinkTokenRow>> {","+  return sql<Array<PeekTelegramLinkTokenRow>>`","+    select","+      id::text as \"id\",","+      status,","+      telegram_user_id as \"telegramUserId\",","+      telegram_username as \"telegramUsername\",","+      expires_at::text as \"expiresAt\",","+      redeemed_at::text as \"redeemedAt\",","+      created_at::text as \"createdAt\"","+    from telegram_link_tokens","+    where user_id = ${userId}","+    order by created_at desc","+    limit ${limit}","+  `;","+}","+","+async function fetchKolRate(","+  sql: Sql,","+  userId: string,","+): Promise<PeekKolRate | null> {","+  const [row] = await sql<","+    Array<{","+      rateBps: number;","+      setBy: string;","+      createdAt: string;","+      updatedAt: string;","+    }>","+  >`","+    select","+      rate_bps as \"rateBps\",","+      set_by as \"setBy\",","+      created_at::text as \"createdAt\",","+      updated_at::text as \"updatedAt\"","+    from referral_kol_rates","+    where user_id = ${userId}","+    limit 1","+  `;","+  return row ?? null;","+}","+","+async function fetchReferralEarnings(","+  sql: Sql,","+  userId: string,","+): Promise<PeekReferralEarningsSummary> {","+  const [row] = await sql<","+    Array<{","+      earningsCount: number;","+      totalReferrerEarnedLamports: string;","+      totalRefereeRebateLamports: string;","+      lastEarnedAt: string | null;","+    }>","+  >`","+    select","+      count(*)::int as \"earningsCount\",","+      coalesce(sum(referrer_earned_lamports), 0)::text as \"totalReferrerEarnedLamports\",","+      coalesce(sum(referee_rebate_lamports), 0)::text as \"totalRefereeRebateLamports\",","+      max(created_at)::text as \"lastEarnedAt\"","+    from referral_earnings","+    where referrer_user_id = ${userId} or referee_user_id = ${userId}","+  `;","+  return (","+    row ?? {","+      earningsCount: 0,","+      totalReferrerEarnedLamports: \"0\",","+      totalRefereeRebateLamports: \"0\",","+      lastEarnedAt: null,","+    }","+  );","+}","+","+async function fetchRecentReferralClaims(","+  sql: Sql,","+  userId: string,","+  limit: number,","+): Promise<ReadonlyArray<PeekReferralClaimRow>> {","+  return sql<Array<PeekReferralClaimRow>>`","+    select","+      id::text as \"id\",","+      amount_lamports::text as \"amountLamports\",","+      status,","+      retry_count as \"retryCount\",","+      tx_signature as \"txSignature\",","+      error,","+      requested_at::text as \"requestedAt\",","+      processed_at::text as \"processedAt\"","+    from referral_claims","+    where user_id = ${userId}","+    order by requested_at desc","+    limit ${limit}","+  `;","+}","+","+async function fetchPlayerPoints(","+  sql: Sql,","+  userId: string,","+): Promise<PeekPlayerPoints> {","+  const [row] = await sql<","+    Array<{","+      balance: string;","+      lifetimeEarned: string;","+      updatedAt: string;","+    }>","+  >`","+    select","+      balance::text as \"balance\",","+      lifetime_earned::text as \"lifetimeEarned\",","+      updated_at::text as \"updatedAt\"","+    from player_points","+    where user_id = ${userId}","+    limit 1","+  `;","+  return (","+    row ?? {","+      balance: \"0\",","+      lifetimeEarned: \"0\",","+      updatedAt: null,","+    }","+  );","+}","+","+async function fetchRecentPointGrants(","+  sql: Sql,","+  userId: string,","+  limit: number,","+): Promise<ReadonlyArray<PeekPointGrantRow>> {","+  return sql<Array<PeekPointGrantRow>>`","+    select","+      id::text as \"id\",","+      source_type as \"sourceType\",","+      source_id as \"sourceId\",","+      amount::text as \"amount\",","+      created_at::text as \"createdAt\"","+    from point_grants","+    where user_id = ${userId}","+    order by created_at desc","+    limit ${limit}","+  `;","+}","+","+async function fetchRecentCrateDrops(","+  sql: Sql,","+  userId: string,","+  limit: number,","+): Promise<ReadonlyArray<PeekCrateDropRow>> {","+  return sql<Array<PeekCrateDropRow>>`","+    select","+      id::text as \"id\",","+      trigger_type as \"triggerType\",","+      trigger_id as \"triggerId\",","+      crate_type as \"crateType\",","+      contents_amount as \"contentsAmount\",","+      status,","+      created_at::text as \"createdAt\",","+      granted_at::text as \"grantedAt\"","+    from crate_drops","+    where user_id = ${userId}","+    order by created_at desc","+    limit ${limit}","+  `;","+}","+","+async function fetchChallengeSummary(","+  sql: Sql,","+  userId: string,","+): Promise<PeekChallengeAssignmentSummary> {","+  const [row] = await sql<","+    Array<{","+      active: number;","+      completed: number;","+      expired: number;","+      total: number;","+    }>","+  >`","+    select","+      count(*) filter (where status = 'active')::int as \"active\",","+      count(*) filter (where status = 'completed')::int as \"completed\",","+      count(*) filter (where status = 'expired')::int as \"expired\",","+      count(*)::int as \"total\"","+    from challenge_assignments","+    where user_id = ${userId}","+  `;","+  return row ?? { active: 0, completed: 0, expired: 0, total: 0 };","+}","+","+async function fetchRecentGameEntries(","+  sql: Sql,","+  userId: string,","+  limit: number,","+): Promise<ReadonlyArray<PeekGameEntryRow>> {","+  return sql<Array<PeekGameEntryRow>>`","+    select","+      id::text as \"id\",","+      game,","+      round_pda as \"roundPda\",","+      match_id as \"matchId\",","+      amount_lamports::text as \"amountLamports\",","+      side,","+      is_winner as \"isWinner\",","+      payout_lamports::text as \"payoutLamports\",","+      created_at::text as \"createdAt\",","+      settled_at::text as \"settledAt\"","+    from game_entries","+    where user_id = ${userId}","+    order by created_at desc","+    limit ${limit}","+  `;","+}","+","+async function fetchRecentTransactions(","+  sql: Sql,","+  userId: string,","+  limit: number,","+): Promise<ReadonlyArray<PeekTransactionRow>> {","+  return sql<Array<PeekTransactionRow>>`","+    select","+      id::text as \"id\",","+      game,","+      match_id as \"matchId\",","+      tx_type as \"txType\",","+      amount_lamports::text as \"amountLamports\",","+      tx_sig as \"txSig\",","+      created_at::text as \"createdAt\"","+    from transactions","+    where user_id = ${userId}","+    order by created_at desc","+    limit ${limit}","+  `;","+}","+","+async function fetchFraudFlags(","+  sql: Sql,","+  userId: string,","+  limit: number,","+): Promise<ReadonlyArray<PeekFraudFlagRow>> {","+  return sql<Array<PeekFraudFlagRow>>`","+    select","+      id::text as \"id\",","+      flag_type as \"flagType\",","+      status,","+      related_id as \"relatedId\",","+      created_at::text as \"createdAt\",","+      resolved_at::text as \"resolvedAt\"","+    from fraud_flags","+    where user_id = ${userId}","+    order by created_at desc","+    limit ${limit}","+  `;","+}","+","+async function fetchRecentUserQueueEvents(","+  sql: Sql,","+  userId: string,","+  wallet: string,","+  limit: number,","+): Promise<ReadonlyArray<PeekUserQueueEventRow>> {","+  // event_queue has no user_id column; join via JSONB payload identifiers that","+  // every backend writer uses today (`userId`, `user_id`, `wallet`). Bounded by","+  // limit so the admin page never streams the full queue.","+  return sql<Array<PeekUserQueueEventRow>>`","+    select","+      id::text as \"id\",","+      event_type as \"eventType\",","+      status,","+      attempts,","+      max_attempts as \"maxAttempts\",","+      scheduled_at::text as \"scheduledAt\",","+      created_at::text as \"createdAt\",","+      error","+    from event_queue","+    where payload->>'userId' = ${userId}","+       or payload->>'user_id' = ${userId}","+       or payload->>'wallet' = ${wallet}","+    order by created_at desc","+    limit ${limit}","+  `;","+}","+","+async function fetchSelfReferralIndicator(","+  sql: Sql,","+  userId: string,","+): Promise<{ selfReferral: boolean }> {","+  const [row] = await sql<Array<{ selfReferral: boolean }>>`","+    select exists (","+      select 1","+      from referral_links rl","+      where rl.referrer_user_id = ${userId}","+        and rl.referee_user_id = ${userId}","+    ) as \"selfReferral\"","+  `;","+  return row ?? { selfReferral: false };","+}","+","+function computeAttention(input: {","+  recentReferralClaims: ReadonlyArray<PeekReferralClaimRow>;","+  recentUserQueueEvents: ReadonlyArray<PeekUserQueueEventRow>;","+  fraudFlags: ReadonlyArray<PeekFraudFlagRow>;","+  recentCrateDrops: ReadonlyArray<PeekCrateDropRow>;","+  selfReferralRow: { selfReferral: boolean };","+}): PeekUserAttentionFlags {","+  return {","+    failedClaim: input.recentReferralClaims.some(","+      (claim) => claim.status === \"failed\" || claim.status === \"error\",","+    ),","+    deadQueueEvent: input.recentUserQueueEvents.some(","+      (event) => event.status === \"dead\",","+    ),","+    activeFraudFlag: input.fraudFlags.some((flag) => flag.status === \"open\"),","+    pendingSolCratePayout: input.recentCrateDrops.some(","+      (drop) => drop.crateType === \"sol\" && drop.status === \"pending\",","+    ),","+    suspiciousReferralLoop: input.selfReferralRow.selfReferral,","+  };","+}"]}],"originalFile":"import type { PeekUserDetail } from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport function formatUserHeading(user: {\n  userId: string;\n  username: string | null;\n}) {\n  return user.username ?? user.userId;\n}\n\nexport async function getPeekUserDetail(\n  userId: string\n): Promise<PeekUserDetail | null> {\n  const sql = getSqlClient();\n  const [user] = await sql<any[]>`\n    select\n      pp.user_id as \"userId\",\n      pp.username as \"username\",\n      pp.wallet as \"wallet\",\n      pp.created_at::text as \"joinedAt\",\n      rc.code as \"referralCode\",\n      rl.referrer_user_id as \"referrerUserId\",\n      ref_code.code as \"referrerCode\",\n      (\n        select count(*)::int\n        from referral_links outbound\n        where outbound.referrer_user_id = pp.user_id\n      ) as \"refereeCount\",\n      coalesce(tla.status, 'none') as \"telegramLinkState\",\n      rl.created_at::text as \"linkedAt\",\n      tla.telegram_user_id as \"telegramUserId\",\n      tla.telegram_username as \"telegramUsername\"\n    from player_profiles pp\n    left join referral_codes rc on rc.user_id = pp.user_id\n    left join referral_links rl on rl.referee_user_id = pp.user_id\n    left join referral_codes ref_code on ref_code.user_id = rl.referrer_user_id\n    left join lateral (\n      select\n        status,\n        provider_account_id as telegram_user_id,\n        nullif(metadata_json->>'telegramUsername', '') as telegram_username\n      from linked_accounts\n      where user_id = pp.user_id\n        and provider = 'telegram'\n        and status = 'active'\n      limit 1\n    ) tla on true\n    where pp.user_id = ${userId}\n  `;\n\n  if (!user) {\n    return null;\n  }\n\n  const outboundReferees = await sql<\n    Array<{\n      refereeUserId: string;\n      refereeUsername: string | null;\n      createdAt: string;\n    }>\n  >`\n    select\n      rl.referee_user_id as \"refereeUserId\",\n      pp.username as \"refereeUsername\",\n      rl.created_at::text as \"createdAt\"\n    from referral_links rl\n    left join player_profiles pp on pp.user_id = rl.referee_user_id\n    where rl.referrer_user_id = ${userId}\n    order by rl.created_at desc\n  `;\n\n  return {\n    user: {\n      userId: user.userId,\n      username: user.username,\n      wallet: user.wallet,\n      joinedAt: user.joinedAt,\n      referralCode: user.referralCode,\n      referrerUserId: user.referrerUserId,\n      referrerCode: user.referrerCode,\n      refereeCount: user.refereeCount,\n      telegramUsername: user.telegramUsername,\n      telegramUserId: user.telegramUserId,\n    },\n    inboundReferral: {\n      referrerUserId: user.referrerUserId,\n      referrerCode: user.referrerCode,\n      linkedAt: user.linkedAt,\n    },\n    outboundReferees,\n    telegram: {\n      state: user.telegramLinkState,\n      telegramUserId: user.telegramUserId,\n      telegramUsername: user.telegramUsername,\n    },\n  };\n}\n","userModified":false}}
