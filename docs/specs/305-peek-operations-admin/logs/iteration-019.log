{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KUs2GFNJc6Zgf4z714s8qV","type":"tool_result","content":"1\t-- 014_telegram_links.sql ŌĆö Telegram account linking via one-time deep-link tokens.\n2\t\n3\tCREATE TABLE telegram_link_tokens (\n4\t  id                BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n5\t  user_id           TEXT         NOT NULL,\n6\t  token             TEXT         NOT NULL UNIQUE,\n7\t  status            TEXT         NOT NULL DEFAULT 'pending'\n8\t                      CHECK (status IN ('pending', 'redeemed', 'expired')),\n9\t  telegram_user_id  TEXT,\n10\t  telegram_username TEXT,\n11\t  expires_at        TIMESTAMPTZ  NOT NULL,\n12\t  redeemed_at       TIMESTAMPTZ,\n13\t  created_at        TIMESTAMPTZ  NOT NULL DEFAULT now()\n14\t);\n15\t\n16\t-- Fast token lookup during redemption (hot path)\n17\tCREATE INDEX idx_tg_link_tokens_token ON telegram_link_tokens (token) WHERE status = 'pending';\n18\t\n19\t-- One active link per platform user\n20\tCREATE UNIQUE INDEX idx_tg_link_tokens_user_redeemed\n21\t  ON telegram_link_tokens (user_id) WHERE status = 'redeemed';\n22\t\n23\t-- One active link per Telegram account\n24\tCREATE UNIQUE INDEX idx_tg_link_tokens_tg_redeemed\n25\t  ON telegram_link_tokens (telegram_user_id) WHERE status = 'redeemed';\n26\t"}]},"parent_tool_use_id":null,"session_id":"a7a6576f-78d4-407f-81cd-207cf72e4e2a","uuid":"1a9ce49f-ca64-4997-bb8a-9a27af83e96a","timestamp":"2026-04-25T11:49:40.510Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/migrations/014_telegram_links.sql","content":"-- 014_telegram_links.sql ŌĆö Telegram account linking via one-time deep-link tokens.\n\nCREATE TABLE telegram_link_tokens (\n  id                BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  user_id           TEXT         NOT NULL,\n  token             TEXT         NOT NULL UNIQUE,\n  status            TEXT         NOT NULL DEFAULT 'pending'\n                      CHECK (status IN ('pending', 'redeemed', 'expired')),\n  telegram_user_id  TEXT,\n  telegram_username TEXT,\n  expires_at        TIMESTAMPTZ  NOT NULL,\n  redeemed_at       TIMESTAMPTZ,\n  created_at        TIMESTAMPTZ  NOT NULL DEFAULT now()\n);\n\n-- Fast token lookup during redemption (hot path)\nCREATE INDEX idx_tg_link_tokens_token ON telegram_link_tokens (token) WHERE status = 'pending';\n\n-- One active link per platform user\nCREATE UNIQUE INDEX idx_tg_link_tokens_user_redeemed\n  ON telegram_link_tokens (user_id) WHERE status = 'redeemed';\n\n-- One active link per Telegram account\nCREATE UNIQUE INDEX idx_tg_link_tokens_tg_redeemed\n  ON telegram_link_tokens (telegram_user_id) WHERE status = 'redeemed';\n","numLines":26,"startLine":1,"totalLines":26}}}
