nks rl","-    left join player_profiles pp on pp.user_id = rl.referee_user_id","-    where rl.referrer_user_id = ${userId}","-    order by rl.created_at desc","-  `;","+  const wallet = user.wallet;"," ","+  const [","+    outboundReferees,","+    linkedAccounts,","+    recentTelegramLinkTokens,","+    kolRate,","+    referralEarnings,","+    recentReferralClaims,","+    points,","+    recentPointGrants,","+    recentCrateDrops,","+    challengeSummary,","+    recentGameEntries,","+    recentTransactions,","+    fraudFlags,","+    recentUserQueueEvents,","+    selfReferralRow,","+  ] = await Promise.all([","+    fetchOutboundReferees(sql, userId),","+    fetchLinkedAccounts(sql, userId),","+    fetchRecentTelegramLinkTokens(sql, userId, tokenLimit),","+    fetchKolRate(sql, userId),","+    fetchReferralEarnings(sql, userId),","+    fetchRecentReferralClaims(sql, userId, recentLimit),","+    fetchPlayerPoints(sql, userId),","+    fetchRecentPointGrants(sql, userId, recentLimit),","+    fetchRecentCrateDrops(sql, userId, recentLimit),","+    fetchChallengeSummary(sql, userId),","+    fetchRecentGameEntries(sql, userId, recentLimit),","+    fetchRecentTransactions(sql, userId, recentLimit),","+    fetchFraudFlags(sql, userId, recentLimit),","+    fetchRecentUserQueueEvents(sql, userId, wallet, recentLimit),","+    fetchSelfReferralIndicator(sql, userId),","+  ]);","+","+  const attention = computeAttention({","+    recentReferralClaims,","+    recentUserQueueEvents,","+    fraudFlags,","+    recentCrateDrops,","+    selfReferralRow,","+  });","+","   return {","     user: {","       userId: user.userId,"]},{"oldStart":81,"oldLines":6,"newStart":168,"newLines":9,"lines":["       refereeCount: user.refereeCount,","       telegramUsername: user.telegramUsername,","       telegramUserId: user.telegramUserId,","+      avatarUrl: user.avatarUrl,","+      heatMultiplier: user.heatMultiplier,","+      profilePointsBalance: user.profilePointsBalance,","     },","     inboundRef