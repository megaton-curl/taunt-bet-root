{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014nrNw2Vw6XBvCSW7PfgXCR","type":"tool_result","content":"1\t-- 011_challenge_engine.sql ŌĆö Challenge engine, reward system, and loot crate tables + seed data.\n2\t\n3\t-- Operator-tunable reward/economy parameters\n4\tCREATE TABLE reward_config (\n5\t  key         TEXT PRIMARY KEY,\n6\t  value       TEXT NOT NULL,\n7\t  updated_at  TIMESTAMPTZ NOT NULL DEFAULT now()\n8\t);\n9\t\n10\t-- Player point balances and lifetime stats\n11\tCREATE TABLE player_points (\n12\t  user_id             TEXT PRIMARY KEY,\n13\t  wallet              TEXT NOT NULL UNIQUE,\n14\t  balance             BIGINT NOT NULL DEFAULT 0,\n15\t  lifetime_earned     BIGINT NOT NULL DEFAULT 0,\n16\t  updated_at          TIMESTAMPTZ NOT NULL DEFAULT now()\n17\t);\n18\t\n19\t-- Immutable point grant ledger (source of truth for history + idempotency)\n20\tCREATE TABLE point_grants (\n21\t  id                  BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n22\t  user_id             TEXT NOT NULL,\n23\t  wallet              TEXT NOT NULL,\n24\t  source_type         TEXT NOT NULL CHECK (source_type IN ('wager', 'challenge_completed', 'bonus_completed', 'crate_points')),\n25\t  source_id           TEXT NOT NULL,\n26\t  amount              BIGINT NOT NULL,\n27\t  metadata            JSONB NOT NULL DEFAULT '{}',\n28\t  created_at          TIMESTAMPTZ NOT NULL DEFAULT now(),\n29\t  UNIQUE (user_id, source_type, source_id)\n30\t);\n31\t\n32\tCREATE INDEX idx_point_grants_user_created ON point_grants (user_id, created_at DESC);\n33\t\n34\t-- Reward pool accounting (single row, updated atomically)\n35\tCREATE TABLE reward_pool (\n36\t  id                  INT PRIMARY KEY DEFAULT 1 CHECK (id = 1),\n37\t  balance_lamports    BIGINT NOT NULL DEFAULT 0,\n38\t  lifetime_funded     BIGINT NOT NULL DEFAULT 0,\n39\t  lifetime_paid       BIGINT NOT NULL DEFAULT 0,\n40\t  updated_at          TIMESTAMPTZ NOT NULL DEFAULT now()\n41\t);\n42\t\n43\t-- Append-only pool funding ledger for idempotent reward_pool_fund handling\n44\tCREATE TABLE reward_pool_fundings (\n45\t  id                  BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n46\t  round_id            TEXT NOT NULL UNIQUE,\n47\t  fee_lamports        BIGINT NOT NULL,\n48\t  funded_lamports     BIGINT NOT NULL,\n49\t  created_at          TIMESTAMPTZ NOT NULL DEFAULT now()\n50\t);\n51\t\n52\t-- Campaign container (Daily, Weekly, Onboarding, Dogpile)\n53\tCREATE TABLE campaigns (\n54\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n55\t  name            TEXT NOT NULL UNIQUE,\n56\t  campaign_type   TEXT NOT NULL CHECK (campaign_type IN ('daily', 'weekly', 'onboarding', 'dogpile')),\n57\t  starts_at       TIMESTAMPTZ,\n58\t  ends_at         TIMESTAMPTZ,\n59\t  is_active       BOOLEAN NOT NULL DEFAULT true,\n60\t  config          JSONB NOT NULL DEFAULT '{}',\n61\t  created_at      TIMESTAMPTZ NOT NULL DEFAULT now()\n62\t);\n63\t\n64\t-- Challenge template definitions (data, not code)\n65\tCREATE TABLE challenges (\n66\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n67\t  campaign_id     BIGINT NOT NULL REFERENCES campaigns(id),\n68\t  title           TEXT NOT NULL,\n69\t  description     TEXT,\n70\t  action          TEXT NOT NULL,\n71\t  scope           TEXT NOT NULL DEFAULT 'any' CHECK (scope IN ('any', 'flipyou', 'potshot', 'closecall')),\n72\t  condition       TEXT NOT NULL DEFAULT 'count',\n73\t  threshold       INT NOT NULL,\n74\t  reward_type     TEXT NOT NULL CHECK (reward_type IN ('points', 'crate')),\n75\t  reward_amount   INT,\n76\t  prerequisite_id BIGINT REFERENCES challenges(id),\n77\t  eligible_if     JSONB NOT NULL DEFAULT '{}',\n78\t  sort_order      INT NOT NULL DEFAULT 0,\n79\t  is_active       BOOLEAN NOT NULL DEFAULT true,\n80\t  created_at      TIMESTAMPTZ NOT NULL DEFAULT now()\n81\t);\n82\t\n83\t-- Per-player challenge assignments for a specific period\n84\tCREATE TABLE challenge_assignments (\n85\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n86\t  user_id         TEXT NOT NULL,\n87\t  challenge_id    BIGINT NOT NULL REFERENCES challenges(id),\n88\t  period_key      TEXT NOT NULL,\n89\t  status          TEXT NOT NULL DEFAULT 'active' CHECK (status IN ('active', 'completed', 'expired')),\n90\t  progress        INT NOT NULL DEFAULT 0,\n91\t  target          INT NOT NULL,\n92\t  assigned_at     TIMESTAMPTZ NOT NULL DEFAULT now(),\n93\t  expires_at      TIMESTAMPTZ,\n94\t  completed_at    TIMESTAMPTZ,\n95\t  UNIQUE (user_id, challenge_id, period_key)\n96\t);\n97\t\n98\tCREATE INDEX idx_assignments_active ON challenge_assignments (user_id, status) WHERE status = 'active';\n99\tCREATE INDEX idx_assignments_period ON challenge_assignments (period_key, status);\n100\t\n101\t-- Tracks which game sessions contributed to progress (for anti-gaming audit + idempotency)\n102\tCREATE TABLE progress_events (\n103\t  id                  BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n104\t  assignment_id       BIGINT NOT NULL REFERENCES challenge_assignments(id),\n105\t  round_id            TEXT NOT NULL,\n106\t  user_id             TEXT NOT NULL,\n107\t  progress_delta      INT NOT NULL DEFAULT 1,\n108\t  metadata            JSONB NOT NULL DEFAULT '{}',\n109\t  created_at          TIMESTAMPTZ NOT NULL DEFAULT now(),\n110\t  UNIQUE (assignment_id, round_id)\n111\t);\n112\t\n113\t-- Completion bonus definitions (meta-quest: complete all dailies -> bonus)\n114\tCREATE TABLE completion_bonuses (\n115\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n116\t  campaign_id     BIGINT NOT NULL REFERENCES campaigns(id),\n117\t  title           TEXT NOT NULL,\n118\t  description     TEXT,\n119\t  required_count  INT NOT NULL,\n120\t  reward_type     TEXT NOT NULL CHECK (reward_type IN ('points', 'crate')),\n121\t  reward_amount   INT,\n122\t  is_active       BOOLEAN NOT NULL DEFAULT true,\n123\t  created_at      TIMESTAMPTZ NOT NULL DEFAULT now()\n124\t);\n125\t\n126\t-- Tracks bonus completion per player per period\n127\tCREATE TABLE bonus_completions (\n128\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n129\t  user_id         TEXT NOT NULL,\n130\t  bonus_id        BIGINT NOT NULL REFERENCES completion_bonuses(id),\n131\t  period_key      TEXT NOT NULL,\n132\t  completed_at    TIMESTAMPTZ NOT NULL DEFAULT now(),\n133\t  UNIQUE (user_id, bonus_id, period_key)\n134\t);\n135\t\n136\t-- Loot crate drops\n137\tCREATE TABLE crate_drops (\n138\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n139\t  user_id         TEXT NOT NULL,\n140\t  trigger_type    TEXT NOT NULL CHECK (trigger_type IN ('game_settled', 'challenge_completed', 'bonus_completed')),\n141\t  trigger_id      TEXT NOT NULL,\n142\t  crate_type      TEXT NOT NULL CHECK (crate_type IN ('points', 'sol')),\n143\t  contents_amount TEXT NOT NULL,\n144\t  status          TEXT NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'granted', 'failed')),\n145\t  created_at      TIMESTAMPTZ NOT NULL DEFAULT now(),\n146\t  granted_at      TIMESTAMPTZ,\n147\t  UNIQUE (user_id, trigger_type, trigger_id)\n148\t);\n149\t\n150\tCREATE INDEX idx_crate_drops_user ON crate_drops (user_id, created_at DESC);\n151\tCREATE INDEX idx_crate_drops_pending ON crate_drops (status) WHERE status = 'pending';\n152\t\n153\t-- Fraud flags\n154\tCREATE TABLE fraud_flags (\n155\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n156\t  user_id         TEXT NOT NULL,\n157\t  flag_type       TEXT NOT NULL,\n158\t  details         JSONB NOT NULL DEFAULT '{}',\n159\t  related_id      TEXT,\n160\t  status          TEXT NOT NULL DEFAULT 'open' CHECK (status IN ('open', 'reviewed', 'dismissed')),\n161\t  created_at      TIMESTAMPTZ NOT NULL DEFAULT now(),\n162\t  resolved_at     TIMESTAMPTZ\n163\t);\n164\t\n165\t-- Dogpile event schedule and state\n166\tCREATE TABLE dogpile_events (\n167\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n168\t  campaign_id     BIGINT REFERENCES campaigns(id),\n169\t  starts_at       TIMESTAMPTZ NOT NULL,\n170\t  ends_at         TIMESTAMPTZ NOT NULL,\n171\t  multiplier      NUMERIC(4,2) NOT NULL DEFAULT 2.0,\n172\t  status          TEXT NOT NULL DEFAULT 'scheduled' CHECK (status IN ('scheduled', 'active', 'ended', 'cancelled')),\n173\t  created_at      TIMESTAMPTZ NOT NULL DEFAULT now()\n174\t);\n175\t\n176\tCREATE INDEX idx_dogpile_active ON dogpile_events (status, starts_at, ends_at) WHERE status IN ('scheduled', 'active');\n177\t\n178\t-- ============================================================\n179\t-- Seed data\n180\t-- ============================================================\n181\t\n182\t-- FR-13: reward_config defaults\n183\tINSERT INTO reward_config (key, value) VALUES\n184\t  ('points_per_dollar',          '500'),\n185\t  ('dogpile_default_multiplier', '2.0'),\n186\t  ('reward_pool_fee_share',      '0.20'),\n187\t  ('points_crate_drop_rate',     '0.05'),\n188\t  ('sol_crate_drop_rate',        '0.01'),\n189\t  ('sol_crate_pool_pct',         '0.10'),\n190\t  ('sol_crate_min_value',        '10000000'),\n191\t  ('points_crate_min',           '500'),\n192\t  ('points_crate_max',           '5000'),\n193\t  ('daily_challenge_count',      '3'),\n194\t  ('weekly_challenge_count',     '2');\n195\t\n196\t-- Reward pool singleton (balance 0)\n197\tINSERT INTO reward_pool (id, balance_lamports, lifetime_funded, lifetime_paid) VALUES (1, 0, 0, 0);\n198\t\n199\t-- Campaigns\n200\tINSERT INTO campaigns (name, campaign_type) VALUES\n201\t  ('Daily Challenges',  'daily'),\n202\t  ('Weekly Challenges', 'weekly'),\n203\t  ('Onboarding',        'onboarding');\n204\t\n205\t-- Daily challenge templates (~6, top 3 by sort_order assigned each day)\n206\tINSERT INTO challenges (campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, sort_order) VALUES\n207\t  ((SELECT id FROM campaigns WHERE name = 'Daily Challenges'), 'Play 3 Games',      'Complete 3 games of any type',           'game_completed', 'any',       'count', 3, 'points', 100,  1),\n208\t  ((SELECT id FROM campaigns WHERE name = 'Daily Challenges'), 'Win a Flip You',   'Win a Flip You game',                    'game_won',       'flipyou',  'count', 1, 'points', 150,  2),\n209\t  ((SELECT id FROM campaigns WHERE name = 'Daily Challenges'), 'Fill a Lobby',      'Create a game and attract an opponent',  'lobby_filled',   'any',       'count', 1, 'points', 200,  3),\n210\t  ((SELECT id FROM campaigns WHERE name = 'Daily Challenges'), 'Play 5 Games',      'Complete 5 games of any type',           'game_completed', 'any',       'count', 5, 'points', 250,  4),\n211\t  ((SELECT id FROM campaigns WHERE name = 'Daily Challenges'), 'Win 3 Games',       'Win 3 games of any type',                'game_won',       'any',       'count', 3, 'points', 300,  5),\n212\t  ((SELECT id FROM campaigns WHERE name = 'Daily Challenges'), 'Try Close Call',    'Play a Close Call round',                'game_completed', 'closecall', 'count', 1, 'points', 150,  6);\n213\t\n214\t-- Weekly challenge templates (~4, top 2 by sort_order assigned each week)\n215\tINSERT INTO challenges (campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, sort_order) VALUES\n216\t  ((SELECT id FROM campaigns WHERE name = 'Weekly Challenges'), 'Play 20 Games',         'Complete 20 games of any type',      'game_completed', 'any', 'count',             20, 'points', 1000, 1),\n217\t  ((SELECT id FROM campaigns WHERE name = 'Weekly Challenges'), 'Win 10 Games',          'Win 10 games of any type',           'game_won',       'any', 'count',             10, 'points', 1500, 2),\n218\t  ((SELECT id FROM campaigns WHERE name = 'Weekly Challenges'), 'Play Every Game Type',  'Play at least one of each game type','game_completed', 'any', 'unique_game_types',  3, 'points', 2000, 3),\n219\t  ((SELECT id FROM campaigns WHERE name = 'Weekly Challenges'), 'Fill 5 Lobbies',        'Create 5 games that get filled',     'lobby_filled',   'any', 'count',              5, 'points', 1200, 4);\n220\t\n221\t-- Onboarding challenge templates (3-step chain via prerequisite_id)\n222\t-- Step 1: no prerequisite\n223\tINSERT INTO challenges (campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, prerequisite_id, sort_order) VALUES\n224\t  ((SELECT id FROM campaigns WHERE name = 'Onboarding'), 'Play Your First Game', 'Complete any game to get started', 'game_completed', 'any', 'count', 1, 'points', 1000, NULL, 1);\n225\t\n226\t-- Step 2: prerequisite = step 1\n227\tINSERT INTO challenges (campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, prerequisite_id, sort_order) VALUES\n228\t  ((SELECT id FROM campaigns WHERE name = 'Onboarding'), 'Win a Game', 'Win any game', 'game_won', 'any', 'count', 1, 'points', 1500,\n229\t   (SELECT id FROM challenges WHERE campaign_id = (SELECT id FROM campaigns WHERE name = 'Onboarding') AND sort_order = 1), 2);\n230\t\n231\t-- Step 3: prerequisite = step 2\n232\tINSERT INTO challenges (campaign_id, title, description, action, scope, condition, threshold, reward_type, reward_amount, prerequisite_id, sort_order) VALUES\n233\t  ((SELECT id FROM campaigns WHERE name = 'Onboarding'), 'Try All 3 Game Types', 'Play Flip You, Pot Shot, and Close Call', 'game_completed', 'any', 'unique_game_types', 3, 'points', 2500,\n234\t   (SELECT id FROM challenges WHERE campaign_id = (SELECT id FROM campaigns WHERE name = 'Onboarding') AND sort_order = 2), 3);\n235\t\n236\t-- Daily completion bonus (complete all 3 daily challenges -> bonus crate)\n237\tINSERT INTO completion_bonuses (campaign_id, title, description, required_count, reward_type) VALUES\n238\t  ((SELECT id FROM campaigns WHERE name = 'Daily Challenges'), 'Daily Bonus Crate', 'Complete all daily challenges for a bonus crate', 3, 'crate');\n239\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_012DWrgQt8Uo78uvA4yxvUQr","session_id":"a7a6576f-78d4-407f-81cd-207cf72e4e2a","uuid":"4eb4484b-33c7-4f4a-8760-3e04e668bce8","timestamp":"2026-04-25T11:49:23.001Z"}
