{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SVo8gx2BTKF9ow4VVuYWeZ","type":"tool_result","content":"1\t-- 014_telegram_links.sql ŌĆö Telegram account linking via one-time deep-link tokens.\n2\t\n3\tCREATE TABLE telegram_link_tokens (\n4\t  id                BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n5\t  user_id           TEXT         NOT NULL,\n6\t  token             TEXT         NOT NULL UNIQUE,\n7\t  status            TEXT         NOT NULL DEFAULT 'pending'\n8\t                      CHECK (status IN ('pending', 'redeemed', 'expired')),\n9\t  telegram_user_id  TEXT,\n10\t  telegram_username TEXT,\n11\t  expires_at        TIMESTAMPTZ  NOT NULL,\n12\t  redeemed_at       TIMESTAMPTZ,\n13\t  created_at        TIMESTAMPTZ  NOT NULL DEFAULT now()\n14\t);\n15\t\n16\t-- Fast token lookup during redemption (hot path)\n17\tCREATE INDEX idx_tg_link_tokens_token ON telegram_link_tokens (token) WHERE status = 'pending';\n18\t\n19\t-- One active link per platform user\n20\tCREATE UNIQUE INDEX idx_tg_link_tokens_user_redeemed\n21\t  ON telegram_link_tokens (user_id) WHERE status = 'redeemed';\n22\t\n23\t-- One active link per Telegram account\n24\tCREATE UNIQUE INDEX idx_tg_link_tokens_tg_redeemed\n25\t  ON telegram_link_tokens (telegram_user_id) WHERE status = 'redeemed';\n26\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_012DWrgQt8Uo78uvA4yxvUQr","session_id":"a7a6576f-78d4-407f-81cd-207cf72e4e2a","uuid":"5056ba9b-6e86-47de-aebf-42ee6afab915","timestamp":"2026-04-25T11:49:22.620Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Nippuz7rzngqemtN5RusMw","type":"tool_result","content":"1\t-- 010_referral.sql ŌĆö Referral system (codes, links, earnings, claims, KOL rates).\n2\t\n3\tCREATE TABLE referral_codes (\n4\t  id          BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n5\t  user_id     TEXT         NOT NULL UNIQUE,\n6\t  wallet      TEXT         NOT NULL UNIQUE,\n7\t  code        TEXT         NOT NULL UNIQUE,\n8\t  created_at  TIMESTAMPTZ  NOT NULL DEFAULT now(),\n9\t  updated_at  TIMESTAMPTZ  NOT NULL DEFAULT now()\n10\t);\n11\t\n12\tCREATE TABLE referral_links (\n13\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n14\t  referrer_user_id TEXT        NOT NULL,\n15\t  referee_user_id  TEXT        NOT NULL UNIQUE,\n16\t  referrer_wallet  TEXT        NOT NULL,\n17\t  referee_wallet   TEXT        NOT NULL,\n18\t  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now()\n19\t);\n20\t\n21\tCREATE INDEX idx_referral_links_referrer ON referral_links (referrer_user_id);\n22\t\n23\tCREATE TABLE referral_earnings (\n24\t  id                        BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n25\t  referrer_user_id          TEXT         NOT NULL,\n26\t  referee_user_id           TEXT         NOT NULL,\n27\t  referrer_wallet           TEXT         NOT NULL,\n28\t  referee_wallet            TEXT         NOT NULL,\n29\t  round_id                  TEXT         NOT NULL,\n30\t  game_type                 TEXT         NOT NULL,\n31\t  wager_lamports            BIGINT       NOT NULL,\n32\t  fee_lamports              BIGINT       NOT NULL,\n33\t  referrer_earned_lamports  BIGINT       NOT NULL,\n34\t  referrer_rate_bps         INTEGER      NOT NULL,\n35\t  referee_rebate_lamports   BIGINT       NOT NULL,\n36\t  referee_rebate_rate_bps   INTEGER      NOT NULL,\n37\t  created_at                TIMESTAMPTZ  NOT NULL DEFAULT now(),\n38\t\n39\t  CONSTRAINT uq_referral_earnings_referee_round UNIQUE (referee_user_id, round_id)\n40\t);\n41\t\n42\tCREATE INDEX idx_referral_earnings_referrer ON referral_earnings (referrer_user_id, created_at);\n43\tCREATE INDEX idx_referral_earnings_referee ON referral_earnings (referee_user_id, created_at);\n44\tCREATE INDEX idx_referral_earnings_round_id ON referral_earnings (round_id);\n45\t\n46\tCREATE TABLE referral_claims (\n47\t  id              UUID         PRIMARY KEY DEFAULT gen_random_uuid(),\n48\t  user_id         TEXT         NOT NULL,\n49\t  wallet          TEXT         NOT NULL,\n50\t  amount_lamports BIGINT       NOT NULL,\n51\t  status          TEXT         NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'error', 'completed', 'failed')),\n52\t  retry_count     INTEGER      NOT NULL DEFAULT 0,\n53\t  tx_signature    TEXT,\n54\t  error           TEXT,\n55\t  requested_at    TIMESTAMPTZ  NOT NULL DEFAULT now(),\n56\t  processed_at    TIMESTAMPTZ\n57\t);\n58\t\n59\tCREATE INDEX idx_referral_claims_user_id ON referral_claims (user_id, requested_at);\n60\tCREATE INDEX idx_referral_claims_status ON referral_claims (status) WHERE status IN ('pending', 'processing');\n61\tCREATE UNIQUE INDEX idx_referral_claims_user_active ON referral_claims (user_id) WHERE status IN ('pending', 'processing', 'error');\n62\t\n63\tCREATE TABLE referral_kol_rates (\n64\t  user_id     TEXT         PRIMARY KEY,\n65\t  wallet      TEXT         NOT NULL UNIQUE,\n66\t  rate_bps    INTEGER      NOT NULL,\n67\t  set_by      TEXT         NOT NULL,\n68\t  created_at  TIMESTAMPTZ  NOT NULL DEFAULT now(),\n69\t  updated_at  TIMESTAMPTZ  NOT NULL DEFAULT now()\n70\t);\n71\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_012DWr