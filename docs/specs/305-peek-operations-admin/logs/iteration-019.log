{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_013rM4daSnyr9A1mRbG2oWAY","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01RfxTvHCqQHfwz3oUfnDEUk","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/db/queries/get-peek-user-detail.ts","content":"import type {\n  PeekChallengeAssignmentSummary,\n  PeekCrateDropRow,\n  PeekFraudFlagRow,\n  PeekGameEntryRow,\n  PeekKolRate,\n  PeekLinkedAccountRow,\n  PeekPlayerPoints,\n  PeekPointGrantRow,\n  PeekReferralClaimRow,\n  PeekReferralEarningsSummary,\n  PeekTelegramLinkTokenRow,\n  PeekTransactionRow,\n  PeekUserAttentionFlags,\n  PeekUserDetail,\n  PeekUserQueueEventRow,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_USER_DETAIL_RECENT_LIMIT = 25;\nexport const PEEK_USER_DETAIL_TOKEN_LIMIT = 10;\n\ntype Sql = ReturnType<typeof getSqlClient>;\n\ntype GetPeekUserDetailOptions = {\n  sql?: Sql;\n  recentLimit?: number;\n  tokenLimit?: number;\n};\n\nexport function formatUserHeading(user: {\n  userId: string;\n  username: string | null;\n}) {\n  return user.username ?? user.userId;\n}\n\nexport async function getPeekUserDetail(\n  userId: string,\n  options: GetPeekUserDetailOptions = {},\n): Promise<PeekUserDetail | null> {\n  const sql = options.sql ?? getSqlClient();\n  const recentLimit = clampPositiveInt(\n    options.recentLimit,\n    PEEK_USER_DETAIL_RECENT_LIMIT,\n  );\n  const tokenLimit = clampPositiveInt(\n    options.tokenLimit,\n    PEEK_USER_DETAIL_TOKEN_LIMIT,\n  );\n\n  // Identity + linked-account telegram view (preserved as queries[0] so the\n  // 303-era listing/detail tests continue to assert the same SQL contract).\n  const [user] = await sql<\n    Array<{\n      userId: string;\n      username: string | null;\n      wallet: string;\n      joinedAt: string;\n      avatarUrl: string | null;\n      heatMultiplier: string;\n      profilePointsBalance: string;\n      referralCode: string | null;\n      referrerUserId: string | null;\n      referrerCode: string | null;\n      refereeCount: number;\n      telegramLinkState: \"active\" | \"none\";\n      linkedAt: string | null;\n      telegramUserId: string | null;\n      telegramUsername: string | null;\n    }>\n  >`\n    select\n      pp.user_id as \"userId\",\n      pp.username as \"username\",\n      pp.wallet as \"wallet\",\n      pp.created_at::text as \"joinedAt\",\n      pp.avatar_url as \"avatarUrl\",\n      pp.heat_multiplier::text as \"heatMultiplier\",\n      pp.points_balance::text as \"profilePointsBalance\",\n      rc.code as \"referralCode\",\n      rl.referrer_user_id as \"referrerUserId\",\n      ref_code.code as \"referrerCode\",\n      (\n        select count(*)::int\n        from referral_links outbound\n        where outbound.referrer_user_id = pp.user_id\n      ) as \"refereeCount\",\n      coalesce(tla.status, 'none') as \"telegramLinkState\",\n      rl.created_at::text as \"linkedAt\",\n      tla.telegram_user_id as \"telegramUserId\",\n      tla.telegram_username as \"telegramUsername\"\n    from player_profiles pp\n    left join referral_codes rc on rc.user_id = pp.user_id\n    left join referral_links rl on rl.referee_user_id = pp.user_id\n    left join referral_codes ref_code on ref_code.user_id = rl.referrer_user_id\n    left join lateral (\n      select\n        status,\n        provider_account_id as telegram_user_id,\n        nullif(metadata_json->>'telegramUsername', '') as telegram_username\n      from linked_accounts\n      where user_id = pp.user_id\n        and provider = 'telegram'\n        and status = 'active'\n      limit 1\n    ) tla on true\n    where pp.user_id = ${userId}\n  `;\n\n  if (!user) {\n    return null;\n  }\n\n  const wallet = user.wallet;\n\n  const [\n    outboundReferees,\n    linkedAccounts,\n    recentTelegramLinkTokens,\n    kolRate,\n    referralEarnings,\n    recentReferralClaims,\n    points,\n    recentPointGrants,\n    recentCrateDrops,\n    challengeSummary,\n    recentGameEntries,\n    recentTransactions,\n    fraudFlags,\n    recentUserQueueEvents,\n    selfReferralRow,\n  ] = await Promise.all([\n    fetchOutboundReferees(sql, userId),\n    fetchLinkedAccounts(sql, userId),\n    fetchRecentTelegramLinkTokens(sql, userId, tokenLimit),\n    fetchKolRate(sql, userId),\n    fetchReferralEarnings(sql, userId),\n    fetchRecentReferralClaims(sql, userId, recentLimit),\n    fetchPlayerPoints(sql, userId),\n    fetchRecentPointGrants(sql, userId, recentLimit),\n    fetchRecentCrateDrops(sql, userId, recentLimit),\n    fetchChallengeSummary(sql, userId),\n    fetchRecentGameEntries(sql, userId, recentLimit),\n    fetchRecentTransactions(sql, userId, recentLimit),\n    fetchFraudFlags(sql, userId, recentLimit),\n    fetchRecentUserQueueEvents(sql, userId, wallet, recentLimit),\n    fetchSelfReferralIndicator(sql, userId),\n  ]);\n\n  const attention = computeAttention({\n    recentReferralClaims,\n    recentUserQueueEvents,\n    fraudFlags,\n    recentCrateDrops,\n    selfReferralRow,\n  });\n\n  return {\n    user: {\n      userId: user.userId,\n      username: user.username,\n      wallet: user.wallet,\n      joinedAt: user.joinedAt,\n      referralCode: user.referralCode,\n      referrerUserId: user.referrerUserId,\n      referrerCode: user.referrerCode,\n      refereeCount: user.refereeCount,\n      telegramUsername: user.telegramUsername,\n      telegramUserId: user.telegramUserId,\n      avatarUrl: user.avatarUrl,\n      heatMultiplier: user.heatMultiplier,\n      profilePointsBalance: user.profilePointsBalance,\n    },\n    inboundReferral: {\n      referrerUserId: user.referrerUserId,\n      referrerCode: user.referrerCode,\n      linkedAt: user.linkedAt,\n    },\n    outboundReferees,\n    telegram: {\n      state: user.telegramLinkState,\n      telegramUserId: user.telegramUserId,\n      telegramUsername: user.telegramUsername,\n    },\n    linkedAccounts,\n    recentTelegramLinkTokens,\n    kolRate,\n    referralEarnings,\n    recentReferralClaims,\n    points,\n    recentPointGrants,\n    recentCrateDrops,\n    challengeSummary,\n    recentGameEntries,\n    recentTransactions,\n    fraudFlags,\n    recentUserQueueEvents,\n    attention,\n  };\n}\n\nfunction clampPositiveInt(value: number | undefined, fallback: number): number {\n  if (typeof value !== \"number\" || !Number.isFinite(value)) return fallback;\n  const floored = Math.floor(value);\n  if (floored <= 0) return 1;\n  return floored;\n}\n\nasync function fetchOutboundReferees(\n  sql: Sql,\n  userId: string,\n): Promise<PeekUserDetail[\"outboundReferees\"]> {\n  return sql<\n    Array<{\n      refereeUserId: string;\n      refereeUsername: string | null;\n      createdAt: string;\n    }>\n  >`\n    select\n      rl.referee_user_id as \"refereeUserId\",\n      pp.username as \"refereeUsername\",\n      rl.created_at::text as \"createdAt\"\n    from referral_links rl\n    left join player_profiles pp on pp.user_id = rl.referee_user_id\n    where rl.referrer_user_id = ${userId}\n    order by rl.created_at desc\n  `;\n}\n\nasync function fetchLinkedAccounts(\n  sql: Sql,\n  userId: string,\n): Promise<ReadonlyArray<PeekLinkedAccountRow>> {\n  return sql<Array<PeekLinkedAccountRow>>`\n    select\n      id::text as \"id\",\n      provider,\n      provider_account_id as \"providerAccountId\",\n      status,\n      nullif(metadata_json->>'telegramUsername', '') as \"telegramUsername\",\n      metadata_json as \"metadataJson\",\n      linked_at::text as \"linkedAt\",\n      updated_at::text as \"updatedAt\"\n    from linked_accounts\n    where user_id = ${userId}\n    order by linked_at desc\n  `;\n}\n\nasync function fetchRecentTelegramLinkTokens(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekTelegramLinkTokenRow>> {\n  return sql<Array<PeekTelegramLinkTokenRow>>`\n    select\n      id::text as \"id\",\n      status,\n      telegram_user_id as \"telegramUserId\",\n      telegram_username as \"telegramUsername\",\n      expires_at::text as \"expiresAt\",\n      redeemed_at::text as \"redeemedAt\",\n      created_at::text as \"createdAt\"\n    from telegram_link_tokens\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchKolRate(\n  sql: Sql,\n  userId: string,\n): Promise<PeekKolRate | null> {\n  const [row] = await sql<\n    Array<{\n      rateBps: number;\n      setBy: string;\n      createdAt: string;\n      updatedAt: string;\n    }>\n  >`\n    select\n      rate_bps as \"rateBps\",\n      set_by as \"setBy\",\n      created_at::text as \"createdAt\",\n      updated_at::text as \"updatedAt\"\n    from referral_kol_rates\n    where user_id = ${userId}\n    limit 1\n  `;\n  return row ?? null;\n}\n\nasync function fetchReferralEarnings(\n  sql: Sql,\n  userId: string,\n): Promise<PeekReferralEarningsSummary> {\n  const [row] = await sql<\n    Array<{\n      earningsCount: number;\n      totalReferrerEarnedLamports: string;\n      totalRefereeRebateLamports: string;\n      lastEarnedAt: string | null;\n    }>\n  >`\n    select\n      count(*)::int as \"earningsCount\",\n      coalesce(sum(referrer_earned_lamports), 0)::text as \"totalReferrerEarnedLamports\",\n      coalesce(sum(referee_rebate_lamports), 0)::text as \"totalRefereeRebateLamports\",\n      max(created_at)::text as \"lastEarnedAt\"\n    from referral_earnings\n    where referrer_user_id = ${userId} or referee_user_id = ${userId}\n  `;\n  return (\n    row ?? {\n      earningsCount: 0,\n      totalReferrerEarnedLamports: \"0\",\n      totalRefereeRebateLamports: \"0\",\n      lastEarnedAt: null,\n    }\n  );\n}\n\nasync function fetchRecentReferralClaims(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekReferralClaimRow>> {\n  return sql<Array<PeekReferralClaimRow>>`\n    select\n      id::text as \"id\",\n      amount_lamports::text as \"amountLamports\",\n      status,\n      retry_count as \"retryCount\",\n      tx_signature as \"txSignature\",\n      error,\n      requested_at::text as \"requestedAt\",\n      processed_at::text as \"processedAt\"\n    from referral_claims\n    where user_id = ${userId}\n    order by requested_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchPlayerPoints(\n  sql: Sql,\n  userId: string,\n): Promise<PeekPlayerPoints> {\n  const [row] = await sql<\n    Array<{\n      balance: string;\n      lifetimeEarned: string;\n      updatedAt: string;\n    }>\n  >`\n    select\n      balance::text as \"balance\",\n      lifetime_earned::text as \"lifetimeEarned\",\n      updated_at::text as \"updatedAt\"\n    from player_points\n    where user_id = ${userId}\n    limit 1\n  `;\n  return (\n    row ?? {\n      balance: \"0\",\n      lifetimeEarned: \"0\",\n      updatedAt: null,\n    }\n  );\n}\n\nasync function fetchRecentPointGrants(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekPointGrantRow>> {\n  return sql<Array<PeekPointGrantRow>>`\n    select\n      id::text as \"id\",\n      source_type as \"sourceType\",\n      source_id as \"sourceId\",\n      amount::text as \"amount\",\n      created_at::text as \"createdAt\"\n    from point_grants\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchRecentCrateDrops(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekCrateDropRow>> {\n  return sql<Array<PeekCrateDropRow>>`\n    select\n      id::text as \"id\",\n      trigger_type as \"triggerType\",\n      trigger_id as \"triggerId\",\n      crate_type as \"crateType\",\n      contents_amount as \"contentsAmount\",\n      status,\n      created_at::text as \"createdAt\",\n      granted_at::text as \"grantedAt\"\n    from crate_drops\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchChallengeSummary(\n  sql: Sql,\n  userId: string,\n): Promise<PeekChallengeAssignmentSummary> {\n  const [row] = await sql<\n    Array<{\n      active: number;\n      completed: number;\n      expired: number;\n      total: number;\n    }>\n  >`\n    select\n      count(*) filter (where status = 'active')::int as \"active\",\n      count(*) filter (where status = 'completed')::int as \"completed\",\n      count(*) filter (where status = 'expired')::int as \"expired\",\n      count(*)::int as \"total\"\n    from challenge_assignments\n    where user_id = ${userId}\n  `;\n  return row ?? { active: 0, completed: 0, expired: 0, total: 0 };\n}\n\nasync function fetchRecentGameEntries(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekGameEntryRow>> {\n  return sql<Array<PeekGameEntryRow>>`\n    select\n      id::text as \"id\",\n      game,\n      round_pda as \"roundPda\",\n      match_id as \"matchId\",\n      amount_lamports::text as \"amountLamports\",\n      side,\n      is_winner as \"isWinner\",\n      payout_lamports::text as \"payoutLamports\",\n      created_at::text as \"createdAt\",\n      settled_at::text as \"settledAt\"\n    from game_entries\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchRecentTransactions(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekTransactionRow>> {\n  return sql<Array<PeekTransactionRow>>`\n    select\n      id::text as \"id\",\n      game,\n      match_id as \"matchId\",\n      tx_type as \"txType\",\n      amount_lamports::text as \"amountLamports\",\n      tx_sig as \"txSig\",\n      created_at::text as \"createdAt\"\n    from transactions\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchFraudFlags(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekFraudFlagRow>> {\n  return sql<Array<PeekFraudFlagRow>>`\n    select\n      id::text as \"id\",\n      flag_type as \"flagType\",\n      status,\n      related_id as \"relatedId\",\n      created_at::text as \"createdAt\",\n      resolved_at::text as \"resolvedAt\"\n    from fraud_flags\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchRecentUserQueueEvents(\n  sql: Sql,\n  userId: string,\n  wallet: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekUserQueueEventRow>> {\n  // event_queue has no user_id column; join via JSONB payload identifiers that\n  // every backend writer uses today (`userId`, `user_id`, `wallet`). Bounded by\n  // limit so the admin page never streams the full queue.\n  return sql<Array<PeekUserQueueEventRow>>`\n    select\n      id::text as \"id\",\n      event_type as \"eventType\",\n      status,\n      attempts,\n      max_attempts as \"maxAttempts\",\n      scheduled_at::text as \"scheduledAt\",\n      created_at::text as \"createdAt\",\n      error\n    from event_queue\n    where payload->>'userId' = ${userId}\n       or payload->>'user_id' = ${userId}\n       or payload->>'wallet' = ${wallet}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchSelfReferralIndicator(\n  sql: Sql,\n  userId: string,\n): Promise<{ selfReferral: boolean }> {\n  const [row] = await sql<Array<{ selfReferral: boolean }>>`\n    select exists (\n      select 1\n      from referral_links rl\n      where rl.referrer_user_id = ${userId}\n        and rl.referee_user_id = ${userId}\n    ) as \"selfReferral\"\n  `;\n  return row ?? { selfReferral: false };\n}\n\nfunction computeAttention(input: {\n  recentReferralClaims: ReadonlyArray<PeekReferralClaimRow>;\n  recentUserQueueEvents: ReadonlyArray<PeekUserQueueEventRow>;\n  fraudFlags: ReadonlyArray<PeekFraudFlagRow>;\n  recentCrateDrops: ReadonlyArray<PeekCrateDropRow>;\n  selfReferralRow: { selfReferral: boolean };\n}): PeekUserAttentionFlags {\n  return {\n    failedClaim: input.recentReferralClaims.some(\n      (claim) => claim.status === \"failed\" || claim.status === \"error\",\n    ),\n    deadQueueEvent: input.recentUserQueueEvents.some(\n      (event) => event.status === \"dead\",\n    ),\n    activeFraudFlag: input.fraudFlags.some((flag) => flag.status === \"open\"),\n    pendingSolCratePayout: input.recentCrateDrops.some(\n      (drop) => drop.crateType === \"sol\" && drop.status === \"pending\",\n    ),\n    suspiciousReferralLoop: input.selfReferralRow.selfReferral,\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":8205,"cache_read_input_tokens":112869,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":8205},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"a7a6576f-78d4-407f-81cd-207cf72e4e2a","uuid":"d51d6a61-95ae-4abf-b8e3-c5dae44a0096"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RfxTvHCqQHfwz3oUfnDEUk","type":"tool_result","content":"The file /workspaces/rng-utopia/peek/src/server/db/queries/get-peek-user-detail.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"a7a6576f-78d4-407f-81cd-207cf72e4e2a","uuid":"7ff84865-694f-41c9-80b2-9a1af522f18d","timestamp":"2026-04-25T11:52:46.089Z","tool_use_result":{"type":"update","filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-peek-user-detail.ts","content":"import type {\n  PeekChallengeAssignmentSummary,\n  PeekCrateDropRow,\n  PeekFraudFlagRow,\n  PeekGameEntryRow,\n  PeekKolRate,\n  PeekLinkedAccountRow,\n  PeekPlayerPoints,\n  PeekPointGrantRow,\n  PeekReferralClaimRow,\n  PeekReferralEarningsSummary,\n  PeekTelegramLinkTokenRow,\n  PeekTransactionRow,\n  PeekUserAttentionFlags,\n  PeekUserDetail,\n  PeekUserQueueEventRow,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_USER_DETAIL_RECENT_LIMIT = 25;\nexport const PEEK_USER_DETAIL_TOKEN_LIMIT = 10;\n\ntype Sql = ReturnType<typeof getSqlClient>;\n\ntype GetPeekUserDetailOptions = {\n  sql?: Sql;\n  recentLimit?: number;\n  tokenLimit?: number;\n};\n\nexport function formatUserHeading(user: {\n  userId: string;\n  username: string | null;\n}) {\n  return user.username ?? user.userId;\n}\n\nexport async function getPeekUserDetail(\n  userId: string,\n  options: GetPeekUserDetailOptions = {},\n): Promise<PeekUserDetail | null> {\n  const sql = options.sql ?? getSqlClient();\n  const recentLimit = clampPositiveInt(\n    options.recentLimit,\n    PEEK_USER_DETAIL_RECENT_LIMIT,\n  );\n  const tokenLimit = clampPositiveInt(\n    options.tokenLimit,\n    PEEK_USER_DETAIL_TOKEN_LIMIT,\n  );\n\n  // Identity + linked-account telegram view (preserved as queries[0] so the\n  // 303-era listing/detail tests continue to assert the same SQL contract).\n  const [user] = await sql<\n    Array<{\n      userId: string;\n      username: string | null;\n      wallet: string;\n      joinedAt: string;\n      avatarUrl: string | null;\n      heatMultiplier: string;\n      profilePointsBalance: string;\n      referralCode: string | null;\n      referrerUserId: string | null;\n      referrerCode: string | null;\n      refereeCount: number;\n      telegramLinkState: \"active\" | \"none\";\n      linkedAt: string | null;\n      telegramUserId: string | null;\n      telegramUsername: string | null;\n    }>\n  >`\n    select\n      pp.user_id as \"userId\",\n      pp.username as \"username\",\n      pp.wallet as \"wallet\",\n      pp.created_at::text as \"joinedAt\",\n      pp.avatar_url as \"avatarUrl\",\n      pp.heat_multiplier::text as \"heatMultiplier\",\n      pp.points_balance::text as \"profilePointsBalance\",\n      rc.code as \"referralCode\",\n      rl.referrer_user_id as \"referrerUserId\",\n      ref_code.code as \"referrerCode\",\n      (\n        select count(*)::int\n        from referral_links outbound\n        where outbound.referrer_user_id = pp.user_id\n      ) as \"refereeCount\",\n      coalesce(tla.status, 'none') as \"telegramLinkState\",\n      rl.created_at::text as \"linkedAt\",\n      tla.telegram_user_id as \"telegramUserId\",\n      tla.telegram_username as \"telegramUsername\"\n    from player_profiles pp\n    left join referral_codes rc on rc.user_id = pp.user_id\n    left join referral_links rl on rl.referee_user_id = pp.user_id\n    left join referral_codes ref_code on ref_code.user_id = rl.referrer_user_id\n    left join lateral (\n      select\n        status,\n        provider_account_id as telegram_user_id,\n        nullif(metadata_json->>'telegramUsername', '') as telegram_username\n      from linked_accounts\n      where user_id = pp.user_id\n        and provider = 'telegram'\n        and status = 'active'\n      limit 1\n    ) tla on true\n    where pp.user_id = ${userId}\n  `;\n\n  if (!user) {\n    return null;\n  }\n\n  const wallet = user.wallet;\n\n  const [\n    outboundReferees,\n    linkedAccounts,\n    recentTelegramLinkTokens,\n    kolRate,\n    referralEarnings,\n    recentReferralClaims,\n    points,\n    recentPointGrants,\n    recentCrateDrops,\n    challengeSummary,\n    recentGameEntries,\n    recentTransactions,\n    fraudFlags,\n    recentUserQueueEvents,\n    selfReferralRow,\n  ] = await Promise.all([\n    fetchOutboundReferees(sql, userId),\n    fetchLinkedAccounts(sql, userId),\n    fetchRecentTelegramLinkTokens(sql, userId, tokenLimit),\n    fetchKolRate(sql, userId),\n    fetchReferralEarnings(sql, userId),\n    fetchRecentReferralClaims(sql, userId, recentLimit),\n    fetchPlayerPoints(sql, userId),\n    fetchRecentPointGrants(sql, userId, recentLimit),\n    fetchRecentCrateDrops(sql, userId, recentLimit),\n    fetchChallengeSummary(sql, userId),\n    fetchRecentGameEntries(sql, userId, recentLimit),\n    fetchRecentTransactions(sql, userId, recentLimit),\n    fetchFraudFlags(sql, userId, recentLimit),\n    fetchRecentUserQueueEvents(sql, userId, wallet, recentLimit),\n    fetchSelfReferralIndicator(sql, userId),\n  ]);\n\n  const attention = computeAttention({\n    recentReferralClaims,\n    recentUserQueueEvents,\n    fraudFlags,\n    recentCrateDrops,\n    selfReferralRow,\n  });\n\n  return {\n    user: {\n      userId: user.userId,\n      username: user.username,\n      wallet: user.wallet,\n      joinedAt: user.joinedAt,\n      referralCode: user.referralCode,\n      referrerUserId: user.referrerUserId,\n      referrerCode: user.referrerCode,\n      refereeCount: user.refereeCount,\n      telegramUsername: user.telegramUsername,\n      telegramUserId: user.telegramUserId,\n      avatarUrl: user.avatarUrl,\n      heatMultiplier: user.heatMultiplier,\n      profilePointsBalance: user.profilePointsBalance,\n    },\n    inboundReferral: {\n      referrerUserId: user.referrerUserId,\n      referrerCode: user.referrerCode,\n      linkedAt: user.linkedAt,\n    },\n    outboundReferees,\n    telegram: {\n      state: user.telegramLinkState,\n      telegramUserId: user.telegramUserId,\n      telegramUsername: user.telegramUsername,\n    },\n    linkedAccounts,\n    recentTelegramLinkTokens,\n    kolRate,\n    referralEarnings,\n    recentReferralClaims,\n    points,\n    recentPointGrants,\n    recentCrateDrops,\n    challengeSummary,\n    recentGameEntries,\n    recentTransactions,\n    fraudFlags,\n    recentUserQueueEvents,\n    attention,\n  };\n}\n\nfunction clampPositiveInt(value: number | undefined, fallback: number): number {\n  if (typeof value !== \"number\" || !Number.isFinite(value)) return fallback;\n  const floored = Math.floor(value);\n  if (floored <= 0) return 1;\n  return floored;\n}\n\nasync function fetchOutboundReferees(\n  sql: Sql,\n  userId: string,\n): Promise<PeekUserDetail[\"outboundReferees\"]> {\n  return sql<\n    Array<{\n      refereeUserId: string;\n      refereeUsername: string | null;\n      createdAt: string;\n    }>\n  >`\n    select\n      rl.referee_user_id as \"refereeUserId\",\n      pp.username as \"refereeUsername\",\n      rl.created_at::text as \"createdAt\"\n    from referral_links rl\n    left join player_profiles pp on pp.user_id = rl.referee_user_id\n    where rl.referrer_user_id = ${userId}\n    order by rl.created_at desc\n  `;\n}\n\nasync function fetchLinkedAccounts(\n  sql: Sql,\n  userId: string,\n): Promise<ReadonlyArray<PeekLinkedAccountRow>> {\n  return sql<Array<PeekLinkedAccountRow>>`\n    select\n      id::text as \"id\",\n      provider,\n      provider_account_id as \"providerAccountId\",\n      status,\n      nullif(metadata_json->>'telegramUsername', '') as \"telegramUsername\",\n      metadata_json as \"metadataJson\",\n      linked_at::text as \"linkedAt\",\n      updated_at::text as \"updatedAt\"\n    from linked_accounts\n    where user_id = ${userId}\n    order by linked_at desc\n  `;\n}\n\nasync function fetchRecentTelegramLinkTokens(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekTelegramLinkTokenRow>> {\n  return sql<Array<PeekTelegramLinkTokenRow>>`\n    select\n      id::text as \"id\",\n      status,\n      telegram_user_id as \"telegramUserId\",\n      telegram_username as \"telegramUsername\",\n      expires_at::text as \"expiresAt\",\n      redeemed_at::text as \"redeemedAt\",\n      created_at::text as \"createdAt\"\n    from telegram_link_tokens\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchKolRate(\n  sql: Sql,\n  userId: string,\n): Promise<PeekKolRate | null> {\n  const [row] = await sql<\n    Array<{\n      rateBps: number;\n      setBy: string;\n      createdAt: string;\n      updatedAt: string;\n    }>\n  >`\n    select\n      rate_bps as \"rateBps\",\n      set_by as \"setBy\",\n      created_at::text as \"createdAt\",\n      updated_at::text as \"updatedAt\"\n    from referral_kol_rates\n    where user_id = ${userId}\n    limit 1\n  `;\n  return row ?? null;\n}\n\nasync function fetchReferralEarnings(\n  sql: Sql,\n  userId: string,\n): Promise<PeekReferralEarningsSummary> {\n  const [row] = await sql<\n    Array<{\n      earningsCount: number;\n      totalReferrerEarnedLamports: string;\n      totalRefereeRebateLamports: string;\n      lastEarnedAt: string | null;\n    }>\n  >`\n    select\n      count(*)::int as \"earningsCount\",\n      coalesce(sum(referrer_earned_lamports), 0)::text as \"totalReferrerEarnedLamports\",\n      coalesce(sum(referee_rebate_lamports), 0)::text as \"totalRefereeRebateLamports\",\n      max(created_at)::text as \"lastEarnedAt\"\n    from referral_earnings\n    where referrer_user_id = ${userId} or referee_user_id = ${userId}\n  `;\n  return (\n    row ?? {\n      earningsCount: 0,\n      totalReferrerEarnedLamports: \"0\",\n      totalRefereeRebateLamports: \"0\",\n      lastEarnedAt: null,\n    }\n  );\n}\n\nasync function fetchRecentReferralClaims(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekReferralClaimRow>> {\n  return sql<Array<PeekReferralClaimRow>>`\n    select\n      id::text as \"id\",\n      amount_lamports::text as \"amountLamports\",\n      status,\n      retry_count as \"retryCount\",\n      tx_signature as \"txSignature\",\n      error,\n      requested_at::text as \"requestedAt\",\n      processed_at::text as \"processedAt\"\n    from referral_claims\n    where user_id = ${userId}\n    order by requested_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchPlayerPoints(\n  sql: Sql,\n  userId: string,\n): Promise<PeekPlayerPoints> {\n  const [row] = await sql<\n    Array<{\n      balance: string;\n      lifetimeEarned: string;\n      updatedAt: string;\n    }>\n  >`\n    select\n      balance::text as \"balance\",\n      lifetime_earned::text as \"lifetimeEarned\",\n      updated_at::text as \"updatedAt\"\n    from player_points\n    where user_id = ${userId}\n    limit 1\n  `;\n  return (\n    row ?? {\n      balance: \"0\",\n      lifetimeEarned: \"0\",\n      updatedAt: null,\n    }\n  );\n}\n\nasync function fetchRecentPointGrants(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekPointGrantRow>> {\n  return sql<Array<PeekPointGrantRow>>`\n    select\n      id::text as \"id\",\n      source_type as \"sourceType\",\n      source_id as \"sourceId\",\n      amount::text as \"amount\",\n      created_at::text as \"createdAt\"\n    from point_grants\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchRecentCrateDrops(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekCrateDropRow>> {\n  return sql<Array<PeekCrateDropRow>>`\n    select\n      id::text as \"id\",\n      trigger_type as \"triggerType\",\n      trigger_id as \"triggerId\",\n      crate_type as \"crateType\",\n      contents_amount as \"contentsAmount\",\n      status,\n      created_at::text as \"createdAt\",\n      granted_at::text as \"grantedAt\"\n    from crate_drops\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchChallengeSummary(\n  sql: Sql,\n  userId: string,\n): Promise<PeekChallengeAssignmentSummary> {\n  const [row] = await sql<\n    Array<{\n      active: number;\n      completed: number;\n      expired: number;\n      total: number;\n    }>\n  >`\n    select\n      count(*) filter (where status = 'active')::int as \"active\",\n      count(*) filter (where status = 'completed')::int as \"completed\",\n      count(*) filter (where status = 'expired')::int as \"expired\",\n      count(*)::int as \"total\"\n    from challenge_assignments\n    where user_id = ${userId}\n  `;\n  return row ?? { active: 0, completed: 0, expired: 0, total: 0 };\n}\n\nasync function fetchRecentGameEntries(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekGameEntryRow>> {\n  return sql<Array<PeekGameEntryRow>>`\n    select\n      id::text as \"id\",\n      game,\n      round_pda as \"roundPda\",\n      match_id as \"matchId\",\n      amount_lamports::text as \"amountLamports\",\n      side,\n      is_winner as \"isWinner\",\n      payout_lamports::text as \"payoutLamports\",\n      created_at::text as \"createdAt\",\n      settled_at::text as \"settledAt\"\n    from game_entries\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchRecentTransactions(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekTransactionRow>> {\n  return sql<Array<PeekTransactionRow>>`\n    select\n      id::text as \"id\",\n      game,\n      match_id as \"matchId\",\n      tx_type as \"txType\",\n      amount_lamports::text as \"amountLamports\",\n      tx_sig as \"txSig\",\n      created_at::text as \"createdAt\"\n    from transactions\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchFraudFlags(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekFraudFlagRow>> {\n  return sql<Array<PeekFraudFlagRow>>`\n    select\n      id::text as \"id\",\n      flag_type as \"flagType\",\n      status,\n      related_id as \"relatedId\",\n      created_at::text as \"createdAt\",\n      resolved_at::text as \"resolvedAt\"\n    from fraud_flags\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchRecentUserQueueEvents(\n  sql: Sql,\n  userId: string,\n  wallet: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekUserQueueEventRow>> {\n  // event_queue has no user_id column; join via JSONB payload identifiers that\n  // every backend writer uses today (`userId`, `user_id`, `wallet`). Bounded by\n  // limit so the admin page never streams the full queue.\n  return sql<Array<PeekUserQueueEventRow>>`\n    select\n      id::text as \"id\",\n      event_type as \"eventType\",\n      status,\n      attempts,\n      max_attempts as \"maxAttempts\",\n      scheduled_at::text as \"scheduledAt\",\n      created_at::text as \"createdAt\",\n      error\n    from event_queue\n    where payload->>'userId' = ${userId}\n       or payload->>'user_id' = ${userId}\n       or payload->>'wallet' = ${wallet}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchSelfReferralIndicator(\n  sql: Sql,\n  userId: string,\n): Promise<{ selfReferral: boolean }> {\n  const [row] = await sql<Array<{ selfReferral: boolean }>>`\n    select exists (\n      select 1\n      from referral_links rl\n      where rl.referrer_user_id = ${userId}\n        and rl.referee_user_id = ${userId}\n    ) as \"selfReferral\"\n  `;\n  return row ?? { selfReferral: false };\n}\n\nfunction computeAttention(input: {\n  recentReferralClaims: ReadonlyArray<PeekReferralClaimRow>;\n  recentUserQueueEvents: ReadonlyArray<PeekUserQueueEventRow>;\n  fraudFlags: ReadonlyArray<PeekFraudFlagRow>;\n  recentCrateDrops: ReadonlyArray<PeekCrateDropRow>;\n  selfReferralRow: { selfReferral: boolean };\n}): PeekUserAttentionFlags {\n  return {\n    failedClaim: input.recentReferralClaims.some(\n      (claim) => claim.status === \"failed\" || claim.status === \"error\",\n    ),\n    deadQueueEvent: input.recentUserQueueEvents.some(\n      (event) => event.status === \"dead\",\n    ),\n    activeFraudFlag: input.fraudFlags.some((flag) => flag.status === \"open\"),\n    pendingSolCratePayout: input.recentCrateDrops.some(\n      (drop) => drop.crateType === \"sol\" && drop.status === \"pending\",\n    ),\n    suspiciousReferralLoop: input.selfReferralRow.selfReferral,\n  };\n}\n","structuredPatch":[{"oldStart":1,"oldLines":6,"newStart":1,"newLines":33,"lines":["-import type { PeekUserDetail } from \"../../../lib/types/peek\";","+import type {","+  PeekChallengeAssignmentSummary,","+  PeekCrateDropRow,","+  PeekFraudFlagRow,","+  PeekGameEntryRow,","+  PeekKolRate,","+  PeekLinkedAccountRow,","+  PeekPlayerPoints,","+  PeekPointGrantRow,","+  PeekReferralClaimRow,","+  PeekReferralEarningsSummary,","+  PeekTelegramLinkTokenRow,","+  PeekTransactionRow,","+  PeekUserAttentionFlags,","+  PeekUserDetail,","+  PeekUserQueueEventRow,","+} from \"../../../lib/types/peek\";"," import { getSqlClient } from \"../client\";"," ","+export const PEEK_USER_DETAIL_RECENT_LIMIT = 25;","+export const PEEK_USER_DETAIL_TOKEN_LIMIT = 10;","+","+type Sql = ReturnType<typeof getSqlClient>;","+","+type GetPeekUserDetailOptions = {","+  sql?: Sql;","+  recentLimit?: number;","+  tokenLimit?: number;","+};","+"," export function formatUserHeading(user: {","   userId: string;","   username: string | null;"]},{"oldStart":9,"oldLines":15,"newStart":36,"newLines":48,"lines":[" }"," "," export async function getPeekUserDetail(","-  userId: string","+  userId: string,","+  options: GetPeekUserDetailOptions = {},"," ): Promise<PeekUserDetail | null> {","-  const sql = getSqlC