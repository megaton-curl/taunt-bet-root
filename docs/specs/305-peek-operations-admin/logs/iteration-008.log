{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01U3PZj7Mw9oXYwi5cofQ5gt","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01AK5tAmF2TZJLhigTm5HmBd","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/__tests__/filter-bar.test.tsx","content":"import { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { FilterBar } from \"../filter-bar\";\nimport type { PeekTableFilter } from \"../../lib/types/peek\";\n\nconst filters: ReadonlyArray<PeekTableFilter> = [\n  {\n    id: \"query\",\n    label: \"Search\",\n    kind: \"text\",\n    value: \"alice\",\n    options: null,\n    placeholder: \"username, wallet, code\",\n    required: false,\n  },\n  {\n    id: \"status\",\n    label: \"Status\",\n    kind: \"select\",\n    value: \"failed\",\n    options: [\n      { value: \"pending\", label: \"Pending\" },\n      { value: \"failed\", label: \"Failed\" },\n      { value: \"settled\", label: \"Settled\" },\n    ],\n    placeholder: \"Any\",\n    required: false,\n  },\n  {\n    id: \"hasReferrer\",\n    label: \"Has referrer\",\n    kind: \"boolean\",\n    value: \"true\",\n    options: null,\n    placeholder: null,\n    required: false,\n  },\n  {\n    id: \"createdAt\",\n    label: \"Created on\",\n    kind: \"date\",\n    value: \"2026-04-20\",\n    options: null,\n    placeholder: null,\n    required: false,\n  },\n  {\n    id: \"window\",\n    label: \"Created window\",\n    kind: \"dateRange\",\n    value: \"2026-04-01..2026-04-25\",\n    options: null,\n    placeholder: null,\n    required: true,\n  },\n];\n\ndescribe(\"FilterBar\", () => {\n  it(\"populated: renders text/select/boolean/date/dateRange inputs with default values and a submit button\", () => {\n    render(<FilterBar filters={filters} />);\n\n    const form = screen.getByRole(\"search\", { name: \"Filter table\" });\n    expect(form).toBeInTheDocument();\n\n    const queryInput = screen.getByLabelText(\"Search\") as HTMLInputElement;\n    expect(queryInput.type).toBe(\"text\");\n    expect(queryInput.value).toBe(\"alice\");\n    expect(queryInput.name).toBe(\"query\");\n    expect(queryInput.placeholder).toBe(\"username, wallet, code\");\n\n    const statusSelect = screen.getByLabelText(\"Status\") as HTMLSelectElement;\n    expect(statusSelect.value).toBe(\"failed\");\n    expect(statusSelect.name).toBe(\"status\");\n    expect(Array.from(statusSelect.options).map((o) => o.value)).toEqual([\n      \"\",\n      \"pending\",\n      \"failed\",\n      \"settled\",\n    ]);\n\n    const referrerCheckbox = screen.getByLabelText(\"Has referrer\") as HTMLInputElement;\n    expect(referrerCheckbox.type).toBe(\"checkbox\");\n    expect(referrerCheckbox.checked).toBe(true);\n    expect(referrerCheckbox.value).toBe(\"true\");\n\n    const dateInput = screen.getByLabelText(\"Created on\") as HTMLInputElement;\n    expect(dateInput.type).toBe(\"date\");\n    expect(dateInput.value).toBe(\"2026-04-20\");\n\n    const fromInput = screen.getByLabelText(\"From\") as HTMLInputElement;\n    expect(fromInput.type).toBe(\"date\");\n    expect(fromInput.value).toBe(\"2026-04-01\");\n    expect(fromInput.name).toBe(\"windowFrom\");\n\n    const toInput = screen.getByLabelText(\"To\") as HTMLInputElement;\n    expect(toInput.type).toBe(\"date\");\n    expect(toInput.value).toBe(\"2026-04-25\");\n    expect(toInput.name).toBe(\"windowTo\");\n\n    expect(screen.getByRole(\"button\", { name: \"Apply filters\" })).toBeInTheDocument();\n  });\n\n  it(\"sparse: renders a status placeholder when no filters are provided\", () => {\n    render(<FilterBar filters={[]} />);\n\n    expect(screen.getByRole(\"status\")).toHaveTextContent(\"No filters available for this view.\");\n    expect(screen.queryByRole(\"search\")).toBeNull();\n    expect(screen.queryByRole(\"button\")).toBeNull();\n  });\n\n  it(\"error: renders an alert instead of filter inputs\", () => {\n    render(<FilterBar filters={filters} error=\"filter config invalid\" />);\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Filters unavailable: filter config invalid\",\n    );\n    expect(screen.queryByRole(\"search\")).toBeNull();\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1428,"cache_read_input_tokens":92053,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1428},"output_tokens":70,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"466ba23a-e2aa-4efb-a30b-66c99824c4eb","uuid":"6116e723-d91c-426e-9728-b98332cdf29c"}
