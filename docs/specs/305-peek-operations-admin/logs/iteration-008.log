 CSSProperties = {\n  margin: 0,\n};\n\nconst metaValueStyle: CSSProperties = {\n  margin: 0,\n  textAlign: \"right\",\n};\n\nconst drilldownStyle: CSSProperties = {\n  fontSize: \"0.8125rem\",\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nfunction freshnessStyle(freshness: PeekMetric[\"freshness\"]): CSSProperties {\n  const tones: Record<PeekMetric[\"freshness\"], { background: string; color: string }> = {\n    live: { background: \"#064e3b\", color: \"#a7f3d0\" },\n    cached: { background: \"#1f2937\", color: \"#cbd5f5\" },\n    manual: { background: \"#3f3f46\", color: \"#fde68a\" },\n    sampled: { background: \"#312e81\", color: \"#c7d2fe\" },\n  };\n  const tone = tones[freshness];\n  return {\n    fontSize: \"0.6875rem\",\n    textTransform: \"uppercase\",\n    letterSpacing: \"0.05em\",\n    padding: \"0.125rem 0.5rem\",\n    borderRadius: \"9999px\",\n    background: tone.background,\n    color: tone.color,\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px solid #1e293b\",\n  background: \"#0b1220\",\n  color: \"#94a3b8\",\n  fontSize: \"0.875rem\",\n};\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01Lh7LFci6tfhGpan5kHfRPU","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Gn3scW9pJgHam4vKu77Fiv","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/filter-bar.tsx","content":"import type { CSSProperties } from \"react\";\nimport type { PeekTableFilter } from \"../lib/types/peek\";\n\nexport type FilterBarProps = {\n  filters: ReadonlyArray<PeekTableFilter>;\n  action?: string;\n  method?: \"get\";\n  submitLabel?: string;\n  error?: string | null;\n};\n\nexport function FilterBar({\n  filters,\n  action,\n  method = \"get\",\n  submitLabel = \"Apply filters\",\n  error = null,\n}: FilterBarProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Filters unavailable: {error}\n      </div>\n    );\n  }\n\n  if (filters.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        No filters available for this view.\n      </div>\n    );\n  }\n\n  return (\n    <form\n      action={action}\n      method={method}\n      role=\"search\"\n      aria-label=\"Filter table\"\n      style={formStyle}\n    >\n      {filters.map((filter) => (\n        <FilterField key={filter.id} filter={filter} />\n      ))}\n      <button type=\"submit\" style={buttonStyle}>\n        {submitLabel}\n      </button>\n    </form>\n  );\n}\n\nfunction FilterField({ filter }: { filter: PeekTableFilter }) {\n  const inputId = `peek-filter-${filter.id}`;\n  const labelText = filter.required ? `${filter.label} *` : filter.label;\n\n  if (filter.kind === \"boolean\") {\n    return (\n      <label htmlFor={inputId} style={checkboxFieldStyle}>\n        <input\n          id={inputId}\n          name={filter.id}\n          type=\"checkbox\"\n          value=\"true\"\n          defaultChecked={filter.value === \"true\"}\n        />\n        <span>{labelText}</span>\n      </label>\n    );\n  }\n\n  if (filter.kind === \"select\") {\n    return (\n      <label htmlFor={inputId} style={fieldStyle}>\n        <span>{labelText}</span>\n        <select\n          id={inputId}\n          name={filter.id}\n          defaultValue={filter.value ?? \"\"}\n          required={filter.required}\n          style={inputStyle}\n        >\n          {!filter.required ? (\n            <option value=\"\">{filter.placeholder ?? \"Any\"}</option>\n          ) : null}\n          {(filter.options ?? []).map((option) => (\n            <option key={option.value} value={option.value}>\n              {option.label}\n            </option>\n          ))}\n        </select>\n      </label>\n    );\n  }\n\n  if (filter.kind === \"date\") {\n    return (\n      <label htmlFor={inputId} style={fieldStyle}>\n        <span>{labelText}</span>\n        <input\n          id={inputId}\n          name={filter.id}\n          type=\"date\"\n          defaultValue={filter.value ?? \"\"}\n          required={filter.required}\n          style={inputStyle}\n        />\n      </label>\n    );\n  }\n\n  if (filter.kind === \"dateRange\") {\n    const [from = \"\", to = \"\"] = (filter.value ?? \"\").split(\"..\");\n    return (\n      <fieldset style={fieldsetStyle}>\n        <legend style={legendStyle}>{labelText}</legend>\n        <div style={dateRangeRowStyle}>\n          <label htmlFor={`${inputId}-from`} style={dateRangeLabelStyle}>\n            <span style={dateRangeSpanStyle}>From</span>\n            <input\n              id={`${inputId}-from`}\n              name={`${filter.id}From`}\n              type=\"date\"\n              defaultValue={from}\n              required={filter.required}\n              style={inputStyle}\n            />\n          </label>\n          <label htmlFor={`${inputId}-to`} style={dateRangeLabelStyle}>\n            <span style={dateRangeSpanStyle}>To</span>\n            <input\n              id={`${inputId}-to`}\n              name={`${filter.id}To`}\n              type=\"date\"\n              defaultValue={to}\n              required={filter.required}\n              style={inputStyle}\n            />\n          </label>\n        </div>\n      </fieldset>\n    );\n  }\n\n  return (\n    <label htmlFor={inputId} style={fieldStyle}>\n      <span>{labelText}</span>\n      <input\n        id={inputId}\n        name={filter.id}\n        type=\"text\"\n        defaultValue={filter.value ?? \"\"}\n        placeholder={filter.placeholder ?? \"\"}\n        required={filter.required}\n        style={inputStyle}\n      />\n    </label>\n  );\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n  gridTemplateColumns: \"repeat(auto-fit, minmax(180px, 1fr))\",\n  alignItems: \"end\",\n};\n\nconst fieldStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.35rem\",\n  fontSize: \"0.875rem\",\n};\n\nconst checkboxFieldStyle: CSSProperties = {\n  display: \"flex\",\n  gap: \"0.5rem\",\n  alignItems: \"center\",\n  fontSize: \"0.875rem\",\n};\n\nconst fieldsetStyle: CSSProperties = {\n  margin: 0,\n  padding: 0,\n  border: \"none\",\n  display: \"grid\",\n  gap: \"0.35rem\",\n  fontSize: \"0.875rem\",\n};\n\nconst legendStyle: CSSProperties = {\n  padding: 0,\n  fontSize: \"0.875rem\",\n};\n\nconst dateRangeRowStyle: CSSProperties = {\n  display: \"flex\",\n  gap: \"0.5rem\",\n};\n\nconst dateRangeLabelStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.25rem\",\n  flex: 1,\n};\n\nconst dateRangeSpanStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n};\n\nconst inputStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #334155\",\n  background: \"#111827\",\n  color: \"#e2e8f0\",\n  padding: \"0.625rem 0.75rem\",\n};\n\nconst buttonStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #475569\",\n  background: \"#1d4ed8\",\n  color: \"#eff6ff\",\n  padding: \"0.75rem 1rem\",\n  fontWeight: 600,\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding