    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n  };\n}\n\nconst sortLinkStyle: CSSProperties = {\n  color: \"inherit\",\n  textDecoration: \"none\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px solid #1e293b\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: \"0.5rem 0 0\",\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_013qhPnTXPN3eDCHqtXedySq","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01EmKyNTWx9JC6dJ2BuhN7ni","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/metric-strip.tsx","content":"import Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type { PeekMetric } from \"../lib/types/peek\";\n\nexport type MetricStripProps = {\n  metrics: ReadonlyArray<PeekMetric>;\n  error?: string | null;\n};\n\nexport function MetricStrip({ metrics, error = null }: MetricStripProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Metrics unavailable: {error}\n      </div>\n    );\n  }\n\n  if (metrics.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        No metrics available for this view.\n      </div>\n    );\n  }\n\n  return (\n    <section\n      aria-label=\"Metric strip\"\n      style={{\n        display: \"grid\",\n        gap: \"1rem\",\n        gridTemplateColumns: \"repeat(auto-fit, minmax(220px, 1fr))\",\n      }}\n    >\n      {metrics.map((metric) => (\n        <article key={metric.id} aria-labelledby={`peek-metric-${metric.id}-label`} style={cardStyle}>\n          <header style={cardHeaderStyle}>\n            <p id={`peek-metric-${metric.id}-label`} style={labelStyle}>\n              {metric.label}\n            </p>\n            <span style={freshnessStyle(metric.freshness)} title={`Freshness: ${metric.freshness}`}>\n              {metric.freshness}\n            </span>\n          </header>\n          <p style={valueStyle}>\n            {metric.valueDisplay}\n            {metric.unit ? <span style={unitStyle}> {metric.unit}</span> : null}\n          </p>\n          <p style={definitionStyle}>{metric.definition}</p>\n          <dl style={metaStyle}>\n            <div style={metaRowStyle}>\n              <dt style={metaTermStyle}>Source</dt>\n              <dd style={metaValueStyle}>{metric.source}</dd>\n            </div>\n            <div style={metaRowStyle}>\n              <dt style={metaTermStyle}>Window</dt>\n              <dd style={metaValueStyle}>{metric.windowLabel}</dd>\n            </div>\n            <div style={metaRowStyle}>\n              <dt style={metaTermStyle}>As of</dt>\n              <dd style={metaValueStyle}>{metric.asOf ?? \"—\"}</dd>\n            </div>\n          </dl>\n          {metric.drilldownHref ? (\n            <Link href={metric.drilldownHref} style={drilldownStyle}>\n              View rows →\n            </Link>\n          ) : null}\n        </article>\n      ))}\n    </section>\n  );\n}\n\nconst cardStyle: CSSProperties = {\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n  padding: \"1rem\",\n  background: \"#111827\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst cardHeaderStyle: CSSProperties = {\n  display: \"flex\",\n  alignItems: \"center\",\n  justifyContent: \"space-between\",\n  gap: \"0.5rem\",\n};\n\nconst labelStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.875rem\",\n  fontWeight: 600,\n};\n\nconst valueStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1.75rem\",\n  fontWeight: 700,\n};\n\nconst unitStyle: CSSProperties = {\n  fontSize: \"0.875rem\",\n  fontWeight: 500,\n  color: \"#94a3b8\",\n  marginLeft: \"0.25rem\",\n};\n\nconst definitionStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.8125rem\",\n  color: \"#cbd5f5\",\n};\n\nconst metaStyle: CSSProperties = {\n  margin: 0,\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst metaRowStyle: CSSProperties = {\n  display: \"flex\",\n  justifyContent: \"space-between\",\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n};\n\nconst metaTermStyle: CSSProperties = {\n  margin: 0,\n};\n\nconst metaValueStyle: CSSProperties = {\n  margin: 0,\n  textAlign: \"right\",\n};\n\nconst drilldownStyle: CSSProperties = {\n  fontSize: \"0.8125rem\",\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nfunction freshnessStyle(freshness: PeekMetric[\"freshness\"]): CSSProperties {\n  const tones: Record<PeekMetric[\"freshness\"], { background: string; color: string }> = {\n    live: { background: \"#064e3b\", color: \"#a7f3d0\" },\n    cached: { background: \"#1f2937\", color: \"#cbd5f5\" },\n    manual: { background: \"#3f3f46\", color: \"#fde68a\" },\n    sampled: { background: \"#312e81\", color: \"#c7d2fe\" },\n  };\n  const tone = tones[freshness];\n  return {\n    fontSize: \"0.6875rem\",\n    textTransform: \"uppercase\",\n    letterSpacing: \"0.05em\",\n    padding: \"0.125rem 0.5rem\",\n    borderRadius: \"9999px\",\n    background: tone.background,\n    color: tone.color,\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px solid #1e293b\",\n  background: \"#0b1220\",\n  color: \"#94a3b8\",\n  fontSize: \"0.875rem\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1929,"cache_read_input_tokens":83578,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1929},"output_tokens":60,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"466ba23a-e2aa-4efb-a30b-66c99824c4eb","uuid":"4739cef4-fb11-49ca-9a3c-d9682efb9052"}
