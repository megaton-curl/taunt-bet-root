 \"build\": \"next build\",\n    \"start\": \"next start\",\n    \"lint\": \"eslint .\",\n    \"typecheck\": \"tsc --noEmit -p tsconfig.typecheck.json\",\n    \"test:watch\": \"vitest\",\n    \"test:e2e\": \"playwright test\",\n    \"verify\": \"pnpm lint && pnpm typecheck && pnpm test && pnpm build\"\n  },\n  \"keywords\": [],\n  \"author\": \"\",\n  \"license\": \"ISC\",\n  \"private\": true,\n  \"dependencies\": {\n    \"jose\": \"^6.2.2\",\n    \"next\": \"^16.2.4\",\n    \"postgres\": \"^3.4.9\",\n    \"react\": \"^19.2.5\",\n    \"react-dom\": \"^19.2.5\",\n    \"zod\": \"^4.3.6\"\n  },\n  \"devDependencies\": {\n    \"@playwright/test\": \"^1.59.1\",\n    \"@testing-library/jest-dom\": \"^6.9.1\",\n    \"@testing-library/react\": \"^16.3.2\",\n    \"@testing-library/user-event\": \"^14.6.1\",\n    \"@types/node\": \"^25.6.0\",\n    \"@types/react\": \"^19.2.14\",\n    \"@types/react-dom\": \"^19.2.3\",\n    \"@vitejs/plugin-react\": \"^4.3.4\",\n    \"eslint\": \"^9.39.4\",\n    \"eslint-config-next\": \"^16.2.4\",\n    \"jsdom\": \"^24.1.3\",\n    \"typescript\": \"^6.0.3\",\n    \"vite\": \"^5.4.21\",\n    \"vitest\": \"3.2.4\"\n  },\n  \"packageManager\": \"pnpm@10.33.0\"\n}","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01Uv7Yhb1dC8tSdge7pAahSL","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Y7rrUcaguE4WX9152shwFu","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/peek-table.tsx","content":"import Link from \"next/link\";\nimport type { CSSProperties, ReactNode } from \"react\";\nimport type {\n  PeekSortDirection,\n  PeekTableRowBase,\n  PeekTableViewModel,\n} from \"../lib/types/peek\";\n\nexport type PeekTableProps<TRow extends PeekTableRowBase> = {\n  viewModel: PeekTableViewModel<TRow>;\n  renderCell: (row: TRow, columnId: string) => ReactNode;\n  buildSortHref?: (columnId: string, nextDirection: PeekSortDirection) => string;\n  error?: string | null;\n};\n\nexport function PeekTable<TRow extends PeekTableRowBase>({\n  viewModel,\n  renderCell,\n  buildSortHref,\n  error = null,\n}: PeekTableProps<TRow>) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Data unavailable: {error}\n      </div>\n    );\n  }\n\n  const { columns, rows, sort, empty } = viewModel;\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>{empty.title}</p>\n        {empty.body ? <p style={emptyBodyStyle}>{empty.body}</p> : null}\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            {columns.map((column) => {\n              const isSorted = sort?.column === column.id;\n              const indicator = isSorted ? (sort?.direction === \"asc\" ? \" ▲\" : \" ▼\") : \"\";\n              const baseStyle = headerCellStyle(column.align);\n              if (!column.sortable || !buildSortHref) {\n                return (\n                  <th key={column.id} style={baseStyle}>\n                    {column.label}\n                    {indicator}\n                  </th>\n                );\n              }\n              const nextDirection: PeekSortDirection =\n                isSorted && sort?.direction === \"desc\" ? \"asc\" : \"desc\";\n              return (\n                <th key={column.id} style={baseStyle} aria-sort={ariaSort(sort, column.id)}>\n                  <Link href={buildSortHref(column.id, nextDirection)} style={sortLinkStyle}>\n                    {column.label}\n                    {indicator}\n                  </Link>\n                </th>\n              );\n            })}\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              {columns.map((column) => (\n                <td key={column.id} style={bodyCellStyle(column.align)}>\n                  {renderCell(row, column.id)}\n                </td>\n              ))}\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction ariaSort(\n  sort: PeekTableViewModel<PeekTableRowBase>[\"sort\"],\n  columnId: string,\n): \"ascending\" | \"descending\" | \"none\" {\n  if (!sort || sort.column !== columnId) return \"none\";\n  return sort.direction === \"asc\" ? \"ascending\" : \"descending\";\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n  };\n}\n\nconst sortLinkStyle: CSSProperties = {\n  color: \"inherit\",\n  textDecoration: \"none\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px solid #1e293b\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: \"0.5rem 0 0\",\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2992,"cache_read_input_tokens":80586,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2992},"output_tokens":72,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"466ba23a-e2aa-4efb-a30b-66c99824c4eb","uuid":"5e4b9519-5456-46b8-9315-ab9092f126c2"}
