{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01STA3wQ6cRhduSXqW8ofDa9","type":"tool_result","content":"1\timport type { CSSProperties } from \"react\";\n2\timport { PaginationControls } from \"../src/components/pagination-controls\";\n3\timport { SummaryStrip } from \"../src/components/summary-strip\";\n4\timport { UsersTable } from \"../src/components/users-table\";\n5\timport { normalizePeekSearchParams } from \"../src/lib/search-params\";\n6\timport type { PeekSummary, PeekUserRow } from \"../src/lib/types/peek\";\n7\timport { countPeekUsers } from \"../src/server/db/queries/count-peek-users\";\n8\timport { getPeekSummary } from \"../src/server/db/queries/get-peek-summary\";\n9\timport { listPeekUsers } from \"../src/server/db/queries/list-peek-users\";\n10\t\n11\texport const dynamic = \"force-dynamic\";\n12\t\n13\texport default async function HomePage({\n14\t  searchParams,\n15\t}: {\n16\t  searchParams: Promise<Record<string, string | string[] | undefined>>;\n17\t}) {\n18\t  const initialParams = normalizePeekSearchParams(await searchParams);\n19\t  let summary: PeekSummary = {\n20\t    totalUsers: 0,\n21\t    totalUsersWithCodes: 0,\n22\t    totalReferredUsers: 0,\n23\t    totalUniqueReferrers: 0,\n24\t  };\n25\t  let users: PeekUserRow[] = [];\n26\t  let totalCount = 0;\n27\t  let loadError: string | null = null;\n28\t  let params = initialParams;\n29\t\n30\t  try {\n31\t    [summary, totalCount] = await Promise.all([\n32\t      getPeekSummary(),\n33\t      countPeekUsers(initialParams),\n34\t    ]);\n35\t\n36\t    if (totalCount > 0) {\n37\t      const totalPages = Math.max(1, Math.ceil(totalCount / initialParams.pageSize));\n38\t      params = {\n39\t        ...initialParams,\n40\t        page: Math.min(initialParams.page, totalPages),\n41\t      };\n42\t    }\n43\t\n44\t    users = await listPeekUsers(params);\n45\t  } catch (error) {\n46\t    loadError =\n47\t      error instanceof Error\n48\t        ? error.message\n49\t        : \"Peek could not load data from the database.\";\n50\t  }\n51\t\n52\t  return (\n53\t    <main style={{ display: \"grid\", gap: \"1.5rem\" }}>\n54\t      <header>\n55\t        <h1>Peek</h1>\n56\t        <p>Users-first waitlist and referral admin.</p>\n57\t      </header>\n58\t      {loadError ? (\n59\t        <p\n60\t          style={{\n61\t            margin: 0,\n62\t            padding: \"0.75rem 1rem\",\n63\t            borderRadius: \"0.75rem\",\n64\t            background: \"#3f1d1d\",\n65\t            color: \"#fecaca\",\n66\t          }}\n67\t        >\n68\t          Data unavailable: {loadError}\n69\t        </p>\n70\t      ) : null}\n71\t      <SummaryStrip summary={summary} />\n72\t      <form\n73\t        style={{\n74\t          display: \"grid\",\n75\t          gap: \"0.75rem\",\n76\t          gridTemplateColumns: \"repeat(auto-fit, minmax(180px, 1fr))\",\n77\t          alignItems: \"end\",\n78\t        }}\n79\t      >\n80\t        <label style={fieldStyle}>\n81\t          <span>Search</span>\n82\t          <input\n83\t            defaultValue={params.query}\n84\t            name=\"query\"\n85\t            placeholder=\"username, wallet, code, user id\"\n86\t            style={inputStyle}\n87\t          />\n88\t        </label>\n89\t\n90\t        <label style={fieldStyle}>\n91\t          <span>Sort</span>\n92\t          <select defaultValue={params.sort} name=\"sort\" style={inputStyle}>\n93\t            <option value=\"joinedAt\">Joined</option>\n94\t            <option value=\"refereeCount\">Referee count</option>\n95\t          </select>\n96\t        </label>\n97\t\n98\t        <label style={fieldStyle}>\n99\t          <span>Direction</span>\n100\t          <select defaultValue={params.direction} name=\"direction\" style={inputStyle}>\n101\t            <option value=\"desc\">Newest first</option>\n102\t            <option value=\"asc\">Oldest first</option>\n103\t          </select>\n104\t        </label>\n105\t\n106\t        <label style={checkboxStyle}>\n107\t          <input defaultChecked={params.filters.hasReferrer} name=\"hasReferrer\" type=\"checkbox\" value=\"true\" />\n108\t          <span>Has referrer</span>\n109\t        </label>\n110\t\n111\t        <label style={checkboxStyle}>\n112\t          <input defaultChecked={params.filters.hasReferees} name=\"hasReferees\" type=\"checkbox\" value=\"true\" />\n113\t          <span>Has referees</span>\n114\t        </label>\n115\t\n116\t        <label style={checkboxStyle}>\n117\t          <input defaultChecked={params.filters.hasCode} name=\"hasCode\" type=\"checkbox\" value=\"true\" />\n118\t          <span>Has code</span>\n119\t        </label>\n120\t\n121\t        <label style={checkboxStyle}>\n122\t          <input\n123\t            defaultChecked={params.filters.hasTelegram}\n124\t            name=\"hasTelegram\"\n125\t            type=\"checkbox\"\n126\t            value=\"true\"\n127\t          />\n128\t          <span>Has Telegram</span>\n129\t        </label>\n130\t\n131\t        <button style={buttonStyle} type=\"submit\">\n132\t          Apply\n133\t        </button>\n134\t      </form>\n135\t      {!loadError ? <PaginationControls params={params} totalCount={totalCount} /> : null}\n136\t      <UsersTable users={users} />\n137\t      {!loadError && totalCount > params.pageSize ? (\n138\t        <PaginationControls params={params} totalCount={totalCount} />\n139\t      ) : null}\n140\t    </main>\n141\t  );\n142\t}\n143\t\n144\tconst fieldStyle: CSSProperties = {\n145\t  display: \"grid\",\n146\t  gap: \"0.35rem\",\n147\t  fontSize: \"0.875rem\",\n148\t};\n149\t\n150\tconst checkboxStyle: CSSProperties = {\n151\t  display: \"flex\",\n152\t  gap: \"0.5rem\",\n153\t  alignItems: \"center\",\n154\t  fontSize: \"0.875rem\",\n155\t};\n156\t\n157\tconst inputStyle: CSSProperties = {\n158\t  borderRadius: \"0.5rem\",\n159\t  border: \"1px solid #334155\",\n160\t  background: \"#111827\",\n161\t  color: \"#e2e8f0\",\n162\t  padding: \"0.625rem 0.75rem\",\n163\t};\n164\t\n165\tconst buttonStyle: CSSProperties = {\n166\t  borderRadius: \"0.5rem\",\n167\t  border: \"1px solid #475569\",\n168\t  background: \"#1d4ed8\",\n169\t  color: \"#eff6ff\",\n170\t  padding: \"0.75rem 1rem\",\n171\t  fontWeight: 600,\n172\t};\n173\t"}]},"parent_tool_use_id":null,"session_id":"466ba23a-e2aa-4efb-a30b-66c99824c4eb","uuid":"a9aa8817-efe1-48a0-8952-fefd4a88d877","timestamp":"2026-04-25T10:50:52.870Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/app/page.tsx","content":"import type { CSSProperties } from \"react\";\nimport { PaginationControls } from \"../src/components/pagination-controls\";\nimport { SummaryStrip } from \"../src/components/summary-strip\";\nimport { UsersTable } from \"../src/components/users-table\";\nimport { normalizePeekSearchParams } from \"../src/lib/search-params\";\nimport type { PeekSummary, PeekUserRow } from \"../src/lib/types/peek\";\nimport { countPeekUsers } from \"../src/server/db/queries/count-peek-users\";\nimport { getPeekSummary } from \"../src/server/db/queries/get-peek-summary\";\nimport { listPeekUsers } from \"../src/server/db/queries/list-peek-users\";\n\nexport const dynamic = \"force-dynamic\";\n\nexport default async function HomePage({\n  searchParams,\n}: {\n  searchParams: Promise<Record<string, string | string[] | undefined>>;\n}) {\n  const initialParams = normalizePeekSearchParams(await searchParams);\n  let summary: PeekSummary = {\n    totalUsers: 0,\n    totalUsersWithCodes: 0,\n    totalReferredUsers: 0,\n    totalUniqueReferrers: 0,\n  };\n  let users: PeekUserRow[] = [];\n  let totalCount = 0;\n  let loadError: string | null = null;\n  let params = initialParams;\n\n  try {\n    [summary, totalCount] = await Promise.all([\n      getPeekSummary(),\n      countPeekUsers(initialParams),\n    ]);\n\n    if (totalCount > 0) {\n      const totalPages = Math.max(1, Math.ceil(totalCount / initialParams.pageSize));\n      params = {\n        ...initialParams,\n        page: Math.min(initialParams.page, totalPages),\n      };\n    }\n\n    users = await listPeekUsers(params);\n  } catch (error) {\n    loadError =\n      error instanceof Error\n        ? error.message\n        : \"Peek could not load data from the database.\";\n  }\n\n  return (\n    <main style={{ display: \"grid\", gap: \"1.5rem\" }}>\n      <header>\n        <h1>Peek</h1>\n        <p>Users-first waitlist and referral admin.</p>\n      </header>\n      {loadError ? (\n        <p\n          style={{\n            margin: 0,\n            padding: \"0.75rem 1rem\",\n            borderRadius: \"0.75rem\",\n            background: \"#3f1d1d\",\n            color: \"#fecaca\",\n          }}\n        >\n          Data unavailable: {loadError}\n        </p>\n      ) : null}\n      <SummaryStrip summary={summary} />\n      <form\n        style={{\n          display: \"grid\",\n          gap: \"0.75rem\",\n          gridTemplateColumns: \"repeat(auto-fit, minmax(180px, 1fr))\",\n          alignItems: \"end\",\n        }}\n      >\n        <label style={fieldStyle}>\n          <span>Search</span>\n          <input\n            defaultValue={params.query}\n            name=\"query\"\n            placeholder=\"username, wallet, code, user id\"\n            style={inputStyle}\n          />\n        </label>\n\n        <label style={fieldStyle}>\n          <span>Sort</span>\n          <select defaultValue={params.sort} name=\"sort\" style={inputStyle}>\n            <option value=\"joinedAt\">Joined</option>\n            <option value=\"refereeCount\">Referee count</option>\n          </select>\n        </label>\n\n        <label style={fieldStyle}>\n          <span>Direction</span>\n          <select defaultValue={params.direction} name=\"direction\" style={inputStyle}>\n            <option value=\"desc\">Newest first</option>\n            <option value=\"asc\">Oldest first</option>\n          </select>\n        </label>\n\n        <label style={checkboxStyle}>\n          <input defaultChecked={params.filters.hasReferrer} name=\"hasReferrer\" type=\"checkbox\" value=\"true\" />\n          <span>Has referrer</span>\n        </label>\n\n        <label style={checkboxStyle}>\n          <input defaultChecked={params.filters.hasReferees} name=\"hasReferees\" type=\"checkbox\" value=\"true\" />\n          <span>Has referees</span>\n        </label>\n\n        <label style={checkboxStyle}>\n          <input defaultChecked={params.filters.hasCode} name=\"hasCode\" type=\"checkbox\" value=\"true\" />\n          <span>Has code</span>\n        </label>\n\n        <label style={checkboxStyle}>\n          <input\n            defaultChecked={params.filters.hasTelegram}\n            name=\"hasTelegram\"\n            type=\"checkbox\"\n            value=\"true\"\n          />\n          <span>Has Telegram</span>\n        </label>\n\n        <button style={buttonStyle} type=\"submit\">\n          Apply\n        </button>\n      </form>\n      {!loadError ? <PaginationControls params={params} totalCount={totalCount} /> : null}\n      <UsersTable users={users} />\n      {!loadError && totalCount > params.pageSize ? (\n        <PaginationControls params={params} totalCount={totalCount} />\n      ) : null}\n    </main>\n  );\n}\n\nconst fieldStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.35rem\",\n  fontSize: \"0.875rem\",\n};\n\nconst checkboxStyle: CSSProperties = {\n  display: \"flex\",\n  gap: \"0.5rem\",\n  alignItems: \"center\",\n  fontSize: \"0.875rem\",\n};\n\nconst inputStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #334155\",\n  background: \"#111827\",\n  color: \"#e2e8f0\",\n  padding: \"0.625rem 0.75rem\",\n};\n\nconst buttonStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #475569\",\n  background: \"#1d4ed8\",\n  color: \"#eff6ff\",\n  padding: \"0.75rem 1rem\",\n  fontWeight: 600,\n};\n","numLines":173,"startLine":1,"totalLines":173}}}
