Username ?? user.telegramUserId ?? \"\"}</td>\n34\t            </tr>\n35\t          ))}\n36\t        </tbody>\n37\t      </table>\n38\t    </div>\n39\t  );\n40\t}\n41\t\n42\tconst headerCellStyle: CSSProperties = {\n43\t  padding: \"0.75rem\",\n44\t  textAlign: \"left\",\n45\t  fontSize: \"0.875rem\",\n46\t  fontWeight: 600,\n47\t};\n48\t\n49\tconst bodyCellStyle: CSSProperties = {\n50\t  padding: \"0.75rem\",\n51\t  fontSize: \"0.875rem\",\n52\t};\n53\t"}]},"parent_tool_use_id":null,"session_id":"466ba23a-e2aa-4efb-a30b-66c99824c4eb","uuid":"ebafeec5-fd15-45b8-9094-d29a2ba9cb3f","timestamp":"2026-04-25T10:50:28.259Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/users-table.tsx","content":"import Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type { PeekUserRow } from \"../lib/types/peek\";\n\nexport function UsersTable({ users }: { users: PeekUserRow[] }) {\n  return (\n    <div style={{ overflowX: \"auto\", border: \"1px solid #1e293b\", borderRadius: \"0.75rem\" }}>\n      <table style={{ width: \"100%\", borderCollapse: \"collapse\" }}>\n        <thead>\n          <tr style={{ background: \"#111827\", color: \"#94a3b8\" }}>\n            <th style={headerCellStyle}>User ID</th>\n            <th style={headerCellStyle}>Username</th>\n            <th style={headerCellStyle}>Wallet</th>\n            <th style={headerCellStyle}>Joined</th>\n            <th style={headerCellStyle}>Referral code</th>\n            <th style={headerCellStyle}>Referrer</th>\n            <th style={headerCellStyle}>Referees</th>\n            <th style={headerCellStyle}>Telegram</th>\n          </tr>\n        </thead>\n        <tbody>\n          {users.map((user) => (\n            <tr key={user.userId} style={{ borderTop: \"1px solid #1e293b\" }}>\n              <td style={bodyCellStyle}>\n                <Link href={`/users/${user.userId}`}>{user.userId}</Link>\n              </td>\n              <td style={bodyCellStyle}>{user.username ?? \"—\"}</td>\n              <td style={{ ...bodyCellStyle, fontFamily: \"monospace\" }}>{user.wallet}</td>\n              <td style={bodyCellStyle}>{user.joinedAt}</td>\n              <td style={bodyCellStyle}>{user.referralCode ?? \"—\"}</td>\n              <td style={bodyCellStyle}>{user.referrerCode ?? user.referrerUserId ?? \"—\"}</td>\n              <td style={bodyCellStyle}>{user.refereeCount}</td>\n              <td style={bodyCellStyle}>{user.telegramUsername ?? user.telegramUserId ?? \"\"}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nconst headerCellStyle: CSSProperties = {\n  padding: \"0.75rem\",\n  textAlign: \"left\",\n  fontSize: \"0.875rem\",\n  fontWeight: 600,\n};\n\nconst bodyCellStyle: CSSProperties = {\n  padding: \"0.75rem\",\n  fontSize: \"0.875rem\",\n};\n","numLines":53,"startLine":1,"totalLines":53}}}
