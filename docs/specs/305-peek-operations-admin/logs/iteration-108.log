{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01Hn8jiFbbX9ijeJXrzUkNW8","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_019fbaVYktgH1pBq4UiL8Do1","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/exports/__tests__/csv.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport { serializePeekCsv } from \"../csv\";\nimport type { PeekTableColumn } from \"../../../lib/types/peek\";\n\nconst COLUMNS: ReadonlyArray<PeekTableColumn> = [\n  { id: \"id\", label: \"Id\", align: \"left\", sortable: false },\n  { id: \"label\", label: \"Label\", align: \"left\", sortable: false },\n  { id: \"amount\", label: \"Amount (lamports)\", align: \"right\", sortable: false },\n];\n\ndescribe(\"serializePeekCsv\", () => {\n  it(\"emits a header row from the column labels and a body row per data row\", () => {\n    const csv = serializePeekCsv(COLUMNS, [\n      { id: \"1\", label: \"alpha\", amount: \"1000\" },\n      { id: \"2\", label: \"beta\", amount: \"2000\" },\n    ]);\n\n    expect(csv).toBe(\n      \"Id,Label,Amount (lamports)\\r\\n\" +\n        \"1,alpha,1000\\r\\n\" +\n        \"2,beta,2000\\r\\n\",\n    );\n  });\n\n  it(\"emits only the header row plus a trailing CRLF when given no data\", () => {\n    expect(serializePeekCsv(COLUMNS, [])).toBe(\n      \"Id,Label,Amount (lamports)\\r\\n\",\n    );\n  });\n\n  it(\"quotes fields containing commas, quotes, or line terminators\", () => {\n    const csv = serializePeekCsv(COLUMNS, [\n      { id: \"1\", label: \"a,b\", amount: \"\" },\n      { id: \"2\", label: 'has \"quote\"', amount: \"\" },\n      { id: \"3\", label: \"line\\nbreak\", amount: \"\" },\n    ]);\n\n    expect(csv).toContain('\"a,b\"');\n    expect(csv).toContain('\"has \"\"quote\"\"\"');\n    expect(csv).toContain('\"line\\nbreak\"');\n  });\n\n  it(\"emits empty cells for missing column ids without breaking row structure\", () => {\n    const csv = serializePeekCsv(COLUMNS, [{ id: \"1\" }]);\n    // Three columns -> two commas in the body row, then CRLF.\n    expect(csv).toBe(\"Id,Label,Amount (lamports)\\r\\n1,,\\r\\n\");\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1256,"cache_read_input_tokens":112537,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1256},"output_tokens":71,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"e55c3bab-e2c0-4dc4-9431-fc752babc2b2","uuid":"0a558343-ce1c-45c0-872d-8a78e6f389e8"}
