{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EMissVGqFHrdC2dbLtMxJx","type":"tool_result","content":"1\timport { describe, expect, it, vi } from \"vitest\";\n2\timport type { Sql } from \"postgres\";\n3\timport {\n4\t  PEEK_AUDIT_REDACTED,\n5\t  type PeekAuditPayload,\n6\t} from \"../../../lib/types/peek\";\n7\timport { writePeekAuditEvent } from \"../writer\";\n8\t\n9\ttype SqlCall = { strings: ReadonlyArray<string>; values: ReadonlyArray<unknown> };\n10\t\n11\ttype SqlMock = {\n12\t  sql: Sql;\n13\t  calls: ReadonlyArray<SqlCall>;\n14\t  jsonArgs: ReadonlyArray<unknown>;\n15\t};\n16\t\n17\tconst JSON_SENTINEL = Symbol(\"peek-audit-json\");\n18\t\n19\tfunction createSqlMock(options: { error?: Error } = {}): SqlMock {\n20\t  const calls: SqlCall[] = [];\n21\t  const jsonArgs: unknown[] = [];\n22\t\n23\t  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n24\t    calls.push({ strings: [...strings], values: [...values] });\n25\t    if (options.error) return Promise.reject(options.error);\n26\t    return Promise.resolve([]);\n27\t  };\n28\t\n29\t  const sql = Object.assign(fn, {\n30\t    json(value: unknown) {\n31\t      jsonArgs.push(value);\n32\t      return { [JSON_SENTINEL]: value };\n33\t    },\n34\t  }) as unknown as Sql;\n35\t\n36\t  return { sql, calls, jsonArgs };\n37\t}\n38\t\n39\tfunction basePayload(\n40\t  overrides: Partial<PeekAuditPayload> = {},\n41\t): PeekAuditPayload {\n42\t  return {\n43\t    actorEmail: \"alice@example.com\",\n44\t    route: null,\n45\t    actionId: null,\n46\t    resourceType: null,\n47\t    resourceId: null,\n48\t    filterSummary: null,\n49\t    resultCount: null,\n50\t    requestId: null,\n51\t    rejectionReason: null,\n52\t    changes: null,\n53\t    ...overrides,\n54\t  };\n55\t}\n56\t\n57\tfunction persistedPayload(mock: SqlMock): PeekAuditPayload {\n58\t  expect(mock.jsonArgs).toHaveLength(1);\n59\t  return mock.jsonArgs[0] as PeekAuditPayload;\n60\t}\n61\t\n62\tdescribe(\"writePeekAuditEvent\", () => {\n63\t  it(\"persists a sensitive read with the full FR-11 payload\", async () => {\n64\t    const mock = createSqlMock();\n65\t\n66\t    const result = await writePeekAuditEvent(\n67\t      {\n68\t        eventType: \"peek.user.view_sensitive\",\n69\t        payload: basePayload({\n70\t          route: \"/users/u-1\",\n71\t          actionId: \"user.view_sensitive\",\n72\t          resourceType: \"user\",\n73\t          resourceId: \"u-1\",\n74\t          filterSummary: \"tab=identity\",\n75\t          resultCount: 1,\n76\t          requestId: \"req-123\",\n77\t        }),\n78\t      },\n79\t      { sql: mock.sql },\n80\t    );\n81\t\n82\t    expect(result).toEqual({ ok: true });\n83\t    expect(mock.calls).toHaveLength(1);\n84\t    const insert = mock.calls[0];\n85\t    expect(insert.strings.join(\" \")).toMatch(/insert into operator_events/i);\n86\t    expect(insert.values[0]).toBe(\"peek.user.view_sensitive\");\n87\t\n88\t    const stored = persistedPayload(mock);\n89\t    expect(stored).toEqual({\n90\t      actorEmail: \"alice@example.com\",\n91\t      route: \"/users/u-1\",\n92\t      actionId: \"user.view_sensitive\",\n93\t      resourceType: \"user\",\n94\t      resourceId: \"u-1\",\n95\t      filterSummary: \"tab=identity\",\n96\t      resultCount: 1,\n97\t      requestId: \"req-123\",\n98\t      rejectionReason: null,\n99\t      changes: null,\n100\t    });\n101\t  });\n102\t\n103\t  it(\"persists an export event with result-count and filter summary\", async () => {\n104\t    const mock = createSqlMock();\n105\t\n106\t    const result = await writePeekAuditEvent(\n107\t      {\n108\t        eventType: \"peek.export\",\n109\t        payload: basePayload({\n110\t          route: \"/growth/referrals/export\",\n111\t          actionId: \"referrers.export\",\n112\t          resourceType: \"export\",\n113\t          resourceId: null,\n114\t          filterSummary: \"status=pending&from=2026-04-01\",\n115\t          resultCount: 142,\n116\t          requestId: \"req-export-7\",\n117\t        }),\n118\t      },\n119\t      { sql: mock.sql },\n120\t    );\n121\t\n122\t    expect(result).toEqual({ ok: true });\n123\t    expect(mock.calls[0]?.values[0]).toBe(\"peek.export\");\n124\t\n125\t    const stored = persistedPayload(mock);\n126\t    expect(stored.actorEmail).toBe(\"alice@example.com\");\n127\t    expect(stored.actionId).toBe(\"referrers.export\");\n128\t    expect(stored.resultCount).toBe(142);\n129\t    expect(stored.filterSummary).toBe(\"status=pending&from=2026-04-01\");\n130\t  });\n131\t\n132\t  it(\"persists an access-denied event with the route and rejection reason\", async () => {\n133\t    const mock = createSqlMock();\n134\t\n135\t    const result = await writePeekAuditEvent(\n136\t      {\n137\t        eventType: \"peek.access.denied\",\n138\t        payload: basePayload({\n139\t          route: \"/audit\",\n140\t          actionId: null,\n141\t          rejectionReason: \"role_required:admin\",\n142\t          resourceType: \"route\",\n143\t          resourceId: \"/audit\",\n144\t        }),\n145\t      },\n146\t      { sql: mock.sql },\n147\t    );\n148\t\n149\t    expect(result).toEqual({ ok: true });\n150\t    expect(mock.calls[0]?.values[0]).toBe(\"peek.access.denied\");\n151\t\n152\t    const stored = persistedPayload(mock);\n153\t    expect(stored.rejectionReason).toBe(\"role_required:admin\");\n154\t    expect(stored.route).toBe(\"/audit\");\n155\t  });\n156\t\n157\t  it(\"persists a mutation-applied event with before/after changes\", async () => {\n158\t    const mock = createSqlMock();\n159\t\n160\t    const result = await writePeekAuditEvent(\n161\t      {\n162\t        eventType: \"peek.change.applied\",\n163\t        payload: basePayload({\n164\t          route: \"/growth/kol\",\n165\t          actionId: \"kol_rate.update\",\n166\t          resourceType: \"referral_kol_rates\",\n167\t          resourceId: \"kol-7\",\n168\t          changes: [\n169\t            { field: \"rate_bps\", before: 1000, after: 1500 },\n170\t            { field: \"set_by\", before: \"alice@example.com\", after: \"alice@example.com\" },\n171\t          ],\n172\t        }),\n173\t      },\n174\t      { sql: mock.sql },\n175\t    );\n176\t\n177\t    expect(result).toEqual({ ok: true });\n178\t    expect(mock.calls[0]?.values[0]).toBe(\"peek.change.applied\");\n179\t\n180\t    const stored = persistedPayload(mock);\n181\t    expect(stored.changes).toEqual([\n182\t      { field: \"rate_bps\", before: 1000, after: 1500 },\n183\t      { field: \"set_by\", before: \"alice@example.com\", after: \"alice@example.com\" },\n184\t    ]);\n185\t  });\n186\t\n187\t  it(\"persists a mutation-rejected event with the rejection reason and no submitted secrets\", async () => {\n188\t    const mock = createSqlMock();\n189\t\n190\t    const result = await writePeekAuditEvent(\n191\t      {\n192\t        eventType: \"peek.change.rejected\",\n193\t        payload: basePayload({\n194\t          route: \"/economy/rewards\",\n195\t          actionId: \"reward_config.update\",\n196\t          resourceType: \"reward_config\",\n197\t          resourceId: \"max_daily_payout_lamports\",\n198\t          rejectionReason: \"value_out_of_range\",\n199\t          changes: [\n200\t            { field: \"value\", before: \"100000\", after: \"999999999999\" },\n201\t          ],\n202\t        }),\n203\t      },\n204\t      { sql: mock.sql },\n205\t    );\n206\t\n207\t    expect(result).toEqual({ ok: true });\n208\t    expect(mock.calls[0]?.values[0]).toBe(\"peek.change.rejected\");\n209\t\n210\t    const stored = persistedPayload(mock);\n211\t    expect(stored.rejectionReason).toBe(\"value_out_of_range\");\n212\t    expect(stored.changes?.[0]?.after).toBe(\"999999999999\");\n213\t  });\n214\t\n215\t  it(\"redacts JWT tokens, DB URLs, private keys, Bearer headers, and CF access headers before persisting\", async () => {\n216\t    const mock = createSqlMock();\n217\t\n218\t    const jwt =\n219\t      \"eyJhbGciOiJSUzI1NiJ9.eyJzdWIiOiJhbGljZSJ9.signaturesignaturesignature\";\n220\t    const dbUrl = \"postgresql://user:pw@db.internal:5432/peek?sslmode=require\";\n221\t    const privateKey = \"-----BEGIN RSA PRIVATE KEY-----\\nABCDEF\\n-----END RSA PRIVATE KEY-----\";\n222\t    const bearer = \"Bearer abc123def456ghi789\";\n223\t    const cfHeader = \"cf-access-jwt-assertion: somevalue\";\n224\t\n225\t    const result = await writePeekAuditEvent(\n226\t      {\n227\t        eventType: \"peek.search\",\n228\t        payload: basePayload({\n229\t          route: dbUrl,\n230\t          actionId: bearer,\n231\t          resourceType: \"search\",\n232\t          resourceId: jwt,\n233\t          filterSummary: cfHeader,\n234\t          requestId: privateKey,\n235\t          changes: [\n236\t            { field: \"token\", before: jwt, after: \"harmless\" },\n237\t            { field: \"conn\", before: \"harmless\", after: dbUrl },\n238\t          ],\n239\t        }),\n240\t      },\n241\t      { sql: mock.sql },\n242\t    );\n243\t\n244\t    expect(result).toEqual({ ok: true });\n245\t    const stored = persistedPayload(mock);\n246\t\n247\t    expect(stored.route).toBe(PEEK_AUDIT_REDACTED);\n248\t    expect(stored.actionId).toBe(PEEK_AUDIT_REDACTED);\n249\t    expect(stored.resourceId).toBe(PEEK_AUDIT_REDACTED);\n250\t    expect(stored.filterSummary).toBe(PEEK_AUDIT_REDACTED);\n251\t    expect(stored.requestId).toBe(PEEK_AUDIT_REDACTED);\n252\t    expect(stored.changes).toEqual([\n253\t      { field: \"token\", before: PEEK_AUDIT_REDACTED, after: \"harmless\" },\n254\t      { field: \"conn\", before: \"harmless\", after: PEEK_AUDIT_REDACTED },\n255\t    ]);\n256\t\n257\t    const serialized = JSON.stringify(stored);\n258\t    expect(serialized).not.toContain(jwt);\n259\t    expect(serialized).not.toContain(dbUrl);\n260\t    expect(serialized).not.toContain(\"PRIVATE KEY\");\n261\t    expect(serialized).not.toContain(\"Bearer \");\n262\t    expect(serialized).not.toContain(\"cf-access-jwt-assertion\");\n263\t  });\n264\t\n265\t  it(\"rejects payloads with an empty actor email without inserting a row\", async () => {\n266\t    const mock = createSqlMock();\n267\t\n268\t    const result = await writePeekAuditEvent(\n269\t      {\n270\t        eventType: \"peek.search\",\n271\t        payload: basePayload({ actorEmail: \"\" }),\n272\t      },\n273\t      { sql: mock.sql },\n274\t    );\n275\t\n276\t    expect(result).toEqual({ ok: false, reason: \"invalid_payload\" });\n277\t    expect(mock.calls).toHaveLength(0);\n278\t    expect(mock.jsonArgs).toHaveLength(0);\n279\t  });\n280\t\n281\t  it(\"returns insert_failed and logs the error when the DB rejects the insert\", async () => {\n282\t    const mock = createSqlMock({\n283\t      error: new Error(\"connection refused: postgres://hidden:secret@host\"),\n284\t    });\n285\t    const logger = vi.fn();\n286\t\n287\t    const result = await writePeekAuditEvent(\n288\t      {\n289\t        eventType: \"peek.export\",\n290\t        payload: basePayload({ actionId: \"users.export\" }),\n291\t      },\n292\t      { sql: mock.sql, logger },\n293\t    );\n294\t\n295\t    expect(result).toEqual({ ok: false, reason: \"insert_failed\" });\n296\t    expect(logger).toHaveBeenCalledTimes(1);\n297\t    const [message, context] = logger.mock.calls[0] ?? [];\n298\t    expect(message).toBe(\"[peek-audit] insert failed\");\n299\t    expect(context).toMatchObject({ eventType: \"peek.export\" });\n300\t  });\n301\t\n302\t  it(\"does not propagate the underlying DB error to the caller\", async () => {\n303\t    const mock = createSqlMock({\n304\t      error: new Error(\"internal: schema=peek password=hunter2\"),\n305\t    });\n306\t    // Suppress the default console.error so the failure path stays quiet during the test.\n307\t    const logger = vi.fn();\n308\t\n309\t    const result = await writePeekAuditEvent(\n310\t      {\n311\t        eventType: \"peek.access.denied\",\n312\t        payload: basePayload(),\n313\t      },\n314\t      { sql: mock.sql, logger },\n315\t    );\n316\t\n317\t    expect(result).toEqual({ ok: false, reason: \"insert_failed\" });\n318\t    // The result is a closed union; \"insert_failed\" carries no error detail.\n319\t    expect(JSON.stringify(result)).not.toContain(\"hunter2\");\n320\t    expect(JSON.stringify(result)).not.toContain(\"password\");\n321\t  });\n322\t});\n323\t"}]},"parent_tool_use_id":null,"session_id":"e55c3bab-e2c0-4dc4-9431-fc752babc2b2","uuid":"e5b06481-7591-433f-9acc-54d32638cffb","timestamp":"2026-04-26T07:50:53.848Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/audit/__tests__/writer.test.ts","content":"import { describe, expect, it, vi } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_AUDIT_REDACTED,\n  type PeekAuditPayload,\n} from \"../../../lib/types/peek\";\nimport { writePeekAuditEvent } from \"../writer\";\n\ntype SqlCall = { strings: ReadonlyArray<string>; values: ReadonlyArray<unknown> };\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n  jsonArgs: ReadonlyArray<unknown>;\n};\n\nconst JSON_SENTINEL = Symbol(\"peek-audit-json\");\n\nfunction createSqlMock(options: { error?: Error } = {}): SqlMock {\n  const calls: SqlCall[] = [];\n  const jsonArgs: unknown[] = [];\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    calls.push({ strings: [...strings], values: [...values] });\n    if (options.error) return Promise.reject(options.error);\n    return Promise.resolve([]);\n  };\n\n  const sql = Object.assign(fn, {\n    json(value: unknown) {\n      jsonArgs.push(value);\n      return { [JSON_SENTINEL]: value };\n    },\n  }) as unknown as Sql;\n\n  return { sql, calls, jsonArgs };\n}\n\nfunction basePayload(\n  overrides: Partial<PeekAuditPayload> = {},\n): PeekAuditPayload {\n  return {\n    actorEmail: \"alice@example.com\",\n    route: null,\n    actionId: null,\n    resourceType: null,\n    resourceId: null,\n    filterSummary: null,\n    resultCount: null,\n    requestId: null,\n    rejectionReason: null,\n    changes: null,\n    ...overrides,\n  };\n}\n\nfunction persistedPayload(mock: SqlMock): PeekAuditPayload {\n  expect(mock.jsonArgs).toHaveLength(1);\n  return mock.jsonArgs[0] as PeekAuditPayload;\n}\n\ndescribe(\"writePeekAuditEvent\", () => {\n  it(\"persists a sensitive read with the full FR-11 payload\", async () => {\n    const mock = createSqlMock();\n\n    const result = await writePeekAuditEvent(\n      {\n        eventType: \"peek.user.view_sensitive\",\n        payload: basePayload({\n          route: \"/users/u-1\",\n          actionId: \"user.view_sensitive\",\n          resourceType: \"user\",\n          resourceId: \"u-1\",\n          filterSummary: \"tab=identity\",\n          resultCount: 1,\n          requestId: \"req-123\",\n        }),\n      },\n      { sql: mock.sql },\n    );\n\n    expect(result).toEqual({ ok: true });\n    expect(mock.calls).toHaveLength(1);\n    const insert = mock.calls[0];\n    expect(insert.strings.join(\" \")).toMatch(/insert into operator_events/i);\n    expect(insert.values[0]).toBe(\"peek.user.view_sensitive\");\n\n    const stored = persistedPayload(mock);\n    expect(stored).toEqual({\n      actorEmail: \"alice@example.com\",\n      route: \"/users/u-1\",\n      actionId: \"user.view_sensitive\",\n      resourceType: \"user\",\n      resourceId: \"u-1\",\n      filterSummary: \"tab=identity\",\n      resultCount: 1,\n      requestId: \"req-123\",\n      rejectionReason: null,\n      changes: null,\n    });\n  });\n\n  it(\"persists an export event with result-count and filter summary\", async () => {\n    const mock = createSqlMock();\n\n    const result = await writePeekAuditEvent(\n      {\n        eventType: \"peek.export\",\n        payload: basePayload({\n          route: \"/growth/referrals/export\",\n          actionId: \"referrers.export\",\n          resourceType: \"export\",\n          resourceId: null,\n          filterSummary: \"status=pending&from=2026-04-01\",\n          resultCount: 142,\n          requestId: \"req-export-7\",\n        }),\n      },\n      { sql: mock.sql },\n    );\n\n    expect(result).toEqual({ ok: true });\n    expect(mock.calls[0]?.values[0]).toBe(\"peek.export\");\n\n    const stored = persistedPayload(mock);\n    expect(stored.actorEmail).toBe(\"alice@example.com\");\n    expect(stored.actionId).toBe(\"referrers.export\");\n    expect(stored.resultCount).toBe(142);\n    expect(stored.filterSummary).toBe(\"status=pending&from=2026-04-01\");\n  });\n\n  it(\"persists an access-denied event with the route and rejection reason\", async () => {\n    const mock = createSqlMock();\n\n    const result = await writePeekAuditEvent(\n      {\n        eventType: \"peek.access.denied\",\n        payload: basePayload({\n          route: \"/audit\",\n          actionId: null,\n          rejectionReason: \"role_required:admin\",\n          resourceType: \"route\",\n          resourceId: \"/audit\",\n        }),\n      },\n      { sql: mock.sql },\n    );\n\n    expect(result).toEqual({ ok: true });\n    expect(mock.calls[0]?.values[0]).toBe(\"peek.access.denied\");\n\n    const stored = persistedPayload(mock);\n    expect(stored.rejectionReason).toBe(\"role_required:admin\");\n    expect(stored.route).toBe(\"/audit\");\n  });\n\n  it(\"persists a mutation-applied event with before/after changes\", async () => {\n    const mock = createSqlMock();\n\n    const result = await writePeekAuditEvent(\n      {\n        eventType: \"peek.change.applied\",\n        payload: basePayload({\n          route: \"/growth/kol\",\n          actionId: \"kol_rate.update\",\n          resourceType: \"referral_kol_rates\",\n          resourceId: \"kol-7\",\n          changes: [\n            { field: \"rate_bps\", before: 1000, after: 1500 },\n            { field: \"set_by\", before: \"alice@example.com\", after: \"alice@example.com\" },\n          ],\n        }),\n      },\n      { sql: mock.sql },\n    );\n\n    expect(result).toEqual({ ok: true });\n    expect(mock.calls[0]?.values[0]).toBe(\"peek.change.applied\");\n\n    const stored = persistedPayload(mock);\n    expect(stored.changes).toEqual([\n      { field: \"rate_bps\", before: 1000, after: 1500 },\n      { field: \"set_by\", before: \"alice@example.com\", after: \"alice@example.com\" },\n    ]);\n  });\n\n  it(\"persists a mutation-rejected event with the rejection reason and no submitted secrets\", async () => {\n    const mock = createSqlMock();\n\n    const result = await writePeekAuditEvent(\n      {\n        eventType: \"peek.change.rejected\",\n        payload: basePayload({\n          route: \"/economy/rewards\",\n          actionId: \"reward_config.update\",\n          resourceType: \"reward_config\",\n          resourceId: \"max_daily_payout_lamports\",\n          rejectionReason: \"value_out_of_range\",\n          changes: [\n            { field: \"value\", before: \"100000\", after: \"999999999999\" },\n          ],\n        }),\n      },\n      { sql: mock.sql },\n    );\n\n    expect(result).toEqual({ ok: true });\n    expect(mock.calls[0]?.values[0]).toBe(\"peek.change.rejected\");\n\n    const stored = persistedPayload(mock);\n    expect(stored.rejectionReason).toBe(\"value_out_of_range\");\n    expect(stored.changes?.[0]?.after).toBe(\"999999999999\");\n  });\n\n  it(\"redacts JWT tokens, DB URLs, private keys, Bearer headers, and CF access headers before persisting\", async () => {\n    const mock = createSqlMock();\n\n    const jwt =\n      \"eyJhbGciOiJSUzI1NiJ9.eyJzdWIiOiJhbGljZSJ9.signaturesignaturesignature\";\n    const dbUrl = \"postgresql://user:pw@db.internal:5432/peek?sslmode=require\";\n    const privateKey = \"-----BEGIN RSA PRIVATE KEY-----\\nABCDEF\\n-----END RSA PRIVATE KEY-----\";\n    const bearer = \"Bearer abc123def456ghi789\";\n    const cfHeader = \"cf-access-jwt-assertion: somevalue\";\n\n    const result = await writePeekAuditEvent(\n      {\n        eventType: \"peek.search\",\n        payload: basePayload({\n          route: dbUrl,\n          actionId: bearer,\n          resourceType: \"search\",\n          resourceId: jwt,\n          filterSummary: cfHeader,\n          requestId: privateKey,\n          changes: [\n            { field: \"token\", before: jwt, after: \"harmless\" },\n            { field: \"conn\", before: \"harmless\", after: dbUrl },\n          ],\n        }),\n      },\n      { sql: mock.sql },\n    );\n\n    expect(result).toEqual({ ok: true });\n    const stored = persistedPayload(mock);\n\n    expect(stored.route).toBe(PEEK_AUDIT_REDACTED);\n    expect(stored.actionId).toBe(PEEK_AUDIT_REDACTED);\n    expect(stored.resourceId).toBe(PEEK_AUDIT_REDACTED);\n    expect(stored.filterSummary).toBe(PEEK_AUDIT_REDACTED);\n    expect(stored.requestId).toBe(PEEK_AUDIT_REDACTED);\n    expect(stored.changes).toEqual([\n      { field: \"token\", before: PEEK_AUDIT_REDACTED, after: \"harmless\" },\n      { field: \"conn\", before: \"harmless\", after: PEEK_AUDIT_REDACTED },\n    ]);\n\n    const serialized = JSON.stringify(stored);\n    expect(serialized).not.toContain(jwt);\n    expect(serialized).not.toContain(dbUrl);\n    expect(serialized).not.toContain(\"PRIVATE KEY\");\n    expect(serialized).not.toContain(\"Bearer \");\n    expect(serialized).not.toContain(\"cf-access-jwt-assertion\");\n  });\n\n  it(\"rejects payloads with an empty actor email without inserting a row\", async () => {\n    const mock = createSqlMock();\n\n    const result = await writePeekAuditEvent(\n      {\n        eventType: \"peek.search\",\n        payload: basePayload({ actorEmail: \"\" }),\n      },\n      { sql: mock.sql },\n    );\n\n    expect(result).toEqual({ ok: false, reason: \"invalid_payload\" });\n    expect(mock.calls).toHaveLength(0);\n    expect(mock.jsonArgs).toHaveLength(0);\n  });\n\n  it(\"returns insert_failed and logs the error when the DB rejects the insert\", async () => {\n    const mock = createSqlMock({\n      error: new Error(\"connection refused: postgres://hidden:secret@host\"),\n    });\n    const logger = vi.fn();\n\n    const result = await writePeekAuditEvent(\n      {\n        eventType: \"peek.export\",\n        payload: basePayload({ actionId: \"users.export\" }),\n      },\n      { sql: mock.sql, logger },\n    );\n\n    expect(result).toEqual({ ok: false, reason: \"insert_failed\" });\n    expect(logger).toHaveBeenCalledTimes(1);\n    const [message, context] = logger.mock.calls[0] ?? [];\n    expect(message).toBe(\"[peek-audit] insert failed\");\n    expect(context).toMatchObject({ eventType: \"peek.export\" });\n  });\n\n  it(\"does not propagate the underlying DB error to the caller\", async () => {\n    const mock = createSqlMock({\n      error: new Error(\"internal: schema=peek password=hunter2\"),\n    });\n    // Suppress the default console.error so the failure path stays quiet during the test.\n    const logger = vi.fn();\n\n    const result = await writePeekAuditEvent(\n      {\n        eventType: \"peek.access.denied\",\n        payload: basePayload(),\n      },\n      { sql: mock.sql, logger },\n    );\n\n    expect(result).toEqual({ ok: false, reason: \"insert_failed\" });\n    // The result is a closed union; \"insert_failed\" carries no error detail.\n    expect(JSON.stringify(result)).not.toContain(\"hunter2\");\n    expect(JSON.stringify(result)).not.toContain(\"password\");\n  });\n});\n","numLines":323,"startLine":1,"totalLines":323}}}
