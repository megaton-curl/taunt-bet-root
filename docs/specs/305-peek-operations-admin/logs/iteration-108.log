.wallet,\n    referralCode: row.referralCode ?? \"\",\n    refereeCount: row.refereeCount.toString(),\n    activeRefereeCount: row.activeRefereeCount.toString(),\n    referredWagerLamports: row.referredWagerLamports,\n    referrerEarnedLamports: row.referrerEarnedLamports,\n    pendingClaimLamports: row.pendingClaimLamports,\n  };\n}\n\nexport const REFERRERS_EXPORTER: PeekExporterDefinition = {\n  entity: \"referrers\",\n  resourceType: \"referral_top_referrer\",\n  columns: REFERRER_COLUMNS,\n  maxRowsPerExport: PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT,\n  requireAtLeastOneFilter: false,\n  async fetch(ctx) {\n    const rows = await listTopReferrers({\n      sql: ctx.sql,\n      limit: ctx.rowCap + 1,\n    });\n    const rowCapApplied = rows.length > ctx.rowCap;\n    const trimmed = rowCapApplied ? rows.slice(0, ctx.rowCap) : rows;\n    return {\n      rows: trimmed.map(rowToCsv),\n      rowCapApplied,\n    };\n  },\n  buildFilterSlug() {\n    // The top-referrers list has no user-supplied filter axis; the bound is\n    // an implicit ranked-list limit. Returning an empty slug yields a\n    // deterministic `peek-referrers-YYYY-MM-DD.csv` filename.\n    return \"\";\n  },\n};\n","numLines":105,"startLine":1,"totalLines":105}}}
