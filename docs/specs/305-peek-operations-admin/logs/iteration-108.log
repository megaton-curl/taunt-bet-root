{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SMcpwQQHsYg4yMTRYyT3ak","type":"tool_result","content":"1\timport { NextRequest } from \"next/server\";\n2\timport { afterEach, describe, expect, it, vi } from \"vitest\";\n3\timport { proxy } from \"../../../proxy\";\n4\timport { VERIFIED_ACCESS_EMAIL_HEADER } from \"../cloudflare-access\";\n5\t\n6\tdescribe(\"cloudflare access middleware\", () => {\n7\t  afterEach(() => {\n8\t    vi.unstubAllEnvs();\n9\t  });\n10\t\n11\t  it(\"blocks direct production traffic without a Cloudflare Access JWT\", async () => {\n12\t    vi.stubEnv(\"NODE_ENV\", \"production\");\n13\t    vi.stubEnv(\"CF_ACCESS_AUD\", \"peek-audience\");\n14\t    vi.stubEnv(\"CF_ACCESS_TEAM_DOMAIN\", \"https://taunt.cloudflareaccess.com\");\n15\t\n16\t    const response = await proxy(\n17\t      new NextRequest(\"https://dev.tb.reporting.win/\"),\n18\t    );\n19\t\n20\t    expect(response.status).toBe(403);\n21\t    await expect(response.text()).resolves.toBe(\"Cloudflare Access required\");\n22\t  });\n23\t\n24\t  it(\"returns 500 in production when Cloudflare Access env is missing\", async () => {\n25\t    vi.stubEnv(\"NODE_ENV\", \"production\");\n26\t    vi.stubEnv(\"CF_ACCESS_AUD\", \"\");\n27\t    vi.stubEnv(\"CF_ACCESS_TEAM_DOMAIN\", \"\");\n28\t\n29\t    const response = await proxy(\n30\t      new NextRequest(\"https://dev.tb.reporting.win/\"),\n31\t    );\n32\t\n33\t    expect(response.status).toBe(500);\n34\t    await expect(response.text()).resolves.toBe(\n35\t      \"Cloudflare Access is not configured\",\n36\t    );\n37\t  });\n38\t\n39\t  it(\"ignores PEEK_DEV_ACCESS_EMAIL in production\", async () => {\n40\t    vi.stubEnv(\"NODE_ENV\", \"production\");\n41\t    vi.stubEnv(\"PEEK_DEV_ACCESS_EMAIL\", \"dev@example.com\");\n42\t    vi.stubEnv(\"CF_ACCESS_AUD\", \"peek-audience\");\n43\t    vi.stubEnv(\"CF_ACCESS_TEAM_DOMAIN\", \"https://taunt.cloudflareaccess.com\");\n44\t\n45\t    const response = await proxy(\n46\t      new NextRequest(\"https://dev.tb.reporting.win/\"),\n47\t    );\n48\t\n49\t    expect(response.status).toBe(403);\n50\t    expect(\n51\t      response.headers.get(`x-middleware-request-${VERIFIED_ACCESS_EMAIL_HEADER}`),\n52\t    ).toBeNull();\n53\t  });\n54\t\n55\t  it(\"honors PEEK_DEV_ACCESS_EMAIL bypass in development\", async () => {\n56\t    vi.stubEnv(\"NODE_ENV\", \"development\");\n57\t    vi.stubEnv(\"PEEK_DEV_ACCESS_EMAIL\", \"Dev@Example.COM\");\n58\t\n59\t    const response = await proxy(\n60\t      new NextRequest(\"http://localhost:3000/\"),\n61\t    );\n62\t\n63\t    expect(response.status).toBe(200);\n64\t    expect(\n65\t      response.headers.get(`x-middleware-request-${VERIFIED_ACCESS_EMAIL_HEADER}`),\n66\t    ).toBe(\"dev@example.com\");\n67\t  });\n68\t\n69\t  it(\"ignores a malformed PEEK_DEV_ACCESS_EMAIL in development\", async () => {\n70\t    vi.stubEnv(\"NODE_ENV\", \"development\");\n71\t    vi.stubEnv(\"PEEK_DEV_ACCESS_EMAIL\", \"not-an-email\");\n72\t\n73\t    const response = await proxy(\n74\t      new NextRequest(\"http://localhost:3000/\"),\n75\t    );\n76\t\n77\t    expect(response.status).toBe(200);\n78\t    expect(\n79\t      response.headers.get(`x-middleware-request-${VERIFIED_ACCESS_EMAIL_HEADER}`),\n80\t    ).toBeNull();\n81\t  });\n82\t});\n83\t"}]},"parent_tool_use_id":null,"session_id":"e55c3bab-e2c0-4dc4-9431-fc752babc2b2","uuid":"ddeebf26-d2ea-49f5-96a2-2b5c07da8820","timestamp":"2026-04-26T07:51:37.856Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/__tests__/cloudflare-access-middleware.test.ts","content":"import { NextRequest } from \"next/server\";\nimport { afterEach, describe, expect, it, vi } from \"vitest\";\nimport { proxy } from \"../../../proxy\";\nimport { VERIFIED_ACCESS_EMAIL_HEADER } from \"../cloudflare-access\";\n\ndescribe(\"cloudflare access middleware\", () => {\n  afterEach(() => {\n    vi.unstubAllEnvs();\n  });\n\n  it(\"blocks direct production traffic without a Cloudflare Access JWT\", async () => {\n    vi.stubEnv(\"NODE_ENV\", \"production\");\n    vi.stubEnv(\"CF_ACCESS_AUD\", \"peek-audience\");\n    vi.stubEnv(\"CF_ACCESS_TEAM_DOMAIN\", \"https://taunt.cloudflareaccess.com\");\n\n    const response = await proxy(\n      new NextRequest(\"https://dev.tb.reporting.win/\"),\n    );\n\n    expect(response.status).toBe(403);\n    await expect(response.text()).resolves.toBe(\"Cloudflare Access required\");\n  });\n\n  it(\"returns 500 in production when Cloudflare Access env is missing\", async () => {\n    vi.stubEnv(\"NODE_ENV\", \"production\");\n    vi.stubEnv(\"CF_ACCESS_AUD\", \"\");\n    vi.stubEnv(\"CF_ACCESS_TEAM_DOMAIN\", \"\");\n\n    const response = await proxy(\n      new NextRequest(\"https://dev.tb.reporting.win/\"),\n    );\n\n    expect(response.status).toBe(500);\n    await expect(response.text()).resolves.toBe(\n      \"Cloudflare Access is not configured\",\n    );\n  });\n\n  it(\"ignores PEEK_DEV_ACCESS_EMAIL in production\", async () => {\n    vi.stubEnv(\"NODE_ENV\", \"production\");\n    vi.stubEnv(\"PEEK_DEV_ACCESS_EMAIL\", \"dev@example.com\");\n    vi.stubEnv(\"CF_ACCESS_AUD\", \"peek-audience\");\n    vi.stubEnv(\"CF_ACCESS_TEAM_DOMAIN\", \"https://taunt.cloudflareaccess.com\");\n\n    const response = await proxy(\n      new NextRequest(\"https://dev.tb.reporting.win/\"),\n    );\n\n    expect(response.status).toBe(403);\n    expect(\n      response.headers.get(`x-middleware-request-${VERIFIED_ACCESS_EMAIL_HEADER}`),\n    ).toBeNull();\n  });\n\n  it(\"honors PEEK_DEV_ACCESS_EMAIL bypass in development\", async () => {\n    vi.stubEnv(\"NODE_ENV\", \"development\");\n    vi.stubEnv(\"PEEK_DEV_ACCESS_EMAIL\", \"Dev@Example.COM\");\n\n    const response = await proxy(\n      new NextRequest(\"http://localhost:3000/\"),\n    );\n\n    expect(response.status).toBe(200);\n    expect(\n      response.headers.get(`x-middleware-request-${VERIFIED_ACCESS_EMAIL_HEADER}`),\n    ).toBe(\"dev@example.com\");\n  });\n\n  it(\"ignores a malformed PEEK_DEV_ACCESS_EMAIL in development\", async () => {\n    vi.stubEnv(\"NODE_ENV\", \"development\");\n    vi.stubEnv(\"PEEK_DEV_ACCESS_EMAIL\", \"not-an-email\");\n\n    const response = await proxy(\n      new NextRequest(\"http://localhost:3000/\"),\n    );\n\n    expect(response.status).toBe(200);\n    expect(\n      response.headers.get(`x-middleware-request-${VERIFIED_ACCESS_EMAIL_HEADER}`),\n    ).toBeNull();\n  });\n});\n","numLines":83,"startLine":1,"totalLines":83}}}
