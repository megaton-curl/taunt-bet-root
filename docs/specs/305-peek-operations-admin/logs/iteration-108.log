{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QYBRbCiDD6GqXnLuCwA7kB","type":"tool_result","content":"1\t// Browser-safe export URL builder (FR-12).\n2\t//\n3\t// Pages render export action links pointing at `/exports/{entity}` with the\n4\t// active table filters serialized as URL params. The export Route Handler\n5\t// reads the params verbatim and forwards them to `runPeekExport`; each\n6\t// exporter picks only the keys it understands, so extra params are ignored.\n7\t//\n8\t// Empty / null filter values are skipped so the export href stays clean and\n9\t// `peek.export` audit `filterSummary` only mentions filters that were actually\n10\t// applied.\n11\timport type { PeekExportEntity } from \"./types/peek\";\n12\t\n13\texport type ExportHrefFilters = Readonly<\n14\t  Record<string, string | null | undefined>\n15\t>;\n16\t\n17\texport function buildExportHref(\n18\t  entity: PeekExportEntity,\n19\t  filters: ExportHrefFilters = {},\n20\t): string {\n21\t  const params = new URLSearchParams();\n22\t  for (const [key, value] of Object.entries(filters)) {\n23\t    if (value === null || value === undefined) continue;\n24\t    const trimmed = String(value).trim();\n25\t    if (trimmed === \"\") continue;\n26\t    params.set(key, trimmed);\n27\t  }\n28\t  const query = params.toString();\n29\t  return query ? `/exports/${entity}?${query}` : `/exports/${entity}`;\n30\t}\n31\t"}]},"parent_tool_use_id":null,"session_id":"e55c3bab-e2c0-4dc4-9431-fc752babc2b2","uuid":"dea39b19-f0fa-4c14-9d96-151b8b71de2b","timestamp":"2026-04-26T07:50:45.131Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/export-href.ts","content":"// Browser-safe export URL builder (FR-12).\n//\n// Pages render export action links pointing at `/exports/{entity}` with the\n// active table filters serialized as URL params. The export Route Handler\n// reads the params verbatim and forwards them to `runPeekExport`; each\n// exporter picks only the keys it understands, so extra params are ignored.\n//\n// Empty / null filter values are skipped so the export href stays clean and\n// `peek.export` audit `filterSummary` only mentions filters that were actually\n// applied.\nimport type { PeekExportEntity } from \"./types/peek\";\n\nexport type ExportHrefFilters = Readonly<\n  Record<string, string | null | undefined>\n>;\n\nexport function buildExportHref(\n  entity: PeekExportEntity,\n  filters: ExportHrefFilters = {},\n): string {\n  const params = new URLSearchParams();\n  for (const [key, value] of Object.entries(filters)) {\n    if (value === null || value === undefined) continue;\n    const trimmed = String(value).trim();\n    if (trimmed === \"\") continue;\n    params.set(key, trimmed);\n  }\n  const query = params.toString();\n  return query ? `/exports/${entity}?${query}` : `/exports/${entity}`;\n}\n","numLines":31,"startLine":1,"totalLines":31}}}
