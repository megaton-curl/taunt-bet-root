{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01YL1DoF9gJdeKbuG8kc1cQK","type":"message","role":"assistant","content":[{"type":"thinking","thinking":"","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":636,"cache_read_input_tokens":125836,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":636},"output_tokens":49,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"e55c3bab-e2c0-4dc4-9431-fc752babc2b2","uuid":"77e0eeda-7cf8-43ea-bd49-98fc449ccae1"}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01YL1DoF9gJdeKbuG8kc1cQK","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_014SZgiesPW8VCYWiaV4L9cr","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/exports/__tests__/route-handler.test.ts","content":"// Route handler tests (FR-12).\n//\n// Asserts that `/exports/[entity]`:\n//   1. Refuses unknown entities and entities without a wired source page\n//      (404 fail-closed).\n//   2. Refuses requests with no resolved actor context (403).\n//   3. Refuses actors whose role cannot reach the source page (403,\n//      role-aware export gate inherits the page-level FR-2 policy).\n//   4. Forwards the URL search params verbatim to the runner.\n//   5. Maps runner failure reasons onto the documented HTTP status codes\n//      (no_filters → 400, audit_unavailable → 503, audit_emit_failed → 502,\n//      unknown_entity → 404).\n//   6. On success, returns CSV bytes with deterministic\n//      `Content-Disposition` and `Cache-Control: no-store`.\n//\n// The runner itself is unit-tested separately; these tests target the\n// handler's role-gate and response shaping only.\n\nimport { NextRequest } from \"next/server\";\nimport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\nconst accessPolicyMock = vi.hoisted(() => ({\n  getPeekActorContext: vi.fn(),\n  isRouteAllowedForRole: vi.fn(),\n}));\n\nconst exportsMock = vi.hoisted(() => ({\n  getPeekExporter: vi.fn(),\n  getSourceRouteForExportEntity: vi.fn(),\n  runPeekExport: vi.fn(),\n  serializePeekCsv: vi.fn(),\n}));\n\nvi.mock(\"../../../../src/server/access-policy\", () => accessPolicyMock);\nvi.mock(\"../../../../src/server/exports\", () => exportsMock);\n\nimport { GET } from \"../../../../app/exports/[entity]/route\";\n\ntype RouteContext = { params: Promise<{ entity: string }> };\n\nfunction makeContext(entity: string): RouteContext {\n  return { params: Promise.resolve({ entity }) };\n}\n\nfunction makeRequest(url: string, headers: Record<string, string> = {}): NextRequest {\n  return new NextRequest(url, { headers });\n}\n\nbeforeEach(() => {\n  // Defaults: known entity, source page exists, actor is admin, role allowed.\n  exportsMock.getPeekExporter.mockReturnValue({ entity: \"claims\" });\n  exportsMock.getSourceRouteForExportEntity.mockReturnValue(\"/growth/referrals\");\n  exportsMock.runPeekExport.mockResolvedValue({\n    ok: true,\n    result: {\n      filename: \"peek-claims-2026-04-26-status-pending.csv\",\n      rowCount: 2,\n      rowCap: 5000,\n      rowCapApplied: false,\n      columns: [\n        { id: \"id\", label: \"Id\", align: \"left\", sortable: false },\n      ],\n      rows: [{ id: \"1\" }, { id: \"2\" }],\n    },\n  });\n  exportsMock.serializePeekCsv.mockReturnValue(\"Id\\r\\n1\\r\\n2\\r\\n\");\n  accessPolicyMock.getPeekActorContext.mockResolvedValue({\n    email: \"alice@example.com\",\n    role: \"admin\",\n  });\n  accessPolicyMock.isRouteAllowedForRole.mockReturnValue(true);\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\ndescribe(\"/exports/[entity] route handler\", () => {\n  describe(\"entity validation\", () => {\n    it(\"returns 404 for an unknown entity name\", async () => {\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/not-a-thing\"),\n        makeContext(\"not-a-thing\"),\n      );\n\n      expect(response.status).toBe(404);\n      expect(exportsMock.runPeekExport).not.toHaveBeenCalled();\n    });\n\n    it(\"returns 404 when the registry has no exporter for a typed entity\", async () => {\n      exportsMock.getPeekExporter.mockReturnValueOnce(null);\n\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/users\"),\n        makeContext(\"users\"),\n      );\n\n      expect(response.status).toBe(404);\n      expect(exportsMock.runPeekExport).not.toHaveBeenCalled();\n    });\n\n    it(\"returns 404 when the entity has no wired source page (fail closed)\", async () => {\n      exportsMock.getSourceRouteForExportEntity.mockReturnValueOnce(null);\n\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/audit\"),\n        makeContext(\"audit\"),\n      );\n\n      expect(response.status).toBe(404);\n      expect(exportsMock.runPeekExport).not.toHaveBeenCalled();\n    });\n  });\n\n  describe(\"role check\", () => {\n    it(\"returns 403 when no actor context can be resolved\", async () => {\n      accessPolicyMock.getPeekActorContext.mockResolvedValueOnce(null);\n\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/claims\"),\n        makeContext(\"claims\"),\n      );\n\n      expect(response.status).toBe(403);\n      expect(exportsMock.runPeekExport).not.toHaveBeenCalled();\n    });\n\n    it(\"returns 403 when the actor's role cannot reach the source page\", async () => {\n      accessPolicyMock.getPeekActorContext.mockResolvedValueOnce({\n        email: \"bob@example.com\",\n        role: \"business\",\n      });\n      accessPolicyMock.isRouteAllowedForRole.mockReturnValueOnce(false);\n\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/claims\"),\n        makeContext(\"claims\"),\n      );\n\n      expect(response.status).toBe(403);\n      expect(accessPolicyMock.isRouteAllowedForRole).toHaveBeenCalledWith(\n        \"/growth/referrals\",\n        \"business\",\n      );\n      expect(exportsMock.runPeekExport).not.toHaveBeenCalled();\n    });\n\n    it(\"inherits page-level access from the entity's source page\", async () => {\n      // claims → /growth/referrals; the route check is delegated to the same\n      // FR-2 policy helper as the page itself, with the same arguments.\n      await GET(\n        makeRequest(\"https://peek.example/exports/claims?status=pending\"),\n        makeContext(\"claims\"),\n      );\n\n      expect(accessPolicyMock.isRouteAllowedForRole).toHaveBeenCalledWith(\n        \"/growth/referrals\",\n        \"admin\",\n      );\n    });\n  });\n\n  describe(\"filter forwarding\", () => {\n    it(\"forwards URL search params to runPeekExport as filters\", async () => {\n      await GET(\n        makeRequest(\n          \"https://peek.example/exports/claims?status=pending&userId=u-1\",\n        ),\n        makeContext(\"claims\"),\n      );\n\n      const call = exportsMock.runPeekExport.mock.calls[0]?.[0];\n      expect(call.entity).toBe(\"claims\");\n      expect(call.filters).toEqual({ status: \"pending\", userId: \"u-1\" });\n      expect(call.actor.email).toBe(\"alice@example.com\");\n      expect(call.actor.route).toBe(\"/growth/referrals\");\n    });\n\n    it(\"propagates the x-request-id header into the actor context\", async () => {\n      await GET(\n        makeRequest(\n          \"https://peek.example/exports/claims?status=pending\",\n          { \"x-request-id\": \"req-9001\" },\n        ),\n        makeContext(\"claims\"),\n      );\n\n      const call = exportsMock.runPeekExport.mock.calls[0]?.[0];\n      expect(call.actor.requestId).toBe(\"req-9001\");\n    });\n  });\n\n  describe(\"runner failure mapping\", () => {\n    it(\"maps no_filters → 400\", async () => {\n      exportsMock.runPeekExport.mockResolvedValueOnce({\n        ok: false,\n        reason: \"no_filters\",\n        message: \"Apply at least one filter.\",\n      });\n\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/claims\"),\n        makeContext(\"claims\"),\n      );\n      expect(response.status).toBe(400);\n    });\n\n    it(\"maps audit_unavailable → 503 (production-without-DB gate)\", async () => {\n      exportsMock.runPeekExport.mockResolvedValueOnce({\n        ok: false,\n        reason: \"audit_unavailable\",\n        message:\n          \"Exports are disabled in production when audit logging is not configured.\",\n      });\n\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/claims?status=pending\"),\n        makeContext(\"claims\"),\n      );\n      expect(response.status).toBe(503);\n    });\n\n    it(\"maps audit_emit_failed → 502 (audit insert failure refuses to leak rows)\", async () => {\n      exportsMock.runPeekExport.mockResolvedValueOnce({\n        ok: false,\n        reason: \"audit_emit_failed\",\n        message: \"Audit emission failed; refusing to return export rows.\",\n      });\n\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/claims?status=pending\"),\n        makeContext(\"claims\"),\n      );\n      expect(response.status).toBe(502);\n    });\n\n    it(\"maps unknown_entity → 404\", async () => {\n      exportsMock.runPeekExport.mockResolvedValueOnce({\n        ok: false,\n        reason: \"unknown_entity\",\n        message: \"No approved peek exporter for entity.\",\n      });\n\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/claims\"),\n        makeContext(\"claims\"),\n      );\n      expect(response.status).toBe(404);\n    });\n  });\n\n  describe(\"success response\", () => {\n    it(\"returns CSV bytes with a deterministic Content-Disposition filename\", async () => {\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/claims?status=pending\"),\n        makeContext(\"claims\"),\n      );\n\n      expect(response.status).toBe(200);\n      expect(response.headers.get(\"Content-Type\")).toBe(\n        \"text/csv; charset=utf-8\",\n      );\n      expect(response.headers.get(\"Content-Disposition\")).toBe(\n        'attachment; filename=\"peek-claims-2026-04-26-status-pending.csv\"',\n      );\n      expect(response.headers.get(\"Cache-Control\")).toBe(\"no-store\");\n      await expect(response.text()).resolves.toBe(\"Id\\r\\n1\\r\\n2\\r\\n\");\n    });\n\n    it(\"calls serializePeekCsv with the exporter columns and runner rows\", async () => {\n      await GET(\n        makeRequest(\"https://peek.example/exports/claims?status=pending\"),\n        makeContext(\"claims\"),\n      );\n\n      const [columns, rows] =\n        exportsMock.serializePeekCsv.mock.calls[0] ?? [];\n      expect(columns).toEqual([\n        { id: \"id\", label: \"Id\", align: \"left\", sortable: false },\n      ]);\n      expect(rows).toEqual([{ id: \"1\" }, { id: \"2\" }]);\n    });\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":636,"cache_read_input_tokens":125836,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":636},"output_tokens":49,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"e55c3bab-e2c0-4dc4-9431-fc752babc2b2","uuid":"0338fce9-7f75-47e2-8057-f60af89a53cd"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014SZgiesPW8VCYWiaV4L9cr","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/server/exports/__tests__/route-handler.test.ts"}]},"parent_tool_use_id":null,"session_id":"e55c3bab-e2c0-4dc4-9431-fc752babc2b2","uuid":"a723fbcd-7949-447a-91f4-89c10c684836","timestamp":"2026-04-26T07:55:06.801Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/server/exports/__tests__/route-handler.test.ts","content":"// Route handler tests (FR-12).\n//\n// Asserts that `/exports/[entity]`:\n//   1. Refuses unknown entities and entities without a wired source page\n//      (404 fail-closed).\n//   2. Refuses requests with no resolved actor context (403).\n//   3. Refuses actors whose role cannot reach the source page (403,\n//      role-aware export gate inherits the page-level FR-2 policy).\n//   4. Forwards the URL search params verbatim to the runner.\n//   5. Maps runner failure reasons onto the documented HTTP status codes\n//      (no_filters → 400, audit_unavailable → 503, audit_emit_failed → 502,\n//      unknown_entity → 404).\n//   6. On success, returns CSV bytes with deterministic\n//      `Content-Disposition` and `Cache-Control: no-store`.\n//\n// The runner itself is unit-tested separately; these tests target the\n// handler's role-gate and response shaping only.\n\nimport { NextRequest } from \"next/server\";\nimport { afterEach, beforeEach, describe, expect, it, vi } from \"vitest\";\n\nconst accessPolicyMock = vi.hoisted(() => ({\n  getPeekActorContext: vi.fn(),\n  isRouteAllowedForRole: vi.fn(),\n}));\n\nconst exportsMock = vi.hoisted(() => ({\n  getPeekExporter: vi.fn(),\n  getSourceRouteForExportEntity: vi.fn(),\n  runPeekExport: vi.fn(),\n  serializePeekCsv: vi.fn(),\n}));\n\nvi.mock(\"../../../../src/server/access-policy\", () => accessPolicyMock);\nvi.mock(\"../../../../src/server/exports\", () => exportsMock);\n\nimport { GET } from \"../../../../app/exports/[entity]/route\";\n\ntype RouteContext = { params: Promise<{ entity: string }> };\n\nfunction makeContext(entity: string): RouteContext {\n  return { params: Promise.resolve({ entity }) };\n}\n\nfunction makeRequest(url: string, headers: Record<string, string> = {}): NextRequest {\n  return new NextRequest(url, { headers });\n}\n\nbeforeEach(() => {\n  // Defaults: known entity, source page exists, actor is admin, role allowed.\n  exportsMock.getPeekExporter.mockReturnValue({ entity: \"claims\" });\n  exportsMock.getSourceRouteForExportEntity.mockReturnValue(\"/growth/referrals\");\n  exportsMock.runPeekExport.mockResolvedValue({\n    ok: true,\n    result: {\n      filename: \"peek-claims-2026-04-26-status-pending.csv\",\n      rowCount: 2,\n      rowCap: 5000,\n      rowCapApplied: false,\n      columns: [\n        { id: \"id\", label: \"Id\", align: \"left\", sortable: false },\n      ],\n      rows: [{ id: \"1\" }, { id: \"2\" }],\n    },\n  });\n  exportsMock.serializePeekCsv.mockReturnValue(\"Id\\r\\n1\\r\\n2\\r\\n\");\n  accessPolicyMock.getPeekActorContext.mockResolvedValue({\n    email: \"alice@example.com\",\n    role: \"admin\",\n  });\n  accessPolicyMock.isRouteAllowedForRole.mockReturnValue(true);\n});\n\nafterEach(() => {\n  vi.clearAllMocks();\n});\n\ndescribe(\"/exports/[entity] route handler\", () => {\n  describe(\"entity validation\", () => {\n    it(\"returns 404 for an unknown entity name\", async () => {\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/not-a-thing\"),\n        makeContext(\"not-a-thing\"),\n      );\n\n      expect(response.status).toBe(404);\n      expect(exportsMock.runPeekExport).not.toHaveBeenCalled();\n    });\n\n    it(\"returns 404 when the registry has no exporter for a typed entity\", async () => {\n      exportsMock.getPeekExporter.mockReturnValueOnce(null);\n\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/users\"),\n        makeContext(\"users\"),\n      );\n\n      expect(response.status).toBe(404);\n      expect(exportsMock.runPeekExport).not.toHaveBeenCalled();\n    });\n\n    it(\"returns 404 when the entity has no wired source page (fail closed)\", async () => {\n      exportsMock.getSourceRouteForExportEntity.mockReturnValueOnce(null);\n\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/audit\"),\n        makeContext(\"audit\"),\n      );\n\n      expect(response.status).toBe(404);\n      expect(exportsMock.runPeekExport).not.toHaveBeenCalled();\n    });\n  });\n\n  describe(\"role check\", () => {\n    it(\"returns 403 when no actor context can be resolved\", async () => {\n      accessPolicyMock.getPeekActorContext.mockResolvedValueOnce(null);\n\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/claims\"),\n        makeContext(\"claims\"),\n      );\n\n      expect(response.status).toBe(403);\n      expect(exportsMock.runPeekExport).not.toHaveBeenCalled();\n    });\n\n    it(\"returns 403 when the actor's role cannot reach the source page\", async () => {\n      accessPolicyMock.getPeekActorContext.mockResolvedValueOnce({\n        email: \"bob@example.com\",\n        role: \"business\",\n      });\n      accessPolicyMock.isRouteAllowedForRole.mockReturnValueOnce(false);\n\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/claims\"),\n        makeContext(\"claims\"),\n      );\n\n      expect(response.status).toBe(403);\n      expect(accessPolicyMock.isRouteAllowedForRole).toHaveBeenCalledWith(\n        \"/growth/referrals\",\n        \"business\",\n      );\n      expect(exportsMock.runPeekExport).not.toHaveBeenCalled();\n    });\n\n    it(\"inherits page-level access from the entity's source page\", async () => {\n      // claims → /growth/referrals; the route check is delegated to the same\n      // FR-2 policy helper as the page itself, with the same arguments.\n      await GET(\n        makeRequest(\"https://peek.example/exports/claims?status=pending\"),\n        makeContext(\"claims\"),\n      );\n\n      expect(accessPolicyMock.isRouteAllowedForRole).toHaveBeenCalledWith(\n        \"/growth/referrals\",\n        \"admin\",\n      );\n    });\n  });\n\n  describe(\"filter forwarding\", () => {\n    it(\"forwards URL search params to runPeekExport as filters\", async () => {\n      await GET(\n        makeRequest(\n          \"https://peek.example/exports/claims?status=pending&userId=u-1\",\n        ),\n        makeContext(\"claims\"),\n      );\n\n      const call = exportsMock.runPeekExport.mock.calls[0]?.[0];\n      expect(call.entity).toBe(\"claims\");\n      expect(call.filters).toEqual({ status: \"pending\", userId: \"u-1\" });\n      expect(call.actor.email).toBe(\"alice@example.com\");\n      expect(call.actor.route).toBe(\"/growth/referrals\");\n    });\n\n    it(\"propagates the x-request-id header into the actor context\", async () => {\n      await GET(\n        makeRequest(\n          \"https://peek.example/exports/claims?status=pending\",\n          { \"x-request-id\": \"req-9001\" },\n        ),\n        makeContext(\"claims\"),\n      );\n\n      const call = exportsMock.runPeekExport.mock.calls[0]?.[0];\n      expect(call.actor.requestId).toBe(\"req-9001\");\n    });\n  });\n\n  describe(\"runner failure mapping\", () => {\n    it(\"maps no_filters → 400\", async () => {\n      exportsMock.runPeekExport.mockResolvedValueOnce({\n        ok: false,\n        reason: \"no_filters\",\n        message: \"Apply at least one filter.\",\n      });\n\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/claims\"),\n        makeContext(\"claims\"),\n      );\n      expect(response.status).toBe(400);\n    });\n\n    it(\"maps audit_unavailable → 503 (production-without-DB gate)\", async () => {\n      exportsMock.runPeekExport.mockResolvedValueOnce({\n        ok: false,\n        reason: \"audit_unavailable\",\n        message:\n          \"Exports are disabled in production when audit logging is not configured.\",\n      });\n\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/claims?status=pending\"),\n        makeContext(\"claims\"),\n      );\n      expect(response.status).toBe(503);\n    });\n\n    it(\"maps audit_emit_failed → 502 (audit insert failure refuses to leak rows)\", async () => {\n      exportsMock.runPeekExport.mockResolvedValueOnce({\n        ok: false,\n        reason: \"audit_emit_failed\",\n        message: \"Audit emission failed; refusing to return export rows.\",\n      });\n\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/claims?status=pending\"),\n        makeContext(\"claims\"),\n      );\n      expect(response.status).toBe(502);\n    });\n\n    it(\"maps unknown_entity → 404\", async () => {\n      exportsMock.runPeekExport.mockResolvedValueOnce({\n        ok: false,\n        reason: \"unknown_entity\",\n        message: \"No approved peek exporter for entity.\",\n      });\n\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/claims\"),\n        makeContext(\"claims\"),\n      );\n      expect(response.status).toBe(404);\n    });\n  });\n\n  describe(\"success response\", () => {\n    it(\"returns CSV bytes with a deterministic Content-Disposition filename\", async () => {\n      const response = await GET(\n        makeRequest(\"https://peek.example/exports/claims?status=pending\"),\n        makeContext(\"claims\"),\n      );\n\n      expect(response.status).toBe(200);\n      expect(response.headers.get(\"Content-Type\")).toBe(\n        \"text/csv; charset=utf-8\",\n      );\n      expect(response.headers.get(\"Content-Disposition\")).toBe(\n        'attachment; filename=\"peek-claims-2026-04-26-status-pending.csv\"',\n      );\n      expect(response.headers.get(\"Cache-Control\")).toBe(\"no-store\");\n      await expect(response.text()).resolves.toBe(\"Id\\r\\n1\\r\\n2\\r\\n\");\n    });\n\n    it(\"calls serializePeekCsv with the exporter columns and runner rows\", async () => {\n      await GET(\n        makeRequest(\"https://peek.example/exports/claims?status=pending\"),\n        makeContext(\"claims\"),\n      );\n\n      const [columns, rows] =\n        exportsMock.serializePeekCsv.mock.calls[0] ?? [];\n      expect(columns).toEqual([\n        { id: \"id\", label: \"Id\", align: \"left\", sortable: false },\n      ]);\n      expect(rows).toEqual([{ id: \"1\" }, { id: \"2\" }]);\n    });\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
