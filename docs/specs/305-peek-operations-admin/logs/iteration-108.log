{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ChzUmH4xHABJs188E51MhH","type":"tool_result","content":"1\t// Approved exporter registry (FR-7, FR-12).\n2\t//\n3\t// The runner consumes a frozen registry keyed by `PeekExportEntity`. Each\n4\t// exporter declares its column set, audit `resourceType`, max rows allowed\n5\t// per export (often a per-entity ceiling lower than `PEEK_EXPORT_ROW_CAP_DEFAULT`\n6\t// because the underlying query module already caps how many rows it returns),\n7\t// whether at least one filter is required to avoid an unfiltered full-table\n8\t// dump, a fetch callback that returns view-model strings, and a deterministic\n9\t// filter-slug builder for the filename.\n10\t//\n11\t// Adding a new approved entity is a four-line change: import the exporter\n12\t// definition, add it to the `entries` list, extend `PeekExportEntity` (already\n13\t// in lib/types/peek.ts), and ship the matching frontend wiring iteration.\n14\t\n15\timport type { Sql } from \"postgres\";\n16\timport type {\n17\t  PeekExportEntity,\n18\t  PeekExportRow,\n19\t  PeekTableColumn,\n20\t} from \"../../lib/types/peek\";\n21\timport { CLAIMS_EXPORTER } from \"./exporters/claims\";\n22\timport { KOL_EXPORTER } from \"./exporters/kol\";\n23\timport { REFERRERS_EXPORTER } from \"./exporters/referrers\";\n24\t\n25\texport type PeekExporterFilters = Readonly<Record<string, string | null>>;\n26\t\n27\texport type PeekExporterFetchContext = {\n28\t  sql: Sql;\n29\t  rowCap: number;\n30\t  filters: PeekExporterFilters;\n31\t};\n32\t\n33\texport type PeekExporterFetchResult = {\n34\t  rows: ReadonlyArray<PeekExportRow>;\n35\t  rowCapApplied: boolean;\n36\t};\n37\t\n38\texport type PeekExporterDefinition = {\n39\t  entity: PeekExportEntity;\n40\t  resourceType: string;\n41\t  columns: ReadonlyArray<PeekTableColumn>;\n42\t  // FR-12: bound the export to a per-entity max so a caller cannot request more\n43\t  // rows than the underlying query module is willing to surface in one shot.\n44\t  maxRowsPerExport: number;\n45\t  // FR-12: refuse \"no filter\" exports for tables whose unfiltered shape would\n46\t  // be a full-table dump. Bounded-by-default tables (top referrers, KOL) set\n47\t  // this to `false` because the query module already enforces a hard limit.\n48\t  requireAtLeastOneFilter: boolean;\n49\t  fetch: (ctx: PeekExporterFetchContext) => Promise<PeekExporterFetchResult>;\n50\t  buildFilterSlug: (filters: PeekExporterFilters) => string;\n51\t};\n52\t\n53\texport type PeekExporterRegistry = Readonly<\n54\t  Partial<Record<PeekExportEntity, PeekExporterDefinition>>\n55\t>;\n56\t\n57\tconst entries: ReadonlyArray<PeekExporterDefinition> = [\n58\t  CLAIMS_EXPORTER,\n59\t  REFERRERS_EXPORTER,\n60\t  KOL_EXPORTER,\n61\t];\n62\t\n63\texport const PEEK_EXPORTERS: PeekExporterRegistry = Object.freeze(\n64\t  entries.reduce<Record<string, PeekExporterDefinition>>((acc, def) => {\n65\t    acc[def.entity] = def;\n66\t    return acc;\n67\t  }, {}),\n68\t);\n69\t\n70\texport function getPeekExporter(\n71\t  entity: PeekExportEntity,\n72\t  registry: PeekExporterRegistry = PEEK_EXPORTERS,\n73\t): PeekExporterDefinition | null {\n74\t  return registry[entity] ?? null;\n75\t}\n76\t"}]},"parent_tool_use_id":null,"session_id":"e55c3bab-e2c0-4dc4-9431-fc752babc2b2","uuid":"ed69122c-e8c0-4d66-8a18-a1c8f56018d8","timestamp":"2026-04-26T07:50:36.517Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/exports/registry.ts","content":"// Approved exporter registry (FR-7, FR-12).\n//\n// The runner consumes a frozen registry keyed by `PeekExportEntity`. Each\n// exporter declares its column set, audit `resourceType`, max rows allowed\n// per export (often a per-entity ceiling lower than `PEEK_EXPORT_ROW_CAP_DEFAULT`\n// because the underlying query module already caps how many rows it returns),\n// whether at least one filter is required to avoid an unfiltered full-table\n// dump, a fetch callback that returns view-model strings, and a deterministic\n// filter-slug builder for the filename.\n//\n// Adding a new approved entity is a four-line change: import the exporter\n// definition, add it to the `entries` list, extend `PeekExportEntity` (already\n// in lib/types/peek.ts), and ship the matching frontend wiring iteration.\n\nimport type { Sql } from \"postgres\";\nimport type {\n  PeekExportEntity,\n  PeekExportRow,\n  PeekTableColumn,\n} from \"../../lib/types/peek\";\nimport { CLAIMS_EXPORTER } from \"./exporters/claims\";\nimport { KOL_EXPORTER } from \"./exporters/kol\";\nimport { REFERRERS_EXPORTER } from \"./exporters/referrers\";\n\nexport type PeekExporterFilters = Readonly<Record<string, string | null>>;\n\nexport type PeekExporterFetchContext = {\n  sql: Sql;\n  rowCap: number;\n  filters: PeekExporterFilters;\n};\n\nexport type PeekExporterFetchResult = {\n  rows: ReadonlyArray<PeekExportRow>;\n  rowCapApplied: boolean;\n};\n\nexport type PeekExporterDefinition = {\n  entity: PeekExportEntity;\n  resourceType: string;\n  columns: ReadonlyArray<PeekTableColumn>;\n  // FR-12: bound the export to a per-entity max so a caller cannot request more\n  // rows than the underlying query module is willing to surface in one shot.\n  maxRowsPerExport: number;\n  // FR-12: refuse \"no filter\" exports for tables whose unfiltered shape would\n  // be a full-table dump. Bounded-by-default tables (top referrers, KOL) set\n  // this to `false` because the query module already enforces a hard limit.\n  requireAtLeastOneFilter: boolean;\n  fetch: (ctx: PeekExporterFetchContext) => Promise<PeekExporterFetchResult>;\n  buildFilterSlug: (filters: PeekExporterFilters) => string;\n};\n\nexport type PeekExporterRegistry = Readonly<\n  Partial<Record<PeekExportEntity, PeekExporterDefinition>>\n>;\n\nconst entries: ReadonlyArray<PeekExporterDefinition> = [\n  CLAIMS_EXPORTER,\n  REFERRERS_EXPORTER,\n  KOL_EXPORTER,\n];\n\nexport const PEEK_EXPORTERS: PeekExporterRegistry = Object.freeze(\n  entries.reduce<Record<string, PeekExporterDefinition>>((acc, def) => {\n    acc[def.entity] = def;\n    return acc;\n  }, {}),\n);\n\nexport function getPeekExporter(\n  entity: PeekExportEntity,\n  registry: PeekExporterRegistry = PEEK_EXPORTERS,\n): PeekExporterDefinition | null {\n  return registry[entity] ?? null;\n}\n","numLines":76,"startLine":1,"totalLines":76}}}
