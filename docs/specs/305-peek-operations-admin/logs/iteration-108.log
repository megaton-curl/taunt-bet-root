{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0194TuEixJ4wk5UrAYQUvtQu","type":"tool_result","content":"1\timport { NextResponse, type NextRequest } from \"next/server\";\n2\timport {\n3\t  VERIFIED_ACCESS_EMAIL_HEADER,\n4\t  verifyCloudflareAccessJwt,\n5\t} from \"./src/server/cloudflare-access\";\n6\t\n7\tconst DEV_BYPASS_EMAIL_PATTERN = /^[^\\s@]+@[^\\s@]+$/;\n8\t\n9\texport async function proxy(request: NextRequest) {\n10\t  const teamDomain = process.env.CF_ACCESS_TEAM_DOMAIN?.trim();\n11\t  const audience = process.env.CF_ACCESS_AUD?.trim();\n12\t  const isDevelopment = process.env.NODE_ENV === \"development\";\n13\t\n14\t  // Strip any browser-supplied verified-email header before any branch can\n15\t  // forward the request: server context must only ever see the value that the\n16\t  // proxy itself sets after verification (or the explicit dev bypass).\n17\t  const requestHeaders = new Headers(request.headers);\n18\t  requestHeaders.delete(VERIFIED_ACCESS_EMAIL_HEADER);\n19\t\n20\t  if (isDevelopment) {\n21\t    const devEmail = process.env.PEEK_DEV_ACCESS_EMAIL?.trim().toLowerCase();\n22\t    if (devEmail && DEV_BYPASS_EMAIL_PATTERN.test(devEmail)) {\n23\t      requestHeaders.set(VERIFIED_ACCESS_EMAIL_HEADER, devEmail);\n24\t      return NextResponse.next({\n25\t        request: { headers: requestHeaders },\n26\t      });\n27\t    }\n28\t  }\n29\t\n30\t  if (!teamDomain || !audience) {\n31\t    if (isDevelopment) {\n32\t      return NextResponse.next({\n33\t        request: { headers: requestHeaders },\n34\t      });\n35\t    }\n36\t\n37\t    return new NextResponse(\"Cloudflare Access is not configured\", {\n38\t      status: 500,\n39\t    });\n40\t  }\n41\t\n42\t  const verification = await verifyCloudflareAccessJwt(\n43\t    request.headers.get(\"cf-access-jwt-assertion\"),\n44\t    {\n45\t      audience,\n46\t      teamDomain,\n47\t    },\n48\t  );\n49\t\n50\t  if (!verification.ok) {\n51\t    return new NextResponse(\"Cloudflare Access required\", { status: 403 });\n52\t  }\n53\t\n54\t  if (verification.email) {\n55\t    requestHeaders.set(VERIFIED_ACCESS_EMAIL_HEADER, verification.email);\n56\t  }\n57\t\n58\t  return NextResponse.next({\n59\t    request: {\n60\t      headers: requestHeaders,\n61\t    },\n62\t  });\n63\t}\n64\t\n65\texport const config = {\n66\t  matcher: [\"/((?!_next/static|_next/image|favicon.ico).*)\"],\n67\t};\n68\t"}]},"parent_tool_use_id":null,"session_id":"e55c3bab-e2c0-4dc4-9431-fc752babc2b2","uuid":"9ef20118-f0ed-4e5c-a013-47e4647e13a6","timestamp":"2026-04-26T07:51:39.871Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/proxy.ts","content":"import { NextResponse, type NextRequest } from \"next/server\";\nimport {\n  VERIFIED_ACCESS_EMAIL_HEADER,\n  verifyCloudflareAccessJwt,\n} from \"./src/server/cloudflare-access\";\n\nconst DEV_BYPASS_EMAIL_PATTERN = /^[^\\s@]+@[^\\s@]+$/;\n\nexport async function proxy(request: NextRequest) {\n  const teamDomain = process.env.CF_ACCESS_TEAM_DOMAIN?.trim();\n  const audience = process.env.CF_ACCESS_AUD?.trim();\n  const isDevelopment = process.env.NODE_ENV === \"development\";\n\n  // Strip any browser-supplied verified-email header before any branch can\n  // forward the request: server context must only ever see the value that the\n  // proxy itself sets after verification (or the explicit dev bypass).\n  const requestHeaders = new Headers(request.headers);\n  requestHeaders.delete(VERIFIED_ACCESS_EMAIL_HEADER);\n\n  if (isDevelopment) {\n    const devEmail = process.env.PEEK_DEV_ACCESS_EMAIL?.trim().toLowerCase();\n    if (devEmail && DEV_BYPASS_EMAIL_PATTERN.test(devEmail)) {\n      requestHeaders.set(VERIFIED_ACCESS_EMAIL_HEADER, devEmail);\n      return NextResponse.next({\n        request: { headers: requestHeaders },\n      });\n    }\n  }\n\n  if (!teamDomain || !audience) {\n    if (isDevelopment) {\n      return NextResponse.next({\n        request: { headers: requestHeaders },\n      });\n    }\n\n    return new NextResponse(\"Cloudflare Access is not configured\", {\n      status: 500,\n    });\n  }\n\n  const verification = await verifyCloudflareAccessJwt(\n    request.headers.get(\"cf-access-jwt-assertion\"),\n    {\n      audience,\n      teamDomain,\n    },\n  );\n\n  if (!verification.ok) {\n    return new NextResponse(\"Cloudflare Access required\", { status: 403 });\n  }\n\n  if (verification.email) {\n    requestHeaders.set(VERIFIED_ACCESS_EMAIL_HEADER, verification.email);\n  }\n\n  return NextResponse.next({\n    request: {\n      headers: requestHeaders,\n    },\n  });\n}\n\nexport const config = {\n  matcher: [\"/((?!_next/static|_next/image|favicon.ico).*)\"],\n};\n","numLines":68,"startLine":1,"totalLines":68}}}
