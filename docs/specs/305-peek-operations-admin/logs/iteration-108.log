{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01L8pymk52Mur2pyAPyhGxag","type":"tool_result","content":"1\t// Server-side export runner (FR-12).\n2\t//\n3\t// Orchestrates a single CSV export end to end:\n4\t//   1. Look up the approved exporter for the requested entity.\n5\t//   2. Refuse \"no filter\" exports when the exporter requires at least one\n6\t//      filter (avoids unfiltered full-table dumps per FR-12).\n7\t//   3. Refuse the export in production when audit logging is not configured\n8\t//      (\"Exports are disabled in production if audit logging is not\n9\t//      configured.\" — FR-12 last bullet).\n10\t//   4. Compute an effective row cap bounded by the per-entity ceiling\n11\t//      (`maxRowsPerExport`) and the global default (`PEEK_EXPORT_ROW_CAP_DEFAULT`).\n12\t//   5. Invoke the exporter's `fetch` to build the view-model rows.\n13\t//   6. Emit a `peek.export` audit event BEFORE returning the rows. If audit\n14\t//      emission fails, refuse to return the rows so we never serve data we\n15\t//      could not record.\n16\t//\n17\t// The runner is dependency-injectable for tests: callers can pass a mock\n18\t// `Sql`, a custom registry, a custom audit emitter, and a custom env.\n19\t\n20\timport type { Sql } from \"postgres\";\n21\timport {\n22\t  PEEK_EXPORT_ROW_CAP_DEFAULT,\n23\t  type PeekExportEntity,\n24\t  type PeekExportResult,\n25\t} from \"../../lib/types/peek\";\n26\timport {\n27\t  writePeekAuditEvent,\n28\t  type PeekAuditWriteResult,\n29\t} from \"../audit/writer\";\n30\timport { getSqlClient } from \"../db/client\";\n31\timport { buildPeekExportFilename } from \"./filename\";\n32\timport {\n33\t  getPeekExporter,\n34\t  PEEK_EXPORTERS,\n35\t  type PeekExporterDefinition,\n36\t  type PeekExporterFilters,\n37\t  type PeekExporterRegistry,\n38\t} from \"./registry\";\n39\t\n40\texport type PeekExportFailureReason =\n41\t  | \"unknown_entity\"\n42\t  | \"no_filters\"\n43\t  | \"audit_unavailable\"\n44\t  | \"audit_emit_failed\";\n45\t\n46\texport type PeekExportRunResult =\n47\t  | { ok: true; result: PeekExportResult }\n48\t  | { ok: false; reason: PeekExportFailureReason; message: string };\n49\t\n50\texport type PeekExportActorContext = {\n51\t  email: string;\n52\t  route: string | null;\n53\t  requestId?: string | null;\n54\t};\n55\t\n56\texport type PeekExportAuditWriter = (\n57\t  input: Parameters<typeof writePeekAuditEvent>[0],\n58\t  options?: Parameters<typeof writePeekAuditEvent>[1],\n59\t) => Promise<PeekAuditWriteResult>;\n60\t\n61\texport type PeekExportRunInput = {\n62\t  entity: PeekExportEntity;\n63\t  filters?: PeekExporterFilters;\n64\t  rowCap?: number;\n65\t  actor: PeekExportActorContext;\n66\t  now?: Date;\n67\t  sql?: Sql;\n68\t  registry?: PeekExporterRegistry;\n69\t  auditWriter?: PeekExportAuditWriter;\n70\t  env?: NodeJS.ProcessEnv;\n71\t};\n72\t\n73\t// Production gate: exports refuse to run when audit logging cannot be\n74\t// configured. The audit writer reads `DATABASE_URL` via `getSqlClient` so the\n75\t// \"configured\" signal is the same env var that would let the writer connect.\n76\texport function isPeekAuditConfigured(\n77\t  env: NodeJS.ProcessEnv = process.env,\n78\t): boolean {\n79\t  const url = env.DATABASE_URL;\n80\t  return typeof url === \"string\" && url.length > 0;\n81\t}\n82\t\n83\tfunction isProduction(env: NodeJS.ProcessEnv): boolean {\n84\t  return env.NODE_ENV === \"production\";\n85\t}\n86\t\n87\tfunction hasAnyFilter(filters: PeekExporterFilters): boolean {\n88\t  for (const value of Object.values(filters)) {\n89\t    if (value !== null && value !== undefined && value !== \"\") return true;\n90\t  }\n91\t  return false;\n92\t}\n93\t\n94\tfunction clampRowCap(\n95\t  raw: number | undefined,\n96\t  perEntityMax: number,\n97\t): number {\n98\t  const ceiling = Math.max(1, Math.min(perEntityMax, PEEK_EXPORT_ROW_CAP_DEFAULT));\n99\t  if (typeof raw !== \"number\" || !Number.isFinite(raw) || raw <= 0) {\n100\t    return ceiling;\n101\t  }\n102\t  return Math.min(ceiling, Math.floor(raw));\n103\t}\n104\t\n105\tfunction summarizeFilters(filters: PeekExporterFilters): string | null {\n106\t  const entries = Object.entries(filters)\n107\t    .filter(\n108\t      ([, value]) => value !== null && value !== undefined && value !== \"\",\n109\t    )\n110\t    .map(([key, value]) => `${key}=${value as string}`);\n111\t  return entries.length > 0 ? entries.join(\", \") : null;\n112\t}\n113\t\n114\tfunction todayDateString(now: Date): string {\n115\t  return now.toISOString().slice(0, 10);\n116\t}\n117\t\n118\tasync function emitExportAudit(\n119\t  exporter: PeekExporterDefinition,\n120\t  input: PeekExportRunInput,\n121\t  filters: PeekExporterFilters,\n122\t  resultCount: number,\n123\t  sql: Sql,\n124\t): Promise<PeekAuditWriteResult> {\n125\t  const writer = input.auditWriter ?? writePeekAuditEvent;\n126\t  return writer(\n127\t    {\n128\t      eventType: \"peek.export\",\n129\t      payload: {\n130\t        actorEmail: input.actor.email,\n131\t        route: input.actor.route ?? null,\n132\t        actionId: `export.${exporter.entity}`,\n133\t        resourceType: exporter.resourceType,\n134\t        resourceId: null,\n135\t        filterSummary: summarizeFilters(filters),\n136\t        resultCount,\n137\t        requestId: input.actor.requestId ?? null,\n138\t        rejectionReason: null,\n139\t        changes: null,\n140\t      },\n141\t    },\n142\t    { sql },\n143\t  );\n144\t}\n145\t\n146\texport async function runPeekExport(\n147\t  input: PeekExportRunInput,\n148\t): Promise<PeekExportRunResult> {\n149\t  const env = input.env ?? process.env;\n150\t  const registry = input.registry ?? PEEK_EXPORTERS;\n151\t  const exporter = getPeekExporter(input.entity, registry);\n152\t  if (!exporter) {\n153\t    return {\n154\t      ok: false,\n155\t      reason: \"unknown_entity\",\n156\t      message: `No approved peek exporter for entity \"${input.entity}\".`,\n157\t    };\n158\t  }\n159\t\n160\t  const filters = input.filters ?? {};\n161\t\n162\t  if (exporter.requireAtLeastOneFilter && !hasAnyFilter(filters)) {\n163\t    return {\n164\t      ok: false,\n165\t      reason: \"no_filters\",\n166\t      message: `Export \"${input.entity}\" requires at least one filter.`,\n167\t    };\n168\t  }\n169\t\n170\t  if (isProduction(env) && !isPeekAuditConfigured(env)) {\n171\t    return {\n172\t      ok: false,\n173\t      reason: \"audit_unavailable\",\n174\t      message:\n175\t        'Exports are disabled in production when audit logging is not configured.',\n176\t    };\n177\t  }\n178\t\n179\t  const rowCap = clampRowCap(input.rowCap, exporter.maxRowsPerExport);\n180\t  const sql = input.sql ?? (getSqlClient() as unknown as Sql);\n181\t  const now = input.now ?? new Date();\n182\t\n183\t  const fetchResult = await exporter.fetch({ sql, rowCap, filters });\n184\t\n185\t  const auditResult = await emitExportAudit(\n186\t    exporter,\n187\t    input,\n188\t    filters,\n189\t    fetchResult.rows.length,\n190\t    sql,\n191\t  );\n192\t  if (!auditResult.ok) {\n193\t    return {\n194\t      ok: false,\n195\t      reason: \"audit_emit_failed\",\n196\t      message: `Audit emission failed (${auditResult.reason}); refusing to return export rows.`,\n197\t    };\n198\t  }\n199\t\n200\t  const filename = buildPeekExportFilename({\n201\t    entity: exporter.entity,\n202\t    date: todayDateString(now),\n203\t    filterSlug: exporter.buildFilterSlug(filters),\n204\t  });\n205\t\n206\t  return {\n207\t    ok: true,\n208\t    result: {\n209\t      filename,\n210\t      rowCount: fetchResult.rows.length,\n211\t      rowCap,\n212\t      rowCapApplied: fetchResult.rowCapApplied,\n213\t      columns: exporter.columns,\n214\t      rows: fetchResult.rows,\n215\t    },\n216\t  };\n217\t}\n218\t"}]},"parent_tool_use_id":null,"session_id":"e55c3bab-e2c0-4dc4-9431-fc752babc2b2","uuid":"6d2cf15f-d4ca-4939-ba3f-73bf9284fe6c","timestamp":"2026-04-26T07:50:36.323Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/exports/runner.ts","content":"// Server-side export runner (FR-12).\n//\n// Orchestrates a single CSV export end to end:\n//   1. Look up the approved exporter for the requested entity.\n//   2. Refuse \"no filter\" exports when the exporter requires at least one\n//      filter (avoids unfiltered full-table dumps per FR-12).\n//   3. Refuse the export in production when audit logging is not configured\n//      (\"Exports are disabled in production if audit logging is not\n//      configured.\" — FR-12 last bullet).\n//   4. Compute an effective row cap bounded by the per-entity ceiling\n//      (`maxRowsPerExport`) and the global default (`PEEK_EXPORT_ROW_CAP_DEFAULT`).\n//   5. Invoke the exporter's `fetch` to build the view-model rows.\n//   6. Emit a `peek.export` audit event BEFORE returning the rows. If audit\n//      emission fails, refuse to return the rows so we never serve data we\n//      could not record.\n//\n// The runner is dependency-injectable for tests: callers can pass a mock\n// `Sql`, a custom registry, a custom audit emitter, and a custom env.\n\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_EXPORT_ROW_CAP_DEFAULT,\n  type PeekExportEntity,\n  type PeekExportResult,\n} from \"../../lib/types/peek\";\nimport {\n  writePeekAuditEvent,\n  type PeekAuditWriteResult,\n} from \"../audit/writer\";\nimport { getSqlClient } from \"../db/client\";\nimport { buildPeekExportFilename } from \"./filename\";\nimport {\n  getPeekExporter,\n  PEEK_EXPORTERS,\n  type PeekExporterDefinition,\n  type PeekExporterFilters,\n  type PeekExporterRegistry,\n} from \"./registry\";\n\nexport type PeekExportFailureReason =\n  | \"unknown_entity\"\n  | \"no_filters\"\n  | \"audit_unavailable\"\n  | \"audit_emit_failed\";\n\nexport type PeekExportRunResult =\n  | { ok: true; result: PeekExportResult }\n  | { ok: false; reason: PeekExportFailureReason; message: string };\n\nexport type PeekExportActorContext = {\n  email: string;\n  route: string | null;\n  requestId?: string | null;\n};\n\nexport type PeekExportAuditWriter = (\n  input: Parameters<typeof writePeekAuditEvent>[0],\n  options?: Parameters<typeof writePeekAuditEvent>[1],\n) => Promise<PeekAuditWriteResult>;\n\nexport type PeekExportRunInput = {\n  entity: PeekExportEntity;\n  filters?: PeekExporterFilters;\n  rowCap?: number;\n  actor: PeekExportActorContext;\n  now?: Date;\n  sql?: Sql;\n  registry?: PeekExporterRegistry;\n  auditWriter?: PeekExportAuditWriter;\n  env?: NodeJS.ProcessEnv;\n};\n\n// Production gate: exports refuse to run when audit logging cannot be\n// configured. The audit writer reads `DATABASE_URL` via `getSqlClient` so the\n// \"configured\" signal is the same env var that would let the writer connect.\nexport function isPeekAuditConfigured(\n  env: NodeJS.ProcessEnv = process.env,\n): boolean {\n  const url = env.DATABASE_URL;\n  return typeof url === \"string\" && url.length > 0;\n}\n\nfunction isProduction(env: NodeJS.ProcessEnv): boolean {\n  return env.NODE_ENV === \"production\";\n}\n\nfunction hasAnyFilter(filters: PeekExporterFilters): boolean {\n  for (const value of Object.values(filters)) {\n    if (value !== null && value !== undefined && value !== \"\") return true;\n  }\n  return false;\n}\n\nfunction clampRowCap(\n  raw: number | undefined,\n  perEntityMax: number,\n): number {\n  const ceiling = Math.max(1, Math.min(perEntityMax, PEEK_EXPORT_ROW_CAP_DEFAULT));\n  if (typeof raw !== \"number\" || !Number.isFinite(raw) || raw <= 0) {\n    return ceiling;\n  }\n  return Math.min(ceiling, Math.floor(raw));\n}\n\nfunction summarizeFilters(filters: PeekExporterFilters): string | null {\n  const entries = Object.entries(filters)\n    .filter(\n      ([, value]) => value !== null && value !== undefined && value !== \"\",\n    )\n    .map(([key, value]) => `${key}=${value as string}`);\n  return entries.length > 0 ? entries.join(\", \") : null;\n}\n\nfunction todayDateString(now: Date): string {\n  return now.toISOString().slice(0, 10);\n}\n\nasync function emitExportAudit(\n  exporter: PeekExporterDefinition,\n  input: PeekExportRunInput,\n  filters: PeekExporterFilters,\n  resultCount: number,\n  sql: Sql,\n): Promise<PeekAuditWriteResult> {\n  const writer = input.auditWriter ?? writePeekAuditEvent;\n  return writer(\n    {\n      eventType: \"peek.export\",\n      payload: {\n        actorEmail: input.actor.email,\n        route: input.actor.route ?? null,\n        actionId: `export.${exporter.entity}`,\n        resourceType: exporter.resourceType,\n        resourceId: null,\n        filterSummary: summarizeFilters(filters),\n        resultCount,\n        requestId: input.actor.requestId ?? null,\n        rejectionReason: null,\n        changes: null,\n      },\n    },\n    { sql },\n  );\n}\n\nexport async function runPeekExport(\n  input: PeekExportRunInput,\n): Promise<PeekExportRunResult> {\n  const env = input.env ?? process.env;\n  const registry = input.registry ?? PEEK_EXPORTERS;\n  const exporter = getPeekExporter(input.entity, registry);\n  if (!exporter) {\n    return {\n      ok: false,\n      reason: \"unknown_entity\",\n      message: `No approved peek exporter for entity \"${input.entity}\".`,\n    };\n  }\n\n  const filters = input.filters ?? {};\n\n  if (exporter.requireAtLeastOneFilter && !hasAnyFilter(filters)) {\n    return {\n      ok: false,\n      reason: \"no_filters\",\n      message: `Export \"${input.entity}\" requires at least one filter.`,\n    };\n  }\n\n  if (isProduction(env) && !isPeekAuditConfigured(env)) {\n    return {\n      ok: false,\n      reason: \"audit_unavailable\",\n      message:\n        'Exports are disabled in production when audit logging is not configured.',\n    };\n  }\n\n  const rowCap = clampRowCap(input.rowCap, exporter.maxRowsPerExport);\n  const sql = input.sql ?? (getSqlClient() as unknown as Sql);\n  const now = input.now ?? new Date();\n\n  const fetchResult = await exporter.fetch({ sql, rowCap, filters });\n\n  const auditResult = await emitExportAudit(\n    exporter,\n    input,\n    filters,\n    fetchResult.rows.length,\n    sql,\n  );\n  if (!auditResult.ok) {\n    return {\n      ok: false,\n      reason: \"audit_emit_failed\",\n      message: `Audit emission failed (${auditResult.reason}); refusing to return export rows.`,\n    };\n  }\n\n  const filename = buildPeekExportFilename({\n    entity: exporter.entity,\n    date: todayDateString(now),\n    filterSlug: exporter.buildFilterSlug(filters),\n  });\n\n  return {\n    ok: true,\n    result: {\n      filename,\n      rowCount: fetchResult.rows.length,\n      rowCap,\n      rowCapApplied: fetchResult.rowCapApplied,\n      columns: exporter.columns,\n      rows: fetchResult.rows,\n    },\n  };\n}\n","numLines":218,"startLine":1,"totalLines":218}}}
