"\",\n49\t    wallet: row.wallet,\n50\t    rateBps: row.rateBps.toString(),\n51\t    setBy: row.setBy,\n52\t    createdAt: row.createdAt,\n53\t    updatedAt: row.updatedAt,\n54\t    refereeCount: row.refereeCount.toString(),\n55\t    referredWagerLamports: row.referredWagerLamports,\n56\t    referrerEarnedLamports: row.referrerEarnedLamports,\n57\t  };\n58\t}\n59\t\n60\texport const KOL_EXPORTER: PeekExporterDefinition = {\n61\t  entity: \"kol\",\n62\t  resourceType: \"referral_kol_rate\",\n63\t  columns: KOL_COLUMNS,\n64\t  maxRowsPerExport: PEEK_GROWTH_KOL_MAX_LIMIT,\n65\t  requireAtLeastOneFilter: false,\n66\t  async fetch(ctx) {\n67\t    const rows = await listKolPerformance({\n68\t      sql: ctx.sql,\n69\t      limit: ctx.rowCap + 1,\n70\t    });\n71\t    const rowCapApplied = rows.length > ctx.rowCap;\n72\t    const trimmed = rowCapApplied ? rows.slice(0, ctx.rowCap) : rows;\n73\t    return {\n74\t      rows: trimmed.map(rowToCsv),\n75\t      rowCapApplied,\n76\t    };\n77\t  },\n78\t  buildFilterSlug() {\n79\t    return \"\";\n80\t  },\n81\t};\n82\t"}]},"parent_tool_use_id":null,"session_id":"e55c3bab-e2c0-4dc4-9431-fc752babc2b2","uuid":"01de1255-9a98-4f1b-8708-2d4899d7eefd","timestamp":"2026-04-26T07:50:48.194Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/exports/exporters/kol.ts","content":"// KOL performance exporter (FR-7, FR-12).\n//\n// Backs the `kol` export entity used by `/growth/kol`. Like the top-referrers\n// exporter, the underlying query is a bounded-by-default ranked list keyed by\n// `referral_kol_rates`, so `requireAtLeastOneFilter` is `false`.\n\nimport {\n  listKolPerformance,\n  PEEK_GROWTH_KOL_MAX_LIMIT,\n} from \"../../db/queries/get-growth-referrals\";\nimport type {\n  PeekKolPerformanceRow,\n  PeekTableColumn,\n} from \"../../../lib/types/peek\";\nimport type { PeekExporterDefinition } from \"../registry\";\n\nconst KOL_COLUMNS: ReadonlyArray<PeekTableColumn> = [\n  { id: \"userId\", label: \"User id\", align: \"left\", sortable: false },\n  { id: \"username\", label: \"Username\", align: \"left\", sortable: false },\n  { id: \"wallet\", label: \"Wallet\", align: \"left\", sortable: false },\n  { id: \"rateBps\", label: \"Rate (bps)\", align: \"right\", sortable: false },\n  { id: \"setBy\", label: \"Set by\", align: \"left\", sortable: false },\n  { id: \"createdAt\", label: \"Created\", align: \"left\", sortable: false },\n  { id: \"updatedAt\", label: \"Updated\", align: \"left\", sortable: false },\n  {\n    id: \"refereeCount\",\n    label: \"Referees\",\n    align: \"right\",\n    sortable: false,\n  },\n  {\n    id: \"referredWagerLamports\",\n    label: \"Referred wager (lamports)\",\n    align: \"right\",\n    sortable: false,\n  },\n  {\n    id: \"referrerEarnedLamports\",\n    label: \"Referrer earned (lamports)\",\n    align: \"right\",\n    sortable: false,\n  },\n];\n\nfunction rowToCsv(row: PeekKolPerformanceRow): Record<string, string> {\n  return {\n    userId: row.userId,\n    username: row.username ?? \"\",\n    wallet: row.wallet,\n    rateBps: row.rateBps.toString(),\n    setBy: row.setBy,\n    createdAt: row.createdAt,\n    updatedAt: row.updatedAt,\n    refereeCount: row.refereeCount.toString(),\n    referredWagerLamports: row.referredWagerLamports,\n    referrerEarnedLamports: row.referrerEarnedLamports,\n  };\n}\n\nexport const KOL_EXPORTER: PeekExporterDefinition = {\n  entity: \"kol\",\n  resourceType: \"referral_kol_rate\",\n  columns: KOL_COLUMNS,\n  maxRowsPerExport: PEEK_GROWTH_KOL_MAX_LIMIT,\n  requireAtLeastOneFilter: false,\n  async fetch(ctx) {\n    const rows = await listKolPerformance({\n      sql: ctx.sql,\n      limit: ctx.rowCap + 1,\n    });\n    const rowCapApplied = rows.length > ctx.rowCap;\n    const trimmed = rowCapApplied ? rows.slice(0, ctx.rowCap) : rows;\n    return {\n      rows: trimmed.map(rowToCsv),\n      rowCapApplied,\n    };\n  },\n  buildFilterSlug() {\n    return \"\";\n  },\n};\n","numLines":82,"startLine":1,"totalLines":82}}}
