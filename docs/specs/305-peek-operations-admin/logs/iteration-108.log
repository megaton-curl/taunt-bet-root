{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016NqHnYjsf8QFWsDEzXLWpE","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/server/exports/__tests__/source-routes.test.ts"}]},"parent_tool_use_id":null,"session_id":"e55c3bab-e2c0-4dc4-9431-fc752babc2b2","uuid":"6b0d45c4-99e6-4c6e-9912-a70027002949","timestamp":"2026-04-26T07:54:02.352Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/server/exports/__tests__/source-routes.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport {\n  PEEK_EXPORT_SOURCE_ROUTES,\n  getSourceRouteForExportEntity,\n} from \"../source-routes\";\nimport type { PeekExportEntity } from \"../../../lib/types/peek\";\n\ndescribe(\"getSourceRouteForExportEntity\", () => {\n  it(\"maps approved entities to their /growth/* source pages\", () => {\n    expect(getSourceRouteForExportEntity(\"referrers\")).toBe(\"/growth/referrals\");\n    expect(getSourceRouteForExportEntity(\"kol\")).toBe(\"/growth/kol\");\n    expect(getSourceRouteForExportEntity(\"claims\")).toBe(\"/growth/referrals\");\n  });\n\n  it(\"returns null for entities whose source pages are not yet built (fail closed)\", () => {\n    const unwiredEntities: ReadonlyArray<PeekExportEntity> = [\n      \"users\",\n      \"rounds\",\n      \"transactions\",\n      \"queue\",\n      \"audit\",\n    ];\n    for (const entity of unwiredEntities) {\n      expect(getSourceRouteForExportEntity(entity)).toBeNull();\n    }\n  });\n\n  it(\"includes every PeekExportEntity in PEEK_EXPORT_SOURCE_ROUTES\", () => {\n    const allKnown: ReadonlyArray<PeekExportEntity> = [\n      \"users\",\n      \"referrers\",\n      \"kol\",\n      \"claims\",\n      \"rounds\",\n      \"transactions\",\n      \"queue\",\n      \"audit\",\n    ];\n    for (const entity of allKnown) {\n      expect(entity in PEEK_EXPORT_SOURCE_ROUTES).toBe(true);\n    }\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
