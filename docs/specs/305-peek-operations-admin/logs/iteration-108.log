et: row.wallet,\n    amountLamports: row.amountLamports,\n    status: row.status,\n    retryCount: row.retryCount.toString(),\n    txSignature: row.txSignature ?? \"\",\n    requestedAt: row.requestedAt,\n    processedAt: row.processedAt ?? \"\",\n    error: row.error ?? \"\",\n  };\n}\n\nexport const CLAIMS_EXPORTER: PeekExporterDefinition = {\n  entity: \"claims\",\n  resourceType: \"referral_claim\",\n  columns: CLAIM_COLUMNS,\n  maxRowsPerExport: PEEK_GROWTH_CLAIMS_MAX_LIMIT,\n  requireAtLeastOneFilter: true,\n  async fetch(ctx) {\n    const filters = pickClaimFilters(ctx.filters);\n    // Request rowCap + 1 so the runner can detect that the cap was the limiter\n    // (rather than the underlying SQL exhausting). The query module clamps to\n    // its own MAX, but `maxRowsPerExport` already keeps `rowCap` ≤ that max.\n    const rows = await listReferralClaims({\n      sql: ctx.sql,\n      limit: ctx.rowCap + 1,\n      filters,\n    });\n    const rowCapApplied = rows.length > ctx.rowCap;\n    const trimmed = rowCapApplied ? rows.slice(0, ctx.rowCap) : rows;\n    return {\n      rows: trimmed.map(rowToCsv),\n      rowCapApplied,\n    };\n  },\n  buildFilterSlug(filters) {\n    const parts: string[] = [];\n    if (filters.status) parts.push(`status-${slugForFilename(filters.status)}`);\n    if (filters.userId) parts.push(`user-${slugForFilename(filters.userId)}`);\n    if (filters.txSignature) {\n      parts.push(`tx-${slugForFilename(filters.txSignature).slice(0, 12)}`);\n    }\n    if (filters.minAmountLamports) {\n      parts.push(`min-${slugForFilename(filters.minAmountLamports)}`);\n    }\n    if (filters.maxAmountLamports) {\n      parts.push(`max-${slugForFilename(filters.maxAmountLamports)}`);\n    }\n    if (filters.requestedFrom) {\n      parts.push(`from-${slugForFilename(filters.requestedFrom).slice(0, 10)}`);\n    }\n    if (filters.requestedTo) {\n      parts.push(`to-${slugForFilename(filters.requestedTo).slice(0, 10)}`);\n    }\n    return parts.jo