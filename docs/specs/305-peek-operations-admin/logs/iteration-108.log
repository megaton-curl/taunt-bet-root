{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N28BCrkZGiCPohhubS6GS9","type":"tool_result","content":"1\timport { afterEach, describe, expect, it, vi } from \"vitest\";\n2\timport {\n3\t  getPeekActorContext,\n4\t  getRequiredRolesForAction,\n5\t  getRequiredRolesForRoute,\n6\t  isActionAllowedForRole,\n7\t  isRouteAllowedForRole,\n8\t  loadPeekRolePolicyFromEnv,\n9\t  normalizeActorEmail,\n10\t  parsePeekRolePolicy,\n11\t  PEEK_ACTION_RULES,\n12\t  PEEK_DEFAULT_ROUTE_ROLES,\n13\t  PEEK_ROUTE_RULES,\n14\t  resolveRoleForEmail,\n15\t  type PeekActionRule,\n16\t  type PeekRolePolicy,\n17\t  type PeekRouteRule,\n18\t} from \"../access-policy\";\n19\timport { VERIFIED_ACCESS_EMAIL_HEADER } from \"../cloudflare-access\";\n20\t\n21\tconst mockHeaders = vi.fn();\n22\tvi.mock(\"next/headers\", () => ({\n23\t  headers: () => mockHeaders(),\n24\t}));\n25\t\n26\tfunction makeHeaders(map: Record<string, string>): Headers {\n27\t  const h = new Headers();\n28\t  for (const [k, v] of Object.entries(map)) h.set(k, v);\n29\t  return h;\n30\t}\n31\t\n32\tdescribe(\"parsePeekRolePolicy\", () => {\n33\t  it(\"returns [] for non-array input\", () => {\n34\t    expect(parsePeekRolePolicy(null)).toEqual([]);\n35\t    expect(parsePeekRolePolicy(undefined)).toEqual([]);\n36\t    expect(parsePeekRolePolicy(\"oops\")).toEqual([]);\n37\t    expect(parsePeekRolePolicy({ match: \"x@y.z\", role: \"admin\" })).toEqual([]);\n38\t  });\n39\t\n40\t  it(\"normalizes match values: trims and lowercases\", () => {\n41\t    expect(\n42\t      parsePeekRolePolicy([\n43\t        { match: \"  Alice@Example.COM \", role: \"admin\" },\n44\t        { match: \"*@Example.COM\", role: \"business\" },\n45\t      ]),\n46\t    ).toEqual([\n47\t      { match: \"alice@example.com\", role: \"admin\" },\n48\t      { match: \"*@example.com\", role: \"business\" },\n49\t    ]);\n50\t  });\n51\t\n52\t  it(\"drops entries with invalid roles\", () => {\n53\t    expect(\n54\t      parsePeekRolePolicy([\n55\t        { match: \"a@b.c\", role: \"owner\" },\n56\t        { match: \"a@b.c\", role: null },\n57\t        { match: \"a@b.c\", role: \"admin\" },\n58\t      ]),\n59\t    ).toEqual([{ match: \"a@b.c\", role: \"admin\" }]);\n60\t  });\n61\t\n62\t  it(\"drops entries missing match or with non-string match\", () => {\n63\t    expect(\n64\t      parsePeekRolePolicy([\n65\t        { role: \"admin\" },\n66\t        { match: 42, role: \"admin\" },\n67\t        { match: \"\", role: \"admin\" },\n68\t        { match: \"   \", role: \"admin\" },\n69\t        { match: \"valid@a.b\", role: \"admin\" },\n70\t      ]),\n71\t    ).toEqual([{ match: \"valid@a.b\", role: \"admin\" }]);\n72\t  });\n73\t\n74\t  it(\"drops entries with malformed wildcard domains\", () => {\n75\t    expect(\n76\t      parsePeekRolePolicy([\n77\t        { match: \"*@\", role: \"admin\" },\n78\t        { match: \"*@*.com\", role: \"admin\" },\n79\t        { match: \"*@with space.com\", role: \"admin\" },\n80\t        { match: \"*@ok.com\", role: \"admin\" },"}]},"parent_tool_use_id":null,"session_id":"e55c3bab-e2c0-4dc4-9431-fc752babc2b2","uuid":"37faa9cd-d721-4c65-ac39-5748e2e2b7ed","timestamp":"2026-04-26T07:54:09.528Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/__tests__/access-policy.test.ts","content":"import { afterEach, describe, expect, it, vi } from \"vitest\";\nimport {\n  getPeekActorContext,\n  getRequiredRolesForAction,\n  getRequiredRolesForRoute,\n  isActionAllowedForRole,\n  isRouteAllowedForRole,\n  loadPeekRolePolicyFromEnv,\n  normalizeActorEmail,\n  parsePeekRolePolicy,\n  PEEK_ACTION_RULES,\n  PEEK_DEFAULT_ROUTE_ROLES,\n  PEEK_ROUTE_RULES,\n  resolveRoleForEmail,\n  type PeekActionRule,\n  type PeekRolePolicy,\n  type PeekRouteRule,\n} from \"../access-policy\";\nimport { VERIFIED_ACCESS_EMAIL_HEADER } from \"../cloudflare-access\";\n\nconst mockHeaders = vi.fn();\nvi.mock(\"next/headers\", () => ({\n  headers: () => mockHeaders(),\n}));\n\nfunction makeHeaders(map: Record<string, string>): Headers {\n  const h = new Headers();\n  for (const [k, v] of Object.entries(map)) h.set(k, v);\n  return h;\n}\n\ndescribe(\"parsePeekRolePolicy\", () => {\n  it(\"returns [] for non-array input\", () => {\n    expect(parsePeekRolePolicy(null)).toEqual([]);\n    expect(parsePeekRolePolicy(undefined)).toEqual([]);\n    expect(parsePeekRolePolicy(\"oops\")).toEqual([]);\n    expect(parsePeekRolePolicy({ match: \"x@y.z\", role: \"admin\" })).toEqual([]);\n  });\n\n  it(\"normalizes match values: trims and lowercases\", () => {\n    expect(\n      parsePeekRolePolicy([\n        { match: \"  Alice@Example.COM \", role: \"admin\" },\n        { match: \"*@Example.COM\", role: \"business\" },\n      ]),\n    ).toEqual([\n      { match: \"alice@example.com\", role: \"admin\" },\n      { match: \"*@example.com\", role: \"business\" },\n    ]);\n  });\n\n  it(\"drops entries with invalid roles\", () => {\n    expect(\n      parsePeekRolePolicy([\n        { match: \"a@b.c\", role: \"owner\" },\n        { match: \"a@b.c\", role: null },\n        { match: \"a@b.c\", role: \"admin\" },\n      ]),\n    ).toEqual([{ match: \"a@b.c\", role: \"admin\" }]);\n  });\n\n  it(\"drops entries missing match or with non-string match\", () => {\n    expect(\n      parsePeekRolePolicy([\n        { role: \"admin\" },\n        { match: 42, role: \"admin\" },\n        { match: \"\", role: \"admin\" },\n        { match: \"   \", role: \"admin\" },\n        { match: \"valid@a.b\", role: \"admin\" },\n      ]),\n    ).toEqual([{ match: \"valid@a.b\", role: \"admin\" }]);\n  });\n\n  it(\"drops entries with malformed wildcard domains\", () => {\n    expect(\n      parsePeekRolePolicy([\n        { match: \"*@\", role: \"admin\" },\n        { match: \"*@*.com\", role: \"admin\" },\n        { match: \"*@with space.com\", role: \"admin\" },\n        { match: \"*@ok.com\", role: \"admin\" },","numLines":80,"startLine":1,"totalLines":412}}}
