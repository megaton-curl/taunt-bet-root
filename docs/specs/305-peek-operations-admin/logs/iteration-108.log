{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01MquoQ8GPXhJMK6FRazEWyj","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FbuRa9zGGubuimvw4TKKZa","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/exports/__tests__/filename.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport {\n  buildPeekExportFilename,\n  slugForFilename,\n} from \"../filename\";\n\ndescribe(\"slugForFilename\", () => {\n  it(\"lowercases and replaces unsafe characters with dashes\", () => {\n    expect(slugForFilename(\"Status: Pending\")).toBe(\"status-pending\");\n  });\n\n  it(\"collapses repeated dashes and trims leading/trailing dashes\", () => {\n    expect(slugForFilename(\"---a   b___c---\")).toBe(\"a-b_c\");\n  });\n\n  it(\"returns an empty string for empty input\", () => {\n    expect(slugForFilename(\"\")).toBe(\"\");\n  });\n\n  it(\"strips path-traversal segments and reserved characters\", () => {\n    expect(slugForFilename(\"../../etc/passwd\")).toBe(\"etc-passwd\");\n    expect(slugForFilename(\".hidden\")).toBe(\"hidden\");\n    expect(slugForFilename(\"a/b\\\\c\\\"'\")).toBe(\"a-b-c\");\n  });\n\n  it(\"preserves digits, lowercase letters, underscores, and dashes\", () => {\n    expect(slugForFilename(\"user_42-abc\")).toBe(\"user_42-abc\");\n  });\n\n  it(\"handles unicode by replacing it with dashes\", () => {\n    expect(slugForFilename(\"café-µ\")).toBe(\"caf-\");\n  });\n});\n\ndescribe(\"buildPeekExportFilename\", () => {\n  it(\"emits peek-{entity}-{date}-{filterSlug}.csv\", () => {\n    expect(\n      buildPeekExportFilename({\n        entity: \"claims\",\n        date: \"2026-04-26\",\n        filterSlug: \"status-pending\",\n      }),\n    ).toBe(\"peek-claims-2026-04-26-status-pending.csv\");\n  });\n\n  it(\"omits the filter slug segment when empty\", () => {\n    expect(\n      buildPeekExportFilename({\n        entity: \"referrers\",\n        date: \"2026-04-26\",\n        filterSlug: \"\",\n      }),\n    ).toBe(\"peek-referrers-2026-04-26.csv\");\n  });\n\n  it(\"falls back to fixed segments when entity or date are blank\", () => {\n    expect(\n      buildPeekExportFilename({\n        entity: \"\" as never,\n        date: \"\",\n        filterSlug: \"x\",\n      }),\n    ).toBe(\"peek-export-undated-x.csv\");\n  });\n\n  it(\"includes the entity, the date, and the filter slug\", () => {\n    const filename = buildPeekExportFilename({\n      entity: \"kol\",\n      date: \"2026-04-26\",\n      filterSlug: \"rate-1500\",\n    });\n    expect(filename.startsWith(\"peek-kol-\")).toBe(true);\n    expect(filename).toContain(\"2026-04-26\");\n    expect(filename).toContain(\"rate-1500\");\n    expect(filename.endsWith(\".csv\")).toBe(true);\n  });\n\n  it(\"re-slugifies inputs so unsafe characters never reach the filename\", () => {\n    const filename = buildPeekExportFilename({\n      entity: \"claims\",\n      date: \"2026/04/26\",\n      filterSlug: 'status=\"pending\"',\n    });\n    expect(filename).not.toMatch(/[\"'/\\\\]/);\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2210,"cache_read_input_tokens":110327,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2210},"output_tokens":65,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"e55c3bab-e2c0-4dc4-9431-fc752babc2b2","uuid":"e905130a-1494-4903-bfde-9d293d28d8a3"}
