ue;\n    seen.add(dedupeKey);\n\n    entries.push({ match, role });\n  }\n\n  return entries;\n}\n\nexport function loadPeekRolePolicyFromEnv(): PeekRolePolicy {\n  const raw = process.env[PEEK_ACCESS_POLICY_ENV]?.trim();\n  if (!raw) return [];\n  let parsed: unknown;\n  try {\n    parsed = JSON.parse(raw);\n  } catch {\n    return [];\n  }\n  return parsePeekRolePolicy(parsed);\n}\n\nexport function normalizeActorEmail(value: string | null | undefined): string | null {\n  if (!value) return null;\n  const email = value.trim().toLowerCase();\n  if (!EMAIL_PATTERN.test(email)) return null;\n  return email;\n}\n\nexport function resolveRoleForEmail(\n  email: string | null | undefined,\n  policy: PeekRolePolicy,\n): PeekRole | null {\n  const normalized = normalizeActorEmail(email);\n  if (!normalized) return null;\n\n  const emailDomain = normalized.split(\"@\")[1] ?? \"\";\n\n  let resolved: PeekRole | null = null;\n\n  for (const entry of policy) {\n    const matched = entry.match.startsWith(\"*@\")\n      ? entry.match.slice(2) === emailDomain\n      : entry.match === normalized;\n    if (!matched) continue;\n\n    if (entry.role === \"admin\") {\n      return \"admin\";\n    }\n    if (!resolved) {\n      resolved = entry.role;\n    }\n  }\n\n  return resolved;\n}\n\nexport async function getPeekActorContext(): Promise<PeekActorContext | null> {\n  const requestHeaders = await headers();\n  const headerEmail = requestHeaders.get(VERIFIED_ACCESS_EMAIL_HEADER);\n  const email = normalizeActorEmail(headerEmail);\n  if (!email) return null;\n\n  const role = resolveRoleForEmail(email, loadPeekRolePolicyFromEnv());\n  if (!role) return null;\n\n  return { email, role };\n}\n\n// --- Route + action authorization (FR-2) -----------------------------------\n//\n// Page authorization is keyed by route prefix: the most specific prefix wins.\n// Mutation/action authorization is keyed by stable action id and fails closed\n// for unknown ids. Unknown route prefixes fall back to the documented default\n// (read-only — any resolved peek role), per System Invariant #6.\n\nexport type PeekRouteRule = {\n  prefix: string;\n  roles: ReadonlyArray<PeekRole>;\n};\n\nexport type PeekActionRule = {\n  actionId: string;\n  roles: ReadonlyArray<PeekRole>;\n};\n\nconst ALL_ROLES: ReadonlyArray<PeekRole> = [\"business\", \"admin\"];\n\n// Default for unknown routes: any resolved peek role (read-only access).\n// Sensitive routes must be enumerated below.\nexport const PEEK_DEFAULT_ROUTE_ROLES: ReadonlyArray<PeekRole> = ALL_ROLES;\n\nexport const PEEK_ROUTE_RULES: ReadonlyArray<PeekRouteRule> = [\n  { prefix: \"/audit\", roles: [\"admin\"] },\n];\n\nexport const PEEK_ACTION_RULES: ReadonlyArray<PeekActionRule> = [\n  { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n  { actionId: \"fraud_flag.status.update\", roles: [\"admin\"] },\n  { actionId: \"dogpile.cancel\", roles: [\"admin\"] },\n  { actionId: \"reward_config.update\", roles: [\"admin\"] },\n];\n\nfunction normalizeRoutePath(path: string): string {\n  if (!path) return \"/\";\n  const withoutQuery = path.split(\"?\")[0]?.split(\"#\")[0] ?? path;\n  if (!withoutQuery.startsWith(\"/\")) return `/${withoutQuery}`;\n  if (withoutQuery.length > 1 && withoutQuery.endsWith(\"/\")) {\n    return withoutQuery.slice(0, -1);\n  }\n  return withoutQuery;\n}\n\nfunction prefixMatches(prefix: string, path: string): boolean {\n  if (prefix === \"/\") return true;\n  if (path === prefix) return true;\n  return path.startsWith(`${prefix}/`);\n}\n\nexport function getRequiredRolesForRoute(\n  path: string,\n  rules: ReadonlyArray<PeekRouteRule> = PEEK_ROUTE_RULES,\n): ReadonlyArray<PeekRole> {\n  const normalized = normalizeRoutePath(path);\n  let best: PeekRouteRule | null = null;\n  for (const rule of rules) {\n    if (!prefixMatches(rule.prefix, normalized)) continue;\n    if (!best || rule.prefix.length > best.prefix.length) {\n      best = rule;\n    }\n  }\n  return best ? best.roles : PEEK_DEFAULT_ROUTE_ROLES;\n}\n\nexport function isRouteAllowedForRole(\n  path: string,\n  role: PeekRole | null | undefined,\n  rules: ReadonlyArray<PeekRouteRule> = PEEK_ROUTE_RULES,\n): boolean {\n  if (!role) return false;\n  return getRequiredRolesForRoute(path, rules).includes(role);\n}\n\nexport function getRequiredRolesForAction(\n  actionId: string,\n  rules: ReadonlyArray<PeekActionRule> = PEEK_ACTION_RULES,\n): ReadonlyArray<PeekRole> | null {\n  const rule = rules.find((entry) => entry.actionId === actionId);\n  return rule ? rule.roles : null;\n}\n\nexport function isActionAllowedForRole(\n  actionId: string,\n  role: PeekRole | null | undefined,\n  rules: ReadonlyArray<PeekActionRule> = PEEK_ACTION_RULES,\n): boolean {\n  if (!role) return false;\n  const required = getRequiredRolesForAction(actionId, rules);\n  if (!required) return false;\n  return required.includes(role);\n}\n","numLines":218,"startLine":1,"totalLines":218}}}
