 \"build\": \"next build\",\n    \"start\": \"next start\",\n    \"lint\": \"eslint .\",\n    \"typecheck\": \"tsc --noEmit -p tsconfig.typecheck.json\",\n    \"test:watch\": \"vitest\",\n    \"test:e2e\": \"playwright test\",\n    \"verify\": \"pnpm lint && pnpm typecheck && pnpm test && pnpm build\"\n  },\n  \"keywords\": [],\n  \"author\": \"\",\n  \"license\": \"ISC\",\n  \"private\": true,\n  \"dependencies\": {\n    \"jose\": \"^6.2.2\",\n    \"next\": \"^16.2.4\",\n    \"postgres\": \"^3.4.9\",\n    \"react\": \"^19.2.5\",\n    \"react-dom\": \"^19.2.5\",\n    \"zod\": \"^4.3.6\"\n  },\n  \"devDependencies\": {\n    \"@playwright/test\": \"^1.59.1\",\n    \"@testing-library/jest-dom\": \"^6.9.1\",\n    \"@testing-library/react\": \"^16.3.2\",\n    \"@testing-library/user-event\": \"^14.6.1\",\n    \"@types/node\": \"^25.6.0\",\n    \"@types/react\": \"^19.2.14\",\n    \"@types/react-dom\": \"^19.2.3\",\n    \"@vitejs/plugin-react\": \"^4.3.4\",\n    \"eslint\": \"^9.39.4\",\n    \"eslint-config-next\": \"^16.2.4\",\n    \"jsdom\": \"^24.1.3\",\n    \"typescript\": \"^6.0.3\",\n    \"vite\": \"^5.4.21\",\n    \"vitest\": \"3.2.4\"\n  },\n  \"packageManager\": \"pnpm@10.33.0\"\n}","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01KQDMY2ot3QDixGYsatfgtX","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01WwgJBzFYMoUbYDx7nA1iWc","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/__tests__/access-policy.test.ts","content":"import { afterEach, describe, expect, it, vi } from \"vitest\";\nimport {\n  getPeekActorContext,\n  getRequiredRolesForAction,\n  getRequiredRolesForRoute,\n  isActionAllowedForRole,\n  isRouteAllowedForRole,\n  loadPeekRolePolicyFromEnv,\n  normalizeActorEmail,\n  parsePeekRolePolicy,\n  PEEK_ACTION_RULES,\n  PEEK_DEFAULT_ROUTE_ROLES,\n  PEEK_ROUTE_RULES,\n  resolveRoleForEmail,\n  type PeekActionRule,\n  type PeekRolePolicy,\n  type PeekRouteRule,\n} from \"../access-policy\";\nimport { VERIFIED_ACCESS_EMAIL_HEADER } from \"../cloudflare-access\";\n\nconst mockHeaders = vi.fn();\nvi.mock(\"next/headers\", () => ({\n  headers: () => mockHeaders(),\n}));\n\nfunction makeHeaders(map: Record<string, string>): Headers {\n  const h = new Headers();\n  for (const [k, v] of Object.entries(map)) h.set(k, v);\n  return h;\n}\n\ndescribe(\"parsePeekRolePolicy\", () => {\n  it(\"returns [] for non-array input\", () => {\n    expect(parsePeekRolePolicy(null)).toEqual([]);\n    expect(parsePeekRolePolicy(undefined)).toEqual([]);\n    expect(parsePeekRolePolicy(\"oops\")).toEqual([]);\n    expect(parsePeekRolePolicy({ match: \"x@y.z\", role: \"admin\" })).toEqual([]);\n  });\n\n  it(\"normalizes match values: trims and lowercases\", () => {\n    expect(\n      parsePeekRolePolicy([\n        { match: \"  Alice@Example.COM \", role: \"admin\" },\n        { match: \"*@Example.COM\", role: \"business\" },\n      ]),\n    ).toEqual([\n      { match: \"alice@example.com\", role: \"admin\" },\n      { match: \"*@example.com\", role: \"business\" },\n    ]);\n  });\n\n  it(\"drops entries with invalid roles\", () => {\n    expect(\n      parsePeekRolePolicy([\n        { match: \"a@b.c\", role: \"owner\" },\n        { match: \"a@b.c\", role: null },\n        { match: \"a@b.c\", role: \"admin\" },\n      ]),\n    ).toEqual([{ match: \"a@b.c\", role: \"admin\" }]);\n  });\n\n  it(\"drops entries missing match or with non-string match\", () => {\n    expect(\n      parsePeekRolePolicy([\n        { role: \"admin\" },\n        { match: 42, role: \"admin\" },\n        { match: \"\", role: \"admin\" },\n        { match: \"   \", role: \"admin\" },\n        { match: \"valid@a.b\", role: \"admin\" },\n      ]),\n    ).toEqual([{ match: \"valid@a.b\", role: \"admin\" }]);\n  });\n\n  it(\"drops entries with malformed wildcard domains\", () => {\n    expect(\n      parsePeekRolePolicy([\n        { match: \"*@\", role: \"admin\" },\n        { match: \"*@*.com\", role: \"admin\" },\n        { match: \"*@with space.com\", role: \"admin\" },\n        { match: \"*@ok.com\", role: \"admin\" },\n      ]),\n    ).toEqual([{ match: \"*@ok.com\", role: \"admin\" }]);\n  });\n\n  it(\"drops malformed exact emails\", () => {\n    expect(\n      parsePeekRolePolicy([\n        { match: \"no-at-sign\", role: \"admin\" },\n        { match: \"two@@signs.com\", role: \"admin\" },\n        { match: \"spa ce@x.com\", role: \"admin\" },\n        { match: \"good@x.com\", role: \"admin\" },\n      ]),\n    ).toEqual([{ match: \"good@x.com\", role: \"admin\" }]);\n  });\n\n  it(\"de-duplicates exact (match, role) pairs while preserving distinct roles\", () => {\n    expect(\n      parsePeekRolePolicy([\n        { match: \"a@b.c\", role: \"admin\" },\n        { match: \"A@B.C\", role: \"admin\" },\n        { match: \"a@b.c\", role: \"business\" },\n      ]),\n    ).toEqual([\n      { match: \"a@b.c\", role: \"admin\" },\n      { match: \"a@b.c\", role: \"business\" },\n    ]);\n  });\n\n  it(\"ignores non-object items\", () => {\n    expect(\n      parsePeekRolePolicy([null, undefined, 0, \"x\", { match: \"a@b.c\", role: \"admin\" }]),\n    ).toEqual([{ match: \"a@b.c\", role: \"admin\" }]);\n  });\n});\n\ndescribe(\"loadPeekRolePolicyFromEnv\", () => {\n  afterEach(() => {\n    vi.unstubAllEnvs();\n  });\n\n  it(\"returns [] when env var is unset\", () => {\n    vi.stubEnv(\"PEEK_ACCESS_POLICY\", \"\");\n    expect(loadPeekRolePolicyFromEnv()).toEqual([]);\n  });\n\n  it(\"returns [] when env var is malformed JSON\", () => {\n    vi.stubEnv(\"PEEK_ACCESS_POLICY\", \"{not json\");\n    expect(loadPeekRolePolicyFromEnv()).toEqual([]);\n  });\n\n  it(\"parses a valid env policy\", () => {\n    vi.stubEnv(\n      \"PEEK_ACCESS_POLICY\",\n      JSON.stringify([\n        { match: \"alice@example.com\", role: \"admin\" },\n        { match: \"*@partner.io\", role: \"business\" },\n      ]),\n    );\n    expect(loadPeekRolePolicyFromEnv()).toEqual([\n      { match: \"alice@example.com\", role: \"admin\" },\n      { match: \"*@partner.io\", role: \"business\" },\n    ]);\n  });\n});\n\ndescribe(\"normalizeActorEmail\", () => {\n  it(\"trims and lowercases\", () => {\n    expect(normalizeActorEmail(\"  Alice@Example.COM \")).toBe(\"alice@example.com\");\n  });\n\n  it(\"returns null for nullish/empty/invalid\", () => {\n    expect(normalizeActorEmail(null)).toBeNull();\n    expect(normalizeActorEmail(undefined)).toBeNull();\n    expect(normalizeActorEmail(\"\")).toBeNull();\n    expect(normalizeActorEmail(\"   \")).toBeNull();\n    expect(normalizeActorEmail(\"nope\")).toBeNull();\n  });\n});\n\ndescribe(\"resolveRoleForEmail\", () => {\n  const policy: PeekRolePolicy = [\n    { match: \"alice@example.com\", role: \"business\" },\n    { match: \"*@example.com\", role: \"business\" },\n    { match: \"boss@example.com\", role: \"admin\" },\n    { match: \"*@admins.io\", role: \"admin\" },\n  ];\n\n  it(\"returns null for invalid/empty email\", () => {\n    expect(resolveRoleForEmail(null, policy)).toBeNull();\n    expect(resolveRoleForEmail(\"\", policy)).toBeNull();\n    expect(resolveRoleForEmail(\"not-an-email\", policy)).toBeNull();\n  });\n\n  it(\"matches exact email entries (case-insensitive)\", () => {\n    expect(resolveRoleForEmail(\"alice@example.com\", policy)).toBe(\"business\");\n    expect(resolveRoleForEmail(\"  ALICE@example.com \", policy)).toBe(\"business\");\n  });\n\n  it(\"matches wildcard domain entries\", () => {\n    expect(resolveRoleForEmail(\"bob@example.com\", policy)).toBe(\"business\");\n    expect(resolveRoleForEmail(\"anyone@admins.io\", policy)).toBe(\"admin\");\n  });\n\n  it(\"admin precedence: exact admin entry wins over wildcard business\", () => {\n    expect(resolveRoleForEmail(\"boss@example.com\", policy)).toBe(\"admin\");\n  });\n\n  it(\"admin precedence: wildcard admin wins over exact business\", () => {\n    const p: PeekRolePolicy = [\n      { match: \"alice@example.com\", role: \"business\" },\n      { match: \"*@example.com\", role: \"admin\" },\n    ];\n    expect(resolveRoleForEmail(\"alice@example.com\", p)).toBe(\"admin\");\n  });\n\n  it(\"returns null when nothing matches\", () => {\n    expect(resolveRoleForEmail(\"stranger@other.org\", policy)).toBeNull();\n  });\n\n  it(\"returns null for an empty policy\", () => {\n    expect(resolveRoleForEmail(\"alice@example.com\", [])).toBeNull();\n  });\n});\n\ndescribe(\"getRequiredRolesForRoute\", () => {\n  it(\"uses the documented default for unknown routes\", () => {\n    expect(getRequiredRolesForRoute(\"/\")).toEqual(PEEK_DEFAULT_ROUTE_ROLES);\n    expect(getRequiredRolesForRoute(\"/users\")).toEqual(PEEK_DEFAULT_ROUTE_ROLES);\n    expect(getRequiredRolesForRoute(\"/games/flipyou\")).toEqual(\n      PEEK_DEFAULT_ROUTE_ROLES,\n    );\n  });\n\n  it(\"returns admin-only for /audit and its subpaths\", () => {\n    expect(getRequiredRolesForRoute(\"/audit\")).toEqual([\"admin\"]);\n    expect(getRequiredRolesForRoute(\"/audit/\")).toEqual([\"admin\"]);\n    expect(getRequiredRolesForRoute(\"/audit/exports\")).toEqual([\"admin\"]);\n  });\n\n  it(\"does not match prefix substrings beyond a path boundary\", () => {\n    expect(getRequiredRolesForRoute(\"/auditing\")).toEqual(PEEK_DEFAULT_ROUTE_ROLES);\n  });\n\n  it(\"strips query strings and hash fragments before matching\", () => {\n    expect(getRequiredRolesForRoute(\"/audit?actor=alice\")).toEqual([\"admin\"]);\n    expect(getRequiredRolesForRoute(\"/audit#section\")).toEqual([\"admin\"]);\n  });\n\n  it(\"normalizes paths missing a leading slash\", () => {\n    expect(getRequiredRolesForRoute(\"audit\")).toEqual([\"admin\"]);\n  });\n\n  it(\"picks the most specific matching prefix when multiple match\", () => {\n    const rules: ReadonlyArray<PeekRouteRule> = [\n      { prefix: \"/x\", roles: [\"business\", \"admin\"] },\n      { prefix: \"/x/secret\", roles: [\"admin\"] },\n    ];\n    expect(getRequiredRolesForRoute(\"/x/secret/inner\", rules)).toEqual([\"admin\"]);\n    expect(getRequiredRolesForRoute(\"/x/other\", rules)).toEqual([\n      \"business\",\n      \"admin\",\n    ]);\n  });\n});\n\ndescribe(\"isRouteAllowedForRole\", () => {\n  it(\"denies for null/undefined role\", () => {\n    expect(isRouteAllowedForRole(\"/users\", null)).toBe(false);\n    expect(isRouteAllowedForRole(\"/users\", undefined)).toBe(false);\n  });\n\n  it(\"allows business and admin on default routes\", () => {\n    expect(isRouteAllowedForRole(\"/users\", \"business\")).toBe(true);\n    expect(isRouteAllowedForRole(\"/users\", \"admin\")).toBe(true);\n  });\n\n  it(\"denies business on /audit but allows admin\", () => {\n    expect(isRouteAllowedForRole(\"/audit\", \"business\")).toBe(false);\n    expect(isRouteAllowedForRole(\"/audit\", \"admin\")).toBe(true);\n  });\n});\n\ndescribe(\"getRequiredRolesForAction\", () => {\n  it(\"returns roles for known action ids\", () => {\n    expect(getRequiredRolesForAction(\"kol_rate.update\")).toEqual([\n      \"business\",\n      \"admin\",\n    ]);\n    expect(getRequiredRolesForAction(\"fraud_flag.status.update\")).toEqual([\n      \"admin\",\n    ]);\n    expect(getRequiredRolesForAction(\"dogpile.cancel\")).toEqual([\"admin\"]);\n    expect(getRequiredRolesForAction(\"reward_config.update\")).toEqual([\"admin\"]);\n  });\n\n  it(\"returns null for unknown action ids\", () => {\n    expect(getRequiredRolesForAction(\"not.a.real.action\")).toBeNull();\n    expect(getRequiredRolesForAction(\"\")).toBeNull();\n  });\n});\n\ndescribe(\"isActionAllowedForRole\", () => {\n  it(\"fails closed for unknown action ids\", () => {\n    expect(isActionAllowedForRole(\"nope\", \"admin\")).toBe(false);\n    expect(isActionAllowedForRole(\"nope\", \"business\")).toBe(false);\n  });\n\n  it(\"denies when role is missing\", () => {\n    expect(isActionAllowedForRole(\"kol_rate.update\", null)).toBe(false);\n    expect(isActionAllowedForRole(\"kol_rate.update\", undefined)).toBe(false);\n  });\n\n  it(\"admin can perform every initial mutation\", () => {\n    for (const rule of PEEK_ACTION_RULES) {\n      expect(isActionAllowedForRole(rule.actionId, \"admin\")).toBe(true);\n    }\n  });\n\n  it(\"business can perform kol_rate.update but not admin-only mutations\", () => {\n    expect(isActionAllowedForRole(\"kol_rate.update\", \"business\")).toBe(true);\n    expect(isActionAllowedForRole(\"fraud_flag.status.update\", \"business\")).toBe(\n      false,\n    );\n    expect(isActionAllowedForRole(\"dogpile.cancel\", \"business\")).toBe(false);\n    expect(isActionAllowedForRole(\"reward_config.update\", \"business\")).toBe(false);\n  });\n\n  it(\"respects an overridden rules table\", () => {\n    const rules: ReadonlyArray<PeekActionRule> = [\n      { actionId: \"custom.thing\", roles: [\"business\"] },\n    ];\n    expect(isActionAllowedForRole(\"custom.thing\", \"business\", rules)).toBe(true);\n    expect(isActionAllowedForRole(\"custom.thing\", \"admin\", rules)).toBe(false);\n    // Initial rules should not leak when an override is supplied.\n    expect(isActionAllowedForRole(\"kol_rate.update\", \"admin\", rules)).toBe(false);\n  });\n});\n\ndescribe(\"getPeekActorContext\", () => {\n  afterEach(() => {\n    vi.unstubAllEnvs();\n    mockHeaders.mockReset();\n  });\n\n  it(\"returns null when the verified email header is missing\", async () => {\n    vi.stubEnv(\n      \"PEEK_ACCESS_POLICY\",\n      JSON.stringify([{ match: \"*@example.com\", role: \"admin\" }]),\n    );\n    mockHeaders.mockReturnValue(makeHeaders({}));\n    await expect(getPeekActorContext()).resolves.toBeNull();\n  });\n\n  it(\"returns null when policy has no match for the verified email\", async () => {\n    vi.stubEnv(\n      \"PEEK_ACCESS_POLICY\",\n      JSON.stringify([{ match: \"*@example.com\", role: \"admin\" }]),\n    );\n    mockHeaders.mockReturnValue(\n      makeHeaders({ [VERIFIED_ACCESS_EMAIL_HEADER]: \"stranger@other.org\" }),\n    );\n    await expect(getPeekActorContext()).resolves.toBeNull();\n  });\n\n  it(\"returns null when the policy is empty\", async () => {\n    vi.stubEnv(\"PEEK_ACCESS_POLICY\", \"\");\n    mockHeaders.mockReturnValue(\n      makeHeaders({ [VERIFIED_ACCESS_EMAIL_HEADER]: \"alice@example.com\" }),\n    );\n    await expect(getPeekActorContext()).resolves.toBeNull();\n  });\n\n  it(\"returns the resolved actor for a verified email matched by exact entry\", async () => {\n    vi.stubEnv(\n      \"PEEK_ACCESS_POLICY\",\n      JSON.stringify([{ match: \"alice@example.com\", role: \"admin\" }]),\n    );\n    mockHeaders.mockReturnValue(\n      makeHeaders({ [VERIFIED_ACCESS_EMAIL_HEADER]: \"alice@example.com\" }),\n    );\n    await expect(getPeekActorContext()).resolves.toEqual({\n      email: \"alice@example.com\",\n      role: \"admin\",\n    });\n  });\n\n  it(\"returns the resolved actor for a verified email matched by wildcard entry, with case normalization\", async () => {\n    vi.stubEnv(\n      \"PEEK_ACCESS_POLICY\",\n      JSON.stringify([{ match: \"*@example.com\", role: \"business\" }]),\n    );\n    mockHeaders.mockReturnValue(\n      makeHeaders({ [VERIFIED_ACCESS_EMAIL_HEADER]: \"  Bob@Example.COM \" }),\n    );\n    await expect(getPeekActorContext()).resolves.toEqual({\n      email: \"bob@example.com\",\n      role: \"business\",\n    });\n  });\n\n  it(\"returns null when the verified email header is malformed\", async () => {\n    vi.stubEnv(\n      \"PEEK_ACCESS_POLICY\",\n      JSON.stringify([{ match: \"*@example.com\", role: \"admin\" }]),\n    );\n    mockHeaders.mockReturnValue(\n      makeHeaders({ [VERIFIED_ACCESS_EMAIL_HEADER]: \"not-an-email\" }),\n    );\n    await expect(getPeekActorContext()).resolves.toBeNull();\n  });\n});\n\ndescribe(\"PEEK_ROUTE_RULES + PEEK_ACTION_RULES (live tables)\", () => {\n  it(\"/audit is admin-only\", () => {\n    const rule = PEEK_ROUTE_RULES.find((r) => r.prefix === \"/audit\");\n    expect(rule).toBeDefined();\n    expect(rule?.roles).toEqual([\"admin\"]);\n  });\n\n  it(\"includes the FR-14 initial mutation candidates\", () => {\n    const ids = PEEK_ACTION_RULES.map((r) => r.actionId);\n    expect(ids).toEqual(\n      expect.arrayContaining([\n        \"kol_rate.update\",\n        \"fraud_flag.status.update\",\n        \"dogpile.cancel\",\n        \"reward_config.update\",\n      ]),\n    );\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":882,"cache_read_input_tokens":74118,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":882},"output_tokens":62,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"aa5a08cd-02b7-4c6c-a7cf-b6590f18e996","uuid":"a8f755d6-5e81-43b2-85c8-3ceba8ae4a70"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WwgJBzFYMoUbYDx7nA1iWc","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/server/__tests__/access-policy.test.ts"}]},"parent_tool_use_id":null,"session_id":"aa5a08cd-02b7-4c6c-a7cf-b6590f18e996","uuid":"6d0d9e8d-adac-4d2c-979b-c17bee3aa39e","timestamp":"2026-04-25T10:41:09.194Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/server/__tests__/access-policy.test.ts","content":"import { afterEach, describe, expect, it, vi } from \"vitest\";\nimport {\n  getPeekActorContext,\n  getRequiredRolesForAction,\n  getRequiredRolesForRoute,\n  isActionAllowedForRole,\n  isRouteAllowedForRole,\n  loadPeekRolePolicyFromEnv,\n  normalizeActorEmail,\n  parsePeekRolePolicy,\n  PEEK_ACTION_RULES,\n  PEEK_DEFAULT_ROUTE_ROLES,\n  PEEK_ROUTE_RULES,\n  resolveRoleForEmail,\n  type PeekActionRule,\n  type PeekRolePolicy,\n  type PeekRouteRule,\n} from \"../access-policy\";\nimport { VERIFIED_ACCESS_EMAIL_HEADER } from \"../cloudflare-access\";\n\nconst mockHeaders = vi.fn();\nvi.mock(\"next/headers\", () => ({\n  headers: () => mockHeaders(),\n}));\n\nfunction makeHeaders(map: Record<string, string>): Headers {\n  const h = new Headers();\n  for (const [k, v] of Object.entries(map)) h.set(k, v);\n  return h;\n}\n\ndescribe(\"parsePeekRolePolicy\", () => {\n  it(\"returns [] for non-array input\", () => {\n    expect(parsePeekRolePolicy(null)).toEqual([]);\n    expect(parsePeekRolePolicy(undefined)).toEqual([]);\n    expect(parsePeekRolePolicy(\"oops\")).toEqual([]);\n    expect(parsePeekRolePolicy({ match: \"x@y.z\", role: \"admin\" })).toEqual([]);\n  });\n\n  it(\"normalizes match values: trims and lowercases\", () => {\n    expect(\n      parsePeekRolePolicy([\n        { match: \"  Alice@Example.COM \", role: \"admin\" },\n        { match: \"*@Example.COM\", role: \"business\" },\n      ]),\n    ).toEqual([\n      { match: \"alice@example.com\", role: \"admin\" },\n      { match: \"*@example.com\", role: \"business\" },\n    ]);\n  });\n\n  it(\"drops entries with invalid roles\", () => {\n    expect(\n      parsePeekRolePolicy([\n        { match: \"a@b.c\", role: \"owner\" },\n        { match: \"a@b.c\", role: null },\n        { match: \"a@b.c\", role: \"admin\" },\n      ]),\n    ).toEqual([{ match: \"a@b.c\", role: \"admin\" }]);\n  });\n\n  it(\"drops entries missing match or with non-string match\", () => {\n    expect(\n      parsePeekRolePolicy([\n        { role: \"admin\" },\n        { match: 42, role: \"admin\" },\n        { match: \"\", role: \"admin\" },\n        { match: \"   \", role: \"admin\" },\n        { match: \"valid@a.b\", role: \"admin\" },\n      ]),\n    ).toEqual([{ match: \"valid@a.b\", role: \"admin\" }]);\n  });\n\n  it(\"drops entries with malformed wildcard domains\", () => {\n    expect(\n      parsePeekRolePolicy([\n        { match: \"*@\", role: \"admin\" },\n        { match: \"*@*.com\", role: \"admin\" },\n        { match: \"*@with space.com\", role: \"admin\" },\n        { match: \"*@ok.com\", role: \"admin\" },\n      ]),\n    ).toEqual([{ match: \"*@ok.com\", role: \"admin\" }]);\n  });\n\n  it(\"drops malformed exact emails\", () => {\n    expect(\n      parsePeekRolePolicy([\n        { match: \"no-at-sign\", role: \"admin\" },\n        { match: \"two@@signs.com\", role: \"admin\" },\n        { match: \"spa ce@x.com\", role: \"admin\" },\n        { match: \"good@x.com\", role: \"admin\" },\n      ]),\n    ).toEqual([{ match: \"good@x.com\", role: \"admin\" }]);\n  });\n\n  it(\"de-duplicates exact (match, role) pairs while preserving distinct roles\", () => {\n    expect(\n      parsePeekRolePolicy([\n        { match: \"a@b.c\", role: \"admin\" },\n        { match: \"A@B.C\", role: \"admin\" },\n        { match: \"a@b.c\", role: \"business\" },\n      ]),\n    ).toEqual([\n      { match: \"a@b.c\", role: \"admin\" },\n      { match: \"a@b.c\", role: \"business\" },\n    ]);\n  });\n\n  it(\"ignores non-object items\", () => {\n    expect(\n      parsePeekRolePolicy([null, undefined, 0, \"x\", { match: \"a@b.c\", role: \"admin\" }]),\n    ).toEqual([{ match: \"a@b.c\", role: \"admin\" }]);\n  });\n});\n\ndescribe(\"loadPeekRolePolicyFromEnv\", () => {\n  afterEach(() => {\n    vi.unstubAllEnvs();\n  });\n\n  it(\"returns [] when env var is unset\", () => {\n    vi.stubEnv(\"PEEK_ACCESS_POLICY\", \"\");\n    expect(loadPeekRolePolicyFromEnv()).toEqual([]);\n  });\n\n  it(\"returns [] when env var is malformed JSON\", () => {\n    vi.stubEnv(\"PEEK_ACCESS_POLICY\", \"{not json\");\n    expect(loadPeekRolePolicyFromEnv()).toEqual([]);\n  });\n\n  it(\"parses a valid env policy\", () => {\n    vi.stubEnv(\n      \"PEEK_ACCESS_POLICY\",\n      JSON.stringify([\n        { match: \"alice@example.com\", role: \"admin\" },\n        { match: \"*@partner.io\", role: \"business\" },\n      ]),\n    );\n    expect(loadPeekRolePolicyFromEnv()).toEqual([\n      { match: \"alice@example.com\", role: \"admin\" },\n      { match: \"*@partner.io\", role: \"business\" },\n    ]);\n  });\n});\n\ndescribe(\"normalizeActorEmail\", () => {\n  it(\"trims and lowercases\", () => {\n    expect(normalizeActorEmail(\"  Alice@Example.COM \")).toBe(\"alice@example.com\");\n  });\n\n  it(\"returns null for nullish/empty/invalid\", () => {\n    expect(normalizeActorEmail(null)).toBeNull();\n    expect(normalizeActorEmail(undefined)).toBeNull();\n    expect(normalizeActorEmail(\"\")).toBeNull();\n    expect(normalizeActorEmail(\"   \")).toBeNull();\n    expect(normalizeActorEmail(\"nope\")).toBeNull();\n  });\n});\n\ndescribe(\"resolveRoleForEmail\", () => {\n  const policy: PeekRolePolicy = [\n    { match: \"alice@example.com\", role: \"business\" },\n    { match: \"*@example.com\", role: \"business\" },\n    { match: \"boss@example.com\", role: \"admin\" },\n    { match: \"*@admins.io\", role: \"admin\" },\n  ];\n\n  it(\"returns null for invalid/empty email\", () => {\n    expect(resolveRoleForEmail(null, policy)).toBeNull();\n    expect(resolveRoleForEmail(\"\", policy)).toBeNull();\n    expect(resolveRoleForEmail(\"not-an-email\", policy)).toBeNull();\n  });\n\n  it(\"matches exact email entries (case-insensitive)\", () => {\n    expect(resolveRoleForEmail(\"alice@example.com\", policy)).toBe(\"business\");\n    expect(resolveRoleForEmail(\"  ALICE@example.com \", policy)).toBe(\"business\");\n  });\n\n  it(\"matches wildcard domain entries\", () => {\n    expect(resolveRoleForEmail(\"bob@example.com\", policy)).toBe(\"business\");\n    expect(resolveRoleForEmail(\"anyone@admins.io\", policy)).toBe(\"admin\");\n  });\n\n  it(\"admin precedence: exact admin entry wins over wildcard business\", () => {\n    expect(resolveRoleForEmail(\"boss@example.com\", policy)).toBe(\"admin\");\n  });\n\n  it(\"admin precedence: wildcard admin wins over exact business\", () => {\n    const p: PeekRolePolicy = [\n      { match: \"alice@example.com\", role: \"business\" },\n      { match: \"*@example.com\", role: \"admin\" },\n    ];\n    expect(resolveRoleForEmail(\"alice@example.com\", p)).toBe(\"admin\");\n  });\n\n  it(\"returns null when nothing matches\", () => {\n    expect(resolveRoleForEmail(\"stranger@other.org\", policy)).toBeNull();\n  });\n\n  it(\"returns null for an empty policy\", () => {\n    expect(resolveRoleForEmail(\"alice@example.com\", [])).toBeNull();\n  });\n});\n\ndescribe(\"getRequiredRolesForRoute\", () => {\n  it(\"uses the documented default for unknown routes\", () => {\n    expect(getRequiredRolesForRoute(\"/\")).toEqual(PEEK_DEFAULT_ROUTE_ROLES);\n    expect(getRequiredRolesForRoute(\"/users\")).toEqual(PEEK_DEFAULT_ROUTE_ROLES);\n    expect(getRequiredRolesForRoute(\"/games/flipyou\")).toEqual(\n      PEEK_DEFAULT_ROUTE_ROLES,\n    );\n  });\n\n  it(\"returns admin-only for /audit and its subpaths\", () => {\n    expect(getRequiredRolesForRoute(\"/audit\")).toEqual([\"admin\"]);\n    expect(getRequiredRolesForRoute(\"/audit/\")).toEqual([\"admin\"]);\n    expect(getRequiredRolesForRoute(\"/audit/exports\")).toEqual([\"admin\"]);\n  });\n\n  it(\"does not match prefix substrings beyond a path boundary\", () => {\n    expect(getRequiredRolesForRoute(\"/auditing\")).toEqual(PEEK_DEFAULT_ROUTE_ROLES);\n  });\n\n  it(\"strips query strings and hash fragments before matching\", () => {\n    expect(getRequiredRolesForRoute(\"/audit?actor=alice\")).toEqual([\"admin\"]);\n    expect(getRequiredRolesForRoute(\"/audit#section\")).toEqual([\"admin\"]);\n  });\n\n  it(\"normalizes paths missing a leading slash\", () => {\n    expect(getRequiredRolesForRoute(\"audit\")).toEqual([\"admin\"]);\n  });\n\n  it(\"picks the most specific matching prefix when multiple match\", () => {\n    const rules: ReadonlyArray<PeekRouteRule> = [\n      { prefix: \"/x\", roles: [\"business\", \"admin\"] },\n      { prefix: \"/x/secret\", roles: [\"admin\"] },\n    ];\n    expect(getRequiredRolesForRoute(\"/x/secret/inner\", rules)).toEqual([\"admin\"]);\n    expect(getRequiredRolesForRoute(\"/x/other\", rules)).toEqual([\n      \"business\",\n      \"admin\",\n    ]);\n  });\n});\n\ndescribe(\"isRouteAllowedForRole\", () => {\n  it(\"denies for null/undefined role\", () => {\n    expect(isRouteAllowedForRole(\"/users\", null)).toBe(false);\n    expect(isRouteAllowedForRole(\"/users\", undefined)).toBe(false);\n  });\n\n  it(\"allows business and admin on default routes\", () => {\n    expect(isRouteAllowedForRole(\"/users\", \"business\")).toBe(true);\n    expect(isRouteAllowedForRole(\"/users\", \"admin\")).toBe(true);\n  });\n\n  it(\"denies business on /audit but allows admin\", () => {\n    expect(isRouteAllowedForRole(\"/audit\", \"business\")).toBe(false);\n    expect(isRouteAllowedForRole(\"/audit\", \"admin\")).toBe(true);\n  });\n});\n\ndescribe(\"getRequiredRolesForAction\", () => {\n  it(\"returns roles for known action ids\", () => {\n    expect(getRequiredRolesForAction(\"kol_rate.update\")).toEqual([\n      \"business\",\n      \"admin\",\n    ]);\n    expect(getRequiredRolesForAction(\"fraud_flag.status.update\")).toEqual([\n      \"admin\",\n    ]);\n    expect(getRequiredRolesForAction(\"dogpile.cancel\")).toEqual([\"admin\"]);\n    expect(getRequiredRolesForAction(\"reward_config.update\")).toEqual([\"admin\"]);\n  });\n\n  it(\"returns null for unknown action ids\", () => {\n    expect(getRequiredRolesForAction(\"not.a.real.action\")).toBeNull();\n    expect(getRequiredRolesForAction(\"\")).toBeNull();\n  });\n});\n\ndescribe(\"isActionAllowedForRole\", () => {\n  it(\"fails closed for unknown action ids\", () => {\n    expect(isActionAllowedForRole(\"nope\", \"admin\")).toBe(false);\n    expect(isActionAllowedForRole(\"nope\", \"business\")).toBe(false);\n  });\n\n  it(\"denies when role is missing\", () => {\n    expect(isActionAllowedForRole(\"kol_rate.update\", null)).toBe(false);\n    expect(isActionAllowedForRole(\"kol_rate.update\", undefined)).toBe(false);\n  });\n\n  it(\"admin can perform every initial mutation\", () => {\n    for (const rule of PEEK_ACTION_RULES) {\n      expect(isActionAllowedForRole(rule.actionId, \"admin\")).toBe(true);\n    }\n  });\n\n  it(\"business can perform kol_rate.update but not admin-only mutations\", () => {\n    expect(isActionAllowedForRole(\"kol_rate.update\", \"business\")).toBe(true);\n    expect(isActionAllowedForRole(\"fraud_flag.status.update\", \"business\")).toBe(\n      false,\n    );\n    expect(isActionAllowedForRole(\"dogpile.cancel\", \"business\")).toBe(false);\n    expect(isActionAllowedForRole(\"reward_config.update\", \"business\")).toBe(false);\n  });\n\n  it(\"respects an overridden rules table\", () => {\n    const rules: ReadonlyArray<PeekActionRule> = [\n      { actionId: \"custom.thing\", roles: [\"business\"] },\n    ];\n    expect(isActionAllowedForRole(\"custom.thing\", \"business\", rules)).toBe(true);\n    expect(isActionAllowedForRole(\"custom.thing\", \"admin\", rules)).toBe(false);\n    // Initial rules should not leak when an override is supplied.\n    expect(isActionAllowedForRole(\"kol_rate.update\", \"admin\", rules)).toBe(false);\n  });\n});\n\ndescribe(\"getPeekActorContext\", () => {\n  afterEach(() => {\n    vi.unstubAllEnvs();\n    mockHeaders.mockReset();\n  });\n\n  it(\"returns null when the verified email header is missing\", async () => {\n    vi.stubEnv(\n      \"PEEK_ACCESS_POLICY\",\n      JSON.stringify([{ match: \"*@example.com\", role: \"admin\" }]),\n    );\n    mockHeaders.mockReturnValue(makeHeaders({}));\n    await expect(getPeekActorContext()).resolves.toBeNull();\n  });\n\n  it(\"returns null when policy has no match for the verified email\", async () => {\n    vi.stubEnv(\n      \"PEEK_ACCESS_POLICY\",\n      JSON.stringify([{ match: \"*@example.com\", role: \"admin\" }]),\n    );\n    mockHeaders.mockReturnValue(\n      makeHeaders({ [VERIFIED_ACCESS_EMAIL_HEADER]: \"stranger@other.org\" }),\n    );\n    await expect(getPeekActorContext()).resolves.toBeNull();\n  });\n\n  it(\"returns null when the policy is empty\", async () => {\n    vi.stubEnv(\"PEEK_ACCESS_POLICY\", \"\");\n    mockHeaders.mockReturnValue(\n      makeHeaders({ [VERIFIED_ACCESS_EMAIL_HEADER]: \"alice@example.com\" }),\n    );\n    await expect(getPeekActorContext()).resolves.toBeNull();\n  });\n\n  it(\"returns the resolved actor for a verified email matched by exact entry\", async () => {\n    vi.stubEnv(\n      \"PEEK_ACCESS_POLICY\",\n      JSON.stringify([{ match: \"alice@example.com\", role: \"admin\" }]),\n    );\n    mockHeaders.mockReturnValue(\n      makeHeaders({ [VERIFIED_ACCESS_EMAIL_HEADER]: \"alice@example.com\" }),\n    );\n    await expect(getPeekActorContext()).resolves.toEqual({\n      email: \"alice@example.com\",\n      role: \"admin\",\n    });\n  });\n\n  it(\"returns the resolved actor for a verified email matched by wildcard entry, with case normalization\", async () => {\n    vi.stubEnv(\n      \"PEEK_ACCESS_POLICY\",\n      JSON.stringify([{ match: \"*@example.com\", role: \"business\" }]),\n    );\n    mockHeaders.mockReturnValue(\n      makeHeaders({ [VERIFIED_ACCESS_EMAIL_HEADER]: \"  Bob@Example.COM \" }),\n    );\n    await expect(getPeekActorContext()).resolves.toEqual({\n      email: \"bob@example.com\",\n      role: \"business\",\n    });\n  });\n\n  it(\"returns null when the verified email header is malformed\", async () => {\n    vi.stubEnv(\n      \"PEEK_ACCESS_POLICY\",\n      JSON.stringify([{ match: \"*@example.com\", role: \"admin\" }]),\n    );\n    mockHeaders.mockReturnValue(\n      makeHeaders({ [VERIFIED_ACCESS_EMAIL_HEADER]: \"not-an-email\" }),\n    );\n    await expect(getPeekActorContext()).resolves.toBeNull();\n  });\n});\n\ndescribe(\"PEEK_ROUTE_RULES + PEEK_ACTION_RULES (live tables)\", () => {\n  it(\"/audit is admin-only\", () => {\n    const rule = PEEK_ROUTE_RULES.find((r) => r.prefix === \"/audit\");\n    expect(rule).toBeDefined();\n    expect(rule?.roles).toEqual([\"admin\"]);\n  });\n\n  it(\"includes the FR-14 initial mutation candidates\", () => {\n    const ids = PEEK_ACTION_RULES.map((r) => r.actionId);\n    expect(ids).toEqual(\n      expect.arrayContaining([\n        \"kol_rate.update\",\n        \"fraud_flag.status.update\",\n        \"dogpile.cancel\",\n        \"reward_config.update\",\n      ]),\n    );\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
