{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BPSMwB6d3bergVXhoXF3Qt","type":"tool_result","content":"1\t// Server-only local role policy for peek (FR-2).\n2\t//\n3\t// Cloudflare Access decides who can reach the app; this module resolves a\n4\t// verified Cloudflare email to a single effective local role (`business` or\n5\t// `admin`) and exposes a server-side actor context. Browser headers are never\n6\t// trusted: the verified email comes only from the trusted middleware-set\n7\t// `VERIFIED_ACCESS_EMAIL_HEADER`, which the proxy strips and re-sets on every\n8\t// request.\n9\timport { headers } from \"next/headers\";\n10\timport { VERIFIED_ACCESS_EMAIL_HEADER } from \"./cloudflare-access\";\n11\t\n12\texport type PeekRole = \"business\" | \"admin\";\n13\t\n14\texport type PeekRolePolicyEntry = {\n15\t  match: string;\n16\t  role: PeekRole;\n17\t};\n18\t\n19\texport type PeekRolePolicy = ReadonlyArray<PeekRolePolicyEntry>;\n20\t\n21\texport type PeekActorContext = {\n22\t  email: string;\n23\t  role: PeekRole;\n24\t};\n25\t\n26\tconst PEEK_ACCESS_POLICY_ENV = \"PEEK_ACCESS_POLICY\";\n27\t\n28\tconst EMAIL_PATTERN = /^[^\\s@]+@[^\\s@]+$/;\n29\t\n30\texport function parsePeekRolePolicy(raw: unknown): PeekRolePolicy {\n31\t  if (!Array.isArray(raw)) {\n32\t    return [];\n33\t  }\n34\t\n35\t  const entries: PeekRolePolicyEntry[] = [];\n36\t  const seen = new Set<string>();\n37\t\n38\t  for (const item of raw) {\n39\t    if (!item || typeof item !== \"object\") continue;\n40\t\n41\t    const role = (item as { role?: unknown }).role;\n42\t    if (role !== \"business\" && role !== \"admin\") continue;\n43\t\n44\t    const matchRaw = (item as { match?: unknown }).match;\n45\t    if (typeof matchRaw !== \"string\") continue;\n46\t\n47\t    const match = matchRaw.trim().toLowerCase();\n48\t    if (!match) continue;\n49\t\n50\t    if (match.startsWith(\"*@\")) {\n51\t      const domain = match.slice(2);\n52\t      if (!domain || !/^[^\\s@*]+$/.test(domain)) continue;\n53\t    } else if (!EMAIL_PATTERN.test(match)) {\n54\t      continue;\n55\t    }\n56\t\n57\t    const dedupeKey = `${match}::${role}`;\n58\t    if (seen.has(dedupeKey)) continue;\n59\t    seen.add(dedupeKey);\n60\t\n61\t    entries.push({ match, role });\n62\t  }\n63\t\n64\t  return entries;\n65\t}\n66\t\n67\texport function loadPeekRolePolicyFromEnv(): PeekRolePolicy {\n68\t  const raw = process.env[PEEK_ACCESS_POLICY_ENV]?.trim();\n69\t  if (!raw) return [];\n70\t  let parsed: unknown;\n71\t  try {\n72\t    parsed = JSON.parse(raw);\n73\t  } catch {\n74\t    return [];\n75\t  }\n76\t  return parsePeekRolePolicy(parsed);\n77\t}\n78\t\n79\texport function normalizeActorEmail(value: string | null | undefined): string | null {\n80\t  if (!value) return null;\n81\t  const email = value.trim().toLowerCase();\n82\t  if (!EMAIL_PATTERN.test(email)) return null;\n83\t  return email;\n84\t}\n85\t\n86\texport function resolveRoleForEmail(\n87\t  email: string | null | undefined,\n88\t  policy: PeekRolePolicy,\n89\t): PeekRole | null {\n90\t  const normalized = normalizeActorEmail(email);\n91\t  if (!normalized) return null;\n92\t\n93\t  const emailDomain = normalized.split(\"@\")[1] ?? \"\";\n94\t\n95\t  let resolved: PeekRole | null = null;\n96\t\n97\t  for (const entry of policy) {\n98\t    const matched = entry.match.startsWith(\"*@\")\n99\t      ? entry.match.slice(2) === emailDomain\n100\t      : entry.match === normalized;\n101\t    if (!matched) continue;\n102\t\n103\t    if (entry.role === \"admin\") {\n104\t      return \"admin\";\n105\t    }\n106\t    if (!resolved) {\n107\t      resolved = entry.role;\n108\t    }\n109\t  }\n110\t\n111\t  return resolved;\n112\t}\n113\t\n114\texport async function getPeekActorContext(): Promise<PeekActorContext | null> {\n115\t  const requestHeaders = await headers();\n116\t  const headerEmail = requestHeaders.get(VERIFIED_ACCESS_EMAIL_HEADER);\n117\t  const email = normalizeActorEmail(headerEmail);\n118\t  