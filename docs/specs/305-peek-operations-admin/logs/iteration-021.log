{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0139qjifSGShizC8vcj3Ka42","type":"tool_result","content":"1\t// Universal search query (FR-5).\n2\t//\n3\t// Resolves a single operator-typed query against the operational identifiers\n4\t// admins care about: user_id, username, wallet, referral code, Telegram\n5\t// username, Telegram provider id, round PDA, match id, tx signature, and\n6\t// queue event id. Results are grouped by entity type (user, referral,\n7\t// linked_account, round, transaction, queue_event); each per-group query is\n8\t// bounded server-side. The function emits a `peek.search` audit event by\n9\t// default; tests can inject a no-op or capturing audit handler.\n10\t//\n11\t// Audit payload contract (FR-5 + FR-11):\n12\t// - actorEmail: provided by the caller from the verified Cloudflare Access\n13\t//   email (never trusted from a browser header).\n14\t// - actionId: stable string `peek.search` so audit views can filter.\n15\t// - resourceType: `search` (no resource id — the search is the resource).\n16\t// - filterSummary: a coarse `query_class=<class>` summary; the writer's\n17\t//   redaction layer scrubs any value that looks like a JWT, DB URL, private\n18\t//   key, Bearer header, or cf-access-jwt-assertion line.\n19\t// - resultCount: total results across all groups.\n20\t// - changes: null (search is read-only).\n21\t\n22\timport type { Sql } from \"postgres\";\n23\timport {\n24\t  PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT,\n25\t  PEEK_SEARCH_MAX_PER_GROUP_LIMIT,\n26\t  type PeekSearchEntityType,\n27\t  type PeekSearchGroup,\n28\t  type PeekSearchQueryClass,\n29\t  type PeekSearchResponse,\n30\t  type PeekSearchResult,\n31\t} from \"../../../lib/types/peek\";\n32\timport { writePeekAuditEvent } from \"../../audit/writer\";\n33\timport { getSqlClient } from \"../client\";\n34\t\n35\tconst BASE58_PATTERN = /^[1-9A-HJ-NP-Za-km-z]+$/;\n36\tconst HEX_PATTERN = /^[0-9a-fA-F]+$/;\n37\tconst UUID_PATTERN =\n38\t  /^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$/;\n39\tconst USERNAME_PATTERN = /^[A-Za-z0-9_]{3,32}$/;\n40\tconst REFERRAL_CODE_PATTERN = /^[A-Z0-9]{4,12}$/;\n41\t\n42\texport type PeekSearchAuditFn = (input: {\n43\t  actorEmail: string;\n44\t  query: string;\n45\t  queryClass: PeekSearchQueryClass;\n46\t  totalResults: number;\n47\t  route: string | null;\n48\t  requestId: string | null;\n49\t}) => Promise<void>;\n50\t\n51\texport type UniversalSearchOptions = {\n52\t  query: string;\n53\t  actorEmail: string;\n54\t  sql?: Sql;\n55\t  perGroupLimit?: number;\n56\t  now?: Date;\n57\t  route?: string | null;\n58\t  requestId?: string | null;\n59\t  audit?: PeekSearchAuditFn | null;\n60\t};\n61\t\n62\t// Heuristic classification used only for audit-event summaries. The function\n63\t// always tries every plausible lookup against the database — the class only\n64\t// labels the search so reviewers can read intent without depending on the\n65\t// (possibly redacted) raw query.\n66\texport function classifyPeekSearchQuery(raw: string): PeekSearchQueryClass {\n67\t  const trimmed = raw.trim();\n68\t  if (trimmed.length === 0) return \"empty\";\n69\t\n70\t  const cleaned = trimmed.startsWith(\"@\") ? trimmed.slice(1) : trimmed;\n71\t\n72\t  if (UUID_PATTERN.test(cleaned)) return \"free_text\";\n73\t  if (/^\\d+$/.test(cleaned)) {\n74\t    return cleaned.length <= 18 ? \"queue_event_id\" : \"telegram_provider_id\";\n75\t  }\n76\t  if (cleaned.length === 16 && HEX_PATTERN.test(cleaned)) return \"match_id\";\n77\t\n78\t  if (BASE58_PATTERN.test(cleaned)) {\n79\t    if (cleaned.length >= 80) return \"tx_signature\";\n80\t    if (cleaned.length >= 32 && cleaned.length <= 44) return \"round_pda\";\n81\t  }\n82\t\n83\t  if (trimmed.startsWith(\"@\")) return \"telegram_username\";\n84\t\n85\t  if (REFERRAL_CODE_PATTERN.test(cleaned)) return \"referral_code\";\n86\t\n87\t  if (USERNAME_PATTERN.test(cleaned)) return \"username\";\n88\t\n89\t  return \"free_text\";\n90\t}\n91\t\n92\tfunction clampLimit(requested: number | undefined): number {\n93\t  const fallback = requested ?? PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT;\n94\t  if (!Number.isFinite(fallback)) return PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT;\n95\t  const floored = Math.floor(fallback);\n96\t  return Math.max(\n97\t    1,\n98\t    Math.min(PEEK_SEARCH_MAX_PER_GROUP_LIMIT, floored),\n99\t  );\n100\t}\n101\t\n102\tfunction emptyGroups(): ReadonlyArray<PeekSearchGroup> {\n103\t  const entityTypes: ReadonlyArray<PeekSearchEntityType> = [\n104\t    \"user\",\n105\t    \"referral\",\n106\t    \"linked_account\",\n107\t    \"round\",\n108\t    \"transaction\",\n109\t    \"queue_event\",\n110\t  ];\n111\t  return entityTypes.map((entityType) => ({\n112\t    entityType,\n113\t    results: [],\n114\t    truncated: false,\n115\t  }));\n116\t}\n117\t\n118\ttype UserRow = {\n119\t  userId: string;\n120\t  username: string | null;"}]},"parent_tool_use_id":null,"session_id":"aa22a004-7967-4272-b3ce-42c86f057c37","uuid":"f7bb4a5c-da57-4e14-8a6c-1051acfcdb42","timestamp":"2026-04-25T12:04:09.386Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/universal-search.ts","content":"// Universal search query (FR-5).\n//\n// Resolves a single operator-typed query against the operational identifiers\n// admins care about: user_id, username, wallet, referral code, Telegram\n// username, Telegram provider id, round PDA, match id, tx signature, and\n// queue event id. Results are grouped by entity type (user, referral,\n// linked_account, round, transaction, queue_event); each per-group query is\n// bounded server-side. The function emits a `peek.search` audit event by\n// default; tests can inject a no-op or capturing audit handler.\n//\n// Audit payload contract (FR-5 + FR-11):\n// - actorEmail: provided by the caller from the verified Cloudflare Access\n//   email (never trusted from a browser header).\n// - actionId: stable string `peek.search` so audit views can filter.\n// - resourceType: `search` (no resource id — the search is the resource).\n// - filterSummary: a coarse `query_class=<class>` summary; the writer's\n//   redaction layer scrubs any value that looks like a JWT, DB URL, private\n//   key, Bearer header, or cf-access-jwt-assertion line.\n// - resultCount: total results across all groups.\n// - changes: null (search is read-only).\n\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT,\n  PEEK_SEARCH_MAX_PER_GROUP_LIMIT,\n  type PeekSearchEntityType,\n  type PeekSearchGroup,\n  type PeekSearchQueryClass,\n  type PeekSearchResponse,\n  type PeekSearchResult,\n} from \"../../../lib/types/peek\";\nimport { writePeekAuditEvent } from \"../../audit/writer\";\nimport { getSqlClient } from \"../client\";\n\nconst BASE58_PATTERN = /^[1-9A-HJ-NP-Za-km-z]+$/;\nconst HEX_PATTERN = /^[0-9a-fA-F]+$/;\nconst UUID_PATTERN =\n  /^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$/;\nconst USERNAME_PATTERN = /^[A-Za-z0-9_]{3,32}$/;\nconst REFERRAL_CODE_PATTERN = /^[A-Z0-9]{4,12}$/;\n\nexport type PeekSearchAuditFn = (input: {\n  actorEmail: string;\n  query: string;\n  queryClass: PeekSearchQueryClass;\n  totalResults: number;\n  route: string | null;\n  requestId: string | null;\n}) => Promise<void>;\n\nexport type UniversalSearchOptions = {\n  query: string;\n  actorEmail: string;\n  sql?: Sql;\n  perGroupLimit?: number;\n  now?: Date;\n  route?: string | null;\n  requestId?: string | null;\n  audit?: PeekSearchAuditFn | null;\n};\n\n// Heuristic classification used only for audit-event summaries. The function\n// always tries every plausible lookup against the database — the class only\n// labels the search so reviewers can read intent without depending on the\n// (possibly redacted) raw query.\nexport function classifyPeekSearchQuery(raw: string): PeekSearchQueryClass {\n  const trimmed = raw.trim();\n  if (trimmed.length === 0) return \"empty\";\n\n  const cleaned = trimmed.startsWith(\"@\") ? trimmed.slice(1) : trimmed;\n\n  if (UUID_PATTERN.test(cleaned)) return \"free_text\";\n  if (/^\\d+$/.test(cleaned)) {\n    return cleaned.length <= 18 ? \"queue_event_id\" : \"telegram_provider_id\";\n  }\n  if (cleaned.length === 16 && HEX_PATTERN.test(cleaned)) return \"match_id\";\n\n  if (BASE58_PATTERN.test(cleaned)) {\n    if (cleaned.length >= 80) return \"tx_signature\";\n    if (cleaned.length >= 32 && cleaned.length <= 44) return \"round_pda\";\n  }\n\n  if (trimmed.startsWith(\"@\")) return \"telegram_username\";\n\n  if (REFERRAL_CODE_PATTERN.test(cleaned)) return \"referral_code\";\n\n  if (USERNAME_PATTERN.test(cleaned)) return \"username\";\n\n  return \"free_text\";\n}\n\nfunction clampLimit(requested: number | undefined): number {\n  const fallback = requested ?? PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT;\n  if (!Number.isFinite(fallback)) return PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT;\n  const floored = Math.floor(fallback);\n  return Math.max(\n    1,\n    Math.min(PEEK_SEARCH_MAX_PER_GROUP_LIMIT, floored),\n  );\n}\n\nfunction emptyGroups(): ReadonlyArray<PeekSearchGroup> {\n  const entityTypes: ReadonlyArray<PeekSearchEntityType> = [\n    \"user\",\n    \"referral\",\n    \"linked_account\",\n    \"round\",\n    \"transaction\",\n    \"queue_event\",\n  ];\n  return entityTypes.map((entityType) => ({\n    entityType,\n    results: [],\n    truncated: false,\n  }));\n}\n\ntype UserRow = {\n  userId: string;\n  username: string | null;","numLines":120,"startLine":1,"totalLines":497}}}
