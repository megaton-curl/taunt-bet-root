{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vqyhjxvz4Ca3ACWg5wfvrB","type":"tool_result","content":"120\t  username: string | null;\n121\t  wallet: string;\n122\t  joinedAt: string;\n123\t};\n124\t\n125\ttype ReferralCodeRow = {\n126\t  code: string;\n127\t  userId: string;\n128\t  wallet: string;\n129\t};\n130\t\n131\ttype LinkedAccountRow = {\n132\t  userId: string;\n133\t  provider: string;\n134\t  providerAccountId: string;\n135\t  telegramUsername: string | null;\n136\t  status: string;\n137\t};\n138\t\n139\ttype RoundRow = {\n140\t  pda: string;\n141\t  game: string;\n142\t  matchId: string;\n143\t  phase: string;\n144\t  creator: string | null;\n145\t};\n146\t\n147\ttype TransactionRow = {\n148\t  id: string;\n149\t  txSig: string;\n150\t  game: string;\n151\t  matchId: string;\n152\t  txType: string;\n153\t  wallet: string;\n154\t  amountLamports: string;\n155\t  createdAt: string;\n156\t};\n157\t\n158\ttype QueueEventRow = {\n159\t  id: string;\n160\t  eventType: string;\n161\t  status: string;\n162\t  attempts: number;\n163\t  scheduledAt: string;\n164\t};\n165\t\n166\tasync function searchUsers(\n167\t  sql: Sql,\n168\t  query: string,\n169\t  limit: number,\n170\t): Promise<PeekSearchResult[]> {\n171\t  const exact = query;\n172\t  const like = `%${query}%`;\n173\t  const rows = await sql<UserRow[]>`\n174\t    select\n175\t      user_id as \"userId\",\n176\t      username,\n177\t      wallet,\n178\t      created_at::text as \"joinedAt\"\n179\t    from player_profiles\n180\t    where user_id = ${exact}\n181\t       or wallet = ${exact}\n182\t       or lower(username) = lower(${exact})\n183\t       or user_id ilike ${like}\n184\t       or wallet ilike ${like}\n185\t       or coalesce(username, '') ilike ${like}\n186\t    order by created_at desc\n187\t    limit ${limit + 1}\n188\t  `;\n189\t  return rows.slice(0, limit).map((row) => ({\n190\t    entityType: \"user\" as const,\n191\t    id: row.userId,\n192\t    label: row.username ?? row.userId,\n193\t    sublabel: row.wallet,\n194\t    context: `joined ${row.joinedAt}`,\n195\t    href: `/users/${encodeURIComponent(row.userId)}`,\n196\t  }));\n197\t}\n198\t\n199\tasync function searchReferralCodes(\n200\t  sql: Sql,\n201\t  query: string,\n202\t  limit: number,\n203\t): Promise<PeekSearchResult[]> {\n204\t  const exact = query;\n205\t  const like = `%${query}%`;\n206\t  const rows = await sql<ReferralCodeRow[]>`\n207\t    select\n208\t      code,\n209\t      user_id as \"userId\",\n210\t      wallet\n211\t    from referral_codes\n212\t    where upper(code) = upper(${exact})\n213\t       or code ilike ${like}\n214\t       or user_id = ${exact}\n215\t       or wallet = ${exact}\n216\t    order by created_at desc\n217\t    limit ${limit + 1}\n218\t  `;\n219\t  return rows.slice(0, limit).map((row) => ({\n220\t    entityType: \"referral\" as const,\n221\t    id: row.code,\n222\t    label: row.code,\n223\t    sublabel: row.userId,\n224\t    context: `wallet ${row.wallet}`,\n225\t    href: `/users/${encodeURIComponent(row.userId)}`,\n226\t  }));\n227\t}\n228\t\n229\tasync function searchLinkedAccounts(\n230\t  sql: Sql,\n231\t  query: string,\n232\t  limit: number,\n233\t): Promise<PeekSearchResult[]> {\n234\t  const trimmed = query.startsWith(\"@\") ? query.slice(1) : query;\n235\t  const exact = trimmed;\n236\t  const like = `%${trimmed}%`;\n237\t  const rows = await sql<LinkedAccountRow[]>`\n238\t    select\n239\t      user_id as \"userId\",\n240\t      provider,\n241\t      provider_account_id as \"providerAccountId\",\n242\t      nullif(metadata_json->>'telegramUsername', '') as \"telegramUsername\",\n243\t      status\n244\t    from linked_accounts\n245\t    where status = 'active'\n246\t      and (\n247\t        provider_account_id = ${exact}\n248\t        or metadata_json->>'telegramUsername' = ${exact}\n249\t        or provider_account_id ilike ${like}\n250\t        or coalesce(metadata_json->>'telegramUsername', '') ilike ${like}\n251\t      )\n252\t    order by linked_at desc\n253\t    limit ${limit + 1}\n254\t  `;\n255\t  return rows.slice(0, limit).map((row) => {\n256\t    const display = row.telegramUsername\n257\t      ? `@${row.telegramUsername}`\n258\t      : row.providerAccountId;\n259\t    return {\n260\t      entityType: \"linked_account\" as const,\n261\t      id: `${row.provider}:${row.providerAccountId}`,\n262\t      label: display,\n263\t      sublabel: row.userId,\n264\t      context: `${row.provider} (${row.status})`,\n265\t      href: `/users/${encodeURIComponent(row.userId)}`,\n266\t    };\n267\t  });\n268\t}\n269\t\n270\tasync function searchRounds(\n271\t  sql: Sql,\n272\t  query: string,\n273\t  limit: number,\n274\t): Promise<PeekSearchResult[]> {\n275\t  const exact = query;\n276\t  const flipPotRows = await sql<RoundRow[]>`\n277\t    select\n278\t      pda,\n279\t      game,\n280\t      match_id as \"matchId\",\n281\t      phase,\n282\t      creator\n283\t    from rounds\n284\t    where pda = ${exact}\n285\t       or match_id = ${exact}\n286\t       or creator = ${exact}\n287\t    order by created_at desc\n288\t    limit ${limit + 1}\n289\t  `;\n290\t  const closeCallRows = await sql<RoundRow[]>`\n291\t    select\n292\t      pda,\n293\t      'closecall'::text as \"game\",\n294\t      round_id as \"matchId\",\n295\t      phase,\n296\t      null::text as \"creator\"\n297\t    from closecall_rounds\n298\t    where pda = ${exact}\n299\t       or round_id = ${exact}\n300\t    order by created_at desc\n301\t    limit ${limit + 1}\n302\t  `;\n303\t  const combined = [...flipPotRows, ...closeCallRows];\n304\t  return combined.slice(0, limit).map((row) => ({\n305\t    entityType: \"round\" as const,\n306\t    id: row.pda,\n307\t    label: row.matchId,\n308\t    sublabel: `${row.game} • ${row.phase}`,\n309\t    context: row.creator ? `creator ${row.creator}` : null,\n310\t    href: `/games/${encodeURIComponent(row.game)}/rounds/${encodeURIComponent(row.pda)}`,\n311\t  }));\n312\t}\n313\t\n314\tasync function searchTransactions(\n315\t  sql: Sql,\n316\t  query: string,\n317\t  limit: number,\n318\t): Promise<PeekSearchResult[]> {\n319\t  const exact = query;\n320\t  const rows = await sql<TransactionRow[]>`\n321\t    select\n322\t      id::text as \"id\",\n323\t      tx_sig as \"txSig\",\n324\t      game,\n325\t      match_id as \"matchId\",\n326\t      tx_type as \"txType\",\n327\t      wallet,\n328\t      amount_lamports::text as \"amountLamports\",\n329\t      created_at::text as \"createdAt\"\n330\t    from transactions\n331\t    where tx_sig = ${exact}\n332\t       or match_id = ${exact}\n333\t       or wallet = ${exact}\n334\t    order by created_at desc\n335\t    limit ${limit + 1}\n336\t  `;\n337\t  return rows.slice(0, limit).map((row) => ({\n338\t    entityType: \"transaction\" as const,\n339\t    id: row.id,\n340\t    label: row.txSig,\n341\t    sublabel: `${row.game} • ${row.txType}`,\n342\t    context: `wallet ${row.wallet} • ${row.amountLamports} lamports`,\n343\t    href: `/games/${encodeURIComponent(row.game)}/rounds/${encodeURIComponent(row.matchId)}`,\n344\t  }));\n345\t}\n346\t\n347\tasync function searchQueueEvents(\n348\t  sql: Sql,\n349\t  query: string,\n350\t  limit: number,\n351\t): Promise<PeekSearchResult[]> {\n352\t  if (!/^\\d+$/.test(query)) return [];\n353\t  const numericId = query;\n354\t  const rows = await sql<QueueEventRow[]>`\n355\t    select\n356\t      id::text as \"id\",\n357\t      event_type as \"eventType\",\n358\t      status,\n359\t      attempts,\n360\t      scheduled_at::text as \"scheduledAt\"\n361\t    from event_queue\n362\t    where id::text = ${numericId}\n363\t    order by created_at desc\n364\t    limit ${limit + 1}\n365\t  `;\n366\t  return rows.slice(0, limit).map((row) => ({\n367\t    entityType: \"queue_event\" as const,\n368\t    id: row.id,\n369\t    label: `#${row.id}`,\n370\t    sublabel: `${row.eventType} • ${row.status}`,\n371\t    context: `attempts ${row.attempts} • scheduled ${row.scheduledAt}`,\n372\t    href: `/operations/queue?id=${encodeURIComponent(row.id)}`,\n373\t  }));\n374\t}\n375\t\n376\tasync function defaultPeekSearchAudit(input: {\n377\t  actorEmail: string;\n378\t  query: string;\n379\t  queryClass: PeekSearchQueryClass;\n380\t  totalResults: number;\n381\t  route: string | null;\n382\t  requestId: string | null;\n383\t}): Promise<void> {\n384\t  await writePeekAuditEvent({\n385\t    eventType: \"peek.search\",\n386\t    payload: {\n387\t      actorEmail: input.actorEmail,\n388\t      route: input.route,\n389\t      actionId: \"peek.search\",\n390\t      resourceType: \"search\",\n391\t      resourceId: null,\n392\t      filterSummary: `query_class=${input.queryClass}`,\n393\t      resultCount: input.totalResults,\n394\t      requestId: input.requestId,\n395\t      rejectionReason: null,\n396\t      changes: null,\n397\t    },\n398\t  });\n399\t}\n400\t\n401\texport async function getUniversalSearchResults(\n402\t  options: UniversalSearchOptions,\n403\t): Promise<PeekSearchResponse> {\n404\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n405\t  const perGroupLimit = clampLimit(options.perGroupLimit);\n406\t  const now = options.now ?? new Date();\n407\t  const generatedAt = now.toISOString();\n408\t  const trimmed = options.query.trim();\n409\t  const queryClass = classifyPeekSearchQuery(trimmed);\n410\t\n411\t  if (trimmed.length === 0) {\n412\t    const response: PeekSearchResponse = {\n413\t      query: trimmed,\n414\t      queryClass,\n415\t      groups: emptyGroups(),\n416\t      totalResults: 0,\n417\t      perGroupLimit,\n418\t      generatedAt,\n419\t    };"}]},"parent_tool_use_id":null,"session_id":"aa22a004-7967-4272-b3ce-42c86f057c37","uuid":"8d042d65-2d42-4043-af60-64613e2f4066","timestamp":"2026-04-25T12:04:12.839Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/universal-search.ts","content":"  username: string | null;\n  wallet: string;\n  joinedAt: string;\n};\n\ntype ReferralCodeRow = {\n  code: string;\n  userId: string;\n  wallet: string;\n};\n\ntype LinkedAccountRow = {\n  userId: string;\n  provider: string;\n  providerAccountId: string;\n  telegramUsername: string | null;\n  status: string;\n};\n\ntype RoundRow = {\n  pda: string;\n  game: string;\n  matchId: string;\n  phase: string;\n  creator: string | null;\n};\n\ntype TransactionRow = {\n  id: string;\n  txSig: string;\n  game: string;\n  matchId: string;\n  txType: string;\n  wallet: string;\n  amountLamports: string;\n  createdAt: string;\n};\n\ntype QueueEventRow = {\n  id: string;\n  eventType: string;\n  status: string;\n  attempts: number;\n  scheduledAt: string;\n};\n\nasync function searchUsers(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const exact = query;\n  const like = `%${query}%`;\n  const rows = await sql<UserRow[]>`\n    select\n      user_id as \"userId\",\n      username,\n      wallet,\n      created_at::text as \"joinedAt\"\n    from player_profiles\n    where user_id = ${exact}\n       or wallet = ${exact}\n       or lower(username) = lower(${exact})\n       or user_id ilike ${like}\n       or wallet ilike ${like}\n       or coalesce(username, '') ilike ${like}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => ({\n    entityType: \"user\" as const,\n    id: row.userId,\n    label: row.username ?? row.userId,\n    sublabel: row.wallet,\n    context: `joined ${row.joinedAt}`,\n    href: `/users/${encodeURIComponent(row.userId)}`,\n  }));\n}\n\nasync function searchReferralCodes(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const exact = query;\n  const like = `%${query}%`;\n  const rows = await sql<ReferralCodeRow[]>`\n    select\n      code,\n      user_id as \"userId\",\n      wallet\n    from referral_codes\n    where upper(code) = upper(${exact})\n       or code ilike ${like}\n       or user_id = ${exact}\n       or wallet = ${exact}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => ({\n    entityType: \"referral\" as const,\n    id: row.code,\n    label: row.code,\n    sublabel: row.userId,\n    context: `wallet ${row.wallet}`,\n    href: `/users/${encodeURIComponent(row.userId)}`,\n  }));\n}\n\nasync function searchLinkedAccounts(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const trimmed = query.startsWith(\"@\") ? query.slice(1) : query;\n  const exact = trimmed;\n  const like = `%${trimmed}%`;\n  const rows = await sql<LinkedAccountRow[]>`\n    select\n      user_id as \"userId\",\n      provider,\n      provider_account_id as \"providerAccountId\",\n      nullif(metadata_json->>'telegramUsername', '') as \"telegramUsername\",\n      status\n    from linked_accounts\n    where status = 'active'\n      and (\n        provider_account_id = ${exact}\n        or metadata_json->>'telegramUsername' = ${exact}\n        or provider_account_id ilike ${like}\n        or coalesce(metadata_json->>'telegramUsername', '') ilike ${like}\n      )\n    order by linked_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => {\n    const display = row.telegramUsername\n      ? `@${row.telegramUsername}`\n      : row.providerAccountId;\n    return {\n      entityType: \"linked_account\" as const,\n      id: `${row.provider}:${row.providerAccountId}`,\n      label: display,\n      sublabel: row.userId,\n      context: `${row.provider} (${row.status})`,\n      href: `/users/${encodeURIComponent(row.userId)}`,\n    };\n  });\n}\n\nasync function searchRounds(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const exact = query;\n  const flipPotRows = await sql<RoundRow[]>`\n    select\n      pda,\n      game,\n      match_id as \"matchId\",\n      phase,\n      creator\n    from rounds\n    where pda = ${exact}\n       or match_id = ${exact}\n       or creator = ${exact}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  const closeCallRows = await sql<RoundRow[]>`\n    select\n      pda,\n      'closecall'::text as \"game\",\n      round_id as \"matchId\",\n      phase,\n      null::text as \"creator\"\n    from closecall_rounds\n    where pda = ${exact}\n       or round_id = ${exact}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  const combined = [...flipPotRows, ...closeCallRows];\n  return combined.slice(0, limit).map((row) => ({\n    entityType: \"round\" as const,\n    id: row.pda,\n    label: row.matchId,\n    sublabel: `${row.game} • ${row.phase}`,\n    context: row.creator ? `creator ${row.creator}` : null,\n    href: `/games/${encodeURIComponent(row.game)}/rounds/${encodeURIComponent(row.pda)}`,\n  }));\n}\n\nasync function searchTransactions(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const exact = query;\n  const rows = await sql<TransactionRow[]>`\n    select\n      id::text as \"id\",\n      tx_sig as \"txSig\",\n      game,\n      match_id as \"matchId\",\n      tx_type as \"txType\",\n      wallet,\n      amount_lamports::text as \"amountLamports\",\n      created_at::text as \"createdAt\"\n    from transactions\n    where tx_sig = ${exact}\n       or match_id = ${exact}\n       or wallet = ${exact}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => ({\n    entityType: \"transaction\" as const,\n    id: row.id,\n    label: row.txSig,\n    sublabel: `${row.game} • ${row.txType}`,\n    context: `wallet ${row.wallet} • ${row.amountLamports} lamports`,\n    href: `/games/${encodeURIComponent(row.game)}/rounds/${encodeURIComponent(row.matchId)}`,\n  }));\n}\n\nasync function searchQueueEvents(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  if (!/^\\d+$/.test(query)) return [];\n  const numericId = query;\n  const rows = await sql<QueueEventRow[]>`\n    select\n      id::text as \"id\",\n      event_type as \"eventType\",\n      status,\n      attempts,\n      scheduled_at::text as \"scheduledAt\"\n    from event_queue\n    where id::text = ${numericId}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => ({\n    entityType: \"queue_event\" as const,\n    id: row.id,\n    label: `#${row.id}`,\n    sublabel: `${row.eventType} • ${row.status}`,\n    context: `attempts ${row.attempts} • scheduled ${row.scheduledAt}`,\n    href: `/operations/queue?id=${encodeURIComponent(row.id)}`,\n  }));\n}\n\nasync function defaultPeekSearchAudit(input: {\n  actorEmail: string;\n  query: string;\n  queryClass: PeekSearchQueryClass;\n  totalResults: number;\n  route: string | null;\n  requestId: string | null;\n}): Promise<void> {\n  await writePeekAuditEvent({\n    eventType: \"peek.search\",\n    payload: {\n      actorEmail: input.actorEmail,\n      route: input.route,\n      actionId: \"peek.search\",\n      resourceType: \"search\",\n      resourceId: null,\n      filterSummary: `query_class=${input.queryClass}`,\n      resultCount: input.totalResults,\n      requestId: input.requestId,\n      rejectionReason: null,\n      changes: null,\n    },\n  });\n}\n\nexport async function getUniversalSearchResults(\n  options: UniversalSearchOptions,\n): Promise<PeekSearchResponse> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const perGroupLimit = clampLimit(options.perGroupLimit);\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n  const trimmed = options.query.trim();\n  const queryClass = classifyPeekSearchQuery(trimmed);\n\n  if (trimmed.length === 0) {\n    const response: PeekSearchResponse = {\n      query: trimmed,\n      queryClass,\n      groups: emptyGroups(),\n      totalResults: 0,\n      perGroupLimit,\n      generatedAt,\n    };","numLines":300,"startLine":120,"totalLines":497}}}
