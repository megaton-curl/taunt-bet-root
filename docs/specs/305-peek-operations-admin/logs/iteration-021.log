\"Rewards\",\n      \"Challenges\",\n      \"Transactions\",\n      \"Attention\",\n    ];\n    for (const heading of expectedHeadings) {\n      expect(\n        screen.getByRole(\"heading\", { level: 2, name: heading }),\n      ).toBeInTheDocument();\n    }\n  });\n\n  it(\"populated: renders each section's data — identity, linked accounts, referrals, games, rewards, challenges, transactions\", () => {\n    render(<UserDetailView detail={buildFullDetail()} />);\n\n    // Identity values are rendered.\n    expect(screen.getByText(\"u-1\")).toBeInTheDocument();\n    expect(screen.getByText(\"https://example.com/a.png\")).toBeInTheDocument();\n    expect(screen.getByText(\"1.50\")).toBeInTheDocument();\n\n    // KOL rate block surfaces the rate bps + ops actor.\n    expect(screen.getByText(\"250\")).toBeInTheDocument();\n    expect(screen.getByText(\"ops@example.com\")).toBeInTheDocument();\n\n    // Outbound referees are linkified to per-user pages.\n    const refereeLink = screen.getByRole(\"link\", { name: \"u-2\" });\n    expect(refereeLink).toHaveAttribute(\"href\", \"/users/u-2\");\n\n    // Game entries linkify to the round-detail page.\n    const gameLink = screen.getByRole(\"link\", { name: \"match-1\" });\n    expect(gameLink).toHaveAttribute(\n      \"href\",\n      \"/games/flipyou/rounds/pda-1\",\n    );\n\n    // Challenge counts surface the read-only summary.\n    expect(screen.getByText(\"3\")).toBeInTheDocument();\n  });\n\n  it(\"populated: every active attention flag becomes a chip inside the attention strip aside\", () => {\n    render(<UserDetailView detail={buildFullDetail()} />);\n\n    const strip = screen.getByRole(\"complementary\", { name: \"Attention\" });\n    expect(strip).toHaveTextContent(\"Attention:\");\n    // 4 flags are on (failedClaim, deadQueueEvent, activeFraudFlag,\n    // pendingSolCratePayout); suspiciousReferralLoop is off.\n    expect(within(strip).getByText(\"Failed claim\")).toBeInTheDocument();\n    expect(within(strip).getByText(\"Dead queue event\")).toBeInTheDocument();\n    expect(within(strip).getByText(\"Active fraud flag\")).toBeInTheDocument();\n    expect(within(strip).getByText(\"Pending SOL crate payout\")).toBeInTheDocument();\n    expect(\n      within(strip).queryByText(\"Suspicious referral self/loop\"),\n    ).toBeNull();\n  });\n\n  it(\"populated: the attention SECTION (inside DetailPanel) lists every flag with its operator description\", () => {\n    render(\n      <UserDetailView\n        detail={buildFullDetail({\n          attention: {\n            failedClaim: false,\n            deadQueueEvent: false,\n            activeFraudFlag: false,\n            pendingSolCratePayout: false,\n            suspiciousReferralLoop: true,\n          },\n        })}\n      />,\n    );\n\n    // The strip has only the loop flag this time; suspiciousReferralLoop has\n    // a long description visible in the body.\n    expect(\n      screen.getByText(\n        \"This user appears as both referrer and referee on a referral_links row.\",\n      ),\n    ).toBeInTheDocument();\n  });\n\n  it(\"populated: applies the activeSectionId to the detail nav so the deep link can pre-highlight a section\", () => {\n    render(\n      <UserDetailView\n        detail={buildFullDetail()}\n        activeSectionId=\"rewards\"\n      />,\n    );\n\n    const nav = screen.getByRole(\"navigation\", { name: \"User detail sections\" });\n    const rewardsLink = within(nav).getByRole(\"link\", { name: \"Rewards\" });\n    expect(rewardsLink).toHaveAttribute(\"aria-current\", \"true\");\n  });\n\n  it(\"sparse: no attention flags → the attention strip aside is suppressed (no false-warning band)\", () => {\n    render(<UserDetailView detail={buildSparseDetail()} />);\n\n    expect(\n      screen.queryByRole(\"complementary\", { name: \"Attention\" }),\n    ).toBeNull();\n  });\n\n  it(\"sparse: empty list sections render operator-readable empty states instead of empty tables\", () => {\n    render(<UserDetailView detail={buildSparseDetail()} />);\n\n    // Linked accounts section: explicit operator copy.\n    expect(\n      screen.getByText(\n        \"This user has not linked any external provider accounts.\",\n      ),\n    ).toBeInTheDocument();\n\n    // Games section: cross-game operator copy.\n    expect(\n      screen.getByText(\n        \"This user has not entered any FlipYou, Pot Shot, or Close Call rounds.\",\n      ),\n    ).toBeInTheDocument();\n\n    // Transactions section.\n    expect(\n      screen.getByText(\n        \"This user has no on-chain transaction records yet.\",\n      ),\n    ).toBeInTheDocument();\n\n    // Challenges section.\n    expect(\n      screen.getByText(\n        \"This user has not been assigned any challenges yet.\",\n      ),\n    ).toBeInTheDocument();\n\n    // KOL rate empty state — non-KOL users see this body copy.\n    expect(screen.getByText(\"No KOL rate configured for this user.\")).toBeInTheDocument();\n\n    // Attention SECTION (inside DetailPanel) shows the no-flags empty state.\n    expect(\n      screen.getByText(\"Nothing currently flagged for review on this user.\"),\n    ).toBeInTheDocument();\n  });\n\n  it(\"sparse: identity heading falls back to user_id when username is null\", () => {\n    render(<UserDetailView detail={buildSparseDetail()} />);\n\n    expect(screen.getByRole(\"heading\", { level: 1 })).toHaveTextContent(\n      \"u-sparse\",\n    );\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
