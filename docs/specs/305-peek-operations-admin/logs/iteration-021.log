{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M9XgDFBhZR77SXvXrY7PZy","type":"tool_result","content":"1\timport \"./globals.css\";\n2\timport type { ReactNode } from \"react\";\n3\timport { headers } from \"next/headers\";\n4\timport {\n5\t  AdminShell,\n6\t  type AdminShellAccessIssue,\n7\t} from \"../src/components/admin-shell\";\n8\timport { VERIFIED_ACCESS_EMAIL_HEADER } from \"../src/server/cloudflare-access\";\n9\timport {\n10\t  getPeekActorContext,\n11\t} from \"../src/server/access-policy\";\n12\timport { getVisibleNavItemsForRole } from \"../src/server/admin-shell-nav\";\n13\t\n14\texport default async function RootLayout({ children }: { children: ReactNode }) {\n15\t  const requestHeaders = await headers();\n16\t  const verifiedEmail = requestHeaders.get(VERIFIED_ACCESS_EMAIL_HEADER);\n17\t  const actor = await getPeekActorContext();\n18\t\n19\t  let accessIssue: AdminShellAccessIssue | null = null;\n20\t  if (!verifiedEmail) {\n21\t    accessIssue = \"no-identity\";\n22\t  } else if (!actor) {\n23\t    accessIssue = \"no-role\";\n24\t  }\n25\t\n26\t  const navItems = getVisibleNavItemsForRole(actor?.role ?? null);\n27\t\n28\t  return (\n29\t    <html lang=\"en\">\n30\t      <body>\n31\t        <AdminShell actor={actor} navItems={navItems} accessIssue={accessIssue}>\n32\t          {children}\n33\t        </AdminShell>\n34\t      </body>\n35\t    </html>\n36\t  );\n37\t}\n38\t"}]},"parent_tool_use_id":null,"session_id":"aa22a004-7967-4272-b3ce-42c86f057c37","uuid":"9922a014-3b72-4ec0-b24a-1249a376ca59","timestamp":"2026-04-25T12:06:07.154Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/app/layout.tsx","content":"import \"./globals.css\";\nimport type { ReactNode } from \"react\";\nimport { headers } from \"next/headers\";\nimport {\n  AdminShell,\n  type AdminShellAccessIssue,\n} from \"../src/components/admin-shell\";\nimport { VERIFIED_ACCESS_EMAIL_HEADER } from \"../src/server/cloudflare-access\";\nimport {\n  getPeekActorContext,\n} from \"../src/server/access-policy\";\nimport { getVisibleNavItemsForRole } from \"../src/server/admin-shell-nav\";\n\nexport default async function RootLayout({ children }: { children: ReactNode }) {\n  const requestHeaders = await headers();\n  const verifiedEmail = requestHeaders.get(VERIFIED_ACCESS_EMAIL_HEADER);\n  const actor = await getPeekActorContext();\n\n  let accessIssue: AdminShellAccessIssue | null = null;\n  if (!verifiedEmail) {\n    accessIssue = \"no-identity\";\n  } else if (!actor) {\n    accessIssue = \"no-role\";\n  }\n\n  const navItems = getVisibleNavItemsForRole(actor?.role ?? null);\n\n  return (\n    <html lang=\"en\">\n      <body>\n        <AdminShell actor={actor} navItems={navItems} accessIssue={accessIssue}>\n          {children}\n        </AdminShell>\n      </body>\n    </html>\n  );\n}\n","numLines":38,"startLine":1,"totalLines":38}}}
