{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018atbqtQe8VbjLAdXYnAoEv","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport type { Sql } from \"postgres\";\n3\timport {\n4\t  COMMAND_CENTER_DEFAULTS,\n5\t  getCommandCenterAttention,\n6\t} from \"../get-command-center-attention\";\n7\timport type { PeekCommandCenterAttentionId } from \"../../../../lib/types/peek\";\n8\t\n9\ttype SqlCall = {\n10\t  text: string;\n11\t  values: ReadonlyArray<unknown>;\n12\t};\n13\t\n14\ttype ResponseValue = ReadonlyArray<{ value: number | string }> | Error;\n15\t\n16\ttype SqlMock = {\n17\t  sql: Sql;\n18\t  calls: ReadonlyArray<SqlCall>;\n19\t};\n20\t\n21\t// Build a SQL mock that returns a sequence of responses, one per call.\n22\t// Each response is either a row array (success) or an Error (rejection).\n23\tfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n24\t  const calls: SqlCall[] = [];\n25\t  let cursor = 0;\n26\t\n27\t  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n28\t    const text = [...strings].join(\"?\");\n29\t    calls.push({ text, values: [...values] });\n30\t    const next = responses[cursor++];\n31\t    if (next instanceof Error) {\n32\t      return Promise.reject(next);\n33\t    }\n34\t    return Promise.resolve(next ?? []);\n35\t  };\n36\t\n37\t  // Cast through unknown — only the tagged-template surface is exercised here.\n38\t  const sql = fn as unknown as Sql;\n39\t  return { sql, calls };\n40\t}\n41\t\n42\tconst ALL_IDS: ReadonlyArray<PeekCommandCenterAttentionId> = [\n43\t  \"failed_claims\",\n44\t  \"dead_queue_events\",\n45\t  \"stuck_rounds_flipyou_potshot\",\n46\t  \"stuck_rounds_closecall\",\n47\t  \"pending_sol_crate_payouts\",\n48\t  \"stale_active_dogpile_events\",\n49\t  \"high_value_exports_24h\",\n50\t];\n51\t\n52\tdescribe(\"getCommandCenterAttention\", () => {\n53\t  it(\"populated: returns one PeekMetric per attention id with FR-4 bookkeeping\", async () => {\n54\t    const mock = createSqlMock([\n55\t      [{ value: 3 }],\n56\t      [{ value: 1 }],\n57\t      [{ value: 5 }],\n58\t      [{ value: 2 }],\n59\t      [{ value: 4 }],\n60\t      [{ value: 6 }],\n61\t      [{ value: 7 }],\n62\t    ]);\n63\t    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n64\t\n65\t    const result = await getCommandCenterAttention({ sql: mock.sql, now });\n66\t\n67\t    expect(result.generatedAt).toBe(\"2026-04-25T10:00:00.000Z\");\n68\t    expect(result.metrics).toHaveLength(7);\n69\t    expect(result.metrics.map((m) => m.id)).toEqual(ALL_IDS);\n70\t\n71\t    for (const metric of result.metrics) {\n72\t      expect(metric.asOf).toBe(\"2026-04-25T10:00:00.000Z\");\n73\t      expect(metric.freshness).toBe(\"live\");\n74\t      expect(metric.label.length).toBeGreaterThan(0);\n75\t      expect(metric.definition.length).toBeGreaterThan(0);\n76\t      expect(metric.source.length).toBeGreaterThan(0);\n77\t      expect(metric.windowLabel.length).toBeGreaterThan(0);\n78\t      expect(metric.drilldownHref).not.toBeNull();\n79\t    }\n80\t\n81\t    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n82\t    expect(byId.get(\"failed_claims\")?.value).toBe(3);\n83\t    expect(byId.get(\"failed_claims\")?.valueDisplay).toBe(\"3\");\n84\t    expect(byId.get(\"failed_claims\")?.source).toBe(\"referral_claims\");\n85\t    expect(byId.get(\"dead_queue_events\")?.value).toBe(1);\n86\t    expect(byId.get(\"stuck_rounds_flipyou_potshot\")?.value).toBe(5);\n87\t    expect(byId.get(\"stuck_rounds_closecall\")?.value).toBe(2);\n88\t    expect(byId.get(\"pending_sol_crate_payouts\")?.value).toBe(4);\n89\t    expect(byId.get(\"stale_active_dogpile_events\")?.value).toBe(6);\n90\t    expect(byId.get(\"high_value_exports_24h\")?.value).toBe(7);\n91\t    expect(byId.get(\"high_value_exports_24h\")?.source).toBe(\"operator_events\");\n92\t  });\n93\t\n94\t  it(\"populated (large counts): formats valueDisplay with a thousands separator\", async () => {\n95\t    const mock = createSqlMock([\n96\t      [{ value: 1234 }],\n97\t      [{ value: 0 }],\n98\t      [{ value: 0 }],\n99\t      [{ value: 0 }],\n100\t      [{ value: 0 }],\n101\t      [{ value: 0 }],\n102\t      [{ value: 0 }],\n103\t    ]);\n104\t\n105\t    const result = await getCommandCenterAttention({ sql: mock.sql });\n106\t\n107\t    const failed = result.metrics.find((m) => m.id === \"failed_claims\");\n108\t    expect(failed?.value).toBe(1234);\n109\t    expect(failed?.valueDisplay).toBe(\"1,234\");\n110\t  });\n111\t\n112\t  it(\"populated (string count): coerces a postgres ::text count to a number\", async () => {\n113\t    // postgres-js can return numeric counts as strings depending on driver\n114\t    // configuration; the query module must coerce them back to numbers.\n115\t    const mock = createSqlMock([\n116\t      [{ value: \"12\" }],\n117\t      [{ value: 0 }],\n118\t      [{ value: 0 }],\n119\t      [{ value: 0 }],\n120\t      [{ value: 0 }],\n121\t      [{ value: 0 }],\n122\t      [{ value: 0 }],\n123\t    ]);\n124\t\n125\t    const result = await getCommandCenterAttention({ sql: mock.sql });\n126\t\n127\t    const failed = result.metrics.find((m) => m.id === \"failed_claims\");\n128\t    expect(failed?.value).toBe(12);\n129\t    expect(failed?.valueDisplay).toBe(\"12\");\n130\t  });\n131\t\n132\t  it(\"sparse: every empty row coerces to a zero count without dropping the metric\", async () => {\n133\t    const mock = createSqlMock([[], [], [], [], [], [], []]);\n134\t\n135\t    const result = await getCommandCenterAttention({ sql: mock.sql });\n136\t\n137\t    expect(result.metrics).toHaveLength(7);\n138\t    for (const metric of result.metrics) {\n139\t      expect(metric.value).toBe(0);\n140\t      expect(metric.valueDisplay).toBe(\"0\");\n141\t    }\n142\t  });\n143\t\n144\t  it(\"threshold overrides: surface in the windowLabel and definition copy\", async () => {\n145\t    const mock = createSqlMock([[], [], [], [], [], [], []]);\n146\t\n147\t    const result = await getCommandCenterAttention({\n148\t      sql: mock.sql,\n149\t      thresholds: {\n150\t        stuckRoundsAgeMinutes: 10,\n151\t        stuckRoundsMaxSettleAttempts: 6,\n152\t        stuckCloseCallAgeMinutes: 7,\n153\t        exportWindowHours: 12,\n154\t        exportRowCountThreshold: 250,\n155\t      },\n156\t    });\n157\t\n158\t    const stuck = result.metrics.find(\n159\t      (m) => m.id === \"stuck_rounds_flipyou_potshot\",\n160\t    );\n161\t    expect(stuck?.windowLabel).toContain(\"10m\");\n162\t    expect(stuck?.windowLabel).toContain(\"> 6\");\n163\t\n164\t    const cc = result.metrics.find((m) => m.id === \"stuck_rounds_closecall\");\n165\t    expect(cc?.windowLabel).toContain(\"7m\");\n166\t\n167\t    const exports = result.metrics.find((m) => m.id === \"high_value_exports_24h\");\n168\t    expect(exports?.windowLabel).toContain(\"Last 12h\");\n169\t    expect(exports?.definition).toContain(\"12h\");\n170\t    expect(exports?.definition).toContain(\"250\");\n171\t  });\n172\t\n173\t  it(\"default thresholds: match the published COMMAND_CENTER_DEFAULTS\", async () => {\n174\t    const mock = createSqlMock([[], [], [], [], [], [], []]);\n175\t\n176\t    const result = await getCommandCenterAttention({ sql: mock.sql });\n177\t\n178\t    const stuck = result.metrics.find(\n179\t      (m) => m.id === \"stuck_rounds_flipyou_potshot\",\n180\t    );\n181\t    expect(stuck?.windowLabel).toContain(\n182\t      `${COMMAND_CENTER_DEFAULTS.stuckRoundsAgeMinutes}m`,\n183\t    );\n184\t    expect(stuck?.windowLabel).toContain(\n185\t      `> ${COMMAND_CENTER_DEFAULTS.stuckRoundsMaxSettleAttempts}`,\n186\t    );\n187\t\n188\t    const exports = result.metrics.find((m) => m.id === \"high_value_exports_24h\");\n189\t    expect(exports?.windowLabel).toContain(\n190\t      `Last ${COMMAND_CENTER_DEFAULTS.exportWindowHours}h`,\n191\t    );\n192\t  });\n193\t\n194\t  it(\"load-error: a rejected query propagates so the caller can render the alert state\", async () => {\n195\t    // Promise.all rejects on the first failure; the page-level try/catch\n196\t    // surfaces the error as `attentionError`. The query module must not\n197\t    // silently swallow the failure.\n198\t    const mock = createSqlMock([\n199\t      [{ value: 0 }],\n200\t      new Error(\"connection refused\"),\n201\t      [{ value: 0 }],\n202\t      [{ value: 0 }],\n203\t      [{ value: 0 }],\n204\t      [{ value: 0 }],\n205\t      [{ value: 0 }],\n206\t    ]);\n207\t\n208\t    await expect(\n209\t      getCommandCenterAttention({ sql: mock.sql }),\n210\t    ).rejects.toThrowError(\"connection refused\");\n211\t  });\n212\t\n213\t  it(\"query bounded: every SQL call returns a single integer count, never row data\", async () => {\n214\t    const mock = createSqlMock([\n215\t      [{ value: 0 }],\n216\t      [{ value: 0 }],\n217\t      [{ value: 0 }],\n218\t      [{ value: 0 }],\n219\t      [{ value: 0 }],\n220\t      [{ value: 0 }],\n221\t      [{ value: 0 }],\n222\t    ]);\n223\t\n224\t    await getCommandCenterAttention({ sql: mock.sql });\n225\t\n226\t    expect(mock.calls).toHaveLength(7);\n227\t    for (const call of mock.calls) {\n228\t      // Every command-center query is a count(*) projection — never row data.\n229\t      expect(call.text).toMatch(/select\\s+count\\(\\*\\)::int as \"value\"/i);\n230\t    }\n231\t  });\n232\t});\n233\t"}]},"parent_tool_use_id":null,"session_id":"aa22a004-7967-4272-b3ce-42c86f057c37","uuid":"1de97237-aaed-4b0b-b5f5-d1bda7058843","timestamp":"2026-04-25T12:03:24.302Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-command-center-attention.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  COMMAND_CENTER_DEFAULTS,\n  getCommandCenterAttention,\n} from \"../get-command-center-attention\";\nimport type { PeekCommandCenterAttentionId } from \"../../../../lib/types/peek\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<{ value: number | string }> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\n// Build a SQL mock that returns a sequence of responses, one per call.\n// Each response is either a row array (success) or an Error (rejection).\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) {\n      return Promise.reject(next);\n    }\n    return Promise.resolve(next ?? []);\n  };\n\n  // Cast through unknown — only the tagged-template surface is exercised here.\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\nconst ALL_IDS: ReadonlyArray<PeekCommandCenterAttentionId> = [\n  \"failed_claims\",\n  \"dead_queue_events\",\n  \"stuck_rounds_flipyou_potshot\",\n  \"stuck_rounds_closecall\",\n  \"pending_sol_crate_payouts\",\n  \"stale_active_dogpile_events\",\n  \"high_value_exports_24h\",\n];\n\ndescribe(\"getCommandCenterAttention\", () => {\n  it(\"populated: returns one PeekMetric per attention id with FR-4 bookkeeping\", async () => {\n    const mock = createSqlMock([\n      [{ value: 3 }],\n      [{ value: 1 }],\n      [{ value: 5 }],\n      [{ value: 2 }],\n      [{ value: 4 }],\n      [{ value: 6 }],\n      [{ value: 7 }],\n    ]);\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getCommandCenterAttention({ sql: mock.sql, now });\n\n    expect(result.generatedAt).toBe(\"2026-04-25T10:00:00.000Z\");\n    expect(result.metrics).toHaveLength(7);\n    expect(result.metrics.map((m) => m.id)).toEqual(ALL_IDS);\n\n    for (const metric of result.metrics) {\n      expect(metric.asOf).toBe(\"2026-04-25T10:00:00.000Z\");\n      expect(metric.freshness).toBe(\"live\");\n      expect(metric.label.length).toBeGreaterThan(0);\n      expect(metric.definition.length).toBeGreaterThan(0);\n      expect(metric.source.length).toBeGreaterThan(0);\n      expect(metric.windowLabel.length).toBeGreaterThan(0);\n      expect(metric.drilldownHref).not.toBeNull();\n    }\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"failed_claims\")?.value).toBe(3);\n    expect(byId.get(\"failed_claims\")?.valueDisplay).toBe(\"3\");\n    expect(byId.get(\"failed_claims\")?.source).toBe(\"referral_claims\");\n    expect(byId.get(\"dead_queue_events\")?.value).toBe(1);\n    expect(byId.get(\"stuck_rounds_flipyou_potshot\")?.value).toBe(5);\n    expect(byId.get(\"stuck_rounds_closecall\")?.value).toBe(2);\n    expect(byId.get(\"pending_sol_crate_payouts\")?.value).toBe(4);\n    expect(byId.get(\"stale_active_dogpile_events\")?.value).toBe(6);\n    expect(byId.get(\"high_value_exports_24h\")?.value).toBe(7);\n    expect(byId.get(\"high_value_exports_24h\")?.source).toBe(\"operator_events\");\n  });\n\n  it(\"populated (large counts): formats valueDisplay with a thousands separator\", async () => {\n    const mock = createSqlMock([\n      [{ value: 1234 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n\n    const result = await getCommandCenterAttention({ sql: mock.sql });\n\n    const failed = result.metrics.find((m) => m.id === \"failed_claims\");\n    expect(failed?.value).toBe(1234);\n    expect(failed?.valueDisplay).toBe(\"1,234\");\n  });\n\n  it(\"populated (string count): coerces a postgres ::text count to a number\", async () => {\n    // postgres-js can return numeric counts as strings depending on driver\n    // configuration; the query module must coerce them back to numbers.\n    const mock = createSqlMock([\n      [{ value: \"12\" }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n\n    const result = await getCommandCenterAttention({ sql: mock.sql });\n\n    const failed = result.metrics.find((m) => m.id === \"failed_claims\");\n    expect(failed?.value).toBe(12);\n    expect(failed?.valueDisplay).toBe(\"12\");\n  });\n\n  it(\"sparse: every empty row coerces to a zero count without dropping the metric\", async () => {\n    const mock = createSqlMock([[], [], [], [], [], [], []]);\n\n    const result = await getCommandCenterAttention({ sql: mock.sql });\n\n    expect(result.metrics).toHaveLength(7);\n    for (const metric of result.metrics) {\n      expect(metric.value).toBe(0);\n      expect(metric.valueDisplay).toBe(\"0\");\n    }\n  });\n\n  it(\"threshold overrides: surface in the windowLabel and definition copy\", async () => {\n    const mock = createSqlMock([[], [], [], [], [], [], []]);\n\n    const result = await getCommandCenterAttention({\n      sql: mock.sql,\n      thresholds: {\n        stuckRoundsAgeMinutes: 10,\n        stuckRoundsMaxSettleAttempts: 6,\n        stuckCloseCallAgeMinutes: 7,\n        exportWindowHours: 12,\n        exportRowCountThreshold: 250,\n      },\n    });\n\n    const stuck = result.metrics.find(\n      (m) => m.id === \"stuck_rounds_flipyou_potshot\",\n    );\n    expect(stuck?.windowLabel).toContain(\"10m\");\n    expect(stuck?.windowLabel).toContain(\"> 6\");\n\n    const cc = result.metrics.find((m) => m.id === \"stuck_rounds_closecall\");\n    expect(cc?.windowLabel).toContain(\"7m\");\n\n    const exports = result.metrics.find((m) => m.id === \"high_value_exports_24h\");\n    expect(exports?.windowLabel).toContain(\"Last 12h\");\n    expect(exports?.definition).toContain(\"12h\");\n    expect(exports?.definition).toContain(\"250\");\n  });\n\n  it(\"default thresholds: match the published COMMAND_CENTER_DEFAULTS\", async () => {\n    const mock = createSqlMock([[], [], [], [], [], [], []]);\n\n    const result = await getCommandCenterAttention({ sql: mock.sql });\n\n    const stuck = result.metrics.find(\n      (m) => m.id === \"stuck_rounds_flipyou_potshot\",\n    );\n    expect(stuck?.windowLabel).toContain(\n      `${COMMAND_CENTER_DEFAULTS.stuckRoundsAgeMinutes}m`,\n    );\n    expect(stuck?.windowLabel).toContain(\n      `> ${COMMAND_CENTER_DEFAULTS.stuckRoundsMaxSettleAttempts}`,\n    );\n\n    const exports = result.metrics.find((m) => m.id === \"high_value_exports_24h\");\n    expect(exports?.windowLabel).toContain(\n      `Last ${COMMAND_CENTER_DEFAULTS.exportWindowHours}h`,\n    );\n  });\n\n  it(\"load-error: a rejected query propagates so the caller can render the alert state\", async () => {\n    // Promise.all rejects on the first failure; the page-level try/catch\n    // surfaces the error as `attentionError`. The query module must not\n    // silently swallow the failure.\n    const mock = createSqlMock([\n      [{ value: 0 }],\n      new Error(\"connection refused\"),\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n\n    await expect(\n      getCommandCenterAttention({ sql: mock.sql }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n\n  it(\"query bounded: every SQL call returns a single integer count, never row data\", async () => {\n    const mock = createSqlMock([\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n\n    await getCommandCenterAttention({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(7);\n    for (const call of mock.calls) {\n      // Every command-center query is a count(*) projection — never row data.\n      expect(call.text).toMatch(/select\\s+count\\(\\*\\)::int as \"value\"/i);\n    }\n  });\n});\n","numLines":233,"startLine":1,"totalLines":233}}}
