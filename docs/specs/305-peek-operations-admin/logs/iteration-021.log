{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016CuKUDDNqamdCUzpPVUhHA","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport { render, screen, within } from \"@testing-library/react\";\n3\timport { RecentActivityList } from \"../recent-activity-list\";\n4\timport type { PeekRecentActivityItem } from \"../../lib/types/peek\";\n5\t\n6\tconst populated: ReadonlyArray<PeekRecentActivityItem> = [\n7\t  {\n8\t    id: \"1\",\n9\t    eventType: \"peek.user.view_sensitive\",\n10\t    actorEmail: \"alice@example.com\",\n11\t    resourceType: \"user\",\n12\t    resourceId: \"u-1\",\n13\t    route: \"/users/u-1\",\n14\t    createdAt: \"2026-04-25T10:00:00.000Z\",\n15\t  },\n16\t  {\n17\t    id: \"2\",\n18\t    eventType: \"peek.export\",\n19\t    actorEmail: \"biz@example.com\",\n20\t    resourceType: \"export\",\n21\t    resourceId: null,\n22\t    route: \"/growth/referrals/export\",\n23\t    createdAt: \"2026-04-25T10:05:00.000Z\",\n24\t  },\n25\t];\n26\t\n27\tconst sparseItem: PeekRecentActivityItem = {\n28\t  id: \"3\",\n29\t  eventType: \"peek.access.denied\",\n30\t  actorEmail: null,\n31\t  resourceType: null,\n32\t  resourceId: null,\n33\t  route: null,\n34\t  createdAt: \"2026-04-25T10:10:00.000Z\",\n35\t};\n36\t\n37\tdescribe(\"RecentActivityList\", () => {\n38\t  it(\"populated: renders one row per item with time, event type, actor, route link, and resource label\", () => {\n39\t    render(<RecentActivityList items={populated} error={null} />);\n40\t\n41\t    const list = screen.getByRole(\"list\", { name: \"Recent operator activity\" });\n42\t    const items = within(list).getAllByRole(\"listitem\");\n43\t    expect(items).toHaveLength(2);\n44\t\n45\t    const first = items[0];\n46\t    expect(first).toHaveTextContent(\"2026-04-25T10:00:00.000Z\");\n47\t    expect(first).toHaveTextContent(\"peek.user.view_sensitive\");\n48\t    expect(first).toHaveTextContent(\"alice@example.com\");\n49\t    expect(within(first).getByRole(\"link\", { name: \"/users/u-1\" })).toHaveAttribute(\n50\t      \"href\",\n51\t      \"/users/u-1\",\n52\t    );\n53\t    expect(first).toHaveTextContent(\"user:u-1\");\n54\t\n55\t    const second = items[1];\n56\t    expect(second).toHaveTextContent(\"peek.export\");\n57\t    expect(within(second).getByRole(\"link\", { name: \"/growth/referrals/export\" })).toHaveAttribute(\n58\t      \"href\",\n59\t      \"/growth/referrals/export\",\n60\t    );\n61\t    expect(second).toHaveTextContent(\"export\");\n62\t    expect(within(second).queryByText(/user:/)).toBeNull();\n63\t  });\n64\t\n65\t  it(\"sparse: missing actor renders an em-dash, missing route renders no link, missing resource renders no label\", () => {\n66\t    render(<RecentActivityList items={[sparseItem]} error={null} />);\n67\t\n68\t    const list = screen.getByRole(\"list\", { name: \"Recent operator activity\" });\n69\t    const item = within(list).getAllByRole(\"listitem\")[0];\n70\t    expect(item).toHaveTextContent(\"peek.access.denied\");\n71\t    expect(item).toHaveTextContent(\"—\");\n72\t    expect(within(item).queryByRole(\"link\")).toBeNull();\n73\t  });\n74\t\n75\t  it(\"empty: renders the operator empty status when items is empty\", () => {\n76\t    render(<RecentActivityList items={[]} error={null} />);\n77\t\n78\t    expect(screen.getByRole(\"status\")).toHaveTextContent(\n79\t      \"No recent operator activity recorded yet.\",\n80\t    );\n81\t    expect(screen.queryByRole(\"list\")).toBeNull();\n82\t  });\n83\t\n84\t  it(\"error: renders an alert and suppresses both the list and the empty state\", () => {\n85\t    render(<RecentActivityList items={populated} error=\"query timeout\" />);\n86\t\n87\t    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n88\t      \"Recent activity unavailable: query timeout\",\n89\t    );\n90\t    expect(screen.queryByRole(\"list\")).toBeNull();\n91\t    expect(screen.queryByRole(\"status\")).toBeNull();\n92\t  });\n93\t});\n9