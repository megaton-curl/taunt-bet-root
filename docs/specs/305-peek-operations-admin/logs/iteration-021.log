{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019bMkn2BCFLbpU3To6cw7Su","type":"tool_result","content":"1\timport type {\n2\t  PeekChallengeAssignmentSummary,\n3\t  PeekCrateDropRow,\n4\t  PeekFraudFlagRow,\n5\t  PeekGameEntryRow,\n6\t  PeekKolRate,\n7\t  PeekLinkedAccountRow,\n8\t  PeekPlayerPoints,\n9\t  PeekPointGrantRow,\n10\t  PeekReferralClaimRow,\n11\t  PeekReferralEarningsSummary,\n12\t  PeekTelegramLinkTokenRow,\n13\t  PeekTransactionRow,\n14\t  PeekUserAttentionFlags,\n15\t  PeekUserDetail,\n16\t  PeekUserQueueEventRow,\n17\t} from \"../../../lib/types/peek\";\n18\timport { getSqlClient } from \"../client\";\n19\t\n20\texport const PEEK_USER_DETAIL_RECENT_LIMIT = 25;\n21\texport const PEEK_USER_DETAIL_TOKEN_LIMIT = 10;\n22\t\n23\ttype Sql = ReturnType<typeof getSqlClient>;\n24\t\n25\ttype GetPeekUserDetailOptions = {\n26\t  sql?: Sql;\n27\t  recentLimit?: number;\n28\t  tokenLimit?: number;\n29\t};\n30\t\n31\texport function formatUserHeading(user: {\n32\t  userId: string;\n33\t  username: string | null;\n34\t}) {\n35\t  return user.username ?? user.userId;\n36\t}\n37\t\n38\texport async function getPeekUserDetail(\n39\t  userId: string,\n40\t  options: GetPeekUserDetailOptions = {},\n41\t): Promise<PeekUserDetail | null> {\n42\t  const sql = options.sql ?? getSqlClient();\n43\t  const recentLimit = clampPositiveInt(\n44\t    options.recentLimit,\n45\t    PEEK_USER_DETAIL_RECENT_LIMIT,\n46\t  );\n47\t  const tokenLimit = clampPositiveInt(\n48\t    options.tokenLimit,\n49\t    PEEK_USER_DETAIL_TOKEN_LIMIT,\n50\t  );\n51\t\n52\t  // Identity + linked-account telegram view (preserved as queries[0] so the\n53\t  // 303-era listing/detail tests continue to assert the same SQL contract).\n54\t  const [user] = await sql<\n55\t    Array<{\n56\t      userId: string;\n57\t      username: string | null;\n58\t      wallet: string;\n59\t      joinedAt: string;\n60\t      avatarUrl: string | null;\n61\t      heatMultiplier: string;\n62\t      profilePointsBalance: string;\n63\t      referralCode: string | null;\n64\t      referrerUserId: string | null;\n65\t      referrerCode: string | null;\n66\t      refereeCount: number;\n67\t      telegramLinkState: \"active\" | \"none\";\n68\t      linkedAt: string | null;\n69\t      telegramUserId: string | null;\n70\t      telegramUsername: string | null;\n71\t    }>\n72\t  >`\n73\t    select\n74\t      pp.user_id as \"userId\",\n75\t      pp.username as \"username\",\n76\t      pp.wallet as \"wallet\",\n77\t      pp.created_at::text as \"joinedAt\",\n78\t      pp.avatar_url as \"avatarUrl\",\n79\t      pp.heat_multiplier::text as \"heatMultiplier\",\n80\t      pp.points_balance::text as \"profilePointsBalance\",\n81\t      rc.code as \"referralCode\",\n82\t      rl.referrer_user_id as \"referrerUserId\",\n83\t      ref_code.code as \"referrerCode\",\n84\t      (\n85\t        select count(*)::int\n86\t        from referral_links outbound\n87\t        where outbound.referrer_user_id = pp.user_id\n88\t      ) as \"refereeCount\",\n89\t      coalesce(tla.status, 'none') as \"telegramLinkState\",\n90\t      rl.created_at::text as \"linkedAt\",\n91\t      tla.telegram_user_id as \"telegramUserId\",\n92\t      tla.telegram_username as \"telegramUsername\"\n93\t    from player_profiles pp\n94\t    left join referral_codes rc on rc.user_id = pp.user_id\n95\t    left join referral_links rl on rl.referee_user_id = pp.user_id\n96\t    left join referral_codes ref_code on ref_code.user_id = rl.referrer_user_id\n97\t    left join lateral (\n98\t      select\n99\t        status,\n100\t        provider_account_id as telegram_user_id,\n101\t        nullif(metadata_json->>'telegramUsername', '') as telegram_username\n102\t      from linked_accounts\n103\t      where user_id = pp.user_id\n104\t        and provider = 'telegram'\n105\t        and status = 'active'\n106\t      limit 1\n107\t    ) tla on true\n108\t    where pp.user_id = ${userId}\n109\t  `;\n110\t\n111\t  if (!user) {\n112\t    return null;\n113\t  }\n114\t\n115\t  const wallet = user.wallet;\n116\t\n117\t  const [\n118\t    outboundReferees,\n119\t    linkedAccounts,\n120\t    recentTelegramLinkTokens,\n121\t    kolRate,\n122\t    referralEarnings,\n123\t    recentReferralClaims,\n124\t    points,\n125\t    recentPointGrants,\n126\t    recentCrateDrops,\n127\t    challengeSummary,\n128\t    recentGameEntries,\n129\t    recentTransactions,\n130\t    fraudFlags,\n131\t    recentUserQueueEvents,\n132\t    selfReferralRow,\n133\t  ] = await Promise.all([\n134\t    fetchOutboundReferees(sql, userId),\n135\t    fetchLinkedAccounts(sql, userId),\n136\t    fetchRecentTelegramLinkTokens(sql, userId, tokenLimit),\n137\t    fetchKolRate(sql, userId),\n138\t    fetchReferralEarnings(sql, userId),\n139\t    fetchRecentReferralClaims(sql, userId, recentLimit),\n140\t    fetchPlayerPoints(sql, userId),\n141\t    fetchRecentPointGrants(sql, userId, recentLimit),\n142\t    fetchRecentCrateDrops(sql, userId, recentLimit),\n143\t    fetchChallengeSummary(sql, userId),\n144\t    fetchRecentGameEntries(sql, userId, recentLimit),\n145\t    fetchRecentTransactions(sql, userId, recentLimit),\n146\t    fetchFraudFlags(sql, userId, recentLimit),\n147\t    fetchRecentUserQueueEvents(sql, userId, wallet, recentLimit),\n148\t    fetchSelfReferralIndicator(sql, userId),\n149\t  ]);\n150\t\n151\t  const attention = computeAttention({\n152\t    recentReferralClaims,\n153\t    recentUserQueueEvents,\n154\t    fraudFlags,\n155\t    recentCrateDrops,\n156\t    selfReferralRow,\n157\t  });\n158\t\n159\t  return {\n160\t    user: {\n161\t      userId: user.userId,\n162\t      username: user.username,\n163\t      wallet: user.wallet,\n164\t      joinedAt: user.joinedAt,\n165\t      referralCode: user.referralCode,\n166\t      referrerUserId: user.referrerUserId,\n167\t      referrerCode: user.referrerCode,\n168\t      refereeCount: user.refereeCount,\n169\t      telegramUsername: user.telegramUsername,\n170\t      telegramUserId: user.telegramUserId,\n171\t      avatarUrl: user.avatarUrl,\n172\t      heatMultiplier: user.heatMultiplier,\n173\t      profilePointsBalance: user.profilePointsBalance,\n174\t    },\n175\t    inboundReferral: {\n176\t      referrerUserId: user.referrerUserId,\n177\t      referrerCode: user.referrerCode,\n178\t      linkedAt: user.linkedAt,\n179\t    },\n180\t    outboundReferees,\n181\t    telegram: {\n182\t      state: user.telegramLinkState,\n183\t      telegramUserId: user.telegramUserId,\n184\t      telegramUsername: user.telegramUsername,\n185\t    },\n186\t    linkedAccounts,\n187\t    recentTelegramLinkTokens,\n188\t    kolRate,\n189\t    referralEarnings,\n190\t    recentReferralClaims,\n191\t    points,\n192\t    recentPointGrants,\n193\t    recentCrateDrops,\n194\t    challengeSummary,\n195\t    recentGameEntries,\n196\t    recentTransactions,\n197\t    fraudFlags,\n198\t    recentUserQueueEvents,\n199\t    attention,\n200\t  };\n201\t}\n202\t\n203\tfunction clampPositiveInt(value: number | undefined, fallback: number): number {\n204\t  if (typeof value !== \"number\" || !Number.isFinite(value)) return fallback;\n205\t  const floored = Math.floor(value);\n206\t  if (floored <= 0) return 1;\n207\t  return floored;\n208\t}\n209\t\n210\tasync function fetchOutboundReferees(\n211\t  sql: Sql,\n212\t  userId: string,\n213\t): Promise<PeekUserDetail[\"outboundReferees\"]> {\n214\t  return sql<\n215\t    Array<{\n216\t      refereeUserId: string;\n217\t      refereeUsername: string | null;\n218\t      createdAt: string;\n219\t    }>\n220\t  >`\n221\t    select\n222\t      rl.referee_user_id as \"refereeUserId\",\n223\t      pp.username as \"refereeUsername\",\n224\t      rl.created_at::text as \"createdAt\"\n225\t    from referral_links rl\n226\t    left join player_profiles pp on pp.user_id = rl.referee_user_id\n227\t    where rl.referrer_user_id = ${userId}\n228\t    order by rl.created_at desc\n229\t  `;\n230\t}\n231\t\n232\tasync function fetchLinkedAccounts(\n233\t  sql: Sql,\n234\t  userId: string,\n235\t): Promise<ReadonlyArray<PeekLinkedAccountRow>> {\n236\t  return sql<Array<PeekLinkedAccountRow>>`\n237\t    select\n238\t      id::text as \"id\",\n239\t      provider,\n240\t      provider_account_id as \"providerAccountId\",\n241\t      status,\n242\t      nullif(metadata_json->>'telegramUsername', '') as \"telegramUsername\",\n243\t      metadata_json as \"metadataJson\",\n244\t      linked_at::text as \"linkedAt\",\n245\t      updated_at::text as \"updatedAt\"\n246\t    from linked_accounts\n247\t    where user_id = ${userId}\n248\t    order by linked_at desc\n249\t  `;\n250\t}\n251\t\n252\tasync function fetchRecentTelegramLinkTokens(\n253\t  sql: Sql,\n254\t  userId: string,\n255\t  limit: number,\n256\t): Promise<ReadonlyArray<PeekTelegramLinkTokenRow>> {\n257\t  return sql<Array<PeekTelegramLinkTokenRow>>`\n258\t    select\n259\t      id::text as \"id\",\n260\t      status,\n261\t      telegram_user_id as \"telegramUserId\",\n262\t      telegram_username as \"telegramUsername\",\n263\t      expires_at::text as \"expiresAt\",\n264\t      redeemed_at::text as \"redeemedAt\",\n265\t      created_at::text as \"createdAt\"\n266\t    from telegram_link_tokens\n267\t    where user_id = ${userId}\n268\t    order by created_at desc\n269\t    limit ${limit}\n270\t  `;\n271\t}\n272\t\n273\tasync function fetchKolRate(\n274\t  sql: Sql,\n275\t  userId: string,\n276\t): Promise<PeekKolRate | null> {\n277\t  const [row] = await sql<\n278\t    Array<{\n279\t      rateBps: number;\n280\t      setBy: string;\n281\t      createdAt: string;\n282\t      updatedAt: string;\n283\t    }>\n284\t  >`\n285\t    select\n286\t      rate_bps as \"rateBps\",\n287\t      set_by as \"setBy\",\n288\t      created_at::text as \"createdAt\",\n289\t      updated_at::text as \"updatedAt\"\n290\t    from referral_kol_rates\n291\t    where user_id = ${userId}\n292\t    limit 1\n293\t  `;\n294\t  return row ?? null;\n295\t}\n296\t\n297\tasync function fetchReferralEarnings(\n298\t  sql: Sql,\n299\t  userId: string,\n300\t): Promise<PeekReferralEarningsSummary> {\n301\t  const [row] = await sql<\n302\t    Array<{\n303\t      earningsCount: number;\n304\t      totalReferrerEarnedLamports: string;\n305\t      totalRefereeRebateLamports: string;\n306\t      lastEarnedAt: string | null;\n307\t    }>\n308\t  >`\n309\t    select\n310\t      count(*)::int as \"earningsCount\",\n311\t      coalesce(sum(referrer_earned_lamports), 0)::text as \"totalReferrerEarnedLamports\",\n312\t      coalesce(sum(referee_rebate_lamports), 0)::text as \"totalRefereeRebateLamports\",\n313\t      max(created_at)::text as \"lastEarnedAt\"\n314\t    from referral_earnings\n315\t    where referrer_user_id = ${userId} or referee_user_id = ${userId}\n316\t  `;\n317\t  return (\n318\t    row ?? {\n319\t      earningsCount: 0,\n320\t      totalReferrerEarnedLamports: \"0\",\n321\t      totalRefereeRebateLamports: \"0\",\n322\t      lastEarnedAt: null,\n323\t    }\n324\t  );\n325\t}\n326\t\n327\tasync function fetchRecentReferralClaims(\n328\t  sql: Sql,\n329\t  userId: string,\n330\t  limit: number,\n331\t): Promise<ReadonlyArray<PeekReferralClaimRow>> {\n332\t  return sql<Array<PeekReferralClaimRow>>`\n333\t    select\n334\t      id::text as \"id\",\n335\t      amount_lamports::text as \"amountLamports\",\n336\t      status,\n337\t      retry_count as \"retryCount\",\n338\t      tx_signature as \"txSignature\",\n339\t      error,\n340\t      requested_at::text as \"requestedAt\",\n341\t      processed_at::text as \"processedAt\"\n342\t    from referral_claims\n343\t    where user_id = ${userId}\n344\t    order by requested_at desc\n345\t    limit ${limit}\n346\t  `;\n347\t}\n348\t\n349\tasync function fetchPlayerPoints(\n350\t  sql: Sql,\n351\t  userId: string,\n352\t): Promise<PeekPlayerPoints> {\n353\t  const [row] = await sql<\n354\t    Array<{\n355\t      balance: string;\n356\t      lifetimeEarned: string;\n357\t      updatedAt: string;\n358\t    }>\n359\t  >`\n360\t    select\n361\t      balance::text as \"balance\",\n362\t      lifetime_earned::text as \"lifetimeEarned\",\n363\t      updated_at::text as \"updatedAt\"\n364\t    from player_points\n365\t    where user_id = ${userId}\n366\t    limit 1\n367\t  `;\n368\t  return (\n369\t    row ?? {\n370\t      balance: \"0\",\n371\t      lifetimeEarned: \"0\",\n372\t      updatedAt: null,\n373\t    }\n374\t  );\n375\t}\n376\t\n377\tasync function fetchRecentPointGrants(\n378\t  sql: Sql,\n379\t  userId: string,\n380\t  limit: number,\n381\t): Promise<ReadonlyArray<PeekPointGrantRow>> {\n382\t  return sql<Array<PeekPointGrantRow>>`\n383\t    select\n384\t      id::text as \"id\",\n385\t      source_type as \"sourceType\",\n386\t      source_id as \"sourceId\",\n387\t      amount::text as \"amount\",\n388\t      created_at::text as \"createdAt\"\n389\t    from point_grants\n390\t    where user_id = ${userId}\n391\t    order by created_at desc\n392\t    limit ${limit}\n393\t  `;\n394\t}\n395\t\n396\tasync function fetchRecentCrateDrops(\n397\t  sql: Sql,\n398\t  userId: string,\n399\t  limit: number,\n400\t): Promise<ReadonlyArray<PeekCrateDropRow>> {\n401\t  return sql<Array<PeekCrateDropRow>>`\n402\t    select\n403\t      id::text as \"id\",\n404\t      trigger_type as \"triggerType\",\n405\t      trigger_id as \"triggerId\",\n406\t      crate_type as \"crateType\",\n407\t      contents_amount as \"contentsAmount\",\n408\t      status,\n409\t      created_at::text as \"createdAt\",\n410\t      granted_at::text as \"grantedAt\"\n411\t    from crate_drops\n412\t    where user_id = ${userId}\n413\t    order by created_at desc\n414\t    limit ${limit}\n415\t  `;\n416\t}\n417\t\n418\tasync function fetchChallengeSummary(\n419\t  sql: Sql,\n420\t  userId: string,\n421\t): Promise<PeekChallengeAssignmentSummary> {\n422\t  const [row] = await sql<\n423\t    Array<{\n424\t      active: number;\n425\t      completed: number;\n426\t      expired: number;\n427\t      total: number;\n428\t    }>\n429\t  >`\n430\t    select\n431\t      count(*) filter (where status = 'active')::int as \"active\",\n432\t      count(*) filter (where status = 'completed')::int as \"completed\",\n433\t      count(*) filter (where status = 'expired')::int as \"expired\",\n434\t      count(*)::int as \"total\"\n435\t    from challenge_assignments\n436\t    where user_id = ${userId}\n437\t  `;\n438\t  return row ?? { active: 0, completed: 0, expired: 0, total: 0 };\n439\t}\n440\t\n441\tasync function fetchRecentGameEntries(\n442\t  sql: Sql,\n443\t  userId: string,\n444\t  limit: number,\n445\t): Promise<ReadonlyArray<PeekGameEntryRow>> {\n446\t  return sql<Array<PeekGameEntryRow>>`\n447\t    select\n448\t      id::text as \"id\",\n449\t      game,\n450\t      round_pda as \"roundPda\",\n451\t      match_id as \"matchId\",\n452\t      amount_lamports::text as \"amountLamports\",\n453\t      side,\n454\t      is_winner as \"isWinner\",\n455\t      payout_lamports::text as \"payoutLamports\",\n456\t      created_at::text as \"createdAt\",\n457\t      settled_at::text as \"settledAt\"\n458\t    from game_entries\n459\t    where user_id = ${userId}\n460\t    order by created_at desc\n461\t    limit ${limit}\n462\t  `;\n463\t}\n464\t\n465\tasync function fetchRecentTransactions(\n466\t  sql: Sql,\n467\t  userId: string,\n468\t  limit: number,\n469\t): Promise<ReadonlyArray<PeekTransactionRow>> {\n470\t  return sql<Array<PeekTransactionRow>>`\n471\t    select\n472\t      id::text as \"id\",\n473\t      game,\n474\t      match_id as \"matchId\",\n475\t      tx_type as \"txType\",\n476\t      amount_lamports::text as \"amountLamports\",\n477\t      tx_sig as \"txSig\",\n478\t      created_at::text as \"createdAt\"\n479\t    from transactions\n480\t    where user_id = ${userId}\n481\t    order by created_at desc\n482\t    limit ${limit}\n483\t  `;\n484\t}\n485\t\n486\tasync function fetchFraudFlags(\n487\t  sql: Sql,\n488\t  userId: string,\n489\t  limit: number,\n490\t): Promise<ReadonlyArray<PeekFraudFlagRow>> {\n491\t  return sql<Array<PeekFraudFlagRow>>`\n492\t    select\n493\t      id::text as \"id\",\n494\t      flag_type as \"flagType\",\n495\t      status,\n496\t      related_id as \"relatedId\",\n497\t      created_at::text as \"createdAt\",\n498\t      resolved_at::text as \"resolvedAt\"\n499\t    from fraud_flags\n500\t    where user_id = ${userId}\n501\t    order by created_at desc\n502\t    limit ${limit}\n503\t  `;\n504\t}\n505\t\n506\tasync function fetchRecentUserQueueEvents(\n507\t  sql: Sql,\n508\t  userId: string,\n509\t  wallet: string,\n510\t  limit: number,\n511\t): Promise<ReadonlyArray<PeekUserQueueEventRow>> {\n512\t  // event_queue has no user_id column; join via JSONB payload identifiers that\n513\t  // every backend writer uses today (`userId`, `user_id`, `wallet`). Bounded by\n514\t  // limit so the admin page never streams the full queue.\n515\t  return sql<Array<PeekUserQueueEventRow>>`\n516\t    select\n517\t      id::text as \"id\",\n518\t      event_type as \"eventType\",\n519\t      status,\n520\t      attempts,\n521\t      max_attempts as \"maxAttempts\",\n522\t      scheduled_at::text as \"scheduledAt\",\n523\t      created_at::text as \"createdAt\",\n524\t      error\n525\t    from event_queue\n526\t    where payload->>'userId' = ${userId}\n527\t       or payload->>'user_id' = ${userId}\n528\t       or payload->>'wallet' = ${wallet}\n529\t    order by created_at desc\n530\t    limit ${limit}\n531\t  `;\n532\t}\n533\t\n534\tasync function fetchSelfReferralIndicator(\n535\t  sql: Sql,\n536\t  userId: string,\n537\t): Promise<{ selfReferral: boolean }> {\n538\t  const [row] = await sql<Array<{ selfReferral: boolean }>>`\n539\t    select exists (\n540\t      select 1\n541\t      from referral_links rl\n542\t      where rl.referrer_user_id = ${userId}\n543\t        and rl.referee_user_id = ${userId}\n544\t    ) as \"selfReferral\"\n545\t  `;\n546\t  return row ?? { selfReferral: false };\n547\t}\n548\t\n549\tfunction computeAttention(input: {\n550\t  recentReferralClaims: ReadonlyArray<PeekReferralClaimRow>;\n551\t  recentUserQueueEvents: ReadonlyArray<PeekUserQueueEventRow>;\n552\t  fraudFlags: ReadonlyArray<PeekFraudFlagRow>;\n553\t  recentCrateDrops: ReadonlyArray<PeekCrateDropRow>;\n554\t  selfReferralRow: { selfReferral: boolean };\n555\t}): PeekUserAttentionFlags {\n556\t  return {\n557\t    failedClaim: input.recentReferralClaims.some(\n558\t      (claim) => claim.status === \"failed\" || claim.status === \"error\",\n559\t    ),\n560\t    deadQueueEvent: input.recentUserQueueEvents.some(\n561\t      (event) => event.status === \"dead\",\n562\t    ),\n563\t    activeFraudFlag: input.fraudFlags.some((flag) => flag.status === \"open\"),\n564\t    pendingSolCratePayout: input.recentCrateDrops.some(\n565\t      (drop) => drop.crateType === \"sol\" && drop.status === \"pending\",\n566\t    ),\n567\t    suspiciousReferralLoop: input.selfReferralRow.selfReferral,\n568\t  };\n569\t}\n570\t"}]},"parent_tool_use_id":null,"session_id":"aa22a004-7967-4272-b3ce-42c86f057c37","uuid":"fd9d2926-39e2-445b-b554-dcc00848ebeb","timestamp":"2026-04-25T12:03:17.367Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-peek-user-detail.ts","content":"import type {\n  PeekChallengeAssignmentSummary,\n  PeekCrateDropRow,\n  PeekFraudFlagRow,\n  PeekGameEntryRow,\n  PeekKolRate,\n  PeekLinkedAccountRow,\n  PeekPlayerPoints,\n  PeekPointGrantRow,\n  PeekReferralClaimRow,\n  PeekReferralEarningsSummary,\n  PeekTelegramLinkTokenRow,\n  PeekTransactionRow,\n  PeekUserAttentionFlags,\n  PeekUserDetail,\n  PeekUserQueueEventRow,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_USER_DETAIL_RECENT_LIMIT = 25;\nexport const PEEK_USER_DETAIL_TOKEN_LIMIT = 10;\n\ntype Sql = ReturnType<typeof getSqlClient>;\n\ntype GetPeekUserDetailOptions = {\n  sql?: Sql;\n  recentLimit?: number;\n  tokenLimit?: number;\n};\n\nexport function formatUserHeading(user: {\n  userId: string;\n  username: string | null;\n}) {\n  return user.username ?? user.userId;\n}\n\nexport async function getPeekUserDetail(\n  userId: string,\n  options: GetPeekUserDetailOptions = {},\n): Promise<PeekUserDetail | null> {\n  const sql = options.sql ?? getSqlClient();\n  const recentLimit = clampPositiveInt(\n    options.recentLimit,\n    PEEK_USER_DETAIL_RECENT_LIMIT,\n  );\n  const tokenLimit = clampPositiveInt(\n    options.tokenLimit,\n    PEEK_USER_DETAIL_TOKEN_LIMIT,\n  );\n\n  // Identity + linked-account telegram view (preserved as queries[0] so the\n  // 303-era listing/detail tests continue to assert the same SQL contract).\n  const [user] = await sql<\n    Array<{\n      userId: string;\n      username: string | null;\n      wallet: string;\n      joinedAt: string;\n      avatarUrl: string | null;\n      heatMultiplier: string;\n      profilePointsBalance: string;\n      referralCode: string | null;\n      referrerUserId: string | null;\n      referrerCode: string | null;\n      refereeCount: number;\n      telegramLinkState: \"active\" | \"none\";\n      linkedAt: string | null;\n      telegramUserId: string | null;\n      telegramUsername: string | null;\n    }>\n  >`\n    select\n      pp.user_id as \"userId\",\n      pp.username as \"username\",\n      pp.wallet as \"wallet\",\n      pp.created_at::text as \"joinedAt\",\n      pp.avatar_url as \"avatarUrl\",\n      pp.heat_multiplier::text as \"heatMultiplier\",\n      pp.points_balance::text as \"profilePointsBalance\",\n      rc.code as \"referralCode\",\n      rl.referrer_user_id as \"referrerUserId\",\n      ref_code.code as \"referrerCode\",\n      (\n        select count(*)::int\n        from referral_links outbound\n        where outbound.referrer_user_id = pp.user_id\n      ) as \"refereeCount\",\n      coalesce(tla.status, 'none') as \"telegramLinkState\",\n      rl.created_at::text as \"linkedAt\",\n      tla.telegram_user_id as \"telegramUserId\",\n      tla.telegram_username as \"telegramUsername\"\n    from player_profiles pp\n    left join referral_codes rc on rc.user_id = pp.user_id\n    left join referral_links rl on rl.referee_user_id = pp.user_id\n    left join referral_codes ref_code on ref_code.user_id = rl.referrer_user_id\n    left join lateral (\n      select\n        status,\n        provider_account_id as telegram_user_id,\n        nullif(metadata_json->>'telegramUsername', '') as telegram_username\n      from linked_accounts\n      where user_id = pp.user_id\n        and provider = 'telegram'\n        and status = 'active'\n      limit 1\n    ) tla on true\n    where pp.user_id = ${userId}\n  `;\n\n  if (!user) {\n    return null;\n  }\n\n  const wallet = user.wallet;\n\n  const [\n    outboundReferees,\n    linkedAccounts,\n    recentTelegramLinkTokens,\n    kolRate,\n    referralEarnings,\n    recentReferralClaims,\n    points,\n    recentPointGrants,\n    recentCrateDrops,\n    challengeSummary,\n    recentGameEntries,\n    recentTransactions,\n    fraudFlags,\n    recentUserQueueEvents,\n    selfReferralRow,\n  ] = await Promise.all([\n    fetchOutboundReferees(sql, userId),\n    fetchLinkedAccounts(sql, userId),\n    fetchRecentTelegramLinkTokens(sql, userId, tokenLimit),\n    fetchKolRate(sql, userId),\n    fetchReferralEarnings(sql, userId),\n    fetchRecentReferralClaims(sql, userId, recentLimit),\n    fetchPlayerPoints(sql, userId),\n    fetchRecentPointGrants(sql, userId, recentLimit),\n    fetchRecentCrateDrops(sql, userId, recentLimit),\n    fetchChallengeSummary(sql, userId),\n    fetchRecentGameEntries(sql, userId, recentLimit),\n    fetchRecentTransactions(sql, userId, recentLimit),\n    fetchFraudFlags(sql, userId, recentLimit),\n    fetchRecentUserQueueEvents(sql, userId, wallet, recentLimit),\n    fetchSelfReferralIndicator(sql, userId),\n  ]);\n\n  const attention = computeAttention({\n    recentReferralClaims,\n    recentUserQueueEvents,\n    fraudFlags,\n    recentCrateDrops,\n    selfReferralRow,\n  });\n\n  return {\n    user: {\n      userId: user.userId,\n      username: user.username,\n      wallet: user.wallet,\n      joinedAt: user.joinedAt,\n      referralCode: user.referralCode,\n      referrerUserId: user.referrerUserId,\n      referrerCode: user.referrerCode,\n      refereeCount: user.refereeCount,\n      telegramUsername: user.telegramUsername,\n      telegramUserId: user.telegramUserId,\n      avatarUrl: user.avatarUrl,\n      heatMultiplier: user.heatMultiplier,\n      profilePointsBalance: user.profilePointsBalance,\n    },\n    inboundReferral: {\n      referrerUserId: user.referrerUserId,\n      referrerCode: user.referrerCode,\n      linkedAt: user.linkedAt,\n    },\n    outboundReferees,\n    telegram: {\n      state: user.telegramLinkState,\n      telegramUserId: user.telegramUserId,\n      telegramUsername: user.telegramUsername,\n    },\n    linkedAccounts,\n    recentTelegramLinkTokens,\n    kolRate,\n    referralEarnings,\n    recentReferralClaims,\n    points,\n    recentPointGrants,\n    recentCrateDrops,\n    challengeSummary,\n    recentGameEntries,\n    recentTransactions,\n    fraudFlags,\n    recentUserQueueEvents,\n    attention,\n  };\n}\n\nfunction clampPositiveInt(value: number | undefined, fallback: number): number {\n  if (typeof value !== \"number\" || !Number.isFinite(value)) return fallback;\n  const floored = Math.floor(value);\n  if (floored <= 0) return 1;\n  return floored;\n}\n\nasync function fetchOutboundReferees(\n  sql: Sql,\n  userId: string,\n): Promise<PeekUserDetail[\"outboundReferees\"]> {\n  return sql<\n    Array<{\n      refereeUserId: string;\n      refereeUsername: string | null;\n      createdAt: string;\n    }>\n  >`\n    select\n      rl.referee_user_id as \"refereeUserId\",\n      pp.username as \"refereeUsername\",\n      rl.created_at::text as \"createdAt\"\n    from referral_links rl\n    left join player_profiles pp on pp.user_id = rl.referee_user_id\n    where rl.referrer_user_id = ${userId}\n    order by rl.created_at desc\n  `;\n}\n\nasync function fetchLinkedAccounts(\n  sql: Sql,\n  userId: string,\n): Promise<ReadonlyArray<PeekLinkedAccountRow>> {\n  return sql<Array<PeekLinkedAccountRow>>`\n    select\n      id::text as \"id\",\n      provider,\n      provider_account_id as \"providerAccountId\",\n      status,\n      nullif(metadata_json->>'telegramUsername', '') as \"telegramUsername\",\n      metadata_json as \"metadataJson\",\n      linked_at::text as \"linkedAt\",\n      updated_at::text as \"updatedAt\"\n    from linked_accounts\n    where user_id = ${userId}\n    order by linked_at desc\n  `;\n}\n\nasync function fetchRecentTelegramLinkTokens(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekTelegramLinkTokenRow>> {\n  return sql<Array<PeekTelegramLinkTokenRow>>`\n    select\n      id::text as \"id\",\n      status,\n      telegram_user_id as \"telegramUserId\",\n      telegram_username as \"telegramUsername\",\n      expires_at::text as \"expiresAt\",\n      redeemed_at::text as \"redeemedAt\",\n      created_at::text as \"createdAt\"\n    from telegram_link_tokens\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchKolRate(\n  sql: Sql,\n  userId: string,\n): Promise<PeekKolRate | null> {\n  const [row] = await sql<\n    Array<{\n      rateBps: number;\n      setBy: string;\n      createdAt: string;\n      updatedAt: string;\n    }>\n  >`\n    select\n      rate_bps as \"rateBps\",\n      set_by as \"setBy\",\n      created_at::text as \"createdAt\",\n      updated_at::text as \"updatedAt\"\n    from referral_kol_rates\n    where user_id = ${userId}\n    limit 1\n  `;\n  return row ?? null;\n}\n\nasync function fetchReferralEarnings(\n  sql: Sql,\n  userId: string,\n): Promise<PeekReferralEarningsSummary> {\n  const [row] = await sql<\n    Array<{\n      earningsCount: number;\n      totalReferrerEarnedLamports: string;\n      totalRefereeRebateLamports: string;\n      lastEarnedAt: string | null;\n    }>\n  >`\n    select\n      count(*)::int as \"earningsCount\",\n      coalesce(sum(referrer_earned_lamports), 0)::text as \"totalReferrerEarnedLamports\",\n      coalesce(sum(referee_rebate_lamports), 0)::text as \"totalRefereeRebateLamports\",\n      max(created_at)::text as \"lastEarnedAt\"\n    from referral_earnings\n    where referrer_user_id = ${userId} or referee_user_id = ${userId}\n  `;\n  return (\n    row ?? {\n      earningsCount: 0,\n      totalReferrerEarnedLamports: \"0\",\n      totalRefereeRebateLamports: \"0\",\n      lastEarnedAt: null,\n    }\n  );\n}\n\nasync function fetchRecentReferralClaims(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekReferralClaimRow>> {\n  return sql<Array<PeekReferralClaimRow>>`\n    select\n      id::text as \"id\",\n      amount_lamports::text as \"amountLamports\",\n      status,\n      retry_count as \"retryCount\",\n      tx_signature as \"txSignature\",\n      error,\n      requested_at::text as \"requestedAt\",\n      processed_at::text as \"processedAt\"\n    from referral_claims\n    where user_id = ${userId}\n    order by requested_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchPlayerPoints(\n  sql: Sql,\n  userId: string,\n): Promise<PeekPlayerPoints> {\n  const [row] = await sql<\n    Array<{\n      balance: string;\n      lifetimeEarned: string;\n      updatedAt: string;\n    }>\n  >`\n    select\n      balance::text as \"balance\",\n      lifetime_earned::text as \"lifetimeEarned\",\n      updated_at::text as \"updatedAt\"\n    from player_points\n    where user_id = ${userId}\n    limit 1\n  `;\n  return (\n    row ?? {\n      balance: \"0\",\n      lifetimeEarned: \"0\",\n      updatedAt: null,\n    }\n  );\n}\n\nasync function fetchRecentPointGrants(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekPointGrantRow>> {\n  return sql<Array<PeekPointGrantRow>>`\n    select\n      id::text as \"id\",\n      source_type as \"sourceType\",\n      source_id as \"sourceId\",\n      amount::text as \"amount\",\n      created_at::text as \"createdAt\"\n    from point_grants\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchRecentCrateDrops(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekCrateDropRow>> {\n  return sql<Array<PeekCrateDropRow>>`\n    select\n      id::text as \"id\",\n      trigger_type as \"triggerType\",\n      trigger_id as \"triggerId\",\n      crate_type as \"crateType\",\n      contents_amount as \"contentsAmount\",\n      status,\n      created_at::text as \"createdAt\",\n      granted_at::text as \"grantedAt\"\n    from crate_drops\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchChallengeSummary(\n  sql: Sql,\n  userId: string,\n): Promise<PeekChallengeAssignmentSummary> {\n  const [row] = await sql<\n    Array<{\n      active: number;\n      completed: number;\n      expired: number;\n      total: number;\n    }>\n  >`\n    select\n      count(*) filter (where status = 'active')::int as \"active\",\n      count(*) filter (where status = 'completed')::int as \"completed\",\n      count(*) filter (where status = 'expired')::int as \"expired\",\n      count(*)::int as \"total\"\n    from challenge_assignments\n    where user_id = ${userId}\n  `;\n  return row ?? { active: 0, completed: 0, expired: 0, total: 0 };\n}\n\nasync function fetchRecentGameEntries(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekGameEntryRow>> {\n  return sql<Array<PeekGameEntryRow>>`\n    select\n      id::text as \"id\",\n      game,\n      round_pda as \"roundPda\",\n      match_id as \"matchId\",\n      amount_lamports::text as \"amountLamports\",\n      side,\n      is_winner as \"isWinner\",\n      payout_lamports::text as \"payoutLamports\",\n      created_at::text as \"createdAt\",\n      settled_at::text as \"settledAt\"\n    from game_entries\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchRecentTransactions(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekTransactionRow>> {\n  return sql<Array<PeekTransactionRow>>`\n    select\n      id::text as \"id\",\n      game,\n      match_id as \"matchId\",\n      tx_type as \"txType\",\n      amount_lamports::text as \"amountLamports\",\n      tx_sig as \"txSig\",\n      created_at::text as \"createdAt\"\n    from transactions\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchFraudFlags(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekFraudFlagRow>> {\n  return sql<Array<PeekFraudFlagRow>>`\n    select\n      id::text as \"id\",\n      flag_type as \"flagType\",\n      status,\n      related_id as \"relatedId\",\n      created_at::text as \"createdAt\",\n      resolved_at::text as \"resolvedAt\"\n    from fraud_flags\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchRecentUserQueueEvents(\n  sql: Sql,\n  userId: string,\n  wallet: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekUserQueueEventRow>> {\n  // event_queue has no user_id column; join via JSONB payload identifiers that\n  // every backend writer uses today (`userId`, `user_id`, `wallet`). Bounded by\n  // limit so the admin page never streams the full queue.\n  return sql<Array<PeekUserQueueEventRow>>`\n    select\n      id::text as \"id\",\n      event_type as \"eventType\",\n      status,\n      attempts,\n      max_attempts as \"maxAttempts\",\n      scheduled_at::text as \"scheduledAt\",\n      created_at::text as \"createdAt\",\n      error\n    from event_queue\n    where payload->>'userId' = ${userId}\n       or payload->>'user_id' = ${userId}\n       or payload->>'wallet' = ${wallet}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchSelfReferralIndicator(\n  sql: Sql,\n  userId: string,\n): Promise<{ selfReferral: boolean }> {\n  const [row] = await sql<Array<{ selfReferral: boolean }>>`\n    select exists (\n      select 1\n      from referral_links rl\n      where rl.referrer_user_id = ${userId}\n        and rl.referee_user_id = ${userId}\n    ) as \"selfReferral\"\n  `;\n  return row ?? { selfReferral: false };\n}\n\nfunction computeAttention(input: {\n  recentReferralClaims: ReadonlyArray<PeekReferralClaimRow>;\n  recentUserQueueEvents: ReadonlyArray<PeekUserQueueEventRow>;\n  fraudFlags: ReadonlyArray<PeekFraudFlagRow>;\n  recentCrateDrops: ReadonlyArray<PeekCrateDropRow>;\n  selfReferralRow: { selfReferral: boolean };\n}): PeekUserAttentionFlags {\n  return {\n    failedClaim: input.recentReferralClaims.some(\n      (claim) => claim.status === \"failed\" || claim.status === \"error\",\n    ),\n    deadQueueEvent: input.recentUserQueueEvents.some(\n      (event) => event.status === \"dead\",\n    ),\n    activeFraudFlag: input.fraudFlags.some((flag) => flag.status === \"open\"),\n    pendingSolCratePayout: input.recentCrateDrops.some(\n      (drop) => drop.crateType === \"sol\" && drop.status === \"pending\",\n    ),\n    suspiciousReferralLoop: input.selfReferralRow.selfReferral,\n  };\n}\n","numLines":570,"startLine":1,"totalLines":570}}}
