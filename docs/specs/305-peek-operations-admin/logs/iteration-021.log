{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01GhCfzm1s8qogxF9hpNaxJb","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0123qAxRtbEdyZ6ArVRXjtRY","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-peek-user-detail.test.ts","content":"import { describe, expect, it, vi } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_USER_DETAIL_RECENT_LIMIT,\n  PEEK_USER_DETAIL_TOKEN_LIMIT,\n  formatUserHeading,\n  getPeekUserDetail,\n  type PeekUserDetailAuditFn,\n} from \"../get-peek-user-detail\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\n// Build a SQL mock that returns a sequence of responses, one per call. The\n// query module fires queries[0] (identity) first, then 15 parallel queries via\n// Promise.all in declaration order:\n//   1: outboundReferees\n//   2: linkedAccounts\n//   3: recentTelegramLinkTokens\n//   4: kolRate\n//   5: referralEarnings\n//   6: recentReferralClaims\n//   7: playerPoints\n//   8: recentPointGrants\n//   9: recentCrateDrops\n//   10: challengeSummary\n//   11: recentGameEntries\n//   12: recentTransactions\n//   13: fraudFlags\n//   14: recentUserQueueEvents\n//   15: selfReferralIndicator\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\nconst IDENTITY_ROW = {\n  userId: \"u-1\",\n  username: \"alice\",\n  wallet: \"wallet-1\",\n  joinedAt: \"2026-01-01T00:00:00.000Z\",\n  avatarUrl: \"https://example.com/a.png\",\n  heatMultiplier: \"1.50\",\n  profilePointsBalance: \"100\",\n  referralCode: \"ALICE2026\",\n  referrerUserId: \"u-0\",\n  referrerCode: \"MENTOR\",\n  refereeCount: 3,\n  telegramLinkState: \"active\" as const,\n  linkedAt: \"2026-01-02T00:00:00.000Z\",\n  telegramUserId: \"tg-9001\",\n  telegramUsername: \"alice_tg\",\n};\n\nfunction fullResponses(): ReadonlyArray<ResponseValue> {\n  return [\n    [IDENTITY_ROW],\n    [\n      {\n        refereeUserId: \"u-2\",\n        refereeUsername: \"bob\",\n        createdAt: \"2026-01-03T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"la-1\",\n        provider: \"telegram\",\n        providerAccountId: \"tg-9001\",\n        status: \"active\",\n        telegramUsername: \"alice_tg\",\n        metadataJson: { telegramUsername: \"alice_tg\" },\n        linkedAt: \"2026-01-02T00:00:00.000Z\",\n        updatedAt: \"2026-01-02T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"tlk-1\",\n        status: \"redeemed\",\n        telegramUserId: \"tg-9001\",\n        telegramUsername: \"alice_tg\",\n        expiresAt: \"2026-01-02T01:00:00.000Z\",\n        redeemedAt: \"2026-01-02T00:30:00.000Z\",\n        createdAt: \"2026-01-02T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        rateBps: 250,\n        setBy: \"ops@example.com\",\n        createdAt: \"2026-01-04T00:00:00.000Z\",\n        updatedAt: \"2026-01-04T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        earningsCount: 7,\n        totalReferrerEarnedLamports: \"12345\",\n        totalRefereeRebateLamports: \"6789\",\n        lastEarnedAt: \"2026-04-20T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"rc-1\",\n        amountLamports: \"1000\",\n        status: \"failed\",\n        retryCount: 3,\n        txSignature: null,\n        error: \"RpcError\",\n        requestedAt: \"2026-04-20T00:00:00.000Z\",\n        processedAt: \"2026-04-20T00:01:00.000Z\",\n      },\n    ],\n    [\n      {\n        balance: \"500\",\n        lifetimeEarned: \"1500\",\n        updatedAt: \"2026-04-24T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"pg-1\",\n        sourceType: \"challenge\",\n        sourceId: \"ch-1\",\n        amount: \"10\",\n        createdAt: \"2026-04-23T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"cd-1\",\n        triggerType: \"level_up\",\n        triggerId: \"lvl-3\",\n        crateType: \"sol\",\n        contentsAmount: \"1000\",\n        status: \"pending\",\n        createdAt: \"2026-04-22T00:00:00.000Z\",\n        grantedAt: null,\n      },\n    ],\n    [{ active: 1, completed: 2, expired: 0, total: 3 }],\n    [\n      {\n        id: \"ge-1\",\n        game: \"flipyou\",\n        roundPda: \"pda-1\",\n        matchId: \"match-1\",\n        amountLamports: \"1000000\",\n        side: \"heads\",\n        isWinner: true,\n        payoutLamports: \"1900000\",\n        createdAt: \"2026-04-21T00:00:00.000Z\",\n        settledAt: \"2026-04-21T00:00:30.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"tx-1\",\n        game: \"flipyou\",\n        matchId: \"match-1\",\n        txType: \"payout\",\n        amountLamports: \"1900000\",\n        txSig: \"sig-1\",\n        createdAt: \"2026-04-21T00:00:30.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"ff-1\",\n        flagType: \"wash_trading\",\n        status: \"open\",\n        relatedId: \"match-1\",\n        createdAt: \"2026-04-20T00:00:00.000Z\",\n        resolvedAt: null,\n      },\n    ],\n    [\n      {\n        id: \"qe-1\",\n        eventType: \"referral_payout\",\n        status: \"dead\",\n        attempts: 5,\n        maxAttempts: 5,\n        scheduledAt: \"2026-04-20T00:00:00.000Z\",\n        createdAt: \"2026-04-20T00:00:00.000Z\",\n        error: \"OnChainError\",\n      },\n    ],\n    [{ selfReferral: false }],\n  ];\n}\n\nfunction sparseResponses(): ReadonlyArray<ResponseValue> {\n  return [\n    // Identity row carries minimum-viable values: nullable identity-add-on\n    // fields default to null; the user still has a row in player_profiles.\n    [\n      {\n        userId: \"u-1\",\n        username: null,\n        wallet: \"wallet-sparse\",\n        joinedAt: \"2026-01-01T00:00:00.000Z\",\n        avatarUrl: null,\n        heatMultiplier: \"1.00\",\n        profilePointsBalance: \"0\",\n        referralCode: null,\n        referrerUserId: null,\n        referrerCode: null,\n        refereeCount: 0,\n        telegramLinkState: \"none\",\n        linkedAt: null,\n        telegramUserId: null,\n        telegramUsername: null,\n      },\n    ],\n    [], // outboundReferees\n    [], // linkedAccounts\n    [], // recentTelegramLinkTokens\n    [], // kolRate (no row)\n    [], // referralEarnings (no aggregate row — fallback to defaults)\n    [], // recentReferralClaims\n    [], // playerPoints (no row — fallback to defaults)\n    [], // recentPointGrants\n    [], // recentCrateDrops\n    [], // challengeSummary (no row — fallback to zeros)\n    [], // recentGameEntries\n    [], // recentTransactions\n    [], // fraudFlags\n    [], // recentUserQueueEvents\n    [], // selfReferralIndicator (no row — fallback to false)\n  ];\n}\n\ndescribe(\"formatUserHeading\", () => {\n  it(\"prefers username over user id in the detail header\", () => {\n    expect(formatUserHeading({ userId: \"u_1\", username: \"alice\" })).toBe(\"alice\");\n    expect(formatUserHeading({ userId: \"u_2\", username: null })).toBe(\"u_2\");\n  });\n});\n\ndescribe(\"getPeekUserDetail\", () => {\n  it(\"user not found: returns null after only the identity query, with no parallel calls\", async () => {\n    const mock = createSqlMock([[]]);\n\n    const detail = await getPeekUserDetail(\"missing\", {\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(detail).toBeNull();\n    expect(mock.calls).toHaveLength(1);\n    expect(mock.calls[0].text).toContain(\"from player_profiles pp\");\n  });\n\n  it(\"populated: shapes the full FR-6 user detail across every section\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    const detail = await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(detail).not.toBeNull();\n    if (!detail) throw new Error(\"detail\");\n\n    // Identity (with the FR-6 profile-identity additions)\n    expect(detail.user.userId).toBe(\"u-1\");\n    expect(detail.user.username).toBe(\"alice\");\n    expect(detail.user.wallet).toBe(\"wallet-1\");\n    expect(detail.user.avatarUrl).toBe(\"https://example.com/a.png\");\n    expect(detail.user.heatMultiplier).toBe(\"1.50\");\n    expect(detail.user.profilePointsBalance).toBe(\"100\");\n\n    // Inbound referral + telegram envelope\n    expect(detail.inboundReferral.referrerUserId).toBe(\"u-0\");\n    expect(detail.inboundReferral.referrerCode).toBe(\"MENTOR\");\n    expect(detail.telegram.state).toBe(\"active\");\n    expect(detail.telegram.telegramUsername).toBe(\"alice_tg\");\n\n    // Per-section aggregates\n    expect(detail.outboundReferees).toHaveLength(1);\n    expect(detail.linkedAccounts).toHaveLength(1);\n    expect(detail.recentTelegramLinkTokens).toHaveLength(1);\n    expect(detail.kolRate?.rateBps).toBe(250);\n    expect(detail.referralEarnings.earningsCount).toBe(7);\n    expect(detail.referralEarnings.totalReferrerEarnedLamports).toBe(\"12345\");\n    expect(detail.recentReferralClaims).toHaveLength(1);\n    expect(detail.points.balance).toBe(\"500\");\n    expect(detail.points.lifetimeEarned).toBe(\"1500\");\n    expect(detail.recentPointGrants).toHaveLength(1);\n    expect(detail.recentCrateDrops).toHaveLength(1);\n    expect(detail.challengeSummary.total).toBe(3);\n    expect(detail.recentGameEntries).toHaveLength(1);\n    expect(detail.recentTransactions).toHaveLength(1);\n    expect(detail.fraudFlags).toHaveLength(1);\n    expect(detail.recentUserQueueEvents).toHaveLength(1);\n\n    // Computed attention flags surface every populated risk signal.\n    expect(detail.attention.failedClaim).toBe(true); // status='failed'\n    expect(detail.attention.deadQueueEvent).toBe(true); // status='dead'\n    expect(detail.attention.activeFraudFlag).toBe(true); // status='open'\n    expect(detail.attention.pendingSolCratePayout).toBe(true); // crateType='sol' & status='pending'\n    expect(detail.attention.suspiciousReferralLoop).toBe(false); // selfReferral row was false\n\n    // 1 identity + 15 parallel = 16 SQL calls total.\n    expect(mock.calls).toHaveLength(16);\n  });\n\n  it(\"populated (suspicious self-referral): surfaces the loop attention flag from the EXISTS row\", async () => {\n    const responses = [...fullResponses()];\n    // Replace the last (selfReferralIndicator) row with selfReferral=true and\n    // strip the dead/failed/open signals so only the loop flag should fire.\n    responses[15] = [{ selfReferral: true }];\n    responses[6] = [\n      {\n        id: \"rc-2\",\n        amountLamports: \"1000\",\n        status: \"paid\",\n        retryCount: 0,\n        txSignature: \"sig-paid\",\n        error: null,\n        requestedAt: \"2026-04-20T00:00:00.000Z\",\n        processedAt: \"2026-04-20T00:01:00.000Z\",\n      },\n    ];\n    responses[9] = [\n      {\n        id: \"cd-1\",\n        triggerType: \"level_up\",\n        triggerId: \"lvl-3\",\n        crateType: \"sol\",\n        contentsAmount: \"1000\",\n        status: \"granted\",\n        createdAt: \"2026-04-22T00:00:00.000Z\",\n        grantedAt: \"2026-04-22T00:00:30.000Z\",\n      },\n    ];\n    responses[13] = [\n      {\n        id: \"ff-1\",\n        flagType: \"wash_trading\",\n        status: \"dismissed\",\n        relatedId: \"match-1\",\n        createdAt: \"2026-04-20T00:00:00.000Z\",\n        resolvedAt: \"2026-04-20T01:00:00.000Z\",\n      },\n    ];\n    responses[14] = [\n      {\n        id: \"qe-1\",\n        eventType: \"referral_payout\",\n        status: \"processed\",\n        attempts: 1,\n        maxAttempts: 5,\n        scheduledAt: \"2026-04-20T00:00:00.000Z\",\n        createdAt: \"2026-04-20T00:00:00.000Z\",\n        error: null,\n      },\n    ];\n\n    const mock = createSqlMock(responses);\n\n    const detail = await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(detail?.attention.suspiciousReferralLoop).toBe(true);\n    expect(detail?.attention.failedClaim).toBe(false);\n    expect(detail?.attention.deadQueueEvent).toBe(false);\n    expect(detail?.attention.activeFraudFlag).toBe(false);\n    expect(detail?.attention.pendingSolCratePayout).toBe(false);\n  });\n\n  it(\"sparse: every parallel section returns []; defaults still produce a renderable view model\", async () => {\n    const mock = createSqlMock(sparseResponses());\n\n    const detail = await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(detail).not.toBeNull();\n    if (!detail) throw new Error(\"detail\");\n\n    // Empty arrays for every list section.\n    expect(detail.outboundReferees).toEqual([]);\n    expect(detail.linkedAccounts).toEqual([]);\n    expect(detail.recentTelegramLinkTokens).toEqual([]);\n    expect(detail.recentReferralClaims).toEqual([]);\n    expect(detail.recentPointGrants).toEqual([]);\n    expect(detail.recentCrateDrops).toEqual([]);\n    expect(detail.recentGameEntries).toEqual([]);\n    expect(detail.recentTransactions).toEqual([]);\n    expect(detail.fraudFlags).toEqual([]);\n    expect(detail.recentUserQueueEvents).toEqual([]);\n\n    // Defaults from missing-row fallbacks.\n    expect(detail.kolRate).toBeNull();\n    expect(detail.referralEarnings).toEqual({\n      earningsCount: 0,\n      totalReferrerEarnedLamports: \"0\",\n      totalRefereeRebateLamports: \"0\",\n      lastEarnedAt: null,\n    });\n    expect(detail.points).toEqual({\n      balance: \"0\",\n      lifetimeEarned: \"0\",\n      updatedAt: null,\n    });\n    expect(detail.challengeSummary).toEqual({\n      active: 0,\n      completed: 0,\n      expired: 0,\n      total: 0,\n    });\n\n    // No risk signals = attention strip stays clean.\n    expect(detail.attention).toEqual({\n      failedClaim: false,\n      deadQueueEvent: false,\n      activeFraudFlag: false,\n      pendingSolCratePayout: false,\n      suspiciousReferralLoop: false,\n    });\n  });\n\n  it(\"bounded: every recent-list query carries the configured recentLimit / tokenLimit\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit: null,\n      recentLimit: 7,\n      tokenLimit: 4,\n    });\n\n    // Token-limit binding is on the recentTelegramLinkTokens query (call #3).\n    expect(mock.calls[3].text).toContain(\"from telegram_link_tokens\");\n    expect(mock.calls[3].values).toContain(4);\n\n    // recentLimit binding lives on every list query that uses it. Spot-check\n    // the user-bound bigger ones.\n    const checkLimit = (callIdx: number, fragment: string) => {\n      expect(mock.calls[callIdx].text).toContain(fragment);\n      expect(mock.calls[callIdx].values).toContain(7);\n    };\n    checkLimit(6, \"from referral_claims\"); // recentReferralClaims\n    checkLimit(8, \"from point_grants\"); // recentPointGrants\n    checkLimit(9, \"from crate_drops\"); // recentCrateDrops\n    checkLimit(11, \"from game_entries\"); // recentGameEntries\n    checkLimit(12, \"from transactions\"); // recentTransactions\n    checkLimit(13, \"from fraud_flags\"); // fraudFlags\n    checkLimit(14, \"from event_queue\"); // recentUserQueueEvents\n  });\n\n  it(\"bounded: clamps non-positive / fractional limits to safe defaults (>= 1)\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit: null,\n      recentLimit: -5, // clamps up to 1\n      tokenLimit: 2.7, // floors to 2\n    });\n\n    // tokenLimit floored to 2.\n    expect(mock.calls[3].values).toContain(2);\n    // recentLimit clamped up to 1.\n    expect(mock.calls[6].values).toContain(1);\n  });\n\n  it(\"bounded: omits limit overrides → defaults to PEEK_USER_DETAIL_RECENT_LIMIT / PEEK_USER_DETAIL_TOKEN_LIMIT\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    await getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null });\n\n    expect(mock.calls[3].values).toContain(PEEK_USER_DETAIL_TOKEN_LIMIT);\n    expect(mock.calls[6].values).toContain(PEEK_USER_DETAIL_RECENT_LIMIT);\n  });\n\n  it(\"queue events: payload-keyed lookup binds both userId and wallet so backend writers all match\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    await getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null });\n\n    const queueCall = mock.calls[14];\n    expect(queueCall.text).toContain(\"from event_queue\");\n    expect(queueCall.text).toContain(\"payload->>'userId'\");\n    expect(queueCall.text).toContain(\"payload->>'user_id'\");\n    expect(queueCall.text).toContain(\"payload->>'wallet'\");\n    // Bound values include the userId + wallet from the identity row.\n    expect(queueCall.values).toContain(\"u-1\");\n    expect(queueCall.values).toContain(\"wallet-1\");\n  });\n\n  it(\"audit: emits peek.user.view_sensitive once when actorEmail is provided\", async () => {\n    const mock = createSqlMock(fullResponses());\n    const audit = vi.fn<PeekUserDetailAuditFn>().mockResolvedValue(undefined);\n\n    const detail = await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit,\n      actorEmail: \"ops@example.com\",\n      route: \"/users/u-1\",\n      requestId: \"req-42\",\n    });\n\n    expect(detail).not.toBeNull();\n    expect(audit).toHaveBeenCalledTimes(1);\n    expect(audit).toHaveBeenCalledWith({\n      actorEmail: \"ops@example.com\",\n      userId: \"u-1\",\n      route: \"/users/u-1\",\n      requestId: \"req-42\",\n    });\n  });\n\n  it(\"audit: skips emission when actorEmail is missing (unauthenticated path)\", async () => {\n    const mock = createSqlMock(fullResponses());\n    const audit = vi.fn<PeekUserDetailAuditFn>().mockResolvedValue(undefined);\n\n    await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit,\n      // no actorEmail\n    });\n\n    expect(audit).not.toHaveBeenCalled();\n  });\n\n  it(\"audit: skips emission when audit is explicitly null (test path)\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    const detail = await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit: null,\n      actorEmail: \"ops@example.com\",\n    });\n\n    expect(detail).not.toBeNull();\n    // No audit handler was invoked; identity SQL was. Just verify the path\n    // didn't throw.\n  });\n\n  it(\"audit: skips emission when the user is not found, regardless of actor\", async () => {\n    const mock = createSqlMock([[]]);\n    const audit = vi.fn<PeekUserDetailAuditFn>().mockResolvedValue(undefined);\n\n    const detail = await getPeekUserDetail(\"ghost\", {\n      sql: mock.sql,\n      audit,\n      actorEmail: \"ops@example.com\",\n      route: \"/users/ghost\",\n    });\n\n    expect(detail).toBeNull();\n    expect(audit).not.toHaveBeenCalled();\n  });\n\n  it(\"audit: a thrown audit handler does not break the user-detail render\", async () => {\n    const mock = createSqlMock(fullResponses());\n    const audit = vi\n      .fn<PeekUserDetailAuditFn>()\n      .mockRejectedValue(new Error(\"audit insert failed\"));\n\n    const detail = await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit,\n      actorEmail: \"ops@example.com\",\n    });\n\n    expect(detail).not.toBeNull();\n    expect(audit).toHaveBeenCalledTimes(1);\n  });\n\n  it(\"load-error: a rejected non-identity query propagates so the page can render an alert state\", async () => {\n    const responses = [...fullResponses()];\n    responses[5] = new Error(\"connection refused\"); // referralEarnings query\n    const mock = createSqlMock(responses);\n\n    await expect(\n      getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n\n  it(\"identity SQL: still preserves the 303-era linked_accounts join contract\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    await getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null });\n\n    const identitySql = mock.calls[0].text;\n    expect(identitySql).toContain(\"from player_profiles pp\");\n    expect(identitySql).toContain(\"from linked_accounts\");\n    expect(identitySql).toContain(\"provider = 'telegram'\");\n    expect(identitySql).toContain(\"status = 'active'\");\n    expect(identitySql).not.toContain(\"from telegram_link_tokens\");\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":417,"cache_read_input_tokens":154404,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":417},"output_tokens":42,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"aa22a004-7967-4272-b3ce-42c86f057c37","uuid":"3d29668e-8619-4634-b8d1-b9dfaea6b647"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0123qAxRtbEdyZ6ArVRXjtRY","type":"tool_result","content":"The file /workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-peek-user-detail.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"aa22a004-7967-4272-b3ce-42c86f057c37","uuid":"e5a07a3c-6fda-4eba-ae80-420527ac9a7d","timestamp":"2026-04-25T12:07:50.911Z","tool_use_result":{"type":"update","filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-peek-user-detail.test.ts","content":"import { describe, expect, it, vi } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_USER_DETAIL_RECENT_LIMIT,\n  PEEK_USER_DETAIL_TOKEN_LIMIT,\n  formatUserHeading,\n  getPeekUserDetail,\n  type PeekUserDetailAuditFn,\n} from \"../get-peek-user-detail\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\n// Build a SQL mock that returns a sequence of responses, one per call. The\n// query module fires queries[0] (identity) first, then 15 parallel queries via\n// Promise.all in declaration order:\n//   1: outboundReferees\n//   2: linkedAccounts\n//   3: recentTelegramLinkTokens\n//   4: kolRate\n//   5: referralEarnings\n//   6: recentReferralClaims\n//   7: playerPoints\n//   8: recentPointGrants\n//   9: recentCrateDrops\n//   10: challengeSummary\n//   11: recentGameEntries\n//   12: recentTransactions\n//   13: fraudFlags\n//   14: recentUserQueueEvents\n//   15: selfReferralIndicator\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\nconst IDENTITY_ROW = {\n  userId: \"u-1\",\n  username: \"alice\",\n  wallet: \"wallet-1\",\n  joinedAt: \"2026-01-01T00:00:00.000Z\",\n  avatarUrl: \"https://example.com/a.png\",\n  heatMultiplier: \"1.50\",\n  profilePointsBalance: \"100\",\n  referralCode: \"ALICE2026\",\n  referrerUserId: \"u-0\",\n  referrerCode: \"MENTOR\",\n  refereeCount: 3,\n  telegramLinkState: \"active\" as const,\n  linkedAt: \"2026-01-02T00:00:00.000Z\",\n  telegramUserId: \"tg-9001\",\n  telegramUsername: \"alice_tg\",\n};\n\nfunction fullResponses(): ReadonlyArray<ResponseValue> {\n  return [\n    [IDENTITY_ROW],\n    [\n      {\n        refereeUserId: \"u-2\",\n        refereeUsername: \"bob\",\n        createdAt: \"2026-01-03T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"la-1\",\n        provider: \"telegram\",\n        providerAccountId: \"tg-9001\",\n        status: \"active\",\n        telegramUsername: \"alice_tg\",\n        metadataJson: { telegramUsername: \"alice_tg\" },\n        linkedAt: \"2026-01-02T00:00:00.000Z\",\n        updatedAt: \"2026-01-02T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"tlk-1\",\n        status: \"redeemed\",\n        telegramUserId: \"tg-9001\",\n        telegramUsername: \"alice_tg\",\n        expiresAt: \"2026-01-02T01:00:00.000Z\",\n        redeemedAt: \"2026-01-02T00:30:00.000Z\",\n        createdAt: \"2026-01-02T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        rateBps: 250,\n        setBy: \"ops@example.com\",\n        createdAt: \"2026-01-04T00:00:00.000Z\",\n        updatedAt: \"2026-01-04T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        earningsCount: 7,\n        totalReferrerEarnedLamports: \"12345\",\n        totalRefereeRebateLamports: \"6789\",\n        lastEarnedAt: \"2026-04-20T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"rc-1\",\n        amountLamports: \"1000\",\n        status: \"failed\",\n        retryCount: 3,\n        txSignature: null,\n        error: \"RpcError\",\n        requestedAt: \"2026-04-20T00:00:00.000Z\",\n        processedAt: \"2026-04-20T00:01:00.000Z\",\n      },\n    ],\n    [\n      {\n        balance: \"500\",\n        lifetimeEarned: \"1500\",\n        updatedAt: \"2026-04-24T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"pg-1\",\n        sourceType: \"challenge\",\n        sourceId: \"ch-1\",\n        amount: \"10\",\n        createdAt: \"2026-04-23T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"cd-1\",\n        triggerType: \"level_up\",\n        triggerId: \"lvl-3\",\n        crateType: \"sol\",\n        contentsAmount: \"1000\",\n        status: \"pending\",\n        createdAt: \"2026-04-22T00:00:00.000Z\",\n        grantedAt: null,\n      },\n    ],\n    [{ active: 1, completed: 2, expired: 0, total: 3 }],\n    [\n      {\n        id: \"ge-1\",\n        game: \"flipyou\",\n        roundPda: \"pda-1\",\n        matchId: \"match-1\",\n        amountLamports: \"1000000\",\n        side: \"heads\",\n        isWinner: true,\n        payoutLamports: \"1900000\",\n        createdAt: \"2026-04-21T00:00:00.000Z\",\n        settledAt: \"2026-04-21T00:00:30.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"tx-1\",\n        game: \"flipyou\",\n        matchId: \"match-1\",\n        txType: \"payout\",\n        amountLamports: \"1900000\",\n        txSig: \"sig-1\",\n        createdAt: \"2026-04-21T00:00:30.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"ff-1\",\n        flagType: \"wash_trading\",\n        status: \"open\",\n        relatedId: \"match-1\",\n        createdAt: \"2026-04-20T00:00:00.000Z\",\n        resolvedAt: null,\n      },\n    ],\n    [\n      {\n        id: \"qe-1\",\n        eventType: \"referral_payout\",\n        status: \"dead\",\n        attempts: 5,\n        maxAttempts: 5,\n        scheduledAt: \"2026-04-20T00:00:00.000Z\",\n        createdAt: \"2026-04-20T00:00:00.000Z\",\n        error: \"OnChainError\",\n      },\n    ],\n    [{ selfReferral: false }],\n  ];\n}\n\nfunction sparseResponses(): ReadonlyArray<ResponseValue> {\n  return [\n    // Identity row carries minimum-viable values: nullable identity-add-on\n    // fields default to null; the user still has a row in player_profiles.\n    [\n      {\n        userId: \"u-1\",\n        username: null,\n        wallet: \"wallet-sparse\",\n        joinedAt: \"2026-01-01T00:00:00.000Z\",\n        avatarUrl: null,\n        heatMultiplier: \"1.00\",\n        profilePointsBalance: \"0\",\n        referralCode: null,\n        referrerUserId: null,\n        referrerCode: null,\n        refereeCount: 0,\n        telegramLinkState: \"none\",\n        linkedAt: null,\n        telegramUserId: null,\n        telegramUsername: null,\n      },\n    ],\n    [], // outboundReferees\n    [], // linkedAccounts\n    [], // recentTelegramLinkTokens\n    [], // kolRate (no row)\n    [], // referralEarnings (no aggregate row — fallback to defaults)\n    [], // recentReferralClaims\n    [], // playerPoints (no row — fallback to defaults)\n    [], // recentPointGrants\n    [], // recentCrateDrops\n    [], // challengeSummary (no row — fallback to zeros)\n    [], // recentGameEntries\n    [], // recentTransactions\n    [], // fraudFlags\n    [], // recentUserQueueEvents\n    [], // selfReferralIndicator (no row — fallback to false)\n  ];\n}\n\ndescribe(\"formatUserHeading\", () => {\n  it(\"prefers username over user id in the detail header\", () => {\n    expect(formatUserHeading({ userId: \"u_1\", username: \"alice\" })).toBe(\"alice\");\n    expect(formatUserHeading({ userId: \"u_2\", username: null })).toBe(\"u_2\");\n  });\n});\n\ndescribe(\"getPeekUserDetail\", () => {\n  it(\"user not found: returns null after only the identity query, with no parallel calls\", async () => {\n    const mock = createSqlMock([[]]);\n\n    const detail = await getPeekUserDetail(\"missing\", {\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(detail).toBeNull();\n    expect(mock.calls).toHaveLength(1);\n    expect(mock.calls[0].text).toContain(\"from player_profiles pp\");\n  });\n\n  it(\"populated: shapes the full FR-6 user detail across every section\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    const detail = await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(detail).not.toBeNull();\n    if (!detail) throw new Error(\"detail\");\n\n    // Identity (with the FR-6 profile-identity additions)\n    expect(detail.user.userId).toBe(\"u-1\");\n    expect(detail.user.username).toBe(\"alice\");\n    expect(detail.user.wallet).toBe(\"wallet-1\");\n    expect(detail.user.avatarUrl).toBe(\"https://example.com/a.png\");\n    expect(detail.user.heatMultiplier).toBe(\"1.50\");\n    expect(detail.user.profilePointsBalance).toBe(\"100\");\n\n    // Inbound referral + telegram envelope\n    expect(detail.inboundReferral.referrerUserId).toBe(\"u-0\");\n    expect(detail.inboundReferral.referrerCode).toBe(\"MENTOR\");\n    expect(detail.telegram.state).toBe(\"active\");\n    expect(detail.telegram.telegramUsername).toBe(\"alice_tg\");\n\n    // Per-section aggregates\n    expect(detail.outboundReferees).toHaveLength(1);\n    expect(detail.linkedAccounts).toHaveLength(1);\n    expect(detail.recentTelegramLinkTokens).toHaveLength(1);\n    expect(detail.kolRate?.rateBps).toBe(250);\n    expect(detail.referralEarnings.earningsCount).toBe(7);\n    expect(detail.referralEarnings.totalReferrerEarnedLamports).toBe(\"12345\");\n    expect(detail.recentReferralClaims).toHaveLength(1);\n    expect(detail.points.balance).toBe(\"500\");\n    expect(detail.points.lifetimeEarned).toBe(\"1500\");\n    expect(detail.recentPointGrants).toHaveLength(1);\n    expect(detail.recentCrateDrops).toHaveLength(1);\n    expect(detail.challengeSummary.total).toBe(3);\n    expect(detail.recentGameEntries).toHaveLength(1);\n    expect(detail.recentTransactions).toHaveLength(1);\n    expect(detail.fraudFlags).toHaveLength(1);\n    expect(detail.recentUserQueueEvents).toHaveLength(1);\n\n    // Computed attention flags surface every populated risk signal.\n    expect(detail.attention.failedClaim).toBe(true); // status='failed'\n    expect(detail.attention.deadQueueEvent).toBe(true); // status='dead'\n    expect(detail.attention.activeFraudFlag).toBe(true); // status='open'\n    expect(detail.attention.pendingSolCratePayout).toBe(true); // crateType='sol' & status='pending'\n    expect(detail.attention.suspiciousReferralLoop).toBe(false); // selfReferral row was false\n\n    // 1 identity + 15 parallel = 16 SQL calls total.\n    expect(mock.calls).toHaveLength(16);\n  });\n\n  it(\"populated (suspicious self-referral): surfaces the loop attention flag from the EXISTS row\", async () => {\n    const responses = [...fullResponses()];\n    // Replace the last (selfReferralIndicator) row with selfReferral=true and\n    // strip the dead/failed/open signals so only the loop flag should fire.\n    responses[15] = [{ selfReferral: true }];\n    responses[6] = [\n      {\n        id: \"rc-2\",\n        amountLamports: \"1000\",\n        status: \"paid\",\n        retryCount: 0,\n        txSignature: \"sig-paid\",\n        error: null,\n        requestedAt: \"2026-04-20T00:00:00.000Z\",\n        processedAt: \"2026-04-20T00:01:00.000Z\",\n      },\n    ];\n    responses[9] = [\n      {\n        id: \"cd-1\",\n        triggerType: \"level_up\",\n        triggerId: \"lvl-3\",\n        crateType: \"sol\",\n        contentsAmount: \"1000\",\n        status: \"granted\",\n        createdAt: \"2026-04-22T00:00:00.000Z\",\n        grantedAt: \"2026-04-22T00:00:30.000Z\",\n      },\n    ];\n    responses[13] = [\n      {\n        id: \"ff-1\",\n        flagType: \"wash_trading\",\n        status: \"dismissed\",\n        relatedId: \"match-1\",\n        createdAt: \"2026-04-20T00:00:00.000Z\",\n        resolvedAt: \"2026-04-20T01:00:00.000Z\",\n      },\n    ];\n    responses[14] = [\n      {\n        id: \"qe-1\",\n        eventType: \"referral_payout\",\n        status: \"processed\",\n        attempts: 1,\n        maxAttempts: 5,\n        scheduledAt: \"2026-04-20T00:00:00.000Z\",\n        createdAt: \"2026-04-20T00:00:00.000Z\",\n        error: null,\n      },\n    ];\n\n    const mock = createSqlMock(responses);\n\n    const detail = await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(detail?.attention.suspiciousReferralLoop).toBe(true);\n    expect(detail?.attention.failedClaim).toBe(false);\n    expect(detail?.attention.deadQueueEvent).toBe(false);\n    expect(detail?.attention.activeFraudFlag).toBe(false);\n    expect(detail?.attention.pendingSolCratePayout).toBe(false);\n  });\n\n  it(\"sparse: every parallel section returns []; defaults still produce a renderable view model\", async () => {\n    const mock = createSqlMock(sparseResponses());\n\n    const detail = await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(detail).not.toBeNull();\n    if (!detail) throw new Error(\"detail\");\n\n    // Empty arrays for every list section.\n    expect(detail.outboundReferees).toEqual([]);\n    expect(detail.linkedAccounts).toEqual([]);\n    expect(detail.recentTelegramLinkTokens).toEqual([]);\n    expect(detail.recentReferralClaims).toEqual([]);\n    expect(detail.recentPointGrants).toEqual([]);\n    expect(detail.recentCrateDrops).toEqual([]);\n    expect(detail.recentGameEntries).toEqual([]);\n    expect(detail.recentTransactions).toEqual([]);\n    expect(detail.fraudFlags).toEqual([]);\n    expect(detail.recentUserQueueEvents).toEqual([]);\n\n    // Defaults from missing-row fallbacks.\n    expect(detail.kolRate).toBeNull();\n    expect(detail.referralEarnings).toEqual({\n      earningsCount: 0,\n      totalReferrerEarnedLamports: \"0\",\n      totalRefereeRebateLamports: \"0\",\n      lastEarnedAt: null,\n    });\n    expect(detail.points).toEqual({\n      balance: \"0\",\n      lifetimeEarned: \"0\",\n      updatedAt: null,\n    });\n    expect(detail.challengeSummary).toEqual({\n      active: 0,\n      completed: 0,\n      expired: 0,\n      total: 0,\n    });\n\n    // No risk signals = attention strip stays clean.\n    expect(detail.attention).toEqual({\n      failedClaim: false,\n      deadQueueEvent: false,\n      activeFraudFlag: false,\n      pendingSolCratePayout: false,\n      suspiciousReferralLoop: false,\n    });\n  });\n\n  it(\"bounded: every recent-list query carries the configured recentLimit / tokenLimit\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit: null,\n      recentLimit: 7,\n      tokenLimit: 4,\n    });\n\n    // Token-limit binding is on the recentTelegramLinkTokens query (call #3).\n    expect(mock.calls[3].text).toContain(\"from telegram_link_tokens\");\n    expect(mock.calls[3].values).toContain(4);\n\n    // recentLimit binding lives on every list query that uses it. Spot-check\n    // the user-bound bigger ones.\n    const checkLimit = (callIdx: number, fragment: string) => {\n      expect(mock.calls[callIdx].text).toContain(fragment);\n      expect(mock.calls[callIdx].values).toContain(7);\n    };\n    checkLimit(6, \"from referral_claims\"); // recentReferralClaims\n    checkLimit(8, \"from point_grants\"); // recentPointGrants\n    checkLimit(9, \"from crate_drops\"); // recentCrateDrops\n    checkLimit(11, \"from game_entries\"); // recentGameEntries\n    checkLimit(12, \"from transactions\"); // recentTransactions\n    checkLimit(13, \"from fraud_flags\"); // fraudFlags\n    checkLimit(14, \"from event_queue\"); // recentUserQueueEvents\n  });\n\n  it(\"bounded: clamps non-positive / fractional limits to safe defaults (>= 1)\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit: null,\n      recentLimit: -5, // clamps up to 1\n      tokenLimit: 2.7, // floors to 2\n    });\n\n    // tokenLimit floored to 2.\n    expect(mock.calls[3].values).toContain(2);\n    // recentLimit clamped up to 1.\n    expect(mock.calls[6].values).toContain(1);\n  });\n\n  it(\"bounded: omits limit overrides → defaults to PEEK_USER_DETAIL_RECENT_LIMIT / PEEK_USER_DETAIL_TOKEN_LIMIT\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    await getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null });\n\n    expect(mock.calls[3].values).toContain(PEEK_USER_DETAIL_TOKEN_LIMIT);\n    expect(mock.calls[6].values).toContain(PEEK_USER_DETAIL_RECENT_LIMIT);\n  });\n\n  it(\"queue events: payload-keyed lookup binds both userId and wallet so backend writers all match\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    await getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null });\n\n    const queueCall = mock.calls[14];\n    expect(queueCall.text).toContain(\"from event_queue\");\n    expect(queueCall.text).toContain(\"payload->>'userId'\");\n    expect(queueCall.text).toContain(\"payload->>'user_id'\");\n    expect(queueCall.text).toContain(\"payload->>'wallet'\");\n    // Bound values include the userId + wallet from the identity row.\n    expect(queueCall.values).toContain(\"u-1\");\n    expect(queueCall.values).toContain(\"wallet-1\");\n  });\n\n  it(\"audit: emits peek.user.view_sensitive once when actorEmail is provided\", async () => {\n    const mock = createSqlMock(fullResponses());\n    const audit = vi.fn<PeekUserDetailAuditFn>().mockResolvedValue(undefined);\n\n    const detail = await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit,\n      actorEmail: \"ops@example.com\",\n      route: \"/users/u-1\",\n      requestId: \"req-42\",\n    });\n\n    expect(detail).not.toBeNull();\n    expect(audit).toHaveBeenCalledTimes(1);\n    expect(audit).toHaveBeenCalledWith({\n      actorEmail: \"ops@example.com\",\n      userId: \"u-1\",\n      route: \"/users/u-1\",\n      requestId: \"req-42\",\n    });\n  });\n\n  it(\"audit: skips emission when actorEmail is missing (unauthenticated path)\", async () => {\n    const mock = createSqlMock(fullResponses());\n    const audit = vi.fn<PeekUserDetailAuditFn>().mockResolvedValue(undefined);\n\n    await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit,\n      // no actorEmail\n    });\n\n    expect(audit).not.toHaveBeenCalled();\n  });\n\n  it(\"audit: skips emission when audit is explicitly null (test path)\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    const detail = await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit: null,\n      actorEmail: \"ops@example.com\",\n    });\n\n    expect(detail).not.toBeNull();\n    // No audit handler was invoked; identity SQL was. Just verify the path\n    // didn't throw.\n  });\n\n  it(\"audit: skips emission when the user is not found, regardless of actor\", async () => {\n    const mock = createSqlMock([[]]);\n    const audit = vi.fn<PeekUserDetailAuditFn>().mockResolvedValue(undefined);\n\n    const detail = await getPeekUserDetail(\"ghost\", {\n      sql: mock.sql,\n      audit,\n      actorEmail: \"ops@example.com\",\n      route: \"/users/ghost\",\n    });\n\n    expect(detail).toBeNull();\n    expect(audit).not.toHaveBeenCalled();\n  });\n\n  it(\"audit: a thrown audit handler does not break the user-detail render\", async () => {\n    const mock = createSqlMock(fullResponses());\n    const audit = vi\n      .fn<PeekUserDetailAuditFn>()\n      .mockRejectedValue(new Error(\"audit insert failed\"));\n\n    const detail = await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit,\n      actorEmail: \"ops@example.com\",\n    });\n\n    expect(detail).not.toBeNull();\n    expect(audit).toHaveBeenCalledTimes(1);\n  });\n\n  it(\"load-error: a rejected non-identity query propagates so the page can render an alert state\", async () => {\n    const responses = [...fullResponses()];\n    responses[5] = new Error(\"connection refused\"); // referralEarnings query\n    const mock = createSqlMock(responses);\n\n    await expect(\n      getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n\n  it(\"identity SQL: still preserves the 303-era linked_accounts join contract\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    await getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null });\n\n    const identitySql = mock.calls[0].text;\n    expect(identitySql).toContain(\"from player_profiles pp\");\n    expect(identitySql).toContain(\"from linked_accounts\");\n    expect(identitySql).toContain(\"provider = 'telegram'\");\n    expect(identitySql).toContain(\"status = 'active'\");\n    expect(identitySql).not.toContain(\"from telegram_link_tokens\");\n  });\n});\n","structuredPatch":[{"oldStart":1,"oldLines":9,"newStart":1,"newLines":622,"lines":["-import { describe, expect, it } from \"vitest\";","-import { formatUserHeading } from \"../get-peek-user-detail\";","+import { describe, expect, it, vi } from \"vitest\";","+import type { Sql } from \"postgres\";","+import {","+  PEEK_USER_DETAIL_RECENT_LIMIT,","+  PEEK_USER_DETAIL_TOKEN_LIMIT,","+  formatUserHeading,","+  getPeekUserDetail,","+  type PeekUserDetailAuditFn,","+} from \"../get-peek-user-detail\";"," ","+type SqlCall = {","+  text: string;","+  values: ReadonlyArray<unknown>;","+};","+","+type ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;","+","+type SqlMock = {","+  sql: Sql;","+  calls: ReadonlyArray<SqlCall>;","+};","+","+// Build a SQL mock that returns a sequence of responses, one per call. The","+// query module fires queries[0] (identity) first, then 15 parallel queries via","+// Promise.all in declaration order:","+//   1: outboundReferees","+//   2: linkedAccounts","+//   3: recentTelegramLinkTokens","+//   4: kolRate","+//   5: referralEarnings","+//   6: recentReferralClaims","+//   7: playerPoints","+//   8: recentPointGrants","+//   9: recentCrateDrops","+//   10: challengeSummary","+//   11: recentGameEntries","+//   12: recentTransactions","+//   13: fraudFlags","+//   14: recentUserQueueEvents","+//   15: selfReferralIndicator","+function createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {","+  const calls: SqlCall[] = [];","+  let cursor = 0;","+","+  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {","+    const text = [...strings].join(\"?\");","+    calls.push({ text, values: [...values] });","+    const next = responses[cursor++];","+    if (next instanceof Error) return Promise.reject(next);","+    return Promise.resolve(next ?? []);","+  };","+","+  const sql = fn as unknown as Sql;","+  return { sql, calls };","+}","+","+const IDENTITY_ROW = {","+  userId: \"u-1\",","+  username: \"alice\",","+  wallet: \"wallet-1\",","+  joinedAt: \"2026-01-01T00:00:00.000Z\",","+  avatarUrl: \"https://example.com/a.png\",","+  heatMultiplier: \"1.50\",","+  profilePointsBalance: \"100\",","+  referralCode: \"ALICE2026\",","+  referrerUserId: \"u-0\",","+  referrerCode: \"MENTOR\",","+  refereeCount: 3,","+  telegramLinkState: \"active\" as const,","+  linkedAt: \"2026-01-02T00:00:00.000Z\",","+  telegramUserId: \"tg-9001\",","+  telegramUsername: \"alice_tg\",","+};","+","+function fullResponses(): ReadonlyArray<ResponseValue> {","+  return [","+    [IDENTITY_ROW],","+    [","+      {","+        refereeUserId: \"u-2\",","+        refereeUsername: \"bob\",","+        createdAt: \"2026-01-03T00:00:00.000Z\",","+      },","+    ],","+    [","+      {","+        id: \"la-1\",","+        provider: \"telegram\",","+        providerAccountId: \"tg-9001\",","+        status: \"active\",","+        telegramUsername: \"alice_tg\",","+        metadataJson: { telegramUsername: \"alice_tg\" },","+        linkedAt: \"2026-01-02T00:00:00.000Z\",","+        updatedAt: \"2026-01-02T00:00:00.000Z\",","+      },","+    ],","+    [","+      {","+        id: \"tlk-1\",","+        status: \"redeemed\",","+        telegramUserId: \"tg-9001\",","+        telegramUsername: \"alice_tg\",","+        expiresAt: \"2026-01-02T01:00:00.000Z\",","+        redeemedAt: \"2026-01-02T00:30:00.000Z\",","+        createdAt: \"2026-01-02T00:00:00.000Z\",","+      },","+    ],","+    [","+      {","+        rateBps: 250,","+        setBy: \"ops@example.com\",","+        createdAt: \"2026-01-04T00:00:00.000Z\",","+        updatedAt: \"2026-01-04T00:00:00.000Z\",","+      },","+    ],","+    [","+      {","+        earningsCount: 7,","+        totalReferrerEarnedLamports: \"12345\",","+        totalRefereeRebateLamports: \"6789\",","+        lastEarnedAt: \"2026-04-20T00:00:00.000Z\",","+      },","+    ],","+    [","+      {","+        id: \"rc-1\",","+        amountLamports: \"1000\",","+        status: \"failed\",","+        retryCount: 3,","+        txSignature: null,","+        error: \"RpcError\",","+        requestedAt: \"2026-04-20T00:00:00.000Z\",","+        processedAt: \"2026-04-20T00:01:00.000Z\",","+      },","+    ],","+    [","+      {","+        balance: \"500\",","+        lifetimeEarned: \"1500\",","+        updatedAt: \"2026-04-24T00:00:00.000Z\",","+      },","+    ],","+    [","+      {","+        id: \"pg-1\",","+        sourceType: \"challenge\",","+        sourceId: \"ch-1\",","+        amount: \"10\",","+        createdAt: \"2026-04-23T00:00:00.000Z\",","+      },","+    ],","+    [","+      {","+        id: \"cd-1\",","+        triggerType: \"level_up\",","+        triggerId: \"lvl-3\",","+        crateType: \"sol\",","+        contentsAmount: \"1000\",","+        status: \"pending\",","+        createdAt: \"2026-04-22T00:00:00.000Z\",","+        grantedAt: null,","+      },","+    ],","+    [{ active: 1, completed: 2, expired: 0, total: 3 }],","+    [","+      {","+        id: \"ge-1\",","+        game: \"flipyou\",","+        roundPda: \"pda-1\",","+        matchId: \"match-1\",","+        amountLamports: \"1000000\",","+        side: \"heads\",","+        isWinner: true,","+        payoutLamports: \"1900000\",","+        createdAt: \"2026-04-21T00:00:00.000Z\",","+        settledAt: \"2026-04-21T00:00:30.000Z\",","+      },","+    ],","+    [","+      {","+        id: \"tx-1\",","+        game: \"flipyou\",","+        matchId: \"match-1\",","+        txType: \"payout\",","+        amountLamports: \"1900000\",","+        txSig: \"sig-1\",","+        createdAt: \"2026-04-21T00:00:30.000Z\",","+      },","+    ],","+    [","+      {","+        id: \"ff-1\",","+        flagType: \"wash_trading\",","+        status: \"open\",","+        relatedId: \"match-1\",","+        createdAt: \"2026-04-20T00:00:00.000Z\",","+        resolvedAt: null,","+      },","+    ],","+    [","+      {","+        id: \"qe-1\",","+        eventType: \"referral_payout\",","+        status: \"dead\",","+        attempts: 5,","+        maxAttempts: 5,","+        scheduledAt: \"2026-04-20T00:00:00.000Z\",","+        createdAt: \"2026-04-20T00:00:00.000Z\",","+        error: \"OnChainError\",","+      },","+    ],","+    [{ selfReferral: false }],","+  ];","+}","+","+function sparseResponses(): ReadonlyArray<ResponseValue> {","+  return [","+    // Identity row carries minimum-viable values: nullable identity-add-on","+    // fields default to null; the user still has a row in player_profiles.","+    [","+      {","+        userId: \"u-1\",","+        username: null,","+        wallet: \"wallet-sparse\",","+        joinedAt: \"2026-01-01T00:00:00.000Z\",","+        avatarUrl: null,","+        heatMultiplier: \"1.00\",","+        profilePointsBalance: \"0\",","+        referralCode: null,","+        referrerUserId: null,","+        referrerCode: null,","+        refereeCount: 0,","+        telegramLinkState: \"none\",","+        linkedAt: null,","+        telegramUserId: null,","+        telegramUsername: null,","+      },","+    ],","+    [], // outboundReferees","+    [], // linkedAccounts","+    [], // recentTelegramLinkTokens","+    [], // kolRate (no row)","+    [], // referralEarnings (no aggregate row — fallback to defaults)","+    [], // recentReferralClaims","+    [], // playerPoints (no row — fallback to defaults)","+    [], // recentPointGrants","+    [], // recentCrateDrops","+    [], // challengeSummary (no row — fallback to zeros)","+    [], // recentGameEntries","+    [], // recentTransactions","+    [], // fraudFlags","+    [], // recentUserQueueEvents","+    [], // selfReferralIndicator (no row — fallback to false)","+  ];","+}","+"," describe(\"formatUserHeading\", () => {","   it(\"prefers username over user id in the detail header\", () => {","     expect(formatUserHeading({ userId: \"u_1\", username: \"alice\" })).toBe(\"alice\");","     expect(formatUserHeading({ userId: \"u_2\", username: null })).toBe(\"u_2\");","   });"," });","+","+describe(\"getPeekUserDetail\", () => {","+  it(\"user not found: returns null after only the identity query, with no parallel calls\", async () => {","+    const mock = createSqlMock([[]]);","+","+    const detail = await getPeekUserDetail(\"missing\", {","+      sql: mock.sql,","+      audit: null,","+    });","+","+    expect(detail).toBeNull();","+    expect(mock.calls).toHaveLength(1);","+    expect(mock.calls[0].text).toContain(\"from player_profiles pp\");","+  });","+","+  it(\"populated: shapes the full FR-6 user detail across every section\", async () => {","+    const mock = createSqlMock(fullResponses());","+","+    const detail = await getPeekUserDetail(\"u-1\", {","+      sql: mock.sql,","+      audit: null,","+    });","+","+    expect(detail).not.toBeNull();","+    if (!detail) throw new Error(\"detail\");","+","+    // Identity (with the FR-6 profile-identity additions)","+    expect(detail.user.userId).toBe(\"u-1\");","+    expect(detail.user.username).toBe(\"alice\");","+    expect(detail.user.wallet).toBe(\"wallet-1\");","+    expect(detail.user.avatarUrl).toBe(\"https://example.com/a.png\");","+    expect(detail.user.heatMultiplier).toBe(\"1.50\");","+    expect(detail.user.profilePointsBalance).toBe(\"100\");","+","+    // Inbound referral + telegram envelope","+    expect(detail.inboundReferral.referrerUserId).toBe(\"u-0\");","+    expect(detail.inboundReferral.referrerCode).toBe(\"MENTOR\");","+    expect(detail.telegram.state).toBe(\"active\");","+    expect(detail.telegram.telegramUsername).toBe(\"alice_tg\");","+","+    // Per-section aggregates","+    expect(detail.outboundReferees).toHaveLength(1);","+    expect(detail.linkedAccounts).toHaveLength(1);","+    expect(detail.recentTelegramLinkTokens).toHaveLength(1);","+    expect(detail.kolRate?.rateBps).toBe(250);","+    expect(detail.referralEarnings.earningsCount).toBe(7);","+    expect(detail.referralEarnings.totalReferrerEarnedLamports).toBe(\"12345\");","+    expect(detail.recentReferralClaims).toHaveLength(1);","+    expect(detail.points.balance).toBe(\"500\");","+    expect(detail.points.lifetimeEarned).toBe(\"1500\");","+    expect(detail.recentPointGrants).toHaveLength(1);","+    expect(detail.recentCrateDrops).toHaveLength(1);","+    expect(detail.challengeSummary.total).toBe(3);","+    expect(detail.recentGameEntries).toHaveLength(1);","+    expect(detail.recentTransactions).toHaveLength(1);","+    expect(detail.fraudFlags).toHaveLength(1);","+    expect(detail.recentUserQueueEvents).toHaveLength(1);","+","+    // Computed attention flags surface every populated risk signal.","+    expect(detail.attention.failedClaim).toBe(true); // status='failed'","+    expect(detail.attention.deadQueueEvent).toBe(true); // status='dead'","+    expect(detail.attention.activeFraudFlag).toBe(true); // status='open'","+    expect(detail.attention.pendingSolCratePayout).toBe(true); // crateType='sol' & status='pending'","+    expect(detail.attention.suspiciousReferralLoop).toBe(false); // selfReferral row was false","+","+    // 1 identity + 15 parallel = 16 SQL calls total.","+    expect(mock.calls).toHaveLength(16);","+  });","+","+  it(\"populated (suspicious self-referral): surfaces the loop attention flag from the EXISTS row\", async () => {","+    const responses = [...fullResponses()];","+    // Replace the last (selfReferralIndicator) row with selfReferral=true and","+    // strip the dead/failed/open signals so only the loop flag should fire.","+    responses[15] = [{ selfReferral: true }];","+    responses[6] = [","+      {","+        id: \"rc-2\",","+        amountLamports: \"1000\",","+        status: \"paid\",","+        retryCount: 0,","+        txSignature: \"sig-paid\",","+        error: null,","+        requestedAt: \"2026-04-20T00:00:00.000Z\",","+        processedAt: \"2026-04-20T00:01:00.000Z\",","+      },","+    ];","+    responses[9] = [","+      {","+        id: \"cd-1\",","+        triggerType: \"level_up\",","+        triggerId: \"lvl-3\",","+        crateType: \"sol\",","+        contentsAmount: \"1000\",","+        status: \"granted\",","+        createdAt: \"2026-04-22T00:00:00.000Z\",","+        grantedAt: \"2026-04-22T00:00:30.000Z\",","+      },","+    ];","+    responses[13] = [","+      {","+        id: \"ff-1\",","+        flagType: \"wash_trading\",","+        status: \"dismissed\",","+        relatedId: \"match-1\",","+        createdAt: \"2026-04-20T00:00:00.000Z\",","+        resolvedAt: \"2026-04-20T01:00:00.000Z\",","+      },","+    ];","+    responses[14] = [","+      {","+        id: \"qe-1\",","+        eventType: \"referral_payout\",","+        status: \"processed\",","+        attempts: 1,","+        maxAttempts: 5,","+        scheduledAt: \"2026-04-20T00:00:00.000Z\",","+        createdAt: \"2026-04-20T00:00:00.000Z\",","+        error: null,","+      },","+    ];","+","+    const mock = createSqlMock(responses);","+","+    const detail = await getPeekUserDetail(\"u-1\", {","+      sql: mock.sql,","+      audit: null,","+    });","+","+    expect(detail?.attention.suspiciousReferralLoop).toBe(true);","+    expect(detail?.attention.failedClaim).toBe(false);","+    expect(detail?.attention.deadQueueEvent).toBe(false);","+    expect(detail?.attention.activeFraudFlag).toBe(false);","+    expect(detail?.attention.pendingSolCratePayout).toBe(false);","+  });","+","+  it(\"sparse: every parallel section returns []; defaults still produce a renderable view model\", async () => {","+    const mock = createSqlMock(sparseResponses());","+","+    const detail = await getPeekUserDetail(\"u-1\", {","+      sql: mock.sql,","+      audit: null,","+    });","+","+    expect(detail).not.toBeNull();","+    if (!detail) throw new Error(\"detail\");","+","+    // Empty arrays for every list section.","+    expect(detail.outboundReferees).toEqual([]);","+    expect(detail.linkedAccounts).toEqual([]);","+    expect(detail.recentTelegramLinkTokens).toEqual([]);","+    expect(detail.recentReferralClaims).toEqual([]);","+    expect(detail.recentPointGrants).toEqual([]);","+    expect(detail.recentCrateDrops).toEqual([]);","+    expect(detail.recentGameEntries).toEqual([]);","+    expect(detail.recentTransactions).toEqual([]);","+    expect(detail.fraudFlags).toEqual([]);","+    expect(detail.recentUserQueueEvents).toEqual([]);","+","+    // Defaults from missing-row fallbacks.","+    expect(detail.kolRate).toBeNull();","+    expect(detail.referralEarnings).toEqual({","+      earningsCount: 0,","+      totalReferrerEarnedLamports: \"0\",","+      totalRefereeRebateLamports: \"0\",","+      lastEarnedAt: null,","+    });","+    expect(detail.points).toEqual({","+      balance: \"0\",","+      lifetimeEarned: \"0\",","+      updatedAt: null,","+    });","+    expect(detail.challengeSummary).toEqual({","+      active: 0,","+      completed: 0,","+      expired: 0,","+      total: 0,","+    });","+","+    // No risk signals = attention strip stays clean.","+    expect(detail.attention).toEqual({","+      failedClaim: false,","+      deadQueueEvent: false,","+      activeFraudFlag: false,","+      pendingSolCratePayout: false,","+      suspiciousReferralLoop: false,","+    });","+  });","+","+  it(\"bounded: every recent-list query carries the configured recentLimit / tokenLimit\", async () => {","+    const mock = createSqlMock(fullResponses());","+","+    await getPeekUserDetail(\"u-1\", {","+      sql: mock.sql,","+      audit: null,","+      recentLimit: 7,","+      tokenLimit: 4,","+    });","+","+    // Token-limit binding is on the recentTelegramLinkTokens query (call #3).","+    expect(mock.calls[3].text).toContain(\"from telegram_link_tokens\");","+    expect(mock.calls[3].values).toContain(4);","+","+    // recentLimit binding lives on every list query that uses it. Spot-check","+    // the user-bound bigger ones.","+    const checkLimit = (callIdx: number, fragment: string) => {","+      expect(mock.calls[callIdx].text).toContain(fragment);","+      expect(mock.calls[callIdx].values).toContain(7);","+    };","+    checkLimit(6, \"from referral_claims\"); // recentReferralClaims","+    checkLimit(8, \"from point_grants\"); // recentPointGrants","+    checkLimit(9, \"from crate_drops\"); // recentCrateDrops","+    checkLimit(11, \"from game_entries\"); // recentGameEntries","+    checkLimit(12, \"from transactions\"); // recentTransactions","+    checkLimit(13, \"from fraud_flags\"); // fraudFlags","+    checkLimit(14, \"from event_queue\"); // recentUserQueueEvents","+  });","+","+  it(\"bounded: clamps non-positive / fractional limits to safe defaults (>= 1)\", async () => {","+    const mock = createSqlMock(fullResponses());","+","+    await getPeekUserDetail(\"u-1\", {","+      sql: mock.sql,","+      audit: null,","+      recentLimit: -5, // clamps up to 1","+      tokenLimit: 2.7, // floors to 2","+    });","+","+    // tokenLimit floored to 2.","+    expect(mock.calls[3].values).toContain(2);","+    // recentLimit clamped up to 1.","+    expect(mock.calls[6].values).toContain(1);","+  });","+","+  it(\"bounded: omits limit overrides → defaults to PEEK_USER_DETAIL_RECENT_LIMIT / PEEK_USER_DETAIL_TOKEN_LIMIT\", async () => {","+    const mock = createSqlMock(fullResponses());","+","+    await getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null });","+","+    expect(mock.calls[3].values).toContain(PEEK_USER_DETAIL_TOKEN_LIMIT);","+    expect(mock.calls[6].values).toContain(PEEK_USER_DETAIL_RECENT_LIMIT);","+  });","+","+  it(\"queue events: payload-keyed lookup binds both userId and wallet so backend writers all match\", async () => {","+    const mock = createSqlMock(fullResponses());","+","+    await getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null });","+","+    const queueCall = mock.calls[14];","+    expect(queueCall.text).toContain(\"from event_queue\");","+    expect(queueCall.text).toContain(\"payload->>'userId'\");","+    expect(queueCall.text).toContain(\"payload->>'user_id'\");","+    expect(queueCall.text).toContain(\"payload->>'wallet'\");","+    // Bound values include the userId + wallet from the identity row.","+    expect(queueCall.values).toContain(\"u-1\");","+    expect(queueCall.values).toContain(\"wallet-1\");","+  });","+","+  it(\"audit: emits peek.user.view_sensitive once when actorEmail is provided\", async () => {","+    const mock = createSqlMock(fullResponses());","+    const audit = vi.fn<PeekUserDetailAuditFn>().mockResolvedValue(undefined);","+","+    const detail = await getPeekUserDetail(\"u-1\", {","+      sql: mock.sql,","+      audit,","+      actorEmail: \"ops@example.com\",","+      route: \"/users/u-1\",","+      requestId: \"req-42\",","+    });","+","+    expect(detail).not.toBeNull();","+    expect(audit).toHaveBeenCalledTimes(1);","+    expect(audit).toHaveBeenCalledWith({","+      actorEmail: \"ops@example.com\",","+      userId: \"u-1\",","+      route: \"/users/u-1\",","+      requestId: \"req-42\",","+    });","+  });","+","+  it(\"audit: skips emission when actorEmail is missing (unauthenticated path)\", async () => {","+    const mock = createSqlMock(fullResponses());","+    const audit = vi.fn<PeekUserDetailAuditFn>().mockResolvedValue(undefined);","+","+    await getPeekUserDetail(\"u-1\", {","+      sql: mock.sql,","+      audit,","+      // no actorEmail","+    });","+","+    expect(audit).not.toHaveBeenCalled();","+  });","+","+  it(\"audit: skips emission when audit is explicitly null (test path)\", async () => {","+    const mock = createSqlMock(fullResponses());","+","+    const detail = await getPeekUserDetail(\"u-1\", {","+      sql: mock.sql,","+      audit: null,","+      actorEmail: \"ops@example.com\",","+    });","+","+    expect(detail).not.toBeNull();","+    // No audit handler was invoked; identity SQL was. Just verify the path","+    // didn't throw.","+  });","+","+  it(\"audit: skips emission when the user is not found, regardless of actor\", async () => {","+    const mock = createSqlMock([[]]);","+    const audit = vi.fn<PeekUserDetailAuditFn>().mockResolvedValue(undefined);","+","+    const detail = await getPeekUserDetail(\"ghost\", {","+      sql: mock.sql,","+      audit,","+      actorEmail: \"ops@example.com\",","+      route: \"/users/ghost\",","+    });","+","+    expect(detail).toBeNull();","+    expect(audit).not.toHaveBeenCalled();","+  });","+","+  it(\"audit: a thrown audit handler does not break the user-detail render\", async () => {","+    const mock = createSqlMock(fullResponses());","+    const audit = vi","+      .fn<PeekUserDetailAuditFn>()","+      .mockRejectedValue(new Error(\"audit insert failed\"));","+","+    const detail = await getPeekUserDetail(\"u-1\", {","+      sql: mock.sql,","+      audit,","+      actorEmail: \"ops@example.com\",","+    });","+","+    expect(detail).not.toBeNull();","+    expect(audit).toHaveBeenCalledTimes(1);","+  });","+","+  it(\"load-error: a rejected non-identity query propagates so the page can render an alert state\", async () => {","+    const responses = [...fullResponses()];","+    responses[5] = new Error(\"connection refused\"); // referralEarnings query","+    const mock = createSqlMock(responses);","+","+    await expect(","+      getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null }),","+    ).rejects.toThrowError(\"connection refused\");","+  });","+","+  it(\"identity SQL: still preserves the 303-era linked_accounts join contract\", async () => {","+    const mock = createSqlMock(fullResponses());","+","+    await getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null });","+","+    const identitySql = mock.calls[0].text;","+    expect(identitySql).toContain(\"from player_profiles pp\");","+    expect(identitySql).toContain(\"from linked_accounts\");","+    expect(identitySql).toContain(\"provider = 'telegram'\");","+    expect(identitySql).toContain(\"status = 'active'\");","+    expect(identitySql).not.toContain(\"from telegram_link_tokens\");","+  });","+});"]}],"originalFile":"import { describe, expect, it } from \"vitest\";\nimport { formatUserHeading } from \"../get-peek-user-detail\";\n\ndescribe(\"formatUserHeading\", () => {\n  it(\"prefers username over user id in the detail header\", () => {\n    expect(formatUserHeading({ userId: \"u_1\", username: \"alice\" })).toBe(\"alice\");\n    expect(formatUserHeading({ userId: \"u_2\", username: null })).toBe(\"u_2\");\n  });\n});\n","userModified":false}}
