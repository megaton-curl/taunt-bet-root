{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MMo7XcjD8ewHE2Ue4h5uHf","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport type { Sql } from \"postgres\";\n3\timport {\n4\t  PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT,\n5\t  PEEK_SEARCH_MAX_PER_GROUP_LIMIT,\n6\t  PEEK_SEARCH_ENTITY_TYPES,\n7\t  type PeekSearchEntityType,\n8\t  type PeekSearchQueryClass,\n9\t} from \"../../../../lib/types/peek\";\n10\timport {\n11\t  classifyPeekSearchQuery,\n12\t  getUniversalSearchResults,\n13\t} from \"../universal-search\";\n14\t\n15\ttype SqlCall = {\n16\t  text: string;\n17\t  values: ReadonlyArray<unknown>;\n18\t};\n19\t\n20\ttype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n21\t\n22\ttype SqlMock = {\n23\t  sql: Sql;\n24\t  calls: ReadonlyArray<SqlCall>;\n25\t};\n26\t\n27\t// Build a SQL mock that returns a sequence of responses, one per call. The\n28\t// universal search runs every entity-class query in parallel via Promise.all.\n29\t// All six search functions kick off synchronously so the *first* SQL call\n30\t// from each fires in declaration order (users, referrals, linked, rounds\n31\t// flipPot, transactions, queueEvents — numeric only). Then microtasks resume\n32\t// the searchRounds continuation which fires the second `await sql` against\n33\t// closecall_rounds. So a non-numeric query produces 6 mock calls in the\n34\t// order: users(0) → referrals(1) → linked(2) → flipPot(3) → transactions(4)\n35\t// → closeCall(5). A numeric query produces 7 calls: users(0) → referrals(1)\n36\t// → linked(2) → flipPot(3) → transactions(4) → queueEvents(5) → closeCall(6).\n37\tfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n38\t  const calls: SqlCall[] = [];\n39\t  let cursor = 0;\n40\t\n41\t  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n42\t    const text = [...strings].join(\"?\");\n43\t    calls.push({ text, values: [...values] });\n44\t    const next = responses[cursor++];\n45\t    if (next instanceof Error) return Promise.reject(next);\n46\t    return Promise.resolve(next ?? []);\n47\t  };\n48\t\n49\t  const sql = fn as unknown as Sql;\n50\t  return { sql, calls };\n51\t}\n52\t\n53\tconst EMPTY_SIX = [[], [], [], [], [], []] as ReadonlyArray<ResponseValue>;\n54\tconst EMPTY_SEVEN = [[], [], [], [], [], [], []] as ReadonlyArray<ResponseValue>;\n55\t\n56\tdescribe(\"classifyPeekSearchQuery\", () => {\n57\t  // Every supported PeekSearchQueryClass label gets at least one positive case\n58\t  // so the audit-summary string can be reasoned about deterministically.\n59\t  const cases: Array<[string, PeekSearchQueryClass]> = [\n60\t    [\"\", \"empty\"],\n61\t    [\"   \", \"empty\"],\n62\t    [\"just some words\", \"free_text\"],\n63\t    [\n64\t      \"11111111-1111-1111-1111-111111111111\",\n65\t      \"free_text\", // UUIDs go to free_text per the heuristic comment\n66\t    ],\n67\t    [\"12345\", \"queue_event_id\"],\n68\t    [\"1234567890123456789\", \"telegram_provider_id\"], // 19 digits > 18\n69\t    [\"abcdef0123456789\", \"match_id\"], // 16-char hex\n70\t    [\n71\t      \"5tWqN7ykNWtXesjaGCu3JoGvU2STNUP6axQjqfA\",\n72\t      \"round_pda\", // 39 base58 chars in [32,44]\n73\t    ],\n74\t    [\n75\t      \"5VfYDnXUcS6mWY3cQy4ipcM5LQqM4XV4nHe89oLQGn7awgJZpF8aWxa9HXP15GgyCcXWXP1aTH8qzuc5whTvP3Da\",\n76\t      \"tx_signature\", // ≥80 base58 chars\n77\t    ],\n78\t    [\"@operator\", \"telegram_username\"],\n79\t    [\"KOL2026\", \"referral_code\"],\n80\t    [\"alice_99\", \"username\"],\n81\t  ];\n82\t\n83\t  it.each(cases)(\"%j classifies as %s\", (input, expected) => {\n84\t    expect(classifyPeekSearchQuery(input)).toBe(expected);\n85\t  });\n86\t\n87\t  it(\"strips a leading @ before classification but still labels as telegram_username when text remains\", () => {\n88\t    expect(classifyPeekSearchQuery(\"@alice_99\")).toBe(\"telegram_username\");\n89\t  });\n90\t});\n91\t\n92\tdescribe(\"getUniversalSearchResults\", () => {\n93\t  it(\"empty query: short-circuits, no SQL calls, returns empty groups for every entity type\", async () => {\n94\t    const mock = createSqlMock([]);\n95\t\n96\t    const response = await getUniversalSearchResults({\n97\t      query: \"   \",\n98\t      actorEmail: \"ops@example.com\",\n99\t      sql: mock.sql,\n100\t      audit: null,"}]},"parent_tool_use_id":null,"session_id":"aa22a004-7967-4272-b3ce-42c86f057c37","uuid":"0f642b5d-92cf-4291-aa68-3109852b7960","timestamp":"2026-04-25T12:04:21.478Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/universal-search.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT,\n  PEEK_SEARCH_MAX_PER_GROUP_LIMIT,\n  PEEK_SEARCH_ENTITY_TYPES,\n  type PeekSearchEntityType,\n  type PeekSearchQueryClass,\n} from \"../../../../lib/types/peek\";\nimport {\n  classifyPeekSearchQuery,\n  getUniversalSearchResults,\n} from \"../universal-search\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\n// Build a SQL mock that returns a sequence of responses, one per call. The\n// universal search runs every entity-class query in parallel via Promise.all.\n// All six search functions kick off synchronously so the *first* SQL call\n// from each fires in declaration order (users, referrals, linked, rounds\n// flipPot, transactions, queueEvents — numeric only). Then microtasks resume\n// the searchRounds continuation which fires the second `await sql` against\n// closecall_rounds. So a non-numeric query produces 6 mock calls in the\n// order: users(0) → referrals(1) → linked(2) → flipPot(3) → transactions(4)\n// → closeCall(5). A numeric query produces 7 calls: users(0) → referrals(1)\n// → linked(2) → flipPot(3) → transactions(4) → queueEvents(5) → closeCall(6).\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\nconst EMPTY_SIX = [[], [], [], [], [], []] as ReadonlyArray<ResponseValue>;\nconst EMPTY_SEVEN = [[], [], [], [], [], [], []] as ReadonlyArray<ResponseValue>;\n\ndescribe(\"classifyPeekSearchQuery\", () => {\n  // Every supported PeekSearchQueryClass label gets at least one positive case\n  // so the audit-summary string can be reasoned about deterministically.\n  const cases: Array<[string, PeekSearchQueryClass]> = [\n    [\"\", \"empty\"],\n    [\"   \", \"empty\"],\n    [\"just some words\", \"free_text\"],\n    [\n      \"11111111-1111-1111-1111-111111111111\",\n      \"free_text\", // UUIDs go to free_text per the heuristic comment\n    ],\n    [\"12345\", \"queue_event_id\"],\n    [\"1234567890123456789\", \"telegram_provider_id\"], // 19 digits > 18\n    [\"abcdef0123456789\", \"match_id\"], // 16-char hex\n    [\n      \"5tWqN7ykNWtXesjaGCu3JoGvU2STNUP6axQjqfA\",\n      \"round_pda\", // 39 base58 chars in [32,44]\n    ],\n    [\n      \"5VfYDnXUcS6mWY3cQy4ipcM5LQqM4XV4nHe89oLQGn7awgJZpF8aWxa9HXP15GgyCcXWXP1aTH8qzuc5whTvP3Da\",\n      \"tx_signature\", // ≥80 base58 chars\n    ],\n    [\"@operator\", \"telegram_username\"],\n    [\"KOL2026\", \"referral_code\"],\n    [\"alice_99\", \"username\"],\n  ];\n\n  it.each(cases)(\"%j classifies as %s\", (input, expected) => {\n    expect(classifyPeekSearchQuery(input)).toBe(expected);\n  });\n\n  it(\"strips a leading @ before classification but still labels as telegram_username when text remains\", () => {\n    expect(classifyPeekSearchQuery(\"@alice_99\")).toBe(\"telegram_username\");\n  });\n});\n\ndescribe(\"getUniversalSearchResults\", () => {\n  it(\"empty query: short-circuits, no SQL calls, returns empty groups for every entity type\", async () => {\n    const mock = createSqlMock([]);\n\n    const response = await getUniversalSearchResults({\n      query: \"   \",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      audit: null,","numLines":100,"startLine":1,"totalLines":763}}}
