e: \"1rem\",\n138\t  fontWeight: 600,\n139\t  color: \"#e2e8f0\",\n140\t};\n141\t\n142\tconst emptyStyle: CSSProperties = {\n143\t  padding: \"1.5rem\",\n144\t  borderRadius: \"0.75rem\",\n145\t  border: \"1px dashed #334155\",\n146\t  background: \"#0b1220\",\n147\t  color: \"#cbd5f5\",\n148\t  display: \"grid\",\n149\t  gap: \"0.5rem\",\n150\t};\n151\t\n152\tconst emptyTitleStyle: CSSProperties = {\n153\t  margin: 0,\n154\t  fontSize: \"1rem\",\n155\t  fontWeight: 600,\n156\t};\n157\t\n158\tconst emptyBodyStyle: CSSProperties = {\n159\t  margin: 0,\n160\t  fontSize: \"0.875rem\",\n161\t  color: \"#94a3b8\",\n162\t};\n163\t\n164\tconst errorStyle: CSSProperties = {\n165\t  margin: 0,\n166\t  padding: \"0.75rem 1rem\",\n167\t  borderRadius: \"0.75rem\",\n168\t  background: \"#3f1d1d\",\n169\t  color: \"#fecaca\",\n170\t};\n171\t"}]},"parent_tool_use_id":null,"session_id":"aa22a004-7967-4272-b3ce-42c86f057c37","uuid":"4ac4e0ec-226a-4510-a755-a45ebdfe877f","timestamp":"2026-04-25T12:08:08.968Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/detail-panel.tsx","content":"import type { CSSProperties, ReactNode } from \"react\";\n\nexport type PeekDetailSection = {\n  id: string;\n  label: string;\n  body: ReactNode;\n};\n\nexport type DetailPanelProps = {\n  sections: ReadonlyArray<PeekDetailSection>;\n  activeId?: string | null;\n  ariaLabel?: string;\n  emptyTitle?: string;\n  emptyBody?: string | null;\n  error?: string | null;\n};\n\nexport function DetailPanel({\n  sections,\n  activeId = null,\n  ariaLabel = \"Detail sections\",\n  emptyTitle = \"No sections available for this view.\",\n  emptyBody = null,\n  error = null,\n}: DetailPanelProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Detail panel unavailable: {error}\n      </div>\n    );\n  }\n\n  if (sections.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>{emptyTitle}</p>\n        {emptyBody ? <p style={emptyBodyStyle}>{emptyBody}</p> : null}\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <nav aria-label={ariaLabel} style={navStyle}>\n        <ul style={listStyle}>\n          {sections.map((section) => {\n            const isActive = activeId === section.id;\n            return (\n              <li key={section.id}>\n                <a\n                  href={`#${section.id}`}\n                  aria-current={isActive ? \"true\" : undefined}\n                  style={isActive ? activeLinkStyle : linkStyle}\n                >\n                  {section.label}\n                </a>\n              </li>\n            );\n          })}\n        </ul>\n      </nav>\n      <div style={sectionsStyle}>\n        {sections.map((section) => (\n          <section\n            key={section.id}\n            id={section.id}\n            aria-labelledby={`peek-section-${section.id}-label`}\n            style={sectionStyle}\n          >\n            <h2 id={`peek-section-${section.id}-label`} style={sectionHeadingStyle}>\n              {section.label}\n            </h2>\n            <div>{section.body}</div>\n          </section>\n        ))}\n      </div>\n    </div>\n  );\n}\n\nconst wrapperStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1rem\",\n};\n\nconst navStyle: CSSProperties = {\n  position: \"sticky\",\n  top: 0,\n  background: \"#0b1220\",\n  paddingBlock: \"0.5rem\",\n};\n\nconst listStyle: CSSProperties = {\n  listStyle: \"none\",\n  margin: 0,\n  padding: 0,\n  display: \"flex\",\n  gap: \"0.5rem\",\n  flexWrap: \"wrap\",\n};\n\nconst linkStyle: CSSProperties = {\n  display: \"inline-flex\",\n  alignItems: \"center\",\n  fontSize: \"0.8125rem\",\n  textDecoration: \"none\",\n  color: \"#94a3b8\",\n  padding: \"0.375rem 0.75rem\",\n  borderRadius: \"9999px\",\n  border: \"1px solid #1e293b\",\n};\n\nconst activeLinkStyle: CSSProperties = {\n  ...linkStyle,\n  color: \"#eff6ff\",\n  background: \"#1d4ed8\",\n  borderColor: \"#1d4ed8\",\n};\n\nconst sectionsStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n  background: \"#111827\",\n  padding: \"1rem\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#e2e8f0\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n","numLines":171,"startLine":1,"totalLines":171}}}
