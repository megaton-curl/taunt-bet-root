udit === undefined ? defaultPeekSearchAudit : options.audit;\n471\t  if (audit) {\n472\t    try {\n473\t      await audit({\n474\t        actorEmail: options.actorEmail,\n475\t        query: trimmed,\n476\t        queryClass,\n477\t        totalResults,\n478\t        route: options.route ?? null,\n479\t        requestId: options.requestId ?? null,\n480\t      });\n481\t    } catch {\n482\t      // Audit failures must never leak to the caller (FR-11). The writer\n483\t      // already logs server-side; swallow here so the search response still\n484\t      // renders.\n485\t    }\n486\t  }\n487\t\n488\t  return {\n489\t    query: trimmed,\n490\t    queryClass,\n491\t    groups,\n492\t    totalResults,\n493\t    perGroupLimit,\n494\t    generatedAt,\n495\t  };\n496\t}\n497\t"}]},"parent_tool_use_id":null,"session_id":"aa22a004-7967-4272-b3ce-42c86f057c37","uuid":"b77e7228-6932-4c7d-b9fa-b61c51ad7827","timestamp":"2026-04-25T12:04:15.849Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/universal-search.ts","content":"    return response;\n  }\n\n  // Run every entity-class query in parallel; per-group LIMIT keeps each query\n  // bounded. Group-level `truncated` is set when the inner query came back\n  // with one more row than `limit`.\n  const [users, referrals, linkedAccounts, rounds, transactions, queueEvents] =\n    await Promise.all([\n      searchUsers(sql, trimmed, perGroupLimit),\n      searchReferralCodes(sql, trimmed, perGroupLimit),\n      searchLinkedAccounts(sql, trimmed, perGroupLimit),\n      searchRounds(sql, trimmed, perGroupLimit),\n      searchTransactions(sql, trimmed, perGroupLimit),\n      searchQueueEvents(sql, trimmed, perGroupLimit),\n    ]);\n\n  const groups: ReadonlyArray<PeekSearchGroup> = [\n    { entityType: \"user\", results: users, truncated: users.length === perGroupLimit },\n    {\n      entityType: \"referral\",\n      results: referrals,\n      truncated: referrals.length === perGroupLimit,\n    },\n    {\n      entityType: \"linked_account\",\n      results: linkedAccounts,\n      truncated: linkedAccounts.length === perGroupLimit,\n    },\n    {\n      entityType: \"round\",\n      results: rounds,\n      truncated: rounds.length === perGroupLimit,\n    },\n    {\n      entityType: \"transaction\",\n      results: transactions,\n      truncated: transactions.length === perGroupLimit,\n    },\n    {\n      entityType: \"queue_event\",\n      results: queueEvents,\n      truncated: queueEvents.length === perGroupLimit,\n    },\n  ];\n\n  const totalResults = groups.reduce(\n    (acc, group) => acc + group.results.length,\n    0,\n  );\n\n  const audit = options.audit === undefined ? defaultPeekSearchAudit : options.audit;\n  if (audit) {\n    try {\n      await audit({\n        actorEmail: options.actorEmail,\n        query: trimmed,\n        queryClass,\n        totalResults,\n        route: options.route ?? null,\n        requestId: options.requestId ?? null,\n      });\n    } catch {\n      // Audit failures must never leak to the caller (FR-11). The writer\n      // already logs server-side; swallow here so the search response still\n      // renders.\n    }\n  }\n\n  return {\n    query: trimmed,\n    queryClass,\n    groups,\n    totalResults,\n    perGroupLimit,\n    generatedAt,\n  };\n}\n","numLines":78,"startLine":420,"totalLines":497}}}
