.length; index += 1) {\n192\t    bytes[index] = binary.charCodeAt(index);\n193\t  }\n194\t\n195\t  return bytes;\n196\t}\n197\t\n198\tfunction isJwtHeader(value: unknown): value is { alg: string; kid: string } {\n199\t  return (\n200\t    typeof value === \"object\" &&\n201\t    value !== null &&\n202\t    \"alg\" in value &&\n203\t    \"kid\" in value &&\n204\t    typeof value.alg === \"string\" &&\n205\t    typeof value.kid === \"string\"\n206\t  );\n207\t}\n208\t\n209\tfunction isAccessJwtClaims(value: unknown): value is {\n210\t  aud: string | string[];\n211\t  email?: string;\n212\t  exp?: number;\n213\t  iss: string;\n214\t  nbf?: number;\n215\t} {\n216\t  return (\n217\t    typeof value === \"object\" &&\n218\t    value !== null &&\n219\t    \"aud\" in value &&\n220\t    \"iss\" in value &&\n221\t    typeof value.iss === \"string\" &&\n222\t    (typeof value.aud === \"string\" ||\n223\t      (Array.isArray(value.aud) &&\n224\t        value.aud.every((audience) => typeof audience === \"string\")))\n225\t  );\n226\t}\n227\t\n228\tfunction isJwksResponse(value: unknown): value is { keys: CloudflareAccessJwk[] } {\n229\t  return (\n230\t    typeof value === \"object\" &&\n231\t    value !== null &&\n232\t    \"keys\" in value &&\n233\t    Array.isArray(value.keys)\n234\t  );\n235\t}\n236\t\n237\tfunction isExpectedIssuer(issuer: string, teamDomain: string): boolean {\n238\t  return normalizeTeamDomain(issuer) === normalizeTeamDomain(teamDomain);\n239\t}\n240\t\n241\tfunction hasExpectedAudience(audience: string | string[], expected: string): boolean {\n242\t  return Array.isArray(audience)\n243\t    ? audience.includes(expected)\n244\t    : audience === expected;\n245\t}\n246\t\n247\tfunction isExpired(\n248\t  claims: { exp?: number; nbf?: number },\n249\t  now: Date,\n250\t): boolean {\n251\t  const nowSeconds = Math.floor(now.getTime() / 1000);\n252\t\n253\t  if (typeof claims.exp === \"number\" && claims.exp <= nowSeconds) {\n254\t    return true;\n255\t  }\n256\t\n257\t  return typeof claims.nbf === \"number\" && claims.nbf > nowSeconds;\n258\t}\n259\t\n260\tfunction normalizeTeamDomain(value: string): string {\n261\t  return value.trim().replace(/\\/+$/, \"\");\n262\t}\n263\t"}]},"parent_tool_use_id":null,"session_id":"0dada0a7-36bb-4454-ab59-57d5690850a5","uuid":"66b83522-8e28-4da0-a5fc-bdfcf00a68d0","timestamp":"2026-04-25T09:41:03.957Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/cloudflare-access.ts","content":"export type CloudflareAccessVerificationReason =\n  | \"missing_token\"\n  | \"malformed_token\"\n  | \"unsupported_algorithm\"\n  | \"invalid_claims\"\n  | \"invalid_issuer\"\n  | \"invalid_audience\"\n  | \"expired_token\"\n  | \"missing_key\"\n  | \"invalid_signature\"\n  | \"jwks_unavailable\";\n\nexport type CloudflareAccessVerificationResult =\n  | { ok: true; email: string | null }\n  | { ok: false; reason: CloudflareAccessVerificationReason };\n\nexport interface CloudflareAccessVerificationOptions {\n  audience: string;\n  teamDomain: string;\n  jwks?: CloudflareAccessJwk[];\n  now?: Date;\n}\n\nexport const VERIFIED_ACCESS_EMAIL_HEADER = \"x-peek-verified-access-email\";\n\ntype CloudflareAccessJwk = JsonWebKey & { kid?: string };\n\nconst jwksCache = new Map<string, CloudflareAccessJwk[]>();\n\nexport async function getVerifiedCloudflareAccessEmailFromHeaders(\n  requestHeaders: Pick<Headers, \"get\">,\n  options: CloudflareAccessVerificationOptions,\n): Promise<CloudflareAccessVerificationResult> {\n  return verifyCloudflareAccessJwt(\n    requestHeaders.get(\"cf-access-jwt-assertion\"),\n    options,\n  );\n}\n\nexport async function verifyCloudflareAccessJwt(\n  token: string | null,\n  options: CloudflareAccessVerificationOptions,\n): Promise<CloudflareAccessVerificationResult> {\n  if (!token) {\n    return { ok: false, reason: \"missing_token\" };\n  }\n\n  const [headerPart, payloadPart, signaturePart] = token.split(\".\");\n\n  if (!headerPart || !payloadPart || !signaturePart) {\n    return { ok: false, reason: \"malformed_token\" };\n  }\n\n  const header = parseJsonPart(headerPart);\n\n  if (!isJwtHeader(header)) {\n    return { ok: false, reason: \"malformed_token\" };\n  }\n\n  if (header.alg !== \"RS256\") {\n    return { ok: false, reason: \"unsupported_algorithm\" };\n  }\n\n  const claims = parseJsonPart(payloadPart);\n\n  if (!isAccessJwtClaims(claims)) {\n    return { ok: false, reason: \"invalid_claims\" };\n  }\n\n  if (!isExpectedIssuer(claims.iss, options.teamDomain)) {\n    return { ok: false, reason: \"invalid_issuer\" };\n  }\n\n  if (!hasExpectedAudience(claims.aud, options.audience)) {\n    return { ok: false, reason: \"invalid_audience\" };\n  }\n\n  if (isExpired(claims, options.now ?? new Date())) {\n    return { ok: false, reason: \"expired_token\" };\n  }\n\n  let jwks: CloudflareAccessJwk[];\n\n  try {\n    jwks = options.jwks ?? (await fetchCloudflareAccessJwks(options.teamDomain));\n  } catch {\n    return { ok: false, reason: \"jwks_unavailable\" };\n  }\n\n  const jwk = jwks.find((key) => key.kid === header.kid);\n\n  if (!jwk) {\n    return { ok: false, reason: \"missing_key\" };\n  }\n\n  const isValidSignature = await verifySignature({\n    data: `${headerPart}.${payloadPart}`,\n    jwk,\n    signature: signaturePart,\n  });\n\n  if (!isValidSignature) {\n    return { ok: false, reason: \"invalid_signature\" };\n  }\n\n  return { ok: true, email: normalizeEmail(claims.email) };\n}\n\nfunction normalizeEmail(value: string | null | undefined): string | null {\n  const email = value?.trim();\n\n  if (!email || !/^[^\\s@]+@[^\\s@]+$/.test(email)) {\n    return null;\n  }\n\n  return email;\n}\n\nasync function fetchCloudflareAccessJwks(\n  teamDomain: string,\n): Promise<CloudflareAccessJwk[]> {\n  const normalizedTeamDomain = normalizeTeamDomain(teamDomain);\n  const cached = jwksCache.get(normalizedTeamDomain);\n\n  if (cached) {\n    return cached;\n  }\n\n  const response = await fetch(`${normalizedTeamDomain}/cdn-cgi/access/certs`);\n\n  if (!response.ok) {\n    throw new Error(\"Cloudflare Access JWKS request failed\");\n  }\n\n  const body: unknown = await response.json();\n\n  if (!isJwksResponse(body)) {\n    throw new Error(\"Cloudflare Access JWKS response was invalid\");\n  }\n\n  jwksCache.set(normalizedTeamDomain, body.keys);\n  return body.keys;\n}\n\nasync function verifySignature({\n  data,\n  jwk,\n  signature,\n}: {\n  data: string;\n  jwk: CloudflareAccessJwk;\n  signature: string;\n}): Promise<boolean> {\n  const key = await crypto.subtle.importKey(\n    \"jwk\",\n    jwk,\n    {\n      name: \"RSASSA-PKCS1-v1_5\",\n      hash: \"SHA-256\",\n    },\n    false,\n    [\"verify\"],\n  );\n\n  return crypto.subtle.verify(\n    \"RSASSA-PKCS1-v1_5\",\n    key,\n    base64UrlToBytes(signature) as unknown as BufferSource,\n    new TextEncoder().encode(data),\n  );\n}\n\nfunction base64UrlToString(value: string): string {\n  return new TextDecoder().decode(base64UrlToBytes(value));\n}\n\nfunction parseJsonPart(value: string): unknown {\n  try {\n    return JSON.parse(base64UrlToString(value));\n  } catch {\n    return null;\n  }\n}\n\nfunction base64UrlToBytes(value: string): Uint8Array {\n  const base64 = value.replaceAll(\"-\", \"+\").replaceAll(\"_\", \"/\");\n  const paddingLength = (4 - (base64.length % 4)) % 4;\n  const binary = atob(`${base64}${\"=\".repeat(paddingLength)}`);\n  const bytes = new Uint8Array(binary.length);\n\n  for (let index = 0; index < binary.length; index += 1) {\n    bytes[index] = binary.charCodeAt(index);\n  }\n\n  return bytes;\n}\n\nfunction isJwtHeader(value: unknown): value is { alg: string; kid: string } {\n  return (\n    typeof value === \"object\" &&\n    value !== null &&\n    \"alg\" in value &&\n    \"kid\" in value &&\n    typeof value.alg === \"string\" &&\n    typeof value.kid === \"string\"\n  );\n}\n\nfunction isAccessJwtClaims(value: unknown): value is {\n  aud: string | string[];\n  email?: string;\n  exp?: number;\n  iss: string;\n  nbf?: number;\n} {\n  return (\n    typeof value === \"object\" &&\n    value !== null &&\n    \"aud\" in value &&\n    \"iss\" in value &&\n    typeof value.iss === \"string\" &&\n    (typeof value.aud === \"string\" ||\n      (Array.isArray(value.aud) &&\n        value.aud.every((audience) => typeof audience === \"string\")))\n  );\n}\n\nfunction isJwksResponse(value: unknown): value is { keys: CloudflareAccessJwk[] } {\n  return (\n    typeof value === \"object\" &&\n    value !== null &&\n    \"keys\" in value &&\n    Array.isArray(value.keys)\n  );\n}\n\nfunction isExpectedIssuer(issuer: string, teamDomain: string): boolean {\n  return normalizeTeamDomain(issuer) === normalizeTeamDomain(teamDomain);\n}\n\nfunction hasExpectedAudience(audience: string | string[], expected: string): boolean {\n  return Array.isArray(audience)\n    ? audience.includes(expected)\n    : audience === expected;\n}\n\nfunction isExpired(\n  claims: { exp?: number; nbf?: number },\n  now: Date,\n): boolean {\n  const nowSeconds = Math.floor(now.getTime() / 1000);\n\n  if (typeof claims.exp === \"number\" && claims.exp <= nowSeconds) {\n    return true;\n  }\n\n  return typeof claims.nbf === \"number\" && claims.nbf > nowSeconds;\n}\n\nfunction normalizeTeamDomain(value: string): string {\n  return value.trim().replace(/\\/+$/, \"\");\n}\n","numLines":263,"startLine":1,"totalLines":263}}}
