header)) {\n57\t    return { ok: false, reason: \"malformed_token\" };\n58\t  }\n59\t\n60\t  if (header.alg !== \"RS256\") {\n61\t    return { ok: false, reason: \"unsupported_algorithm\" };\n62\t  }\n63\t\n64\t  const claims = parseJsonPart(payloadPart);\n65\t\n66\t  if (!isAccessJwtClaims(claims)) {\n67\t    return { ok: false, reason: \"invalid_claims\" };\n68\t  }\n69\t\n70\t  if (!isExpectedIssuer(claims.iss, options.teamDomain)) {\n71\t    return { ok: false, reason: \"invalid_issuer\" };\n72\t  }\n73\t\n74\t  if (!hasExpectedAudience(claims.aud, options.audience)) {\n75\t    return { ok: false, reason: \"invalid_audience\" };\n76\t  }\n77\t\n78\t  if (isExpired(claims, options.now ?? new Date())) {\n79\t    return { ok: false, reason: \"expired_token\" };\n80\t  }\n81\t\n82\t  let jwks: CloudflareAccessJwk[];\n83\t\n84\t  try {\n85\t    jwks = options.jwks ?? (await fetchCloudflareAccessJwks(options.teamDomain));\n86\t  } catch {\n87\t    return { ok: false, reason: \"jwks_unavailable\" };\n88\t  }\n89\t\n90\t  const jwk = jwks.find((key) => key.kid === header.kid);\n91\t\n92\t  if (!jwk) {\n93\t    return { ok: false, reason: \"missing_key\" };\n94\t  }\n95\t\n96\t  const isValidSignature = await verifySignature({\n97\t    data: `${headerPart}.${payloadPart}`,\n98\t    jwk,\n99\t    signature: signaturePart,\n100\t  });\n101\t\n102\t  if (!isValidSignature) {\n103\t    return { ok: false, reason: \"invalid_signature\" };\n104\t  }\n105\t\n106\t  return { ok: true, email: normalizeEmail(claims.email) };\n107\t}\n108\t\n109\tfunction normalizeEmail(value: string | null | undefined): string | null {\n110\t  const email = value?.trim();\n111\t\n112\t  if (!email || !/^[^\\s@]+@[^\\s@]+$/.test(email)) {\n113\t    return null;\n114\t  }\n115\t\n116\t  return email;\n117\t}\n118\t\n119\tasync function fetchCloudflareAccessJwks(\n120\t  teamDomain: string,\n121\t): Promise<CloudflareAccessJwk[]> {\n122\t  const normalizedTeamDomain = normalizeTeamDomain(teamDomain);