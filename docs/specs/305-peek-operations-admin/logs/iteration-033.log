{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014iW8VzJAK14srzFwvFR2Nm","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport type { Sql } from \"postgres\";\n3\timport { getGamesOverview } from \"../get-games-overview\";\n4\timport {\n5\t  PEEK_GAME_IDS,\n6\t  PEEK_GAME_OVERVIEW_METRIC_IDS,\n7\t  type PeekGameId,\n8\t} from \"../../../../lib/types/peek\";\n9\t\n10\ttype SqlCall = {\n11\t  text: string;\n12\t  values: ReadonlyArray<unknown>;\n13\t};\n14\t\n15\ttype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n16\t\n17\ttype SqlMock = {\n18\t  sql: Sql;\n19\t  calls: ReadonlyArray<SqlCall>;\n20\t};\n21\t\n22\t// SQL mock that tracks every tagged-template call and returns a queued\n23\t// response per call (rows or an Error to reject). Mirrors the pattern used in\n24\t// get-growth-referrals.test.ts and get-command-center-attention.test.ts so the\n25\t// query test surface stays consistent.\n26\tfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n27\t  const calls: SqlCall[] = [];\n28\t  let cursor = 0;\n29\t\n30\t  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n31\t    const text = [...strings].join(\"?\");\n32\t    calls.push({ text, values: [...values] });\n33\t    const next = responses[cursor++];\n34\t    if (next instanceof Error) return Promise.reject(next);\n35\t    return Promise.resolve(next ?? []);\n36\t  };\n37\t\n38\t  const sql = fn as unknown as Sql;\n39\t  return { sql, calls };\n40\t}\n41\t\n42\t// Two queries fire in parallel via Promise.all:\n43\t//   0 — per-game GROUP BY aggregate over `game_entries`\n44\t//   1 — platform-wide DISTINCT user_id count\n45\t\n46\tdescribe(\"getGamesOverview\", () => {\n47\t  it(\"populated: builds per-game rows + 6-metric strip with FR-4 bookkeeping for every advertised id\", async () => {\n48\t    const aggregates = [\n49\t      {\n50\t        game: \"flipyou\" as PeekGameId,\n51\t        entries: 10,\n52\t        unique_users: 7,\n53\t        wagered_lamports: \"2500000000\",\n54\t        settled_entries: 8,\n55\t        refund_entries: 1,\n56\t        payout_lamports: \"1500000000\",\n57\t        wins: 4,\n58\t        losses: 3,\n59\t      },\n60\t      {\n61\t        game: \"potshot\" as PeekGameId,\n62\t        entries: 5,\n63\t        unique_users: 3,\n64\t        wagered_lamports: \"1000000000\",\n65\t        settled_entries: 5,\n66\t        refund_entries: 0,\n67\t        payout_lamports: \"900000000\",\n68\t        wins: 2,\n69\t        losses: 3,\n70\t      },\n71\t      {\n72\t        game: \"closecall\" as PeekGameId,\n73\t        entries: 12,\n74\t        unique_users: 9,\n75\t        wagered_lamports: \"4000000000\",\n76\t        settled_entries: 11,\n77\t        refund_entries: 2,\n78\t        payout_lamports: \"3500000000\",\n79\t        wins: 5,\n80\t        losses: 4,\n81\t      },\n82\t    ];\n83\t    const mock = createSqlMock([aggregates, [{ value: 14 }]]);\n84\t    const now = new Date(\"2026-04-25T12:00:00.000Z\");\n85\t\n86\t    const result = await getGamesOverview({ sql: mock.sql, now });\n87\t\n88\t    expect(result.generatedAt).toBe(\"2026-04-25T12:00:00.000Z\");\n89\t\n90\t    // Per-game rows: stable order matching PEEK_GAME_IDS.\n91\t    expect(result.perGame.map((r) => r.game)).toEqual(PEEK_GAME_IDS);\n92\t    const flipyou = result.perGame.find((r) => r.game === \"flipyou\");\n93\t    expect(flipyou).toMatchObject({\n94\t      entries: 10,\n95\t      uniqueUsers: 7,\n96\t      wageredLamports: \"2500000000\",\n97\t      settledEntries: 8,\n98\t      refundEntries: 1,\n99\t      payoutLamports: \"1500000000\",\n100\t      wins: 4,\n101\t      losses: 3,\n102\t    });\n103\t\n104\t    // Metrics: every advertised PeekGameOverviewMetricId emitted with FR-4\n105\t    // bookkeeping (label, definition, source, windowLabel, asOf, freshness,\n106\t    // drilldownHref).\n107\t    expect(result.metrics).toHaveLength(6);\n108\t    const emittedIds = result.metrics.map((m) => m.id);\n109\t    expect(emittedIds).toEqual([...PEEK_GAME_OVERVIEW_METRIC_IDS]);\n110\t    for (const metric of result.metrics) {\n111\t      expect(metric.asOf).toBe(\"2026-04-25T12:00:00.000Z\");\n112\t      expect(metric.freshness).toBe(\"live\");\n113\t      expect(metric.label.length).toBeGreaterThan(0);\n114\t      expect(metric.definition.length).toBeGreaterThan(0);\n115\t      expect(metric.source).toBe(\"game_entries\");\n116\t      expect(metric.windowLabel).toBe(\"All time\");\n117\t      expect(metric.drilldownHref).toBe(\"/games\");\n118\t    }\n119\t\n120\t    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n121\t    expect(byId.get(\"games.total_entries\")?.value).toBe(27);\n122\t    expect(byId.get(\"games.total_entries\")?.valueDisplay).toBe(\"27\");\n123\t\n124\t    // Unique-players metric reads the platform-wide DISTINCT count, NOT the\n125\t    // sum of per-game distincts (would double-count cross-game players).\n126\t    expect(byId.get(\"games.unique_users\")?.value).toBe(14);\n127\t    expect(byId.get(\"games.unique_users\")?.valueDisplay).toBe(\"14\");\n128\t\n129\t    // Lamport totals: BigInt sum across games preserves u64 precision and\n130\t    // displays with thousands separators.\n131\t    expect(byId.get(\"games.wagered_lamports\")?.value).toBe(\"7500000000\");\n132\t    expect(byId.get(\"games.wagered_lamports\")?.valueDisplay).toBe(\n133\t      \"7,500,000,000\",\n134\t    );\n135\t    expect(byId.get(\"games.payout_lamports\")?.value).toBe(\"5900000000\");\n136\t    expect(byId.get(\"games.payout_lamports\")?.valueDisplay).toBe(\n137\t      \"5,900,000,000\",\n138\t    );\n139\t    expect(byId.get(\"games.settled_entries\")?.value).toBe(24);\n140\t    expect(byId.get(\"games.refund_entries\")?.value).toBe(3);\n141\t    expect(byId.get(\"games.refund_entries\")?.unit).toBe(\"entries\");\n142\t\n143\t    // SQL was emitted twice in parallel (per-game aggregate + DISTINCT count).\n144\t    expect(mock.calls).toHaveLength(2);\n145\t    expect(mock.calls[0].text).toContain(\"from game_entries\");\n146\t    expect(mock.calls[0].text).toContain(\"group by game\");\n147\t    expect(mock.calls[0].text).toContain(\n148\t      \"count(*) filter (where settled_at is not null and is_winner is null)\",\n149\t    );\n150\t    expect(mock.calls[1].text).toContain(\"count(distinct user_id)\");\n151\t  });\n152\t\n153\t  it(\"sparse (no rows): zero-fills every PEEK_GAME_ID and emits zeroed metrics rather than dropping the strip\", async () => {\n154\t    const mock = createSqlMock([[], [{ value: 0 }]]);\n155\t    const now = new Date(\"2026-04-25T12:00:00.000Z\");\n156\t\n157\t    const result = await getGamesOverview({ sql: mock.sql, now });\n158\t\n159\t    expect(result.perGame.map((r) => r.game)).toEqual(PEEK_GAME_IDS);\n160\t    for (const row of result.perGame) {\n161\t      expect(row.entries).toBe(0);\n162\t      expect(row.uniqueUsers).toBe(0);\n163\t      expect(row.wageredLamports).toBe(\"0\");\n164\t      expect(row.settledEntries).toBe(0);\n165\t      expect(row.refundEntries).toBe(0);\n166\t      expect(row.payoutLamports).toBe(\"0\");\n167\t      expect(row.wins).toBe(0);\n168\t      expect(row.losses).toBe(0);\n169\t    }\n170\t\n171\t    expect(result.metrics).toHaveLength(6);\n172\t    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n173\t    expect(byId.get(\"games.total_entries\")?.value).toBe(0);\n174\t    expect(byId.get(\"games.total_entries\")?.valueDisplay).toBe(\"0\");\n175\t    expect(byId.get(\"games.unique_users\")?.value).toBe(0);\n176\t    expect(byId.get(\"games.wagered_lamports\")?.value).toBe(\"0\");\n177\t    expect(byId.get(\"games.wagered_lamports\")?.valueDisplay).toBe(\"0\");\n178\t    expect(byId.get(\"games.payout_lamports\")?.value).toBe(\"0\");\n179\t  });\n180\t\n181\t  it(\"sparse (one game only): zero-fills missing games while preserving the populated row\", async () => {\n182\t    const mock = createSqlMock([\n183\t      [\n184\t        {\n185\t          game: \"potshot\" as PeekGameId,\n186\t          entries: 3,\n187\t          unique_users: 2,\n188\t          wagered_lamports: \"500\",\n189\t          settled_entries: 2,\n190\t          refund_entries: 0,\n191\t          payout_lamports: \"400\",\n192\t          wins: 1,\n193\t          losses: 1,\n194\t        },\n195\t      ],\n196\t      [{ value: 2 }],\n197\t    ]);\n198\t\n199\t    const result = await getGamesOverview({ sql: mock.sql });\n200\t\n201\t    const byGame = new Map(result.perGame.map((r) => [r.game, r]));\n202\t    expect(byGame.get(\"flipyou\")?.entries).toBe(0);\n203\t    expect(byGame.get(\"flipyou\")?.wageredLamports).toBe(\"0\");\n204\t    expect(byGame.get(\"potshot\")?.entries).toBe(3);\n205\t    expect(byGame.get(\"potshot\")?.wageredLamports).toBe(\"500\");\n206\t    expect(byGame.get(\"closecall\")?.entries).toBe(0);\n207\t    expect(byGame.get(\"closecall\")?.payoutLamports).toBe(\"0\");\n208\t\n209\t    const totalEntries = result.metrics.find(\n210\t      (m) => m.id === \"games.total_entries\",\n211\t    );\n212\t    expect(totalEntries?.value).toBe(3);\n213\t    const wagered = result.metrics.find(\n214\t      (m) => m.id === \"games.wagered_lamports\",\n215\t    );\n216\t    expect(wagered?.value).toBe(\"500\");\n217\t  });\n218\t\n219\t  it(\"string count coercion: postgres ::text counts convert to numbers\", async () => {\n220\t    const mock = createSqlMock([\n221\t      [\n222\t        {\n223\t          game: \"flipyou\" as PeekGameId,\n224\t          entries: \"9\",\n225\t          unique_users: \"7\",\n226\t          wagered_lamports: \"100\",\n227\t          settled_entries: \"5\",\n228\t          refund_entries: \"1\",\n229\t          payout_lamports: \"80\",\n230\t          wins: \"3\",\n231\t          losses: \"1\",\n232\t        },\n233\t      ],\n234\t      [{ value: \"7\" }],\n235\t    ]);\n236\t\n237\t    const result = await getGamesOverview({ sql: mock.sql });\n238\t    const flipyou = result.perGame.find((r) => r.game === \"flipyou\");\n239\t    expect(flipyou?.entries).toBe(9);\n240\t    expect(flipyou?.uniqueUsers).toBe(7);\n241\t    expect(flipyou?.settledEntries).toBe(5);\n242\t    expect(flipyou?.refundEntries).toBe(1);\n243\t    expect(flipyou?.wins).toBe(3);\n244\t    expect(flipyou?.losses).toBe(1);\n245\t\n246\t    const uniqueUsers = result.metrics.find(\n247\t      (m) => m.id === \"games.unique_users\",\n248\t    );\n249\t    expect(uniqueUsers?.value).toBe(7);\n250\t  });\n251\t\n252\t  it(\"filters out unknown game ids the DB might return so deferred/out-of-band games cannot leak into the UI\", async () => {\n253\t    const mock = createSqlMock([\n254\t      [\n255\t        {\n256\t          game: \"flipyou\" as PeekGameId,\n257\t          entries: 1,\n258\t          unique_users: 1,\n259\t          wagered_lamports: \"10\",\n260\t          settled_entries: 1,\n261\t          refund_entries: 0,\n262\t          payout_lamports: \"10\",\n263\t          wins: 1,\n264\t          losses: 0,\n265\t        },\n266\t        {\n267\t          // Not a member of PEEK_GAME_IDS — must be ignored.\n268\t          game: \"crash\" as unknown as PeekGameId,\n269\t          entries: 999,\n270\t          unique_users: 999,\n271\t          wagered_lamports: \"999999\",\n272\t          settled_entries: 999,\n273\t          refund_entries: 0,\n274\t          payout_lamports: \"0\",\n275\t          wins: 999,\n276\t          losses: 0,\n277\t        },\n278\t      ],\n279\t      [{ value: 1 }],\n280\t    ]);\n281\t\n282\t    const result = await getGamesOverview({ sql: mock.sql });\n283\t\n284\t    expect(result.perGame.map((r) => r.game)).toEqual(PEEK_GAME_IDS);\n285\t    expect(result.perGame.find((r) => r.game === \"flipyou\")?.entries).toBe(1);\n286\t    // The bogus \"crash\" row's 999s never bleed into totals.\n287\t    const totalEntries = result.metrics.find(\n288\t      (m) => m.id === \"games.total_entries\",\n289\t    );\n290\t    expect(totalEntries?.value).toBe(1);\n291\t  });\n292\t\n293\t  it(\"BigInt sum: lamport totals across games preserve u64 precision beyond Number.MAX_SAFE_INTEGER\", async () => {\n294\t    // Two near-MAX_SAFE_INTEGER per-game lamport sums. Naive Number addition\n295\t    // would round; BigInt sum must keep every digit.\n296\t    const big = \"9007199254740992\"; // Number.MAX_SAFE_INTEGER + 1\n297\t    const mock = createSqlMock([\n298\t      [\n299\t        {\n300\t          game: \"flipyou\" as PeekGameId,\n301\t          entries: 1,\n302\t          unique_users: 1,\n303\t          wagered_lamports: big,\n304\t          settled_entries: 0,\n305\t          refund_entries: 0,\n306\t          payout_lamports: \"0\",\n307\t          wins: 0,\n308\t          losses: 0,\n309\t        },\n310\t        {\n311\t          game: \"potshot\" as PeekGameId,\n312\t          entries: 1,\n313\t          unique_users: 1,\n314\t          wagered_lamports: big,\n315\t          settled_entries: 0,\n316\t          refund_entries: 0,\n317\t          payout_lamports: \"0\",\n318\t          wins: 0,\n319\t          losses: 0,\n320\t        },\n321\t      ],\n322\t      [{ value: 2 }],\n323\t    ]);\n324\t\n325\t    const result = await getGamesOverview({ sql: mock.sql });\n326\t    const wagered = result.metrics.find(\n327\t      (m) => m.id === \"games.wagered_lamports\",\n328\t    );\n329\t    expect(wagered?.value).toBe(\"18014398509481984\");\n330\t    expect(wagered?.valueDisplay).toBe(\"18,014,398,509,481,984\");\n331\t  });\n332\t\n333\t  it(\"load-error: a rejected aggregate query propagates so the page can render the alert state\", async () => {\n334\t    const mock = createSqlMock([\n335\t      new Error(\"connection refused\"),\n336\t      [{ value: 0 }],\n337\t    ]);\n338\t\n339\t    await expect(getGamesOverview({ sql: mock.sql })).rejects.toThrowError(\n340\t      \"connection refused\",\n341\t    );\n342\t  });\n343\t\n344\t  it(\"load-error: a rejected unique-users query also propagates\", async () => {\n345\t    const mock = createSqlMock([[], new Error(\"statement timeout\")]);\n346\t\n347\t    await expect(getGamesOverview({ sql: mock.sql })).rejects.toThrowError(\n348\t      \"statement timeout\",\n349\t    );\n350\t  });\n351\t});\n352\t"}]},"parent_tool_use_id":null,"session_id":"ecdb13ab-d22c-40f2-a1b0-874b3e540ce1","uuid":"257f9fae-7750-4d63-b896-acf834b1c806","timestamp":"2026-04-25T12:59:23.661Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-games-overview.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport { getGamesOverview } from \"../get-games-overview\";\nimport {\n  PEEK_GAME_IDS,\n  PEEK_GAME_OVERVIEW_METRIC_IDS,\n  type PeekGameId,\n} from \"../../../../lib/types/peek\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\n// SQL mock that tracks every tagged-template call and returns a queued\n// response per call (rows or an Error to reject). Mirrors the pattern used in\n// get-growth-referrals.test.ts and get-command-center-attention.test.ts so the\n// query test surface stays consistent.\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\n// Two queries fire in parallel via Promise.all:\n//   0 — per-game GROUP BY aggregate over `game_entries`\n//   1 — platform-wide DISTINCT user_id count\n\ndescribe(\"getGamesOverview\", () => {\n  it(\"populated: builds per-game rows + 6-metric strip with FR-4 bookkeeping for every advertised id\", async () => {\n    const aggregates = [\n      {\n        game: \"flipyou\" as PeekGameId,\n        entries: 10,\n        unique_users: 7,\n        wagered_lamports: \"2500000000\",\n        settled_entries: 8,\n        refund_entries: 1,\n        payout_lamports: \"1500000000\",\n        wins: 4,\n        losses: 3,\n      },\n      {\n        game: \"potshot\" as PeekGameId,\n        entries: 5,\n        unique_users: 3,\n        wagered_lamports: \"1000000000\",\n        settled_entries: 5,\n        refund_entries: 0,\n        payout_lamports: \"900000000\",\n        wins: 2,\n        losses: 3,\n      },\n      {\n        game: \"closecall\" as PeekGameId,\n        entries: 12,\n        unique_users: 9,\n        wagered_lamports: \"4000000000\",\n        settled_entries: 11,\n        refund_entries: 2,\n        payout_lamports: \"3500000000\",\n        wins: 5,\n        losses: 4,\n      },\n    ];\n    const mock = createSqlMock([aggregates, [{ value: 14 }]]);\n    const now = new Date(\"2026-04-25T12:00:00.000Z\");\n\n    const result = await getGamesOverview({ sql: mock.sql, now });\n\n    expect(result.generatedAt).toBe(\"2026-04-25T12:00:00.000Z\");\n\n    // Per-game rows: stable order matching PEEK_GAME_IDS.\n    expect(result.perGame.map((r) => r.game)).toEqual(PEEK_GAME_IDS);\n    const flipyou = result.perGame.find((r) => r.game === \"flipyou\");\n    expect(flipyou).toMatchObject({\n      entries: 10,\n      uniqueUsers: 7,\n      wageredLamports: \"2500000000\",\n      settledEntries: 8,\n      refundEntries: 1,\n      payoutLamports: \"1500000000\",\n      wins: 4,\n      losses: 3,\n    });\n\n    // Metrics: every advertised PeekGameOverviewMetricId emitted with FR-4\n    // bookkeeping (label, definition, source, windowLabel, asOf, freshness,\n    // drilldownHref).\n    expect(result.metrics).toHaveLength(6);\n    const emittedIds = result.metrics.map((m) => m.id);\n    expect(emittedIds).toEqual([...PEEK_GAME_OVERVIEW_METRIC_IDS]);\n    for (const metric of result.metrics) {\n      expect(metric.asOf).toBe(\"2026-04-25T12:00:00.000Z\");\n      expect(metric.freshness).toBe(\"live\");\n      expect(metric.label.length).toBeGreaterThan(0);\n      expect(metric.definition.length).toBeGreaterThan(0);\n      expect(metric.source).toBe(\"game_entries\");\n      expect(metric.windowLabel).toBe(\"All time\");\n      expect(metric.drilldownHref).toBe(\"/games\");\n    }\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"games.total_entries\")?.value).toBe(27);\n    expect(byId.get(\"games.total_entries\")?.valueDisplay).toBe(\"27\");\n\n    // Unique-players metric reads the platform-wide DISTINCT count, NOT the\n    // sum of per-game distincts (would double-count cross-game players).\n    expect(byId.get(\"games.unique_users\")?.value).toBe(14);\n    expect(byId.get(\"games.unique_users\")?.valueDisplay).toBe(\"14\");\n\n    // Lamport totals: BigInt sum across games preserves u64 precision and\n    // displays with thousands separators.\n    expect(byId.get(\"games.wagered_lamports\")?.value).toBe(\"7500000000\");\n    expect(byId.get(\"games.wagered_lamports\")?.valueDisplay).toBe(\n      \"7,500,000,000\",\n    );\n    expect(byId.get(\"games.payout_lamports\")?.value).toBe(\"5900000000\");\n    expect(byId.get(\"games.payout_lamports\")?.valueDisplay).toBe(\n      \"5,900,000,000\",\n    );\n    expect(byId.get(\"games.settled_entries\")?.value).toBe(24);\n    expect(byId.get(\"games.refund_entries\")?.value).toBe(3);\n    expect(byId.get(\"games.refund_entries\")?.unit).toBe(\"entries\");\n\n    // SQL was emitted twice in parallel (per-game aggregate + DISTINCT count).\n    expect(mock.calls).toHaveLength(2);\n    expect(mock.calls[0].text).toContain(\"from game_entries\");\n    expect(mock.calls[0].text).toContain(\"group by game\");\n    expect(mock.calls[0].text).toContain(\n      \"count(*) filter (where settled_at is not null and is_winner is null)\",\n    );\n    expect(mock.calls[1].text).toContain(\"count(distinct user_id)\");\n  });\n\n  it(\"sparse (no rows): zero-fills every PEEK_GAME_ID and emits zeroed metrics rather than dropping the strip\", async () => {\n    const mock = createSqlMock([[], [{ value: 0 }]]);\n    const now = new Date(\"2026-04-25T12:00:00.000Z\");\n\n    const result = await getGamesOverview({ sql: mock.sql, now });\n\n    expect(result.perGame.map((r) => r.game)).toEqual(PEEK_GAME_IDS);\n    for (const row of result.perGame) {\n      expect(row.entries).toBe(0);\n      expect(row.uniqueUsers).toBe(0);\n      expect(row.wageredLamports).toBe(\"0\");\n      expect(row.settledEntries).toBe(0);\n      expect(row.refundEntries).toBe(0);\n      expect(row.payoutLamports).toBe(\"0\");\n      expect(row.wins).toBe(0);\n      expect(row.losses).toBe(0);\n    }\n\n    expect(result.metrics).toHaveLength(6);\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"games.total_entries\")?.value).toBe(0);\n    expect(byId.get(\"games.total_entries\")?.valueDisplay).toBe(\"0\");\n    expect(byId.get(\"games.unique_users\")?.value).toBe(0);\n    expect(byId.get(\"games.wagered_lamports\")?.value).toBe(\"0\");\n    expect(byId.get(\"games.wagered_lamports\")?.valueDisplay).toBe(\"0\");\n    expect(byId.get(\"games.payout_lamports\")?.value).toBe(\"0\");\n  });\n\n  it(\"sparse (one game only): zero-fills missing games while preserving the populated row\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          game: \"potshot\" as PeekGameId,\n          entries: 3,\n          unique_users: 2,\n          wagered_lamports: \"500\",\n          settled_entries: 2,\n          refund_entries: 0,\n          payout_lamports: \"400\",\n          wins: 1,\n          losses: 1,\n        },\n      ],\n      [{ value: 2 }],\n    ]);\n\n    const result = await getGamesOverview({ sql: mock.sql });\n\n    const byGame = new Map(result.perGame.map((r) => [r.game, r]));\n    expect(byGame.get(\"flipyou\")?.entries).toBe(0);\n    expect(byGame.get(\"flipyou\")?.wageredLamports).toBe(\"0\");\n    expect(byGame.get(\"potshot\")?.entries).toBe(3);\n    expect(byGame.get(\"potshot\")?.wageredLamports).toBe(\"500\");\n    expect(byGame.get(\"closecall\")?.entries).toBe(0);\n    expect(byGame.get(\"closecall\")?.payoutLamports).toBe(\"0\");\n\n    const totalEntries = result.metrics.find(\n      (m) => m.id === \"games.total_entries\",\n    );\n    expect(totalEntries?.value).toBe(3);\n    const wagered = result.metrics.find(\n      (m) => m.id === \"games.wagered_lamports\",\n    );\n    expect(wagered?.value).toBe(\"500\");\n  });\n\n  it(\"string count coercion: postgres ::text counts convert to numbers\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          game: \"flipyou\" as PeekGameId,\n          entries: \"9\",\n          unique_users: \"7\",\n          wagered_lamports: \"100\",\n          settled_entries: \"5\",\n          refund_entries: \"1\",\n          payout_lamports: \"80\",\n          wins: \"3\",\n          losses: \"1\",\n        },\n      ],\n      [{ value: \"7\" }],\n    ]);\n\n    const result = await getGamesOverview({ sql: mock.sql });\n    const flipyou = result.perGame.find((r) => r.game === \"flipyou\");\n    expect(flipyou?.entries).toBe(9);\n    expect(flipyou?.uniqueUsers).toBe(7);\n    expect(flipyou?.settledEntries).toBe(5);\n    expect(flipyou?.refundEntries).toBe(1);\n    expect(flipyou?.wins).toBe(3);\n    expect(flipyou?.losses).toBe(1);\n\n    const uniqueUsers = result.metrics.find(\n      (m) => m.id === \"games.unique_users\",\n    );\n    expect(uniqueUsers?.value).toBe(7);\n  });\n\n  it(\"filters out unknown game ids the DB might return so deferred/out-of-band games cannot leak into the UI\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          game: \"flipyou\" as PeekGameId,\n          entries: 1,\n          unique_users: 1,\n          wagered_lamports: \"10\",\n          settled_entries: 1,\n          refund_entries: 0,\n          payout_lamports: \"10\",\n          wins: 1,\n          losses: 0,\n        },\n        {\n          // Not a member of PEEK_GAME_IDS — must be ignored.\n          game: \"crash\" as unknown as PeekGameId,\n          entries: 999,\n          unique_users: 999,\n          wagered_lamports: \"999999\",\n          settled_entries: 999,\n          refund_entries: 0,\n          payout_lamports: \"0\",\n          wins: 999,\n          losses: 0,\n        },\n      ],\n      [{ value: 1 }],\n    ]);\n\n    const result = await getGamesOverview({ sql: mock.sql });\n\n    expect(result.perGame.map((r) => r.game)).toEqual(PEEK_GAME_IDS);\n    expect(result.perGame.find((r) => r.game === \"flipyou\")?.entries).toBe(1);\n    // The bogus \"crash\" row's 999s never bleed into totals.\n    const totalEntries = result.metrics.find(\n      (m) => m.id === \"games.total_entries\",\n    );\n    expect(totalEntries?.value).toBe(1);\n  });\n\n  it(\"BigInt sum: lamport totals across games preserve u64 precision beyond Number.MAX_SAFE_INTEGER\", async () => {\n    // Two near-MAX_SAFE_INTEGER per-game lamport sums. Naive Number addition\n    // would round; BigInt sum must keep every digit.\n    const big = \"9007199254740992\"; // Number.MAX_SAFE_INTEGER + 1\n    const mock = createSqlMock([\n      [\n        {\n          game: \"flipyou\" as PeekGameId,\n          entries: 1,\n          unique_users: 1,\n          wagered_lamports: big,\n          settled_entries: 0,\n          refund_entries: 0,\n          payout_lamports: \"0\",\n          wins: 0,\n          losses: 0,\n        },\n        {\n          game: \"potshot\" as PeekGameId,\n          entries: 1,\n          unique_users: 1,\n          wagered_lamports: big,\n          settled_entries: 0,\n          refund_entries: 0,\n          payout_lamports: \"0\",\n          wins: 0,\n          losses: 0,\n        },\n      ],\n      [{ value: 2 }],\n    ]);\n\n    const result = await getGamesOverview({ sql: mock.sql });\n    const wagered = result.metrics.find(\n      (m) => m.id === \"games.wagered_lamports\",\n    );\n    expect(wagered?.value).toBe(\"18014398509481984\");\n    expect(wagered?.valueDisplay).toBe(\"18,014,398,509,481,984\");\n  });\n\n  it(\"load-error: a rejected aggregate query propagates so the page can render the alert state\", async () => {\n    const mock = createSqlMock([\n      new Error(\"connection refused\"),\n      [{ value: 0 }],\n    ]);\n\n    await expect(getGamesOverview({ sql: mock.sql })).rejects.toThrowError(\n      \"connection refused\",\n    );\n  });\n\n  it(\"load-error: a rejected unique-users query also propagates\", async () => {\n    const mock = createSqlMock([[], new Error(\"statement timeout\")]);\n\n    await expect(getGamesOverview({ sql: mock.sql })).rejects.toThrowError(\n      \"statement timeout\",\n    );\n  });\n});\n","numLines":352,"startLine":1,"totalLines":352}}}
