{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DVQCH6vM98L9YZoBkaYJJy","type":"tool_result","content":"1\t// Games overview admin queries (FR-8).\n2\t//\n3\t// Backs `/games`: cross-game `game_entries` aggregations per game, plus a\n4\t// small platform-wide metric strip suitable for the FR-4 metric primitive.\n5\t// The single source of truth is `game_entries` (migration 007): one row per\n6\t// participation, UPSERT'd at settlement. The migration documents the refund\n7\t// convention used here:\n8\t//\n9\t//   \"Refunded entries: is_winner = NULL, payout_lamports = amount_lamports.\"\n10\t//\n11\t// Per-game counters:\n12\t//   entries          — all game_entries rows for the game\n13\t//   uniqueUsers      — distinct user_id values\n14\t//   wageredLamports  — sum(amount_lamports)\n15\t//   settledEntries   — rows with settled_at IS NOT NULL\n16\t//   refundEntries    — settled rows with is_winner IS NULL (refund sentinel)\n17\t//   payoutLamports   — sum(payout_lamports)\n18\t//   wins             — rows with is_winner = TRUE\n19\t//   losses           — rows with is_winner = FALSE\n20\t//\n21\t// Bounded: a single grouped query — no row-level data crosses the wire here.\n22\t// Deferred games (Crash, Game of Trades, Chart the Course, Slots Utopia, Tug\n23\t// of Earn) are not part of the data shape; the `/games` page renders them as\n24\t// documented placeholders only (system invariant 13).\n25\t\n26\timport type { Sql } from \"postgres\";\n27\timport {\n28\t  PEEK_GAME_IDS,\n29\t  type PeekGameId,\n30\t  type PeekGameOverview,\n31\t  type PeekGameOverviewMetricId,\n32\t  type PeekGameOverviewRow,\n33\t  type PeekMetric,\n34\t} from \"../../../lib/types/peek\";\n35\timport { getSqlClient } from \"../client\";\n36\t\n37\texport type GamesOverviewOptions = {\n38\t  sql?: Sql;\n39\t  now?: Date;\n40\t};\n41\t\n42\ttype AggregateRow = {\n43\t  game: PeekGameId;\n44\t  entries: number | string;\n45\t  unique_users: number | string;\n46\t  wagered_lamports: string;\n47\t  settled_entries: number | string;\n48\t  refund_entries: number | string;\n49\t  payout_lamports: string;\n50\t  wins: number | string;\n51\t  losses: number | string;\n52\t};\n53\t\n54\ttype CountRow = { value: number | string };\n55\t\n56\tfunction readInt(value: number | string | null | undefined): number {\n57\t  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n58\t  if (typeof value === \"string\") {\n59\t    const parsed = Number.parseInt(value, 10);\n60\t    return Number.isFinite(parsed) ? parsed : 0;\n61\t  }\n62\t  return 0;\n63\t}\n64\t\n65\tfunction readSum(value: string | null | undefined): string {\n66\t  return typeof value === \"string\" && value.length > 0 ? value : \"0\";\n67\t}\n68\t\n69\tfunction formatCount(count: number): string {\n70\t  return count.toLocaleString(\"en-US\");\n71\t}\n72\t\n73\tfunction formatLamports(value: string): string {\n74\t  if (!value || value === \"0\") return \"0\";\n75\t  const negative = value.startsWith(\"-\");\n76\t  const digits = negative ? value.slice(1) : value;\n77\t  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n78\t  return negative ? `-${grouped}` : grouped;\n79\t}\n80\t\n81\tfunction emptyRow(game: PeekGameId): PeekGameOverviewRow {\n82\t  return {\n83\t    game,\n84\t    entries: 0,\n85\t    uniqueUsers: 0,\n86\t    wageredLamports: \"0\",\n87\t    settledEntries: 0,\n88\t    refundEntries: 0,\n89\t    payoutLamports: \"0\",\n90\t    wins: 0,\n91\t    losses: 0,\n92\t  };\n93\t}\n94\t\n95\tfunction sumLamports(values: ReadonlyArray<string>): string {\n96\t  // BigInt sum keeps u64 precision across per-game lamport totals; values\n97\t  // are strings from the postgres driver.\n98\t  let total = 0n;\n99\t  for (const v of values) {\n100\t    if (!v) continue;\n101\t    try {\n102\t      total += BigInt(v);\n103\t    } catch {\n104\t      // ignore unparsable values; the per-game row already reflects them.\n105\t    }\n106\t  }\n107\t  return total.toString();\n108\t}\n109\t\n110\ttype MetricBlueprint = {\n111\t  id: PeekGameOverviewMetricId;\n112\t  label: string;\n113\t  unit: string | null;\n114\t  source: string;\n115\t  windowLabel: string;\n116\t  definition: string;\n117\t  drilldownHref: string | null;\n118\t};\n119\t\n120\tfunction buildMetric(\n121\t  blueprint: MetricBlueprint,\n122\t  raw: number | string,\n123\t  display: string,\n124\t  asOf: string,\n125\t): PeekMetric {\n126\t  return {\n127\t    id: blueprint.id,\n128\t    label: blueprint.label,\n129\t    value: raw,\n130\t    valueDisplay: display,\n131\t    unit: blueprint.unit,\n132\t    source: blueprint.source,\n133\t    windowLabel: blueprint.windowLabel,\n134\t    asOf,\n135\t    definition: blueprint.definition,\n136\t    freshness: \"live\",\n137\t    drilldownHref: blueprint.drilldownHref,\n138\t  };\n139\t}\n140\t\n141\texport async function getGamesOverview(\n142\t  options: GamesOverviewOptions = {},\n143\t): Promise<PeekGameOverview> {\n144\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n145\t  const now = options.now ?? new Date();\n146\t  const generatedAt = now.toISOString();\n147\t\n148\t  // Two queries fire in parallel:\n149\t  //   1. per-game aggregates (one row per game appearing in the table).\n150\t  //   2. platform-wide unique-users count (DISTINCT user_id across all\n151\t  //      games — different from summing per-game distinct counts because a\n152\t  //      single player can appear in multiple games).\n153\t  const [aggregateRows, uniqueUsersRows] = await Promise.all([\n154\t    sql<AggregateRow[]>`\n155\t      select\n156\t        game,\n157\t        count(*)::int as \"entries\",\n158\t        count(distinct user_id)::int as \"unique_users\",\n159\t        coalesce(sum(amount_lamports), 0)::text as \"wagered_lamports\",\n160\t        count(*) filter (where settled_at is not null)::int as \"settled_entries\",\n161\t        count(*) filter (where settled_at is not null and is_winner is null)::int as \"refund_entries\",\n162\t        coalesce(sum(payout_lamports), 0)::text as \"payout_lamports\",\n163\t        count(*) filter (where is_winner = true)::int as \"wins\",\n164\t        count(*) filter (where is_winner = false)::int as \"losses\"\n165\t      from game_entries\n166\t      group by game\n167\t    `,\n168\t    sql<CountRow[]>`\n169\t      select count(distinct user_id)::int as \"value\"\n170\t      from game_entries\n171\t    `,\n172\t  ]);\n173\t\n174\t  // Normalize: emit one row per known PeekGameId in stable order, zeroed when\n175\t  // a game has no entries yet so the UI does not have to special-case missing\n176\t  // rows. Unknown game values returned by the DB are ignored — the migration\n177\t  // CHECK constraint should keep them in lockstep with PEEK_GAME_IDS, but\n178\t  // skipping unknowns here means an out-of-band row cannot leak into the UI.\n179\t  const byGame = new Map<PeekGameId, AggregateRow>();\n180\t  for (const row of aggregateRows) {\n181\t    if ((PEEK_GAME_IDS as ReadonlyArray<string>).includes(row.game)) {\n182\t      byGame.set(row.game, row);\n183\t    }\n184\t  }\n185\t\n186\t  const perGame: PeekGameOverviewRow[] = PEEK_GAME_IDS.map((game) => {\n187\t    const row = byGame.get(game);\n188\t    if (!row) return emptyRow(game);\n189\t    return {\n190\t      game,\n191\t      entries: readInt(row.entries),\n192\t      uniqueUsers: readInt(row.unique_users),\n193\t      wageredLamports: readSum(row.wagered_lamports),\n194\t      settledEntries: readInt(row.settled_entries),\n195\t      refundEntries: readInt(row.refund_entries),\n196\t      payoutLamports: readSum(row.payout_lamports),\n197\t      wins: readInt(row.wins),\n198\t      losses: readInt(row.losses),\n199\t    };\n200\t  });\n201\t\n202\t  const totalEntries = perGame.reduce((acc, r) => acc + r.entries, 0);\n203\t  const totalSettled = perGame.reduce((acc, r) => acc + r.settledEntries, 0);\n204\t  const totalRefunds = perGame.reduce((acc, r) => acc + r.refundEntries, 0);\n205\t  const totalWagered = sumLamports(perGame.map((r) => r.wageredLamports));\n206\t  const totalPayouts = sumLamports(perGame.map((r) => r.payoutLamports));\n207\t  const platformUniqueUsers = readInt(\n208\t    uniqueUsersRows.length > 0 ? uniqueUsersRows[0]?.value : 0,\n209\t  );\n210\t\n211\t  const blueprints: ReadonlyArray<{\n212\t    blueprint: MetricBlueprint;\n213\t    raw: number | string;\n214\t    display: string;\n215\t  }> = [\n216\t    {\n217\t      blueprint: {\n218\t        id: \"games.total_entries\",\n219\t        label: \"Game entries\",\n220\t        unit: \"entries\",\n221\t        source: \"game_entries\",\n222\t        windowLabel: \"All time\",\n223\t        definition:\n224\t          \"Total game_entries rows across FlipYou, Pot Shot, and Close Call — one row per participation.\",\n225\t        drilldownHref: \"/games\",\n226\t      },\n227\t      raw: totalEntries,\n228\t      display: formatCount(totalEntries),\n229\t    },\n230\t    {\n231\t      blueprint: {\n232\t        id: \"games.unique_users\",\n233\t        label: \"Unique players\",\n234\t        unit: \"users\",\n235\t        source: \"game_entries\",\n236\t        windowLabel: \"All time\",\n237\t        definition:\n238\t          \"Distinct user_id values across all games — a single player counted once even if they played multiple games.\",\n239\t        drilldownHref: \"/games\",\n240\t      },\n241\t      raw: platformUniqueUsers,\n242\t      display: formatCount(platformUniqueUsers),\n243\t    },\n244\t    {\n245\t      blueprint: {\n246\t        id: \"games.wagered_lamports\",\n247\t        label: \"Wagered (lamports)\",\n248\t        unit: \"lamports\",\n249\t        source: \"game_entries\",\n250\t        windowLabel: \"All time\",\n251\t        definition:\n252\t          \"Sum of amount_lamports across game_entries — gross wager volume across all games.\",\n253\t        drilldownHref: \"/games\",\n254\t      },\n255\t      raw: totalWagered,\n256\t      display: formatLamports(totalWagered),\n257\t    },\n258\t    {\n259\t      blueprint: {\n260\t        id: \"games.settled_entries\",\n261\t        label: \"Settled entries\",\n262\t        unit: \"entries\",\n263\t        source: \"game_entries\",\n264\t        windowLabel: \"All time\",\n265\t        definition:\n266\t          \"Game entries with settled_at set — includes wins, losses, and refunds.\",\n267\t        drilldownHref: \"/games\",\n268\t      },\n269\t      raw: totalSettled,\n270\t      display: formatCount(totalSettled),\n271\t    },\n272\t    {\n273\t      blueprint: {\n274\t        id: \"games.refund_entries\",\n275\t        label: \"Refunded entries\",\n276\t        unit: \"entries\",\n277\t        source: \"game_entries\",\n278\t        windowLabel: \"All time\",\n279\t        definition:\n280\t          \"Settled entries with is_winner IS NULL — the migration's refund sentinel (payout_lamports = amount_lamports).\",\n281\t        drilldownHref: \"/games\",\n282\t      },\n283\t      raw: totalRefunds,\n284\t      display: formatCount(totalRefunds),\n285\t    },\n286\t    {\n287\t      blueprint: {\n288\t        id: \"games.payout_lamports\",\n289\t        label: \"Paid out (lamports)\",\n290\t        unit: \"lamports\",\n291\t        source: \"game_entries\",\n292\t        windowLabel: \"All time\",\n293\t        definition:\n294\t          \"Sum of payout_lamports across game_entries — gross winnings + refunds returned to players.\",\n295\t        drilldownHref: \"/games\",\n296\t      },\n297\t      raw: totalPayouts,\n298\t      display: formatLamports(totalPayouts),\n299\t    },\n300\t  ];\n301\t\n302\t  return {\n303\t    generatedAt,\n304\t    metrics: blueprints.map(({ blueprint, raw, display }) =>\n305\t      buildMetric(blueprint, raw, display, generatedAt),\n306\t    ),\n307\t    perGame,\n308\t  };\n309\t}\n310\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_0189zm3YvBvduAPooCasBMvk","session_id":"ecdb13ab-d22c-40f2-a1b0-874b3e540ce1","uuid":"edf8202d-4365-49cc-94cb-c73161ca45b5","timestamp":"2026-04-25T12:57:49.355Z"}
