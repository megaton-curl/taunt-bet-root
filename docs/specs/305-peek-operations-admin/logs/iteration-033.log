{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NRJyRYemSZxn7MAH3iodEP","type":"tool_result","content":"1\t// Growth / referral admin queries (FR-7).\n2\t//\n3\t// One module that backs `/growth/referrals` and `/growth/kol`:\n4\t//\n5\t// - getGrowthReferralOverview() — eight FR-4 metrics: referrers, referred\n6\t//   users, activated referred users (have at least one game_entries row),\n7\t//   total referrer-earned lamports, total referee-rebate lamports, pending\n8\t//   claim lamports, failed claim count, KOL count.\n9\t// - listTopReferrers() — per-referrer aggregate with referee count, active\n10\t//   referee count, referred wager volume, referrer earnings, and pending\n11\t//   claim amount; used by the top-referrers table on /growth/referrals.\n12\t// - listKolPerformance() — `referral_kol_rates` joined with the same\n13\t//   per-referrer performance aggregates so the KOL table on /growth/kol can\n14\t//   show rate alongside actual production.\n15\t// - listReferralClaims() — filterable claims table reading from\n16\t//   `referral_claims` joined with `player_profiles` for the username column.\n17\t// - getReferralGraphNode() — one-hop referral-graph node centered on a user;\n18\t//   surfaces inbound referrer (back-link) + outbound referees (drill into\n19\t//   their user-detail pages). Re-uses the read paths the user-detail page\n20\t//   already covers; collected here so the upcoming /growth/referrals graph\n21\t//   navigation has a stable contract without changing user-detail.\n22\t//\n23\t// All queries are bounded server-side and rely only on existing tables.\n24\t// Lamport / u64 sums round-trip as `text` to preserve precision.\n25\t\n26\timport type { Sql } from \"postgres\";\n27\timport {\n28\t  type PeekGrowthClaimRow,\n29\t  type PeekGrowthOverview,\n30\t  type PeekGrowthOverviewMetricId,\n31\t  type PeekKolPerformanceRow,\n32\t  type PeekMetric,\n33\t  type PeekReferralClaimFilters,\n34\t  type PeekReferralGraphNode,\n35\t  type PeekReferralGraphRefereeRow,\n36\t  type PeekTopReferrerRow,\n37\t} from \"../../../lib/types/peek\";\n38\timport { getSqlClient } from \"../client\";\n39\t\n40\texport const PEEK_GROWTH_TOP_REFERRERS_DEFAULT_LIMIT = 50;\n41\texport const PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT = 250;\n42\texport const PEEK_GROWTH_KOL_DEFAULT_LIMIT = 100;\n43\texport const PEEK_GROWTH_KOL_MAX_LIMIT = 500;\n44\texport const PEEK_GROWTH_CLAIMS_DEFAULT_LIMIT = 100;\n45\texport const PEEK_GROWTH_CLAIMS_MAX_LIMIT = 500;\n46\t\n47\ttype GrowthOverviewOptions = {\n48\t  sql?: Sql;\n49\t  now?: Date;\n50\t};\n51\t\n52\ttype ListLimitOptions = {\n53\t  sql?: Sql;\n54\t  limit?: number;\n55\t};\n56\t\n57\texport type ListReferralClaimsOptions = {\n58\t  sql?: Sql;\n59\t  limit?: number;\n60\t  filters?: Partial<PeekReferralClaimFilters>;\n61\t};\n62\t\n63\texport type ReferralGraphOptions = {\n64\t  sql?: Sql;\n65\t  refereeLimit?: number;\n66\t};\n67\t\n68\tfunction clampLimit(\n69\t  raw: number | undefined,\n70\t  fallback: number,\n71\t  max: number,\n72\t): number {\n73\t  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n74\t  const floored = Math.floor(raw);\n75\t  if (floored <= 0) return 1;\n76\t  return Math.min(max, floored);\n77\t}\n78\t\n79\tfunction formatCount(count: number): string {\n80\t  return count.toLocaleString(\"en-US\");\n81\t}\n82\t\n83\tfunction formatLamports(value: string): string {\n84\t  // Show the raw lamport integer with thousands separators; the UI\n85\t  // optionally re-renders as SOL for display while keeping lamports as the\n86\t  // precise value (FR-4 monetary handling).\n87\t  if (!value || value === \"0\") return \"0\";\n88\t  // The value is a base-10 integer string from sum(BIGINT); group it manually\n89\t  // to avoid a lossy Number conversion on large platform-wide sums.\n90\t  const negative = value.startsWith(\"-\");\n91\t  const digits = negative ? value.slice(1) : value;\n92\t  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n93\t  return negative ? `-${grouped}` : grouped;\n94\t}\n95\t\n96\ttype CountRow = { value: number };\n97\ttype SumRow = { value: string };\n98\t\n99\tfunction readCount(rows: ReadonlyArray<CountRow> | undefined): number {\n100\t  if (!rows || rows.length === 0) return 0;\n101\t  const raw = rows[0]?.value;\n102\t  if (typeof raw === \"number\" && Number.isFinite(raw)) return raw;\n103\t  if (typeof raw === \"string\") {\n104\t    const parsed = Number.parseInt(raw, 10);\n105\t    return Number.isFinite(parsed) ? parsed : 0;\n106\t  }\n107\t  return 0;\n108\t}\n109\t\n110\tfunction readSum(rows: ReadonlyArray<SumRow> | undefined): string {\n111\t  if (!rows || rows.length === 0) return \"0\";\n112\t  const raw = rows[0]?.value;\n113\t  return typeof raw === \"string\" && raw.length > 0 ? raw : \"0\";\n114\t}\n115\t\n116\ttype GrowthMetricBlueprint = {\n117\t  id: PeekGrowthOverviewMetricId;\n118\t  label: string;\n119\t  unit: string | null;\n120\t  source: string;\n121\t  windowLabel: string;\n122\t  definition: string;\n123\t  drilldownHref: string | null;\n124\t};\n125\t\n126\tfunction buildMetric(\n127\t  blueprint: GrowthMetricBlueprint,\n128\t  raw: number | string,\n129\t  display: string,\n130\t  asOf: string,\n131\t): PeekMetric {\n132\t  return {\n133\t    id: blueprint.id,\n134\t    label: blueprint.label,\n135\t    value: raw,\n136\t    valueDisplay: display,\n137\t    unit: blueprint.unit,\n138\t    source: blueprint.source,\n139\t    windowLabel: blueprint.windowLabel,\n140\t    asOf,\n141\t    definition: blueprint.definition,\n142\t    freshness: \"live\",\n143\t    drilldownHref: blueprint.drilldownHref,\n144\t  };\n145\t}\n146\t\n147\texport async function getGrowthReferralOverview(\n148\t  options: GrowthOverviewOptions = {},\n149\t): Promise<PeekGrowthOverview> {\n150\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n151\t  const now = options.now ?? new Date();\n152\t  const generatedAt = now.toISOString();\n153\t\n154\t  const [\n155\t    referrersRows,\n156\t    referredUsersRows,\n157\t    activatedReferredRows,\n158\t    referrerEarningsRows,\n159\t    refereeRebatesRows,\n160\t    pendingClaimsLamportsRows,\n161\t    failedClaimsRows,\n162\t    kolCountRows,\n163\t  ] = await Promise.all([\n164\t    sql<CountRow[]>`\n165\t      select count(distinct referrer_user_id)::int as \"value\"\n166\t      from referral_links\n167\t    `,\n168\t    sql<CountRow[]>`\n169\t      select count(*)::int as \"value\"\n170\t      from referral_links\n171\t    `,\n172\t    sql<CountRow[]>`\n173\t      select count(*)::int as \"value\"\n174\t      from (\n175\t        select rl.referee_user_id\n176\t        from referral_links rl\n177\t        where exists (\n178\t          select 1 from game_entries ge\n179\t          where ge.user_id = rl.referee_user_id\n180\t        )\n181\t      ) activated\n182\t    `,\n183\t    sql<SumRow[]>`\n184\t      select coalesce(sum(referrer_earned_lamports), 0)::text as \"value\"\n185\t      from referral_earnings\n186\t    `,\n187\t    sql<SumRow[]>`\n188\t      select coalesce(sum(referee_rebate_lamports), 0)::text as \"value\"\n189\t      from referral_earnings\n190\t    `,\n191\t    sql<SumRow[]>`\n192\t      select coalesce(sum(amount_lamports), 0)::text as \"value\"\n193\t      from referral_claims\n194\t      where status in ('pending', 'processing')\n195\t    `,\n196\t    sql<CountRow[]>`\n197\t      select count(*)::int as \"value\"\n198\t      from referral_claims\n199\t      where status in ('failed', 'error')\n200\t    `,\n201\t    sql<CountRow[]>`\n202\t      select count(*)::int as \"value\"\n203\t      from referral_kol_rates\n204\t    `,\n205\t  ]);\n206\t\n207\t  const referrers = readCount(referrersRows);\n208\t  const referredUsers = readCount(referredUsersRows);\n209\t  const activatedReferred = readCount(activatedReferredRows);\n210\t  const referrerEarnings = readSum(referrerEarningsRows);\n211\t  const refereeRebates = readSum(refereeRebatesRows);\n212\t  const pendingClaimsLamports = readSum(pendingClaimsLamportsRows);\n213\t  const failedClaims = readCount(failedClaimsRows);\n214\t  const kolCount = readCount(kolCountRows);\n215\t\n216\t  const blueprints: ReadonlyArray<{\n217\t    blueprint: GrowthMetricBlueprint;\n218\t    raw: number | string;\n219\t    display: string;\n220\t  }> = [\n221\t    {\n222\t      blueprint: {\n223\t        id: \"growth.referrers\",\n224\t        label: \"Referrers\",\n225\t        unit: \"users\",\n226\t        source: \"referral_links\",\n227\t        windowLabel: \"All time\",\n228\t        definition:\n229\t          \"Distinct referrer_user_id values in referral_links — users who have referred at least one player.\",\n230\t        drilldownHref: \"/growth/referrals#top-referrers\",\n231\t      },\n232\t      raw: referrers,\n233\t      display: formatCount(referrers),\n234\t    },\n235\t    {\n236\t      blueprint: {\n237\t        id: \"growth.referred_users\",\n238\t        label: \"Referred users\",\n239\t        unit: \"users\",\n240\t        source: \"referral_links\",\n241\t        windowLabel: \"All time\",\n242\t        definition:\n243\t          \"Total referral_links rows — referees attached to a referrer (one row per referee).\",\n244\t        drilldownHref: \"/growth/referrals#top-referrers\",\n245\t      },\n246\t      raw: referredUsers,\n247\t      display: formatCount(referredUsers),\n248\t    },\n249\t    {\n250\t      blueprint: {\n251\t        id: \"growth.activated_referred_users\",\n252\t        label: \"Activated referred users\",\n253\t        unit: \"users\",\n254\t        source: \"referral_links + game_entries\",\n255\t        windowLabel: \"All time\",\n256\t        definition:\n257\t          \"Referees who have at least one game_entries row — they have actually played.\",\n258\t        drilldownHref: \"/growth/referrals#top-referrers\",\n259\t      },\n260\t      raw: activatedReferred,\n261\t      display: formatCount(activatedReferred),\n262\t    },\n263\t    {\n264\t      blueprint: {\n265\t        id: \"growth.referrer_earnings_lamports\",\n266\t        label: \"Referrer earnings (lamports)\",\n267\t        unit: \"lamports\",\n268\t        source: \"referral_earnings\",\n269\t        windowLabel: \"All time\",\n270\t        definition:\n271\t          \"Sum of referrer_earned_lamports across referral_earnings — the gross referral economy paid to referrers.\",\n272\t        drilldownHref: \"/growth/referrals#top-referrers\",\n273\t      },\n274\t      raw: referrerEarnings,\n275\t      display: formatLamports(referrerEarnings),\n276\t    },\n277\t    {\n278\t      blueprint: {\n279\t        id: \"growth.referee_rebates_lamports\",\n280\t        label: \"Referee rebates (lamports)\",\n281\t        unit: \"lamports\",\n282\t        source: \"referral_earnings\",\n283\t        windowLabel: \"All time\",\n284\t        definition:\n285\t          \"Sum of referee_rebate_lamports across referral_earnings — the referee-side rebate paid back from referral fees.\",\n286\t        drilldownHref: \"/growth/referrals#top-referrers\",\n287\t      },\n288\t      raw: refereeRebates,\n289\t      display: formatLamports(refereeRebates),\n290\t    },\n291\t    {\n292\t      blueprint: {\n293\t        id: \"growth.pending_claims_lamports\",\n294\t        label: \"Pending claim payouts (lamports)\",\n295\t        unit: \"lamports\",\n296\t        source: \"referral_claims\",\n297\t        windowLabel: \"Status pending or processing\",\n298\t        definition:\n299\t          \"Sum of amount_lamports for referral_claims awaiting on-chain payout (status pending/processing).\",\n300\t        drilldownHref: \"/growth/referrals?claimStatus=pending\",\n301\t      },\n302\t      raw: pendingClaimsLamports,\n303\t      display: formatLamports(pendingClaimsLamports),\n304\t    },\n305\t    {\n306\t      blueprint: {\n307\t        id: \"growth.failed_claims\",\n308\t        label: \"Failed claims\",\n309\t        unit: \"claims\",\n310\t        source: \"referral_claims\",\n311\t        windowLabel: \"Status failed or error\",\n312\t        definition:\n313\t          \"Referral claims with status 'failed' or 'error' that have not been recovered.\",\n314\t        drilldownHref: \"/growth/referrals?claimStatus=failed\",\n315\t      },\n316\t      raw: failedClaims,\n317\t      display: formatCount(failedClaims),\n318\t    },\n319\t    {\n320\t      blueprint: {\n321\t        id: \"growth.kol_count\",\n322\t        label: \"KOLs\",\n323\t        unit: \"users\",\n324\t        source: \"referral_kol_rates\",\n325\t        windowLabel: \"All time\",\n326\t        definition:\n327\t          \"Rows in referral_kol_rates — users with an explicit KOL rate override.\",\n328\t        drilldownHref: \"/growth/kol\",\n329\t      },\n330\t      raw: kolCount,\n331\t      display: formatCount(kolCount),\n332\t    },\n333\t  ];\n334\t\n335\t  return {\n336\t    generatedAt,\n337\t    metrics: blueprints.map(({ blueprint, raw, display }) =>\n338\t      buildMetric(blueprint, raw, display, generatedAt),\n339\t    ),\n340\t  };\n341\t}\n342\t\n343\texport async function listTopReferrers(\n344\t  options: ListLimitOptions = {},\n345\t): Promise<ReadonlyArray<PeekTopReferrerRow>> {\n346\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n347\t  const limit = clampLimit(\n348\t    options.limit,\n349\t    PEEK_GROWTH_TOP_REFERRERS_DEFAULT_LIMIT,\n350\t    PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT,\n351\t  );\n352\t\n353\t  return sql<Array<PeekTopReferrerRow>>`\n354\t    select\n355\t      rl_agg.referrer_user_id as \"referrerUserId\",\n356\t      pp.username as \"username\",\n357\t      rl_agg.referrer_wallet as \"wallet\",\n358\t      rc.code as \"referralCode\",\n359\t      rl_agg.referee_count as \"refereeCount\",\n360\t      rl_agg.active_referee_count as \"activeRefereeCount\",\n361\t      coalesce(re_agg.wager_lamports, 0)::text as \"referredWagerLamports\",\n362\t      coalesce(re_agg.referrer_earned_lamports, 0)::text as \"referrerEarnedLamports\",\n363\t      coalesce(claims_agg.pending_lamports, 0)::text as \"pendingClaimLamports\"\n364\t    from (\n365\t      select\n366\t        rl.referrer_user_id,\n367\t        max(rl.referrer_wallet) as referrer_wallet,\n368\t        count(*)::int as referee_count,\n369\t        count(distinct ge.user_id)::int as active_referee_count\n370\t      from referral_links rl\n371\t      left join (\n372\t        select distinct user_id from game_entries\n373\t      ) ge on ge.user_id = rl.referee_user_id\n374\t      group by rl.referrer_user_id\n375\t    ) rl_agg\n376\t    left join player_profiles pp on pp.user_id = rl_agg.referrer_user_id\n377\t    left join referral_codes rc on rc.user_id = rl_agg.referrer_user_id\n378\t    left join (\n379\t      select\n380\t        referrer_user_id,\n381\t        sum(wager_lamports) as wager_lamports,\n382\t        sum(referrer_earned_lamports) as referrer_earned_lamports\n383\t      from referral_earnings\n384\t      group by referrer_user_id\n385\t    ) re_agg on re_agg.referrer_user_id = rl_agg.referrer_user_id\n386\t    left join (\n387\t      select\n388\t        user_id,\n389\t        sum(amount_lamports) as pending_lamports\n390\t      from referral_claims\n391\t      where status in ('pending', 'processing')\n392\t      group by user_id\n393\t    ) claims_agg on claims_agg.user_id = rl_agg.referrer_user_id\n394\t    order by\n395\t      coalesce(re_agg.referrer_earned_lamports, 0) desc,\n396\t      rl_agg.referee_count desc,\n397\t      rl_agg.referrer_user_id asc\n398\t    limit ${limit}\n399\t  `;\n400\t}\n401\t\n402\texport async function listKolPerformance(\n403\t  options: ListLimitOptions = {},\n404\t): Promise<ReadonlyArray<PeekKolPerformanceRow>> {\n405\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n406\t  const limit = clampLimit(\n407\t    options.limit,\n408\t    PEEK_GROWTH_KOL_DEFAULT_LIMIT,\n409\t    PEEK_GROWTH_KOL_MAX_LIMIT,\n410\t  );\n411\t\n412\t  return sql<Array<PeekKolPerformanceRow>>`\n413\t    select\n414\t      kol.user_id as \"userId\",\n415\t      pp.username as \"username\",\n416\t      kol.wallet as \"wallet\",\n417\t      kol.rate_bps as \"rateBps\",\n418\t      kol.set_by as \"setBy\",\n419\t      kol.created_at::text as \"createdAt\",\n420\t      kol.updated_at::text as \"updatedAt\",\n421\t      coalesce(rl_agg.referee_count, 0)::int as \"refereeCount\",\n422\t      coalesce(re_agg.wager_lamports, 0)::text as \"referredWagerLamports\",\n423\t      coalesce(re_agg.referrer_earned_lamports, 0)::text as \"referrerEarnedLamports\"\n424\t    from referral_kol_rates kol\n425\t    left join player_profiles pp on pp.user_id = kol.user_id\n426\t    left join (\n427\t      select\n428\t        referrer_user_id,\n429\t        count(*)::int as referee_count\n430\t      from referral_links\n431\t      group by referrer_user_id\n432\t    ) rl_agg on rl_agg.referrer_user_id = kol.user_id\n433\t    left join (\n434\t      select\n435\t        referrer_user_id,\n436\t        sum(wager_lamports) as wager_lamports,\n437\t        sum(referrer_earned_lamports) as referrer_earned_lamports\n438\t      from referral_earnings\n439\t      group by referrer_user_id\n440\t    ) re_agg on re_agg.referrer_user_id = kol.user_id\n441\t    order by\n442\t      coalesce(re_agg.referrer_earned_lamports, 0) desc,\n443\t      kol.updated_at desc,\n444\t      kol.user_id asc\n445\t    limit ${limit}\n446\t  `;\n447\t}\n448\t\n449\texport async function listReferralClaims(\n450\t  options: ListReferralClaimsOptions = {},\n451\t): Promise<ReadonlyArray<PeekGrowthClaimRow>> {\n452\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n453\t  const limit = clampLimit(\n454\t    options.limit,\n455\t    PEEK_GROWTH_CLAIMS_DEFAULT_LIMIT,\n456\t    PEEK_GROWTH_CLAIMS_MAX_LIMIT,\n457\t  );\n458\t\n459\t  const filters = options.filters ?? {};\n460\t  const status = filters.status?.trim() || null;\n461\t  const userId = filters.userId?.trim() || null;\n462\t  const minAmount = filters.minAmountLamports?.trim() || null;\n463\t  const maxAmount = filters.maxAmountLamports?.trim() || null;\n464\t  const requestedFrom = filters.requestedFrom?.trim() || null;\n465\t  const requestedTo = filters.requestedTo?.trim() || null;\n466\t  const txSignature = filters.txSignature?.trim() || null;\n467\t  const errorContains = filters.errorContains?.trim() || null;\n468\t  const errorLike = errorContains ? `%${errorContains}%` : null;\n469\t\n470\t  // The \"failed\" virtual filter widens to status in ('failed','error') so the\n471\t  // command-center drill-down link works without a contract change.\n472\t  const isFailedAlias = status === \"failed\";\n473\t\n474\t  return sql<Array<PeekGrowthClaimRow>>`\n475\t    select\n476\t      rc.id::text as \"id\",\n477\t      rc.user_id as \"userId\",\n478\t      pp.username as \"username\",\n479\t      rc.wallet as \"wallet\",\n480\t      rc.amount_lamports::text as \"amountLamports\",\n481\t      rc.status as \"status\",\n482\t      rc.retry_count as \"retryCount\",\n483\t      rc.tx_signature as \"txSignature\",\n484\t      rc.error as \"error\",\n485\t      rc.requested_at::text as \"requestedAt\",\n486\t      rc.processed_at::text as \"processedAt\"\n487\t    from referral_claims rc\n488\t    left join player_profiles pp on pp.user_id = rc.user_id\n489\t    where\n490\t      (${status === null} or ${isFailedAlias} or rc.status = ${status ?? \"\"})\n491\t      and (${!isFailedAlias} or rc.status in ('failed', 'error'))\n492\t      and (${userId === null} or rc.user_id = ${userId ?? \"\"})\n493\t      and (${minAmount === null} or rc.amount_lamports >= ${minAmount ?? \"0\"}::bigint)\n494\t      and (${maxAmount === null} or rc.amount_lamports <= ${maxAmount ?? \"0\"}::bigint)\n495\t      and (${requestedFrom === null} or rc.requested_at >= ${requestedFrom ?? \"\"}::timestamptz)\n496\t      and (${requestedTo === null} or rc.requested_at < ${requestedTo ?? \"\"}::timestamptz)\n497\t      and (${txSignature === null} or rc.tx_signature = ${txSignature ?? \"\"})\n498\t      and (${errorLike === null} or coalesce(rc.error, '') ilike ${errorLike ?? \"\"})\n499\t    order by rc.requested_at desc, rc.id desc\n500\t    limit ${limit}\n501\t  `;\n502\t}\n503\t\n504\texport async function getReferralGraphNode(\n505\t  userId: string,\n506\t  options: ReferralGraphOptions = {},\n507\t): Promise<PeekReferralGraphNode | null> {\n508\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n509\t  const refereeLimit = clampLimit(options.refereeLimit, 200, 1000);\n510\t\n511\t  const [center] = await sql<\n512\t    Array<{\n513\t      userId: string;\n514\t      username: string | null;\n515\t      wallet: string;\n516\t      referralCode: string | null;\n517\t      referrerUserId: string | null;\n518\t      referrerUsername: string | null;\n519\t      referrerWallet: string | null;\n520\t      referrerCode: string | null;\n521\t      linkedAt: string | null;\n522\t    }>\n523\t  >`\n524\t    select\n525\t      pp.user_id as \"userId\",\n526\t      pp.username as \"username\",\n527\t      pp.wallet as \"wallet\",\n528\t      rc.code as \"referralCode\",\n529\t      rl.referrer_user_id as \"referrerUserId\",\n530\t      ref_pp.username as \"referrerUsername\",\n531\t      rl.referrer_wallet as \"referrerWallet\",\n532\t      ref_code.code as \"referrerCode\",\n533\t      rl.created_at::text as \"linkedAt\"\n534\t    from player_profiles pp\n535\t    left join referral_codes rc on rc.user_id = pp.user_id\n536\t    left join referral_links rl on rl.referee_user_id = pp.user_id\n537\t    left join player_profiles ref_pp on ref_pp.user_id = rl.referrer_user_id\n538\t    left join referral_codes ref_code on ref_code.user_id = rl.referrer_user_id\n539\t    where pp.user_id = ${userId}\n540\t    limit 1\n541\t  `;\n542\t\n543\t  if (!center) return null;\n544\t\n545\t  const referees = await sql<Array<PeekReferralGraphRefereeRow>>`\n546\t    select\n547\t      rl.referee_user_id as \"refereeUserId\",\n548\t      pp.username as \"refereeUsername\",\n549\t      rl.referee_wallet as \"refereeWallet\",\n550\t      rl.created_at::text as \"createdAt\"\n551\t    from referral_links rl\n552\t    left join player_profiles pp on pp.user_id = rl.referee_user_id\n553\t    where rl.referrer_user_id = ${userId}\n554\t    order by rl.created_at desc\n555\t    limit ${refereeLimit}\n556\t  `;\n557\t\n558\t  return {\n559\t    userId: center.userId,\n560\t    username: center.username,\n561\t    wallet: center.wallet,\n562\t    referralCode: center.referralCode,\n563\t    inboundReferrer: {\n564\t      referrerUserId: center.referrerUserId,\n565\t      referrerUsername: center.referrerUsername,\n566\t      referrerWallet: center.referrerWallet,\n567\t      referrerCode: center.referrerCode,\n568\t      linkedAt: center.linkedAt,\n569\t    },\n570\t    outboundReferees: referees,\n571\t  };\n572\t}\n573\t"}]},"parent_tool_use_id":null,"session_id":"ecdb13ab-d22c-40f2-a1b0-874b3e540ce1","uuid":"04a53788-0631-4b7c-a257-ef7de8c0e831","timestamp":"2026-04-25T12:59:20.469Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-growth-referrals.ts","content":"// Growth / referral admin queries (FR-7).\n//\n// One module that backs `/growth/referrals` and `/growth/kol`:\n//\n// - getGrowthReferralOverview() — eight FR-4 metrics: referrers, referred\n//   users, activated referred users (have at least one game_entries row),\n//   total referrer-earned lamports, total referee-rebate lamports, pending\n//   claim lamports, failed claim count, KOL count.\n// - listTopReferrers() — per-referrer aggregate with referee count, active\n//   referee count, referred wager volume, referrer earnings, and pending\n//   claim amount; used by the top-referrers table on /growth/referrals.\n// - listKolPerformance() — `referral_kol_rates` joined with the same\n//   per-referrer performance aggregates so the KOL table on /growth/kol can\n//   show rate alongside actual production.\n// - listReferralClaims() — filterable claims table reading from\n//   `referral_claims` joined with `player_profiles` for the username column.\n// - getReferralGraphNode() — one-hop referral-graph node centered on a user;\n//   surfaces inbound referrer (back-link) + outbound referees (drill into\n//   their user-detail pages). Re-uses the read paths the user-detail page\n//   already covers; collected here so the upcoming /growth/referrals graph\n//   navigation has a stable contract without changing user-detail.\n//\n// All queries are bounded server-side and rely only on existing tables.\n// Lamport / u64 sums round-trip as `text` to preserve precision.\n\nimport type { Sql } from \"postgres\";\nimport {\n  type PeekGrowthClaimRow,\n  type PeekGrowthOverview,\n  type PeekGrowthOverviewMetricId,\n  type PeekKolPerformanceRow,\n  type PeekMetric,\n  type PeekReferralClaimFilters,\n  type PeekReferralGraphNode,\n  type PeekReferralGraphRefereeRow,\n  type PeekTopReferrerRow,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_GROWTH_TOP_REFERRERS_DEFAULT_LIMIT = 50;\nexport const PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT = 250;\nexport const PEEK_GROWTH_KOL_DEFAULT_LIMIT = 100;\nexport const PEEK_GROWTH_KOL_MAX_LIMIT = 500;\nexport const PEEK_GROWTH_CLAIMS_DEFAULT_LIMIT = 100;\nexport const PEEK_GROWTH_CLAIMS_MAX_LIMIT = 500;\n\ntype GrowthOverviewOptions = {\n  sql?: Sql;\n  now?: Date;\n};\n\ntype ListLimitOptions = {\n  sql?: Sql;\n  limit?: number;\n};\n\nexport type ListReferralClaimsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekReferralClaimFilters>;\n};\n\nexport type ReferralGraphOptions = {\n  sql?: Sql;\n  refereeLimit?: number;\n};\n\nfunction clampLimit(\n  raw: number | undefined,\n  fallback: number,\n  max: number,\n): number {\n  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n  const floored = Math.floor(raw);\n  if (floored <= 0) return 1;\n  return Math.min(max, floored);\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\nfunction formatLamports(value: string): string {\n  // Show the raw lamport integer with thousands separators; the UI\n  // optionally re-renders as SOL for display while keeping lamports as the\n  // precise value (FR-4 monetary handling).\n  if (!value || value === \"0\") return \"0\";\n  // The value is a base-10 integer string from sum(BIGINT); group it manually\n  // to avoid a lossy Number conversion on large platform-wide sums.\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\ntype CountRow = { value: number };\ntype SumRow = { value: string };\n\nfunction readCount(rows: ReadonlyArray<CountRow> | undefined): number {\n  if (!rows || rows.length === 0) return 0;\n  const raw = rows[0]?.value;\n  if (typeof raw === \"number\" && Number.isFinite(raw)) return raw;\n  if (typeof raw === \"string\") {\n    const parsed = Number.parseInt(raw, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction readSum(rows: ReadonlyArray<SumRow> | undefined): string {\n  if (!rows || rows.length === 0) return \"0\";\n  const raw = rows[0]?.value;\n  return typeof raw === \"string\" && raw.length > 0 ? raw : \"0\";\n}\n\ntype GrowthMetricBlueprint = {\n  id: PeekGrowthOverviewMetricId;\n  label: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  definition: string;\n  drilldownHref: string | null;\n};\n\nfunction buildMetric(\n  blueprint: GrowthMetricBlueprint,\n  raw: number | string,\n  display: string,\n  asOf: string,\n): PeekMetric {\n  return {\n    id: blueprint.id,\n    label: blueprint.label,\n    value: raw,\n    valueDisplay: display,\n    unit: blueprint.unit,\n    source: blueprint.source,\n    windowLabel: blueprint.windowLabel,\n    asOf,\n    definition: blueprint.definition,\n    freshness: \"live\",\n    drilldownHref: blueprint.drilldownHref,\n  };\n}\n\nexport async function getGrowthReferralOverview(\n  options: GrowthOverviewOptions = {},\n): Promise<PeekGrowthOverview> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n\n  const [\n    referrersRows,\n    referredUsersRows,\n    activatedReferredRows,\n    referrerEarningsRows,\n    refereeRebatesRows,\n    pendingClaimsLamportsRows,\n    failedClaimsRows,\n    kolCountRows,\n  ] = await Promise.all([\n    sql<CountRow[]>`\n      select count(distinct referrer_user_id)::int as \"value\"\n      from referral_links\n    `,\n    sql<CountRow[]>`\n      select count(*)::int as \"value\"\n      from referral_links\n    `,\n    sql<CountRow[]>`\n      select count(*)::int as \"value\"\n      from (\n        select rl.referee_user_id\n        from referral_links rl\n        where exists (\n          select 1 from game_entries ge\n          where ge.user_id = rl.referee_user_id\n        )\n      ) activated\n    `,\n    sql<SumRow[]>`\n      select coalesce(sum(referrer_earned_lamports), 0)::text as \"value\"\n      from referral_earnings\n    `,\n    sql<SumRow[]>`\n      select coalesce(sum(referee_rebate_lamports), 0)::text as \"value\"\n      from referral_earnings\n    `,\n    sql<SumRow[]>`\n      select coalesce(sum(amount_lamports), 0)::text as \"value\"\n      from referral_claims\n      where status in ('pending', 'processing')\n    `,\n    sql<CountRow[]>`\n      select count(*)::int as \"value\"\n      from referral_claims\n      where status in ('failed', 'error')\n    `,\n    sql<CountRow[]>`\n      select count(*)::int as \"value\"\n      from referral_kol_rates\n    `,\n  ]);\n\n  const referrers = readCount(referrersRows);\n  const referredUsers = readCount(referredUsersRows);\n  const activatedReferred = readCount(activatedReferredRows);\n  const referrerEarnings = readSum(referrerEarningsRows);\n  const refereeRebates = readSum(refereeRebatesRows);\n  const pendingClaimsLamports = readSum(pendingClaimsLamportsRows);\n  const failedClaims = readCount(failedClaimsRows);\n  const kolCount = readCount(kolCountRows);\n\n  const blueprints: ReadonlyArray<{\n    blueprint: GrowthMetricBlueprint;\n    raw: number | string;\n    display: string;\n  }> = [\n    {\n      blueprint: {\n        id: \"growth.referrers\",\n        label: \"Referrers\",\n        unit: \"users\",\n        source: \"referral_links\",\n        windowLabel: \"All time\",\n        definition:\n          \"Distinct referrer_user_id values in referral_links — users who have referred at least one player.\",\n        drilldownHref: \"/growth/referrals#top-referrers\",\n      },\n      raw: referrers,\n      display: formatCount(referrers),\n    },\n    {\n      blueprint: {\n        id: \"growth.referred_users\",\n        label: \"Referred users\",\n        unit: \"users\",\n        source: \"referral_links\",\n        windowLabel: \"All time\",\n        definition:\n          \"Total referral_links rows — referees attached to a referrer (one row per referee).\",\n        drilldownHref: \"/growth/referrals#top-referrers\",\n      },\n      raw: referredUsers,\n      display: formatCount(referredUsers),\n    },\n    {\n      blueprint: {\n        id: \"growth.activated_referred_users\",\n        label: \"Activated referred users\",\n        unit: \"users\",\n        source: \"referral_links + game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Referees who have at least one game_entries row — they have actually played.\",\n        drilldownHref: \"/growth/referrals#top-referrers\",\n      },\n      raw: activatedReferred,\n      display: formatCount(activatedReferred),\n    },\n    {\n      blueprint: {\n        id: \"growth.referrer_earnings_lamports\",\n        label: \"Referrer earnings (lamports)\",\n        unit: \"lamports\",\n        source: \"referral_earnings\",\n        windowLabel: \"All time\",\n        definition:\n          \"Sum of referrer_earned_lamports across referral_earnings — the gross referral economy paid to referrers.\",\n        drilldownHref: \"/growth/referrals#top-referrers\",\n      },\n      raw: referrerEarnings,\n      display: formatLamports(referrerEarnings),\n    },\n    {\n      blueprint: {\n        id: \"growth.referee_rebates_lamports\",\n        label: \"Referee rebates (lamports)\",\n        unit: \"lamports\",\n        source: \"referral_earnings\",\n        windowLabel: \"All time\",\n        definition:\n          \"Sum of referee_rebate_lamports across referral_earnings — the referee-side rebate paid back from referral fees.\",\n        drilldownHref: \"/growth/referrals#top-referrers\",\n      },\n      raw: refereeRebates,\n      display: formatLamports(refereeRebates),\n    },\n    {\n      blueprint: {\n        id: \"growth.pending_claims_lamports\",\n        label: \"Pending claim payouts (lamports)\",\n        unit: \"lamports\",\n        source: \"referral_claims\",\n        windowLabel: \"Status pending or processing\",\n        definition:\n          \"Sum of amount_lamports for referral_claims awaiting on-chain payout (status pending/processing).\",\n        drilldownHref: \"/growth/referrals?claimStatus=pending\",\n      },\n      raw: pendingClaimsLamports,\n      display: formatLamports(pendingClaimsLamports),\n    },\n    {\n      blueprint: {\n        id: \"growth.failed_claims\",\n        label: \"Failed claims\",\n        unit: \"claims\",\n        source: \"referral_claims\",\n        windowLabel: \"Status failed or error\",\n        definition:\n          \"Referral claims with status 'failed' or 'error' that have not been recovered.\",\n        drilldownHref: \"/growth/referrals?claimStatus=failed\",\n      },\n      raw: failedClaims,\n      display: formatCount(failedClaims),\n    },\n    {\n      blueprint: {\n        id: \"growth.kol_count\",\n        label: \"KOLs\",\n        unit: \"users\",\n        source: \"referral_kol_rates\",\n        windowLabel: \"All time\",\n        definition:\n          \"Rows in referral_kol_rates — users with an explicit KOL rate override.\",\n        drilldownHref: \"/growth/kol\",\n      },\n      raw: kolCount,\n      display: formatCount(kolCount),\n    },\n  ];\n\n  return {\n    generatedAt,\n    metrics: blueprints.map(({ blueprint, raw, display }) =>\n      buildMetric(blueprint, raw, display, generatedAt),\n    ),\n  };\n}\n\nexport async function listTopReferrers(\n  options: ListLimitOptions = {},\n): Promise<ReadonlyArray<PeekTopReferrerRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_GROWTH_TOP_REFERRERS_DEFAULT_LIMIT,\n    PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT,\n  );\n\n  return sql<Array<PeekTopReferrerRow>>`\n    select\n      rl_agg.referrer_user_id as \"referrerUserId\",\n      pp.username as \"username\",\n      rl_agg.referrer_wallet as \"wallet\",\n      rc.code as \"referralCode\",\n      rl_agg.referee_count as \"refereeCount\",\n      rl_agg.active_referee_count as \"activeRefereeCount\",\n      coalesce(re_agg.wager_lamports, 0)::text as \"referredWagerLamports\",\n      coalesce(re_agg.referrer_earned_lamports, 0)::text as \"referrerEarnedLamports\",\n      coalesce(claims_agg.pending_lamports, 0)::text as \"pendingClaimLamports\"\n    from (\n      select\n        rl.referrer_user_id,\n        max(rl.referrer_wallet) as referrer_wallet,\n        count(*)::int as referee_count,\n        count(distinct ge.user_id)::int as active_referee_count\n      from referral_links rl\n      left join (\n        select distinct user_id from game_entries\n      ) ge on ge.user_id = rl.referee_user_id\n      group by rl.referrer_user_id\n    ) rl_agg\n    left join player_profiles pp on pp.user_id = rl_agg.referrer_user_id\n    left join referral_codes rc on rc.user_id = rl_agg.referrer_user_id\n    left join (\n      select\n        referrer_user_id,\n        sum(wager_lamports) as wager_lamports,\n        sum(referrer_earned_lamports) as referrer_earned_lamports\n      from referral_earnings\n      group by referrer_user_id\n    ) re_agg on re_agg.referrer_user_id = rl_agg.referrer_user_id\n    left join (\n      select\n        user_id,\n        sum(amount_lamports) as pending_lamports\n      from referral_claims\n      where status in ('pending', 'processing')\n      group by user_id\n    ) claims_agg on claims_agg.user_id = rl_agg.referrer_user_id\n    order by\n      coalesce(re_agg.referrer_earned_lamports, 0) desc,\n      rl_agg.referee_count desc,\n      rl_agg.referrer_user_id asc\n    limit ${limit}\n  `;\n}\n\nexport async function listKolPerformance(\n  options: ListLimitOptions = {},\n): Promise<ReadonlyArray<PeekKolPerformanceRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_GROWTH_KOL_DEFAULT_LIMIT,\n    PEEK_GROWTH_KOL_MAX_LIMIT,\n  );\n\n  return sql<Array<PeekKolPerformanceRow>>`\n    select\n      kol.user_id as \"userId\",\n      pp.username as \"username\",\n      kol.wallet as \"wallet\",\n      kol.rate_bps as \"rateBps\",\n      kol.set_by as \"setBy\",\n      kol.created_at::text as \"createdAt\",\n      kol.updated_at::text as \"updatedAt\",\n      coalesce(rl_agg.referee_count, 0)::int as \"refereeCount\",\n      coalesce(re_agg.wager_lamports, 0)::text as \"referredWagerLamports\",\n      coalesce(re_agg.referrer_earned_lamports, 0)::text as \"referrerEarnedLamports\"\n    from referral_kol_rates kol\n    left join player_profiles pp on pp.user_id = kol.user_id\n    left join (\n      select\n        referrer_user_id,\n        count(*)::int as referee_count\n      from referral_links\n      group by referrer_user_id\n    ) rl_agg on rl_agg.referrer_user_id = kol.user_id\n    left join (\n      select\n        referrer_user_id,\n        sum(wager_lamports) as wager_lamports,\n        sum(referrer_earned_lamports) as referrer_earned_lamports\n      from referral_earnings\n      group by referrer_user_id\n    ) re_agg on re_agg.referrer_user_id = kol.user_id\n    order by\n      coalesce(re_agg.referrer_earned_lamports, 0) desc,\n      kol.updated_at desc,\n      kol.user_id asc\n    limit ${limit}\n  `;\n}\n\nexport async function listReferralClaims(\n  options: ListReferralClaimsOptions = {},\n): Promise<ReadonlyArray<PeekGrowthClaimRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_GROWTH_CLAIMS_DEFAULT_LIMIT,\n    PEEK_GROWTH_CLAIMS_MAX_LIMIT,\n  );\n\n  const filters = options.filters ?? {};\n  const status = filters.status?.trim() || null;\n  const userId = filters.userId?.trim() || null;\n  const minAmount = filters.minAmountLamports?.trim() || null;\n  const maxAmount = filters.maxAmountLamports?.trim() || null;\n  const requestedFrom = filters.requestedFrom?.trim() || null;\n  const requestedTo = filters.requestedTo?.trim() || null;\n  const txSignature = filters.txSignature?.trim() || null;\n  const errorContains = filters.errorContains?.trim() || null;\n  const errorLike = errorContains ? `%${errorContains}%` : null;\n\n  // The \"failed\" virtual filter widens to status in ('failed','error') so the\n  // command-center drill-down link works without a contract change.\n  const isFailedAlias = status === \"failed\";\n\n  return sql<Array<PeekGrowthClaimRow>>`\n    select\n      rc.id::text as \"id\",\n      rc.user_id as \"userId\",\n      pp.username as \"username\",\n      rc.wallet as \"wallet\",\n      rc.amount_lamports::text as \"amountLamports\",\n      rc.status as \"status\",\n      rc.retry_count as \"retryCount\",\n      rc.tx_signature as \"txSignature\",\n      rc.error as \"error\",\n      rc.requested_at::text as \"requestedAt\",\n      rc.processed_at::text as \"processedAt\"\n    from referral_claims rc\n    left join player_profiles pp on pp.user_id = rc.user_id\n    where\n      (${status === null} or ${isFailedAlias} or rc.status = ${status ?? \"\"})\n      and (${!isFailedAlias} or rc.status in ('failed', 'error'))\n      and (${userId === null} or rc.user_id = ${userId ?? \"\"})\n      and (${minAmount === null} or rc.amount_lamports >= ${minAmount ?? \"0\"}::bigint)\n      and (${maxAmount === null} or rc.amount_lamports <= ${maxAmount ?? \"0\"}::bigint)\n      and (${requestedFrom === null} or rc.requested_at >= ${requestedFrom ?? \"\"}::timestamptz)\n      and (${requestedTo === null} or rc.requested_at < ${requestedTo ?? \"\"}::timestamptz)\n      and (${txSignature === null} or rc.tx_signature = ${txSignature ?? \"\"})\n      and (${errorLike === null} or coalesce(rc.error, '') ilike ${errorLike ?? \"\"})\n    order by rc.requested_at desc, rc.id desc\n    limit ${limit}\n  `;\n}\n\nexport async function getReferralGraphNode(\n  userId: string,\n  options: ReferralGraphOptions = {},\n): Promise<PeekReferralGraphNode | null> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const refereeLimit = clampLimit(options.refereeLimit, 200, 1000);\n\n  const [center] = await sql<\n    Array<{\n      userId: string;\n      username: string | null;\n      wallet: string;\n      referralCode: string | null;\n      referrerUserId: string | null;\n      referrerUsername: string | null;\n      referrerWallet: string | null;\n      referrerCode: string | null;\n      linkedAt: string | null;\n    }>\n  >`\n    select\n      pp.user_id as \"userId\",\n      pp.username as \"username\",\n      pp.wallet as \"wallet\",\n      rc.code as \"referralCode\",\n      rl.referrer_user_id as \"referrerUserId\",\n      ref_pp.username as \"referrerUsername\",\n      rl.referrer_wallet as \"referrerWallet\",\n      ref_code.code as \"referrerCode\",\n      rl.created_at::text as \"linkedAt\"\n    from player_profiles pp\n    left join referral_codes rc on rc.user_id = pp.user_id\n    left join referral_links rl on rl.referee_user_id = pp.user_id\n    left join player_profiles ref_pp on ref_pp.user_id = rl.referrer_user_id\n    left join referral_codes ref_code on ref_code.user_id = rl.referrer_user_id\n    where pp.user_id = ${userId}\n    limit 1\n  `;\n\n  if (!center) return null;\n\n  const referees = await sql<Array<PeekReferralGraphRefereeRow>>`\n    select\n      rl.referee_user_id as \"refereeUserId\",\n      pp.username as \"refereeUsername\",\n      rl.referee_wallet as \"refereeWallet\",\n      rl.created_at::text as \"createdAt\"\n    from referral_links rl\n    left join player_profiles pp on pp.user_id = rl.referee_user_id\n    where rl.referrer_user_id = ${userId}\n    order by rl.created_at desc\n    limit ${refereeLimit}\n  `;\n\n  return {\n    userId: center.userId,\n    username: center.username,\n    wallet: center.wallet,\n    referralCode: center.referralCode,\n    inboundReferrer: {\n      referrerUserId: center.referrerUserId,\n      referrerUsername: center.referrerUsername,\n      referrerWallet: center.referrerWallet,\n      referrerCode: center.referrerCode,\n      linkedAt: center.linkedAt,\n    },\n    outboundReferees: referees,\n  };\n}\n","numLines":573,"startLine":1,"totalLines":573}}}
