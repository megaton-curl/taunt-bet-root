{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RbaC49YCAoFv7s6wjzM3Ki","type":"tool_result","content":"130\t\n131\ttype LinkedAccountRow = {\n132\t  userId: string;\n133\t  provider: string;\n134\t  providerAccountId: string;\n135\t  telegramUsername: string | null;\n136\t  status: string;\n137\t};\n138\t\n139\ttype RoundRow = {\n140\t  pda: string;\n141\t  game: string;\n142\t  matchId: string;\n143\t  phase: string;\n144\t  creator: string | null;\n145\t};\n146\t\n147\ttype TransactionRow = {\n148\t  id: string;\n149\t  txSig: string;\n150\t  game: string;\n151\t  matchId: string;\n152\t  txType: string;\n153\t  wallet: string;\n154\t  amountLamports: string;\n155\t  createdAt: string;\n156\t};\n157\t\n158\ttype QueueEventRow = {\n159\t  id: string;\n160\t  eventType: string;\n161\t  status: string;\n162\t  attempts: number;\n163\t  scheduledAt: string;\n164\t};\n165\t\n166\tasync function searchUsers(\n167\t  sql: Sql,\n168\t  query: string,\n169\t  limit: number,\n170\t): Promise<PeekSearchResult[]> {\n171\t  const exact = query;\n172\t  const like = `%${query}%`;\n173\t  const rows = await sql<UserRow[]>`\n174\t    select\n175\t      user_id as \"userId\",\n176\t      username,\n177\t      wallet,\n178\t      created_at::text as \"joinedAt\"\n179\t    from player_profiles\n180\t    where user_id = ${exact}\n181\t       or wallet = ${exact}\n182\t       or lower(username) = lower(${exact})\n183\t       or user_id ilike ${like}\n184\t       or wallet ilike ${like}\n185\t       or coalesce(username, '') ilike ${like}\n186\t    order by created_at desc\n187\t    limit ${limit + 1}\n188\t  `;\n189\t  return rows.slice(0, limit).map((row) => ({\n190\t    entityType: \"user\" as const,\n191\t    id: row.userId,\n192\t    label: row.username ?? row.userId,\n193\t    sublabel: row.wallet,\n194\t    context: `joined ${row.joinedAt}`,\n195\t    href: `/users/${encodeURIComponent(row.userId)}`,\n196\t  }));\n197\t}\n198\t\n199\tasync function searchReferralCodes(\n200\t  sql: Sql,\n201\t  query: string,\n202\t  limit: number,\n203\t): Promise<PeekSearchResult[]> {\n204\t  const exact = query;\n205\t  const like = `%${query}%`;\n206\t  const rows = await sql<ReferralCodeRow[]>`\n207\t    select\n208\t      code,\n209\t      user_id as \"userId\",\n210\t      wallet\n211\t    from referral_codes\n212\t    where upper(code) = upper(${exact})\n213\t       or code ilike ${like}\n214\t       or user_id = ${exact}\n215\t       or wallet = ${exact}\n216\t    order by created_at desc\n217\t    limit ${limit + 1}\n218\t  `;\n219\t  return rows.slice(0, limit).map((row) => ({\n220\t    entityType: \"referral\" as const,\n221\t    id: row.code,\n222\t    label: row.code,\n223\t    sublabel: row.userId,\n224\t    context: `wallet ${row.wallet}`,\n225\t    href: `/users/${encodeURIComponent(row.userId)}`,\n226\t  }));\n227\t}\n228\t\n229\tasync function searchLinkedAccounts(\n230\t  sql: Sql,\n231\t  query: string,\n232\t  limit: number,\n233\t): Promise<PeekSearchResult[]> {\n234\t  const trimmed = query.startsWith(\"@\") ? query.slice(1) : query;\n235\t  const exact = trimmed;\n236\t  const like = `%${trimmed}%`;\n237\t  const rows = await sql<LinkedAccountRow[]>`\n238\t    select\n239\t      user_id as \"userId\",\n240\t      provider,\n241\t      provider_account_id as \"providerAccountId\",\n242\t      nullif(metadata_json->>'telegramUsername', '') as \"telegramUsername\",\n243\t      status\n244\t    from linked_accounts\n245\t    where status = 'active'\n246\t      and (\n247\t        provider_account_id = ${exact}\n248\t        or metadata_json->>'telegramUsername' = ${exact}\n249\t        or provider_account_id ilike ${like}\n250\t        or coalesce(metadata_json->>'telegramUsername', '') ilike ${like}\n251\t      )\n252\t    order by linked_at desc\n253\t    limit ${limit + 1}\n254\t  `;\n255\t  return rows.slice(0, limit).map((row) => {\n256\t    const display = row.telegramUsername\n257\t      ? `@${row.telegramUsername}`\n258\t      : row.providerAccountId;\n259\t    return {\n260\t      entityType: \"linked_account\" as const,\n261\t      id: `${row.provider}:${row.providerAccountId}`,\n262\t      label: display,\n263\t      sublabel: row.userId,\n264\t      context: `${row.provider} (${row.status})`,\n265\t      href: `/users/${encodeURIComponent(row.userId)}`,\n266\t    };\n267\t  });\n268\t}\n269\t\n270\tasync function searchRounds(\n271\t  sql: Sql,\n272\t  query: string,\n273\t  limit: number,\n274\t): Promise<PeekSearchResult[]> {\n275\t  const exact = query;\n276\t  const flipPotRows = await sql<RoundRow[]>`\n277\t    select\n278\t      pda,\n279\t      game,\n280\t      match_id as \"matchId\",\n281\t      phase,\n282\t      creator\n283\t    from rounds\n284\t    where pda = ${exact}\n285\t       or match_id = ${exact}\n286\t       or creator = ${exact}\n287\t    order by created_at desc\n288\t    limit ${limit + 1}\n289\t  `;\n290\t  const closeCallRows = await sql<RoundRow[]>`\n291\t    select\n292\t      pda,\n293\t      'closecall'::text as \"game\",\n294\t      round_id as \"matchId\",\n295\t      phase,\n296\t      null::text as \"creator\"\n297\t    from closecall_rounds\n298\t    where pda = ${exact}\n299\t       or round_id = ${exact}\n300\t    order by created_at desc\n301\t    limit ${limit + 1}\n302\t  `;\n303\t  const combined = [...flipPotRows, ...closeCallRows];\n304\t  return combined.slice(0, limit).map((row) => ({\n305\t    entityType: \"round\" as const,\n306\t    id: row.pda,\n307\t    label: row.matchId,\n308\t    sublabel: `${row.game} • ${row.phase}`,\n309\t    context: row.creator ? `creator ${row.creator}` : null,\n310\t    href: `/games/${encodeURIComponent(row.game)}/rounds/${encodeURIComponent(row.pda)}`,\n311\t  }));\n312\t}\n313\t\n314\tasync function searchTransactions(\n315\t  sql: Sql,\n316\t  query: string,\n317\t  limit: number,\n318\t): Promise<PeekSearchResult[]> {\n319\t  const exact = query;\n320\t  const rows = await 