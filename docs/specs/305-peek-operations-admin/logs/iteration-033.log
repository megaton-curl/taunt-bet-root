{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01CW7YhZCxAXdPx7zFL1d5hZ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01JyjcSxb539zZ3j9QHxrF3S","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/db/queries/get-game-rounds.ts","content":"// Per-game round queries (FR-8).\n//\n// Backs `/games/[game]` for FlipYou, Pot Shot, and Close Call.\n//\n// FlipYou + Pot Shot share the `rounds` table (migration 001) and the\n// commit-reveal lifecycle (`created` -> `locked` -> `settling` -> `settled`\n// or `expired`). Close Call uses the separate `closecall_rounds` table\n// (migration 004) with its own `open` -> `settled`/`refunded` lifecycle and\n// a Pyth-driven `outcome` column.\n//\n// Stuck-state filters cover the four operational signals from FR-8:\n//\n//   - nonterminalAged   — phase is in a non-terminal state for longer than\n//                         the configured age threshold (created/locked/\n//                         settling for FlipYou+Pot Shot; open for Close\n//                         Call).\n//   - highAttempts      — settle_attempts above the configured threshold\n//                         (FlipYou+Pot Shot only — `closecall_rounds` has no\n//                         `settle_attempts` column).\n//   - settledWithoutTx  — round is settled but no payout/refund row exists\n//                         in `transactions` for the round's match_id +\n//                         game; the on-chain settlement step did not\n//                         produce the expected ledger record.\n//   - refunds           — phase reflects the refund terminal state\n//                         (`expired` for FlipYou+Pot Shot; `refunded` or\n//                         outcome `refund` for Close Call).\n//\n// Queries are bounded server-side via clamped page size and an explicit\n// total-count query; lamport / u64 sums round-trip as `text` to preserve\n// precision.\n\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_ROUNDS_GAME_IDS,\n  type PeekCloseCallOutcome,\n  type PeekCloseCallPhase,\n  type PeekCloseCallRoundFilters,\n  type PeekCloseCallRoundRow,\n  type PeekCloseCallRoundStuckFilters,\n  type PeekPagination,\n  type PeekRoundFilters,\n  type PeekRoundPhase,\n  type PeekRoundRow,\n  type PeekRoundStuckFilters,\n  type PeekRoundsGameId,\n  type PeekRoundsListResult,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE = 50;\nexport const PEEK_GAME_ROUNDS_MAX_PAGE_SIZE = 250;\n\nexport type RoundStuckThresholds = {\n  ageMinutes: number;\n  maxSettleAttempts: number;\n};\n\nexport const PEEK_ROUND_STUCK_DEFAULTS: RoundStuckThresholds = {\n  ageMinutes: 5,\n  maxSettleAttempts: 3,\n};\n\nexport type ListRoundsOptions = {\n  sql?: Sql;\n  game: PeekRoundsGameId;\n  filters?: Partial<PeekRoundFilters>;\n  page?: number;\n  pageSize?: number;\n  thresholds?: Partial<RoundStuckThresholds>;\n};\n\nexport type ListCloseCallRoundsOptions = {\n  sql?: Sql;\n  filters?: Partial<PeekCloseCallRoundFilters>;\n  page?: number;\n  pageSize?: number;\n  thresholds?: Partial<RoundStuckThresholds>;\n};\n\nconst EMPTY_STUCK_FILTERS: PeekRoundStuckFilters = {\n  nonterminalAged: false,\n  highAttempts: false,\n  settledWithoutTx: false,\n  refunds: false,\n};\n\nconst EMPTY_CC_STUCK_FILTERS: PeekCloseCallRoundStuckFilters = {\n  nonterminalAged: false,\n  settledWithoutTx: false,\n  refunds: false,\n};\n\nfunction clampPage(value: number | undefined): number {\n  if (typeof value !== \"number\" || !Number.isFinite(value)) return 1;\n  const floored = Math.floor(value);\n  return floored < 1 ? 1 : floored;\n}\n\nfunction clampPageSize(value: number | undefined): number {\n  if (typeof value !== \"number\" || !Number.isFinite(value)) {\n    return PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE;\n  }\n  const floored = Math.floor(value);\n  if (floored <= 0) return 1;\n  return Math.min(PEEK_GAME_ROUNDS_MAX_PAGE_SIZE, floored);\n}\n\nfunction readInt(value: number | string | null | undefined): number {\n  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n  if (typeof value === \"string\") {\n    const parsed = Number.parseInt(value, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction buildPagination(\n  page: number,\n  pageSize: number,\n  totalCount: number,\n): PeekPagination {\n  const totalPages = totalCount === 0 ? 1 : Math.ceil(totalCount / pageSize);\n  return { page, pageSize, totalCount, totalPages };\n}\n\nfunction isPeekRoundsGameId(value: string): value is PeekRoundsGameId {\n  return (PEEK_ROUNDS_GAME_IDS as ReadonlyArray<string>).includes(value);\n}\n\n// ---------- FlipYou + Pot Shot -----------------------------------------------\n\ntype RawRoundRow = {\n  pda: string;\n  game: string;\n  matchId: string;\n  phase: string;\n  creator: string;\n  targetSlot: string | null;\n  settleAttempts: number | string;\n  settleTx: string | null;\n  resultSide: number | string | null;\n  winner: string | null;\n  amountLamports: string;\n  createdAt: string;\n  updatedAt: string;\n  settledAt: string | null;\n};\n\nfunction normalizeRoundRow(row: RawRoundRow): PeekRoundRow | null {\n  if (!isPeekRoundsGameId(row.game)) return null;\n  return {\n    game: row.game,\n    pda: row.pda,\n    matchId: row.matchId,\n    phase: row.phase as PeekRoundPhase,\n    creator: row.creator,\n    targetSlot: row.targetSlot,\n    settleAttempts: readInt(row.settleAttempts),\n    settleTx: row.settleTx,\n    resultSide:\n      row.resultSide === null || row.resultSide === undefined\n        ? null\n        : readInt(row.resultSide),\n    winner: row.winner,\n    amountLamports:\n      typeof row.amountLamports === \"string\" ? row.amountLamports : \"0\",\n    createdAt: row.createdAt,\n    updatedAt: row.updatedAt,\n    settledAt: row.settledAt,\n  };\n}\n\nexport async function listRounds(\n  options: ListRoundsOptions,\n): Promise<PeekRoundsListResult<PeekRoundRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const game = options.game;\n  const page = clampPage(options.page);\n  const pageSize = clampPageSize(options.pageSize);\n  const offset = (page - 1) * pageSize;\n  const thresholds: RoundStuckThresholds = {\n    ...PEEK_ROUND_STUCK_DEFAULTS,\n    ...options.thresholds,\n  };\n  const ageInterval = `${thresholds.ageMinutes} minutes`;\n\n  const filters = options.filters ?? {};\n  const phase = filters.phase ?? null;\n  const search = filters.search?.trim() || null;\n  const searchLike = search ? `%${search}%` : null;\n  const fromDate = filters.fromDate?.trim() || null;\n  const toDate = filters.toDate?.trim() || null;\n  const stuck: PeekRoundStuckFilters = {\n    ...EMPTY_STUCK_FILTERS,\n    ...filters.stuck,\n  };\n\n  // The four stuck flags are OR'd together so an operator can stack any\n  // combination without writing four separate queries. When none of the\n  // flags are set, the predicate disappears (`true`).\n  const anyStuck =\n    stuck.nonterminalAged ||\n    stuck.highAttempts ||\n    stuck.settledWithoutTx ||\n    stuck.refunds;\n\n  const [rows, countRows] = await Promise.all([\n    sql<RawRoundRow[]>`\n      select\n        r.pda as \"pda\",\n        r.game as \"game\",\n        r.match_id as \"matchId\",\n        r.phase as \"phase\",\n        r.creator as \"creator\",\n        r.target_slot::text as \"targetSlot\",\n        r.settle_attempts as \"settleAttempts\",\n        r.settle_tx as \"settleTx\",\n        r.result_side as \"resultSide\",\n        r.winner as \"winner\",\n        r.amount_lamports::text as \"amountLamports\",\n        r.created_at::text as \"createdAt\",\n        r.updated_at::text as \"updatedAt\",\n        r.settled_at::text as \"settledAt\"\n      from rounds r\n      where r.game = ${game}\n        and (${phase === null} or r.phase = ${phase ?? \"\"})\n        and (\n          ${searchLike === null}\n          or r.pda ilike ${searchLike ?? \"\"}\n          or r.match_id ilike ${searchLike ?? \"\"}\n          or r.creator ilike ${searchLike ?? \"\"}\n        )\n        and (${fromDate === null} or r.created_at >= ${fromDate ?? \"\"}::timestamptz)\n        and (${toDate === null} or r.created_at < ${toDate ?? \"\"}::timestamptz)\n        and (\n          ${!anyStuck}\n          or (\n            (${stuck.nonterminalAged} and r.phase in ('created','locked','settling') and r.created_at < now() - ${ageInterval}::interval)\n            or (${stuck.highAttempts} and r.settle_attempts > ${thresholds.maxSettleAttempts})\n            or (${stuck.settledWithoutTx} and r.phase = 'settled' and not exists (\n              select 1 from transactions t\n              where t.game = r.game\n                and t.match_id = r.match_id\n                and t.tx_type in ('payout','refund')\n            ))\n            or (${stuck.refunds} and r.phase = 'expired')\n          )\n        )\n      order by r.created_at desc, r.pda asc\n      limit ${pageSize} offset ${offset}\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from rounds r\n      where r.game = ${game}\n        and (${phase === null} or r.phase = ${phase ?? \"\"})\n        and (\n          ${searchLike === null}\n          or r.pda ilike ${searchLike ?? \"\"}\n          or r.match_id ilike ${searchLike ?? \"\"}\n          or r.creator ilike ${searchLike ?? \"\"}\n        )\n        and (${fromDate === null} or r.created_at >= ${fromDate ?? \"\"}::timestamptz)\n        and (${toDate === null} or r.created_at < ${toDate ?? \"\"}::timestamptz)\n        and (\n          ${!anyStuck}\n          or (\n            (${stuck.nonterminalAged} and r.phase in ('created','locked','settling') and r.created_at < now() - ${ageInterval}::interval)\n            or (${stuck.highAttempts} and r.settle_attempts > ${thresholds.maxSettleAttempts})\n            or (${stuck.settledWithoutTx} and r.phase = 'settled' and not exists (\n              select 1 from transactions t\n              where t.game = r.game\n                and t.match_id = r.match_id\n                and t.tx_type in ('payout','refund')\n            ))\n            or (${stuck.refunds} and r.phase = 'expired')\n          )\n        )\n    `,\n  ]);\n\n  const normalized: PeekRoundRow[] = [];\n  for (const row of rows) {\n    const r = normalizeRoundRow(row);\n    if (r) normalized.push(r);\n  }\n\n  const totalCount = readInt(countRows[0]?.value);\n  return {\n    rows: normalized,\n    pagination: buildPagination(page, pageSize, totalCount),\n  };\n}\n\n// ---------- Close Call -------------------------------------------------------\n\ntype RawCloseCallRoundRow = {\n  pda: string;\n  roundId: string;\n  phase: string;\n  outcome: string;\n  openPrice: string;\n  openPriceExpo: number | string;\n  closePrice: string | null;\n  greenPoolLamports: string;\n  redPoolLamports: string;\n  totalFeeLamports: string;\n  settleTx: string | null;\n  createdAt: string;\n  settledAt: string | null;\n};\n\nfunction normalizeCloseCallRow(\n  row: RawCloseCallRoundRow,\n): PeekCloseCallRoundRow {\n  return {\n    pda: row.pda,\n    roundId: row.roundId,\n    phase: row.phase as PeekCloseCallPhase,\n    outcome: row.outcome as PeekCloseCallOutcome,\n    openPrice: typeof row.openPrice === \"string\" ? row.openPrice : \"0\",\n    openPriceExpo: readInt(row.openPriceExpo),\n    closePrice: row.closePrice,\n    greenPoolLamports:\n      typeof row.greenPoolLamports === \"string\" ? row.greenPoolLamports : \"0\",\n    redPoolLamports:\n      typeof row.redPoolLamports === \"string\" ? row.redPoolLamports : \"0\",\n    totalFeeLamports:\n      typeof row.totalFeeLamports === \"string\" ? row.totalFeeLamports : \"0\",\n    settleTx: row.settleTx,\n    createdAt: row.createdAt,\n    settledAt: row.settledAt,\n  };\n}\n\nexport async function listCloseCallRounds(\n  options: ListCloseCallRoundsOptions = {},\n): Promise<PeekRoundsListResult<PeekCloseCallRoundRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const page = clampPage(options.page);\n  const pageSize = clampPageSize(options.pageSize);\n  const offset = (page - 1) * pageSize;\n  const thresholds: RoundStuckThresholds = {\n    ...PEEK_ROUND_STUCK_DEFAULTS,\n    ...options.thresholds,\n  };\n  const ageInterval = `${thresholds.ageMinutes} minutes`;\n\n  const filters = options.filters ?? {};\n  const phase = filters.phase ?? null;\n  const outcome = filters.outcome ?? null;\n  const search = filters.search?.trim() || null;\n  const searchLike = search ? `%${search}%` : null;\n  const fromDate = filters.fromDate?.trim() || null;\n  const toDate = filters.toDate?.trim() || null;\n  const stuck: PeekCloseCallRoundStuckFilters = {\n    ...EMPTY_CC_STUCK_FILTERS,\n    ...filters.stuck,\n  };\n\n  const anyStuck =\n    stuck.nonterminalAged || stuck.settledWithoutTx || stuck.refunds;\n\n  const [rows, countRows] = await Promise.all([\n    sql<RawCloseCallRoundRow[]>`\n      select\n        cc.pda as \"pda\",\n        cc.round_id as \"roundId\",\n        cc.phase as \"phase\",\n        cc.outcome as \"outcome\",\n        cc.open_price::text as \"openPrice\",\n        cc.open_price_expo as \"openPriceExpo\",\n        cc.close_price::text as \"closePrice\",\n        cc.green_pool::text as \"greenPoolLamports\",\n        cc.red_pool::text as \"redPoolLamports\",\n        cc.total_fee::text as \"totalFeeLamports\",\n        cc.settle_tx as \"settleTx\",\n        cc.created_at::text as \"createdAt\",\n        cc.settled_at::text as \"settledAt\"\n      from closecall_rounds cc\n      where (${phase === null} or cc.phase = ${phase ?? \"\"})\n        and (${outcome === null} or cc.outcome = ${outcome ?? \"\"})\n        and (\n          ${searchLike === null}\n          or cc.pda ilike ${searchLike ?? \"\"}\n          or cc.round_id ilike ${searchLike ?? \"\"}\n        )\n        and (${fromDate === null} or cc.created_at >= ${fromDate ?? \"\"}::timestamptz)\n        and (${toDate === null} or cc.created_at < ${toDate ?? \"\"}::timestamptz)\n        and (\n          ${!anyStuck}\n          or (\n            (${stuck.nonterminalAged} and cc.phase = 'open' and cc.created_at < now() - ${ageInterval}::interval)\n            or (${stuck.settledWithoutTx} and cc.phase = 'settled' and not exists (\n              select 1 from transactions t\n              where t.game = 'closecall'\n                and t.match_id = cc.round_id\n                and t.tx_type in ('payout','refund')\n            ))\n            or (${stuck.refunds} and (cc.phase = 'refunded' or cc.outcome = 'refund'))\n          )\n        )\n      order by cc.created_at desc, cc.pda asc\n      limit ${pageSize} offset ${offset}\n    `,\n    sql<Array<{ value: number | string }>>`\n      select count(*)::int as \"value\"\n      from closecall_rounds cc\n      where (${phase === null} or cc.phase = ${phase ?? \"\"})\n        and (${outcome === null} or cc.outcome = ${outcome ?? \"\"})\n        and (\n          ${searchLike === null}\n          or cc.pda ilike ${searchLike ?? \"\"}\n          or cc.round_id ilike ${searchLike ?? \"\"}\n        )\n        and (${fromDate === null} or cc.created_at >= ${fromDate ?? \"\"}::timestamptz)\n        and (${toDate === null} or cc.created_at < ${toDate ?? \"\"}::timestamptz)\n        and (\n          ${!anyStuck}\n          or (\n            (${stuck.nonterminalAged} and cc.phase = 'open' and cc.created_at < now() - ${ageInterval}::interval)\n            or (${stuck.settledWithoutTx} and cc.phase = 'settled' and not exists (\n              select 1 from transactions t\n              where t.game = 'closecall'\n                and t.match_id = cc.round_id\n                and t.tx_type in ('payout','refund')\n            ))\n            or (${stuck.refunds} and (cc.phase = 'refunded' or cc.outcome = 'refund'))\n          )\n        )\n    `,\n  ]);\n\n  const normalized = rows.map(normalizeCloseCallRow);\n  const totalCount = readInt(countRows[0]?.value);\n\n  return {\n    rows: normalized,\n    pagination: buildPagination(page, pageSize, totalCount),\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":875,"cache_read_input_tokens":119263,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":875},"output_tokens":46,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"ecdb13ab-d22c-40f2-a1b0-874b3e540ce1","uuid":"d2558552-9fb9-40c2-8980-753962f69c5c"}
