{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HhCjQqSF3gR9VMeP3c8pCn","type":"tool_result","content":"1\timport type { PeekSummary } from \"../../../lib/types/peek\";\n2\timport { getSqlClient } from \"../client\";\n3\t\n4\texport async function getPeekSummary(): Promise<PeekSummary> {\n5\t  const sql = getSqlClient();\n6\t  const [row] = await sql<PeekSummary[]>`\n7\t    select\n8\t      (select count(*)::int from player_profiles) as \"totalUsers\",\n9\t      (select count(*)::int from referral_codes) as \"totalUsersWithCodes\",\n10\t      (select count(*)::int from referral_links) as \"totalReferredUsers\",\n11\t      (select count(distinct referrer_user_id)::int from referral_links) as \"totalUniqueReferrers\"\n12\t  `;\n13\t\n14\t  return row;\n15\t}\n16\t"}]},"parent_tool_use_id":null,"session_id":"a037f20c-2fad-4bfb-9c41-68dddd9e3cd0","uuid":"ed970034-66e2-41aa-a469-dfff879b49bc","timestamp":"2026-04-25T12:15:37.959Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-peek-summary.ts","content":"import type { PeekSummary } from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport async function getPeekSummary(): Promise<PeekSummary> {\n  const sql = getSqlClient();\n  const [row] = await sql<PeekSummary[]>`\n    select\n      (select count(*)::int from player_profiles) as \"totalUsers\",\n      (select count(*)::int from referral_codes) as \"totalUsersWithCodes\",\n      (select count(*)::int from referral_links) as \"totalReferredUsers\",\n      (select count(distinct referrer_user_id)::int from referral_links) as \"totalUniqueReferrers\"\n  `;\n\n  return row;\n}\n","numLines":16,"startLine":1,"totalLines":16}}}
