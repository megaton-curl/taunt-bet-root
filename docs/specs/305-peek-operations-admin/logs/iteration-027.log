{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RTPonMbTJB7wedi6SPd1xt","type":"tool_result","content":"300\t      metadata_json as \"metadataJson\",\n301\t      linked_at::text as \"linkedAt\",\n302\t      updated_at::text as \"updatedAt\"\n303\t    from linked_accounts\n304\t    where user_id = ${userId}\n305\t    order by linked_at desc\n306\t  `;\n307\t}\n308\t\n309\tasync function fetchRecentTelegramLinkTokens(\n310\t  sql: Sql,\n311\t  userId: string,\n312\t  limit: number,\n313\t): Promise<ReadonlyArray<PeekTelegramLinkTokenRow>> {\n314\t  return sql<Array<PeekTelegramLinkTokenRow>>`\n315\t    select\n316\t      id::text as \"id\",\n317\t      status,\n318\t      telegram_user_id as \"telegramUserId\",\n319\t      telegram_username as \"telegramUsername\",\n320\t      expires_at::text as \"expiresAt\",\n321\t      redeemed_at::text as \"redeemedAt\",\n322\t      created_at::text as \"createdAt\"\n323\t    from telegram_link_tokens\n324\t    where user_id = ${userId}\n325\t    order by created_at desc\n326\t    limit ${limit}\n327\t  `;\n328\t}\n329\t\n330\tasync function fetchKolRate(\n331\t  sql: Sql,\n332\t  userId: string,\n333\t): Promise<PeekKolRate | null> {\n334\t  const [row] = await sql<\n335\t    Array<{\n336\t      rateBps: number;\n337\t      setBy: string;\n338\t      createdAt: string;\n339\t      updatedAt: string;\n340\t    }>\n341\t  >`\n342\t    select\n343\t      rate_bps as \"rateBps\",\n344\t      set_by as \"setBy\",\n345\t      created_at::text as \"createdAt\",\n346\t      updated_at::text as \"updatedAt\"\n347\t    from referral_kol_rates\n348\t    where user_id = ${userId}\n349\t    limit 1\n350\t  `;\n351\t  return row ?? null;\n352\t}\n353\t\n354\tasync function fetchReferralEarnings(\n355\t  sql: Sql,\n356\t  userId: string,\n357\t): Promise<PeekReferralEarningsSummary> {\n358\t  const [row] = await sql<\n359\t    Array<{\n360\t      earningsCount: number;\n361\t      totalReferrerEarnedLamports: string;\n362\t      totalRefereeRebateLamports: string;\n363\t      lastEarnedAt: string | null;\n364\t    }>\n365\t  >`\n366\t    select\n367\t      count(*)::int as \"earningsCount\",\n368\t      coalesce(sum(referrer_earned_lamports), 0)::text as \"totalReferrerEarnedLamports\",\n369\t      coalesce(sum(referee_rebate_lamports), 0)::text as \"totalRefereeRebateLamports\",\n370\t      max(created_at)::text as \"lastEarnedAt\"\n371\t    from referral_earnings\n372\t    where referrer_user_id = ${userId} or referee_user_id = ${userId}\n373\t  `;\n374\t  return (\n375\t    row ?? {\n376\t      earningsCount: 0,\n377\t      totalReferrerEarnedLamports: \"0\",\n378\t      totalRefereeRebateLamports: \"0\",\n379\t      lastEarnedAt: null,\n380\t    }\n381\t  );\n382\t}\n383\t\n384\tasync function fetchRecentReferralClaims(\n385\t  sql: Sql,\n386\t  userId: string,\n387\t  limit: number,\n388\t): Promise<ReadonlyArray<PeekReferralClaimRow>> {\n389\t  return sql<Array<PeekReferralClaimRow>>`\n390\t    select\n391\t      id::text as \"id\",\n392\t      amount_lamports::text as \"amountLamports\",\n393\t      status,\n394\t      retry_count as \"retryCount\",\n395\t      tx_signature as \"txSignature\",\n396\t      error,\n397\t      requested_at::text as \"requestedAt\",\n398\t      processed_at::text as \"processedAt\"\n399\t    from referral_claims\n400\t    where user_id = ${userId}\n401\t    order by requested_at desc\n402\t    limit ${limit}\n403\t  `;\n404\t}\n405\t\n406\tasync function fetchPlayerPoints(\n407\t  sql: Sql,\n408\t  userId: string,\n409\t): Promise<PeekPlayerPoints> {\n410\t  const [row] = await sql<\n411\t    Array<{\n412\t      balance: string;\n413\t      lifetimeEarned: string;\n414\t      updatedAt: string;\n415\t    }>\n416\t  >`\n417\t    select\n418\t      balance::text as \"balance\",\n419\t      lifetime_earned::text as \"lifetimeEarned\",\n420\t      updated_at::text as \"updatedAt\"\n421\t    from player_points\n422\t    where user_id = ${userId}\n423\t    limit 1\n424\t  `;\n425\t  return (\n426\t    row ?? {\n427\t      balance: \"0\",\n428\t      lifetimeEarned: \"0\",\n429\t      updatedAt: null,\n430\t    }\n431\t  );\n432\t}\n433\t\n434\tasync function fetchRecentPointGrants(\n435\t  sql: Sql,\n436\t  userId: string,\n437\t  limit: number,\n438\t): Promise<ReadonlyArray<PeekPointGrantRow>> {\n439\t  return sql<Array<PeekPointGrantRow>>`\n440\t    select\n441\t      id::text as \"id\",\n442\t      source_type as \"sourceType\",\n443\t      source_id as \"sourceId\",\n444\t      amount::text as \"amount\",\n445\t      created_at::text as \"createdAt\"\n446\t    from point_grants\n447\t    where user_id = ${userId}\n448\t    order by created_at desc\n449\t    limit ${limit}\n450\t  `;\n451\t}\n452\t\n453\tasync function fetchRecentCrateDrops(\n454\t  sql: Sql,\n455\t  userId: string,\n456\t  limit: number,\n457\t): Promise<ReadonlyArray<PeekCrateDropRow>> {\n458\t  return sql<Array<PeekCrateDropRow>>`\n459\t    select\n460\t      id::text as \"id\",\n461\t      trigger_type as \"triggerType\",\n462\t      trigger_id as \"triggerId\",\n463\t      crate_type as \"crateType\",\n464\t      contents_amount as \"contentsAmount\",\n465\t      status,\n466\t      created_at::text as \"createdAt\",\n467\t      granted_at::text as \"grantedAt\"\n468\t    from crate_drops\n469\t    where user_id = ${userId}\n470\t    order by created_at desc\n471\t    limit ${limit}\n472\t  `;\n473\t}\n474\t\n475\tasync function fetchChallengeSummary(\n476\t  sql: Sql,\n477\t  userId: string,\n478\t): Promise<PeekChallengeAssignmentSummary> {\n479\t  const [row] = await sql<\n480\t    Array<{\n481\t      active: number;\n482\t      completed: number;\n483\t      expired: number;\n484\t      total: number;\n485\t    }>\n486\t  >`\n487\t    select\n488\t      count(*) filter (where status = 'active')::int as \"active\",\n489\t      count(*) filter (where status = 'completed')::int as \"completed\",\n490\t      count(*) filter (where status = 'expired')::int as \"expired\",\n491\t      count(*)::int as \"total\"\n492\t    from challenge_assignments\n493\t    where user_id = ${userId}\n494\t  `;\n495\t  return row ?? { active: 0, completed: 0, expired: 0, total: 0 };\n496\t}\n497\t\n498\tasync function fetchRecentGameEntries(\n499\t  sql: Sql,\n500\t  userId: string,\n501\t  limit: number,\n502\t): Promise<ReadonlyArray<PeekGameEntryRow>> {\n503\t  return sql<Array<PeekGameEntryRow>>`\n504\t    select\n505\t      id::text as \"id\",\n506\t      game,\n507\t      round_pda as \"roundPda\",\n508\t      match_id as \"matchId\",\n509\t      amount_lamports::text as \"amountLamports\",\n510\t      side,\n511\t      is_winner as \"isWinner\",\n512\t      payout_lamports::text as \"payoutLamports\",\n513\t      created_at::text as \"createdAt\",\n514\t      settled_at::text as \"settledAt\"\n515\t    from game_entries\n516\t    where user_id = ${userId}\n517\t    order by created_at desc\n518\t    limit ${limit}\n519\t  `;\n520\t}\n521\t\n522\tasync function fetchRecentTransactions(\n523\t  sql: Sql,\n524\t  userId: string,\n525\t  limit: number,\n526\t): Promise<ReadonlyArray<PeekTransactionRow>> {\n527\t  return sql<Array<PeekTransactionRow>>`\n528\t    select\n529\t      id::text as \"id\",\n530\t      game,\n531\t      match_id as \"matchId\",\n532\t      tx_type as \"txType\",\n533\t      amount_lamports::text as \"amountLamports\",\n534\t      tx_sig as \"txSig\",\n535\t      created_at::text as \"createdAt\"\n536\t    from transactions\n537\t    where user_id = ${userId}\n538\t    order by created_at desc\n539\t    limit ${limit}\n540\t  `;\n541\t}\n542\t\n543\tasync function fetchFraudFlags(\n544\t  sql: Sql,\n545\t  userId: string,\n546\t  limit: number,\n547\t): Promise<ReadonlyArray<PeekFraudFlagRow>> {\n548\t  return sql<Array<PeekFraudFlagRow>>`\n549\t    select\n550\t      id::text as \"id\",\n551\t      flag_type as \"flagType\",\n552\t      status,\n553\t      related_id as \"relatedId\",\n554\t      created_at::text as \"createdAt\",\n555\t      resolved_at::text as \"resolvedAt\"\n556\t    from fraud_flags\n557\t    where user_id = ${userId}\n558\t    order by created_at desc\n559\t    limit ${limit}\n560\t  `;\n561\t}\n562\t\n563\tasync function fetchRecentUserQueueEvents(\n564\t  sql: Sql,\n565\t  userId: string,\n566\t  wallet: string,\n567\t  limit: number,\n568\t): Promise<ReadonlyArray<PeekUserQueueEventRow>> {\n569\t  // event_queue has no user_id column; join via JSONB payload identifiers that\n570\t  // every backend writer uses today (`userId`, `user_id`, `wallet`). Bounded by\n571\t  // limit so the admin page never streams the full queue.\n572\t  return sql<Array<PeekUserQueueEventRow>>`\n573\t    select\n574\t      id::text as \"id\",\n575\t      event_type as \"eventType\",\n576\t      status,\n577\t      attempts,\n578\t      max_attempts as \"maxAttempts\",\n579\t      scheduled_at::text as \"scheduledAt\",\n580\t      created_at::text as \"createdAt\",\n581\t      error\n582\t    from event_queue\n583\t    where payload->>'userId' = ${userId}\n584\t       or payload->>'user_id' = ${userId}\n585\t       or payload->>'wallet' = ${wallet}\n586\t    order by created_at desc\n587\t    limit ${limit}\n588\t  `;\n589\t}\n590\t\n591\tasync function fetchSelfReferralIndicator(\n592\t  sql: Sql,\n593\t  userId: string,\n594\t): Promise<{ selfReferral: boolean }> {\n595\t  const [row] = await sql<Array<{ selfReferral: boolean }>>`\n596\t    select exists (\n597\t      select 1\n598\t      from referral_links rl\n599\t      where rl.referrer_user_id = ${userId}"}]},"parent_tool_use_id":null,"session_id":"a037f20c-2fad-4bfb-9c41-68dddd9e3cd0","uuid":"216f6c24-96f2-466f-843e-cc48e195ad05","timestamp":"2026-04-25T12:16:01.629Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-peek-user-detail.ts","content":"      metadata_json as \"metadataJson\",\n      linked_at::text as \"linkedAt\",\n      updated_at::text as \"updatedAt\"\n    from linked_accounts\n    where user_id = ${userId}\n    order by linked_at desc\n  `;\n}\n\nasync function fetchRecentTelegramLinkTokens(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekTelegramLinkTokenRow>> {\n  return sql<Array<PeekTelegramLinkTokenRow>>`\n    select\n      id::text as \"id\",\n      status,\n      telegram_user_id as \"telegramUserId\",\n      telegram_username as \"telegramUsername\",\n      expires_at::text as \"expiresAt\",\n      redeemed_at::text as \"redeemedAt\",\n      created_at::text as \"createdAt\"\n    from telegram_link_tokens\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchKolRate(\n  sql: Sql,\n  userId: string,\n): Promise<PeekKolRate | null> {\n  const [row] = await sql<\n    Array<{\n      rateBps: number;\n      setBy: string;\n      createdAt: string;\n      updatedAt: string;\n    }>\n  >`\n    select\n      rate_bps as \"rateBps\",\n      set_by as \"setBy\",\n      created_at::text as \"createdAt\",\n      updated_at::text as \"updatedAt\"\n    from referral_kol_rates\n    where user_id = ${userId}\n    limit 1\n  `;\n  return row ?? null;\n}\n\nasync function fetchReferralEarnings(\n  sql: Sql,\n  userId: string,\n): Promise<PeekReferralEarningsSummary> {\n  const [row] = await sql<\n    Array<{\n      earningsCount: number;\n      totalReferrerEarnedLamports: string;\n      totalRefereeRebateLamports: string;\n      lastEarnedAt: string | null;\n    }>\n  >`\n    select\n      count(*)::int as \"earningsCount\",\n      coalesce(sum(referrer_earned_lamports), 0)::text as \"totalReferrerEarnedLamports\",\n      coalesce(sum(referee_rebate_lamports), 0)::text as \"totalRefereeRebateLamports\",\n      max(created_at)::text as \"lastEarnedAt\"\n    from referral_earnings\n    where referrer_user_id = ${userId} or referee_user_id = ${userId}\n  `;\n  return (\n    row ?? {\n      earningsCount: 0,\n      totalReferrerEarnedLamports: \"0\",\n      totalRefereeRebateLamports: \"0\",\n      lastEarnedAt: null,\n    }\n  );\n}\n\nasync function fetchRecentReferralClaims(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekReferralClaimRow>> {\n  return sql<Array<PeekReferralClaimRow>>`\n    select\n      id::text as \"id\",\n      amount_lamports::text as \"amountLamports\",\n      status,\n      retry_count as \"retryCount\",\n      tx_signature as \"txSignature\",\n      error,\n      requested_at::text as \"requestedAt\",\n      processed_at::text as \"processedAt\"\n    from referral_claims\n    where user_id = ${userId}\n    order by requested_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchPlayerPoints(\n  sql: Sql,\n  userId: string,\n): Promise<PeekPlayerPoints> {\n  const [row] = await sql<\n    Array<{\n      balance: string;\n      lifetimeEarned: string;\n      updatedAt: string;\n    }>\n  >`\n    select\n      balance::text as \"balance\",\n      lifetime_earned::text as \"lifetimeEarned\",\n      updated_at::text as \"updatedAt\"\n    from player_points\n    where user_id = ${userId}\n    limit 1\n  `;\n  return (\n    row ?? {\n      balance: \"0\",\n      lifetimeEarned: \"0\",\n      updatedAt: null,\n    }\n  );\n}\n\nasync function fetchRecentPointGrants(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekPointGrantRow>> {\n  return sql<Array<PeekPointGrantRow>>`\n    select\n      id::text as \"id\",\n      source_type as \"sourceType\",\n      source_id as \"sourceId\",\n      amount::text as \"amount\",\n      created_at::text as \"createdAt\"\n    from point_grants\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchRecentCrateDrops(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekCrateDropRow>> {\n  return sql<Array<PeekCrateDropRow>>`\n    select\n      id::text as \"id\",\n      trigger_type as \"triggerType\",\n      trigger_id as \"triggerId\",\n      crate_type as \"crateType\",\n      contents_amount as \"contentsAmount\",\n      status,\n      created_at::text as \"createdAt\",\n      granted_at::text as \"grantedAt\"\n    from crate_drops\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchChallengeSummary(\n  sql: Sql,\n  userId: string,\n): Promise<PeekChallengeAssignmentSummary> {\n  const [row] = await sql<\n    Array<{\n      active: number;\n      completed: number;\n      expired: number;\n      total: number;\n    }>\n  >`\n    select\n      count(*) filter (where status = 'active')::int as \"active\",\n      count(*) filter (where status = 'completed')::int as \"completed\",\n      count(*) filter (where status = 'expired')::int as \"expired\",\n      count(*)::int as \"total\"\n    from challenge_assignments\n    where user_id = ${userId}\n  `;\n  return row ?? { active: 0, completed: 0, expired: 0, total: 0 };\n}\n\nasync function fetchRecentGameEntries(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekGameEntryRow>> {\n  return sql<Array<PeekGameEntryRow>>`\n    select\n      id::text as \"id\",\n      game,\n      round_pda as \"roundPda\",\n      match_id as \"matchId\",\n      amount_lamports::text as \"amountLamports\",\n      side,\n      is_winner as \"isWinner\",\n      payout_lamports::text as \"payoutLamports\",\n      created_at::text as \"createdAt\",\n      settled_at::text as \"settledAt\"\n    from game_entries\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchRecentTransactions(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekTransactionRow>> {\n  return sql<Array<PeekTransactionRow>>`\n    select\n      id::text as \"id\",\n      game,\n      match_id as \"matchId\",\n      tx_type as \"txType\",\n      amount_lamports::text as \"amountLamports\",\n      tx_sig as \"txSig\",\n      created_at::text as \"createdAt\"\n    from transactions\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchFraudFlags(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekFraudFlagRow>> {\n  return sql<Array<PeekFraudFlagRow>>`\n    select\n      id::text as \"id\",\n      flag_type as \"flagType\",\n      status,\n      related_id as \"relatedId\",\n      created_at::text as \"createdAt\",\n      resolved_at::text as \"resolvedAt\"\n    from fraud_flags\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchRecentUserQueueEvents(\n  sql: Sql,\n  userId: string,\n  wallet: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekUserQueueEventRow>> {\n  // event_queue has no user_id column; join via JSONB payload identifiers that\n  // every backend writer uses today (`userId`, `user_id`, `wallet`). Bounded by\n  // limit so the admin page never streams the full queue.\n  return sql<Array<PeekUserQueueEventRow>>`\n    select\n      id::text as \"id\",\n      event_type as \"eventType\",\n      status,\n      attempts,\n      max_attempts as \"maxAttempts\",\n      scheduled_at::text as \"scheduledAt\",\n      created_at::text as \"createdAt\",\n      error\n    from event_queue\n    where payload->>'userId' = ${userId}\n       or payload->>'user_id' = ${userId}\n       or payload->>'wallet' = ${wallet}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchSelfReferralIndicator(\n  sql: Sql,\n  userId: string,\n): Promise<{ selfReferral: boolean }> {\n  const [row] = await sql<Array<{ selfReferral: boolean }>>`\n    select exists (\n      select 1\n      from referral_links rl\n      where rl.referrer_user_id = ${userId}","numLines":300,"startLine":300,"totalLines":627}}}
