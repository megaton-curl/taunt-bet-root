{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013QFzQ6eKafCzPGcrLydVni","type":"tool_result","content":"600\t        and rl.referee_user_id = ${userId}\n601\t    ) as \"selfReferral\"\n602\t  `;\n603\t  return row ?? { selfReferral: false };\n604\t}\n605\t\n606\tfunction computeAttention(input: {\n607\t  recentReferralClaims: ReadonlyArray<PeekReferralClaimRow>;\n608\t  recentUserQueueEvents: ReadonlyArray<PeekUserQueueEventRow>;\n609\t  fraudFlags: ReadonlyArray<PeekFraudFlagRow>;\n610\t  recentCrateDrops: ReadonlyArray<PeekCrateDropRow>;\n611\t  selfReferralRow: { selfReferral: boolean };\n612\t}): PeekUserAttentionFlags {\n613\t  return {\n614\t    failedClaim: input.recentReferralClaims.some(\n615\t      (claim) => claim.status === \"failed\" || claim.status === \"error\",\n616\t    ),\n617\t    deadQueueEvent: input.recentUserQueueEvents.some(\n618\t      (event) => event.status === \"dead\",\n619\t    ),\n620\t    activeFraudFlag: input.fraudFlags.some((flag) => flag.status === \"open\"),\n621\t    pendingSolCratePayout: input.recentCrateDrops.some(\n622\t      (drop) => drop.crateType === \"sol\" && drop.status === \"pending\",\n623\t    ),\n624\t    suspiciousReferralLoop: input.selfReferralRow.selfReferral,\n625\t  };\n626\t}\n627\t"}]},"parent_tool_use_id":null,"session_id":"a037f20c-2fad-4bfb-9c41-68dddd9e3cd0","uuid":"6559d2ed-55d7-420d-b7dd-505679583656","timestamp":"2026-04-25T12:16:04.448Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-peek-user-detail.ts","content":"        and rl.referee_user_id = ${userId}\n    ) as \"selfReferral\"\n  `;\n  return row ?? { selfReferral: false };\n}\n\nfunction computeAttention(input: {\n  recentReferralClaims: ReadonlyArray<PeekReferralClaimRow>;\n  recentUserQueueEvents: ReadonlyArray<PeekUserQueueEventRow>;\n  fraudFlags: ReadonlyArray<PeekFraudFlagRow>;\n  recentCrateDrops: ReadonlyArray<PeekCrateDropRow>;\n  selfReferralRow: { selfReferral: boolean };\n}): PeekUserAttentionFlags {\n  return {\n    failedClaim: input.recentReferralClaims.some(\n      (claim) => claim.status === \"failed\" || claim.status === \"error\",\n    ),\n    deadQueueEvent: input.recentUserQueueEvents.some(\n      (event) => event.status === \"dead\",\n    ),\n    activeFraudFlag: input.fraudFlags.some((flag) => flag.status === \"open\"),\n    pendingSolCratePayout: input.recentCrateDrops.some(\n      (drop) => drop.crateType === \"sol\" && drop.status === \"pending\",\n    ),\n    suspiciousReferralLoop: input.selfReferralRow.selfReferral,\n  };\n}\n","numLines":28,"startLine":600,"totalLines":627}}}
