{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016DDzvtXr8TkMEWdc1o1Fi9","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport type { Sql } from \"postgres\";\n3\timport {\n4\t  COMMAND_CENTER_DEFAULTS,\n5\t  getCommandCenterAttention,\n6\t} from \"../get-command-center-attention\";\n7\timport type { PeekCommandCenterAttentionId } from \"../../../../lib/types/peek\";\n8\t\n9\ttype SqlCall = {\n10\t  text: string;\n11\t  values: ReadonlyArray<unknown>;\n12\t};\n13\t\n14\ttype ResponseValue = ReadonlyArray<{ value: number | string }> | Error;\n15\t\n16\ttype SqlMock = {\n17\t  sql: Sql;\n18\t  calls: ReadonlyArray<SqlCall>;\n19\t};\n20\t\n21\t// Build a SQL mock that returns a sequence of responses, one per call.\n22\t// Each response is either a row array (success) or an Error (rejection).\n23\tfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n24\t  const calls: SqlCall[] = [];\n25\t  let cursor = 0;\n26\t\n27\t  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n28\t    const text = [...strings].join(\"?\");\n29\t    calls.push({ text, values: [...values] });\n30\t    const next = responses[cursor++];\n31\t    if (next instanceof Error) {\n32\t      return Promise.reject(next);\n33\t    }\n34\t    return Promise.resolve(next ?? []);\n35\t  };\n36\t\n37\t  // Cast through unknown — only the tagged-template surface is exercised here.\n38\t  const sql = fn as unknown as Sql;\n39\t  return { sql, calls };\n40\t}\n41\t\n42\tconst ALL_IDS: ReadonlyArray<PeekCommandCenterAttentionId> = [\n43\t  \"failed_claims\",\n44\t  \"dead_queue_events\",\n45\t  \"stuck_rounds_flipyou_potshot\",\n46\t  \"stuck_rounds_closecall\",\n47\t  \"pending_sol_crate_payouts\",\n48\t  \"stale_active_dogpile_events\",\n49\t  \"high_value_exports_24h\",\n50\t];\n51\t\n52\tdescribe(\"getCommandCenterAttention\", () => {\n53\t  it(\"populated: returns one PeekMetric per attention id with FR-4 bookkeeping\", async () => {\n54\t    const mock = createSqlMock([\n55\t      [{ value: 3 }],\n56\t      [{ value: 1 }],\n57\t      [{ value: 5 }],\n58\t      [{ value: 2 }],\n59\t      [{ value: 4 }],\n60\t      [{ value: 6 }],\n61\t      [{ value: 7 }],\n62\t    ]);\n63\t    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n64\t\n65\t    const result = await getCommandCenterAttention({ sql: mock.sql, now });\n66\t\n67\t    expect(result.generatedAt).toBe(\"2026-04-25T10:00:00.000Z\");\n68\t    expect(result.metrics).toHaveLength(7);\n69\t    expect(result.metrics.map((m) => m.id)).toEqual(ALL_IDS);\n70\t\n71\t    for (const metric of result.metrics) {\n72\t      expect(metric.asOf).toBe(\"2026-04-25T10:00:00.000Z\");\n73\t      expect(metric.freshness).toBe(\"live\");\n74\t      expect(metric.label.length).toBeGreaterThan(0);\n75\t      expect(metric.definition.length).toBeGreaterThan(0);\n76\t      expect(metric.source.length).toBeGreaterThan(0);\n77\t      expect(metric.windowLabel.length).toBeGreaterThan(0);\n78\t      expect(metric.drilldownHref).not.toBeNull();\n79\t    }\n80\t\n81\t    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n82\t    expect(byId.get(\"failed_claims\")?.value).toBe(3);\n83\t    expect(byId.get(\"failed_claims\")?.valueDisplay).toBe(\"3\");\n84\t    expect(byId.get(\"failed_claims\")?.source).toBe(\"referral_claims\");\n85\t    expect(byId.get(\"dead_queue_events\")?.value).toBe(1);\n86\t    expect(byId.get(\"stuck_rounds_flipyou_potshot\")?.value).toBe(5);\n87\t    expect(byId.get(\"stuck_rounds_closecall\")?.value).toBe(2);\n88\t    expect(byId.get(\"pending_sol_crate_payouts\")?.value).toBe(4);\n89\t    expect(byId.get(\"stale_active_dogpile_events\")?.value).toBe(6);\n90\t    expect(byId.get(\"high_value_exports_24h\")?.value).toBe(7);\n91\t    expect(byId.get(\"high_value_exports_24h\")?.source).toBe(\"operator_events\");\n92\t  });\n93\t\n94\t  it(\"populated (large counts): formats valueDisplay with a thousands separator\", async () => {\n95\t    const mock = createSqlMock([\n96\t      [{ value: 1234 }],\n97\t      [{ value: 0 }],\n98\t      [{ value: 0 }],\n99\t      [{ value: 0 }],\n100\t      [{ value: 0 }],"}]},"parent_tool_use_id":null,"session_id":"a037f20c-2fad-4bfb-9c41-68dddd9e3cd0","uuid":"1afacd86-6fb9-4ca5-8da5-6d1b41a6d0ab","timestamp":"2026-04-25T12:16:41.545Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-command-center-attention.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  COMMAND_CENTER_DEFAULTS,\n  getCommandCenterAttention,\n} from \"../get-command-center-attention\";\nimport type { PeekCommandCenterAttentionId } from \"../../../../lib/types/peek\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<{ value: number | string }> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\n// Build a SQL mock that returns a sequence of responses, one per call.\n// Each response is either a row array (success) or an Error (rejection).\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) {\n      return Promise.reject(next);\n    }\n    return Promise.resolve(next ?? []);\n  };\n\n  // Cast through unknown — only the tagged-template surface is exercised here.\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\nconst ALL_IDS: ReadonlyArray<PeekCommandCenterAttentionId> = [\n  \"failed_claims\",\n  \"dead_queue_events\",\n  \"stuck_rounds_flipyou_potshot\",\n  \"stuck_rounds_closecall\",\n  \"pending_sol_crate_payouts\",\n  \"stale_active_dogpile_events\",\n  \"high_value_exports_24h\",\n];\n\ndescribe(\"getCommandCenterAttention\", () => {\n  it(\"populated: returns one PeekMetric per attention id with FR-4 bookkeeping\", async () => {\n    const mock = createSqlMock([\n      [{ value: 3 }],\n      [{ value: 1 }],\n      [{ value: 5 }],\n      [{ value: 2 }],\n      [{ value: 4 }],\n      [{ value: 6 }],\n      [{ value: 7 }],\n    ]);\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getCommandCenterAttention({ sql: mock.sql, now });\n\n    expect(result.generatedAt).toBe(\"2026-04-25T10:00:00.000Z\");\n    expect(result.metrics).toHaveLength(7);\n    expect(result.metrics.map((m) => m.id)).toEqual(ALL_IDS);\n\n    for (const metric of result.metrics) {\n      expect(metric.asOf).toBe(\"2026-04-25T10:00:00.000Z\");\n      expect(metric.freshness).toBe(\"live\");\n      expect(metric.label.length).toBeGreaterThan(0);\n      expect(metric.definition.length).toBeGreaterThan(0);\n      expect(metric.source.length).toBeGreaterThan(0);\n      expect(metric.windowLabel.length).toBeGreaterThan(0);\n      expect(metric.drilldownHref).not.toBeNull();\n    }\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"failed_claims\")?.value).toBe(3);\n    expect(byId.get(\"failed_claims\")?.valueDisplay).toBe(\"3\");\n    expect(byId.get(\"failed_claims\")?.source).toBe(\"referral_claims\");\n    expect(byId.get(\"dead_queue_events\")?.value).toBe(1);\n    expect(byId.get(\"stuck_rounds_flipyou_potshot\")?.value).toBe(5);\n    expect(byId.get(\"stuck_rounds_closecall\")?.value).toBe(2);\n    expect(byId.get(\"pending_sol_crate_payouts\")?.value).toBe(4);\n    expect(byId.get(\"stale_active_dogpile_events\")?.value).toBe(6);\n    expect(byId.get(\"high_value_exports_24h\")?.value).toBe(7);\n    expect(byId.get(\"high_value_exports_24h\")?.source).toBe(\"operator_events\");\n  });\n\n  it(\"populated (large counts): formats valueDisplay with a thousands separator\", async () => {\n    const mock = createSqlMock([\n      [{ value: 1234 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],","numLines":100,"startLine":1,"totalLines":233}}}
