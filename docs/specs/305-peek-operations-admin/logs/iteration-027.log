n  wallet: \"wallet-1\",\n  joinedAt: \"2026-01-01T00:00:00.000Z\",\n  avatarUrl: \"https://example.com/a.png\",\n  heatMultiplier: \"1.50\",\n  profilePointsBalance: \"100\",\n  referralCode: \"ALICE2026\",\n  referrerUserId: \"u-0\",\n  referrerCode: \"MENTOR\",\n  refereeCount: 3,\n  telegramLinkState: \"active\" as const,\n  linkedAt: \"2026-01-02T00:00:00.000Z\",\n  telegramUserId: \"tg-9001\",\n  telegramUsername: \"alice_tg\",\n};\n\nfunction fullResponses(): ReadonlyArray<ResponseValue> {\n  return [\n    [IDENTITY_ROW],\n    [\n      {\n        refereeUserId: \"u-2\",\n        refereeUsername: \"bob\",\n        createdAt: \"2026-01-03T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"la-1\",\n        provider: \"telegram\",\n        providerAccountId: \"tg-9001\",\n        status: \"active\",\n        telegramUsername: \"alice_tg\",\n        metadataJson: { telegramUsername: \"alice_tg\" },\n        linkedAt: \"2026-01-02T00:00:00.000Z\",\n        updatedAt: \"2026-01-02T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"tlk-1\",\n        status: \"redeemed\",\n        telegramUserId: \"tg-9001\",\n        telegramUsername: \"alice_tg\",\n        expiresAt: \"2026-01-02T01:00:00.000Z\",\n        redeemedAt: \"2026-01-02T00:30:00.000Z\",\n        createdAt: \"2026-01-02T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        rateBps: 250,\n        setBy: \"ops@example.com\",\n        createdAt: \"2026-01-04T00:00:00.000Z\",\n        updatedAt: \"2026-01-04T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        earningsCount: 7,\n        totalReferrerEarnedLamports: \"12345\",\n        totalRefereeRebateLamports: \"6789\",","numLines":120,"startLine":1,"totalLines":623}}}
