{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QkqQQm33KiWy6Rh2T4oUvz","type":"tool_result","content":"1\t-- 007_game_entries.sql — Single source of truth for participation + stats + leaderboard.\n2\t--\n3\t-- Written at participation time (create/bet), updated at settlement via UPSERT.\n4\t-- Refunded entries: is_winner = NULL, payout_lamports = amount_lamports.\n5\t\n6\tCREATE TABLE game_entries (\n7\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n8\t  user_id         TEXT         NOT NULL,\n9\t  wallet          TEXT         NOT NULL,\n10\t  game            TEXT         NOT NULL CHECK (game IN ('flipyou', 'potshot', 'closecall')),\n11\t  round_pda       TEXT         NOT NULL,\n12\t  match_id        TEXT         NOT NULL,\n13\t  amount_lamports BIGINT       NOT NULL CHECK (amount_lamports > 0),\n14\t  side            TEXT,\n15\t  is_winner       BOOLEAN,\n16\t  payout_lamports BIGINT       NOT NULL DEFAULT 0,\n17\t  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n18\t  settled_at      TIMESTAMPTZ,\n19\t  UNIQUE (wallet, round_pda)\n20\t);\n21\t\n22\tCREATE INDEX idx_game_entries_settled ON game_entries (settled_at DESC) WHERE settled_at IS NOT NULL;\n23\tCREATE INDEX idx_game_entries_game_settled ON game_entries (game, settled_at DESC) WHERE settled_at IS NOT NULL;\n24\tCREATE INDEX idx_game_entries_user_settled ON game_entries (user_id, settled_at DESC);\n25\tCREATE INDEX idx_game_entries_round_pda ON game_entries (round_pda);\n26\t"}]},"parent_tool_use_id":null,"session_id":"a037f20c-2fad-4bfb-9c41-68dddd9e3cd0","uuid":"0fc4f6f1-c357-411f-919f-f2a2210a1dcc","timestamp":"2026-04-25T12:15:58.964Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/migrations/007_game_entries.sql","content":"-- 007_game_entries.sql — Single source of truth for participation + stats + leaderboard.\n--\n-- Written at participation time (create/bet), updated at settlement via UPSERT.\n-- Refunded entries: is_winner = NULL, payout_lamports = amount_lamports.\n\nCREATE TABLE game_entries (\n  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  user_id         TEXT         NOT NULL,\n  wallet          TEXT         NOT NULL,\n  game            TEXT         NOT NULL CHECK (game IN ('flipyou', 'potshot', 'closecall')),\n  round_pda       TEXT         NOT NULL,\n  match_id        TEXT         NOT NULL,\n  amount_lamports BIGINT       NOT NULL CHECK (amount_lamports > 0),\n  side            TEXT,\n  is_winner       BOOLEAN,\n  payout_lamports BIGINT       NOT NULL DEFAULT 0,\n  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n  settled_at      TIMESTAMPTZ,\n  UNIQUE (wallet, round_pda)\n);\n\nCREATE INDEX idx_game_entries_settled ON game_entries (settled_at DESC) WHERE settled_at IS NOT NULL;\nCREATE INDEX idx_game_entries_game_settled ON game_entries (game, settled_at DESC) WHERE settled_at IS NOT NULL;\nCREATE INDEX idx_game_entries_user_settled ON game_entries (user_id, settled_at DESC);\nCREATE INDEX idx_game_entries_round_pda ON game_entries (round_pda);\n","numLines":26,"startLine":1,"totalLines":26}}}
