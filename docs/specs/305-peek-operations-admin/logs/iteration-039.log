{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014RrN7eoZudLuKM8xx126sT","type":"tool_result","content":"1\t// Command-center attention queue query (FR-3, FR-10).\n2\t//\n3\t// Returns a small set of bounded \"needs attention\" metrics that the command\n4\t// center renders at the top of `/`. Each metric carries the FR-4 bookkeeping\n5\t// (id, label, value, source table, time window, \"as of\", definition,\n6\t// freshness, drill-down href) so the metric-strip primitive can render it\n7\t// without per-page hardcoding.\n8\t//\n9\t// Bounded queries: every query returns a single integer count. No row-level\n10\t// data crosses the wire here; per-feature pages provide the row drill-downs.\n11\t\n12\timport type {\n13\t  PeekCommandCenterAttention,\n14\t  PeekCommandCenterAttentionId,\n15\t  PeekMetric,\n16\t} from \"../../../lib/types/peek\";\n17\timport type { Sql } from \"postgres\";\n18\timport { getSqlClient } from \"../client\";\n19\t\n20\t// Thresholds — tuned for an operator console, not a fairness oracle. Tests can\n21\t// override via the `options` argument so age/limit assertions stay\n22\t// deterministic.\n23\texport type CommandCenterThresholds = {\n24\t  stuckRoundsAgeMinutes: number;\n25\t  stuckRoundsMaxSettleAttempts: number;\n26\t  stuckCloseCallAgeMinutes: number;\n27\t  exportWindowHours: number;\n28\t  exportRowCountThreshold: number;\n29\t};\n30\t\n31\texport const COMMAND_CENTER_DEFAULTS: CommandCenterThresholds = {\n32\t  stuckRoundsAgeMinutes: 5,\n33\t  stuckRoundsMaxSettleAttempts: 3,\n34\t  stuckCloseCallAgeMinutes: 5,\n35\t  exportWindowHours: 24,\n36\t  exportRowCountThreshold: 1000,\n37\t};\n38\t\n39\texport type CommandCenterOptions = {\n40\t  sql?: Sql;\n41\t  thresholds?: Partial<CommandCenterThresholds>;\n42\t  now?: Date;\n43\t};\n44\t\n45\ttype AttentionRow = { value: number };\n46\t\n47\tfunction readCount(rows: ReadonlyArray<AttentionRow> | undefined): number {\n48\t  if (!rows || rows.length === 0) {\n49\t    return 0;\n50\t  }\n51\t  const raw = rows[0]?.value;\n52\t  if (typeof raw === \"number\" && Number.isFinite(raw)) {\n53\t    return raw;\n54\t  }\n55\t  if (typeof raw === \"string\") {\n56\t    const parsed = Number.parseInt(raw, 10);\n57\t    return Number.isFinite(parsed) ? parsed : 0;\n58\t  }\n59\t  return 0;\n60\t}"}]},"parent_tool_use_id":null,"session_id":"6d08dc30-d2d5-4518-bdcf-d62720202bde","uuid":"83470a59-3b68-4ac3-a0c1-d9cf52fd993f","timestamp":"2026-04-25T13:51:39.330Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-command-center-attention.ts","content":"// Command-center attention queue query (FR-3, FR-10).\n//\n// Returns a small set of bounded \"needs attention\" metrics that the command\n// center renders at the top of `/`. Each metric carries the FR-4 bookkeeping\n// (id, label, value, source table, time window, \"as of\", definition,\n// freshness, drill-down href) so the metric-strip primitive can render it\n// without per-page hardcoding.\n//\n// Bounded queries: every query returns a single integer count. No row-level\n// data crosses the wire here; per-feature pages provide the row drill-downs.\n\nimport type {\n  PeekCommandCenterAttention,\n  PeekCommandCenterAttentionId,\n  PeekMetric,\n} from \"../../../lib/types/peek\";\nimport type { Sql } from \"postgres\";\nimport { getSqlClient } from \"../client\";\n\n// Thresholds — tuned for an operator console, not a fairness oracle. Tests can\n// override via the `options` argument so age/limit assertions stay\n// deterministic.\nexport type CommandCenterThresholds = {\n  stuckRoundsAgeMinutes: number;\n  stuckRoundsMaxSettleAttempts: number;\n  stuckCloseCallAgeMinutes: number;\n  exportWindowHours: number;\n  exportRowCountThreshold: number;\n};\n\nexport const COMMAND_CENTER_DEFAULTS: CommandCenterThresholds = {\n  stuckRoundsAgeMinutes: 5,\n  stuckRoundsMaxSettleAttempts: 3,\n  stuckCloseCallAgeMinutes: 5,\n  exportWindowHours: 24,\n  exportRowCountThreshold: 1000,\n};\n\nexport type CommandCenterOptions = {\n  sql?: Sql;\n  thresholds?: Partial<CommandCenterThresholds>;\n  now?: Date;\n};\n\ntype AttentionRow = { value: number };\n\nfunction readCount(rows: ReadonlyArray<AttentionRow> | undefined): number {\n  if (!rows || rows.length === 0) {\n    return 0;\n  }\n  const raw = rows[0]?.value;\n  if (typeof raw === \"number\" && Number.isFinite(raw)) {\n    return raw;\n  }\n  if (typeof raw === \"string\") {\n    const parsed = Number.parseInt(raw, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}","numLines":60,"startLine":1,"totalLines":272}}}
