{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015Pqtaoa7pc1ht7fyuUkPWR","type":"tool_result","content":"40\t  const app = new Hono();\n41\t\n42\t  // Admin auth middleware — all routes in this sub-router require X-Admin-Key\n43\t  app.use(\"*\", async (c, next) => {\n44\t    const key = c.req.header(\"X-Admin-Key\");\n45\t    if (!key || key !== adminApiKey) {\n46\t      return c.json({ error: \"UNAUTHORIZED\" }, 401);\n47\t    }\n48\t    await next();\n49\t  });\n50\t\n51\t  // GET /reward-config — all config key-value pairs\n52\t  app.get(\"/reward-config\", async (c) => {\n53\t    const rows = await db.rawSql<{ key: string; value: string; updated_at: string }[]>`\n54\t      SELECT key, value, updated_at FROM reward_config ORDER BY key ASC\n55\t    `;\n56\t    const config: Record<string, { value: string; updatedAt: string }> = {};\n57\t    for (const row of rows) {\n58\t      config[row.key] = { value: row.value, updatedAt: row.updated_at };\n59\t    }\n60\t    return c.json(config);\n61\t  });\n62\t\n63\t  // PUT /reward-config/:key — update a single config value\n64\t  app.put(\"/reward-config/:key\", async (c) => {\n65\t    const key = c.req.param(\"key\");\n66\t\n67\t    if (!VALID_CONFIG_KEYS.has(key)) {\n68\t      return c.json({ error: \"INVALID_KEY\", message: `Unknown config key: ${key}` }, 400);\n69\t    }\n70\t\n71\t    const body = await c.req.json<{ value?: string }>();\n72\t    if (body.value === undefined || body.value === null) {\n73\t      return c.json({ error: \"MISSING_VALUE\", message: \"Request body must include 'value'\" }, 400);\n74\t    }\n75\t\n76\t    await db.rawSql`\n77\t      UPDATE reward_config\n78\t      SET value = ${String(body.value)}, updated_at = now()\n79\t      WHERE key = ${key}\n80\t    `;\n81\t\n82\t    return c.json({ key, value: String(body.value) });\n83\t  });\n84\t\n85\t  // GET /reward-pool — current pool state\n86\t  app.get(\"/reward-pool\", async (c) => {\n87\t    const rows = await db