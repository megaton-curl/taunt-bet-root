{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vr3dCRV7sdf1GXD2U4T6WB","type":"tool_result","content":"1\t-- 011_challenge_engine.sql — Challenge engine, reward system, and loot crate tables + seed data.\n2\t\n3\t-- Operator-tunable reward/economy parameters\n4\tCREATE TABLE reward_config (\n5\t  key         TEXT PRIMARY KEY,\n6\t  value       TEXT NOT NULL,\n7\t  updated_at  TIMESTAMPTZ NOT NULL DEFAULT now()\n8\t);\n9\t\n10\t-- Player point balances and lifetime stats\n11\tCREATE TABLE player_points (\n12\t  user_id             TEXT PRIMARY KEY,\n13\t  wallet              TEXT NOT NULL UNIQUE,\n14\t  balance             BIGINT NOT NULL DEFAULT 0,\n15\t  lifetime_earned     BIGINT NOT NULL DEFAULT 0,\n16\t  updated_at          TIMESTAMPTZ NOT NULL DEFAULT now()\n17\t);\n18\t\n19\t-- Immutable point grant ledger (source of truth for history + idempotency)\n20\tCREATE TABLE point_grants (\n21\t  id                  BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n22\t  user_id             TEXT NOT NULL,\n23\t  wallet              TEXT NOT NULL,\n24\t  source_type         TEXT NOT NULL CHECK (source_type IN ('wager', 'challenge_completed', 'bonus_completed', 'crate_points')),\n25\t  source_id           TEXT NOT NULL,\n26\t  amount              BIGINT NOT NULL,\n27\t  metadata            JSONB NOT NULL DEFAULT '{}',\n28\t  created_at          TIMESTAMPTZ NOT NULL DEFAULT now(),\n29\t  UNIQUE (user_id, source_type, source_id)\n30\t);\n31\t\n32\tCREATE INDEX idx_point_grants_user_created ON point_grants (user_id, created_at DESC);\n33\t\n34\t-- Reward pool accounting (single row, updated atomically)\n35\tCREATE TABLE reward_pool (\n36\t  id                  INT PRIMARY KEY DEFAULT 1 CHECK (id = 1),\n37\t  balance_lamports    BIGINT NOT NULL DEFAULT 0,\n38\t  lifetime_funded     BIGINT NOT NULL DEFAULT 0,\n39\t  lifetime_paid       BIGINT NOT NULL DEFAULT 0,\n40\t  updated_at          TIMESTAMPTZ NOT NULL DEFAULT now()\n41\t);\n42\t\n43\t-- Append-only pool funding ledger for idempotent reward_pool_fund handling\n44\tCREATE TABLE reward_pool_fundings (\n45\t  id                  BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n46\t  round_id            TEXT NOT NULL UNIQUE,\n47\t  fee_lamports        BIGINT NOT NULL,\n48\t  funded_lamports     BIGINT NOT NULL,\n49\t  created_at          TIMESTAMPTZ NOT NULL DEFAULT now()\n50\t);\n51\t\n52\t-- Campaign container (Daily, Weekly, Onboarding, Dogpile)\n53\tCREATE TABLE campaigns (\n54\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n55\t  name            TEXT NOT NULL UNIQUE,\n56\t  campaign_type   TEXT NOT NULL CHECK (campaign_type IN ('daily', 'weekly', 'onboarding', 'dogpile')),\n57\t  starts_at       TIMESTAMPTZ,\n58\t  ends_at         TIMESTAMPTZ,\n59\t  is_active       BOOLEAN NOT NULL DEFAULT true,\n60\t  config          JSONB NOT NULL DEFAULT '{}',\n61\t  created_at      TIMESTAMPTZ NOT NULL DEFAULT now()\n62\t);\n63\t\n64\t-- Challenge template definitions (data, not code)\n65\tCREATE TABLE challenges (\n66\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n67\t  campaign_id     BIGINT NOT NULL REFERENCES campaigns(id),\n68\t  title           TEXT NOT NULL,\n69\t  description     TEXT,\n70\t  action          TEXT NOT NULL,\n71\t  scope           TEXT NOT NULL DEFAULT 'any' CHECK (scope IN ('any', 'flipyou', 'potshot', 'closecall')),\n72\t  condition       TEXT NOT NULL DEFAULT 'count',\n73\t  threshold       INT NOT NULL,\n74\t  reward_type     TEXT NOT NULL CHECK (reward_type IN ('points', 'crate')),\n75\t  reward_amount   INT,\n76\t  prerequisite_id BIGINT REFERENCES challenges(id),\n77\t  eligible_if     JSONB NOT NULL DEFAULT '{}',\n78\t  sort_order      INT NOT NULL DEFAULT 0,\n79\t  is_active       BOOLEAN NOT NULL DEFAULT true,\n80\t  created_at      TIMESTAMPTZ NOT NULL DEFAULT now()\n81\t);\n82\t\n83\t-- Per-player challenge assignments for a specific period\n84\tCREATE TABLE challenge_assignments (\n85\t  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n86\t  user_id         TEXT NOT NULL,\n87\t  challenge_id    BIGINT NOT NULL REFERENCES challenges(id),\n88\t  period_key      TEXT NOT NULL,\n89\t  status          TEXT NOT NULL DEFAULT 'active' CHECK (status IN ('active', 'completed', 'expired')),\n90\t  progress        INT NOT NULL DEFAULT 0,\n91\t  target          INT NOT NULL,\n92\t  assigned_at     TIMESTAMPTZ NOT NULL DEFAULT now(),\n93\t  expires_at      TIMESTAMPTZ,\n94\t  completed_at    TIMESTAMPTZ,\n95\t  UNIQUE (user_id, challenge_id, period_key)\n96\t);\n97\t\n98\tCREATE INDEX idx_assignments_active ON challenge_assignments (user_id, status) WHERE status = 'active';\n99\tCREATE INDEX idx_assignments_period ON challenge_assignments (period_key, status);\n100\t"}]},"parent_tool_use_id":null,"session_id":"6d08dc30-d2d5-4518-bdcf-d62720202bde","uuid":"31943023-b8e7-4d26-92bf-b76bf34ebee4","timestamp":"2026-04-25T13:50:37.323Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/migrations/011_challenge_engine.sql","content":"-- 011_challenge_engine.sql — Challenge engine, reward system, and loot crate tables + seed data.\n\n-- Operator-tunable reward/economy parameters\nCREATE TABLE reward_config (\n  key         TEXT PRIMARY KEY,\n  value       TEXT NOT NULL,\n  updated_at  TIMESTAMPTZ NOT NULL DEFAULT now()\n);\n\n-- Player point balances and lifetime stats\nCREATE TABLE player_points (\n  user_id             TEXT PRIMARY KEY,\n  wallet              TEXT NOT NULL UNIQUE,\n  balance             BIGINT NOT NULL DEFAULT 0,\n  lifetime_earned     BIGINT NOT NULL DEFAULT 0,\n  updated_at          TIMESTAMPTZ NOT NULL DEFAULT now()\n);\n\n-- Immutable point grant ledger (source of truth for history + idempotency)\nCREATE TABLE point_grants (\n  id                  BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  user_id             TEXT NOT NULL,\n  wallet              TEXT NOT NULL,\n  source_type         TEXT NOT NULL CHECK (source_type IN ('wager', 'challenge_completed', 'bonus_completed', 'crate_points')),\n  source_id           TEXT NOT NULL,\n  amount              BIGINT NOT NULL,\n  metadata            JSONB NOT NULL DEFAULT '{}',\n  created_at          TIMESTAMPTZ NOT NULL DEFAULT now(),\n  UNIQUE (user_id, source_type, source_id)\n);\n\nCREATE INDEX idx_point_grants_user_created ON point_grants (user_id, created_at DESC);\n\n-- Reward pool accounting (single row, updated atomically)\nCREATE TABLE reward_pool (\n  id                  INT PRIMARY KEY DEFAULT 1 CHECK (id = 1),\n  balance_lamports    BIGINT NOT NULL DEFAULT 0,\n  lifetime_funded     BIGINT NOT NULL DEFAULT 0,\n  lifetime_paid       BIGINT NOT NULL DEFAULT 0,\n  updated_at          TIMESTAMPTZ NOT NULL DEFAULT now()\n);\n\n-- Append-only pool funding ledger for idempotent reward_pool_fund handling\nCREATE TABLE reward_pool_fundings (\n  id                  BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  round_id            TEXT NOT NULL UNIQUE,\n  fee_lamports        BIGINT NOT NULL,\n  funded_lamports     BIGINT NOT NULL,\n  created_at          TIMESTAMPTZ NOT NULL DEFAULT now()\n);\n\n-- Campaign container (Daily, Weekly, Onboarding, Dogpile)\nCREATE TABLE campaigns (\n  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  name            TEXT NOT NULL UNIQUE,\n  campaign_type   TEXT NOT NULL CHECK (campaign_type IN ('daily', 'weekly', 'onboarding', 'dogpile')),\n  starts_at       TIMESTAMPTZ,\n  ends_at         TIMESTAMPTZ,\n  is_active       BOOLEAN NOT NULL DEFAULT true,\n  config          JSONB NOT NULL DEFAULT '{}',\n  created_at      TIMESTAMPTZ NOT NULL DEFAULT now()\n);\n\n-- Challenge template definitions (data, not code)\nCREATE TABLE challenges (\n  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  campaign_id     BIGINT NOT NULL REFERENCES campaigns(id),\n  title           TEXT NOT NULL,\n  description     TEXT,\n  action          TEXT NOT NULL,\n  scope           TEXT NOT NULL DEFAULT 'any' CHECK (scope IN ('any', 'flipyou', 'potshot', 'closecall')),\n  condition       TEXT NOT NULL DEFAULT 'count',\n  threshold       INT NOT NULL,\n  reward_type     TEXT NOT NULL CHECK (reward_type IN ('points', 'crate')),\n  reward_amount   INT,\n  prerequisite_id BIGINT REFERENCES challenges(id),\n  eligible_if     JSONB NOT NULL DEFAULT '{}',\n  sort_order      INT NOT NULL DEFAULT 0,\n  is_active       BOOLEAN NOT NULL DEFAULT true,\n  created_at      TIMESTAMPTZ NOT NULL DEFAULT now()\n);\n\n-- Per-player challenge assignments for a specific period\nCREATE TABLE challenge_assignments (\n  id              BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  user_id         TEXT NOT NULL,\n  challenge_id    BIGINT NOT NULL REFERENCES challenges(id),\n  period_key      TEXT NOT NULL,\n  status          TEXT NOT NULL DEFAULT 'active' CHECK (status IN ('active', 'completed', 'expired')),\n  progress        INT NOT NULL DEFAULT 0,\n  target          INT NOT NULL,\n  assigned_at     TIMESTAMPTZ NOT NULL DEFAULT now(),\n  expires_at      TIMESTAMPTZ,\n  completed_at    TIMESTAMPTZ,\n  UNIQUE (user_id, challenge_id, period_key)\n);\n\nCREATE INDEX idx_assignments_active ON challenge_assignments (user_id, status) WHERE status = 'active';\nCREATE INDEX idx_assignments_period ON challenge_assignments (period_key, status);\n","numLines":100,"startLine":1,"totalLines":239}}}
