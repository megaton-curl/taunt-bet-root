{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PMUq5mdeLuxFL5EopjEHT1","type":"tool_result","content":"600\t  wallet: string;\n601\t  rateBps: number;\n602\t  setBy: string;\n603\t  createdAt: string;\n604\t  updatedAt: string;\n605\t  refereeCount: number;\n606\t  referredWagerLamports: string;\n607\t  referrerEarnedLamports: string;\n608\t};\n609\t\n610\t// Status filter values mirror the migration check constraint:\n611\t// 'pending' | 'processing' | 'error' | 'completed' | 'failed'. Treated as a\n612\t// loose `string` here so the UI can pass through a \"failed_or_error\" virtual\n613\t// alias without a contract change. Extends the per-user\n614\t// `PeekReferralClaimRow` with the `userId`/`username`/`wallet` columns the\n615\t// /growth/referrals claims table needs to render and link rows back to user\n616\t// detail.\n617\texport type PeekGrowthClaimRow = PeekReferralClaimRow & {\n618\t  userId: string;\n619\t  username: string | null;\n620\t  wallet: string;\n621\t};\n622\t\n623\texport type PeekReferralClaimFilters = {\n624\t  status: string | null;\n625\t  userId: string | null;\n626\t  minAmountLamports: string | null;\n627\t  maxAmountLamports: string | null;\n628\t  requestedFrom: string | null;\n629\t  requestedTo: string | null;\n630\t  txSignature: string | null;\n631\t  errorContains: string | null;\n632\t};\n633\t\n634\texport type PeekReferralGraphRefereeRow = {\n635\t  refereeUserId: string;\n636\t  refereeUsername: string | null;\n637\t  refereeWallet: string;\n638\t  createdAt: string;\n639\t};\n640\t\n641\texport type PeekReferralGraphInboundReferrer = {\n642\t  referrerUserId: string | null;\n643\t  referrerUsername: string | null;\n644\t  referrerWallet: string | null;\n645\t  referrerCode: string | null;\n646\t  linkedAt: string | null;\n647\t};\n648\t\n649\texport type PeekReferralGraphNode = {\n650\t  userId: string;\n651\t  username: string | null;\n652\t  wallet: string;\n653\t  referralCode: string | null;\n654\t  inboundReferrer: PeekReferralGraphInboundReferrer;\n655\t  outboundReferees: ReadonlyArray<PeekReferralGraphRefereeRow>;\n656\t};\n657\t\n658\t// --- Games overview (FR-8) ---------------------------------------------------\n659\t//\n660\t// Browser-safe view models for `/games`. The engine query reads the single\n661\t// source of truth `game_entries` (migration 007) and produces (a) a small set\n662\t// of platform-wide FR-4 metrics for the overview strip and (b) per-game rows\n663\t// with the operational counters the spec calls out: entries, unique users,\n664\t// wagered lamports, settled entries, refund entries, payout lamports, wins,\n665\t// losses. Lamport sums round-trip as `text` to preserve u64 precision; the UI\n666\t// formats at render time.\n667\t//\n668\t// `PeekGameId` mirrors the migration's CHECK constraint on `game_entries.game`\n669\t// (`'flipyou' | 'potshot' | 'closecall'`). Deferred games (Crash, Game of\n670\t// Trades, Chart the Course, Slots Utopia, Tug of Earn) are documented\n671\t// placeholders rendered by the page; they intentionally are not part of the\n672\t// data shape because they have no persisted source yet (system invariant 13).\n673\t\n674\texport type PeekGameId = \"flipyou\" | \"potshot\" | \"closecall\";\n675\t\n676\texport const PEEK_GAME_IDS: ReadonlyArray<PeekGameId> = [\n677\t  \"flipyou\",\n678\t  \"potshot\",\n679\t  \"closecall\",\n680\t];\n681\t\n682\texport type PeekGameOverviewRow = {\n683\t  game: PeekGameId;\n684\t  entries: number;\n685\t  uniqueUsers: number;\n686\t  wageredLamports: string;\n687\t  settledEntries: number;\n688\t  refundEntries: number;\n689\t  payoutLamports: string;\n690\t  wins: number;\n691\t  losses: number;\n692\t};\n693\t\n694\texport type PeekGameOverviewMetricId =\n695\t  | \"games.total_entries\"\n696\t  | \"games.unique_users\"\n697\t  | \"games.wagered_lamports\"\n698\t  | \"games.settled_entries\"\n699\t  | \"games.refund_entries\""}]},"parent_tool_use_id":null,"session_i