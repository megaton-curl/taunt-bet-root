{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_011YM3Dt8WR8qFX1qJ45UaJm","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01UMN3ScTTp2Tw6RoqaHmHAg","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","old_string":"export type PeekRoundDetail =\n  | {\n      game: PeekRoundsGameId;\n      round: PeekRoundRow;\n      entries: ReadonlyArray<PeekRoundEntryRow>;\n      transactions: ReadonlyArray<PeekRoundTransactionRow>;\n    }\n  | {\n      game: \"closecall\";\n      round: PeekCloseCallRoundRow;\n      entries: ReadonlyArray<PeekRoundEntryRow>;\n      transactions: ReadonlyArray<PeekRoundTransactionRow>;\n    };","new_string":"export type PeekRoundDetail =\n  | {\n      game: PeekRoundsGameId;\n      round: PeekRoundRow;\n      entries: ReadonlyArray<PeekRoundEntryRow>;\n      transactions: ReadonlyArray<PeekRoundTransactionRow>;\n    }\n  | {\n      game: \"closecall\";\n      round: PeekCloseCallRoundRow;\n      entries: ReadonlyArray<PeekRoundEntryRow>;\n      transactions: ReadonlyArray<PeekRoundTransactionRow>;\n    };\n\n// --- Economy: rewards (FR-9) -------------------------------------------------\n//\n// Browser-safe view models for `/economy/rewards`. Reads three migration-011\n// tables:\n//\n//   - reward_config           — operator-tunable economy parameters; each row\n//     is annotated server-side with a human-readable definition and an\n//     expected-value type from a static registry so the page can show what a\n//     key means without an extra docs lookup.\n//   - reward_pool             — singleton accounting row (balance, lifetime\n//     funded, lifetime paid, updated_at).\n//   - reward_pool_fundings    — append-only ledger of per-round funding events\n//     keyed on round_id (the source round whose fee fed the pool).\n//\n// Lamport / u64 values round-trip as `text` to preserve precision (FR-4).\n// Unknown reward_config keys still surface (with `definition: null` and\n// `expectedType: \"unknown\"`) so an operator immediately notices when a new\n// key has been seeded but the registry has not been updated.\n\nexport type PeekRewardConfigExpectedType =\n  | \"integer\"\n  | \"float\"\n  | \"ratio\"\n  | \"lamports\"\n  | \"unknown\";\n\nexport type PeekRewardConfigRow = {\n  key: string;\n  value: string;\n  updatedAt: string;\n  definition: string | null;\n  expectedType: PeekRewardConfigExpectedType;\n};\n\nexport type PeekRewardPool = {\n  balanceLamports: string;\n  lifetimeFunded: string;\n  lifetimePaid: string;\n  updatedAt: string;\n};\n\nexport type PeekRewardPoolFundingRow = {\n  id: string;\n  roundId: string;\n  feeLamports: string;\n  fundedLamports: string;\n  createdAt: string;\n};\n\nexport type PeekRewardsOverviewMetricId =\n  | \"rewards.balance_lamports\"\n  | \"rewards.lifetime_funded_lamports\"\n  | \"rewards.lifetime_paid_lamports\"\n  | \"rewards.recent_fundings\";\n\nexport const PEEK_REWARDS_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekRewardsOverviewMetricId> =\n  [\n    \"rewards.balance_lamports\",\n    \"rewards.lifetime_funded_lamports\",\n    \"rewards.lifetime_paid_lamports\",\n    \"rewards.recent_fundings\",\n  ];\n\nexport type PeekRewardsOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":677,"cache_read_input_tokens":111233,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":677},"output_tokens":65,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"6d08dc30-d2d5-4518-bdcf-d62720202bde","uuid":"ab02862f-8c34-4892-982f-7dd5f418d98c"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UMN3ScTTp2Tw6RoqaHmHAg","type":"tool_result","content":"The file /workspaces/rng-utopia/peek/src/lib/types/peek.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"6d08dc30-d2d5-4518-bdcf-d62720202bde","uuid":"359eead8-2a87-44ad-b09c-636a59c49722","timestamp":"2026-04-25T13:53:12.134Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","oldString":"export type PeekRoundDetail =\n  | {\n      game: PeekRoundsGameId;\n      round: PeekRoundRow;\n      entries: ReadonlyArray<PeekRoundEntryRow>;\n      transactions: ReadonlyArray<PeekRoundTransactionRow>;\n    }\n  | {\n      game: \"closecall\";\n      round: PeekCloseCallRoundRow;\n      entries: ReadonlyArray<PeekRoundEntryRow>;\n      transactions: ReadonlyArray<PeekRoundTransactionRow>;\n    };","newString":"export type PeekRoundDetail =\n  | {\n      game: PeekRoundsGameId;\n      round: PeekRoundRow;\n      entries: ReadonlyArray<PeekRoundEntryRow>;\n      transactions: ReadonlyArray<PeekRoundTransactionRow>;\n    }\n  | {\n      game: \"closecall\";\n      round: PeekCloseCallRoundRow;\n      entries: ReadonlyArray<PeekRoundEntryRow>;\n      transactions: ReadonlyArray<PeekRoundTransactionRow>;\n    };\n\n// --- Economy: rewards (FR-9) -------------------------------------------------\n//\n// Browser-safe view models for `/economy/rewards`. Reads three migration-011\n// tables:\n//\n//   - reward_config           — operator-tunable economy parameters; each row\n//     is annotated server-side with a human-readable definition and an\n//     expected-value type from a static registry so the page can show what a\n//     key means without an extra docs lookup.\n//   - reward_pool             — singleton accounting row (balance, lifetime\n//     funded, lifetime paid, updated_at).\n//   - reward_pool_fundings    — append-only ledger of per-round funding events\n//     keyed on round_id (the source round whose fee fed the pool).\n//\n// Lamport / u64 values round-trip as `text` to preserve precision (FR-4).\n// Unknown reward_config keys still surface (with `definition: null` and\n// `expectedType: \"unknown\"`) so an operator immediately notices when a new\n// key has been seeded but the registry has not been updated.\n\nexport type PeekRewardConfigExpectedType =\n  | \"integer\"\n  | \"float\"\n  | \"ratio\"\n  | \"lamports\"\n  | \"unknown\";\n\nexport type PeekRewardConfigRow = {\n  key: string;\n  value: string;\n  updatedAt: string;\n  definition: string | null;\n  expectedType: PeekRewardConfigExpectedType;\n};\n\nexport type PeekRewardPool = {\n  balanceLamports: string;\n  lifetimeFunded: string;\n  lifetimePaid: string;\n  updatedAt: string;\n};\n\nexport type PeekRewardPoolFundingRow = {\n  id: string;\n  roundId: string;\n  feeLamports: string;\n  fundedLamports: string;\n  createdAt: string;\n};\n\nexport type PeekRewardsOverviewMetricId =\n  | \"rewards.balance_lamports\"\n  | \"rewards.lifetime_funded_lamports\"\n  | \"rewards.lifetime_paid_lamports\"\n  | \"rewards.recent_fundings\";\n\nexport const PEEK_REWARDS_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekRewardsOverviewMetricId> =\n  [\n    \"rewards.balance_lamports\",\n    \"rewards.lifetime_funded_lamports\",\n    \"rewards.lifetime_paid_lamports\",\n    \"rewards.recent_fundings\",\n  ];\n\nexport type PeekRewardsOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};","originalFile":"// Browser-safe view-model primitives for `peek`.\n//\n// Foundational shapes used across feature pages: metric metadata (FR-4),\n// URL-addressable table filters, pagination, sort, and a small table-row base\n// type that per-feature row types can extend. Per-feature shapes (PeekUserRow,\n// PeekUserDetail, future referral/game/queue/etc. rows) live alongside or\n// extend these primitives.\n\nimport type { PeekRole } from \"../access-policy\";\n\n// --- Existing 303-era shapes (kept stable for current callers) ---------------\n\nexport type PeekSummary = {\n  totalUsers: number;\n  totalUsersWithCodes: number;\n  totalReferredUsers: number;\n  totalUniqueReferrers: number;\n};\n\nexport type PeekUserRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  joinedAt: string;\n  referralCode: string | null;\n  referrerUserId: string | null;\n  referrerCode: string | null;\n  refereeCount: number;\n  telegramUsername: string | null;\n  telegramUserId: string | null;\n};\n\n// --- Expanded user-detail shapes (FR-6) --------------------------------------\n//\n// Per-section row types for the full support/audit user profile. Lamports and\n// numeric/precision-sensitive values arrive as `text` to preserve precision; the\n// UI re-formats at render time. All shapes are browser-safe (no server imports).\n\nexport type PeekLinkedAccountRow = {\n  id: string;\n  provider: string;\n  providerAccountId: string;\n  status: string;\n  telegramUsername: string | null;\n  metadataJson: Record<string, unknown> | null;\n  linkedAt: string;\n  updatedAt: string;\n};\n\nexport type PeekTelegramLinkTokenRow = {\n  id: string;\n  status: string;\n  telegramUserId: string | null;\n  telegramUsername: string | null;\n  expiresAt: string;\n  redeemedAt: string | null;\n  createdAt: string;\n};\n\nexport type PeekKolRate = {\n  rateBps: number;\n  setBy: string;\n  createdAt: string;\n  updatedAt: string;\n};\n\nexport type PeekReferralEarningsSummary = {\n  earningsCount: number;\n  totalReferrerEarnedLamports: string;\n  totalRefereeRebateLamports: string;\n  lastEarnedAt: string | null;\n};\n\nexport type PeekReferralClaimRow = {\n  id: string;\n  amountLamports: string;\n  status: string;\n  retryCount: number;\n  txSignature: string | null;\n  error: string | null;\n  requestedAt: string;\n  processedAt: string | null;\n};\n\nexport type PeekPointGrantRow = {\n  id: string;\n  sourceType: string;\n  sourceId: string;\n  amount: string;\n  createdAt: string;\n};\n\nexport type PeekPlayerPoints = {\n  balance: string;\n  lifetimeEarned: string;\n  updatedAt: string | null;\n};\n\nexport type PeekCrateDropRow = {\n  id: string;\n  triggerType: string;\n  triggerId: string;\n  crateType: string;\n  contentsAmount: string;\n  status: string;\n  createdAt: string;\n  grantedAt: string | null;\n};\n\nexport type PeekChallengeAssignmentSummary = {\n  active: number;\n  completed: number;\n  expired: number;\n  total: number;\n};\n\nexport type PeekGameEntryRow = {\n  id: string;\n  game: string;\n  roundPda: string;\n  matchId: string;\n  amountLamports: string;\n  side: string | null;\n  isWinner: boolean | null;\n  payoutLamports: string;\n  createdAt: string;\n  settledAt: string | null;\n};\n\nexport type PeekTransactionRow = {\n  id: string;\n  game: string;\n  matchId: string;\n  txType: string;\n  amountLamports: string;\n  txSig: string;\n  createdAt: string;\n};\n\nexport type PeekFraudFlagRow = {\n  id: string;\n  flagType: string;\n  status: string;\n  relatedId: string | null;\n  createdAt: string;\n  resolvedAt: string | null;\n};\n\nexport type PeekUserQueueEventRow = {\n  id: string;\n  eventType: string;\n  status: string;\n  attempts: number;\n  maxAttempts: number;\n  scheduledAt: string;\n  createdAt: string;\n  error: string | null;\n};\n\nexport type PeekUserAttentionFlags = {\n  failedClaim: boolean;\n  deadQueueEvent: boolean;\n  activeFraudFlag: boolean;\n  pendingSolCratePayout: boolean;\n  suspiciousReferralLoop: boolean;\n};\n\nexport type PeekUserDetailUser = PeekUserRow & {\n  avatarUrl: string | null;\n  heatMultiplier: string;\n  profilePointsBalance: string;\n};\n\nexport type PeekUserDetail = {\n  user: PeekUserDetailUser;\n  inboundReferral: {\n    referrerUserId: string | null;\n    referrerCode: string | null;\n    linkedAt: string | null;\n  };\n  outboundReferees: Array<{\n    refereeUserId: string;\n    refereeUsername: string | null;\n    createdAt: string;\n  }>;\n  telegram: {\n    state: \"active\" | \"none\";\n    telegramUserId: string | null;\n    telegramUsername: string | null;\n  };\n  linkedAccounts: ReadonlyArray<PeekLinkedAccountRow>;\n  recentTelegramLinkTokens: ReadonlyArray<PeekTelegramLinkTokenRow>;\n  kolRate: PeekKolRate | null;\n  referralEarnings: PeekReferralEarningsSummary;\n  recentReferralClaims: ReadonlyArray<PeekReferralClaimRow>;\n  points: PeekPlayerPoints;\n  recentPointGrants: ReadonlyArray<PeekPointGrantRow>;\n  recentCrateDrops: ReadonlyArray<PeekCrateDropRow>;\n  challengeSummary: PeekChallengeAssignmentSummary;\n  recentGameEntries: ReadonlyArray<PeekGameEntryRow>;\n  recentTransactions: ReadonlyArray<PeekTransactionRow>;\n  fraudFlags: ReadonlyArray<PeekFraudFlagRow>;\n  recentUserQueueEvents: ReadonlyArray<PeekUserQueueEventRow>;\n  attention: PeekUserAttentionFlags;\n};\n\n// --- Actor view model (browser-safe) -----------------------------------------\n\nexport type PeekActorView = {\n  email: string;\n  role: PeekRole;\n};\n\n// --- Metric metadata (FR-4) --------------------------------------------------\n//\n// Each metric carries the bookkeeping required by the data-surfacing standard:\n// stable id, label, value, source table/query, time window, \"as of\" timestamp,\n// short definition, optional unit, and optional drill-down link to the filtered\n// detail rows behind the number.\n\nexport type PeekMetricFreshness = \"live\" | \"cached\" | \"manual\" | \"sampled\";\n\nexport type PeekMetric = {\n  id: string;\n  label: string;\n  value: number | string | null;\n  valueDisplay: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  asOf: string | null;\n  definition: string;\n  freshness: PeekMetricFreshness;\n  drilldownHref: string | null;\n};\n\n// --- Pagination primitive ----------------------------------------------------\n\nexport type PeekPagination = {\n  page: number;\n  pageSize: number;\n  totalCount: number;\n  totalPages: number;\n};\n\n// --- Sort primitive ----------------------------------------------------------\n\nexport type PeekSortDirection = \"asc\" | \"desc\";\n\nexport type PeekTableSort = {\n  column: string;\n  direction: PeekSortDirection;\n};\n\n// --- Table filter primitive (URL-addressable) --------------------------------\n\nexport type PeekFilterKind =\n  | \"text\"\n  | \"select\"\n  | \"boolean\"\n  | \"date\"\n  | \"dateRange\";\n\nexport type PeekFilterOption = {\n  value: string;\n  label: string;\n};\n\nexport type PeekTableFilter = {\n  id: string;\n  label: string;\n  kind: PeekFilterKind;\n  value: string | null;\n  options: ReadonlyArray<PeekFilterOption> | null;\n  placeholder: string | null;\n  required: boolean;\n};\n\n// --- Status chip tone (shared) -----------------------------------------------\n\nexport type PeekStatusTone =\n  | \"neutral\"\n  | \"positive\"\n  | \"warning\"\n  | \"negative\"\n  | \"info\";\n\n// --- Empty-state primitive ---------------------------------------------------\n\nexport type PeekEmptyState = {\n  title: string;\n  body: string | null;\n};\n\n// --- Table row + column primitives -------------------------------------------\n//\n// Per-feature row types extend `PeekTableRowBase` for the shared identifier +\n// optional drill-down link, then add feature-specific fields. The shared dense\n// table component reads `columns` for layout and per-row data via the typed\n// row shape supplied by the feature page.\n\nexport type PeekTableColumnAlign = \"left\" | \"right\" | \"center\";\n\nexport type PeekTableColumn = {\n  id: string;\n  label: string;\n  align: PeekTableColumnAlign;\n  sortable: boolean;\n};\n\nexport type PeekTableRowBase = {\n  id: string;\n  href: string | null;\n};\n\nexport type PeekTableViewModel<TRow extends PeekTableRowBase> = {\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<TRow>;\n  pagination: PeekPagination;\n  filters: ReadonlyArray<PeekTableFilter>;\n  sort: PeekTableSort | null;\n  empty: PeekEmptyState;\n};\n\n// --- Command-center attention queue (FR-3, FR-10) ----------------------------\n//\n// The command-center page surfaces a small set of \"needs attention\" metrics so\n// operators see exception states (failed claims, dead queue events, stuck\n// settlements, pending SOL crate payouts, stale active Dogpile events,\n// high-value export activity) before they dig into per-feature pages. Each\n// item is a `PeekMetric` so the metric-strip primitive renders it with the\n// FR-4 bookkeeping (definition, source, time window, \"as of\", drill-down).\n\nexport type PeekCommandCenterAttentionId =\n  | \"failed_claims\"\n  | \"dead_queue_events\"\n  | \"stuck_rounds_flipyou_potshot\"\n  | \"stuck_rounds_closecall\"\n  | \"pending_sol_crate_payouts\"\n  | \"stale_active_dogpile_events\"\n  | \"high_value_exports_24h\";\n\nexport type PeekCommandCenterAttention = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};\n\n// --- Recent operator activity (FR-3 command-center \"high-signal activity\") ---\n//\n// Compact projection of the latest `operator_events` rows for the command-center\n// \"Recent activity\" section. Pulled from the same JSONB payload the audit\n// writer persists, but kept narrow on purpose — the command center surfaces\n// only the few fields needed to recognize what happened, not the full payload.\n// The audit view (`/audit`, later iteration) renders the full bounded table.\n\nexport type PeekRecentActivityItem = {\n  id: string;\n  eventType: string;\n  actorEmail: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  route: string | null;\n  createdAt: string;\n};\n\n// --- Audit event contracts (FR-11) -------------------------------------------\n//\n// Browser-safe view of `operator_events` rows the audit writer produces under\n// `peek.*` event types. The `PeekAuditPayload` shape pins the fields required by\n// FR-11 so the writer (`peek/src/server/audit/**`, next iteration) and the audit\n// view (`/audit`, later iteration) agree on a serialization contract. Secrets\n// (JWTs, access tokens, DB URLs, private keys, raw secrets) must be replaced by\n// `PEEK_AUDIT_REDACTED` before persisting; the audit-view component renders the\n// token verbatim so reviewers can see that a field was redacted (not silently\n// absent).\n\nexport type PeekAuditEventType =\n  | \"peek.search\"\n  | \"peek.user.view_sensitive\"\n  | \"peek.export\"\n  | \"peek.access.denied\"\n  | \"peek.change.applied\"\n  | \"peek.change.rejected\";\n\nexport const PEEK_AUDIT_EVENT_TYPES: ReadonlyArray<PeekAuditEventType> = [\n  \"peek.search\",\n  \"peek.user.view_sensitive\",\n  \"peek.export\",\n  \"peek.access.denied\",\n  \"peek.change.applied\",\n  \"peek.change.rejected\",\n];\n\nexport function isPeekAuditEventType(\n  value: unknown,\n): value is PeekAuditEventType {\n  return (\n    typeof value === \"string\" &&\n    (PEEK_AUDIT_EVENT_TYPES as ReadonlyArray<string>).includes(value)\n  );\n}\n\nexport const PEEK_AUDIT_REDACTED = \"[REDACTED]\";\n\nexport type PeekAuditScalar = string | number | boolean | null;\n\nexport type PeekAuditChange = {\n  field: string;\n  before: PeekAuditScalar;\n  after: PeekAuditScalar;\n};\n\nexport type PeekAuditPayload = {\n  actorEmail: string;\n  route: string | null;\n  actionId: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  filterSummary: string | null;\n  resultCount: number | null;\n  requestId: string | null;\n  rejectionReason: string | null;\n  changes: ReadonlyArray<PeekAuditChange> | null;\n};\n\nexport type PeekAuditEvent = {\n  id: string;\n  eventType: PeekAuditEventType;\n  createdAt: string;\n  payload: PeekAuditPayload;\n};\n\n// --- Export contracts (FR-12) ------------------------------------------------\n//\n// Exports are server-rendered CSVs gated by the same page-level access as the\n// source page, bounded by a server-side row cap, named with a deterministic\n// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n// bytes return. Export rows reuse the table view-model column ids so the export\n// shape stays in lockstep with the rendered table; values are pre-formatted\n// strings so CSV serialization stays straightforward and locale-stable.\n\nexport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n\nexport type PeekExportEntity =\n  | \"users\"\n  | \"referrers\"\n  | \"kol\"\n  | \"claims\"\n  | \"rounds\"\n  | \"transactions\"\n  | \"queue\"\n  | \"audit\";\n\nexport type PeekExportRow = Record<string, string>;\n\nexport type PeekExportFilenameInput = {\n  entity: PeekExportEntity;\n  date: string;\n  filterSlug: string;\n};\n\nexport type PeekExportResult = {\n  filename: string;\n  rowCount: number;\n  rowCap: number;\n  rowCapApplied: boolean;\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<PeekExportRow>;\n};\n\n// --- Universal search (FR-5) -------------------------------------------------\n//\n// One search entry point that resolves common operational identifiers to typed\n// result groups. Results are grouped by entity type so the UI can section them\n// (user, referral, linked account, round, transaction, queue event). Each\n// result includes enough context to disambiguate similar matches; sensitive\n// values (wallet, Telegram id, tx signature) live in the result's `id`/`label`\n// fields for operator readability and the audit event records only the actor\n// email, query class, and result counts (never the raw query, which the audit\n// writer redacts if it looks like a secret).\n\nexport type PeekSearchEntityType =\n  | \"user\"\n  | \"referral\"\n  | \"linked_account\"\n  | \"round\"\n  | \"transaction\"\n  | \"queue_event\";\n\nexport const PEEK_SEARCH_ENTITY_TYPES: ReadonlyArray<PeekSearchEntityType> = [\n  \"user\",\n  \"referral\",\n  \"linked_account\",\n  \"round\",\n  \"transaction\",\n  \"queue_event\",\n];\n\n// Coarse heuristic classification used only for the `peek.search` audit\n// summary so reviewers can see which class of identifier was searched without\n// inferring it from the (possibly redacted) raw query.\nexport type PeekSearchQueryClass =\n  | \"empty\"\n  | \"free_text\"\n  | \"user_id\"\n  | \"username\"\n  | \"wallet\"\n  | \"referral_code\"\n  | \"telegram_username\"\n  | \"telegram_provider_id\"\n  | \"round_pda\"\n  | \"match_id\"\n  | \"tx_signature\"\n  | \"queue_event_id\";\n\nexport type PeekSearchResult = {\n  entityType: PeekSearchEntityType;\n  id: string;\n  label: string;\n  sublabel: string | null;\n  context: string | null;\n  href: string;\n};\n\nexport type PeekSearchGroup = {\n  entityType: PeekSearchEntityType;\n  results: ReadonlyArray<PeekSearchResult>;\n  truncated: boolean;\n};\n\nexport type PeekSearchResponse = {\n  query: string;\n  queryClass: PeekSearchQueryClass;\n  groups: ReadonlyArray<PeekSearchGroup>;\n  totalResults: number;\n  perGroupLimit: number;\n  generatedAt: string;\n};\n\nexport const PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT = 5;\nexport const PEEK_SEARCH_MAX_PER_GROUP_LIMIT = 25;\n\n// --- Growth + referral admin (FR-7) ------------------------------------------\n//\n// Browser-safe view models for `/growth/referrals` and `/growth/kol`. The\n// engine queries surface (a) overview metrics that fit the FR-4 metric\n// bookkeeping, (b) top-referrer rows that combine `referral_links`,\n// `referral_codes`, `referral_earnings`, and pending `referral_claims` per\n// referrer, (c) KOL rows that join `referral_kol_rates` with linked\n// performance from `referral_links`/`referral_earnings`, (d) claim rows for\n// the filterable `/growth/referrals` claims table, and (e) a one-hop\n// referral-graph node that lets the UI navigate from a user-detail page to\n// the inbound referrer or any outbound referee and back.\n//\n// All numeric/precision-sensitive values arrive as `text` to preserve u64\n// lamport precision; the UI formats at render time.\n\nexport type PeekGrowthOverviewMetricId =\n  | \"growth.referrers\"\n  | \"growth.referred_users\"\n  | \"growth.activated_referred_users\"\n  | \"growth.referrer_earnings_lamports\"\n  | \"growth.referee_rebates_lamports\"\n  | \"growth.pending_claims_lamports\"\n  | \"growth.failed_claims\"\n  | \"growth.kol_count\";\n\nexport const PEEK_GROWTH_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekGrowthOverviewMetricId> =\n  [\n    \"growth.referrers\",\n    \"growth.referred_users\",\n    \"growth.activated_referred_users\",\n    \"growth.referrer_earnings_lamports\",\n    \"growth.referee_rebates_lamports\",\n    \"growth.pending_claims_lamports\",\n    \"growth.failed_claims\",\n    \"growth.kol_count\",\n  ];\n\nexport type PeekGrowthOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};\n\nexport type PeekTopReferrerRow = {\n  referrerUserId: string;\n  username: string | null;\n  wallet: string;\n  referralCode: string | null;\n  refereeCount: number;\n  activeRefereeCount: number;\n  referredWagerLamports: string;\n  referrerEarnedLamports: string;\n  pendingClaimLamports: string;\n};\n\nexport type PeekKolPerformanceRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  rateBps: number;\n  setBy: string;\n  createdAt: string;\n  updatedAt: string;\n  refereeCount: number;\n  referredWagerLamports: string;\n  referrerEarnedLamports: string;\n};\n\n// Status filter values mirror the migration check constraint:\n// 'pending' | 'processing' | 'error' | 'completed' | 'failed'. Treated as a\n// loose `string` here so the UI can pass through a \"failed_or_error\" virtual\n// alias without a contract change. Extends the per-user\n// `PeekReferralClaimRow` with the `userId`/`username`/`wallet` columns the\n// /growth/referrals claims table needs to render and link rows back to user\n// detail.\nexport type PeekGrowthClaimRow = PeekReferralClaimRow & {\n  userId: string;\n  username: string | null;\n  wallet: string;\n};\n\nexport type PeekReferralClaimFilters = {\n  status: string | null;\n  userId: string | null;\n  minAmountLamports: string | null;\n  maxAmountLamports: string | null;\n  requestedFrom: string | null;\n  requestedTo: string | null;\n  txSignature: string | null;\n  errorContains: string | null;\n};\n\nexport type PeekReferralGraphRefereeRow = {\n  refereeUserId: string;\n  refereeUsername: string | null;\n  refereeWallet: string;\n  createdAt: string;\n};\n\nexport type PeekReferralGraphInboundReferrer = {\n  referrerUserId: string | null;\n  referrerUsername: string | null;\n  referrerWallet: string | null;\n  referrerCode: string | null;\n  linkedAt: string | null;\n};\n\nexport type PeekReferralGraphNode = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  referralCode: string | null;\n  inboundReferrer: PeekReferralGraphInboundReferrer;\n  outboundReferees: ReadonlyArray<PeekReferralGraphRefereeRow>;\n};\n\n// --- Games overview (FR-8) ---------------------------------------------------\n//\n// Browser-safe view models for `/games`. The engine query reads the single\n// source of truth `game_entries` (migration 007) and produces (a) a small set\n// of platform-wide FR-4 metrics for the overview strip and (b) per-game rows\n// with the operational counters the spec calls out: entries, unique users,\n// wagered lamports, settled entries, refund entries, payout lamports, wins,\n// losses. Lamport sums round-trip as `text` to preserve u64 precision; the UI\n// formats at render time.\n//\n// `PeekGameId` mirrors the migration's CHECK constraint on `game_entries.game`\n// (`'flipyou' | 'potshot' | 'closecall'`). Deferred games (Crash, Game of\n// Trades, Chart the Course, Slots Utopia, Tug of Earn) are documented\n// placeholders rendered by the page; they intentionally are not part of the\n// data shape because they have no persisted source yet (system invariant 13).\n\nexport type PeekGameId = \"flipyou\" | \"potshot\" | \"closecall\";\n\nexport const PEEK_GAME_IDS: ReadonlyArray<PeekGameId> = [\n  \"flipyou\",\n  \"potshot\",\n  \"closecall\",\n];\n\nexport type PeekGameOverviewRow = {\n  game: PeekGameId;\n  entries: number;\n  uniqueUsers: number;\n  wageredLamports: string;\n  settledEntries: number;\n  refundEntries: number;\n  payoutLamports: string;\n  wins: number;\n  losses: number;\n};\n\nexport type PeekGameOverviewMetricId =\n  | \"games.total_entries\"\n  | \"games.unique_users\"\n  | \"games.wagered_lamports\"\n  | \"games.settled_entries\"\n  | \"games.refund_entries\"\n  | \"games.payout_lamports\";\n\nexport const PEEK_GAME_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekGameOverviewMetricId> =\n  [\n    \"games.total_entries\",\n    \"games.unique_users\",\n    \"games.wagered_lamports\",\n    \"games.settled_entries\",\n    \"games.refund_entries\",\n    \"games.payout_lamports\",\n  ];\n\nexport type PeekGameOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n  perGame: ReadonlyArray<PeekGameOverviewRow>;\n};\n\n// --- Per-game round detail (FR-8) --------------------------------------------\n//\n// Browser-safe view models for the round-detail surfaces backing\n// `/games/[game]`. Two distinct shapes because the underlying tables differ:\n//\n//   - FlipYou and Pot Shot share the `rounds` table (migration 001) — the\n//     CHECK constraint pins phase to one of five lifecycle states. Lamport\n//     and slot values are u64-precision and round-trip as `text`.\n//   - Close Call uses the separate `closecall_rounds` table (migration 004)\n//     with its own three-phase lifecycle and a Pyth-driven outcome column.\n//\n// `stuck-state filters` cover the four operational signals the spec calls\n// out: nonterminal-aged (created/locked/settling past the age threshold for\n// FlipYou/Pot Shot; open past the age threshold for Close Call), high settle\n// attempts (FlipYou/Pot Shot only — `closecall_rounds` has no\n// `settle_attempts`), settled rounds without an expected payout/refund\n// transaction in `transactions`, and refunds (phase `expired` for FlipYou/\n// Pot Shot; phase `refunded` or outcome `refund` for Close Call).\n\nexport type PeekRoundPhase =\n  | \"created\"\n  | \"locked\"\n  | \"settling\"\n  | \"settled\"\n  | \"expired\";\n\nexport const PEEK_ROUND_PHASES: ReadonlyArray<PeekRoundPhase> = [\n  \"created\",\n  \"locked\",\n  \"settling\",\n  \"settled\",\n  \"expired\",\n];\n\nexport type PeekRoundsGameId = Extract<PeekGameId, \"flipyou\" | \"potshot\">;\n\nexport const PEEK_ROUNDS_GAME_IDS: ReadonlyArray<PeekRoundsGameId> = [\n  \"flipyou\",\n  \"potshot\",\n];\n\nexport type PeekRoundRow = {\n  game: PeekRoundsGameId;\n  pda: string;\n  matchId: string;\n  phase: PeekRoundPhase;\n  creator: string;\n  targetSlot: string | null;\n  settleAttempts: number;\n  settleTx: string | null;\n  resultSide: number | null;\n  winner: string | null;\n  amountLamports: string;\n  createdAt: string;\n  updatedAt: string;\n  settledAt: string | null;\n};\n\nexport type PeekCloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n\nexport const PEEK_CLOSECALL_PHASES: ReadonlyArray<PeekCloseCallPhase> = [\n  \"open\",\n  \"settled\",\n  \"refunded\",\n];\n\nexport type PeekCloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n\nexport const PEEK_CLOSECALL_OUTCOMES: ReadonlyArray<PeekCloseCallOutcome> = [\n  \"pending\",\n  \"green\",\n  \"red\",\n  \"refund\",\n];\n\nexport type PeekCloseCallRoundRow = {\n  pda: string;\n  roundId: string;\n  phase: PeekCloseCallPhase;\n  outcome: PeekCloseCallOutcome;\n  openPrice: string;\n  openPriceExpo: number;\n  closePrice: string | null;\n  greenPoolLamports: string;\n  redPoolLamports: string;\n  totalFeeLamports: string;\n  settleTx: string | null;\n  createdAt: string;\n  settledAt: string | null;\n};\n\nexport type PeekRoundStuckFilters = {\n  nonterminalAged: boolean;\n  highAttempts: boolean;\n  settledWithoutTx: boolean;\n  refunds: boolean;\n};\n\nexport type PeekRoundFilters = {\n  phase: PeekRoundPhase | null;\n  search: string | null;\n  fromDate: string | null;\n  toDate: string | null;\n  stuck: PeekRoundStuckFilters;\n};\n\nexport type PeekCloseCallRoundStuckFilters = Omit<\n  PeekRoundStuckFilters,\n  \"highAttempts\"\n>;\n\nexport type PeekCloseCallRoundFilters = {\n  phase: PeekCloseCallPhase | null;\n  outcome: PeekCloseCallOutcome | null;\n  search: string | null;\n  fromDate: string | null;\n  toDate: string | null;\n  stuck: PeekCloseCallRoundStuckFilters;\n};\n\nexport type PeekRoundsListResult<TRow> = {\n  rows: ReadonlyArray<TRow>;\n  pagination: PeekPagination;\n};\n\n// --- Round detail (FR-8) -----------------------------------------------------\n//\n// Browser-safe view models for `/games/[game]/rounds/[roundId]`. The detail\n// joins the round summary (FlipYou/Pot Shot from `rounds`, Close Call from\n// `closecall_rounds`) with all participating `game_entries` and the related\n// `transactions` rows for the round (matched by `match_id` + `game`, where\n// `match_id` is `closecall_rounds.round_id` for the Close Call branch).\n//\n// Entries and transactions carry the operator-readable identity context the\n// detail page renders alongside each row (wallet always; user id + username\n// when the player has a `player_profiles` row). Lamport amounts and slot\n// values stay as `text` to preserve u64 precision.\n\nexport type PeekRoundEntryRow = {\n  id: string;\n  userId: string;\n  username: string | null;\n  wallet: string;\n  amountLamports: string;\n  side: string | null;\n  isWinner: boolean | null;\n  payoutLamports: string;\n  createdAt: string;\n  settledAt: string | null;\n};\n\nexport type PeekRoundTransactionRow = {\n  id: string;\n  userId: string | null;\n  username: string | null;\n  wallet: string;\n  txType: string;\n  amountLamports: string;\n  txSig: string;\n  createdAt: string;\n};\n\nexport type PeekRoundDetail =\n  | {\n      game: PeekRoundsGameId;\n      round: PeekRoundRow;\n      entries: ReadonlyArray<PeekRoundEntryRow>;\n      transactions: ReadonlyArray<PeekRoundTransactionRow>;\n    }\n  | {\n      game: \"closecall\";\n      round: PeekCloseCallRoundRow;\n      entries: ReadonlyArray<PeekRoundEntryRow>;\n      transactions: ReadonlyArray<PeekRoundTransactionRow>;\n    };\n","structuredPatch":[{"oldStart":890,"oldLines":3,"newStart":890,"newLines":71,"lines":["       entries: ReadonlyArray<PeekRoundEntryRow>;","       transactions: ReadonlyArray<PeekRoundTransactionRow>;","     };","+","+// --- Economy: rewards (FR-9) -------------------------------------------------","+//","+// Browser-safe view models for `/economy/rewards`. Reads three migration-011","+// tables:","+//","+//   - reward_config           — operator-tunable economy parameters; each row","+//     is annotated server-side with a human-readable definition and an","+//     expected-value type from a static registry so the page can show what a","+//     key means without an extra docs lookup.","+//   - reward_pool             — singleton accounting row (balance, lifetime","+//     funded, lifetime paid, updated_at).","+//   - reward_pool_fundings    — append-only ledger of per-round funding events","+//     keyed on round_id (the source round whose fee fed the pool).","+//","+// Lamport / u64 values round-trip as `text` to preserve precision (FR-4).","+// Unknown reward_config keys still surface (with `definition: null` and","+// `expectedType: \"unknown\"`) so an operator immediately notices when a new","+// key has been seeded but the registry has not been updated.","+","+export type PeekRewardConfigExpectedType =","+  | \"integer\"","+  | \"float\"","+  | \"ratio\"","+  | \"lamports\"","+  | \"unknown\";","+","+export type PeekRewardConfigRow = {","+  key: string;","+  value: string;","+  updatedAt: string;","+  definition: string | null;","+  expectedType: PeekRewardConfigExpectedType;","+};","+","+export type PeekRewardPool = {","+  balanceLamports: string;","+  lifetimeFunded: string;","+  lifetimePaid: string;","+  updatedAt: string;","+};","+","+export type PeekRewardPoolFundingRow = {","+  id: string;","+  roundId: string;","+  feeLamports: string;","+  fundedLamports: string;","+  createdAt: string;","+};","+","+export type PeekRewardsOverviewMetricId =","+  | \"rewards.balance_lamports\"","+  | \"rewards.lifetime_funded_lamports\"","+  | \"rewards.lifetime_paid_lamports\"","+  | \"rewards.recent_fundings\";","+","+export const PEEK_REWARDS_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekRewardsOverviewMetricId> =","+  [","+    \"rewards.balance_lamports\",","+    \"rewards.lifetime_funded_lamports\",","+    \"rewards.lifetime_paid_lamports\",","+    \"rewards.recent_fundings\",","+  ];","+","+export type PeekRewardsOverview = {","+  generatedAt: string;","+  metrics: ReadonlyArray<PeekMetric>;","+};"]}],"userModified":false,"replaceAll":false}}
