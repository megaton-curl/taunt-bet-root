{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017iLcy4Vk4vpUjuy51f5muC","type":"tool_result","content":"1\t// Games overview admin queries (FR-8).\n2\t//\n3\t// Backs `/games`: cross-game `game_entries` aggregations per game, plus a\n4\t// small platform-wide metric strip suitable for the FR-4 metric primitive.\n5\t// The single source of truth is `game_entries` (migration 007): one row per\n6\t// participation, UPSERT'd at settlement. The migration documents the refund\n7\t// convention used here:\n8\t//\n9\t//   \"Refunded entries: is_winner = NULL, payout_lamports = amount_lamports.\"\n10\t//\n11\t// Per-game counters:\n12\t//   entries          — all game_entries rows for the game\n13\t//   uniqueUsers      — distinct user_id values\n14\t//   wageredLamports  — sum(amount_lamports)\n15\t//   settledEntries   — rows with settled_at IS NOT NULL\n16\t//   refundEntries    — settled rows with is_winner IS NULL (refund sentinel)\n17\t//   payoutLamports   — sum(payout_lamports)\n18\t//   wins             — rows with is_winner = TRUE\n19\t//   losses           — rows with is_winner = FALSE\n20\t//\n21\t// Bounded: a single grouped query — no row-level data crosses the wire here.\n22\t// Deferred games (Crash, Game of Trades, Chart the Course, Slots Utopia, Tug\n23\t// of Earn) are not part of the data shape; the `/games` page renders them as\n24\t// documented placeholders only (system invariant 13).\n25\t\n26\timport type { Sql } from \"postgres\";\n27\timport {\n28\t  PEEK_GAME_IDS,\n29\t  type PeekGameId,\n30\t  type PeekGameOverview,\n31\t  type PeekGameOverviewMetricId,\n32\t  type PeekGameOverviewRow,\n33\t  type PeekMetric,\n34\t} from \"../../../lib/types/peek\";\n35\timport { getSqlClient } from \"../client\";\n36\t\n37\texport type GamesOverviewOptions = {\n38\t  sql?: Sql;\n39\t  now?: Date;\n40\t};\n41\t\n42\ttype AggregateRow = {\n43\t  game: PeekGameId;\n44\t  entries: number | string;\n45\t  unique_users: number | string;\n46\t  wagered_lamports: string;\n47\t  settled_entries: number | string;\n48\t  refund_entries: number | string;\n49\t  payout_lamports: string;\n50\t  wins: number | string;\n51\t  losses: number | string;\n52\t};\n53\t\n54\ttype CountRow = { value: number | string };\n55\t\n56\tfunction readInt(value: number | string | null | undefined): number {\n57\t  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n58\t  if (typeof value === \"string\") {\n59\t    const parsed = Number.parseInt(value, 10);\n60\t    return Number.isFinite(parsed) ? parsed : 0;\n61\t  }\n62\t  return 0;\n63\t}\n64\t\n65\tfunction readSum(value: string | null | undefined): string {\n66\t  return typeof value === \"string\" && value.length > 0 ? value : \"0\";\n67\t}\n68\t\n69\tfunction formatCount(count: number): string {\n70\t  return count.toLocaleString(\"en-US\");\n71\t}\n72\t\n73\tfunction formatLamports(value: string): string {\n74\t  if (!value || value === \"0\") return \"0\";\n75\t  const negative = value.startsWith(\"-\");\n76\t  const digits = negative ? value.slice(1) : value;\n77\t  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n78\t  return negative ? `-${grouped}` : grouped;\n79\t}\n80\t\n81\tfunction emptyRow(game: PeekGameId): PeekGameOverviewRow {\n82\t  return {\n83\t    game,\n84\t    entries: 0,\n85\t    uniqueUsers: 0,\n86\t    wageredLamports: \"0\",\n87\t    settledEntries: 0,\n88\t    refundEntries: 0,\n89\t    payoutLamports: \"0\",\n90\t    wins: 0,\n91\t    losses: 0,\n92\t  };\n93\t}\n94\t\n95\tfunction sumLamports(values: ReadonlyArray<string>): string {\n96\t  // BigInt sum keeps u64 precision across per-game lamport totals; values\n97\t  // are strings from the postgres driver.\n98\t  let total = 0n;\n99\t  for (const v of values) {\n100\t    if (!v) continue;\n101\t    try {\n102\t      total += BigInt(v);\n103\t    } catch {\n104\t      // ignore unparsable values; the per-game row already reflects them.\n105\t    }\n106\t  }\n107\t  return total.toString();\n108\t}\n109\t\n110\ttype MetricBlueprint = {\n111\t  id: PeekGameOverviewMetricId;\n112\t  label: string;\n113\t  unit: string | null;\n114\t  source: string;\n115\t  windowLabel: string;\n116\t  definition: string;\n117\t  drilldownHref: string | null;\n118\t};\n119\t\n120\tfunction buildMetric(\n121\t  blueprint: MetricBlueprint,\n122\t  raw: number | string,\n123\t  display: string,\n124\t  asOf: string,\n125\t): PeekMetric {\n126\t  return {\n127\t    id: blueprint.id,\n128\t    label: blueprint.label,\n129\t    value: raw,\n130\t    valueDisplay: display,\n131\t    unit: blueprint.unit,\n132\t    source: blueprint.source,\n133\t    windowLabel: blueprint.windowLabel,\n134\t    asOf,\n135\t    definition: blueprint.definition,\n136\t    freshness: \"live\",\n137\t    drilldownHref: blueprint.drilldownHref,\n138\t  };\n139\t}\n140\t\n141\texport async function getGamesOverview(\n142\t  options: GamesOverviewOptions = {},\n143\t): Promise<PeekGameOverview> {\n144\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n145\t  const now = options.now ?? new Date();\n146\t  const generatedAt = now.toISOString();\n147\t\n148\t  // Two queries fire in parallel:\n149\t  //   1. per-game aggregates (one row per game appearing in the table).\n150\t  //   2. platform-wide unique-users count (DISTINCT user_id across all\n151\t  //      games — different from summing per-game distinct counts because a\n152\t  //      single player can appear in multiple games).\n153\t  const [aggregateRows, uniqueUsersRows] = await Promise.all([\n154\t    sql<AggregateRow[]>`\n155\t      select\n156\t        game,\n157\t        count(*)::int as \"entries\",\n158\t        count(distinct user_id)::int as \"unique_users\",\n159\t        coalesce(sum(amount_lamports), 0)::text as \"wagered_lamports\",\n160\t        count(*) filter (where settled_at is not null)::int as \"settled_entries\",\n161\t        count(*) filter (where settled_at is not null and is_winner is null)::int as \"refund_entries\",\n162\t        coalesce(sum(payout_lamports), 0)::text as \"payout_lamports\",\n163\t        count(*) filter (where is_winner = true)::int as \"wins\",\n164\t        count(*) filter (where is_winner = false)::int as \"losses\"\n165\t      from game_entries\n166\t      group by game\n167\t    `,\n168\t    sql<CountRow[]>`\n169\t      select count(distinct user_id)::int as \"value\"\n170\t      from game_entries\n171\t    `,\n172\t  ]);\n173\t\n174\t  // Normalize: emit one row per known PeekGameId in stable order, zeroed when\n175\t  // a game has no entries yet so the UI does not have to special-case missing\n176\t  // rows. Unknown game values returned by the DB are ignored — the migration\n177\t  // CHECK constraint should keep them in lockstep with PEEK_GAME_IDS, but\n178\t  // skipping unknowns here means an out-of-band row cannot leak into the UI.\n179\t  const byGame = new Map<PeekGameId, AggregateRow>();\n180\t  for (const row of aggregateRows) {\n181\t    if ((PEEK_GAME_IDS as ReadonlyArray<string>).includes(row.game)) {\n182\t      byGame.set(row.game, row);\n183\t    }\n184\t  }\n185\t\n186\t  const perGame: PeekGameOverviewRow[] = PEEK_GAME_IDS.map((game) => {\n187\t    const row = byGame.get(game);\n188\t    if (!row) return emptyRow(game);\n189\t    return {\n190\t      game,\n191\t      entries: readInt(row.entries),\n192\t      uniqueUsers: readInt(row.unique_users),\n193\t      wageredLamports: readSum(row.wagered_lamports),\n194\t      settledEntries: readInt(row.settled_entries),\n195\t      refundEntries: readInt(row.refund_entries),\n196\t      payoutLamports: readSum(row.payout_lamports),\n197\t      wins: readInt(row.wins),\n198\t      losses: readInt(row.losses),\n199\t    };\n200\t  });\n201\t\n202\t  const totalEntries = perGame.reduce((acc, r) => acc + r.entries, 0);\n203\t  const totalSettled = perGame.reduce((acc, r) => acc + r.settledEntries, 0);\n204\t  const totalRefunds = perGame.reduce((acc, r) => acc + r.refundEntries, 0);\n205\t  const totalWagered = sumLamports(perGame.map((r) => r.wageredLamports));\n206\t  const totalPayouts = sumLamports(perGame.map((r) => r.payoutLamports));\n207\t  const platformUniqueUsers = readInt(\n208\t    uniqueUsersRows.length > 0 ? uniqueUsersRows[0]?.value : 0,\n209\t  );\n210\t\n211\t  const blueprints: ReadonlyArray<{\n212\t    blueprint: MetricBlueprint;\n213\t    raw: number | string;\n214\t    display: string;\n215\t  }> = [\n216\t    {\n217\t      blueprint: {\n218\t        id: \"games.total_entries\",\n219\t        label: \"Game entries\",\n220\t        unit: \"entries\",\n221\t        source: \"game_entries\",\n222\t        windowLabel: \"All time\",\n223\t        definition:\n224\t          \"Total game_entries rows across FlipYou, Pot Shot, and Close Call — one row per participation.\",\n225\t        drilldownHref: \"/games\",\n226\t      },\n227\t      raw: totalEntries,\n228\t      display: formatCount(totalEntries),\n229\t    },\n230\t    {\n231\t      blueprint: {\n232\t        id: \"games.unique_users\",\n233\t        label: \"Unique players\",\n234\t        unit: \"users\",\n235\t        source: \"game_entries\",\n236\t        windowLabel: \"All time\",\n237\t        definition:\n238\t          \"Distinct user_id values across all games — a single player counted once even if they played multiple games.\",\n239\t        drilldownHref: \"/games\",\n240\t      },\n241\t      raw: platformUniqueUsers,\n242\t      display: formatCount(platformUniqueUsers),\n243\t    },\n244\t    {\n245\t      blueprint: {\n246\t        id: \"games.wagered_lamports\",\n247\t        label: \"Wagered (lamports)\",\n248\t        unit: \"lamports\",\n249\t        source: \"game_entries\",\n250\t        windowLabel: \"All time\",\n251\t        definition:\n252\t          \"Sum of amount_lamports across game_entries — gross wager volume across all games.\",\n253\t        drilldownHref: \"/games\",\n254\t      },\n255\t      raw: totalWagered,\n256\t      display: formatLamports(totalWagered),\n257\t    },\n258\t    {\n259\t      blueprint: {\n260\t        id: \"games.settled_entries\",\n261\t        label: \"Settled entries\",\n262\t        unit: \"entries\",\n263\t        source: \"game_entries\",\n264\t        windowLabel: \"All time\",\n265\t        definition:\n266\t          \"Game entries with settled_at set — includes wins, losses, and refunds.\",\n267\t        drilldownHref: \"/games\",\n268\t      },\n269\t      raw: totalSettled,\n270\t      display: formatCount(totalSettled),\n271\t    },\n272\t    {\n273\t      blueprint: {\n274\t        id: \"games.refund_entries\",\n275\t        label: \"Refunded entries\",\n276\t        unit: \"entries\",\n277\t        source: \"game_entries\",\n278\t        windowLabel: \"All time\",\n279\t        definition:\n280\t          \"Settled entries with is_winner IS NULL — the migration's refund sentinel (payout_lamports = amount_lamports).\",\n281\t        drilldownHref: \"/games\",\n282\t      },\n283\t      raw: totalRefunds,\n284\t      display: formatCount(totalRefunds),\n285\t    },\n286\t    {\n287\t      blueprint: {\n288\t        id: \"games.payout_lamports\",\n289\t        label: \"Paid out (lamports)\",\n290\t        unit: \"lamports\",\n291\t        source: \"game_entries\",\n292\t        windowLabel: \"All time\",\n293\t        definition:\n294\t          \"Sum of payout_lamports across game_entries — gross winnings + refunds returned to players.\",\n295\t        drilldownHref: \"/games\",\n296\t      },\n297\t      raw: totalPayouts,\n298\t      display: formatLamports(totalPayouts),\n299\t    },\n300\t  ];\n301\t\n302\t  return {\n303\t    generatedAt,\n304\t    metrics: blueprints.map(({ blueprint, raw, display }) =>\n305\t      buildMetric(blueprint, raw, display, generatedAt),\n306\t    ),\n307\t    perGame,\n308\t  };\n309\t}\n310\t"}]},"parent_tool_use_id":null,"session_id":"b796dedf-129f-4036-aac1-59555f53ee60","uuid":"4fc83667-1bde-4926-84fc-2fda9bd57ac1","timestamp":"2026-04-25T12:44:12.428Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-games-overview.ts","content":"// Games overview admin queries (FR-8).\n//\n// Backs `/games`: cross-game `game_entries` aggregations per game, plus a\n// small platform-wide metric strip suitable for the FR-4 metric primitive.\n// The single source of truth is `game_entries` (migration 007): one row per\n// participation, UPSERT'd at settlement. The migration documents the refund\n// convention used here:\n//\n//   \"Refunded entries: is_winner = NULL, payout_lamports = amount_lamports.\"\n//\n// Per-game counters:\n//   entries          — all game_entries rows for the game\n//   uniqueUsers      — distinct user_id values\n//   wageredLamports  — sum(amount_lamports)\n//   settledEntries   — rows with settled_at IS NOT NULL\n//   refundEntries    — settled rows with is_winner IS NULL (refund sentinel)\n//   payoutLamports   — sum(payout_lamports)\n//   wins             — rows with is_winner = TRUE\n//   losses           — rows with is_winner = FALSE\n//\n// Bounded: a single grouped query — no row-level data crosses the wire here.\n// Deferred games (Crash, Game of Trades, Chart the Course, Slots Utopia, Tug\n// of Earn) are not part of the data shape; the `/games` page renders them as\n// documented placeholders only (system invariant 13).\n\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_GAME_IDS,\n  type PeekGameId,\n  type PeekGameOverview,\n  type PeekGameOverviewMetricId,\n  type PeekGameOverviewRow,\n  type PeekMetric,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport type GamesOverviewOptions = {\n  sql?: Sql;\n  now?: Date;\n};\n\ntype AggregateRow = {\n  game: PeekGameId;\n  entries: number | string;\n  unique_users: number | string;\n  wagered_lamports: string;\n  settled_entries: number | string;\n  refund_entries: number | string;\n  payout_lamports: string;\n  wins: number | string;\n  losses: number | string;\n};\n\ntype CountRow = { value: number | string };\n\nfunction readInt(value: number | string | null | undefined): number {\n  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n  if (typeof value === \"string\") {\n    const parsed = Number.parseInt(value, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction readSum(value: string | null | undefined): string {\n  return typeof value === \"string\" && value.length > 0 ? value : \"0\";\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\nfunction formatLamports(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nfunction emptyRow(game: PeekGameId): PeekGameOverviewRow {\n  return {\n    game,\n    entries: 0,\n    uniqueUsers: 0,\n    wageredLamports: \"0\",\n    settledEntries: 0,\n    refundEntries: 0,\n    payoutLamports: \"0\",\n    wins: 0,\n    losses: 0,\n  };\n}\n\nfunction sumLamports(values: ReadonlyArray<string>): string {\n  // BigInt sum keeps u64 precision across per-game lamport totals; values\n  // are strings from the postgres driver.\n  let total = 0n;\n  for (const v of values) {\n    if (!v) continue;\n    try {\n      total += BigInt(v);\n    } catch {\n      // ignore unparsable values; the per-game row already reflects them.\n    }\n  }\n  return total.toString();\n}\n\ntype MetricBlueprint = {\n  id: PeekGameOverviewMetricId;\n  label: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  definition: string;\n  drilldownHref: string | null;\n};\n\nfunction buildMetric(\n  blueprint: MetricBlueprint,\n  raw: number | string,\n  display: string,\n  asOf: string,\n): PeekMetric {\n  return {\n    id: blueprint.id,\n    label: blueprint.label,\n    value: raw,\n    valueDisplay: display,\n    unit: blueprint.unit,\n    source: blueprint.source,\n    windowLabel: blueprint.windowLabel,\n    asOf,\n    definition: blueprint.definition,\n    freshness: \"live\",\n    drilldownHref: blueprint.drilldownHref,\n  };\n}\n\nexport async function getGamesOverview(\n  options: GamesOverviewOptions = {},\n): Promise<PeekGameOverview> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n\n  // Two queries fire in parallel:\n  //   1. per-game aggregates (one row per game appearing in the table).\n  //   2. platform-wide unique-users count (DISTINCT user_id across all\n  //      games — different from summing per-game distinct counts because a\n  //      single player can appear in multiple games).\n  const [aggregateRows, uniqueUsersRows] = await Promise.all([\n    sql<AggregateRow[]>`\n      select\n        game,\n        count(*)::int as \"entries\",\n        count(distinct user_id)::int as \"unique_users\",\n        coalesce(sum(amount_lamports), 0)::text as \"wagered_lamports\",\n        count(*) filter (where settled_at is not null)::int as \"settled_entries\",\n        count(*) filter (where settled_at is not null and is_winner is null)::int as \"refund_entries\",\n        coalesce(sum(payout_lamports), 0)::text as \"payout_lamports\",\n        count(*) filter (where is_winner = true)::int as \"wins\",\n        count(*) filter (where is_winner = false)::int as \"losses\"\n      from game_entries\n      group by game\n    `,\n    sql<CountRow[]>`\n      select count(distinct user_id)::int as \"value\"\n      from game_entries\n    `,\n  ]);\n\n  // Normalize: emit one row per known PeekGameId in stable order, zeroed when\n  // a game has no entries yet so the UI does not have to special-case missing\n  // rows. Unknown game values returned by the DB are ignored — the migration\n  // CHECK constraint should keep them in lockstep with PEEK_GAME_IDS, but\n  // skipping unknowns here means an out-of-band row cannot leak into the UI.\n  const byGame = new Map<PeekGameId, AggregateRow>();\n  for (const row of aggregateRows) {\n    if ((PEEK_GAME_IDS as ReadonlyArray<string>).includes(row.game)) {\n      byGame.set(row.game, row);\n    }\n  }\n\n  const perGame: PeekGameOverviewRow[] = PEEK_GAME_IDS.map((game) => {\n    const row = byGame.get(game);\n    if (!row) return emptyRow(game);\n    return {\n      game,\n      entries: readInt(row.entries),\n      uniqueUsers: readInt(row.unique_users),\n      wageredLamports: readSum(row.wagered_lamports),\n      settledEntries: readInt(row.settled_entries),\n      refundEntries: readInt(row.refund_entries),\n      payoutLamports: readSum(row.payout_lamports),\n      wins: readInt(row.wins),\n      losses: readInt(row.losses),\n    };\n  });\n\n  const totalEntries = perGame.reduce((acc, r) => acc + r.entries, 0);\n  const totalSettled = perGame.reduce((acc, r) => acc + r.settledEntries, 0);\n  const totalRefunds = perGame.reduce((acc, r) => acc + r.refundEntries, 0);\n  const totalWagered = sumLamports(perGame.map((r) => r.wageredLamports));\n  const totalPayouts = sumLamports(perGame.map((r) => r.payoutLamports));\n  const platformUniqueUsers = readInt(\n    uniqueUsersRows.length > 0 ? uniqueUsersRows[0]?.value : 0,\n  );\n\n  const blueprints: ReadonlyArray<{\n    blueprint: MetricBlueprint;\n    raw: number | string;\n    display: string;\n  }> = [\n    {\n      blueprint: {\n        id: \"games.total_entries\",\n        label: \"Game entries\",\n        unit: \"entries\",\n        source: \"game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Total game_entries rows across FlipYou, Pot Shot, and Close Call — one row per participation.\",\n        drilldownHref: \"/games\",\n      },\n      raw: totalEntries,\n      display: formatCount(totalEntries),\n    },\n    {\n      blueprint: {\n        id: \"games.unique_users\",\n        label: \"Unique players\",\n        unit: \"users\",\n        source: \"game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Distinct user_id values across all games — a single player counted once even if they played multiple games.\",\n        drilldownHref: \"/games\",\n      },\n      raw: platformUniqueUsers,\n      display: formatCount(platformUniqueUsers),\n    },\n    {\n      blueprint: {\n        id: \"games.wagered_lamports\",\n        label: \"Wagered (lamports)\",\n        unit: \"lamports\",\n        source: \"game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Sum of amount_lamports across game_entries — gross wager volume across all games.\",\n        drilldownHref: \"/games\",\n      },\n      raw: totalWagered,\n      display: formatLamports(totalWagered),\n    },\n    {\n      blueprint: {\n        id: \"games.settled_entries\",\n        label: \"Settled entries\",\n        unit: \"entries\",\n        source: \"game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Game entries with settled_at set — includes wins, losses, and refunds.\",\n        drilldownHref: \"/games\",\n      },\n      raw: totalSettled,\n      display: formatCount(totalSettled),\n    },\n    {\n      blueprint: {\n        id: \"games.refund_entries\",\n        label: \"Refunded entries\",\n        unit: \"entries\",\n        source: \"game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Settled entries with is_winner IS NULL — the migration's refund sentinel (payout_lamports = amount_lamports).\",\n        drilldownHref: \"/games\",\n      },\n      raw: totalRefunds,\n      display: formatCount(totalRefunds),\n    },\n    {\n      blueprint: {\n        id: \"games.payout_lamports\",\n        label: \"Paid out (lamports)\",\n        unit: \"lamports\",\n        source: \"game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Sum of payout_lamports across game_entries — gross winnings + refunds returned to players.\",\n        drilldownHref: \"/games\",\n      },\n      raw: totalPayouts,\n      display: formatLamports(totalPayouts),\n    },\n  ];\n\n  return {\n    generatedAt,\n    metrics: blueprints.map(({ blueprint, raw, display }) =>\n      buildMetric(blueprint, raw, display, generatedAt),\n    ),\n    perGame,\n  };\n}\n","numLines":310,"startLine":1,"totalLines":310}}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01AaZMgAtrXhG9os34xd4PQw","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_018ZdmmYMHpDqccA4rmoQsHu","name":"Read","input":{"file_path":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4669,"cache_read_input_tokens":70538,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4669},"output_tokens":44,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"b796dedf-129f-4036-aac1-59555f53ee60","uuid":"89ee7b01-3d9e-46f0-9fb6-0c2d93ca6a2e"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018ZdmmYMHpDqccA4rmoQsHu","type":"tool_result","content":"1\t// Browser-safe view-model primitives for `peek`.\n2\t//\n3\t// Foundational shapes used across feature pages: metric metadata (FR-4),\n4\t// URL-addressable table filters, pagination, sort, and a small table-row base\n5\t// type that per-feature row types can extend. Per-feature shapes (PeekUserRow,\n6\t// PeekUserDetail, future referral/game/queue/etc. rows) live alongside or\n7\t// extend these primitives.\n8\t\n9\timport type { PeekRole } from \"../access-policy\";\n10\t\n11\t// --- Existing 303-era shapes (kept stable for current callers) ---------------\n12\t\n13\texport type PeekSummary = {\n14\t  totalUsers: number;\n15\t  totalUsersWithCodes: number;\n16\t  totalReferredUsers: number;\n17\t  totalUniqueReferrers: number;\n18\t};\n19\t\n20\texport type PeekUserRow = {\n21\t  userId: string;\n22\t  username: string | null;\n23\t  wallet: string;\n24\t  joinedAt: string;\n25\t  referralCode: string | null;\n26\t  referrerUserId: string | null;\n27\t  referrerCode: string | null;\n28\t  refereeCount: number;\n29\t  telegramUsername: string | null;\n30\t  telegramUserId: string | null;\n31\t};\n32\t\n33\t// --- Expanded user-detail shapes (FR-6) --------------------------------------\n34\t//\n35\t// Per-section row types for the full support/audit user profile. Lamports and\n36\t// numeric/precision-sensitive values arrive as `text` to preserve precision; the\n37\t// UI re-formats at render time. All shapes are browser-safe (no server imports).\n38\t\n39\texport type PeekLinkedAccountRow = {\n40\t  id: string;\n41\t  provider: string;\n42\t  providerAccountId: string;\n43\t  status: string;\n44\t  telegramUsername: string | null;\n45\t  metadataJson: Record<string, unknown> | null;\n46\t  linkedAt: string;\n47\t  updatedAt: string;\n48\t};\n49\t\n50\texport type PeekTelegramLinkTokenRow = {\n51\t  id: string;\n52\t  status: string;\n53\t  telegramUserId: string | null;\n54\t  telegramUsername: string | null;\n55\t  expiresAt: string;\n56\t  redeemedAt: string | null;\n57\t  createdAt: string;\n58\t};\n59\t\n60\texport type PeekKolRate = {\n61\t  rateBps: number;\n62\t  setBy: string;\n63\t  createdAt: string;\n64\t  updatedAt: string;\n65\t};\n66\t\n67\texport type PeekReferralEarningsSummary = {\n68\t  earningsCount: number;\n69\t  totalReferrerEarnedLamports: string;\n70\t  totalRefereeRebateLamports: string;\n71\t  lastEarnedAt: string | null;\n72\t};\n73\t\n74\texport type PeekReferralClaimRow = {\n75\t  id: string;\n76\t  amountLamports: string;\n77\t  status: string;\n78\t  retryCount: number;\n79\t  txSignature: string | null;\n80\t  error: string | null;\n81\t  requestedAt: string;\n82\t  processedAt: string | null;\n83\t};\n84\t\n85\texport type PeekPointGrantRow = {\n86\t  id: string;\n87\t  sourceType: string;\n88\t  sourceId: string;\n89\t  amount: string;\n90\t  createdAt: string;\n91\t};\n92\t\n93\texport type PeekPlayerPoints = {\n94\t  balance: string;\n95\t  lifetimeEarned: string;\n96\t  updatedAt: string | null;\n97\t};\n98\t\n99\texport type PeekCrateDropRow = {\n100\t  id: string;\n101\t  triggerType: string;\n102\t  triggerId: string;\n103\t  crateType: string;\n104\t  contentsAmount: string;\n105\t  status: string;\n106\t  createdAt: string;\n107\t  grantedAt: string | null;\n108\t};\n109\t\n110\texport type PeekChallengeAssignmentSummary = {\n111\t  active: number;\n112\t  completed: number;\n113\t  expired: number;\n114\t  total: number;\n115\t};\n116\t\n117\texport type PeekGameEntryRow = {\n118\t  id: string;\n119\t  game: string;\n120\t  roundPda: string;\n121\t  matchId: string;\n122\t  amountLamports: string;\n123\t  side: string | null;\n124\t  isWinner: boolean | null;\n125\t  payoutLamports: string;\n126\t  createdAt: string;\n127\t  settledAt: string | null;\n128\t};\n129\t\n130\texport type PeekTransactionRow = {\n131\t  id: string;\n132\t  game: string;\n133\t  matchId: string;\n134\t  txType: string;\n135\t  amountLamports: string;\n136\t  txSig: string;\n137\t  createdAt: string;\n138\t};\n139\t\n140\texport type PeekFraudFlagRow = {\n141\t  id: string;\n142\t  flagType: string;\n143\t  status: string;\n144\t  relatedId: string | null;\n145\t  createdAt: string;\n146\t  resolvedAt: string | null;\n147\t};\n148\t\n149\texport type PeekUserQueueEventRow = {\n150\t  id: string;\n151\t  eventType: string;\n152\t  status: string;\n153\t  attempts: number;\n154\t  maxAttempts: number;\n155\t  scheduledAt: string;\n156\t  createdAt: string;\n157\t  error: string | null;\n158\t};\n159\t\n160\texport type PeekUserAttentionFlags = {\n161\t  failedClaim: boolean;\n162\t  deadQueueEvent: boolean;\n163\t  activeFraudFlag: boolean;\n164\t  pendingSolCratePayout: boolean;\n165\t  suspiciousReferralLoop: boolean;\n166\t};\n167\t\n168\texport type PeekUserDetailUser = PeekUserRow & {\n169\t  avatarUrl: string | null;\n170\t  heatMultiplier: string;\n171\t  profilePointsBalance: string;\n172\t};\n173\t\n174\texport type PeekUserDetail = {\n175\t  user: PeekUserDetailUser;\n176\t  inboundReferral: {\n177\t    referrerUserId: string | null;\n178\t    referrerCode: string | null;\n179\t    linkedAt: string | null;\n180\t  };\n181\t  outboundReferees: Array<{\n182\t    refereeUserId: string;\n183\t    refereeUsername: string | null;\n184\t    createdAt: string;\n185\t  }>;\n186\t  telegram: {\n187\t    state: \"active\" | \"none\";\n188\t    telegramUserId: string | null;\n189\t    telegramUsername: string | null;\n190\t  };\n191\t  linkedAccounts: ReadonlyArray<PeekLinkedAccountRow>;\n192\t  recentTelegramLinkTokens: ReadonlyArray<PeekTelegramLinkTokenRow>;\n193\t  kolRate: PeekKolRate | null;\n194\t  referralEarnings: PeekReferralEarningsSummary;\n195\t  recentReferralClaims: ReadonlyArray<PeekReferralClaimRow>;\n196\t  points: PeekPlayerPoints;\n197\t  recentPointGrants: ReadonlyArray<PeekPointGrantRow>;\n198\t  recentCrateDrops: ReadonlyArray<PeekCrateDropRow>;\n199\t  challengeSummary: PeekChallengeAssignmentSummary;\n200\t  recentGameEntries: ReadonlyArray<PeekGameEntryRow>;\n201\t  recentTransactions: ReadonlyArray<PeekTransactionRow>;\n202\t  fraudFlags: ReadonlyArray<PeekFraudFlagRow>;\n203\t  recentUserQueueEvents: ReadonlyArray<PeekUserQueueEventRow>;\n204\t  attention: PeekUserAttentionFlags;\n205\t};\n206\t\n207\t// --- Actor view model (browser-safe) -----------------------------------------\n208\t\n209\texport type PeekActorView = {\n210\t  email: string;\n211\t  role: PeekRole;\n212\t};\n213\t\n214\t// --- Metric metadata (FR-4) --------------------------------------------------\n215\t//\n216\t// Each metric carries the bookkeeping required by the data-surfacing standard:\n217\t// stable id, label, value, source table/query, time window, \"as of\" timestamp,\n218\t// short definition, optional unit, and optional drill-down link to the filtered\n219\t// detail rows behind the number.\n220\t\n221\texport type PeekMetricFreshness = \"live\" | \"cached\" | \"manual\" | \"sampled\";\n222\t\n223\texport type PeekMetric = {\n224\t  id: string;\n225\t  label: string;\n226\t  value: number | string | null;\n227\t  valueDisplay: string;\n228\t  unit: string | null;\n229\t  source: string;\n230\t  windowLabel: string;\n231\t  asOf: string | null;\n232\t  definition: string;\n233\t  freshness: PeekMetricFreshness;\n234\t  drilldownHref: string | null;\n235\t};\n236\t\n237\t// --- Pagination primitive ----------------------------------------------------\n238\t\n239\texport type PeekPagination = {\n240\t  page: number;\n241\t  pageSize: number;\n242\t  totalCount: number;\n243\t  totalPages: number;\n244\t};\n245\t\n246\t// --- Sort primitive ----------------------------------------------------------\n247\t\n248\texport type PeekSortDirection = \"asc\" | \"desc\";\n249\t\n250\texport type PeekTableSort = {\n251\t  column: string;\n252\t  direction: PeekSortDirection;\n253\t};\n254\t\n255\t// --- Table filter primitive (URL-addressable) --------------------------------\n256\t\n257\texport type PeekFilterKind =\n258\t  | \"text\"\n259\t  | \"select\"\n260\t  | \"boolean\"\n261\t  | \"date\"\n262\t  | \"dateRange\";\n263\t\n264\texport type PeekFilterOption = {\n265\t  value: string;\n266\t  label: string;\n267\t};\n268\t\n269\texport type PeekTableFilter = {\n270\t  id: string;\n271\t  label: string;\n272\t  kind: PeekFilterKind;\n273\t  value: string | null;\n274\t  options: ReadonlyArray<PeekFilterOption> | null;\n275\t  placeholder: string | null;\n276\t  required: boolean;\n277\t};\n278\t\n279\t// --- Status chip tone (shared) -----------------------------------------------\n280\t\n281\texport type PeekStatusTone =\n282\t  | \"neutral\"\n283\t  | \"positive\"\n284\t  | \"warning\"\n285\t  | \"negative\"\n286\t  | \"info\";\n287\t\n288\t// --- Empty-state primitive ---------------------------------------------------\n289\t\n290\texport type PeekEmptyState = {\n291\t  title: string;\n292\t  body: string | null;\n293\t};\n294\t\n295\t// --- Table row + column primitives -------------------------------------------\n296\t//\n297\t// Per-feature row types extend `PeekTableRowBase` for the shared identifier +\n298\t// optional drill-down link, then add feature-specific fields. The shared dense\n299\t// table component reads `columns` for layout and per-row data via the typed\n300\t// row shape supplied by the feature page.\n301\t\n302\texport type PeekTableColumnAlign = \"left\" | \"right\" | \"center\";\n303\t\n304\texport type PeekTableColumn = {\n305\t  id: string;\n306\t  label: string;\n307\t  align: PeekTableColumnAlign;\n308\t  sortable: boolean;\n309\t};\n310\t\n311\texport type PeekTableRowBase = {\n312\t  id: string;\n313\t  href: string | null;\n314\t};\n315\t\n316\texport type PeekTableViewModel<TRow extends PeekTableRowBase> = {\n317\t  columns: ReadonlyArray<PeekTableColumn>;\n318\t  rows: ReadonlyArray<TRow>;\n319\t  pagination: PeekPagination;\n320\t  filters: ReadonlyArray<PeekTableFilter>;\n321\t  sort: PeekTableSort | null;\n322\t  empty: PeekEmptyState;\n323\t};\n324\t\n325\t// --- Command-center attention queue (FR-3, FR-10) ----------------------------\n326\t//\n327\t// The command-center page surfaces a small set of \"needs attention\" metrics so\n328\t// operators see exception states (failed claims, dead queue events, stuck\n329\t// settlements, pending SOL crate payouts, stale active Dogpile events,\n330\t// high-value export activity) before they dig into per-feature pages. Each\n331\t// item is a `PeekMetric` so the metric-strip primitive renders it with the\n332\t// FR-4 bookkeeping (definition, source, time window, \"as of\", drill-down).\n333\t\n334\texport type PeekCommandCenterAttentionId =\n335\t  | \"failed_claims\"\n336\t  | \"dead_queue_events\"\n337\t  | \"stuck_rounds_flipyou_potshot\"\n338\t  | \"stuck_rounds_closecall\"\n339\t  | \"pending_sol_crate_payouts\"\n340\t  | \"stale_active_dogpile_events\"\n341\t  | \"high_value_exports_24h\";\n342\t\n343\texport type PeekCommandCenterAttention = {\n344\t  generatedAt: string;\n345\t  metrics: ReadonlyArray<PeekMetric>;\n346\t};\n347\t\n348\t// --- Recent operator activity (FR-3 command-center \"high-signal activity\") ---\n349\t//\n350\t// Compact projection of the latest `operator_events` rows for the command-center\n351\t// \"Recent activity\" section. Pulled from the same JSONB payload the audit\n352\t// writer persists, but kept narrow on purpose — the command center surfaces\n353\t// only the few fields needed to recognize what happened, not the full payload.\n354\t// The audit view (`/audit`, later iteration) renders the full bounded table.\n355\t\n356\texport type PeekRecentActivityItem = {\n357\t  id: string;\n358\t  eventType: string;\n359\t  actorEmail: string | null;\n360\t  resourceType: string | null;\n361\t  resourceId: string | null;\n362\t  route: string | null;\n363\t  createdAt: string;\n364\t};\n365\t\n366\t// --- Audit event contracts (FR-11) -------------------------------------------\n367\t//\n368\t// Browser-safe view of `operator_events` rows the audit writer produces under\n369\t// `peek.*` event types. The `PeekAuditPayload` shape pins the fields required by\n370\t// FR-11 so the writer (`peek/src/server/audit/**`, next iteration) and the audit\n371\t// view (`/audit`, later iteration) agree on a serialization contract. Secrets\n372\t// (JWTs, access tokens, DB URLs, private keys, raw secrets) must be replaced by\n373\t// `PEEK_AUDIT_REDACTED` before persisting; the audit-view component renders the\n374\t// token verbatim so reviewers can see that a field was redacted (not silently\n375\t// absent).\n376\t\n377\texport type PeekAuditEventType =\n378\t  | \"peek.search\"\n379\t  | \"peek.user.view_sensitive\"\n380\t  | \"peek.export\"\n381\t  | \"peek.access.denied\"\n382\t  | \"peek.change.applied\"\n383\t  | \"peek.change.rejected\";\n384\t\n385\texport const PEEK_AUDIT_EVENT_TYPES: ReadonlyArray<PeekAuditEventType> = [\n386\t  \"peek.search\",\n387\t  \"peek.user.view_sensitive\",\n388\t  \"peek.export\",\n389\t  \"peek.access.denied\",\n390\t  \"peek.change.applied\",\n391\t  \"peek.change.rejected\",\n392\t];\n393\t\n394\texport function isPeekAuditEventType(\n395\t  value: unknown,\n396\t): value is PeekAuditEventType {\n397\t  return (\n398\t    typeof value === \"string\" &&\n399\t    (PEEK_AUDIT_EVENT_TYPES as ReadonlyArray<string>).includes(value)\n400\t  );\n401\t}\n402\t\n403\texport const PEEK_AUDIT_REDACTED = \"[REDACTED]\";\n404\t\n405\texport type PeekAuditScalar = string | number | boolean | null;\n406\t\n407\texport type PeekAuditChange = {\n408\t  field: string;\n409\t  before: PeekAuditScalar;\n410\t  after: PeekAuditScalar;\n411\t};\n412\t\n413\texport type PeekAuditPayload = {\n414\t  actorEmail: string;\n415\t  route: string | null;\n416\t  actionId: string | null;\n417\t  resourceType: string | null;\n418\t  resourceId: string | null;\n419\t  filterSummary: string | null;\n420\t  resultCount: number | null;\n421\t  requestId: string | null;\n422\t  rejectionReason: string | null;\n423\t  changes: ReadonlyArray<PeekAuditChange> | null;\n424\t};\n425\t\n426\texport type PeekAuditEvent = {\n427\t  id: string;\n428\t  eventType: PeekAuditEventType;\n429\t  createdAt: string;\n430\t  payload: PeekAuditPayload;\n431\t};\n432\t\n433\t// --- Export contracts (FR-12) ------------------------------------------------\n434\t//\n435\t// Exports are server-rendered CSVs gated by the same page-level access as the\n436\t// source page, bounded by a server-side row cap, named with a deterministic\n437\t// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n438\t// bytes return. Export rows reuse the table view-model column ids so the export\n439\t// shape stays in lockstep with the rendered table; values are pre-formatted\n440\t// strings so CSV serialization stays straightforward and locale-stable.\n441\t\n442\texport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n443\t\n444\texport type PeekExportEntity =\n445\t  | \"users\"\n446\t  | \"referrers\"\n447\t  | \"kol\"\n448\t  | \"claims\"\n449\t  | \"rounds\"\n450\t  | \"transactions\"\n451\t  | \"queue\"\n452\t  | \"audit\";\n453\t\n454\texport type PeekExportRow = Record<string, string>;\n455\t\n456\texport type PeekExportFilenameInput = {\n457\t  entity: PeekExportEntity;\n458\t  date: string;\n459\t  filterSlug: string;\n460\t};\n461\t\n462\texport type PeekExportResult = {\n463\t  filename: string;\n464\t  rowCount: number;\n465\t  rowCap: number;\n466\t  rowCapApplied: boolean;\n467\t  columns: ReadonlyArray<PeekTableColumn>;\n468\t  rows: ReadonlyArray<PeekExportRow>;\n469\t};\n470\t\n471\t// --- Universal search (FR-5) -------------------------------------------------\n472\t//\n473\t// One search entry point that resolves common operational identifiers to typed\n474\t// result groups. Results are grouped by entity type so the UI can section them\n475\t// (user, referral, linked account, round, transaction, queue event). Each\n476\t// result includes enough context to disambiguate similar matches; sensitive\n477\t// values (wallet, Telegram id, tx signature) live in the result's `id`/`label`\n478\t// fields for operator readability and the audit event records only the actor\n479\t// email, query class, and result counts (never the raw query, which the audit\n480\t// writer redacts if it looks like a secret).\n481\t\n482\texport type PeekSearchEntityType =\n483\t  | \"user\"\n484\t  | \"referral\"\n485\t  | \"linked_account\"\n486\t  | \"round\"\n487\t  | \"transaction\"\n488\t  | \"queue_event\";\n489\t\n490\texport const PEEK_SEARCH_ENTITY_TYPES: ReadonlyArray<PeekSearchEntityType> = [\n491\t  \"user\",\n492\t  \"referral\",\n493\t  \"linked_account\",\n494\t  \"round\",\n495\t  \"transaction\",\n496\t  \"queue_event\",\n497\t];\n498\t\n499\t// Coarse heuristic classification used only for the `peek.search` audit\n500\t// summary so reviewers can see which class of identifier was searched without\n501\t// inferring it from the (possibly redacted) raw query.\n502\texport type PeekSearchQueryClass =\n503\t  | \"empty\"\n504\t  | \"free_text\"\n505\t  | \"user_id\"\n506\t  | \"username\"\n507\t  | \"wallet\"\n508\t  | \"referral_code\"\n509\t  | \"telegram_username\"\n510\t  | \"telegram_provider_id\"\n511\t  | \"round_pda\"\n512\t  | \"match_id\"\n513\t  | \"tx_signature\"\n514\t  | \"queue_event_id\";\n515\t\n516\texport type PeekSearchResult = {\n517\t  entityType: PeekSearchEntityType;\n518\t  id: string;\n519\t  label: string;\n520\t  sublabel: string | null;\n521\t  context: string | null;\n522\t  href: string;\n523\t};\n524\t\n525\texport type PeekSearchGroup = {\n526\t  entityType: PeekSearchEntityType;\n527\t  results: ReadonlyArray<PeekSearchResult>;\n528\t  truncated: boolean;\n529\t};\n530\t\n531\texport type PeekSearchResponse = {\n532\t  query: string;\n533\t  queryClass: PeekSearchQueryClass;\n534\t  groups: ReadonlyArray<PeekSearchGroup>;\n535\t  totalResults: number;\n536\t  perGroupLimit: number;\n537\t  generatedAt: string;\n538\t};\n539\t\n540\texport const PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT = 5;\n541\texport const PEEK_SEARCH_MAX_PER_GROUP_LIMIT = 25;\n542\t\n543\t// --- Growth + referral admin (FR-7) ------------------------------------------\n544\t//\n545\t// Browser-safe view models for `/growth/referrals` and `/growth/kol`. The\n546\t// engine queries surface (a) overview metrics that fit the FR-4 metric\n547\t// bookkeeping, (b) top-referrer rows that combine `referral_links`,\n548\t// `referral_codes`, `referral_earnings`, and pending `referral_claims` per\n549\t// referrer, (c) KOL rows that join `referral_kol_rates` with linked\n550\t// performance from `referral_links`/`referral_earnings`, (d) claim rows for\n551\t// the filterable `/growth/referrals` claims table, and (e) a one-hop\n552\t// referral-graph node that lets the UI navigate from a user-detail page to\n553\t// the inbound referrer or any outbound referee and back.\n554\t//\n555\t// All numeric/precision-sensitive values arrive as `text` to preserve u64\n556\t// lamport precision; the UI formats at render time.\n557\t\n558\texport type PeekGrowthOverviewMetricId =\n559\t  | \"growth.referrers\"\n560\t  | \"growth.referred_users\"\n561\t  | \"growth.activated_referred_users\"\n562\t  | \"growth.referrer_earnings_lamports\"\n563\t  | \"growth.referee_rebates_lamports\"\n564\t  | \"growth.pending_claims_lamports\"\n565\t  | \"growth.failed_claims\"\n566\t  | \"growth.kol_count\";\n567\t\n568\texport const PEEK_GROWTH_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekGrowthOverviewMetricId> =\n569\t  [\n570\t    \"growth.referrers\",\n571\t    \"growth.referred_users\",\n572\t    \"growth.activated_referred_users\",\n573\t    \"growth.referrer_earnings_lamports\",\n574\t    \"growth.referee_rebates_lamports\",\n575\t    \"growth.pending_claims_lamports\",\n576\t    \"growth.failed_claims\",\n577\t    \"growth.kol_count\",\n578\t  ];\n579\t\n580\texport type PeekGrowthOverview = {\n581\t  generatedAt: string;\n582\t  metrics: ReadonlyArray<PeekMetric>;\n583\t};\n584\t\n585\texport type PeekTopReferrerRow = {\n586\t  referrerUserId: string;\n587\t  username: string | null;\n588\t  wallet: string;\n589\t  referralCode: string | null;\n590\t  refereeCount: number;\n591\t  activeRefereeCount: number;\n592\t  referredWagerLamports: string;\n593\t  referrerEarnedLamports: string;\n594\t  pendingClaimLamports: string;\n595\t};\n596\t\n597\texport type PeekKolPerformanceRow = {\n598\t  userId: string;\n599\t  username: string | null;\n600\t  wallet: string;\n601\t  rateBps: number;\n602\t  setBy: string;\n603\t  createdAt: string;\n604\t  updatedAt: string;\n605\t  refereeCount: number;\n606\t  referredWagerLamports: string;\n607\t  referrerEarnedLamports: string;\n608\t};\n609\t\n610\t// Status filter values mirror the migration check constraint:\n611\t// 'pending' | 'processing' | 'error' | 'completed' | 'failed'. Treated as a\n612\t// loose `string` here so the UI can pass through a \"failed_or_error\" virtual\n613\t// alias without a contract change. Extends the per-user\n614\t// `PeekReferralClaimRow` with the `userId`/`username`/`wallet` columns the\n615\t// /growth/referrals claims table needs to render and link rows back to user\n616\t// detail.\n617\texport type PeekGrowthClaimRow = PeekReferralClaimRow & {\n618\t  userId: string;\n619\t  username: string | null;\n620\t  wallet: string;\n621\t};\n622\t\n623\texport type PeekReferralClaimFilters = {\n624\t  status: string | null;\n625\t  userId: string | null;\n626\t  minAmountLamports: string | null;\n627\t  maxAmountLamports: string | null;\n628\t  requestedFrom: string | null;\n629\t  requestedTo: string | null;\n630\t  txSignature: string | null;\n631\t  errorContains: string | null;\n632\t};\n633\t\n634\texport type PeekReferralGraphRefereeRow = {\n635\t  refereeUserId: string;\n636\t  refereeUsername: string | null;\n637\t  refereeWallet: string;\n638\t  createdAt: string;\n639\t};\n640\t\n641\texport type PeekReferralGraphInboundReferrer = {\n642\t  referrerUserId: string | null;\n643\t  referrerUsername: string | null;\n644\t  referrerWallet: string | null;\n645\t  referrerCode: string | null;\n646\t  linkedAt: string | null;\n647\t};\n648\t\n649\texport type PeekReferralGraphNode = {\n650\t  userId: string;\n651\t  username: string | null;\n652\t  wallet: string;\n653\t  referralCode: string | null;\n654\t  inboundReferrer: PeekReferralGraphInboundReferrer;\n655\t  outboundReferees: ReadonlyArray<PeekReferralGraphRefereeRow>;\n656\t};\n657\t\n658\t// --- Games overview (FR-8) ---------------------------------------------------\n659\t//\n660\t// Browser-safe view models for `/games`. The engine query reads the single\n661\t// source of truth `game_entries` (migration 007) and produces (a) a small set\n662\t// of platform-wide FR-4 metrics for the overview strip and (b) per-game rows\n663\t// with the operational counters the spec calls out: entries, unique users,\n664\t// wagered lamports, settled entries, refund entries, payout lamports, wins,\n665\t// losses. Lamport sums round-trip as `text` to preserve u64 precision; the UI\n666\t// formats at render time.\n667\t//\n668\t// `PeekGameId` mirrors the migration's CHECK constraint on `game_entries.game`\n669\t// (`'flipyou' | 'potshot' | 'closecall'`). Deferred games (Crash, Game of\n670\t// Trades, Chart the Course, Slots Utopia, Tug of Earn) are documented\n671\t// placeholders rendered by the page; they intentionally are not part of the\n672\t// data shape because they have no persisted source yet (system invariant 13).\n673\t\n674\texport type PeekGameId = \"flipyou\" | \"potshot\" | \"closecall\";\n675\t\n676\texport const PEEK_GAME_IDS: ReadonlyArray<PeekGameId> = [\n677\t  \"flipyou\",\n678\t  \"potshot\",\n679\t  \"closecall\",\n680\t];\n681\t\n682\texport type PeekGameOverviewRow = {\n683\t  game: PeekGameId;\n684\t  entries: number;\n685\t  uniqueUsers: number;\n686\t  wageredLamports: string;\n687\t  settledEntries: number;\n688\t  refundEntries: number;\n689\t  payoutLamports: string;\n690\t  wins: number;\n691\t  losses: number;\n692\t};\n693\t\n694\texport type PeekGameOverviewMetricId =\n695\t  | \"games.total_entries\"\n696\t  | \"games.unique_users\"\n697\t  | \"games.wagered_lamports\"\n698\t  | \"games.settled_entries\"\n699\t  | \"games.refund_entries\"\n700\t  | \"games.payout_lamports\";\n701\t\n702\texport const PEEK_GAME_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekGameOverviewMetricId> =\n703\t  [\n704\t    \"games.total_entries\",\n705\t    \"games.unique_users\",\n706\t    \"games.wagered_lamports\",\n707\t    \"games.settled_entries\",\n708\t    \"games.refund_entries\",\n709\t    \"games.payout_lamports\",\n710\t  ];\n711\t\n712\texport type PeekGameOverview = {\n713\t  generatedAt: string;\n714\t  metrics: ReadonlyArray<PeekMetric>;\n715\t  perGame: ReadonlyArray<PeekGameOverviewRow>;\n716\t};\n717\t"}]},"parent_tool_use_id":null,"session_id":"b796dedf-129f-4036-aac1-59555f53ee60","uuid":"a1d96437-bcc9-430a-916c-44b1b0faba78","timestamp":"2026-04-25T12:44:15.885Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","content":"// Browser-safe view-model primitives for `peek`.\n//\n// Foundational shapes used across feature pages: metric metadata (FR-4),\n// URL-addressable table filters, pagination, sort, and a small table-row base\n// type that per-feature row types can extend. Per-feature shapes (PeekUserRow,\n// PeekUserDetail, future referral/game/queue/etc. rows) live alongside or\n// extend these primitives.\n\nimport type { PeekRole } from \"../access-policy\";\n\n// --- Existing 303-era shapes (kept stable for current callers) ---------------\n\nexport type PeekSummary = {\n  totalUsers: number;\n  totalUsersWithCodes: number;\n  totalReferredUsers: number;\n  totalUniqueReferrers: number;\n};\n\nexport type PeekUserRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  joinedAt: string;\n  referralCode: string | null;\n  referrerUserId: string | null;\n  referrerCode: string | null;\n  refereeCount: number;\n  telegramUsername: string | null;\n  telegramUserId: string | null;\n};\n\n// --- Expanded user-detail shapes (FR-6) --------------------------------------\n//\n// Per-section row types for the full support/audit user profile. Lamports and\n// numeric/precision-sensitive values arrive as `text` to preserve precision; the\n// UI re-formats at render time. All shapes are browser-safe (no server imports).\n\nexport type PeekLinkedAccountRow = {\n  id: string;\n  provider: string;\n  providerAccountId: string;\n  status: string;\n  telegramUsername: string | null;\n  metadataJson: Record<string, unknown> | null;\n  linkedAt: string;\n  updatedAt: string;\n};\n\nexport type PeekTelegramLinkTokenRow = {\n  id: string;\n  status: string;\n  telegramUserId: string | null;\n  telegramUsername: string | null;\n  expiresAt: string;\n  redeemedAt: string | null;\n  createdAt: string;\n};\n\nexport type PeekKolRate = {\n  rateBps: number;\n  setBy: string;\n  createdAt: string;\n  updatedAt: string;\n};\n\nexport type PeekReferralEarningsSummary = {\n  earningsCount: number;\n  totalReferrerEarnedLamports: string;\n  totalRefereeRebateLamports: string;\n  lastEarnedAt: string | null;\n};\n\nexport type PeekReferralClaimRow = {\n  id: string;\n  amountLamports: string;\n  status: string;\n  retryCount: number;\n  txSignature: string | null;\n  error: string | null;\n  requestedAt: string;\n  processedAt: string | null;\n};\n\nexport type PeekPointGrantRow = {\n  id: string;\n  sourceType: string;\n  sourceId: string;\n  amount: string;\n  createdAt: string;\n};\n\nexport type PeekPlayerPoints = {\n  balance: string;\n  lifetimeEarned: string;\n  updatedAt: string | null;\n};\n\nexport type PeekCrateDropRow = {\n  id: string;\n  triggerType: string;\n  triggerId: string;\n  crateType: string;\n  contentsAmount: string;\n  status: string;\n  createdAt: string;\n  grantedAt: string | null;\n};\n\nexport type PeekChallengeAssignmentSummary = {\n  active: number;\n  completed: number;\n  expired: number;\n  total: number;\n};\n\nexport type PeekGameEntryRow = {\n  id: string;\n  game: string;\n  roundPda: string;\n  matchId: string;\n  amountLamports: string;\n  side: string | null;\n  isWinner: boolean | null;\n  payoutLamports: string;\n  createdAt: string;\n  settledAt: string | null;\n};\n\nexport type PeekTransactionRow = {\n  id: string;\n  game: string;\n  matchId: string;\n  txType: string;\n  amountLamports: string;\n  txSig: string;\n  createdAt: string;\n};\n\nexport type PeekFraudFlagRow = {\n  id: string;\n  flagType: string;\n  status: string;\n  relatedId: string | null;\n  createdAt: string;\n  resolvedAt: string | null;\n};\n\nexport type PeekUserQueueEventRow = {\n  id: string;\n  eventType: string;\n  status: string;\n  attempts: number;\n  maxAttempts: number;\n  scheduledAt: string;\n  createdAt: string;\n  error: string | null;\n};\n\nexport type PeekUserAttentionFlags = {\n  failedClaim: boolean;\n  deadQueueEvent: boolean;\n  activeFraudFlag: boolean;\n  pendingSolCratePayout: boolean;\n  suspiciousReferralLoop: boolean;\n};\n\nexport type PeekUserDetailUser = PeekUserRow & {\n  avatarUrl: string | null;\n  heatMultiplier: string;\n  profilePointsBalance: string;\n};\n\nexport type PeekUserDetail = {\n  user: PeekUserDetailUser;\n  inboundReferral: {\n    referrerUserId: string | null;\n    referrerCode: string | null;\n    linkedAt: string | null;\n  };\n  outboundReferees: Array<{\n    refereeUserId: string;\n    refereeUsername: string | null;\n    createdAt: string;\n  }>;\n  telegram: {\n    state: \"active\" | \"none\";\n    telegramUserId: string | null;\n    telegramUsername: string | null;\n  };\n  linkedAccounts: ReadonlyArray<PeekLinkedAccountRow>;\n  recentTelegramLinkTokens: ReadonlyArray<PeekTelegramLinkTokenRow>;\n  kolRate: PeekKolRate | null;\n  referralEarnings: PeekReferralEarningsSummary;\n  recentReferralClaims: ReadonlyArray<PeekReferralClaimRow>;\n  points: PeekPlayerPoints;\n  recentPointGrants: ReadonlyArray<PeekPointGrantRow>;\n  recentCrateDrops: ReadonlyArray<PeekCrateDropRow>;\n  challengeSummary: PeekChallengeAssignmentSummary;\n  recentGameEntries: ReadonlyArray<PeekGameEntryRow>;\n  recentTransactions: ReadonlyArray<PeekTransactionRow>;\n  fraudFlags: ReadonlyArray<PeekFraudFlagRow>;\n  recentUserQueueEvents: ReadonlyArray<PeekUserQueueEventRow>;\n  attention: PeekUserAttentionFlags;\n};\n\n// --- Actor view model (browser-safe) -----------------------------------------\n\nexport type PeekActorView = {\n  email: string;\n  role: PeekRole;\n};\n\n// --- Metric metadata (FR-4) --------------------------------------------------\n//\n// Each metric carries the bookkeeping required by the data-surfacing standard:\n// stable id, label, value, source table/query, time window, \"as of\" timestamp,\n// short definition, optional unit, and optional drill-down link to the filtered\n// detail rows behind the number.\n\nexport type PeekMetricFreshness = \"live\" | \"cached\" | \"manual\" | \"sampled\";\n\nexport type PeekMetric = {\n  id: string;\n  label: string;\n  value: number | string | null;\n  valueDisplay: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  asOf: string | null;\n  definition: string;\n  freshness: PeekMetricFreshness;\n  drilldownHref: string | null;\n};\n\n// --- Pagination primitive ----------------------------------------------------\n\nexport type PeekPagination = {\n  page: number;\n  pageSize: number;\n  totalCount: number;\n  totalPages: number;\n};\n\n// --- Sort primitive ----------------------------------------------------------\n\nexport type PeekSortDirection = \"asc\" | \"desc\";\n\nexport type PeekTableSort = {\n  column: string;\n  direction: PeekSortDirection;\n};\n\n// --- Table filter primitive (URL-addressable) --------------------------------\n\nexport type PeekFilterKind =\n  | \"text\"\n  | \"select\"\n  | \"boolean\"\n  | \"date\"\n  | \"dateRange\";\n\nexport type PeekFilterOption = {\n  value: string;\n  label: string;\n};\n\nexport type PeekTableFilter = {\n  id: string;\n  label: string;\n  kind: PeekFilterKind;\n  value: string | null;\n  options: ReadonlyArray<PeekFilterOption> | null;\n  placeholder: string | null;\n  required: boolean;\n};\n\n// --- Status chip tone (shared) -----------------------------------------------\n\nexport type PeekStatusTone =\n  | \"neutral\"\n  | \"positive\"\n  | \"warning\"\n  | \"negative\"\n  | \"info\";\n\n// --- Empty-state primitive ---------------------------------------------------\n\nexport type PeekEmptyState = {\n  title: string;\n  body: string | null;\n};\n\n// --- Table row + column primitives -------------------------------------------\n//\n// Per-feature row types extend `PeekTableRowBase` for the shared identifier +\n// optional drill-down link, then add feature-specific fields. The shared dense\n// table component reads `columns` for layout and per-row data via the typed\n// row shape supplied by the feature page.\n\nexport type PeekTableColumnAlign = \"left\" | \"right\" | \"center\";\n\nexport type PeekTableColumn = {\n  id: string;\n  label: string;\n  align: PeekTableColumnAlign;\n  sortable: boolean;\n};\n\nexport type PeekTableRowBase = {\n  id: string;\n  href: string | null;\n};\n\nexport type PeekTableViewModel<TRow extends PeekTableRowBase> = {\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<TRow>;\n  pagination: PeekPagination;\n  filters: ReadonlyArray<PeekTableFilter>;\n  sort: PeekTableSort | null;\n  empty: PeekEmptyState;\n};\n\n// --- Command-center attention queue (FR-3, FR-10) ----------------------------\n//\n// The command-center page surfaces a small set of \"needs attention\" metrics so\n// operators see exception states (failed claims, dead queue events, stuck\n// settlements, pending SOL crate payouts, stale active Dogpile events,\n// high-value export activity) before they dig into per-feature pages. Each\n// item is a `PeekMetric` so the metric-strip primitive renders it with the\n// FR-4 bookkeeping (definition, source, time window, \"as of\", drill-down).\n\nexport type PeekCommandCenterAttentionId =\n  | \"failed_claims\"\n  | \"dead_queue_events\"\n  | \"stuck_rounds_flipyou_potshot\"\n  | \"stuck_rounds_closecall\"\n  | \"pending_sol_crate_payouts\"\n  | \"stale_active_dogpile_events\"\n  | \"high_value_exports_24h\";\n\nexport type PeekCommandCenterAttention = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};\n\n// --- Recent operator activity (FR-3 command-center \"high-signal activity\") ---\n//\n// Compact projection of the latest `operator_events` rows for the command-center\n// \"Recent activity\" section. Pulled from the same JSONB payload the audit\n// writer persists, but kept narrow on purpose — the command center surfaces\n// only the few fields needed to recognize what happened, not the full payload.\n// The audit view (`/audit`, later iteration) renders the full bounded table.\n\nexport type PeekRecentActivityItem = {\n  id: string;\n  eventType: string;\n  actorEmail: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  route: string | null;\n  createdAt: string;\n};\n\n// --- Audit event contracts (FR-11) -------------------------------------------\n//\n// Browser-safe view of `operator_events` rows the audit writer produces under\n// `peek.*` event types. The `PeekAuditPayload` shape pins the fields required by\n// FR-11 so the writer (`peek/src/server/audit/**`, next iteration) and the audit\n// view (`/audit`, later iteration) agree on a serialization contract. Secrets\n// (JWTs, access tokens, DB URLs, private keys, raw secrets) must be replaced by\n// `PEEK_AUDIT_REDACTED` before persisting; the audit-view component renders the\n// token verbatim so reviewers can see that a field was redacted (not silently\n// absent).\n\nexport type PeekAuditEventType =\n  | \"peek.search\"\n  | \"peek.user.view_sensitive\"\n  | \"peek.export\"\n  | \"peek.access.denied\"\n  | \"peek.change.applied\"\n  | \"peek.change.rejected\";\n\nexport const PEEK_AUDIT_EVENT_TYPES: ReadonlyArray<PeekAuditEventType> = [\n  \"peek.search\",\n  \"peek.user.view_sensitive\",\n  \"peek.export\",\n  \"peek.access.denied\",\n  \"peek.change.applied\",\n  \"peek.change.rejected\",\n];\n\nexport function isPeekAuditEventType(\n  value: unknown,\n): value is PeekAuditEventType {\n  return (\n    typeof value === \"string\" &&\n    (PEEK_AUDIT_EVENT_TYPES as ReadonlyArray<string>).includes(value)\n  );\n}\n\nexport const PEEK_AUDIT_REDACTED = \"[REDACTED]\";\n\nexport type PeekAuditScalar = string | number | boolean | null;\n\nexport type PeekAuditChange = {\n  field: string;\n  before: PeekAuditScalar;\n  after: PeekAuditScalar;\n};\n\nexport type PeekAuditPayload = {\n  actorEmail: string;\n  route: string | null;\n  actionId: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  filterSummary: string | null;\n  resultCount: number | null;\n  requestId: string | null;\n  rejectionReason: string | null;\n  changes: ReadonlyArray<PeekAuditChange> | null;\n};\n\nexport type PeekAuditEvent = {\n  id: string;\n  eventType: PeekAuditEventType;\n  createdAt: string;\n  payload: PeekAuditPayload;\n};\n\n// --- Export contracts (FR-12) ------------------------------------------------\n//\n// Exports are server-rendered CSVs gated by the same page-level access as the\n// source page, bounded by a server-side row cap, named with a deterministic\n// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n// bytes return. Export rows reuse the table view-model column ids so the export\n// shape stays in lockstep with the rendered table; values are pre-formatted\n// strings so CSV serialization stays straightforward and locale-stable.\n\nexport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n\nexport type PeekExportEntity =\n  | \"users\"\n  | \"referrers\"\n  | \"kol\"\n  | \"claims\"\n  | \"rounds\"\n  | \"transactions\"\n  | \"queue\"\n  | \"audit\";\n\nexport type PeekExportRow = Record<string, string>;\n\nexport type PeekExportFilenameInput = {\n  entity: PeekExportEntity;\n  date: string;\n  filterSlug: string;\n};\n\nexport type PeekExportResult = {\n  filename: string;\n  rowCount: number;\n  rowCap: number;\n  rowCapApplied: boolean;\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<PeekExportRow>;\n};\n\n// --- Universal search (FR-5) -------------------------------------------------\n//\n// One search entry point that resolves common operational identifiers to typed\n// result groups. Results are grouped by entity type so the UI can section them\n// (user, referral, linked account, round, transaction, queue event). Each\n// result includes enough context to disambiguate similar matches; sensitive\n// values (wallet, Telegram id, tx signature) live in the result's `id`/`label`\n// fields for operator readability and the audit event records only the actor\n// email, query class, and result counts (never the raw query, which the audit\n// writer redacts if it looks like a secret).\n\nexport type PeekSearchEntityType =\n  | \"user\"\n  | \"referral\"\n  | \"linked_account\"\n  | \"round\"\n  | \"transaction\"\n  | \"queue_event\";\n\nexport const PEEK_SEARCH_ENTITY_TYPES: ReadonlyArray<PeekSearchEntityType> = [\n  \"user\",\n  \"referral\",\n  \"linked_account\",\n  \"round\",\n  \"transaction\",\n  \"queue_event\",\n];\n\n// Coarse heuristic classification used only for the `peek.search` audit\n// summary so reviewers can see which class of identifier was searched without\n// inferring it from the (possibly redacted) raw query.\nexport type PeekSearchQueryClass =\n  | \"empty\"\n  | \"free_text\"\n  | \"user_id\"\n  | \"username\"\n  | \"wallet\"\n  | \"referral_code\"\n  | \"telegram_username\"\n  | \"telegram_provider_id\"\n  | \"round_pda\"\n  | \"match_id\"\n  | \"tx_signature\"\n  | \"queue_event_id\";\n\nexport type PeekSearchResult = {\n  entityType: PeekSearchEntityType;\n  id: string;\n  label: string;\n  sublabel: string | null;\n  context: string | null;\n  href: string;\n};\n\nexport type PeekSearchGroup = {\n  entityType: PeekSearchEntityType;\n  results: ReadonlyArray<PeekSearchResult>;\n  truncated: boolean;\n};\n\nexport type PeekSearchResponse = {\n  query: string;\n  queryClass: PeekSearchQueryClass;\n  groups: ReadonlyArray<PeekSearchGroup>;\n  totalResults: number;\n  perGroupLimit: number;\n  generatedAt: string;\n};\n\nexport const PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT = 5;\nexport const PEEK_SEARCH_MAX_PER_GROUP_LIMIT = 25;\n\n// --- Growth + referral admin (FR-7) ------------------------------------------\n//\n// Browser-safe view models for `/growth/referrals` and `/growth/kol`. The\n// engine queries surface (a) overview metrics that fit the FR-4 metric\n// bookkeeping, (b) top-referrer rows that combine `referral_links`,\n// `referral_codes`, `referral_earnings`, and pending `referral_claims` per\n// referrer, (c) KOL rows that join `referral_kol_rates` with linked\n// performance from `referral_links`/`referral_earnings`, (d) claim rows for\n// the filterable `/growth/referrals` claims table, and (e) a one-hop\n// referral-graph node that lets the UI navigate from a user-detail page to\n// the inbound referrer or any outbound referee and back.\n//\n// All numeric/precision-sensitive values arrive as `text` to preserve u64\n// lamport precision; the UI formats at render time.\n\nexport type PeekGrowthOverviewMetricId =\n  | \"growth.referrers\"\n  | \"growth.referred_users\"\n  | \"growth.activated_referred_users\"\n  | \"growth.referrer_earnings_lamports\"\n  | \"growth.referee_rebates_lamports\"\n  | \"growth.pending_claims_lamports\"\n  | \"growth.failed_claims\"\n  | \"growth.kol_count\";\n\nexport const PEEK_GROWTH_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekGrowthOverviewMetricId> =\n  [\n    \"growth.referrers\",\n    \"growth.referred_users\",\n    \"growth.activated_referred_users\",\n    \"growth.referrer_earnings_lamports\",\n    \"growth.referee_rebates_lamports\",\n    \"growth.pending_claims_lamports\",\n    \"growth.failed_claims\",\n    \"growth.kol_count\",\n  ];\n\nexport type PeekGrowthOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};\n\nexport type PeekTopReferrerRow = {\n  referrerUserId: string;\n  username: string | null;\n  wallet: string;\n  referralCode: string | null;\n  refereeCount: number;\n  activeRefereeCount: number;\n  referredWagerLamports: string;\n  referrerEarnedLamports: string;\n  pendingClaimLamports: string;\n};\n\nexport type PeekKolPerformanceRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  rateBps: number;\n  setBy: string;\n  createdAt: string;\n  updatedAt: string;\n  refereeCount: number;\n  referredWagerLamports: string;\n  referrerEarnedLamports: string;\n};\n\n// Status filter values mirror the migration check constraint:\n// 'pending' | 'processing' | 'error' | 'completed' | 'failed'. Treated as a\n// loose `string` here so the UI can pass through a \"failed_or_error\" virtual\n// alias without a contract change. Extends the per-user\n// `PeekReferralClaimRow` with the `userId`/`username`/`wallet` columns the\n// /growth/referrals claims table needs to render and link rows back to user\n// detail.\nexport type PeekGrowthClaimRow = PeekReferralClaimRow & {\n  userId: string;\n  username: string | null;\n  wallet: string;\n};\n\nexport type PeekReferralClaimFilters = {\n  status: string | null;\n  userId: string | null;\n  minAmountLamports: string | null;\n  maxAmountLamports: string | null;\n  requestedFrom: string | null;\n  requestedTo: string | null;\n  txSignature: string | null;\n  errorContains: string | null;\n};\n\nexport type PeekReferralGraphRefereeRow = {\n  refereeUserId: string;\n  refereeUsername: string | null;\n  refereeWallet: string;\n  createdAt: string;\n};\n\nexport type PeekReferralGraphInboundReferrer = {\n  referrerUserId: string | null;\n  referrerUsername: string | null;\n  referrerWallet: string | null;\n  referrerCode: string | null;\n  linkedAt: string | null;\n};\n\nexport type PeekReferralGraphNode = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  referralCode: string | null;\n  inboundReferrer: PeekReferralGraphInboundReferrer;\n  outboundReferees: ReadonlyArray<PeekReferralGraphRefereeRow>;\n};\n\n// --- Games overview (FR-8) ---------------------------------------------------\n//\n// Browser-safe view models for `/games`. The engine query reads the single\n// source of truth `game_entries` (migration 007) and produces (a) a small set\n// of platform-wide FR-4 metrics for the overview strip and (b) per-game rows\n// with the operational counters the spec calls out: entries, unique users,\n// wagered lamports, settled entries, refund entries, payout lamports, wins,\n// losses. Lamport sums round-trip as `text` to preserve u64 precision; the UI\n// formats at render time.\n//\n// `PeekGameId` mirrors the migration's CHECK constraint on `game_entries.game`\n// (`'flipyou' | 'potshot' | 'closecall'`). Deferred games (Crash, Game of\n// Trades, Chart the Course, Slots Utopia, Tug of Earn) are documented\n// placeholders rendered by the page; they intentionally are not part of the\n// data shape because they have no persisted source yet (system invariant 13).\n\nexport type PeekGameId = \"flipyou\" | \"potshot\" | \"closecall\";\n\nexport const PEEK_GAME_IDS: ReadonlyArray<PeekGameId> = [\n  \"flipyou\",\n  \"potshot\",\n  \"closecall\",\n];\n\nexport type PeekGameOverviewRow = {\n  game: PeekGameId;\n  entries: number;\n  uniqueUsers: number;\n  wageredLamports: string;\n  settledEntries: number;\n  refundEntries: number;\n  payoutLamports: string;\n  wins: number;\n  losses: number;\n};\n\nexport type PeekGameOverviewMetricId =\n  | \"games.total_entries\"\n  | \"games.unique_users\"\n  | \"games.wagered_lamports\"\n  | \"games.settled_entries\"\n  | \"games.refund_entries\"\n  | \"games.payout_lamports\";\n\nexport const PEEK_GAME_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekGameOverviewMetricId> =\n  [\n    \"games.total_entries\",\n    \"games.unique_users\",\n    \"games.wagered_lamports\",\n    \"games.settled_entries\",\n    \"games.refund_entries\",\n    \"games.payout_lamports\",\n  ];\n\nexport type PeekGameOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n  perGame: ReadonlyArray<PeekGameOverviewRow>;\n};\n","numLines":717,"startLine":1,"totalLines":717}}}
