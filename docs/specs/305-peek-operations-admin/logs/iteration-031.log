{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01CqVM3s3EBngmL6cBRnsess","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01MEy64epSV4Apj1mSKFfzHT","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/games-overview-table.tsx","content":"// Per-game overview table for /games (FR-8).\n//\n// Dense readonly table over `PeekGameOverviewRow` showing the operational\n// counters the spec calls out: entries, unique users, wagered lamports,\n// settled entries, refund entries, payout lamports, wins, losses. Lamport\n// columns are right-aligned and grouped with thousands separators; counts use\n// integer formatting per FR-4.\nimport type { CSSProperties } from \"react\";\nimport type { PeekGameId, PeekGameOverviewRow } from \"../lib/types/peek\";\n\nexport type GamesOverviewTableProps = {\n  rows: ReadonlyArray<PeekGameOverviewRow>;\n  error?: string | null;\n};\n\nconst GAME_LABELS: Record<PeekGameId, string> = {\n  flipyou: \"FlipYou\",\n  potshot: \"Pot Shot\",\n  closecall: \"Close Call\",\n};\n\nexport function GamesOverviewTable({\n  rows,\n  error = null,\n}: GamesOverviewTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Per-game activity unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No game activity recorded.</p>\n        <p style={emptyBodyStyle}>\n          `game_entries` is empty, so no per-game counters can be rendered.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Game</th>\n            <th style={headerCellStyle(\"right\")}>Entries</th>\n            <th style={headerCellStyle(\"right\")}>Unique users</th>\n            <th style={headerCellStyle(\"right\")}>Wagered (lamports)</th>\n            <th style={headerCellStyle(\"right\")}>Settled</th>\n            <th style={headerCellStyle(\"right\")}>Refunds</th>\n            <th style={headerCellStyle(\"right\")}>Paid out (lamports)</th>\n            <th style={headerCellStyle(\"right\")}>Wins</th>\n            <th style={headerCellStyle(\"right\")}>Losses</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.game} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>\n                <span style={gameLabelStyle}>{GAME_LABELS[row.game]}</span>\n                <span style={subValueStyle}> · {row.game}</span>\n              </td>\n              <td style={bodyCellStyle(\"right\")}>{formatCount(row.entries)}</td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatCount(row.uniqueUsers)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatLamports(row.wageredLamports)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatCount(row.settledEntries)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatCount(row.refundEntries)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatLamports(row.payoutLamports)}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>{formatCount(row.wins)}</td>\n              <td style={bodyCellStyle(\"right\")}>{formatCount(row.losses)}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction formatCount(value: number): string {\n  return value.toLocaleString(\"en-US\");\n}\n\nfunction formatLamports(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst gameLabelStyle: CSSProperties = {\n  color: \"#e2e8f0\",\n  fontWeight: 600,\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n  marginLeft: \"0.25rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1061,"cache_read_input_tokens":98460,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_toke