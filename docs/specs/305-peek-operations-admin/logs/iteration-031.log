{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PECq6FJfhuxEb98xppckpN","type":"tool_result","content":"1\timport Link from \"next/link\";\n2\timport type { CSSProperties } from \"react\";\n3\timport type { PeekMetric } from \"../lib/types/peek\";\n4\t\n5\texport type MetricStripProps = {\n6\t  metrics: ReadonlyArray<PeekMetric>;\n7\t  error?: string | null;\n8\t};\n9\t\n10\texport function MetricStrip({ metrics, error = null }: MetricStripProps) {\n11\t  if (error) {\n12\t    return (\n13\t      <div role=\"alert\" style={errorStyle}>\n14\t        Metrics unavailable: {error}\n15\t      </div>\n16\t    );\n17\t  }\n18\t\n19\t  if (metrics.length === 0) {\n20\t    return (\n21\t      <div role=\"status\" style={emptyStyle}>\n22\t        No metrics available for this view.\n23\t      </div>\n24\t    );\n25\t  }\n26\t\n27\t  return (\n28\t    <section\n29\t      aria-label=\"Metric strip\"\n30\t      style={{\n31\t        display: \"grid\",\n32\t        gap: \"1rem\",\n33\t        gridTemplateColumns: \"repeat(auto-fit, minmax(220px, 1fr))\",\n34\t      }}\n35\t    >\n36\t      {metrics.map((metric) => (\n37\t        <article key={metric.id} aria-labelledby={`peek-metric-${metric.id}-label`} style={cardStyle}>\n38\t          <header style={cardHeaderStyle}>\n39\t            <p id={`peek-metric-${metric.id}-label`} style={labelStyle}>\n40\t              {metric.label}\n41\t            </p>\n42\t            <span style={freshnessStyle(metric.freshness)} title={`Freshness: ${metric.freshness}`}>\n43\t              {metric.freshness}\n44\t            </span>\n45\t          </header>\n46\t          <p style={valueStyle}>\n47\t            {metric.valueDisplay}\n48\t            {metric.unit ? <span style={unitStyle}> {metric.unit}</span> : null}\n49\t          </p>\n50\t          <p style={definitionStyle}>{metric.definition}</p>\n51\t          <dl style={metaStyle}>\n52\t            <div style={metaRowStyle}>\n53\t              <dt style={metaTermStyle}>Source</dt>\n54\t              <dd style={metaValueStyle}>{metric.source}</dd>\n55\t            </div>\n56\t            <div style={metaRowStyle}>\n57\t              <dt style={metaTermStyle}>Window</dt>\n58\t              <dd style={metaValueStyle}>{metric.windowLabel}</dd>\n59\t            </div>\n60\t            <div style={metaRowStyle}>\n61\t              <dt style={metaTermStyle}>As of</dt>\n62\t              <dd style={metaValueStyle}>{metric.asOf ?? \"—\"}</dd>\n63\t            </div>\n64\t          </dl>\n65\t          {metric.drilldownHref ? (\n66\t            <Link href={metric.drilldownHref} style={drilldownStyle}>\n67\t              View rows →\n68\t            </Link>\n69\t          ) : null}\n70\t        </article>\n71\t      ))}\n72\t    </section>\n73\t  );\n74\t}\n75\t\n76\tconst cardStyle: CSSProperties = {\n77\t  border: \"1px solid #1e293b\",\n78\t  borderRadius: \"0.75rem\",\n79\t  padding: \"1rem\",\n80\t  background: \"#111827\",\n81\t  display: \"grid\",\n82\t  gap: \"0.5rem\",\n83\t};\n84\t\n85\tconst cardHeaderStyle: CSSProperties = {\n86\t  display: \"flex\",\n87\t  alignItems: \"center\",\n88\t  justifyContent: \"space-between\",\n89\t  gap: \"0.5rem\",\n90\t};\n91\t\n92\tconst labelStyle: CSSProperties = {\n93\t  margin: 0,\n94\t  color: \"#94a3b8\",\n95\t  fontSize: \"0.875rem\",\n96\t  fontWeight: 600,\n97\t};\n98\t\n99\tconst valueStyle: CSSProperties = {\n100\t  margin: 0,\n101\t  fontSize: \"1.75rem\",\n102\t  fontWeight: 700,\n103\t};\n104\t\n105\tconst unitStyle: CSSProperties = {\n106\t  fontSize: \"0.875rem\",\n107\t  fontWeight: 500,\n108\t  color: \"#94a3b8\",\n109\t  marginLeft: \"0.25rem\",\n110\t};\n111\t\n112\tconst definitionStyle: CSSProperties = {\n113\t  margin: 0,\n114\t  fontSize: \"0.8125rem\",\n115\t  color: \"#cbd5f5\",\n116\t};\n117\t\n118\tconst metaStyle: CSSProperties = {\n119\t  margin: 0,\n120\t  display: \"grid\",\n121\t  gap: \"0.25rem\",\n122\t};\n123\t\n124\tconst metaRowStyle: CSSProperties = {\n125\t  display: \"flex\",\n126\t  justifyContent: \"space-between\",\n127\t  fontSize: \"0.75rem\",\n128\t  color: \"#94a3b8\",\n129\t};\n130\t\n131\tconst metaTermStyle: CSSProperties = {\n132\t  margin: 0,\n133\t};\n134\t\n135\tconst metaValueStyle: CSSProperties = {\n136\t  margin: 0,\n137\t  textAlign: \"right\",\n138\t};\n139\t\n140\tconst drilldownStyle: CSSProperties = {\n141\t  fontSize: \"0.8125rem\",\n142\t  color: \"#93c5fd\",\n143\t  textDecoration: \"none\",\n144\t};\n145\t\n146\tfunction freshnessStyle(freshness: PeekMetric[\"freshness\"]): CSSProperties {\n147\t  const tones: Record<PeekMetric[\"freshness\"], { background: string; color: string }> = {\n148\t    live: { background: \"#064e3b\", color: \"#a7f3d0\" },\n149\t    cached: { background: \"#1f2937\", color: \"#cbd5f5\" },\n150\t    manual: { background: \"#3f3f46\", color: \"#fde68a\" },\n151\t    sampled: { background: \"#312e81\", color: \"#c7d2fe\" },\n152\t  };\n153\t  const tone = tones[freshness];\n154\t  return {\n155\t    fontSize: \"0.6875rem\",\n156\t    textTransform: \"uppercase\",\n157\t    letterSpacing: \"0.05em\",\n158\t    padding: \"0.125rem 0.5rem\",\n159\t    borderRadius: \"9999px\",\n160\t    background: tone.background,\n161\t    color: tone.color,\n162\t  };\n163\t}\n164\t\n165\tconst errorStyle: CSSProperties = {\n166\t  margin: 0,\n167\t  padding: \"0.75rem 1rem\",\n168\t  borderRadius: \"0.75rem\",\n169\t  background: \"#3f1d1d\",\n170\t  color: \"#fecaca\",\n171\t};\n172\t\n173\tconst emptyStyle: CSSProperties = {\n174\t  padding: \"1rem\",\n175\t  borderRadius: \"0.75rem\",\n176\t  border: \"1px solid #1e293b\",\n177\t  background: \"#0b1220\",\n178\t  color: \"#94a3b8\",\n179\t  fontSize: \"0.875rem\",\n180\t};\n181\t"}]},"parent_tool_use_id":null,"session_id":"b796dedf-129f-4036-aac1-59555f53ee60","uuid":"700dba37-3e58-4080-acf3-4854054b4157","timestamp":"2026-04-25T12:44:19.339Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/metric-strip.tsx","content":"import Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type { PeekMetric } from \"../lib/types/peek\";\n\nexport type MetricStripProps = {\n  metrics: ReadonlyArray<PeekMetric>;\n  error?: string | null;\n};\n\nexport function MetricStrip({ metrics, error = null }: MetricStripProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Metrics unavailable: {error}\n      </div>\n    );\n  }\n\n  if (metrics.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        No metrics available for this view.\n      </div>\n    );\n  }\n\n  return (\n    <section\n      aria-label=\"Metric strip\"\n      style={{\n        display: \"grid\",\n        gap: \"1rem\",\n        gridTemplateColumns: \"repeat(auto-fit, minmax(220px, 1fr))\",\n      }}\n    >\n      {metrics.map((metric) => (\n        <article key={metric.id} aria-labelledby={`peek-metric-${metric.id}-label`} style={cardStyle}>\n          <header style={cardHeaderStyle}>\n            <p id={`peek-metric-${metric.id}-label`} style={labelStyle}>\n              {metric.label}\n            </p>\n            <span style={freshnessStyle(metric.freshness)} title={`Freshness: ${metric.freshness}`}>\n              {metric.freshness}\n            </span>\n          </header>\n          <p style={valueStyle}>\n            {metric.valueDisplay}\n            {metric.unit ? <span style={unitStyle}> {metric.unit}</span> : null}\n          </p>\n          <p style={definitionStyle}>{metric.definition}</p>\n          <dl style={metaStyle}>\n            <div style={metaRowStyle}>\n              <dt style={metaTermStyle}>Source</dt>\n              <dd style={metaValueStyle}>{metric.source}</dd>\n            </div>\n            <div style={metaRowStyle}>\n              <dt style={metaTermStyle}>Window</dt>\n              <dd style={metaValueStyle}>{metric.windowLabel}</dd>\n            </div>\n            <div style={metaRowStyle}>\n              <dt style={metaTermStyle}>As of</dt>\n              <dd style={metaValueStyle}>{metric.asOf ?? \"—\"}</dd>\n            </div>\n          </dl>\n          {metric.drilldownHref ? (\n            <Link href={metric.drilldownHref} style={drilldownStyle}>\n              View rows →\n            </Link>\n          ) : null}\n        </article>\n      ))}\n    </section>\n  );\n}\n\nconst cardStyle: CSSProperties = {\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n  padding: \"1rem\",\n  background: \"#111827\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst cardHeaderStyle: CSSProperties = {\n  display: \"flex\",\n  alignItems: \"center\",\n  justifyContent: \"space-between\",\n  gap: \"0.5rem\",\n};\n\nconst labelStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.875rem\",\n  fontWeight: 600,\n};\n\nconst valueStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1.75rem\",\n  fontWeight: 700,\n};\n\nconst unitStyle: CSSProperties = {\n  fontSize: \"0.875rem\",\n  fontWeight: 500,\n  color: \"#94a3b8\",\n  marginLeft: \"0.25rem\",\n};\n\nconst definitionStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.8125rem\",\n  color: \"#cbd5f5\",\n};\n\nconst metaStyle: CSSProperties = {\n  margin: 0,\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst metaRowStyle: CSSProperties = {\n  display: \"flex\",\n  justifyContent: \"space-between\",\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n};\n\nconst metaTermStyle: CSSProperties = {\n  margin: 0,\n};\n\nconst metaValueStyle: CSSProperties = {\n  margin: 0,\n  textAlign: \"right\",\n};\n\nconst drilldownStyle: CSSProperties = {\n  fontSize: \"0.8125rem\",\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nfunction freshnessStyle(freshness: PeekMetric[\"freshness\"]): CSSProperties {\n  const tones: Record<PeekMetric[\"freshness\"], { background: string; color: string }> = {\n    live: { background: \"#064e3b\", color: \"#a7f3d0\" },\n    cached: { background: \"#1f2937\", color: \"#cbd5f5\" },\n    manual: { background: \"#3f3f46\", color: \"#fde68a\" },\n    sampled: { background: \"#312e81\", color: \"#c7d2fe\" },\n  };\n  const tone = tones[freshness];\n  return {\n    fontSize: \"0.6875rem\",\n    textTransform: \"uppercase\",\n    letterSpacing: \"0.05em\",\n    padding: \"0.125rem 0.5rem\",\n    borderRadius: \"9999px\",\n    background: tone.background,\n    color: tone.color,\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px solid #1e293b\",\n  background: \"#0b1220\",\n  color: \"#94a3b8\",\n  fontSize: \"0.875rem\",\n};\n","numLines":181,"startLine":1,"totalLines":181}}}
