n      <section\n        aria-labelledby=\"claims-heading\"\n        id=\"claims\"\n        style={sectionStyle}\n      >\n        <h2 id=\"claims-heading\" style={sectionHeadingStyle}>\n          Referral claims\n        </h2>\n        <p style={hintStyle}>\n          Filterable by status, user, amount, requested date, tx signature, and\n          error text. URL-addressable so internal investigations can be shared.\n        </p>\n        <GrowthClaimsFilterBar filters={filters} action={ROUTE} />\n        <GrowthClaimsTable rows={claims} error={claimsError} />\n      </section>\n    </main>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n","numLines":178,"startLine":1,"totalLines":178}}}
