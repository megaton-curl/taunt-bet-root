{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017ufyGFwuiH3j9iZW6UcHRm","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport type { Sql } from \"postgres\";\n3\timport {\n4\t  RECENT_OPERATOR_EVENTS_DEFAULT_LIMIT,\n5\t  RECENT_OPERATOR_EVENTS_MAX_LIMIT,\n6\t  getRecentOperatorEvents,\n7\t} from \"../get-recent-operator-events\";\n8\t\n9\ttype SqlCall = {\n10\t  text: string;\n11\t  values: ReadonlyArray<unknown>;\n12\t};\n13\t\n14\ttype Row = {\n15\t  id: string;\n16\t  eventType: string;\n17\t  actorEmail: string | null;\n18\t  resourceType: string | null;\n19\t  resourceId: string | null;\n20\t  route: string | null;\n21\t  createdAt: string;\n22\t};\n23\t\n24\ttype Response = ReadonlyArray<Row> | Error;\n25\t\n26\ttype SqlMock = {\n27\t  sql: Sql;\n28\t  calls: ReadonlyArray<SqlCall>;\n29\t};\n30\t\n31\tfunction createSqlMock(response: Response): SqlMock {\n32\t  const calls: SqlCall[] = [];\n33\t  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n34\t    const text = [...strings].join(\"?\");\n35\t    calls.push({ text, values: [...values] });\n36\t    if (response instanceof Error) return Promise.reject(response);\n37\t    return Promise.resolve(response);\n38\t  };\n39\t  const sql = fn as unknown as Sql;\n40\t  return { sql, calls };\n41\t}\n42\t\n43\tdescribe(\"getRecentOperatorEvents\", () => {\n44\t  it(\"populated: shapes rows into PeekRecentActivityItem and preserves order\", async () => {\n45\t    const mock = createSqlMock([\n46\t      {\n47\t        id: \"1\",\n48\t        eventType: \"peek.user.view_sensitive\",\n49\t        actorEmail: \"alice@example.com\",\n50\t        resourceType: \"user\",\n51\t        resourceId: \"u-1\",\n52\t        route: \"/users/u-1\",\n53\t        createdAt: \"2026-04-25T10:00:00.000Z\",\n54\t      },\n55\t      {\n56\t        id: \"2\",\n57\t        eventType: \"peek.export\",\n58\t        actorEmail: \"biz@example.com\",\n59\t        resourceType: \"export\",\n60\t        resourceId: null,\n61\t        route: \"/growth/referrals/export\",\n62\t        createdAt: \"2026-04-25T09:55:00.000Z\",\n63\t      },\n64\t    ]);\n65\t\n66\t    const items = await getRecentOperatorEvents({ sql: mock.sql });\n67\t\n68\t    expect(items).toHaveLength(2);\n69\t    expect(items[0].id).toBe(\"1\");\n70\t    expect(items[0].eventType).toBe(\"peek.user.view_sensitive\");\n71\t    expect(items[0].actorEmail).toBe(\"alice@example.com\");\n72\t    expect(items[0].resourceType).toBe(\"user\");\n73\t    expect(items[0].resourceId).toBe(\"u-1\");\n74\t    expect(items[0].route).toBe(\"/users/u-1\");\n75\t    expect(items[0].createdAt).toBe(\"2026-04-25T10:00:00.000Z\");\n76\t    expect(items[1].resourceId).toBeNull();\n77\t  });\n78\t\n79\t  it(\"populated: defaults the limit to RECENT_OPERATOR_EVENTS_DEFAULT_LIMIT\", async () => {\n80\t    const mock = createSqlMock([]);\n81\t\n82\t    await getRecentOperatorEvents({ sql: mock.sql });\n83\t\n84\t    expect(mock.calls).toHaveLength(1);\n85\t    expect(mock.calls[0].values).toContain(\n86\t      RECENT_OPERATOR_EVENTS_DEFAULT_LIMIT,\n87\t    );\n88\t  });\n89\t\n90\t  it(\"limit clamp: oversized limits clamp down to RECENT_OPERATOR_EVENTS_MAX_LIMIT\", async () => {\n91\t    const mock = createSqlMock([]);\n92\t\n93\t    await getRecentOperatorEvents({ sql: mock.sql, limit: 9999 });\n94\t\n95\t    expect(mock.calls[0].values).toContain(RECENT_OPERATOR_EVENTS_MAX_LIMIT);\n96\t    expect(mock.calls[0].values).not.toContain(9999);\n97\t  });\n98\t\n99\t  it(\"limit clamp: zero/negative limits clamp up to 1 so the query stays bounded but useful\", async () => {\n100\t    const mockZero = createSqlMock([]);\n101\t    await getRecentOperatorEvents({ sql: mockZero.sql, limit: 0 });\n102\t    expect(mockZero.calls[0].values).toContain(1);\n103\t\n104\t    const mockNeg = createSqlMock([]);\n105\t    await getRecentOperatorEvents({ sql: mockNeg.sql, limit: -5 });\n106\t    expect(mockNeg.calls[0].values).toContain(1);\n107\t  });\n108\t\n109\t  it(\"limit clamp: fractional limits floor to an integer before applying the bound\", async () => {\n110\t    const mock = createSqlMock([]);\n111\t\n112\t    await getRecentOperatorEvents({ sql: mock.sql, limit: 7.9 });\n113\t\n114\t    expect(mock.calls[0].values).toContain(7);\n115\t    expect(mock.calls[0].values).not.toContain(7.9);\n116\t  });\n117\t\n118\t  it(\"empty: returns [] when the table has no rows\", async () => {\n119\t    const mock = createSqlMock([]);\n120\t\n121\t    const items = await getRecentOperatorEvents({ sql: mock.sql });\n122\t\n123\t    expect(items).toEqual([]);\n124\t  });\n125\t\n126\t  it(\"query: orders by created_at desc and projects the activity columns\", async () => {\n127\t    const mock = createSqlMock([]);\n128\t\n129\t    await getRecentOperatorEvents({ sql: mock.sql });\n130\t\n131\t    const text = mock.calls[0].text;\n132\t    expect(text).toMatch(/from operator_events/i);\n133\t    expect(text).toMatch(/order by created_at desc/i);\n134\t    expect(text).toMatch(/payload->>'actorEmail'/);\n135\t    expect(text).toMatch(/payload->>'resourceType'/);\n136\t    expect(text).toMatch(/payload->>'resourceId'/);\n137\t    expect(text).toMatch(/payload->>'route'/);\n138\t  });\n139\t\n140\t  it(\"load-error: a rejected query propagates so the page-level try/catch can render the alert\", async () => {\n141\t    const mock = createSqlMock(new Error(\"connection refused\"));\n142\t\n143\t    await expect(\n144\t      getRecentOperatorEvents({ sql: mock.sql }),\n145\t    ).rejects.toThrowError(\"connection refused\");\n146\t  });\n147\t});\n148\t"}]},"parent_tool_use_id":null,"session_id":"d4d72e16-a61e-41f5-8f09-281d33e306cd","uuid":"8ce1d834-6509-4f04-9efa-c85ec0dabe35","timestamp":"2026-04-25T11:41:25.994Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-recent-operator-events.test.ts","content":"import { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  RECENT_OPERATOR_EVENTS_DEFAULT_LIMIT,\n  RECENT_OPERATOR_EVENTS_MAX_LIMIT,\n  getRecentOperatorEvents,\n} from \"../get-recent-operator-events\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype Row = {\n  id: string;\n  eventType: string;\n  actorEmail: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  route: string | null;\n  createdAt: string;\n};\n\ntype Response = ReadonlyArray<Row> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\nfunction createSqlMock(response: Response): SqlMock {\n  const calls: SqlCall[] = [];\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    if (response instanceof Error) return Promise.reject(response);\n    return Promise.resolve(response);\n  };\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\ndescribe(\"getRecentOperatorEvents\", () => {\n  it(\"populated: shapes rows into PeekRecentActivityItem and preserves order\", async () => {\n    const mock = createSqlMock([\n      {\n        id: \"1\",\n        eventType: \"peek.user.view_sensitive\",\n        actorEmail: \"alice@example.com\",\n        resourceType: \"user\",\n        resourceId: \"u-1\",\n        route: \"/users/u-1\",\n        createdAt: \"2026-04-25T10:00:00.000Z\",\n      },\n      {\n        id: \"2\",\n        eventType: \"peek.export\",\n        actorEmail: \"biz@example.com\",\n        resourceType: \"export\",\n        resourceId: null,\n        route: \"/growth/referrals/export\",\n        createdAt: \"2026-04-25T09:55:00.000Z\",\n      },\n    ]);\n\n    const items = await getRecentOperatorEvents({ sql: mock.sql });\n\n    expect(items).toHaveLength(2);\n    expect(items[0].id).toBe(\"1\");\n    expect(items[0].eventType).toBe(\"peek.user.view_sensitive\");\n    expect(items[0].actorEmail).toBe(\"alice@example.com\");\n    expect(items[0].resourceType).toBe(\"user\");\n    expect(items[0].resourceId).toBe(\"u-1\");\n    expect(items[0].route).toBe(\"/users/u-1\");\n    expect(items[0].createdAt).toBe(\"2026-04-25T10:00:00.000Z\");\n    expect(items[1].resourceId).toBeNull();\n  });\n\n  it(\"populated: defaults the limit to RECENT_OPERATOR_EVENTS_DEFAULT_LIMIT\", async () => {\n    const mock = createSqlMock([]);\n\n    await getRecentOperatorEvents({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    expect(mock.calls[0].values).toContain(\n      RECENT_OPERATOR_EVENTS_DEFAULT_LIMIT,\n    );\n  });\n\n  it(\"limit clamp: oversized limits clamp down to RECENT_OPERATOR_EVENTS_MAX_LIMIT\", async () => {\n    const mock = createSqlMock([]);\n\n    await getRecentOperatorEvents({ sql: mock.sql, limit: 9999 });\n\n    expect(mock.calls[0].values).toContain(RECENT_OPERATOR_EVENTS_MAX_LIMIT);\n    expect(mock.calls[0].values).not.toContain(9999);\n  });\n\n  it(\"limit clamp: zero/negative limits clamp up to 1 so the query stays bounded but useful\", async () => {\n    const mockZero = createSqlMock([]);\n    await getRecentOperatorEvents({ sql: mockZero.sql, limit: 0 });\n    expect(mockZero.calls[0].values).toContain(1);\n\n    const mockNeg = createSqlMock([]);\n    await getRecentOperatorEvents({ sql: mockNeg.sql, limit: -5 });\n    expect(mockNeg.calls[0].values).toContain(1);\n  });\n\n  it(\"limit clamp: fractional limits floor to an integer before applying the bound\", async () => {\n    const mock = createSqlMock([]);\n\n    await getRecentOperatorEvents({ sql: mock.sql, limit: 7.9 });\n\n    expect(mock.calls[0].values).toContain(7);\n    expect(mock.calls[0].values).not.toContain(7.9);\n  });\n\n  it(\"empty: returns [] when the table has no rows\", async () => {\n    const mock = createSqlMock([]);\n\n    const items = await getRecentOperatorEvents({ sql: mock.sql });\n\n    expect(items).toEqual([]);\n  });\n\n  it(\"query: orders by created_at desc and projects the activity columns\", async () => {\n    const mock = createSqlMock([]);\n\n    await getRecentOperatorEvents({ sql: mock.sql });\n\n    const text = mock.calls[0].text;\n    expect(text).toMatch(/from operator_events/i);\n    expect(text).toMatch(/order by created_at desc/i);\n    expect(text).toMatch(/payload->>'actorEmail'/);\n    expect(text).toMatch(/payload->>'resourceType'/);\n    expect(text).toMatch(/payload->>'resourceId'/);\n    expect(text).toMatch(/payload->>'route'/);\n  });\n\n  it(\"load-error: a rejected query propagates so the page-level try/catch can render the alert\", async () => {\n    const mock = createSqlMock(new Error(\"connection refused\"));\n\n    await expect(\n      getRecentOperatorEvents({ sql: mock.sql }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n});\n","numLines":148,"startLine":1,"totalLines":148}}}
