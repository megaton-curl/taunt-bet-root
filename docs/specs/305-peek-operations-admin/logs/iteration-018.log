{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GroppM6pQL4am1Xp9hdqB3","type":"tool_result","content":"1\t// Recent operator events query (FR-3 command-center \"high-signal activity\").\n2\t//\n3\t// Returns the latest N rows from `operator_events`, projecting only the fields\n4\t// the command-center \"Recent activity\" list renders. Bounded — never returns\n5\t// more than `MAX_LIMIT` rows even if a caller passes a larger limit. The audit\n6\t// page (later iteration) is the place for filtered, paginated audit browsing;\n7\t// this query exists only for the dense home-page activity strip.\n8\t\n9\timport type { Sql } from \"postgres\";\n10\timport type { PeekRecentActivityItem } from \"../../../lib/types/peek\";\n11\timport { getSqlClient } from \"../client\";\n12\t\n13\texport const RECENT_OPERATOR_EVENTS_DEFAULT_LIMIT = 10;\n14\texport const RECENT_OPERATOR_EVENTS_MAX_LIMIT = 50;\n15\t\n16\texport type RecentOperatorEventsOptions = {\n17\t  sql?: Sql;\n18\t  limit?: number;\n19\t};\n20\t\n21\ttype RecentOperatorEventRow = {\n22\t  id: string;\n23\t  eventType: string;\n24\t  actorEmail: string | null;\n25\t  resourceType: string | null;\n26\t  resourceId: string | null;\n27\t  route: string | null;\n28\t  createdAt: string;\n29\t};\n30\t\n31\texport async function getRecentOperatorEvents(\n32\t  options: RecentOperatorEventsOptions = {},\n33\t): Promise<PeekRecentActivityItem[]> {\n34\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n35\t  const requestedLimit = options.limit ?? RECENT_OPERATOR_EVENTS_DEFAULT_LIMIT;\n36\t  const limit = Math.max(\n37\t    1,\n38\t    Math.min(RECENT_OPERATOR_EVENTS_MAX_LIMIT, Math.floor(requestedLimit)),\n39\t  );\n40\t\n41\t  const rows = await sql<RecentOperatorEventRow[]>`\n42\t    select\n43\t      id::text as \"id\",\n44\t      event_type as \"eventType\",\n45\t      payload->>'actorEmail' as \"actorEmail\",\n46\t      payload->>'resourceType' as \"resourceType\",\n47\t      payload->>'resourceId' as \"resourceId\",\n48\t      payload->>'route' as \"route\",\n49\t      created_at::text as \"createdAt\"\n50\t    from operator_events\n51\t    order by created_at desc\n52\t    limit ${limit}\n53\t  `;\n54\t\n55\t  return rows.map((row) => ({\n56\t    id: row.id,\n57\t    eventType: row.eventType,\n58\t    actorEmail: row.actorEmail,\n59\t    resourceType: row.resourceType,\n60\t    resourceId: row.resourceId,\n61\t    route: row.route,\n62\t    createdAt: row.createdAt,\n63\t  }));\n64\t}\n65\t"}]},"parent_tool_use_id":null,"session_id":"d4d72e16-a61e-41f5-8f09-281d33e306cd","uuid":"180fd8b4-b352-4f0b-9922-9d6a95d1dfd9","timestamp":"2026-04-25T11:41:52.687Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-recent-operator-events.ts","content":"// Recent operator events query (FR-3 command-center \"high-signal activity\").\n//\n// Returns the latest N rows from `operator_events`, projecting only the fields\n// the command-center \"Recent activity\" list renders. Bounded — never returns\n// more than `MAX_LIMIT` rows even if a caller passes a larger limit. The audit\n// page (later iteration) is the place for filtered, paginated audit browsing;\n// this query exists only for the dense home-page activity strip.\n\nimport type { Sql } from \"postgres\";\nimport type { PeekRecentActivityItem } from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport const RECENT_OPERATOR_EVENTS_DEFAULT_LIMIT = 10;\nexport const RECENT_OPERATOR_EVENTS_MAX_LIMIT = 50;\n\nexport type RecentOperatorEventsOptions = {\n  sql?: Sql;\n  limit?: number;\n};\n\ntype RecentOperatorEventRow = {\n  id: string;\n  eventType: string;\n  actorEmail: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  route: string | null;\n  createdAt: string;\n};\n\nexport async function getRecentOperatorEvents(\n  options: RecentOperatorEventsOptions = {},\n): Promise<PeekRecentActivityItem[]> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const requestedLimit = options.limit ?? RECENT_OPERATOR_EVENTS_DEFAULT_LIMIT;\n  const limit = Math.max(\n    1,\n    Math.min(RECENT_OPERATOR_EVENTS_MAX_LIMIT, Math.floor(requestedLimit)),\n  );\n\n  const rows = await sql<RecentOperatorEventRow[]>`\n    select\n      id::text as \"id\",\n      event_type as \"eventType\",\n      payload->>'actorEmail' as \"actorEmail\",\n      payload->>'resourceType' as \"resourceType\",\n      payload->>'resourceId' as \"resourceId\",\n      payload->>'route' as \"route\",\n      created_at::text as \"createdAt\"\n    from operator_events\n    order by created_at desc\n    limit ${limit}\n  `;\n\n  return rows.map((row) => ({\n    id: row.id,\n    eventType: row.eventType,\n    actorEmail: row.actorEmail,\n    resourceType: row.resourceType,\n    resourceId: row.resourceId,\n    route: row.route,\n    createdAt: row.createdAt,\n  }));\n}\n","numLines":65,"startLine":1,"totalLines":65}}}
