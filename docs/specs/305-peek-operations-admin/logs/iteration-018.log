{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0176naH6eotPSQk3fUwTWSLY","type":"tool_result","content":"The file /workspaces/rng-utopia/peek/src/server/db/queries/__tests__/universal-search.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"d4d72e16-a61e-41f5-8f09-281d33e306cd","uuid":"132f476f-585c-4510-8879-8f25bf202ade","timestamp":"2026-04-25T11:46:20.449Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/universal-search.test.ts","oldString":"  it(\"tx_signature identifier (long base58): classifies tx_signature and shapes the transaction row\", async () => {\n    const mock = createSqlMock([\n      [],\n      [],\n      [],\n      [],\n      [],\n      [\n        {\n          id: \"1\",\n          txSig:\n            \"5VfYDnXUcS6mWY3cQy4ipcM5LQqM4XV4nHe89oLQGn7awgJZpF8aWxa9HXP15GgyCcXWXP1aTH8qzuc5whTvP3Da\",\n          game: \"potshot\",\n          matchId: \"deadbeefdeadbeef\",\n          txType: \"join\",\n          wallet: \"WalletA\",\n          amountLamports: \"26000000\",\n          createdAt: \"2026-04-24T00:00:00.000Z\",\n        },\n      ],\n    ]);","newString":"  it(\"tx_signature identifier (long base58): classifies tx_signature and shapes the transaction row\", async () => {\n    // Non-numeric → 6 calls. Transactions is at index 4.\n    const mock = createSqlMock([\n      [],\n      [],\n      [],\n      [],\n      [\n        {\n          id: \"1\",\n          txSig:\n            \"5VfYDnXUcS6mWY3cQy4ipcM5LQqM4XV4nHe89oLQGn7awgJZpF8aWxa9HXP15GgyCcXWXP1aTH8qzuc5whTvP3Da\",\n          game: \"potshot\",\n          matchId: \"deadbeefdeadbeef\",\n          txType: \"join\",\n          wallet: \"WalletA\",\n          amountLamports: \"26000000\",\n          createdAt: \"2026-04-24T00:00:00.000Z\",\n        },\n      ],\n      [],\n    ]);","originalFile":"import { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT,\n  PEEK_SEARCH_MAX_PER_GROUP_LIMIT,\n  PEEK_SEARCH_ENTITY_TYPES,\n  type PeekSearchEntityType,\n  type PeekSearchQueryClass,\n} from \"../../../../lib/types/peek\";\nimport {\n  classifyPeekSearchQuery,\n  getUniversalSearchResults,\n} from \"../universal-search\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\n// Build a SQL mock that returns a sequence of responses, one per call. The\n// universal search runs every entity-class query in parallel via Promise.all.\n// All six search functions kick off synchronously so the *first* SQL call\n// from each fires in declaration order (users, referrals, linked, rounds\n// flipPot, transactions, queueEvents — numeric only). Then microtasks resume\n// the searchRounds continuation which fires the second `await sql` against\n// closecall_rounds. So a non-numeric query produces 6 mock calls in the\n// order: users(0) → referrals(1) → linked(2) → flipPot(3) → transactions(4)\n// → closeCall(5). A numeric query produces 7 calls: users(0) → referrals(1)\n// → linked(2) → flipPot(3) → transactions(4) → queueEvents(5) → closeCall(6).\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\nconst EMPTY_SIX = [[], [], [], [], [], []] as ReadonlyArray<ResponseValue>;\nconst EMPTY_SEVEN = [[], [], [], [], [], [], []] as ReadonlyArray<ResponseValue>;\n\ndescribe(\"classifyPeekSearchQuery\", () => {\n  // Every supported PeekSearchQueryClass label gets at least one positive case\n  // so the audit-summary string can be reasoned about deterministically.\n  const cases: Array<[string, PeekSearchQueryClass]> = [\n    [\"\", \"empty\"],\n    [\"   \", \"empty\"],\n    [\"just some words\", \"free_text\"],\n    [\n      \"11111111-1111-1111-1111-111111111111\",\n      \"free_text\", // UUIDs go to free_text per the heuristic comment\n    ],\n    [\"12345\", \"queue_event_id\"],\n    [\"1234567890123456789\", \"telegram_provider_id\"], // 19 digits > 18\n    [\"abcdef0123456789\", \"match_id\"], // 16-char hex\n    [\n      \"5tWqN7ykNWtXesjaGCu3JoGvU2STNUP6axQjqfA\",\n      \"round_pda\", // 39 base58 chars in [32,44]\n    ],\n    [\n      \"5VfYDnXUcS6mWY3cQy4ipcM5LQqM4XV4nHe89oLQGn7awgJZpF8aWxa9HXP15GgyCcXWXP1aTH8qzuc5whTvP3Da\",\n      \"tx_signature\", // ≥80 base58 chars\n    ],\n    [\"@operator\", \"telegram_username\"],\n    [\"KOL2026\", \"referral_code\"],\n    [\"alice_99\", \"username\"],\n  ];\n\n  it.each(cases)(\"%j classifies as %s\", (input, expected) => {\n    expect(classifyPeekSearchQuery(input)).toBe(expected);\n  });\n\n  it(\"strips a leading @ before classification but still labels as telegram_username when text remains\", () => {\n    expect(classifyPeekSearchQuery(\"@alice_99\")).toBe(\"telegram_username\");\n  });\n});\n\ndescribe(\"getUniversalSearchResults\", () => {\n  it(\"empty query: short-circuits, no SQL calls, returns empty groups for every entity type\", async () => {\n    const mock = createSqlMock([]);\n\n    const response = await getUniversalSearchResults({\n      query: \"   \",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(mock.calls).toHaveLength(0);\n    expect(response.totalResults).toBe(0);\n    expect(response.queryClass).toBe(\"empty\");\n    expect(response.query).toBe(\"\");\n    expect(response.groups).toHaveLength(PEEK_SEARCH_ENTITY_TYPES.length);\n    expect(response.groups.map((g) => g.entityType)).toEqual([\n      ...PEEK_SEARCH_ENTITY_TYPES,\n    ]);\n    for (const group of response.groups) {\n      expect(group.results).toEqual([]);\n      expect(group.truncated).toBe(false);\n    }\n    expect(response.perGroupLimit).toBe(PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT);\n  });\n\n  it(\"user identifier (user_id-shaped): shapes player_profiles row into a user group result\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          userId: \"u-123\",\n          username: \"alice\",\n          wallet: \"Wallet111\",\n          joinedAt: \"2026-04-01T00:00:00.000Z\",\n        },\n      ],\n      ...EMPTY_SIX.slice(1),\n    ]);\n\n    const response = await getUniversalSearchResults({\n      query: \"u-123\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      audit: null,\n    });\n\n    const userGroup = response.groups.find((g) => g.entityType === \"user\");\n    expect(userGroup?.results).toHaveLength(1);\n    const result = userGroup?.results[0];\n    expect(result?.id).toBe(\"u-123\");\n    expect(result?.label).toBe(\"alice\");\n    expect(result?.sublabel).toBe(\"Wallet111\");\n    expect(result?.context).toBe(\"joined 2026-04-01T00:00:00.000Z\");\n    expect(result?.href).toBe(\"/users/u-123\");\n    expect(response.totalResults).toBe(1);\n  });\n\n  it(\"referral_code identifier: shapes referral_codes row into a referral group result\", async () => {\n    const mock = createSqlMock([\n      [],\n      [{ code: \"KOL2026\", userId: \"u-7\", wallet: \"Wallet777\" }],\n      [],\n      [],\n      [],\n      [],\n    ]);\n\n    const response = await getUniversalSearchResults({\n      query: \"KOL2026\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(response.queryClass).toBe(\"referral_code\");\n    const ref = response.groups.find((g) => g.entityType === \"referral\");\n    expect(ref?.results).toHaveLength(1);\n    expect(ref?.results[0].id).toBe(\"KOL2026\");\n    expect(ref?.results[0].label).toBe(\"KOL2026\");\n    expect(ref?.results[0].sublabel).toBe(\"u-7\");\n    expect(ref?.results[0].context).toBe(\"wallet Wallet777\");\n    expect(ref?.results[0].href).toBe(\"/users/u-7\");\n  });\n\n  it(\"telegram_username identifier: strips the leading @ and labels with @username when present\", async () => {\n    const mock = createSqlMock([\n      [],\n      [],\n      [\n        {\n          userId: \"u-42\",\n          provider: \"telegram\",\n          providerAccountId: \"987654\",\n          telegramUsername: \"operator\",\n          status: \"active\",\n        },\n      ],\n      [],\n      [],\n      [],\n    ]);\n\n    const response = await getUniversalSearchResults({\n      query: \"@operator\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(response.queryClass).toBe(\"telegram_username\");\n    const linked = response.groups.find((g) => g.entityType === \"linked_account\");\n    expect(linked?.results[0].label).toBe(\"@operator\");\n    expect(linked?.results[0].id).toBe(\"telegram:987654\");\n    expect(linked?.results[0].sublabel).toBe(\"u-42\");\n    expect(linked?.results[0].context).toBe(\"telegram (active)\");\n    expect(linked?.results[0].href).toBe(\"/users/u-42\");\n\n    // The trimmed query (without @) is what gets bound to the SQL exact-match\n    // and ILIKE predicates — never the raw `@operator` string.\n    const linkedCall = mock.calls[2];\n    expect(linkedCall.values).toContain(\"operator\");\n    expect(linkedCall.values).not.toContain(\"@operator\");\n  });\n\n  it(\"telegram_provider_id identifier: long-numeric resolves through linked_accounts.provider_account_id\", async () => {\n    const mock = createSqlMock([\n      [],\n      [],\n      [\n        {\n          userId: \"u-9\",\n          provider: \"telegram\",\n          providerAccountId: \"1234567890123456789\",\n          telegramUsername: null,\n          status: \"active\",\n        },\n      ],\n      [],\n      [],\n      [],\n      [], // queueEvents fires for numeric queries\n    ]);\n\n    const response = await getUniversalSearchResults({\n      query: \"1234567890123456789\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(response.queryClass).toBe(\"telegram_provider_id\");\n    const linked = response.groups.find((g) => g.entityType === \"linked_account\");\n    // Falls back to the providerAccountId display when telegramUsername is null.\n    expect(linked?.results[0].label).toBe(\"1234567890123456789\");\n  });\n\n  it(\"round identifier (PDA-shaped): merges flipyou/potshot rounds + closecall_rounds into the round group\", async () => {\n    const flipPot = [\n      {\n        pda: \"Pda1111\",\n        game: \"flipyou\",\n        matchId: \"abcdef0123456789\",\n        phase: \"settling\",\n        creator: \"WalletCreator\",\n      },\n    ];\n    const closeCall = [\n      {\n        pda: \"Pda2222\",\n        game: \"closecall\",\n        matchId: \"1717171717171717\",\n        phase: \"open\",\n        creator: null,\n      },\n    ];\n    // Order: users(0) → referrals(1) → linked(2) → flipPot(3) →\n    // transactions(4) → closeCall(5).\n    const mock = createSqlMock([\n      [],\n      [],\n      [],\n      flipPot,\n      [],\n      closeCall,\n    ]);\n\n    const response = await getUniversalSearchResults({\n      query: \"5tWqN7ykNWtXesjaGCu3JoGvU2STNUP6axQjqfA\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(response.queryClass).toBe(\"round_pda\");\n    const rounds = response.groups.find((g) => g.entityType === \"round\");\n    expect(rounds?.results).toHaveLength(2);\n    const flip = rounds?.results.find((r) => r.id === \"Pda1111\");\n    expect(flip?.label).toBe(\"abcdef0123456789\");\n    expect(flip?.sublabel).toBe(\"flipyou • settling\");\n    expect(flip?.context).toBe(\"creator WalletCreator\");\n    expect(flip?.href).toBe(\"/games/flipyou/rounds/Pda1111\");\n    const cc = rounds?.results.find((r) => r.id === \"Pda2222\");\n    expect(cc?.sublabel).toBe(\"closecall • open\");\n    expect(cc?.context).toBeNull();\n    expect(cc?.href).toBe(\"/games/closecall/rounds/Pda2222\");\n  });\n\n  it(\"match_id identifier (16-char hex): classifies as match_id and runs a transactions lookup\", async () => {\n    // Non-numeric, so 6 calls. Transactions is at index 4.\n    const mock = createSqlMock([\n      [],\n      [],\n      [],\n      [],\n      [\n        {\n          id: \"42\",\n          txSig: \"Sig123\",\n          game: \"flipyou\",\n          matchId: \"abcdef0123456789\",\n          txType: \"settle\",\n          wallet: \"WalletPlayer\",\n          amountLamports: \"1000000\",\n          createdAt: \"2026-04-25T08:00:00.000Z\",\n        },\n      ],\n      [],\n    ]);\n\n    const response = await getUniversalSearchResults({\n      query: \"abcdef0123456789\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(response.queryClass).toBe(\"match_id\");\n    const tx = response.groups.find((g) => g.entityType === \"transaction\");\n    expect(tx?.results).toHaveLength(1);\n    expect(tx?.results[0].label).toBe(\"Sig123\");\n    expect(tx?.results[0].sublabel).toBe(\"flipyou • settle\");\n    expect(tx?.results[0].context).toBe(\"wallet WalletPlayer • 1000000 lamports\");\n    expect(tx?.results[0].href).toBe(\n      \"/games/flipyou/rounds/abcdef0123456789\",\n    );\n  });\n\n  it(\"tx_signature identifier (long base58): classifies tx_signature and shapes the transaction row\", async () => {\n    const mock = createSqlMock([\n      [],\n      [],\n      [],\n      [],\n      [],\n      [\n        {\n          id: \"1\",\n          txSig:\n            \"5VfYDnXUcS6mWY3cQy4ipcM5LQqM4XV4nHe89oLQGn7awgJZpF8aWxa9HXP15GgyCcXWXP1aTH8qzuc5whTvP3Da\",\n          game: \"potshot\",\n          matchId: \"deadbeefdeadbeef\",\n          txType: \"join\",\n          wallet: \"WalletA\",\n          amountLamports: \"26000000\",\n          createdAt: \"2026-04-24T00:00:00.000Z\",\n        },\n      ],\n    ]);\n\n    const response = await getUniversalSearchResults({\n      query:\n        \"5VfYDnXUcS6mWY3cQy4ipcM5LQqM4XV4nHe89oLQGn7awgJZpF8aWxa9HXP15GgyCcXWXP1aTH8qzuc5whTvP3Da\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(response.queryClass).toBe(\"tx_signature\");\n    const tx = response.groups.find((g) => g.entityType === \"transaction\");\n    expect(tx?.results).toHaveLength(1);\n    expect(tx?.results[0].sublabel).toBe(\"potshot • join\");\n  });\n\n  it(\"queue_event_id identifier (short numeric): only fires the queue lookup for numeric queries and shapes the row\", async () => {\n    const mock = createSqlMock([\n      [],\n      [],\n      [],\n      [],\n      [],\n      [],\n      [\n        {\n          id: \"777\",\n          eventType: \"claim.process\",\n          status: \"failed\",\n          attempts: 3,\n          scheduledAt: \"2026-04-25T07:30:00.000Z\",\n        },\n      ],\n    ]);\n\n    const response = await getUniversalSearchResults({\n      query: \"777\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(response.queryClass).toBe(\"queue_event_id\");\n    const qe = response.groups.find((g) => g.entityType === \"queue_event\");\n    expect(qe?.results).toHaveLength(1);\n    expect(qe?.results[0].id).toBe(\"777\");\n    expect(qe?.results[0].label).toBe(\"#777\");\n    expect(qe?.results[0].sublabel).toBe(\"claim.process • failed\");\n    expect(qe?.results[0].context).toBe(\"attempts 3 • scheduled 2026-04-25T07:30:00.000Z\");\n    expect(qe?.results[0].href).toBe(\"/operations/queue?id=777\");\n    // Seven SQL calls = six entity classes + queue events (numeric branch).\n    expect(mock.calls).toHaveLength(7);\n  });\n\n  it(\"non-numeric query: skips the queue_event lookup entirely\", async () => {\n    const mock = createSqlMock(EMPTY_SIX);\n\n    await getUniversalSearchResults({\n      query: \"alice_99\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      audit: null,\n    });\n\n    // Six calls — searchQueueEvents short-circuits without hitting SQL.\n    expect(mock.calls).toHaveLength(6);\n    for (const call of mock.calls) {\n      expect(call.text).not.toMatch(/from event_queue/i);\n    }\n  });\n\n  it(\"no-result behavior: empty rows in every entity class produce zero totalResults but every group still appears\", async () => {\n    const mock = createSqlMock(EMPTY_SEVEN);\n\n    const response = await getUniversalSearchResults({\n      query: \"777\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(response.totalResults).toBe(0);\n    expect(response.groups).toHaveLength(PEEK_SEARCH_ENTITY_TYPES.length);\n    for (const group of response.groups) {\n      expect(group.results).toEqual([]);\n      expect(group.truncated).toBe(false);\n    }\n  });\n\n  it(\"bounded query: every entity-class SQL emits a LIMIT clause bound to perGroupLimit + 1\", async () => {\n    const mock = createSqlMock(EMPTY_SEVEN);\n\n    await getUniversalSearchResults({\n      query: \"777\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(mock.calls.length).toBeGreaterThan(0);\n    for (const call of mock.calls) {\n      expect(call.text).toMatch(/limit\\s+\\?/i);\n      // The function passes `limit + 1` so it can detect truncation.\n      const expected = PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT + 1;\n      expect(call.values).toContain(expected);\n    }\n  });\n\n  it(\"bounded query: a custom perGroupLimit binds limit+1 to every SQL call\", async () => {\n    const mock = createSqlMock(EMPTY_SIX);\n\n    await getUniversalSearchResults({\n      query: \"alice_99\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      perGroupLimit: 3,\n      audit: null,\n    });\n\n    for (const call of mock.calls) {\n      expect(call.values).toContain(4);\n    }\n  });\n\n  it(\"bounded query: oversized perGroupLimit clamps down to PEEK_SEARCH_MAX_PER_GROUP_LIMIT\", async () => {\n    const mock = createSqlMock(EMPTY_SIX);\n\n    const response = await getUniversalSearchResults({\n      query: \"alice_99\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      perGroupLimit: 9999,\n      audit: null,\n    });\n\n    expect(response.perGroupLimit).toBe(PEEK_SEARCH_MAX_PER_GROUP_LIMIT);\n    for (const call of mock.calls) {\n      expect(call.values).toContain(PEEK_SEARCH_MAX_PER_GROUP_LIMIT + 1);\n    }\n  });\n\n  it(\"bounded query: zero or negative perGroupLimit clamps up to 1 so the query stays bounded but useful\", async () => {\n    const mockZero = createSqlMock(EMPTY_SIX);\n    const responseZero = await getUniversalSearchResults({\n      query: \"alice_99\",\n      actorEmail: \"ops@example.com\",\n      sql: mockZero.sql,\n      perGroupLimit: 0,\n      audit: null,\n    });\n    expect(responseZero.perGroupLimit).toBe(1);\n    for (const call of mockZero.calls) {\n      expect(call.values).toContain(2);\n    }\n\n    const mockNeg = createSqlMock(EMPTY_SIX);\n    const responseNeg = await getUniversalSearchResults({\n      query: \"alice_99\",\n      actorEmail: \"ops@example.com\",\n      sql: mockNeg.sql,\n      perGroupLimit: -3,\n      audit: null,\n    });\n    expect(responseNeg.perGroupLimit).toBe(1);\n  });\n\n  it(\"bounded query: fractional perGroupLimit floors before clamping\", async () => {\n    const mock = createSqlMock(EMPTY_SIX);\n\n    const response = await getUniversalSearchResults({\n      query: \"alice_99\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      perGroupLimit: 4.9,\n      audit: null,\n    });\n\n    expect(response.perGroupLimit).toBe(4);\n    for (const call of mock.calls) {\n      expect(call.values).toContain(5);\n    }\n  });\n\n  it(\"truncation: a group whose results length === perGroupLimit gets truncated=true\", async () => {\n    // Returning exactly perGroupLimit user rows (the function slices at limit\n    // even when the LIMIT+1 fetch would have brought back one more).\n    const limit = PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT;\n    const userRows = Array.from({ length: limit + 1 }, (_, idx) => ({\n      userId: `u-${idx}`,\n      username: `alice${idx}`,\n      wallet: `Wallet${idx}`,\n      joinedAt: \"2026-04-25T00:00:00.000Z\",\n    }));\n    const mock = createSqlMock([userRows, [], [], [], [], []]);\n\n    const response = await getUniversalSearchResults({\n      query: \"alice\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      audit: null,\n    });\n\n    const userGroup = response.groups.find((g) => g.entityType === \"user\");\n    expect(userGroup?.results).toHaveLength(limit);\n    expect(userGroup?.truncated).toBe(true);\n    const referralGroup = response.groups.find((g) => g.entityType === \"referral\");\n    expect(referralGroup?.truncated).toBe(false);\n  });\n\n  it(\"audit emission: default writer is invoked with actorEmail, query class, and total result count\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          userId: \"u-7\",\n          username: \"alice\",\n          wallet: \"Wallet777\",\n          joinedAt: \"2026-04-25T00:00:00.000Z\",\n        },\n      ],\n      [],\n      [],\n      [],\n      [],\n      [],\n    ]);\n\n    type AuditCall = {\n      actorEmail: string;\n      query: string;\n      queryClass: PeekSearchQueryClass;\n      totalResults: number;\n      route: string | null;\n      requestId: string | null;\n    };\n    const auditCalls: AuditCall[] = [];\n\n    await getUniversalSearchResults({\n      query: \"alice_99\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      route: \"/\",\n      requestId: \"req-1\",\n      audit: async (input) => {\n        auditCalls.push(input);\n      },\n    });\n\n    expect(auditCalls).toHaveLength(1);\n    expect(auditCalls[0].actorEmail).toBe(\"ops@example.com\");\n    expect(auditCalls[0].queryClass).toBe(\"username\");\n    expect(auditCalls[0].totalResults).toBe(1);\n    expect(auditCalls[0].route).toBe(\"/\");\n    expect(auditCalls[0].requestId).toBe(\"req-1\");\n    // FR-11: the trimmed raw query is passed to the audit handler so the\n    // writer can choose to redact it; the production writer scrubs anything\n    // shaped like a JWT/secret before persistence.\n    expect(auditCalls[0].query).toBe(\"alice_99\");\n  });\n\n  it(\"audit emission: trims whitespace from the query passed to the audit handler\", async () => {\n    const mock = createSqlMock(EMPTY_SIX);\n    const auditCalls: Array<{ query: string; queryClass: PeekSearchQueryClass }> = [];\n\n    await getUniversalSearchResults({\n      query: \"  alice_99  \",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      audit: async (input) => {\n        auditCalls.push({\n          query: input.query,\n          queryClass: input.queryClass,\n        });\n      },\n    });\n\n    expect(auditCalls[0].query).toBe(\"alice_99\");\n    expect(auditCalls[0].queryClass).toBe(\"username\");\n  });\n\n  it(\"audit emission: empty queries skip the audit emission entirely\", async () => {\n    const mock = createSqlMock([]);\n    let invoked = false;\n\n    await getUniversalSearchResults({\n      query: \"   \",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      audit: async () => {\n        invoked = true;\n      },\n    });\n\n    expect(invoked).toBe(false);\n  });\n\n  it(\"audit emission: a thrown audit handler does not surface to the caller (search response still returns)\", async () => {\n    const mock = createSqlMock(EMPTY_SIX);\n\n    const response = await getUniversalSearchResults({\n      query: \"alice_99\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      audit: async () => {\n        throw new Error(\"audit insert failed\");\n      },\n    });\n\n    // The response is still produced — audit failures are swallowed (FR-11).\n    expect(response.totalResults).toBe(0);\n    expect(response.queryClass).toBe(\"username\");\n  });\n\n  it(\"audit emission: passing audit=null disables emission (used by tests + unauthenticated paths)\", async () => {\n    const mock = createSqlMock(EMPTY_SIX);\n    // Should not throw — and there's no audit handler we can spy on, so the\n    // assertion is that the call resolves and SQL is still issued.\n    const response = await getUniversalSearchResults({\n      query: \"alice_99\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      audit: null,\n    });\n    expect(response.totalResults).toBe(0);\n    expect(mock.calls).toHaveLength(6);\n  });\n\n  it(\"entity ordering: response.groups follows PEEK_SEARCH_ENTITY_TYPES regardless of which queries returned data\", async () => {\n    const mock = createSqlMock([\n      [],\n      [],\n      [],\n      [],\n      [\n        {\n          id: \"1\",\n          txSig: \"Sig123\",\n          game: \"flipyou\",\n          matchId: \"abcdef0123456789\",\n          txType: \"join\",\n          wallet: \"WalletA\",\n          amountLamports: \"1000000\",\n          createdAt: \"2026-04-25T00:00:00.000Z\",\n        },\n      ],\n      [],\n    ]);\n\n    const response = await getUniversalSearchResults({\n      query: \"abcdef0123456789\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(response.groups.map((g) => g.entityType)).toEqual([\n      ...PEEK_SEARCH_ENTITY_TYPES,\n    ]);\n    const entityTypeSet: ReadonlySet<PeekSearchEntityType> = new Set(\n      response.groups.map((g) => g.entityType),\n    );\n    for (const expected of PEEK_SEARCH_ENTITY_TYPES) {\n      expect(entityTypeSet.has(expected)).toBe(true);\n    }\n  });\n\n  it(\"generatedAt: uses the injected `now` so tests can assert deterministic timestamps\", async () => {\n    const mock = createSqlMock(EMPTY_SIX);\n\n    const response = await getUniversalSearchResults({\n      query: \"alice_99\",\n      actorEmail: \"ops@example.com\",\n      sql: mock.sql,\n      now: new Date(\"2026-04-25T12:00:00.000Z\"),\n      audit: null,\n    });\n\n    expect(response.generatedAt).toBe(\"2026-04-25T12:00:00.000Z\");\n  });\n\n  it(\"load-error: a rejected entity-class query propagates so the page-level try/catch can render the alert\", async () => {\n    // Promise.all rejects on the first failure — the page-level catch in\n    // app/page.tsx surfaces the error as `searchError`. The query module must\n    // not silently swallow.\n    const mock = createSqlMock([\n      [],\n      new Error(\"connection refused\"),\n      [],\n      [],\n      [],\n      [],\n    ]);\n\n    await expect(\n      getUniversalSearchResults({\n        query: \"alice_99\",\n        actorEmail: \"ops@example.com\",\n        sql: mock.sql,\n        audit: null,\n      }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n});\n","structuredPatch":[{"oldStart":337,"oldLines":12,"newStart":337,"newLines":12,"lines":["   });"," ","   it(\"tx_signature identifier (long base58): classifies tx_signature and shapes the transaction row\", async () => {","+    // Non-numeric → 6 calls. Transactions is at index 4.","     const mock = createSqlMock([","       [],","       [],","       [],","       [],","-      [],","       [","         {","           id: \"1\","]},{"oldStart":356,"oldLines":6,"newStart":356,"newLines":7,"lines":["           createdAt: \"2026-04-24T00:00:00.000Z\",","         },","       ],","+      [],","     ]);"," ","     const response = await getUniversalSearchResults({"]}],"userModified":false,"replaceAll":false}}
