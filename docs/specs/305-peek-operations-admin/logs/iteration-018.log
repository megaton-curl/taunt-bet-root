 PeekMetricFreshness;\n  drilldownHref: string | null;\n};\n\n// --- Pagination primitive ----------------------------------------------------\n\nexport type PeekPagination = {\n  page: number;\n  pageSize: number;\n  totalCount: number;\n  totalPages: number;\n};\n\n// --- Sort primitive ----------------------------------------------------------\n\nexport type PeekSortDirection = \"asc\" | \"desc\";\n\nexport type PeekTableSort = {\n  column: string;\n  direction: PeekSortDirection;\n};\n\n// --- Table filter primitive (URL-addressable) --------------------------------","numLines":100,"startLine":1,"totalLines":387}}}
