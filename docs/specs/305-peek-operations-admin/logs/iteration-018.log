{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FT8DWWy62BGFBfHvpUNR6C","type":"tool_result","content":"1\t// Universal search query (FR-5).\n2\t//\n3\t// Resolves a single operator-typed query against the operational identifiers\n4\t// admins care about: user_id, username, wallet, referral code, Telegram\n5\t// username, Telegram provider id, round PDA, match id, tx signature, and\n6\t// queue event id. Results are grouped by entity type (user, referral,\n7\t// linked_account, round, transaction, queue_event); each per-group query is\n8\t// bounded server-side. The function emits a `peek.search` audit event by\n9\t// default; tests can inject a no-op or capturing audit handler.\n10\t//\n11\t// Audit payload contract (FR-5 + FR-11):\n12\t// - actorEmail: provided by the caller from the verified Cloudflare Access\n13\t//   email (never trusted from a browser header).\n14\t// - actionId: stable string `peek.search` so audit views can filter.\n15\t// - resourceType: `search` (no resource id — the search is the resource).\n16\t// - filterSummary: a coarse `query_class=<class>` summary; the writer's\n17\t//   redaction layer scrubs any value that looks like a JWT, DB URL, private\n18\t//   key, Bearer header, or cf-access-jwt-assertion line.\n19\t// - resultCount: total results across all groups.\n20\t// - changes: null (search is read-only).\n21\t\n22\timport type { Sql } from \"postgres\";\n23\timport {\n24\t  PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT,\n25\t  PEEK_SEARCH_MAX_PER_GROUP_LIMIT,\n26\t  type PeekSearchEntityType,\n27\t  type PeekSearchGroup,\n28\t  type PeekSearchQueryClass,\n29\t  type PeekSearchResponse,\n30\t  type PeekSearchResult,\n31\t} from \"../../../lib/types/peek\";\n32\timport { writePeekAuditEvent } from \"../../audit/writer\";\n33\timport { getSqlClient } from \"../client\";\n34\t\n35\tconst BASE58_PATTERN = /^[1-9A-HJ-NP-Za-km-z]+$/;\n36\tconst HEX_PATTERN = /^[0-9a-fA-F]+$/;\n37\tconst UUID_PATTERN =\n38\t  /^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$/;\n39\tconst USERNAME_PATTERN = /^[A-Za-z0-9_]{3,32}$/;\n40\tconst REFERRAL_CODE_PATTERN = /^[A-Z0-9]{4,12}$/;\n41\t\n42\texport type PeekSearchAuditFn = (input: {\n43\t  actorEmail: string;\n44\t  query: string;\n45\t  queryClass: PeekSearchQueryClass;\n46\t  totalResults: number;\n47\t  route: string | null;\n48\t  requestId: string | null;\n49\t}) => Promise<void>;\n50\t\n51\texport type UniversalSearchOptions = {\n52\t  query: string;\n53\t  actorEmail: string;\n54\t  sql?: Sql;\n55\t  perGroupLimit?: number;\n56\t  now?: Date;\n57\t  route?: string | null;\n58\t  requestId?: string | null;\n59\t  audit?: PeekSearchAuditFn | null;\n60\t};\n61\t\n62\t// Heuristic classification used only for audit-event summaries. The function\n63\t// always tries every plausible lookup against the database — the class only\n64\t// labels the search so reviewers can read intent without depending on the\n65\t// (possibly redacted) raw query.\n66\texport function classifyPeekSearchQuery(raw: string): PeekSearchQueryClass {\n67\t  const trimmed = raw.trim();\n68\t  if (trimmed.length === 0) return \"empty\";\n69\t\n70\t  const cleaned = trimmed.startsWith(\"@\") ? trimmed.slice(1) : trimmed;\n71\t\n72\t  if (UUID_PATTERN.test(cleaned)) return \"free_text\";\n73\t  if (/^\\d+$/.test(cleaned)) {\n74\t    return cleaned.length <= 18 ? \"queue_event_id\" : \"telegram_provider_id\";\n75\t  }\n76\t  if (cleaned.length === 16 && HEX_PATTERN.test(cleaned)) return \"match_id\";\n77\t\n78\t  if (BASE58_PATTERN.test(cleaned)) {\n79\t    if (cleaned.length >= 80) return \"tx_signature\";\n80\t    if (cleaned.length >= 32 && cleaned.length <= 44) return \"round_pda\";\n81\t  }\n82\t\n83\t  if (trimmed.startsWith(\"@\")) return \"telegram_username\";\n84\t\n85\t  if (REFERRAL_CODE_PATTERN.test(cleaned)) return \"referral_code\";\n86\t\n87\t  if (USERNAME_PATTERN.test(cleaned)) return \"username\";\n88\t\n89\t  return \"free_text\";\n90\t}\n91\t\n92\tfunction clampLimit(requested: number | undefined): number {\n93\t  const fallback = requested ?? PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT;\n94\t  if (!Number.isFinite(fallback)) return PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT;\n95\t  const floored = Math.floor(fallback);\n96\t  return Math.max(\n97\t    1,\n98\t    Math.min(PEEK_SEARCH_MAX_PER_GROUP_LIMIT, floored),\n99\t  );\n100\t}\n101\t\n102\tfunction emptyGroups(): ReadonlyArray<PeekSearchGroup> {\n103\t  const entityTypes: ReadonlyArray<PeekSearchEntityType> = [\n104\t    \"user\",\n105\t    \"referral\",\n106\t    \"linked_account\",\n107\t    \"round\",\n108\t    \"transaction\",\n109\t    \"queue_event\",\n110\t  ];\n111\t  return entityTypes.map((entityType) => ({\n112\t    entityType,\n113\t    results: [],\n114\t    truncated: false,\n115\t  }));\n116\t}\n117\t\n118\ttype UserRow = {\n119\t  userId: string;\n120\t  username: string | null;\n121\t  wallet: string;\n122\t  joinedAt: string;\n123\t};\n124\t\n125\ttype ReferralCodeRow = {\n126\t  code: string;\n127\t  userId: string;\n128\t  wallet: string;\n129\t};\n130\t\n131\ttype LinkedAccountRow = {\n132\t  userId: string;\n133\t  provider: string;\n134\t  providerAccountId: string;\n135\t  telegramUsername: string | null;\n136\t  status: string;\n137\t};\n138\t\n139\ttype RoundRow = {\n140\t  pda: string;\n141\t  game: string;\n142\t  matchId: string;\n143\t  phase: string;\n144\t  creator: string | null;\n145\t};\n146\t\n147\ttype TransactionRow = {\n148\t  id: string;\n149\t  txSig: string;\n150\t  game: string;\n151\t  matchId: string;\n152\t  txType: string;\n153\t  wallet: string;\n154\t  amountLamports: string;\n155\t  createdAt: string;\n156\t};\n157\t\n158\ttype QueueEventRow = {\n159\t  id: string;\n160\t  eventType: string;\n161\t  status: string;\n162\t  attempts: number;\n163\t  scheduledAt: string;\n164\t};\n165\t\n166\tasync function searchUsers(\n167\t  sql: Sql,\n168\t  query: string,\n169\t  limit: number,\n170\t): Promise<PeekSearchResult[]> {\n171\t  const exact = query;\n172\t  const like = `%${query}%`;\n173\t  const rows = await sql<UserRow[]>`\n174\t    select\n175\t      user_id as \"userId\",\n176\t      username,\n177\t      wallet,\n178\t      created_at::text as \"joinedAt\"\n179\t    from player_profiles\n180\t    where user_id = ${exact}\n181\t       or wallet = ${exact}\n182\t       or lower(username) = lower(${exact})\n183\t       or user_id ilike ${like}\n184\t       or wallet ilike ${like}\n185\t       or coalesce(username, '') ilike ${like}\n186\t    order by created_at desc\n187\t    limit ${limit + 1}\n188\t  `;\n189\t  return rows.slice(0, limit).map((row) => ({\n190\t    entityType: \"user\" as const,\n191\t    id: row.userId,\n192\t    label: row.username ?? row.userId,\n193\t    sublabel: row.wallet,\n194\t    context: `joined ${row.joinedAt}`,\n195\t    href: `/users/${encodeURIComponent(row.userId)}`,\n196\t  }));\n197\t}\n198\t\n199\tasync function searchReferralCodes(\n200\t  sql: Sql,\n201\t  query: string,\n202\t  limit: number,\n203\t): Promise<PeekSearchResult[]> {\n204\t  const exact = query;\n205\t  const like = `%${query}%`;\n206\t  const rows = await sql<ReferralCodeRow[]>`\n207\t    select\n208\t      code,\n209\t      user_id as \"userId\",\n210\t      wallet\n211\t    from referral_codes\n212\t    where upper(code) = upper(${exact})\n213\t       or code ilike ${like}\n214\t       or user_id = ${exact}\n215\t       or wallet = ${exact}\n216\t    order by created_at desc\n217\t    limit ${limit + 1}\n218\t  `;\n219\t  return rows.slice(0, limit).map((row) => ({\n220\t    entityType: \"referral\" as const,\n221\t    id: row.code,\n222\t    label: row.code,\n223\t    sublabel: row.userId,\n224\t    context: `wallet ${row.wallet}`,\n225\t    href: `/users/${encodeURIComponent(row.userId)}`,\n226\t  }));\n227\t}\n228\t\n229\tasync function searchLinkedAccounts(\n230\t  sql: Sql,\n231\t  query: string,\n232\t  limit: number,\n233\t): Promise<PeekSearchResult[]> {\n234\t  const trimmed = query.startsWith(\"@\") ? query.slice(1) : query;\n235\t  const exact = trimmed;\n236\t  const like = `%${trimmed}%`;\n237\t  const rows = await sql<LinkedAccountRow[]>`\n238\t    select\n239\t      user_id as \"userId\",\n240\t      provider,\n241\t      provider_account_id as \"providerAccountId\",\n242\t      nullif(metadata_json->>'telegramUsername', '') as \"telegramUsername\",\n243\t      status\n244\t    from linked_accounts\n245\t    where status = 'active'\n246\t      and (\n247\t        provider_account_id = ${exact}\n248\t        or metadata_json->>'telegramUsername' = ${exact}\n249\t        or provider_account_id ilike ${like}\n250\t        or coalesce(metadata_json->>'telegramUsername', '') ilike ${like}\n251\t      )\n252\t    order by linked_at desc\n253\t    limit ${limit + 1}\n254\t  `;\n255\t  return rows.slice(0, limit).map((row) => {\n256\t    const display = row.telegramUsername\n257\t      ? `@${row.telegramUsername}`\n258\t      : row.providerAccountId;\n259\t    return {\n260\t      entityType: \"linked_account\" as const,\n261\t      id: `${row.provider}:${row.providerAccountId}`,\n262\t      label: display,\n263\t      sublabel: row.userId,\n264\t      context: `${row.provider} (${row.status})`,\n265\t      href: `/users/${encodeURIComponent(row.userId)}`,\n266\t    };\n267\t  });\n268\t}\n269\t\n270\tasync function searchRounds(\n271\t  sql: Sql,\n272\t  query: string,\n273\t  limit: number,\n274\t): Promise<PeekSearchResult[]> {\n275\t  const exact = query;\n276\t  const flipPotRows = await sql<RoundRow[]>`\n277\t    select\n278\t      pda,\n279\t      game,\n280\t      match_id as \"matchId\",\n281\t      phase,\n282\t      creator\n283\t    from rounds\n284\t    where pda = ${exact}\n285\t       or match_id = ${exact}\n286\t       or creator = ${exact}\n287\t    order by created_at desc\n288\t    limit ${limit + 1}\n289\t  `;\n290\t  const closeCallRows = await sql<RoundRow[]>`\n291\t    select\n292\t      pda,\n293\t      'closecall'::text as \"game\",\n294\t      round_id as \"matchId\",\n295\t      phase,\n296\t      null::text as \"creator\"\n297\t    from closecall_rounds\n298\t    where pda = ${exact}\n299\t       or round_id = ${exact}\n300\t    order by created_at desc\n301\t    limit ${limit + 1}\n302\t  `;\n303\t  const combined = [...flipPotRows, ...closeCallRows];\n304\t  return combined.slice(0, limit).map((row) => ({\n305\t    entityType: \"round\" as const,\n306\t    id: row.pda,\n307\t    label: row.matchId,\n308\t    sublabel: `${row.game} • ${row.phase}`,\n309\t    context: row.creator ? `creator ${row.creator}` : null,\n310\t    href: `/games/${encodeURIComponent(row.game)}/rounds/${encodeURIComponent(row.pda)}`,\n311\t  }));\n312\t}\n313\t\n314\tasync function searchTransactions(\n315\t  sql: Sql,\n316\t  query: string,\n317\t  limit: number,\n318\t): Promise<PeekSearchResult[]> {\n319\t  const exact = query;\n320\t  const rows = await sql<TransactionRow[]>`\n321\t    select\n322\t      id::text as \"id\",\n323\t      tx_sig as \"txSig\",\n324\t      game,\n325\t      match_id as \"matchId\",\n326\t      tx_type as \"txType\",\n327\t      wallet,\n328\t      amount_lamports::text as \"amountLamports\",\n329\t      created_at::text as \"createdAt\"\n330\t    from transactions\n331\t    where tx_sig = ${exact}\n332\t       or match_id = ${exact}\n333\t       or wallet = ${exact}\n334\t    order by created_at desc\n335\t    limit ${limit + 1}\n336\t  `;\n337\t  return rows.slice(0, limit).map((row) => ({\n338\t    entityType: \"transaction\" as const,\n339\t    id: row.id,\n340\t    label: row.txSig,\n341\t    sublabel: `${row.game} • ${row.txType}`,\n342\t    context: `wallet ${row.wallet} • ${row.amountLamports} lamports`,\n343\t    href: `/games/${encodeURIComponent(row.game)}/rounds/${encodeURIComponent(row.matchId)}`,\n344\t  }));\n345\t}\n346\t\n347\tasync function searchQueueEvents(\n348\t  sql: Sql,\n349\t  query: string,\n350\t  limit: number,\n351\t): Promise<PeekSearchResult[]> {\n352\t  if (!/^\\d+$/.test(query)) return [];\n353\t  const numericId = query;\n354\t  const rows = await sql<QueueEventRow[]>`\n355\t    select\n356\t      id::text as \"id\",\n357\t      event_type as \"eventType\",\n358\t      status,\n359\t      attempts,\n360\t      scheduled_at::text as \"scheduledAt\"\n361\t    from event_queue\n362\t    where id::text = ${numericId}\n363\t    order by created_at desc\n364\t    limit ${limit + 1}\n365\t  `;\n366\t  return rows.slice(0, limit).map((row) => ({\n367\t    entityType: \"queue_event\" as const,\n368\t    id: row.id,\n369\t    label: `#${row.id}`,\n370\t    sublabel: `${row.eventType} • ${row.status}`,\n371\t    context: `attempts ${row.attempts} • scheduled ${row.scheduledAt}`,\n372\t    href: `/operations/queue?id=${encodeURIComponent(row.id)}`,\n373\t  }));\n374\t}\n375\t\n376\tasync function defaultPeekSearchAudit(input: {\n377\t  actorEmail: string;\n378\t  query: string;\n379\t  queryClass: PeekSearchQueryClass;\n380\t  totalResults: number;\n381\t  route: string | null;\n382\t  requestId: string | null;\n383\t}): Promise<void> {\n384\t  await writePeekAuditEvent({\n385\t    eventType: \"peek.search\",\n386\t    payload: {\n387\t      actorEmail: input.actorEmail,\n388\t      route: input.route,\n389\t      actionId: \"peek.search\",\n390\t      resourceType: \"search\",\n391\t      resourceId: null,\n392\t      filterSummary: `query_class=${input.queryClass}`,\n393\t      resultCount: input.totalResults,\n394\t      requestId: input.requestId,\n395\t      rejectionReason: null,\n396\t      changes: null,\n397\t    },\n398\t  });\n399\t}\n400\t\n401\texport async function getUniversalSearchResults(\n402\t  options: UniversalSearchOptions,\n403\t): Promise<PeekSearchResponse> {\n404\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n405\t  const perGroupLimit = clampLimit(options.perGroupLimit);\n406\t  const now = options.now ?? new Date();\n407\t  const generatedAt = now.toISOString();\n408\t  const trimmed = options.query.trim();\n409\t  const queryClass = classifyPeekSearchQuery(trimmed);\n410\t\n411\t  if (trimmed.length === 0) {\n412\t    const response: PeekSearchResponse = {\n413\t      query: trimmed,\n414\t      queryClass,\n415\t      groups: emptyGroups(),\n416\t      totalResults: 0,\n417\t      perGroupLimit,\n418\t      generatedAt,\n419\t    };\n420\t    return response;\n421\t  }\n422\t\n423\t  // Run every entity-class query in parallel; per-group LIMIT keeps each query\n424\t  // bounded. Group-level `truncated` is set when the inner query came back\n425\t  // with one more row than `limit`.\n426\t  const [users, referrals, linkedAccounts, rounds, transactions, queueEvents] =\n427\t    await Promise.all([\n428\t      searchUsers(sql, trimmed, perGroupLimit),\n429\t      searchReferralCodes(sql, trimmed, perGroupLimit),\n430\t      searchLinkedAccounts(sql, trimmed, perGroupLimit),\n431\t      searchRounds(sql, trimmed, perGroupLimit),\n432\t      searchTransactions(sql, trimmed, perGroupLimit),\n433\t      searchQueueEvents(sql, trimmed, perGroupLimit),\n434\t    ]);\n435\t\n436\t  const groups: ReadonlyArray<PeekSearchGroup> = [\n437\t    { entityType: \"user\", results: users, truncated: users.length === perGroupLimit },\n438\t    {\n439\t      entityType: \"referral\",\n440\t      results: referrals,\n441\t      truncated: referrals.length === perGroupLimit,\n442\t    },\n443\t    {\n444\t      entityType: \"linked_account\",\n445\t      results: linkedAccounts,\n446\t      truncated: linkedAccounts.length === perGroupLimit,\n447\t    },\n448\t    {\n449\t      entityType: \"round\",\n450\t      results: rounds,\n451\t      truncated: rounds.length === perGroupLimit,\n452\t    },\n453\t    {\n454\t      entityType: \"transaction\",\n455\t      results: transactions,\n456\t      truncated: transactions.length === perGroupLimit,\n457\t    },\n458\t    {\n459\t      entityType: \"queue_event\",\n460\t      results: queueEvents,\n461\t      truncated: queueEvents.length === perGroupLimit,\n462\t    },\n463\t  ];\n464\t\n465\t  const totalResults = groups.reduce(\n466\t    (acc, group) => acc + group.results.length,\n467\t    0,\n468\t  );\n469\t\n470\t  const audit = options.audit === undefined ? defaultPeekSearchAudit : options.audit;\n471\t  if (audit) {\n472\t    try {\n473\t      await audit({\n474\t        actorEmail: options.actorEmail,\n475\t        query: trimmed,\n476\t        queryClass,\n477\t        totalResults,\n478\t        route: options.route ?? null,\n479\t        requestId: options.requestId ?? null,\n480\t      });\n481\t    } catch {\n482\t      // Audit failures must never leak to the caller (FR-11). The writer\n483\t      // already logs server-side; swallow here so the search response still\n484\t      // renders.\n485\t    }\n486\t  }\n487\t\n488\t  return {\n489\t    query: trimmed,\n490\t    queryClass,\n491\t    groups,\n492\t    totalResults,\n493\t    perGroupLimit,\n494\t    generatedAt,\n495\t  };\n496\t}\n497\t"}]},"parent_tool_use_id":null,"session_id":"d4d72e16-a61e-41f5-8f09-281d33e306cd","uuid":"b4ac13de-eb6f-4759-8736-3d1c9827d8da","timestamp":"2026-04-25T11:41:12.371Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/universal-search.ts","content":"// Universal search query (FR-5).\n//\n// Resolves a single operator-typed query against the operational identifiers\n// admins care about: user_id, username, wallet, referral code, Telegram\n// username, Telegram provider id, round PDA, match id, tx signature, and\n// queue event id. Results are grouped by entity type (user, referral,\n// linked_account, round, transaction, queue_event); each per-group query is\n// bounded server-side. The function emits a `peek.search` audit event by\n// default; tests can inject a no-op or capturing audit handler.\n//\n// Audit payload contract (FR-5 + FR-11):\n// - actorEmail: provided by the caller from the verified Cloudflare Access\n//   email (never trusted from a browser header).\n// - actionId: stable string `peek.search` so audit views can filter.\n// - resourceType: `search` (no resource id — the search is the resource).\n// - filterSummary: a coarse `query_class=<class>` summary; the writer's\n//   redaction layer scrubs any value that looks like a JWT, DB URL, private\n//   key, Bearer header, or cf-access-jwt-assertion line.\n// - resultCount: total results across all groups.\n// - changes: null (search is read-only).\n\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT,\n  PEEK_SEARCH_MAX_PER_GROUP_LIMIT,\n  type PeekSearchEntityType,\n  type PeekSearchGroup,\n  type PeekSearchQueryClass,\n  type PeekSearchResponse,\n  type PeekSearchResult,\n} from \"../../../lib/types/peek\";\nimport { writePeekAuditEvent } from \"../../audit/writer\";\nimport { getSqlClient } from \"../client\";\n\nconst BASE58_PATTERN = /^[1-9A-HJ-NP-Za-km-z]+$/;\nconst HEX_PATTERN = /^[0-9a-fA-F]+$/;\nconst UUID_PATTERN =\n  /^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$/;\nconst USERNAME_PATTERN = /^[A-Za-z0-9_]{3,32}$/;\nconst REFERRAL_CODE_PATTERN = /^[A-Z0-9]{4,12}$/;\n\nexport type PeekSearchAuditFn = (input: {\n  actorEmail: string;\n  query: string;\n  queryClass: PeekSearchQueryClass;\n  totalResults: number;\n  route: string | null;\n  requestId: string | null;\n}) => Promise<void>;\n\nexport type UniversalSearchOptions = {\n  query: string;\n  actorEmail: string;\n  sql?: Sql;\n  perGroupLimit?: number;\n  now?: Date;\n  route?: string | null;\n  requestId?: string | null;\n  audit?: PeekSearchAuditFn | null;\n};\n\n// Heuristic classification used only for audit-event summaries. The function\n// always tries every plausible lookup against the database — the class only\n// labels the search so reviewers can read intent without depending on the\n// (possibly redacted) raw query.\nexport function classifyPeekSearchQuery(raw: string): PeekSearchQueryClass {\n  const trimmed = raw.trim();\n  if (trimmed.length === 0) return \"empty\";\n\n  const cleaned = trimmed.startsWith(\"@\") ? trimmed.slice(1) : trimmed;\n\n  if (UUID_PATTERN.test(cleaned)) return \"free_text\";\n  if (/^\\d+$/.test(cleaned)) {\n    return cleaned.length <= 18 ? \"queue_event_id\" : \"telegram_provider_id\";\n  }\n  if (cleaned.length === 16 && HEX_PATTERN.test(cleaned)) return \"match_id\";\n\n  if (BASE58_PATTERN.test(cleaned)) {\n    if (cleaned.length >= 80) return \"tx_signature\";\n    if (cleaned.length >= 32 && cleaned.length <= 44) return \"round_pda\";\n  }\n\n  if (trimmed.startsWith(\"@\")) return \"telegram_username\";\n\n  if (REFERRAL_CODE_PATTERN.test(cleaned)) return \"referral_code\";\n\n  if (USERNAME_PATTERN.test(cleaned)) return \"username\";\n\n  return \"free_text\";\n}\n\nfunction clampLimit(requested: number | undefined): number {\n  const fallback = requested ?? PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT;\n  if (!Number.isFinite(fallback)) return PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT;\n  const floored = Math.floor(fallback);\n  return Math.max(\n    1,\n    Math.min(PEEK_SEARCH_MAX_PER_GROUP_LIMIT, floored),\n  );\n}\n\nfunction emptyGroups(): ReadonlyArray<PeekSearchGroup> {\n  const entityTypes: ReadonlyArray<PeekSearchEntityType> = [\n    \"user\",\n    \"referral\",\n    \"linked_account\",\n    \"round\",\n    \"transaction\",\n    \"queue_event\",\n  ];\n  return entityTypes.map((entityType) => ({\n    entityType,\n    results: [],\n    truncated: false,\n  }));\n}\n\ntype UserRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  joinedAt: string;\n};\n\ntype ReferralCodeRow = {\n  code: string;\n  userId: string;\n  wallet: string;\n};\n\ntype LinkedAccountRow = {\n  userId: string;\n  provider: string;\n  providerAccountId: string;\n  telegramUsername: string | null;\n  status: string;\n};\n\ntype RoundRow = {\n  pda: string;\n  game: string;\n  matchId: string;\n  phase: string;\n  creator: string | null;\n};\n\ntype TransactionRow = {\n  id: string;\n  txSig: string;\n  game: string;\n  matchId: string;\n  txType: string;\n  wallet: string;\n  amountLamports: string;\n  createdAt: string;\n};\n\ntype QueueEventRow = {\n  id: string;\n  eventType: string;\n  status: string;\n  attempts: number;\n  scheduledAt: string;\n};\n\nasync function searchUsers(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const exact = query;\n  const like = `%${query}%`;\n  const rows = await sql<UserRow[]>`\n    select\n      user_id as \"userId\",\n      username,\n      wallet,\n      created_at::text as \"joinedAt\"\n    from player_profiles\n    where user_id = ${exact}\n       or wallet = ${exact}\n       or lower(username) = lower(${exact})\n       or user_id ilike ${like}\n       or wallet ilike ${like}\n       or coalesce(username, '') ilike ${like}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => ({\n    entityType: \"user\" as const,\n    id: row.userId,\n    label: row.username ?? row.userId,\n    sublabel: row.wallet,\n    context: `joined ${row.joinedAt}`,\n    href: `/users/${encodeURIComponent(row.userId)}`,\n  }));\n}\n\nasync function searchReferralCodes(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const exact = query;\n  const like = `%${query}%`;\n  const rows = await sql<ReferralCodeRow[]>`\n    select\n      code,\n      user_id as \"userId\",\n      wallet\n    from referral_codes\n    where upper(code) = upper(${exact})\n       or code ilike ${like}\n       or user_id = ${exact}\n       or wallet = ${exact}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => ({\n    entityType: \"referral\" as const,\n    id: row.code,\n    label: row.code,\n    sublabel: row.userId,\n    context: `wallet ${row.wallet}`,\n    href: `/users/${encodeURIComponent(row.userId)}`,\n  }));\n}\n\nasync function searchLinkedAccounts(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const trimmed = query.startsWith(\"@\") ? query.slice(1) : query;\n  const exact = trimmed;\n  const like = `%${trimmed}%`;\n  const rows = await sql<LinkedAccountRow[]>`\n    select\n      user_id as \"userId\",\n      provider,\n      provider_account_id as \"providerAccountId\",\n      nullif(metadata_json->>'telegramUsername', '') as \"telegramUsername\",\n      status\n    from linked_accounts\n    where status = 'active'\n      and (\n        provider_account_id = ${exact}\n        or metadata_json->>'telegramUsername' = ${exact}\n        or provider_account_id ilike ${like}\n        or coalesce(metadata_json->>'telegramUsername', '') ilike ${like}\n      )\n    order by linked_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => {\n    const display = row.telegramUsername\n      ? `@${row.telegramUsername}`\n      : row.providerAccountId;\n    return {\n      entityType: \"linked_account\" as const,\n      id: `${row.provider}:${row.providerAccountId}`,\n      label: display,\n      sublabel: row.userId,\n      context: `${row.provider} (${row.status})`,\n      href: `/users/${encodeURIComponent(row.userId)}`,\n    };\n  });\n}\n\nasync function searchRounds(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const exact = query;\n  const flipPotRows = await sql<RoundRow[]>`\n    select\n      pda,\n      game,\n      match_id as \"matchId\",\n      phase,\n      creator\n    from rounds\n    where pda = ${exact}\n       or match_id = ${exact}\n       or creator = ${exact}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  const closeCallRows = await sql<RoundRow[]>`\n    select\n      pda,\n      'closecall'::text as \"game\",\n      round_id as \"matchId\",\n      phase,\n      null::text as \"creator\"\n    from closecall_rounds\n    where pda = ${exact}\n       or round_id = ${exact}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  const combined = [...flipPotRows, ...closeCallRows];\n  return combined.slice(0, limit).map((row) => ({\n    entityType: \"round\" as const,\n    id: row.pda,\n    label: row.matchId,\n    sublabel: `${row.game} • ${row.phase}`,\n    context: row.creator ? `creator ${row.creator}` : null,\n    href: `/games/${encodeURIComponent(row.game)}/rounds/${encodeURIComponent(row.pda)}`,\n  }));\n}\n\nasync function searchTransactions(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  const exact = query;\n  const rows = await sql<TransactionRow[]>`\n    select\n      id::text as \"id\",\n      tx_sig as \"txSig\",\n      game,\n      match_id as \"matchId\",\n      tx_type as \"txType\",\n      wallet,\n      amount_lamports::text as \"amountLamports\",\n      created_at::text as \"createdAt\"\n    from transactions\n    where tx_sig = ${exact}\n       or match_id = ${exact}\n       or wallet = ${exact}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => ({\n    entityType: \"transaction\" as const,\n    id: row.id,\n    label: row.txSig,\n    sublabel: `${row.game} • ${row.txType}`,\n    context: `wallet ${row.wallet} • ${row.amountLamports} lamports`,\n    href: `/games/${encodeURIComponent(row.game)}/rounds/${encodeURIComponent(row.matchId)}`,\n  }));\n}\n\nasync function searchQueueEvents(\n  sql: Sql,\n  query: string,\n  limit: number,\n): Promise<PeekSearchResult[]> {\n  if (!/^\\d+$/.test(query)) return [];\n  const numericId = query;\n  const rows = await sql<QueueEventRow[]>`\n    select\n      id::text as \"id\",\n      event_type as \"eventType\",\n      status,\n      attempts,\n      scheduled_at::text as \"scheduledAt\"\n    from event_queue\n    where id::text = ${numericId}\n    order by created_at desc\n    limit ${limit + 1}\n  `;\n  return rows.slice(0, limit).map((row) => ({\n    entityType: \"queue_event\" as const,\n    id: row.id,\n    label: `#${row.id}`,\n    sublabel: `${row.eventType} • ${row.status}`,\n    context: `attempts ${row.attempts} • scheduled ${row.scheduledAt}`,\n    href: `/operations/queue?id=${encodeURIComponent(row.id)}`,\n  }));\n}\n\nasync function defaultPeekSearchAudit(input: {\n  actorEmail: string;\n  query: string;\n  queryClass: PeekSearchQueryClass;\n  totalResults: number;\n  route: string | null;\n  requestId: string | null;\n}): Promise<void> {\n  await writePeekAuditEvent({\n    eventType: \"peek.search\",\n    payload: {\n      actorEmail: input.actorEmail,\n      route: input.route,\n      actionId: \"peek.search\",\n      resourceType: \"search\",\n      resourceId: null,\n      filterSummary: `query_class=${input.queryClass}`,\n      resultCount: input.totalResults,\n      requestId: input.requestId,\n      rejectionReason: null,\n      changes: null,\n    },\n  });\n}\n\nexport async function getUniversalSearchResults(\n  options: UniversalSearchOptions,\n): Promise<PeekSearchResponse> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const perGroupLimit = clampLimit(options.perGroupLimit);\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n  const trimmed = options.query.trim();\n  const queryClass = classifyPeekSearchQuery(trimmed);\n\n  if (trimmed.length === 0) {\n    const response: PeekSearchResponse = {\n      query: trimmed,\n      queryClass,\n      groups: emptyGroups(),\n      totalResults: 0,\n      perGroupLimit,\n      generatedAt,\n    };\n    return response;\n  }\n\n  // Run every entity-class query in parallel; per-group LIMIT keeps each query\n  // bounded. Group-level `truncated` is set when the inner query came back\n  // with one more row than `limit`.\n  const [users, referrals, linkedAccounts, rounds, transactions, queueEvents] =\n    await Promise.all([\n      searchUsers(sql, trimmed, perGroupLimit),\n      searchReferralCodes(sql, trimmed, perGroupLimit),\n      searchLinkedAccounts(sql, trimmed, perGroupLimit),\n      searchRounds(sql, trimmed, perGroupLimit),\n      searchTransactions(sql, trimmed, perGroupLimit),\n      searchQueueEvents(sql, trimmed, perGroupLimit),\n    ]);\n\n  const groups: ReadonlyArray<PeekSearchGroup> = [\n    { entityType: \"user\", results: users, truncated: users.length === perGroupLimit },\n    {\n      entityType: \"referral\",\n      results: referrals,\n      truncated: referrals.length === perGroupLimit,\n    },\n    {\n      entityType: \"linked_account\",\n      results: linkedAccounts,\n      truncated: linkedAccounts.length === perGroupLimit,\n    },\n    {\n      entityType: \"round\",\n      results: rounds,\n      truncated: rounds.length === perGroupLimit,\n    },\n    {\n      entityType: \"transaction\",\n      results: transactions,\n      truncated: transactions.length === perGroupLimit,\n    },\n    {\n      entityType: \"queue_event\",\n      results: queueEvents,\n      truncated: queueEvents.length === perGroupLimit,\n    },\n  ];\n\n  const totalResults = groups.reduce(\n    (acc, group) => acc + group.results.length,\n    0,\n  );\n\n  const audit = options.audit === undefined ? defaultPeekSearchAudit : options.audit;\n  if (audit) {\n    try {\n      await audit({\n        actorEmail: options.actorEmail,\n        query: trimmed,\n        queryClass,\n        totalResults,\n        route: options.route ?? null,\n        requestId: options.requestId ?? null,\n      });\n    } catch {\n      // Audit failures must never leak to the caller (FR-11). The writer\n      // already logs server-side; swallow here so the search response still\n      // renders.\n    }\n  }\n\n  return {\n    query: trimmed,\n    queryClass,\n    groups,\n    totalResults,\n    perGroupLimit,\n    generatedAt,\n  };\n}\n","numLines":497,"startLine":1,"totalLines":497}}}
