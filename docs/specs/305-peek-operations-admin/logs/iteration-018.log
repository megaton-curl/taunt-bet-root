{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014HUg78skxzc8Re8thN5KME","type":"tool_result","content":"320\t// (user, referral, linked account, round, transaction, queue event). Each\n321\t// result includes enough context to disambiguate similar matches; sensitive\n322\t// values (wallet, Telegram id, tx signature) live in the result's `id`/`label`\n323\t// fields for operator readability and the audit event records only the actor\n324\t// email, query class, and result counts (never the raw query, which the audit\n325\t// writer redacts if it looks like a secret).\n326\t\n327\texport type PeekSearchEntityType =\n328\t  | \"user\"\n329\t  | \"referral\"\n330\t  | \"linked_account\"\n331\t  | \"round\"\n332\t  | \"transaction\"\n333\t  | \"queue_event\";\n334\t\n335\texport const PEEK_SEARCH_ENTITY_TYPES: ReadonlyArray<PeekSearchEntityType> = [\n336\t  \"user\",\n337\t  \"referral\",\n338\t  \"linked_account\",\n339\t  \"round\",\n340\t  \"transaction\",\n341\t  \"queue_event\",\n342\t];\n343\t\n344\t// Coarse heuristic classification used only for the `peek.search` audit\n345\t// summary so reviewers can see which class of identifier was searched without\n346\t// inferring it from the (possibly redacted) raw query.\n347\texport type PeekSearchQueryClass =\n348\t  | \"empty\"\n349\t  | \"free_text\"\n350\t  | \"user_id\"\n351\t  | \"username\"\n352\t  | \"wallet\"\n353\t  | \"referral_code\"\n354\t  | \"telegram_username\"\n355\t  | \"telegram_provider_id\"\n356\t  | \"round_pda\"\n357\t  | \"match_id\"\n358\t  | \"tx_signature\"\n359\t  | \"queue_event_id\";\n360\t\n361\texport type PeekSearchResult = {\n362\t  entityType: PeekSearchEntityType;\n363\t  id: string;\n364\t  label: string;\n365\t  sublabel: string | null;\n366\t  context: string | null;\n367\t  href: string;\n368\t};\n369\t\n370\texport type PeekSearchGroup = {\n371\t  entityType: PeekSearchEntityType;\n372\t  results: ReadonlyArray<PeekSearchResult>;\n373\t  truncated: boolean;\n374\t};\n375\t\n376\texport type PeekSearchResponse = {\n377\t  query: string;\n378\t  queryClass: PeekSearchQueryClass;\n379\t  groups: ReadonlyArray<PeekSearchGroup>;\n380\t  totalResults: number;\n381\t  perGroupLimit: number;\n382\t  generatedAt: string;\n383\t};\n384\t\n385\texport const PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT = 5;\n386\texport const PEEK_SEARCH_MAX_PER_GROUP_LIMIT = 25;\n387\t"}]},"parent_tool_use_id":null,"session_id":"d4d72e16-a61e-41f5-8f09-281d33e306cd","uuid":"e93d08a9-ed08-4c2f-a483-22dd6e993ecc","timestamp":"2026-04-25T11:41:22.637Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","content":"// (user, referral, linked account, round, transaction, queue event). Each\n// result includes enough context to disambiguate similar matches; sensitive\n// values (wallet, Telegram id, tx signature) live in the result's `id`/`label`\n// fields for operator readability and the audit event records only the actor\n// email, query class, and result counts (never the raw query, which the audit\n// writer redacts if it looks like a secret).\n\nexport type PeekSearchEntityType =\n  | \"user\"\n  | \"referral\"\n  | \"linked_account\"\n  | \"round\"\n  | \"transaction\"\n  | \"queue_event\";\n\nexport const PEEK_SEARCH_ENTITY_TYPES: ReadonlyArray<PeekSearchEntityType> = [\n  \"user\",\n  \"referral\",\n  \"linked_account\",\n  \"round\",\n  \"transaction\",\n  \"queue_event\",\n];\n\n// Coarse heuristic classification used only for the `peek.search` audit\n// summary so reviewers can see which class of identifier was searched without\n// inferring it from the (possibly redacted) raw query.\nexport type PeekSearchQueryClass =\n  | \"empty\"\n  | \"free_text\"\n  | \"user_id\"\n  | \"username\"\n  | \"wallet\"\n  | \"referral_code\"\n  | \"telegram_username\"\n  | \"telegram_provider_id\"\n  | \"round_pda\"\n  | \"match_id\"\n  | \"tx_signature\"\n  | \"queue_event_id\";\n\nexport type PeekSearchResult = {\n  entityType: PeekSearchEntityType;\n  id: string;\n  label: string;\n  sublabel: string | null;\n  context: string | null;\n  href: string;\n};\n\nexport type PeekSearchGroup = {\n  entityType: PeekSearchEntityType;\n  results: ReadonlyArray<PeekSearchResult>;\n  truncated: boolean;\n};\n\nexport type PeekSearchResponse = {\n  query: string;\n  queryClass: PeekSearchQueryClass;\n  groups: ReadonlyArray<PeekSearchGroup>;\n  totalResults: number;\n  perGroupLimit: number;\n  generatedAt: string;\n};\n\nexport const PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT = 5;\nexport const PEEK_SEARCH_MAX_PER_GROUP_LIMIT = 25;\n","numLines":68,"startLine":320,"totalLines":387}}}
