{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011AEdZiWPqcuavBEEaNTuaR","type":"tool_result","content":"1\timport { NextResponse, type NextRequest } from \"next/server\";\n2\timport {\n3\t  VERIFIED_ACCESS_EMAIL_HEADER,\n4\t  verifyCloudflareAccessJwt,\n5\t} from \"./src/server/cloudflare-access\";\n6\t\n7\tconst DEV_BYPASS_EMAIL_PATTERN = /^[^\\s@]+@[^\\s@]+$/;\n8\t\n9\texport async function proxy(request: NextRequest) {\n10\t  const teamDomain = process.env.CF_ACCESS_TEAM_DOMAIN?.trim();\n11\t  const audience = process.env.CF_ACCESS_AUD?.trim();\n12\t  const isDevelopment = process.env.NODE_ENV === \"development\";\n13\t\n14\t  // Strip any browser-supplied verified-email header before any branch can\n15\t  // forward the request: server context must only ever see the value that the\n16\t  // proxy itself sets after verification (or the explicit dev bypass).\n17\t  const requestHeaders = new Headers(request.headers);\n18\t  requestHeaders.delete(VERIFIED_ACCESS_EMAIL_HEADER);\n19\t\n20\t  if (isDevelopment) {\n21\t    const devEmail = process.env.PEEK_DEV_ACCESS_EMAIL?.trim().toLowerCase();\n22\t    if (devEmail && DEV_BYPASS_EMAIL_PATTERN.test(devEmail)) {\n23\t      requestHeaders.set(VERIFIED_ACCESS_EMAIL_HEADER, devEmail);\n24\t      return NextResponse.next({\n25\t        request: { headers: requestHeaders },\n26\t      });\n27\t    }\n28\t  }\n29\t\n30\t  if (!teamDomain || !audience) {\n31\t    if (isDevelopment) {\n32\t      return NextResponse.next({\n33\t        request: { headers: requestHeaders },\n34\t      });\n35\t    }\n36\t\n37\t    return new NextResponse(\"Cloudflare Access is not configured\", {\n38\t      status: 500,\n39\t    });\n40\t  }\n41\t\n42\t  const verification = await verifyCloudflareAccessJwt(\n43\t    request.headers.get(\"cf-access-jwt-assertion\"),\n44\t    {\n45\t      audience,\n46\t      teamDomain,\n47\t    },\n48\t  );\n49\t\n50\t  if (!verification.ok) {\n51\t    return new NextResponse(\"Cloudfl