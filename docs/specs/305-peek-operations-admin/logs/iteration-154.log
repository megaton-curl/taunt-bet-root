teJwks(issuer);\n60\t\n61\t  let payload: JWTPayload;\n62\t  try {\n63\t    const result = await jwtVerify(token, getKey, {\n64\t      algorithms: [\"RS256\"],\n65\t      audience: options.audience,\n66\t      currentDate: options.now,\n67\t      issuer,\n68\t    });\n69\t    payload = result.payload;\n70\t  } catch (error) {\n71\t    return { ok: false, reason: mapJoseError(error) };\n72\t  }\n73\t\n74\t  const email = typeof payload.email === \"string\" ? payload.email : null;\n75\t  return { ok: true, email: normalizeEmail(email) };\n76\t}\n77\t\n78\tfunction getRemoteJwks(issuer: string): JWTVerifyGetKey {\n79\t  const cached = remoteJwksCache.get(issuer);\n80\t  if (cached) {\n81\t    return cached;\n82\t  }\n83\t  const resolver = createRemoteJWKSet(new URL(`${issuer}/cdn-cgi/access/certs`));\n84\t  remoteJwksCache.set(issuer, resolver);\n85\t  return resolver;\n86\t}\n87\t\n88\tfunction mapJoseError(error: unknown): CloudflareAccessVerificationReason {\n89\t  if (error instanceof joseErrors.JWTExpired) {\n90\t    return \"expired_token\";\n91\t  }\n92\t  if (error instanceof joseErrors.JWTClaimValidationFailed) {\n93\t    if (error.claim === \"iss\") {\n94\t      return \"invalid_issuer\";\n95\t    }\n96\t    if (error.claim === \"aud\") {\n97\t      return \"invalid_audience\";\n98\t    }\n99\t    return \"invalid_claims\";\n100\t  }\n101\t  if (\n102\t    error instanceof joseErrors.JOSEAlgNotAllowed ||\n103\t    error instanceof joseErrors.JOSENotSupported\n104\t  ) {\n105\t    return \"unsupported_algorithm\";\n106\t  }\n107\t  if (error instanceof joseErrors.JWKSNoMatchingKey) {\n108\t    return \"missing_key\";\n109\t  }\n110\t  if (error instanceof joseErrors.JWSSignatureVerificationFailed) {\n111\t    return \"invalid_signature\";\n112\t  }\n113\t  if (\n114\t    error instanceof joseErrors.JWKSTimeout ||\n115\t    error instanceof joseErrors.JWKSInvalid ||\n116\t    error instanceof joseErrors.JWKInvalid\n117\t  ) {\n118\t    return \"jwks_unavailable\";\n119\t  }\n120\t  if (\n121\t    error instanceof joseErrors.JWTInvalid ||\n122\t    error instanceof joseErrors.JWSInvalid\n123\t  ) {\n124\t    return \"malformed_token\";\n125\t  }\n126\t  return \"jwks_unavailable\";\n127\t}\n128\t\n129\tfunction normalizeEmail(value: string | null | undefined): string | null {\n130\t  const email = value?.trim().toLowerCase();\n131\t\n132\t  if (!email || !/^[^\\s@]+@[^\\s@]+$/.test(email)) {\n133\t    return null;\n134\t  }\n135\t\n136\t  return email;\n137\t}\n138\t\n139\tfunction normalizeTeamDomain(value: string): string {\n140\t  return value.trim().replace(/\\/+$/, \"\");\n141\t}\n142\t"}]},"parent_tool_use_id":null,"session_id":"fbb345f7-d650-4fa3-be65-355d8ff344be","uuid":"0c102c6c-c25d-49d3-b300-d5812a2d60b3","timestamp":"2026-04-26T20:01:42.428Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/cloudflare-access.ts","content":"import {\n  createLocalJWKSet,\n  createRemoteJWKSet,\n  errors as joseErrors,\n  jwtVerify,\n  type JWK,\n  type JWTPayload,\n  type JWTVerifyGetKey,\n} from \"jose\";\n\nexport type CloudflareAccessVerificationReason =\n  | \"missing_token\"\n  | \"malformed_token\"\n  | \"unsupported_algorithm\"\n  | \"invalid_claims\"\n  | \"invalid_issuer\"\n  | \"invalid_audience\"\n  | \"expired_token\"\n  | \"missing_key\"\n  | \"invalid_signature\"\n  | \"jwks_unavailable\";\n\nexport type CloudflareAccessVerificationResult =\n  | { ok: true; email: string | null }\n  | { ok: false; reason: CloudflareAccessVerificationReason };\n\nexport interface CloudflareAccessVerificationOptions {\n  audience: string;\n  teamDomain: string;\n  jwks?: JWK[];\n  now?: Date;\n}\n\nexport const VERIFIED_ACCESS_EMAIL_HEADER = \"x-peek-verified-access-email\";\n\nconst remoteJwksCache = new Map<string, JWTVerifyGetKey>();\n\nexport async function getVerifiedCloudflareAccessEmailFromHeaders(\n  requestHeaders: Pick<Headers, \"get\">,\n  options: CloudflareAccessVerificationOptions,\n): Promise<CloudflareAccessVerificationResult> {\n  return verifyCloudflareAccessJwt(\n    requestHeaders.get(\"cf-access-jwt-assertion\"),\n    options,\n  );\n}\n\nexport async function verifyCloudflareAccessJwt(\n  token: string | null,\n  options: CloudflareAccessVerificationOptions,\n): Promise<CloudflareAccessVerificationResult> {\n  if (!token) {\n    return { ok: false, reason: \"missing_token\" };\n  }\n\n  const issuer = normalizeTeamDomain(options.teamDomain);\n  const getKey = options.jwks\n    ? createLocalJWKSet({ keys: options.jwks })\n    : getRemoteJwks(issuer);\n\n  let payload: JWTPayload;\n  try {\n    const result = await jwtVerify(token, getKey, {\n      algorithms: [\"RS256\"],\n      audience: options.audience,\n      currentDate: options.now,\n      issuer,\n    });\n    payload = result.payload;\n  } catch (error) {\n    return { ok: false, reason: mapJoseError(error) };\n  }\n\n  const email = typeof payload.email === \"string\" ? payload.email : null;\n  return { ok: true, email: normalizeEmail(email) };\n}\n\nfunction getRemoteJwks(issuer: string): JWTVerifyGetKey {\n  const cached = remoteJwksCache.get(issuer);\n  if (cached) {\n    return cached;\n  }\n  const resolver = createRemoteJWKSet(new URL(`${issuer}/cdn-cgi/access/certs`));\n  remoteJwksCache.set(issuer, resolver);\n  return resolver;\n}\n\nfunction mapJoseError(error: unknown): CloudflareAccessVerificationReason {\n  if (error instanceof joseErrors.JWTExpired) {\n    return \"expired_token\";\n  }\n  if (error instanceof joseErrors.JWTClaimValidationFailed) {\n    if (error.claim === \"iss\") {\n      return \"invalid_issuer\";\n    }\n    if (error.claim === \"aud\") {\n      return \"invalid_audience\";\n    }\n    return \"invalid_claims\";\n  }\n  if (\n    error instanceof joseErrors.JOSEAlgNotAllowed ||\n    error instanceof joseErrors.JOSENotSupported\n  ) {\n    return \"unsupported_algorithm\";\n  }\n  if (error instanceof joseErrors.JWKSNoMatchingKey) {\n    return \"missing_key\";\n  }\n  if (error instanceof joseErrors.JWSSignatureVerificationFailed) {\n    return \"invalid_signature\";\n  }\n  if (\n    error instanceof joseErrors.JWKSTimeout ||\n    error instanceof joseErrors.JWKSInvalid ||\n    error instanceof joseErrors.JWKInvalid\n  ) {\n    return \"jwks_unavailable\";\n  }\n  if (\n    error instanceof joseErrors.JWTInvalid ||\n    error instanceof joseErrors.JWSInvalid\n  ) {\n    return \"malformed_token\";\n  }\n  return \"jwks_unavailable\";\n}\n\nfunction normalizeEmail(value: string | null | undefined): string | null {\n  const email = value?.trim().toLowerCase();\n\n  if (!email || !/^[^\\s@]+@[^\\s@]+$/.test(email)) {\n    return null;\n  }\n\n  return email;\n}\n\nfunction normalizeTeamDomain(value: string): string {\n  return value.trim().replace(/\\/+$/, \"\");\n}\n","numLines":142,"startLine":1,"totalLines":142}}}
