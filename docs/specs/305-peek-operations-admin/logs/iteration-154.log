{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016QmvFTQ6HJTtV6sGL949qa","type":"tool_result","content":"1\t// Approved mutation registry (FR-14).\n2\t//\n3\t// The runner consumes a frozen registry keyed by stable action id. Each\n4\t// definition declares the FR-2 access-policy action id, the audit\n5\t// `resourceType` to record on `peek.change.applied`, a zod input schema, and\n6\t// an `execute` callback that runs inside a transaction (`sql.begin`) and\n7\t// returns the audit-friendly resource id + before/after change list.\n8\t//\n9\t// Adding a new approved mutation is a four-line change: import the\n10\t// definition, add it to the `entries` list, register the matching action id\n11\t// in `peek/src/server/access-policy.ts` (`PEEK_ACTION_RULES`) so the role\n12\t// check has a rule to find, and ship the matching frontend wiring iteration.\n13\t//\n14\t// Approved mutations land one at a time. The registered mutations to date are\n15\t// `kol_rate.update` (referral_kol_rates create/update),\n16\t// `fraud_flag.status.update` (fraud_flags status transition),\n17\t// `dogpile.cancel` (cancel a scheduled future dogpile_events row), and\n18\t// `reward_config.update` (edit a single allowlisted reward_config row).\n19\t\n20\timport type { Sql } from \"postgres\";\n21\timport type { ZodTypeAny } from \"zod\";\n22\timport type { PeekAuditChange } from \"../../lib/types/peek\";\n23\timport { dogpileCancelMutation } from \"./dogpile\";\n24\timport { fraudFlagStatusUpdateMutation } from \"./fraud-flag\";\n25\timport { kolRateUpdateMutation } from \"./kol-rate\";\n26\timport { rewardConfigUpdateMutation } from \"./reward-config\";\n27\t\n28\texport type PeekMutationActionId = string;\n29\t\n30\texport type PeekMutationActorContext = {\n31\t  email: string;\n32\t  route: string | null;\n33\t  requestId?: string | null;\n34\t};\n35\t\n36\texport type PeekMutationExecuteContext<TInput> = {\n37\t  input: TInput;\n38\t  sql: Sql;\n39\t  actor: PeekMutationActorContext;\n40\t};\n41\t\n42\texport type PeekMutationExecuteResult = {\n43\t  // Audit identifier for the row the mutation touched. `null` when the\n44\t  // mutation creates a new row whose id is not separately surfaced.\n45\t  resourceId: string | null;\n46\t  // Before/after diff persisted to the `peek.change.applied` audit payload.\n47\t  // `null` when the mutation does not produce a field-level diff (e.g.\n48\t  // a pure create).\n49\t  changes: ReadonlyArray<PeekAuditChange> | null;\n50\t};\n51\t\n52\texport type PeekMutationDefinition<TInput = unknown> = {\n53\t  actionId: PeekMutationActionId;\n54\t  resourceType: string;\n55\t  schema: ZodTypeAny;\n56\t  execute: (\n57\t    ctx: PeekMutationExecuteContext<TInput>,\n58\t  ) => Promise<PeekMutationExecuteResult>;\n59\t};\n60\t\n61\texport type PeekMutationRegistry = Readonly<\n62\t  Record<PeekMutationActionId, PeekMutationDefinition>\n63\t>;\n64\t\n65\tconst entries: ReadonlyArray<PeekMutationDefinition> = [\n66\t  kolRateUpdateMutation as PeekMutationDefinition,\n67\t  fraudFlagStatusUpdateMutation as PeekMutationDefinition,\n68\t  dogpileCancelMutation as PeekMutationDefinition,\n69\t  rewardConfigUpdateMutation as PeekMutationDefinition,\n70\t];\n71\t\n72\texport const PEEK_MUTATIONS: PeekMutationRegistry = Object.freeze(\n73\t  entries.reduce<Record<string, PeekMutationDefinition>>((acc, def) => {\n74\t    acc[def.actionId] = def;\n75\t    return acc;\n76\t  }, {}),\n77\t);\n78\t\n79\texport function getPeekMutation(\n80\t  actionId: PeekMutationActionId,\n81\t  registry: PeekMutationRegistry = PEEK_MUTATIONS,\n82\t): PeekMutationDefinition | null {\n83\t  return registry[actionId] ?? null;\n84\t}\n85\t"}]},"parent_tool_use_id":null,"session_id":"fbb345f7-d650-4fa3-be65-355d8ff344be","uuid":"986a3a61-824a-4069-a8dd-782dd2b44345","timestamp":"2026-04-26T20:01:45.835Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/mutations/registry.ts","content":"// Approved mutation registry (FR-14).\n//\n// The runner consumes a frozen registry keyed by stable action id. Each\n// definition declares the FR-2 access-policy action id, the audit\n// `resourceType` to record on `peek.change.applied`, a zod input schema, and\n// an `execute` callback that runs inside a transaction (`sql.begin`) and\n// returns the audit-friendly resource id + before/after change list.\n//\n// Adding a new approved mutation is a four-line change: import the\n// definition, add it to the `entries` list, register the matching action id\n// in `peek/src/server/access-policy.ts` (`PEEK_ACTION_RULES`) so the role\n// check has a rule to find, and ship the matching frontend wiring iteration.\n//\n// Approved mutations land one at a time. The registered mutations to date are\n// `kol_rate.update` (referral_kol_rates create/update),\n// `fraud_flag.status.update` (fraud_flags status transition),\n// `dogpile.cancel` (cancel a scheduled future dogpile_events row), and\n// `reward_config.update` (edit a single allowlisted reward_config row).\n\nimport type { Sql } from \"postgres\";\nimport type { ZodTypeAny } from \"zod\";\nimport type { PeekAuditChange } from \"../../lib/types/peek\";\nimport { dogpileCancelMutation } from \"./dogpile\";\nimport { fraudFlagStatusUpdateMutation } from \"./fraud-flag\";\nimport { kolRateUpdateMutation } from \"./kol-rate\";\nimport { rewardConfigUpdateMutation } from \"./reward-config\";\n\nexport type PeekMutationActionId = string;\n\nexport type PeekMutationActorContext = {\n  email: string;\n  route: string | null;\n  requestId?: string | null;\n};\n\nexport type PeekMutationExecuteContext<TInput> = {\n  input: TInput;\n  sql: Sql;\n  actor: PeekMutationActorContext;\n};\n\nexport type PeekMutationExecuteResult = {\n  // Audit identifier for the row the mutation touched. `null` when the\n  // mutation creates a new row whose id is not separately surfaced.\n  resourceId: string | null;\n  // Before/after diff persisted to the `peek.change.applied` audit payload.\n  // `null` when the mutation does not produce a field-level diff (e.g.\n  // a pure create).\n  changes: ReadonlyArray<PeekAuditChange> | null;\n};\n\nexport type PeekMutationDefinition<TInput = unknown> = {\n  actionId: PeekMutationActionId;\n  resourceType: string;\n  schema: ZodTypeAny;\n  execute: (\n    ctx: PeekMutationExecuteContext<TInput>,\n  ) => Promise<PeekMutationExecuteResult>;\n};\n\nexport type PeekMutationRegistry = Readonly<\n  Record<PeekMutationActionId, PeekMutationDefinition>\n>;\n\nconst entries: ReadonlyArray<PeekMutationDefinition> = [\n  kolRateUpdateMutation as PeekMutationDefinition,\n  fraudFlagStatusUpdateMutation as PeekMutationDefinition,\n  dogpileCancelMutation as PeekMutationDefinition,\n  rewardConfigUpdateMutation as PeekMutationDefinition,\n];\n\nexport const PEEK_MUTATIONS: PeekMutationRegistry = Object.freeze(\n  entries.reduce<Record<string, PeekMutationDefinition>>((acc, def) => {\n    acc[def.actionId] = def;\n    return acc;\n  }, {}),\n);\n\nexport function getPeekMutation(\n  actionId: PeekMutationActionId,\n  registry: PeekMutationRegistry = PEEK_MUTATIONS,\n): PeekMutationDefinition | null {\n  return registry[actionId] ?? null;\n}\n","numLines":85,"startLine":1,"totalLines":85}}}
