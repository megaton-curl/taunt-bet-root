{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XvMXCost2T8jn1yUVnQWF6","type":"tool_result","content":"1\t// Query tests for the FR-10 event-queue admin reads (`get-event-queue.ts`).\n2\t//\n3\t// Backs `/operations/queue`. The spec line driving these tests is:\n4\t// \"Queue query + page tests for pending, failed, dead, aged, filtered,\n5\t// redacted-payload states.\" Each case asserts:\n6\t//   - state-transition coverage (pending / processing / failed / dead);\n7\t//   - bounded SQL (limit clamps);\n8\t//   - filter binding into the right slot of the (`null` ? \"\" : value) toggle;\n9\t//   - age-bucket window application;\n10\t//   - secret redaction at every surfacing path (`error`, `payload`, linked ids).\n11\t//\n12\t// Mirrors the SQL-mock pattern used in `get-points-and-crates.test.ts`,\n13\t// `get-dogpile-and-fraud.test.ts`, and `get-rewards.test.ts`: a tagged-template\n14\t// stub records each call (joined SQL text + bound values) and dequeues a\n15\t// per-call response so each test can assert which SQL fired, in what order,\n16\t// and with which clamps.\n17\t//\n18\t// Read-only guarantee: every queue mutation (retry / cancel / replay) is\n19\t// explicitly out of scope for spec 305 (FR-10 line 342). These tests keep the\n20\t// queries SELECT-only so a future regression cannot silently introduce a\n21\t// queue write.\n22\t\n23\timport { describe, expect, it } from \"vitest\";\n24\timport type { Sql } from \"postgres\";\n25\timport {\n26\t  PEEK_EVENT_QUEUE_AGED_PENDING_HOURS,\n27\t  PEEK_EVENT_QUEUE_DEFAULT_LIMIT,\n28\t  PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS,\n29\t  PEEK_EVENT_QUEUE_MAX_LIMIT,\n30\t  PEEK_EVENT_QUEUE_TYPE_COUNT_LIMIT,\n31\t  getEventQueueDetail,\n32\t  getEventQueueOverview,\n33\t  listEventQueue,\n34\t} from \"../get-event-queue\";\n35\timport {\n36\t  PEEK_AUDIT_REDACTED,\n37\t  PEEK_EVENT_QUEUE_AGE_BUCKETS,\n38\t  PEEK_EVENT_QUEUE_OVERVIEW_METRIC_IDS,\n39\t  PEEK_EVENT_QUEUE_STATUSES,\n40\t} from \"../../../../lib/types/peek\";\n41\t\n42\ttype SqlCall = {\n43\t  text: string;\n44\t  values: ReadonlyArray<unknown>;\n45\t};\n46\t\n47\ttype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n48\t\n49\ttype SqlMock = {\n50\t  sql: Sql;\n51\t  calls: ReadonlyArray<SqlCall>;\n52\t};\n53\t\n54\tfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n55\t  const calls: SqlCall[] = [];\n56\t  let cursor = 0;\n57\t\n58\t  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n59\t    const text = [...strings].join(\"?\");\n60\t    calls.push({ text, values: [...values] });\n61\t    const next = responses[cursor++];\n62\t    if (next instanceof Error) return Promise.reject(next);\n63\t    return Promise.resolve(next ?? []);\n64\t  };\n65\t\n66\t  const sql = fn as unknown as Sql;\n67\t  return { sql, calls };\n68\t}\n69\t\n70\tfunction expectReadOnly(call: SqlCall) {\n71\t  expect(call.text).not.toMatch(/\\binsert\\s+into\\b/i);\n72\t  expect(call.text).not.toMatch(/\\bupdate\\s+\\w/i);\n73\t  expect(call.text).not.toMatch(/\\bdelete\\s+from\\b/i);\n74\t  expect(call.text).toMatch(/\\bselect\\b/i);\n75\t}\n76\t\n77\tdescribe(\"listEventQueue\", () => {\n78\t  it(\"default: clamps to PEEK_EVENT_QUEUE_DEFAULT_LIMIT and reads from event_queue with the right column projection\", async () => {\n79\t    const mock = createSqlMock([[]]);\n80\t    await listEventQueue({ sql: mock.sql });\n81\t\n82\t    expect(mock.calls).toHaveLength(1);\n83\t    const call = mock.calls[0];\n84\t    expectReadOnly(call);\n85\t    expect(call.text).toMatch(/from event_queue eq/i);\n86\t    // Linked-id projection mirrors the spec line \"linked user/round/claim\n87\t    // routes when identifiers are present\" (FR-10).\n88\t    expect(call.text).toMatch(/eq\\.payload->>'userId'/);\n89\t    expect(call.text).toMatch(/eq\\.payload->>'roundId'/);\n90\t    expect(call.text).toMatch(/eq\\.payload->>'claimId'/);\n91\t    expect(call.text).toMatch(/order by eq\\.created_at desc, eq\\.id desc/i);\n92\t    expect(call.values).toContain(PEEK_EVENT_QUEUE_DEFAULT_LIMIT);\n93\t  });\n94\t\n95\t  it(\"limit clamps to MAX when caller asks for more\", async () => {\n96\t    const mock = createSqlMock([[]]);\n97\t    await listEventQueue({\n98\t      sql: mock.sql,\n99\t      limit: PEEK_EVENT_QUEUE_MAX_LIMIT + 100,\n100\t    });"}]},"parent_tool_use_id":null,"session_id":"1edb02e8-e510-485b-94e1-43c571929f7f","uuid":"fbf97202-0d2b-42f7-aa11-699e8c88c683","timestamp":"2026-04-26T07:11:37.949Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-event-queue.test.ts","content":"// Query tests for the FR-10 event-queue admin reads (`get-event-queue.ts`).\n//\n// Backs `/operations/queue`. The spec line driving these tests is:\n// \"Queue query + page tests for pending, failed, dead, aged, filtered,\n// redacted-payload states.\" Each case asserts:\n//   - state-transition coverage (pending / processing / failed / dead);\n//   - bounded SQL (limit clamps);\n//   - filter binding into the right slot of the (`null` ? \"\" : value) toggle;\n//   - age-bucket window application;\n//   - secret redaction at every surfacing path (`error`, `payload`, linked ids).\n//\n// Mirrors the SQL-mock pattern used in `get-points-and-crates.test.ts`,\n// `get-dogpile-and-fraud.test.ts`, and `get-rewards.test.ts`: a tagged-template\n// stub records each call (joined SQL text + bound values) and dequeues a\n// per-call response so each test can assert which SQL fired, in what order,\n// and with which clamps.\n//\n// Read-only guarantee: every queue mutation (retry / cancel / replay) is\n// explicitly out of scope for spec 305 (FR-10 line 342). These tests keep the\n// queries SELECT-only so a future regression cannot silently introduce a\n// queue write.\n\nimport { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_EVENT_QUEUE_AGED_PENDING_HOURS,\n  PEEK_EVENT_QUEUE_DEFAULT_LIMIT,\n  PEEK_EVENT_QUEUE_ERROR_PREVIEW_CHARS,\n  PEEK_EVENT_QUEUE_MAX_LIMIT,\n  PEEK_EVENT_QUEUE_TYPE_COUNT_LIMIT,\n  getEventQueueDetail,\n  getEventQueueOverview,\n  listEventQueue,\n} from \"../get-event-queue\";\nimport {\n  PEEK_AUDIT_REDACTED,\n  PEEK_EVENT_QUEUE_AGE_BUCKETS,\n  PEEK_EVENT_QUEUE_OVERVIEW_METRIC_IDS,\n  PEEK_EVENT_QUEUE_STATUSES,\n} from \"../../../../lib/types/peek\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\nfunction expectReadOnly(call: SqlCall) {\n  expect(call.text).not.toMatch(/\\binsert\\s+into\\b/i);\n  expect(call.text).not.toMatch(/\\bupdate\\s+\\w/i);\n  expect(call.text).not.toMatch(/\\bdelete\\s+from\\b/i);\n  expect(call.text).toMatch(/\\bselect\\b/i);\n}\n\ndescribe(\"listEventQueue\", () => {\n  it(\"default: clamps to PEEK_EVENT_QUEUE_DEFAULT_LIMIT and reads from event_queue with the right column projection\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expectReadOnly(call);\n    expect(call.text).toMatch(/from event_queue eq/i);\n    // Linked-id projection mirrors the spec line \"linked user/round/claim\n    // routes when identifiers are present\" (FR-10).\n    expect(call.text).toMatch(/eq\\.payload->>'userId'/);\n    expect(call.text).toMatch(/eq\\.payload->>'roundId'/);\n    expect(call.text).toMatch(/eq\\.payload->>'claimId'/);\n    expect(call.text).toMatch(/order by eq\\.created_at desc, eq\\.id desc/i);\n    expect(call.values).toContain(PEEK_EVENT_QUEUE_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listEventQueue({\n      sql: mock.sql,\n      limit: PEEK_EVENT_QUEUE_MAX_LIMIT + 100,\n    });","numLines":100,"startLine":1,"totalLines":779}}}
