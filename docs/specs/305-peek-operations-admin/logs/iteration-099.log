{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VQq74T2MnUiN2ivDpU3E5L","type":"tool_result","content":"1\t// /operations/dogpile — Dogpile lifecycle + fraud review admin page (FR-9).\n2\t//\n3\t// Reads two migration-011 tables via `get-dogpile-and-fraud.ts` and composes\n4\t// the FR-4 metric strip with two operator surfaces:\n5\t//\n6\t//   - Dogpile events — scheduled / active / ended / cancelled lifecycle rows\n7\t//                       with per-event game_entries + point_grants window\n8\t//                       counts, filtered by status + starts_at range.\n9\t//   - Fraud flags    — read-only review queue (open / reviewed / dismissed)\n10\t//                       linked back to /users/[userId] with the JSONB\n11\t//                       `details` payload rendered verbatim.\n12\t//\n13\t// Both sections are read-only. Cancelling a scheduled dogpile event lives\n14\t// behind the FR-14 `dogpile.cancel` action id; transitioning a fraud flag\n15\t// lives behind the `fraud_flag.status.update` action id; neither mutation is\n16\t// implemented yet.\n17\timport type { CSSProperties } from \"react\";\n18\timport { DogpileEventsTable } from \"../../../src/components/dogpile-events-table\";\n19\timport { FraudFlagsTable } from \"../../../src/components/fraud-flags-table\";\n20\timport { MetricStrip } from \"../../../src/components/metric-strip\";\n21\timport {\n22\t  DogpileEventsFilterBar,\n23\t  FraudFlagsFilterBar,\n24\t} from \"../../../src/components/operations-dogpile-filter-bar\";\n25\timport {\n26\t  normalizeDogpileEventFiltersFromSearchParams,\n27\t  normalizeFraudFlagFiltersFromSearchParams,\n28\t} from \"../../../src/lib/operations-dogpile-search-params\";\n29\timport type {\n30\t  PeekDogpileEventRow,\n31\t  PeekDogpileFraudOverview,\n32\t  PeekFraudFlagListRow,\n33\t} from \"../../../src/lib/types/peek\";\n34\timport {\n35\t  getPeekActorContext,\n36\t  isRouteAllowedForRole,\n37\t} from \"../../../src/server/access-policy\";\n38\timport {\n39\t  PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT,\n40\t  PEEK_FRAUD_FLAGS_DEFAULT_LIMIT,\n41\t  getDogpileFraudOverview,\n42\t  listDogpileEvents,\n43\t  listFraudFlags,\n44\t} from \"../../../src/server/db/queries/get-dogpile-and-fraud\";\n45\t\n46\texport const dynamic = \"force-dynamic\";\n47\t\n48\tconst ROUTE = \"/operations/dogpile\";\n49\t\n50\texport default async function OperationsDogpilePage({\n51\t  searchParams,\n52\t}: {\n53\t  searchParams: Promise<Record<string, string | string[] | undefined>>;\n54\t}) {\n55\t  const actor = await getPeekActorContext();\n56\t  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n57\t\n58\t  if (!allowed) {\n59\t    return (\n60\t      <main style={mainStyle}>\n61\t        <header>\n62\t          <h1>Operations · Dogpile</h1>\n63\t        </header>\n64\t        <p role=\"alert\" style={errorStyle}>\n65\t          You do not have access to this page.\n66\t        </p>\n67\t      </main>\n68\t    );\n69\t  }\n70\t\n71\t  const params = await searchParams;\n72\t  const dogpileFilters = normalizeDogpileEventFiltersFromSearchParams(params);\n73\t  const fraudFilters = normalizeFraudFlagFiltersFromSearchParams(params);\n74\t\n75\t  let overview: PeekDogpileFraudOverview = {\n76\t    generatedAt: new Date().toISOString(),\n77\t    metrics: [],\n78\t  };\n79\t  let dogpileEvents: ReadonlyArray<PeekDogpileEventRow> = [];\n80\t  let fraudFlags: ReadonlyArray<PeekFraudFlagListRow> = [];\n81\t\n82\t  let overviewError: string | null = null;\n83\t  let dogpileError: string | null = null;\n84\t  let fraudError: string | null = null;\n85\t\n86\t  try {\n87\t    overview = await getDogpileFraudOverview();\n88\t  } catch (error) {\n89\t    overviewError =\n90\t      error instanceof Error\n91\t        ? error.message\n92\t        : \"Dogpile + fraud overview could not be loaded.\";\n93\t  }\n94\t\n95\t  try {\n96\t    dogpileEvents = await listDogpileEvents({ filters: dogpileFilters });\n97\t  } catch (error) {\n98\t    dogpileError =\n99\t      error instanceof Error\n100\t        ? error.message\n101\t        : \"Dogpile events could not be loaded.\";\n102\t  }\n103\t\n104\t  try {\n105\t    fraudFlags = await listFraudFlags({ filters: fraudFilters });\n106\t  } catch (error) {\n107\t    fraudError =\n108\t      error instanceof Error\n109\t        ? error.message\n110\t        : \"Fraud flags could not be loaded.\";\n111\t  }\n112\t\n113\t  return (\n114\t    <main style={mainStyle}>\n115\t      <header>\n116\t        <h1>Operations · Dogpile</h1>\n117\t        <p style={leadStyle}>\n118\t          Dogpile lifecycle (scheduled / active / ended / cancelled) and the\n119\t          fraud review queue. Read-only — cancelling a scheduled dogpile event\n120\t          and transitioning a fraud flag both live behind FR-14 mutation\n121\t          action ids that are not yet implemented.\n122\t        </p>\n123\t      </header>\n124\t\n125\t      <section aria-labelledby=\"overview-heading\">\n126\t        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n127\t          Overview\n128\t        </h2>\n129\t        <MetricStrip metrics={overview.metrics} error={overviewError} />\n130\t      </section>\n131\t\n132\t      <section\n133\t        aria-labelledby=\"dogpile-events-heading\"\n134\t        id=\"dogpile-events\"\n135\t        style={sectionStyle}\n136\t      >\n137\t        <h2 id=\"dogpile-events-heading\" style={sectionHeadingStyle}>\n138\t          Dogpile events\n139\t        </h2>\n140\t        <p style={hintStyle}>\n141\t          Default {PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT} rows · sorted newest\n142\t          starts first · server-side capped. Filter by status and a [from, to)\n143\t          starts-at window. Game-entries and point-grants counts reflect the\n144\t          rows whose `created_at` falls inside each event window. Read-only.\n145\t        </p>\n146\t        <DogpileEventsFilterBar filters={dogpileFilters} action={ROUTE} />\n147\t        <DogpileEventsTable rows={dogpileEvents} error={dogpileError} />\n148\t      </section>\n149\t\n150\t      <section\n151\t        aria-labelledby=\"fraud-heading\"\n152\t        id=\"fraud\"\n153\t        style={sectionStyle}\n154\t      >\n155\t        <h2 id=\"fraud-heading\" style={sectionHeadingStyle}>\n156\t          Fraud flags\n157\t        </h2>\n158\t        <p style={hintStyle}>\n159\t          Default {PEEK_FRAUD_FLAGS_DEFAULT_LIMIT} rows · sorted open first\n160\t          then newest · server-side capped. Filter by status, user, flag type,\n161\t          and a [from, to) created-at window. Read-only — status transitions\n162\t          are guarded by the `fraud_flag.status.update` mutation action.\n163\t        </p>\n164\t        <FraudFlagsFilterBar filters={fraudFilters} action={ROUTE} />\n165\t        <FraudFlagsTable rows={fraudFlags} error={fraudError} />\n166\t      </section>\n167\t    </main>\n168\t  );\n169\t}\n170\t\n171\tconst mainStyle: CSSProperties = {\n172\t  display: \"grid\",\n173\t  gap: \"1.5rem\",\n174\t};\n175\t\n176\tconst sectionStyle: CSSProperties = {\n177\t  display: \"grid\",\n178\t  gap: \"0.75rem\",\n179\t};\n180\t\n181\tconst sectionHeadingStyle: CSSProperties = {\n182\t  margin: \"0 0 0.75rem\",\n183\t  fontSize: \"1rem\",\n184\t  fontWeight: 600,\n185\t  color: \"#cbd5f5\",\n186\t  textTransform: \"uppercase\",\n187\t  letterSpacing: \"0.05em\",\n188\t};\n189\t\n190\tconst leadStyle: CSSProperties = {\n191\t  margin: \"0.25rem 0 0\",\n192\t  color: \"#94a3b8\",\n193\t};\n194\t\n195\tconst hintStyle: CSSProperties = {\n196\t  margin: 0,\n197\t  color: \"#94a3b8\",\n198\t  fontSize: \"0.8125rem\",\n199\t};\n200\t\n201\tconst errorStyle: CSSProperties = {\n202\t  margin: 0,\n203\t  padding: \"0.75rem 1rem\",\n204\t  borderRadius: \"0.75rem\",\n205\t  background: \"#3f1d1d\",\n206\t  color: \"#fecaca\",\n207\t};\n208\t"}]},"parent_tool_use_id":null,"session_id":"247526a1-4b21-4707-9ade-4ba9edd09da3","uuid":"7e92e390-e342-4620-8882-379eea9b4290","timestamp":"2026-04-26T06:33:46.017Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/app/operations/dogpile/page.tsx","content":"// /operations/dogpile — Dogpile lifecycle + fraud review admin page (FR-9).\n//\n// Reads two migration-011 tables via `get-dogpile-and-fraud.ts` and composes\n// the FR-4 metric strip with two operator surfaces:\n//\n//   - Dogpile events — scheduled / active / ended / cancelled lifecycle rows\n//                       with per-event game_entries + point_grants window\n//                       counts, filtered by status + starts_at range.\n//   - Fraud flags    — read-only review queue (open / reviewed / dismissed)\n//                       linked back to /users/[userId] with the JSONB\n//                       `details` payload rendered verbatim.\n//\n// Both sections are read-only. Cancelling a scheduled dogpile event lives\n// behind the FR-14 `dogpile.cancel` action id; transitioning a fraud flag\n// lives behind the `fraud_flag.status.update` action id; neither mutation is\n// implemented yet.\nimport type { CSSProperties } from \"react\";\nimport { DogpileEventsTable } from \"../../../src/components/dogpile-events-table\";\nimport { FraudFlagsTable } from \"../../../src/components/fraud-flags-table\";\nimport { MetricStrip } from \"../../../src/components/metric-strip\";\nimport {\n  DogpileEventsFilterBar,\n  FraudFlagsFilterBar,\n} from \"../../../src/components/operations-dogpile-filter-bar\";\nimport {\n  normalizeDogpileEventFiltersFromSearchParams,\n  normalizeFraudFlagFiltersFromSearchParams,\n} from \"../../../src/lib/operations-dogpile-search-params\";\nimport type {\n  PeekDogpileEventRow,\n  PeekDogpileFraudOverview,\n  PeekFraudFlagListRow,\n} from \"../../../src/lib/types/peek\";\nimport {\n  getPeekActorContext,\n  isRouteAllowedForRole,\n} from \"../../../src/server/access-policy\";\nimport {\n  PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT,\n  PEEK_FRAUD_FLAGS_DEFAULT_LIMIT,\n  getDogpileFraudOverview,\n  listDogpileEvents,\n  listFraudFlags,\n} from \"../../../src/server/db/queries/get-dogpile-and-fraud\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst ROUTE = \"/operations/dogpile\";\n\nexport default async function OperationsDogpilePage({\n  searchParams,\n}: {\n  searchParams: Promise<Record<string, string | string[] | undefined>>;\n}) {\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n\n  if (!allowed) {\n    return (\n      <main style={mainStyle}>\n        <header>\n          <h1>Operations · Dogpile</h1>\n        </header>\n        <p role=\"alert\" style={errorStyle}>\n          You do not have access to this page.\n        </p>\n      </main>\n    );\n  }\n\n  const params = await searchParams;\n  const dogpileFilters = normalizeDogpileEventFiltersFromSearchParams(params);\n  const fraudFilters = normalizeFraudFlagFiltersFromSearchParams(params);\n\n  let overview: PeekDogpileFraudOverview = {\n    generatedAt: new Date().toISOString(),\n    metrics: [],\n  };\n  let dogpileEvents: ReadonlyArray<PeekDogpileEventRow> = [];\n  let fraudFlags: ReadonlyArray<PeekFraudFlagListRow> = [];\n\n  let overviewError: string | null = null;\n  let dogpileError: string | null = null;\n  let fraudError: string | null = null;\n\n  try {\n    overview = await getDogpileFraudOverview();\n  } catch (error) {\n    overviewError =\n      error instanceof Error\n        ? error.message\n        : \"Dogpile + fraud overview could not be loaded.\";\n  }\n\n  try {\n    dogpileEvents = await listDogpileEvents({ filters: dogpileFilters });\n  } catch (error) {\n    dogpileError =\n      error instanceof Error\n        ? error.message\n        : \"Dogpile events could not be loaded.\";\n  }\n\n  try {\n    fraudFlags = await listFraudFlags({ filters: fraudFilters });\n  } catch (error) {\n    fraudError =\n      error instanceof Error\n        ? error.message\n        : \"Fraud flags could not be loaded.\";\n  }\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <h1>Operations · Dogpile</h1>\n        <p style={leadStyle}>\n          Dogpile lifecycle (scheduled / active / ended / cancelled) and the\n          fraud review queue. Read-only — cancelling a scheduled dogpile event\n          and transitioning a fraud flag both live behind FR-14 mutation\n          action ids that are not yet implemented.\n        </p>\n      </header>\n\n      <section aria-labelledby=\"overview-heading\">\n        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n          Overview\n        </h2>\n        <MetricStrip metrics={overview.metrics} error={overviewError} />\n      </section>\n\n      <section\n        aria-labelledby=\"dogpile-events-heading\"\n        id=\"dogpile-events\"\n        style={sectionStyle}\n      >\n        <h2 id=\"dogpile-events-heading\" style={sectionHeadingStyle}>\n          Dogpile events\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT} rows · sorted newest\n          starts first · server-side capped. Filter by status and a [from, to)\n          starts-at window. Game-entries and point-grants counts reflect the\n          rows whose `created_at` falls inside each event window. Read-only.\n        </p>\n        <DogpileEventsFilterBar filters={dogpileFilters} action={ROUTE} />\n        <DogpileEventsTable rows={dogpileEvents} error={dogpileError} />\n      </section>\n\n      <section\n        aria-labelledby=\"fraud-heading\"\n        id=\"fraud\"\n        style={sectionStyle}\n      >\n        <h2 id=\"fraud-heading\" style={sectionHeadingStyle}>\n          Fraud flags\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_FRAUD_FLAGS_DEFAULT_LIMIT} rows · sorted open first\n          then newest · server-side capped. Filter by status, user, flag type,\n          and a [from, to) created-at window. Read-only — status transitions\n          are guarded by the `fraud_flag.status.update` mutation action.\n        </p>\n        <FraudFlagsFilterBar filters={fraudFilters} action={ROUTE} />\n        <FraudFlagsTable rows={fraudFlags} error={fraudError} />\n      </section>\n    </main>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n","numLines":208,"startLine":1,"totalLines":208}}}
