{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011U2cdxMrburua71S3axMVS","type":"tool_result","content":"60\t};\n61\t\n62\tconst EMPTY_PROG_FILTERS: PeekProgressEventFilters = {\n63\t  assignmentId: null,\n64\t  challengeId: null,\n65\t  userId: null,\n66\t  roundId: null,\n67\t  createdFrom: null,\n68\t  createdTo: null,\n69\t};\n70\t\n71\tconst POPULATED_PROG_FILTERS: PeekProgressEventFilters = {\n72\t  assignmentId: \"asg-1\",\n73\t  challengeId: \"challenge-7\",\n74\t  userId: \"user-9\",\n75\t  roundId: \"round-PDA-x\",\n76\t  createdFrom: \"2026-04-01\",\n77\t  createdTo: \"2026-04-26\",\n78\t};\n79\t\n80\tconst EMPTY_BC_FILTERS: PeekBonusCompletionFilters = {\n81\t  userId: null,\n82\t  bonusId: null,\n83\t  campaignId: null,\n84\t  periodKey: null,\n85\t  completedFrom: null,\n86\t  completedTo: null,\n87\t};\n88\t\n89\tconst POPULATED_BC_FILTERS: PeekBonusCompletionFilters = {\n90\t  userId: \"user-1\",\n91\t  bonusId: \"bonus-9\",\n92\t  campaignId: \"campaign-3\",\n93\t  periodKey: \"2026-04-26\",\n94\t  completedFrom: \"2026-04-01\",\n95\t  completedTo: \"2026-04-26\",\n96\t};\n97\t\n98\tdescribe(\"ChallengesFilterBar\", () => {\n99\t  it(\"empty: form posts to /economy/challenges by default with both inputs blank and 'Any' selected\", () => {\n100\t    render(<ChallengesFilterBar filters={EMPTY_CH_FILTERS} />);\n101\t\n102\t    const form = screen.getByRole(\"search\", { name: \"Filter challenges\" });\n103\t    expect(form).toHaveAttribute(\"action\", \"/economy/challenges\");\n104\t    expect(form).toHaveAttribute(\"method\", \"get\");\n105\t\n106\t    expect(\n107\t      (screen.getByLabelText(\"Campaign ID\") as HTMLInputElement).value,\n108\t    ).toBe(\"\");\n109\t\n110\t    const isActive = screen.getByLabelText(\"Active?\") as HTMLSelectElement;\n111\t    expect(isActive.value).toBe(\"\");\n112\t    const optionValues = Array.from(isActive.options).map((o) => o.value);\n113\t    expect(optionValues).toContain(\"\");\n114\t    for (const value of PEEK_CHALLENGE_IS_ACTIVE_VALUES) {\n115\t      expect(optionValues).toContain(value);\n116\t    }\n117\t  });\n118\t\n119\t  it(\"populated: pre-fills every field including the isActive select\", () => {\n120\t    render(<ChallengesFilterBar filters={POPULATED_CH_FILTERS} />);\n121\t\n122\t    expect(\n123\t      (screen.getByLabelText(\"Campaign ID\") as HTMLInputElement).value,\n124\t    ).toBe(\"campaign-7\");\n125\t    expect(\n126\t      (screen.getByLabelText(\"Active?\") as HTMLSelectElement).value,\n127\t    ).toBe(\"true\");\n128\t  });\n129\t\n130\t  it(\"inputs use the chFilter* prefix so the form can co-exist with the other three\", () => {\n131\t    render(<ChallengesFilterBar filters={EMPTY_CH_FILTERS} />);\n132\t\n133\t    expect(\n134\t      (screen.getByLabelText(\"Campaign ID\") as HTMLInputElement).name,\n135\t    ).toBe(\"chFilterCampaignId\");\n136\t    expect(\n137\t      (screen.getByLabelText(\"Active?\") as HTMLSelectElement).name,\n138\t    ).toBe(\"chFilterIsActive\");\n139\t  });\n140\t\n141\t  it(\"custom action overrides the default form target\", () => {\n142\t    render(\n143\t      <ChallengesFilterBar\n144\t        filters={EMPTY_CH_FILTERS}\n145\t        action=\"/economy/challenges?embed=1\"\n146\t      />,\n147\t    );\n148\t\n149\t    const form = screen.getByRole(\"search\", { name: \"Filter challenges\" });\n150\t    expect(form).toHaveAttribute(\"action\", \"/economy/challenges?embed=1\");\n151\t  });\n152\t});\n153\t\n154\tdescribe(\"ChallengeAssignmentsFilterBar\", () => {\n155\t  it(\"empty: form posts to /economy/challenges with all inputs blank and the status select on 'Any'\", () => {\n156\t    render(\n157\t      <ChallengeAssignmentsFilterBar filters={EMPTY_ASG_FILTERS} />,\n158\t    );\n159\t\n160\t    const form = screen.getByRole(\"search\", {\n161\t      name: \"Filter challenge assignments\",\n162\t    });\n163\t    expect(form).toHaveAttribute(\"action\", \"/economy/challenges\");\n164\t    expect(form).toHaveAttribute(\"method\", \"get\");\n165\t\n166\t    const status = screen.getByLabelText(\"Status\") as HTMLSelectElement;\n167\t    expect(status.value).toBe(\"\");\n168\t    const optionValues = Array.from(status.options).map((o) => o.value);\n169\t    expect(optionValues).toContain(\"\");\n170\t    for (const value of PEEK_CHALLENGE_ASSIGNMENT_STATUSES) {\n171\t      expect(optionValues).toContain(value);\n172\t    }\n173\t  });\n174\t\n175\t  it(\"populated: pre-fills every input including the status select\", () => {\n176\t    render(\n177\t      <ChallengeAssignmentsFilterBar filters={POPULATED_ASG_FILTERS} />,\n178\t    );\n179\t\n180\t    expect(\n181\t      (screen.getByLabelText(\"User ID\") as HTMLInputElement).value,\n182\t    ).toBe(\"user-1\");\n183\t    expect(\n184\t      (screen.getByLabelText(\"Challenge ID\") as HTMLInputElement).value,\n185\t    ).toBe(\"challenge-7\");\n186\t    expect(\n187\t      (screen.getByLabelText(\"Campaign ID\") as HTMLInputElement).value,\n188\t    ).toBe(\"campaign-3\");\n189\t    expect(\n190\t      (screen.getByLabelText(\"Period key\") as HTMLInputElement).value,\n191\t    ).toBe(\"2026-04-26\");\n192\t    expect(\n193\t      (screen.getByLabelText(\"Status\") as HTMLSelectElement).value,\n194\t    ).toBe(\"active\");\n195\t    expect(\n196\t      (screen.getByLabelText(\"Assigned from\") as HTMLInputElement).value,\n197\t    ).toBe(\"2026-04-01\");\n198\t    expect(\n199\t      (screen.getByLabelText(\"Assigned to\") as HTMLInputElement).value,\n200\t    ).toBe(\"2026-04-26\");\n201\t  });\n202\t\n203\t  it(\"inputs use the asgFilter* prefix so the form can co-exist with the other three\", () => {\n204\t    render(\n205\t      <ChallengeAssignmentsFilterBar filters={EMPTY_ASG_FILTERS} />,\n206\t    );\n207\t\n208\t    expect(\n209\t      (screen.getByLabelText(\"User ID\") as HTMLInputElement).name,\n210\t    ).toBe(\"asgFilterUserId\");\n211\t    expect(\n212\t      (screen.getByLabelText(\"