{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RLHbkw1qfwWNysDNjvW45C","type":"tool_result","content":"1\t// Component tests for the FR-9 /economy/challenges filter bars.\n2\t//\n3\t// Four prefixed forms (`chFilter*`, `asgFilter*`, `progFilter*`, `bcFilter*`)\n4\t// share the same /economy/challenges page so each table can be filtered\n5\t// independently while the URL stays shareable. These tests verify:\n6\t//   - the form posts to /economy/challenges via GET\n7\t//   - each input uses its prefixed name (no collision across forms)\n8\t//   - the status + isActive selects expose every allowlisted enum value\n9\t//   - populated filters pre-fill every field\n10\t//   - ISO timestamps in date filters are truncated to YYYY-MM-DD\n11\t//   - the custom action prop overrides the default form target\n12\t\n13\timport { describe, expect, it } from \"vitest\";\n14\timport { render, screen } from \"@testing-library/react\";\n15\timport {\n16\t  BonusCompletionsFilterBar,\n17\t  ChallengeAssignmentsFilterBar,\n18\t  ChallengesFilterBar,\n19\t  ProgressEventsFilterBar,\n20\t} from \"../economy-challenges-filter-bar\";\n21\timport {\n22\t  PEEK_CHALLENGE_ASSIGNMENT_STATUSES,\n23\t  PEEK_CHALLENGE_IS_ACTIVE_VALUES,\n24\t} from \"../../lib/economy-challenges-search-params\";\n25\timport type {\n26\t  PeekBonusCompletionFilters,\n27\t  PeekChallengeAssignmentFilters,\n28\t  PeekChallengeFilters,\n29\t  PeekProgressEventFilters,\n30\t} from \"../../lib/types/peek\";\n31\t\n32\tconst EMPTY_CH_FILTERS: PeekChallengeFilters = {\n33\t  campaignId: null,\n34\t  isActive: null,\n35\t};\n36\t\n37\tconst POPULATED_CH_FILTERS: PeekChallengeFilters = {\n38\t  campaignId: \"campaign-7\",\n39\t  isActive: \"true\",\n40\t};\n41\t\n42\tconst EMPTY_ASG_FILTERS: PeekChallengeAssignmentFilters = {\n43\t  userId: null,\n44\t  challengeId: null,\n45\t  campaignId: null,\n46\t  periodKey: null,\n47\t  status: null,\n48\t  assignedFrom: null,\n49\t  assignedTo: null,\n50\t};\n51\t\n52\tconst POPULATED_ASG_FILTERS: PeekChallengeAssignmentFilters = {\n53\t  userId: \"user-1\",\n54\t  challengeId: \"challenge-7\",\n55\t  campaignId: \"campaign-3\",\n56\t  periodKey: \"2026-04-26\",\n57\t  status: \"active\",\n58\t  assignedFrom: \"2026-04-01\",\n59\t  assignedTo: \"2026-04-26\",\n60\t};"}]},"parent_tool_use_id":null,"session_id":"247526a1-4b21-4707-9ade-4ba9edd09da3","uuid":"421ba375-3de9-49af-a6e8-2ac1323ca880","timestamp":"2026-04-26T06:34:26.001Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/economy-challenges-filter-bar.test.tsx","content":"// Component tests for the FR-9 /economy/challenges filter bars.\n//\n// Four prefixed forms (`chFilter*`, `asgFilter*`, `progFilter*`, `bcFilter*`)\n// share the same /economy/challenges page so each table can be filtered\n// independently while the URL stays shareable. These tests verify:\n//   - the form posts to /economy/challenges via GET\n//   - each input uses its prefixed name (no collision across forms)\n//   - the status + isActive selects expose every allowlisted enum value\n//   - populated filters pre-fill every field\n//   - ISO timestamps in date filters are truncated to YYYY-MM-DD\n//   - the custom action prop overrides the default form target\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport {\n  BonusCompletionsFilterBar,\n  ChallengeAssignmentsFilterBar,\n  ChallengesFilterBar,\n  ProgressEventsFilterBar,\n} from \"../economy-challenges-filter-bar\";\nimport {\n  PEEK_CHALLENGE_ASSIGNMENT_STATUSES,\n  PEEK_CHALLENGE_IS_ACTIVE_VALUES,\n} from \"../../lib/economy-challenges-search-params\";\nimport type {\n  PeekBonusCompletionFilters,\n  PeekChallengeAssignmentFilters,\n  PeekChallengeFilters,\n  PeekProgressEventFilters,\n} from \"../../lib/types/peek\";\n\nconst EMPTY_CH_FILTERS: PeekChallengeFilters = {\n  campaignId: null,\n  isActive: null,\n};\n\nconst POPULATED_CH_FILTERS: PeekChallengeFilters = {\n  campaignId: \"campaign-7\",\n  isActive: \"true\",\n};\n\nconst EMPTY_ASG_FILTERS: PeekChallengeAssignmentFilters = {\n  userId: null,\n  challengeId: null,\n  campaignId: null,\n  periodKey: null,\n  status: null,\n  assignedFrom: null,\n  assignedTo: null,\n};\n\nconst POPULATED_ASG_FILTERS: PeekChallengeAssignmentFilters = {\n  userId: \"user-1\",\n  challengeId: \"challenge-7\",\n  campaignId: \"campaign-3\",\n  periodKey: \"2026-04-26\",\n  status: \"active\",\n  assignedFrom: \"2026-04-01\",\n  assignedTo: \"2026-04-26\",\n};","numLines":60,"startLine":1,"totalLines":425}}}
