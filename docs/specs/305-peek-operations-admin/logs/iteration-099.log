{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ASMrKjTv5f9jGTAKWudCZJ","type":"tool_result","content":"1\t// Tests for the FR-9 /economy/challenges URL-addressable filter normalisers.\n2\t//\n3\t// Four prefixed param groups (`chFilter*`, `asgFilter*`, `progFilter*`,\n4\t// `bcFilter*`) co-exist on the same page so each table can be filtered\n5\t// independently. The normalisers are the contract that keeps a stale URL\n6\t// chip from lying about a table's filter state — empty/whitespace → null,\n7\t// unknown enum → null, recognised allowlist values pass through.\n8\t\n9\timport { describe, expect, it } from \"vitest\";\n10\timport {\n11\t  PEEK_CHALLENGE_ASSIGNMENT_STATUSES,\n12\t  PEEK_CHALLENGE_IS_ACTIVE_VALUES,\n13\t  normalizeBonusCompletionFiltersFromSearchParams,\n14\t  normalizeChallengeAssignmentFiltersFromSearchParams,\n15\t  normalizeChallengeFiltersFromSearchParams,\n16\t  normalizeProgressEventFiltersFromSearchParams,\n17\t} from \"../economy-challenges-search-params\";\n18\t\n19\tdescribe(\"normalizeChallengeFiltersFromSearchParams\", () => {\n20\t  it(\"empty input: every filter normalises to null\", () => {\n21\t    expect(normalizeChallengeFiltersFromSearchParams({})).toEqual({\n22\t      campaignId: null,\n23\t      isActive: null,\n24\t    });\n25\t  });\n26\t\n27\t  it(\"whitespace-only values normalise to null\", () => {\n28\t    expect(\n29\t      normalizeChallengeFiltersFromSearchParams({\n30\t        chFilterCampaignId: \"   \",\n31\t        chFilterIsActive: \"   \",\n32\t      }),\n33\t    ).toEqual({ campaignId: null, isActive: null });\n34\t  });\n35\t\n36\t  it(\"populated: campaignId is trimmed; allowlisted isActive value passes through\", () => {\n37\t    const filters = normalizeChallengeFiltersFromSearchParams({\n38\t      chFilterCampaignId: \"  campaign-7  \",\n39\t      chFilterIsActive: \"true\",\n40\t    });\n41\t    expect(filters.campaignId).toBe(\"campaign-7\");\n42\t    expect(filters.isActive).toBe(\"true\");\n43\t  });\n44\t\n45\t  it(\"isActive: every allowlisted value passes through verbatim\", () => {\n46\t    for (const value of PEEK_CHALLENGE_IS_ACTIVE_VALUES) {\n47\t      const filters = normalizeChallengeFiltersFromSearchParams({\n48\t        chFilterIsActive: value,\n49\t      });\n50\t      expect(filters.isActive).toBe(value);\n51\t    }\n52\t  });\n53\t\n54\t  it(\"isActive: unknown enum value normalises to null so a stale URL chip cannot lie\", () => {\n55\t    expect(\n56\t      normalizeChallengeFiltersFromSearchParams({\n57\t        chFilterIsActive: \"maybe\",\n58\t      }).isActive,\n59\t    ).toBeNull();\n60\t  });\n61\t\n62\t  it(\"array values: only the first element is read\", () => {\n63\t    expect(\n64\t      normalizeChallengeFiltersFromSearchParams({\n65\t        chFilterCampaignId: [\"campaign-7\", \"campaign-8\"],\n66\t      }).campaignId,\n67\t    ).toBe(\"campaign-7\");\n68\t  });\n69\t});\n70\t\n71\tdescribe(\"normalizeChallengeAssignmentFiltersFromSearchParams\", () => {\n72\t  it(\"empty input: every filter normalises to null\", () => {\n73\t    expect(\n74\t      normalizeChallengeAssignmentFiltersFromSearchParams({}),\n75\t    ).toEqual({\n76\t      userId: null,\n77\t      challengeId: null,\n78\t      campaignId: null,\n79\t      periodKey: null,\n80\t      status: null,\n81\t      assignedFrom: null,\n82\t      assignedTo: null,\n83\t    });\n84\t  });\n85\t\n86\t  it(\"populated: every field flows through with trimming applied\", () => {\n87\t    const filters = normalizeChallengeAssignmentFiltersFromSearchParams({\n88\t      asgFilterUserId: \"user-1\",\n89\t      asgFilterChallengeId: \" challenge-7 \",\n90\t      asgFilterCampaignId: \"campaign-3\",\n91\t      asgFilterPeriodKey: \"2026-04-26\",\n92\t      asgFilterStatus: \"active\",\n93\t      asgFilterFrom: \"2026-04-01\",\n94\t      asgFilterTo: \"2026-04-26\",\n95\t    });\n96\t    expect(filters).toEqual({\n97\t      userId: \"user-1\",\n98\t      challengeId: \"challenge-7\",\n99\t      campaignId: \"campaign-3\",\n100\t      periodKey: \"2026-04-26\",\n101\t      status: \"active\",\n102\t      assignedFrom: \"2026-04-01\",\n103\t      assignedTo: \"2026-04-26\",\n104\t    });\n105\t  });\n106\t\n107\t  it(\"status transitions: every allowlisted value passes through verbatim\", () => {\n108\t    for (const status of PEEK_CHALLENGE_ASSIGNMENT_STATUSES) {\n109\t      const filters = normalizeChallengeAssignmentFiltersFromSearchParams({\n110\t        asgFilterStatus: status,\n111\t      });\n112\t      expect(filters.status).toBe(status);\n113\t    }\n114\t  });\n115\t\n116\t  it(\"status transitions: unknown enum value normalises to null\", () => {\n117\t    expect(\n118\t      normalizeChallengeAssignmentFiltersFromSearchParams({\n119\t        asgFilterStatus: \"stalled\",\n120\t      }).status,\n121\t    ).toBeNull();\n122\t  });\n123\t\n124\t  it(\"status transitions: empty status normalises to null\", () => {\n125\t    expect(\n126\t      normalizeChallengeAssignmentFiltersFromSearchParams({\n127\t        asgFilterStatus: \"\",\n128\t      }).status,\n129\t    ).toBeNull();\n130\t  });\n131\t});\n132\t\n133\tdescribe(\"normalizeProgressEventFiltersFromSearchParams\", () => {\n134\t  it(\"empty input: every filter normalises to null\", () => {\n135\t    expect(normalizeProgressEventFiltersFromSearchParams({})).toEqual({\n136\t      assignmentId: null,\n137\t      challengeId: null,\n138\t      userId: null,\n139\t      roundId: null,\n140\t      createdFrom: null,\n141\t      createdTo: null,\n142\t    });\n143\t  });\n144\t\n145\t  it(\"populated: every field flows through with trimming\", () => {\n146\t    const filters = normalizeProgressEventFiltersFromSearchParams({\n147\t      progFilterAssignmentId: \" asg-1 \",\n148\t      progFilterChallengeId: \"challenge-7\",\n149\t      progFilterUserId: \"user-9\",\n150\t      progFilterRoundId: \"round-PDA-x\",\n151\t      progFilterFrom: \"2026-04-01\",\n152\t      progFilterTo: \"2026-04-26\",\n153\t    });\n154\t    expect(filters).toEqual({\n155\t      assignmentId: \"asg-1\",\n156\t      challengeId: \"challenge-7\",\n157\t      userId: \"user-9\",\n158\t      roundId: \"round-PDA-x\",\n159\t      createdFrom: \"2026-04-01\",\n160\t      createdTo: \"2026-04-26\",\n161\t    });\n162\t  });\n163\t});\n164\t\n165\tdescribe(\"normalizeBonusCompletionFiltersFromSearchParams\", () => {\n166\t  it(\"empty input: every filter normalises to null\", () => {\n167\t    expect(normalizeBonusCompletionFiltersFromSearchParams({})).toEqual({\n168\t      userId: null,\n169\t      bonusId: null,\n170\t      campaignId: null,\n171\t      periodKey: null,\n172\t      completedFrom: null,\n173\t      completedTo: null,\n174\t    });\n175\t  });\n176\t\n177\t  it(\"populated: every field flows through with trimming\", () => {\n178\t    const filters = normalizeBonusCompletionFiltersFromSearchParams({\n179\t      bcFilterUserId: \" user-1 \",\n180\t      bcFilterBonusId: \"bonus-9\",\n181\t      bcFilterCampaignId: \"campaign-3\",\n182\t      bcFilterPeriodKey: \"2026-04-26\",\n183\t      bcFilterFrom: \"2026-04-01\",\n184\t      bcFilterTo: \"2026-04-26\",\n185\t    });\n186\t    expect(filters).toEqual({\n187\t      userId: \"user-1\",\n188\t      bonusId: \"bonus-9\",\n189\t      campaignId: \"campaign-3\",\n190\t      periodKey: \"2026-04-26\",\n191\t      completedFrom: \"2026-04-01\",\n192\t      completedTo: \"2026-04-26\",\n193\t    });\n194\t  });\n195\t});\n196\t"}]},"parent_tool_use_id":null,"session_id":"247526a1-4b21-4707-9ade-4ba9edd09da3","uuid":"896076aa-2f8a-47b1-8f50-5460e5be4069","timestamp":"2026-04-26T06:34:12.624Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/__tests__/economy-challenges-search-params.test.ts","content":"// Tests for the FR-9 /economy/challenges URL-addressable filter normalisers.\n//\n// Four prefixed param groups (`chFilter*`, `asgFilter*`, `progFilter*`,\n// `bcFilter*`) co-exist on the same page so each table can be filtered\n// independently. The normalisers are the contract that keeps a stale URL\n// chip from lying about a table's filter state — empty/whitespace → null,\n// unknown enum → null, recognised allowlist values pass through.\n\nimport { describe, expect, it } from \"vitest\";\nimport {\n  PEEK_CHALLENGE_ASSIGNMENT_STATUSES,\n  PEEK_CHALLENGE_IS_ACTIVE_VALUES,\n  normalizeBonusCompletionFiltersFromSearchParams,\n  normalizeChallengeAssignmentFiltersFromSearchParams,\n  normalizeChallengeFiltersFromSearchParams,\n  normalizeProgressEventFiltersFromSearchParams,\n} from \"../economy-challenges-search-params\";\n\ndescribe(\"normalizeChallengeFiltersFromSearchParams\", () => {\n  it(\"empty input: every filter normalises to null\", () => {\n    expect(normalizeChallengeFiltersFromSearchParams({})).toEqual({\n      campaignId: null,\n      isActive: null,\n    });\n  });\n\n  it(\"whitespace-only values normalise to null\", () => {\n    expect(\n      normalizeChallengeFiltersFromSearchParams({\n        chFilterCampaignId: \"   \",\n        chFilterIsActive: \"   \",\n      }),\n    ).toEqual({ campaignId: null, isActive: null });\n  });\n\n  it(\"populated: campaignId is trimmed; allowlisted isActive value passes through\", () => {\n    const filters = normalizeChallengeFiltersFromSearchParams({\n      chFilterCampaignId: \"  campaign-7  \",\n      chFilterIsActive: \"true\",\n    });\n    expect(filters.campaignId).toBe(\"campaign-7\");\n    expect(filters.isActive).toBe(\"true\");\n  });\n\n  it(\"isActive: every allowlisted value passes through verbatim\", () => {\n    for (const value of PEEK_CHALLENGE_IS_ACTIVE_VALUES) {\n      const filters = normalizeChallengeFiltersFromSearchParams({\n        chFilterIsActive: value,\n      });\n      expect(filters.isActive).toBe(value);\n    }\n  });\n\n  it(\"isActive: unknown enum value normalises to null so a stale URL chip cannot lie\", () => {\n    expect(\n      normalizeChallengeFiltersFromSearchParams({\n        chFilterIsActive: \"maybe\",\n      }).isActive,\n    ).toBeNull();\n  });\n\n  it(\"array values: only the first element is read\", () => {\n    expect(\n      normalizeChallengeFiltersFromSearchParams({\n        chFilterCampaignId: [\"campaign-7\", \"campaign-8\"],\n      }).campaignId,\n    ).toBe(\"campaign-7\");\n  });\n});\n\ndescribe(\"normalizeChallengeAssignmentFiltersFromSearchParams\", () => {\n  it(\"empty input: every filter normalises to null\", () => {\n    expect(\n      normalizeChallengeAssignmentFiltersFromSearchParams({}),\n    ).toEqual({\n      userId: null,\n      challengeId: null,\n      campaignId: null,\n      periodKey: null,\n      status: null,\n      assignedFrom: null,\n      assignedTo: null,\n    });\n  });\n\n  it(\"populated: every field flows through with trimming applied\", () => {\n    const filters = normalizeChallengeAssignmentFiltersFromSearchParams({\n      asgFilterUserId: \"user-1\",\n      asgFilterChallengeId: \" challenge-7 \",\n      asgFilterCampaignId: \"campaign-3\",\n      asgFilterPeriodKey: \"2026-04-26\",\n      asgFilterStatus: \"active\",\n      asgFilterFrom: \"2026-04-01\",\n      asgFilterTo: \"2026-04-26\",\n    });\n    expect(filters).toEqual({\n      userId: \"user-1\",\n      challengeId: \"challenge-7\",\n      campaignId: \"campaign-3\",\n      periodKey: \"2026-04-26\",\n      status: \"active\",\n      assignedFrom: \"2026-04-01\",\n      assignedTo: \"2026-04-26\",\n    });\n  });\n\n  it(\"status transitions: every allowlisted value passes through verbatim\", () => {\n    for (const status of PEEK_CHALLENGE_ASSIGNMENT_STATUSES) {\n      const filters = normalizeChallengeAssignmentFiltersFromSearchParams({\n        asgFilterStatus: status,\n      });\n      expect(filters.status).toBe(status);\n    }\n  });\n\n  it(\"status transitions: unknown enum value normalises to null\", () => {\n    expect(\n      normalizeChallengeAssignmentFiltersFromSearchParams({\n        asgFilterStatus: \"stalled\",\n      }).status,\n    ).toBeNull();\n  });\n\n  it(\"status transitions: empty status normalises to null\", () => {\n    expect(\n      normalizeChallengeAssignmentFiltersFromSearchParams({\n        asgFilterStatus: \"\",\n      }).status,\n    ).toBeNull();\n  });\n});\n\ndescribe(\"normalizeProgressEventFiltersFromSearchParams\", () => {\n  it(\"empty input: every filter normalises to null\", () => {\n    expect(normalizeProgressEventFiltersFromSearchParams({})).toEqual({\n      assignmentId: null,\n      challengeId: null,\n      userId: null,\n      roundId: null,\n      createdFrom: null,\n      createdTo: null,\n    });\n  });\n\n  it(\"populated: every field flows through with trimming\", () => {\n    const filters = normalizeProgressEventFiltersFromSearchParams({\n      progFilterAssignmentId: \" asg-1 \",\n      progFilterChallengeId: \"challenge-7\",\n      progFilterUserId: \"user-9\",\n      progFilterRoundId: \"round-PDA-x\",\n      progFilterFrom: \"2026-04-01\",\n      progFilterTo: \"2026-04-26\",\n    });\n    expect(filters).toEqual({\n      assignmentId: \"asg-1\",\n      challengeId: \"challenge-7\",\n      userId: \"user-9\",\n      roundId: \"round-PDA-x\",\n      createdFrom: \"2026-04-01\",\n      createdTo: \"2026-04-26\",\n    });\n  });\n});\n\ndescribe(\"normalizeBonusCompletionFiltersFromSearchParams\", () => {\n  it(\"empty input: every filter normalises to null\", () => {\n    expect(normalizeBonusCompletionFiltersFromSearchParams({})).toEqual({\n      userId: null,\n      bonusId: null,\n      campaignId: null,\n      periodKey: null,\n      completedFrom: null,\n      completedTo: null,\n    });\n  });\n\n  it(\"populated: every field flows through with trimming\", () => {\n    const filters = normalizeBonusCompletionFiltersFromSearchParams({\n      bcFilterUserId: \" user-1 \",\n      bcFilterBonusId: \"bonus-9\",\n      bcFilterCampaignId: \"campaign-3\",\n      bcFilterPeriodKey: \"2026-04-26\",\n      bcFilterFrom: \"2026-04-01\",\n      bcFilterTo: \"2026-04-26\",\n    });\n    expect(filters).toEqual({\n      userId: \"user-1\",\n      bonusId: \"bonus-9\",\n      campaignId: \"campaign-3\",\n      periodKey: \"2026-04-26\",\n      completedFrom: \"2026-04-01\",\n      completedTo: \"2026-04-26\",\n    });\n  });\n});\n","numLines":196,"startLine":1,"totalLines":196}}}
