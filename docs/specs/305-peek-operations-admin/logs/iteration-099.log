n co-exist with the other three\", () => {\n    render(<BonusCompletionsFilterBar filters={EMPTY_BC_FILTERS} />);\n\n    expect(\n      (screen.getByLabelText(\"User ID\") as HTMLInputElement).name,\n    ).toBe(\"bcFilterUserId\");\n    expect(\n      (screen.getByLabelText(\"Bonus ID\") as HTMLInputElement).name,\n    ).toBe(\"bcFilterBonusId\");\n    expect(\n      (screen.getByLabelText(\"Campaign ID\") as HTMLInputElement).name,\n    ).toBe(\"bcFilterCampaignId\");\n    expect(\n      (screen.getByLabelText(\"Period key\") as HTMLInputElement).name,\n    ).toBe(\"bcFilterPeriodKey\");\n    expect(\n      (screen.getByLabelText(\"Completed from\") as HTMLInputElement).name,\n    ).toBe(\"bcFilterFrom\");\n    expect(\n      (screen.getByLabelText(\"Completed to\") as HTMLInputElement).name,\n    ).toBe(\"bcFilterTo\");\n  });\n\n  it(\"populated: ISO timestamps in completedFrom/completedTo are truncated to YYYY-MM-DD\", () => {\n    render(\n      <BonusCompletionsFilterBar\n        filters={{\n          ...EMPTY_BC_FILTERS,\n          completedFrom: \"2026-04-01T10:00:00.000Z\",\n          completedTo: \"2026-04-26T23:59:59.999Z\",\n        }}\n      />,\n    );\n\n    expect(\n      (screen.getByLabelText(\"Completed from\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-01\");\n    expect(\n      (screen.getByLabelText(\"Completed to\") as HTMLInputElement).value,\n    ).toBe(\"2026-04-26\");\n  });\n});\n","numLines":366,"startLine":60,"totalLines":425}}}
