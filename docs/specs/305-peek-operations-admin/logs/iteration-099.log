{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BDg1Xfn3zH7WE1uir8jyTA","type":"tool_result","content":"1\t// Component tests for the FR-9 campaigns table.\n2\t//\n3\t// Read-only by spec (FR-9 / FR-14 — challenge / campaign / completion-bonus\n4\t// definition editing is out of scope), so these tests assert there are no\n5\t// edit affordances rendered: no buttons, no editable inputs, and the row\n6\t// structure is just the dense table the operator drills down from.\n7\t\n8\timport { describe, expect, it } from \"vitest\";\n9\timport { render, screen } from \"@testing-library/react\";\n10\timport { CampaignsTable } from \"../campaigns-table\";\n11\timport type { PeekCampaignRow } from \"../../lib/types/peek\";\n12\t\n13\tconst ROW_DAILY: PeekCampaignRow = {\n14\t  id: \"1\",\n15\t  name: \"Daily challenges\",\n16\t  campaignType: \"daily\",\n17\t  startsAt: \"2026-04-25T00:00:00.000Z\",\n18\t  endsAt: \"2026-12-31T23:59:59.000Z\",\n19\t  isActive: true,\n20\t  createdAt: \"2026-04-01T00:00:00.000Z\",\n21\t  challengeCount: 5,\n22\t  activeAssignmentCount: 1234,\n23\t};\n24\t\n25\tconst ROW_INACTIVE_ONBOARDING: PeekCampaignRow = {\n26\t  id: \"2\",\n27\t  name: \"Onboarding crate\",\n28\t  campaignType: \"onboarding\",\n29\t  startsAt: null,\n30\t  endsAt: null,\n31\t  isActive: false,\n32\t  createdAt: \"2026-03-01T00:00:00.000Z\",\n33\t  challengeCount: 0,\n34\t  activeAssignmentCount: 0,\n35\t};\n36\t\n37\tconst ROW_DOGPILE: PeekCampaignRow = {\n38\t  id: \"3\",\n39\t  name: \"Bull-run dogpile\",\n40\t  campaignType: \"dogpile\",\n41\t  startsAt: \"2026-04-26T10:00:00.000Z\",\n42\t  endsAt: \"2026-04-26T12:00:00.000Z\",\n43\t  isActive: true,\n44\t  createdAt: \"2026-04-26T09:00:00.000Z\",\n45\t  challengeCount: 2,\n46\t  activeAssignmentCount: 87,\n47\t};\n48\t\n49\tdescribe(\"CampaignsTable\", () => {\n50\t  it(\"populated: renders the operator columns and the type/state chips\", () => {\n51\t    render(<CampaignsTable rows={[ROW_DAILY, ROW_INACTIVE_ONBOARDING]} />);\n52\t\n53\t    for (const header of [\n54\t      \"Name\",\n55\t      \"Type\",\n56\t      \"State\",\n57\t      \"Starts\",\n58\t      \"Ends\",\n59\t      \"Challenges\",\n60\t      \"Active assignments\",\n61\t      \"Created\",\n62\t      \"ID\",\n63\t    ]) {\n64\t      expect(screen.getByText(header)).toBeInTheDocument();\n65\t    }\n66\t\n67\t    expect(screen.getByText(\"Daily challenges\")).toBeInTheDocument();\n68\t    expect(screen.getByText(\"Onboarding crate\")).toBeInTheDocument();\n69\t    expect(screen.getByText(\"daily\")).toBeInTheDocument();\n70\t    expect(screen.getByText(\"onboarding\")).toBeInTheDocument();\n71\t    expect(screen.getByText(\"active\")).toBeInTheDocument();\n72\t    expect(screen.getByText(\"inactive\")).toBeInTheDocument();\n73\t  });\n74\t\n75\t  it(\"populated: counts use thousands separators and null start/end dates render '—'\", () => {\n76\t    render(<CampaignsTable rows={[ROW_DAILY, ROW_INACTIVE_ONBOARDING]} />);\n77\t\n78\t    expect(screen.getByText(\"1,234\")).toBeInTheDocument();\n79\t    // Two rows × two null date columns each → expect at least 2 dashes.\n80\t    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(2);\n81\t  });\n82\t\n83\t  it(\"populated: dogpile rows render the warning chip variant\", () => {\n84\t    render(<CampaignsTable rows={[ROW_DOGPILE]} />);\n85\t\n86\t    expect(screen.getByText(\"dogpile\")).toBeInTheDocument();\n87\t    expect(screen.getByText(\"Bull-run dogpile\")).toBeInTheDocument();\n88\t  });\n89\t\n90\t  it(\"read-only: no edit affordances rendered (no buttons, no editable inputs)\", () => {\n91\t    render(<CampaignsTable rows={[ROW_DAILY, ROW_DOGPILE]} />);\n92\t\n93\t    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n94\t    expect(screen.queryByRole(\"textbox\")).toBeNull();\n95\t    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n96\t  });\n97\t\n98\t  it(\"empty: renders the operator status block when no campaigns exist\", () => {\n99\t    render(<CampaignsTable rows={[]} />);\n100\t\n101\t    const status = screen.getByRole(\"status\");\n102\t    expect(status).toHaveTextContent(\"No campaigns rows.\");\n103\t    expect(status).toHaveTextContent(\"campaigns\");\n104\t    expect(screen.queryByRole(\"table\")).toBeNull();\n105\t  });\n106\t\n107\t  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n108\t    render(\n109\t      <CampaignsTable rows={[ROW_DAILY]} error=\"connection refused\" />,\n110\t    );\n111\t\n112\t    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n113\t      \"Campaigns unavailable: connection refused\",\n114\t    );\n115\t    expect(screen.queryByRole(\"table\")).toBeNull();\n116\t    expect(screen.queryByRole(\"status\")).toBeNull();\n117\t  });\n118\t});\n119\t"}]},"parent_tool_use_id":null,"session_id":"247526a1-4b21-4707-9ade-4ba9edd09da3","uuid":"8018359f-2408-49de-86ad-a3d8581d54b5","timestamp":"2026-04-26T06:34:09.570Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/campaigns-table.test.tsx","content":"// Component tests for the FR-9 campaigns table.\n//\n// Read-only by spec (FR-9 / FR-14 — challenge / campaign / completion-bonus\n// definition editing is out of scope), so these tests assert there are no\n// edit affordances rendered: no buttons, no editable inputs, and the row\n// structure is just the dense table the operator drills down from.\n\nimport { describe, expect, it } from \"vitest\";\nimport { render, screen } from \"@testing-library/react\";\nimport { CampaignsTable } from \"../campaigns-table\";\nimport type { PeekCampaignRow } from \"../../lib/types/peek\";\n\nconst ROW_DAILY: PeekCampaignRow = {\n  id: \"1\",\n  name: \"Daily challenges\",\n  campaignType: \"daily\",\n  startsAt: \"2026-04-25T00:00:00.000Z\",\n  endsAt: \"2026-12-31T23:59:59.000Z\",\n  isActive: true,\n  createdAt: \"2026-04-01T00:00:00.000Z\",\n  challengeCount: 5,\n  activeAssignmentCount: 1234,\n};\n\nconst ROW_INACTIVE_ONBOARDING: PeekCampaignRow = {\n  id: \"2\",\n  name: \"Onboarding crate\",\n  campaignType: \"onboarding\",\n  startsAt: null,\n  endsAt: null,\n  isActive: false,\n  createdAt: \"2026-03-01T00:00:00.000Z\",\n  challengeCount: 0,\n  activeAssignmentCount: 0,\n};\n\nconst ROW_DOGPILE: PeekCampaignRow = {\n  id: \"3\",\n  name: \"Bull-run dogpile\",\n  campaignType: \"dogpile\",\n  startsAt: \"2026-04-26T10:00:00.000Z\",\n  endsAt: \"2026-04-26T12:00:00.000Z\",\n  isActive: true,\n  createdAt: \"2026-04-26T09:00:00.000Z\",\n  challengeCount: 2,\n  activeAssignmentCount: 87,\n};\n\ndescribe(\"CampaignsTable\", () => {\n  it(\"populated: renders the operator columns and the type/state chips\", () => {\n    render(<CampaignsTable rows={[ROW_DAILY, ROW_INACTIVE_ONBOARDING]} />);\n\n    for (const header of [\n      \"Name\",\n      \"Type\",\n      \"State\",\n      \"Starts\",\n      \"Ends\",\n      \"Challenges\",\n      \"Active assignments\",\n      \"Created\",\n      \"ID\",\n    ]) {\n      expect(screen.getByText(header)).toBeInTheDocument();\n    }\n\n    expect(screen.getByText(\"Daily challenges\")).toBeInTheDocument();\n    expect(screen.getByText(\"Onboarding crate\")).toBeInTheDocument();\n    expect(screen.getByText(\"daily\")).toBeInTheDocument();\n    expect(screen.getByText(\"onboarding\")).toBeInTheDocument();\n    expect(screen.getByText(\"active\")).toBeInTheDocument();\n    expect(screen.getByText(\"inactive\")).toBeInTheDocument();\n  });\n\n  it(\"populated: counts use thousands separators and null start/end dates render '—'\", () => {\n    render(<CampaignsTable rows={[ROW_DAILY, ROW_INACTIVE_ONBOARDING]} />);\n\n    expect(screen.getByText(\"1,234\")).toBeInTheDocument();\n    // Two rows × two null date columns each → expect at least 2 dashes.\n    expect(screen.getAllByText(\"—\").length).toBeGreaterThanOrEqual(2);\n  });\n\n  it(\"populated: dogpile rows render the warning chip variant\", () => {\n    render(<CampaignsTable rows={[ROW_DOGPILE]} />);\n\n    expect(screen.getByText(\"dogpile\")).toBeInTheDocument();\n    expect(screen.getByText(\"Bull-run dogpile\")).toBeInTheDocument();\n  });\n\n  it(\"read-only: no edit affordances rendered (no buttons, no editable inputs)\", () => {\n    render(<CampaignsTable rows={[ROW_DAILY, ROW_DOGPILE]} />);\n\n    expect(screen.queryAllByRole(\"button\")).toHaveLength(0);\n    expect(screen.queryByRole(\"textbox\")).toBeNull();\n    expect(screen.queryByRole(\"checkbox\")).toBeNull();\n  });\n\n  it(\"empty: renders the operator status block when no campaigns exist\", () => {\n    render(<CampaignsTable rows={[]} />);\n\n    const status = screen.getByRole(\"status\");\n    expect(status).toHaveTextContent(\"No campaigns rows.\");\n    expect(status).toHaveTextContent(\"campaigns\");\n    expect(screen.queryByRole(\"table\")).toBeNull();\n  });\n\n  it(\"error: renders an alert and hides both the table and the empty status\", () => {\n    render(\n      <CampaignsTable rows={[ROW_DAILY]} error=\"connection refused\" />,\n    );\n\n    expect(screen.getByRole(\"alert\")).toHaveTextContent(\n      \"Campaigns unavailable: connection refused\",\n    );\n    expect(screen.queryByRole(\"table\")).toBeNull();\n    expect(screen.queryByRole(\"status\")).toBeNull();\n  });\n});\n","numLines":119,"startLine":1,"totalLines":119}}}
