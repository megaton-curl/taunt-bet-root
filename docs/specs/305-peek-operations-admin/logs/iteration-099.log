{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01VpW3bdhmHFJyS1gSvfC57v","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01NHRjaZSvxrT6ZEXfdLMFfQ","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-dogpile-and-fraud.test.ts","content":"// Query tests for the FR-9 dogpile + fraud admin reads\n// (`get-dogpile-and-fraud.ts`).\n//\n// Mirrors the SQL-mock pattern used in `get-challenges.test.ts`,\n// `get-rewards.test.ts`, and `get-points-and-crates.test.ts`: a tagged-template\n// stub records each call (joined SQL text + bound values) and dequeues a\n// per-call response so each test can assert which SQL fired, in what order,\n// and with which clamps.\n//\n// Both surfaces (dogpile_events, fraud_flags) are read-only by spec — every\n// dogpile or fraud-flag mutation lives behind the FR-14 `dogpile.cancel` and\n// `fraud_flag.status.update` action ids, declared in\n// `peek/src/server/access-policy.ts:154-159` but unimplemented. These tests\n// guarantee the queries only emit SELECT statements and never INSERT / UPDATE\n// / DELETE.\n//\n// State-transition coverage: every `PEEK_DOGPILE_STATUSES` value\n// (scheduled / active / ended / cancelled) and every `fraud_flags.status`\n// migration value (open / reviewed / dismissed) flows through to the SQL\n// binding so the operator can scope the URL to a specific lifecycle state.\n\nimport { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT,\n  PEEK_DOGPILE_EVENTS_MAX_LIMIT,\n  PEEK_DOGPILE_FRAUD_OVERVIEW_WINDOW_HOURS,\n  PEEK_FRAUD_FLAGS_DEFAULT_LIMIT,\n  PEEK_FRAUD_FLAGS_MAX_LIMIT,\n  getDogpileFraudOverview,\n  listDogpileEvents,\n  listFraudFlags,\n} from \"../get-dogpile-and-fraud\";\nimport {\n  PEEK_DOGPILE_FRAUD_OVERVIEW_METRIC_IDS,\n  PEEK_DOGPILE_STATUSES,\n  type PeekDogpileFraudOverviewMetricId,\n} from \"../../../../lib/types/peek\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\nfunction expectReadOnly(call: SqlCall) {\n  // Read-only guarantee: every dogpile + fraud query must be SELECT only.\n  // FR-14 keeps every dogpile_events or fraud_flags write behind a mutation\n  // action id, none of which are implemented yet.\n  expect(call.text).not.toMatch(/\\binsert\\s+into\\b/i);\n  expect(call.text).not.toMatch(/\\bupdate\\s+\\w/i);\n  expect(call.text).not.toMatch(/\\bdelete\\s+from\\b/i);\n  expect(call.text).toMatch(/\\bselect\\b/i);\n}\n\nconst FRAUD_FLAG_STATUSES: ReadonlyArray<string> = [\n  \"open\",\n  \"reviewed\",\n  \"dismissed\",\n];\n\n// `getDogpileFraudOverview` runs five queries in parallel via Promise.all.\nconst OVERVIEW_ORDER: ReadonlyArray<PeekDogpileFraudOverviewMetricId> = [\n  \"dogpile.scheduled\",\n  \"dogpile.active\",\n  \"dogpile.ended_window\",\n  \"dogpile.cancelled_window\",\n  \"fraud.open_flags\",\n];\n\ndescribe(\"listDogpileEvents\", () => {\n  it(\"default limit: clamps to PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT and reads from dogpile_events with the campaigns left join\", async () => {\n    const mock = createSqlMock([[]]);\n    await listDogpileEvents({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expectReadOnly(call);\n    expect(call.text).toMatch(/from dogpile_events d/i);\n    expect(call.text).toMatch(/left join campaigns c on c\\.id = d\\.campaign_id/i);\n    expect(call.text).toMatch(/from game_entries ge/i);\n    expect(call.text).toMatch(/from point_grants pg/i);\n    expect(call.text).toMatch(/order by d\\.starts_at desc, d\\.id desc/i);\n    expect(call.values).toContain(PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listDogpileEvents({\n      sql: mock.sql,\n      limit: PEEK_DOGPILE_EVENTS_MAX_LIMIT + 100,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_DOGPILE_EVENTS_MAX_LIMIT);\n  });\n\n  it(\"non-positive limit clamps to 1\", async () => {\n    const mock = createSqlMock([[]]);\n    await listDogpileEvents({ sql: mock.sql, limit: -5 });\n    expect(mock.calls[0].values).toContain(1);\n  });\n\n  it(\"non-finite limit falls back to the default\", async () => {\n    const mock = createSqlMock([[]]);\n    await listDogpileEvents({ sql: mock.sql, limit: Number.NaN });\n    expect(mock.calls[0].values).toContain(PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT);\n  });\n\n  it(\"filters: empty filters bind null sentinels so all 3 predicates are skipped\", async () => {\n    const mock = createSqlMock([[]]);\n    await listDogpileEvents({ sql: mock.sql, filters: {} });\n    const values = mock.calls[0].values;\n    // 3 filters → 3 `true` sentinels (one per predicate).\n    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(3);\n  });\n\n  it(\"filters: every status transition (scheduled / active / ended / cancelled) binds verbatim\", async () => {\n    // Migration-011 dogpile lifecycle covers four states. The operator must\n    // be able to scope the URL to any of them, so each value passes through\n    // to the SQL binding.\n    for (const status of PEEK_DOGPILE_STATUSES) {\n      const mock = createSqlMock([[]]);\n      await listDogpileEvents({\n        sql: mock.sql,\n        filters: { status },\n      });\n      expect(mock.calls[0].values).toContain(status);\n    }\n  });\n\n  it(\"filters: startsFrom/startsTo are cast to timestamptz\", async () => {\n    const mock = createSqlMock([[]]);\n    await listDogpileEvents({\n      sql: mock.sql,\n      filters: { startsFrom: \"2026-04-01\", startsTo: \"2026-04-26\" },\n    });\n    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n    const values = mock.calls[0].values;\n    expect(values).toContain(\"2026-04-01\");\n    expect(values).toContain(\"2026-04-26\");\n  });\n\n  it(\"filters: whitespace-only filter values normalise to null\", async () => {\n    const mock = createSqlMock([[]]);\n    await listDogpileEvents({\n      sql: mock.sql,\n      filters: { status: \"   \", startsFrom: \"\", startsTo: \"  \" },\n    });\n    const values = mock.calls[0].values;\n    // All 3 whitespace/empty filters become null → 3 toggles `true` (skip).\n    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(3);\n  });\n\n  it(\"populated: numeric counts coerce through readInt (string → number)\", async () => {\n    // postgres-js can return ::int casts as strings depending on column path;\n    // readInt must coerce strings → numbers so the table can render\n    // `toLocaleString` without `NaN`.\n    const mock = createSqlMock([\n      [\n        {\n          id: \"1\",\n          campaignId: \"c-1\",\n          campaignName: \"Bull-run dogpile\",\n          campaignType: \"dogpile\",\n          startsAt: \"2026-04-26T10:00:00.000Z\",\n          endsAt: \"2026-04-26T12:00:00.000Z\",\n          multiplier: \"2.5\",\n          status: \"active\",\n          createdAt: \"2026-04-26T09:00:00.000Z\",\n          gameEntryCount: \"12345\",\n          pointGrantCount: 67,\n        },\n      ],\n    ]);\n\n    const rows = await listDogpileEvents({ sql: mock.sql });\n    expect(rows).toHaveLength(1);\n    expect(rows[0].gameEntryCount).toBe(12345);\n    expect(rows[0].pointGrantCount).toBe(67);\n    expect(rows[0].multiplier).toBe(\"2.5\");\n    expect(rows[0].status).toBe(\"active\");\n  });\n\n  it(\"populated: nullable campaign columns round-trip as null\", async () => {\n    // dogpile_events.campaign_id is nullable, so the left join can return\n    // null for every campaign field — the row mapper must preserve null.\n    const mock = createSqlMock([\n      [\n        {\n          id: \"2\",\n          campaignId: null,\n          campaignName: null,\n          campaignType: null,\n          startsAt: \"2026-04-26T10:00:00.000Z\",\n          endsAt: \"2026-04-26T12:00:00.000Z\",\n          multiplier: \"1.5\",\n          status: \"scheduled\",\n          createdAt: \"2026-04-25T10:00:00.000Z\",\n          gameEntryCount: 0,\n          pointGrantCount: 0,\n        },\n      ],\n    ]);\n\n    const rows = await listDogpileEvents({ sql: mock.sql });\n    expect(rows[0].campaignId).toBeNull();\n    expect(rows[0].campaignName).toBeNull();\n    expect(rows[0].campaignType).toBeNull();\n  });\n\n  it(\"sparse: an empty dogpile_events table returns []\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listDogpileEvents({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"connection refused\")]);\n    await expect(listDogpileEvents({ sql: mock.sql })).rejects.toThrowError(\n      \"connection refused\",\n    );\n  });\n\n  it(\"read-only: a `false`-toggle skipped predicate never binds the active value as a real WHERE filter (regression)\", async () => {\n    // Sanity check that the predicate-toggle pattern uses a sentinel: when\n    // status is null, the SQL still binds the empty-string fallback `${ ?? \"\"}`\n    // — this test fails fast if someone replaces the fallback with the active\n    // user-supplied value.\n    const mock = createSqlMock([[]]);\n    await listDogpileEvents({ sql: mock.sql, filters: {} });\n    const values = mock.calls[0].values;\n    // Empty fallback strings are bound for the 3 skipped predicates.\n    expect(values.filter((v) => v === \"\").length).toBeGreaterThanOrEqual(3);\n  });\n});\n\ndescribe(\"listFraudFlags\", () => {\n  it(\"default limit: clamps to PEEK_FRAUD_FLAGS_DEFAULT_LIMIT and reads from fraud_flags with the player_profiles left join\", async () => {\n    const mock = createSqlMock([[]]);\n    await listFraudFlags({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expectReadOnly(call);\n    expect(call.text).toMatch(/from fraud_flags f/i);\n    expect(call.text).toMatch(\n      /left join player_profiles prof on prof\\.user_id = f\\.user_id/i,\n    );\n    expect(call.text).toMatch(\n      /case f\\.status when 'open' then 0 when 'reviewed' then 1 else 2 end/i,\n    );\n    expect(call.text).toMatch(/order by[\\s\\S]+f\\.created_at desc/i);\n    expect(call.values).toContain(PEEK_FRAUD_FLAGS_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listFraudFlags({\n      sql: mock.sql,\n      limit: PEEK_FRAUD_FLAGS_MAX_LIMIT + 999,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_FRAUD_FLAGS_MAX_LIMIT);\n  });\n\n  it(\"filters: every supported filter (status, userId, flagType, createdFrom, createdTo) flows into bound values\", async () => {\n    const mock = createSqlMock([[]]);\n    await listFraudFlags({\n      sql: mock.sql,\n      filters: {\n        status: \"open\",\n        userId: \"user-1\",\n        flagType: \"self_referral\",\n        createdFrom: \"2026-04-01\",\n        createdTo: \"2026-04-26\",\n      },\n    });\n    const values = mock.calls[0].values;\n    expect(values).toContain(\"open\");\n    expect(values).toContain(\"user-1\");\n    expect(values).toContain(\"self_referral\");\n    expect(values).toContain(\"2026-04-01\");\n    expect(values).toContain(\"2026-04-26\");\n  });\n\n  it(\"filters: every status transition (open / reviewed / dismissed) binds verbatim\", async () => {\n    // Migration-011 fraud_flags lifecycle covers three states. The operator\n    // must be able to scope the URL to any of them.\n    for (const status of FRAUD_FLAG_STATUSES) {\n      const mock = createSqlMock([[]]);\n      await listFraudFlags({\n        sql: mock.sql,\n        filters: { status },\n      });\n      expect(mock.calls[0].values).toContain(status);\n    }\n  });\n\n  it(\"filters: empty filters bind null sentinels so all 5 predicates are skipped\", async () => {\n    const mock = createSqlMock([[]]);\n    await listFraudFlags({ sql: mock.sql, filters: {} });\n    const values = mock.calls[0].values;\n    // 5 filters → 5 `true` sentinels (one per predicate).\n    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(5);\n  });\n\n  it(\"filters: createdFrom/createdTo are cast to timestamptz\", async () => {\n    const mock = createSqlMock([[]]);\n    await listFraudFlags({\n      sql: mock.sql,\n      filters: { createdFrom: \"2026-04-01\", createdTo: \"2026-04-26\" },\n    });\n    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n  });\n\n  it(\"filters: whitespace-only filter values normalise to null\", async () => {\n    const mock = createSqlMock([[]]);\n    await listFraudFlags({\n      sql: mock.sql,\n      filters: {\n        status: \"   \",\n        userId: \"\",\n        flagType: \"  \",\n        createdFrom: \"\",\n        createdTo: \"   \",\n      },\n    });\n    const values = mock.calls[0].values;\n    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(5);\n  });\n\n  it(\"populated: rows round-trip with null username + wallet (sparse profile join)\", async () => {\n    // The left join on player_profiles can return null username + wallet\n    // when the profile is sparse (e.g. user not yet onboarded). Operator\n    // expects null to surface so the UI can render the fallback.\n    const mock = createSqlMock([\n      [\n        {\n          id: \"1\",\n          userId: \"user-1\",\n          username: null,\n          wallet: null,\n          flagType: \"self_referral\",\n          status: \"open\",\n          relatedId: null,\n          details: null,\n          createdAt: \"2026-04-26T09:00:00.000Z\",\n          resolvedAt: null,\n        },\n      ],\n    ]);\n\n    const rows = await listFraudFlags({ sql: mock.sql });\n    expect(rows).toHaveLength(1);\n    expect(rows[0].username).toBeNull();\n    expect(rows[0].wallet).toBeNull();\n    expect(rows[0].relatedId).toBeNull();\n    expect(rows[0].details).toBeNull();\n    expect(rows[0].resolvedAt).toBeNull();\n    expect(rows[0].status).toBe(\"open\");\n  });\n\n  it(\"populated: JSONB details column round-trips verbatim\", async () => {\n    // The JSONB `details` payload is operator-meaningful — the writer can\n    // attach arbitrary metadata. The mapper must round-trip the object as-is.\n    const details = { reason: \"loop\", referrer_id: \"ref-9\", attempts: 3 };\n    const mock = createSqlMock([\n      [\n        {\n          id: \"1\",\n          userId: \"user-1\",\n          username: \"alice\",\n          wallet: \"Wal1...\",\n          flagType: \"self_referral\",\n          status: \"reviewed\",\n          relatedId: \"ref-9\",\n          details,\n          createdAt: \"2026-04-26T09:00:00.000Z\",\n          resolvedAt: \"2026-04-26T10:00:00.000Z\",\n        },\n      ],\n    ]);\n\n    const rows = await listFraudFlags({ sql: mock.sql });\n    expect(rows[0].details).toEqual(details);\n    expect(rows[0].relatedId).toBe(\"ref-9\");\n    expect(rows[0].resolvedAt).toBe(\"2026-04-26T10:00:00.000Z\");\n  });\n\n  it(\"sparse: an empty fraud_flags table returns []\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listFraudFlags({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"query timeout\")]);\n    await expect(listFraudFlags({ sql: mock.sql })).rejects.toThrowError(\n      \"query timeout\",\n    );\n  });\n});\n\ndescribe(\"getDogpileFraudOverview\", () => {\n  function buildPopulatedResponses() {\n    return [\n      [{ value: 4 }],\n      [{ value: 7 }],\n      [{ value: 30 }],\n      [{ value: 2 }],\n      [{ value: 11 }],\n    ];\n  }\n\n  it(\"populated: emits one PeekMetric per FR-4 id with correct values, units, and bookkeeping\", async () => {\n    const mock = createSqlMock(buildPopulatedResponses());\n    const now = new Date(\"2026-04-26T10:00:00.000Z\");\n\n    const result = await getDogpileFraudOverview({ sql: mock.sql, now });\n\n    expect(result.generatedAt).toBe(\"2026-04-26T10:00:00.000Z\");\n    expect(result.metrics).toHaveLength(5);\n    expect(result.metrics.map((m) => m.id)).toEqual(OVERVIEW_ORDER);\n    for (const id of PEEK_DOGPILE_FRAUD_OVERVIEW_METRIC_IDS) {\n      expect(result.metrics.find((m) => m.id === id)).toBeDefined();\n    }\n    for (const metric of result.metrics) {\n      expect(metric.asOf).toBe(\"2026-04-26T10:00:00.000Z\");\n      expect(metric.freshness).toBe(\"live\");\n      expect(metric.label.length).toBeGreaterThan(0);\n      expect(metric.definition.length).toBeGreaterThan(0);\n      expect(metric.source.length).toBeGreaterThan(0);\n      expect(metric.windowLabel.length).toBeGreaterThan(0);\n      expect(metric.drilldownHref).not.toBeNull();\n    }\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"dogpile.scheduled\")?.value).toBe(4);\n    expect(byId.get(\"dogpile.scheduled\")?.valueDisplay).toBe(\"4\");\n    expect(byId.get(\"dogpile.scheduled\")?.unit).toBe(\"events\");\n    expect(byId.get(\"dogpile.scheduled\")?.source).toBe(\"dogpile_events\");\n    expect(byId.get(\"dogpile.scheduled\")?.drilldownHref).toBe(\n      \"/operations/dogpile?status=scheduled\",\n    );\n\n    expect(byId.get(\"dogpile.active\")?.value).toBe(7);\n    expect(byId.get(\"dogpile.active\")?.drilldownHref).toBe(\n      \"/operations/dogpile?status=active\",\n    );\n\n    expect(byId.get(\"dogpile.ended_window\")?.value).toBe(30);\n    expect(byId.get(\"dogpile.ended_window\")?.drilldownHref).toBe(\n      \"/operations/dogpile?status=ended\",\n    );\n\n    expect(byId.get(\"dogpile.cancelled_window\")?.value).toBe(2);\n    expect(byId.get(\"dogpile.cancelled_window\")?.drilldownHref).toBe(\n      \"/operations/dogpile?status=cancelled\",\n    );\n\n    expect(byId.get(\"fraud.open_flags\")?.value).toBe(11);\n    expect(byId.get(\"fraud.open_flags\")?.unit).toBe(\"flags\");\n    expect(byId.get(\"fraud.open_flags\")?.source).toBe(\"fraud_flags\");\n    expect(byId.get(\"fraud.open_flags\")?.drilldownHref).toBe(\n      \"/operations/dogpile?fraudStatus=open#fraud\",\n    );\n  });\n\n  it(\"populated: numeric counts coerce through readInt (string → number)\", async () => {\n    const mock = createSqlMock([\n      [{ value: \"4\" }],\n      [{ value: \"7\" }],\n      [{ value: \"30\" }],\n      [{ value: \"2\" }],\n      [{ value: \"11\" }],\n    ]);\n\n    const result = await getDogpileFraudOverview({ sql: mock.sql });\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"dogpile.scheduled\")?.value).toBe(4);\n    expect(byId.get(\"fraud.open_flags\")?.value).toBe(11);\n  });\n\n  it(\"populated (large counts): formats valueDisplay with thousands separator\", async () => {\n    const mock = createSqlMock([\n      [{ value: 12345 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n    const result = await getDogpileFraudOverview({ sql: mock.sql });\n    const scheduled = result.metrics.find((m) => m.id === \"dogpile.scheduled\");\n    expect(scheduled?.value).toBe(12345);\n    expect(scheduled?.valueDisplay).toBe(\"12,345\");\n  });\n\n  it(\"sparse (every count = 0): every metric still emits with display '0' so the strip never drops a tile\", async () => {\n    const mock = createSqlMock([[], [], [], [], []]);\n\n    const result = await getDogpileFraudOverview({ sql: mock.sql });\n\n    expect(result.metrics).toHaveLength(5);\n    for (const metric of result.metrics) {\n      expect(metric.value).toBe(0);\n      expect(metric.valueDisplay).toBe(\"0\");\n    }\n  });\n\n  it(\"default window: window label uses PEEK_DOGPILE_FRAUD_OVERVIEW_WINDOW_HOURS and binds the matching `since` timestamp\", async () => {\n    const mock = createSqlMock(buildPopulatedResponses());\n    const now = new Date(\"2026-04-26T10:00:00.000Z\");\n\n    const result = await getDogpileFraudOverview({ sql: mock.sql, now });\n    const ended = result.metrics.find(\n      (m) => m.id === \"dogpile.ended_window\",\n    );\n    const cancelled = result.metrics.find(\n      (m) => m.id === \"dogpile.cancelled_window\",\n    );\n    expect(ended?.windowLabel).toBe(\n      `Last ${PEEK_DOGPILE_FRAUD_OVERVIEW_WINDOW_HOURS}h`,\n    );\n    expect(cancelled?.windowLabel).toBe(\n      `Last ${PEEK_DOGPILE_FRAUD_OVERVIEW_WINDOW_HOURS}h`,\n    );\n\n    // The ended_window and cancelled_window queries (call indexes 2 and 3)\n    // bind the cutoff timestamp.\n    const since = new Date(\n      now.getTime() - PEEK_DOGPILE_FRAUD_OVERVIEW_WINDOW_HOURS * 60 * 60 * 1000,\n    ).toISOString();\n    expect(mock.calls[2].values).toContain(since);\n    expect(mock.calls[3].values).toContain(since);\n  });\n\n  it(\"custom windowHours: caller-provided window flows into the label and the `since` cutoff\", async () => {\n    const mock = createSqlMock(buildPopulatedResponses());\n    const now = new Date(\"2026-04-26T10:00:00.000Z\");\n\n    const result = await getDogpileFraudOverview({\n      sql: mock.sql,\n      now,\n      windowHours: 6,\n    });\n    const ended = result.metrics.find(\n      (m) => m.id === \"dogpile.ended_window\",\n    );\n    expect(ended?.windowLabel).toBe(\"Last 6h\");\n    const since = new Date(now.getTime() - 6 * 60 * 60 * 1000).toISOString();\n    expect(mock.calls[2].values).toContain(since);\n    expect(mock.calls[3].values).toContain(since);\n  });\n\n  it(\"queries fire in parallel: all 5 SQL calls happen via Promise.all, scoped to the right table+status\", async () => {\n    const mock = createSqlMock(buildPopulatedResponses());\n    await getDogpileFraudOverview({ sql: mock.sql });\n    expect(mock.calls).toHaveLength(5);\n\n    expectReadOnly(mock.calls[0]);\n    expect(mock.calls[0].text).toMatch(/from dogpile_events/i);\n    expect(mock.calls[0].text).toMatch(/where status = 'scheduled'/i);\n\n    expectReadOnly(mock.calls[1]);\n    expect(mock.calls[1].text).toMatch(/from dogpile_events/i);\n    expect(mock.calls[1].text).toMatch(/where status = 'active'/i);\n\n    expectReadOnly(mock.calls[2]);\n    expect(mock.calls[2].text).toMatch(/from dogpile_events/i);\n    expect(mock.calls[2].text).toMatch(/where status = 'ended'/i);\n\n    expectReadOnly(mock.calls[3]);\n    expect(mock.calls[3].text).toMatch(/from dogpile_events/i);\n    expect(mock.calls[3].text).toMatch(/where status = 'cancelled'/i);\n\n    expectReadOnly(mock.calls[4]);\n    expect(mock.calls[4].text).toMatch(/from fraud_flags/i);\n    expect(mock.calls[4].text).toMatch(/where status = 'open'/i);\n  });\n\n  it(\"load-error: a rejected query propagates so the page can render the alert state\", async () => {\n    const mock = createSqlMock([\n      new Error(\"connection refused\"),\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n    await expect(\n      getDogpileFraudOverview({ sql: mock.sql }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":6226,"cache_read_input_tokens":117391,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":6226},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"247526a1-4b21-4707-9ade-4ba9edd09da3","uuid":"78663c49-7275-48e5-9493-18de07420a37"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NHRjaZSvxrT6ZEXfdLMFfQ","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-dogpile-and-fraud.test.ts"}]},"parent_tool_use_id":null,"session_id":"247526a1-4b21-4707-9ade-4ba9edd09da3","uuid":"66c093ad-a61d-4f40-a561-0c28ded1d988","timestamp":"2026-04-26T06:36:16.669Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-dogpile-and-fraud.test.ts","content":"// Query tests for the FR-9 dogpile + fraud admin reads\n// (`get-dogpile-and-fraud.ts`).\n//\n// Mirrors the SQL-mock pattern used in `get-challenges.test.ts`,\n// `get-rewards.test.ts`, and `get-points-and-crates.test.ts`: a tagged-template\n// stub records each call (joined SQL text + bound values) and dequeues a\n// per-call response so each test can assert which SQL fired, in what order,\n// and with which clamps.\n//\n// Both surfaces (dogpile_events, fraud_flags) are read-only by spec — every\n// dogpile or fraud-flag mutation lives behind the FR-14 `dogpile.cancel` and\n// `fraud_flag.status.update` action ids, declared in\n// `peek/src/server/access-policy.ts:154-159` but unimplemented. These tests\n// guarantee the queries only emit SELECT statements and never INSERT / UPDATE\n// / DELETE.\n//\n// State-transition coverage: every `PEEK_DOGPILE_STATUSES` value\n// (scheduled / active / ended / cancelled) and every `fraud_flags.status`\n// migration value (open / reviewed / dismissed) flows through to the SQL\n// binding so the operator can scope the URL to a specific lifecycle state.\n\nimport { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT,\n  PEEK_DOGPILE_EVENTS_MAX_LIMIT,\n  PEEK_DOGPILE_FRAUD_OVERVIEW_WINDOW_HOURS,\n  PEEK_FRAUD_FLAGS_DEFAULT_LIMIT,\n  PEEK_FRAUD_FLAGS_MAX_LIMIT,\n  getDogpileFraudOverview,\n  listDogpileEvents,\n  listFraudFlags,\n} from \"../get-dogpile-and-fraud\";\nimport {\n  PEEK_DOGPILE_FRAUD_OVERVIEW_METRIC_IDS,\n  PEEK_DOGPILE_STATUSES,\n  type PeekDogpileFraudOverviewMetricId,\n} from \"../../../../lib/types/peek\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\nfunction expectReadOnly(call: SqlCall) {\n  // Read-only guarantee: every dogpile + fraud query must be SELECT only.\n  // FR-14 keeps every dogpile_events or fraud_flags write behind a mutation\n  // action id, none of which are implemented yet.\n  expect(call.text).not.toMatch(/\\binsert\\s+into\\b/i);\n  expect(call.text).not.toMatch(/\\bupdate\\s+\\w/i);\n  expect(call.text).not.toMatch(/\\bdelete\\s+from\\b/i);\n  expect(call.text).toMatch(/\\bselect\\b/i);\n}\n\nconst FRAUD_FLAG_STATUSES: ReadonlyArray<string> = [\n  \"open\",\n  \"reviewed\",\n  \"dismissed\",\n];\n\n// `getDogpileFraudOverview` runs five queries in parallel via Promise.all.\nconst OVERVIEW_ORDER: ReadonlyArray<PeekDogpileFraudOverviewMetricId> = [\n  \"dogpile.scheduled\",\n  \"dogpile.active\",\n  \"dogpile.ended_window\",\n  \"dogpile.cancelled_window\",\n  \"fraud.open_flags\",\n];\n\ndescribe(\"listDogpileEvents\", () => {\n  it(\"default limit: clamps to PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT and reads from dogpile_events with the campaigns left join\", async () => {\n    const mock = createSqlMock([[]]);\n    await listDogpileEvents({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expectReadOnly(call);\n    expect(call.text).toMatch(/from dogpile_events d/i);\n    expect(call.text).toMatch(/left join campaigns c on c\\.id = d\\.campaign_id/i);\n    expect(call.text).toMatch(/from game_entries ge/i);\n    expect(call.text).toMatch(/from point_grants pg/i);\n    expect(call.text).toMatch(/order by d\\.starts_at desc, d\\.id desc/i);\n    expect(call.values).toContain(PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listDogpileEvents({\n      sql: mock.sql,\n      limit: PEEK_DOGPILE_EVENTS_MAX_LIMIT + 100,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_DOGPILE_EVENTS_MAX_LIMIT);\n  });\n\n  it(\"non-positive limit clamps to 1\", async () => {\n    const mock = createSqlMock([[]]);\n    await listDogpileEvents({ sql: mock.sql, limit: -5 });\n    expect(mock.calls[0].values).toContain(1);\n  });\n\n  it(\"non-finite limit falls back to the default\", async () => {\n    const mock = createSqlMock([[]]);\n    await listDogpileEvents({ sql: mock.sql, limit: Number.NaN });\n    expect(mock.calls[0].values).toContain(PEEK_DOGPILE_EVENTS_DEFAULT_LIMIT);\n  });\n\n  it(\"filters: empty filters bind null sentinels so all 3 predicates are skipped\", async () => {\n    const mock = createSqlMock([[]]);\n    await listDogpileEvents({ sql: mock.sql, filters: {} });\n    const values = mock.calls[0].values;\n    // 3 filters → 3 `true` sentinels (one per predicate).\n    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(3);\n  });\n\n  it(\"filters: every status transition (scheduled / active / ended / cancelled) binds verbatim\", async () => {\n    // Migration-011 dogpile lifecycle covers four states. The operator must\n    // be able to scope the URL to any of them, so each value passes through\n    // to the SQL binding.\n    for (const status of PEEK_DOGPILE_STATUSES) {\n      const mock = createSqlMock([[]]);\n      await listDogpileEvents({\n        sql: mock.sql,\n        filters: { status },\n      });\n      expect(mock.calls[0].values).toContain(status);\n    }\n  });\n\n  it(\"filters: startsFrom/startsTo are cast to timestamptz\", async () => {\n    const mock = createSqlMock([[]]);\n    await listDogpileEvents({\n      sql: mock.sql,\n      filters: { startsFrom: \"2026-04-01\", startsTo: \"2026-04-26\" },\n    });\n    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n    const values = mock.calls[0].values;\n    expect(values).toContain(\"2026-04-01\");\n    expect(values).toContain(\"2026-04-26\");\n  });\n\n  it(\"filters: whitespace-only filter values normalise to null\", async () => {\n    const mock = createSqlMock([[]]);\n    await listDogpileEvents({\n      sql: mock.sql,\n      filters: { status: \"   \", startsFrom: \"\", startsTo: \"  \" },\n    });\n    const values = mock.calls[0].values;\n    // All 3 whitespace/empty filters become null → 3 toggles `true` (skip).\n    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(3);\n  });\n\n  it(\"populated: numeric counts coerce through readInt (string → number)\", async () => {\n    // postgres-js can return ::int casts as strings depending on column path;\n    // readInt must coerce strings → numbers so the table can render\n    // `toLocaleString` without `NaN`.\n    const mock = createSqlMock([\n      [\n        {\n          id: \"1\",\n          campaignId: \"c-1\",\n          campaignName: \"Bull-run dogpile\",\n          campaignType: \"dogpile\",\n          startsAt: \"2026-04-26T10:00:00.000Z\",\n          endsAt: \"2026-04-26T12:00:00.000Z\",\n          multiplier: \"2.5\",\n          status: \"active\",\n          createdAt: \"2026-04-26T09:00:00.000Z\",\n          gameEntryCount: \"12345\",\n          pointGrantCount: 67,\n        },\n      ],\n    ]);\n\n    const rows = await listDogpileEvents({ sql: mock.sql });\n    expect(rows).toHaveLength(1);\n    expect(rows[0].gameEntryCount).toBe(12345);\n    expect(rows[0].pointGrantCount).toBe(67);\n    expect(rows[0].multiplier).toBe(\"2.5\");\n    expect(rows[0].status).toBe(\"active\");\n  });\n\n  it(\"populated: nullable campaign columns round-trip as null\", async () => {\n    // dogpile_events.campaign_id is nullable, so the left join can return\n    // null for every campaign field — the row mapper must preserve null.\n    const mock = createSqlMock([\n      [\n        {\n          id: \"2\",\n          campaignId: null,\n          campaignName: null,\n          campaignType: null,\n          startsAt: \"2026-04-26T10:00:00.000Z\",\n          endsAt: \"2026-04-26T12:00:00.000Z\",\n          multiplier: \"1.5\",\n          status: \"scheduled\",\n          createdAt: \"2026-04-25T10:00:00.000Z\",\n          gameEntryCount: 0,\n          pointGrantCount: 0,\n        },\n      ],\n    ]);\n\n    const rows = await listDogpileEvents({ sql: mock.sql });\n    expect(rows[0].campaignId).toBeNull();\n    expect(rows[0].campaignName).toBeNull();\n    expect(rows[0].campaignType).toBeNull();\n  });\n\n  it(\"sparse: an empty dogpile_events table returns []\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listDogpileEvents({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"connection refused\")]);\n    await expect(listDogpileEvents({ sql: mock.sql })).rejects.toThrowError(\n      \"connection refused\",\n    );\n  });\n\n  it(\"read-only: a `false`-toggle skipped predicate never binds the active value as a real WHERE filter (regression)\", async () => {\n    // Sanity check that the predicate-toggle pattern uses a sentinel: when\n    // status is null, the SQL still binds the empty-string fallback `${ ?? \"\"}`\n    // — this test fails fast if someone replaces the fallback with the active\n    // user-supplied value.\n    const mock = createSqlMock([[]]);\n    await listDogpileEvents({ sql: mock.sql, filters: {} });\n    const values = mock.calls[0].values;\n    // Empty fallback strings are bound for the 3 skipped predicates.\n    expect(values.filter((v) => v === \"\").length).toBeGreaterThanOrEqual(3);\n  });\n});\n\ndescribe(\"listFraudFlags\", () => {\n  it(\"default limit: clamps to PEEK_FRAUD_FLAGS_DEFAULT_LIMIT and reads from fraud_flags with the player_profiles left join\", async () => {\n    const mock = createSqlMock([[]]);\n    await listFraudFlags({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expectReadOnly(call);\n    expect(call.text).toMatch(/from fraud_flags f/i);\n    expect(call.text).toMatch(\n      /left join player_profiles prof on prof\\.user_id = f\\.user_id/i,\n    );\n    expect(call.text).toMatch(\n      /case f\\.status when 'open' then 0 when 'reviewed' then 1 else 2 end/i,\n    );\n    expect(call.text).toMatch(/order by[\\s\\S]+f\\.created_at desc/i);\n    expect(call.values).toContain(PEEK_FRAUD_FLAGS_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listFraudFlags({\n      sql: mock.sql,\n      limit: PEEK_FRAUD_FLAGS_MAX_LIMIT + 999,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_FRAUD_FLAGS_MAX_LIMIT);\n  });\n\n  it(\"filters: every supported filter (status, userId, flagType, createdFrom, createdTo) flows into bound values\", async () => {\n    const mock = createSqlMock([[]]);\n    await listFraudFlags({\n      sql: mock.sql,\n      filters: {\n        status: \"open\",\n        userId: \"user-1\",\n        flagType: \"self_referral\",\n        createdFrom: \"2026-04-01\",\n        createdTo: \"2026-04-26\",\n      },\n    });\n    const values = mock.calls[0].values;\n    expect(values).toContain(\"open\");\n    expect(values).toContain(\"user-1\");\n    expect(values).toContain(\"self_referral\");\n    expect(values).toContain(\"2026-04-01\");\n    expect(values).toContain(\"2026-04-26\");\n  });\n\n  it(\"filters: every status transition (open / reviewed / dismissed) binds verbatim\", async () => {\n    // Migration-011 fraud_flags lifecycle covers three states. The operator\n    // must be able to scope the URL to any of them.\n    for (const status of FRAUD_FLAG_STATUSES) {\n      const mock = createSqlMock([[]]);\n      await listFraudFlags({\n        sql: mock.sql,\n        filters: { status },\n      });\n      expect(mock.calls[0].values).toContain(status);\n    }\n  });\n\n  it(\"filters: empty filters bind null sentinels so all 5 predicates are skipped\", async () => {\n    const mock = createSqlMock([[]]);\n    await listFraudFlags({ sql: mock.sql, filters: {} });\n    const values = mock.calls[0].values;\n    // 5 filters → 5 `true` sentinels (one per predicate).\n    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(5);\n  });\n\n  it(\"filters: createdFrom/createdTo are cast to timestamptz\", async () => {\n    const mock = createSqlMock([[]]);\n    await listFraudFlags({\n      sql: mock.sql,\n      filters: { createdFrom: \"2026-04-01\", createdTo: \"2026-04-26\" },\n    });\n    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n  });\n\n  it(\"filters: whitespace-only filter values normalise to null\", async () => {\n    const mock = createSqlMock([[]]);\n    await listFraudFlags({\n      sql: mock.sql,\n      filters: {\n        status: \"   \",\n        userId: \"\",\n        flagType: \"  \",\n        createdFrom: \"\",\n        createdTo: \"   \",\n      },\n    });\n    const values = mock.calls[0].values;\n    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(5);\n  });\n\n  it(\"populated: rows round-trip with null username + wallet (sparse profile join)\", async () => {\n    // The left join on player_profiles can return null username + wallet\n    // when the profile is sparse (e.g. user not yet onboarded). Operator\n    // expects null to surface so the UI can render the fallback.\n    const mock = createSqlMock([\n      [\n        {\n          id: \"1\",\n          userId: \"user-1\",\n          username: null,\n          wallet: null,\n          flagType: \"self_referral\",\n          status: \"open\",\n          relatedId: null,\n          details: null,\n          createdAt: \"2026-04-26T09:00:00.000Z\",\n          resolvedAt: null,\n        },\n      ],\n    ]);\n\n    const rows = await listFraudFlags({ sql: mock.sql });\n    expect(rows).toHaveLength(1);\n    expect(rows[0].username).toBeNull();\n    expect(rows[0].wallet).toBeNull();\n    expect(rows[0].relatedId).toBeNull();\n    expect(rows[0].details).toBeNull();\n    expect(rows[0].resolvedAt).toBeNull();\n    expect(rows[0].status).toBe(\"open\");\n  });\n\n  it(\"populated: JSONB details column round-trips verbatim\", async () => {\n    // The JSONB `details` payload is operator-meaningful — the writer can\n    // attach arbitrary metadata. The mapper must round-trip the object as-is.\n    const details = { reason: \"loop\", referrer_id: \"ref-9\", attempts: 3 };\n    const mock = createSqlMock([\n      [\n        {\n          id: \"1\",\n          userId: \"user-1\",\n          username: \"alice\",\n          wallet: \"Wal1...\",\n          flagType: \"self_referral\",\n          status: \"reviewed\",\n          relatedId: \"ref-9\",\n          details,\n          createdAt: \"2026-04-26T09:00:00.000Z\",\n          resolvedAt: \"2026-04-26T10:00:00.000Z\",\n        },\n      ],\n    ]);\n\n    const rows = await listFraudFlags({ sql: mock.sql });\n    expect(rows[0].details).toEqual(details);\n    expect(rows[0].relatedId).toBe(\"ref-9\");\n    expect(rows[0].resolvedAt).toBe(\"2026-04-26T10:00:00.000Z\");\n  });\n\n  it(\"sparse: an empty fraud_flags table returns []\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listFraudFlags({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"query timeout\")]);\n    await expect(listFraudFlags({ sql: mock.sql })).rejects.toThrowError(\n      \"query timeout\",\n    );\n  });\n});\n\ndescribe(\"getDogpileFraudOverview\", () => {\n  function buildPopulatedResponses() {\n    return [\n      [{ value: 4 }],\n      [{ value: 7 }],\n      [{ value: 30 }],\n      [{ value: 2 }],\n      [{ value: 11 }],\n    ];\n  }\n\n  it(\"populated: emits one PeekMetric per FR-4 id with correct values, units, and bookkeeping\", async () => {\n    const mock = createSqlMock(buildPopulatedResponses());\n    const now = new Date(\"2026-04-26T10:00:00.000Z\");\n\n    const result = await getDogpileFraudOverview({ sql: mock.sql, now });\n\n    expect(result.generatedAt).toBe(\"2026-04-26T10:00:00.000Z\");\n    expect(result.metrics).toHaveLength(5);\n    expect(result.metrics.map((m) => m.id)).toEqual(OVERVIEW_ORDER);\n    for (const id of PEEK_DOGPILE_FRAUD_OVERVIEW_METRIC_IDS) {\n      expect(result.metrics.find((m) => m.id === id)).toBeDefined();\n    }\n    for (const metric of result.metrics) {\n      expect(metric.asOf).toBe(\"2026-04-26T10:00:00.000Z\");\n      expect(metric.freshness).toBe(\"live\");\n      expect(metric.label.length).toBeGreaterThan(0);\n      expect(metric.definition.length).toBeGreaterThan(0);\n      expect(metric.source.length).toBeGreaterThan(0);\n      expect(metric.windowLabel.length).toBeGreaterThan(0);\n      expect(metric.drilldownHref).not.toBeNull();\n    }\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"dogpile.scheduled\")?.value).toBe(4);\n    expect(byId.get(\"dogpile.scheduled\")?.valueDisplay).toBe(\"4\");\n    expect(byId.get(\"dogpile.scheduled\")?.unit).toBe(\"events\");\n    expect(byId.get(\"dogpile.scheduled\")?.source).toBe(\"dogpile_events\");\n    expect(byId.get(\"dogpile.scheduled\")?.drilldownHref).toBe(\n      \"/operations/dogpile?status=scheduled\",\n    );\n\n    expect(byId.get(\"dogpile.active\")?.value).toBe(7);\n    expect(byId.get(\"dogpile.active\")?.drilldownHref).toBe(\n      \"/operations/dogpile?status=active\",\n    );\n\n    expect(byId.get(\"dogpile.ended_window\")?.value).toBe(30);\n    expect(byId.get(\"dogpile.ended_window\")?.drilldownHref).toBe(\n      \"/operations/dogpile?status=ended\",\n    );\n\n    expect(byId.get(\"dogpile.cancelled_window\")?.value).toBe(2);\n    expect(byId.get(\"dogpile.cancelled_window\")?.drilldownHref).toBe(\n      \"/operations/dogpile?status=cancelled\",\n    );\n\n    expect(byId.get(\"fraud.open_flags\")?.value).toBe(11);\n    expect(byId.get(\"fraud.open_flags\")?.unit).toBe(\"flags\");\n    expect(byId.get(\"fraud.open_flags\")?.source).toBe(\"fraud_flags\");\n    expect(byId.get(\"fraud.open_flags\")?.drilldownHref).toBe(\n      \"/operations/dogpile?fraudStatus=open#fraud\",\n    );\n  });\n\n  it(\"populated: numeric counts coerce through readInt (string → number)\", async () => {\n    const mock = createSqlMock([\n      [{ value: \"4\" }],\n      [{ value: \"7\" }],\n      [{ value: \"30\" }],\n      [{ value: \"2\" }],\n      [{ value: \"11\" }],\n    ]);\n\n    const result = await getDogpileFraudOverview({ sql: mock.sql });\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"dogpile.scheduled\")?.value).toBe(4);\n    expect(byId.get(\"fraud.open_flags\")?.value).toBe(11);\n  });\n\n  it(\"populated (large counts): formats valueDisplay with thousands separator\", async () => {\n    const mock = createSqlMock([\n      [{ value: 12345 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n    const result = await getDogpileFraudOverview({ sql: mock.sql });\n    const scheduled = result.metrics.find((m) => m.id === \"dogpile.scheduled\");\n    expect(scheduled?.value).toBe(12345);\n    expect(scheduled?.valueDisplay).toBe(\"12,345\");\n  });\n\n  it(\"sparse (every count = 0): every metric still emits with display '0' so the strip never drops a tile\", async () => {\n    const mock = createSqlMock([[], [], [], [], []]);\n\n    const result = await getDogpileFraudOverview({ sql: mock.sql });\n\n    expect(result.metrics).toHaveLength(5);\n    for (const metric of result.metrics) {\n      expect(metric.value).toBe(0);\n      expect(metric.valueDisplay).toBe(\"0\");\n    }\n  });\n\n  it(\"default window: window label uses PEEK_DOGPILE_FRAUD_OVERVIEW_WINDOW_HOURS and binds the matching `since` timestamp\", async () => {\n    const mock = createSqlMock(buildPopulatedResponses());\n    const now = new Date(\"2026-04-26T10:00:00.000Z\");\n\n    const result = await getDogpileFraudOverview({ sql: mock.sql, now });\n    const ended = result.metrics.find(\n      (m) => m.id === \"dogpile.ended_window\",\n    );\n    const cancelled = result.metrics.find(\n      (m) => m.id === \"dogpile.cancelled_window\",\n    );\n    expect(ended?.windowLabel).toBe(\n      `Last ${PEEK_DOGPILE_FRAUD_OVERVIEW_WINDOW_HOURS}h`,\n    );\n    expect(cancelled?.windowLabel).toBe(\n      `Last ${PEEK_DOGPILE_FRAUD_OVERVIEW_WINDOW_HOURS}h`,\n    );\n\n    // The ended_window and cancelled_window queries (call indexes 2 and 3)\n    // bind the cutoff timestamp.\n    const since = new Date(\n      now.getTime() - PEEK_DOGPILE_FRAUD_OVERVIEW_WINDOW_HOURS * 60 * 60 * 1000,\n    ).toISOString();\n    expect(mock.calls[2].values).toContain(since);\n    expect(mock.calls[3].values).toContain(since);\n  });\n\n  it(\"custom windowHours: caller-provided window flows into the label and the `since` cutoff\", async () => {\n    const mock = createSqlMock(buildPopulatedResponses());\n    const now = new Date(\"2026-04-26T10:00:00.000Z\");\n\n    const result = await getDogpileFraudOverview({\n      sql: mock.sql,\n      now,\n      windowHours: 6,\n    });\n    const ended = result.metrics.find(\n      (m) => m.id === \"dogpile.ended_window\",\n    );\n    expect(ended?.windowLabel).toBe(\"Last 6h\");\n    const since = new Date(now.getTime() - 6 * 60 * 60 * 1000).toISOString();\n    expect(mock.calls[2].values).toContain(since);\n    expect(mock.calls[3].values).toContain(since);\n  });\n\n  it(\"queries fire in parallel: all 5 SQL calls happen via Promise.all, scoped to the right table+status\", async () => {\n    const mock = createSqlMock(buildPopulatedResponses());\n    await getDogpileFraudOverview({ sql: mock.sql });\n    expect(mock.calls).toHaveLength(5);\n\n    expectReadOnly(mock.calls[0]);\n    expect(mock.calls[0].text).toMatch(/from dogpile_events/i);\n    expect(mock.calls[0].text).toMatch(/where status = 'scheduled'/i);\n\n    expectReadOnly(mock.calls[1]);\n    expect(mock.calls[1].text).toMatch(/from dogpile_events/i);\n    expect(mock.calls[1].text).toMatch(/where status = 'active'/i);\n\n    expectReadOnly(mock.calls[2]);\n    expect(mock.calls[2].text).toMatch(/from dogpile_events/i);\n    expect(mock.calls[2].text).toMatch(/where status = 'ended'/i);\n\n    expectReadOnly(mock.calls[3]);\n    expect(mock.calls[3].text).toMatch(/from dogpile_events/i);\n    expect(mock.calls[3].text).toMatch(/where status = 'cancelled'/i);\n\n    expectReadOnly(mock.calls[4]);\n    expect(mock.calls[4].text).toMatch(/from fraud_flags/i);\n    expect(mock.calls[4].text).toMatch(/where status = 'open'/i);\n  });\n\n  it(\"load-error: a rejected query propagates so the page can render the alert state\", async () => {\n    const mock = createSqlMock([\n      new Error(\"connection refused\"),\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n    await expect(\n      getDogpileFraudOverview({ sql: mock.sql }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
