{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CBKziPTsFxCmQZBB7VSgjL","type":"tool_result","content":"1\t// Query tests for the FR-9 challenge engine admin reads (`get-challenges.ts`).\n2\t//\n3\t// Mirrors the SQL-mock pattern used in `get-rewards.test.ts` and\n4\t// `get-points-and-crates.test.ts`: a tagged-template stub records each call\n5\t// (joined SQL text + bound values) and dequeues a per-call response so each\n6\t// test can assert which SQL fired, in what order, and with which clamps.\n7\t//\n8\t// The challenge engine views are read-only by spec (FR-9 / FR-14 — challenge\n9\t// and campaign definition editing is out of scope), so these tests assert the\n10\t// queries only emit SELECT statements and never INSERT/UPDATE/DELETE.\n11\t\n12\timport { describe, expect, it } from \"vitest\";\n13\timport type { Sql } from \"postgres\";\n14\timport {\n15\t  PEEK_BONUS_COMPLETIONS_DEFAULT_LIMIT,\n16\t  PEEK_BONUS_COMPLETIONS_MAX_LIMIT,\n17\t  PEEK_CAMPAIGNS_DEFAULT_LIMIT,\n18\t  PEEK_CAMPAIGNS_MAX_LIMIT,\n19\t  PEEK_CHALLENGES_DEFAULT_LIMIT,\n20\t  PEEK_CHALLENGES_MAX_LIMIT,\n21\t  PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS,\n22\t  PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT,\n23\t  PEEK_CHALLENGE_ASSIGNMENTS_MAX_LIMIT,\n24\t  PEEK_COMPLETION_BONUSES_DEFAULT_LIMIT,\n25\t  PEEK_COMPLETION_BONUSES_MAX_LIMIT,\n26\t  PEEK_PROGRESS_EVENTS_DEFAULT_LIMIT,\n27\t  PEEK_PROGRESS_EVENTS_MAX_LIMIT,\n28\t  getChallengesOverview,\n29\t  listBonusCompletions,\n30\t  listCampaigns,\n31\t  listChallengeAssignments,\n32\t  listChallenges,\n33\t  listCompletionBonuses,\n34\t  listProgressEvents,\n35\t} from \"../get-challenges\";\n36\timport {\n37\t  PEEK_CHALLENGES_OVERVIEW_METRIC_IDS,\n38\t  type PeekChallengesOverviewMetricId,\n39\t} from \"../../../../lib/types/peek\";\n40\t\n41\ttype SqlCall = {\n42\t  text: string;\n43\t  values: ReadonlyArray<unknown>;\n44\t};\n45\t\n46\ttype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n47\t\n48\ttype SqlMock = {\n49\t  sql: Sql;\n50\t  calls: ReadonlyArray<SqlCall>;\n51\t};\n52\t\n53\tfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n54\t  const calls: SqlCall[] = [];\n55\t  let cursor = 0;\n56\t\n57\t  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n58\t    const text = [...strings].join(\"?\");\n59\t    calls.push({ text, values: [...values] });\n60\t    const next = responses[cursor++];\n61\t    if (next instanceof Error) return Promise.reject(next);\n62\t    return Promise.resolve(next ?? []);\n63\t  };\n64\t\n65\t  const sql = fn as unknown as Sql;\n66\t  return { sql, calls };\n67\t}\n68\t\n69\tfunction expectReadOnly(call: SqlCall) {\n70\t  // Read-only guarantee: every challenge engine query must be a SELECT only.\n71\t  // Catch a stray INSERT/UPDATE/DELETE before it can ship — FR-9 keeps\n72\t  // challenge/campaign/completion-bonus definitions out of scope (FR-14).\n73\t  expect(call.text).not.toMatch(/\\binsert\\s+into\\b/i);\n74\t  expect(call.text).not.toMatch(/\\bupdate\\s+\\w/i);\n75\t  expect(call.text).not.toMatch(/\\bdelete\\s+from\\b/i);\n76\t  expect(call.text).toMatch(/\\bselect\\b/i);\n77\t}\n78\t\n79\t// `getChallengesOverview` runs five queries in parallel via Promise.all.\n80\tconst OVERVIEW_ORDER: ReadonlyArray<PeekChallengesOverviewMetricId> = [\n81\t  \"challenges.active_campaigns\",\n82\t  \"challenges.active_challenges\",\n83\t  \"challenges.active_assignments\",\n84\t  \"challenges.completed_assignments_window\",\n85\t  \"challenges.bonus_completions_window\",\n86\t];\n87\t\n88\tdescribe(\"listCampaigns\", () => {\n89\t  it(\"default limit: clamps to PEEK_CAMPAIGNS_DEFAULT_LIMIT and reads from campaigns with annotated counts\", async () => {\n90\t    const mock = createSqlMock([[]]);\n91\t    await listCampaigns({ sql: mock.sql });\n92\t\n93\t    expect(mock.calls).toHaveLength(1);\n94\t    const call = mock.calls[0];\n95\t    expectReadOnly(call);\n96\t    expect(call.text).toMatch(/from campaigns c/i);\n97\t    // Per-campaign challenge count + active assignment count are joined in.\n98\t    expect(call.text).toMatch(/from challenges/i);\n99\t    expect(call.text).toMatch(/from challenge_assignments ca/i);\n100\t    expect(call.text).toMatch(/where ca\\.status = 'active'/i);\n101\t    expect(call.text).toMatch(\n102\t      /order by c\\.is_active desc, c\\.created_at desc/i,\n103\t    );\n104\t    expect(call.values).toContain(PEEK_CAMPAIGNS_DEFAULT_LIMIT);\n105\t  });\n106\t\n107\t  it(\"limit clamps to MAX when caller asks for more\", async () => {\n108\t    const mock = createSqlMock([[]]);\n109\t    await listCampaigns({\n110\t      sql: mock.sql,\n111\t      limit: PEEK_CAMPAIGNS_MAX_LIMIT + 100,\n112\t    });\n113\t    expect(mock.calls[0].values).toContain(PEEK_CAMPAIGNS_MAX_LIMIT);\n114\t  });\n115\t\n116\t  it(\"non-positive limit clamps to 1\", async () => {\n117\t    const mock = createSqlMock([[]]);\n118\t    await listCampaigns({ sql: mock.sql, limit: -5 });\n119\t    expect(mock.calls[0].values).toContain(1);\n120\t  });\n121\t\n122\t  it(\"non-finite limit falls back to the default\", async () => {\n123\t    const mock = createSqlMock([[]]);\n124\t    await listCampaigns({ sql: mock.sql, limit: Number.NaN });\n125\t    expect(mock.calls[0].values).toContain(PEEK_CAMPAIGNS_DEFAULT_LIMIT);\n126\t  });\n127\t\n128\t  it(\"populated: numeric counts coerce through readInt (string → number)\", async () => {\n129\t    // Postgres ::int cast can come back as a string in the postgres-js driver\n130\t    // depending on the column path; readInt must coerce strings → numbers so\n131\t    // the table can render `toLocaleString` without `NaN`.\n132\t    const mock = createSqlMock([\n133\t      [\n134\t        {\n135\t          id: \"1\",\n136\t          name: \"Daily challenges\",\n137\t          campaignType: \"daily\",\n138\t          startsAt: null,\n139\t          endsAt: null,\n140\t          isActive: true,\n141\t          createdAt: \"2026-04-25T10:00:00.000Z\",\n142\t          challengeCount: \"5\", // string from postgres\n143\t          activeAssignmentCount: 12,\n144\t        },\n145\t      ],\n146\t    ]);\n147\t\n148\t    const rows = await listCampaigns({ sql: mock.sql });\n149\t    expect(rows).toHaveLength(1);\n150\t    expect(rows[0].challengeCount).toBe(5);\n151\t    expect(rows[0].activeAssignmentCount).toBe(12);\n152\t    expect(rows[0].name).toBe(\"Daily challenges\");\n153\t    expect(rows[0].isActive).toBe(true);\n154\t  });\n155\t\n156\t  it(\"sparse: an empty campaigns table returns []\", async () => {\n157\t    const mock = createSqlMock([[]]);\n158\t    const rows = await listCampaigns({ sql: mock.sql });\n159\t    expect(rows).toEqual([]);\n160\t  });\n161\t\n162\t  it(\"load-error: a rejected query propagates\", async () => {\n163\t    const mock = createSqlMock([new Error(\"connection refused\")]);\n164\t    await expect(listCampaigns({ sql: mock.sql })).rejects.toThrowError(\n165\t      \"connection refused\",\n166\t    );\n167\t  });\n168\t});\n169\t\n170\tdescribe(\"listChallenges\", () => {\n171\t  it(\"default limit: clamps to PEEK_CHALLENGES_DEFAULT_LIMIT and reads from challenges joined with campaigns\", async () => {\n172\t    const mock = createSqlMock([[]]);\n173\t    await listChallenges({ sql: mock.sql });\n174\t\n175\t    expect(mock.calls).toHaveLength(1);\n176\t    const call = mock.calls[0];\n177\t    expectReadOnly(call);\n178\t    expect(call.text).toMatch(/from challenges ch/i);\n179\t    expect(call.text).toMatch(/left join campaigns c on c\\.id = ch\\.campaign_id/i);\n180\t    expect(call.text).toMatch(/order by ch\\.campaign_id asc/i);\n181\t    expect(call.values).toContain(PEEK_CHALLENGES_DEFAULT_LIMIT);\n182\t  });\n183\t\n184\t  it(\"limit clamps to MAX when caller asks for more\", async () => {\n185\t    const mock = createSqlMock([[]]);\n186\t    await listChallenges({\n187\t      sql: mock.sql,\n188\t      limit: PEEK_CHALLENGES_MAX_LIMIT + 999,\n189\t    });\n190\t    expect(mock.calls[0].values).toContain(PEEK_CHALLENGES_MAX_LIMIT);\n191\t  });\n192\t\n193\t  it(\"filters: empty filters bind null sentinels so both predicates are skipped\", async () => {\n194\t    const mock = createSqlMock([[]]);\n195\t    await listChallenges({ sql: mock.sql, filters: {} });\n196\t    const values = mock.calls[0].values;\n197\t    // 2 filters → at least 2 `true` sentinels (one per predicate toggle).\n198\t    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(2);\n199\t  });\n200\t\n201\t  it(\"filters: campaignId binds the value verbatim\", async () => {\n202\t    const mock = createSqlMock([[]]);\n203\t    await listChallenges({\n204\t      sql: mock.sql,\n205\t      filters: { campaignId: \"campaign-7\" },\n206\t    });\n207\t    expect(mock.calls[0].values).toContain(\"campaign-7\");\n208\t  });\n209\t\n210\t  it(\"filters: isActive='true' binds boolean true\", async () => {\n211\t    const mock = createSqlMock([[]]);\n212\t    await listChallenges({\n213\t      sql: mock.sql,\n214\t      filters: { isActive: \"true\" },\n215\t    });\n216\t    const values = mock.calls[0].values;\n217\t    // Active toggle off (false) + isActive=true bound.\n218\t    expect(values).toContain(true);\n219\t  });\n220\t\n221\t  it(\"filters: isActive='false' binds boolean false\", async () => {\n222\t    const mock = createSqlMock([[]]);\n223\t    await listChallenges({\n224\t      sql: mock.sql,\n225\t      filters: { isActive: \"false\" },\n226\t    });\n227\t    expect(mock.calls[0].values).toContain(false);\n228\t  });\n229\t\n230\t  it(\"filters: unknown isActive value normalises to null (predicate skipped)\", async () => {\n231\t    const mock = createSqlMock([[]]);\n232\t    await listChallenges({\n233\t      sql: mock.sql,\n234\t      filters: { isActive: \"maybe\" },\n235\t    });\n236\t    const values = mock.calls[0].values;\n237\t    // No bool was bound for the predicate → toggle is `true` (skip).\n238\t    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(2);\n239\t  });\n240\t\n241\t  it(\"filters: whitespace-only campaignId normalises to null\", async () => {\n242\t    const mock = createSqlMock([[]]);\n243\t    await listChallenges({\n244\t      sql: mock.sql,\n245\t      filters: { campaignId: \"   \" },\n246\t    });\n247\t    const values = mock.calls[0].values;\n248\t    // The campaignId predicate toggles `true` (skip).\n249\t    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(1);\n250\t  });\n251\t\n252\t  it(\"sparse: an empty result set returns []\", async () => {\n253\t    const mock = createSqlMock([[]]);\n254\t    const rows = await listChallenges({ sql: mock.sql });\n255\t    expect(rows).toEqual([]);\n256\t  });\n257\t\n258\t  it(\"load-error: a rejected query propagates\", async () => {\n259\t    const mock = createSqlMock([new Error(\"query timeout\")]);\n260\t    await expect(listChallenges({ sql: mock.sql })).rejects.toThrowError(\n261\t      \"query timeout\",\n262\t    );\n263\t  });\n264\t});\n265\t\n266\tdescribe(\"listChallengeAssignments\", () => {\n267\t  it(\"default limit: clamps to PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT and reads with player_profiles + challenges + campaigns joined\", async () => {\n268\t    const mock = createSqlMock([[]]);\n269\t    await listChallengeAssignments({ sql: mock.sql });\n270\t\n271\t    expect(mock.calls).toHaveLength(1);\n272\t    const call = mock.calls[0];\n273\t    expectReadOnly(call);\n274\t    expect(call.text).toMatch(/from challenge_assignments ca/i);\n275\t    expect(call.text).toMatch(/left join challenges ch on ch\\.id = ca\\.challenge_id/i);\n276\t    expect(call.text).toMatch(/left join campaigns c on c\\.id = ch\\.campaign_id/i);\n277\t    expect(call.text).toMatch(\n278\t      /left join player_profiles prof on prof\\.user_id = ca\\.user_id/i,\n279\t    );\n280\t    expect(call.text).toMatch(/order by ca\\.assigned_at desc/i);\n281\t    expect(call.values).toContain(PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT);\n282\t  });\n283\t\n284\t  it(\"limit clamps to MAX when caller asks for more\", async () => {\n285\t    const mock = createSqlMock([[]]);\n286\t    await listChallengeAssignments({\n287\t      sql: mock.sql,\n288\t      limit: PEEK_CHALLENGE_ASSIGNMENTS_MAX_LIMIT + 9999,\n289\t    });\n290\t    expect(mock.calls[0].values).toContain(\n291\t      PEEK_CHALLENGE_ASSIGNMENTS_MAX_LIMIT,\n292\t    );\n293\t  });\n294\t\n295\t  it(\"filters: every supported filter (userId, challengeId, campaignId, periodKey, status, assignedFrom, assignedTo) flows into bound values\", async () => {\n296\t    const mock = createSqlMock([[]]);\n297\t    await listChallengeAssignments({\n298\t      sql: mock.sql,\n299\t      filters: {\n300\t        userId: \"user-1\",\n301\t        challengeId: \"challenge-7\",\n302\t        campaignId: \"campaign-9\",\n303\t        periodKey: \"2026-04-26\",\n304\t        status: \"active\",\n305\t        assignedFrom: \"2026-04-01\",\n306\t        assignedTo: \"2026-04-26\",\n307\t      },\n308\t    });\n309\t    const values = mock.calls[0].values;\n310\t    expect(values).toContain(\"user-1\");\n311\t    expect(values).toContain(\"challenge-7\");\n312\t    expect(values).toContain(\"campaign-9\");\n313\t    expect(values).toContain(\"2026-04-26\");\n314\t    expect(values).toContain(\"active\");\n315\t    expect(values).toContain(\"2026-04-01\");\n316\t  });\n317\t\n318\t  it(\"filters: status transitions all bind verbatim (active, completed, expired)\", async () => {\n319\t    // Migration-011 status transitions matter to operators — assert each\n320\t    // value passes through to the SQL binding so the URL chip can scope to a\n321\t    // specific lifecycle state.\n322\t    for (const status of [\"active\", \"completed\", \"expired\"]) {\n323\t      const mock = createSqlMock([[]]);\n324\t      await listChallengeAssignments({\n325\t        sql: mock.sql,\n326\t        filters: { status },\n327\t      });\n328\t      expect(mock.calls[0].values).toContain(status);\n329\t    }\n330\t  });\n331\t\n332\t  it(\"filters: empty filters bind null sentinels so all 7 predicates are skipped\", async () => {\n333\t    const mock = createSqlMock([[]]);\n334\t    await listChallengeAssignments({ sql: mock.sql, filters: {} });\n335\t    const values = mock.calls[0].values;\n336\t    // 7 filters → 7 `true` sentinels (one per predicate).\n337\t    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(7);\n338\t  });\n339\t\n340\t  it(\"filters: assignedFrom/assignedTo are cast to timestamptz\", async () => {\n341\t    const mock = createSqlMock([[]]);\n342\t    await listChallengeAssignments({\n343\t      sql: mock.sql,\n344\t      filters: { assignedFrom: \"2026-04-01\", assignedTo: \"2026-04-26\" },\n345\t    });\n346\t    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n347\t  });\n348\t\n349\t  it(\"filters: whitespace-only filter values normalise to null\", async () => {\n350\t    const mock = createSqlMock([[]]);\n351\t    await listChallengeAssignments({\n352\t      sql: mock.sql,\n353\t      filters: {\n354\t        userId: \"   \",\n355\t        challengeId: \"\",\n356\t        status: \"  \",\n357\t      },\n358\t    });\n359\t    const values = mock.calls[0].values;\n360\t    // All 3 whitespace/empty filters become null → 3 toggles `true` (plus the\n361\t    // 4 still-null ones → ≥7 total).\n362\t    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(7);\n363\t  });\n364\t\n365\t  it(\"populated: rows round-trip including username + status\", async () => {\n366\t    const row = {\n367\t      id: \"9001\",\n368\t      userId: \"user-1\",\n369\t      username: \"alice\",\n370\t      challengeId: \"challenge-7\",\n371\t      challengeTitle: \"Wager 5 SOL today\",\n372\t      campaignId: \"campaign-3\",\n373\t      campaignName: \"Daily challenges\",\n374\t      periodKey: \"2026-04-26\",\n375\t      status: \"active\",\n376\t      progress: 2,\n377\t      target: 5,\n378\t      assignedAt: \"2026-04-26T00:00:00.000Z\",\n379\t      expiresAt: \"2026-04-27T00:00:00.000Z\",\n380\t      completedAt: null,\n381\t    };\n382\t    const mock = createSqlMock([[row]]);\n383\t    const rows = await listChallengeAssignments({ sql: mock.sql });\n384\t    expect(rows).toEqual([row]);\n385\t    expect(rows[0].status).toBe(\"active\");\n386\t    expect(rows[0].completedAt).toBeNull();\n387\t  });\n388\t\n389\t  it(\"sparse: an empty result set returns []\", async () => {\n390\t    const mock = createSqlMock([[]]);\n391\t    const rows = await listChallengeAssignments({ sql: mock.sql });\n392\t    expect(rows).toEqual([]);\n393\t  });\n394\t\n395\t  it(\"load-error: a rejected query propagates\", async () => {\n396\t    const mock = createSqlMock([new Error(\"db down\")]);\n397\t    await expect(\n398\t      listChallengeAssignments({ sql: mock.sql }),\n399\t    ).rejects.toThrowError(\"db down\");\n400\t  });\n401\t});\n402\t\n403\tdescribe(\"listProgressEvents\", () => {\n404\t  it(\"default limit: clamps to PEEK_PROGRESS_EVENTS_DEFAULT_LIMIT and reads with assignment + challenge + profile joined\", async () => {\n405\t    const mock = createSqlMock([[]]);\n406\t    await listProgressEvents({ sql: mock.sql });\n407\t\n408\t    expect(mock.calls).toHaveLength(1);\n409\t    const call = mock.calls[0];\n410\t    expectReadOnly(call);\n411\t    expect(call.text).toMatch(/from progress_events pe/i);\n412\t    expect(call.text).toMatch(\n413\t      /left join challenge_assignments ca on ca\\.id = pe\\.assignment_id/i,\n414\t    );\n415\t    expect(call.text).toMatch(/left join challenges ch on ch\\.id = ca\\.challenge_id/i);\n416\t    expect(call.text).toMatch(\n417\t      /left join player_profiles prof on prof\\.user_id = pe\\.user_id/i,\n418\t    );\n419\t    expect(call.text).toMatch(/order by pe\\.created_at desc/i);\n420\t    expect(call.values).toContain(PEEK_PROGRESS_EVENTS_DEFAULT_LIMIT);\n421\t  });\n422\t\n423\t  it(\"limit clamps to MAX when caller asks for more\", async () => {\n424\t    const mock = createSqlMock([[]]);\n425\t    await listProgressEvents({\n426\t      sql: mock.sql,\n427\t      limit: PEEK_PROGRESS_EVENTS_MAX_LIMIT + 1,\n428\t    });\n429\t    expect(mock.calls[0].values).toContain(PEEK_PROGRESS_EVENTS_MAX_LIMIT);\n430\t  });\n431\t\n432\t  it(\"filters: every supported filter (assignmentId, challengeId, userId, roundId, createdFrom, createdTo) flows into bound values\", async () => {\n433\t    const mock = createSqlMock([[]]);\n434\t    await listProgressEvents({\n435\t      sql: mock.sql,\n436\t      filters: {\n437\t        assignmentId: \"asg-1\",\n438\t        challengeId: \"challenge-7\",\n439\t        userId: \"user-9\",\n440\t        roundId: \"round-PDA-x\",\n441\t        createdFrom: \"2026-04-01\",\n442\t        createdTo: \"2026-04-26\",\n443\t      },\n444\t    });\n445\t    const values = mock.calls[0].values;\n446\t    expect(values).toContain(\"asg-1\");\n447\t    expect(values).toContain(\"challenge-7\");\n448\t    expect(values).toContain(\"user-9\");\n449\t    expect(values).toContain(\"round-PDA-x\");\n450\t    expect(values).toContain(\"2026-04-01\");\n451\t    expect(values).toContain(\"2026-04-26\");\n452\t  });\n453\t\n454\t  it(\"filters: empty filters bind null sentinels so all 6 predicates are skipped\", async () => {\n455\t    const mock = createSqlMock([[]]);\n456\t    await listProgressEvents({ sql: mock.sql, filters: {} });\n457\t    const values = mock.calls[0].values;\n458\t    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(6);\n459\t  });\n460\t\n461\t  it(\"filters: createdFrom/createdTo are cast to timestamptz\", async () => {\n462\t    const mock = createSqlMock([[]]);\n463\t    await listProgressEvents({\n464\t      sql: mock.sql,\n465\t      filters: { createdFrom: \"2026-04-01\", createdTo: \"2026-04-26\" },\n466\t    });\n467\t    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n468\t  });\n469\t\n470\t  it(\"sparse: an empty result set returns []\", async () => {\n471\t    const mock = createSqlMock([[]]);\n472\t    const rows = await listProgressEvents({ sql: mock.sql });\n473\t    expect(rows).toEqual([]);\n474\t  });\n475\t\n476\t  it(\"load-error: a rejected query propagates\", async () => {\n477\t    const mock = createSqlMock([new Error(\"query timeout\")]);\n478\t    await expect(listProgressEvents({ sql: mock.sql })).rejects.toThrowError(\n479\t      \"query timeout\",\n480\t    );\n481\t  });\n482\t});\n483\t\n484\tdescribe(\"listCompletionBonuses\", () => {\n485\t  it(\"default limit: clamps to PEEK_COMPLETION_BONUSES_DEFAULT_LIMIT and reads with completion counts joined\", async () => {\n486\t    const mock = createSqlMock([[]]);\n487\t    await listCompletionBonuses({ sql: mock.sql });\n488\t\n489\t    expect(mock.calls).toHaveLength(1);\n490\t    const call = mock.calls[0];\n491\t    expectReadOnly(call);\n492\t    expect(call.text).toMatch(/from completion_bonuses cb/i);\n493\t    expect(call.text).toMatch(/left join campaigns c on c\\.id = cb\\.campaign_id/i);\n494\t    expect(call.text).toMatch(/from bonus_completions/i);\n495\t    expect(call.text).toMatch(\n496\t      /order by cb\\.is_active desc, cb\\.created_at desc/i,\n497\t    );\n498\t    expect(call.values).toContain(PEEK_COMPLETION_BONUSES_DEFAULT_LIMIT);\n499\t  });\n500\t\n501\t  it(\"limit clamps to MAX when caller asks for more\", async () => {\n502\t    const mock = createSqlMock([[]]);\n503\t    await listCompletionBonuses({\n504\t      sql: mock.sql,\n505\t      limit: PEEK_COMPLETION_BONUSES_MAX_LIMIT + 1,\n506\t    });\n507\t    expect(mock.calls[0].values).toContain(PEEK_COMPLETION_BONUSES_MAX_LIMIT);\n508\t  });\n509\t\n510\t  it(\"populated: nullable rewardAmount is preserved (no coercion to 0)\", async () => {\n511\t    const mock = createSqlMock([\n512\t      [\n513\t        {\n514\t          id: \"1\",\n515\t          campaignId: \"c-1\",\n516\t          campaignName: \"Daily challenges\",\n517\t          campaignType: \"daily\",\n518\t          title: \"Complete all dailies\",\n519\t          description: null,\n520\t          requiredCount: 3,\n521\t          rewardType: \"crate\",\n522\t          rewardAmount: null,\n523\t          isActive: true,\n524\t          createdAt: \"2026-04-25T10:00:00.000Z\",\n525\t          completionCount: 0,\n526\t        },\n527\t      ],\n528\t    ]);\n529\t    const rows = await listCompletionBonuses({ sql: mock.sql });\n530\t    expect(rows[0].rewardAmount).toBeNull();\n531\t    expect(rows[0].requiredCount).toBe(3);\n532\t    expect(rows[0].completionCount).toBe(0);\n533\t  });\n534\t\n535\t  it(\"populated: numeric counts coerce through readInt (string → number)\", async () => {\n536\t    const mock = createSqlMock([\n537\t      [\n538\t        {\n539\t          id: \"2\",\n540\t          campaignId: \"c-2\",\n541\t          campaignName: null,\n542\t          campaignType: null,\n543\t          title: \"Win 10 rounds\",\n544\t          description: \"Win ten rounds in any game\",\n545\t          requiredCount: \"10\",\n546\t          rewardType: \"points\",\n547\t          rewardAmount: \"500\",\n548\t          isActive: false,\n549\t          createdAt: \"2026-04-25T10:00:00.000Z\",\n550\t          completionCount: \"42\",\n551\t        },\n552\t      ],\n553\t    ]);\n554\t    const rows = await listCompletionBonuses({ sql: mock.sql });\n555\t    expect(rows[0].requiredCount).toBe(10);\n556\t    expect(rows[0].rewardAmount).toBe(500);\n557\t    expect(rows[0].completionCount).toBe(42);\n558\t    expect(rows[0].isActive).toBe(false);\n559\t  });\n560\t\n561\t  it(\"sparse: an empty completion_bonuses table returns []\", async () => {\n562\t    const mock = createSqlMock([[]]);\n563\t    const rows = await listCompletionBonuses({ sql: mock.sql });\n564\t    expect(rows).toEqual([]);\n565\t  });\n566\t\n567\t  it(\"load-error: a rejected query propagates\", async () => {\n568\t    const mock = createSqlMock([new Error(\"connection refused\")]);\n569\t    await expect(\n570\t      listCompletionBonuses({ sql: mock.sql }),\n571\t    ).rejects.toThrowError(\"connection refused\");\n572\t  });\n573\t});\n574\t\n575\tdescribe(\"listBonusCompletions\", () => {\n576\t  it(\"default limit: clamps to PEEK_BONUS_COMPLETIONS_DEFAULT_LIMIT and reads with bonus + campaign + profile joined\", async () => {\n577\t    const mock = createSqlMock([[]]);\n578\t    await listBonusCompletions({ sql: mock.sql });\n579\t\n580\t    expect(mock.calls).toHaveLength(1);\n581\t    const call = mock.calls[0];\n582\t    expectReadOnly(call);\n583\t    expect(call.text).toMatch(/from bonus_completions bc/i);\n584\t    expect(call.text).toMatch(\n585\t      /left join completion_bonuses cb on cb\\.id = bc\\.bonus_id/i,\n586\t    );\n587\t    expect(call.text).toMatch(/left join campaigns c on c\\.id = cb\\.campaign_id/i);\n588\t    expect(call.text).toMatch(\n589\t      /left join player_profiles prof on prof\\.user_id = bc\\.user_id/i,\n590\t    );\n591\t    expect(call.text).toMatch(/order by bc\\.completed_at desc/i);\n592\t    expect(call.values).toContain(PEEK_BONUS_COMPLETIONS_DEFAULT_LIMIT);\n593\t  });\n594\t\n595\t  it(\"limit clamps to MAX when caller asks for more\", async () => {\n596\t    const mock = createSqlMock([[]]);\n597\t    await listBonusCompletions({\n598\t      sql: mock.sql,\n599\t      limit: PEEK_BONUS_COMPLETIONS_MAX_LIMIT + 50,\n600\t    });\n601\t    expect(mock.calls[0].values).toContain(PEEK_BONUS_COMPLETIONS_MAX_LIMIT);\n602\t  });\n603\t\n604\t  it(\"filters: every supported filter (userId, bonusId, campaignId, periodKey, completedFrom, completedTo) flows into bound values\", async () => {\n605\t    const mock = createSqlMock([[]]);\n606\t    await listBonusCompletions({\n607\t      sql: mock.sql,\n608\t      filters: {\n609\t        userId: \"user-1\",\n610\t        bonusId: \"bonus-9\",\n611\t        campaignId: \"campaign-3\",\n612\t        periodKey: \"2026-04-26\",\n613\t        completedFrom: \"2026-04-01\",\n614\t        completedTo: \"2026-04-26\",\n615\t      },\n616\t    });\n617\t    const values = mock.calls[0].values;\n618\t    expect(values).toContain(\"user-1\");\n619\t    expect(values).toContain(\"bonus-9\");\n620\t    expect(values).toContain(\"campaign-3\");\n621\t    expect(values).toContain(\"2026-04-26\");\n622\t    expect(values).toContain(\"2026-04-01\");\n623\t  });\n624\t\n625\t  it(\"filters: empty filters bind null sentinels so all 6 predicates are skipped\", async () => {\n626\t    const mock = createSqlMock([[]]);\n627\t    await listBonusCompletions({ sql: mock.sql, filters: {} });\n628\t    const values = mock.calls[0].values;\n629\t    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(6);\n630\t  });\n631\t\n632\t  it(\"filters: completedFrom/completedTo are cast to timestamptz\", async () => {\n633\t    const mock = createSqlMock([[]]);\n634\t    await listBonusCompletions({\n635\t      sql: mock.sql,\n636\t      filters: { completedFrom: \"2026-04-01\", completedTo: \"2026-04-26\" },\n637\t    });\n638\t    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n639\t  });\n640\t\n641\t  it(\"sparse: an empty result set returns []\", async () => {\n642\t    const mock = createSqlMock([[]]);\n643\t    const rows = await listBonusCompletions({ sql: mock.sql });\n644\t    expect(rows).toEqual([]);\n645\t  });\n646\t\n647\t  it(\"load-error: a rejected query propagates\", async () => {\n648\t    const mock = createSqlMock([new Error(\"db down\")]);\n649\t    await expect(listBonusCompletions({ sql: mock.sql })).rejects.toThrowError(\n650\t      \"db down\",\n651\t    );\n652\t  });\n653\t});\n654\t\n655\tdescribe(\"getChallengesOverview\", () => {\n656\t  function buildPopulatedResponses() {\n657\t    return [\n658\t      [{ value: 4 }],\n659\t      [{ value: 12 }],\n660\t      [{ value: 30 }],\n661\t      [{ value: 7 }],\n662\t      [{ value: 5 }],\n663\t    ];\n664\t  }\n665\t\n666\t  it(\"populated: emits one PeekMetric per FR-4 id with correct values, units, and bookkeeping\", async () => {\n667\t    const mock = createSqlMock(buildPopulatedResponses());\n668\t    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n669\t\n670\t    const result = await getChallengesOverview({ sql: mock.sql, now });\n671\t\n672\t    expect(result.generatedAt).toBe(\"2026-04-25T10:00:00.000Z\");\n673\t    expect(result.metrics).toHaveLength(5);\n674\t    expect(result.metrics.map((m) => m.id)).toEqual(OVERVIEW_ORDER);\n675\t    for (const id of PEEK_CHALLENGES_OVERVIEW_METRIC_IDS) {\n676\t      expect(result.metrics.find((m) => m.id === id)).toBeDefined();\n677\t    }\n678\t    for (const metric of result.metrics) {\n679\t      expect(metric.asOf).toBe(\"2026-04-25T10:00:00.000Z\");\n680\t      expect(metric.freshness).toBe(\"live\");\n681\t      expect(metric.label.length).toBeGreaterThan(0);\n682\t      expect(metric.definition.length).toBeGreaterThan(0);\n683\t      expect(metric.source.length).toBeGreaterThan(0);\n684\t      expect(metric.windowLabel.length).toBeGreaterThan(0);\n685\t      expect(metric.drilldownHref).not.toBeNull();\n686\t    }\n687\t\n688\t    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n689\t    expect(byId.get(\"challenges.active_campaigns\")?.value).toBe(4);\n690\t    expect(byId.get(\"challenges.active_campaigns\")?.valueDisplay).toBe(\"4\");\n691\t    expect(byId.get(\"challenges.active_campaigns\")?.unit).toBe(\"campaigns\");\n692\t    expect(byId.get(\"challenges.active_campaigns\")?.source).toBe(\"campaigns\");\n693\t\n694\t    expect(byId.get(\"challenges.active_challenges\")?.value).toBe(12);\n695\t    expect(byId.get(\"challenges.active_challenges\")?.unit).toBe(\"challenges\");\n696\t    expect(byId.get(\"challenges.active_challenges\")?.source).toBe(\"challenges\");\n697\t\n698\t    expect(byId.get(\"challenges.active_assignments\")?.value).toBe(30);\n699\t    expect(byId.get(\"challenges.active_assignments\")?.unit).toBe(\"assignments\");\n700\t    expect(byId.get(\"challenges.active_assignments\")?.source).toBe(\n701\t      \"challenge_assignments\",\n702\t    );\n703\t\n704\t    expect(byId.get(\"challenges.completed_assignments_window\")?.value).toBe(7);\n705\t    expect(byId.get(\"challenges.completed_assignments_window\")?.unit).toBe(\n706\t      \"assignments\",\n707\t    );\n708\t\n709\t    expect(byId.get(\"challenges.bonus_completions_window\")?.value).toBe(5);\n710\t    expect(byId.get(\"challenges.bonus_completions_window\")?.unit).toBe(\n711\t      \"completions\",\n712\t    );\n713\t    expect(byId.get(\"challenges.bonus_completions_window\")?.source).toBe(\n714\t      \"bonus_completions\",\n715\t    );\n716\t  });\n717\t\n718\t  it(\"populated: numeric counts coerce through readInt (string → number)\", async () => {\n719\t    const mock = createSqlMock([\n720\t      [{ value: \"4\" }],\n721\t      [{ value: \"12\" }],\n722\t      [{ value: \"30\" }],\n723\t      [{ value: \"7\" }],\n724\t      [{ value: \"5\" }],\n725\t    ]);\n726\t\n727\t    const result = await getChallengesOverview({ sql: mock.sql });\n728\t\n729\t    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n730\t    expect(byId.get(\"challenges.active_campaigns\")?.value).toBe(4);\n731\t    expect(byId.get(\"challenges.bonus_completions_window\")?.value).toBe(5);\n732\t  });\n733\t\n734\t  it(\"populated (large counts): formats valueDisplay with thousands separator\", async () => {\n735\t    const mock = createSqlMock([\n736\t      [{ value: 0 }],\n737\t      [{ value: 0 }],\n738\t      [{ value: 0 }],\n739\t      [{ value: 0 }],\n740\t      [{ value: 12345 }],\n741\t    ]);\n742\t    const result = await getChallengesOverview({ sql: mock.sql });\n743\t    const recent = result.metrics.find(\n744\t      (m) => m.id === \"challenges.bonus_completions_window\",\n745\t    );\n746\t    expect(recent?.value).toBe(12345);\n747\t    expect(recent?.valueDisplay).toBe(\"12,345\");\n748\t  });\n749\t\n750\t  it(\"sparse (every count = 0): every metric still emits with display '0' so the strip never drops a tile\", async () => {\n751\t    const mock = createSqlMock([[], [], [], [], []]);\n752\t\n753\t    const result = await getChallengesOverview({ sql: mock.sql });\n754\t\n755\t    expect(result.metrics).toHaveLength(5);\n756\t    for (const metric of result.metrics) {\n757\t      expect(metric.value).toBe(0);\n758\t      expect(metric.valueDisplay).toBe(\"0\");\n759\t    }\n760\t  });\n761\t\n762\t  it(\"default window: window label uses PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS and binds the matching `since` timestamp\", async () => {\n763\t    const mock = createSqlMock(buildPopulatedResponses());\n764\t    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n765\t\n766\t    const result = await getChallengesOverview({ sql: mock.sql, now });\n767\t    const completed = result.metrics.find(\n768\t      (m) => m.id === \"challenges.completed_assignments_window\",\n769\t    );\n770\t    const recent = result.metrics.find(\n771\t      (m) => m.id === \"challenges.bonus_completions_window\",\n772\t    );\n773\t    expect(completed?.windowLabel).toBe(\n774\t      `Last ${PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS}h`,\n775\t    );\n776\t    expect(recent?.windowLabel).toBe(\n777\t      `Last ${PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS}h`,\n778\t    );\n779\t\n780\t    // The completed_assignments and bonus_completions queries (call indexes 3\n781\t    // and 4) bind the cutoff timestamp.\n782\t    const since = new Date(\n783\t      now.getTime() - PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS * 60 * 60 * 1000,\n784\t    ).toISOString();\n785\t    expect(mock.calls[3].values).toContain(since);\n786\t    expect(mock.calls[4].values).toContain(since);\n787\t  });\n788\t\n789\t  it(\"custom windowHours: caller-provided window flows into the label and the `since` cutoff\", async () => {\n790\t    const mock = createSqlMock(buildPopulatedResponses());\n791\t    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n792\t\n793\t    const result = await getChallengesOverview({\n794\t      sql: mock.sql,\n795\t      now,\n796\t      windowHours: 6,\n797\t    });\n798\t    const recent = result.metrics.find(\n799\t      (m) => m.id === \"challenges.bonus_completions_window\",\n800\t    );\n801\t    expect(recent?.windowLabel).toBe(\"Last 6h\");\n802\t    const since = new Date(\n803\t      now.getTime() - 6 * 60 * 60 * 1000,\n804\t    ).toISOString();\n805\t    expect(mock.calls[3].values).toContain(since);\n806\t    expect(mock.calls[4].values).toContain(since);\n807\t  });\n808\t\n809\t  it(\"queries fire in parallel: all 5 SQL calls happen via Promise.all in declared order\", async () => {\n810\t    const mock = createSqlMock(buildPopulatedResponses());\n811\t    await getChallengesOverview({ sql: mock.sql });\n812\t    expect(mock.calls).toHaveLength(5);\n813\t    expectReadOnly(mock.calls[0]);\n814\t    expect(mock.calls[0].text).toMatch(/from campaigns/i);\n815\t    expect(mock.calls[0].text).toMatch(/where is_active = true/i);\n816\t    expectReadOnly(mock.calls[1]);\n817\t    expect(mock.calls[1].text).toMatch(/from challenges/i);\n818\t    expect(mock.calls[1].text).toMatch(/where is_active = true/i);\n819\t    expectReadOnly(mock.calls[2]);\n820\t    expect(mock.calls[2].text).toMatch(/from challenge_assignments/i);\n821\t    expect(mock.calls[2].text).toMatch(/where status = 'active'/i);\n822\t    expectReadOnly(mock.calls[3]);\n823\t    expect(mock.calls[3].text).toMatch(/where status = 'completed'/i);\n824\t    expectReadOnly(mock.calls[4]);\n825\t    expect(mock.calls[4].text).toMatch(/from bonus_completions/i);\n826\t  });\n827\t\n828\t  it(\"load-error: a rejected query propagates so the page can render the alert state\", async () => {\n829\t    const mock = createSqlMock([\n830\t      new Error(\"connection refused\"),\n831\t      [{ value: 0 }],\n832\t      [{ value: 0 }],\n833\t      [{ value: 0 }],\n834\t      [{ value: 0 }],\n835\t    ]);\n836\t    await expect(\n837\t      getChallengesOverview({ sql: mock.sql }),\n838\t    ).rejects.toThrowError(\"connection refused\");\n839\t  });\n840\t});\n841\t"}]},"parent_tool_use_id":null,"session_id":"247526a1-4b21-4707-9ade-4ba9edd09da3","uuid":"aa1e3008-c162-42b0-a587-729f6be92e25","timestamp":"2026-04-26T06:34:03.460Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-challenges.test.ts","content":"// Query tests for the FR-9 challenge engine admin reads (`get-challenges.ts`).\n//\n// Mirrors the SQL-mock pattern used in `get-rewards.test.ts` and\n// `get-points-and-crates.test.ts`: a tagged-template stub records each call\n// (joined SQL text + bound values) and dequeues a per-call response so each\n// test can assert which SQL fired, in what order, and with which clamps.\n//\n// The challenge engine views are read-only by spec (FR-9 / FR-14 — challenge\n// and campaign definition editing is out of scope), so these tests assert the\n// queries only emit SELECT statements and never INSERT/UPDATE/DELETE.\n\nimport { describe, expect, it } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_BONUS_COMPLETIONS_DEFAULT_LIMIT,\n  PEEK_BONUS_COMPLETIONS_MAX_LIMIT,\n  PEEK_CAMPAIGNS_DEFAULT_LIMIT,\n  PEEK_CAMPAIGNS_MAX_LIMIT,\n  PEEK_CHALLENGES_DEFAULT_LIMIT,\n  PEEK_CHALLENGES_MAX_LIMIT,\n  PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS,\n  PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT,\n  PEEK_CHALLENGE_ASSIGNMENTS_MAX_LIMIT,\n  PEEK_COMPLETION_BONUSES_DEFAULT_LIMIT,\n  PEEK_COMPLETION_BONUSES_MAX_LIMIT,\n  PEEK_PROGRESS_EVENTS_DEFAULT_LIMIT,\n  PEEK_PROGRESS_EVENTS_MAX_LIMIT,\n  getChallengesOverview,\n  listBonusCompletions,\n  listCampaigns,\n  listChallengeAssignments,\n  listChallenges,\n  listCompletionBonuses,\n  listProgressEvents,\n} from \"../get-challenges\";\nimport {\n  PEEK_CHALLENGES_OVERVIEW_METRIC_IDS,\n  type PeekChallengesOverviewMetricId,\n} from \"../../../../lib/types/peek\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\nfunction expectReadOnly(call: SqlCall) {\n  // Read-only guarantee: every challenge engine query must be a SELECT only.\n  // Catch a stray INSERT/UPDATE/DELETE before it can ship — FR-9 keeps\n  // challenge/campaign/completion-bonus definitions out of scope (FR-14).\n  expect(call.text).not.toMatch(/\\binsert\\s+into\\b/i);\n  expect(call.text).not.toMatch(/\\bupdate\\s+\\w/i);\n  expect(call.text).not.toMatch(/\\bdelete\\s+from\\b/i);\n  expect(call.text).toMatch(/\\bselect\\b/i);\n}\n\n// `getChallengesOverview` runs five queries in parallel via Promise.all.\nconst OVERVIEW_ORDER: ReadonlyArray<PeekChallengesOverviewMetricId> = [\n  \"challenges.active_campaigns\",\n  \"challenges.active_challenges\",\n  \"challenges.active_assignments\",\n  \"challenges.completed_assignments_window\",\n  \"challenges.bonus_completions_window\",\n];\n\ndescribe(\"listCampaigns\", () => {\n  it(\"default limit: clamps to PEEK_CAMPAIGNS_DEFAULT_LIMIT and reads from campaigns with annotated counts\", async () => {\n    const mock = createSqlMock([[]]);\n    await listCampaigns({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expectReadOnly(call);\n    expect(call.text).toMatch(/from campaigns c/i);\n    // Per-campaign challenge count + active assignment count are joined in.\n    expect(call.text).toMatch(/from challenges/i);\n    expect(call.text).toMatch(/from challenge_assignments ca/i);\n    expect(call.text).toMatch(/where ca\\.status = 'active'/i);\n    expect(call.text).toMatch(\n      /order by c\\.is_active desc, c\\.created_at desc/i,\n    );\n    expect(call.values).toContain(PEEK_CAMPAIGNS_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listCampaigns({\n      sql: mock.sql,\n      limit: PEEK_CAMPAIGNS_MAX_LIMIT + 100,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_CAMPAIGNS_MAX_LIMIT);\n  });\n\n  it(\"non-positive limit clamps to 1\", async () => {\n    const mock = createSqlMock([[]]);\n    await listCampaigns({ sql: mock.sql, limit: -5 });\n    expect(mock.calls[0].values).toContain(1);\n  });\n\n  it(\"non-finite limit falls back to the default\", async () => {\n    const mock = createSqlMock([[]]);\n    await listCampaigns({ sql: mock.sql, limit: Number.NaN });\n    expect(mock.calls[0].values).toContain(PEEK_CAMPAIGNS_DEFAULT_LIMIT);\n  });\n\n  it(\"populated: numeric counts coerce through readInt (string → number)\", async () => {\n    // Postgres ::int cast can come back as a string in the postgres-js driver\n    // depending on the column path; readInt must coerce strings → numbers so\n    // the table can render `toLocaleString` without `NaN`.\n    const mock = createSqlMock([\n      [\n        {\n          id: \"1\",\n          name: \"Daily challenges\",\n          campaignType: \"daily\",\n          startsAt: null,\n          endsAt: null,\n          isActive: true,\n          createdAt: \"2026-04-25T10:00:00.000Z\",\n          challengeCount: \"5\", // string from postgres\n          activeAssignmentCount: 12,\n        },\n      ],\n    ]);\n\n    const rows = await listCampaigns({ sql: mock.sql });\n    expect(rows).toHaveLength(1);\n    expect(rows[0].challengeCount).toBe(5);\n    expect(rows[0].activeAssignmentCount).toBe(12);\n    expect(rows[0].name).toBe(\"Daily challenges\");\n    expect(rows[0].isActive).toBe(true);\n  });\n\n  it(\"sparse: an empty campaigns table returns []\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listCampaigns({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"connection refused\")]);\n    await expect(listCampaigns({ sql: mock.sql })).rejects.toThrowError(\n      \"connection refused\",\n    );\n  });\n});\n\ndescribe(\"listChallenges\", () => {\n  it(\"default limit: clamps to PEEK_CHALLENGES_DEFAULT_LIMIT and reads from challenges joined with campaigns\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallenges({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expectReadOnly(call);\n    expect(call.text).toMatch(/from challenges ch/i);\n    expect(call.text).toMatch(/left join campaigns c on c\\.id = ch\\.campaign_id/i);\n    expect(call.text).toMatch(/order by ch\\.campaign_id asc/i);\n    expect(call.values).toContain(PEEK_CHALLENGES_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallenges({\n      sql: mock.sql,\n      limit: PEEK_CHALLENGES_MAX_LIMIT + 999,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_CHALLENGES_MAX_LIMIT);\n  });\n\n  it(\"filters: empty filters bind null sentinels so both predicates are skipped\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallenges({ sql: mock.sql, filters: {} });\n    const values = mock.calls[0].values;\n    // 2 filters → at least 2 `true` sentinels (one per predicate toggle).\n    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(2);\n  });\n\n  it(\"filters: campaignId binds the value verbatim\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallenges({\n      sql: mock.sql,\n      filters: { campaignId: \"campaign-7\" },\n    });\n    expect(mock.calls[0].values).toContain(\"campaign-7\");\n  });\n\n  it(\"filters: isActive='true' binds boolean true\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallenges({\n      sql: mock.sql,\n      filters: { isActive: \"true\" },\n    });\n    const values = mock.calls[0].values;\n    // Active toggle off (false) + isActive=true bound.\n    expect(values).toContain(true);\n  });\n\n  it(\"filters: isActive='false' binds boolean false\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallenges({\n      sql: mock.sql,\n      filters: { isActive: \"false\" },\n    });\n    expect(mock.calls[0].values).toContain(false);\n  });\n\n  it(\"filters: unknown isActive value normalises to null (predicate skipped)\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallenges({\n      sql: mock.sql,\n      filters: { isActive: \"maybe\" },\n    });\n    const values = mock.calls[0].values;\n    // No bool was bound for the predicate → toggle is `true` (skip).\n    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(2);\n  });\n\n  it(\"filters: whitespace-only campaignId normalises to null\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallenges({\n      sql: mock.sql,\n      filters: { campaignId: \"   \" },\n    });\n    const values = mock.calls[0].values;\n    // The campaignId predicate toggles `true` (skip).\n    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(1);\n  });\n\n  it(\"sparse: an empty result set returns []\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listChallenges({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"query timeout\")]);\n    await expect(listChallenges({ sql: mock.sql })).rejects.toThrowError(\n      \"query timeout\",\n    );\n  });\n});\n\ndescribe(\"listChallengeAssignments\", () => {\n  it(\"default limit: clamps to PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT and reads with player_profiles + challenges + campaigns joined\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallengeAssignments({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expectReadOnly(call);\n    expect(call.text).toMatch(/from challenge_assignments ca/i);\n    expect(call.text).toMatch(/left join challenges ch on ch\\.id = ca\\.challenge_id/i);\n    expect(call.text).toMatch(/left join campaigns c on c\\.id = ch\\.campaign_id/i);\n    expect(call.text).toMatch(\n      /left join player_profiles prof on prof\\.user_id = ca\\.user_id/i,\n    );\n    expect(call.text).toMatch(/order by ca\\.assigned_at desc/i);\n    expect(call.values).toContain(PEEK_CHALLENGE_ASSIGNMENTS_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallengeAssignments({\n      sql: mock.sql,\n      limit: PEEK_CHALLENGE_ASSIGNMENTS_MAX_LIMIT + 9999,\n    });\n    expect(mock.calls[0].values).toContain(\n      PEEK_CHALLENGE_ASSIGNMENTS_MAX_LIMIT,\n    );\n  });\n\n  it(\"filters: every supported filter (userId, challengeId, campaignId, periodKey, status, assignedFrom, assignedTo) flows into bound values\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallengeAssignments({\n      sql: mock.sql,\n      filters: {\n        userId: \"user-1\",\n        challengeId: \"challenge-7\",\n        campaignId: \"campaign-9\",\n        periodKey: \"2026-04-26\",\n        status: \"active\",\n        assignedFrom: \"2026-04-01\",\n        assignedTo: \"2026-04-26\",\n      },\n    });\n    const values = mock.calls[0].values;\n    expect(values).toContain(\"user-1\");\n    expect(values).toContain(\"challenge-7\");\n    expect(values).toContain(\"campaign-9\");\n    expect(values).toContain(\"2026-04-26\");\n    expect(values).toContain(\"active\");\n    expect(values).toContain(\"2026-04-01\");\n  });\n\n  it(\"filters: status transitions all bind verbatim (active, completed, expired)\", async () => {\n    // Migration-011 status transitions matter to operators — assert each\n    // value passes through to the SQL binding so the URL chip can scope to a\n    // specific lifecycle state.\n    for (const status of [\"active\", \"completed\", \"expired\"]) {\n      const mock = createSqlMock([[]]);\n      await listChallengeAssignments({\n        sql: mock.sql,\n        filters: { status },\n      });\n      expect(mock.calls[0].values).toContain(status);\n    }\n  });\n\n  it(\"filters: empty filters bind null sentinels so all 7 predicates are skipped\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallengeAssignments({ sql: mock.sql, filters: {} });\n    const values = mock.calls[0].values;\n    // 7 filters → 7 `true` sentinels (one per predicate).\n    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(7);\n  });\n\n  it(\"filters: assignedFrom/assignedTo are cast to timestamptz\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallengeAssignments({\n      sql: mock.sql,\n      filters: { assignedFrom: \"2026-04-01\", assignedTo: \"2026-04-26\" },\n    });\n    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n  });\n\n  it(\"filters: whitespace-only filter values normalise to null\", async () => {\n    const mock = createSqlMock([[]]);\n    await listChallengeAssignments({\n      sql: mock.sql,\n      filters: {\n        userId: \"   \",\n        challengeId: \"\",\n        status: \"  \",\n      },\n    });\n    const values = mock.calls[0].values;\n    // All 3 whitespace/empty filters become null → 3 toggles `true` (plus the\n    // 4 still-null ones → ≥7 total).\n    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(7);\n  });\n\n  it(\"populated: rows round-trip including username + status\", async () => {\n    const row = {\n      id: \"9001\",\n      userId: \"user-1\",\n      username: \"alice\",\n      challengeId: \"challenge-7\",\n      challengeTitle: \"Wager 5 SOL today\",\n      campaignId: \"campaign-3\",\n      campaignName: \"Daily challenges\",\n      periodKey: \"2026-04-26\",\n      status: \"active\",\n      progress: 2,\n      target: 5,\n      assignedAt: \"2026-04-26T00:00:00.000Z\",\n      expiresAt: \"2026-04-27T00:00:00.000Z\",\n      completedAt: null,\n    };\n    const mock = createSqlMock([[row]]);\n    const rows = await listChallengeAssignments({ sql: mock.sql });\n    expect(rows).toEqual([row]);\n    expect(rows[0].status).toBe(\"active\");\n    expect(rows[0].completedAt).toBeNull();\n  });\n\n  it(\"sparse: an empty result set returns []\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listChallengeAssignments({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"db down\")]);\n    await expect(\n      listChallengeAssignments({ sql: mock.sql }),\n    ).rejects.toThrowError(\"db down\");\n  });\n});\n\ndescribe(\"listProgressEvents\", () => {\n  it(\"default limit: clamps to PEEK_PROGRESS_EVENTS_DEFAULT_LIMIT and reads with assignment + challenge + profile joined\", async () => {\n    const mock = createSqlMock([[]]);\n    await listProgressEvents({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expectReadOnly(call);\n    expect(call.text).toMatch(/from progress_events pe/i);\n    expect(call.text).toMatch(\n      /left join challenge_assignments ca on ca\\.id = pe\\.assignment_id/i,\n    );\n    expect(call.text).toMatch(/left join challenges ch on ch\\.id = ca\\.challenge_id/i);\n    expect(call.text).toMatch(\n      /left join player_profiles prof on prof\\.user_id = pe\\.user_id/i,\n    );\n    expect(call.text).toMatch(/order by pe\\.created_at desc/i);\n    expect(call.values).toContain(PEEK_PROGRESS_EVENTS_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listProgressEvents({\n      sql: mock.sql,\n      limit: PEEK_PROGRESS_EVENTS_MAX_LIMIT + 1,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_PROGRESS_EVENTS_MAX_LIMIT);\n  });\n\n  it(\"filters: every supported filter (assignmentId, challengeId, userId, roundId, createdFrom, createdTo) flows into bound values\", async () => {\n    const mock = createSqlMock([[]]);\n    await listProgressEvents({\n      sql: mock.sql,\n      filters: {\n        assignmentId: \"asg-1\",\n        challengeId: \"challenge-7\",\n        userId: \"user-9\",\n        roundId: \"round-PDA-x\",\n        createdFrom: \"2026-04-01\",\n        createdTo: \"2026-04-26\",\n      },\n    });\n    const values = mock.calls[0].values;\n    expect(values).toContain(\"asg-1\");\n    expect(values).toContain(\"challenge-7\");\n    expect(values).toContain(\"user-9\");\n    expect(values).toContain(\"round-PDA-x\");\n    expect(values).toContain(\"2026-04-01\");\n    expect(values).toContain(\"2026-04-26\");\n  });\n\n  it(\"filters: empty filters bind null sentinels so all 6 predicates are skipped\", async () => {\n    const mock = createSqlMock([[]]);\n    await listProgressEvents({ sql: mock.sql, filters: {} });\n    const values = mock.calls[0].values;\n    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(6);\n  });\n\n  it(\"filters: createdFrom/createdTo are cast to timestamptz\", async () => {\n    const mock = createSqlMock([[]]);\n    await listProgressEvents({\n      sql: mock.sql,\n      filters: { createdFrom: \"2026-04-01\", createdTo: \"2026-04-26\" },\n    });\n    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n  });\n\n  it(\"sparse: an empty result set returns []\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listProgressEvents({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"query timeout\")]);\n    await expect(listProgressEvents({ sql: mock.sql })).rejects.toThrowError(\n      \"query timeout\",\n    );\n  });\n});\n\ndescribe(\"listCompletionBonuses\", () => {\n  it(\"default limit: clamps to PEEK_COMPLETION_BONUSES_DEFAULT_LIMIT and reads with completion counts joined\", async () => {\n    const mock = createSqlMock([[]]);\n    await listCompletionBonuses({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expectReadOnly(call);\n    expect(call.text).toMatch(/from completion_bonuses cb/i);\n    expect(call.text).toMatch(/left join campaigns c on c\\.id = cb\\.campaign_id/i);\n    expect(call.text).toMatch(/from bonus_completions/i);\n    expect(call.text).toMatch(\n      /order by cb\\.is_active desc, cb\\.created_at desc/i,\n    );\n    expect(call.values).toContain(PEEK_COMPLETION_BONUSES_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listCompletionBonuses({\n      sql: mock.sql,\n      limit: PEEK_COMPLETION_BONUSES_MAX_LIMIT + 1,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_COMPLETION_BONUSES_MAX_LIMIT);\n  });\n\n  it(\"populated: nullable rewardAmount is preserved (no coercion to 0)\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          id: \"1\",\n          campaignId: \"c-1\",\n          campaignName: \"Daily challenges\",\n          campaignType: \"daily\",\n          title: \"Complete all dailies\",\n          description: null,\n          requiredCount: 3,\n          rewardType: \"crate\",\n          rewardAmount: null,\n          isActive: true,\n          createdAt: \"2026-04-25T10:00:00.000Z\",\n          completionCount: 0,\n        },\n      ],\n    ]);\n    const rows = await listCompletionBonuses({ sql: mock.sql });\n    expect(rows[0].rewardAmount).toBeNull();\n    expect(rows[0].requiredCount).toBe(3);\n    expect(rows[0].completionCount).toBe(0);\n  });\n\n  it(\"populated: numeric counts coerce through readInt (string → number)\", async () => {\n    const mock = createSqlMock([\n      [\n        {\n          id: \"2\",\n          campaignId: \"c-2\",\n          campaignName: null,\n          campaignType: null,\n          title: \"Win 10 rounds\",\n          description: \"Win ten rounds in any game\",\n          requiredCount: \"10\",\n          rewardType: \"points\",\n          rewardAmount: \"500\",\n          isActive: false,\n          createdAt: \"2026-04-25T10:00:00.000Z\",\n          completionCount: \"42\",\n        },\n      ],\n    ]);\n    const rows = await listCompletionBonuses({ sql: mock.sql });\n    expect(rows[0].requiredCount).toBe(10);\n    expect(rows[0].rewardAmount).toBe(500);\n    expect(rows[0].completionCount).toBe(42);\n    expect(rows[0].isActive).toBe(false);\n  });\n\n  it(\"sparse: an empty completion_bonuses table returns []\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listCompletionBonuses({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"connection refused\")]);\n    await expect(\n      listCompletionBonuses({ sql: mock.sql }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n});\n\ndescribe(\"listBonusCompletions\", () => {\n  it(\"default limit: clamps to PEEK_BONUS_COMPLETIONS_DEFAULT_LIMIT and reads with bonus + campaign + profile joined\", async () => {\n    const mock = createSqlMock([[]]);\n    await listBonusCompletions({ sql: mock.sql });\n\n    expect(mock.calls).toHaveLength(1);\n    const call = mock.calls[0];\n    expectReadOnly(call);\n    expect(call.text).toMatch(/from bonus_completions bc/i);\n    expect(call.text).toMatch(\n      /left join completion_bonuses cb on cb\\.id = bc\\.bonus_id/i,\n    );\n    expect(call.text).toMatch(/left join campaigns c on c\\.id = cb\\.campaign_id/i);\n    expect(call.text).toMatch(\n      /left join player_profiles prof on prof\\.user_id = bc\\.user_id/i,\n    );\n    expect(call.text).toMatch(/order by bc\\.completed_at desc/i);\n    expect(call.values).toContain(PEEK_BONUS_COMPLETIONS_DEFAULT_LIMIT);\n  });\n\n  it(\"limit clamps to MAX when caller asks for more\", async () => {\n    const mock = createSqlMock([[]]);\n    await listBonusCompletions({\n      sql: mock.sql,\n      limit: PEEK_BONUS_COMPLETIONS_MAX_LIMIT + 50,\n    });\n    expect(mock.calls[0].values).toContain(PEEK_BONUS_COMPLETIONS_MAX_LIMIT);\n  });\n\n  it(\"filters: every supported filter (userId, bonusId, campaignId, periodKey, completedFrom, completedTo) flows into bound values\", async () => {\n    const mock = createSqlMock([[]]);\n    await listBonusCompletions({\n      sql: mock.sql,\n      filters: {\n        userId: \"user-1\",\n        bonusId: \"bonus-9\",\n        campaignId: \"campaign-3\",\n        periodKey: \"2026-04-26\",\n        completedFrom: \"2026-04-01\",\n        completedTo: \"2026-04-26\",\n      },\n    });\n    const values = mock.calls[0].values;\n    expect(values).toContain(\"user-1\");\n    expect(values).toContain(\"bonus-9\");\n    expect(values).toContain(\"campaign-3\");\n    expect(values).toContain(\"2026-04-26\");\n    expect(values).toContain(\"2026-04-01\");\n  });\n\n  it(\"filters: empty filters bind null sentinels so all 6 predicates are skipped\", async () => {\n    const mock = createSqlMock([[]]);\n    await listBonusCompletions({ sql: mock.sql, filters: {} });\n    const values = mock.calls[0].values;\n    expect(values.filter((v) => v === true).length).toBeGreaterThanOrEqual(6);\n  });\n\n  it(\"filters: completedFrom/completedTo are cast to timestamptz\", async () => {\n    const mock = createSqlMock([[]]);\n    await listBonusCompletions({\n      sql: mock.sql,\n      filters: { completedFrom: \"2026-04-01\", completedTo: \"2026-04-26\" },\n    });\n    expect(mock.calls[0].text).toMatch(/::timestamptz/);\n  });\n\n  it(\"sparse: an empty result set returns []\", async () => {\n    const mock = createSqlMock([[]]);\n    const rows = await listBonusCompletions({ sql: mock.sql });\n    expect(rows).toEqual([]);\n  });\n\n  it(\"load-error: a rejected query propagates\", async () => {\n    const mock = createSqlMock([new Error(\"db down\")]);\n    await expect(listBonusCompletions({ sql: mock.sql })).rejects.toThrowError(\n      \"db down\",\n    );\n  });\n});\n\ndescribe(\"getChallengesOverview\", () => {\n  function buildPopulatedResponses() {\n    return [\n      [{ value: 4 }],\n      [{ value: 12 }],\n      [{ value: 30 }],\n      [{ value: 7 }],\n      [{ value: 5 }],\n    ];\n  }\n\n  it(\"populated: emits one PeekMetric per FR-4 id with correct values, units, and bookkeeping\", async () => {\n    const mock = createSqlMock(buildPopulatedResponses());\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getChallengesOverview({ sql: mock.sql, now });\n\n    expect(result.generatedAt).toBe(\"2026-04-25T10:00:00.000Z\");\n    expect(result.metrics).toHaveLength(5);\n    expect(result.metrics.map((m) => m.id)).toEqual(OVERVIEW_ORDER);\n    for (const id of PEEK_CHALLENGES_OVERVIEW_METRIC_IDS) {\n      expect(result.metrics.find((m) => m.id === id)).toBeDefined();\n    }\n    for (const metric of result.metrics) {\n      expect(metric.asOf).toBe(\"2026-04-25T10:00:00.000Z\");\n      expect(metric.freshness).toBe(\"live\");\n      expect(metric.label.length).toBeGreaterThan(0);\n      expect(metric.definition.length).toBeGreaterThan(0);\n      expect(metric.source.length).toBeGreaterThan(0);\n      expect(metric.windowLabel.length).toBeGreaterThan(0);\n      expect(metric.drilldownHref).not.toBeNull();\n    }\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"challenges.active_campaigns\")?.value).toBe(4);\n    expect(byId.get(\"challenges.active_campaigns\")?.valueDisplay).toBe(\"4\");\n    expect(byId.get(\"challenges.active_campaigns\")?.unit).toBe(\"campaigns\");\n    expect(byId.get(\"challenges.active_campaigns\")?.source).toBe(\"campaigns\");\n\n    expect(byId.get(\"challenges.active_challenges\")?.value).toBe(12);\n    expect(byId.get(\"challenges.active_challenges\")?.unit).toBe(\"challenges\");\n    expect(byId.get(\"challenges.active_challenges\")?.source).toBe(\"challenges\");\n\n    expect(byId.get(\"challenges.active_assignments\")?.value).toBe(30);\n    expect(byId.get(\"challenges.active_assignments\")?.unit).toBe(\"assignments\");\n    expect(byId.get(\"challenges.active_assignments\")?.source).toBe(\n      \"challenge_assignments\",\n    );\n\n    expect(byId.get(\"challenges.completed_assignments_window\")?.value).toBe(7);\n    expect(byId.get(\"challenges.completed_assignments_window\")?.unit).toBe(\n      \"assignments\",\n    );\n\n    expect(byId.get(\"challenges.bonus_completions_window\")?.value).toBe(5);\n    expect(byId.get(\"challenges.bonus_completions_window\")?.unit).toBe(\n      \"completions\",\n    );\n    expect(byId.get(\"challenges.bonus_completions_window\")?.source).toBe(\n      \"bonus_completions\",\n    );\n  });\n\n  it(\"populated: numeric counts coerce through readInt (string → number)\", async () => {\n    const mock = createSqlMock([\n      [{ value: \"4\" }],\n      [{ value: \"12\" }],\n      [{ value: \"30\" }],\n      [{ value: \"7\" }],\n      [{ value: \"5\" }],\n    ]);\n\n    const result = await getChallengesOverview({ sql: mock.sql });\n\n    const byId = new Map(result.metrics.map((m) => [m.id, m]));\n    expect(byId.get(\"challenges.active_campaigns\")?.value).toBe(4);\n    expect(byId.get(\"challenges.bonus_completions_window\")?.value).toBe(5);\n  });\n\n  it(\"populated (large counts): formats valueDisplay with thousands separator\", async () => {\n    const mock = createSqlMock([\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 12345 }],\n    ]);\n    const result = await getChallengesOverview({ sql: mock.sql });\n    const recent = result.metrics.find(\n      (m) => m.id === \"challenges.bonus_completions_window\",\n    );\n    expect(recent?.value).toBe(12345);\n    expect(recent?.valueDisplay).toBe(\"12,345\");\n  });\n\n  it(\"sparse (every count = 0): every metric still emits with display '0' so the strip never drops a tile\", async () => {\n    const mock = createSqlMock([[], [], [], [], []]);\n\n    const result = await getChallengesOverview({ sql: mock.sql });\n\n    expect(result.metrics).toHaveLength(5);\n    for (const metric of result.metrics) {\n      expect(metric.value).toBe(0);\n      expect(metric.valueDisplay).toBe(\"0\");\n    }\n  });\n\n  it(\"default window: window label uses PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS and binds the matching `since` timestamp\", async () => {\n    const mock = createSqlMock(buildPopulatedResponses());\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getChallengesOverview({ sql: mock.sql, now });\n    const completed = result.metrics.find(\n      (m) => m.id === \"challenges.completed_assignments_window\",\n    );\n    const recent = result.metrics.find(\n      (m) => m.id === \"challenges.bonus_completions_window\",\n    );\n    expect(completed?.windowLabel).toBe(\n      `Last ${PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS}h`,\n    );\n    expect(recent?.windowLabel).toBe(\n      `Last ${PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS}h`,\n    );\n\n    // The completed_assignments and bonus_completions queries (call indexes 3\n    // and 4) bind the cutoff timestamp.\n    const since = new Date(\n      now.getTime() - PEEK_CHALLENGES_OVERVIEW_WINDOW_HOURS * 60 * 60 * 1000,\n    ).toISOString();\n    expect(mock.calls[3].values).toContain(since);\n    expect(mock.calls[4].values).toContain(since);\n  });\n\n  it(\"custom windowHours: caller-provided window flows into the label and the `since` cutoff\", async () => {\n    const mock = createSqlMock(buildPopulatedResponses());\n    const now = new Date(\"2026-04-25T10:00:00.000Z\");\n\n    const result = await getChallengesOverview({\n      sql: mock.sql,\n      now,\n      windowHours: 6,\n    });\n    const recent = result.metrics.find(\n      (m) => m.id === \"challenges.bonus_completions_window\",\n    );\n    expect(recent?.windowLabel).toBe(\"Last 6h\");\n    const since = new Date(\n      now.getTime() - 6 * 60 * 60 * 1000,\n    ).toISOString();\n    expect(mock.calls[3].values).toContain(since);\n    expect(mock.calls[4].values).toContain(since);\n  });\n\n  it(\"queries fire in parallel: all 5 SQL calls happen via Promise.all in declared order\", async () => {\n    const mock = createSqlMock(buildPopulatedResponses());\n    await getChallengesOverview({ sql: mock.sql });\n    expect(mock.calls).toHaveLength(5);\n    expectReadOnly(mock.calls[0]);\n    expect(mock.calls[0].text).toMatch(/from campaigns/i);\n    expect(mock.calls[0].text).toMatch(/where is_active = true/i);\n    expectReadOnly(mock.calls[1]);\n    expect(mock.calls[1].text).toMatch(/from challenges/i);\n    expect(mock.calls[1].text).toMatch(/where is_active = true/i);\n    expectReadOnly(mock.calls[2]);\n    expect(mock.calls[2].text).toMatch(/from challenge_assignments/i);\n    expect(mock.calls[2].text).toMatch(/where status = 'active'/i);\n    expectReadOnly(mock.calls[3]);\n    expect(mock.calls[3].text).toMatch(/where status = 'completed'/i);\n    expectReadOnly(mock.calls[4]);\n    expect(mock.calls[4].text).toMatch(/from bonus_completions/i);\n  });\n\n  it(\"load-error: a rejected query propagates so the page can render the alert state\", async () => {\n    const mock = createSqlMock([\n      new Error(\"connection refused\"),\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n      [{ value: 0 }],\n    ]);\n    await expect(\n      getChallengesOverview({ sql: mock.sql }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n});\n","numLines":841,"startLine":1,"totalLines":841}}}
