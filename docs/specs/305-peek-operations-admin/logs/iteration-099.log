{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XXwqUtqaCSeaj2dChmeYd3","type":"tool_result","content":"1\t// Fraud flags review table for /operations/dogpile (FR-9).\n2\t//\n3\t// Read-only review queue over `PeekFraudFlagListRow` so an operator can scan\n4\t// open flags, jump to the user-detail page, and inspect the JSONB `details`\n5\t// payload verbatim. Status drives the chip tone (open = warning, reviewed =\n6\t// info, dismissed = neutral). Status transitions live behind the FR-14\n7\t// `fraud_flag.status.update` mutation action id (not yet implemented).\n8\timport Link from \"next/link\";\n9\timport type { CSSProperties } from \"react\";\n10\timport type {\n11\t  PeekFraudFlagListRow,\n12\t  PeekStatusTone,\n13\t} from \"../lib/types/peek\";\n14\timport { StatusChip } from \"./status-chip\";\n15\t\n16\texport type FraudFlagsTableProps = {\n17\t  rows: ReadonlyArray<PeekFraudFlagListRow>;\n18\t  error?: string | null;\n19\t};\n20\t\n21\texport function FraudFlagsTable({ rows, error = null }: FraudFlagsTableProps) {\n22\t  if (error) {\n23\t    return (\n24\t      <div role=\"alert\" style={errorStyle}>\n25\t        Fraud flags unavailable: {error}\n26\t      </div>\n27\t    );\n28\t  }\n29\t\n30\t  if (rows.length === 0) {\n31\t    return (\n32\t      <div role=\"status\" style={emptyStyle}>\n33\t        <p style={emptyTitleStyle}>\n34\t          No fraud_flags rows match these filters.\n35\t        </p>\n36\t        <p style={emptyBodyStyle}>\n37\t          Adjust the filters above or clear them to see open, reviewed, and\n38\t          dismissed flags.\n39\t        </p>\n40\t      </div>\n41\t    );\n42\t  }\n43\t\n44\t  return (\n45\t    <div style={wrapperStyle}>\n46\t      <table style={tableStyle}>\n47\t        <thead>\n48\t          <tr style={headerRowStyle}>\n49\t            <th style={headerCellStyle(\"left\")}>Status</th>\n50\t            <th style={headerCellStyle(\"left\")}>Flag type</th>\n51\t            <th style={headerCellStyle(\"left\")}>User</th>\n52\t            <th style={headerCellStyle(\"left\")}>Wallet</th>\n53\t            <th style={headerCellStyle(\"left\")}>Related</th>\n54\t            <th style={headerCellStyle(\"left\")}>Details</th>\n55\t            <th style={headerCellStyle(\"left\")}>Created</th>\n56\t            <th style={headerCellStyle(\"left\")}>Resolved</th>\n57\t            <th style={headerCellStyle(\"left\")}>ID</th>\n58\t          </tr>\n59\t        </thead>\n60\t        <tbody>\n61\t          {rows.map((row) => (\n62\t            <tr key={row.id} style={bodyRowStyle}>\n63\t              <td style={bodyCellStyle(\"left\")}>\n64\t                <StatusChip\n65\t                  label={row.status}\n66\t                  tone={fraudStatusTone(row.status)}\n67\t                />\n68\t              </td>\n69\t              <td\n70\t                style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n71\t              >\n72\t                {row.flagType}\n73\t              </td>\n74\t              <td style={bodyCellStyle(\"left\")}>\n75\t                <Link href={`/users/${row.userId}`} style={linkStyle}>\n76\t                  {row.username ?? row.userId}\n77\t                </Link>\n78\t                {row.username ? (\n79\t                  <div style={subValueStyle}>{row.userId}</div>\n80\t                ) : null}\n81\t              </td>\n82\t              <td\n83\t                style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n84\t              >\n85\t                {row.wallet ?? \"—\"}\n86\t              </td>\n87\t              <td\n88\t                style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}\n89\t              >\n90\t                {row.relatedId ?? \"—\"}\n91\t              </td>\n92\t              <td style={bodyCellStyle(\"left\")}>\n93\t                {row.details ? (\n94\t                  <pre style={detailsStyle}>\n95\t                    {JSON.stringify(row.details, null, 2)}\n96\t                  </pre>\n97\t                ) : (\n98\t                  \"—\"\n99\t                )}\n100\t              </td>\n101\t              <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n102\t              <td style={bodyCellStyle(\"left\")}>{row.resolvedAt ?? \"—\"}</td>\n103\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n104\t                {row.id}\n105\t              </td>\n106\t            </tr>\n107\t          ))}\n108\t        </tbody>\n109\t      </table>\n110\t    </div>\n111\t  );\n112\t}\n113\t\n114\tfunction fraudStatusTone(value: string): PeekStatusTone {\n115\t  if (value === \"open\") return \"warning\";\n116\t  if (value === \"reviewed\") return \"info\";\n117\t  if (value === \"dismissed\") return \"neutral\";\n118\t  return \"neutral\";\n119\t}\n120\t\n121\tconst wrapperStyle: CSSProperties = {\n122\t  overflowX: \"auto\",\n123\t  border: \"1px solid #1e293b\",\n124\t  borderRadius: \"0.75rem\",\n125\t};\n126\t\n127\tconst tableStyle: CSSProperties = {\n128\t  width: \"100%\",\n129\t  borderCollapse: \"collapse\",\n130\t};\n131\t\n132\tconst headerRowStyle: CSSProperties = {\n133\t  background: \"#111827\",\n134\t  color: \"#94a3b8\",\n135\t};\n136\t\n137\tconst bodyRowStyle: CSSProperties = {\n138\t  borderTop: \"1px solid #1e293b\",\n139\t};\n140\t\n141\tconst linkStyle: CSSProperties = {\n142\t  color: \"#93c5fd\",\n143\t  textDecoration: \"none\",\n144\t};\n145\t\n146\tconst subValueStyle: CSSProperties = {\n147\t  color: \"#64748b\",\n148\t  fontSize: \"0.75rem\",\n149\t};\n150\t\n151\tconst detailsStyle: CSSProperties = {\n152\t  margin: 0,\n153\t  padding: \"0.5rem\",\n154\t  borderRadius: \"0.5rem\",\n155\t  background: \"#0b1220\",\n156\t  color: \"#cbd5f5\",\n157\t  fontSize: \"0.75rem\",\n158\t  fontFamily: \"monospace\",\n159\t  whiteSpace: \"pre-wrap\",\n160\t  wordBreak: \"break-word\",\n161\t  maxWidth: \"24rem\",\n162\t};\n163\t\n164\tfunction headerCellS