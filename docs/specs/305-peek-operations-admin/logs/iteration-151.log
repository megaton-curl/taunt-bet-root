{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q871Vpc4iQN7w3kdZ9yUqi","type":"tool_result","content":"1\timport { describe, expect, it, vi } from \"vitest\";\n2\timport type { Sql } from \"postgres\";\n3\timport type { PeekActionRule } from \"../../access-policy\";\n4\timport type { PeekAuditWriteResult } from \"../../audit/writer\";\n5\timport type {\n6\t  PeekAuditChange,\n7\t  PeekAuditPayload,\n8\t} from \"../../../lib/types/peek\";\n9\timport {\n10\t  DOGPILE_EVENT_STATUSES,\n11\t  dogpileCancelInputSchema,\n12\t  dogpileCancelMutation,\n13\t  type DogpileEventStatus,\n14\t} from \"../dogpile\";\n15\timport {\n16\t  runPeekMutation,\n17\t  type PeekMutationAuditWriter,\n18\t  type PeekMutationRunResult,\n19\t} from \"../runner\";\n20\timport {\n21\t  type PeekMutationActorContext,\n22\t  type PeekMutationRegistry,\n23\t} from \"../registry\";\n24\t\n25\t// ---------------------------------------------------------------------------\n26\t// Test scaffolding (mirrors the kol-rate / fraud-flag harnesses)\n27\t// ---------------------------------------------------------------------------\n28\t\n29\ttype AuditCall = {\n30\t  eventType: string;\n31\t  payload: PeekAuditPayload;\n32\t  sql: Sql | undefined;\n33\t};\n34\t\n35\tfunction createAuditWriter(): {\n36\t  writer: PeekMutationAuditWriter;\n37\t  calls: AuditCall[];\n38\t} {\n39\t  const calls: AuditCall[] = [];\n40\t  const writer: PeekMutationAuditWriter = vi.fn(async (input, options) => {\n41\t    calls.push({\n42\t      eventType: input.eventType,\n43\t      payload: input.payload,\n44\t      sql: options?.sql,\n45\t    });\n46\t    const result: PeekAuditWriteResult = { ok: true };\n47\t    return result;\n48\t  });\n49\t  return { writer, calls };\n50\t}\n51\t\n52\ttype SqlCall = {\n53\t  fragments: ReadonlyArray<string>;\n54\t  values: ReadonlyArray<unknown>;\n55\t};\n56\t\n57\ttype ExistingRow = {\n58\t  id: string;\n59\t  status: DogpileEventStatus;\n60\t  startsInFuture: boolean;\n61\t};\n62\t\n63\tfunction createSqlMock(options: {\n64\t  existingRow?: ExistingRow | null;\n65\t  failOnUpdate?: Error;\n66\t} = {}): {\n67\t  sql: Sql;\n68\t  txCalls: SqlCall[];\n69\t  beginCalls: number;\n70\t  rolledBack: boolean;\n71\t} {\n72\t  const txCalls: SqlCall[] = [];\n73\t  let beginCalls = 0;\n74\t  let rolledBack = false;\n75\t\n76\t  const txSql = ((\n77\t    fragments: TemplateStringsArray,\n78\t    ...values: ReadonlyArray<unknown>\n79\t  ) => {\n80\t    const frags = Array.from(fragments);\n81\t    txCalls.push({ fragments: frags, values });\n82\t    const head = (frags[0] ?? \"\").trim().toLowerCase();\n83\t    if (head.startsWith(\"select\")) {\n84\t      return Promise.resolve(\n85\t        options.existingRow ? [options.existingRow] : [],\n86\t      );\n87\t    }\n88\t    if (head.startsWith(\"update\") && options.failOnUpdate) {\n89\t      return Promise.reject(options.failOnUpdate);\n90\t    }\n91\t    return Promise.resolve([]);\n92\t  }) as unknown as Sql;\n93\t\n94\t  const sql = {\n95\t    async begin<T>(callback: (tx: Sql) => Promise<T>): Promise<T> {\n96\t      beginCalls += 1;\n97\t      try {\n98\t        return await callback(txSql);\n99\t      } catch (err) {\n100\t        rolledBack = true;\n101\t        throw err;\n102\t      }\n103\t    },\n104\t  } as unknown as Sql;\n105\t\n106\t  return {\n107\t    sql,\n108\t    txCalls,\n109\t    get beginCalls() {\n110\t      return beginCalls;\n111\t    },\n112\t    get rolledBack() {\n113\t      return rolledBack;\n114\t    },\n115\t  } as ReturnType<typeof createSqlMock>;\n116\t}\n117\t\n118\tconst ACTOR: PeekMutationActorContext = Object.freeze({\n119\t  email: \"admin@example.com\",\n120\t  route: \"/operations/dogpile\",\n121\t  requestId: \"req-dogpile-1\",\n122\t});\n123\t\n124\tconst ACTION_RULES: ReadonlyArray<PeekActionRule> = [\n125\t  { actionId: \"dogpile.cancel\", roles: [\"admin\"] },\n126\t];\n127\t\n128\tconst REGISTRY: PeekMutationRegistry = Object.freeze({\n129\t  \"dogpile.cancel\":\n130\t    dogpileCancelMutation as unknown as PeekMutationRegistry[string],\n131\t});\n132\t\n133\tfunction findCall(\n134\t  txCalls: ReadonlyArray<SqlCall>,\n135\t  prefix: string,\n136\t): SqlCall | undefined {\n137\t  return txCalls.find((call) =>\n138\t    (call.fragments[0] ?? \"\").trim().toLowerCase().startsWith(prefix),\n139\t  );\n140\t}\n141\t\n142\t// ---------------------------------------------------------------------------\n143\t// Schema-level tests\n144\t// ---------------------------------------------------------------------------\n145\t\n146\tdescribe(\"dogpileCancelInputSchema\", () => {\n147\t  it(\"accepts a valid numeric eventId\", () => {\n148\t    const parsed = dogpileCancelInputSchema.safeParse({ eventId: \"42\" });\n149\t    expect(parsed.success).toBe(true);\n150\t  });\n151\t\n152\t  it(\"trims whitespace from eventId\", () => {\n153\t    const parsed = dogpileCancelInputSchema.parse({ eventId: \"  42  \" });\n154\t    expect(parsed.eventId).toBe(\"42\");\n155\t  });\n156\t\n157\t  it(\"rejects a non-numeric eventId\", () => {\n158\t    const parsed = dogpileCancelInputSchema.safeParse({ eventId: \"abc\" });\n159\t    expect(parsed.success).toBe(false);\n160\t  });\n161\t\n162\t  it(\"rejects a mixed alphanumeric eventId\", () => {\n163\t    const parsed = dogpileCancelInputSchema.safeParse({ eventId: \"12a\" });\n164\t    expect(parsed.success).toBe(false);\n165\t  });\n166\t\n167\t  it(\"rejects an empty eventId after trim\", () => {\n168\t    const parsed = dogpileCancelInputSchema.safeParse({ eventId: \"   \" });\n169\t    expect(parsed.success).toBe(false);\n170\t  });\n171\t\n172\t  it(\"rejects unknown extra fields (strict)\", () => {\n173\t    const parsed = dogpileCancelInputSchema.safeParse({\n174\t      eventId: \"1\",\n175\t      smuggled: \"x\",\n176\t    });\n177\t    expect(parsed.success).toBe(false);\n178\t  });\n179\t});\n180\t\n181\t// ---------------------------------------------------------------------------\n182\t// Status enum\n183\t// ---------------------------------------------------------------------------\n184\t\n185\tdescribe(\"DOGPILE_EVENT_STATUSES\", () => {\n186\t  it(\"enumerates exactly the four lifecycle statuses\", () => {\n187\t    expect([...DOGPILE_EVENT_STATUSES].sort()).toEqual(\n188\t      [\"scheduled\", \"active\", \"ended\", \"cancelled\"].sort(),\n189\t    );\n190\t  });\n191\t});\n192\t\n193\t// ---------------------------------------------------------------------------\n194\t// Definition wiring\n195\t// ---------------------------------------------------------------------------\n196\t\n197\tdescribe(\"dogpileCancelMutation definition\", () => {\n198\t  it(\"registers the FR-14 actionId and resourceType expected by the audit log\", () => {\n199\t    expect(dogpileCancelMutation.actionId).toBe(\"dogpile.cancel\");\n200\t    expect(dogpileCancelMutation.resourceType).toBe(\"dogpile_events\");\n201\t  });\n202\t});\n203\t\n204\t// ---------------------------------------------------------------------------\n205\t// End-to-end runner tests\n206\t// ---------------------------------------------------------------------------\n207\t\n208\tdescribe(\"dogpile.cancel via runPeekMutation\", () => {\n209\t  it(\"cancels a scheduled future event and emits peek.change.applied with status diff\", async () => {\n210\t    const audit = createAuditWriter();\n211\t    const sqlMock = createSqlMock({\n212\t      existingRow: { id: \"42\", status: \"scheduled\", startsInFuture: true },\n213\t    });\n214\t\n215\t    const result: PeekMutationRunResult = await runPeekMutation({\n216\t      actionId: \"dogpile.cancel\",\n217\t      rawInput: { eventId: \"42\" },\n218\t      actorRole: \"admin\",\n219\t      actor: ACTOR,\n220\t      sql: sqlMock.sql,\n221\t      registry: REGISTRY,\n222\t      actionRules: ACTION_RULES,\n223\t      auditWriter: audit.writer,\n224\t    });\n225\t\n226\t    expect(result.ok).toBe(true);\n227\t    if (!result.ok) return;\n228\t    expect(result.actionId).toBe(\"dogpile.cancel\");\n229\t    expect(result.resourceId).toBe(\"42\");\n230\t    expect(result.changes).toEqual([\n231\t      { field: \"status\", before: \"scheduled\", after: \"cancelled\" },\n232\t    ] as ReadonlyArray<PeekAuditChange>);\n233\t\n234\t    expect(sqlMock.beginCalls).toBe(1);\n235\t    expect(sqlMock.rolledBack).toBe(false);\n236\t\n237\t    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n238\t    const updateCall = findCall(sqlMock.txCalls, \"update\");\n239\t    expect(updateCall).toBeDefined();\n240\t    expect(updateCall?.values).toEqual([\"42\"]);\n241\t    const updateSql = (updateCall?.fragments ?? []).join(\"?\").toLowerCase();\n242\t    expect(updateSql).toContain(\"status = 'cancelled'\");\n243\t\n244\t    expect(audit.calls).toHaveLength(1);\n245\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n246\t    expect(audit.calls[0]?.payload).toMatchObject({\n247\t      actorEmail: ACTOR.email,\n248\t      route: ACTOR.route,\n249\t      actionId: \"dogpile.cancel\",\n250\t      resourceType: \"dogpile_events\",\n251\t      resourceId: \"42\",\n252\t      filterSummary: null,\n253\t      resultCount: null,\n254\t      requestId: ACTOR.requestId,\n255\t      rejectionReason: null,\n256\t    });\n257\t    expect(audit.calls[0]?.payload.changes).toEqual([\n258\t      { field: \"status\", before: \"scheduled\", after: \"cancelled\" },\n259\t    ]);\n260\t    // Audit must be written on the in-tx Sql so the change + audit row are atomic.\n261\t    expect(audit.calls[0]?.sql).toBeDefined();\n262\t  });\n263\t\n264\t  it(\"denies cancelling an active event with peek.change.rejected, rolls back, and never UPDATEs\", async () => {\n265\t    const audit = createAuditWriter();\n266\t    const sqlMock = createSqlMock({\n267\t      existingRow: { id: \"7\", status: \"active\", startsInFuture: false },\n268\t    });\n269\t\n270\t    const result = await runPeekMutation({\n271\t      actionId: \"dogpile.cancel\",\n272\t      rawInput: { eventId: \"7\" },\n273\t      actorRole: \"admin\",\n274\t      actor: ACTOR,\n275\t      sql: sqlMock.sql,\n276\t      registry: REGISTRY,\n277\t      actionRules: ACTION_RULES,\n278\t      auditWriter: audit.writer,\n279\t    });\n280\t\n281\t    expect(result.ok).toBe(false);\n282\t    if (!result.ok) {\n283\t      expect(result.reason).toBe(\"execution_failed\");\n284\t      expect(result.message).toContain(\"invalid_status\");\n285\t      expect(result.message).toContain(\"active\");\n286\t    }\n287\t\n288\t    expect(sqlMock.beginCalls).toBe(1);\n289\t    expect(sqlMock.rolledBack).toBe(true);\n290\t    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n291\t    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n292\t\n293\t    expect(audit.calls).toHaveLength(1);\n294\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n295\t    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n296\t      /^execution_failed: invalid_status: active$/,\n297\t    );\n298\t    expect(audit.calls[0]?.payload.actionId).toBe(\"dogpile.cancel\");\n299\t    expect(audit.calls[0]?.payload.resourceType).toBe(\"dogpile_events\");\n300\t    expect(audit.calls[0]?.payload.changes).toBeNull();\n301\t  });\n302\t\n303\t  it(\"denies cancelling an ended event with peek.change.rejected and never UPDATEs\", async () => {\n304\t    const audit = createAuditWriter();\n305\t    const sqlMock = createSqlMock({\n306\t      existingRow: { id: \"8\", status: \"ended\", startsInFuture: false },\n307\t    });\n308\t\n309\t    const result = await runPeekMutation({\n310\t      actionId: \"dogpile.cancel\",\n311\t      rawInput: { eventId: \"8\" },\n312\t      actorRole: \"admin\",\n313\t      actor: ACTOR,\n314\t      sql: sqlMock.sql,\n315\t      registry: REGISTRY,\n316\t      actionRules: ACTION_RULES,\n317\t      auditWriter: audit.writer,\n318\t    });\n319\t\n320\t    expect(result.ok).toBe(false);\n321\t    if (!result.ok) {\n322\t      expect(result.reason).toBe(\"execution_failed\");\n323\t      expect(result.message).toContain(\"invalid_status\");\n324\t      expect(result.message).toContain(\"ended\");\n325\t    }\n326\t    expect(sqlMock.rolledBack).toBe(true);\n327\t    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n328\t\n329\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n330\t    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n331\t      /^execution_failed: invalid_status: ended$/,\n332\t    );\n333\t  });\n334\t\n335\t  it(\"denies cancelling an already-cancelled event (no-op) with peek.change.rejected and never UPDATEs\", async () => {\n336\t    const audit = createAuditWriter();\n337\t    const sqlMock = createSqlMock({\n338\t      existingRow: { id: \"9\", status: \"cancelled\", startsInFuture: false },\n339\t    });\n340\t\n341\t    const result = await runPeekMutation({\n342\t      actionId: \"dogpile.cancel\",\n343\t      rawInput: { eventId: \"9\" },\n344\t      actorRole: \"admin\",\n345\t      actor: ACTOR,\n346\t      sql: sqlMock.sql,\n347\t      registry: REGISTRY,\n348\t      actionRules: ACTION_RULES,\n349\t      auditWriter: audit.writer,\n350\t    });\n351\t\n352\t    expect(result.ok).toBe(false);\n353\t    if (!result.ok) {\n354\t      expect(result.reason).toBe(\"execution_failed\");\n355\t      expect(result.message).toContain(\"invalid_status\");\n356\t      expect(result.message).toContain(\"cancelled\");\n357\t    }\n358\t    expect(sqlMock.rolledBack).toBe(true);\n359\t    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n360\t\n361\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n362\t    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n363\t      /^execution_failed: invalid_status: cancelled$/,\n364\t    );\n365\t  });\n366\t\n367\t  it(\"denies cancelling a scheduled event whose starts_at has already elapsed (worker promotion race) and never UPDATEs\", async () => {\n368\t    const audit = createAuditWriter();\n369\t    const sqlMock = createSqlMock({\n370\t      // scheduled in DB, but starts_at <= now() — about to be promoted to active.\n371\t      existingRow: { id: \"12\", status: \"scheduled\", startsInFuture: false },\n372\t    });\n373\t\n374\t    const result = await runPeekMutation({\n375\t      actionId: \"dogpile.cancel\",\n376\t      rawInput: { eventId: \"12\" },\n377\t      actorRole: \"admin\",\n378\t      actor: ACTOR,\n379\t      sql: sqlMock.sql,\n380\t      registry: REGISTRY,\n381\t      actionRules: ACTION_RULES,\n382\t      auditWriter: audit.writer,\n383\t    });\n384\t\n385\t    expect(result.ok).toBe(false);\n386\t    if (!result.ok) {\n387\t      expect(result.reason).toBe(\"execution_failed\");\n388\t      expect(result.message).toContain(\"starts_at_in_past\");\n389\t    }\n390\t    expect(sqlMock.beginCalls).toBe(1);\n391\t    expect(sqlMock.rolledBack).toBe(true);\n392\t    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n393\t    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n394\t\n395\t    expect(audit.calls).toHaveLength(1);\n396\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n397\t    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n398\t      /^execution_failed: starts_at_in_past$/,\n399\t    );\n400\t    expect(audit.calls[0]?.payload.changes).toBeNull();\n401\t  });\n402\t\n403\t  it(\"rejects an unknown event id with peek.change.rejected, rolls back, and never UPDATEs\", async () => {\n404\t    const audit = createAuditWriter();\n405\t    const sqlMock = createSqlMock({ existingRow: null });\n406\t\n407\t    const result = await runPeekMutation({\n408\t      actionId: \"dogpile.cancel\",\n409\t      rawInput: { eventId: \"999\" },\n410\t      actorRole: \"admin\",\n411\t      actor: ACTOR,\n412\t      sql: sqlMock.sql,\n413\t      registry: REGISTRY,\n414\t      actionRules: ACTION_RULES,\n415\t      auditWriter: audit.writer,\n416\t    });\n417\t\n418\t    expect(result.ok).toBe(false);\n419\t    if (!result.ok) {\n420\t      expect(result.reason).toBe(\"execution_failed\");\n421\t      expect(result.message).toContain(\"unknown_event\");\n422\t      expect(result.message).toContain(\"999\");\n423\t    }\n424\t    expect(sqlMock.beginCalls).toBe(1);\n425\t    expect(sqlMock.rolledBack).toBe(true);\n426\t    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n427\t    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n428\t\n429\t    expect(audit.calls).toHaveLength(1);\n430\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n431\t    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n432\t      /^execution_failed: unknown_event: 999$/,\n433\t    );\n434\t    expect(audit.calls[0]?.payload.actionId).toBe(\"dogpile.cancel\");\n435\t    expect(audit.calls[0]?.payload.resourceType).toBe(\"dogpile_events\");\n436\t  });\n437\t\n438\t  it(\"rejects a non-admin actor with peek.change.rejected and never queries the DB\", async () => {\n439\t    const audit = createAuditWriter();\n440\t    const sqlMock = createSqlMock({\n441\t      existingRow: { id: \"1\", status: \"scheduled\", startsInFuture: true },\n442\t    });\n443\t\n444\t    const result = await runPeekMutation({\n445\t      actionId: \"dogpile.cancel\",\n446\t      rawInput: { eventId: \"1\" },\n447\t      actorRole: \"business\",\n448\t      actor: ACTOR,\n449\t      sql: sqlMock.sql,\n450\t      registry: REGISTRY,\n451\t      actionRules: ACTION_RULES,\n452\t      auditWriter: audit.writer,\n453\t    });\n454\t\n455\t    expect(result.ok).toBe(false);\n456\t    if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n457\t\n458\t    expect(sqlMock.beginCalls).toBe(0);\n459\t    expect(sqlMock.txCalls).toHaveLength(0);\n460\t\n461\t    expect(audit.calls).toHaveLength(1);\n462\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n463\t    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n464\t    expect(audit.calls[0]?.payload.actionId).toBe(\"dogpile.cancel\");\n465\t    expect(audit.calls[0]?.payload.resourceType).toBe(\"dogpile_events\");\n466\t  });\n467\t\n468\t  it(\"rejects an actor with no resolved role with peek.change.rejected\", async () => {\n469\t    const audit = createAuditWriter();\n470\t    const sqlMock = createSqlMock({\n471\t      existingRow: { id: \"1\", status: \"scheduled\", startsInFuture: true },\n472\t    });\n473\t\n474\t    const result = await runPeekMutation({\n475\t      actionId: \"dogpile.cancel\",\n476\t      rawInput: { eventId: \"1\" },\n477\t      actorRole: null,\n478\t      actor: ACTOR,\n479\t      sql: sqlMock.sql,\n480\t      registry: REGISTRY,\n481\t      actionRules: ACTION_RULES,\n482\t      auditWriter: audit.writer,\n483\t    });\n484\t\n485\t    expect(result.ok).toBe(false);\n486\t    if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n487\t\n488\t    expect(sqlMock.beginCalls).toBe(0);\n489\t    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n490\t  });\n491\t\n492\t  it(\"rejects an invalid input via the schema with peek.change.rejected and never opens a transaction\", async () => {\n493\t    const audit = createAuditWriter();\n494\t    const sqlMock = createSqlMock();\n495\t\n496\t    const result = await runPeekMutation({\n497\t      actionId: \"dogpile.cancel\",\n498\t      rawInput: { eventId: \"abc\" },\n499\t      actorRole: \"admin\",\n500\t      actor: ACTOR,\n501\t      sql: sqlMock.sql,\n502\t      registry: REGISTRY,\n503\t      actionRules: ACTION_RULES,\n504\t      auditWriter: audit.writer,\n505\t    });\n506\t\n507\t    expect(result.ok).toBe(false);\n508\t    if (!result.ok) {\n509\t      expect(result.reason).toBe(\"invalid_input\");\n510\t      expect(result.fieldErrors?.eventId?.length).toBeGreaterThan(0);\n511\t    }\n512\t    expect(sqlMock.beginCalls).toBe(0);\n513\t    expect(sqlMock.txCalls).toHaveLength(0);\n514\t\n515\t    expect(audit.calls).toHaveLength(1);\n516\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n517\t    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n518\t    expect(audit.calls[0]?.payload.actionId).toBe(\"dogpile.cancel\");\n519\t    expect(audit.calls[0]?.payload.resourceType).toBe(\"dogpile_events\");\n520\t    expect(audit.calls[0]?.payload.changes).toBeNull();\n521\t  });\n522\t});\n523\t"}]},"parent_tool_use_id":null,"session_id":"d5d6cbcc-e1cc-4b53-bc96-dc64b8c2e1bc","uuid":"67b5c65b-00db-469d-acd9-cf1af6a6ad1b","timestamp":"2026-04-26T19:18:46.575Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/mutations/__tests__/dogpile.test.ts","content":"import { describe, expect, it, vi } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport type { PeekActionRule } from \"../../access-policy\";\nimport type { PeekAuditWriteResult } from \"../../audit/writer\";\nimport type {\n  PeekAuditChange,\n  PeekAuditPayload,\n} from \"../../../lib/types/peek\";\nimport {\n  DOGPILE_EVENT_STATUSES,\n  dogpileCancelInputSchema,\n  dogpileCancelMutation,\n  type DogpileEventStatus,\n} from \"../dogpile\";\nimport {\n  runPeekMutation,\n  type PeekMutationAuditWriter,\n  type PeekMutationRunResult,\n} from \"../runner\";\nimport {\n  type PeekMutationActorContext,\n  type PeekMutationRegistry,\n} from \"../registry\";\n\n// ---------------------------------------------------------------------------\n// Test scaffolding (mirrors the kol-rate / fraud-flag harnesses)\n// ---------------------------------------------------------------------------\n\ntype AuditCall = {\n  eventType: string;\n  payload: PeekAuditPayload;\n  sql: Sql | undefined;\n};\n\nfunction createAuditWriter(): {\n  writer: PeekMutationAuditWriter;\n  calls: AuditCall[];\n} {\n  const calls: AuditCall[] = [];\n  const writer: PeekMutationAuditWriter = vi.fn(async (input, options) => {\n    calls.push({\n      eventType: input.eventType,\n      payload: input.payload,\n      sql: options?.sql,\n    });\n    const result: PeekAuditWriteResult = { ok: true };\n    return result;\n  });\n  return { writer, calls };\n}\n\ntype SqlCall = {\n  fragments: ReadonlyArray<string>;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ExistingRow = {\n  id: string;\n  status: DogpileEventStatus;\n  startsInFuture: boolean;\n};\n\nfunction createSqlMock(options: {\n  existingRow?: ExistingRow | null;\n  failOnUpdate?: Error;\n} = {}): {\n  sql: Sql;\n  txCalls: SqlCall[];\n  beginCalls: number;\n  rolledBack: boolean;\n} {\n  const txCalls: SqlCall[] = [];\n  let beginCalls = 0;\n  let rolledBack = false;\n\n  const txSql = ((\n    fragments: TemplateStringsArray,\n    ...values: ReadonlyArray<unknown>\n  ) => {\n    const frags = Array.from(fragments);\n    txCalls.push({ fragments: frags, values });\n    const head = (frags[0] ?? \"\").trim().toLowerCase();\n    if (head.startsWith(\"select\")) {\n      return Promise.resolve(\n        options.existingRow ? [options.existingRow] : [],\n      );\n    }\n    if (head.startsWith(\"update\") && options.failOnUpdate) {\n      return Promise.reject(options.failOnUpdate);\n    }\n    return Promise.resolve([]);\n  }) as unknown as Sql;\n\n  const sql = {\n    async begin<T>(callback: (tx: Sql) => Promise<T>): Promise<T> {\n      beginCalls += 1;\n      try {\n        return await callback(txSql);\n      } catch (err) {\n        rolledBack = true;\n        throw err;\n      }\n    },\n  } as unknown as Sql;\n\n  return {\n    sql,\n    txCalls,\n    get beginCalls() {\n      return beginCalls;\n    },\n    get rolledBack() {\n      return rolledBack;\n    },\n  } as ReturnType<typeof createSqlMock>;\n}\n\nconst ACTOR: PeekMutationActorContext = Object.freeze({\n  email: \"admin@example.com\",\n  route: \"/operations/dogpile\",\n  requestId: \"req-dogpile-1\",\n});\n\nconst ACTION_RULES: ReadonlyArray<PeekActionRule> = [\n  { actionId: \"dogpile.cancel\", roles: [\"admin\"] },\n];\n\nconst REGISTRY: PeekMutationRegistry = Object.freeze({\n  \"dogpile.cancel\":\n    dogpileCancelMutation as unknown as PeekMutationRegistry[string],\n});\n\nfunction findCall(\n  txCalls: ReadonlyArray<SqlCall>,\n  prefix: string,\n): SqlCall | undefined {\n  return txCalls.find((call) =>\n    (call.fragments[0] ?? \"\").trim().toLowerCase().startsWith(prefix),\n  );\n}\n\n// ---------------------------------------------------------------------------\n// Schema-level tests\n// ---------------------------------------------------------------------------\n\ndescribe(\"dogpileCancelInputSchema\", () => {\n  it(\"accepts a valid numeric eventId\", () => {\n    const parsed = dogpileCancelInputSchema.safeParse({ eventId: \"42\" });\n    expect(parsed.success).toBe(true);\n  });\n\n  it(\"trims whitespace from eventId\", () => {\n    const parsed = dogpileCancelInputSchema.parse({ eventId: \"  42  \" });\n    expect(parsed.eventId).toBe(\"42\");\n  });\n\n  it(\"rejects a non-numeric eventId\", () => {\n    const parsed = dogpileCancelInputSchema.safeParse({ eventId: \"abc\" });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects a mixed alphanumeric eventId\", () => {\n    const parsed = dogpileCancelInputSchema.safeParse({ eventId: \"12a\" });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects an empty eventId after trim\", () => {\n    const parsed = dogpileCancelInputSchema.safeParse({ eventId: \"   \" });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects unknown extra fields (strict)\", () => {\n    const parsed = dogpileCancelInputSchema.safeParse({\n      eventId: \"1\",\n      smuggled: \"x\",\n    });\n    expect(parsed.success).toBe(false);\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Status enum\n// ---------------------------------------------------------------------------\n\ndescribe(\"DOGPILE_EVENT_STATUSES\", () => {\n  it(\"enumerates exactly the four lifecycle statuses\", () => {\n    expect([...DOGPILE_EVENT_STATUSES].sort()).toEqual(\n      [\"scheduled\", \"active\", \"ended\", \"cancelled\"].sort(),\n    );\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Definition wiring\n// ---------------------------------------------------------------------------\n\ndescribe(\"dogpileCancelMutation definition\", () => {\n  it(\"registers the FR-14 actionId and resourceType expected by the audit log\", () => {\n    expect(dogpileCancelMutation.actionId).toBe(\"dogpile.cancel\");\n    expect(dogpileCancelMutation.resourceType).toBe(\"dogpile_events\");\n  });\n});\n\n// ---------------------------------------------------------------------------\n// End-to-end runner tests\n// ---------------------------------------------------------------------------\n\ndescribe(\"dogpile.cancel via runPeekMutation\", () => {\n  it(\"cancels a scheduled future event and emits peek.change.applied with status diff\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { id: \"42\", status: \"scheduled\", startsInFuture: true },\n    });\n\n    const result: PeekMutationRunResult = await runPeekMutation({\n      actionId: \"dogpile.cancel\",\n      rawInput: { eventId: \"42\" },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(true);\n    if (!result.ok) return;\n    expect(result.actionId).toBe(\"dogpile.cancel\");\n    expect(result.resourceId).toBe(\"42\");\n    expect(result.changes).toEqual([\n      { field: \"status\", before: \"scheduled\", after: \"cancelled\" },\n    ] as ReadonlyArray<PeekAuditChange>);\n\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(false);\n\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    const updateCall = findCall(sqlMock.txCalls, \"update\");\n    expect(updateCall).toBeDefined();\n    expect(updateCall?.values).toEqual([\"42\"]);\n    const updateSql = (updateCall?.fragments ?? []).join(\"?\").toLowerCase();\n    expect(updateSql).toContain(\"status = 'cancelled'\");\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n    expect(audit.calls[0]?.payload).toMatchObject({\n      actorEmail: ACTOR.email,\n      route: ACTOR.route,\n      actionId: \"dogpile.cancel\",\n      resourceType: \"dogpile_events\",\n      resourceId: \"42\",\n      filterSummary: null,\n      resultCount: null,\n      requestId: ACTOR.requestId,\n      rejectionReason: null,\n    });\n    expect(audit.calls[0]?.payload.changes).toEqual([\n      { field: \"status\", before: \"scheduled\", after: \"cancelled\" },\n    ]);\n    // Audit must be written on the in-tx Sql so the change + audit row are atomic.\n    expect(audit.calls[0]?.sql).toBeDefined();\n  });\n\n  it(\"denies cancelling an active event with peek.change.rejected, rolls back, and never UPDATEs\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { id: \"7\", status: \"active\", startsInFuture: false },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"dogpile.cancel\",\n      rawInput: { eventId: \"7\" },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"execution_failed\");\n      expect(result.message).toContain(\"invalid_status\");\n      expect(result.message).toContain(\"active\");\n    }\n\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(true);\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n      /^execution_failed: invalid_status: active$/,\n    );\n    expect(audit.calls[0]?.payload.actionId).toBe(\"dogpile.cancel\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"dogpile_events\");\n    expect(audit.calls[0]?.payload.changes).toBeNull();\n  });\n\n  it(\"denies cancelling an ended event with peek.change.rejected and never UPDATEs\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { id: \"8\", status: \"ended\", startsInFuture: false },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"dogpile.cancel\",\n      rawInput: { eventId: \"8\" },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"execution_failed\");\n      expect(result.message).toContain(\"invalid_status\");\n      expect(result.message).toContain(\"ended\");\n    }\n    expect(sqlMock.rolledBack).toBe(true);\n    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n      /^execution_failed: invalid_status: ended$/,\n    );\n  });\n\n  it(\"denies cancelling an already-cancelled event (no-op) with peek.change.rejected and never UPDATEs\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { id: \"9\", status: \"cancelled\", startsInFuture: false },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"dogpile.cancel\",\n      rawInput: { eventId: \"9\" },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"execution_failed\");\n      expect(result.message).toContain(\"invalid_status\");\n      expect(result.message).toContain(\"cancelled\");\n    }\n    expect(sqlMock.rolledBack).toBe(true);\n    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n      /^execution_failed: invalid_status: cancelled$/,\n    );\n  });\n\n  it(\"denies cancelling a scheduled event whose starts_at has already elapsed (worker promotion race) and never UPDATEs\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      // scheduled in DB, but starts_at <= now() — about to be promoted to active.\n      existingRow: { id: \"12\", status: \"scheduled\", startsInFuture: false },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"dogpile.cancel\",\n      rawInput: { eventId: \"12\" },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"execution_failed\");\n      expect(result.message).toContain(\"starts_at_in_past\");\n    }\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(true);\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n      /^execution_failed: starts_at_in_past$/,\n    );\n    expect(audit.calls[0]?.payload.changes).toBeNull();\n  });\n\n  it(\"rejects an unknown event id with peek.change.rejected, rolls back, and never UPDATEs\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({ existingRow: null });\n\n    const result = await runPeekMutation({\n      actionId: \"dogpile.cancel\",\n      rawInput: { eventId: \"999\" },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"execution_failed\");\n      expect(result.message).toContain(\"unknown_event\");\n      expect(result.message).toContain(\"999\");\n    }\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(true);\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n      /^execution_failed: unknown_event: 999$/,\n    );\n    expect(audit.calls[0]?.payload.actionId).toBe(\"dogpile.cancel\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"dogpile_events\");\n  });\n\n  it(\"rejects a non-admin actor with peek.change.rejected and never queries the DB\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { id: \"1\", status: \"scheduled\", startsInFuture: true },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"dogpile.cancel\",\n      rawInput: { eventId: \"1\" },\n      actorRole: \"business\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(sqlMock.txCalls).toHaveLength(0);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n    expect(audit.calls[0]?.payload.actionId).toBe(\"dogpile.cancel\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"dogpile_events\");\n  });\n\n  it(\"rejects an actor with no resolved role with peek.change.rejected\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { id: \"1\", status: \"scheduled\", startsInFuture: true },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"dogpile.cancel\",\n      rawInput: { eventId: \"1\" },\n      actorRole: null,\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n  });\n\n  it(\"rejects an invalid input via the schema with peek.change.rejected and never opens a transaction\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock();\n\n    const result = await runPeekMutation({\n      actionId: \"dogpile.cancel\",\n      rawInput: { eventId: \"abc\" },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"invalid_input\");\n      expect(result.fieldErrors?.eventId?.length).toBeGreaterThan(0);\n    }\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(sqlMock.txCalls).toHaveLength(0);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n    expect(audit.calls[0]?.payload.actionId).toBe(\"dogpile.cancel\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"dogpile_events\");\n    expect(audit.calls[0]?.payload.changes).toBeNull();\n  });\n});\n","numLines":523,"startLine":1,"totalLines":523}}}
