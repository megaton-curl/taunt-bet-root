{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VMZ5jpu9tRjtmmLXnY7NMY","type":"tool_result","content":"1\t// Public surface for the peek mutations module (FR-14).\n2\t//\n3\t// Subsequent FR-14 iterations import `runPeekMutation` to wire the\n4\t// approved mutation actions (KOL rate, fraud-flag status, dogpile cancel,\n5\t// reward-config edit) into route handlers, and import the registry types\n6\t// to register new mutation definitions alongside the framework.\n7\t\n8\texport {\n9\t  PEEK_MUTATIONS,\n10\t  getPeekMutation,\n11\t  type PeekMutationActionId,\n12\t  type PeekMutationActorContext,\n13\t  type PeekMutationDefinition,\n14\t  type PeekMutationExecuteContext,\n15\t  type PeekMutationExecuteResult,\n16\t  type PeekMutationRegistry,\n17\t} from \"./registry\";\n18\texport {\n19\t  runPeekMutation,\n20\t  type PeekMutationAuditWriter,\n21\t  type PeekMutationFailure,\n22\t  type PeekMutationFailureReason,\n23\t  type PeekMutationRunInput,\n24\t  type PeekMutationRunResult,\n25\t  type PeekMutationSuccess,\n26\t} from \"./runner\";\n27\texport {\n28\t  KOL_RATE_BPS_MAX,\n29\t  KOL_RATE_BPS_MIN,\n30\t  kolRateUpdateInputSchema,\n31\t  kolRateUpdateMutation,\n32\t  type KolRateUpdateInput,\n33\t} from \"./kol-rate\";\n34\texport {\n35\t  FRAUD_FLAG_ALLOWED_TRANSITIONS,\n36\t  FRAUD_FLAG_STATUSES,\n37\t  fraudFlagStatusUpdateInputSchema,\n38\t  fraudFlagStatusUpdateMutation,\n39\t  isFraudFlagTransitionAllowed,\n40\t  type FraudFlagStatus,\n41\t  type FraudFlagStatusUpdateInput,\n42\t} from \"./fraud-flag\";\n43\texport {\n44\t  DOGPILE_EVENT_STATUSES,\n45\t  dogpileCancelInputSchema,\n46\t  dogpileCancelMutation,\n47\t  type DogpileCancelInput,\n48\t  type DogpileEventStatus,\n49\t} from \"./dogpile\";\n50\texport {\n51\t  PEEK_REWARD_CONFIG_EDITABLE_KEYS,\n52\t  rewardConfigUpdateInputSchema,\n53\t  rewardConfigUpdateMutation,\n54\t  validateRewardConfigValueForKey,\n55\t  type RewardConfigUpdateInput,\n56\t  type RewardConfigValueValidationResult,\n57\t} from \"./reward-config\";\n58\t"}]},"parent_tool_use_id":null,"session_id":"d5d6cbcc-e1cc-4b53-bc96-dc64b8c2e1bc","uuid":"fb27072c-18b6-499f-9c1c-2c73a19df2cb","timestamp":"2026-04-26T19:19:06.015Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/mutations/index.ts","content":"// Public surface for the peek mutations module (FR-14).\n//\n// Subsequent FR-14 iterations import `runPeekMutation` to wire the\n// approved mutation actions (KOL rate, fraud-flag status, dogpile cancel,\n// reward-config edit) into route handlers, and import the registry types\n// to register new mutation definitions alongside the framework.\n\nexport {\n  PEEK_MUTATIONS,\n  getPeekMutation,\n  type PeekMutationActionId,\n  type PeekMutationActorContext,\n  type PeekMutationDefinition,\n  type PeekMutationExecuteContext,\n  type PeekMutationExecuteResult,\n  type PeekMutationRegistry,\n} from \"./registry\";\nexport {\n  runPeekMutation,\n  type PeekMutationAuditWriter,\n  type PeekMutationFailure,\n  type PeekMutationFailureReason,\n  type PeekMutationRunInput,\n  type PeekMutationRunResult,\n  type PeekMutationSuccess,\n} from \"./runner\";\nexport {\n  KOL_RATE_BPS_MAX,\n  KOL_RATE_BPS_MIN,\n  kolRateUpdateInputSchema,\n  kolRateUpdateMutation,\n  type KolRateUpdateInput,\n} from \"./kol-rate\";\nexport {\n  FRAUD_FLAG_ALLOWED_TRANSITIONS,\n  FRAUD_FLAG_STATUSES,\n  fraudFlagStatusUpdateInputSchema,\n  fraudFlagStatusUpdateMutation,\n  isFraudFlagTransitionAllowed,\n  type FraudFlagStatus,\n  type FraudFlagStatusUpdateInput,\n} from \"./fraud-flag\";\nexport {\n  DOGPILE_EVENT_STATUSES,\n  dogpileCancelInputSchema,\n  dogpileCancelMutation,\n  type DogpileCancelInput,\n  type DogpileEventStatus,\n} from \"./dogpile\";\nexport {\n  PEEK_REWARD_CONFIG_EDITABLE_KEYS,\n  rewardConfigUpdateInputSchema,\n  rewardConfigUpdateMutation,\n  validateRewardConfigValueForKey,\n  type RewardConfigUpdateInput,\n  type RewardConfigValu