{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AoYDFpPo8BgNJjMqyDmZy3","type":"tool_result","content":"1\timport { describe, expect, it, vi } from \"vitest\";\n2\timport type { Sql } from \"postgres\";\n3\timport type { PeekActionRule } from \"../../access-policy\";\n4\timport type { PeekAuditWriteResult } from \"../../audit/writer\";\n5\timport type {\n6\t  PeekAuditChange,\n7\t  PeekAuditPayload,\n8\t} from \"../../../lib/types/peek\";\n9\timport {\n10\t  FRAUD_FLAG_ALLOWED_TRANSITIONS,\n11\t  FRAUD_FLAG_STATUSES,\n12\t  fraudFlagStatusUpdateInputSchema,\n13\t  fraudFlagStatusUpdateMutation,\n14\t  isFraudFlagTransitionAllowed,\n15\t  type FraudFlagStatus,\n16\t} from \"../fraud-flag\";\n17\timport {\n18\t  runPeekMutation,\n19\t  type PeekMutationAuditWriter,\n20\t  type PeekMutationRunResult,\n21\t} from \"../runner\";\n22\timport {\n23\t  type PeekMutationActorContext,\n24\t  type PeekMutationRegistry,\n25\t} from \"../registry\";\n26\t\n27\t// ---------------------------------------------------------------------------\n28\t// Test scaffolding (mirrors the kol-rate test harness)\n29\t// ---------------------------------------------------------------------------\n30\t\n31\ttype AuditCall = {\n32\t  eventType: string;\n33\t  payload: PeekAuditPayload;\n34\t  sql: Sql | undefined;\n35\t};\n36\t\n37\tfunction createAuditWriter(): {\n38\t  writer: PeekMutationAuditWriter;\n39\t  calls: AuditCall[];\n40\t} {\n41\t  const calls: AuditCall[] = [];\n42\t  const writer: PeekMutationAuditWriter = vi.fn(async (input, options) => {\n43\t    calls.push({\n44\t      eventType: input.eventType,\n45\t      payload: input.payload,\n46\t      sql: options?.sql,\n47\t    });\n48\t    const result: PeekAuditWriteResult = { ok: true };\n49\t    return result;\n50\t  });\n51\t  return { writer, calls };\n52\t}\n53\t\n54\ttype SqlCall = {\n55\t  fragments: ReadonlyArray<string>;\n56\t  values: ReadonlyArray<unknown>;\n57\t};\n58\t\n59\ttype ExistingRow = {\n60\t  id: string;\n61\t  status: FraudFlagStatus;\n62\t};\n63\t\n64\tfunction createSqlMock(options: {\n65\t  existingRow?: ExistingRow | null;\n66\t  failOnUpdate?: Error;\n67\t} = {}): {\n68\t  sql: Sql;\n69\t  txCalls: SqlCall[];\n70\t  beginCalls: number;\n71\t  rolledBack: boolean;\n72\t} {\n73\t  const txCalls: SqlCall[] = [];\n74\t  let beginCalls = 0;\n75\t  let rolledBack = false;\n76\t\n77\t  const txSql = ((\n78\t    fragments: TemplateStringsArray,\n79\t    ...values: ReadonlyArray<unknown>\n80\t  ) => {\n81\t    const frags = Array.from(fragments);\n82\t    txCalls.push({ fragments: frags, values });\n83\t    const head = (frags[0] ?? \"\").trim().toLowerCase();\n84\t    if (head.startsWith(\"select\")) {\n85\t      return Promise.resolve(\n86\t        options.existingRow ? [options.existingRow] : [],\n87\t      );\n88\t    }\n89\t    if (head.startsWith(\"update\") && options.failOnUpdate) {\n90\t      return Promise.reject(options.failOnUpdate);\n91\t    }\n92\t    return Promise.resolve([]);\n93\t  }) as unknown as Sql;\n94\t\n95\t  const sql = {\n96\t    async begin<T>(callback: (tx: Sql) => Promise<T>): Promise<T> {\n97\t      beginCalls += 1;\n98\t      try {\n99\t        return await callback(txSql);\n100\t      } catch (err) {\n101\t        rolledBack = true;\n102\t        throw err;\n103\t      }\n104\t    },\n105\t  } as unknown as Sql;\n106\t\n107\t  return {\n108\t    sql,\n109\t    txCalls,\n110\t    get beginCalls() {\n111\t      return beginCalls;\n112\t    },\n113\t    get rolledBack() {\n114\t      return rolledBack;\n115\t    },\n116\t  } as ReturnType<typeof createSqlMock>;\n117\t}\n118\t\n119\tconst ACTOR: PeekMutationActorContext = Object.freeze({\n120\t  email: \"admin@example.com\",\n121\t  route: \"/users/user-1\",\n122\t  requestId: \"req-fraud-1\",\n123\t});\n124\t\n125\tconst ACTION_RULES: ReadonlyArray<PeekActionRule> = [\n126\t  { actionId: \"fraud_flag.status.update\", roles: [\"admin\"] },\n127\t];\n128\t\n129\tconst REGISTRY: PeekMutationRegistry = Object.freeze({\n130\t  \"fraud_flag.status.update\":\n131\t    fraudFlagStatusUpdateMutation as unknown as PeekMutationRegistry[string],\n132\t});\n133\t\n134\tfunction findCall(\n135\t  txCalls: ReadonlyArray<SqlCall>,\n136\t  prefix: string,\n137\t): SqlCall | undefined {\n138\t  return txCalls.find((call) =>\n139\t    (call.fragments[0] ?? \"\").trim().toLowerCase().startsWith(prefix),\n140\t  );\n141\t}\n142\t\n143\t// ---------------------------------------------------------------------------\n144\t// Schema-level tests\n145\t// ---------------------------------------------------------------------------\n146\t\n147\tdescribe(\"fraudFlagStatusUpdateInputSchema\", () => {\n148\t  it(\"accepts a valid input shape\", () => {\n149\t    const parsed = fraudFlagStatusUpdateInputSchema.safeParse({\n150\t      flagId: \"42\",\n151\t      nextStatus: \"reviewed\",\n152\t    });\n153\t    expect(parsed.success).toBe(true);\n154\t  });\n155\t\n156\t  it(\"rejects a non-numeric flagId\", () => {\n157\t    const parsed = fraudFlagStatusUpdateInputSchema.safeParse({\n158\t      flagId: \"abc\",\n159\t      nextStatus: \"reviewed\",\n160\t    });\n161\t    expect(parsed.success).toBe(false);\n162\t  });\n163\t\n164\t  it(\"rejects an empty flagId after trim\", () => {\n165\t    const parsed = fraudFlagStatusUpdateInputSchema.safeParse({\n166\t      flagId: \"   \",\n167\t      nextStatus: \"reviewed\",\n168\t    });\n169\t    expect(parsed.success).toBe(false);\n170\t  });\n171\t\n172\t  it(\"trims whitespace from flagId\", () => {\n173\t    const parsed = fraudFlagStatusUpdateInputSchema.parse({\n174\t      flagId: \"  42  \",\n175\t      nextStatus: \"open\",\n176\t    });\n177\t    expect(parsed.flagId).toBe(\"42\");\n178\t  });\n179\t\n180\t  it(\"rejects an unknown nextStatus value\", () => {\n181\t    const parsed = fraudFlagStatusUpdateInputSchema.safeParse({\n182\t      flagId: \"1\",\n183\t      nextStatus: \"archived\",\n184\t    });\n185\t    expect(parsed.success).toBe(false);\n186\t  });\n187\t\n188\t  it(\"rejects unknown extra fields (strict)\", () => {\n189\t    const parsed = fraudFlagStatusUpdateInputSchema.safeParse({\n190\t      flagId: \"1\",\n191\t      nextStatus: \"reviewed\",\n192\t      smuggled: \"x\",\n193\t    });\n194\t    expect(parsed.success).toBe(false);\n195\t  });\n196\t});\n197\t\n198\t// ---------------------------------------------------------------------------\n199\t// Transition matrix\n200\t// ---------------------------------------------------------------------------\n201\t\n202\tdescribe(\"FRAUD_FLAG_ALLOWED_TRANSITIONS\", () => {\n203\t  it(\"admits exactly the five allowed (from, to) tuples\", () => {\n204\t    const tuples = FRAUD_FLAG_ALLOWED_TRANSITIONS.map(([f, t]) => `${f}->${t}`);\n205\t    expect([...tuples].sort()).toEqual(\n206\t      [\n207\t        \"open->reviewed\",\n208\t        \"open->dismissed\",\n209\t        \"reviewed->open\",\n210\t        \"reviewed->dismissed\",\n211\t        \"dismissed->open\",\n212\t      ].sort(),\n213\t    );\n214\t  });\n215\t\n216\t  it(\"denies dismissed -> reviewed (must reopen first)\", () => {\n217\t    expect(isFraudFlagTransitionAllowed(\"dismissed\", \"reviewed\")).toBe(false);\n218\t  });\n219\t\n220\t  it(\"denies every no-op X -> X transition\", () => {\n221\t    for (const status of FRAUD_FLAG_STATUSES) {\n222\t      expect(isFraudFlagTransitionAllowed(status, status)).toBe(false);\n223\t    }\n224\t  });\n225\t});\n226\t\n227\t// ---------------------------------------------------------------------------\n228\t// Definition wiring\n229\t// ---------------------------------------------------------------------------\n230\t\n231\tdescribe(\"fraudFlagStatusUpdateMutation definition\", () => {\n232\t  it(\"registers the FR-14 actionId and resourceType expected by the audit log\", () => {\n233\t    expect(fraudFlagStatusUpdateMutation.actionId).toBe(\n234\t      \"fraud_flag.status.update\",\n235\t    );\n236\t    expect(fraudFlagStatusUpdateMutation.resourceType).toBe(\"fraud_flags\");\n237\t  });\n238\t});\n239\t\n240\t// ---------------------------------------------------------------------------\n241\t// End-to-end runner tests\n242\t// ---------------------------------------------------------------------------\n243\t\n244\tdescribe(\"fraud_flag.status.update via runPeekMutation\", () => {\n245\t  it(\"performs a valid open -> reviewed transition, sets resolved_at, and emits peek.change.applied with status diff\", async () => {\n246\t    const audit = createAuditWriter();\n247\t    const sqlMock = createSqlMock({\n248\t      existingRow: { id: \"42\", status: \"open\" },\n249\t    });\n250\t\n251\t    const result: PeekMutationRunResult = await runPeekMutation({\n252\t      actionId: \"fraud_flag.status.update\",\n253\t      rawInput: { flagId: \"42\", nextStatus: \"reviewed\" },\n254\t      actorRole: \"admin\",\n255\t      actor: ACTOR,\n256\t      sql: sqlMock.sql,\n257\t      registry: REGISTRY,\n258\t      actionRules: ACTION_RULES,\n259\t      auditWriter: audit.writer,\n260\t    });\n261\t\n262\t    expect(result.ok).toBe(true);\n263\t    if (!result.ok) return;\n264\t    expect(result.actionId).toBe(\"fraud_flag.status.update\");\n265\t    expect(result.resourceId).toBe(\"42\");\n266\t    expect(result.changes).toEqual([\n267\t      { field: \"status\", before: \"open\", after: \"reviewed\" },\n268\t    ] as ReadonlyArray<PeekAuditChange>);\n269\t\n270\t    expect(sqlMock.beginCalls).toBe(1);\n271\t    expect(sqlMock.rolledBack).toBe(false);\n272\t\n273\t    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n274\t    const updateCall = findCall(sqlMock.txCalls, \"update\");\n275\t    expect(updateCall).toBeDefined();\n276\t    // Non-open transitions bind nextStatus + flagId only — resolved_at is now().\n277\t    expect(updateCall?.values).toEqual([\"reviewed\", \"42\"]);\n278\t\n279\t    expect(audit.calls).toHaveLength(1);\n280\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n281\t    expect(audit.calls[0]?.payload).toMatchObject({\n282\t      actorEmail: ACTOR.email,\n283\t      route: ACTOR.route,\n284\t      actionId: \"fraud_flag.status.update\",\n285\t      resourceType: \"fraud_flags\",\n286\t      resourceId: \"42\",\n287\t      filterSummary: null,\n288\t      resultCount: null,\n289\t      requestId: ACTOR.requestId,\n290\t      rejectionReason: null,\n291\t    });\n292\t    expect(audit.calls[0]?.payload.changes).toEqual([\n293\t      { field: \"status\", before: \"open\", after: \"reviewed\" },\n294\t    ]);\n295\t    // Audit must be written on the in-tx Sql so the change + audit row are atomic.\n296\t    expect(audit.calls[0]?.sql).toBeDefined();\n297\t  });\n298\t\n299\t  it(\"performs a reopen (dismissed -> open), clears resolved_at, and emits applied audit\", async () => {\n300\t    const audit = createAuditWriter();\n301\t    const sqlMock = createSqlMock({\n302\t      existingRow: { id: \"7\", status: \"dismissed\" },\n303\t    });\n304\t\n305\t    const result = await runPeekMutation({\n306\t      actionId: \"fraud_flag.status.update\",\n307\t      rawInput: { flagId: \"7\", nextStatus: \"open\" },\n308\t      actorRole: \"admin\",\n309\t      actor: ACTOR,\n310\t      sql: sqlMock.sql,\n311\t      registry: REGISTRY,\n312\t      actionRules: ACTION_RULES,\n313\t      auditWriter: audit.writer,\n314\t    });\n315\t\n316\t    expect(result.ok).toBe(true);\n317\t    if (!result.ok) return;\n318\t    expect(result.changes).toEqual([\n319\t      { field: \"status\", before: \"dismissed\", after: \"open\" },\n320\t    ]);\n321\t\n322\t    const updateCall = findCall(sqlMock.txCalls, \"update\");\n323\t    // Reopen branch binds nextStatus + flagId; resolved_at is set to NULL literal.\n324\t    expect(updateCall?.values).toEqual([\"open\", \"7\"]);\n325\t    // Reopen UPDATE writes resolved_at = null (not now()).\n326\t    const updateSql = (updateCall?.fragments ?? []).join(\"?\").toLowerCase();\n327\t    expect(updateSql).toContain(\"resolved_at = null\");\n328\t    expect(updateSql).not.toContain(\"now()\");\n329\t\n330\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n331\t  });\n332\t\n333\t  it(\"rejects an invalid dismissed -> reviewed transition with peek.change.rejected, rolls back, and never UPDATEs\", async () => {\n334\t    const audit = createAuditWriter();\n335\t    const sqlMock = createSqlMock({\n336\t      existingRow: { id: \"9\", status: \"dismissed\" },\n337\t    });\n338\t\n339\t    const result = await runPeekMutation({\n340\t      actionId: \"fraud_flag.status.update\",\n341\t      rawInput: { flagId: \"9\", nextStatus: \"reviewed\" },\n342\t      actorRole: \"admin\",\n343\t      actor: ACTOR,\n344\t      sql: sqlMock.sql,\n345\t      registry: REGISTRY,\n346\t      actionRules: ACTION_RULES,\n347\t      auditWriter: audit.writer,\n348\t    });\n349\t\n350\t    expect(result.ok).toBe(false);\n351\t    if (!result.ok) {\n352\t      expect(result.reason).toBe(\"execution_failed\");\n353\t      expect(result.message).toContain(\"invalid_transition\");\n354\t      expect(result.message).toContain(\"dismissed\");\n355\t      expect(result.message).toContain(\"reviewed\");\n356\t    }\n357\t\n358\t    expect(sqlMock.beginCalls).toBe(1);\n359\t    expect(sqlMock.rolledBack).toBe(true);\n360\t    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n361\t    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n362\t\n363\t    expect(audit.calls).toHaveLength(1);\n364\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n365\t    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n366\t      /^execution_failed: invalid_transition: dismissed -> reviewed$/,\n367\t    );\n368\t    expect(audit.calls[0]?.payload.actionId).toBe(\"fraud_flag.status.update\");\n369\t    expect(audit.calls[0]?.payload.resourceType).toBe(\"fraud_flags\");\n370\t    expect(audit.calls[0]?.payload.changes).toBeNull();\n371\t  });\n372\t\n373\t  it(\"rejects a no-op X -> X transition with peek.change.rejected and never UPDATEs\", async () => {\n374\t    const audit = createAuditWriter();\n375\t    const sqlMock = createSqlMock({\n376\t      existingRow: { id: \"11\", status: \"open\" },\n377\t    });\n378\t\n379\t    const result = await runPeekMutation({\n380\t      actionId: \"fraud_flag.status.update\",\n381\t      rawInput: { flagId: \"11\", nextStatus: \"open\" },\n382\t      actorRole: \"admin\",\n383\t      actor: ACTOR,\n384\t      sql: sqlMock.sql,\n385\t      registry: REGISTRY,\n386\t      actionRules: ACTION_RULES,\n387\t      auditWriter: audit.writer,\n388\t    });\n389\t\n390\t    expect(result.ok).toBe(false);\n391\t    if (!result.ok) {\n392\t      expect(result.reason).toBe(\"execution_failed\");\n393\t      expect(result.message).toContain(\"invalid_transition\");\n394\t    }\n395\t    expect(sqlMock.rolledBack).toBe(true);\n396\t    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n397\t\n398\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n399\t    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n400\t      /invalid_transition: open -> open/,\n401\t    );\n402\t  });\n403\t\n404\t  it(\"rejects an unknown flag id with peek.change.rejected, rolls back, and never UPDATEs\", async () => {\n405\t    const audit = createAuditWriter();\n406\t    const sqlMock = createSqlMock({ existingRow: null });\n407\t\n408\t    const result = await runPeekMutation({\n409\t      actionId: \"fraud_flag.status.update\",\n410\t      rawInput: { flagId: \"999\", nextStatus: \"reviewed\" },\n411\t      actorRole: \"admin\",\n412\t      actor: ACTOR,\n413\t      sql: sqlMock.sql,\n414\t      registry: REGISTRY,\n415\t      actionRules: ACTION_RULES,\n416\t      auditWriter: audit.writer,\n417\t    });\n418\t\n419\t    expect(result.ok).toBe(false);\n420\t    if (!result.ok) {\n421\t      expect(result.reason).toBe(\"execution_failed\");\n422\t      expect(result.message).toContain(\"unknown_flag\");\n423\t      expect(result.message).toContain(\"999\");\n424\t    }\n425\t    expect(sqlMock.beginCalls).toBe(1);\n426\t    expect(sqlMock.rolledBack).toBe(true);\n427\t    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n428\t    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n429\t\n430\t    expect(audit.calls).toHaveLength(1);\n431\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n432\t    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n433\t      /^execution_failed: unknown_flag: 999$/,\n434\t    );\n435\t    expect(audit.calls[0]?.payload.actionId).toBe(\"fraud_flag.status.update\");\n436\t    expect(audit.calls[0]?.payload.resourceType).toBe(\"fraud_flags\");\n437\t  });\n438\t\n439\t  it(\"rejects a non-admin actor with peek.change.rejected and never queries the DB\", async () => {\n440\t    const audit = createAuditWriter();\n441\t    const sqlMock = createSqlMock({\n442\t      existingRow: { id: \"1\", status: \"open\" },\n443\t    });\n444\t\n445\t    const result = await runPeekMutation({\n446\t      actionId: \"fraud_flag.status.update\",\n447\t      rawInput: { flagId: \"1\", nextStatus: \"reviewed\" },\n448\t      actorRole: \"business\",\n449\t      actor: ACTOR,\n450\t      sql: sqlMock.sql,\n451\t      registry: REGISTRY,\n452\t      actionRules: ACTION_RULES,\n453\t      auditWriter: audit.writer,\n454\t    });\n455\t\n456\t    expect(result.ok).toBe(false);\n457\t    if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n458\t\n459\t    expect(sqlMock.beginCalls).toBe(0);\n460\t    expect(sqlMock.txCalls).toHaveLength(0);\n461\t\n462\t    expect(audit.calls).toHaveLength(1);\n463\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n464\t    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n465\t    expect(audit.calls[0]?.payload.actionId).toBe(\"fraud_flag.status.update\");\n466\t    expect(audit.calls[0]?.payload.resourceType).toBe(\"fraud_flags\");\n467\t  });\n468\t\n469\t  it(\"rejects an actor with no resolved role with peek.change.rejected\", async () => {\n470\t    const audit = createAuditWriter();\n471\t    const sqlMock = createSqlMock({\n472\t      existingRow: { id: \"1\", status: \"open\" },\n473\t    });\n474\t\n475\t    const result = await runPeekMutation({\n476\t      actionId: \"fraud_flag.status.update\",\n477\t      rawInput: { flagId: \"1\", nextStatus: \"reviewed\" },\n478\t      actorRole: null,\n479\t      actor: ACTOR,\n480\t      sql: sqlMock.sql,\n481\t      registry: REGISTRY,\n482\t      actionRules: ACTION_RULES,\n483\t      auditWriter: audit.writer,\n484\t    });\n485\t\n486\t    expect(result.ok).toBe(false);\n487\t    if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n488\t\n489\t    expect(sqlMock.beginCalls).toBe(0);\n490\t    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n491\t  });\n492\t\n493\t  it(\"rejects an invalid input via the schema with peek.change.rejected and never opens a transaction\", async () => {\n494\t    const audit = createAuditWriter();\n495\t    const sqlMock = createSqlMock();\n496\t\n497\t    const result = await runPeekMutation({\n498\t      actionId: \"fraud_flag.status.update\",\n499\t      rawInput: { flagId: \"abc\", nextStatus: \"reviewed\" },\n500\t      actorRole: \"admin\",\n501\t      actor: ACTOR,\n502\t      sql: sqlMock.sql,\n503\t      registry: REGISTRY,\n504\t      actionRules: ACTION_RULES,\n505\t      auditWriter: audit.writer,\n506\t    });\n507\t\n508\t    expect(result.ok).toBe(false);\n509\t    if (!result.ok) {\n510\t      expect(result.reason).toBe(\"invalid_input\");\n511\t      expect(result.fieldErrors?.flagId?.length).toBeGreaterThan(0);\n512\t    }\n513\t    expect(sqlMock.beginCalls).toBe(0);\n514\t    expect(sqlMock.txCalls).toHaveLength(0);\n515\t\n516\t    expect(audit.calls).toHaveLength(1);\n517\t    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n518\t    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n519\t    expect(audit.calls[0]?.payload.actionId).toBe(\"fraud_flag.status.update\");\n520\t    expect(audit.calls[0]?.payload.resourceType).toBe(\"fraud_flags\");\n521\t    expect(audit.calls[0]?.payload.changes).toBeNull();\n522\t  });\n523\t});\n524\t"}]},"parent_tool_use_id":null,"session_id":"d5d6cbcc-e1cc-4b53-bc96-dc64b8c2e1bc","uuid":"fc2aa4fb-6b3f-4da9-8d8b-701f25438053","timestamp":"2026-04-26T19:19:03.300Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/mutations/__tests__/fraud-flag.test.ts","content":"import { describe, expect, it, vi } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport type { PeekActionRule } from \"../../access-policy\";\nimport type { PeekAuditWriteResult } from \"../../audit/writer\";\nimport type {\n  PeekAuditChange,\n  PeekAuditPayload,\n} from \"../../../lib/types/peek\";\nimport {\n  FRAUD_FLAG_ALLOWED_TRANSITIONS,\n  FRAUD_FLAG_STATUSES,\n  fraudFlagStatusUpdateInputSchema,\n  fraudFlagStatusUpdateMutation,\n  isFraudFlagTransitionAllowed,\n  type FraudFlagStatus,\n} from \"../fraud-flag\";\nimport {\n  runPeekMutation,\n  type PeekMutationAuditWriter,\n  type PeekMutationRunResult,\n} from \"../runner\";\nimport {\n  type PeekMutationActorContext,\n  type PeekMutationRegistry,\n} from \"../registry\";\n\n// ---------------------------------------------------------------------------\n// Test scaffolding (mirrors the kol-rate test harness)\n// ---------------------------------------------------------------------------\n\ntype AuditCall = {\n  eventType: string;\n  payload: PeekAuditPayload;\n  sql: Sql | undefined;\n};\n\nfunction createAuditWriter(): {\n  writer: PeekMutationAuditWriter;\n  calls: AuditCall[];\n} {\n  const calls: AuditCall[] = [];\n  const writer: PeekMutationAuditWriter = vi.fn(async (input, options) => {\n    calls.push({\n      eventType: input.eventType,\n      payload: input.payload,\n      sql: options?.sql,\n    });\n    const result: PeekAuditWriteResult = { ok: true };\n    return result;\n  });\n  return { writer, calls };\n}\n\ntype SqlCall = {\n  fragments: ReadonlyArray<string>;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ExistingRow = {\n  id: string;\n  status: FraudFlagStatus;\n};\n\nfunction createSqlMock(options: {\n  existingRow?: ExistingRow | null;\n  failOnUpdate?: Error;\n} = {}): {\n  sql: Sql;\n  txCalls: SqlCall[];\n  beginCalls: number;\n  rolledBack: boolean;\n} {\n  const txCalls: SqlCall[] = [];\n  let beginCalls = 0;\n  let rolledBack = false;\n\n  const txSql = ((\n    fragments: TemplateStringsArray,\n    ...values: ReadonlyArray<unknown>\n  ) => {\n    const frags = Array.from(fragments);\n    txCalls.push({ fragments: frags, values });\n    const head = (frags[0] ?? \"\").trim().toLowerCase();\n    if (head.startsWith(\"select\")) {\n      return Promise.resolve(\n        options.existingRow ? [options.existingRow] : [],\n      );\n    }\n    if (head.startsWith(\"update\") && options.failOnUpdate) {\n      return Promise.reject(options.failOnUpdate);\n    }\n    return Promise.resolve([]);\n  }) as unknown as Sql;\n\n  const sql = {\n    async begin<T>(callback: (tx: Sql) => Promise<T>): Promise<T> {\n      beginCalls += 1;\n      try {\n        return await callback(txSql);\n      } catch (err) {\n        rolledBack = true;\n        throw err;\n      }\n    },\n  } as unknown as Sql;\n\n  return {\n    sql,\n    txCalls,\n    get beginCalls() {\n      return beginCalls;\n    },\n    get rolledBack() {\n      return rolledBack;\n    },\n  } as ReturnType<typeof createSqlMock>;\n}\n\nconst ACTOR: PeekMutationActorContext = Object.freeze({\n  email: \"admin@example.com\",\n  route: \"/users/user-1\",\n  requestId: \"req-fraud-1\",\n});\n\nconst ACTION_RULES: ReadonlyArray<PeekActionRule> = [\n  { actionId: \"fraud_flag.status.update\", roles: [\"admin\"] },\n];\n\nconst REGISTRY: PeekMutationRegistry = Object.freeze({\n  \"fraud_flag.status.update\":\n    fraudFlagStatusUpdateMutation as unknown as PeekMutationRegistry[string],\n});\n\nfunction findCall(\n  txCalls: ReadonlyArray<SqlCall>,\n  prefix: string,\n): SqlCall | undefined {\n  return txCalls.find((call) =>\n    (call.fragments[0] ?? \"\").trim().toLowerCase().startsWith(prefix),\n  );\n}\n\n// ---------------------------------------------------------------------------\n// Schema-level tests\n// ---------------------------------------------------------------------------\n\ndescribe(\"fraudFlagStatusUpdateInputSchema\", () => {\n  it(\"accepts a valid input shape\", () => {\n    const parsed = fraudFlagStatusUpdateInputSchema.safeParse({\n      flagId: \"42\",\n      nextStatus: \"reviewed\",\n    });\n    expect(parsed.success).toBe(true);\n  });\n\n  it(\"rejects a non-numeric flagId\", () => {\n    const parsed = fraudFlagStatusUpdateInputSchema.safeParse({\n      flagId: \"abc\",\n      nextStatus: \"reviewed\",\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects an empty flagId after trim\", () => {\n    const parsed = fraudFlagStatusUpdateInputSchema.safeParse({\n      flagId: \"   \",\n      nextStatus: \"reviewed\",\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"trims whitespace from flagId\", () => {\n    const parsed = fraudFlagStatusUpdateInputSchema.parse({\n      flagId: \"  42  \",\n      nextStatus: \"open\",\n    });\n    expect(parsed.flagId).toBe(\"42\");\n  });\n\n  it(\"rejects an unknown nextStatus value\", () => {\n    const parsed = fraudFlagStatusUpdateInputSchema.safeParse({\n      flagId: \"1\",\n      nextStatus: \"archived\",\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects unknown extra fields (strict)\", () => {\n    const parsed = fraudFlagStatusUpdateInputSchema.safeParse({\n      flagId: \"1\",\n      nextStatus: \"reviewed\",\n      smuggled: \"x\",\n    });\n    expect(parsed.success).toBe(false);\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Transition matrix\n// ---------------------------------------------------------------------------\n\ndescribe(\"FRAUD_FLAG_ALLOWED_TRANSITIONS\", () => {\n  it(\"admits exactly the five allowed (from, to) tuples\", () => {\n    const tuples = FRAUD_FLAG_ALLOWED_TRANSITIONS.map(([f, t]) => `${f}->${t}`);\n    expect([...tuples].sort()).toEqual(\n      [\n        \"open->reviewed\",\n        \"open->dismissed\",\n        \"reviewed->open\",\n        \"reviewed->dismissed\",\n        \"dismissed->open\",\n      ].sort(),\n    );\n  });\n\n  it(\"denies dismissed -> reviewed (must reopen first)\", () => {\n    expect(isFraudFlagTransitionAllowed(\"dismissed\", \"reviewed\")).toBe(false);\n  });\n\n  it(\"denies every no-op X -> X transition\", () => {\n    for (const status of FRAUD_FLAG_STATUSES) {\n      expect(isFraudFlagTransitionAllowed(status, status)).toBe(false);\n    }\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Definition wiring\n// ---------------------------------------------------------------------------\n\ndescribe(\"fraudFlagStatusUpdateMutation definition\", () => {\n  it(\"registers the FR-14 actionId and resourceType expected by the audit log\", () => {\n    expect(fraudFlagStatusUpdateMutation.actionId).toBe(\n      \"fraud_flag.status.update\",\n    );\n    expect(fraudFlagStatusUpdateMutation.resourceType).toBe(\"fraud_flags\");\n  });\n});\n\n// ---------------------------------------------------------------------------\n// End-to-end runner tests\n// ---------------------------------------------------------------------------\n\ndescribe(\"fraud_flag.status.update via runPeekMutation\", () => {\n  it(\"performs a valid open -> reviewed transition, sets resolved_at, and emits peek.change.applied with status diff\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { id: \"42\", status: \"open\" },\n    });\n\n    const result: PeekMutationRunResult = await runPeekMutation({\n      actionId: \"fraud_flag.status.update\",\n      rawInput: { flagId: \"42\", nextStatus: \"reviewed\" },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(true);\n    if (!result.ok) return;\n    expect(result.actionId).toBe(\"fraud_flag.status.update\");\n    expect(result.resourceId).toBe(\"42\");\n    expect(result.changes).toEqual([\n      { field: \"status\", before: \"open\", after: \"reviewed\" },\n    ] as ReadonlyArray<PeekAuditChange>);\n\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(false);\n\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    const updateCall = findCall(sqlMock.txCalls, \"update\");\n    expect(updateCall).toBeDefined();\n    // Non-open transitions bind nextStatus + flagId only — resolved_at is now().\n    expect(updateCall?.values).toEqual([\"reviewed\", \"42\"]);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n    expect(audit.calls[0]?.payload).toMatchObject({\n      actorEmail: ACTOR.email,\n      route: ACTOR.route,\n      actionId: \"fraud_flag.status.update\",\n      resourceType: \"fraud_flags\",\n      resourceId: \"42\",\n      filterSummary: null,\n      resultCount: null,\n      requestId: ACTOR.requestId,\n      rejectionReason: null,\n    });\n    expect(audit.calls[0]?.payload.changes).toEqual([\n      { field: \"status\", before: \"open\", after: \"reviewed\" },\n    ]);\n    // Audit must be written on the in-tx Sql so the change + audit row are atomic.\n    expect(audit.calls[0]?.sql).toBeDefined();\n  });\n\n  it(\"performs a reopen (dismissed -> open), clears resolved_at, and emits applied audit\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { id: \"7\", status: \"dismissed\" },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"fraud_flag.status.update\",\n      rawInput: { flagId: \"7\", nextStatus: \"open\" },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(true);\n    if (!result.ok) return;\n    expect(result.changes).toEqual([\n      { field: \"status\", before: \"dismissed\", after: \"open\" },\n    ]);\n\n    const updateCall = findCall(sqlMock.txCalls, \"update\");\n    // Reopen branch binds nextStatus + flagId; resolved_at is set to NULL literal.\n    expect(updateCall?.values).toEqual([\"open\", \"7\"]);\n    // Reopen UPDATE writes resolved_at = null (not now()).\n    const updateSql = (updateCall?.fragments ?? []).join(\"?\").toLowerCase();\n    expect(updateSql).toContain(\"resolved_at = null\");\n    expect(updateSql).not.toContain(\"now()\");\n\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n  });\n\n  it(\"rejects an invalid dismissed -> reviewed transition with peek.change.rejected, rolls back, and never UPDATEs\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { id: \"9\", status: \"dismissed\" },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"fraud_flag.status.update\",\n      rawInput: { flagId: \"9\", nextStatus: \"reviewed\" },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"execution_failed\");\n      expect(result.message).toContain(\"invalid_transition\");\n      expect(result.message).toContain(\"dismissed\");\n      expect(result.message).toContain(\"reviewed\");\n    }\n\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(true);\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n      /^execution_failed: invalid_transition: dismissed -> reviewed$/,\n    );\n    expect(audit.calls[0]?.payload.actionId).toBe(\"fraud_flag.status.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"fraud_flags\");\n    expect(audit.calls[0]?.payload.changes).toBeNull();\n  });\n\n  it(\"rejects a no-op X -> X transition with peek.change.rejected and never UPDATEs\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { id: \"11\", status: \"open\" },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"fraud_flag.status.update\",\n      rawInput: { flagId: \"11\", nextStatus: \"open\" },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"execution_failed\");\n      expect(result.message).toContain(\"invalid_transition\");\n    }\n    expect(sqlMock.rolledBack).toBe(true);\n    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n      /invalid_transition: open -> open/,\n    );\n  });\n\n  it(\"rejects an unknown flag id with peek.change.rejected, rolls back, and never UPDATEs\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({ existingRow: null });\n\n    const result = await runPeekMutation({\n      actionId: \"fraud_flag.status.update\",\n      rawInput: { flagId: \"999\", nextStatus: \"reviewed\" },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"execution_failed\");\n      expect(result.message).toContain(\"unknown_flag\");\n      expect(result.message).toContain(\"999\");\n    }\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(true);\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n      /^execution_failed: unknown_flag: 999$/,\n    );\n    expect(audit.calls[0]?.payload.actionId).toBe(\"fraud_flag.status.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"fraud_flags\");\n  });\n\n  it(\"rejects a non-admin actor with peek.change.rejected and never queries the DB\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { id: \"1\", status: \"open\" },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"fraud_flag.status.update\",\n      rawInput: { flagId: \"1\", nextStatus: \"reviewed\" },\n      actorRole: \"business\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(sqlMock.txCalls).toHaveLength(0);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n    expect(audit.calls[0]?.payload.actionId).toBe(\"fraud_flag.status.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"fraud_flags\");\n  });\n\n  it(\"rejects an actor with no resolved role with peek.change.rejected\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { id: \"1\", status: \"open\" },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"fraud_flag.status.update\",\n      rawInput: { flagId: \"1\", nextStatus: \"reviewed\" },\n      actorRole: null,\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n  });\n\n  it(\"rejects an invalid input via the schema with peek.change.rejected and never opens a transaction\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock();\n\n    const result = await runPeekMutation({\n      actionId: \"fraud_flag.status.update\",\n      rawInput: { flagId: \"abc\", nextStatus: \"reviewed\" },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"invalid_input\");\n      expect(result.fieldErrors?.flagId?.length).toBeGreaterThan(0);\n    }\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(sqlMock.txCalls).toHaveLength(0);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n    expect(audit.calls[0]?.payload.actionId).toBe(\"fraud_flag.status.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"fraud_flags\");\n    expect(audit.calls[0]?.payload.changes).toBeNull();\n  });\n});\n","numLines":524,"startLine":1,"totalLines":524}}}
