{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01BZAQLsSGWDQbF6FnYwWogj","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_019FqPM2fejGjhD34iU4aWLT","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/mutations/__tests__/reward-config.test.ts","content":"import { describe, expect, it, vi } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport type { PeekActionRule } from \"../../access-policy\";\nimport type { PeekAuditWriteResult } from \"../../audit/writer\";\nimport type {\n  PeekAuditChange,\n  PeekAuditPayload,\n} from \"../../../lib/types/peek\";\nimport { PEEK_REWARD_CONFIG_KEY_REGISTRY } from \"../../db/queries/get-rewards\";\nimport {\n  PEEK_REWARD_CONFIG_EDITABLE_KEYS,\n  rewardConfigUpdateInputSchema,\n  rewardConfigUpdateMutation,\n  validateRewardConfigValueForKey,\n} from \"../reward-config\";\nimport {\n  runPeekMutation,\n  type PeekMutationAuditWriter,\n  type PeekMutationRunResult,\n} from \"../runner\";\nimport {\n  type PeekMutationActorContext,\n  type PeekMutationRegistry,\n} from \"../registry\";\n\n// ---------------------------------------------------------------------------\n// Test scaffolding (mirrors the kol-rate / fraud-flag / dogpile harnesses)\n// ---------------------------------------------------------------------------\n\ntype AuditCall = {\n  eventType: string;\n  payload: PeekAuditPayload;\n  sql: Sql | undefined;\n};\n\nfunction createAuditWriter(): {\n  writer: PeekMutationAuditWriter;\n  calls: AuditCall[];\n} {\n  const calls: AuditCall[] = [];\n  const writer: PeekMutationAuditWriter = vi.fn(async (input, options) => {\n    calls.push({\n      eventType: input.eventType,\n      payload: input.payload,\n      sql: options?.sql,\n    });\n    const result: PeekAuditWriteResult = { ok: true };\n    return result;\n  });\n  return { writer, calls };\n}\n\ntype SqlCall = {\n  fragments: ReadonlyArray<string>;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ExistingRow = {\n  key: string;\n  value: string;\n};\n\nfunction createSqlMock(options: {\n  existingRow?: ExistingRow | null;\n  failOnUpdate?: Error;\n} = {}): {\n  sql: Sql;\n  txCalls: SqlCall[];\n  beginCalls: number;\n  rolledBack: boolean;\n} {\n  const txCalls: SqlCall[] = [];\n  let beginCalls = 0;\n  let rolledBack = false;\n\n  const txSql = ((\n    fragments: TemplateStringsArray,\n    ...values: ReadonlyArray<unknown>\n  ) => {\n    const frags = Array.from(fragments);\n    txCalls.push({ fragments: frags, values });\n    const head = (frags[0] ?? \"\").trim().toLowerCase();\n    if (head.startsWith(\"select\")) {\n      return Promise.resolve(\n        options.existingRow ? [options.existingRow] : [],\n      );\n    }\n    if (head.startsWith(\"update\") && options.failOnUpdate) {\n      return Promise.reject(options.failOnUpdate);\n    }\n    return Promise.resolve([]);\n  }) as unknown as Sql;\n\n  const sql = {\n    async begin<T>(callback: (tx: Sql) => Promise<T>): Promise<T> {\n      beginCalls += 1;\n      try {\n        return await callback(txSql);\n      } catch (err) {\n        rolledBack = true;\n        throw err;\n      }\n    },\n  } as unknown as Sql;\n\n  return {\n    sql,\n    txCalls,\n    get beginCalls() {\n      return beginCalls;\n    },\n    get rolledBack() {\n      return rolledBack;\n    },\n  } as ReturnType<typeof createSqlMock>;\n}\n\nconst ACTOR: PeekMutationActorContext = Object.freeze({\n  email: \"admin@example.com\",\n  route: \"/economy/rewards\",\n  requestId: \"req-reward-config-1\",\n});\n\nconst ACTION_RULES: ReadonlyArray<PeekActionRule> = [\n  { actionId: \"reward_config.update\", roles: [\"admin\"] },\n];\n\nconst REGISTRY: PeekMutationRegistry = Object.freeze({\n  \"reward_config.update\":\n    rewardConfigUpdateMutation as unknown as PeekMutationRegistry[string],\n});\n\nfunction findCall(\n  txCalls: ReadonlyArray<SqlCall>,\n  prefix: string,\n): SqlCall | undefined {\n  return txCalls.find((call) =>\n    (call.fragments[0] ?? \"\").trim().toLowerCase().startsWith(prefix),\n  );\n}\n\n// ---------------------------------------------------------------------------\n// Editable-keys allowlist\n// ---------------------------------------------------------------------------\n\ndescribe(\"PEEK_REWARD_CONFIG_EDITABLE_KEYS\", () => {\n  it(\"contains only registered keys whose expectedType is not 'unknown'\", () => {\n    for (const key of PEEK_REWARD_CONFIG_EDITABLE_KEYS) {\n      const entry = PEEK_REWARD_CONFIG_KEY_REGISTRY[key];\n      expect(entry).toBeDefined();\n      expect(entry?.expectedType).not.toBe(\"unknown\");\n    }\n  });\n\n  it(\"includes the seeded reward economy keys at minimum\", () => {\n    expect(PEEK_REWARD_CONFIG_EDITABLE_KEYS).toContain(\"points_per_dollar\");\n    expect(PEEK_REWARD_CONFIG_EDITABLE_KEYS).toContain(\n      \"reward_pool_fee_share\",\n    );\n    expect(PEEK_REWARD_CONFIG_EDITABLE_KEYS).toContain(\"sol_crate_min_value\");\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Value validator\n// ---------------------------------------------------------------------------\n\ndescribe(\"validateRewardConfigValueForKey\", () => {\n  it(\"accepts valid integer text for an integer key\", () => {\n    expect(\n      validateRewardConfigValueForKey(\"points_per_dollar\", \"100\"),\n    ).toEqual({ ok: true });\n    expect(\n      validateRewardConfigValueForKey(\"points_per_dollar\", \"-3\"),\n    ).toEqual({ ok: true });\n  });\n\n  it(\"rejects non-integer text for an integer key\", () => {\n    const r = validateRewardConfigValueForKey(\"points_per_dollar\", \"1.5\");\n    expect(r.ok).toBe(false);\n    if (!r.ok) expect(r.reason).toBe(\"expected_integer\");\n  });\n\n  it(\"accepts valid lamports text for a lamports key\", () => {\n    expect(\n      validateRewardConfigValueForKey(\"sol_crate_min_value\", \"100000\"),\n    ).toEqual({ ok: true });\n  });\n\n  it(\"rejects negative or non-numeric text for a lamports key\", () => {\n    const negative = validateRewardConfigValueForKey(\n      \"sol_crate_min_value\",\n      \"-1\",\n    );\n    expect(negative.ok).toBe(false);\n    if (!negative.ok) expect(negative.reason).toBe(\"expected_lamports\");\n\n    const nonNumeric = validateRewardConfigValueForKey(\n      \"sol_crate_min_value\",\n      \"abc\",\n    );\n    expect(nonNumeric.ok).toBe(false);\n    if (!nonNumeric.ok) expect(nonNumeric.reason).toBe(\"expected_lamports\");\n  });\n\n  it(\"accepts a decimal float for a float key\", () => {\n    expect(\n      validateRewardConfigValueForKey(\"dogpile_default_multiplier\", \"1.5\"),\n    ).toEqual({ ok: true });\n  });\n\n  it(\"rejects pure-integer text in a float slot to prevent silent narrowing\", () => {\n    const r = validateRewardConfigValueForKey(\n      \"dogpile_default_multiplier\",\n      \"2\",\n    );\n    expect(r.ok).toBe(false);\n    if (!r.ok) expect(r.reason).toBe(\"expected_float_with_decimal\");\n  });\n\n  it(\"rejects non-finite text for a float key\", () => {\n    const r = validateRewardConfigValueForKey(\n      \"dogpile_default_multiplier\",\n      \"abc\",\n    );\n    expect(r.ok).toBe(false);\n    if (!r.ok) expect(r.reason).toBe(\"expected_float\");\n  });\n\n  it(\"accepts a ratio in [0, 1] for a ratio key\", () => {\n    expect(\n      validateRewardConfigValueForKey(\"reward_pool_fee_share\", \"0.25\"),\n    ).toEqual({ ok: true });\n    expect(\n      validateRewardConfigValueForKey(\"reward_pool_fee_share\", \"0\"),\n    ).toEqual({ ok: true });\n    expect(\n      validateRewardConfigValueForKey(\"reward_pool_fee_share\", \"1\"),\n    ).toEqual({ ok: true });\n  });\n\n  it(\"rejects an out-of-range ratio\", () => {\n    const tooHigh = validateRewardConfigValueForKey(\n      \"reward_pool_fee_share\",\n      \"1.5\",\n    );\n    expect(tooHigh.ok).toBe(false);\n    if (!tooHigh.ok) expect(tooHigh.reason).toBe(\"ratio_out_of_range\");\n\n    const negative = validateRewardConfigValueForKey(\n      \"reward_pool_fee_share\",\n      \"-0.1\",\n    );\n    expect(negative.ok).toBe(false);\n    if (!negative.ok) expect(negative.reason).toBe(\"ratio_out_of_range\");\n  });\n\n  it(\"rejects an unknown key\", () => {\n    const r = validateRewardConfigValueForKey(\"not_a_real_key\", \"1\");\n    expect(r.ok).toBe(false);\n    if (!r.ok) expect(r.reason).toBe(\"unknown_key\");\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Schema-level tests\n// ---------------------------------------------------------------------------\n\ndescribe(\"rewardConfigUpdateInputSchema\", () => {\n  it(\"accepts a valid allowlisted integer key with confirmation\", () => {\n    const parsed = rewardConfigUpdateInputSchema.safeParse({\n      key: \"points_per_dollar\",\n      value: \"200\",\n      confirm: true,\n    });\n    expect(parsed.success).toBe(true);\n  });\n\n  it(\"trims whitespace around key and value\", () => {\n    const parsed = rewardConfigUpdateInputSchema.parse({\n      key: \"  points_per_dollar  \",\n      value: \"  150  \",\n      confirm: true,\n    });\n    expect(parsed.key).toBe(\"points_per_dollar\");\n    expect(parsed.value).toBe(\"150\");\n  });\n\n  it(\"rejects a key that is not in the editable allowlist\", () => {\n    const parsed = rewardConfigUpdateInputSchema.safeParse({\n      key: \"not_a_real_key\",\n      value: \"1\",\n      confirm: true,\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects a malformed value for the declared expected type\", () => {\n    const parsed = rewardConfigUpdateInputSchema.safeParse({\n      key: \"points_per_dollar\",\n      value: \"1.5\",\n      confirm: true,\n    });\n    expect(parsed.success).toBe(false);\n    if (!parsed.success) {\n      const flat = parsed.error.flatten();\n      expect(flat.fieldErrors.value?.length ?? 0).toBeGreaterThan(0);\n    }\n  });\n\n  it(\"rejects a missing confirm flag\", () => {\n    const parsed = rewardConfigUpdateInputSchema.safeParse({\n      key: \"points_per_dollar\",\n      value: \"200\",\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects confirm: false explicitly\", () => {\n    const parsed = rewardConfigUpdateInputSchema.safeParse({\n      key: \"points_per_dollar\",\n      value: \"200\",\n      confirm: false,\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects an empty value after trim\", () => {\n    const parsed = rewardConfigUpdateInputSchema.safeParse({\n      key: \"points_per_dollar\",\n      value: \"   \",\n      confirm: true,\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects unknown extra fields (strict)\", () => {\n    const parsed = rewardConfigUpdateInputSchema.safeParse({\n      key: \"points_per_dollar\",\n      value: \"200\",\n      confirm: true,\n      smuggled: \"x\",\n    });\n    expect(parsed.success).toBe(false);\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Definition wiring\n// ---------------------------------------------------------------------------\n\ndescribe(\"rewardConfigUpdateMutation definition\", () => {\n  it(\"registers the FR-14 actionId and resourceType expected by the audit log\", () => {\n    expect(rewardConfigUpdateMutation.actionId).toBe(\"reward_config.update\");\n    expect(rewardConfigUpdateMutation.resourceType).toBe(\"reward_config\");\n  });\n});\n\n// ---------------------------------------------------------------------------\n// End-to-end runner tests\n// ---------------------------------------------------------------------------\n\ndescribe(\"reward_config.update via runPeekMutation\", () => {\n  it(\"updates an allowlisted integer key and emits peek.change.applied with value diff\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { key: \"points_per_dollar\", value: \"100\" },\n    });\n\n    const result: PeekMutationRunResult = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"points_per_dollar\",\n        value: \"200\",\n        confirm: true,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(true);\n    if (!result.ok) return;\n    expect(result.actionId).toBe(\"reward_config.update\");\n    expect(result.resourceId).toBe(\"points_per_dollar\");\n    expect(result.changes).toEqual([\n      { field: \"value\", before: \"100\", after: \"200\" },\n    ] as ReadonlyArray<PeekAuditChange>);\n\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(false);\n\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    const updateCall = findCall(sqlMock.txCalls, \"update\");\n    expect(updateCall).toBeDefined();\n    // Update binds the new value + key only — updated_at uses now() literal.\n    expect(updateCall?.values).toEqual([\"200\", \"points_per_dollar\"]);\n    const updateSql = (updateCall?.fragments ?? []).join(\"?\").toLowerCase();\n    expect(updateSql).toContain(\"update reward_config\");\n    expect(updateSql).toContain(\"updated_at = now()\");\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n    expect(audit.calls[0]?.payload).toMatchObject({\n      actorEmail: ACTOR.email,\n      route: ACTOR.route,\n      actionId: \"reward_config.update\",\n      resourceType: \"reward_config\",\n      resourceId: \"points_per_dollar\",\n      filterSummary: null,\n      resultCount: null,\n      requestId: ACTOR.requestId,\n      rejectionReason: null,\n    });\n    expect(audit.calls[0]?.payload.changes).toEqual([\n      { field: \"value\", before: \"100\", after: \"200\" },\n    ]);\n    // Audit must be written on the in-tx Sql so the change + audit row are atomic.\n    expect(audit.calls[0]?.sql).toBeDefined();\n  });\n\n  it(\"updates a ratio key and emits applied audit\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { key: \"reward_pool_fee_share\", value: \"0.1\" },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"reward_pool_fee_share\",\n        value: \"0.25\",\n        confirm: true,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(true);\n    if (!result.ok) return;\n    expect(result.changes).toEqual([\n      { field: \"value\", before: \"0.1\", after: \"0.25\" },\n    ]);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n  });\n\n  it(\"rejects a disallowed key with peek.change.rejected and never opens a transaction\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock();\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"not_a_real_key\",\n        value: \"1\",\n        confirm: true,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"invalid_input\");\n      expect(result.fieldErrors?.key?.length).toBeGreaterThan(0);\n    }\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(sqlMock.txCalls).toHaveLength(0);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n    expect(audit.calls[0]?.payload.actionId).toBe(\"reward_config.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"reward_config\");\n    expect(audit.calls[0]?.payload.changes).toBeNull();\n  });\n\n  it(\"rejects a malformed value for the declared expected type with peek.change.rejected and never opens a transaction\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock();\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"points_per_dollar\",\n        value: \"1.5\",\n        confirm: true,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"invalid_input\");\n      expect(result.fieldErrors?.value?.length).toBeGreaterThan(0);\n    }\n    expect(sqlMock.beginCalls).toBe(0);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n    expect(audit.calls[0]?.payload.changes).toBeNull();\n  });\n\n  it(\"rejects an out-of-range ratio with peek.change.rejected\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock();\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"reward_pool_fee_share\",\n        value: \"1.5\",\n        confirm: true,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"invalid_input\");\n      expect(result.fieldErrors?.value?.length).toBeGreaterThan(0);\n    }\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n  });\n\n  it(\"rejects a missing confirmation flag with peek.change.rejected and never opens a transaction\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock();\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"points_per_dollar\",\n        value: \"200\",\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"invalid_input\");\n      expect(result.fieldErrors?.confirm?.length).toBeGreaterThan(0);\n    }\n    expect(sqlMock.beginCalls).toBe(0);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n    expect(audit.calls[0]?.payload.changes).toBeNull();\n  });\n\n  it(\"rejects confirm: false with peek.change.rejected\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock();\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"points_per_dollar\",\n        value: \"200\",\n        confirm: false,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) expect(result.reason).toBe(\"invalid_input\");\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n  });\n\n  it(\"rejects a no-op (value unchanged) with peek.change.rejected, rolls back, and never UPDATEs\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { key: \"points_per_dollar\", value: \"200\" },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"points_per_dollar\",\n        value: \"200\",\n        confirm: true,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"execution_failed\");\n      expect(result.message).toContain(\"noop_value\");\n    }\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(true);\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n      /^execution_failed: noop_value$/,\n    );\n    expect(audit.calls[0]?.payload.changes).toBeNull();\n  });\n\n  it(\"rejects an allowlisted key missing from the database with peek.change.rejected and never UPDATEs\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({ existingRow: null });\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"points_per_dollar\",\n        value: \"200\",\n        confirm: true,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"execution_failed\");\n      expect(result.message).toContain(\"unknown_key\");\n      expect(result.message).toContain(\"points_per_dollar\");\n    }\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(true);\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n      /^execution_failed: unknown_key: points_per_dollar$/,\n    );\n    expect(audit.calls[0]?.payload.actionId).toBe(\"reward_config.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"reward_config\");\n  });\n\n  it(\"rejects a non-admin actor with peek.change.rejected and never queries the DB\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { key: \"points_per_dollar\", value: \"100\" },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"points_per_dollar\",\n        value: \"200\",\n        confirm: true,\n      },\n      actorRole: \"business\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(sqlMock.txCalls).toHaveLength(0);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n    expect(audit.calls[0]?.payload.actionId).toBe(\"reward_config.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"reward_config\");\n  });\n\n  it(\"rejects an actor with no resolved role with peek.change.rejected\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { key: \"points_per_dollar\", value: \"100\" },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"points_per_dollar\",\n        value: \"200\",\n        confirm: true,\n      },\n      actorRole: null,\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n  });\n});\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":963,"cache_read_input_tokens":102749,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":963},"output_tokens":39,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"d5d6cbcc-e1cc-4b53-bc96-dc64b8c2e1bc","uuid":"9bd41816-8d61-4ba6-ac63-8a894cd12f45"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019FqPM2fejGjhD34iU4aWLT","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/server/mutations/__tests__/reward-config.test.ts"}]},"parent_tool_use_id":null,"session_id":"d5d6cbcc-e1cc-4b53-bc96-dc64b8c2e1bc","uuid":"70eeab05-ab7f-4f9d-9fac-e91071518250","timestamp":"2026-04-26T19:20:48.382Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/server/mutations/__tests__/reward-config.test.ts","content":"import { describe, expect, it, vi } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport type { PeekActionRule } from \"../../access-policy\";\nimport type { PeekAuditWriteResult } from \"../../audit/writer\";\nimport type {\n  PeekAuditChange,\n  PeekAuditPayload,\n} from \"../../../lib/types/peek\";\nimport { PEEK_REWARD_CONFIG_KEY_REGISTRY } from \"../../db/queries/get-rewards\";\nimport {\n  PEEK_REWARD_CONFIG_EDITABLE_KEYS,\n  rewardConfigUpdateInputSchema,\n  rewardConfigUpdateMutation,\n  validateRewardConfigValueForKey,\n} from \"../reward-config\";\nimport {\n  runPeekMutation,\n  type PeekMutationAuditWriter,\n  type PeekMutationRunResult,\n} from \"../runner\";\nimport {\n  type PeekMutationActorContext,\n  type PeekMutationRegistry,\n} from \"../registry\";\n\n// ---------------------------------------------------------------------------\n// Test scaffolding (mirrors the kol-rate / fraud-flag / dogpile harnesses)\n// ---------------------------------------------------------------------------\n\ntype AuditCall = {\n  eventType: string;\n  payload: PeekAuditPayload;\n  sql: Sql | undefined;\n};\n\nfunction createAuditWriter(): {\n  writer: PeekMutationAuditWriter;\n  calls: AuditCall[];\n} {\n  const calls: AuditCall[] = [];\n  const writer: PeekMutationAuditWriter = vi.fn(async (input, options) => {\n    calls.push({\n      eventType: input.eventType,\n      payload: input.payload,\n      sql: options?.sql,\n    });\n    const result: PeekAuditWriteResult = { ok: true };\n    return result;\n  });\n  return { writer, calls };\n}\n\ntype SqlCall = {\n  fragments: ReadonlyArray<string>;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ExistingRow = {\n  key: string;\n  value: string;\n};\n\nfunction createSqlMock(options: {\n  existingRow?: ExistingRow | null;\n  failOnUpdate?: Error;\n} = {}): {\n  sql: Sql;\n  txCalls: SqlCall[];\n  beginCalls: number;\n  rolledBack: boolean;\n} {\n  const txCalls: SqlCall[] = [];\n  let beginCalls = 0;\n  let rolledBack = false;\n\n  const txSql = ((\n    fragments: TemplateStringsArray,\n    ...values: ReadonlyArray<unknown>\n  ) => {\n    const frags = Array.from(fragments);\n    txCalls.push({ fragments: frags, values });\n    const head = (frags[0] ?? \"\").trim().toLowerCase();\n    if (head.startsWith(\"select\")) {\n      return Promise.resolve(\n        options.existingRow ? [options.existingRow] : [],\n      );\n    }\n    if (head.startsWith(\"update\") && options.failOnUpdate) {\n      return Promise.reject(options.failOnUpdate);\n    }\n    return Promise.resolve([]);\n  }) as unknown as Sql;\n\n  const sql = {\n    async begin<T>(callback: (tx: Sql) => Promise<T>): Promise<T> {\n      beginCalls += 1;\n      try {\n        return await callback(txSql);\n      } catch (err) {\n        rolledBack = true;\n        throw err;\n      }\n    },\n  } as unknown as Sql;\n\n  return {\n    sql,\n    txCalls,\n    get beginCalls() {\n      return beginCalls;\n    },\n    get rolledBack() {\n      return rolledBack;\n    },\n  } as ReturnType<typeof createSqlMock>;\n}\n\nconst ACTOR: PeekMutationActorContext = Object.freeze({\n  email: \"admin@example.com\",\n  route: \"/economy/rewards\",\n  requestId: \"req-reward-config-1\",\n});\n\nconst ACTION_RULES: ReadonlyArray<PeekActionRule> = [\n  { actionId: \"reward_config.update\", roles: [\"admin\"] },\n];\n\nconst REGISTRY: PeekMutationRegistry = Object.freeze({\n  \"reward_config.update\":\n    rewardConfigUpdateMutation as unknown as PeekMutationRegistry[string],\n});\n\nfunction findCall(\n  txCalls: ReadonlyArray<SqlCall>,\n  prefix: string,\n): SqlCall | undefined {\n  return txCalls.find((call) =>\n    (call.fragments[0] ?? \"\").trim().toLowerCase().startsWith(prefix),\n  );\n}\n\n// ---------------------------------------------------------------------------\n// Editable-keys allowlist\n// ---------------------------------------------------------------------------\n\ndescribe(\"PEEK_REWARD_CONFIG_EDITABLE_KEYS\", () => {\n  it(\"contains only registered keys whose expectedType is not 'unknown'\", () => {\n    for (const key of PEEK_REWARD_CONFIG_EDITABLE_KEYS) {\n      const entry = PEEK_REWARD_CONFIG_KEY_REGISTRY[key];\n      expect(entry).toBeDefined();\n      expect(entry?.expectedType).not.toBe(\"unknown\");\n    }\n  });\n\n  it(\"includes the seeded reward economy keys at minimum\", () => {\n    expect(PEEK_REWARD_CONFIG_EDITABLE_KEYS).toContain(\"points_per_dollar\");\n    expect(PEEK_REWARD_CONFIG_EDITABLE_KEYS).toContain(\n      \"reward_pool_fee_share\",\n    );\n    expect(PEEK_REWARD_CONFIG_EDITABLE_KEYS).toContain(\"sol_crate_min_value\");\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Value validator\n// ---------------------------------------------------------------------------\n\ndescribe(\"validateRewardConfigValueForKey\", () => {\n  it(\"accepts valid integer text for an integer key\", () => {\n    expect(\n      validateRewardConfigValueForKey(\"points_per_dollar\", \"100\"),\n    ).toEqual({ ok: true });\n    expect(\n      validateRewardConfigValueForKey(\"points_per_dollar\", \"-3\"),\n    ).toEqual({ ok: true });\n  });\n\n  it(\"rejects non-integer text for an integer key\", () => {\n    const r = validateRewardConfigValueForKey(\"points_per_dollar\", \"1.5\");\n    expect(r.ok).toBe(false);\n    if (!r.ok) expect(r.reason).toBe(\"expected_integer\");\n  });\n\n  it(\"accepts valid lamports text for a lamports key\", () => {\n    expect(\n      validateRewardConfigValueForKey(\"sol_crate_min_value\", \"100000\"),\n    ).toEqual({ ok: true });\n  });\n\n  it(\"rejects negative or non-numeric text for a lamports key\", () => {\n    const negative = validateRewardConfigValueForKey(\n      \"sol_crate_min_value\",\n      \"-1\",\n    );\n    expect(negative.ok).toBe(false);\n    if (!negative.ok) expect(negative.reason).toBe(\"expected_lamports\");\n\n    const nonNumeric = validateRewardConfigValueForKey(\n      \"sol_crate_min_value\",\n      \"abc\",\n    );\n    expect(nonNumeric.ok).toBe(false);\n    if (!nonNumeric.ok) expect(nonNumeric.reason).toBe(\"expected_lamports\");\n  });\n\n  it(\"accepts a decimal float for a float key\", () => {\n    expect(\n      validateRewardConfigValueForKey(\"dogpile_default_multiplier\", \"1.5\"),\n    ).toEqual({ ok: true });\n  });\n\n  it(\"rejects pure-integer text in a float slot to prevent silent narrowing\", () => {\n    const r = validateRewardConfigValueForKey(\n      \"dogpile_default_multiplier\",\n      \"2\",\n    );\n    expect(r.ok).toBe(false);\n    if (!r.ok) expect(r.reason).toBe(\"expected_float_with_decimal\");\n  });\n\n  it(\"rejects non-finite text for a float key\", () => {\n    const r = validateRewardConfigValueForKey(\n      \"dogpile_default_multiplier\",\n      \"abc\",\n    );\n    expect(r.ok).toBe(false);\n    if (!r.ok) expect(r.reason).toBe(\"expected_float\");\n  });\n\n  it(\"accepts a ratio in [0, 1] for a ratio key\", () => {\n    expect(\n      validateRewardConfigValueForKey(\"reward_pool_fee_share\", \"0.25\"),\n    ).toEqual({ ok: true });\n    expect(\n      validateRewardConfigValueForKey(\"reward_pool_fee_share\", \"0\"),\n    ).toEqual({ ok: true });\n    expect(\n      validateRewardConfigValueForKey(\"reward_pool_fee_share\", \"1\"),\n    ).toEqual({ ok: true });\n  });\n\n  it(\"rejects an out-of-range ratio\", () => {\n    const tooHigh = validateRewardConfigValueForKey(\n      \"reward_pool_fee_share\",\n      \"1.5\",\n    );\n    expect(tooHigh.ok).toBe(false);\n    if (!tooHigh.ok) expect(tooHigh.reason).toBe(\"ratio_out_of_range\");\n\n    const negative = validateRewardConfigValueForKey(\n      \"reward_pool_fee_share\",\n      \"-0.1\",\n    );\n    expect(negative.ok).toBe(false);\n    if (!negative.ok) expect(negative.reason).toBe(\"ratio_out_of_range\");\n  });\n\n  it(\"rejects an unknown key\", () => {\n    const r = validateRewardConfigValueForKey(\"not_a_real_key\", \"1\");\n    expect(r.ok).toBe(false);\n    if (!r.ok) expect(r.reason).toBe(\"unknown_key\");\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Schema-level tests\n// ---------------------------------------------------------------------------\n\ndescribe(\"rewardConfigUpdateInputSchema\", () => {\n  it(\"accepts a valid allowlisted integer key with confirmation\", () => {\n    const parsed = rewardConfigUpdateInputSchema.safeParse({\n      key: \"points_per_dollar\",\n      value: \"200\",\n      confirm: true,\n    });\n    expect(parsed.success).toBe(true);\n  });\n\n  it(\"trims whitespace around key and value\", () => {\n    const parsed = rewardConfigUpdateInputSchema.parse({\n      key: \"  points_per_dollar  \",\n      value: \"  150  \",\n      confirm: true,\n    });\n    expect(parsed.key).toBe(\"points_per_dollar\");\n    expect(parsed.value).toBe(\"150\");\n  });\n\n  it(\"rejects a key that is not in the editable allowlist\", () => {\n    const parsed = rewardConfigUpdateInputSchema.safeParse({\n      key: \"not_a_real_key\",\n      value: \"1\",\n      confirm: true,\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects a malformed value for the declared expected type\", () => {\n    const parsed = rewardConfigUpdateInputSchema.safeParse({\n      key: \"points_per_dollar\",\n      value: \"1.5\",\n      confirm: true,\n    });\n    expect(parsed.success).toBe(false);\n    if (!parsed.success) {\n      const flat = parsed.error.flatten();\n      expect(flat.fieldErrors.value?.length ?? 0).toBeGreaterThan(0);\n    }\n  });\n\n  it(\"rejects a missing confirm flag\", () => {\n    const parsed = rewardConfigUpdateInputSchema.safeParse({\n      key: \"points_per_dollar\",\n      value: \"200\",\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects confirm: false explicitly\", () => {\n    const parsed = rewardConfigUpdateInputSchema.safeParse({\n      key: \"points_per_dollar\",\n      value: \"200\",\n      confirm: false,\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects an empty value after trim\", () => {\n    const parsed = rewardConfigUpdateInputSchema.safeParse({\n      key: \"points_per_dollar\",\n      value: \"   \",\n      confirm: true,\n    });\n    expect(parsed.success).toBe(false);\n  });\n\n  it(\"rejects unknown extra fields (strict)\", () => {\n    const parsed = rewardConfigUpdateInputSchema.safeParse({\n      key: \"points_per_dollar\",\n      value: \"200\",\n      confirm: true,\n      smuggled: \"x\",\n    });\n    expect(parsed.success).toBe(false);\n  });\n});\n\n// ---------------------------------------------------------------------------\n// Definition wiring\n// ---------------------------------------------------------------------------\n\ndescribe(\"rewardConfigUpdateMutation definition\", () => {\n  it(\"registers the FR-14 actionId and resourceType expected by the audit log\", () => {\n    expect(rewardConfigUpdateMutation.actionId).toBe(\"reward_config.update\");\n    expect(rewardConfigUpdateMutation.resourceType).toBe(\"reward_config\");\n  });\n});\n\n// ---------------------------------------------------------------------------\n// End-to-end runner tests\n// ---------------------------------------------------------------------------\n\ndescribe(\"reward_config.update via runPeekMutation\", () => {\n  it(\"updates an allowlisted integer key and emits peek.change.applied with value diff\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { key: \"points_per_dollar\", value: \"100\" },\n    });\n\n    const result: PeekMutationRunResult = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"points_per_dollar\",\n        value: \"200\",\n        confirm: true,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(true);\n    if (!result.ok) return;\n    expect(result.actionId).toBe(\"reward_config.update\");\n    expect(result.resourceId).toBe(\"points_per_dollar\");\n    expect(result.changes).toEqual([\n      { field: \"value\", before: \"100\", after: \"200\" },\n    ] as ReadonlyArray<PeekAuditChange>);\n\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(false);\n\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    const updateCall = findCall(sqlMock.txCalls, \"update\");\n    expect(updateCall).toBeDefined();\n    // Update binds the new value + key only — updated_at uses now() literal.\n    expect(updateCall?.values).toEqual([\"200\", \"points_per_dollar\"]);\n    const updateSql = (updateCall?.fragments ?? []).join(\"?\").toLowerCase();\n    expect(updateSql).toContain(\"update reward_config\");\n    expect(updateSql).toContain(\"updated_at = now()\");\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n    expect(audit.calls[0]?.payload).toMatchObject({\n      actorEmail: ACTOR.email,\n      route: ACTOR.route,\n      actionId: \"reward_config.update\",\n      resourceType: \"reward_config\",\n      resourceId: \"points_per_dollar\",\n      filterSummary: null,\n      resultCount: null,\n      requestId: ACTOR.requestId,\n      rejectionReason: null,\n    });\n    expect(audit.calls[0]?.payload.changes).toEqual([\n      { field: \"value\", before: \"100\", after: \"200\" },\n    ]);\n    // Audit must be written on the in-tx Sql so the change + audit row are atomic.\n    expect(audit.calls[0]?.sql).toBeDefined();\n  });\n\n  it(\"updates a ratio key and emits applied audit\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { key: \"reward_pool_fee_share\", value: \"0.1\" },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"reward_pool_fee_share\",\n        value: \"0.25\",\n        confirm: true,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(true);\n    if (!result.ok) return;\n    expect(result.changes).toEqual([\n      { field: \"value\", before: \"0.1\", after: \"0.25\" },\n    ]);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n  });\n\n  it(\"rejects a disallowed key with peek.change.rejected and never opens a transaction\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock();\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"not_a_real_key\",\n        value: \"1\",\n        confirm: true,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"invalid_input\");\n      expect(result.fieldErrors?.key?.length).toBeGreaterThan(0);\n    }\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(sqlMock.txCalls).toHaveLength(0);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n    expect(audit.calls[0]?.payload.actionId).toBe(\"reward_config.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"reward_config\");\n    expect(audit.calls[0]?.payload.changes).toBeNull();\n  });\n\n  it(\"rejects a malformed value for the declared expected type with peek.change.rejected and never opens a transaction\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock();\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"points_per_dollar\",\n        value: \"1.5\",\n        confirm: true,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"invalid_input\");\n      expect(result.fieldErrors?.value?.length).toBeGreaterThan(0);\n    }\n    expect(sqlMock.beginCalls).toBe(0);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n    expect(audit.calls[0]?.payload.changes).toBeNull();\n  });\n\n  it(\"rejects an out-of-range ratio with peek.change.rejected\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock();\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"reward_pool_fee_share\",\n        value: \"1.5\",\n        confirm: true,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"invalid_input\");\n      expect(result.fieldErrors?.value?.length).toBeGreaterThan(0);\n    }\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n  });\n\n  it(\"rejects a missing confirmation flag with peek.change.rejected and never opens a transaction\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock();\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"points_per_dollar\",\n        value: \"200\",\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"invalid_input\");\n      expect(result.fieldErrors?.confirm?.length).toBeGreaterThan(0);\n    }\n    expect(sqlMock.beginCalls).toBe(0);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n    expect(audit.calls[0]?.payload.changes).toBeNull();\n  });\n\n  it(\"rejects confirm: false with peek.change.rejected\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock();\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"points_per_dollar\",\n        value: \"200\",\n        confirm: false,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) expect(result.reason).toBe(\"invalid_input\");\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n  });\n\n  it(\"rejects a no-op (value unchanged) with peek.change.rejected, rolls back, and never UPDATEs\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { key: \"points_per_dollar\", value: \"200\" },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"points_per_dollar\",\n        value: \"200\",\n        confirm: true,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"execution_failed\");\n      expect(result.message).toContain(\"noop_value\");\n    }\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(true);\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n      /^execution_failed: noop_value$/,\n    );\n    expect(audit.calls[0]?.payload.changes).toBeNull();\n  });\n\n  it(\"rejects an allowlisted key missing from the database with peek.change.rejected and never UPDATEs\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({ existingRow: null });\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"points_per_dollar\",\n        value: \"200\",\n        confirm: true,\n      },\n      actorRole: \"admin\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) {\n      expect(result.reason).toBe(\"execution_failed\");\n      expect(result.message).toContain(\"unknown_key\");\n      expect(result.message).toContain(\"points_per_dollar\");\n    }\n    expect(sqlMock.beginCalls).toBe(1);\n    expect(sqlMock.rolledBack).toBe(true);\n    expect(findCall(sqlMock.txCalls, \"select\")).toBeDefined();\n    expect(findCall(sqlMock.txCalls, \"update\")).toBeUndefined();\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n      /^execution_failed: unknown_key: points_per_dollar$/,\n    );\n    expect(audit.calls[0]?.payload.actionId).toBe(\"reward_config.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"reward_config\");\n  });\n\n  it(\"rejects a non-admin actor with peek.change.rejected and never queries the DB\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { key: \"points_per_dollar\", value: \"100\" },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"points_per_dollar\",\n        value: \"200\",\n        confirm: true,\n      },\n      actorRole: \"business\",\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(sqlMock.txCalls).toHaveLength(0);\n\n    expect(audit.calls).toHaveLength(1);\n    expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n    expect(audit.calls[0]?.payload.actionId).toBe(\"reward_config.update\");\n    expect(audit.calls[0]?.payload.resourceType).toBe(\"reward_config\");\n  });\n\n  it(\"rejects an actor with no resolved role with peek.change.rejected\", async () => {\n    const audit = createAuditWriter();\n    const sqlMock = createSqlMock({\n      existingRow: { key: \"points_per_dollar\", value: \"100\" },\n    });\n\n    const result = await runPeekMutation({\n      actionId: \"reward_config.update\",\n      rawInput: {\n        key: \"points_per_dollar\",\n        value: \"200\",\n        confirm: true,\n      },\n      actorRole: null,\n      actor: ACTOR,\n      sql: sqlMock.sql,\n      registry: REGISTRY,\n      actionRules: ACTION_RULES,\n      auditWriter: audit.writer,\n    });\n\n    expect(result.ok).toBe(false);\n    if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n\n    expect(sqlMock.beginCalls).toBe(0);\n    expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n  });\n});\n","structuredPatch":[],"originalFile":null,"userModified":false}}
