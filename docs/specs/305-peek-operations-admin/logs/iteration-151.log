{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017qV2MZtpSYL8NCttwmNVA2","type":"tool_result","content":"1\t// Approved FR-14 mutation: edit a single `reward_config` row.\n2\t//\n3\t// Scope:\n4\t//   - Identified by the TEXT primary key `reward_config.key`.\n5\t//   - Only the `value` column moves; the diff records the before/after pair.\n6\t//   - `updated_at` is bumped server-side and stays out of the audit diff\n7\t//     (matches the kol-rate `updated_at` precedent).\n8\t//\n9\t// Key allowlist (FR-14: \"selected `reward_config` keys\"):\n10\t//   The mutation accepts keys present in `PEEK_REWARD_CONFIG_KEY_REGISTRY`\n11\t//   (and only those whose `expectedType` is not `\"unknown\"`). Unknown keys\n12\t//   are rejected at schema time so a typo or a key that has been seeded but\n13\t//   not registered cannot be edited from the admin UI.\n14\t//\n15\t// Value validation:\n16\t//   The submitted `value` is a string (matches the TEXT column shape) and\n17\t//   is validated against the registry-declared `expectedType`:\n18\t//     - integer  -> ^-?[0-9]+$\n19\t//     - float    -> finite Number; bigint-only forms are rejected so\n20\t//       operators do not stash an integer into a float slot by accident\n21\t//       (use the integer slot instead).\n22\t//     - ratio    -> finite Number in [0, 1]\n23\t//     - lamports -> ^[0-9]+$ (non-negative u64-style decimal text)\n24\t//   Whitespace is trimmed before validation.\n25\t//\n26\t// Explicit confirmation flag:\n27\t//   The input requires `confirm: true`. A missing/false `confirm` is\n28\t//   rejected as `invalid_input` so the operator UI cannot silently apply\n29\t//   a reward-economy change.\n30\t//\n31\t// No-op rejection:\n32\t//   If the new `value` matches the row's existing `value`, the mutation is\n33\t//   rejected (`execution_failed: noop_value`) so the audit row reflects a\n34\t//   real movement.\n35\t//\n36\t// Failure semantics (surfaced through the runner's execute path):\n37\t//   - Unknown key                -> `execution_failed: unknown_key:`.\n38\t//     Note: the schema layer rejects un-allowlisted keys ahead of execute,\n39\t//     so this surfaces only when a key listed in the registry is missing\n40\t//     from the database.\n41\t//   - No-op (value unchanged)    -> `execution_failed: noop_value`.\n42\t//   - Schema validation failures (missing key/value, disallowed key,\n43\t//     malformed value, missing confirmation) -> the runner's\n44\t//     `invalid_input` path before any DB work.\n45\t//\n46\t// Authorization:\n47\t//   `reward_config.update` is admin-only per FR-2 `PEEK_ACTION_RULES`.\n48\t//   The runner enforces this before `execute` is called.\n49\t\n50\timport type { Sql } from \"postgres\";\n51\timport { z } from \"zod\";\n52\timport type { PeekAuditChange } from \"../../lib/types/peek\";\n53\timport {\n54\t  PEEK_REWARD_CONFIG_KEY_REGISTRY,\n55\t} from \"../db/queries/get-rewards\";\n56\timport type {\n57\t  PeekMutationDefinition,\n58\t  PeekMutationExecuteContext,\n59\t  PeekMutationExecuteResult,\n60\t} from \"./registry\";\n61\t\n62\t// Editable keys are the registered keys whose expected type is known.\n63\t// `Object.keys` on a frozen registry preserves insertion order; the result\n64\t// is reused both for the schema enum and for runtime allowlist checks.\n65\texport const PEEK_REWARD_CONFIG_EDITABLE_KEYS: ReadonlyArray<string> =\n66\t  Object.freeze(\n67\t    Object.entries(PEEK_REWARD_CONFIG_KEY_REGISTRY)\n68\t      .filter(([, entry]) => entry.expectedType !== \"unknown\")\n69\t      .map(([key]) => key),\n70\t  );\n71\t\n72\tfunction isEditableKey(key: string): boolean {\n73\t  return PEEK_REWARD_CONFIG_EDITABLE_KEYS.includes(key);\n74\t}\n75\t\n76\tconst INTEGER_PATTERN = /^-?[0-9]+$/u;\n77\tconst LAMPORTS_PATTERN = /^[0-9]+$/u;\n78\t\n79\texport type RewardConfigValueValidationResult =\n80\t  | { ok: true }\n81\t  | { ok: false; reason: string };\n82\t\n83\texport function validateRewardConfigValueForKey(\n84\t  key: string,\n85\t  value: string,\n86\t): RewardConfigValueValidationResult {\n87\t  const entry = PEEK_REWARD_CONFIG_KEY_REGISTRY[key];\n88\t  if (!entry) {\n89\t    return { ok: false, reason: \"unknown_key\" };\n90\t  }\n91\t  switch (entry.expectedType) {\n92\t    case \"integer\": {\n93\t      if (!INTEGER_PATTERN.test(value)) {\n94\t        return { ok: false, reason: \"expected_integer\" };\n95\t      }\n96\t      return { ok: true };\n97\t    }\n98\t    case \"lamports\": {\n99\t      if (!LAMPORTS_PATTERN.test(value)) {\n100\t        return { ok: false, reason: \"expected_lamports\" };\n101\t      }\n102\t      return { ok: true };\n103\t    }\n104\t    case \"float\": {\n105\t      const parsed = Number(value);\n106\t      if (!Number.isFinite(parsed)) {\n107\t        return { ok: false, reason: \"expected_float\" };\n108\t      }\n109\t      // Reject pure-integer text so operators do not silently fill a float\n110\t      // slot with a non-decimal value (e.g. \"2\" where \"2.0\" was intended).\n111\t      if (INTEGER_PATTERN.test(value)) {\n112\t        return { ok: false, reason: \"expected_float_with_decimal\" };\n113\t      }\n114\t      return { ok: true };\n115\t    }\n116\t    case \"ratio\": {\n117\t      const parsed = Number(value);\n118\t      if (!Number.isFinite(parsed)) {\n119\t        return { ok: false, reason: \"expected_ratio\" };\n120\t      }\n121\t      if (parsed < 0 || parsed > 1) {\n122\t        return { ok: false, reason: \"ratio_out_of_range\" };\n123\t      }\n124\t      return { ok: true };\n125\t    }\n126\t    case \"unknown\":\n127\t    default: {\n128\t      return { ok: false, reason: \"unknown_expected_type\" };\n129\t    }\n130\t  }\n131\t}\n132\t\n133\texport const rewardConfigUpdateInputSchema = z\n134\t  .object({\n135\t    key: z\n136\t      .string()\n137\t      .trim()\n138\t      .min(1)\n139\t      .refine(isEditableKey, {\n140\t        message: \"key is not in the reward_config edit allowlist\",\n141\t      }),\n142\t    value: z.string().trim().min(1),\n143\t    confirm: z.literal(true, {\n144\t      message: \"confirm must be true to apply a reward_config change\",\n145\t    }),\n146\t  })\n147\t  .strict()\n148\t  .superRefine((data, ctx) => {\n149\t    const result = validateRewardConfigValueForKey(data.key, data.value);\n150\t    if (!result.ok) {\n151\t      ctx.addIssue({\n152\t        code: z.ZodIssueCode.custom,\n153\t        path: [\"value\"],\n154\t        message: result.reason,\n155\t      });\n156\t    }\n157\t  });\n158\t\n159\texport type RewardConfigUpdateInput = z.infer<\n160\t  typeof rewardConfigUpdateInputSchema\n161\t>;\n162\t\n163\ttype ExistingRewardConfigRow = {\n164\t  key: string;\n165\t  value: string;\n166\t};\n167\t\n168\tasync function fetchExistingRow(\n169\t  sql: Sql,\n170\t  key: string,\n171\t): Promise<ExistingRewardConfigRow | null> {\n172\t  const rows = await sql<Array<ExistingRewardConfigRow>>`\n173\t    select\n174\t      key as \"key\",\n175\t      value as \"value\"\n176\t    from reward_config\n177\t    where key = ${key}\n178\t    for update\n179\t  `;\n180\t  return rows[0] ?? null;\n181\t}\n182\t\n183\tasync function executeRewardConfigUpdate(\n184\t  ctx: PeekMutationExecuteContext<RewardConfigUpdateInput>,\n185\t): Promise<PeekMutationExecuteResult> {\n186\t  const { sql, input } = ctx;\n187\t  const { key, value } = input;\n188\t\n189\t  const existing = await fetchExistingRow(sql, key);\n190\t  if (!existing) {\n191\t    throw new Error(`unknown_key: ${key}`);\n192\t  }\n193\t\n194\t  if (existing.value === value) {\n195\t    throw new Error(\"noop_value\");\n196\t  }\n197\t\n198\t  await sql`\n199\t    update reward_config\n200\t    set value = ${value}, updated_at = now()\n201\t    where key = ${key}\n202\t  `;\n203\t\n204\t  const changes: ReadonlyArray<PeekAuditChange> = [\n205\t    { field: \"value\", before: existing.value, after: value },\n206\t  ];\n207\t  return { resourceId: existing.key, changes };\n208\t}\n209\t\n210\texport const rewardConfigUpdateMutation: PeekMutationDefinition<RewardConfigUpdateInput> =\n211\t  {\n212\t    actionId: \"reward_config.update\",\n213\t    resourceType: \"reward_config\",\n214\t    schema: rewardConfigUpdateInputSchema,\n215\t    execute:\n216\t      executeRewardConfigUpdate as PeekMutationDefinition[\"execute\"],\n217\t  };\n218\t"}]},"parent_tool_use_id":null,"session_id":"d5d6cbcc-e1cc-4b53-bc96-dc64b8c2e1bc","uuid":"aa186918-f4f4-4774-8a64-901b094f2134","timestamp":"2026-04-26T19:18:43.929Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/mutations/reward-config.ts","content":"// Approved FR-14 mutation: edit a single `reward_config` row.\n//\n// Scope:\n//   - Identified by the TEXT primary key `reward_config.key`.\n//   - Only the `value` column moves; the diff records the before/after pair.\n//   - `updated_at` is bumped server-side and stays out of the audit diff\n//     (matches the kol-rate `updated_at` precedent).\n//\n// Key allowlist (FR-14: \"selected `reward_config` keys\"):\n//   The mutation accepts keys present in `PEEK_REWARD_CONFIG_KEY_REGISTRY`\n//   (and only those whose `expectedType` is not `\"unknown\"`). Unknown keys\n//   are rejected at schema time so a typo or a key that has been seeded but\n//   not registered cannot be edited from the admin UI.\n//\n// Value validation:\n//   The submitted `value` is a string (matches the TEXT column shape) and\n//   is validated against the registry-declared `expectedType`:\n//     - integer  -> ^-?[0-9]+$\n//     - float    -> finite Number; bigint-only forms are rejected so\n//       operators do not stash an integer into a float slot by accident\n//       (use the integer slot instead).\n//     - ratio    -> finite Number in [0, 1]\n//     - lamports -> ^[0-9]+$ (non-negative u64-style decimal text)\n//   Whitespace is trimmed before validation.\n//\n// Explicit confirmation flag:\n//   The input requires `confirm: true`. A missing/false `confirm` is\n//   rejected as `invalid_input` so the operator UI cannot silently apply\n//   a reward-economy change.\n//\n// No-op rejection:\n//   If the new `value` matches the row's existing `value`, the mutation is\n//   rejected (`execution_failed: noop_value`) so the audit row reflects a\n//   real movement.\n//\n// Failure semantics (surfaced through the runner's execute path):\n//   - Unknown key                -> `execution_failed: unknown_key:`.\n//     Note: the schema layer rejects un-allowlisted keys ahead of execute,\n//     so this surfaces only when a key listed in the registry is missing\n//     from the database.\n//   - No-op (value unchanged)    -> `execution_failed: noop_value`.\n//   - Schema validation failures (missing key/value, disallowed key,\n//     malformed value, missing confirmation) -> the runner's\n//     `invalid_input` path before any DB work.\n//\n// Authorization:\n//   `reward_config.update` is admin-only per FR-2 `PEEK_ACTION_RULES`.\n//   The runner enforces this before `execute` is called.\n\nimport type { Sql } from \"postgres\";\nimport { z } from \"zod\";\nimport type { PeekAuditChange } from \"../../lib/types/peek\";\nimport {\n  PEEK_REWARD_CONFIG_KEY_REGISTRY,\n} from \"../db/queries/get-rewards\";\nimport type {\n  PeekMutationDefinition,\n  PeekMutationExecuteContext,\n  PeekMutationExecuteResult,\n} from \"./registry\";\n\n// Editable keys are the registered keys whose expected type is known.\n// `Object.keys` on a frozen registry preserves insertion order; the result\n// is reused both for the schema enum and for runtime allowlist checks.\nexport const PEEK_REWARD_CONFIG_EDITABLE_KEYS: ReadonlyArray<string> =\n  Object.freeze(\n    Object.entries(PEEK_REWARD_CONFIG_KEY_REGISTRY)\n      .filter(([, entry]) => entry.expectedType !== \"unknown\")\n      .map(([key]) => key),\n  );\n\nfunction isEditableKey(key: string): boolean {\n  return PEEK_REWARD_CONFIG_EDITABLE_KEYS.includes(key);\n}\n\nconst INTEGER_PATTERN = /^-?[0-9]+$/u;\nconst LAMPORTS_PATTERN = /^[0-9]+$/u;\n\nexport type RewardConfigValueValidationResult =\n  | { ok: true }\n  | { ok: false; reason: string };\n\nexport function validateRewardConfigValueForKey(\n  key: string,\n  value: string,\n): RewardConfigValueValidationResult {\n  const entry = PEEK_REWARD_CONFIG_KEY_REGISTRY[key];\n  if (!entry) {\n    return { ok: false, reason: \"unknown_key\" };\n  }\n  switch (entry.expectedType) {\n    case \"integer\": {\n      if (!INTEGER_PATTERN.test(value)) {\n        return { ok: false, reason: \"expected_integer\" };\n      }\n      return { ok: true };\n    }\n    case \"lamports\": {\n      if (!LAMPORTS_PATTERN.test(value)) {\n        return { ok: false, reason: \"expected_lamports\" };\n      }\n      return { ok: true };\n    }\n    case \"float\": {\n      const parsed = Number(value);\n      if (!Number.isFinite(parsed)) {\n        return { ok: false, reason: \"expected_float\" };\n      }\n      // Reject pure-integer text so operators do not silently fill a float\n      // slot with a non-decimal value (e.g. \"2\" where \"2.0\" was intended).\n      if (INTEGER_PATTERN.test(value)) {\n        return { ok: false, reason: \"expected_float_with_decimal\" };\n      }\n      return { ok: true };\n    }\n    case \"ratio\": {\n      const parsed = Number(value);\n      if (!Number.isFinite(parsed)) {\n        return { ok: false, reason: \"expected_ratio\" };\n      }\n      if (parsed < 0 || parsed > 1) {\n        return { ok: false, reason: \"ratio_out_of_range\" };\n      }\n      return { ok: true };\n    }\n    case \"unknown\":\n    default: {\n      return { ok: false, reason: \"unknown_expected_type\" };\n    }\n  }\n}\n\nexport const rewardConfigUpdateInputSchema = z\n  .object({\n    key: z\n      .string()\n      .trim()\n      .min(1)\n      .refine(isEditableKey, {\n        message: \"key is not in the reward_config edit allowlist\",\n      }),\n    value: z.string().trim().min(1),\n    confirm: z.literal(true, {\n      message: \"confirm must be true to apply a reward_config change\",\n    }),\n  })\n  .strict()\n  .superRefine((data, ctx) => {\n    const result = validateRewardConfigValueForKey(data.key, data.value);\n    if (!result.ok) {\n      ctx.addIssue({\n        code: z.ZodIssueCode.custom,\n        path: [\"value\"],\n        message: result.reason,\n      });\n    }\n  });\n\nexport type RewardConfigUpdateInput = z.infer<\n  typeof rewardConfigUpdateInputSchema\n>;\n\ntype ExistingRewardConfigRow = {\n  key: string;\n  value: string;\n};\n\nasync function fetchExistingRow(\n  sql: Sql,\n  key: string,\n): Promise<ExistingRewardConfigRow | null> {\n  const rows = await sql<Array<ExistingRewardConfigRow>>`\n    select\n      key as \"key\",\n      value as \"value\"\n    from reward_config\n    where key = ${key}\n    for update\n  `;\n  return rows[0] ?? null;\n}\n\nasync function executeRewardConfigUpdate(\n  ctx: PeekMutationExecuteContext<RewardConfigUpdateInput>,\n): Promise<PeekMutationExecuteResult> {\n  const { sql, input } = ctx;\n  const { key, value } = input;\n\n  const existing = await fetchExistingRow(sql, key);\n  if (!existing) {\n    throw new Error(`unknown_key: ${key}`);\n  }\n\n  if (existing.value === value) {\n    throw new Error(\"noop_value\");\n  }\n\n  await sql`\n    update reward_config\n    set value = ${value}, updated_at = now()\n    where key = ${key}\n  `;\n\n  const changes: ReadonlyArray<PeekAuditChange> = [\n    { field: \"value\", before: existing.value, after: value },\n  ];\n  return { resourceId: existing.key, changes };\n}\n\nexport const rewardConfigUpdateMutation: PeekMutationDefinition<RewardConfigUpdateInput> =\n  {\n    actionId: \"reward_config.update\",\n    resourceType: \"reward_config\",\n    schema: rewardConfigUpdateInputSchema,\n    execute:\n      executeRewardConfigUpdate as PeekMutationDefinition[\"execute\"],\n  };\n","numLines":218,"startLine":1,"totalLines":218}}}
