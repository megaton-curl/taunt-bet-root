{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Aut5HWm8qCUKkqSvFSJ9HH","type":"tool_result","content":"1\t// Approved mutation registry (FR-14).\n2\t//\n3\t// The runner consumes a frozen registry keyed by stable action id. Each\n4\t// definition declares the FR-2 access-policy action id, the audit\n5\t// `resourceType` to record on `peek.change.applied`, a zod input schema, and\n6\t// an `execute` callback that runs inside a transaction (`sql.begin`) and\n7\t// returns the audit-friendly resource id + before/after change list.\n8\t//\n9\t// Adding a new approved mutation is a four-line change: import the\n10\t// definition, add it to the `entries` list, register the matching action id\n11\t// in `peek/src/server/access-policy.ts` (`PEEK_ACTION_RULES`) so the role\n12\t// check has a rule to find, and ship the matching frontend wiring iteration.\n13\t//\n14\t// The registry starts empty in this iteration: only the framework lands\n15\t// here. Individual mutations (KOL rate, fraud flag status, dogpile cancel,\n16\t// reward config edit) ship in subsequent FR-14 iterations.\n17\t\n18\timport type { Sql } from \"postgres\";\n19\timport type { ZodTypeAny } from \"zod\";\n20\timport type { PeekAuditChange } from \"../../lib/types/peek\";\n21\t\n22\texport type PeekMutationActionId = string;\n23\t\n24\texport type PeekMutationActorContext = {\n25\t  email: string;\n26\t  route: string | null;\n27\t  requestId?: string | null;\n28\t};\n29\t\n30\texport type PeekMutationExecuteContext<TInput> = {\n31\t  input: TInput;\n32\t  sql: Sql;\n33\t  actor: PeekMutationActorContext;\n34\t};\n35\t\n36\texport type PeekMutationExecuteResult = {\n37\t  // Audit identifier for the row the mutation touched. `null` when the\n38\t  // mutation creates a new row whose id is not separately surfaced.\n39\t  resourceId: string | null;\n40\t  // Before/after diff persisted to the `peek.change.applied` audit payload.\n41\t  // `null` when the mutation does not produce a field-level diff (e.g.\n42\t  // a pure create).\n43\t  changes: ReadonlyArray<PeekAuditChange> | null;\n44\t};\n45\t\n46\texport type PeekMutationDefinition<TInput = unknown> = {\n47\t  actionId: PeekMutationActionId;\n48\t  resourceType: string;\n49\t  schema: ZodTypeAny;\n50\t  execute: (\n51\t    ctx: PeekMutationExecuteContext<TInput>,\n52\t  ) => Promise<PeekMutationExecuteResult>;\n53\t};\n54\t\n55\texport type PeekMutationRegistry = Readonly<\n56\t  Record<PeekMutationActionId, PeekMutationDefinition>\n57\t>;\n58\t\n59\tconst entries: ReadonlyArray<PeekMutationDefinition> = [];\n60\t\n61\texport const PEEK_MUTATIONS: PeekMutationRegistry = Object.freeze(\n62\t  entries.reduce<Record<string, PeekMutationDefinition>>((acc, def) => {\n63\t    acc[def.actionId] = def;\n64\t    return acc;\n65\t  }, {}),\n66\t);\n67\t\n68\texport function getPeekMutation(\n69\t  actionId: PeekMutationActionId,\n70\t  registry: PeekMutationRegistry = PEEK_MUTATIONS,\n71\t): PeekMutationDefinition | null {\n72\t  return registry[actionId] ?? null;\n73\t}\n74\t"}]},"parent_tool_use_id":null,"session_id":"92e99259-5ba5-4fb3-9064-7f0408166402","uuid":"7ecaa5a0-7177-4832-9f2a-6a3e6863b29d","timestamp":"2026-04-26T15:13:19.020Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/mutations/registry.ts","content":"// Approved mutation registry (FR-14).\n//\n// The runner consumes a frozen registry keyed by stable action id. Each\n// definition declares the FR-2 access-policy action id, the audit\n// `resourceType` to record on `peek.change.applied`, a zod input schema, and\n// an `execute` callback that runs inside a transaction (`sql.begin`) and\n// returns the audit-friendly resource id + before/after change list.\n//\n// Adding a new approved mutation is a four-line change: import the\n// definition, add it to the `entries` list, register the matching action id\n// in `peek/src/server/access-policy.ts` (`PEEK_ACTION_RULES`) so the role\n// check has a rule to find, and ship the matching frontend wiring iteration.\n//\n// The registry starts empty in this iteration: only the framework lands\n// here. Individual mutations (KOL rate, fraud flag status, dogpile cancel,\n// reward config edit) ship in subsequent FR-14 iterations.\n\nimport type { Sql } from \"postgres\";\nimport type { ZodTypeAny } from \"zod\";\nimport type { PeekAuditChange } from \"../../lib/types/peek\";\n\nexport type PeekMutationActionId = string;\n\nexport type PeekMutationActorContext = {\n  email: string;\n  route: string | null;\n  requestId?: string | null;\n};\n\nexport type PeekMutationExecuteContext<TInput> = {\n  input: TInput;\n  sql: Sql;\n  actor: PeekMutationActorContext;\n};\n\nexport type PeekMutationExecuteResult = {\n  // Audit identifier for the row the mutation touched. `null` when the\n  // mutation creates a new row whose id is not separately surfaced.\n  resourceId: string | null;\n  // Before/after diff persisted to the `peek.change.applied` audit payload.\n  // `null` when the mutation does not produce a field-level diff (e.g.\n  // a pure create).\n  changes: ReadonlyArray<PeekAuditChange> | null;\n};\n\nexport type PeekMutationDefinition<TInput = unknown> = {\n  actionId: PeekMutationActionId;\n  resourceType: string;\n  schema: ZodTypeAny;\n  execute: (\n    ctx: PeekMutationExecuteContext<TInput>,\n  ) => Promise<PeekMutationExecuteResult>;\n};\n\nexport type PeekMutationRegistry = Readonly<\n  Record<PeekMutationActionId, PeekMutationDefinition>\n>;\n\nconst entries: ReadonlyArray<PeekMutationDefinition> = [];\n\nexport const PEEK_MUTATIONS: PeekMutationRegistry = Object.freeze(\n  entries.reduce<Record<string, PeekMutationDefinition>>((acc, def) => {\n    acc[def.actionId] = def;\n    return acc;\n  }, {}),\n);\n\nexport function getPeekMutation(\n  actionId: PeekMutationActionId,\n  registry: PeekMutationRegistry = PEEK_MUTATIONS,\n): PeekMutationDefinition | null {\n  return registry[actionId] ?? null;\n}\n","numLines":74,"startLine":1,"totalLines":74}}}
