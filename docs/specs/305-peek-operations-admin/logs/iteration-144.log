d: \"rate_bps\", before: 1000, after: 1500 },\n170\t            { field: \"set_by\", before: \"alice@example.com\", after: \"alice@example.com\" },\n171\t          ],\n172\t        }),\n173\t      },\n174\t      { sql: mock.sql },\n175\t    );\n176\t\n177\t    expect(result).toEqual({ ok: true });\n178\t    expect(mock.calls[0]?.values[0]).toBe(\"peek.change.applied\");\n179\t\n180\t    const stored = persistedPayload(mock);\n181\t    expect(stored.changes).toEqual([\n182\t      { field: \"rate_bps\", before: 1000, after: 1500 },\n183\t      { field: \"set_by\", before: \"alice@example.com\", after: \"alice@example.com\" },\n184\t    ]);\n185\t  });\n186\t\n187\t  it(\"persists a mutation-rejected event with the rejection reason and no submitted secrets\", async () => {\n188\t    const mock = createSqlMock();\n189\t\n190\t    const result = await writePeekAuditEvent(\n191\t      {\n192\t        eventType: \"peek.change.rejected\",\n193\t        payload: basePayload({\n194\t          route: \"/economy/rewards\",\n195\t          actionId: \"reward_config.update\",\n196\t          resourceType: \"reward_config\",\n197\t          resourceId: \"max_daily_payout_lamports\",\n198\t          rejectionReason: \"value_out_of_range\",\n199\t          changes: [\n200\t            { field: \"value\", before: \"100000\", after: \"999999999999\" },\n201\t          ],\n202\t        }),\n203\t      },\n204\t      { sql: mock.sql },\n205\t    );\n206\t\n207\t    expect(result).toEqual({ ok: true });\n208\t    expect(mock.calls[0]?.values[0]).toBe(\"peek.change.rejected\");\n209\t\n210\t    const stored = persistedPayload(mock);\n211\t    expect(stored.rejectionReason).toBe(\"value_out_of_range\");\n212\t    expect(stored.changes?.[0]?.after).toBe(\"999999999999\");\n213\t  });\n214\t\n215\t  it(\"redacts JWT tokens, DB URLs, private keys, Bearer headers, and CF access headers before persisting\", async () => {\n216\t    const mock = createSqlMock();\n217\t\n218\t    const jwt =\n219\t      \"eyJhbGciOiJSUzI1NiJ9.eyJzdWIiOiJhbGljZSJ9.signaturesignaturesignature\";\n220\t    const dbUrl = \"postgresql://user:pw@db.internal:5432/peek?sslmode=require\";\n221\t    const privateKey = \"-----BEGIN RSA PRIVATE KEY-----\\nABCDEF\\n-----END RSA PRIVATE KEY-----\";\n222\t    const bearer = \"Bearer abc123def456ghi789\";\n223\t    const cfHeader = \"cf-access-jwt-assertion: somevalue\";\n224\t\n225\t    const result = await writePeekAuditEvent(\n226\t      {\n227\t        eventType: \"peek.search\",\n228\t        payload: basePayload({\n229\t          route: dbUrl,\n230\t          actionId: bearer,\n231\t          resourceType: \"search\",\n232\t          resourceId: jwt,\n233\t          filterSummary: cfHeader,\n234\t          requestId: privateKey,\n235\t          changes: [\n236\t            { field: \"token\", before: jwt, after: \"harmless\" },\n237\t            { field: \"conn\", before: \"harmless\", after: dbUrl },\n238\t          ],\n239\t        }),\n240\t      },\n241\t      { sql: mock.sql },\n242\t    );\n243\t\n244\t    expect(result).toEqual({ ok: true });\n245\t    const stored = persistedPayload(mock);\n246\t\n247\t    expect(stored.route).toBe(PEEK_AUDIT_REDACTED);\n248\t    expect(stored.actionId).toBe(PEEK_AUDIT_REDACTED);\n249\t    expect(stored.resourceId).toBe(PEEK_AUDIT_REDACTED);\n250\t    expect(stored.filterSummary).toBe(PEEK_AUDIT_REDACTED);\n251\t    expect(stored.requestId).toBe(PEEK_AUDIT_REDACTED);\n252\t    expect(stored.changes).toEqual([\n253\t      { field: \"token\", before: PEEK_AUDIT_REDACTED, after: \"harmless\" },\n254\t      { field: \"conn\", before: \"harmless\", after: PEEK_AUDIT_REDACTED },\n255\t    ]);\n256\t\n257\t    const serialized = JSON.stringify(stored);\n258\t    expect(serialized).not.toContain(jwt);\n259\t    expect(serialized).not.toContain(dbUrl);\n260\t    expect(serialized).not.toContain(\"PRIVATE KEY\");\n261\t    expect(serialized).not.toContain(\"Bearer \");\n262\t    expect(serialized).not.toContain(\"cf-access-jwt-assertion\");\n263\t  });\n264\t\n265\t  it(\"rejects payloads with an empty actor email without inserting a row\", async () => {\n266\t    const mock = createSqlMock();\n267\t\n268\t    const result = await writePeekAuditEvent(\n269\t      {\n270\t        eventType: \"peek.search\",\n271\t        payload: basePayload({ actorEmail: \"\" }),\n272\t      },\n273\t      { sql: mock.sql },\n274\t    );\n275\t\n276\t    expect(result).toEqual({ ok: false, reason: \"invalid_payload\" });\n277\t    expect(mock.calls).toHaveLength(0);\n278\t    expect(mock.jsonArgs).toHaveLength(0);\n279\t  });\n280\t\n281\t  it(\"returns insert_failed and logs the error when the DB rejects the insert\", async () => {\n282\t    const mock = createSqlMock({\n283\t      error: new Error(\"connection refused: postgres://hidden:secret@host\"),\n284\t    });\n285\t    const logger = vi.fn();\n286\t\n287\t    const result = await writePeekAuditEvent(\n288\t      {\n289\t        eventType: \"peek.export\",\n290\t        payload: basePayload({ actionId: \"users.export\" }),\n291\t      },\n292\t      { sql: mock.sql, logger },\n293\t    );\n294\t\n295\t    expect(result).toEqual({ ok: false, reason: \"insert_failed\" });\n296\t    expect(logger).toHaveBeenCalledTimes(1);\n297\t    const [message, context] = logger.mock.calls[0] ?? [];\n298\t    expect(message).toBe(\"[peek-audit] insert failed\");\n299\t    expect(context).toMatchObject({ eventType: \"peek.export\" });\n300\t  });\n301\t\n302\t  it(\"does not propagate the underlying DB error to the caller\", async () => {\n303\t    const mock = createSqlMock({\n304\t      error: new Error(\"internal: schema=peek password=hunter2\"),\n305\t    });\n306\t    // Suppress the default console.error so the failure path stays quiet during the test.\n307\t    const logger = vi.fn();\n308\t\n309\t    const result = await writePeekAuditEvent(\n310\t      {\n311\t        eventType: \"peek.access.denied\",\n312\t        payload: baseP