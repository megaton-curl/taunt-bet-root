{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TAx1tV3zgYojxXDEe4LB4u","type":"tool_result","content":"The file /workspaces/rng-utopia/peek/src/server/mutations/__tests__/runner.test.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"92e99259-5ba5-4fb3-9064-7f0408166402","uuid":"84a243ac-4979-4eda-98f9-bad4bc977bcf","timestamp":"2026-04-26T15:17:00.252Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/peek/src/server/mutations/__tests__/runner.test.ts","oldString":"      const writer: PeekMutationAuditWriter = vi.fn(async (input, options) => {\n        const call: AuditCall = {\n          eventType: input.eventType,\n          payload: input.payload,\n          sql: options?.sql,\n        };\n        calls.push(call);\n        if (calls.length === 1) {\n          return { ok: false, reason: \"insert_failed\" };\n        }\n        return { ok: true };\n      });","newString":"      const writer: PeekMutationAuditWriter = vi.fn(async (input, options) => {\n        const call: AuditCall = {\n          eventType: input.eventType,\n          payload: input.payload,\n          sql: options?.sql,\n        };\n        calls.push(call);\n        const result: PeekAuditWriteResult =\n          calls.length === 1\n            ? { ok: false, reason: \"insert_failed\" }\n            : { ok: true };\n        return result;\n      });","originalFile":"import { describe, expect, it, vi } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport { z } from \"zod\";\nimport type { PeekActionRule } from \"../../access-policy\";\nimport type { PeekAuditWriteResult } from \"../../audit/writer\";\nimport {\n  PEEK_AUDIT_REDACTED,\n  type PeekAuditChange,\n  type PeekAuditPayload,\n} from \"../../../lib/types/peek\";\nimport {\n  runPeekMutation,\n  type PeekMutationAuditWriter,\n  type PeekMutationRunResult,\n} from \"../runner\";\nimport {\n  type PeekMutationActorContext,\n  type PeekMutationDefinition,\n  type PeekMutationRegistry,\n} from \"../registry\";\n\n// ---------------------------------------------------------------------------\n// Mocks\n// ---------------------------------------------------------------------------\n\ntype AuditCall = {\n  eventType: string;\n  payload: PeekAuditPayload;\n  sql: Sql | undefined;\n};\n\nfunction createAuditWriter(\n  result: PeekAuditWriteResult | ((call: AuditCall) => PeekAuditWriteResult) = {\n    ok: true,\n  },\n): { writer: PeekMutationAuditWriter; calls: AuditCall[] } {\n  const calls: AuditCall[] = [];\n  const writer: PeekMutationAuditWriter = vi.fn(async (input, options) => {\n    const call: AuditCall = {\n      eventType: input.eventType,\n      payload: input.payload,\n      sql: options?.sql,\n    };\n    calls.push(call);\n    return typeof result === \"function\" ? result(call) : result;\n  });\n  return { writer, calls };\n}\n\ntype SqlMock = {\n  sql: Sql;\n  txSql: Sql;\n  beginCalls: number;\n  rolledBack: boolean;\n};\n\nfunction createSqlMock(): SqlMock {\n  // The transactional Sql is a sentinel object so tests can verify that the\n  // applied-audit insert was issued with the same `Sql` `sql.begin` handed to\n  // the execute callback (i.e. the audit row commits with the mutation row).\n  const txSql = { __sql: \"tx\" } as unknown as Sql;\n  let beginCalls = 0;\n  let rolledBack = false;\n  const sql = {\n    async begin<T>(callback: (tx: Sql) => Promise<T>): Promise<T> {\n      beginCalls += 1;\n      try {\n        return await callback(txSql);\n      } catch (err) {\n        rolledBack = true;\n        throw err;\n      }\n    },\n  } as unknown as Sql;\n  return {\n    sql,\n    txSql,\n    get beginCalls() {\n      return beginCalls;\n    },\n    get rolledBack() {\n      return rolledBack;\n    },\n  } as SqlMock;\n}\n\nconst ACTOR: PeekMutationActorContext = Object.freeze({\n  email: \"alice@example.com\",\n  route: \"/growth/kol\",\n  requestId: \"req-1\",\n});\n\nfunction makeMutation(\n  overrides: Partial<PeekMutationDefinition> & {\n    onExecute?: PeekMutationDefinition[\"execute\"];\n  } = {},\n): PeekMutationDefinition {\n  const schema =\n    overrides.schema ??\n    z.object({\n      rateBps: z.number().int().min(0).max(10000),\n    });\n  const actionId = overrides.actionId ?? \"kol_rate.update\";\n  const resourceType = overrides.resourceType ?? \"referral_kol_rates\";\n  const execute: PeekMutationDefinition[\"execute\"] =\n    overrides.onExecute ??\n    (async () => ({\n      resourceId: \"kol-7\",\n      changes: [\n        { field: \"rate_bps\", before: 1000, after: 1500 },\n      ] as ReadonlyArray<PeekAuditChange>,\n    }));\n  return { actionId, resourceType, schema, execute };\n}\n\nfunction makeRegistry(\n  ...defs: ReadonlyArray<PeekMutationDefinition>\n): PeekMutationRegistry {\n  const map: Record<string, PeekMutationDefinition> = {};\n  for (const def of defs) map[def.actionId] = def;\n  return Object.freeze(map);\n}\n\n// ---------------------------------------------------------------------------\n// Tests\n// ---------------------------------------------------------------------------\n\ndescribe(\"runPeekMutation\", () => {\n  describe(\"authorized success\", () => {\n    it(\"runs execute inside a transaction and emits peek.change.applied\", async () => {\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const executeFn = vi.fn<PeekMutationDefinition[\"execute\"]>(async () => ({\n        resourceId: \"kol-7\",\n        changes: [\n          { field: \"rate_bps\", before: 1000, after: 1500 },\n        ] as ReadonlyArray<PeekAuditChange>,\n      }));\n      const definition = makeMutation({ onExecute: executeFn });\n      const registry = makeRegistry(definition);\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n      ];\n\n      const result: PeekMutationRunResult = await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: 1500 },\n        actorRole: \"business\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: audit.writer,\n      });\n\n      expect(result).toEqual({\n        ok: true,\n        actionId: \"kol_rate.update\",\n        resourceId: \"kol-7\",\n        changes: [{ field: \"rate_bps\", before: 1000, after: 1500 }],\n      });\n      expect(sqlMock.beginCalls).toBe(1);\n      expect(sqlMock.rolledBack).toBe(false);\n      expect(executeFn).toHaveBeenCalledTimes(1);\n\n      // Execute received the parsed input + transactional sql.\n      const executeArg = executeFn.mock.calls[0]?.[0];\n      expect(executeArg?.input).toEqual({ rateBps: 1500 });\n      expect(executeArg?.sql).toBe(sqlMock.txSql);\n      expect(executeArg?.actor).toBe(ACTOR);\n\n      // Exactly one audit emit: peek.change.applied on the transactional sql.\n      expect(audit.calls).toHaveLength(1);\n      expect(audit.calls[0]?.eventType).toBe(\"peek.change.applied\");\n      expect(audit.calls[0]?.sql).toBe(sqlMock.txSql);\n    });\n\n    it(\"populates the applied payload with FR-14 fields and forwards the before/after diff\", async () => {\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const definition = makeMutation();\n      const registry = makeRegistry(definition);\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n      ];\n\n      await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: 1500 },\n        actorRole: \"admin\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: audit.writer,\n      });\n\n      const payload = audit.calls[0]?.payload;\n      expect(payload).toEqual({\n        actorEmail: \"alice@example.com\",\n        route: \"/growth/kol\",\n        actionId: \"kol_rate.update\",\n        resourceType: \"referral_kol_rates\",\n        resourceId: \"kol-7\",\n        filterSummary: null,\n        resultCount: null,\n        requestId: \"req-1\",\n        rejectionReason: null,\n        changes: [{ field: \"rate_bps\", before: 1000, after: 1500 }],\n      });\n    });\n\n    it(\"supports mutations whose execute returns null resourceId / null changes (pure create)\", async () => {\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const definition = makeMutation({\n        onExecute: async () => ({ resourceId: null, changes: null }),\n      });\n      const registry = makeRegistry(definition);\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n      ];\n\n      const result = await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: 0 },\n        actorRole: \"admin\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: audit.writer,\n      });\n\n      expect(result).toEqual({\n        ok: true,\n        actionId: \"kol_rate.update\",\n        resourceId: null,\n        changes: null,\n      });\n      expect(audit.calls[0]?.payload.resourceId).toBeNull();\n      expect(audit.calls[0]?.payload.changes).toBeNull();\n    });\n  });\n\n  describe(\"unauthorized denial\", () => {\n    it(\"rejects when no action rule matches the actor role and emits peek.change.rejected\", async () => {\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const executeFn = vi.fn();\n      const definition = makeMutation({ onExecute: executeFn });\n      const registry = makeRegistry(definition);\n      // Action exists but requires admin; actor has business.\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"admin\"] },\n      ];\n\n      const result = await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: 1500 },\n        actorRole: \"business\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: audit.writer,\n      });\n\n      expect(result).toMatchObject({ ok: false, reason: \"unauthorized\" });\n      expect(executeFn).not.toHaveBeenCalled();\n      expect(sqlMock.beginCalls).toBe(0);\n\n      expect(audit.calls).toHaveLength(1);\n      expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n      expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n      expect(audit.calls[0]?.payload.resourceType).toBe(\"referral_kol_rates\");\n      expect(audit.calls[0]?.payload.changes).toBeNull();\n      // Rejected audit row writes on the main connection, not a transactional sql.\n      expect(audit.calls[0]?.sql).toBe(sqlMock.sql);\n    });\n\n    it(\"rejects when actor has no resolved role at all\", async () => {\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const definition = makeMutation();\n      const registry = makeRegistry(definition);\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n      ];\n\n      const result = await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: 1500 },\n        actorRole: null,\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: audit.writer,\n      });\n\n      expect(result.ok).toBe(false);\n      if (!result.ok) expect(result.reason).toBe(\"unauthorized\");\n      expect(audit.calls).toHaveLength(1);\n      expect(audit.calls[0]?.payload.rejectionReason).toBe(\"unauthorized\");\n    });\n  });\n\n  describe(\"unknown action\", () => {\n    it(\"emits peek.change.rejected with rejectionReason=unknown_action and does not open a transaction\", async () => {\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const registry: PeekMutationRegistry = Object.freeze({});\n\n      const result = await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: 1500 },\n        actorRole: \"admin\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules: [],\n        auditWriter: audit.writer,\n      });\n\n      expect(result).toMatchObject({ ok: false, reason: \"unknown_action\" });\n      expect(sqlMock.beginCalls).toBe(0);\n\n      expect(audit.calls).toHaveLength(1);\n      const audited = audit.calls[0]!;\n      expect(audited.eventType).toBe(\"peek.change.rejected\");\n      expect(audited.payload.rejectionReason).toBe(\"unknown_action\");\n      // The runner did not have a definition, so resourceType is null (not leaked).\n      expect(audited.payload.resourceType).toBeNull();\n      expect(audited.payload.actionId).toBe(\"kol_rate.update\");\n      expect(audited.payload.changes).toBeNull();\n    });\n  });\n\n  describe(\"validation failure\", () => {\n    it(\"rejects invalid input, surfaces field errors, does not run execute, and emits peek.change.rejected\", async () => {\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const executeFn = vi.fn();\n      const definition = makeMutation({ onExecute: executeFn });\n      const registry = makeRegistry(definition);\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n      ];\n\n      const result = await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: -1 },\n        actorRole: \"admin\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: audit.writer,\n      });\n\n      expect(result.ok).toBe(false);\n      if (!result.ok) {\n        expect(result.reason).toBe(\"invalid_input\");\n        expect(result.message).toBe(\"Input failed validation.\");\n        expect(result.fieldErrors).toBeDefined();\n        expect(result.fieldErrors?.rateBps?.length).toBeGreaterThan(0);\n      }\n\n      expect(executeFn).not.toHaveBeenCalled();\n      expect(sqlMock.beginCalls).toBe(0);\n      expect(audit.calls).toHaveLength(1);\n      expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n      expect(audit.calls[0]?.payload.rejectionReason).toBe(\"invalid_input\");\n    });\n\n    it(\"does not echo raw input or field-level errors into the audit payload\", async () => {\n      // FR-14: rejected mutation attempts log actor email, action id, resource\n      // type/id, rejection reason, and no submitted secrets. Field errors stay\n      // in the response (so the UI can render them) but never reach the audit\n      // record (so a malicious payload can't smuggle secrets through validation\n      // errors).\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const definition = makeMutation({\n        // Schema demanding a nonempty token field; fail by sending the empty\n        // string with a JWT-shaped submission alongside it.\n        schema: z.object({\n          token: z.string().min(1),\n        }),\n      });\n      const registry = makeRegistry(definition);\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"admin\"] },\n      ];\n\n      const sensitive = {\n        token: \"\",\n        smuggled:\n          \"eyJhbGciOiJSUzI1NiJ9.eyJzdWIiOiJzZWNyZXQifQ.signaturesignaturesignature\",\n      };\n\n      await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: sensitive,\n        actorRole: \"admin\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: audit.writer,\n      });\n\n      const serialized = JSON.stringify(audit.calls[0]?.payload ?? {});\n      expect(serialized).not.toContain(sensitive.smuggled);\n      expect(audit.calls[0]?.payload.changes).toBeNull();\n    });\n  });\n\n  describe(\"transaction rollback (execution_failed)\", () => {\n    it(\"rolls back when execute throws and emits peek.change.rejected on the main connection\", async () => {\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const definition = makeMutation({\n        onExecute: async () => {\n          throw new Error(\"DB constraint violated\");\n        },\n      });\n      const registry = makeRegistry(definition);\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n      ];\n\n      const result = await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: 1500 },\n        actorRole: \"admin\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: audit.writer,\n      });\n\n      expect(result.ok).toBe(false);\n      if (!result.ok) {\n        expect(result.reason).toBe(\"execution_failed\");\n        expect(result.message).toContain(\"DB constraint violated\");\n      }\n\n      // Transaction was opened and rolled back.\n      expect(sqlMock.beginCalls).toBe(1);\n      expect(sqlMock.rolledBack).toBe(true);\n\n      // No applied-audit row landed (since the tx rolled back).\n      expect(audit.calls).toHaveLength(1);\n      expect(audit.calls[0]?.eventType).toBe(\"peek.change.rejected\");\n      expect(audit.calls[0]?.payload.rejectionReason).toMatch(\n        /^execution_failed: /,\n      );\n      // Rejected audit row writes on the main connection, not the rolled-back tx.\n      expect(audit.calls[0]?.sql).toBe(sqlMock.sql);\n    });\n  });\n\n  describe(\"audit emit failure inside the transaction\", () => {\n    it(\"rolls back the mutation, surfaces audit_emit_failed, and writes peek.change.rejected on the main connection\", async () => {\n      const sqlMock = createSqlMock();\n      const calls: AuditCall[] = [];\n      // First (in-tx) write fails; second (post-rollback) rejection succeeds.\n      const writer: PeekMutationAuditWriter = vi.fn(async (input, options) => {\n        const call: AuditCall = {\n          eventType: input.eventType,\n          payload: input.payload,\n          sql: options?.sql,\n        };\n        calls.push(call);\n        if (calls.length === 1) {\n          return { ok: false, reason: \"insert_failed\" };\n        }\n        return { ok: true };\n      });\n\n      const executeFn = vi.fn(async () => ({\n        resourceId: \"kol-7\",\n        changes: [\n          { field: \"rate_bps\", before: 1000, after: 1500 },\n        ] as ReadonlyArray<PeekAuditChange>,\n      }));\n      const definition = makeMutation({ onExecute: executeFn });\n      const registry = makeRegistry(definition);\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"business\", \"admin\"] },\n      ];\n\n      const result = await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: 1500 },\n        actorRole: \"admin\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: writer,\n      });\n\n      expect(result.ok).toBe(false);\n      if (!result.ok) {\n        expect(result.reason).toBe(\"audit_emit_failed\");\n        expect(result.message).toContain(\"Audit emission failed\");\n        expect(result.message).toContain(\"insert_failed\");\n      }\n\n      expect(executeFn).toHaveBeenCalledTimes(1);\n      expect(sqlMock.beginCalls).toBe(1);\n      expect(sqlMock.rolledBack).toBe(true);\n\n      // Two audit writes: applied (in tx, failed) + rejected (on main connection).\n      expect(calls).toHaveLength(2);\n      expect(calls[0]?.eventType).toBe(\"peek.change.applied\");\n      expect(calls[0]?.sql).toBe(sqlMock.txSql);\n      expect(calls[1]?.eventType).toBe(\"peek.change.rejected\");\n      expect(calls[1]?.sql).toBe(sqlMock.sql);\n      expect(calls[1]?.payload.rejectionReason).toMatch(\n        /^peek_audit_emit_failed:insert_failed/,\n      );\n    });\n  });\n\n  describe(\"audit payload safety\", () => {\n    it(\"never echoes secrets pulled from execute changes verbatim — relies on the audit writer's redactor downstream\", async () => {\n      // The runner forwards changes verbatim; the audit writer redacts before\n      // persisting. To prove that contract is intact, this test routes the\n      // applied payload through the production writer's redaction by importing\n      // its redactor and asserting that the runner-emitted payload, when sent\n      // through it, has secrets stripped without losing the diff structure.\n      const { redactPayload } = await import(\"../../audit/redact\");\n      const audit = createAuditWriter();\n      const sqlMock = createSqlMock();\n      const definition = makeMutation({\n        onExecute: async () => ({\n          resourceId: \"kol-7\",\n          changes: [\n            { field: \"rate_bps\", before: 1000, after: 1500 },\n            {\n              field: \"set_by\",\n              before: \"alice@example.com\",\n              after:\n                \"eyJhbGciOiJSUzI1NiJ9.eyJzdWIiOiJsZWFrIn0.signaturesignaturesignature\",\n            },\n          ] as ReadonlyArray<PeekAuditChange>,\n        }),\n      });\n      const registry = makeRegistry(definition);\n      const actionRules: ReadonlyArray<PeekActionRule> = [\n        { actionId: \"kol_rate.update\", roles: [\"admin\"] },\n      ];\n\n      await runPeekMutation({\n        actionId: \"kol_rate.update\",\n        rawInput: { rateBps: 1500 },\n        actorRole: \"admin\",\n        actor: ACTOR,\n        sql: sqlMock.sql,\n        registry,\n        actionRules,\n        auditWriter: audit.writer,\n      });\n\n      const safe = redactPayload(audit.calls[0]!.payload);\n      const safeChanges = safe.changes!;\n      expect(safeChanges[0]).toEqual({\n        field: \"rate_bps\",\n        before: 1000,\n        after: 1500,\n      });\n      expect(safeChanges[1]?.after).toBe(PEEK_AUDIT_REDACTED);\n      expect(JSON.stringify(safe)).not.toContain(\"eyJhbGciOiJSUzI1NiJ9\");\n    });\n  });\n});\n","structuredPatch":[{"oldStart":475,"oldLines":10,"newStart":475,"newLines":11,"lines":["           sql: options?.sql,","         };","         calls.push(call);","-        if (calls.length === 1) {","-          return { ok: false, reason: \"insert_failed\" };","-        }","-        return { ok: true };","+        const result: PeekAuditWriteResult =","+          calls.length === 1","+            ? { ok: false, reason: \"insert_failed\" }","+            : { ok: true };","+        return result;","       });"," ","       const executeFn = vi.fn(async () => ({"]}],"userModified":false,"replaceAll":false}}
