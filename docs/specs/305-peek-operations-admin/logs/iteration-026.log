{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ve85jxpmFDxNi2qav8psae","type":"tool_result","content":"1\timport type { CSSProperties, ReactNode } from \"react\";\n2\timport Link from \"next/link\";\n3\timport type {\n4\t  PeekChallengeAssignmentSummary,\n5\t  PeekCrateDropRow,\n6\t  PeekFraudFlagRow,\n7\t  PeekGameEntryRow,\n8\t  PeekKolRate,\n9\t  PeekLinkedAccountRow,\n10\t  PeekPlayerPoints,\n11\t  PeekPointGrantRow,\n12\t  PeekReferralClaimRow,\n13\t  PeekReferralEarningsSummary,\n14\t  PeekStatusTone,\n15\t  PeekTelegramLinkTokenRow,\n16\t  PeekTransactionRow,\n17\t  PeekUserAttentionFlags,\n18\t  PeekUserDetail,\n19\t  PeekUserQueueEventRow,\n20\t} from \"../lib/types/peek\";\n21\timport { DetailPanel, type PeekDetailSection } from \"./detail-panel\";\n22\timport { EmptyState } from \"./empty-state\";\n23\timport { StatusChip } from \"./status-chip\";\n24\t\n25\texport type UserDetailViewProps = {\n26\t  detail: PeekUserDetail;\n27\t  activeSectionId?: string | null;\n28\t};\n29\t\n30\texport const USER_DETAIL_SECTION_IDS = [\n31\t  \"identity\",\n32\t  \"linked-accounts\",\n33\t  \"referrals\",\n34\t  \"games\",\n35\t  \"rewards\",\n36\t  \"challenges\",\n37\t  \"transactions\",\n38\t  \"attention\",\n39\t] as const;\n40\t\n41\texport type UserDetailSectionId = (typeof USER_DETAIL_SECTION_IDS)[number];\n42\t\n43\texport function UserDetailView({\n44\t  detail,\n45\t  activeSectionId = null,\n46\t}: UserDetailViewProps) {\n47\t  const sections: ReadonlyArray<PeekDetailSection> = [\n48\t    {\n49\t      id: \"identity\",\n50\t      label: \"Identity\",\n51\t      body: <IdentitySection detail={detail} />,\n52\t    },\n53\t    {\n54\t      id: \"linked-accounts\",\n55\t      label: \"Linked accounts\",\n56\t      body: <LinkedAccountsSection detail={detail} />,\n57\t    },\n58\t    {\n59\t      id: \"referrals\",\n60\t      label: \"Referrals\",\n61\t      body: <ReferralsSection detail={detail} />,\n62\t    },\n63\t    {\n64\t      id: \"games\",\n65\t      label: \"Games\",\n66\t      body: <GamesSection detail={detail} />,\n67\t    },\n68\t    {\n69\t      id: \"rewards\",\n70\t      label: \"Rewards\",\n71\t      body: <RewardsSection detail={detail} />,\n72\t    },\n73\t    {\n74\t      id: \"challenges\",\n75\t      label: \"Challenges\",\n76\t      body: <ChallengesSection summary={detail.challengeSummary} />,\n77\t    },\n78\t    {\n79\t      id: \"transactions\",\n80\t      label: \"Transactions\",\n81\t      body: <TransactionsSection detail={detail} />,\n82\t    },\n83\t    {\n84\t      id: \"attention\",\n85\t      label: \"Attention\",\n86\t      body: <AttentionSection detail={detail} />,\n87\t    },\n88\t  ];\n89\t\n90\t  return (\n91\t    <article style={pageStyle} aria-label=\"User detail\">\n92\t      <UserHeader detail={detail} />\n93\t      <AttentionStrip flags={detail.attention} />\n94\t      <DetailPanel\n95\t        sections={sections}\n96\t        activeId={activeSectionId}\n97\t        ariaLabel=\"User detail sections\"\n98\t      />\n99\t    </article>\n100\t  );\n101\t}\n102\t\n103\tfunction UserHeader({ detail }: { detail: PeekUserDetail }) {\n104\t  const heading = detail.user.username ?? detail.user.userId;\n105\t  return (\n106\t    <header style={headerStyle}>\n107\t      <div>\n108\t        <h1 style={headingStyle}>{heading}</h1>\n109\t        <p style={walletStyle}>{detail.user.wallet}</p>\n110\t      </div>\n111\t      <dl style={metaStyle}>\n112\t        <MetaPair label=\"user_id\" value={detail.user.userId} />\n113\t        <MetaPair label=\"joined\" value={detail.user.joinedAt} />\n114\t      </dl>\n115\t    </header>\n116\t  );\n117\t}\n118\t\n119\tfunction MetaPair({ label, value }: { label: string; value: string }) {\n120\t  return (\n121\t    <div style={metaPairStyle}>\n122\t      <dt style={metaLabelStyle}>{label}</dt>\n123\t      <dd style={metaValueStyle}>{value}</dd>\n124\t    </div>\n125\t  );\n126\t}\n127\t\n128\tfunction AttentionStrip({ flags }: { flags: PeekUserAttentionFlags }) {\n129\t  const items = buildAttentionItems(flags);\n130\t  if (items.length === 0) {\n131\t    return null;\n132\t  }\n133\t  return (\n134\t    <aside aria-label=\"Attention\" style={attentionStripStyle}>\n135\t      <span style={attentionLabelStyle}>Attention:</span>\n136\t      {items.map((item) => (\n137\t        <StatusChip\n138\t          key={item.id}\n139\t          label={item.label}\n140\t          tone={item.tone}\n141\t          title={item.description}\n142\t        />\n143\t      ))}\n144\t    </aside>\n145\t  );\n146\t}\n147\t\n148\tfunction IdentitySection({ detail }: { detail: PeekUserDetail }) {\n149\t  const rows: Array<[string, string | null]> = [\n150\t    [\"user_id\", detail.user.userId],\n151\t    [\"username\", detail.user.username],\n152\t    [\"wallet\", detail.user.wallet],\n153\t    [\"joined\", detail.user.joinedAt],\n154\t    [\"avatar_url\", detail.user.avatarUrl],\n155\t    [\"heat_multiplier\", detail.user.heatMultiplier],\n156\t    [\"profile_points_balance\", detail.user.profilePointsBalance],\n157\t  ];\n158\t  return (\n159\t    <DefinitionList\n160\t      rows={rows}\n161\t      empty=\"No identity recorded for this user.\"\n162\t    />\n163\t  );\n164\t}\n165\t\n166\tfunction LinkedAccountsSection({ detail }: { detail: PeekUserDetail }) {\n167\t  return (\n168\t    <div style={stackStyle}>\n169\t      <SubSection title=\"Telegram link state\">\n170\t        <DefinitionList\n171\t          rows={[\n172\t            [\"state\", detail.telegram.state],\n173\t            [\"telegram_user_id\", detail.telegram.telegramUserId],\n174\t            [\"telegram_username\", detail.telegram.telegramUsername],\n175\t          ]}\n176\t        />\n177\t      </SubSection>\n178\t\n179\t      <SubSection title=\"Linked accounts\">\n180\t        {detail.linkedAccounts.length === 0 ? (\n181\t          <EmptyState\n182\t            state={{\n183\t              title: \"No linked accounts.\",\n184\t              body: \"This user has not linked any external provider accounts.\",\n185\t            }}\n186\t          />\n187\t        ) : (\n188\t          <SimpleTable\n189\t            head={[\n190\t              \"provider\",\n191\t              \"provider_account_id\",\n192\t              \"status\",\n193\t              \"telegram_username\",\n194\t              \"linked_at\",\n195\t            ]}\n196\t            rows={detail.linkedAccounts.map((row: PeekLinkedAccountRow) => [\n197\t              row.provider,\n198\t              row.providerAccountId,\n199\t              <StatusChip\n200\t                key=\"status\"\n201\t                label={row.status}\n202\t                tone={\n203\t                  row.status === \"active\"\n204\t                    ? \"positive\"\n205\t                    : row.status === \"revoked\"\n206\t                    ? \"negative\"\n207\t                    : \"neutral\"\n208\t                }\n209\t              />,\n210\t              row.telegramUsername ?? \"—\",\n211\t              row.linkedAt,\n212\t            ])}\n213\t          />\n214\t        )}\n215\t      </SubSection>\n216\t\n217\t      <SubSection title=\"Recent Telegram link tokens\">\n218\t        {detail.recentTelegramLinkTokens.length === 0 ? (\n219\t          <EmptyState\n220\t            state={{\n221\t              title: \"No Telegram link tokens issued.\",\n222\t              body: null,\n223\t            }}\n224\t          />\n225\t        ) : (\n226\t          <SimpleTable\n227\t            head={[\n228\t              \"status\",\n229\t              \"telegram_user_id\",\n230\t              \"telegram_username\",\n231\t              \"expires_at\",\n232\t              \"redeemed_at\",\n233\t              \"created_at\",\n234\t            ]}\n235\t            rows={detail.recentTelegramLinkTokens.map(\n236\t              (row: PeekTelegramLinkTokenRow) => [\n237\t                <StatusChip\n238\t                  key=\"status\"\n239\t                  label={row.status}\n240\t                  tone={\n241\t                    row.status === \"redeemed\"\n242\t                      ? \"positive\"\n243\t                      : row.status === \"expired\"\n244\t                      ? \"warning\"\n245\t                      : \"neutral\"\n246\t                  }\n247\t                />,\n248\t                row.telegramUserId ?? \"—\",\n249\t                row.telegramUsername ?? \"—\",\n250\t                row.expiresAt,\n251\t                row.redeemedAt ?? \"—\",\n252\t                row.createdAt,\n253\t              ],\n254\t            )}\n255\t          />\n256\t        )}\n257\t      </SubSection>\n258\t    </div>\n259\t  );\n260\t}\n261\t\n262\tfunction ReferralsSection({ detail }: { detail: PeekUserDetail }) {\n263\t  const inboundLabel =\n264\t    detail.inboundReferral.referrerCode ??\n265\t    detail.inboundReferral.referrerUserId ??\n266\t    \"No referrer\";\n267\t  return (\n268\t    <div style={stackStyle}>\n269\t      <SubSection title=\"Inbound referral\">\n270\t        <DefinitionList\n271\t          rows={[\n272\t            [\"referrer\", inboundLabel],\n273\t            [\"referrer_user_id\", detail.inboundReferral.referrerUserId],\n274\t            [\"linked_at\", detail.inboundReferral.linkedAt],\n275\t          ]}\n276\t        />\n277\t      </SubSection>\n278\t\n279\t      <SubSection title=\"Referral code\">\n280\t        <DefinitionList\n281\t          rows={[\n282\t            [\"referral_code\", detail.user.referralCode],\n283\t            [\"referee_count\", String(detail.user.refereeCount)],\n284\t          ]}\n285\t        />\n286\t      </SubSection>\n287\t\n288\t      <SubSection title=\"KOL rate\">\n289\t        <KolRateBlock rate={detail.kolRate} />\n290\t      </SubSection>\n291\t\n292\t      <SubSection title=\"Earnings & rebates\">\n293\t        <EarningsBlock summary={detail.referralEarnings} />\n294\t      </SubSection>\n295\t\n296\t      <SubSection title=\"Recent referral claims\">\n297\t        {detail.recentReferralClaims.length === 0 ? (\n298\t          <EmptyState state={{ title: \"No referral claims yet.\", body: null }} />\n299\t        ) : (\n300\t          <SimpleTable\n301\t            head={[\n302\t              \"amount_lamports\",\n303\t              \"status\",\n304\t              \"retry_count\",\n305\t              \"tx_signature\",\n306\t              \"requested_at\",\n307\t              \"processed_at\",\n308\t              \"error\",\n309\t            ]}\n310\t            rows={detail.recentReferralClaims.map(\n311\t              (row: PeekReferralClaimRow) => [\n312\t                row.amountLamports,\n313\t                <StatusChip\n314\t                  key=\"status\"\n315\t                  label={row.status}\n316\t                  tone={\n317\t                    row.status === \"paid\"\n318\t                      ? \"positive\"\n319\t                      : row.status === \"failed\" || row.status === \"error\"\n320\t                      ? \"negative\"\n321\t                      : row.status === \"processing\"\n322\t                      ? \"info\"\n323\t                      : \"neutral\"\n324\t                  }\n325\t                />,\n326\t                String(row.retryCount),\n327\t                row.txSignature ?? \"—\",\n328\t                row.requestedAt,\n329\t                row.processedAt ?? \"—\",\n330\t                row.error ?? \"—\",\n331\t              ],\n332\t            )}\n333\t          />\n334\t        )}\n335\t      </SubSection>\n336\t\n337\t      <SubSection title=\"Outbound referees\">\n338\t        {detail.outboundReferees.length === 0 ? (\n339\t          <EmptyState state={{ title: \"No referees yet.\", body: null }} />\n340\t        ) : (\n341\t          <SimpleTable\n342\t            head={[\"referee_user_id\", \"username\", \"linked_at\"]}\n343\t            rows={detail.outboundReferees.map((row) => [\n344\t              <Link key=\"link\" href={`/users/${row.refereeUserId}`} style={linkStyle}>\n345\t                {row.refereeUserId}\n346\t              </Link>,\n347\t              row.refereeUsername ?? \"—\",\n348\t              row.createdAt,\n349\t            ])}\n350\t          />\n351\t        )}\n352\t      </SubSection>\n353\t    </div>\n354\t  );\n355\t}\n356\t\n357\tfunction GamesSection({ detail }: { detail: PeekUserDetail }) {\n358\t  if (detail.recentGameEntries.length === 0) {\n359\t    return (\n360\t      <EmptyState\n361\t        state={{\n362\t          title: \"No game entries yet.\",\n363\t          body: \"This user has not entered any FlipYou, Pot Shot, or Close Call rounds.\",\n364\t        }}\n365\t      />\n366\t    );\n367\t  }\n368\t  return (\n369\t    <SimpleTable\n370\t      head={[\n371\t        \"game\",\n372\t        \"match_id\",\n373\t        \"amount_lamports\",\n374\t        \"side\",\n375\t        \"is_winner\",\n376\t        \"payout_lamports\",\n377\t        \"created_at\",\n378\t        \"settled_at\",\n379\t      ]}\n380\t      rows={detail.recentGameEntries.map((row: PeekGameEntryRow) => [\n381\t        <StatusChip key=\"game\" label={row.game} tone=\"info\" />,\n382\t        <Link\n383\t          key=\"match\"\n384\t          href={`/games/${row.game}/rounds/${row.roundPda}`}\n385\t          style={linkStyle}\n386\t        >\n387\t          {row.matchId}\n388\t        </Link>,\n389\t        row.amountLamports,\n390\t        row.side ?? \"—\",\n391\t        renderWinner(row.isWinner),\n392\t        row.payoutLamports,\n393\t        row.createdAt,\n394\t        row.settledAt ?? \"—\",\n395\t      ])}\n396\t    />\n397\t  );\n398\t}\n399\t\n400\tfunction RewardsSection({ detail }: { detail: PeekUserDetail }) {\n401\t  return (\n402\t    <div style={stackStyle}>\n403\t      <SubSection title=\"Points balance\">\n404\t        <PointsBlock points={detail.points} />\n405\t      </SubSection>\n406\t\n407\t      <SubSection title=\"Recent point grants\">\n408\t        {detail.recentPointGrants.length === 0 ? (\n409\t          <EmptyState state={{ title: \"No point grants recorded.\", body: null }} />\n410\t        ) : (\n411\t          <SimpleTable\n412\t            head={[\"source_type\", \"source_id\", \"amount\", \"created_at\"]}\n413\t            rows={detail.recentPointGrants.map((row: PeekPointGrantRow) => [\n414\t              row.sourceType,\n415\t              row.sourceId,\n416\t              row.amount,\n417\t              row.createdAt,\n418\t            ])}\n419\t          />\n420\t        )}\n421\t      </SubSection>\n422\t\n423\t      <SubSection title=\"Recent crate drops\">\n424\t        {detail.recentCrateDrops.length === 0 ? (\n425\t          <EmptyState state={{ title: \"No crate drops recorded.\", body: null }} />\n426\t        ) : (\n427\t          <SimpleTable\n428\t            head={[\n429\t              \"trigger_type\",\n430\t              \"trigger_id\",\n431\t              \"crate_type\",\n432\t              \"contents_amount\",\n433\t              \"status\",\n434\t              \"created_at\",\n435\t              \"granted_at\",\n436\t            ]}\n437\t            rows={detail.recentCrateDrops.map((row: PeekCrateDropRow) => [\n438\t              row.triggerType,\n439\t              row.triggerId,\n440\t              row.crateType,\n441\t              row.contentsAmount,\n442\t              <StatusChip\n443\t                key=\"status\"\n444\t                label={row.status}\n445\t                tone={\n446\t                  row.status === \"granted\"\n447\t                    ? \"positive\"\n448\t                    : row.status === \"pending\"\n449\t                    ? \"warning\"\n450\t                    : row.status === \"failed\"\n451\t                    ? \"negative\"\n452\t                    : \"neutral\"\n453\t                }\n454\t              />,\n455\t              row.createdAt,\n456\t              row.grantedAt ?? \"—\",\n457\t            ])}\n458\t          />\n459\t        )}\n460\t      </SubSection>\n461\t    </div>\n462\t  );\n463\t}\n464\t\n465\tfunction ChallengesSection({\n466\t  summary,\n467\t}: {\n468\t  summary: PeekChallengeAssignmentSummary;\n469\t}) {\n470\t  if (summary.total === 0) {\n471\t    return (\n472\t      <EmptyState\n473\t        state={{\n474\t          title: \"No challenge assignments.\",\n475\t          body: \"This user has not been assigned any challenges yet.\",\n476\t        }}\n477\t      />\n478\t    );\n479\t  }\n480\t  return (\n481\t    <DefinitionList\n482\t      rows={[\n483\t        [\"active\", String(summary.active)],\n484\t        [\"completed\", String(summary.completed)],\n485\t        [\"expired\", String(summary.expired)],\n486\t        [\"total\", String(summary.total)],\n487\t      ]}\n488\t    />\n489\t  );\n490\t}\n491\t\n492\tfunction TransactionsSection({ detail }: { detail: PeekUserDetail }) {\n493\t  if (detail.recentTransactions.length === 0) {\n494\t    return (\n495\t      <EmptyState\n496\t        state={{\n497\t          title: \"No transactions recorded.\",\n498\t          body: \"This user has no on-chain transaction records yet.\",\n499\t        }}\n500\t      />\n501\t    );\n502\t  }\n503\t  return (\n504\t    <SimpleTable\n505\t      head={[\n506\t        \"game\",\n507\t        \"match_id\",\n508\t        \"tx_type\",\n509\t        \"amount_lamports\",\n510\t        \"tx_sig\",\n511\t        \"created_at\",\n512\t      ]}\n513\t      rows={detail.recentTransactions.map((row: PeekTransactionRow) => [\n514\t        <StatusChip key=\"game\" label={row.game} tone=\"info\" />,\n515\t        row.matchId,\n516\t        <StatusChip\n517\t          key=\"type\"\n518\t          label={row.txType}\n519\t          tone={\n520\t            row.txType === \"payout\"\n521\t              ? \"positive\"\n522\t              : row.txType === \"refund\"\n523\t              ? \"warning\"\n524\t              : \"neutral\"\n525\t          }\n526\t        />,\n527\t        row.amountLamports,\n528\t        row.txSig,\n529\t        row.createdAt,\n530\t      ])}\n531\t    />\n532\t  );\n533\t}\n534\t\n535\tfunction AttentionSection({ detail }: { detail: PeekUserDetail }) {\n536\t  const items = buildAttentionItems(detail.attention);\n537\t  return (\n538\t    <div style={stackStyle}>\n539\t      <SubSection title=\"Attention flags\">\n540\t        {items.length === 0 ? (\n541\t          <EmptyState\n542\t            state={{\n543\t              title: \"No attention flags.\",\n544\t              body: \"Nothing currently flagged for review on this user.\",\n545\t            }}\n546\t          />\n547\t        ) : (\n548\t          <ul style={attentionListStyle}>\n549\t            {items.map((item) => (\n550\t              <li key={item.id} style={attentionItemStyle}>\n551\t                <StatusChip label={item.label} tone={item.tone} />\n552\t                <span style={attentionDescStyle}>{item.description}</span>\n553\t              </li>\n554\t            ))}\n555\t          </ul>\n556\t        )}\n557\t      </SubSection>\n558\t\n559\t      <SubSection title=\"Open fraud flags\">\n560\t        {detail.fraudFlags.length === 0 ? (\n561\t          <EmptyState state={{ title: \"No fraud flags.\", body: null }} />\n562\t        ) : (\n563\t          <SimpleTable\n564\t            head={[\"flag_type\", \"status\", \"related_id\", \"created_at\", \"resolved_at\"]}\n565\t            rows={detail.fraudFlags.map((row: PeekFraudFlagRow) => [\n566\t              row.flagType,\n567\t              <StatusChip\n568\t                key=\"status\"\n569\t                label={row.status}\n570\t                tone={\n571\t                  row.status === \"open\"\n572\t                    ? \"negative\"\n573\t                    : row.status === \"reviewed\"\n574\t                    ? \"info\"\n575\t                    : \"neutral\"\n576\t                }\n577\t              />,\n578\t              row.relatedId ?? \"—\",\n579\t              row.createdAt,\n580\t              row.resolvedAt ?? \"—\",\n581\t            ])}\n582\t          />\n583\t        )}\n584\t      </SubSection>\n585\t\n586\t      <SubSection title=\"Recent queue events\">\n587\t        {detail.recentUserQueueEvents.length === 0 ? (\n588\t          <EmptyState state={{ title: \"No queue events for this user.\", body: null }} />\n589\t        ) : (\n590\t          <SimpleTable\n591\t            head={[\n592\t              \"event_type\",\n593\t              \"status\",\n594\t              \"attempts\",\n595\t              \"scheduled_at\",\n596\t              \"created_at\",\n597\t              \"error\",\n598\t            ]}\n599\t            rows={detail.recentUserQueueEvents.map(\n600\t              (row: PeekUserQueueEventRow) => [\n601\t                row.eventType,\n602\t                <StatusChip\n603\t                  key=\"status\"\n604\t                  label={row.status}\n605\t                  tone={\n606\t                    row.status === \"dead\"\n607\t                      ? \"negative\"\n608\t                      : row.status === \"failed\"\n609\t                      ? \"warning\"\n610\t                      : row.status === \"processed\"\n611\t                      ? \"positive\"\n612\t                      : \"neutral\"\n613\t                  }\n614\t                />,\n615\t                `${row.attempts} / ${row.maxAttempts}`,\n616\t                row.scheduledAt,\n617\t                row.createdAt,\n618\t                row.error ?? \"—\",\n619\t              ],\n620\t            )}\n621\t          />\n622\t        )}\n623\t      </SubSection>\n624\t    </div>\n625\t  );\n626\t}\n627\t\n628\t// --- Reusable building blocks ------------------------------------------------\n629\t\n630\tfunction SubSection({\n631\t  title,\n632\t  children,\n633\t}: {\n634\t  title: string;\n635\t  children: ReactNode;\n636\t}) {\n637\t  return (\n638\t    <section style={subSectionStyle}>\n639\t      <h3 style={subHeadingStyle}>{title}</h3>\n640\t      {children}\n641\t    </section>\n642\t  );\n643\t}\n644\t\n645\tfunction DefinitionList({\n646\t  rows,\n647\t  empty,\n648\t}: {\n649\t  rows: ReadonlyArray<readonly [string, string | null]>;\n650\t  empty?: string;\n651\t}) {\n652\t  const usable = rows.filter(([, value]) => value !== null && value !== \"\");\n653\t  if (usable.length === 0) {\n654\t    return (\n655\t      <EmptyState\n656\t        state={{\n657\t          title: empty ?? \"No data recorded for this section.\",\n658\t          body: null,\n659\t        }}\n660\t      />\n661\t    );\n662\t  }\n663\t  return (\n664\t    <dl style={dlStyle}>\n665\t      {rows.map(([label, value]) => (\n666\t        <div key={label} style={dlRowStyle}>\n667\t          <dt style={dlLabelStyle}>{label}</dt>\n668\t          <dd style={dlValueStyle}>{value ?? \"—\"}</dd>\n669\t        </div>\n670\t      ))}\n671\t    </dl>\n672\t  );\n673\t}\n674\t\n675\tfunction SimpleTable({\n676\t  head,\n677\t  rows,\n678\t}: {\n679\t  head: ReadonlyArray<string>;\n680\t  rows: ReadonlyArray<ReadonlyArray<ReactNode>>;\n681\t}) {\n682\t  return (\n683\t    <div style={tableWrapperStyle}>\n684\t      <table style={tableStyle}>\n685\t        <thead>\n686\t          <tr>\n687\t            {head.map((label) => (\n688\t              <th key={label} style={thStyle}>\n689\t                {label}\n690\t              </th>\n691\t            ))}\n692\t          </tr>\n693\t        </thead>\n694\t        <tbody>\n695\t          {rows.map((row, rowIndex) => (\n696\t            <tr key={rowIndex}>\n697\t              {row.map((cell, cellIndex) => (\n698\t                <td key={cellIndex} style={tdStyle}>\n699\t                  {cell}\n700\t                </td>\n701\t              ))}\n702\t            </tr>\n703\t          ))}\n704\t        </tbody>\n705\t      </table>\n706\t    </div>\n707\t  );\n708\t}\n709\t\n710\tfunction KolRateBlock({ rate }: { rate: PeekKolRate | null }) {\n711\t  if (!rate) {\n712\t    return (\n713\t      <EmptyState\n714\t        state={{ title: \"Not a KOL.\", body: \"No KOL rate configured for this user.\" }}\n715\t      />\n716\t    );\n717\t  }\n718\t  return (\n719\t    <DefinitionList\n720\t      rows={[\n721\t        [\"rate_bps\", String(rate.rateBps)],\n722\t        [\"set_by\", rate.setBy],\n723\t        [\"created_at\", rate.createdAt],\n724\t        [\"updated_at\", rate.updatedAt],\n725\t      ]}\n726\t    />\n727\t  );\n728\t}\n729\t\n730\tfunction EarningsBlock({\n731\t  summary,\n732\t}: {\n733\t  summary: PeekReferralEarningsSummary;\n734\t}) {\n735\t  if (summary.earningsCount === 0) {\n736\t    return (\n737\t      <EmptyState state={{ title: \"No referral earnings yet.\", body: null }} />\n738\t    );\n739\t  }\n740\t  return (\n741\t    <DefinitionList\n742\t      rows={[\n743\t        [\"earnings_count\", String(summary.earningsCount)],\n744\t        [\"total_referrer_earned_lamports\", summary.totalReferrerEarnedLamports],\n745\t        [\"total_referee_rebate_lamports\", summary.totalRefereeRebateLamports],\n746\t        [\"last_earned_at\", summary.lastEarnedAt],\n747\t      ]}\n748\t    />\n749\t  );\n750\t}\n751\t\n752\tfunction PointsBlock({ points }: { points: PeekPlayerPoints }) {\n753\t  return (\n754\t    <DefinitionList\n755\t      rows={[\n756\t        [\"balance\", points.balance],\n757\t        [\"lifetime_earned\", points.lifetimeEarned],\n758\t        [\"updated_at\", points.updatedAt],\n759\t      ]}\n760\t    />\n761\t  );\n762\t}\n763\t\n764\tfunction renderWinner(value: boolean | null): string {\n765\t  if (value === null) return \"—\";\n766\t  return value ? \"win\" : \"loss\";\n767\t}\n768\t\n769\ttype AttentionItem = {\n770\t  id: string;\n771\t  label: string;\n772\t  tone: PeekStatusTone;\n773\t  description: string;\n774\t};\n775\t\n776\tfunction buildAttentionItems(\n777\t  flags: PeekUserAttentionFlags,\n778\t): ReadonlyArray<AttentionItem> {\n779\t  const items: AttentionItem[] = [];\n780\t  if (flags.failedClaim) {\n781\t    items.push({\n782\t      id: \"failed_claim\",\n783\t      label: \"Failed claim\",\n784\t      tone: \"negative\",\n785\t      description: \"At least one recent referral claim is in failed/error status.\",\n786\t    });\n787\t  }\n788\t  if (flags.deadQueueEvent) {\n789\t    items.push({\n790\t      id: \"dead_queue_event\",\n791\t      label: \"Dead queue event\",\n792\t      tone: \"negative\",\n793\t      description: \"An async queue event for this user has hit max attempts.\",\n794\t    });\n795\t  }\n796\t  if (flags.activeFraudFlag) {\n797\t    items.push({\n798\t      id: \"active_fraud_flag\",\n799\t      label: \"Active fraud flag\",\n800\t      tone: \"warning\",\n801\t      description: \"An open fraud flag exists on this user and needs review.\",\n802\t    });\n803\t  }\n804\t  if (flags.pendingSolCratePayout) {\n805\t    items.push({\n806\t      id: \"pending_sol_crate_payout\",\n807\t      label: \"Pending SOL crate payout\",\n808\t      tone: \"warning\",\n809\t      description: \"A SOL crate drop is pending payout for this user.\",\n810\t    });\n811\t  }\n812\t  if (flags.suspiciousReferralLoop) {\n813\t    items.push({\n814\t      id: \"suspicious_referral_loop\",\n815\t      label: \"Suspicious referral self/loop\",\n816\t      tone: \"negative\",\n817\t      description:\n818\t        \"This user appears as both referrer and referee on a referral_links row.\",\n819\t    });\n820\t  }\n821\t  return items;\n822\t}\n823\t\n824\t// --- Styles ------------------------------------------------------------------\n825\t\n826\tconst pageStyle: CSSProperties = {\n827\t  display: \"grid\",\n828\t  gap: \"1.25rem\",\n829\t};\n830\t\n831\tconst headerStyle: CSSProperties = {\n832\t  display: \"flex\",\n833\t  flexWrap: \"wrap\",\n834\t  gap: \"1rem\",\n835\t  alignItems: \"flex-end\",\n836\t  justifyContent: \"space-between\",\n837\t  borderBottom: \"1px solid #1e293b\",\n838\t  paddingBottom: \"1rem\",\n839\t};\n840\t\n841\tconst headingStyle: CSSProperties = {\n842\t  margin: 0,\n843\t  fontSize: \"1.5rem\",\n844\t  color: \"#e2e8f0\",\n845\t};\n846\t\n847\tconst walletStyle: CSSProperties = {\n848\t  margin: \"0.25rem 0 0\",\n849\t  fontFamily: \"monospace\",\n850\t  color: \"#94a3b8\",\n851\t  fontSize: \"0.875rem\",\n852\t};\n853\t\n854\tconst metaStyle: CSSProperties = {\n855\t  margin: 0,\n856\t  display: \"flex\",\n857\t  flexWrap: \"wrap\",\n858\t  gap: \"1rem\",\n859\t};\n860\t\n861\tconst metaPairStyle: CSSProperties = {\n862\t  display: \"grid\",\n863\t  gap: \"0.125rem\",\n864\t};\n865\t\n866\tconst metaLabelStyle: CSSProperties = {\n867\t  margin: 0,\n868\t  fontSize: \"0.6875rem\",\n869\t  textTransform: \"uppercase\",\n870\t  letterSpacing: \"0.05em\",\n871\t  color: \"#94a3b8\",\n872\t};\n873\t\n874\tconst metaValueStyle: CSSProperties = {\n875\t  margin: 0,\n876\t  fontSize: \"0.8125rem\",\n877\t  fontFamily: \"monospace\",\n878\t  color: \"#e2e8f0\",\n879\t};\n880\t\n881\tconst attentionStripStyle: CSSProperties = {\n882\t  display: \"flex\",\n883\t  flexWrap: \"wrap\",\n884\t  alignItems: \"center\",\n885\t  gap: \"0.5rem\",\n886\t  padding: \"0.5rem 0.75rem\",\n887\t  borderRadius: \"0.5rem\",\n888\t  background: \"#1f1305\",\n889\t  border: \"1px solid #b45309\",\n890\t};\n891\t\n892\tconst attentionLabelStyle: CSSProperties = {\n893\t  fontSize: \"0.75rem\",\n894\t  fontWeight: 600,\n895\t  textTransform: \"uppercase\",\n896\t  letterSpacing: \"0.05em\",\n897\t  color: \"#fde68a\",\n898\t};\n899\t\n900\tconst attentionListStyle: CSSProperties = {\n901\t  listStyle: \"none\",\n902\t  margin: 0,\n903\t  padding: 0,\n904\t  display: \"grid\",\n905\t  gap: \"0.5rem\",\n906\t};\n907\t\n908\tconst attentionItemStyle: CSSProperties = {\n909\t  display: \"flex\",\n910\t  alignItems: \"center\",\n911\t  gap: \"0.5rem\",\n912\t};\n913\t\n914\tconst attentionDescStyle: CSSProperties = {\n915\t  fontSize: \"0.8125rem\",\n916\t  color: \"#cbd5f5\",\n917\t};\n918\t\n919\tconst stackStyle: CSSProperties = {\n920\t  display: \"grid\",\n921\t  gap: \"1rem\",\n922\t};\n923\t\n924\tconst subSectionStyle: CSSProperties = {\n925\t  display: \"grid\",\n926\t  gap: \"0.5rem\",\n927\t};\n928\t\n929\tconst subHeadingStyle: CSSProperties = {\n930\t  margin: 0,\n931\t  fontSize: \"0.875rem\",\n932\t  fontWeight: 600,\n933\t  color: \"#cbd5f5\",\n934\t  textTransform: \"uppercase\",\n935\t  letterSpacing: \"0.05em\",\n936\t};\n937\t\n938\tconst dlStyle: CSSProperties = {\n939\t  margin: 0,\n940\t  display: \"grid\",\n941\t  gridTemplateColumns: \"max-content 1fr\",\n942\t  gap: \"0.25rem 1rem\",\n943\t};\n944\t\n945\tconst dlRowStyle: CSSProperties = {\n946\t  display: \"contents\",\n947\t};\n948\t\n949\tconst dlLabelStyle: CSSProperties = {\n950\t  margin: 0,\n951\t  fontSize: \"0.6875rem\",\n952\t  textTransform: \"uppercase\",\n953\t  letterSpacing: \"0.05em\",\n954\t  color: \"#94a3b8\",\n955\t};\n956\t\n957\tconst dlValueStyle: CSSProperties = {\n958\t  margin: 0,\n959\t  fontSize: \"0.8125rem\",\n960\t  fontFamily: \"monospace\",\n961\t  color: \"#e2e8f0\",\n962\t  overflowWrap: \"anywhere\",\n963\t};\n964\t\n965\tconst tableWrapperStyle: CSSProperties = {\n966\t  overflowX: \"auto\",\n967\t  border: \"1px solid #1e293b\",\n968\t  borderRadius: \"0.5rem\",\n969\t};\n970\t\n971\tconst tableStyle: CSSProperties = {\n972\t  width: \"100%\",\n973\t  borderCollapse: \"collapse\",\n974\t  fontSize: \"0.8125rem\",\n975\t};\n976\t\n977\tconst thStyle: CSSProperties = {\n978\t  textAlign: \"left\",\n979\t  padding: \"0.5rem 0.75rem\",\n980\t  background: \"#0b1220\",\n981\t  color: \"#94a3b8\",\n982\t  fontWeight: 600,\n983\t  borderBottom: \"1px solid #1e293b\",\n984\t  whiteSpace: \"nowrap\",\n985\t};\n986\t\n987\tconst tdStyle: CSSProperties = {\n988\t  padding: \"0.5rem 0.75rem\",\n989\t  borderBottom: \"1px solid #1e293b\",\n990\t  color: \"#e2e8f0\",\n991\t  fontFamily: \"monospace\",\n992\t  whiteSpace: \"nowrap\",\n993\t};\n994\t\n995\tconst linkStyle: CSSProperties = {\n996\t  color: \"#bfdbfe\",\n997\t  textDecoration: \"underline\",\n998\t};\n999\t"}]},"parent_tool_use_id":null,"session_id":"7d6a4572-ffc4-43a8-900d-a576c5df45f4","uuid":"9baa0158-0f84-4a3b-87bd-6f41626612e2","timestamp":"2026-04-25T12:10:36.111Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/user-detail-view.tsx","content":"import type { CSSProperties, ReactNode } from \"react\";\nimport Link from \"next/link\";\nimport type {\n  PeekChallengeAssignmentSummary,\n  PeekCrateDropRow,\n  PeekFraudFlagRow,\n  PeekGameEntryRow,\n  PeekKolRate,\n  PeekLinkedAccountRow,\n  PeekPlayerPoints,\n  PeekPointGrantRow,\n  PeekReferralClaimRow,\n  PeekReferralEarningsSummary,\n  PeekStatusTone,\n  PeekTelegramLinkTokenRow,\n  PeekTransactionRow,\n  PeekUserAttentionFlags,\n  PeekUserDetail,\n  PeekUserQueueEventRow,\n} from \"../lib/types/peek\";\nimport { DetailPanel, type PeekDetailSection } from \"./detail-panel\";\nimport { EmptyState } from \"./empty-state\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type UserDetailViewProps = {\n  detail: PeekUserDetail;\n  activeSectionId?: string | null;\n};\n\nexport const USER_DETAIL_SECTION_IDS = [\n  \"identity\",\n  \"linked-accounts\",\n  \"referrals\",\n  \"games\",\n  \"rewards\",\n  \"challenges\",\n  \"transactions\",\n  \"attention\",\n] as const;\n\nexport type UserDetailSectionId = (typeof USER_DETAIL_SECTION_IDS)[number];\n\nexport function UserDetailView({\n  detail,\n  activeSectionId = null,\n}: UserDetailViewProps) {\n  const sections: ReadonlyArray<PeekDetailSection> = [\n    {\n      id: \"identity\",\n      label: \"Identity\",\n      body: <IdentitySection detail={detail} />,\n    },\n    {\n      id: \"linked-accounts\",\n      label: \"Linked accounts\",\n      body: <LinkedAccountsSection detail={detail} />,\n    },\n    {\n      id: \"referrals\",\n      label: \"Referrals\",\n      body: <ReferralsSection detail={detail} />,\n    },\n    {\n      id: \"games\",\n      label: \"Games\",\n      body: <GamesSection detail={detail} />,\n    },\n    {\n      id: \"rewards\",\n      label: \"Rewards\",\n      body: <RewardsSection detail={detail} />,\n    },\n    {\n      id: \"challenges\",\n      label: \"Challenges\",\n      body: <ChallengesSection summary={detail.challengeSummary} />,\n    },\n    {\n      id: \"transactions\",\n      label: \"Transactions\",\n      body: <TransactionsSection detail={detail} />,\n    },\n    {\n      id: \"attention\",\n      label: \"Attention\",\n      body: <AttentionSection detail={detail} />,\n    },\n  ];\n\n  return (\n    <article style={pageStyle} aria-label=\"User detail\">\n      <UserHeader detail={detail} />\n      <AttentionStrip flags={detail.attention} />\n      <DetailPanel\n        sections={sections}\n        activeId={activeSectionId}\n        ariaLabel=\"User detail sections\"\n      />\n    </article>\n  );\n}\n\nfunction UserHeader({ detail }: { detail: PeekUserDetail }) {\n  const heading = detail.user.username ?? detail.user.userId;\n  return (\n    <header style={headerStyle}>\n      <div>\n        <h1 style={headingStyle}>{heading}</h1>\n        <p style={walletStyle}>{detail.user.wallet}</p>\n      </div>\n      <dl style={metaStyle}>\n        <MetaPair label=\"user_id\" value={detail.user.userId} />\n        <MetaPair label=\"joined\" value={detail.user.joinedAt} />\n      </dl>\n    </header>\n  );\n}\n\nfunction MetaPair({ label, value }: { label: string; value: string }) {\n  return (\n    <div style={metaPairStyle}>\n      <dt style={metaLabelStyle}>{label}</dt>\n      <dd style={metaValueStyle}>{value}</dd>\n    </div>\n  );\n}\n\nfunction AttentionStrip({ flags }: { flags: PeekUserAttentionFlags }) {\n  const items = buildAttentionItems(flags);\n  if (items.length === 0) {\n    return null;\n  }\n  return (\n    <aside aria-label=\"Attention\" style={attentionStripStyle}>\n      <span style={attentionLabelStyle}>Attention:</span>\n      {items.map((item) => (\n        <StatusChip\n          key={item.id}\n          label={item.label}\n          tone={item.tone}\n          title={item.description}\n        />\n      ))}\n    </aside>\n  );\n}\n\nfunction IdentitySection({ detail }: { detail: PeekUserDetail }) {\n  const rows: Array<[string, string | null]> = [\n    [\"user_id\", detail.user.userId],\n    [\"username\", detail.user.username],\n    [\"wallet\", detail.user.wallet],\n    [\"joined\", detail.user.joinedAt],\n    [\"avatar_url\", detail.user.avatarUrl],\n    [\"heat_multiplier\", detail.user.heatMultiplier],\n    [\"profile_points_balance\", detail.user.profilePointsBalance],\n  ];\n  return (\n    <DefinitionList\n      rows={rows}\n      empty=\"No identity recorded for this user.\"\n    />\n  );\n}\n\nfunction LinkedAccountsSection({ detail }: { detail: PeekUserDetail }) {\n  return (\n    <div style={stackStyle}>\n      <SubSection title=\"Telegram link state\">\n        <DefinitionList\n          rows={[\n            [\"state\", detail.telegram.state],\n            [\"telegram_user_id\", detail.telegram.telegramUserId],\n            [\"telegram_username\", detail.telegram.telegramUsername],\n          ]}\n        />\n      </SubSection>\n\n      <SubSection title=\"Linked accounts\">\n        {detail.linkedAccounts.length === 0 ? (\n          <EmptyState\n            state={{\n              title: \"No linked accounts.\",\n              body: \"This user has not linked any external provider accounts.\",\n            }}\n          />\n        ) : (\n          <SimpleTable\n            head={[\n              \"provider\",\n              \"provider_account_id\",\n              \"status\",\n              \"telegram_username\",\n              \"linked_at\",\n            ]}\n            rows={detail.linkedAccounts.map((row: PeekLinkedAccountRow) => [\n              row.provider,\n              row.providerAccountId,\n              <StatusChip\n                key=\"status\"\n                label={row.status}\n                tone={\n                  row.status === \"active\"\n                    ? \"positive\"\n                    : row.status === \"revoked\"\n                    ? \"negative\"\n                    : \"neutral\"\n                }\n              />,\n              row.telegramUsername ?? \"—\",\n              row.linkedAt,\n            ])}\n          />\n        )}\n      </SubSection>\n\n      <SubSection title=\"Recent Telegram link tokens\">\n        {detail.recentTelegramLinkTokens.length === 0 ? (\n          <EmptyState\n            state={{\n              title: \"No Telegram link tokens issued.\",\n              body: null,\n            }}\n          />\n        ) : (\n          <SimpleTable\n            head={[\n              \"status\",\n              \"telegram_user_id\",\n              \"telegram_username\",\n              \"expires_at\",\n              \"redeemed_at\",\n              \"created_at\",\n            ]}\n            rows={detail.recentTelegramLinkTokens.map(\n              (row: PeekTelegramLinkTokenRow) => [\n                <StatusChip\n                  key=\"status\"\n                  label={row.status}\n                  tone={\n                    row.status === \"redeemed\"\n                      ? \"positive\"\n                      : row.status === \"expired\"\n                      ? \"warning\"\n                      : \"neutral\"\n                  }\n                />,\n                row.telegramUserId ?? \"—\",\n                row.telegramUsername ?? \"—\",\n                row.expiresAt,\n                row.redeemedAt ?? \"—\",\n                row.createdAt,\n              ],\n            )}\n          />\n        )}\n      </SubSection>\n    </div>\n  );\n}\n\nfunction ReferralsSection({ detail }: { detail: PeekUserDetail }) {\n  const inboundLabel =\n    detail.inboundReferral.referrerCode ??\n    detail.inboundReferral.referrerUserId ??\n    \"No referrer\";\n  return (\n    <div style={stackStyle}>\n      <SubSection title=\"Inbound referral\">\n        <DefinitionList\n          rows={[\n            [\"referrer\", inboundLabel],\n            [\"referrer_user_id\", detail.inboundReferral.referrerUserId],\n            [\"linked_at\", detail.inboundReferral.linkedAt],\n          ]}\n        />\n      </SubSection>\n\n      <SubSection title=\"Referral code\">\n        <DefinitionList\n          rows={[\n            [\"referral_code\", detail.user.referralCode],\n            [\"referee_count\", String(detail.user.refereeCount)],\n          ]}\n        />\n      </SubSection>\n\n      <SubSection title=\"KOL rate\">\n        <KolRateBlock rate={detail.kolRate} />\n      </SubSection>\n\n      <SubSection title=\"Earnings & rebates\">\n        <EarningsBlock summary={detail.referralEarnings} />\n      </SubSection>\n\n      <SubSection title=\"Recent referral claims\">\n        {detail.recentReferralClaims.length === 0 ? (\n          <EmptyState state={{ title: \"No referral claims yet.\", body: null }} />\n        ) : (\n          <SimpleTable\n            head={[\n              \"amount_lamports\",\n              \"status\",\n              \"retry_count\",\n              \"tx_signature\",\n              \"requested_at\",\n              \"processed_at\",\n              \"error\",\n            ]}\n            rows={detail.recentReferralClaims.map(\n              (row: PeekReferralClaimRow) => [\n                row.amountLamports,\n                <StatusChip\n                  key=\"status\"\n                  label={row.status}\n                  tone={\n                    row.status === \"paid\"\n                      ? \"positive\"\n                      : row.status === \"failed\" || row.status === \"error\"\n                      ? \"negative\"\n                      : row.status === \"processing\"\n                      ? \"info\"\n                      : \"neutral\"\n                  }\n                />,\n                String(row.retryCount),\n                row.txSignature ?? \"—\",\n                row.requestedAt,\n                row.processedAt ?? \"—\",\n                row.error ?? \"—\",\n              ],\n            )}\n          />\n        )}\n      </SubSection>\n\n      <SubSection title=\"Outbound referees\">\n        {detail.outboundReferees.length === 0 ? (\n          <EmptyState state={{ title: \"No referees yet.\", body: null }} />\n        ) : (\n          <SimpleTable\n            head={[\"referee_user_id\", \"username\", \"linked_at\"]}\n            rows={detail.outboundReferees.map((row) => [\n              <Link key=\"link\" href={`/users/${row.refereeUserId}`} style={linkStyle}>\n                {row.refereeUserId}\n              </Link>,\n              row.refereeUsername ?? \"—\",\n              row.createdAt,\n            ])}\n          />\n        )}\n      </SubSection>\n    </div>\n  );\n}\n\nfunction GamesSection({ detail }: { detail: PeekUserDetail }) {\n  if (detail.recentGameEntries.length === 0) {\n    return (\n      <EmptyState\n        state={{\n          title: \"No game entries yet.\",\n          body: \"This user has not entered any FlipYou, Pot Shot, or Close Call rounds.\",\n        }}\n      />\n    );\n  }\n  return (\n    <SimpleTable\n      head={[\n        \"game\",\n        \"match_id\",\n        \"amount_lamports\",\n        \"side\",\n        \"is_winner\",\n        \"payout_lamports\",\n        \"created_at\",\n        \"settled_at\",\n      ]}\n      rows={detail.recentGameEntries.map((row: PeekGameEntryRow) => [\n        <StatusChip key=\"game\" label={row.game} tone=\"info\" />,\n        <Link\n          key=\"match\"\n          href={`/games/${row.game}/rounds/${row.roundPda}`}\n          style={linkStyle}\n        >\n          {row.matchId}\n        </Link>,\n        row.amountLamports,\n        row.side ?? \"—\",\n        renderWinner(row.isWinner),\n        row.payoutLamports,\n        row.createdAt,\n        row.settledAt ?? \"—\",\n      ])}\n    />\n  );\n}\n\nfunction RewardsSection({ detail }: { detail: PeekUserDetail }) {\n  return (\n    <div style={stackStyle}>\n      <SubSection title=\"Points balance\">\n        <PointsBlock points={detail.points} />\n      </SubSection>\n\n      <SubSection title=\"Recent point grants\">\n        {detail.recentPointGrants.length === 0 ? (\n          <EmptyState state={{ title: \"No point grants recorded.\", body: null }} />\n        ) : (\n          <SimpleTable\n            head={[\"source_type\", \"source_id\", \"amount\", \"created_at\"]}\n            rows={detail.recentPointGrants.map((row: PeekPointGrantRow) => [\n              row.sourceType,\n              row.sourceId,\n              row.amount,\n              row.createdAt,\n            ])}\n          />\n        )}\n      </SubSection>\n\n      <SubSection title=\"Recent crate drops\">\n        {detail.recentCrateDrops.length === 0 ? (\n          <EmptyState state={{ title: \"No crate drops recorded.\", body: null }} />\n        ) : (\n          <SimpleTable\n            head={[\n              \"trigger_type\",\n              \"trigger_id\",\n              \"crate_type\",\n              \"contents_amount\",\n              \"status\",\n              \"created_at\",\n              \"granted_at\",\n            ]}\n            rows={detail.recentCrateDrops.map((row: PeekCrateDropRow) => [\n              row.triggerType,\n              row.triggerId,\n              row.crateType,\n              row.contentsAmount,\n              <StatusChip\n                key=\"status\"\n                label={row.status}\n                tone={\n                  row.status === \"granted\"\n                    ? \"positive\"\n                    : row.status === \"pending\"\n                    ? \"warning\"\n                    : row.status === \"failed\"\n                    ? \"negative\"\n                    : \"neutral\"\n                }\n              />,\n              row.createdAt,\n              row.grantedAt ?? \"—\",\n            ])}\n          />\n        )}\n      </SubSection>\n    </div>\n  );\n}\n\nfunction ChallengesSection({\n  summary,\n}: {\n  summary: PeekChallengeAssignmentSummary;\n}) {\n  if (summary.total === 0) {\n    return (\n      <EmptyState\n        state={{\n          title: \"No challenge assignments.\",\n          body: \"This user has not been assigned any challenges yet.\",\n        }}\n      />\n    );\n  }\n  return (\n    <DefinitionList\n      rows={[\n        [\"active\", String(summary.active)],\n        [\"completed\", String(summary.completed)],\n        [\"expired\", String(summary.expired)],\n        [\"total\", String(summary.total)],\n      ]}\n    />\n  );\n}\n\nfunction TransactionsSection({ detail }: { detail: PeekUserDetail }) {\n  if (detail.recentTransactions.length === 0) {\n    return (\n      <EmptyState\n        state={{\n          title: \"No transactions recorded.\",\n          body: \"This user has no on-chain transaction records yet.\",\n        }}\n      />\n    );\n  }\n  return (\n    <SimpleTable\n      head={[\n        \"game\",\n        \"match_id\",\n        \"tx_type\",\n        \"amount_lamports\",\n        \"tx_sig\",\n        \"created_at\",\n      ]}\n      rows={detail.recentTransactions.map((row: PeekTransactionRow) => [\n        <StatusChip key=\"game\" label={row.game} tone=\"info\" />,\n        row.matchId,\n        <StatusChip\n          key=\"type\"\n          label={row.txType}\n          tone={\n            row.txType === \"payout\"\n              ? \"positive\"\n              : row.txType === \"refund\"\n              ? \"warning\"\n              : \"neutral\"\n          }\n        />,\n        row.amountLamports,\n        row.txSig,\n        row.createdAt,\n      ])}\n    />\n  );\n}\n\nfunction AttentionSection({ detail }: { detail: PeekUserDetail }) {\n  const items = buildAttentionItems(detail.attention);\n  return (\n    <div style={stackStyle}>\n      <SubSection title=\"Attention flags\">\n        {items.length === 0 ? (\n          <EmptyState\n            state={{\n              title: \"No attention flags.\",\n              body: \"Nothing currently flagged for review on this user.\",\n            }}\n          />\n        ) : (\n          <ul style={attentionListStyle}>\n            {items.map((item) => (\n              <li key={item.id} style={attentionItemStyle}>\n                <StatusChip label={item.label} tone={item.tone} />\n                <span style={attentionDescStyle}>{item.description}</span>\n              </li>\n            ))}\n          </ul>\n        )}\n      </SubSection>\n\n      <SubSection title=\"Open fraud flags\">\n        {detail.fraudFlags.length === 0 ? (\n          <EmptyState state={{ title: \"No fraud flags.\", body: null }} />\n        ) : (\n          <SimpleTable\n            head={[\"flag_type\", \"status\", \"related_id\", \"created_at\", \"resolved_at\"]}\n            rows={detail.fraudFlags.map((row: PeekFraudFlagRow) => [\n              row.flagType,\n              <StatusChip\n                key=\"status\"\n                label={row.status}\n                tone={\n                  row.status === \"open\"\n                    ? \"negative\"\n                    : row.status === \"reviewed\"\n                    ? \"info\"\n                    : \"neutral\"\n                }\n              />,\n              row.relatedId ?? \"—\",\n              row.createdAt,\n              row.resolvedAt ?? \"—\",\n            ])}\n          />\n        )}\n      </SubSection>\n\n      <SubSection title=\"Recent queue events\">\n        {detail.recentUserQueueEvents.length === 0 ? (\n          <EmptyState state={{ title: \"No queue events for this user.\", body: null }} />\n        ) : (\n          <SimpleTable\n            head={[\n              \"event_type\",\n              \"status\",\n              \"attempts\",\n              \"scheduled_at\",\n              \"created_at\",\n              \"error\",\n            ]}\n            rows={detail.recentUserQueueEvents.map(\n              (row: PeekUserQueueEventRow) => [\n                row.eventType,\n                <StatusChip\n                  key=\"status\"\n                  label={row.status}\n                  tone={\n                    row.status === \"dead\"\n                      ? \"negative\"\n                      : row.status === \"failed\"\n                      ? \"warning\"\n                      : row.status === \"processed\"\n                      ? \"positive\"\n                      : \"neutral\"\n                  }\n                />,\n                `${row.attempts} / ${row.maxAttempts}`,\n                row.scheduledAt,\n                row.createdAt,\n                row.error ?? \"—\",\n              ],\n            )}\n          />\n        )}\n      </SubSection>\n    </div>\n  );\n}\n\n// --- Reusable building blocks ------------------------------------------------\n\nfunction SubSection({\n  title,\n  children,\n}: {\n  title: string;\n  children: ReactNode;\n}) {\n  return (\n    <section style={subSectionStyle}>\n      <h3 style={subHeadingStyle}>{title}</h3>\n      {children}\n    </section>\n  );\n}\n\nfunction DefinitionList({\n  rows,\n  empty,\n}: {\n  rows: ReadonlyArray<readonly [string, string | null]>;\n  empty?: string;\n}) {\n  const usable = rows.filter(([, value]) => value !== null && value !== \"\");\n  if (usable.length === 0) {\n    return (\n      <EmptyState\n        state={{\n          title: empty ?? \"No data recorded for this section.\",\n          body: null,\n        }}\n      />\n    );\n  }\n  return (\n    <dl style={dlStyle}>\n      {rows.map(([label, value]) => (\n        <div key={label} style={dlRowStyle}>\n          <dt style={dlLabelStyle}>{label}</dt>\n          <dd style={dlValueStyle}>{value ?? \"—\"}</dd>\n        </div>\n      ))}\n    </dl>\n  );\n}\n\nfunction SimpleTable({\n  head,\n  rows,\n}: {\n  head: ReadonlyArray<string>;\n  rows: ReadonlyArray<ReadonlyArray<ReactNode>>;\n}) {\n  return (\n    <div style={tableWrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr>\n            {head.map((label) => (\n              <th key={label} style={thStyle}>\n                {label}\n              </th>\n            ))}\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row, rowIndex) => (\n            <tr key={rowIndex}>\n              {row.map((cell, cellIndex) => (\n                <td key={cellIndex} style={tdStyle}>\n                  {cell}\n                </td>\n              ))}\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction KolRateBlock({ rate }: { rate: PeekKolRate | null }) {\n  if (!rate) {\n    return (\n      <EmptyState\n        state={{ title: \"Not a KOL.\", body: \"No KOL rate configured for this user.\" }}\n      />\n    );\n  }\n  return (\n    <DefinitionList\n      rows={[\n        [\"rate_bps\", String(rate.rateBps)],\n        [\"set_by\", rate.setBy],\n        [\"created_at\", rate.createdAt],\n        [\"updated_at\", rate.updatedAt],\n      ]}\n    />\n  );\n}\n\nfunction EarningsBlock({\n  summary,\n}: {\n  summary: PeekReferralEarningsSummary;\n}) {\n  if (summary.earningsCount === 0) {\n    return (\n      <EmptyState state={{ title: \"No referral earnings yet.\", body: null }} />\n    );\n  }\n  return (\n    <DefinitionList\n      rows={[\n        [\"earnings_count\", String(summary.earningsCount)],\n        [\"total_referrer_earned_lamports\", summary.totalReferrerEarnedLamports],\n        [\"total_referee_rebate_lamports\", summary.totalRefereeRebateLamports],\n        [\"last_earned_at\", summary.lastEarnedAt],\n      ]}\n    />\n  );\n}\n\nfunction PointsBlock({ points }: { points: PeekPlayerPoints }) {\n  return (\n    <DefinitionList\n      rows={[\n        [\"balance\", points.balance],\n        [\"lifetime_earned\", points.lifetimeEarned],\n        [\"updated_at\", points.updatedAt],\n      ]}\n    />\n  );\n}\n\nfunction renderWinner(value: boolean | null): string {\n  if (value === null) return \"—\";\n  return value ? \"win\" : \"loss\";\n}\n\ntype AttentionItem = {\n  id: string;\n  label: string;\n  tone: PeekStatusTone;\n  description: string;\n};\n\nfunction buildAttentionItems(\n  flags: PeekUserAttentionFlags,\n): ReadonlyArray<AttentionItem> {\n  const items: AttentionItem[] = [];\n  if (flags.failedClaim) {\n    items.push({\n      id: \"failed_claim\",\n      label: \"Failed claim\",\n      tone: \"negative\",\n      description: \"At least one recent referral claim is in failed/error status.\",\n    });\n  }\n  if (flags.deadQueueEvent) {\n    items.push({\n      id: \"dead_queue_event\",\n      label: \"Dead queue event\",\n      tone: \"negative\",\n      description: \"An async queue event for this user has hit max attempts.\",\n    });\n  }\n  if (flags.activeFraudFlag) {\n    items.push({\n      id: \"active_fraud_flag\",\n      label: \"Active fraud flag\",\n      tone: \"warning\",\n      description: \"An open fraud flag exists on this user and needs review.\",\n    });\n  }\n  if (flags.pendingSolCratePayout) {\n    items.push({\n      id: \"pending_sol_crate_payout\",\n      label: \"Pending SOL crate payout\",\n      tone: \"warning\",\n      description: \"A SOL crate drop is pending payout for this user.\",\n    });\n  }\n  if (flags.suspiciousReferralLoop) {\n    items.push({\n      id: \"suspicious_referral_loop\",\n      label: \"Suspicious referral self/loop\",\n      tone: \"negative\",\n      description:\n        \"This user appears as both referrer and referee on a referral_links row.\",\n    });\n  }\n  return items;\n}\n\n// --- Styles ------------------------------------------------------------------\n\nconst pageStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.25rem\",\n};\n\nconst headerStyle: CSSProperties = {\n  display: \"flex\",\n  flexWrap: \"wrap\",\n  gap: \"1rem\",\n  alignItems: \"flex-end\",\n  justifyContent: \"space-between\",\n  borderBottom: \"1px solid #1e293b\",\n  paddingBottom: \"1rem\",\n};\n\nconst headingStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1.5rem\",\n  color: \"#e2e8f0\",\n};\n\nconst walletStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  fontFamily: \"monospace\",\n  color: \"#94a3b8\",\n  fontSize: \"0.875rem\",\n};\n\nconst metaStyle: CSSProperties = {\n  margin: 0,\n  display: \"flex\",\n  flexWrap: \"wrap\",\n  gap: \"1rem\",\n};\n\nconst metaPairStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.125rem\",\n};\n\nconst metaLabelStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.6875rem\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n  color: \"#94a3b8\",\n};\n\nconst metaValueStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.8125rem\",\n  fontFamily: \"monospace\",\n  color: \"#e2e8f0\",\n};\n\nconst attentionStripStyle: CSSProperties = {\n  display: \"flex\",\n  flexWrap: \"wrap\",\n  alignItems: \"center\",\n  gap: \"0.5rem\",\n  padding: \"0.5rem 0.75rem\",\n  borderRadius: \"0.5rem\",\n  background: \"#1f1305\",\n  border: \"1px solid #b45309\",\n};\n\nconst attentionLabelStyle: CSSProperties = {\n  fontSize: \"0.75rem\",\n  fontWeight: 600,\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n  color: \"#fde68a\",\n};\n\nconst attentionListStyle: CSSProperties = {\n  listStyle: \"none\",\n  margin: 0,\n  padding: 0,\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst attentionItemStyle: CSSProperties = {\n  display: \"flex\",\n  alignItems: \"center\",\n  gap: \"0.5rem\",\n};\n\nconst attentionDescStyle: CSSProperties = {\n  fontSize: \"0.8125rem\",\n  color: \"#cbd5f5\",\n};\n\nconst stackStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1rem\",\n};\n\nconst subSectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst subHeadingStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst dlStyle: CSSProperties = {\n  margin: 0,\n  display: \"grid\",\n  gridTemplateColumns: \"max-content 1fr\",\n  gap: \"0.25rem 1rem\",\n};\n\nconst dlRowStyle: CSSProperties = {\n  display: \"contents\",\n};\n\nconst dlLabelStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.6875rem\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n  color: \"#94a3b8\",\n};\n\nconst dlValueStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.8125rem\",\n  fontFamily: \"monospace\",\n  color: \"#e2e8f0\",\n  overflowWrap: \"anywhere\",\n};\n\nconst tableWrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.5rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n  fontSize: \"0.8125rem\",\n};\n\nconst thStyle: CSSProperties = {\n  textAlign: \"left\",\n  padding: \"0.5rem 0.75rem\",\n  background: \"#0b1220\",\n  color: \"#94a3b8\",\n  fontWeight: 600,\n  borderBottom: \"1px solid #1e293b\",\n  whiteSpace: \"nowrap\",\n};\n\nconst tdStyle: CSSProperties = {\n  padding: \"0.5rem 0.75rem\",\n  borderBottom: \"1px solid #1e293b\",\n  color: \"#e2e8f0\",\n  fontFamily: \"monospace\",\n  whiteSpace: \"nowrap\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#bfdbfe\",\n  textDecoration: \"underline\",\n};\n","numLines":999,"startLine":1,"totalLines":999}}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_013YRU8yvE1EnV2c2Z81E3nq","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01NKUGbxi1aYsS9AJz9NuBsR","name":"Read","input":{"file_path":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":12101,"cache_read_input_tokens":110556,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":12101},"output_tokens":43,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"7d6a4572-ffc4-43a8-900d-a576c5df45f4","uuid":"4dd6c293-0f73-4d59-9529-923669fe84c5"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NKUGbxi1aYsS9AJz9NuBsR","type":"tool_result","content":"1\t// Browser-safe view-model primitives for `peek`.\n2\t//\n3\t// Foundational shapes used across feature pages: metric metadata (FR-4),\n4\t// URL-addressable table filters, pagination, sort, and a small table-row base\n5\t// type that per-feature row types can extend. Per-feature shapes (PeekUserRow,\n6\t// PeekUserDetail, future referral/game/queue/etc. rows) live alongside or\n7\t// extend these primitives.\n8\t\n9\timport type { PeekRole } from \"../access-policy\";\n10\t\n11\t// --- Existing 303-era shapes (kept stable for current callers) ---------------\n12\t\n13\texport type PeekSummary = {\n14\t  totalUsers: number;\n15\t  totalUsersWithCodes: number;\n16\t  totalReferredUsers: number;\n17\t  totalUniqueReferrers: number;\n18\t};\n19\t\n20\texport type PeekUserRow = {\n21\t  userId: string;\n22\t  username: string | null;\n23\t  wallet: string;\n24\t  joinedAt: string;\n25\t  referralCode: string | null;\n26\t  referrerUserId: string | null;\n27\t  referrerCode: string | null;\n28\t  refereeCount: number;\n29\t  telegramUsername: string | null;\n30\t  telegramUserId: string | null;\n31\t};\n32\t\n33\t// --- Expanded user-detail shapes (FR-6) --------------------------------------\n34\t//\n35\t// Per-section row types for the full support/audit user profile. Lamports and\n36\t// numeric/precision-sensitive values arrive as `text` to preserve precision; the\n37\t// UI re-formats at render time. All shapes are browser-safe (no server imports).\n38\t\n39\texport type PeekLinkedAccountRow = {\n40\t  id: string;\n41\t  provider: string;\n42\t  providerAccountId: string;\n43\t  status: string;\n44\t  telegramUsername: string | null;\n45\t  metadataJson: Record<string, unknown> | null;\n46\t  linkedAt: string;\n47\t  updatedAt: string;\n48\t};\n49\t\n50\texport type PeekTelegramLinkTokenRow = {\n51\t  id: string;\n52\t  status: string;\n53\t  telegramUserId: string | null;\n54\t  telegramUsername: string | null;\n55\t  expiresAt: string;\n56\t  redeemedAt: string | null;\n57\t  createdAt: string;\n58\t};\n59\t\n60\texport type PeekKolRate = {\n61\t  rateBps: number;\n62\t  setBy: string;\n63\t  createdAt: string;\n64\t  updatedAt: string;\n65\t};\n66\t\n67\texport type PeekReferralEarningsSummary = {\n68\t  earningsCount: number;\n69\t  totalReferrerEarnedLamports: string;\n70\t  totalRefereeRebateLamports: string;\n71\t  lastEarnedAt: string | null;\n72\t};\n73\t\n74\texport type PeekReferralClaimRow = {\n75\t  id: string;\n76\t  amountLamports: string;\n77\t  status: string;\n78\t  retryCount: number;\n79\t  txSignature: string | null;\n80\t  error: string | null;\n81\t  requestedAt: string;\n82\t  processedAt: string | null;\n83\t};\n84\t\n85\texport type PeekPointGrantRow = {\n86\t  id: string;\n87\t  sourceType: string;\n88\t  sourceId: string;\n89\t  amount: string;\n90\t  createdAt: string;\n91\t};\n92\t\n93\texport type PeekPlayerPoints = {\n94\t  balance: string;\n95\t  lifetimeEarned: string;\n96\t  updatedAt: string | null;\n97\t};\n98\t\n99\texport type PeekCrateDropRow = {\n100\t  id: string;\n101\t  triggerType: string;\n102\t  triggerId: string;\n103\t  crateType: string;\n104\t  contentsAmount: string;\n105\t  status: string;\n106\t  createdAt: string;\n107\t  grantedAt: string | null;\n108\t};\n109\t\n110\texport type PeekChallengeAssignmentSummary = {\n111\t  active: number;\n112\t  completed: number;\n113\t  expired: number;\n114\t  total: number;\n115\t};\n116\t\n117\texport type PeekGameEntryRow = {\n118\t  id: string;\n119\t  game: string;\n120\t  roundPda: string;\n121\t  matchId: string;\n122\t  amountLamports: string;\n123\t  side: string | null;\n124\t  isWinner: boolean | null;\n125\t  payoutLamports: string;\n126\t  createdAt: string;\n127\t  settledAt: string | null;\n128\t};\n129\t\n130\texport type PeekTransactionRow = {\n131\t  id: string;\n132\t  game: string;\n133\t  matchId: string;\n134\t  txType: string;\n135\t  amountLamports: string;\n136\t  txSig: string;\n137\t  createdAt: string;\n138\t};\n139\t\n140\texport type PeekFraudFlagRow = {\n141\t  id: string;\n142\t  flagType: string;\n143\t  status: string;\n144\t  relatedId: string | null;\n145\t  createdAt: string;\n146\t  resolvedAt: string | null;\n147\t};\n148\t\n149\texport type PeekUserQueueEventRow = {\n150\t  id: string;\n151\t  eventType: string;\n152\t  status: string;\n153\t  attempts: number;\n154\t  maxAttempts: number;\n155\t  scheduledAt: string;\n156\t  createdAt: string;\n157\t  error: string | null;\n158\t};\n159\t\n160\texport type PeekUserAttentionFlags = {\n161\t  failedClaim: boolean;\n162\t  deadQueueEvent: boolean;\n163\t  activeFraudFlag: boolean;\n164\t  pendingSolCratePayout: boolean;\n165\t  suspiciousReferralLoop: boolean;\n166\t};\n167\t\n168\texport type PeekUserDetailUser = PeekUserRow & {\n169\t  avatarUrl: string | null;\n170\t  heatMultiplier: string;\n171\t  profilePointsBalance: string;\n172\t};\n173\t\n174\texport type PeekUserDetail = {\n175\t  user: PeekUserDetailUser;\n176\t  inboundReferral: {\n177\t    referrerUserId: string | null;\n178\t    referrerCode: string | null;\n179\t    linkedAt: string | null;\n180\t  };\n181\t  outboundReferees: Array<{\n182\t    refereeUserId: string;\n183\t    refereeUsername: string | null;\n184\t    createdAt: string;\n185\t  }>;\n186\t  telegram: {\n187\t    state: \"active\" | \"none\";\n188\t    telegramUserId: string | null;\n189\t    telegramUsername: string | null;\n190\t  };\n191\t  linkedAccounts: ReadonlyArray<PeekLinkedAccountRow>;\n192\t  recentTelegramLinkTokens: ReadonlyArray<PeekTelegramLinkTokenRow>;\n193\t  kolRate: PeekKolRate | null;\n194\t  referralEarnings: PeekReferralEarningsSummary;\n195\t  recentReferralClaims: ReadonlyArray<PeekReferralClaimRow>;\n196\t  points: PeekPlayerPoints;\n197\t  recentPointGrants: ReadonlyArray<PeekPointGrantRow>;\n198\t  recentCrateDrops: ReadonlyArray<PeekCrateDropRow>;\n199\t  challengeSummary: PeekChallengeAssignmentSummary;\n200\t  recentGameEntries: ReadonlyArray<PeekGameEntryRow>;\n201\t  recentTransactions: ReadonlyArray<PeekTransactionRow>;\n202\t  fraudFlags: ReadonlyArray<PeekFraudFlagRow>;\n203\t  recentUserQueueEvents: ReadonlyArray<PeekUserQueueEventRow>;\n204\t  attention: PeekUserAttentionFlags;\n205\t};\n206\t\n207\t// --- Actor view model (browser-safe) -----------------------------------------\n208\t\n209\texport type PeekActorView = {\n210\t  email: string;\n211\t  role: PeekRole;\n212\t};\n213\t\n214\t// --- Metric metadata (FR-4) --------------------------------------------------\n215\t//\n216\t// Each metric carries the bookkeeping required by the data-surfacing standard:\n217\t// stable id, label, value, source table/query, time window, \"as of\" timestamp,\n218\t// short definition, optional unit, and optional drill-down link to the filtered\n219\t// detail rows behind the number.\n220\t\n221\texport type PeekMetricFreshness = \"live\" | \"cached\" | \"manual\" | \"sampled\";\n222\t\n223\texport type PeekMetric = {\n224\t  id: string;\n225\t  label: string;\n226\t  value: number | string | null;\n227\t  valueDisplay: string;\n228\t  unit: string | null;\n229\t  source: string;\n230\t  windowLabel: string;\n231\t  asOf: string | null;\n232\t  definition: string;\n233\t  freshness: PeekMetricFreshness;\n234\t  drilldownHref: string | null;\n235\t};\n236\t\n237\t// --- Pagination primitive ----------------------------------------------------\n238\t\n239\texport type PeekPagination = {\n240\t  page: number;\n241\t  pageSize: number;\n242\t  totalCount: number;\n243\t  totalPages: number;\n244\t};\n245\t\n246\t// --- Sort primitive ----------------------------------------------------------\n247\t\n248\texport type PeekSortDirection = \"asc\" | \"desc\";\n249\t\n250\texport type PeekTableSort = {\n251\t  column: string;\n252\t  direction: PeekSortDirection;\n253\t};\n254\t\n255\t// --- Table filter primitive (URL-addressable) --------------------------------\n256\t\n257\texport type PeekFilterKind =\n258\t  | \"text\"\n259\t  | \"select\"\n260\t  | \"boolean\"\n261\t  | \"date\"\n262\t  | \"dateRange\";\n263\t\n264\texport type PeekFilterOption = {\n265\t  value: string;\n266\t  label: string;\n267\t};\n268\t\n269\texport type PeekTableFilter = {\n270\t  id: string;\n271\t  label: string;\n272\t  kind: PeekFilterKind;\n273\t  value: string | null;\n274\t  options: ReadonlyArray<PeekFilterOption> | null;\n275\t  placeholder: string | null;\n276\t  required: boolean;\n277\t};\n278\t\n279\t// --- Status chip tone (shared) -----------------------------------------------\n280\t\n281\texport type PeekStatusTone =\n282\t  | \"neutral\"\n283\t  | \"positive\"\n284\t  | \"warning\"\n285\t  | \"negative\"\n286\t  | \"info\";\n287\t\n288\t// --- Empty-state primitive ---------------------------------------------------\n289\t\n290\texport type PeekEmptyState = {\n291\t  title: string;\n292\t  body: string | null;\n293\t};\n294\t\n295\t// --- Table row + column primitives -------------------------------------------\n296\t//\n297\t// Per-feature row types extend `PeekTableRowBase` for the shared identifier +\n298\t// optional drill-down link, then add feature-specific fields. The shared dense\n299\t// table component reads `columns` for layout and per-row data via the typed\n300\t// row shape supplied by the feature page.\n301\t\n302\texport type PeekTableColumnAlign = \"left\" | \"right\" | \"center\";\n303\t\n304\texport type PeekTableColumn = {\n305\t  id: string;\n306\t  label: string;\n307\t  align: PeekTableColumnAlign;\n308\t  sortable: boolean;\n309\t};\n310\t\n311\texport type PeekTableRowBase = {\n312\t  id: string;\n313\t  href: string | null;\n314\t};\n315\t\n316\texport type PeekTableViewModel<TRow extends PeekTableRowBase> = {\n317\t  columns: ReadonlyArray<PeekTableColumn>;\n318\t  rows: ReadonlyArray<TRow>;\n319\t  pagination: PeekPagination;\n320\t  filters: ReadonlyArray<PeekTableFilter>;\n321\t  sort: PeekTableSort | null;\n322\t  empty: PeekEmptyState;\n323\t};\n324\t\n325\t// --- Command-center attention queue (FR-3, FR-10) ----------------------------\n326\t//\n327\t// The command-center page surfaces a small set of \"needs attention\" metrics so\n328\t// operators see exception states (failed claims, dead queue events, stuck\n329\t// settlements, pending SOL crate payouts, stale active Dogpile events,\n330\t// high-value export activity) before they dig into per-feature pages. Each\n331\t// item is a `PeekMetric` so the metric-strip primitive renders it with the\n332\t// FR-4 bookkeeping (definition, source, time window, \"as of\", drill-down).\n333\t\n334\texport type PeekCommandCenterAttentionId =\n335\t  | \"failed_claims\"\n336\t  | \"dead_queue_events\"\n337\t  | \"stuck_rounds_flipyou_potshot\"\n338\t  | \"stuck_rounds_closecall\"\n339\t  | \"pending_sol_crate_payouts\"\n340\t  | \"stale_active_dogpile_events\"\n341\t  | \"high_value_exports_24h\";\n342\t\n343\texport type PeekCommandCenterAttention = {\n344\t  generatedAt: string;\n345\t  metrics: ReadonlyArray<PeekMetric>;\n346\t};\n347\t\n348\t// --- Recent operator activity (FR-3 command-center \"high-signal activity\") ---\n349\t//\n350\t// Compact projection of the latest `operator_events` rows for the command-center\n351\t// \"Recent activity\" section. Pulled from the same JSONB payload the audit\n352\t// writer persists, but kept narrow on purpose — the command center surfaces\n353\t// only the few fields needed to recognize what happened, not the full payload.\n354\t// The audit view (`/audit`, later iteration) renders the full bounded table.\n355\t\n356\texport type PeekRecentActivityItem = {\n357\t  id: string;\n358\t  eventType: string;\n359\t  actorEmail: string | null;\n360\t  resourceType: string | null;\n361\t  resourceId: string | null;\n362\t  route: string | null;\n363\t  createdAt: string;\n364\t};\n365\t\n366\t// --- Audit event contracts (FR-11) -------------------------------------------\n367\t//\n368\t// Browser-safe view of `operator_events` rows the audit writer produces under\n369\t// `peek.*` event types. The `PeekAuditPayload` shape pins the fields required by\n370\t// FR-11 so the writer (`peek/src/server/audit/**`, next iteration) and the audit\n371\t// view (`/audit`, later iteration) agree on a serialization contract. Secrets\n372\t// (JWTs, access tokens, DB URLs, private keys, raw secrets) must be replaced by\n373\t// `PEEK_AUDIT_REDACTED` before persisting; the audit-view component renders the\n374\t// token verbatim so reviewers can see that a field was redacted (not silently\n375\t// absent).\n376\t\n377\texport type PeekAuditEventType =\n378\t  | \"peek.search\"\n379\t  | \"peek.user.view_sensitive\"\n380\t  | \"peek.export\"\n381\t  | \"peek.access.denied\"\n382\t  | \"peek.change.applied\"\n383\t  | \"peek.change.rejected\";\n384\t\n385\texport const PEEK_AUDIT_EVENT_TYPES: ReadonlyArray<PeekAuditEventType> = [\n386\t  \"peek.search\",\n387\t  \"peek.user.view_sensitive\",\n388\t  \"peek.export\",\n389\t  \"peek.access.denied\",\n390\t  \"peek.change.applied\",\n391\t  \"peek.change.rejected\",\n392\t];\n393\t\n394\texport function isPeekAuditEventType(\n395\t  value: unknown,\n396\t): value is PeekAuditEventType {\n397\t  return (\n398\t    typeof value === \"string\" &&\n399\t    (PEEK_AUDIT_EVENT_TYPES as ReadonlyArray<string>).includes(value)\n400\t  );\n401\t}\n402\t\n403\texport const PEEK_AUDIT_REDACTED = \"[REDACTED]\";\n404\t\n405\texport type PeekAuditScalar = string | number | boolean | null;\n406\t\n407\texport type PeekAuditChange = {\n408\t  field: string;\n409\t  before: PeekAuditScalar;\n410\t  after: PeekAuditScalar;\n411\t};\n412\t\n413\texport type PeekAuditPayload = {\n414\t  actorEmail: string;\n415\t  route: string | null;\n416\t  actionId: string | null;\n417\t  resourceType: string | null;\n418\t  resourceId: string | null;\n419\t  filterSummary: string | null;\n420\t  resultCount: number | null;\n421\t  requestId: string | null;\n422\t  rejectionReason: string | null;\n423\t  changes: ReadonlyArray<PeekAuditChange> | null;\n424\t};\n425\t\n426\texport type PeekAuditEvent = {\n427\t  id: string;\n428\t  eventType: PeekAuditEventType;\n429\t  createdAt: string;\n430\t  payload: PeekAuditPayload;\n431\t};\n432\t\n433\t// --- Export contracts (FR-12) ------------------------------------------------\n434\t//\n435\t// Exports are server-rendered CSVs gated by the same page-level access as the\n436\t// source page, bounded by a server-side row cap, named with a deterministic\n437\t// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n438\t// bytes return. Export rows reuse the table view-model column ids so the export\n439\t// shape stays in lockstep with the rendered table; values are pre-formatted\n440\t// strings so CSV serialization stays straightforward and locale-stable.\n441\t\n442\texport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n443\t\n444\texport type PeekExportEntity =\n445\t  | \"users\"\n446\t  | \"referrers\"\n447\t  | \"kol\"\n448\t  | \"claims\"\n449\t  | \"rounds\"\n450\t  | \"transactions\"\n451\t  | \"queue\"\n452\t  | \"audit\";\n453\t\n454\texport type PeekExportRow = Record<string, string>;\n455\t\n456\texport type PeekExportFilenameInput = {\n457\t  entity: PeekExportEntity;\n458\t  date: string;\n459\t  filterSlug: string;\n460\t};\n461\t\n462\texport type PeekExportResult = {\n463\t  filename: string;\n464\t  rowCount: number;\n465\t  rowCap: number;\n466\t  rowCapApplied: boolean;\n467\t  columns: ReadonlyArray<PeekTableColumn>;\n468\t  rows: ReadonlyArray<PeekExportRow>;\n469\t};\n470\t\n471\t// --- Universal search (FR-5) -------------------------------------------------\n472\t//\n473\t// One search entry point that resolves common operational identifiers to typed\n474\t// result groups. Results are grouped by entity type so the UI can section them\n475\t// (user, referral, linked account, round, transaction, queue event). Each\n476\t// result includes enough context to disambiguate similar matches; sensitive\n477\t// values (wallet, Telegram id, tx signature) live in the result's `id`/`label`\n478\t// fields for operator readability and the audit event records only the actor\n479\t// email, query class, and result counts (never the raw query, which the audit\n480\t// writer redacts if it looks like a secret).\n481\t\n482\texport type PeekSearchEntityType =\n483\t  | \"user\"\n484\t  | \"referral\"\n485\t  | \"linked_account\"\n486\t  | \"round\"\n487\t  | \"transaction\"\n488\t  | \"queue_event\";\n489\t\n490\texport const PEEK_SEARCH_ENTITY_TYPES: ReadonlyArray<PeekSearchEntityType> = [\n491\t  \"user\",\n492\t  \"referral\",\n493\t  \"linked_account\",\n494\t  \"round\",\n495\t  \"transaction\",\n496\t  \"queue_event\",\n497\t];\n498\t\n499\t// Coarse heuristic classification used only for the `peek.search` audit\n500\t// summary so reviewers can see which class of identifier was searched without\n501\t// inferring it from the (possibly redacted) raw query.\n502\texport type PeekSearchQueryClass =\n503\t  | \"empty\"\n504\t  | \"free_text\"\n505\t  | \"user_id\"\n506\t  | \"username\"\n507\t  | \"wallet\"\n508\t  | \"referral_code\"\n509\t  | \"telegram_username\"\n510\t  | \"telegram_provider_id\"\n511\t  | \"round_pda\"\n512\t  | \"match_id\"\n513\t  | \"tx_signature\"\n514\t  | \"queue_event_id\";\n515\t\n516\texport type PeekSearchResult = {\n517\t  entityType: PeekSearchEntityType;\n518\t  id: string;\n519\t  label: string;\n520\t  sublabel: string | null;\n521\t  context: string | null;\n522\t  href: string;\n523\t};\n524\t\n525\texport type PeekSearchGroup = {\n526\t  entityType: PeekSearchEntityType;\n527\t  results: ReadonlyArray<PeekSearchResult>;\n528\t  truncated: boolean;\n529\t};\n530\t\n531\texport type PeekSearchResponse = {\n532\t  query: string;\n533\t  queryClass: PeekSearchQueryClass;\n534\t  groups: ReadonlyArray<PeekSearchGroup>;\n535\t  totalResults: number;\n536\t  perGroupLimit: number;\n537\t  generatedAt: string;\n538\t};\n539\t\n540\texport const PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT = 5;\n541\texport const PEEK_SEARCH_MAX_PER_GROUP_LIMIT = 25;\n542\t"}]},"parent_tool_use_id":null,"session_id":"7d6a4572-ffc4-43a8-900d-a576c5df45f4","uuid":"af7f4feb-6dfa-4a82-add4-ac03862430f3","timestamp":"2026-04-25T12:10:38.906Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","content":"// Browser-safe view-model primitives for `peek`.\n//\n// Foundational shapes used across feature pages: metric metadata (FR-4),\n// URL-addressable table filters, pagination, sort, and a small table-row base\n// type that per-feature row types can extend. Per-feature shapes (PeekUserRow,\n// PeekUserDetail, future referral/game/queue/etc. rows) live alongside or\n// extend these primitives.\n\nimport type { PeekRole } from \"../access-policy\";\n\n// --- Existing 303-era shapes (kept stable for current callers) ---------------\n\nexport type PeekSummary = {\n  totalUsers: number;\n  totalUsersWithCodes: number;\n  totalReferredUsers: number;\n  totalUniqueReferrers: number;\n};\n\nexport type PeekUserRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  joinedAt: string;\n  referralCode: string | null;\n  referrerUserId: string | null;\n  referrerCode: string | null;\n  refereeCount: number;\n  telegramUsername: string | null;\n  telegramUserId: string | null;\n};\n\n// --- Expanded user-detail shapes (FR-6) --------------------------------------\n//\n// Per-section row types for the full support/audit user profile. Lamports and\n// numeric/precision-sensitive values arrive as `text` to preserve precision; the\n// UI re-formats at render time. All shapes are browser-safe (no server imports).\n\nexport type PeekLinkedAccountRow = {\n  id: string;\n  provider: string;\n  providerAccountId: string;\n  status: string;\n  telegramUsername: string | null;\n  metadataJson: Record<string, unknown> | null;\n  linkedAt: string;\n  updatedAt: string;\n};\n\nexport type PeekTelegramLinkTokenRow = {\n  id: string;\n  status: string;\n  telegramUserId: string | null;\n  telegramUsername: string | null;\n  expiresAt: string;\n  redeemedAt: string | null;\n  createdAt: string;\n};\n\nexport type PeekKolRate = {\n  rateBps: number;\n  setBy: string;\n  createdAt: string;\n  updatedAt: string;\n};\n\nexport type PeekReferralEarningsSummary = {\n  earningsCount: number;\n  totalReferrerEarnedLamports: string;\n  totalRefereeRebateLamports: string;\n  lastEarnedAt: string | null;\n};\n\nexport type PeekReferralClaimRow = {\n  id: string;\n  amountLamports: string;\n  status: string;\n  retryCount: number;\n  txSignature: string | null;\n  error: string | null;\n  requestedAt: string;\n  processedAt: string | null;\n};\n\nexport type PeekPointGrantRow = {\n  id: string;\n  sourceType: string;\n  sourceId: string;\n  amount: string;\n  createdAt: string;\n};\n\nexport type PeekPlayerPoints = {\n  balance: string;\n  lifetimeEarned: string;\n  updatedAt: string | null;\n};\n\nexport type PeekCrateDropRow = {\n  id: string;\n  triggerType: string;\n  triggerId: string;\n  crateType: string;\n  contentsAmount: string;\n  status: string;\n  createdAt: string;\n  grantedAt: string | null;\n};\n\nexport type PeekChallengeAssignmentSummary = {\n  active: number;\n  completed: number;\n  expired: number;\n  total: number;\n};\n\nexport type PeekGameEntryRow = {\n  id: string;\n  game: string;\n  roundPda: string;\n  matchId: string;\n  amountLamports: string;\n  side: string | null;\n  isWinner: boolean | null;\n  payoutLamports: string;\n  createdAt: string;\n  settledAt: string | null;\n};\n\nexport type PeekTransactionRow = {\n  id: string;\n  game: string;\n  matchId: string;\n  txType: string;\n  amountLamports: string;\n  txSig: string;\n  createdAt: string;\n};\n\nexport type PeekFraudFlagRow = {\n  id: string;\n  flagType: string;\n  status: string;\n  relatedId: string | null;\n  createdAt: string;\n  resolvedAt: string | null;\n};\n\nexport type PeekUserQueueEventRow = {\n  id: string;\n  eventType: string;\n  status: string;\n  attempts: number;\n  maxAttempts: number;\n  scheduledAt: string;\n  createdAt: string;\n  error: string | null;\n};\n\nexport type PeekUserAttentionFlags = {\n  failedClaim: boolean;\n  deadQueueEvent: boolean;\n  activeFraudFlag: boolean;\n  pendingSolCratePayout: boolean;\n  suspiciousReferralLoop: boolean;\n};\n\nexport type PeekUserDetailUser = PeekUserRow & {\n  avatarUrl: string | null;\n  heatMultiplier: string;\n  profilePointsBalance: string;\n};\n\nexport type PeekUserDetail = {\n  user: PeekUserDetailUser;\n  inboundReferral: {\n    referrerUserId: string | null;\n    referrerCode: string | null;\n    linkedAt: string | null;\n  };\n  outboundReferees: Array<{\n    refereeUserId: string;\n    refereeUsername: string | null;\n    createdAt: string;\n  }>;\n  telegram: {\n    state: \"active\" | \"none\";\n    telegramUserId: string | null;\n    telegramUsername: string | null;\n  };\n  linkedAccounts: ReadonlyArray<PeekLinkedAccountRow>;\n  recentTelegramLinkTokens: ReadonlyArray<PeekTelegramLinkTokenRow>;\n  kolRate: PeekKolRate | null;\n  referralEarnings: PeekReferralEarningsSummary;\n  recentReferralClaims: ReadonlyArray<PeekReferralClaimRow>;\n  points: PeekPlayerPoints;\n  recentPointGrants: ReadonlyArray<PeekPointGrantRow>;\n  recentCrateDrops: ReadonlyArray<PeekCrateDropRow>;\n  challengeSummary: PeekChallengeAssignmentSummary;\n  recentGameEntries: ReadonlyArray<PeekGameEntryRow>;\n  recentTransactions: ReadonlyArray<PeekTransactionRow>;\n  fraudFlags: ReadonlyArray<PeekFraudFlagRow>;\n  recentUserQueueEvents: ReadonlyArray<PeekUserQueueEventRow>;\n  attention: PeekUserAttentionFlags;\n};\n\n// --- Actor view model (browser-safe) -----------------------------------------\n\nexport type PeekActorView = {\n  email: string;\n  role: PeekRole;\n};\n\n// --- Metric metadata (FR-4) --------------------------------------------------\n//\n// Each metric carries the bookkeeping required by the data-surfacing standard:\n// stable id, label, value, source table/query, time window, \"as of\" timestamp,\n// short definition, optional unit, and optional drill-down link to the filtered\n// detail rows behind the number.\n\nexport type PeekMetricFreshness = \"live\" | \"cached\" | \"manual\" | \"sampled\";\n\nexport type PeekMetric = {\n  id: string;\n  label: string;\n  value: number | string | null;\n  valueDisplay: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  asOf: string | null;\n  definition: string;\n  freshness: PeekMetricFreshness;\n  drilldownHref: string | null;\n};\n\n// --- Pagination primitive ----------------------------------------------------\n\nexport type PeekPagination = {\n  page: number;\n  pageSize: number;\n  totalCount: number;\n  totalPages: number;\n};\n\n// --- Sort primitive ----------------------------------------------------------\n\nexport type PeekSortDirection = \"asc\" | \"desc\";\n\nexport type PeekTableSort = {\n  column: string;\n  direction: PeekSortDirection;\n};\n\n// --- Table filter primitive (URL-addressable) --------------------------------\n\nexport type PeekFilterKind =\n  | \"text\"\n  | \"select\"\n  | \"boolean\"\n  | \"date\"\n  | \"dateRange\";\n\nexport type PeekFilterOption = {\n  value: string;\n  label: string;\n};\n\nexport type PeekTableFilter = {\n  id: string;\n  label: string;\n  kind: PeekFilterKind;\n  value: string | null;\n  options: ReadonlyArray<PeekFilterOption> | null;\n  placeholder: string | null;\n  required: boolean;\n};\n\n// --- Status chip tone (shared) -----------------------------------------------\n\nexport type PeekStatusTone =\n  | \"neutral\"\n  | \"positive\"\n  | \"warning\"\n  | \"negative\"\n  | \"info\";\n\n// --- Empty-state primitive ---------------------------------------------------\n\nexport type PeekEmptyState = {\n  title: string;\n  body: string | null;\n};\n\n// --- Table row + column primitives -------------------------------------------\n//\n// Per-feature row types extend `PeekTableRowBase` for the shared identifier +\n// optional drill-down link, then add feature-specific fields. The shared dense\n// table component reads `columns` for layout and per-row data via the typed\n// row shape supplied by the feature page.\n\nexport type PeekTableColumnAlign = \"left\" | \"right\" | \"center\";\n\nexport type PeekTableColumn = {\n  id: string;\n  label: string;\n  align: PeekTableColumnAlign;\n  sortable: boolean;\n};\n\nexport type PeekTableRowBase = {\n  id: string;\n  href: string | null;\n};\n\nexport type PeekTableViewModel<TRow extends PeekTableRowBase> = {\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<TRow>;\n  pagination: PeekPagination;\n  filters: ReadonlyArray<PeekTableFilter>;\n  sort: PeekTableSort | null;\n  empty: PeekEmptyState;\n};\n\n// --- Command-center attention queue (FR-3, FR-10) ----------------------------\n//\n// The command-center page surfaces a small set of \"needs attention\" metrics so\n// operators see exception states (failed claims, dead queue events, stuck\n// settlements, pending SOL crate payouts, stale active Dogpile events,\n// high-value export activity) before they dig into per-feature pages. Each\n// item is a `PeekMetric` so the metric-strip primitive renders it with the\n// FR-4 bookkeeping (definition, source, time window, \"as of\", drill-down).\n\nexport type PeekCommandCenterAttentionId =\n  | \"failed_claims\"\n  | \"dead_queue_events\"\n  | \"stuck_rounds_flipyou_potshot\"\n  | \"stuck_rounds_closecall\"\n  | \"pending_sol_crate_payouts\"\n  | \"stale_active_dogpile_events\"\n  | \"high_value_exports_24h\";\n\nexport type PeekCommandCenterAttention = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};\n\n// --- Recent operator activity (FR-3 command-center \"high-signal activity\") ---\n//\n// Compact projection of the latest `operator_events` rows for the command-center\n// \"Recent activity\" section. Pulled from the same JSONB payload the audit\n// writer persists, but kept narrow on purpose — the command center surfaces\n// only the few fields needed to recognize what happened, not the full payload.\n// The audit view (`/audit`, later iteration) renders the full bounded table.\n\nexport type PeekRecentActivityItem = {\n  id: string;\n  eventType: string;\n  actorEmail: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  route: string | null;\n  createdAt: string;\n};\n\n// --- Audit event contracts (FR-11) -------------------------------------------\n//\n// Browser-safe view of `operator_events` rows the audit writer produces under\n// `peek.*` event types. The `PeekAuditPayload` shape pins the fields required by\n// FR-11 so the writer (`peek/src/server/audit/**`, next iteration) and the audit\n// view (`/audit`, later iteration) agree on a serialization contract. Secrets\n// (JWTs, access tokens, DB URLs, private keys, raw secrets) must be replaced by\n// `PEEK_AUDIT_REDACTED` before persisting; the audit-view component renders the\n// token verbatim so reviewers can see that a field was redacted (not silently\n// absent).\n\nexport type PeekAuditEventType =\n  | \"peek.search\"\n  | \"peek.user.view_sensitive\"\n  | \"peek.export\"\n  | \"peek.access.denied\"\n  | \"peek.change.applied\"\n  | \"peek.change.rejected\";\n\nexport const PEEK_AUDIT_EVENT_TYPES: ReadonlyArray<PeekAuditEventType> = [\n  \"peek.search\",\n  \"peek.user.view_sensitive\",\n  \"peek.export\",\n  \"peek.access.denied\",\n  \"peek.change.applied\",\n  \"peek.change.rejected\",\n];\n\nexport function isPeekAuditEventType(\n  value: unknown,\n): value is PeekAuditEventType {\n  return (\n    typeof value === \"string\" &&\n    (PEEK_AUDIT_EVENT_TYPES as ReadonlyArray<string>).includes(value)\n  );\n}\n\nexport const PEEK_AUDIT_REDACTED = \"[REDACTED]\";\n\nexport type PeekAuditScalar = string | number | boolean | null;\n\nexport type PeekAuditChange = {\n  field: string;\n  before: PeekAuditScalar;\n  after: PeekAuditScalar;\n};\n\nexport type PeekAuditPayload = {\n  actorEmail: string;\n  route: string | null;\n  actionId: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  filterSummary: string | null;\n  resultCount: number | null;\n  requestId: string | null;\n  rejectionReason: string | null;\n  changes: ReadonlyArray<PeekAuditChange> | null;\n};\n\nexport type PeekAuditEvent = {\n  id: string;\n  eventType: PeekAuditEventType;\n  createdAt: string;\n  payload: PeekAuditPayload;\n};\n\n// --- Export contracts (FR-12) ------------------------------------------------\n//\n// Exports are server-rendered CSVs gated by the same page-level access as the\n// source page, bounded by a server-side row cap, named with a deterministic\n// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n// bytes return. Export rows reuse the table view-model column ids so the export\n// shape stays in lockstep with the rendered table; values are pre-formatted\n// strings so CSV serialization stays straightforward and locale-stable.\n\nexport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n\nexport type PeekExportEntity =\n  | \"users\"\n  | \"referrers\"\n  | \"kol\"\n  | \"claims\"\n  | \"rounds\"\n  | \"transactions\"\n  | \"queue\"\n  | \"audit\";\n\nexport type PeekExportRow = Record<string, string>;\n\nexport type PeekExportFilenameInput = {\n  entity: PeekExportEntity;\n  date: string;\n  filterSlug: string;\n};\n\nexport type PeekExportResult = {\n  filename: string;\n  rowCount: number;\n  rowCap: number;\n  rowCapApplied: boolean;\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<PeekExportRow>;\n};\n\n// --- Universal search (FR-5) -------------------------------------------------\n//\n// One search entry point that resolves common operational identifiers to typed\n// result groups. Results are grouped by entity type so the UI can section them\n// (user, referral, linked account, round, transaction, queue event). Each\n// result includes enough context to disambiguate similar matches; sensitive\n// values (wallet, Telegram id, tx signature) live in the result's `id`/`label`\n// fields for operator readability and the audit event records only the actor\n// email, query class, and result counts (never the raw query, which the audit\n// writer redacts if it looks like a secret).\n\nexport type PeekSearchEntityType =\n  | \"user\"\n  | \"referral\"\n  | \"linked_account\"\n  | \"round\"\n  | \"transaction\"\n  | \"queue_event\";\n\nexport const PEEK_SEARCH_ENTITY_TYPES: ReadonlyArray<PeekSearchEntityType> = [\n  \"user\",\n  \"referral\",\n  \"linked_account\",\n  \"round\",\n  \"transaction\",\n  \"queue_event\",\n];\n\n// Coarse heuristic classification used only for the `peek.search` audit\n// summary so reviewers can see which class of identifier was searched without\n// inferring it from the (possibly redacted) raw query.\nexport type PeekSearchQueryClass =\n  | \"empty\"\n  | \"free_text\"\n  | \"user_id\"\n  | \"username\"\n  | \"wallet\"\n  | \"referral_code\"\n  | \"telegram_username\"\n  | \"telegram_provider_id\"\n  | \"round_pda\"\n  | \"match_id\"\n  | \"tx_signature\"\n  | \"queue_event_id\";\n\nexport type PeekSearchResult = {\n  entityType: PeekSearchEntityType;\n  id: string;\n  label: string;\n  sublabel: string | null;\n  context: string | null;\n  href: string;\n};\n\nexport type PeekSearchGroup = {\n  entityType: PeekSearchEntityType;\n  results: ReadonlyArray<PeekSearchResult>;\n  truncated: boolean;\n};\n\nexport type PeekSearchResponse = {\n  query: string;\n  queryClass: PeekSearchQueryClass;\n  groups: ReadonlyArray<PeekSearchGroup>;\n  totalResults: number;\n  perGroupLimit: number;\n  generatedAt: string;\n};\n\nexport const PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT = 5;\nexport const PEEK_SEARCH_MAX_PER_GROUP_LIMIT = 25;\n","numLines":542,"startLine":1,"totalLines":542}}}
