{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DuxcGwrwPzMDZwDRtMtrWi","type":"tool_result","content":"1\timport type {\n2\t  PeekChallengeAssignmentSummary,\n3\t  PeekCrateDropRow,\n4\t  PeekFraudFlagRow,\n5\t  PeekGameEntryRow,\n6\t  PeekKolRate,\n7\t  PeekLinkedAccountRow,\n8\t  PeekPlayerPoints,\n9\t  PeekPointGrantRow,\n10\t  PeekReferralClaimRow,\n11\t  PeekReferralEarningsSummary,\n12\t  PeekTelegramLinkTokenRow,\n13\t  PeekTransactionRow,\n14\t  PeekUserAttentionFlags,\n15\t  PeekUserDetail,\n16\t  PeekUserQueueEventRow,\n17\t} from \"../../../lib/types/peek\";\n18\timport { writePeekAuditEvent } from \"../../audit/writer\";\n19\timport { getSqlClient } from \"../client\";\n20\t\n21\texport const PEEK_USER_DETAIL_RECENT_LIMIT = 25;\n22\texport const PEEK_USER_DETAIL_TOKEN_LIMIT = 10;\n23\t\n24\ttype Sql = ReturnType<typeof getSqlClient>;\n25\t\n26\texport type PeekUserDetailAuditFn = (input: {\n27\t  actorEmail: string;\n28\t  userId: string;\n29\t  route: string | null;\n30\t  requestId: string | null;\n31\t}) => Promise<void>;\n32\t\n33\ttype GetPeekUserDetailOptions = {\n34\t  sql?: Sql;\n35\t  recentLimit?: number;\n36\t  tokenLimit?: number;\n37\t  actorEmail?: string | null;\n38\t  route?: string | null;\n39\t  requestId?: string | null;\n40\t  audit?: PeekUserDetailAuditFn | null;\n41\t};\n42\t\n43\tasync function defaultPeekUserDetailAudit(input: {\n44\t  actorEmail: string;\n45\t  userId: string;\n46\t  route: string | null;\n47\t  requestId: string | null;\n48\t}): Promise<void> {\n49\t  await writePeekAuditEvent({\n50\t    eventType: \"peek.user.view_sensitive\",\n51\t    payload: {\n52\t      actorEmail: input.actorEmail,\n53\t      route: input.route,\n54\t      actionId: \"peek.user.view_sensitive\",\n55\t      resourceType: \"user\",\n56\t      resourceId: input.userId,\n57\t      filterSummary: null,\n58\t      resultCount: 1,\n59\t      requestId: input.requestId,\n60\t      rejectionReason: null,\n61\t      changes: null,\n62\t    },\n63\t  });\n64\t}\n65\t\n66\texport function formatUserHeading(user: {\n67\t  userId: string;\n68\t  username: string | null;\n69\t}) {\n70\t  return user.username ?? user.userId;\n71\t}\n72\t\n73\texport async function getPeekUserDetail(\n74\t  userId: string,\n75\t  options: GetPeekUserDetailOptions = {},\n76\t): Promise<PeekUserDetail | null> {\n77\t  const sql = options.sql ?? getSqlClient();\n78\t  const recentLimit = clampPositiveInt(\n79\t    options.recentLimit,\n80\t    PEEK_USER_DETAIL_RECENT_LIMIT,\n81\t  );\n82\t  const tokenLimit = clampPositiveInt(\n83\t    options.tokenLimit,\n84\t    PEEK_USER_DETAIL_TOKEN_LIMIT,\n85\t  );\n86\t\n87\t  // Identity + linked-account telegram view (preserved as queries[0] so the\n88\t  // 303-era listing/detail tests continue to assert the same SQL contract).\n89\t  const [user] = await sql<\n90\t    Array<{\n91\t      userId: string;\n92\t      username: string | null;\n93\t      wallet: string;\n94\t      joinedAt: string;\n95\t      avatarUrl: string | null;\n96\t      heatMultiplier: string;\n97\t      profilePointsBalance: string;\n98\t      referralCode: string | null;\n99\t      referrerUserId: string | null;\n100\t      referrerCode: string | null;\n101\t      refereeCount: number;\n102\t      telegramLinkState: \"active\" | \"none\";\n103\t      linkedAt: string | null;\n104\t      telegramUserId: string | null;\n105\t      telegramUsername: string | null;\n106\t    }>\n107\t  >`\n108\t    select\n109\t      pp.user_id as \"userId\",\n110\t      pp.username as \"username\",\n111\t      pp.wallet as \"wallet\",\n112\t      pp.created_at::text as \"joinedAt\",\n113\t      pp.avatar_url as \"avatarUrl\",\n114\t      pp.heat_multiplier::text as \"heatMultiplier\",\n115\t      pp.points_balance::text as \"profilePointsBalance\",\n116\t      rc.code as \"referralCode\",\n117\t      rl.referrer_user_id as \"referrerUserId\",\n118\t      ref_code.code as \"referrerCode\",\n119\t      (\n120\t        select count(*)::int\n121\t        from referral_links outbound\n122\t        where outbound.referrer_user_id = pp.user_id\n123\t      ) as \"refereeCount\",\n124\t      coalesce(tla.status, 'none') as \"telegramLinkState\",\n125\t      rl.created_at::text as \"linkedAt\",\n126\t      tla.telegram_user_id as \"telegramUserId\",\n127\t      tla.telegram_username as \"telegramUsername\"\n128\t    from player_profiles pp\n129\t    left join referral_codes rc on rc.user_id = pp.user_id\n130\t    left join referral_links rl on rl.referee_user_id = pp.user_id\n131\t    left join referral_codes ref_code on ref_code.user_id = rl.referrer_user_id\n132\t    left join lateral (\n133\t      select\n134\t        status,\n135\t        provider_account_id as telegram_user_id,\n136\t        nullif(metadata_json->>'telegramUsername', '') as telegram_username\n137\t      from linked_accounts\n138\t      where user_id = pp.user_id\n139\t        and provider = 'telegram'\n140\t        and status = 'active'\n141\t      limit 1\n142\t    ) tla on true\n143\t    where pp.user_id = ${userId}\n144\t  `;\n145\t\n146\t  if (!user) {\n147\t    return null;\n148\t  }\n149\t\n150\t  const wallet = user.wallet;\n151\t\n152\t  const [\n153\t    outboundReferees,\n154\t    linkedAccounts,\n155\t    recentTelegramLinkTokens,\n156\t    kolRate,\n157\t    referralEarnings,\n158\t    recentReferralClaims,\n159\t    points,\n160\t    recentPointGrants,\n161\t    recentCrateDrops,\n162\t    challengeSummary,\n163\t    recentGameEntries,\n164\t    recentTransactions,\n165\t    fraudFlags,\n166\t    recentUserQueueEvents,\n167\t    selfReferralRow,\n168\t  ] = await Promise.all([\n169\t    fetchOutboundReferees(sql, userId),\n170\t    fetchLinkedAccounts(sql, userId),\n171\t    fetchRecentTelegramLinkTokens(sql, userId, tokenLimit),\n172\t    fetchKolRate(sql, userId),\n173\t    fetchReferralEarnings(sql, userId),\n174\t    fetchRecentReferralClaims(sql, userId, recentLimit),\n175\t    fetchPlayerPoints(sql, userId),\n176\t    fetchRecentPointGrants(sql, userId, recentLimit),\n177\t    fetchRecentCrateDrops(sql, userId, recentLimit),\n178\t    fetchChallengeSummary(sql, userId),\n179\t    fetchRecentGameEntries(sql, userId, recentLimit),\n180\t    fetchRecentTransactions(sql, userId, recentLimit),\n181\t    fetchFraudFlags(sql, userId, recentLimit),\n182\t    fetchRecentUserQueueEvents(sql, userId, wallet, recentLimit),\n183\t    fetchSelfReferralIndicator(sql, userId),\n184\t  ]);\n185\t\n186\t  const attention = computeAttention({\n187\t    recentReferralClaims,\n188\t    recentUserQueueEvents,\n189\t    fraudFlags,\n190\t    recentCrateDrops,\n191\t    selfReferralRow,\n192\t  });\n193\t\n194\t  // FR-11: emit a `peek.user.view_sensitive` audit event when an authorized\n195\t  // operator opens this user-detail page. The handler is opt-in via\n196\t  // `actorEmail`; an empty actor or an explicit `audit: null` skips emission.\n197\t  // Audit failures are caught here so the page still renders even if the\n198\t  // writer's DB insert fails (the writer logs the underlying error).\n199\t  const audit =\n200\t    options.audit === undefined ? defaultPeekUserDetailAudit : options.audit;\n201\t  if (audit && options.actorEmail) {\n202\t    try {\n203\t      await audit({\n204\t        actorEmail: options.actorEmail,\n205\t        userId,\n206\t        route: options.route ?? null,\n207\t        requestId: options.requestId ?? null,\n208\t      });\n209\t    } catch {\n210\t      // Audit failures must never leak to the caller (FR-11). The writer\n211\t      // already logs server-side; swallow here so the user-detail page still\n212\t      // renders.\n213\t    }\n214\t  }\n215\t\n216\t  return {\n217\t    user: {\n218\t      userId: user.userId,\n219\t      username: user.username,\n220\t      wallet: user.wallet,\n221\t      joinedAt: user.joinedAt,\n222\t      referralCode: user.referralCode,\n223\t      referrerUserId: user.referrerUserId,\n224\t      referrerCode: user.referrerCode,\n225\t      refereeCount: user.refereeCount,\n226\t      telegramUsername: user.telegramUsername,\n227\t      telegramUserId: user.telegramUserId,\n228\t      avatarUrl: user.avatarUrl,\n229\t      heatMultiplier: user.heatMultiplier,\n230\t      profilePointsBalance: user.profilePointsBalance,\n231\t    },\n232\t    inboundReferral: {\n233\t      referrerUserId: user.referrerUserId,\n234\t      referrerCode: user.referrerCode,\n235\t      linkedAt: user.linkedAt,\n236\t    },\n237\t    outboundReferees,\n238\t    telegram: {\n239\t      state: user.telegramLinkState,\n240\t      telegramUserId: user.telegramUserId,\n241\t      telegramUsername: user.telegramUsername,\n242\t    },\n243\t    linkedAccounts,\n244\t    recentTelegramLinkTokens,\n245\t    kolRate,\n246\t    referralEarnings,\n247\t    recentReferralClaims,\n248\t    points,\n249\t    recentPointGrants,\n250\t    recentCrateDrops,\n251\t    challengeSummary,\n252\t    recentGameEntries,\n253\t    recentTransactions,\n254\t    fraudFlags,\n255\t    recentUserQueueEvents,\n256\t    attention,\n257\t  };\n258\t}\n259\t\n260\tfunction clampPositiveInt(value: number | undefined, fallback: number): number {\n261\t  if (typeof value !== \"number\" || !Number.isFinite(value)) return fallback;\n262\t  const floored = Math.floor(value);\n263\t  if (floored <= 0) return 1;\n264\t  return floored;\n265\t}\n266\t\n267\tasync function fetchOutboundReferees(\n268\t  sql: Sql,\n269\t  userId: string,\n270\t): Promise<PeekUserDetail[\"outboundReferees\"]> {\n271\t  return sql<\n272\t    Array<{\n273\t      refereeUserId: string;\n274\t      refereeUsername: string | null;\n275\t      createdAt: string;\n276\t    }>\n277\t  >`\n278\t    select\n279\t      rl.referee_user_id as \"refereeUserId\",\n280\t      pp.username as \"refereeUsername\",\n281\t      rl.created_at::text as \"createdAt\"\n282\t    from referral_links rl\n283\t    left join player_profiles pp on pp.user_id = rl.referee_user_id\n284\t    where rl.referrer_user_id = ${userId}\n285\t    order by rl.created_at desc\n286\t  `;\n287\t}\n288\t\n289\tasync function fetchLinkedAccounts(\n290\t  sql: Sql,\n291\t  userId: string,\n292\t): Promise<ReadonlyArray<PeekLinkedAccountRow>> {\n293\t  return sql<Array<PeekLinkedAccountRow>>`\n294\t    select\n295\t      id::text as \"id\",\n296\t      provider,\n297\t      provider_account_id as \"providerAccountId\",\n298\t      status,\n299\t      nullif(metadata_json->>'telegramUsername', '') as \"telegramUsername\",\n300\t      metadata_json as \"metadataJson\",\n301\t      linked_at::text as \"linkedAt\",\n302\t      updated_at::text as \"updatedAt\"\n303\t    from linked_accounts\n304\t    where user_id = ${userId}\n305\t    order by linked_at desc\n306\t  `;\n307\t}\n308\t\n309\tasync function fetchRecentTelegramLinkTokens(\n310\t  sql: Sql,\n311\t  userId: string,\n312\t  limit: number,\n313\t): Promise<ReadonlyArray<PeekTelegramLinkTokenRow>> {\n314\t  return sql<Array<PeekTelegramLinkTokenRow>>`\n315\t    select\n316\t      id::text as \"id\",\n317\t      status,\n318\t      telegram_user_id as \"telegramUserId\",\n319\t      telegram_username as \"telegramUsername\",\n320\t      expires_at::text as \"expiresAt\",\n321\t      redeemed_at::text as \"redeemedAt\",\n322\t      created_at::text as \"createdAt\"\n323\t    from telegram_link_tokens\n324\t    where user_id = ${userId}\n325\t    order by created_at desc\n326\t    limit ${limit}\n327\t  `;\n328\t}\n329\t\n330\tasync function fetchKolRate(\n331\t  sql: Sql,\n332\t  userId: string,\n333\t): Promise<PeekKolRate | null> {\n334\t  const [row] = await sql<\n335\t    Array<{\n336\t      rateBps: number;\n337\t      setBy: string;\n338\t      createdAt: string;\n339\t      updatedAt: string;\n340\t    }>\n341\t  >`\n342\t    select\n343\t      rate_bps as \"rateBps\",\n344\t      set_by as \"setBy\",\n345\t      created_at::text as \"createdAt\",\n346\t      updated_at::text as \"updatedAt\"\n347\t    from referral_kol_rates\n348\t    where user_id = ${userId}\n349\t    limit 1\n350\t  `;\n351\t  return row ?? null;\n352\t}\n353\t\n354\tasync function fetchReferralEarnings(\n355\t  sql: Sql,\n356\t  userId: string,\n357\t): Promise<PeekReferralEarningsSummary> {\n358\t  const [row] = await sql<\n359\t    Array<{\n360\t      earningsCount: number;\n361\t      totalReferrerEarnedLamports: string;\n362\t      totalRefereeRebateLamports: string;\n363\t      lastEarnedAt: string | null;\n364\t    }>\n365\t  >`\n366\t    select\n367\t      count(*)::int as \"earningsCount\",\n368\t      coalesce(sum(referrer_earned_lamports), 0)::text as \"totalReferrerEarnedLamports\",\n369\t      coalesce(sum(referee_rebate_lamports), 0)::text as \"totalRefereeRebateLamports\",\n370\t      max(created_at)::text as \"lastEarnedAt\"\n371\t    from referral_earnings\n372\t    where referrer_user_id = ${userId} or referee_user_id = ${userId}\n373\t  `;\n374\t  return (\n375\t    row ?? {\n376\t      earningsCount: 0,\n377\t      totalReferrerEarnedLamports: \"0\",\n378\t      totalRefereeRebateLamports: \"0\",\n379\t      lastEarnedAt: null,\n380\t    }\n381\t  );\n382\t}\n383\t\n384\tasync function fetchRecentReferralClaims(\n385\t  sql: Sql,\n386\t  userId: string,\n387\t  limit: number,\n388\t): Promise<ReadonlyArray<PeekReferralClaimRow>> {\n389\t  return sql<Array<PeekReferralClaimRow>>`\n390\t    select\n391\t      id::text as \"id\",\n392\t      amount_lamports::text as \"amountLamports\",\n393\t      status,\n394\t      retry_count as \"retryCount\",\n395\t      tx_signature as \"txSignature\",\n396\t      error,\n397\t      requested_at::text as \"requestedAt\",\n398\t      processed_at::text as \"processedAt\"\n399\t    from referral_claims\n400\t    where user_id = ${userId}\n401\t    order by requested_at desc\n402\t    limit ${limit}\n403\t  `;\n404\t}\n405\t\n406\tasync function fetchPlayerPoints(\n407\t  sql: Sql,\n408\t  userId: string,\n409\t): Promise<PeekPlayerPoints> {\n410\t  const [row] = await sql<\n411\t    Array<{\n412\t      balance: string;\n413\t      lifetimeEarned: string;\n414\t      updatedAt: string;\n415\t    }>\n416\t  >`\n417\t    select\n418\t      balance::text as \"balance\",\n419\t      lifetime_earned::text as \"lifetimeEarned\",\n420\t      updated_at::text as \"updatedAt\"\n421\t    from player_points\n422\t    where user_id = ${userId}\n423\t    limit 1\n424\t  `;\n425\t  return (\n426\t    row ?? {\n427\t      balance: \"0\",\n428\t      lifetimeEarned: \"0\",\n429\t      updatedAt: null,\n430\t    }\n431\t  );\n432\t}\n433\t\n434\tasync function fetchRecentPointGrants(\n435\t  sql: Sql,\n436\t  userId: string,\n437\t  limit: number,\n438\t): Promise<ReadonlyArray<PeekPointGrantRow>> {\n439\t  return sql<Array<PeekPointGrantRow>>`\n440\t    select\n441\t      id::text as \"id\",\n442\t      source_type as \"sourceType\",\n443\t      source_id as \"sourceId\",\n444\t      amount::text as \"amount\",\n445\t      created_at::text as \"createdAt\"\n446\t    from point_grants\n447\t    where user_id = ${userId}\n448\t    order by created_at desc\n449\t    limit ${limit}\n450\t  `;\n451\t}\n452\t\n453\tasync function fetchRecentCrateDrops(\n454\t  sql: Sql,\n455\t  userId: string,\n456\t  limit: number,\n457\t): Promise<ReadonlyArray<PeekCrateDropRow>> {\n458\t  return sql<Array<PeekCrateDropRow>>`\n459\t    select\n460\t      id::text as \"id\",\n461\t      trigger_type as \"triggerType\",\n462\t      trigger_id as \"triggerId\",\n463\t      crate_type as \"crateType\",\n464\t      contents_amount as \"contentsAmount\",\n465\t      status,\n466\t      created_at::text as \"createdAt\",\n467\t      granted_at::text as \"grantedAt\"\n468\t    from crate_drops\n469\t    where user_id = ${userId}\n470\t    order by created_at desc\n471\t    limit ${limit}\n472\t  `;\n473\t}\n474\t\n475\tasync function fetchChallengeSummary(\n476\t  sql: Sql,\n477\t  userId: string,\n478\t): Promise<PeekChallengeAssignmentSummary> {\n479\t  const [row] = await sql<\n480\t    Array<{\n481\t      active: number;\n482\t      completed: number;\n483\t      expired: number;\n484\t      total: number;\n485\t    }>\n486\t  >`\n487\t    select\n488\t      count(*) filter (where status = 'active')::int as \"active\",\n489\t      count(*) filter (where status = 'completed')::int as \"completed\",\n490\t      count(*) filter (where status = 'expired')::int as \"expired\",\n491\t      count(*)::int as \"total\"\n492\t    from challenge_assignments\n493\t    where user_id = ${userId}\n494\t  `;\n495\t  return row ?? { active: 0, completed: 0, expired: 0, total: 0 };\n496\t}\n497\t\n498\tasync function fetchRecentGameEntries(\n499\t  sql: Sql,\n500\t  userId: string,\n501\t  limit: number,\n502\t): Promise<ReadonlyArray<PeekGameEntryRow>> {\n503\t  return sql<Array<PeekGameEntryRow>>`\n504\t    select\n505\t      id::text as \"id\",\n506\t      game,\n507\t      round_pda as \"roundPda\",\n508\t      match_id as \"matchId\",\n509\t      amount_lamports::text as \"amountLamports\",\n510\t      side,\n511\t      is_winner as \"isWinner\",\n512\t      payout_lamports::text as \"payoutLamports\",\n513\t      created_at::text as \"createdAt\",\n514\t      settled_at::text as \"settledAt\"\n515\t    from game_entries\n516\t    where user_id = ${userId}\n517\t    order by created_at desc\n518\t    limit ${limit}\n519\t  `;\n520\t}\n521\t\n522\tasync function fetchRecentTransactions(\n523\t  sql: Sql,\n524\t  userId: string,\n525\t  limit: number,\n526\t): Promise<ReadonlyArray<PeekTransactionRow>> {\n527\t  return sql<Array<PeekTransactionRow>>`\n528\t    select\n529\t      id::text as \"id\",\n530\t      game,\n531\t      match_id as \"matchId\",\n532\t      tx_type as \"txType\",\n533\t      amount_lamports::text as \"amountLamports\",\n534\t      tx_sig as \"txSig\",\n535\t      created_at::text as \"createdAt\"\n536\t    from transactions\n537\t    where user_id = ${userId}\n538\t    order by created_at desc\n539\t    limit ${limit}\n540\t  `;\n541\t}\n542\t\n543\tasync function fetchFraudFlags(\n544\t  sql: Sql,\n545\t  userId: string,\n546\t  limit: number,\n547\t): Promise<ReadonlyArray<PeekFraudFlagRow>> {\n548\t  return sql<Array<PeekFraudFlagRow>>`\n549\t    select\n550\t      id::text as \"id\",\n551\t      flag_type as \"flagType\",\n552\t      status,\n553\t      related_id as \"relatedId\",\n554\t      created_at::text as \"createdAt\",\n555\t      resolved_at::text as \"resolvedAt\"\n556\t    from fraud_flags\n557\t    where user_id = ${userId}\n558\t    order by created_at desc\n559\t    limit ${limit}\n560\t  `;\n561\t}\n562\t\n563\tasync function fetchRecentUserQueueEvents(\n564\t  sql: Sql,\n565\t  userId: string,\n566\t  wallet: string,\n567\t  limit: number,\n568\t): Promise<ReadonlyArray<PeekUserQueueEventRow>> {\n569\t  // event_queue has no user_id column; join via JSONB payload identifiers that\n570\t  // every backend writer uses today (`userId`, `user_id`, `wallet`). Bounded by\n571\t  // limit so the admin page never streams the full queue.\n572\t  return sql<Array<PeekUserQueueEventRow>>`\n573\t    select\n574\t      id::text as \"id\",\n575\t      event_type as \"eventType\",\n576\t      status,\n577\t      attempts,\n578\t      max_attempts as \"maxAttempts\",\n579\t      scheduled_at::text as \"scheduledAt\",\n580\t      created_at::text as \"createdAt\",\n581\t      error\n582\t    from event_queue\n583\t    where payload->>'userId' = ${userId}\n584\t       or payload->>'user_id' = ${userId}\n585\t       or payload->>'wallet' = ${wallet}\n586\t    order by created_at desc\n587\t    limit ${limit}\n588\t  `;\n589\t}\n590\t\n591\tasync function fetchSelfReferralIndicator(\n592\t  sql: Sql,\n593\t  userId: string,\n594\t): Promise<{ selfReferral: boolean }> {\n595\t  const [row] = await sql<Array<{ selfReferral: boolean }>>`\n596\t    select exists (\n597\t      select 1\n598\t      from referral_links rl\n599\t      where rl.referrer_user_id = ${userId}\n600\t        and rl.referee_user_id = ${userId}\n601\t    ) as \"selfReferral\"\n602\t  `;\n603\t  return row ?? { selfReferral: false };\n604\t}\n605\t\n606\tfunction computeAttention(input: {\n607\t  recentReferralClaims: ReadonlyArray<PeekReferralClaimRow>;\n608\t  recentUserQueueEvents: ReadonlyArray<PeekUserQueueEventRow>;\n609\t  fraudFlags: ReadonlyArray<PeekFraudFlagRow>;\n610\t  recentCrateDrops: ReadonlyArray<PeekCrateDropRow>;\n611\t  selfReferralRow: { selfReferral: boolean };\n612\t}): PeekUserAttentionFlags {\n613\t  return {\n614\t    failedClaim: input.recentReferralClaims.some(\n615\t      (claim) => claim.status === \"failed\" || claim.status === \"error\",\n616\t    ),\n617\t    deadQueueEvent: input.recentUserQueueEvents.some(\n618\t      (event) => event.status === \"dead\",\n619\t    ),\n620\t    activeFraudFlag: input.fraudFlags.some((flag) => flag.status === \"open\"),\n621\t    pendingSolCratePayout: input.recentCrateDrops.some(\n622\t      (drop) => drop.crateType === \"sol\" && drop.status === \"pending\",\n623\t    ),\n624\t    suspiciousReferralLoop: input.selfReferralRow.selfReferral,\n625\t  };\n626\t}\n627\t"}]},"parent_tool_use_id":null,"session_id":"7d6a4572-ffc4-43a8-900d-a576c5df45f4","uuid":"3297b59f-3d14-4223-8113-c0b620ebbc94","timestamp":"2026-04-25T12:10:33.277Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-peek-user-detail.ts","content":"import type {\n  PeekChallengeAssignmentSummary,\n  PeekCrateDropRow,\n  PeekFraudFlagRow,\n  PeekGameEntryRow,\n  PeekKolRate,\n  PeekLinkedAccountRow,\n  PeekPlayerPoints,\n  PeekPointGrantRow,\n  PeekReferralClaimRow,\n  PeekReferralEarningsSummary,\n  PeekTelegramLinkTokenRow,\n  PeekTransactionRow,\n  PeekUserAttentionFlags,\n  PeekUserDetail,\n  PeekUserQueueEventRow,\n} from \"../../../lib/types/peek\";\nimport { writePeekAuditEvent } from \"../../audit/writer\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_USER_DETAIL_RECENT_LIMIT = 25;\nexport const PEEK_USER_DETAIL_TOKEN_LIMIT = 10;\n\ntype Sql = ReturnType<typeof getSqlClient>;\n\nexport type PeekUserDetailAuditFn = (input: {\n  actorEmail: string;\n  userId: string;\n  route: string | null;\n  requestId: string | null;\n}) => Promise<void>;\n\ntype GetPeekUserDetailOptions = {\n  sql?: Sql;\n  recentLimit?: number;\n  tokenLimit?: number;\n  actorEmail?: string | null;\n  route?: string | null;\n  requestId?: string | null;\n  audit?: PeekUserDetailAuditFn | null;\n};\n\nasync function defaultPeekUserDetailAudit(input: {\n  actorEmail: string;\n  userId: string;\n  route: string | null;\n  requestId: string | null;\n}): Promise<void> {\n  await writePeekAuditEvent({\n    eventType: \"peek.user.view_sensitive\",\n    payload: {\n      actorEmail: input.actorEmail,\n      route: input.route,\n      actionId: \"peek.user.view_sensitive\",\n      resourceType: \"user\",\n      resourceId: input.userId,\n      filterSummary: null,\n      resultCount: 1,\n      requestId: input.requestId,\n      rejectionReason: null,\n      changes: null,\n    },\n  });\n}\n\nexport function formatUserHeading(user: {\n  userId: string;\n  username: string | null;\n}) {\n  return user.username ?? user.userId;\n}\n\nexport async function getPeekUserDetail(\n  userId: string,\n  options: GetPeekUserDetailOptions = {},\n): Promise<PeekUserDetail | null> {\n  const sql = options.sql ?? getSqlClient();\n  const recentLimit = clampPositiveInt(\n    options.recentLimit,\n    PEEK_USER_DETAIL_RECENT_LIMIT,\n  );\n  const tokenLimit = clampPositiveInt(\n    options.tokenLimit,\n    PEEK_USER_DETAIL_TOKEN_LIMIT,\n  );\n\n  // Identity + linked-account telegram view (preserved as queries[0] so the\n  // 303-era listing/detail tests continue to assert the same SQL contract).\n  const [user] = await sql<\n    Array<{\n      userId: string;\n      username: string | null;\n      wallet: string;\n      joinedAt: string;\n      avatarUrl: string | null;\n      heatMultiplier: string;\n      profilePointsBalance: string;\n      referralCode: string | null;\n      referrerUserId: string | null;\n      referrerCode: string | null;\n      refereeCount: number;\n      telegramLinkState: \"active\" | \"none\";\n      linkedAt: string | null;\n      telegramUserId: string | null;\n      telegramUsername: string | null;\n    }>\n  >`\n    select\n      pp.user_id as \"userId\",\n      pp.username as \"username\",\n      pp.wallet as \"wallet\",\n      pp.created_at::text as \"joinedAt\",\n      pp.avatar_url as \"avatarUrl\",\n      pp.heat_multiplier::text as \"heatMultiplier\",\n      pp.points_balance::text as \"profilePointsBalance\",\n      rc.code as \"referralCode\",\n      rl.referrer_user_id as \"referrerUserId\",\n      ref_code.code as \"referrerCode\",\n      (\n        select count(*)::int\n        from referral_links outbound\n        where outbound.referrer_user_id = pp.user_id\n      ) as \"refereeCount\",\n      coalesce(tla.status, 'none') as \"telegramLinkState\",\n      rl.created_at::text as \"linkedAt\",\n      tla.telegram_user_id as \"telegramUserId\",\n      tla.telegram_username as \"telegramUsername\"\n    from player_profiles pp\n    left join referral_codes rc on rc.user_id = pp.user_id\n    left join referral_links rl on rl.referee_user_id = pp.user_id\n    left join referral_codes ref_code on ref_code.user_id = rl.referrer_user_id\n    left join lateral (\n      select\n        status,\n        provider_account_id as telegram_user_id,\n        nullif(metadata_json->>'telegramUsername', '') as telegram_username\n      from linked_accounts\n      where user_id = pp.user_id\n        and provider = 'telegram'\n        and status = 'active'\n      limit 1\n    ) tla on true\n    where pp.user_id = ${userId}\n  `;\n\n  if (!user) {\n    return null;\n  }\n\n  const wallet = user.wallet;\n\n  const [\n    outboundReferees,\n    linkedAccounts,\n    recentTelegramLinkTokens,\n    kolRate,\n    referralEarnings,\n    recentReferralClaims,\n    points,\n    recentPointGrants,\n    recentCrateDrops,\n    challengeSummary,\n    recentGameEntries,\n    recentTransactions,\n    fraudFlags,\n    recentUserQueueEvents,\n    selfReferralRow,\n  ] = await Promise.all([\n    fetchOutboundReferees(sql, userId),\n    fetchLinkedAccounts(sql, userId),\n    fetchRecentTelegramLinkTokens(sql, userId, tokenLimit),\n    fetchKolRate(sql, userId),\n    fetchReferralEarnings(sql, userId),\n    fetchRecentReferralClaims(sql, userId, recentLimit),\n    fetchPlayerPoints(sql, userId),\n    fetchRecentPointGrants(sql, userId, recentLimit),\n    fetchRecentCrateDrops(sql, userId, recentLimit),\n    fetchChallengeSummary(sql, userId),\n    fetchRecentGameEntries(sql, userId, recentLimit),\n    fetchRecentTransactions(sql, userId, recentLimit),\n    fetchFraudFlags(sql, userId, recentLimit),\n    fetchRecentUserQueueEvents(sql, userId, wallet, recentLimit),\n    fetchSelfReferralIndicator(sql, userId),\n  ]);\n\n  const attention = computeAttention({\n    recentReferralClaims,\n    recentUserQueueEvents,\n    fraudFlags,\n    recentCrateDrops,\n    selfReferralRow,\n  });\n\n  // FR-11: emit a `peek.user.view_sensitive` audit event when an authorized\n  // operator opens this user-detail page. The handler is opt-in via\n  // `actorEmail`; an empty actor or an explicit `audit: null` skips emission.\n  // Audit failures are caught here so the page still renders even if the\n  // writer's DB insert fails (the writer logs the underlying error).\n  const audit =\n    options.audit === undefined ? defaultPeekUserDetailAudit : options.audit;\n  if (audit && options.actorEmail) {\n    try {\n      await audit({\n        actorEmail: options.actorEmail,\n        userId,\n        route: options.route ?? null,\n        requestId: options.requestId ?? null,\n      });\n    } catch {\n      // Audit failures must never leak to the caller (FR-11). The writer\n      // already logs server-side; swallow here so the user-detail page still\n      // renders.\n    }\n  }\n\n  return {\n    user: {\n      userId: user.userId,\n      username: user.username,\n      wallet: user.wallet,\n      joinedAt: user.joinedAt,\n      referralCode: user.referralCode,\n      referrerUserId: user.referrerUserId,\n      referrerCode: user.referrerCode,\n      refereeCount: user.refereeCount,\n      telegramUsername: user.telegramUsername,\n      telegramUserId: user.telegramUserId,\n      avatarUrl: user.avatarUrl,\n      heatMultiplier: user.heatMultiplier,\n      profilePointsBalance: user.profilePointsBalance,\n    },\n    inboundReferral: {\n      referrerUserId: user.referrerUserId,\n      referrerCode: user.referrerCode,\n      linkedAt: user.linkedAt,\n    },\n    outboundReferees,\n    telegram: {\n      state: user.telegramLinkState,\n      telegramUserId: user.telegramUserId,\n      telegramUsername: user.telegramUsername,\n    },\n    linkedAccounts,\n    recentTelegramLinkTokens,\n    kolRate,\n    referralEarnings,\n    recentReferralClaims,\n    points,\n    recentPointGrants,\n    recentCrateDrops,\n    challengeSummary,\n    recentGameEntries,\n    recentTransactions,\n    fraudFlags,\n    recentUserQueueEvents,\n    attention,\n  };\n}\n\nfunction clampPositiveInt(value: number | undefined, fallback: number): number {\n  if (typeof value !== \"number\" || !Number.isFinite(value)) return fallback;\n  const floored = Math.floor(value);\n  if (floored <= 0) return 1;\n  return floored;\n}\n\nasync function fetchOutboundReferees(\n  sql: Sql,\n  userId: string,\n): Promise<PeekUserDetail[\"outboundReferees\"]> {\n  return sql<\n    Array<{\n      refereeUserId: string;\n      refereeUsername: string | null;\n      createdAt: string;\n    }>\n  >`\n    select\n      rl.referee_user_id as \"refereeUserId\",\n      pp.username as \"refereeUsername\",\n      rl.created_at::text as \"createdAt\"\n    from referral_links rl\n    left join player_profiles pp on pp.user_id = rl.referee_user_id\n    where rl.referrer_user_id = ${userId}\n    order by rl.created_at desc\n  `;\n}\n\nasync function fetchLinkedAccounts(\n  sql: Sql,\n  userId: string,\n): Promise<ReadonlyArray<PeekLinkedAccountRow>> {\n  return sql<Array<PeekLinkedAccountRow>>`\n    select\n      id::text as \"id\",\n      provider,\n      provider_account_id as \"providerAccountId\",\n      status,\n      nullif(metadata_json->>'telegramUsername', '') as \"telegramUsername\",\n      metadata_json as \"metadataJson\",\n      linked_at::text as \"linkedAt\",\n      updated_at::text as \"updatedAt\"\n    from linked_accounts\n    where user_id = ${userId}\n    order by linked_at desc\n  `;\n}\n\nasync function fetchRecentTelegramLinkTokens(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekTelegramLinkTokenRow>> {\n  return sql<Array<PeekTelegramLinkTokenRow>>`\n    select\n      id::text as \"id\",\n      status,\n      telegram_user_id as \"telegramUserId\",\n      telegram_username as \"telegramUsername\",\n      expires_at::text as \"expiresAt\",\n      redeemed_at::text as \"redeemedAt\",\n      created_at::text as \"createdAt\"\n    from telegram_link_tokens\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchKolRate(\n  sql: Sql,\n  userId: string,\n): Promise<PeekKolRate | null> {\n  const [row] = await sql<\n    Array<{\n      rateBps: number;\n      setBy: string;\n      createdAt: string;\n      updatedAt: string;\n    }>\n  >`\n    select\n      rate_bps as \"rateBps\",\n      set_by as \"setBy\",\n      created_at::text as \"createdAt\",\n      updated_at::text as \"updatedAt\"\n    from referral_kol_rates\n    where user_id = ${userId}\n    limit 1\n  `;\n  return row ?? null;\n}\n\nasync function fetchReferralEarnings(\n  sql: Sql,\n  userId: string,\n): Promise<PeekReferralEarningsSummary> {\n  const [row] = await sql<\n    Array<{\n      earningsCount: number;\n      totalReferrerEarnedLamports: string;\n      totalRefereeRebateLamports: string;\n      lastEarnedAt: string | null;\n    }>\n  >`\n    select\n      count(*)::int as \"earningsCount\",\n      coalesce(sum(referrer_earned_lamports), 0)::text as \"totalReferrerEarnedLamports\",\n      coalesce(sum(referee_rebate_lamports), 0)::text as \"totalRefereeRebateLamports\",\n      max(created_at)::text as \"lastEarnedAt\"\n    from referral_earnings\n    where referrer_user_id = ${userId} or referee_user_id = ${userId}\n  `;\n  return (\n    row ?? {\n      earningsCount: 0,\n      totalReferrerEarnedLamports: \"0\",\n      totalRefereeRebateLamports: \"0\",\n      lastEarnedAt: null,\n    }\n  );\n}\n\nasync function fetchRecentReferralClaims(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekReferralClaimRow>> {\n  return sql<Array<PeekReferralClaimRow>>`\n    select\n      id::text as \"id\",\n      amount_lamports::text as \"amountLamports\",\n      status,\n      retry_count as \"retryCount\",\n      tx_signature as \"txSignature\",\n      error,\n      requested_at::text as \"requestedAt\",\n      processed_at::text as \"processedAt\"\n    from referral_claims\n    where user_id = ${userId}\n    order by requested_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchPlayerPoints(\n  sql: Sql,\n  userId: string,\n): Promise<PeekPlayerPoints> {\n  const [row] = await sql<\n    Array<{\n      balance: string;\n      lifetimeEarned: string;\n      updatedAt: string;\n    }>\n  >`\n    select\n      balance::text as \"balance\",\n      lifetime_earned::text as \"lifetimeEarned\",\n      updated_at::text as \"updatedAt\"\n    from player_points\n    where user_id = ${userId}\n    limit 1\n  `;\n  return (\n    row ?? {\n      balance: \"0\",\n      lifetimeEarned: \"0\",\n      updatedAt: null,\n    }\n  );\n}\n\nasync function fetchRecentPointGrants(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekPointGrantRow>> {\n  return sql<Array<PeekPointGrantRow>>`\n    select\n      id::text as \"id\",\n      source_type as \"sourceType\",\n      source_id as \"sourceId\",\n      amount::text as \"amount\",\n      created_at::text as \"createdAt\"\n    from point_grants\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchRecentCrateDrops(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekCrateDropRow>> {\n  return sql<Array<PeekCrateDropRow>>`\n    select\n      id::text as \"id\",\n      trigger_type as \"triggerType\",\n      trigger_id as \"triggerId\",\n      crate_type as \"crateType\",\n      contents_amount as \"contentsAmount\",\n      status,\n      created_at::text as \"createdAt\",\n      granted_at::text as \"grantedAt\"\n    from crate_drops\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchChallengeSummary(\n  sql: Sql,\n  userId: string,\n): Promise<PeekChallengeAssignmentSummary> {\n  const [row] = await sql<\n    Array<{\n      active: number;\n      completed: number;\n      expired: number;\n      total: number;\n    }>\n  >`\n    select\n      count(*) filter (where status = 'active')::int as \"active\",\n      count(*) filter (where status = 'completed')::int as \"completed\",\n      count(*) filter (where status = 'expired')::int as \"expired\",\n      count(*)::int as \"total\"\n    from challenge_assignments\n    where user_id = ${userId}\n  `;\n  return row ?? { active: 0, completed: 0, expired: 0, total: 0 };\n}\n\nasync function fetchRecentGameEntries(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekGameEntryRow>> {\n  return sql<Array<PeekGameEntryRow>>`\n    select\n      id::text as \"id\",\n      game,\n      round_pda as \"roundPda\",\n      match_id as \"matchId\",\n      amount_lamports::text as \"amountLamports\",\n      side,\n      is_winner as \"isWinner\",\n      payout_lamports::text as \"payoutLamports\",\n      created_at::text as \"createdAt\",\n      settled_at::text as \"settledAt\"\n    from game_entries\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchRecentTransactions(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekTransactionRow>> {\n  return sql<Array<PeekTransactionRow>>`\n    select\n      id::text as \"id\",\n      game,\n      match_id as \"matchId\",\n      tx_type as \"txType\",\n      amount_lamports::text as \"amountLamports\",\n      tx_sig as \"txSig\",\n      created_at::text as \"createdAt\"\n    from transactions\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchFraudFlags(\n  sql: Sql,\n  userId: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekFraudFlagRow>> {\n  return sql<Array<PeekFraudFlagRow>>`\n    select\n      id::text as \"id\",\n      flag_type as \"flagType\",\n      status,\n      related_id as \"relatedId\",\n      created_at::text as \"createdAt\",\n      resolved_at::text as \"resolvedAt\"\n    from fraud_flags\n    where user_id = ${userId}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchRecentUserQueueEvents(\n  sql: Sql,\n  userId: string,\n  wallet: string,\n  limit: number,\n): Promise<ReadonlyArray<PeekUserQueueEventRow>> {\n  // event_queue has no user_id column; join via JSONB payload identifiers that\n  // every backend writer uses today (`userId`, `user_id`, `wallet`). Bounded by\n  // limit so the admin page never streams the full queue.\n  return sql<Array<PeekUserQueueEventRow>>`\n    select\n      id::text as \"id\",\n      event_type as \"eventType\",\n      status,\n      attempts,\n      max_attempts as \"maxAttempts\",\n      scheduled_at::text as \"scheduledAt\",\n      created_at::text as \"createdAt\",\n      error\n    from event_queue\n    where payload->>'userId' = ${userId}\n       or payload->>'user_id' = ${userId}\n       or payload->>'wallet' = ${wallet}\n    order by created_at desc\n    limit ${limit}\n  `;\n}\n\nasync function fetchSelfReferralIndicator(\n  sql: Sql,\n  userId: string,\n): Promise<{ selfReferral: boolean }> {\n  const [row] = await sql<Array<{ selfReferral: boolean }>>`\n    select exists (\n      select 1\n      from referral_links rl\n      where rl.referrer_user_id = ${userId}\n        and rl.referee_user_id = ${userId}\n    ) as \"selfReferral\"\n  `;\n  return row ?? { selfReferral: false };\n}\n\nfunction computeAttention(input: {\n  recentReferralClaims: ReadonlyArray<PeekReferralClaimRow>;\n  recentUserQueueEvents: ReadonlyArray<PeekUserQueueEventRow>;\n  fraudFlags: ReadonlyArray<PeekFraudFlagRow>;\n  recentCrateDrops: ReadonlyArray<PeekCrateDropRow>;\n  selfReferralRow: { selfReferral: boolean };\n}): PeekUserAttentionFlags {\n  return {\n    failedClaim: input.recentReferralClaims.some(\n      (claim) => claim.status === \"failed\" || claim.status === \"error\",\n    ),\n    deadQueueEvent: input.recentUserQueueEvents.some(\n      (event) => event.status === \"dead\",\n    ),\n    activeFraudFlag: input.fraudFlags.some((flag) => flag.status === \"open\"),\n    pendingSolCratePayout: input.recentCrateDrops.some(\n      (drop) => drop.crateType === \"sol\" && drop.status === \"pending\",\n    ),\n    suspiciousReferralLoop: input.selfReferralRow.selfReferral,\n  };\n}\n","numLines":627,"startLine":1,"totalLines":627}}}
