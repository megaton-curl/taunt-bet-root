{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QsN7kHddT4W9ZoHTkYjT11","type":"tool_result","content":"1\timport { describe, expect, it, vi } from \"vitest\";\n2\timport type { Sql } from \"postgres\";\n3\timport {\n4\t  PEEK_USER_DETAIL_RECENT_LIMIT,\n5\t  PEEK_USER_DETAIL_TOKEN_LIMIT,\n6\t  formatUserHeading,\n7\t  getPeekUserDetail,\n8\t  type PeekUserDetailAuditFn,\n9\t} from \"../get-peek-user-detail\";\n10\t\n11\ttype SqlCall = {\n12\t  text: string;\n13\t  values: ReadonlyArray<unknown>;\n14\t};\n15\t\n16\ttype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n17\t\n18\ttype SqlMock = {\n19\t  sql: Sql;\n20\t  calls: ReadonlyArray<SqlCall>;\n21\t};\n22\t\n23\t// Build a SQL mock that returns a sequence of responses, one per call. The\n24\t// query module fires queries[0] (identity) first, then 15 parallel queries via\n25\t// Promise.all in declaration order:\n26\t//   1: outboundReferees\n27\t//   2: linkedAccounts\n28\t//   3: recentTelegramLinkTokens\n29\t//   4: kolRate\n30\t//   5: referralEarnings\n31\t//   6: recentReferralClaims\n32\t//   7: playerPoints\n33\t//   8: recentPointGrants\n34\t//   9: recentCrateDrops\n35\t//   10: challengeSummary\n36\t//   11: recentGameEntries\n37\t//   12: recentTransactions\n38\t//   13: fraudFlags\n39\t//   14: recentUserQueueEvents\n40\t//   15: selfReferralIndicator\n41\tfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n42\t  const calls: SqlCall[] = [];\n43\t  let cursor = 0;\n44\t\n45\t  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n46\t    const text = [...strings].join(\"?\");\n47\t    calls.push({ text, values: [...values] });\n48\t    const next = responses[cursor++];\n49\t    if (next instanceof Error) return Promise.reject(next);\n50\t    return Promise.resolve(next ?? []);\n51\t  };\n52\t\n53\t  const sql = fn as unknown as Sql;\n54\t  return { sql, calls };\n55\t}\n56\t\n57\tconst IDENTITY_ROW = {\n58\t  userId: \"u-1\",\n59\t  username: \"alice\",\n60\t  wallet: \"wallet-1\",\n61\t  joinedAt: \"2026-01-01T00:00:00.000Z\",\n62\t  avatarUrl: \"https://example.com/a.png\",\n63\t  heatMultiplier: \"1.50\",\n64\t  profilePointsBalance: \"100\",\n65\t  referralCode: \"ALICE2026\",\n66\t  referrerUserId: \"u-0\",\n67\t  referrerCode: \"MENTOR\",\n68\t  refereeCount: 3,\n69\t  telegramLinkState: \"active\" as const,\n70\t  linkedAt: \"2026-01-02T00:00:00.000Z\",\n71\t  telegramUserId: \"tg-9001\",\n72\t  telegramUsername: \"alice_tg\",\n73\t};\n74\t\n75\tfunction fullResponses(): ReadonlyArray<ResponseValue> {\n76\t  return [\n77\t    [IDENTITY_ROW],\n78\t    [\n79\t      {\n80\t        refereeUserId: \"u-2\",\n81\t        refereeUsername: \"bob\",\n82\t        createdAt: \"2026-01-03T00:00:00.000Z\",\n83\t      },\n84\t    ],\n85\t    [\n86\t      {\n87\t        id: \"la-1\",\n88\t        provider: \"telegram\",\n89\t        providerAccountId: \"tg-9001\",\n90\t        status: \"active\",\n91\t        telegramUsername: \"alice_tg\",\n92\t        metadataJson: { telegramUsername: \"alice_tg\" },\n93\t        linkedAt: \"2026-01-02T00:00:00.000Z\",\n94\t        updatedAt: \"2026-01-02T00:00:00.000Z\",\n95\t      },\n96\t    ],\n97\t    [\n98\t      {\n99\t        id: \"tlk-1\",\n100\t        status: \"redeemed\",\n101\t        telegramUserId: \"tg-9001\",\n102\t        telegramUsername: \"alice_tg\",\n103\t        expiresAt: \"2026-01-02T01:00:00.000Z\",\n104\t        redeemedAt: \"2026-01-02T00:30:00.000Z\",\n105\t        createdAt: \"2026-01-02T00:00:00.000Z\",\n106\t      },\n107\t    ],\n108\t    [\n109\t      {\n110\t        rateBps: 250,\n111\t        setBy: \"ops@example.com\",\n112\t        createdAt: \"2026-01-04T00:00:00.000Z\",\n113\t        updatedAt: \"2026-01-04T00:00:00.000Z\",\n114\t      },\n115\t    ],\n116\t    [\n117\t      {\n118\t        earningsCount: 7,\n119\t        totalReferrerEarnedLamports: \"12345\",\n120\t        totalRefereeRebateLamports: \"6789\",\n121\t        lastEarnedAt: \"2026-04-20T00:00:00.000Z\",\n122\t      },\n123\t    ],\n124\t    [\n125\t      {\n126\t        id: \"rc-1\",\n127\t        amountLamports: \"1000\",\n128\t        status: \"failed\",\n129\t        retryCount: 3,\n130\t        txSignature: null,\n131\t        error: \"RpcError\",\n132\t        requestedAt: \"2026-04-20T00:00:00.000Z\",\n133\t        processedAt: \"2026-04-20T00:01:00.000Z\",\n134\t      },\n135\t    ],\n136\t    [\n137\t      {\n138\t        balance: \"500\",\n139\t        lifetimeEarned: \"1500\",\n140\t        updatedAt: \"2026-04-24T00:00:00.000Z\",\n141\t      },\n142\t    ],\n143\t    [\n144\t      {\n145\t        id: \"pg-1\",\n146\t        sourceType: \"challenge\",\n147\t        sourceId: \"ch-1\",\n148\t        amount: \"10\",\n149\t        createdAt: \"2026-04-23T00:00:00.000Z\",\n150\t      },\n151\t    ],\n152\t    [\n153\t      {\n154\t        id: \"cd-1\",\n155\t        triggerType: \"level_up\",\n156\t        triggerId: \"lvl-3\",\n157\t        crateType: \"sol\",\n158\t        contentsAmount: \"1000\",\n159\t        status: \"pending\",\n160\t        createdAt: \"2026-04-22T00:00:00.000Z\",\n161\t        grantedAt: null,\n162\t      },\n163\t    ],\n164\t    [{ active: 1, completed: 2, expired: 0, total: 3 }],\n165\t    [\n166\t      {\n167\t        id: \"ge-1\",\n168\t        game: \"flipyou\",\n169\t        roundPda: \"pda-1\",\n170\t        matchId: \"match-1\",\n171\t        amountLamports: \"1000000\",\n172\t        side: \"heads\",\n173\t        isWinner: true,\n174\t        payoutLamports: \"1900000\",\n175\t        createdAt: \"2026-04-21T00:00:00.000Z\",\n176\t        settledAt: \"2026-04-21T00:00:30.000Z\",\n177\t      },\n178\t    ],\n179\t    [\n180\t      {\n181\t        id: \"tx-1\",\n182\t        game: \"flipyou\",\n183\t        matchId: \"match-1\",\n184\t        txType: \"payout\",\n185\t        amountLamports: \"1900000\",\n186\t        txSig: \"sig-1\",\n187\t        createdAt: \"2026-04-21T00:00:30.000Z\",\n188\t      },\n189\t    ],\n190\t    [\n191\t      {\n192\t        id: \"ff-1\",\n193\t        flagType: \"wash_trading\",\n194\t        status: \"open\",\n195\t        relatedId: \"match-1\",\n196\t        createdAt: \"2026-04-20T00:00:00.000Z\",\n197\t        resolvedAt: null,\n198\t      },\n199\t    ],\n200\t    [\n201\t      {\n202\t        id: \"qe-1\",\n203\t        eventType: \"referral_payout\",\n204\t        status: \"dead\",\n205\t        attempts: 5,\n206\t        maxAttempts: 5,\n207\t        scheduledAt: \"2026-04-20T00:00:00.000Z\",\n208\t        createdAt: \"2026-04-20T00:00:00.000Z\",\n209\t        error: \"OnChainError\",\n210\t      },\n211\t    ],\n212\t    [{ selfReferral: false }],\n213\t  ];\n214\t}\n215\t\n216\tfunction sparseResponses(): ReadonlyArray<ResponseValue> {\n217\t  return [\n218\t    // Identity row carries minimum-viable values: nullable identity-add-on\n219\t    // fields default to null; the user still has a row in player_profiles.\n220\t    [\n221\t      {\n222\t        userId: \"u-1\",\n223\t        username: null,\n224\t        wallet: \"wallet-sparse\",\n225\t        joinedAt: \"2026-01-01T00:00:00.000Z\",\n226\t        avatarUrl: null,\n227\t        heatMultiplier: \"1.00\",\n228\t        profilePointsBalance: \"0\",\n229\t        referralCode: null,\n230\t        referrerUserId: null,\n231\t        referrerCode: null,\n232\t        refereeCount: 0,\n233\t        telegramLinkState: \"none\",\n234\t        linkedAt: null,\n235\t        telegramUserId: null,\n236\t        telegramUsername: null,\n237\t      },\n238\t    ],\n239\t    [], // outboundReferees\n240\t    [], // linkedAccounts\n241\t    [], // recentTelegramLinkTokens\n242\t    [], // kolRate (no row)\n243\t    [], // referralEarnings (no aggregate row — fallback to defaults)\n244\t    [], // recentReferralClaims\n245\t    [], // playerPoints (no row — fallback to defaults)\n246\t    [], // recentPointGrants\n247\t    [], // recentCrateDrops\n248\t    [], // challengeSummary (no row — fallback to zeros)\n249\t    [], // recentGameEntries\n250\t    [], // recentTransactions\n251\t    [], // fraudFlags\n252\t    [], // recentUserQueueEvents\n253\t    [], // selfReferralIndicator (no row — fallback to false)\n254\t  ];\n255\t}\n256\t\n257\tdescribe(\"formatUserHeading\", () => {\n258\t  it(\"prefers username over user id in the detail header\", () => {\n259\t    expect(formatUserHeading({ userId: \"u_1\", username: \"alice\" })).toBe(\"alice\");\n260\t    expect(formatUserHeading({ userId: \"u_2\", username: null })).toBe(\"u_2\");\n261\t  });\n262\t});\n263\t\n264\tdescribe(\"getPeekUserDetail\", () => {\n265\t  it(\"user not found: returns null after only the identity query, with no parallel calls\", async () => {\n266\t    const mock = createSqlMock([[]]);\n267\t\n268\t    const detail = await getPeekUserDetail(\"missing\", {\n269\t      sql: mock.sql,\n270\t      audit: null,\n271\t    });\n272\t\n273\t    expect(detail).toBeNull();\n274\t    expect(mock.calls).toHaveLength(1);\n275\t    expect(mock.calls[0].text).toContain(\"from player_profiles pp\");\n276\t  });\n277\t\n278\t  it(\"populated: shapes the full FR-6 user detail across every section\", async () => {\n279\t    const mock = createSqlMock(fullResponses());\n280\t\n281\t    const detail = await getPeekUserDetail(\"u-1\", {\n282\t      sql: mock.sql,\n283\t      audit: null,\n284\t    });\n285\t\n286\t    expect(detail).not.toBeNull();\n287\t    if (!detail) throw new Error(\"detail\");\n288\t\n289\t    // Identity (with the FR-6 profile-identity additions)\n290\t    expect(detail.user.userId).toBe(\"u-1\");\n291\t    expect(detail.user.username).toBe(\"alice\");\n292\t    expect(detail.user.wallet).toBe(\"wallet-1\");\n293\t    expect(detail.user.avatarUrl).toBe(\"https://example.com/a.png\");\n294\t    expect(detail.user.heatMultiplier).toBe(\"1.50\");\n295\t    expect(detail.user.profilePointsBalance).toBe(\"100\");\n296\t\n297\t    // Inbound referral + telegram envelope\n298\t    expect(detail.inboundReferral.referrerUserId).toBe(\"u-0\");\n299\t    expect(detail.inboundReferral.referrerCode).toBe(\"MENTOR\");\n300\t    expect(detail.telegram.state).toBe(\"active\");\n301\t    expect(detail.telegram.telegramUsername).toBe(\"alice_tg\");\n302\t\n303\t    // Per-section aggregates\n304\t    expect(detail.outboundReferees).toHaveLength(1);\n305\t    expect(detail.linkedAccounts).toHaveLength(1);\n306\t    expect(detail.recentTelegramLinkTokens).toHaveLength(1);\n307\t    expect(detail.kolRate?.rateBps).toBe(250);\n308\t    expect(detail.referralEarnings.earningsCount).toBe(7);\n309\t    expect(detail.referralEarnings.totalReferrerEarnedLamports).toBe(\"12345\");\n310\t    expect(detail.recentReferralClaims).toHaveLength(1);\n311\t    expect(detail.points.balance).toBe(\"500\");\n312\t    expect(detail.points.lifetimeEarned).toBe(\"1500\");\n313\t    expect(detail.recentPointGrants).toHaveLength(1);\n314\t    expect(detail.recentCrateDrops).toHaveLength(1);\n315\t    expect(detail.challengeSummary.total).toBe(3);\n316\t    expect(detail.recentGameEntries).toHaveLength(1);\n317\t    expect(detail.recentTransactions).toHaveLength(1);\n318\t    expect(detail.fraudFlags).toHaveLength(1);\n319\t    expect(detail.recentUserQueueEvents).toHaveLength(1);\n320\t\n321\t    // Computed attention flags surface every populated risk signal.\n322\t    expect(detail.attention.failedClaim).toBe(true); // status='failed'\n323\t    expect(detail.attention.deadQueueEvent).toBe(true); // status='dead'\n324\t    expect(detail.attention.activeFraudFlag).toBe(true); // status='open'\n325\t    expect(detail.attention.pendingSolCratePayout).toBe(true); // crateType='sol' & status='pending'\n326\t    expect(detail.attention.suspiciousReferralLoop).toBe(false); // selfReferral row was false\n327\t\n328\t    // 1 identity + 15 parallel = 16 SQL calls total.\n329\t    expect(mock.calls).toHaveLength(16);\n330\t  });\n331\t\n332\t  it(\"populated (suspicious self-referral): surfaces the loop attention flag from the EXISTS row\", async () => {\n333\t    const responses = [...fullResponses()];\n334\t    // Replace the last (selfReferralIndicator) row with selfReferral=true and\n335\t    // strip the dead/failed/open signals so only the loop flag should fire.\n336\t    responses[15] = [{ selfReferral: true }];\n337\t    responses[6] = [\n338\t      {\n339\t        id: \"rc-2\",\n340\t        amountLamports: \"1000\",\n341\t        status: \"paid\",\n342\t        retryCount: 0,\n343\t        txSignature: \"sig-paid\",\n344\t        error: null,\n345\t        requestedAt: \"2026-04-20T00:00:00.000Z\",\n346\t        processedAt: \"2026-04-20T00:01:00.000Z\",\n347\t      },\n348\t    ];\n349\t    responses[9] = [\n350\t      {\n351\t        id: \"cd-1\",\n352\t        triggerType: \"level_up\",\n353\t        triggerId: \"lvl-3\",\n354\t        crateType: \"sol\",\n355\t        contentsAmount: \"1000\",\n356\t        status: \"granted\",\n357\t        createdAt: \"2026-04-22T00:00:00.000Z\",\n358\t        grantedAt: \"2026-04-22T00:00:30.000Z\",\n359\t      },\n360\t    ];\n361\t    responses[13] = [\n362\t      {\n363\t        id: \"ff-1\",\n364\t        flagType: \"wash_trading\",\n365\t        status: \"dismissed\",\n366\t        relatedId: \"match-1\",\n367\t        createdAt: \"2026-04-20T00:00:00.000Z\",\n368\t        resolvedAt: \"2026-04-20T01:00:00.000Z\",\n369\t      },\n370\t    ];\n371\t    responses[14] = [\n372\t      {\n373\t        id: \"qe-1\",\n374\t        eventType: \"referral_payout\",\n375\t        status: \"processed\",\n376\t        attempts: 1,\n377\t        maxAttempts: 5,\n378\t        scheduledAt: \"2026-04-20T00:00:00.000Z\",\n379\t        createdAt: \"2026-04-20T00:00:00.000Z\",\n380\t        error: null,\n381\t      },\n382\t    ];\n383\t\n384\t    const mock = createSqlMock(responses);\n385\t\n386\t    const detail = await getPeekUserDetail(\"u-1\", {\n387\t      sql: mock.sql,\n388\t      audit: null,\n389\t    });\n390\t\n391\t    expect(detail?.attention.suspiciousReferralLoop).toBe(true);\n392\t    expect(detail?.attention.failedClaim).toBe(false);\n393\t    expect(detail?.attention.deadQueueEvent).toBe(false);\n394\t    expect(detail?.attention.activeFraudFlag).toBe(false);\n395\t    expect(detail?.attention.pendingSolCratePayout).toBe(false);\n396\t  });\n397\t\n398\t  it(\"sparse: every parallel section returns []; defaults still produce a renderable view model\", async () => {\n399\t    const mock = createSqlMock(sparseResponses());\n400\t\n401\t    const detail = await getPeekUserDetail(\"u-1\", {\n402\t      sql: mock.sql,\n403\t      audit: null,\n404\t    });\n405\t\n406\t    expect(detail).not.toBeNull();\n407\t    if (!detail) throw new Error(\"detail\");\n408\t\n409\t    // Empty arrays for every list section.\n410\t    expect(detail.outboundReferees).toEqual([]);\n411\t    expect(detail.linkedAccounts).toEqual([]);\n412\t    expect(detail.recentTelegramLinkTokens).toEqual([]);\n413\t    expect(detail.recentReferralClaims).toEqual([]);\n414\t    expect(detail.recentPointGrants).toEqual([]);\n415\t    expect(detail.recentCrateDrops).toEqual([]);\n416\t    expect(detail.recentGameEntries).toEqual([]);\n417\t    expect(detail.recentTransactions).toEqual([]);\n418\t    expect(detail.fraudFlags).toEqual([]);\n419\t    expect(detail.recentUserQueueEvents).toEqual([]);\n420\t\n421\t    // Defaults from missing-row fallbacks.\n422\t    expect(detail.kolRate).toBeNull();\n423\t    expect(detail.referralEarnings).toEqual({\n424\t      earningsCount: 0,\n425\t      totalReferrerEarnedLamports: \"0\",\n426\t      totalRefereeRebateLamports: \"0\",\n427\t      lastEarnedAt: null,\n428\t    });\n429\t    expect(detail.points).toEqual({\n430\t      balance: \"0\",\n431\t      lifetimeEarned: \"0\",\n432\t      updatedAt: null,\n433\t    });\n434\t    expect(detail.challengeSummary).toEqual({\n435\t      active: 0,\n436\t      completed: 0,\n437\t      expired: 0,\n438\t      total: 0,\n439\t    });\n440\t\n441\t    // No risk signals = attention strip stays clean.\n442\t    expect(detail.attention).toEqual({\n443\t      failedClaim: false,\n444\t      deadQueueEvent: false,\n445\t      activeFraudFlag: false,\n446\t      pendingSolCratePayout: false,\n447\t      suspiciousReferralLoop: false,\n448\t    });\n449\t  });\n450\t\n451\t  it(\"bounded: every recent-list query carries the configured recentLimit / tokenLimit\", async () => {\n452\t    const mock = createSqlMock(fullResponses());\n453\t\n454\t    await getPeekUserDetail(\"u-1\", {\n455\t      sql: mock.sql,\n456\t      audit: null,\n457\t      recentLimit: 7,\n458\t      tokenLimit: 4,\n459\t    });\n460\t\n461\t    // Token-limit binding is on the recentTelegramLinkTokens query (call #3).\n462\t    expect(mock.calls[3].text).toContain(\"from telegram_link_tokens\");\n463\t    expect(mock.calls[3].values).toContain(4);\n464\t\n465\t    // recentLimit binding lives on every list query that uses it. Spot-check\n466\t    // the user-bound bigger ones.\n467\t    const checkLimit = (callIdx: number, fragment: string) => {\n468\t      expect(mock.calls[callIdx].text).toContain(fragment);\n469\t      expect(mock.calls[callIdx].values).toContain(7);\n470\t    };\n471\t    checkLimit(6, \"from referral_claims\"); // recentReferralClaims\n472\t    checkLimit(8, \"from point_grants\"); // recentPointGrants\n473\t    checkLimit(9, \"from crate_drops\"); // recentCrateDrops\n474\t    checkLimit(11, \"from game_entries\"); // recentGameEntries\n475\t    checkLimit(12, \"from transactions\"); // recentTransactions\n476\t    checkLimit(13, \"from fraud_flags\"); // fraudFlags\n477\t    checkLimit(14, \"from event_queue\"); // recentUserQueueEvents\n478\t  });\n479\t\n480\t  it(\"bounded: clamps non-positive / fractional limits to safe defaults (>= 1)\", async () => {\n481\t    const mock = createSqlMock(fullResponses());\n482\t\n483\t    await getPeekUserDetail(\"u-1\", {\n484\t      sql: mock.sql,\n485\t      audit: null,\n486\t      recentLimit: -5, // clamps up to 1\n487\t      tokenLimit: 2.7, // floors to 2\n488\t    });\n489\t\n490\t    // tokenLimit floored to 2.\n491\t    expect(mock.calls[3].values).toContain(2);\n492\t    // recentLimit clamped up to 1.\n493\t    expect(mock.calls[6].values).toContain(1);\n494\t  });\n495\t\n496\t  it(\"bounded: omits limit overrides → defaults to PEEK_USER_DETAIL_RECENT_LIMIT / PEEK_USER_DETAIL_TOKEN_LIMIT\", async () => {\n497\t    const mock = createSqlMock(fullResponses());\n498\t\n499\t    await getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null });\n500\t\n501\t    expect(mock.calls[3].values).toContain(PEEK_USER_DETAIL_TOKEN_LIMIT);\n502\t    expect(mock.calls[6].values).toContain(PEEK_USER_DETAIL_RECENT_LIMIT);\n503\t  });\n504\t\n505\t  it(\"queue events: payload-keyed lookup binds both userId and wallet so backend writers all match\", async () => {\n506\t    const mock = createSqlMock(fullResponses());\n507\t\n508\t    await getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null });\n509\t\n510\t    const queueCall = mock.calls[14];\n511\t    expect(queueCall.text).toContain(\"from event_queue\");\n512\t    expect(queueCall.text).toContain(\"payload->>'userId'\");\n513\t    expect(queueCall.text).toContain(\"payload->>'user_id'\");\n514\t    expect(queueCall.text).toContain(\"payload->>'wallet'\");\n515\t    // Bound values include the userId + wallet from the identity row.\n516\t    expect(queueCall.values).toContain(\"u-1\");\n517\t    expect(queueCall.values).toContain(\"wallet-1\");\n518\t  });\n519\t\n520\t  it(\"audit: emits peek.user.view_sensitive once when actorEmail is provided\", async () => {\n521\t    const mock = createSqlMock(fullResponses());\n522\t    const audit = vi.fn<PeekUserDetailAuditFn>().mockResolvedValue(undefined);\n523\t\n524\t    const detail = await getPeekUserDetail(\"u-1\", {\n525\t      sql: mock.sql,\n526\t      audit,\n527\t      actorEmail: \"ops@example.com\",\n528\t      route: \"/users/u-1\",\n529\t      requestId: \"req-42\",\n530\t    });\n531\t\n532\t    expect(detail).not.toBeNull();\n533\t    expect(audit).toHaveBeenCalledTimes(1);\n534\t    expect(audit).toHaveBeenCalledWith({\n535\t      actorEmail: \"ops@example.com\",\n536\t      userId: \"u-1\",\n537\t      route: \"/users/u-1\",\n538\t      requestId: \"req-42\",\n539\t    });\n540\t  });\n541\t\n542\t  it(\"audit: skips emission when actorEmail is missing (unauthenticated path)\", async () => {\n543\t    const mock = createSqlMock(fullResponses());\n544\t    const audit = vi.fn<PeekUserDetailAuditFn>().mockResolvedValue(undefined);\n545\t\n546\t    await getPeekUserDetail(\"u-1\", {\n547\t      sql: mock.sql,\n548\t      audit,\n549\t      // no actorEmail\n550\t    });\n551\t\n552\t    expect(audit).not.toHaveBeenCalled();\n553\t  });\n554\t\n555\t  it(\"audit: skips emission when audit is explicitly null (test path)\", async () => {\n556\t    const mock = createSqlMock(fullResponses());\n557\t\n558\t    const detail = await getPeekUserDetail(\"u-1\", {\n559\t      sql: mock.sql,\n560\t      audit: null,\n561\t      actorEmail: \"ops@example.com\",\n562\t    });\n563\t\n564\t    expect(detail).not.toBeNull();\n565\t    // No audit handler was invoked; identity SQL was. Just verify the path\n566\t    // didn't throw.\n567\t  });\n568\t\n569\t  it(\"audit: skips emission when the user is not found, regardless of actor\", async () => {\n570\t    const mock = createSqlMock([[]]);\n571\t    const audit = vi.fn<PeekUserDetailAuditFn>().mockResolvedValue(undefined);\n572\t\n573\t    const detail = await getPeekUserDetail(\"ghost\", {\n574\t      sql: mock.sql,\n575\t      audit,\n576\t      actorEmail: \"ops@example.com\",\n577\t      route: \"/users/ghost\",\n578\t    });\n579\t\n580\t    expect(detail).toBeNull();\n581\t    expect(audit).not.toHaveBeenCalled();\n582\t  });\n583\t\n584\t  it(\"audit: a thrown audit handler does not break the user-detail render\", async () => {\n585\t    const mock = createSqlMock(fullResponses());\n586\t    const audit = vi\n587\t      .fn<PeekUserDetailAuditFn>()\n588\t      .mockRejectedValue(new Error(\"audit insert failed\"));\n589\t\n590\t    const detail = await getPeekUserDetail(\"u-1\", {\n591\t      sql: mock.sql,\n592\t      audit,\n593\t      actorEmail: \"ops@example.com\",\n594\t    });\n595\t\n596\t    expect(detail).not.toBeNull();\n597\t    expect(audit).toHaveBeenCalledTimes(1);\n598\t  });\n599\t\n600\t  it(\"load-error: a rejected non-identity query propagates so the page can render an alert state\", async () => {\n601\t    const responses = [...fullResponses()];\n602\t    responses[5] = new Error(\"connection refused\"); // referralEarnings query\n603\t    const mock = createSqlMock(responses);\n604\t\n605\t    await expect(\n606\t      getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null }),\n607\t    ).rejects.toThrowError(\"connection refused\");\n608\t  });\n609\t\n610\t  it(\"identity SQL: still preserves the 303-era linked_accounts join contract\", async () => {\n611\t    const mock = createSqlMock(fullResponses());\n612\t\n613\t    await getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null });\n614\t\n615\t    const identitySql = mock.calls[0].text;\n616\t    expect(identitySql).toContain(\"from player_profiles pp\");\n617\t    expect(identitySql).toContain(\"from linked_accounts\");\n618\t    expect(identitySql).toContain(\"provider = 'telegram'\");\n619\t    expect(identitySql).toContain(\"status = 'active'\");\n620\t    expect(identitySql).not.toContain(\"from telegram_link_tokens\");\n621\t  });\n622\t});\n623\t"}]},"parent_tool_use_id":null,"session_id":"7d6a4572-ffc4-43a8-900d-a576c5df45f4","uuid":"5cf81475-40c8-4c2a-a691-da8f53d3a583","timestamp":"2026-04-25T12:11:02.347Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/__tests__/get-peek-user-detail.test.ts","content":"import { describe, expect, it, vi } from \"vitest\";\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_USER_DETAIL_RECENT_LIMIT,\n  PEEK_USER_DETAIL_TOKEN_LIMIT,\n  formatUserHeading,\n  getPeekUserDetail,\n  type PeekUserDetailAuditFn,\n} from \"../get-peek-user-detail\";\n\ntype SqlCall = {\n  text: string;\n  values: ReadonlyArray<unknown>;\n};\n\ntype ResponseValue = ReadonlyArray<Record<string, unknown>> | Error;\n\ntype SqlMock = {\n  sql: Sql;\n  calls: ReadonlyArray<SqlCall>;\n};\n\n// Build a SQL mock that returns a sequence of responses, one per call. The\n// query module fires queries[0] (identity) first, then 15 parallel queries via\n// Promise.all in declaration order:\n//   1: outboundReferees\n//   2: linkedAccounts\n//   3: recentTelegramLinkTokens\n//   4: kolRate\n//   5: referralEarnings\n//   6: recentReferralClaims\n//   7: playerPoints\n//   8: recentPointGrants\n//   9: recentCrateDrops\n//   10: challengeSummary\n//   11: recentGameEntries\n//   12: recentTransactions\n//   13: fraudFlags\n//   14: recentUserQueueEvents\n//   15: selfReferralIndicator\nfunction createSqlMock(responses: ReadonlyArray<ResponseValue>): SqlMock {\n  const calls: SqlCall[] = [];\n  let cursor = 0;\n\n  const fn = (strings: TemplateStringsArray, ...values: unknown[]) => {\n    const text = [...strings].join(\"?\");\n    calls.push({ text, values: [...values] });\n    const next = responses[cursor++];\n    if (next instanceof Error) return Promise.reject(next);\n    return Promise.resolve(next ?? []);\n  };\n\n  const sql = fn as unknown as Sql;\n  return { sql, calls };\n}\n\nconst IDENTITY_ROW = {\n  userId: \"u-1\",\n  username: \"alice\",\n  wallet: \"wallet-1\",\n  joinedAt: \"2026-01-01T00:00:00.000Z\",\n  avatarUrl: \"https://example.com/a.png\",\n  heatMultiplier: \"1.50\",\n  profilePointsBalance: \"100\",\n  referralCode: \"ALICE2026\",\n  referrerUserId: \"u-0\",\n  referrerCode: \"MENTOR\",\n  refereeCount: 3,\n  telegramLinkState: \"active\" as const,\n  linkedAt: \"2026-01-02T00:00:00.000Z\",\n  telegramUserId: \"tg-9001\",\n  telegramUsername: \"alice_tg\",\n};\n\nfunction fullResponses(): ReadonlyArray<ResponseValue> {\n  return [\n    [IDENTITY_ROW],\n    [\n      {\n        refereeUserId: \"u-2\",\n        refereeUsername: \"bob\",\n        createdAt: \"2026-01-03T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"la-1\",\n        provider: \"telegram\",\n        providerAccountId: \"tg-9001\",\n        status: \"active\",\n        telegramUsername: \"alice_tg\",\n        metadataJson: { telegramUsername: \"alice_tg\" },\n        linkedAt: \"2026-01-02T00:00:00.000Z\",\n        updatedAt: \"2026-01-02T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"tlk-1\",\n        status: \"redeemed\",\n        telegramUserId: \"tg-9001\",\n        telegramUsername: \"alice_tg\",\n        expiresAt: \"2026-01-02T01:00:00.000Z\",\n        redeemedAt: \"2026-01-02T00:30:00.000Z\",\n        createdAt: \"2026-01-02T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        rateBps: 250,\n        setBy: \"ops@example.com\",\n        createdAt: \"2026-01-04T00:00:00.000Z\",\n        updatedAt: \"2026-01-04T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        earningsCount: 7,\n        totalReferrerEarnedLamports: \"12345\",\n        totalRefereeRebateLamports: \"6789\",\n        lastEarnedAt: \"2026-04-20T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"rc-1\",\n        amountLamports: \"1000\",\n        status: \"failed\",\n        retryCount: 3,\n        txSignature: null,\n        error: \"RpcError\",\n        requestedAt: \"2026-04-20T00:00:00.000Z\",\n        processedAt: \"2026-04-20T00:01:00.000Z\",\n      },\n    ],\n    [\n      {\n        balance: \"500\",\n        lifetimeEarned: \"1500\",\n        updatedAt: \"2026-04-24T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"pg-1\",\n        sourceType: \"challenge\",\n        sourceId: \"ch-1\",\n        amount: \"10\",\n        createdAt: \"2026-04-23T00:00:00.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"cd-1\",\n        triggerType: \"level_up\",\n        triggerId: \"lvl-3\",\n        crateType: \"sol\",\n        contentsAmount: \"1000\",\n        status: \"pending\",\n        createdAt: \"2026-04-22T00:00:00.000Z\",\n        grantedAt: null,\n      },\n    ],\n    [{ active: 1, completed: 2, expired: 0, total: 3 }],\n    [\n      {\n        id: \"ge-1\",\n        game: \"flipyou\",\n        roundPda: \"pda-1\",\n        matchId: \"match-1\",\n        amountLamports: \"1000000\",\n        side: \"heads\",\n        isWinner: true,\n        payoutLamports: \"1900000\",\n        createdAt: \"2026-04-21T00:00:00.000Z\",\n        settledAt: \"2026-04-21T00:00:30.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"tx-1\",\n        game: \"flipyou\",\n        matchId: \"match-1\",\n        txType: \"payout\",\n        amountLamports: \"1900000\",\n        txSig: \"sig-1\",\n        createdAt: \"2026-04-21T00:00:30.000Z\",\n      },\n    ],\n    [\n      {\n        id: \"ff-1\",\n        flagType: \"wash_trading\",\n        status: \"open\",\n        relatedId: \"match-1\",\n        createdAt: \"2026-04-20T00:00:00.000Z\",\n        resolvedAt: null,\n      },\n    ],\n    [\n      {\n        id: \"qe-1\",\n        eventType: \"referral_payout\",\n        status: \"dead\",\n        attempts: 5,\n        maxAttempts: 5,\n        scheduledAt: \"2026-04-20T00:00:00.000Z\",\n        createdAt: \"2026-04-20T00:00:00.000Z\",\n        error: \"OnChainError\",\n      },\n    ],\n    [{ selfReferral: false }],\n  ];\n}\n\nfunction sparseResponses(): ReadonlyArray<ResponseValue> {\n  return [\n    // Identity row carries minimum-viable values: nullable identity-add-on\n    // fields default to null; the user still has a row in player_profiles.\n    [\n      {\n        userId: \"u-1\",\n        username: null,\n        wallet: \"wallet-sparse\",\n        joinedAt: \"2026-01-01T00:00:00.000Z\",\n        avatarUrl: null,\n        heatMultiplier: \"1.00\",\n        profilePointsBalance: \"0\",\n        referralCode: null,\n        referrerUserId: null,\n        referrerCode: null,\n        refereeCount: 0,\n        telegramLinkState: \"none\",\n        linkedAt: null,\n        telegramUserId: null,\n        telegramUsername: null,\n      },\n    ],\n    [], // outboundReferees\n    [], // linkedAccounts\n    [], // recentTelegramLinkTokens\n    [], // kolRate (no row)\n    [], // referralEarnings (no aggregate row — fallback to defaults)\n    [], // recentReferralClaims\n    [], // playerPoints (no row — fallback to defaults)\n    [], // recentPointGrants\n    [], // recentCrateDrops\n    [], // challengeSummary (no row — fallback to zeros)\n    [], // recentGameEntries\n    [], // recentTransactions\n    [], // fraudFlags\n    [], // recentUserQueueEvents\n    [], // selfReferralIndicator (no row — fallback to false)\n  ];\n}\n\ndescribe(\"formatUserHeading\", () => {\n  it(\"prefers username over user id in the detail header\", () => {\n    expect(formatUserHeading({ userId: \"u_1\", username: \"alice\" })).toBe(\"alice\");\n    expect(formatUserHeading({ userId: \"u_2\", username: null })).toBe(\"u_2\");\n  });\n});\n\ndescribe(\"getPeekUserDetail\", () => {\n  it(\"user not found: returns null after only the identity query, with no parallel calls\", async () => {\n    const mock = createSqlMock([[]]);\n\n    const detail = await getPeekUserDetail(\"missing\", {\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(detail).toBeNull();\n    expect(mock.calls).toHaveLength(1);\n    expect(mock.calls[0].text).toContain(\"from player_profiles pp\");\n  });\n\n  it(\"populated: shapes the full FR-6 user detail across every section\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    const detail = await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(detail).not.toBeNull();\n    if (!detail) throw new Error(\"detail\");\n\n    // Identity (with the FR-6 profile-identity additions)\n    expect(detail.user.userId).toBe(\"u-1\");\n    expect(detail.user.username).toBe(\"alice\");\n    expect(detail.user.wallet).toBe(\"wallet-1\");\n    expect(detail.user.avatarUrl).toBe(\"https://example.com/a.png\");\n    expect(detail.user.heatMultiplier).toBe(\"1.50\");\n    expect(detail.user.profilePointsBalance).toBe(\"100\");\n\n    // Inbound referral + telegram envelope\n    expect(detail.inboundReferral.referrerUserId).toBe(\"u-0\");\n    expect(detail.inboundReferral.referrerCode).toBe(\"MENTOR\");\n    expect(detail.telegram.state).toBe(\"active\");\n    expect(detail.telegram.telegramUsername).toBe(\"alice_tg\");\n\n    // Per-section aggregates\n    expect(detail.outboundReferees).toHaveLength(1);\n    expect(detail.linkedAccounts).toHaveLength(1);\n    expect(detail.recentTelegramLinkTokens).toHaveLength(1);\n    expect(detail.kolRate?.rateBps).toBe(250);\n    expect(detail.referralEarnings.earningsCount).toBe(7);\n    expect(detail.referralEarnings.totalReferrerEarnedLamports).toBe(\"12345\");\n    expect(detail.recentReferralClaims).toHaveLength(1);\n    expect(detail.points.balance).toBe(\"500\");\n    expect(detail.points.lifetimeEarned).toBe(\"1500\");\n    expect(detail.recentPointGrants).toHaveLength(1);\n    expect(detail.recentCrateDrops).toHaveLength(1);\n    expect(detail.challengeSummary.total).toBe(3);\n    expect(detail.recentGameEntries).toHaveLength(1);\n    expect(detail.recentTransactions).toHaveLength(1);\n    expect(detail.fraudFlags).toHaveLength(1);\n    expect(detail.recentUserQueueEvents).toHaveLength(1);\n\n    // Computed attention flags surface every populated risk signal.\n    expect(detail.attention.failedClaim).toBe(true); // status='failed'\n    expect(detail.attention.deadQueueEvent).toBe(true); // status='dead'\n    expect(detail.attention.activeFraudFlag).toBe(true); // status='open'\n    expect(detail.attention.pendingSolCratePayout).toBe(true); // crateType='sol' & status='pending'\n    expect(detail.attention.suspiciousReferralLoop).toBe(false); // selfReferral row was false\n\n    // 1 identity + 15 parallel = 16 SQL calls total.\n    expect(mock.calls).toHaveLength(16);\n  });\n\n  it(\"populated (suspicious self-referral): surfaces the loop attention flag from the EXISTS row\", async () => {\n    const responses = [...fullResponses()];\n    // Replace the last (selfReferralIndicator) row with selfReferral=true and\n    // strip the dead/failed/open signals so only the loop flag should fire.\n    responses[15] = [{ selfReferral: true }];\n    responses[6] = [\n      {\n        id: \"rc-2\",\n        amountLamports: \"1000\",\n        status: \"paid\",\n        retryCount: 0,\n        txSignature: \"sig-paid\",\n        error: null,\n        requestedAt: \"2026-04-20T00:00:00.000Z\",\n        processedAt: \"2026-04-20T00:01:00.000Z\",\n      },\n    ];\n    responses[9] = [\n      {\n        id: \"cd-1\",\n        triggerType: \"level_up\",\n        triggerId: \"lvl-3\",\n        crateType: \"sol\",\n        contentsAmount: \"1000\",\n        status: \"granted\",\n        createdAt: \"2026-04-22T00:00:00.000Z\",\n        grantedAt: \"2026-04-22T00:00:30.000Z\",\n      },\n    ];\n    responses[13] = [\n      {\n        id: \"ff-1\",\n        flagType: \"wash_trading\",\n        status: \"dismissed\",\n        relatedId: \"match-1\",\n        createdAt: \"2026-04-20T00:00:00.000Z\",\n        resolvedAt: \"2026-04-20T01:00:00.000Z\",\n      },\n    ];\n    responses[14] = [\n      {\n        id: \"qe-1\",\n        eventType: \"referral_payout\",\n        status: \"processed\",\n        attempts: 1,\n        maxAttempts: 5,\n        scheduledAt: \"2026-04-20T00:00:00.000Z\",\n        createdAt: \"2026-04-20T00:00:00.000Z\",\n        error: null,\n      },\n    ];\n\n    const mock = createSqlMock(responses);\n\n    const detail = await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(detail?.attention.suspiciousReferralLoop).toBe(true);\n    expect(detail?.attention.failedClaim).toBe(false);\n    expect(detail?.attention.deadQueueEvent).toBe(false);\n    expect(detail?.attention.activeFraudFlag).toBe(false);\n    expect(detail?.attention.pendingSolCratePayout).toBe(false);\n  });\n\n  it(\"sparse: every parallel section returns []; defaults still produce a renderable view model\", async () => {\n    const mock = createSqlMock(sparseResponses());\n\n    const detail = await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit: null,\n    });\n\n    expect(detail).not.toBeNull();\n    if (!detail) throw new Error(\"detail\");\n\n    // Empty arrays for every list section.\n    expect(detail.outboundReferees).toEqual([]);\n    expect(detail.linkedAccounts).toEqual([]);\n    expect(detail.recentTelegramLinkTokens).toEqual([]);\n    expect(detail.recentReferralClaims).toEqual([]);\n    expect(detail.recentPointGrants).toEqual([]);\n    expect(detail.recentCrateDrops).toEqual([]);\n    expect(detail.recentGameEntries).toEqual([]);\n    expect(detail.recentTransactions).toEqual([]);\n    expect(detail.fraudFlags).toEqual([]);\n    expect(detail.recentUserQueueEvents).toEqual([]);\n\n    // Defaults from missing-row fallbacks.\n    expect(detail.kolRate).toBeNull();\n    expect(detail.referralEarnings).toEqual({\n      earningsCount: 0,\n      totalReferrerEarnedLamports: \"0\",\n      totalRefereeRebateLamports: \"0\",\n      lastEarnedAt: null,\n    });\n    expect(detail.points).toEqual({\n      balance: \"0\",\n      lifetimeEarned: \"0\",\n      updatedAt: null,\n    });\n    expect(detail.challengeSummary).toEqual({\n      active: 0,\n      completed: 0,\n      expired: 0,\n      total: 0,\n    });\n\n    // No risk signals = attention strip stays clean.\n    expect(detail.attention).toEqual({\n      failedClaim: false,\n      deadQueueEvent: false,\n      activeFraudFlag: false,\n      pendingSolCratePayout: false,\n      suspiciousReferralLoop: false,\n    });\n  });\n\n  it(\"bounded: every recent-list query carries the configured recentLimit / tokenLimit\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit: null,\n      recentLimit: 7,\n      tokenLimit: 4,\n    });\n\n    // Token-limit binding is on the recentTelegramLinkTokens query (call #3).\n    expect(mock.calls[3].text).toContain(\"from telegram_link_tokens\");\n    expect(mock.calls[3].values).toContain(4);\n\n    // recentLimit binding lives on every list query that uses it. Spot-check\n    // the user-bound bigger ones.\n    const checkLimit = (callIdx: number, fragment: string) => {\n      expect(mock.calls[callIdx].text).toContain(fragment);\n      expect(mock.calls[callIdx].values).toContain(7);\n    };\n    checkLimit(6, \"from referral_claims\"); // recentReferralClaims\n    checkLimit(8, \"from point_grants\"); // recentPointGrants\n    checkLimit(9, \"from crate_drops\"); // recentCrateDrops\n    checkLimit(11, \"from game_entries\"); // recentGameEntries\n    checkLimit(12, \"from transactions\"); // recentTransactions\n    checkLimit(13, \"from fraud_flags\"); // fraudFlags\n    checkLimit(14, \"from event_queue\"); // recentUserQueueEvents\n  });\n\n  it(\"bounded: clamps non-positive / fractional limits to safe defaults (>= 1)\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit: null,\n      recentLimit: -5, // clamps up to 1\n      tokenLimit: 2.7, // floors to 2\n    });\n\n    // tokenLimit floored to 2.\n    expect(mock.calls[3].values).toContain(2);\n    // recentLimit clamped up to 1.\n    expect(mock.calls[6].values).toContain(1);\n  });\n\n  it(\"bounded: omits limit overrides → defaults to PEEK_USER_DETAIL_RECENT_LIMIT / PEEK_USER_DETAIL_TOKEN_LIMIT\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    await getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null });\n\n    expect(mock.calls[3].values).toContain(PEEK_USER_DETAIL_TOKEN_LIMIT);\n    expect(mock.calls[6].values).toContain(PEEK_USER_DETAIL_RECENT_LIMIT);\n  });\n\n  it(\"queue events: payload-keyed lookup binds both userId and wallet so backend writers all match\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    await getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null });\n\n    const queueCall = mock.calls[14];\n    expect(queueCall.text).toContain(\"from event_queue\");\n    expect(queueCall.text).toContain(\"payload->>'userId'\");\n    expect(queueCall.text).toContain(\"payload->>'user_id'\");\n    expect(queueCall.text).toContain(\"payload->>'wallet'\");\n    // Bound values include the userId + wallet from the identity row.\n    expect(queueCall.values).toContain(\"u-1\");\n    expect(queueCall.values).toContain(\"wallet-1\");\n  });\n\n  it(\"audit: emits peek.user.view_sensitive once when actorEmail is provided\", async () => {\n    const mock = createSqlMock(fullResponses());\n    const audit = vi.fn<PeekUserDetailAuditFn>().mockResolvedValue(undefined);\n\n    const detail = await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit,\n      actorEmail: \"ops@example.com\",\n      route: \"/users/u-1\",\n      requestId: \"req-42\",\n    });\n\n    expect(detail).not.toBeNull();\n    expect(audit).toHaveBeenCalledTimes(1);\n    expect(audit).toHaveBeenCalledWith({\n      actorEmail: \"ops@example.com\",\n      userId: \"u-1\",\n      route: \"/users/u-1\",\n      requestId: \"req-42\",\n    });\n  });\n\n  it(\"audit: skips emission when actorEmail is missing (unauthenticated path)\", async () => {\n    const mock = createSqlMock(fullResponses());\n    const audit = vi.fn<PeekUserDetailAuditFn>().mockResolvedValue(undefined);\n\n    await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit,\n      // no actorEmail\n    });\n\n    expect(audit).not.toHaveBeenCalled();\n  });\n\n  it(\"audit: skips emission when audit is explicitly null (test path)\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    const detail = await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit: null,\n      actorEmail: \"ops@example.com\",\n    });\n\n    expect(detail).not.toBeNull();\n    // No audit handler was invoked; identity SQL was. Just verify the path\n    // didn't throw.\n  });\n\n  it(\"audit: skips emission when the user is not found, regardless of actor\", async () => {\n    const mock = createSqlMock([[]]);\n    const audit = vi.fn<PeekUserDetailAuditFn>().mockResolvedValue(undefined);\n\n    const detail = await getPeekUserDetail(\"ghost\", {\n      sql: mock.sql,\n      audit,\n      actorEmail: \"ops@example.com\",\n      route: \"/users/ghost\",\n    });\n\n    expect(detail).toBeNull();\n    expect(audit).not.toHaveBeenCalled();\n  });\n\n  it(\"audit: a thrown audit handler does not break the user-detail render\", async () => {\n    const mock = createSqlMock(fullResponses());\n    const audit = vi\n      .fn<PeekUserDetailAuditFn>()\n      .mockRejectedValue(new Error(\"audit insert failed\"));\n\n    const detail = await getPeekUserDetail(\"u-1\", {\n      sql: mock.sql,\n      audit,\n      actorEmail: \"ops@example.com\",\n    });\n\n    expect(detail).not.toBeNull();\n    expect(audit).toHaveBeenCalledTimes(1);\n  });\n\n  it(\"load-error: a rejected non-identity query propagates so the page can render an alert state\", async () => {\n    const responses = [...fullResponses()];\n    responses[5] = new Error(\"connection refused\"); // referralEarnings query\n    const mock = createSqlMock(responses);\n\n    await expect(\n      getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null }),\n    ).rejects.toThrowError(\"connection refused\");\n  });\n\n  it(\"identity SQL: still preserves the 303-era linked_accounts join contract\", async () => {\n    const mock = createSqlMock(fullResponses());\n\n    await getPeekUserDetail(\"u-1\", { sql: mock.sql, audit: null });\n\n    const identitySql = mock.calls[0].text;\n    expect(identitySql).toContain(\"from player_profiles pp\");\n    expect(identitySql).toContain(\"from linked_accounts\");\n    expect(identitySql).toContain(\"provider = 'telegram'\");\n    expect(identitySql).toContain(\"status = 'active'\");\n    expect(identitySql).not.toContain(\"from telegram_link_tokens\");\n  });\n});\n","numLines":623,"startLine":1,"totalLines":623}}}
