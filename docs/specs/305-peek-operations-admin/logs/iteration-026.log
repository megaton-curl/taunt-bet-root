{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GnLLxa6NxmwHffhpAxZCsi","type":"tool_result","content":"1\timport { describe, expect, it } from \"vitest\";\n2\timport { render, screen, within } from \"@testing-library/react\";\n3\timport {\n4\t  USER_DETAIL_SECTION_IDS,\n5\t  UserDetailView,\n6\t} from \"../user-detail-view\";\n7\timport type {\n8\t  PeekUserAttentionFlags,\n9\t  PeekUserDetail,\n10\t} from \"../../lib/types/peek\";\n11\t\n12\tconst ALL_FLAGS_OFF: PeekUserAttentionFlags = {\n13\t  failedClaim: false,\n14\t  deadQueueEvent: false,\n15\t  activeFraudFlag: false,\n16\t  pendingSolCratePayout: false,\n17\t  suspiciousReferralLoop: false,\n18\t};\n19\t\n20\tfunction buildFullDetail(\n21\t  overrides: Partial<PeekUserDetail> = {},\n22\t): PeekUserDetail {\n23\t  return {\n24\t    user: {\n25\t      userId: \"u-1\",\n26\t      username: \"alice\",\n27\t      wallet: \"wallet-1\",\n28\t      joinedAt: \"2026-01-01T00:00:00.000Z\",\n29\t      referralCode: \"ALICE2026\",\n30\t      referrerUserId: \"u-0\",\n31\t      referrerCode: \"MENTOR\",\n32\t      refereeCount: 1,\n33\t      telegramUsername: \"alice_tg\",\n34\t      telegramUserId: \"tg-9001\",\n35\t      avatarUrl: \"https://example.com/a.png\",\n36\t      heatMultiplier: \"1.50\",\n37\t      profilePointsBalance: \"100\",\n38\t    },\n39\t    inboundReferral: {\n40\t      referrerUserId: \"u-0\",\n41\t      referrerCode: \"MENTOR\",\n42\t      linkedAt: \"2026-01-02T00:00:00.000Z\",\n43\t    },\n44\t    outboundReferees: [\n45\t      {\n46\t        refereeUserId: \"u-2\",\n47\t        refereeUsername: \"bob\",\n48\t        createdAt: \"2026-01-03T00:00:00.000Z\",\n49\t      },\n50\t    ],\n51\t    telegram: {\n52\t      state: \"active\",\n53\t      telegramUserId: \"tg-9001\",\n54\t      telegramUsername: \"alice_tg\",\n55\t    },\n56\t    linkedAccounts: [\n57\t      {\n58\t        id: \"la-1\",\n59\t        provider: \"telegram\",\n60\t        providerAccountId: \"tg-90