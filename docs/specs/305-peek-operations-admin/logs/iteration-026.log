,\n121\t        triggerId: \"lvl-3\",\n122\t        crateType: \"sol\",\n123\t        contentsAmount: \"1000\",\n124\t        status: \"pending\",\n125\t        createdAt: \"2026-04-22T00:00:00.000Z\",\n126\t        grantedAt: null,\n127\t      },\n128\t    ],\n129\t    challengeSummary: { active: 1, completed: 2, expired: 0, total: 3 },\n130\t    recentGameEntries: [\n131\t      {\n132\t        id: \"ge-1\",\n133\t        game: \"flipyou\",\n134\t        roundPda: \"pda-1\",\n135\t        matchId: \"match-1\",\n136\t        amountLamports: \"1000000\",\n137\t        side: \"heads\",\n138\t        isWinner: true,\n139\t        payoutLamports: \"1900000\",\n140\t        createdAt: \"2026-04-21T00:00:00.000Z\",\n141\t        settledAt: \"2026-04-21T00:00:30.000Z\",\n142\t      },\n143\t    ],\n144\t    recentTransactions: [\n145\t      {\n146\t        id: \"tx-1\",\n147\t        game: \"flipyou\",\n148\t        matchId: \"match-1\",\n149\t        txType: \"payout\",\n150\t        amountLamports: \"1900000\",\n151\t        txSig: \"sig-1\",\n152\t        createdAt: \"2026-04-21T00:00:30.000Z\",\n153\t      },\n154\t    ],\n155\t    fraudFlags: [\n156\t      {\n157\t        id: \"ff-1\",\n158\t        flagType: \"wash_trading\",\n159\t        status: \"open\",\n160\t        relatedId: \"match-1\",\n161\t        createdAt: \"2026-04-20T00:00:00.000Z\",\n162\t        resolvedAt: null,\n163\t      },\n164\t    ],\n165\t    recentUserQueueEvents: [\n166\t      {\n167\t        id: \"qe-1\",\n168\t        eventType: \"referral_payout\",\n169\t        status: \"dead\",\n170\t        attempts: 5,\n171\t        maxAttempts: 5,\n172\t        scheduledAt: \"2026-04-20T00:00:00.000Z\",\n173\t        createdAt: \"2026-04-20T00:00:00.000Z\",\n174\t        error: \"OnChainError\",\n175\t      },\n176\t    ],\n177\t    attention: {\n178\t      failedClaim: true,\n179\t      deadQueueEvent: true,\n180\t      activeFraudFlag: true,\n181\t      pendingSolCratePayout: true,\n182\t      suspiciousReferralLoop: false,\n183\t    },\n184\t    ...overrides,\n185\t  };\n186\t}\n187\t\n188\tfunction buildSparseDetail(): PeekUserDetail {\n189\t  return {\n190\t    user: {\n191\t      userId: \"u-sparse\",\n192\t      username: null,\n193\t      wallet: \"wallet-sparse\",\n194\t      joinedAt: \"2026-01-01T00:00:00.000Z\",\n195\t      referralCode: null,\n196\t      referrerUserId: null,\n197\t      referrerCode: null,\n198\t      refereeCount: 0,\n199\t      telegramUsername: null,\n200\t      telegramUserId: null,\n201\t      avatarUrl: null,\n202\t      heatMultiplier: \"1.00\",\n203\t      profilePointsBalance: \"0\",\n204\t    },\n205\t    inboundReferral: {\n206\t      referrerUserId: null,\n207\t      referrerCode: null,\n208\t      linkedAt: null,\n209\t    },\n210\t    outboundReferees: [],\n211\t    telegram: { state: \"none\", telegramUserId: null, telegramUsername: null },\n212\t    linkedAccounts: [],\n213\t    recentTelegramLinkTokens: [],\n214\t    kolRate: null,\n215\t    referralEarnings: {\n216\t      earningsCount: 0,\n217\t      totalReferrerEarnedLamports: \"0\",\n218\t      totalRefereeRebateLamports: \"0\",\n219\t      lastEarnedAt: null,\n220\t    },\n221\t    recentReferralClaims: [],\n222\t    points: {\n223\t      balance: \"0\",\n224\t      lifetimeEarned: \"0\",\n225\t      updatedAt: null,\n226\t    },\n227\t    recentPointGrants: [],\n228\t    recentCrateDrops: [],\n229\t    challengeSummary: { active: 0, completed: 0, expired: 0, total: 0 },\n230\t    recentGameEntries: [],\n231\t    recentTransactions: [],\n232\t    fraudFlags: [],\n233\t    recentUserQueueEvents: [],\n234\t    attention: ALL_FLAGS_OFF,\n235\t  };\n236\t}\n237\t\n238\tdescribe(\"UserDetailView\", () => {\n239\t  it(\"populated: renders the article header, every section anchor link, and section headings in spec order\", () => {\n240\t    render(<UserDetailView detail={buildFullDetail()} />);\n241\t\n242\t    // Header\n243\t    expect(screen.getByRole(\"article\", { name: \"User detail\" })).toBeInTheDocument();\n244\t    expect(screen.getByRole(\"heading\", { level: 1 })).toHaveTextContent(\"alice\");\n245\t\n246\t    // Nav anchors mirror the published USER_DETAIL_SECTION_IDS order.\n247\t    const nav = screen.getByRole(\"navigation\", { name: \"User detail sections\" });\n248\t    const labels = within(nav)\n249\t      .getAllByRole(\"link\")\n250\t      .map((link) => link.getAttribute(\"href\"));\n251\t    expect(labels).toEqual(\n252\t      USER_DETAIL_SECTION_IDS.map((id) => `#${id}`),\n253\t    );\n254\t\n255\t    // Section headings exist (h2 inside DetailPanel).\n256\t    const expectedHeadings = [\n257\t      \"Identity\",\n258\t      \"Linked accounts\",\n259\t      \"Referrals\",\n260\t      \"Games\",\n261\t      \"Rewards\",\n262\t      \"Challenges\",\n263\t      \"Transactions\",\n264\t      \"Attention\",\n265\t    ];\n266\t    for (const heading of expectedHeadings) {\n267\t      expect(\n268\t        screen.getByRole(\"heading\", { level: 2, name: heading }),\n269\t      ).toBeInTheDocument();\n270\t    }\n271\t  });\n272\t\n273\t  it(\"populated: renders each section's data — identity, linked accounts, referrals, games, rewards, challenges, transactions\", () => {\n274\t    render(<UserDetailView detail={buildFullDetail()} />);\n275\t\n276\t    // Identity values are rendered.\n277\t    expect(screen.getByText(\"u-1\")).toBeInTheDocument();\n278\t    expect(screen.getByText(\"https://example.com/a.png\")).toBeInTheDocument();\n279\t    expect(screen.getByText(\"1.50\")).toBeInTheDocument();\n280\t\n281\t    // KOL rate block surfaces the rate bps + ops actor.\n282\t    expect(screen.getByText(\"250\")).toBeInTheDocument();\n283\t    expect(screen.getByText(\"ops@example.com\")).toBeInTheDocument();\n284\t\n285\t    // Outbound referees are linkified to per-user pages.\n286\t    const refereeLink = screen.getByRole(\"link\", { name: \"u-2\" });\n287\t    expect(refereeLink).toHaveAttribute(\"href\", \"/users/u-2\");\n288\t\n289\t    // Game entries linkify to the round-detail page.\n290\t    const gameLink = screen.getByRole(\"link\", { name: \"match-1\" });\n291\t    expect(gameLink).toHaveAttribute(\n292\t      \"href\",\n293\t      \"/games/flipyou/rounds/pda-1\",\n294\t    );\n295\t\n296\t    // Challenge counts surface the read-only summary.\n297\t    expect(screen.getByText(\"3\")).toBeInTheDocument();\n298\t  });\n299\t\n300\t  it(\"populated: every active attention flag becomes a chip inside the attention strip aside\", () => {\n301\t    render(<UserDetailView detail={buildFullDetail()} />);\n302\t\n303\t    const strip = screen.getByRole(\"complementary\", { name: \"Attention\" });\n304\t    expect(strip).toHaveTextContent(\"Attention:\");\n305\t    // 4 flags are on (failedClaim, deadQueueEvent, activeFraudFlag,\n306\t    // pendingSolCratePayout); suspiciousReferralLoop is off.\n307\t    expect(within(strip).getByText(\"Failed claim\")).toBeInTheDocument();\n308\t    expect(within(strip).getByText(\"Dead queue event\")).toBeInTheDocument();\n309\t    expect(within(strip).getByText(\"Active fraud flag\")).toBeInTheDocument();\n310\t    expect(within(strip).getByText(\"Pending SOL crate payout\")).toBeInTheDocument();\n311\t    expect(\n312\t      within(strip).queryByText(\"Suspicious referral self/loop\"),\n313\t    ).toBeNull();\n314\t  });\n315\t\n316\t  it(\"populated: the attention SECTION (inside DetailPanel) lists every flag with its operator description\", () => {\n317\t    render(\n318\t      <UserDetailView\n319\t        detail={buildFullDetail({\n320\t          attention: {\n321\t            failedClaim: false,\n322\t            deadQueueEvent: false,\n323\t            activeFraudFlag: false,\n324\t            pendingSolCratePayout: false,\n325\t            suspiciousReferralLoop: true,\n326\t          },\n327\t        })}\n328\t      />,\n329\t    );\n330\t\n331\t    // The strip has only the loop flag this time; suspiciousReferralLoop has\n332\t    // a long description visible in the body.\n333\t    expect(\n334\t      screen.getByText(\n335\t        \"This user appears as both referrer and referee on a referral_links row.\",\n336\t      ),\n337\t    ).toBeInTheDocument();\n338\t  });\n339\t\n340\t  it(\"populated: applies the activeSectionId to the detail nav so the deep link can pre-highlight a section\", () => {\n341\t    render(\n342\t      <UserDetailView\n343\t        detail={buildFullDetail()}\n344\t        activeSectionId=\"rewards\"\n345\t      />,\n346\t    );\n347\t\n348\t    const nav = screen.getByRole(\"navigation\", { name: \"User detail sections\" });\n349\t    const rewardsLink = within(nav).getByRole(\"link\", { name: \"Rewards\" });\n350\t    expect(rewardsLink).toHaveAttribute(\"aria-current\", \"true\");\n351\t  });\n352\t\n353\t  it(\"sparse: no attention flags → the attention strip aside is suppressed (no false-warning band)\", () => {\n354\t    render(<UserDetailView detail={buildSparseDetail()} />);\n355\t\n356\t    expect(\n357\t      screen.queryByRole(\"complementary\", { name: \"Attention\" }),\n358\t    ).toBeNull();\n359\t  });\n360\t\n361\t  it(\"sparse: empty list sections render operator-readable empty states instead of empty tables\", () => {\n362\t    render(<UserDetailView detail={buildSparseDetail()} />);\n363\t\n364\t    // Linked accounts section: explicit operator copy.\n365\t    expect(\n366\t      screen.getByText(\n367\t        \"This user has not linked any external provider accounts.\",\n368\t      ),\n369\t    ).toBeInTheDocument();\n370\t\n371\t    // Games section: cross-game operator copy.\n372\t    expect(\n373\t      screen.getByText(\n374\t        \"This user has not entered any FlipYou, Pot Shot, or Close Call rounds.\",\n375\t      ),\n376\t    ).toBeInTheDocument();\n377\t\n378\t    // Transactions section.\n379\t    expect(\n380\t      screen.getByText(\n381\t        \"This user has no on-chain transaction records yet.\",\n382\t      ),\n383\t    ).toBeInTheDocument();\n384\t\n385\t    // Challenges section.\n386\t    expect(\n387\t      screen.getByText(\n388\t        \"This user has not been assigned any challenges yet.\",\n389\t      ),\n390\t    ).toBeInTheDocument();\n391\t\n392\t    // KOL rate empty state — non-KOL users see this body copy.\n393\t    expect(screen.getByText(\"No KOL rate configured for this user.\")).toBeInTheDocument();\n394\t\n395\t    // Attention SECTION (inside DetailPanel) shows the no-flags empty state.\n396\t    expect(\n397\t      screen.getByText(\"Nothing currently flagged for review on this user.\"),\n398\t    ).toBeInTheDocument();\n399\t  });\n400\t\n401\t  it(\"sparse: identity heading falls back to user_id when username is null\", () => {\n402\t    render(<UserDetailView detail={buildSparseDetail()} />);\n403\t\n404\t    expect(screen.getByRole(\"heading\", { level: 1 })).toHaveTextContent(\n405\t      \"u-sparse\",\n406\t    );\n407\t  });\n408\t});\n409\t"}]},"parent_tool_use_id":null,"session_id":"7d6a4572-ffc4-43a8-900d-a576c5df45f4","uuid":"8cb4277b-5691-452d-a50b-24d90801f155","timestamp":"2026-04-25T12:11:06.408Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/__tests__/user-detail-view.test.tsx","content":"import { describe, expect, it } from \"vitest\";\nimport { render, screen, within } from \"@testing-library/react\";\nimport {\n  USER_DETAIL_SECTION_IDS,\n  UserDetailView,\n} from \"../user-detail-view\";\nimport type {\n  PeekUserAttentionFlags,\n  PeekUserDetail,\n} from \"../../lib/types/peek\";\n\nconst ALL_FLAGS_OFF: PeekUserAttentionFlags = {\n  failedClaim: false,\n  deadQueueEvent: false,\n  activeFraudFlag: false,\n  pendingSolCratePayout: false,\n  suspiciousReferralLoop: false,\n};\n\nfunction buildFullDetail(\n  overrides: Partial<PeekUserDetail> = {},\n): PeekUserDetail {\n  return {\n    user: {\n      userId: \"u-1\",\n      username: \"alice\",\n      wallet: \"wallet-1\",\n      joinedAt: \"2026-01-01T00:00:00.000Z\",\n      referralCode: \"ALICE2026\",\n      referrerUserId: \"u-0\",\n      referrerCode: \"MENTOR\",\n      refereeCount: 1,\n      telegramUsername: \"alice_tg\",\n      telegramUserId: \"tg-9001\",\n      avatarUrl: \"https://example.com/a.png\",\n      heatMultiplier: \"1.50\",\n      profilePointsBalance: \"100\",\n    },\n    inboundReferral: {\n      referrerUserId: \"u-0\",\n      referrerCode: \"MENTOR\",\n      linkedAt: \"2026-01-02T00:00:00.000Z\",\n    },\n    outboundReferees: [\n      {\n        refereeUserId: \"u-2\",\n        refereeUsername: \"bob\",\n        createdAt: \"2026-01-03T00:00:00.000Z\",\n      },\n    ],\n    telegram: {\n      state: \"active\",\n      telegramUserId: \"tg-9001\",\n      telegramUsername: \"alice_tg\",\n    },\n    linkedAccounts: [\n      {\n        id: \"la-1\",\n        provider: \"telegram\",\n        providerAccountId: \"tg-9001\",\n        status: \"active\",\n        telegramUsername: \"alice_tg\",\n        metadataJson: { telegramUsername: \"alice_tg\" },\n        linkedAt: \"2026-01-02T00:00:00.000Z\",\n        updatedAt: \"2026-01-02T00:00:00.000Z\",\n      },\n    ],\n    recentTelegramLinkTokens: [\n      {\n        id: \"tlk-1\",\n        status: \"redeemed\",\n        telegramUserId: \"tg-9001\",\n        telegramUsername: \"alice_tg\",\n        expiresAt: \"2026-01-02T01:00:00.000Z\",\n        redeemedAt: \"2026-01-02T00:30:00.000Z\",\n        createdAt: \"2026-01-02T00:00:00.000Z\",\n      },\n    ],\n    kolRate: {\n      rateBps: 250,\n      setBy: \"ops@example.com\",\n      createdAt: \"2026-01-04T00:00:00.000Z\",\n      updatedAt: \"2026-01-04T00:00:00.000Z\",\n    },\n    referralEarnings: {\n      earningsCount: 7,\n      totalReferrerEarnedLamports: \"12345\",\n      totalRefereeRebateLamports: \"6789\",\n      lastEarnedAt: \"2026-04-20T00:00:00.000Z\",\n    },\n    recentReferralClaims: [\n      {\n        id: \"rc-1\",\n        amountLamports: \"1000\",\n        status: \"failed\",\n        retryCount: 3,\n        txSignature: null,\n        error: \"RpcError\",\n        requestedAt: \"2026-04-20T00:00:00.000Z\",\n        processedAt: \"2026-04-20T00:01:00.000Z\",\n      },\n    ],\n    points: {\n      balance: \"500\",\n      lifetimeEarned: \"1500\",\n      updatedAt: \"2026-04-24T00:00:00.000Z\",\n    },\n    recentPointGrants: [\n      {\n        id: \"pg-1\",\n        sourceType: \"challenge\",\n        sourceId: \"ch-1\",\n        amount: \"10\",\n        createdAt: \"2026-04-23T00:00:00.000Z\",\n      },\n    ],\n    recentCrateDrops: [\n      {\n        id: \"cd-1\",\n        triggerType: \"level_up\",\n        triggerId: \"lvl-3\",\n        crateType: \"sol\",\n        contentsAmount: \"1000\",\n        status: \"pending\",\n        createdAt: \"2026-04-22T00:00:00.000Z\",\n        grantedAt: null,\n      },\n    ],\n    challengeSummary: { active: 1, completed: 2, expired: 0, total: 3 },\n    recentGameEntries: [\n      {\n        id: \"ge-1\",\n        game: \"flipyou\",\n        roundPda: \"pda-1\",\n        matchId: \"match-1\",\n        amountLamports: \"1000000\",\n        side: \"heads\",\n        isWinner: true,\n        payoutLamports: \"1900000\",\n        createdAt: \"2026-04-21T00:00:00.000Z\",\n        settledAt: \"2026-04-21T00:00:30.000Z\",\n      },\n    ],\n    recentTransactions: [\n      {\n        id: \"tx-1\",\n        game: \"flipyou\",\n        matchId: \"match-1\",\n        txType: \"payout\",\n        amountLamports: \"1900000\",\n        txSig: \"sig-1\",\n        createdAt: \"2026-04-21T00:00:30.000Z\",\n      },\n    ],\n    fraudFlags: [\n      {\n        id: \"ff-1\",\n        flagType: \"wash_trading\",\n        status: \"open\",\n        relatedId: \"match-1\",\n        createdAt: \"2026-04-20T00:00:00.000Z\",\n        resolvedAt: null,\n      },\n    ],\n    recentUserQueueEvents: [\n      {\n        id: \"qe-1\",\n        eventType: \"referral_payout\",\n        status: \"dead\",\n        attempts: 5,\n        maxAttempts: 5,\n        scheduledAt: \"2026-04-20T00:00:00.000Z\",\n        createdAt: \"2026-04-20T00:00:00.000Z\",\n        error: \"OnChainError\",\n      },\n    ],\n    attention: {\n      failedClaim: true,\n      deadQueueEvent: true,\n      activeFraudFlag: true,\n      pendingSolCratePayout: true,\n      suspiciousReferralLoop: false,\n    },\n    ...overrides,\n  };\n}\n\nfunction buildSparseDetail(): PeekUserDetail {\n  return {\n    user: {\n      userId: \"u-sparse\",\n      username: null,\n      wallet: \"wallet-sparse\",\n      joinedAt: \"2026-01-01T00:00:00.000Z\",\n      referralCode: null,\n      referrerUserId: null,\n      referrerCode: null,\n      refereeCount: 0,\n      telegramUsername: null,\n      telegramUserId: null,\n      avatarUrl: null,\n      heatMultiplier: \"1.00\",\n      profilePointsBalance: \"0\",\n    },\n    inboundReferral: {\n      referrerUserId: null,\n      referrerCode: null,\n      linkedAt: null,\n    },\n    outboundReferees: [],\n    telegram: { state: \"none\", telegramUserId: null, telegramUsername: null },\n    linkedAccounts: [],\n    recentTelegramLinkTokens: [],\n    kolRate: null,\n    referralEarnings: {\n      earningsCount: 0,\n      totalReferrerEarnedLamports: \"0\",\n      totalRefereeRebateLamports: \"0\",\n      lastEarnedAt: null,\n    },\n    recentReferralClaims: [],\n    points: {\n      balance: \"0\",\n      lifetimeEarned: \"0\",\n      updatedAt: null,\n    },\n    recentPointGrants: [],\n    recentCrateDrops: [],\n    challengeSummary: { active: 0, completed: 0, expired: 0, total: 0 },\n    recentGameEntries: [],\n    recentTransactions: [],\n    fraudFlags: [],\n    recentUserQueueEvents: [],\n    attention: ALL_FLAGS_OFF,\n  };\n}\n\ndescribe(\"UserDetailView\", () => {\n  it(\"populated: renders the article header, every section anchor link, and section headings in spec order\", () => {\n    render(<UserDetailView detail={buildFullDetail()} />);\n\n    // Header\n    expect(screen.getByRole(\"article\", { name: \"User detail\" })).toBeInTheDocument();\n    expect(screen.getByRole(\"heading\", { level: 1 })).toHaveTextContent(\"alice\");\n\n    // Nav anchors mirror the published USER_DETAIL_SECTION_IDS order.\n    const nav = screen.getByRole(\"navigation\", { name: \"User detail sections\" });\n    const labels = within(nav)\n      .getAllByRole(\"link\")\n      .map((link) => link.getAttribute(\"href\"));\n    expect(labels).toEqual(\n      USER_DETAIL_SECTION_IDS.map((id) => `#${id}`),\n    );\n\n    // Section headings exist (h2 inside DetailPanel).\n    const expectedHeadings = [\n      \"Identity\",\n      \"Linked accounts\",\n      \"Referrals\",\n      \"Games\",\n      \"Rewards\",\n      \"Challenges\",\n      \"Transactions\",\n      \"Attention\",\n    ];\n    for (const heading of expectedHeadings) {\n      expect(\n        screen.getByRole(\"heading\", { level: 2, name: heading }),\n      ).toBeInTheDocument();\n    }\n  });\n\n  it(\"populated: renders each section's data — identity, linked accounts, referrals, games, rewards, challenges, transactions\", () => {\n    render(<UserDetailView detail={buildFullDetail()} />);\n\n    // Identity values are rendered.\n    expect(screen.getByText(\"u-1\")).toBeInTheDocument();\n    expect(screen.getByText(\"https://example.com/a.png\")).toBeInTheDocument();\n    expect(screen.getByText(\"1.50\")).toBeInTheDocument();\n\n    // KOL rate block surfaces the rate bps + ops actor.\n    expect(screen.getByText(\"250\")).toBeInTheDocument();\n    expect(screen.getByText(\"ops@example.com\")).toBeInTheDocument();\n\n    // Outbound referees are linkified to per-user pages.\n    const refereeLink = screen.getByRole(\"link\", { name: \"u-2\" });\n    expect(refereeLink).toHaveAttribute(\"href\", \"/users/u-2\");\n\n    // Game entries linkify to the round-detail page.\n    const gameLink = screen.getByRole(\"link\", { name: \"match-1\" });\n    expect(gameLink).toHaveAttribute(\n      \"href\",\n      \"/games/flipyou/rounds/pda-1\",\n    );\n\n    // Challenge counts surface the read-only summary.\n    expect(screen.getByText(\"3\")).toBeInTheDocument();\n  });\n\n  it(\"populated: every active attention flag becomes a chip inside the attention strip aside\", () => {\n    render(<UserDetailView detail={buildFullDetail()} />);\n\n    const strip = screen.getByRole(\"complementary\", { name: \"Attention\" });\n    expect(strip).toHaveTextContent(\"Attention:\");\n    // 4 flags are on (failedClaim, deadQueueEvent, activeFraudFlag,\n    // pendingSolCratePayout); suspiciousReferralLoop is off.\n    expect(within(strip).getByText(\"Failed claim\")).toBeInTheDocument();\n    expect(within(strip).getByText(\"Dead queue event\")).toBeInTheDocument();\n    expect(within(strip).getByText(\"Active fraud flag\")).toBeInTheDocument();\n    expect(within(strip).getByText(\"Pending SOL crate payout\")).toBeInTheDocument();\n    expect(\n      within(strip).queryByText(\"Suspicious referral self/loop\"),\n    ).toBeNull();\n  });\n\n  it(\"populated: the attention SECTION (inside DetailPanel) lists every flag with its operator description\", () => {\n    render(\n      <UserDetailView\n        detail={buildFullDetail({\n          attention: {\n            failedClaim: false,\n            deadQueueEvent: false,\n            activeFraudFlag: false,\n            pendingSolCratePayout: false,\n            suspiciousReferralLoop: true,\n          },\n        })}\n      />,\n    );\n\n    // The strip has only the loop flag this time; suspiciousReferralLoop has\n    // a long description visible in the body.\n    expect(\n      screen.getByText(\n        \"This user appears as both referrer and referee on a referral_links row.\",\n      ),\n    ).toBeInTheDocument();\n  });\n\n  it(\"populated: applies the activeSectionId to the detail nav so the deep link can pre-highlight a section\", () => {\n    render(\n      <UserDetailView\n        detail={buildFullDetail()}\n        activeSectionId=\"rewards\"\n      />,\n    );\n\n    const nav = screen.getByRole(\"navigation\", { name: \"User detail sections\" });\n    const rewardsLink = within(nav).getByRole(\"link\", { name: \"Rewards\" });\n    expect(rewardsLink).toHaveAttribute(\"aria-current\", \"true\");\n  });\n\n  it(\"sparse: no attention flags → the attention strip aside is suppressed (no false-warning band)\", () => {\n    render(<UserDetailView detail={buildSparseDetail()} />);\n\n    expect(\n      screen.queryByRole(\"complementary\", { name: \"Attention\" }),\n    ).toBeNull();\n  });\n\n  it(\"sparse: empty list sections render operator-readable empty states instead of empty tables\", () => {\n    render(<UserDetailView detail={buildSparseDetail()} />);\n\n    // Linked accounts section: explicit operator copy.\n    expect(\n      screen.getByText(\n        \"This user has not linked any external provider accounts.\",\n      ),\n    ).toBeInTheDocument();\n\n    // Games section: cross-game operator copy.\n    expect(\n      screen.getByText(\n        \"This user has not entered any FlipYou, Pot Shot, or Close Call rounds.\",\n      ),\n    ).toBeInTheDocument();\n\n    // Transactions section.\n    expect(\n      screen.getByText(\n        \"This user has no on-chain transaction records yet.\",\n      ),\n    ).toBeInTheDocument();\n\n    // Challenges section.\n    expect(\n      screen.getByText(\n        \"This user has not been assigned any challenges yet.\",\n      ),\n    ).toBeInTheDocument();\n\n    // KOL rate empty state — non-KOL users see this body copy.\n    expect(screen.getByText(\"No KOL rate configured for this user.\")).toBeInTheDocument();\n\n    // Attention SECTION (inside DetailPanel) shows the no-flags empty state.\n    expect(\n      screen.getByText(\"Nothing currently flagged for review on this user.\"),\n    ).toBeInTheDocument();\n  });\n\n  it(\"sparse: identity heading falls back to user_id when username is null\", () => {\n    render(<UserDetailView detail={buildSparseDetail()} />);\n\n    expect(screen.getByRole(\"heading\", { level: 1 })).toHaveTextContent(\n      \"u-sparse\",\n    );\n  });\n});\n","numLines":409,"startLine":1,"totalLines":409}}}
