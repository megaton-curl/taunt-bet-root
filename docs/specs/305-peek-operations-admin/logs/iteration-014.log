onst rows = await sql<RecentOperatorEventRow[]>`\n    select\n      id::text as \"id\",\n      event_type as \"eventType\",\n      payload->>'actorEmail' as \"actorEmail\",\n      payload->>'resourceType' as \"resourceType\",\n      payload->>'resourceId' as \"resourceId\",\n      payload->>'route' as \"route\",\n      created_at::text as \"createdAt\"\n    from operator_events\n    order by created_at desc\n    limit ${limit}\n  `;\n\n  return rows.map((row) => ({\n    id: row.id,\n    eventType: row.eventType,\n    actorEmail: row.actorEmail,\n    resourceType: row.resourceType,\n    resourceId: row.resourceId,\n    route: row.route,\n    createdAt: row.createdAt,\n  }));\n}\n","structuredPatch":[],"originalFile":null,"userModified":false}}
