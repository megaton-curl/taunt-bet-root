{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013vsuGxXH8Te9XHDbG1Yaze","type":"tool_result","content":"1\texport type PeekSearchParams = {\n2\t  query: string;\n3\t  sort: \"joinedAt\" | \"refereeCount\";\n4\t  direction: \"asc\" | \"desc\";\n5\t  page: number;\n6\t  pageSize: number;\n7\t  filters: {\n8\t    hasReferrer: boolean;\n9\t    hasReferees: boolean;\n10\t    hasCode: boolean;\n11\t    hasTelegram: boolean;\n12\t  };\n13\t};\n14\t\n15\tfunction readSingleValue(value: string | string[] | undefined) {\n16\t  return Array.isArray(value) ? value[0] ?? \"\" : value ?? \"\";\n17\t}\n18\t\n19\tfunction readPositiveInteger(\n20\t  value: string | string[] | undefined,\n21\t  fallback: number\n22\t) {\n23\t  const parsedValue = Number.parseInt(readSingleValue(value), 10);\n24\t\n25\t  if (Number.isFinite(parsedValue) && parsedValue > 0) {\n26\t    return parsedValue;\n27\t  }\n28\t\n29\t  return fallback;\n30\t}\n31\t\n32\texport function normalizePeekSearchParams(\n33\t  input: Record<string, string | string[] | undefined>\n34\t): PeekSearchParams {\n35\t  return {\n36\t    query: readSingleValue(input.query),\n37\t    sort: readSingleValue(input.sort) === \"refereeCount\" ? \"refereeCount\" : \"joinedAt\",\n38\t    direction: readSingleValue(input.direction) === \"asc\" ? \"asc\" : \"desc\",\n39\t    page: readPositiveInteger(input.page, 1),\n40\t    pageSize: Number(process.env.PEEK_DEFAULT_PAGE_SIZE || \"50\"),\n41\t    filters: {\n42\t      hasReferrer: readSingleValue(input.hasReferrer) === \"true\",\n43\t      hasReferees: readSingleValue(input.hasReferees) === \"true\",\n44\t      hasCode: readSingleValue(input.hasCode) === \"true\",\n45\t      hasTelegram: readSingleValue(input.hasTelegram) === \"true\",\n46\t    },\n47\t  };\n48\t}\n49\t"}]},"parent_tool_use_id":null,"session_id":"042e06eb-8d45-46fd-a019-d381aebe19ab","uuid":"43800c28-b72e-40ff-93c7-da7e7fc934cf","timestamp":"2026-04-25T11:19:36.455Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/search-params.ts","content":"export type PeekSearchParams = {\n  query: string;\n  sort: \"joinedAt\" | \"refereeCount\";\n  direction: \"asc\" | \"desc\";\n  page: number;\n  pageSize: number;\n  filters: {\n    hasReferrer: boolean;\n    hasReferees: boolean;\n    hasCode: boolean;\n    hasTelegram: boolean;\n  };\n};\n\nfunction readSingleValue(value: string | string[] | undefined) {\n  return Array.isArray(value) ? value[0] ?? \"\" : value ?? \"\";\n}\n\nfunction readPositiveInteger(\n  value: string | string[] | undefined,\n  fallback: number\n) {\n  const parsedValue = Number.parseInt(readSingleValue(value), 10);\n\n  if (Number.isFinite(parsedValue) && parsedValue > 0) {\n    return parsedValue;\n  }\n\n  return fallback;\n}\n\nexport function normalizePeekSearchParams(\n  input: Record<string, string | string[] | undefined>\n): PeekSearchParams {\n  return {\n    query: readSingleValue(input.query),\n    sort: readSingleValue(input.sort) === \"refereeCount\" ? \"refereeCount\" : \"joinedAt\",\n    direction: readSingleValue(input.direction) === \"asc\" ? \"asc\" : \"desc\",\n    page: readPositiveInteger(input.page, 1),\n    pageSize: Number(process.env.PEEK_DEFAULT_PAGE_SIZE || \"50\"),\n    filters: {\n      hasReferrer: readSingleValue(input.hasReferrer) === \"true\",\n      hasReferees: readSingleValue(input.hasReferees) === \"true\",\n      hasCode: readSingleValue(input.hasCode) === \"true\",\n      hasTelegram: readSingleValue(input.hasTelegram) === \"true\",\n    },\n  };\n}\n","numLines":49,"startLine":1,"totalLines":49}}}
