{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01LP6hnnfWWKUCDhPXztKMZ4","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_017EFcCYtoHsMoqdteeUNyL4","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/db/queries/get-recent-operator-events.ts","content":"// Recent operator events query (FR-3 command-center \"high-signal activity\").\n//\n// Returns the latest N rows from `operator_events`, projecting only the fields\n// the command-center \"Recent activity\" list renders. Bounded — never returns\n// more than `MAX_LIMIT` rows even if a caller passes a larger limit. The audit\n// page (later iteration) is the place for filtered, paginated audit browsing;\n// this query exists only for the dense home-page activity strip.\n\nimport type { Sql } from \"postgres\";\nimport type { PeekRecentActivityItem } from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport const RECENT_OPERATOR_EVENTS_DEFAULT_LIMIT = 10;\nexport const RECENT_OPERATOR_EVENTS_MAX_LIMIT = 50;\n\nexport type RecentOperatorEventsOptions = {\n  sql?: Sql;\n  limit?: number;\n};\n\ntype RecentOperatorEventRow = {\n  id: string;\n  eventType: string;\n  actorEmail: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  route: string | null;\n  createdAt: string;\n};\n\nexport async function getRecentOperatorEvents(\n  options: RecentOperatorEventsOptions = {},\n): Promise<PeekRecentActivityItem[]> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const requestedLimit = options.limit ?? RECENT_OPERATOR_EVENTS_DEFAULT_LIMIT;\n  const limit = Math.max(\n    1,\n    Math.min(RECENT_OPERATOR_EVENTS_MAX_LIMIT, Math.floor(requestedLimit)),\n  );\n\n  const rows = await sql<RecentOperatorEventRow[]>`\n    select\n      id::text as \"id\",\n      event_type as \"eventType\",\n      payload->>'actorEmail' as \"actorEmail\",\n      payload->>'resourceType' as \"resourceType\",\n      payload->>'resourceId' as \"resourceId\",\n      payload->>'route' as \"route\",\n      created_at::text as \"createdAt\"\n    from operator_events\n    order by created_at desc\n    limit ${limit}\n  `;\n\n  return rows.map((row) => ({\n    id: row.id,\n    eventType: row.eventType,\n    actorEmail: row.actorEmail,\n    resourceType: row.resourceType,\n    resourceId: row.resourceId,\n    route: row.route,\n    createdAt: row.createdAt,\n  }));\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":638,"cache_read_input_tokens":107559,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":638},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"042e06eb-8d45-46fd-a019-d381aebe19ab","uuid":"b2fbcb39-2aa2-4cc0-8c90-c21594fcd839"}
