{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018PRAZeRmY6ng9i86RbLdEm","type":"tool_result","content":"1\t#!/bin/bash\n2\tset -e\n3\texport CI=true\n4\t\n5\t# =============================================================================\n6\t# verify — End-to-end verification for Taunt Bet\n7\t#\n8\t# Usage:\n9\t#   ./scripts/verify              Full verification (all steps)\n10\t#   ./scripts/verify --anchor     Anchor programs only (build + test)\n11\t#   ./scripts/verify --ts         TypeScript only (lint + typecheck + test)\n12\t#   ./scripts/verify --devnet     Devnet E2E tests (non-blocking, skips if env vars missing)\n13\t#\n14\t# Note:\n15\t#   Chat verification currently lives in the `chat/` submodule as `pnpm verify`.\n16\t#   Telegram verification currently lives in the `telegram/` submodule as\n17\t#   `pnpm verify`.\n18\t#   Root verify intentionally remains limited to `backend/` and `solana/` until\n19\t#   the chat/telegram service contracts stabilise.\n20\t# =============================================================================\n21\t\n22\t# Color codes\n23\tGREEN='\\033[0;32m'\n24\tRED='\\033[0;31m'\n25\tYELLOW='\\033[0;33m'\n26\tNC='\\033[0m'\n27\t\n28\tMODE=\"${1:-full}\"\n29\t\n30\t# Normalize flags\n31\tcase \"$MODE\" in\n32\t    --anchor|--anchor-only|anchor) MODE=\"anchor\" ;;\n33\t    --ts|--ts-only|ts) MODE=\"ts\" ;;\n34\t    --devnet|devnet) MODE=\"devnet\" ;;\n35\t    --full|full|\"\") MODE=\"full\" ;;\n36\t    *)\n37\t        echo \"Usage: ./scripts/verify [--anchor|--ts|--devnet|--full]\"\n38\t        exit 1\n39\t        ;;\n40\tesac\n41\t\n42\tROOT=\"$(cd \"$(dirname \"$0\")/..\" && pwd)\"\n43\t\n44\techo -e \"${GREEN}=== Taunt Bet Verification ($MODE) ===${NC}\"\n45\t\n46\t# Check for submodules\n47\tif [ ! -f \"$ROOT/backend/package.json\" ]; then\n48\t    echo -e \"${RED}[FAIL] Backend submodule not initialized.${NC}\"\n49\t    echo \"Run: git submodule update --init --recursive\"\n50\t    exit 1\n51\tfi\n52\t\n53\t# ---------------------------------------------------------------------------\n54\t# TypeScript steps (lint, typecheck, test)\n55\t# ---------------------------------------------------------------------------\n56\trun_ts() {\n57\t    cd \"$ROOT/backend\"\n58\t\n59\t    # Install dependencies if missing\n60\t    if [ ! -d \"node_modules\" ]; then\n61\t        echo -e \"${GREEN}[INFO] Installing dependencies...${NC}\"\n62\t        pnpm install\n63\t    fi\n64\t\n65\t    echo -e \"${GREEN}[STEP] Linting...${NC}\"\n66\t    pnpm lint\n67\t\n68\t    echo -e \"${GREEN}[STEP] Typechecking...${NC}\"\n69\t    pnpm typecheck\n70\t\n71\t    echo -e \"${GREEN}[STEP] Testing (TS packages)...${NC}\"\n72\t    pnpm test\n73\t\n74\t    cd \"$ROOT\"\n75\t}\n76\t\n77\t# ---------------------------------------------------------------------------\n78\t# Anchor steps (build + test)\n79\t# ---------------------------------------------------------------------------\n80\trun_anchor() {\n81\t    if ! command -v anchor &>/dev/null; then\n82\t        echo -e \"${YELLOW}[SKIP] Anchor tests (anchor CLI not found)${NC}\"\n83\t        return 0\n84\t    fi\n85\t\n86\t    cd \"$ROOT/solana\"\n87\t\n88\t    if [ ! -d \"node_modules\" ]; then\n89\t        pnpm install --ignore-workspace\n90\t    fi\n91\t\n92\t    echo -e \"${GREEN}[STEP] Building Anchor programs...${NC}\"\n93\t    anchor build\n94\t\n95\t    echo -e \"${GREEN}[STEP] Testing (Anchor programs)...${NC}\"\n96\t    pnpm exec mocha --require tsx/cjs -t 1000000 --exit tests/closecall.ts tests/flipyou.ts tests/potshot.ts tests/platform.ts\n97\t\n98\t    cd \"$ROOT\"\n99\t}\n100\t\n101\t# ---------------------------------------------------------------------------\n102\t# Devnet E2E tests (non-blocking)\n103\t# ---------------------------------------------------------------------------\n104\trun_devnet_e2e() {\n105\t    if [ -z \"${VITE_FLIPYOU_PROGRAM_ID:-}\" ]; then\n106\t        echo -e \"${YELLOW}[SKIP] Devnet E2E (VITE_FLIPYOU_PROGRAM_ID not set)${NC}\"\n107\t        return 0\n108\t    fi\n109\t\n110\t    if [ ! -d \"$ROOT/e2e/node_modules\" ]; then\n111\t        echo -e \"${GREEN}[INFO] Installing E2E dependencies...${NC}\"\n112\t        cd \"$ROOT/e2e\" && pnpm install && cd \"$ROOT\"\n113\t    fi\n114\t\n115\t    echo -e \"${GREEN}[STEP] Running devnet E2E tests...${NC}\"\n116\t    if cd \"$ROOT/e2e\" && pnpm exec playwright test; then\n117\t        echo -e \"${GREEN}[PASS] Devnet E2E tests passed${NC}\"\n118\t    else\n119\t        echo -e \"${YELLOW}[WARN] Devnet E2E tests failed (non-blocking)${NC}\"\n120\t    fi\n121\t\n122\t    cd \"$ROOT\"\n123\t    return 0\n124\t}\n125\t\n126\t# ---------------------------------------------------------------------------\n127\t# Fee constant consistency check (always runs)\n128\t# ---------------------------------------------------------------------------\n129\techo -e \"${GREEN}[STEP] Checking fee constant consistency...${NC}\"\n130\t\"$ROOT/scripts/check-fees.sh\"\n131\t\n132\t# ---------------------------------------------------------------------------\n133\t# Run based on mode\n134\t# ---------------------------------------------------------------------------\n135\tcase \"$MODE\" in\n136\t    full)\n137\t        run_ts\n138\t        run_anchor\n139\t        ;;\n140\t    ts)\n141\t        run_ts\n142\t        ;;\n143\t    anchor)\n144\t        run_anchor\n145\t        ;;\n146\t    devnet)\n147\t        run_devnet_e2e\n148\t        ;;\n149\tesac\n150\t\n151\techo -e \"${GREEN}=== VERIFICATION PASSED ($MODE) ===${NC}\"\n152\texit 0\n153\t"}]},"parent_tool_use_id":null,"session_id":"39eb5474-9f91-4902-88f7-7ddd830071a9","uuid":"877b887f-818e-46af-a572-0060aad40e90","timestamp":"2026-04-26T20:22:04.431Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/scripts/verify","content":"#!/bin/bash\nset -e\nexport CI=true\n\n# =============================================================================\n# verify — End-to-end verification for Taunt Bet\n#\n# Usage:\n#   ./scripts/verify              Full verification (all steps)\n#   ./scripts/verify --anchor     Anchor programs only (build + test)\n#   ./scripts/verify --ts         TypeScript only (lint + typecheck + test)\n#   ./scripts/verify --devnet     Devnet E2E tests (non-blocking, skips if env vars missing)\n#\n# Note:\n#   Chat verification currently lives in the `chat/` submodule as `pnpm verify`.\n#   Telegram verification currently lives in the `telegram/` submodule as\n#   `pnpm verify`.\n#   Root verify intentionally remains limited to `backend/` and `solana/` until\n#   the chat/telegram service contracts stabilise.\n# =============================================================================\n\n# Color codes\nGREEN='\\033[0;32m'\nRED='\\033[0;31m'\nYELLOW='\\033[0;33m'\nNC='\\033[0m'\n\nMODE=\"${1:-full}\"\n\n# Normalize flags\ncase \"$MODE\" in\n    --anchor|--anchor-only|anchor) MODE=\"anchor\" ;;\n    --ts|--ts-only|ts) MODE=\"ts\" ;;\n    --devnet|devnet) MODE=\"devnet\" ;;\n    --full|full|\"\") MODE=\"full\" ;;\n    *)\n        echo \"Usage: ./scripts/verify [--anchor|--ts|--devnet|--full]\"\n        exit 1\n        ;;\nesac\n\nROOT=\"$(cd \"$(dirname \"$0\")/..\" && pwd)\"\n\necho -e \"${GREEN}=== Taunt Bet Verification ($MODE) ===${NC}\"\n\n# Check for submodules\nif [ ! -f \"$ROOT/backend/package.json\" ]; then\n    echo -e \"${RED}[FAIL] Backend submodule not initialized.${NC}\"\n    echo \"Run: git submodule update --init --recursive\"\n    exit 1\nfi\n\n# ---------------------------------------------------------------------------\n# TypeScript steps (lint, typecheck, test)\n# ---------------------------------------------------------------------------\nrun_ts() {\n    cd \"$ROOT/backend\"\n\n    # Install dependencies if missing\n    if [ ! -d \"node_modules\" ]; then\n        echo -e \"${GREEN}[INFO] Installing dependencies...${NC}\"\n        pnpm install\n    fi\n\n    echo -e \"${GREEN}[STEP] Linting...${NC}\"\n    pnpm lint\n\n    echo -e \"${GREEN}[STEP] Typechecking...${NC}\"\n    pnpm typecheck\n\n    echo -e \"${GREEN}[STEP] Testing (TS packages)...${NC}\"\n    pnpm test\n\n    cd \"$ROOT\"\n}\n\n# ---------------------------------------------------------------------------\n# Anchor steps (build + test)\n# ---------------------------------------------------------------------------\nrun_anchor() {\n    if ! command -v anchor &>/dev/null; then\n        echo -e \"${YELLOW}[SKIP] Anchor tests (anchor CLI not found)${NC}\"\n        return 0\n    fi\n\n    cd \"$ROOT/solana\"\n\n    if [ ! -d \"node_modules\" ]; then\n        pnpm install --ignore-workspace\n    fi\n\n    echo -e \"${GREEN}[STEP] Building Anchor programs...${NC}\"\n    anchor build\n\n    echo -e \"${GREEN}[STEP] Testing (Anchor programs)...${NC}\"\n    pnpm exec mocha --require tsx/cjs -t 1000000 --exit tests/closecall.ts tests/flipyou.ts tests/potshot.ts tests/platform.ts\n\n    cd \"$ROOT\"\n}\n\n# ---------------------------------------------------------------------------\n# Devnet E2E tests (non-blocking)\n# ---------------------------------------------------------------------------\nrun_devnet_e2e() {\n    if [ -z \"${VITE_FLIPYOU_PROGRAM_ID:-}\" ]; then\n        echo -e \"${YELLOW}[SKIP] Devnet E2E (VITE_FLIPYOU_PROGRAM_ID not set)${NC}\"\n        return 0\n    fi\n\n    if [ ! -d \"$ROOT/e2e/node_modules\" ]; then\n        echo -e \"${GREEN}[INFO] Installing E2E dependencies...${NC}\"\n        cd \"$ROOT/e2e\" && pnpm install && cd \"$ROOT\"\n    fi\n\n    echo -e \"${GREEN}[STEP] Running devnet E2E tests...${NC}\"\n    if cd \"$ROOT/e2e\" && pnpm exec playwright test; then\n        echo -e \"${GREEN}[PASS] Devnet E2E tests passed${NC}\"\n    else\n        echo -e \"${YELLOW}[WARN] Devnet E2E tests failed (non-blocking)${NC}\"\n    fi\n\n    cd \"$ROOT\"\n    return 0\n}\n\n# ---------------------------------------------------------------------------\n# Fee constant consistency check (always runs)\n# ---------------------------------------------------------------------------\necho -e \"${GREEN}[STEP] Checking fee constant consistency...${NC}\"\n\"$ROOT/scripts/check-fees.sh\"\n\n# ---------------------------------------------------------------------------\n# Run based on mode\n# ---------------------------------------------------------------------------\ncase \"$MODE\" in\n    full)\n        run_ts\n        run_anchor\n        ;;\n    ts)\n        run_ts\n        ;;\n    anchor)\n        run_anchor\n        ;;\n    devnet)\n        run_devnet_e2e\n        ;;\nesac\n\necho -e \"${GREEN}=== VERIFICATION PASSED ($MODE) ===${NC}\"\nexit 0\n","numLines":153,"startLine":1,"totalLines":153}}}
