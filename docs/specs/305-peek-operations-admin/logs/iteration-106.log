,\n    align: \"right\",\n    sortable: false,\n  },\n  {\n    id: \"referrerEarnedLamports\",\n    label: \"Referrer earned (lamports)\",\n    align: \"right\",\n    sortable: false,\n  },\n  {\n    id: \"pendingClaimLamports\",\n    label: \"Pending claim (lamports)\",\n    align: \"right\",\n    sortable: false,\n  },\n];\n\nfunction rowToCsv(row: PeekTopReferrerRow): Record<string, string> {\n  return {\n    referrerUserId: row.referrerUserId,\n    username: row.username ?? \"\",\n    wallet: row.wallet,\n    referralCode: row.referralCode ?? \"\",\n    refereeCount: row.refereeCount.toString(),\n    activeRefereeCount: row.activeRefereeCount.toString(),\n    referredWagerLamports: row.referredWagerLamports,\n    referrerEarnedLamports: row.referrerEarnedLamports,\n    pendingClaimLamports: row.pendingClaimLamports,\n  };\n}\n\nexport const REFERRERS_EXPORTER: PeekExporterDefinition = {\n  entity: \"referrers\",\n  resourceType: \"referral_top_referrer\",\n  columns: REFERRER_COLUMNS,\n  maxRowsPerExport: PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT,\n  requireAtLeastOneFilter: false,\n  async fetch(ctx) {\n    const rows = await listTopReferrers({\n      sql: ctx.sql,\n      limit: ctx.rowCap + 1,\n    });\n    const rowCapApplied = rows.length > ctx.rowCap;\n    const trimmed = rowCapApplied ? rows.slice(0, ctx.rowCap) : rows;\n    return {\n      rows: trimmed.map(rowToCsv),\n      rowCapApplied,\n    };\n  },\n  buildFilterSlug() {\n    // The top-referrers list has no user-supplied filter axis; the bound is\n    // an implicit ranked-list limit. Returning an empty slug yields a\n    // deterministic `peek-referrers-YYYY-MM-DD.csv` filename.\n    return \"\";\n  },\n};\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01MocfV6SvUSK8XK9y1pEDmV","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01WEw6P4mBLW3xDmBve42EwR","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/exports/exporters/kol.ts","content":"// KOL performance exporter (FR-7, FR-12).\n//\n// Backs the `kol` export entity used by `/growth/kol`. Like the top-referrers\n// exporter, the underlying query is a bounded-by-default ranked list keyed by\n// `referral_kol_rates`, so `requireAtLeastOneFilter` is `false`.\n\nimport {\n  listKolPerformance,\n  PEEK_GROWTH_KOL_MAX_LIMIT,\n} from \"../../db/queries/get-growth-referrals\";\nimport type {\n  PeekKolPerformanceRow,\n  PeekTableColumn,\n} from \"../../../lib/types/peek\";\nimport type { PeekExporterDefinition } from \"../registry\";\n\nconst KOL_COLUMNS: ReadonlyArray<PeekTableColumn> = [\n  { id: \"userId\", label: \"User id\", align: \"left\", sortable: false },\n  { id: \"username\", label: \"Username\", align: \"left\", sortable: false },\n  { id: \"wallet\", label: \"Wallet\", align: \"left\", sortable: false },\n  { id: \"rateBps\", label: \"Rate (bps)\", align: \"right\", sortable: false },\n  { id: \"setBy\", label: \"Set by\", align: \"left\", sortable: false },\n  { id: \"createdAt\", label: \"Created\", align: \"left\", sortable: false },\n  { id: \"updatedAt\", label: \"Updated\", align: \"left\", sortable: false },\n  {\n    id: \"refereeCount\",\n    label: \"Referees\",\n    align: \"right\",\n    sortable: false,\n  },\n  {\n    id: \"referredWagerLamports\",\n    label: \"Referred wager (lamports)\",\n    align: \"right\",\n    sortable: false,\n  },\n  {\n    id: \"referrerEarnedLamports\",\n    label: \"Referrer earned (lamports)\",\n    align: \"right\",\n    sortable: false,\n  },\n];\n\nfunction rowToCsv(row: PeekKolPerformanceRow): Record<string, string> {\n  return {\n    userId: row.userId,\n    username: row.username ?? \"\",\n    wallet: row.wallet,\n    rateBps: row.rateBps.toString(),\n    setBy: row.setBy,\n    createdAt: row.createdAt,\n    updatedAt: row.updatedAt,\n    refereeCount: row.refereeCount.toString(),\n    referredWagerLamports: row.referredWagerLamports,\n    referrerEarnedLamports: row.referrerEarnedLamports,\n  };\n}\n\nexport const KOL_EXPORTER: PeekExporterDefinition = {\n  entity: \"kol\",\n  resourceType: \"referral_kol_rate\",\n  columns: KOL_COLUMNS,\n  maxRowsPerExport: PEEK_GROWTH_KOL_MAX_LIMIT,\n  requireAtLeastOneFilter: false,\n  async fetch(ctx) {\n    const rows = await listKolPerformance({\n      sql: ctx.sql,\n      limit: ctx.rowCap + 1,\n    });\n    const rowCapApplied = rows.length > ctx.rowCap;\n    const trimmed = rowCapApplied ? rows.slice(0, ctx.rowCap) : rows;\n    return {\n      rows: trimmed.map(rowToCsv),\n      rowCapApplied,\n    };\n  },\n  buildFilterSlug() {\n    return \"\";\n  },\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1525,"cache_read_input_tokens":121493,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1525},"output_tokens":65,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"4cc437f6-074f-409d-aaec-b59a5e7b518d","uuid":"4d334c97-6352-411e-9108-415ac14b39bd"}
