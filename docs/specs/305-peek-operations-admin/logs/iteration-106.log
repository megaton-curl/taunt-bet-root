{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CtiYGPV61FkvhK9LCuw987","type":"tool_result","content":"1\t// Growth / referral admin queries (FR-7).\n2\t//\n3\t// One module that backs `/growth/referrals` and `/growth/kol`:\n4\t//\n5\t// - getGrowthReferralOverview() — eight FR-4 metrics: referrers, referred\n6\t//   users, activated referred users (have at least one game_entries row),\n7\t//   total referrer-earned lamports, total referee-rebate lamports, pending\n8\t//   claim lamports, failed claim count, KOL count.\n9\t// - listTopReferrers() — per-referrer aggregate with referee count, active\n10\t//   referee count, referred wager volume, referrer earnings, and pending\n11\t//   claim amount; used by the top-referrers table on /growth/referrals.\n12\t// - listKolPerformance() — `referral_kol_rates` joined with the same\n13\t//   per-referrer performance aggregates so the KOL table on /growth/kol can\n14\t//   show rate alongside actual production.\n15\t// - listReferralClaims() — filterable claims table reading from\n16\t//   `referral_claims` joined with `player_profiles` for the username column.\n17\t// - getReferralGraphNode() — one-hop referral-graph node centered on a user;\n18\t//   surfaces inbound referrer (back-link) + outbound referees (drill into\n19\t//   their user-detail pages). Re-uses the read paths the user-detail page\n20\t//   already covers; collected here so the upcoming /growth/referrals graph\n21\t//   navigation has a stable contract without changing user-detail.\n22\t//\n23\t// All queries are bounded server-side and rely only on existing tables.\n24\t// Lamport / u64 sums round-trip as `text` to preserve precision.\n25\t\n26\timport type { Sql } from \"postgres\";\n27\timport {\n28\t  type PeekGrowthClaimRow,\n29\t  type PeekGrowthOverview,\n30\t  type PeekGrowthOverviewMetricId,\n31\t  type PeekKolPerformanceRow,\n32\t  type PeekMetric,\n33\t  type PeekReferralClaimFilters,\n34\t  type PeekReferralGraphNode,\n35\t  type PeekReferralGraphRefereeRow,\n36\t  type PeekTopReferrerRow,\n37\t} from \"../../../lib/types/peek\";\n38\timport { getSqlClient } from \"../client\";\n39\t\n40\texport const PEEK_GROWTH_TOP_REFERRERS_DEFAULT_LIMIT = 50;\n41\texport const PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT = 250;\n42\texport const PEEK_GROWTH_KOL_DEFAULT_LIMIT = 100;\n43\texport const PEEK_GROWTH_KOL_MAX_LIMIT = 500;\n44\texport const PEEK_GROWTH_CLAIMS_DEFAULT_LIMIT = 100;\n45\texport const PEEK_GROWTH_CLAIMS_MAX_LIMIT = 500;\n46\t\n47\ttype GrowthOverviewOptions = {\n48\t  sql?: Sql;\n49\t  now?: Date;\n50\t};\n51\t\n52\ttype ListLimitOptions = {\n53\t  sql?: Sql;\n54\t  limit?: number;\n55\t};\n56\t\n57\texport type ListReferralClaimsOptions = {\n58\t  sql?: Sql;\n59\t  limit?: number;\n60\t  filters?: Partial<PeekReferralClaimFilters>;\n61\t};\n62\t\n63\texport type ReferralGraphOptions = {\n64\t  sql?: Sql;\n65\t  refereeLimit?: number;\n66\t};\n67\t\n68\tfunction clampLimit(\n69\t  raw: number | undefined,\n70\t  fallback: number,\n71\t  max: number,\n72\t): number {\n73\t  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n74\t  const floored = Math.floor(raw);\n75\t  if (floored <= 0) return 1;\n76\t  return Math.min(max, floored);\n77\t}\n78\t\n79\tfunction formatCount(count: number): string {\n80\t  return count.toLocaleString(\"en-US\");"}]},"parent_tool_use_id":null,"session_id":"4cc437f6-074f-409d-aaec-b59a5e7b518d","uuid":"36147fa1-25cf-4ca5-8c29-72d730c375f4","timestamp":"2026-04-26T07:33:00.511Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-growth-referrals.ts","content":"// Growth / referral admin queries (FR-7).\n//\n// One module that backs `/growth/referrals` and `/growth/kol`:\n//\n// - getGrowthReferralOverview() — eight FR-4 metrics: referrers, referred\n//   users, activated referred users (have at least one game_entries row),\n//   total referrer-earned lamports, total referee-rebate lamports, pending\n//   claim lamports, failed claim count, KOL count.\n// - listTopReferrers() — per-referrer aggregate with referee count, active\n//   referee count, referred wager volume, referrer earnings, and pending\n//   claim amount; used by the top-referrers table on /growth/referrals.\n// - listKolPerformance() — `referral_kol_rates` joined with the same\n//   per-referrer performance aggregates so the KOL table on /growth/kol can\n//   show rate alongside actual production.\n// - listReferralClaims() — filterable claims table reading from\n//   `referral_claims` joined with `player_profiles` for the username column.\n// - getReferralGraphNode() — one-hop referral-graph node centered on a user;\n//   surfaces inbound referrer (back-link) + outbound referees (drill into\n//   their user-detail pages). Re-uses the read paths the user-detail page\n//   already covers; collected here so the upcoming /growth/referrals graph\n//   navigation has a stable contract without changing user-detail.\n//\n// All queries are bounded server-side and rely only on existing tables.\n// Lamport / u64 sums round-trip as `text` to preserve precision.\n\nimport type { Sql } from \"postgres\";\nimport {\n  type PeekGrowthClaimRow,\n  type PeekGrowthOverview,\n  type PeekGrowthOverviewMetricId,\n  type PeekKolPerformanceRow,\n  type PeekMetric,\n  type PeekReferralClaimFilters,\n  type PeekReferralGraphNode,\n  type PeekReferralGraphRefereeRow,\n  type PeekTopReferrerRow,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport const PEEK_GROWTH_TOP_REFERRERS_DEFAULT_LIMIT = 50;\nexport const PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT = 250;\nexport const PEEK_GROWTH_KOL_DEFAULT_LIMIT = 100;\nexport const PEEK_GROWTH_KOL_MAX_LIMIT = 500;\nexport const PEEK_GROWTH_CLAIMS_DEFAULT_LIMIT = 100;\nexport const PEEK_GROWTH_CLAIMS_MAX_LIMIT = 500;\n\ntype GrowthOverviewOptions = {\n  sql?: Sql;\n  now?: Date;\n};\n\ntype ListLimitOptions = {\n  sql?: Sql;\n  limit?: number;\n};\n\nexport type ListReferralClaimsOptions = {\n  sql?: Sql;\n  limit?: number;\n  filters?: Partial<PeekReferralClaimFilters>;\n};\n\nexport type ReferralGraphOptions = {\n  sql?: Sql;\n  refereeLimit?: number;\n};\n\nfunction clampLimit(\n  raw: number | undefined,\n  fallback: number,\n  max: number,\n): number {\n  if (typeof raw !== \"number\" || !Number.isFinite(raw)) return fallback;\n  const floored = Math.floor(raw);\n  if (floored <= 0) return 1;\n  return Math.min(max, floored);\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");","numLines":80,"startLine":1,"totalLines":573}}}
