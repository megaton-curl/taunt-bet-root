{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01Nzavo3yuQ88nAXjh2yqhsm","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01LzrQXb3F1vXJVx9XdUZQGz","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/exports/csv.ts","content":"// Server-side CSV serialization for peek exports (FR-12).\n//\n// Minimal RFC 4180 emitter: header from `PeekTableColumn.label`, body from\n// `PeekExportRow` keyed by `PeekTableColumn.id`. Quoting is applied to any\n// field that contains `,`, `\"`, `\\r`, or `\\n`; embedded quotes are doubled.\n// Line endings are CRLF so the file opens cleanly in Excel and Google Sheets\n// without locale-specific reinterpretation.\n\nimport type { PeekExportRow, PeekTableColumn } from \"../../lib/types/peek\";\n\nconst NEEDS_QUOTING = /[\",\\r\\n]/;\n\nfunction escapeCsvField(value: string): string {\n  if (value === \"\") return \"\";\n  if (NEEDS_QUOTING.test(value)) {\n    return `\"${value.replace(/\"/g, '\"\"')}\"`;\n  }\n  return value;\n}\n\nexport function serializePeekCsv(\n  columns: ReadonlyArray<PeekTableColumn>,\n  rows: ReadonlyArray<PeekExportRow>,\n): string {\n  const header = columns.map((c) => escapeCsvField(c.label)).join(\",\");\n  const body = rows.map((row) =>\n    columns.map((c) => escapeCsvField(row[c.id] ?? \"\")).join(\",\"),\n  );\n  return [header, ...body].join(\"\\r\\n\") + \"\\r\\n\";\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":870,"cache_read_input_tokens":116377,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":870},"output_tokens":64,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"4cc437f6-074f-409d-aaec-b59a5e7b518d","uuid":"cb48d804-54a6-46fd-b38c-54e8315f231e"}
