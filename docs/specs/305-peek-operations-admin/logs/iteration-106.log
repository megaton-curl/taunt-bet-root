{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LRjx8myBKrtXz7VzrefzNu","type":"tool_result","content":"1\t// Filterable referral-claims table for /growth/referrals (FR-7).\n2\t//\n3\t// Renders a status chip per row and links the user cell to user-detail.\n4\timport Link from \"next/link\";\n5\timport type { CSSProperties } from \"react\";\n6\timport type {\n7\t  PeekGrowthClaimRow,\n8\t  PeekStatusTone,\n9\t} from \"../lib/types/peek\";\n10\timport { StatusChip } from \"./status-chip\";\n11\t\n12\texport type GrowthClaimsTableProps = {\n13\t  rows: ReadonlyArray<PeekGrowthClaimRow>;\n14\t  error?: string | null;\n15\t};\n16\t\n17\texport function GrowthClaimsTable({\n18\t  rows,\n19\t  error = null,\n20\t}: GrowthClaimsTableProps) {\n21\t  if (error) {\n22\t    return (\n23\t      <div role=\"alert\" style={errorStyle}>\n24\t        Claims unavailable: {error}\n25\t      </div>\n26\t    );\n27\t  }\n28\t\n29\t  if (rows.length === 0) {\n30\t    return (\n31\t      <div role=\"status\" style={emptyStyle}>\n32\t        <p style={emptyTitleStyle}>No claims match these filters.</p>\n33\t        <p style={emptyBodyStyle}>\n34\t          Adjust the filters above or clear them to see all recent referral\n35\t          claims.\n36\t        </p>\n37\t      </div>\n38\t    );\n39\t  }\n40\t\n41\t  return (\n42\t    <div style={wrapperStyle}>\n43\t      <table style={tableStyle}>\n44\t        <thead>\n45\t          <tr style={headerRowStyle}>\n46\t            <th style={headerCellStyle(\"left\")}>Requested</th>\n47\t            <th style={headerCellStyle(\"left\")}>User</th>\n48\t            <th style={headerCellStyle(\"left\")}>Wallet</th>\n49\t            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>\n50\t            <th style={headerCellStyle(\"left\")}>Status</th>\n51\t            <th style={headerCellStyle(\"right\")}>Retries</th>\n52\t            <th style={headerCellStyle(\"left\")}>Tx signature</th>\n53\t            <th style={headerCellStyle(\"left\")}>Processed</th>\n54\t            <th style={headerCellStyle(\"left\")}>Error</th>\n55\t          </tr>\n56\t        </thead>\n57\t        <tbody>\n58\t          {rows.map((row) => (\n59\t            <tr key={row.id} style={bodyRowStyle}>\n60\t              <td style={bodyCellStyle(\"left\")}>{row.requestedAt}</td>\n61\t              <td style={bodyCellStyle(\"left\")}>\n62\t                <Link href={`/users/${row.userId}`} style={linkStyle}>\n63\t                  {row.username ?? row.userId}\n64\t                </Link>\n65\t                {row.username ? (\n66\t                  <span style={subValueStyle}> · {row.userId}</span>\n67\t                ) : null}\n68\t              </td>\n69\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n70\t                {row.wallet}\n71\t              </td>\n72\t              <td style={bodyCellStyle(\"right\")}>\n73\t                {formatLamports(row.amountLamports)}\n74\t              </td>\n75\t              <td style={bodyCellStyle(\"left\")}>\n76\t                <StatusChip\n77\t                  label={row.status}\n78\t                  tone={statusTone(row.status)}\n79\t                />\n80\t              </td>\n81\t              <td style={bodyCellStyle(\"right\")}>{row.retryCount}</td>\n82\t              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n83\t                {row.txSignature ?? \"—\"}\n84\t              </td>\n85\t              <td style={bodyCellStyle(\"left\")}>{row.processedAt ?? \"—\"}</td>\n86\t              <td style={bodyCellStyle(\"left\")}>{row.error ?? \"—\"}</td>\n87\t            </tr>\n88\t          ))}\n89\t        </tbody>\n90\t      </table>\n91\t    </div>\n92\t  );\n93\t}\n94\t\n95\tfunction statusTone(status: string): PeekStatusTone {\n96\t  if (status === \"completed\") return \"positive\";\n97\t  if (status === \"failed\" || status === \"error\") return \"negative\";\n98\t  if (status === \"pending\" || status === \"processing\") return \"info\";\n99\t  return \"neutral\";\n100\t}\n101\t\n102\tfunction formatLamports(value: string): string {\n103\t  if (!value || value === \"0\") return \"0\";\n104\t  const negative = value.startsWith(\"-\");\n105\t  const digits = negative ? value.slice(1) : value;\n106\t  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n107\t  return negative ? `-${grouped}` : grouped;\n108\t}\n109\t\n110\tconst wrapperStyle: CSSProperties = {\n111\t  overflowX: \"auto\",\n112\t  border: \"1px solid #1e293b\",\n113\t  borderRadius: \"0.75rem\",\n114\t};\n115\t\n116\tconst tableStyle: CSSProperties = {\n117\t  width: \"100%\",\n118\t  borderCollapse: \"collapse\",\n119\t};\n120\t\n121\tconst headerRowStyle: CSSProperties = {\n122\t  background: \"#111827\",\n123\t  color: \"#94a3b8\",\n124\t};\n125\t\n126\tconst bodyRowStyle: CSSProperties = {\n127\t  borderTop: \"1px solid #1e293b\",\n128\t};\n129\t\n130\tconst linkStyle: CSSProperties = {\n131\t  color: \"#93c5fd\",\n132\t  textDecoration: \"none\",\n133\t};\n134\t\n135\tconst subValueStyle: CSSProperties = {\n136\t  color: \"#64748b\",\n137\t  fontSize: \"0.75rem\",\n138\t  marginLeft: \"0.25rem\",\n139\t};\n140\t\n141\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n142\t  return {\n143\t    padding: \"0.75rem\",\n144\t    textAlign: align,\n145\t    fontSize: \"0.875rem\",\n146\t    fontWeight: 600,\n147\t  };\n148\t}\n149\t\n150\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n151\t  return {\n152\t    padding: \"0.75rem\",\n153\t    textAlign: align,\n154\t    fontSize: \"0.875rem\",\n155\t  };\n156\t}\n157\t\n158\tconst errorStyle: CSSProperties = {\n159\t  margin: 0,\n160\t  padding: \"0.75rem 1rem\",\n161\t  borderRadius: \"0.75rem\",\n162\t  background: \"#3f1d1d\",\n163\t  color: \"#fecaca\",\n164\t};\n165\t\n166\tconst emptyStyle: CSSProperties = {\n167\t  padding: \"1.5rem\",\n168\t  borderRadius: \"0.75rem\",\n169\t  border: \"1px dashed #334155\",\n170\t  background: \"#0b1220\",\n171\t  color: \"#cbd5f5\",\n172\t  display: \"grid\",\n173\t  gap: \"0.5rem\",\n174\t};\n175\t\n176\tconst emptyTitleStyle: CSSProperties = {\n177\t  margin: 0,\n178\t  fontSize: \"1rem\",\n179\t  fontWeight: 600,\n180\t};\n181\t\n182\tconst emptyBodyStyle: CSSProperties = {\n183\t  margin: 0,\n184\t  fontSize: \"0.875rem\",\n185\t  color: \"#94a3b8\",\n186\t};\n187\t"}]},"parent_tool_use_id":null,"session_id":"4cc437f6-074f-409d-aaec-b59a5e7b518d","uuid":"b89ef05c-5485-4f46-8b6f-953a243a7c75","timestamp":"2026-04-26T07:33:11.299Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/growth-claims-table.tsx","content":"// Filterable referral-claims table for /growth/referrals (FR-7).\n//\n// Renders a status chip per row and links the user cell to user-detail.\nimport Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekGrowthClaimRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type GrowthClaimsTableProps = {\n  rows: ReadonlyArray<PeekGrowthClaimRow>;\n  error?: string | null;\n};\n\nexport function GrowthClaimsTable({\n  rows,\n  error = null,\n}: GrowthClaimsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Claims unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No claims match these filters.</p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see all recent referral\n          claims.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Requested</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>\n            <th style={headerCellStyle(\"left\")}>Status</th>\n            <th style={headerCellStyle(\"right\")}>Retries</th>\n            <th style={headerCellStyle(\"left\")}>Tx signature</th>\n            <th style={headerCellStyle(\"left\")}>Processed</th>\n            <th style={headerCellStyle(\"left\")}>Error</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => (\n            <tr key={row.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{row.requestedAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <Link href={`/users/${row.userId}`} style={linkStyle}>\n                  {row.username ?? row.userId}\n                </Link>\n                {row.username ? (\n                  <span style={subValueStyle}> · {row.userId}</span>\n                ) : null}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.wallet}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatLamports(row.amountLamports)}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip\n                  label={row.status}\n                  tone={statusTone(row.status)}\n                />\n              </td>\n              <td style={bodyCellStyle(\"right\")}>{row.retryCount}</td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                {row.txSignature ?? \"—\"}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{row.processedAt ?? \"—\"}</td>\n              <td style={bodyCellStyle(\"left\")}>{row.error ?? \"—\"}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction statusTone(status: string): PeekStatusTone {\n  if (status === \"completed\") return \"positive\";\n  if (status === \"failed\" || status === \"error\") return \"negative\";\n  if (status === \"pending\" || status === \"processing\") return \"info\";\n  return \"neutral\";\n}\n\nfunction formatLamports(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n  marginLeft: \"0.25rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":187,"startLine":1,"totalLines":187}}}
