{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01NeTpjmQdcD8qvLXhZdn133","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01CYy8fvYXwJfVqEzyPVKE9r","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/exports/exporters/referrers.ts","content":"// Top-referrers exporter (FR-7, FR-12).\n//\n// Backs the `referrers` export entity used by `/growth/referrals`. The list\n// is bounded-by-default (the query module always orders by earnings DESC and\n// applies a hard `PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT` ceiling), so an\n// \"unfiltered\" export here is still a bounded, ranked table — not a full\n// dump of `referral_links`. Therefore `requireAtLeastOneFilter` is `false`.\n\nimport {\n  listTopReferrers,\n  PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT,\n} from \"../../db/queries/get-growth-referrals\";\nimport type {\n  PeekTableColumn,\n  PeekTopReferrerRow,\n} from \"../../../lib/types/peek\";\nimport type { PeekExporterDefinition } from \"../registry\";\n\nconst REFERRER_COLUMNS: ReadonlyArray<PeekTableColumn> = [\n  {\n    id: \"referrerUserId\",\n    label: \"Referrer user id\",\n    align: \"left\",\n    sortable: false,\n  },\n  { id: \"username\", label: \"Username\", align: \"left\", sortable: false },\n  { id: \"wallet\", label: \"Wallet\", align: \"left\", sortable: false },\n  {\n    id: \"referralCode\",\n    label: \"Referral code\",\n    align: \"left\",\n    sortable: false,\n  },\n  {\n    id: \"refereeCount\",\n    label: \"Referees\",\n    align: \"right\",\n    sortable: false,\n  },\n  {\n    id: \"activeRefereeCount\",\n    label: \"Active referees\",\n    align: \"right\",\n    sortable: false,\n  },\n  {\n    id: \"referredWagerLamports\",\n    label: \"Referred wager (lamports)\",\n    align: \"right\",\n    sortable: false,\n  },\n  {\n    id: \"referrerEarnedLamports\",\n    label: \"Referrer earned (lamports)\",\n    align: \"right\",\n    sortable: false,\n  },\n  {\n    id: \"pendingClaimLamports\",\n    label: \"Pending claim (lamports)\",\n    align: \"right\",\n    sortable: false,\n  },\n];\n\nfunction rowToCsv(row: PeekTopReferrerRow): Record<string, string> {\n  return {\n    referrerUserId: row.referrerUserId,\n    username: row.username ?? \"\",\n    wallet: row.wallet,\n    referralCode: row.referralCode ?? \"\",\n    refereeCount: row.refereeCount.toString(),\n    activeRefereeCount: row.activeRefereeCount.toString(),\n    referredWagerLamports: row.referredWagerLamports,\n    referrerEarnedLamports: row.referrerEarnedLamports,\n    pendingClaimLamports: row.pendingClaimLamports,\n  };\n}\n\nexport const REFERRERS_EXPORTER: PeekExporterDefinition = {\n  entity: \"referrers\",\n  resourceType: \"referral_top_referrer\",\n  columns: REFERRER_COLUMNS,\n  maxRowsPerExport: PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT,\n  requireAtLeastOneFilter: false,\n  async fetch(ctx) {\n    const rows = await listTopReferrers({\n      sql: ctx.sql,\n      limit: ctx.rowCap + 1,\n    });\n    const rowCapApplied = rows.length > ctx.rowCap;\n    const trimmed = rowCapApplied ? rows.slice(0, ctx.rowCap) : rows;\n    return {\n      rows: trimmed.map(rowToCsv),\n      rowCapApplied,\n    };\n  },\n  buildFilterSlug() {\n    // The top-referrers list has no user-supplied filter axis; the bound is\n    // an implicit ranked-list limit. Returning an empty slug yields a\n    // deterministic `peek-referrers-YYYY-MM-DD.csv` filename.\n    return \"\";\n  },\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2108,"cache_read_input_tokens":119385,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2108},"output_tokens":64,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"4cc437f6-074f-409d-aaec-b59a5e7b518d","uuid":"a478d030-817e-4567-a6d7-b20cfcf1d0f