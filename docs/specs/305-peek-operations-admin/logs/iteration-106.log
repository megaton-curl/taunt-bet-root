ty;\n  resourceType: string;\n  columns: ReadonlyArray<PeekTableColumn>;\n  // FR-12: bound the export to a per-entity max so a caller cannot request more\n  // rows than the underlying query module is willing to surface in one shot.\n  maxRowsPerExport: number;\n  // FR-12: refuse \"no filter\" exports for tables whose unfiltered shape would\n  // be a full-table dump. Bounded-by-default tables (top referrers, KOL) set\n  // this to `false` because the query module already enforces a hard limit.\n  requireAtLeastOneFilter: boolean;\n  fetch: (ctx: PeekExporterFetchContext) => Promise<PeekExporterFetchResult>;\n  buildFilterSlug: (filters: PeekExporterFilters) => string;\n};\n\nexport type PeekExporterRegistry = Readonly<\n  Partial<Record<PeekExportEntity, PeekExporterDefinition>>\n>;\n\nconst entries: ReadonlyArray<PeekExporterDefinition> = [\n  CLAIMS_EXPORTER,\n  REFERRERS_EXPORTER,\n  KOL_EXPORTER,\n];\n\nexport const PEEK_EXPORTERS: PeekExporterRegistry = Object.freeze(\n  entries.reduce<Record<string, PeekExporterDefinition>>((acc, def) => {\n    acc[def.entity] = def;\n    return acc;\n  }, {}),\n);\n\nexport function getPeekExporter(\n  entity: PeekExportEntity,\n  registry: PeekExporterRegistry = PEEK_EXPORTERS,\n): PeekExporterDefinition | null {\n  return registry[entity] ?? null;\n}\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01Y5dZQLbdVurgYNhWZ78iYo","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01UVcW8KaS4sC7BND6rZxVKc","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/exports/exporters/claims.ts","content":"// Referral claims exporter (FR-7, FR-12).\n//\n// Backs the `claims` export entity used by `/growth/referrals`. The fetch path\n// reuses `listReferralClaims` so the column set matches what the page renders;\n// row limits are honored through the query module's own clamp ceiling so the\n// export cannot exceed `PEEK_GROWTH_CLAIMS_MAX_LIMIT`.\n\nimport {\n  listReferralClaims,\n  PEEK_GROWTH_CLAIMS_MAX_LIMIT,\n} from \"../../db/queries/get-growth-referrals\";\nimport type {\n  PeekGrowthClaimRow,\n  PeekReferralClaimFilters,\n  PeekTableColumn,\n} from \"../../../lib/types/peek\";\nimport type {\n  PeekExporterDefinition,\n  PeekExporterFilters,\n} from \"../registry\";\nimport { slugForFilename } from \"../filename\";\n\nconst CLAIM_COLUMNS: ReadonlyArray<PeekTableColumn> = [\n  { id: \"id\", label: \"Claim id\", align: \"left\", sortable: false },\n  { id: \"userId\", label: \"User id\", align: \"left\", sortable: false },\n  { id: \"username\", label: \"Username\", align: \"left\", sortable: false },\n  { id: \"wallet\", label: \"Wallet\", align: \"left\", sortable: false },\n  {\n    id: \"amountLamports\",\n    label: \"Amount (lamports)\",\n    align: \"right\",\n    sortable: false,\n  },\n  { id: \"status\", label: \"Status\", align: \"left\", sortable: false },\n  { id: \"retryCount\", label: \"Retries\", align: \"right\", sortable: false },\n  { id: \"txSignature\", label: \"Tx signature\", align: \"left\", sortable: false },\n  { id: \"requestedAt\", label: \"Requested\", align: \"left\", sortable: false },\n  { id: \"processedAt\", label: \"Processed\", align: \"left\", sortable: false },\n  { id: \"error\", label: \"Error\", align: \"left\", sortable: false },\n];\n\nexport const CLAIM_EXPORT_FILTER_KEYS = [\n  \"status\",\n  \"userId\",\n  \"minAmountLamports\",\n  \"maxAmountLamports\",\n  \"requestedFrom\",\n  \"requestedTo\",\n  \"txSignature\",\n  \"errorContains\",\n] as const satisfies ReadonlyArray<keyof PeekReferralClaimFilters>;\n\nfunction pickClaimFilters(\n  filters: PeekExporterFilters,\n): Partial<PeekReferralClaimFilters> {\n  const out: Partial<PeekReferralClaimFilters> = {};\n  for (const key of CLAIM_EXPORT_FILTER_KEYS) {\n    const raw = filters[key];\n    if (raw !== null && raw !== undefined && raw !== \"\") {\n      out[key] = raw;\n    }\n  }\n  return out;\n}\n\nfunction rowToCsv(row: PeekGrowthClaimRow): Record<string, string> {\n  return {\n    id: row.id,\n    userId: row.userId,\n    username: row.username ?? \"\",\n    wallet: row.wallet,\n    amountLamports: row.amountLamports,\n    status: row.status,\n    retryCount: row.retryCount.toString(),\n    txSignature: row.txSignature ?? \"\",\n    requestedAt: row.requestedAt,\n    processedAt: row.processedAt ?? \"\",\n    error: row.error ?? \"\",\n  };\n}\n\nexport const CLAIMS_EXPORTER: PeekExporterDefinition = {\n  entity: \"claims\",\n  resourceType: \"referral_claim\",\n  columns: CLAIM_COLUMNS,\n  maxRowsPerExport: PEEK_GROWTH_CLAIMS_MAX_LIMIT,\n  requireAtLeastOneFilter: true,\n  async fetch(ctx) {\n    const filters = pickClaimFilters(ctx.filters);\n    // Request rowCap + 1 so the runner can detect that the cap was the limiter\n    // (rather than the underlying SQL exhausting). The query module clamps to\n    // its own MAX, but `maxRowsPerExport` already keeps `rowCap` ≤ that max.\n    const rows = await listReferralClaims({\n      sql: ctx.sql,\n      limit: ctx.rowCap + 1,\n      filters,\n    });\n    const rowCapApplied = rows.length > ctx.rowCap;\n    const trimmed = rowCapApplied ? rows.slice(0, ctx.rowCap) : rows;\n    return {\n      rows: trimmed.map(rowToCsv),\n      rowCapApplied,\n    };\n  },\n  buildFilterSlug(filters) {\n    const parts: string[] = [];\n    if (filters.status) parts.push(`status-${slugForFilename(filters.status)}`);\n    if (filters.userId) parts.push(`user-${slugForFilename(filters.userId)}`);\n    if (filters.txSignature) {\n      parts.push(`tx-${slugForFilename(filters.txSignature).slice(0, 12)}`);\n    }\n    if (filters.minAmountLamports) {\n      parts.push(`min-${slugForFilename(filters.minAmountLamports)}`);\n    }\n    if (filters.maxAmountLamports) {\n      parts.push(`max-${slugForFilename(filters.maxAmountLamports)}`);\n    }\n    if (filters.requestedFrom) {\n      parts.push(`from-${slugForFilename(filters.requestedFrom).slice(0, 10)}`);\n    }\n    if (filters.requestedTo) {\n      parts.push(`to-${slugForFilename(filters.requestedTo).slice(0, 10)}`);\n    }\n    return parts.join(\"_\");\n  },\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1493,"cache_read_input_tokens":117892,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1493},"output_tokens":68,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"4cc437f6-074f-409d-aaec-b59a5e7b518d","uuid":"af400d1a-699d-4745-b9ba-a43b66be617a"}
