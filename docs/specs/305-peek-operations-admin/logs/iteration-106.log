,\n    align: \"right\",\n    sortable: false,\n  },\n];\n\nfunction rowToCsv(row: PeekKolPerformanceRow): Record<string, string> {\n  return {\n    userId: row.userId,\n    username: row.username ?? \"\",\n    wallet: row.wallet,\n    rateBps: row.rateBps.toString(),\n    setBy: row.setBy,\n    createdAt: row.createdAt,\n    updatedAt: row.updatedAt,\n    refereeCount: row.refereeCount.toString(),\n    referredWagerLamports: row.referredWagerLamports,\n    referrerEarnedLamports: row.referrerEarnedLamports,\n  };\n}\n\nexport const KOL_EXPORTER: PeekExporterDefinition = {\n  entity: \"kol\",\n  resourceType: \"referral_kol_rate\",\n  columns: KOL_COLUMNS,\n  maxRowsPerExport: PEEK_GROWTH_KOL_MAX_LIMIT,\n  requireAtLeastOneFilter: false,\n  async fetch(ctx) {\n    const rows = await listKolPerformance({\n      sql: ctx.sql,\n      limit: ctx.rowCap + 1,\n    });\n    const rowCapApplied = rows.length > ctx.rowCap;\n    const trimmed = rowCapApplied ? rows.slice(0, ctx.rowCap) : rows;\n    return {\n      rows: trimmed.map(rowToCsv),\n      rowCapApplied,\n    };\n  },\n  buildFilterSlug() {\n    return \"\";\n  },\n};\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01T15RuwciGt3A2d6ERgQCx7","type":"message","role":"assistant","content":[{"type":"text","text":"Now the runner:"}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1296,"cache_read_input_tokens":123018,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1296},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"4cc437f6-074f-409d-aaec-b59a5e7b518d","uuid":"081cceeb-cdfa-4b31-b9f4-8d03edc77661"}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01T15RuwciGt3A2d6ERgQCx7","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_012QtV26VDirCTRRWk8H8jsy","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/exports/runner.ts","content":"// Server-side export runner (FR-12).\n//\n// Orchestrates a single CSV export end to end:\n//   1. Look up the approved exporter for the requested entity.\n//   2. Refuse \"no filter\" exports when the exporter requires at least one\n//      filter (avoids unfiltered full-table dumps per FR-12).\n//   3. Refuse the export in production when audit logging is not configured\n//      (\"Exports are disabled in production if audit logging is not\n//      configured.\" — FR-12 last bullet).\n//   4. Compute an effective row cap bounded by the per-entity ceiling\n//      (`maxRowsPerExport`) and the global default (`PEEK_EXPORT_ROW_CAP_DEFAULT`).\n//   5. Invoke the exporter's `fetch` to build the view-model rows.\n//   6. Emit a `peek.export` audit event BEFORE returning the rows. If audit\n//      emission fails, refuse to return the rows so we never serve data we\n//      could not record.\n//\n// The runner is dependency-injectable for tests: callers can pass a mock\n// `Sql`, a custom registry, a custom audit emitter, and a custom env.\n\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_EXPORT_ROW_CAP_DEFAULT,\n  type PeekExportEntity,\n  type PeekExportResult,\n} from \"../../lib/types/peek\";\nimport {\n  writePeekAuditEvent,\n  type PeekAuditWriteResult,\n} from \"../audit/writer\";\nimport { getSqlClient } from \"../db/client\";\nimport { buildPeekExportFilename } from \"./filename\";\nimport {\n  getPeekExporter,\n  PEEK_EXPORTERS,\n  type PeekExporterDefinition,\n  type PeekExporterFilters,\n  type PeekExporterRegistry,\n} from \"./registry\";\n\nexport type PeekExportFailureReason =\n  | \"unknown_entity\"\n  | \"no_filters\"\n  | \"audit_unavailable\"\n  | \"audit_emit_failed\";\n\nexport type PeekExportRunResult =\n  | { ok: true; result: PeekExportResult }\n  | { ok: false; reason: PeekExportFailureReason; message: string };\n\nexport type PeekExportActorContext = {\n  email: string;\n  route: string | null;\n  requestId?: string | null;\n};\n\nexport type PeekExportAuditWriter = (\n  input: Parameters<typeof writePeekAuditEvent>[0],\n  options?: Parameters<typeof writePeekAuditEvent>[1],\n) => Promise<PeekAuditWriteResult>;\n\nexport type PeekExportRunInput = {\n  entity: PeekExportEntity;\n  filters?: PeekExporterFilters;\n  rowCap?: number;\n  actor: PeekExportActorContext;\n  now?: Date;\n  sql?: Sql;\n  registry?: PeekExporterRegistry;\n  auditWriter?: PeekExportAuditWriter;\n  env?: NodeJS.ProcessEnv;\n};\n\n// Production gate: exports refuse to run when audit logging cannot be\n// configured. The audit writer reads `DATABASE_URL` via `getSqlClient` so the\n// \"configured\" signal is the same env var that would let the writer connect.\nexport function isPeekAuditConfigured(\n  env: NodeJS.ProcessEnv = process.env,\n): boolean {\n  const url = env.DATABASE_URL;\n  return typeof url === \"string\" && url.length > 0;\n}\n\nfunction isProduction(env: NodeJS.ProcessEnv): boolean {\n  return env.NODE_ENV === \"production\";\n}\n\nfunction hasAnyFilter(filters: PeekExporterFilters): boolean {\n  for (const value of Object.values(filters)) {\n    if (value !== null && value !== undefined && value !== \"\") return true;\n  }\n  return false;\n}\n\nfunction clampRowCap(\n  raw: number | undefined,\n  perEntityMax: number,\n): number {\n  const ceiling = Math.max(1, Math.min(perEntityMax, PEEK_EXPORT_ROW_CAP_DEFAULT));\n  if (typeof raw !== \"number\" || !Number.isFinite(raw) || raw <= 0) {\n    return ceiling;\n  }\n  return Math.min(ceiling, Math.floor(raw));\n}\n\nfunction summarizeFilters(filters: PeekExporterFilters): string | null {\n  const entries = Object.entries(filters)\n    .filter(\n      ([, value]) => value !== null && value !== undefined && value !== \"\",\n    )\n    .map(([key, value]) => `${key}=${value as string}`);\n  return entries.length > 0 ? entries.join(\", \") : null;\n}\n\nfunction todayDateString(now: Date): string {\n  return now.toISOString().slice(0, 10);\n}\n\nasync function emitExportAudit(\n  exporter: PeekExporterDefinition,\n  input: PeekExportRunInput,\n  filters: PeekExporterFilters,\n  resultCount: number,\n  sql: Sql,\n): Promise<PeekAuditWriteResult> {\n  const writer = input.auditWriter ?? writePeekAuditEvent;\n  return writer(\n    {\n      eventType: \"peek.export\",\n      payload: {\n        actorEmail: input.actor.email,\n        route: input.actor.route ?? null,\n        actionId: `export.${exporter.entity}`,\n        resourceType: exporter.resourceType,\n        resourceId: null,\n        filterSummary: summarizeFilters(filters),\n        resultCount,\n        requestId: input.actor.requestId ?? null,\n        rejectionReason: null,\n        changes: null,\n      },\n    },\n    { sql },\n  );\n}\n\nexport async function runPeekExport(\n  input: PeekExportRunInput,\n): Promise<PeekExportRunResult> {\n  const env = input.env ?? process.env;\n  const registry = input.registry ?? PEEK_EXPORTERS;\n  const exporter = getPeekExporter(input.entity, registry);\n  if (!exporter) {\n    return {\n      ok: false,\n      reason: \"unknown_entity\",\n      message: `No approved peek exporter for entity \"${input.entity}\".`,\n    };\n  }\n\n  const filters = input.filters ?? {};\n\n  if (exporter.requireAtLeastOneFilter && !hasAnyFilter(filters)) {\n    return {\n      ok: false,\n      reason: \"no_filters\",\n      message: `Export \"${input.entity}\" requires at least one filter.`,\n    };\n  }\n\n  if (isProduction(env) && !isPeekAuditConfigured(env)) {\n    return {\n      ok: false,\n      reason: \"audit_unavailable\",\n      message:\n        'Exports are disabled in production when audit logging is not configured.',\n    };\n  }\n\n  const rowCap = clampRowCap(input.rowCap, exporter.maxRowsPerExport);\n  const sql = input.sql ?? (getSqlClient() as unknown as Sql);\n  const now = input.now ?? new Date();\n\n  const fetchResult = await exporter.fetch({ sql, rowCap, filters });\n\n  const auditResult = await emitExportAudit(\n    exporter,\n    input,\n    filters,\n    fetchResult.rows.length,\n    sql,\n  );\n  if (!auditResult.ok) {\n    return {\n      ok: false,\n      reason: \"audit_emit_failed\",\n      message: `Audit emission failed (${auditResult.reason}); refusing to return export rows.`,\n    };\n  }\n\n  const filename = buildPeekExportFilename({\n    entity: exporter.entity,\n    date: todayDateString(now),\n    filterSlug: exporter.buildFilterSlug(filters),\n  });\n\n  return {\n    ok: true,\n    result: {\n      filename,\n      rowCount: fetchResult.rows.length,\n      rowCap,\n      rowCapApplied: fetchResult.rowCapApplied,\n      columns: exporter.columns,\n      rows: fetchResult.rows,\n    },\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1296,"cache_read_input_tokens":123018,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1296},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"4cc437f6-074f-409d-aaec-b59a5e7b518d","uuid":"ecc1b857-5935-4b29-a7d0-59f35299cb86"}
