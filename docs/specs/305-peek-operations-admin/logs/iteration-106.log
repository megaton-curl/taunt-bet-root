{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VPq4ob4dm2QY7mkQo5xcMC","type":"tool_result","content":"460\t  | \"audit.access_denied_24h\"\n461\t  | \"audit.changes_applied_24h\"\n462\t  | \"audit.changes_rejected_24h\";\n463\t\n464\texport type PeekAuditOverview = {\n465\t  generatedAt: string;\n466\t  metrics: ReadonlyArray<PeekMetric>;\n467\t  eventTypeCounts: ReadonlyArray<PeekAuditEventTypeCount>;\n468\t};\n469\t\n470\t// --- Export contracts (FR-12) ------------------------------------------------\n471\t//\n472\t// Exports are server-rendered CSVs gated by the same page-level access as the\n473\t// source page, bounded by a server-side row cap, named with a deterministic\n474\t// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n475\t// bytes return. Export rows reuse the table view-model column ids so the export\n476\t// shape stays in lockstep with the rendered table; values are pre-formatted\n477\t// strings so CSV serialization stays straightforward and locale-stable.\n478\t\n479\texport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n480\t\n481\texport type PeekExportEntity =\n482\t  | \"users\"\n483\t  | \"referrers\"\n484\t  | \"kol\"\n485\t  | \"claims\"\n486\t  | \"rounds\"\n487\t  | \"transactions\"\n488\t  | \"queue\"\n489\t  | \"audit\";\n490\t\n491\texport type PeekExportRow = Record<string, string>;\n492\t\n493\texport type PeekExportFilenameInput = {\n494\t  entity: PeekExportEntity;\n495\t  date: string;\n496\t  filterSlug: string;\n497\t};\n498\t\n499\texport type PeekExportResult = {\n500\t  filename: string;\n501\t  rowCount: number;\n502\t  rowCap: number;\n503\t  rowCapApplied: boolean;\n504\t  columns: ReadonlyArray<PeekTableColumn>;\n505\t  rows: ReadonlyArray<PeekExportRow>;\n506\t};\n507\t\n508\t// --- Universal search (FR-5) -------------------------------------------------\n509\t//\n510\t// One search entry point that resolves common operational identifiers to typed\n511\t// result groups. Results are grouped by entity type so the UI can section them\n512\t// (user, referral, linked account, round, transaction, queue event). Each\n513\t// result includes enough context to disambiguate similar matches; sensitive\n514\t// values (wallet, Telegram id, tx signature) live in the result's `id`/`label`\n515\t// fields for operator readability and the audit event records only the actor\n516\t// email, query class, and result counts (never the raw query, which the audit\n517\t// writer redacts if it looks like a secret).\n518\t\n519\texport type PeekSearchEntityType =\n520\t  | \"user\"\n521\t  | \"referral\"\n522\t  | \"linked_account\"\n523\t  | \"round\"\n524\t  | \"transaction\"\n525\t  | \"queue_event\";\n526\t\n527\texport const PEEK_SEARCH_ENTITY_TYPES: ReadonlyArray<PeekSearchEntityType> = [\n528\t  \"user\",\n529\t  \"referral\",\n530\t  \"linked_account\",\n531\t  \"round\",\n532\t  \"transaction\",\n533\t  \"queue_event\",\n534\t];\n535\t\n536\t// Coarse heuristic classification used only for the `peek.search` audit\n537\t// summary so reviewers can see which class of identifier was searched without\n538\t// inferring it from the (possibly redacted) raw query.\n539\texport type PeekSearchQueryClass =\n540\t  | \"empty\"\n541\t  | \"free_text\"\n542\t  | \"user_id\"\n543\t  | \"username\"\n544\t  | \"wallet\"\n545\t  | \"referral_code\"\n546\t  | \"telegram_username\"\n547\t  | \"telegram_provider_id\"\n548\t  | \"round_pda\"\n549\t  | \"match_id\"\n550\t  | \"tx_signature\"\n551\t  | \"queue_event_id\";\n552\t\n553\texport type PeekSearchResult = {\n554\t  entityType: PeekSearchEntityType;\n555\t  id: string;\n556\t  label: string;\n557\t  sublabel: string | null;\n558\t  context: string | null;\n559\t  href: string;\n560\t};\n561\t\n562\texport type PeekSearchGroup = {\n563\t  entityType: PeekSearchEntityType;\n564\t  results: ReadonlyArray<PeekSearchResult>;\n565\t  truncated: boolean;\n566\t};\n567\t\n568\texport type PeekSearchResponse = {\n569\t  query: string;\n570\t  queryClass: PeekSearchQueryClass;\n571\t  groups: ReadonlyArray<PeekSearchGroup>;\n572\t  totalResults: number;\n573\t  perGroupLimit: number;\n574\t  generatedAt: string;\n575\t};\n576\t\n577\texport const PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT = 5;\n578\texport const PEEK_SEARCH_MAX_PER_GROUP_LIMIT = 25;\n579\t"}]},"parent_tool_use_id":null,"session_id":"4cc437f6-074f-409d-aaec-b59a5e7b518d","uuid":"dfd785d5-135d-4644-90ae-a72b18c90ffa","timestamp":"2026-04-26T07:32:50.384Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","content":"  | \"audit.access_denied_24h\"\n  | \"audit.changes_applied_24h\"\n  | \"audit.changes_rejected_24h\";\n\nexport type PeekAuditOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n  eventTypeCounts: ReadonlyArray<PeekAuditEventTypeCount>;\n};\n\n// --- Export contracts (FR-12) ------------------------------------------------\n//\n// Exports are server-rendered CSVs gated by the same page-level access as the\n// source page, bounded by a server-side row cap, named with a deterministic\n// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n// bytes return. Export rows reuse the table view-model column ids so the export\n// shape stays in lockstep with the rendered table; values are pre-formatted\n// strings so CSV serialization stays straightforward and locale-stable.\n\nexport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n\nexport type PeekExportEntity =\n  | \"users\"\n  | \"referrers\"\n  | \"kol\"\n  | \"claims\"\n  | \"rounds\"\n  | \"transactions\"\n  | \"queue\"\n  | \"audit\";\n\nexport type PeekExportRow = Record<string, string>;\n\nexport type PeekExportFilenameInput = {\n  entity: PeekExportEntity;\n  date: string;\n  filterSlug: string;\n};\n\nexport type PeekExportResult = {\n  filename: string;\n  rowCount: number;\n  rowCap: number;\n  rowCapApplied: boolean;\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<PeekExportRow>;\n};\n\n// --- Universal search (FR-5) -------------------------------------------------\n//\n// One search entry point that resolves common operational identifiers to typed\n// result groups. Results are grouped by entity type so the UI can section them\n// (user, referral, linked account, round, transaction, queue event). Each\n// result includes enough context to disambiguate similar matches; sensitive\n// values (wallet, Telegram id, tx signature) live in the result's `id`/`label`\n// fields for operator readability and the audit event records only the actor\n// email, query class, and result counts (never the raw query, which the audit\n// writer redacts if it looks like a secret).\n\nexport type PeekSearchEntityType =\n  | \"user\"\n  | \"referral\"\n  | \"linked_account\"\n  | \"round\"\n  | \"transaction\"\n  | \"queue_event\";\n\nexport const PEEK_SEARCH_ENTITY_TYPES: ReadonlyArray<PeekSearchEntityType> = [\n  \"user\",\n  \"referral\",\n  \"linked_account\",\n  \"round\",\n  \"transaction\",\n  \"queue_event\",\n];\n\n// Coarse heuristic classification used only for the `peek.search` audit\n// summary so reviewers can see which class of identifier was searched without\n// inferring it from the (possibly redacted) raw query.\nexport type PeekSearchQueryClass =\n  | \"empty\"\n  | \"free_text\"\n  | \"user_id\"\n  | \"username\"\n  | \"wallet\"\n  | \"referral_code\"\n  | \"telegram_username\"\n  | \"telegram_provider_id\"\n  | \"round_pda\"\n  | \"match_id\"\n  | \"tx_signature\"\n  | \"queue_event_id\";\n\nexport type PeekSearchResult = {\n  entityType: PeekSearchEntityType;\n  id: string;\n  label: string;\n  sublabel: string | null;\n  context: string | null;\n  href: string;\n};\n\nexport type PeekSearchGroup = {\n  entityType: PeekSearchEntityType;\n  results: ReadonlyArray<PeekSearchResult>;\n  truncated: boolean;\n};\n\nexport type PeekSearchResponse = {\n  query: string;\n  queryClass: PeekSearchQueryClass;\n  groups: ReadonlyArray<PeekSearchGroup>;\n  totalResults: number;\n  perGroupLimit: number;\n  generatedAt: string;\n};\n\nexport const PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT = 5;\nexport const PEEK_SEARCH_MAX_PER_GROUP_LIMIT = 25;\n","numLines":120,"startLine":460,"totalLines":1476}}}
