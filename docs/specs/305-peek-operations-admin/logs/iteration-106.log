e {\n  return (\n    typeof value === \"string\" &&\n    (PEEK_AUDIT_EVENT_TYPES as ReadonlyArray<string>).includes(value)\n  );\n}\n\nexport const PEEK_AUDIT_REDACTED = \"[REDACTED]\";\n\nexport type PeekAuditScalar = string | number | boolean | null;\n\nexport type PeekAuditChange = {\n  field: string;\n  before: PeekAuditScalar;\n  after: PeekAuditScalar;\n};\n\nexport type PeekAuditPayload = {\n  actorEmail: string;\n  route: string | null;\n  actionId: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  filterSummary: string | null;\n  resultCount: number | null;\n  requestId: string | null;\n  rejectionReason: string | null;\n  changes: ReadonlyArray<PeekAuditChange> | null;\n};\n\nexport type PeekAuditEvent = {\n  id: string;\n  eventType: PeekAuditEventType;\n  createdAt: string;\n  payload: PeekAuditPayload;\n};\n\n// --- Audit log query contracts (FR-11 audit view) ----------------------------\n//\n// `/audit` reads `operator_events` filtered to the `peek.*` event types. The\n// filter shape is the FR-11 spec line \"filters by event type, actor email,\n// resource id, route, and date\" plus the bounded-list discipline shared with\n// the queue page (`PeekEventQueueFilters`). All values arrive as URL params and\n// are normalised server-side: unknown event types fall back to \"any peek.*\",\n// trimmed strings normalise to `null`, and date filters are bound as ISO\n// strings cast to `timestamptz` server-side.\n\nexport type PeekAuditFilters = {\n  eventType: PeekAuditEventType | null;\n  actorEmail: string | null;\n  resourceId: string | null;\n  route: string | null;\n  createdFrom: string | null;\n  createdTo: string | null;\n};\n\nexport type PeekAuditEventTypeCount = {\n  eventType: PeekAuditEventType;\n  count: number;\n};\n\nexport type PeekAuditOverviewMetricId =\n  | \"audit.total_24h\"\n  | \"audit.exports_24h\"","numLines":160,"startLine":300,"totalLines":1476}}}
