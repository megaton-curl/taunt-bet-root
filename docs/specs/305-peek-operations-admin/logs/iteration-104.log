PEEK_EVENT_QUEUE_AGE_BUCKET_VALUES),\n  };\n}\n\nexport function readSelectedQueueIdFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): string | null {\n  return trimOrNull(readSingleValue(input.selectedId));\n}\n\n// Two-arg overload tolerated for callers that prefer to pass URLSearchParams\n// indirectly. Also exposes the prefix tokens so the filter bar form fields stay\n// in lockstep with the URL parser without duplicating the literals.\nexport const PEEK_EVENT_QUEUE_FILTER_PARAM_NAMES = {\n  status: \"queueFilterStatus\",\n  eventType: \"queueFilterType\",\n  id: \"queueFilterId\",\n  payloadUserId: \"queueFilterUserId\",\n  scheduledFrom: \"queueFilterScheduledFrom\",\n  scheduledTo: \"queueFilterScheduledTo\",\n  createdFrom: \"queueFilterCreatedFrom\",\n  createdTo: \"queueFilterCreatedTo\",\n  ageBucket: \"queueFilterAge\",\n  selectedId: \"selectedId\",\n} as const;\n","numLines":76,"startLine":1,"totalLines":76}}}
