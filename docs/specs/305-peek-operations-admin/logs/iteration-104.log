 null {\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nfunction coerceEventType(raw: string | null): PeekAuditEventType | null {\n  if (raw === null) return null;\n  return isPeekAuditEventType(raw) ? raw : null;\n}\n\nexport function normalizeAuditFiltersFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): PeekAuditFilters {\n  const eventTypeShort = trimOrNull(readSingleValue(input.eventType));\n  const eventTypeLong = trimOrNull(readSingleValue(input.auditFilterEventType));\n  const eventType = coerceEventType(eventTypeShort ?? eventTypeLong);\n\n  return {\n    eventType,\n    actorEmail: trimOrNull(readSingleValue(input.auditFilterActor)),\n    resourceId: trimOrNull(readSingleValue(input.auditFilterResource)),\n    route: trimOrNull(readSingleValue(input.auditFilterRoute)),\n    createdFrom: trimOrNull(readSingleValue(input.auditFilterCreatedFrom)),\n    createdTo: trimOrNull(readSingleValue(input.auditFilterCreatedTo)),\n  };\n}\n\nexport const PEEK_AUDIT_FILTER_PARAM_NAMES = {\n  eventType: \"auditFilterEventType\",\n  actorEmail: \"auditFilterActor\",\n  resourceId: \"auditFilterResource\",\n  route: \"auditFilterRoute\",\n  createdFrom: \"auditFilterCreatedFrom\",\n  createdTo: \"auditFilterCreatedTo\",\n} as const;\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_013ZtUpHjpVt7L3UNckuufgj","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01EXhxb6TF2bJiVMs496xEGU","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/components/audit-events-filter-bar.tsx","content":"// URL-addressable filter bar for /audit (FR-11 audit view).\n//\n// Filters mirror the spec line \"filters by event type, actor email, resource\n// id, route, and date\". Submitting the form posts queryparams with the\n// `auditFilter*` prefix declared in `audit-search-params.ts`. The short-form\n// `eventType` URL param used by command-center metric drilldown links is not\n// rendered as a hidden input — submitting the form swaps the chip out for the\n// in-form `auditFilterEventType` value so the form is the single source of\n// truth on submit.\nimport type { CSSProperties } from \"react\";\nimport { PEEK_AUDIT_EVENT_TYPES } from \"../lib/types/peek\";\nimport type { PeekAuditFilters } from \"../lib/types/peek\";\n\nexport type AuditEventsFilterBarProps = {\n  filters: PeekAuditFilters;\n  action?: string;\n};\n\nexport function AuditEventsFilterBar({\n  filters,\n  action = \"/audit\",\n}: AuditEventsFilterBarProps) {\n  return (\n    <form\n      action={action}\n      method=\"get\"\n      role=\"search\"\n      aria-label=\"Filter audit events\"\n      style={formStyle}\n    >\n      <label style={fieldStyle}>\n        <span>Event type</span>\n        <select\n          name=\"auditFilterEventType\"\n          defaultValue={filters.eventType ?? \"\"}\n          style={inputStyle}\n        >\n          <option value=\"\">Any peek.*</option>\n          {PEEK_AUDIT_EVENT_TYPES.map((value) => (\n            <option key={value} value={value}>\n              {value}\n            </option>\n          ))}\n        </select>\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Actor email</span>\n        <input\n          name=\"auditFilterActor\"\n          type=\"text\"\n          defaultValue={filters.actorEmail ?? \"\"}\n          placeholder=\"alice@example.com\"\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Resource id</span>\n        <input\n          name=\"auditFilterResource\"\n          type=\"text\"\n          defaultValue={filters.resourceId ?? \"\"}\n          placeholder=\"payload.resourceId\"\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Route</span>\n        <input\n          name=\"auditFilterRoute\"\n          type=\"text\"\n          defaultValue={filters.route ?? \"\"}\n          placeholder=\"/users/[userId]\"\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Created from</span>\n        <input\n          name=\"auditFilterCreatedFrom\"\n          type=\"date\"\n          defaultValue={(filters.createdFrom ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <label style={fieldStyle}>\n        <span>Created to</span>\n        <input\n          name=\"auditFilterCreatedTo\"\n          type=\"date\"\n          defaultValue={(filters.createdTo ?? \"\").slice(0, 10)}\n          style={inputStyle}\n        />\n      </label>\n\n      <button type=\"submit\" style={buttonStyle}>\n        Apply filters\n      </button>\n    </form>\n  );\n}\n\nconst formStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n  gridTemplateColumns: \"repeat(auto-fit, minmax(180px, 1fr))\",\n  alignItems: \"end\",\n};\n\nconst fieldStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.35rem\",\n  fontSize: \"0.875rem\",\n};\n\nconst inputStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #334155\",\n  background: \"#111827\",\n  color: \"#e2e8f0\",\n  padding: \"0.625rem 0.75rem\",\n};\n\nconst buttonStyle: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #475569\",\n  background: \"#1d4ed8\",\n  color: \"#eff6ff\",\n  padding: \"0.75rem 1rem\",\n  fontWeight: 600,\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1345,"cache_read_input_tokens":107632,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1345},"output_tokens":62,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"c940aec5-6cb5-4439-bfa5-041f04d6e3f7","uuid":"0e250ce3-21b2-4ccd-9ece-021e7b9a3934"}
