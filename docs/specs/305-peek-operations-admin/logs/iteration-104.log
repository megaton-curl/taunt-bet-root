{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KwmWQ4yFw5n84aQ4VyohmV","type":"tool_result","content":"1\t// Event queue detail panel for /operations/queue (FR-10).\n2\t//\n3\t// Renders one `PeekEventQueueDetail` row alongside the event queue list when\n4\t// `?selectedId=<id>` is on the URL. The payload + error fields have already\n5\t// been redacted server-side via the audit redactor — `looksLikeSecret` strings\n6\t// are replaced with the `PEEK_AUDIT_REDACTED` marker before reaching this\n7\t// component (see `peek/src/server/db/queries/get-event-queue.ts`). This view\n8\t// re-renders the redacted JSON verbatim so an operator can confirm a secret\n9\t// was not leaked, but cannot see the original value.\n10\t//\n11\t// Read-only — retry / cancel / replay actions are explicitly out of scope\n12\t// (FR-10 line 342). No buttons or editable inputs are rendered.\n13\timport Link from \"next/link\";\n14\timport type { CSSProperties } from \"react\";\n15\timport type {\n16\t  PeekEventQueueDetail,\n17\t  PeekStatusTone,\n18\t} from \"../lib/types/peek\";\n19\timport { StatusChip } from \"./status-chip\";\n20\t\n21\texport type EventQueueDetailPanelProps = {\n22\t  detail: PeekEventQueueDetail | null;\n23\t  selectedId: string | null;\n24\t  notFound?: boolean;\n25\t  error?: string | null;\n26\t};\n27\t\n28\texport function EventQueueDetailPanel({\n29\t  detail,\n30\t  selectedId,\n31\t  notFound = false,\n32\t  error = null,\n33\t}: EventQueueDetailPanelProps) {\n34\t  if (error) {\n35\t    return (\n36\t      <aside aria-label=\"Event queue detail\" style={errorStyle} role=\"alert\">\n37\t        Detail unavailable: {error}\n38\t      </aside>\n39\t    );\n40\t  }\n41\t\n42\t  if (selectedId === null) {\n43\t    return (\n44\t      <aside aria-label=\"Event queue detail\" style={hintStyle} role=\"status\">\n45\t        Select a row id to load the full payload.\n46\t      </aside>\n47\t    );\n48\t  }\n49\t\n50\t  if (!detail) {\n51\t    return (\n52\t      <aside aria-label=\"Event queue detail\" style={hintStyle} role=\"status\">\n53\t        {notFound\n54\t          ? `No event_queue row matches id ${selectedId}.`\n55\t          : \"Loading detail…\"}\n56\t      </aside>\n57\t    );\n58\t  }\n59\t\n60\t  return (\n61\t    <aside aria-label=\"Event queue detail\" style={panelStyle}>\n62\t      <header style={panelHeaderStyle}>\n63\t        <div style={titleRowStyle}>\n64\t          <StatusChip\n65\t            label={detail.status}\n66\t            tone={queueStatusTone(detail.status)}\n67\t          />\n68\t          <h3 style={titleStyle}>Event {detail.id}</h3>\n69\t        </div>\n70\t        <p style={subtitleStyle}>\n71\t          <span style={monoStyle}>{detail.eventType}</span>\n72\t        </p>\n73\t      </header>\n74\t\n75\t      <dl style={metaListStyle}>\n76\t        <MetaRow label=\"Attempts\">\n77\t          <span style={monoStyle}>\n78\t            {detail.attempts.toLocaleString(\"en-US\")} /{\" \"}\n79\t            {detail.maxAttempts.toLocaleString(\"en-US\")}\n80\t          </span>\n81\t        </MetaRow>\n82\t        <MetaRow label=\"Created\">{detail.createdAt}</MetaRow>\n83\t        <MetaRow label=\"Scheduled\">{detail.scheduledAt}</MetaRow>\n84\t        <MetaRow label=\"Started\">{detail.startedAt ?? \"—\"}</MetaRow>\n85\t        <MetaRow label=\"Completed\">{detail.completedAt ?? \"—\"}</MetaRow>\n86\t        {detail.linked.userId ? (\n87\t          <MetaRow label=\"User\">\n88\t            <Link\n89\t              href={`/users/${encodeURIComponent(detail.linked.userId)}`}\n90\t              style={linkStyle}\n91\t            >\n92\t              {detail.linked.userId}\n93\t            </Link>\n94\t          </MetaRow>\n95\t        ) : null}\n96\t        {detail.linked.roundId ? (\n97\t          <MetaRow label=\"Round\">\n98\t            <span style={monoStyle}>{detail.linked.roundId}</span>\n99\t          </MetaRow>\n100\t        ) : null}\n101\t        {detail.linked.claimId ? (\n102\t          <MetaRow label=\"Claim\">\n103\t            <span style={monoStyle}>{detail.linked.claimId}</span>\n104\t          </MetaRow>\n105\t        ) : null}\n106\t      </dl>\n107\t\n108\t      <section aria-labelledby=\"event-queue-error-heading\">\n109\t        <h4 id=\"event-queue-error-heading\" style={sectionHeadingStyle}>\n110\t          Error (redacted)\n111\t        </h4>\n112\t        {detail.error === null ? (\n113\t          <p style={muteStyle}>—</p>\n114\t        ) : (\n115\t          <pre style={preStyle}>{detail.error}</pre>\n116\t        )}\n117\t      </section>\n118\t\n119\t      <section aria-labelledby=\"event-queue-payload-heading\">\n120\t        <h4 id=\"event-queue-payload-heading\" style={sectionHeadingStyle}>\n121\t          Payload (redacted)\n122\t        </h4>\n123\t        <pre style={preStyle}>{formatPayload(detail.payload)}</pre>\n124\t      </section>\n125\t\n126\t      <p style={readonlyNoticeStyle}>\n127\t        Read-only view. Retry, cancel, and replay actions are out of scope and\n128\t        live behind a separate mutation spec.\n129\t      </p>\n130\t    </aside>\n131\t  );\n132\t}\n133\t\n134\tfunction MetaRow({\n135\t  label,\n136\t  children,\n137\t}: {\n138\t  label: string;\n139\t  children: React.ReactNode;\n140\t}) {\n141\t  return (\n142\t    <div style={metaRowStyle}>\n143\t      <dt style={metaTermStyle}>{label}</dt>\n144\t      <dd style={metaValueStyle}>{children}</dd>\n145\t    </div>\n146\t  );\n147\t}\n148\t\n149\tfunction formatPayload(value: unknown): string {\n150\t  try {\n151\t    return JSON.stringify(value, null, 2);\n152\t  } catch {\n153\t    return String(value);\n154\t  }\n155\t}\n156\t\n157\texport function queueStatusTone(value: string): PeekStatusTone {\n158\t  if (value === \"completed\") return \"positive\";\n159\t  if (value === \"processing\") return \"info\";\n160\t  if (value === \"pending\") return \"neutral\";\n161\t  if (value === \"failed\") return \"warning\";\n162\t  if (value === \"dead\") return \"negative\";\n163\t  return \"neutral\";\n164\t}\n165\t\n166\tconst panelStyle: CSSProperties = {\n167\t  display: \"grid\",\n168\t  gap: \"1rem\",\n169\t  border: \"1px solid #1e293b\",\n170\t  borderRadius: \"0.75rem\",\n171\t  padding: \"1rem\",\n172\t  background: \"#0b1220\",\n173\t};\n174\t\n175\tconst panelHeaderStyle: CSSProperties = {\n176\t  display: \"grid\",\n177\t  gap: \"0.25rem\",\n178\t};\n179\t\n180\tconst titleRowStyle: CSSProperties = {\n181\t  display: \"flex\",\n182\t  alignItems: \"center\",\n183\t  gap: \"0.5rem\",\n184\t};\n185\t\n186\tconst titleStyle: CSSProperties = {\n187\t  margin: 0,\n188\t  fontSize: \"1rem\",\n189\t  fontWeight: 600,\n190\t  color: \"#e2e8f0\",\n191\t  fontFamily: \"monospace\",\n192\t  wordBreak: \"break-all\",\n193\t};\n194\t\n195\tconst subtitleStyle: CSSProperties = {\n196\t  margin: 0,\n197\t  fontSize: \"0.8125rem\",\n198\t  color: \"#94a3b8\",\n199\t};\n200\t\n201\tconst metaListStyle: CSSProperties = {\n202\t  margin: 0,\n203\t  display: \"grid\",\n204\t  gap: \"0.25rem\",\n205\t};\n206\t\n207\tconst metaRowStyle: CSSProperties = {\n208\t  display: \"grid\",\n209\t  gridTemplateColumns: \"8rem 1fr\",\n210\t  gap: \"0.5rem\",\n211\t  fontSize: \"0.8125rem\",\n212\t  color: \"#cbd5f5\",\n213\t};\n214\t\n215\tconst metaTermStyle: CSSProperties = {\n216\t  margin: 0,\n217\t  color: \"#94a3b8\",\n218\t};\n219\t\n220\tconst metaValueStyle: CSSProperties = {\n221\t  margin: 0,\n222\t  color: \"#e2e8f0\",\n223\t  wordBreak: \"break-all\",\n224\t};\n225\t\n226\tconst monoStyle: CSSProperties = {\n227\t  fontFamily: \"monospace\",\n228\t};\n229\t\n230\tconst sectionHeadingStyle: CSSProperties = {\n231\t  margin: \"0 0 0.5rem\",\n232\t  fontSize: \"0.8125rem\",\n233\t  fontWeight: 600,\n234\t  color: \"#cbd5f5\",\n235\t  textTransform: \"uppercase\",\n236\t  letterSpacing: \"0.05em\",\n237\t};\n238\t\n239\tconst preStyle: CSSProperties = {\n240\t  margin: 0,\n241\t  padding: \"0.75rem\",\n242\t  borderRadius: \"0.5rem\",\n243\t  background: \"#111827\",\n244\t  border: \"1px solid #1e293b\",\n245\t  color: \"#e2e8f0\",\n246\t  fontSize: \"0.75rem\",\n247\t  fontFamily: \"monospace\",\n248\t  whiteSpace: \"pre-wrap\",\n249\t  wordBreak: \"break-word\",\n250\t  maxHeight: \"24rem\",\n251\t  overflowY: \"auto\",\n252\t};\n253\t\n254\tconst muteStyle: CSSProperties = {\n255\t  margin: 0,\n256\t  fontSize: \"0.8125rem\",\n257\t  color: \"#94a3b8\",\n258\t};\n259\t\n260\tconst linkStyle: CSSProperties = {\n261\t  fontFamily: \"monospace\",\n262\t  color: \"#93c5fd\",\n263\t  textDecoration: \"none\",\n264\t};\n265\t\n266\tconst readonlyNoticeStyle: CSSProperties = {\n267\t  margin: 0,\n268\t  fontSize: \"0.75rem\",\n269\t  color: \"#94a3b8\",\n270\t  fontStyle: \"italic\",\n271\t};\n272\t\n273\tconst hintStyle: CSSProperties = {\n274\t  margin: 0,\n275\t  padding: \"1.5rem\",\n276\t  borderRadius: \"0.75rem\",\n277\t  border: \"1px dashed #334155\",\n278\t  background: \"#0b1220\",\n279\t  color: \"#cbd5f5\",\n280\t  fontSize: \"0.875rem\",\n281\t};\n282\t\n283\tconst errorStyle: CSSProperties = {\n284\t  margin: 0,\n285\t  padding: \"0.75rem 1rem\",\n286\t  borderRadius: \"0.75rem\",\n287\t  background: \"#3f1d1d\",\n288\t  color: \"#fecaca\",\n289\t};\n290\t"}]},"parent_tool_use_id":null,"session_id":"c940aec5-6cb5-4439-bfa5-041f04d6e3f7","uuid":"cd37d3c6-2bef-4ca5-a346-0e8ef48cf9df","timestamp":"2026-04-26T07:17:44.270Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/event-queue-detail-panel.tsx","content":"// Event queue detail panel for /operations/queue (FR-10).\n//\n// Renders one `PeekEventQueueDetail` row alongside the event queue list when\n// `?selectedId=<id>` is on the URL. The payload + error fields have already\n// been redacted server-side via the audit redactor — `looksLikeSecret` strings\n// are replaced with the `PEEK_AUDIT_REDACTED` marker before reaching this\n// component (see `peek/src/server/db/queries/get-event-queue.ts`). This view\n// re-renders the redacted JSON verbatim so an operator can confirm a secret\n// was not leaked, but cannot see the original value.\n//\n// Read-only — retry / cancel / replay actions are explicitly out of scope\n// (FR-10 line 342). No buttons or editable inputs are rendered.\nimport Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekEventQueueDetail,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type EventQueueDetailPanelProps = {\n  detail: PeekEventQueueDetail | null;\n  selectedId: string | null;\n  notFound?: boolean;\n  error?: string | null;\n};\n\nexport function EventQueueDetailPanel({\n  detail,\n  selectedId,\n  notFound = false,\n  error = null,\n}: EventQueueDetailPanelProps) {\n  if (error) {\n    return (\n      <aside aria-label=\"Event queue detail\" style={errorStyle} role=\"alert\">\n        Detail unavailable: {error}\n      </aside>\n    );\n  }\n\n  if (selectedId === null) {\n    return (\n      <aside aria-label=\"Event queue detail\" style={hintStyle} role=\"status\">\n        Select a row id to load the full payload.\n      </aside>\n    );\n  }\n\n  if (!detail) {\n    return (\n      <aside aria-label=\"Event queue detail\" style={hintStyle} role=\"status\">\n        {notFound\n          ? `No event_queue row matches id ${selectedId}.`\n          : \"Loading detail…\"}\n      </aside>\n    );\n  }\n\n  return (\n    <aside aria-label=\"Event queue detail\" style={panelStyle}>\n      <header style={panelHeaderStyle}>\n        <div style={titleRowStyle}>\n          <StatusChip\n            label={detail.status}\n            tone={queueStatusTone(detail.status)}\n          />\n          <h3 style={titleStyle}>Event {detail.id}</h3>\n        </div>\n        <p style={subtitleStyle}>\n          <span style={monoStyle}>{detail.eventType}</span>\n        </p>\n      </header>\n\n      <dl style={metaListStyle}>\n        <MetaRow label=\"Attempts\">\n          <span style={monoStyle}>\n            {detail.attempts.toLocaleString(\"en-US\")} /{\" \"}\n            {detail.maxAttempts.toLocaleString(\"en-US\")}\n          </span>\n        </MetaRow>\n        <MetaRow label=\"Created\">{detail.createdAt}</MetaRow>\n        <MetaRow label=\"Scheduled\">{detail.scheduledAt}</MetaRow>\n        <MetaRow label=\"Started\">{detail.startedAt ?? \"—\"}</MetaRow>\n        <MetaRow label=\"Completed\">{detail.completedAt ?? \"—\"}</MetaRow>\n        {detail.linked.userId ? (\n          <MetaRow label=\"User\">\n            <Link\n              href={`/users/${encodeURIComponent(detail.linked.userId)}`}\n              style={linkStyle}\n            >\n              {detail.linked.userId}\n            </Link>\n          </MetaRow>\n        ) : null}\n        {detail.linked.roundId ? (\n          <MetaRow label=\"Round\">\n            <span style={monoStyle}>{detail.linked.roundId}</span>\n          </MetaRow>\n        ) : null}\n        {detail.linked.claimId ? (\n          <MetaRow label=\"Claim\">\n            <span style={monoStyle}>{detail.linked.claimId}</span>\n          </MetaRow>\n        ) : null}\n      </dl>\n\n      <section aria-labelledby=\"event-queue-error-heading\">\n        <h4 id=\"event-queue-error-heading\" style={sectionHeadingStyle}>\n          Error (redacted)\n        </h4>\n        {detail.error === null ? (\n          <p style={muteStyle}>—</p>\n        ) : (\n          <pre style={preStyle}>{detail.error}</pre>\n        )}\n      </section>\n\n      <section aria-labelledby=\"event-queue-payload-heading\">\n        <h4 id=\"event-queue-payload-heading\" style={sectionHeadingStyle}>\n          Payload (redacted)\n        </h4>\n        <pre style={preStyle}>{formatPayload(detail.payload)}</pre>\n      </section>\n\n      <p style={readonlyNoticeStyle}>\n        Read-only view. Retry, cancel, and replay actions are out of scope and\n        live behind a separate mutation spec.\n      </p>\n    </aside>\n  );\n}\n\nfunction MetaRow({\n  label,\n  children,\n}: {\n  label: string;\n  children: React.ReactNode;\n}) {\n  return (\n    <div style={metaRowStyle}>\n      <dt style={metaTermStyle}>{label}</dt>\n      <dd style={metaValueStyle}>{children}</dd>\n    </div>\n  );\n}\n\nfunction formatPayload(value: unknown): string {\n  try {\n    return JSON.stringify(value, null, 2);\n  } catch {\n    return String(value);\n  }\n}\n\nexport function queueStatusTone(value: string): PeekStatusTone {\n  if (value === \"completed\") return \"positive\";\n  if (value === \"processing\") return \"info\";\n  if (value === \"pending\") return \"neutral\";\n  if (value === \"failed\") return \"warning\";\n  if (value === \"dead\") return \"negative\";\n  return \"neutral\";\n}\n\nconst panelStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1rem\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n  padding: \"1rem\",\n  background: \"#0b1220\",\n};\n\nconst panelHeaderStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst titleRowStyle: CSSProperties = {\n  display: \"flex\",\n  alignItems: \"center\",\n  gap: \"0.5rem\",\n};\n\nconst titleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#e2e8f0\",\n  fontFamily: \"monospace\",\n  wordBreak: \"break-all\",\n};\n\nconst subtitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.8125rem\",\n  color: \"#94a3b8\",\n};\n\nconst metaListStyle: CSSProperties = {\n  margin: 0,\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst metaRowStyle: CSSProperties = {\n  display: \"grid\",\n  gridTemplateColumns: \"8rem 1fr\",\n  gap: \"0.5rem\",\n  fontSize: \"0.8125rem\",\n  color: \"#cbd5f5\",\n};\n\nconst metaTermStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n};\n\nconst metaValueStyle: CSSProperties = {\n  margin: 0,\n  color: \"#e2e8f0\",\n  wordBreak: \"break-all\",\n};\n\nconst monoStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.5rem\",\n  fontSize: \"0.8125rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst preStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem\",\n  borderRadius: \"0.5rem\",\n  background: \"#111827\",\n  border: \"1px solid #1e293b\",\n  color: \"#e2e8f0\",\n  fontSize: \"0.75rem\",\n  fontFamily: \"monospace\",\n  whiteSpace: \"pre-wrap\",\n  wordBreak: \"break-word\",\n  maxHeight: \"24rem\",\n  overflowY: \"auto\",\n};\n\nconst muteStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.8125rem\",\n  color: \"#94a3b8\",\n};\n\nconst linkStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst readonlyNoticeStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n  fontStyle: \"italic\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  fontSize: \"0.875rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n","numLines":290,"startLine":1,"totalLines":290}}}
