n173\t\n174\texport type PeekUserDetail = {\n175\t  user: PeekUserDetailUser;\n176\t  inboundReferral: {\n177\t    referrerUserId: string | null;\n178\t    referrerCode: string | null;\n179\t    linkedAt: string | null;\n180\t  };\n181\t  outboundReferees: Array<{\n182\t    refereeUserId: string;\n183\t    refereeUsername: string | null;\n184\t    createdAt: string;\n185\t  }>;\n186\t  telegram: {\n187\t    state: \"active\" | \"none\";\n188\t    telegramUserId: string | null;\n189\t    telegramUsername: string | null;\n190\t  };\n191\t  linkedAccounts: ReadonlyArray<PeekLinkedAccountRow>;\n192\t  recentTelegramLinkTokens: ReadonlyArray<PeekTelegramLinkTokenRow>;\n193\t  kolRate: PeekKolRate | null;\n194\t  referralEarnings: PeekReferralEarningsSummary;\n195\t  recentReferralClaims: ReadonlyArray<PeekReferralClaimRow>;\n196\t  points: PeekPlayerPoints;\n197\t  recentPointGrants: ReadonlyArray<PeekPointGrantRow>;\n198\t  recentCrateDrops: ReadonlyArray<PeekCrateDropRow>;\n199\t  challengeSummary: PeekChallengeAssignmentSummary;\n200\t  recentGameEntries: ReadonlyArray<PeekGameEntryRow>;\n201\t  recentTransactions: ReadonlyArray<PeekTransactionRow>;\n202\t  fraudFlags: ReadonlyArray<PeekFraudFlagRow>;\n203\t  recentUserQueueEvents: ReadonlyArray<PeekUserQueueEventRow>;\n204\t  attention: PeekUserAttentionFlags;\n205\t};\n206\t\n207\t// --- Actor view model (browser-safe) -----------------------------------------\n208\t\n209\texport type PeekActorView = {\n210\t  email: string;\n211\t  role: PeekRole;\n212\t};\n213\t\n214\t// --- Metric metadata (FR-4) --------------------------------------------------\n215\t//\n216\t// Each metric carries the bookkeeping required by the data-surfacing standard:\n217\t// stable id, label, value, source table/query, time window, \"as of\" timestamp,\n218\t// short definition, optional unit, and optional drill-down link to the filtered\n219\t// detail rows behind the number.\n220\t\n221\texport type PeekMetricFreshness = \"live\" | \"cached\" | \"manual\" | \"sampled\";\n222\t\n223\texport type PeekMetric = {\n224\t  id: string;\n225\t  label: string;\n226\t  value: number | string | null;\n227\t  valueDisplay: string;\n228\t  unit: string | null;\n229\t  source: string;\n230\t  windowLabel: string;\n231\t  asOf: string | null;\n232\t  definition: string;\n233\t  freshness: PeekMetricFreshness;\n234\t  drilldownHref: string | null;\n235\t};\n236\t\n237\t// --- Pagination primitive ----------------------------------------------------\n238\t\n239\texport type PeekPagination = {\n240\t  page: number;\n241\t  pageSize: number;\n242\t  totalCount: number;\n243\t  totalPages: number;\n244\t};\n245\t\n246\t// --- Sort primitive ----------------------------------------------------------\n247\t\n248\texport type PeekSortDirection = \"asc\" | \"desc\";\n249\t\n250\texport type PeekTableSort = {\n251\t  column: string;\n252\t  direction: PeekSortDirection;\n253\t};\n254\t\n255\t// --- Table filter primitive (URL-addressable) --------------------------------\n256\t\n257\texport type PeekFilterKind =\n258\t  | \"text\"\n259\t  | \"select\"\n260\t  | \"boolean\"\n261\t  | \"date\"\n262\t  | \"dateRange\";\n263\t\n264\texport type PeekFilterOption = {\n265\t  value: string;\n266\t  label: string;\n267\t};\n268\t\n269\texport type PeekTableFilter = {\n270\t  id: string;\n271\t  label: string;\n272\t  kind: PeekFilterKind;\n273\t  value: string | null;\n274\t  options: ReadonlyArray<PeekFilterOption> | null;\n275\t  placeholder: string | null;\n276\t  required: boolean;\n277\t};\n278\t\n279\t// --- Status chip tone (shared) -----------------------------------------------\n280\t\n281\texport type PeekStatusTone =\n282\t  | \"neutral\"\n283\t  | \"positive\"\n284\t  | \"warning\"\n285\t  | \"negative\"\n286\t  | \"info\";\n287\t\n288\t// --- Empty-state primitive ---------------------------------------------------\n289\t\n290\texport type PeekEmptyState = {\n291\t  title: string;\n292\t  body: string | null;\n293\t};\n294\t\n295\t// --- Table row + column primitives -------------------------------------------\n296\t//\n297\t// Per-feature row types extend `PeekTableRowBase` for the shared identifier +\n298\t// optional drill-down link, then add feature-specific fields. The shared dense\n299\t// table component reads `columns` for layout and per-row data via the typed\n300\t// row shape supplied by the feature page.\n301\t\n302\texport type PeekTableColumnAlign = \"left\" | \"right\" | \"center\";\n303\t\n304\texport type PeekTableColumn = {\n305\t  id: string;\n306\t  label: string;\n307\t  align: PeekTableColumnAlign;\n308\t  sortable: boolean;\n309\t};\n310\t\n311\texport type PeekTableRowBase = {\n312\t  id: string;\n313\t  href: string | null;\n314\t};\n315\t\n316\texport type PeekTableViewModel<TRow extends PeekTableRowBase> = {\n317\t  columns: ReadonlyArray<PeekTableColumn>;\n318\t  rows: ReadonlyArray<TRow>;\n319\t  pagination: PeekPagination;\n320\t  filters: ReadonlyArray<PeekTableFilter>;\n321\t  sort: PeekTableSort | null;\n322\t  empty: PeekEmptyState;\n323\t};\n324\t\n325\t// --- Command-center attention queue (FR-3, FR-10) ----------------------------\n326\t//\n327\t// The command-center page surfaces a small set of \"needs attention\" metrics so\n328\t// operators see exception states (failed claims, dead queue events, stuck\n329\t// settlements, pending SOL crate payouts, stale active Dogpile events,\n330\t// high-value export activity) before they dig into per-feature pages. Each\n331\t// item is a `PeekMetric` so the metric-strip primitive renders it with the\n332\t// FR-4 bookkeeping (definition, source, time window, \"as of\", drill-down).\n333\t\n334\texport type PeekCommandCenterAttentionId =\n335\t  | \"failed_claims\"\n336\t  | \"dead_queue_events\"\n337\t  | \"stuck_rounds_flipyou_potshot\"\n338\t  | \"stuck_rounds_closecall\"\n339\t  | \"pending_sol_crate_payouts\"\n340\t  | \"stale_active_dogpile_events\"\n341\t  | \"high_value_exports_24h\";\n342\t\n343\texport type PeekCommandCenterAttention = {\n344\t  generatedAt: string;\n345\t  metrics: ReadonlyArray<PeekMetric>;\n346\t};\n347\t\n348\t// --- Recent operator activity (FR-3 command-center \"high-signal activity\") ---\n349\t//\n350\t// Compact projection of the latest `operator_events` rows for the command-center\n351\t// \"Recent activity\" section. Pulled from the same JSONB payload the audit\n352\t// writer persists, but kept narrow on purpose — the command center surfaces\n353\t// only the few fields needed to recognize what happened, not the full payload.\n354\t// The audit view (`/audit`, later iteration) renders the full bounded table.\n355\t\n356\texport type PeekRecentActivityItem = {\n357\t  id: string;\n358\t  eventType: string;\n359\t  actorEmail: string | null;\n360\t  resourceType: string | null;\n361\t  resourceId: string | null;\n362\t  route: string | null;\n363\t  createdAt: string;\n364\t};\n365\t\n366\t// --- Audit event contracts (FR-11) -------------------------------------------\n367\t//\n368\t// Browser-safe view of `operator_events` rows the audit writer produces under\n369\t// `peek.*` event types. The `PeekAuditPayload` shape pins the fields required by\n370\t// FR-11 so the writer (`peek/src/server/audit/**`, next iteration) and the audit\n371\t// view (`/audit`, later iteration) agree on a serialization contract. Secrets\n372\t// (JWTs, access tokens, DB URLs, private keys, raw secrets) must be replaced by\n373\t// `PEEK_AUDIT_REDACTED` before persisting; the audit-view component renders the\n374\t// token verbatim so reviewers can see that a field was redacted (not silently\n375\t// absent).\n376\t\n377\texport type PeekAuditEventType =\n378\t  | \"peek.search\"\n379\t  | \"peek.user.view_sensitive\"\n380\t  | \"peek.export\"\n381\t  | \"peek.access.denied\"\n382\t  | \"peek.change.applied\"\n383\t  | \"peek.change.rejected\";\n384\t\n385\texport const PEEK_AUDIT_EVENT_TYPES: ReadonlyArray<PeekAuditEventType> = [\n386\t  \"peek.search\",\n387\t  \"peek.user.view_sensitive\",\n388\t  \"peek.export\",\n389\t  \"peek.access.denied\",\n390\t  \"peek.change.applied\",\n391\t  \"peek.change.rejected\",\n392\t];\n393\t\n394\texport function isPeekAuditEventType(\n395\t  value: unknown,\n396\t): value is PeekAuditEventType {\n397\t  return (\n398\t    typeof value === \"string\" &&\n399\t    (PEEK_AUDIT_EVENT_TYPES as ReadonlyArray<string>).includes(value)"}]},"parent_tool_use_id":null,"session_id":"e174db15-b365-437f-8743-46cb380241b8","uuid":"b485ed4f-1a90-444c-b222-0757117631c0","timestamp":"2026-04-25T12:39:05.082Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","content":"  id: string;\n  triggerType: string;\n  triggerId: string;\n  crateType: string;\n  contentsAmount: string;\n  status: string;\n  createdAt: string;\n  grantedAt: string | null;\n};\n\nexport type PeekChallengeAssignmentSummary = {\n  active: number;\n  completed: number;\n  expired: number;\n  total: number;\n};\n\nexport type PeekGameEntryRow = {\n  id: string;\n  game: string;\n  roundPda: string;\n  matchId: string;\n  amountLamports: string;\n  side: string | null;\n  isWinner: boolean | null;\n  payoutLamports: string;\n  createdAt: string;\n  settledAt: string | null;\n};\n\nexport type PeekTransactionRow = {\n  id: string;\n  game: string;\n  matchId: string;\n  txType: string;\n  amountLamports: string;\n  txSig: string;\n  createdAt: string;\n};\n\nexport type PeekFraudFlagRow = {\n  id: string;\n  flagType: string;\n  status: string;\n  relatedId: string | null;\n  createdAt: string;\n  resolvedAt: string | null;\n};\n\nexport type PeekUserQueueEventRow = {\n  id: string;\n  eventType: string;\n  status: string;\n  attempts: number;\n  maxAttempts: number;\n  scheduledAt: string;\n  createdAt: string;\n  error: string | null;\n};\n\nexport type PeekUserAttentionFlags = {\n  failedClaim: boolean;\n  deadQueueEvent: boolean;\n  activeFraudFlag: boolean;\n  pendingSolCratePayout: boolean;\n  suspiciousReferralLoop: boolean;\n};\n\nexport type PeekUserDetailUser = PeekUserRow & {\n  avatarUrl: string | null;\n  heatMultiplier: string;\n  profilePointsBalance: string;\n};\n\nexport type PeekUserDetail = {\n  user: PeekUserDetailUser;\n  inboundReferral: {\n    referrerUserId: string | null;\n    referrerCode: string | null;\n    linkedAt: string | null;\n  };\n  outboundReferees: Array<{\n    refereeUserId: string;\n    refereeUsername: string | null;\n    createdAt: string;\n  }>;\n  telegram: {\n    state: \"active\" | \"none\";\n    telegramUserId: string | null;\n    telegramUsername: string | null;\n  };\n  linkedAccounts: ReadonlyArray<PeekLinkedAccountRow>;\n  recentTelegramLinkTokens: ReadonlyArray<PeekTelegramLinkTokenRow>;\n  kolRate: PeekKolRate | null;\n  referralEarnings: PeekReferralEarningsSummary;\n  recentReferralClaims: ReadonlyArray<PeekReferralClaimRow>;\n  points: PeekPlayerPoints;\n  recentPointGrants: ReadonlyArray<PeekPointGrantRow>;\n  recentCrateDrops: ReadonlyArray<PeekCrateDropRow>;\n  challengeSummary: PeekChallengeAssignmentSummary;\n  recentGameEntries: ReadonlyArray<PeekGameEntryRow>;\n  recentTransactions: ReadonlyArray<PeekTransactionRow>;\n  fraudFlags: ReadonlyArray<PeekFraudFlagRow>;\n  recentUserQueueEvents: ReadonlyArray<PeekUserQueueEventRow>;\n  attention: PeekUserAttentionFlags;\n};\n\n// --- Actor view model (browser-safe) -----------------------------------------\n\nexport type PeekActorView = {\n  email: string;\n  role: PeekRole;\n};\n\n// --- Metric metadata (FR-4) --------------------------------------------------\n//\n// Each metric carries the bookkeeping required by the data-surfacing standard:\n// stable id, label, value, source table/query, time window, \"as of\" timestamp,\n// short definition, optional unit, and optional drill-down link to the filtered\n// detail rows behind the number.\n\nexport type PeekMetricFreshness = \"live\" | \"cached\" | \"manual\" | \"sampled\";\n\nexport type PeekMetric = {\n  id: string;\n  label: string;\n  value: number | string | null;\n  valueDisplay: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  asOf: string | null;\n  definition: string;\n  freshness: PeekMetricFreshness;\n  drilldownHref: string | null;\n};\n\n// --- Pagination primitive ----------------------------------------------------\n\nexport type PeekPagination = {\n  page: number;\n  pageSize: number;\n  totalCount: number;\n  totalPages: number;\n};\n\n// --- Sort primitive ----------------------------------------------------------\n\nexport type PeekSortDirection = \"asc\" | \"desc\";\n\nexport type PeekTableSort = {\n  column: string;\n  direction: PeekSortDirection;\n};\n\n// --- Table filter primitive (URL-addressable) --------------------------------\n\nexport type PeekFilterKind =\n  | \"text\"\n  | \"select\"\n  | \"boolean\"\n  | \"date\"\n  | \"dateRange\";\n\nexport type PeekFilterOption = {\n  value: string;\n  label: string;\n};\n\nexport type PeekTableFilter = {\n  id: string;\n  label: string;\n  kind: PeekFilterKind;\n  value: string | null;\n  options: ReadonlyArray<PeekFilterOption> | null;\n  placeholder: string | null;\n  required: boolean;\n};\n\n// --- Status chip tone (shared) -----------------------------------------------\n\nexport type PeekStatusTone =\n  | \"neutral\"\n  | \"positive\"\n  | \"warning\"\n  | \"negative\"\n  | \"info\";\n\n// --- Empty-state primitive ---------------------------------------------------\n\nexport type PeekEmptyState = {\n  title: string;\n  body: string | null;\n};\n\n// --- Table row + column primitives -------------------------------------------\n//\n// Per-feature row types extend `PeekTableRowBase` for the shared identifier +\n// optional drill-down link, then add feature-specific fields. The shared dense\n// table component reads `columns` for layout and per-row data via the typed\n// row shape supplied by the feature page.\n\nexport type PeekTableColumnAlign = \"left\" | \"right\" | \"center\";\n\nexport type PeekTableColumn = {\n  id: string;\n  label: string;\n  align: PeekTableColumnAlign;\n  sortable: boolean;\n};\n\nexport type PeekTableRowBase = {\n  id: string;\n  href: string | null;\n};\n\nexport type PeekTableViewModel<TRow extends PeekTableRowBase> = {\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<TRow>;\n  pagination: PeekPagination;\n  filters: ReadonlyArray<PeekTableFilter>;\n  sort: PeekTableSort | null;\n  empty: PeekEmptyState;\n};\n\n// --- Command-center attention queue (FR-3, FR-10) ----------------------------\n//\n// The command-center page surfaces a small set of \"needs attention\" metrics so\n// operators see exception states (failed claims, dead queue events, stuck\n// settlements, pending SOL crate payouts, stale active Dogpile events,\n// high-value export activity) before they dig into per-feature pages. Each\n// item is a `PeekMetric` so the metric-strip primitive renders it with the\n// FR-4 bookkeeping (definition, source, time window, \"as of\", drill-down).\n\nexport type PeekCommandCenterAttentionId =\n  | \"failed_claims\"\n  | \"dead_queue_events\"\n  | \"stuck_rounds_flipyou_potshot\"\n  | \"stuck_rounds_closecall\"\n  | \"pending_sol_crate_payouts\"\n  | \"stale_active_dogpile_events\"\n  | \"high_value_exports_24h\";\n\nexport type PeekCommandCenterAttention = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};\n\n// --- Recent operator activity (FR-3 command-center \"high-signal activity\") ---\n//\n// Compact projection of the latest `operator_events` rows for the command-center\n// \"Recent activity\" section. Pulled from the same JSONB payload the audit\n// writer persists, but kept narrow on purpose — the command center surfaces\n// only the few fields needed to recognize what happened, not the full payload.\n// The audit view (`/audit`, later iteration) renders the full bounded table.\n\nexport type PeekRecentActivityItem = {\n  id: string;\n  eventType: string;\n  actorEmail: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  route: string | null;\n  createdAt: string;\n};\n\n// --- Audit event contracts (FR-11) -------------------------------------------\n//\n// Browser-safe view of `operator_events` rows the audit writer produces under\n// `peek.*` event types. The `PeekAuditPayload` shape pins the fields required by\n// FR-11 so the writer (`peek/src/server/audit/**`, next iteration) and the audit\n// view (`/audit`, later iteration) agree on a serialization contract. Secrets\n// (JWTs, access tokens, DB URLs, private keys, raw secrets) must be replaced by\n// `PEEK_AUDIT_REDACTED` before persisting; the audit-view component renders the\n// token verbatim so reviewers can see that a field was redacted (not silently\n// absent).\n\nexport type PeekAuditEventType =\n  | \"peek.search\"\n  | \"peek.user.view_sensitive\"\n  | \"peek.export\"\n  | \"peek.access.denied\"\n  | \"peek.change.applied\"\n  | \"peek.change.rejected\";\n\nexport const PEEK_AUDIT_EVENT_TYPES: ReadonlyArray<PeekAuditEventType> = [\n  \"peek.search\",\n  \"peek.user.view_sensitive\",\n  \"peek.export\",\n  \"peek.access.denied\",\n  \"peek.change.applied\",\n  \"peek.change.rejected\",\n];\n\nexport function isPeekAuditEventType(\n  value: unknown,\n): value is PeekAuditEventType {\n  return (\n    typeof value === \"string\" &&\n    (PEEK_AUDIT_EVENT_TYPES as ReadonlyArray<string>).includes(value)","numLines":300,"startLine":100,"totalLines":657}}}
