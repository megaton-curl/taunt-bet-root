/__tests__/get-recent-operator-events.test.ts (8 tests) 33ms\n ✓ src/server/__tests__/cloudflare-access-middleware.test.ts (5 tests) 33ms\n ✓ src/server/db/queries/__tests__/get-peek-summary.test.ts (5 tests) 6ms\n ✓ src/server/db/queries/__tests__/list-peek-users.test.ts (3 tests) 7ms\n ✓ src/server/__tests__/admin-shell-nav.test.ts (4 tests) 7ms\n\n Test Files  30 passed (30)\n      Tests  250 passed (250)\n   Start at  12:41:51\n   Duration  33.15s (transform 2.51s, setup 16.28s, collect 24.71s, tests 7.88s, environment 108.81s, prepare 14.38s)","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
