\t    referrerEarningsRows,\n159\t    refereeRebatesRows,\n160\t    pendingClaimsLamportsRows,\n161\t    failedClaimsRows,\n162\t    kolCountRows,\n163\t  ] = await Promise.all([\n164\t    sql<CountRow[]>`\n165\t      select count(distinct referrer_user_id)::int as \"value\"\n166\t      from referral_links\n167\t    `,\n168\t    sql<CountRow[]>`\n169\t      select count(*)::int as \"value\"\n170\t      from referral_links\n171\t    `,\n172\t    sql<CountRow[]>`\n173\t      select count(*)::int as \"value\"\n174\t      from (\n175\t        select rl.referee_user_id\n176\t        from referral_links rl\n177\t        where exists (\n178\t          select 1 from game_entries ge\n179\t          where ge.user_id = rl.referee_user_id\n180\t        )\n181\t      ) activated\n182\t    `,\n183\t    sql<SumRow[]>`\n184\t      select coalesce(sum(referrer_earned_lamports), 0)::text as \"value\"\n185\t      from referral_earnings\n186\t    `,\n187\t    sql<SumRow[]>`\n188\t      select coalesce(sum(referee_rebate_lamports), 0)::text as \"value\"\n189\t      from referral_earnings\n190\t    `,\n191\t    sql<SumRow[]>`\n192\t      select coalesce(sum(amount_lamports), 0)::text as \"value\"\n193\t      from referral_claims\n194\t      where status in ('pending', 'processing')\n195\t    `,\n196\t    sql<CountRow[]>`\n197\t      select count(*)::int as \"value\"\n198\t      from referral_claims\n199\t      where status in ('failed', 'error')\n200\t    `,\n201\t    sql<CountRow[]>`\n202\t      select count(*)::int as \"value\"\n203\t      from referral_kol_rates\n204\t    `,\n205\t  ]);\n206\t\n207\t  const referrers = readCount(referrersRows);\n208\t  const referredUsers = readCount(referredUsersRows);\n209\t  const activatedReferred = readCount(activatedReferredRows);\n210\t  const referrerEarnings = readSum(referrerEarningsRows);\n211\t  const refereeRebates = readSum(refereeRebatesRows);\n212\t  const pendingClaimsLamports = readSum(pendingClaimsLamportsRows);\n213\t  const failedClaims = readCount(failedClaimsRows);\n214\t  const kolCount = readCount(kolCountRows);\n215\t\n216\t  const blueprints: ReadonlyArray<{\n217\t    blueprint: GrowthMetricBlueprint;\n218\t    raw: number | string;\n219\t    display: string;\n220\t  }> = [\n221\t    {\n222\t      blueprint: {\n223\t        id: \"growth.referrers\",\n224\t        label: \"Referrers\",\n225\t        unit: \"users\",\n226\t        source: \"referral_links\",\n227\t        windowLabel: \"All time\",\n228\t        definition:\n229\t          \"Distinct referrer_user_id values in referral_links — users who have referred at least one player.\",\n230\t        drilldownHref: \"/growth/referrals#top-referrers\",\n231\t      },\n232\t      raw: referrers,\n233\t      display: formatCount(referrers),\n234\t    },\n235\t    {\n236\t      blueprint: {\n237\t        id: \"growth.referred_users\",\n238\t        label: \"Referred users\",\n239\t        unit: \"users\",\n240\t        source: \"referral_links\",\n241\t        windowLabel: \"All time\",\n242\t        definition:\n243\t          \"Total referral_links rows — referees attached to a referrer (one row per referee).\",\n244\t        drilldownHref: \"/growth/referrals#top-referrers\",\n245\t      },\n246\t      raw: referredUsers,\n247\t      display: formatCount(referredUsers),\n248\t    },\n249\t    {\n250\t      blueprint: {\n251\t        id: \"growth.activated_referred_users\",\n252\t        label: \"Activated referred users\",\n253\t        unit: \"users\",\n254\t        source: \"referral_links + game_entries\",\n255\t        windowLabel: \"All time\",\n256\t        definition:\n257\t          \"Referees who have at least one game_entries row — they have actually played.\",\n258\t        drilldownHref: \"/growth/referrals#top-referrers\",\n259\t      },\n260\t      raw: activatedReferred,\n261\t      display: formatCount(activatedReferred),\n262\t    },\n263\t    {\n264\t      blueprint: {\n265\t        id: \"growth.referrer_earnings_lamports\",\n266\t        label: \"Referrer earnings (lamports)\",\n267\t        unit: \"lamports\",\n268\t        source: \"referral_earnings\",\n269\t        windowLabel: \"All time\",\n270\t        definition:\n271\t          \"Sum of referrer_earned_lamports across referral_earnings — the gross referral economy paid to referrers.\",\n272\t        drilldownHref: \"/growth/referrals#top-referrers\",\n273\t      },\n274\t      raw: referrerEarnings,\n275\t      display: formatLamports(referrerEarnings),\n276\t    },\n277\t    {\n278\t      blueprint: {\n279\t        id: \"growth.referee_rebates_lamports\",\n280\t        label: \"Referee rebates (lamports)\",\n281\t        unit: \"lamports\",\n282\t        source: \"referral_earnings\",\n283\t        windowLabel: \"All time\",\n284\t        definition:\n285\t          \"Sum of referee_rebate_lamports across referral_earnings — the referee-side rebate paid back from referral fees.\",\n286\t        drilldownHref: \"/growth/referrals#top-referrers\",\n287\t      },\n288\t      raw: refereeRebates,\n289\t      display: formatLamports(refereeRebates),\n290\t    },\n291\t    {\n292\t      blueprint: {\n293\t        id: \"growth.pending_claims_lamports\",\n294\t        label: \"Pending claim payouts (lamports)\",\n295\t        unit: \"lamports\",\n296\t        source: \"referral_claims\",\n297\t        windowLabel: \"Status pending or processing\",\n298\t        definition:\n299\t          \"Sum of amount_lamports for referral_claims awaiting on-chain payout (status pending/processing).\",\n300\t        drilldownHref: \"/growth/referrals?claimStatus=pending\",\n301\t      },\n302\t      raw: pendingClaimsLamports,\n303\t      display: formatLamports(pendingClaimsLamports),\n304\t    },\n305\t    {\n306\t      blueprint: {\n307\t        id: \"growth.failed_claims\",\n308\t        label: \"Failed claims\",\n309\t        unit: \"claims\",\n310\t        source: \"referral_claims\",\n311\t        windowLabel: \"Status failed or error\",\n312\t        definition:\n313\t          \"Referral claims with status 'failed' or 'error' that have not been recovered.\",\n314\t        drilldownHref: \"/growth/referrals?claimStatus=failed\",\n315\t      },\n316\t      raw: failedClaims,\n317\t      display: formatCount(failedClaims),\n318\t    },\n319\t    {\n320\t      blueprint: {\n321\t        id: \"growth.kol_count\",\n322\t        label: \"KOLs\",\n323\t        unit: \"users\",\n324\t        source: \"referral_kol_rates\",\n325\t        windowLabel: \"All time\",\n326\t        definition:\n327\t          \"Rows in referral_kol_rates — users with an explicit KOL rate override.\",\n328\t        drilldownHref: \"/growth/kol\",\n329\t      },\n330\t      raw: kolCount,\n331\t      display: formatCount(kolCount),\n332\t    },\n333\t  ];\n334\t\n335\t  return {\n336\t    generatedAt,\n337\t    metrics: blueprints.map(({ blueprint, raw, display }) =>\n338\t      buildMetric(blueprint, raw, display, generatedAt),\n339\t    ),\n340\t  };\n341\t}\n342\t\n343\texport async function listTopReferrers(\n344\t  options: ListLimitOptions = {},\n345\t): Promise<ReadonlyArray<PeekTopReferrerRow>> {\n346\t  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n347\t  const limit = clampLimit(\n348\t    options.limit,\n349\t    PEEK_GROWTH_TOP_REFERRERS_DEFAULT_LIMIT,\n350\t    PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT,\n351\t  );\n352\t\n353\t  return sql<Array<PeekTopReferrerRow>>`\n354\t    select\n355\t      rl_agg.referrer_user_id as \"referrerUserId\",\n356\t      pp.username as \"username\",\n357\t      rl_agg.referrer_wallet as \"wallet\",\n358\t      rc.code as \"referralCode\",\n359\t      rl_agg.referee_count as \"refereeCount\",\n360\t      rl_agg.active_referee_count as \"activeRefereeCount\",\n361\t      coalesce(re_agg.wager_lamports, 0)::text as \"referredWagerLamports\",\n362\t      coalesce(re_agg.referrer_earned_lamports, 0)::text as \"referrerEarnedLamports\",\n363\t      coalesce(claims_agg.pending_lamports, 0)::text as \"pendingClaimLamports\"\n364\t    from (\n365\t      select\n366\t        rl.referrer_user_id,\n367\t        max(rl.referrer_wallet) as referrer_wallet,\n368\t        count(*)::int as referee_count,\n369\t        count(distinct ge.user_id)::int as active_referee_count\n370\t      from referral_links rl\n371\t      left join (\n372\t        select distinct user_id from game_entries\n373\t      ) ge on ge.user_id = rl.referee_user_id\n374\t      group by rl.referrer_user_id\n375\t    ) rl_agg\n376\t    left join player_profiles pp on pp.user_id = rl_agg.referrer_user_id\n377\t    left join referral_codes rc on rc.user_id = rl_agg.referrer_user_id\n378\t    left join (\n379\t      select\n380\t        referrer_user_id,\n381\t        sum(wager_lamports) as wager_lamports,\n382\t        sum(referrer_earned_lamports) as referrer_earned_lamports\n383\t      from referral_earnings\n384\t      group by referrer_user_id\n385\t    ) re_agg on re_agg.referrer_user_id = rl_agg.referrer_user_id\n386\t    left join (\n387\t      select\n388\t        user_id,\n389\t        sum(amount_lamports) as pending_lamports\n390\t      from referral_claims\n391\t      where status in ('pending', 'processing')\n392\t      group by user_id\n393\t    ) claims_agg on claims_agg.user_id = rl_agg.referrer_user_id\n394\t    order by\n395\t      coalesce(re_agg.referrer_earned_lamports, 0) desc,\n396\t      rl_agg.referee_count desc,\n397\t      rl_agg.referrer_user_id asc\n398\t    limit ${limit}\n399\t  `;"}]},"parent_tool_use_id":null,"session_id":"e174db15-b365-437f-8743-46cb380241b8","uuid":"804668d8-5186-4c37-a98e-6d7b9aa6f95a","timestamp":"2026-04-25T12:38:56.469Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-growth-referrals.ts","content":"  if (!rows || rows.length === 0) return 0;\n  const raw = rows[0]?.value;\n  if (typeof raw === \"number\" && Number.isFinite(raw)) return raw;\n  if (typeof raw === \"string\") {\n    const parsed = Number.parseInt(raw, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction readSum(rows: ReadonlyArray<SumRow> | undefined): string {\n  if (!rows || rows.length === 0) return \"0\";\n  const raw = rows[0]?.value;\n  return typeof raw === \"string\" && raw.length > 0 ? raw : \"0\";\n}\n\ntype GrowthMetricBlueprint = {\n  id: PeekGrowthOverviewMetricId;\n  label: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  definition: string;\n  drilldownHref: string | null;\n};\n\nfunction buildMetric(\n  blueprint: GrowthMetricBlueprint,\n  raw: number | string,\n  display: string,\n  asOf: string,\n): PeekMetric {\n  return {\n    id: blueprint.id,\n    label: blueprint.label,\n    value: raw,\n    valueDisplay: display,\n    unit: blueprint.unit,\n    source: blueprint.source,\n    windowLabel: blueprint.windowLabel,\n    asOf,\n    definition: blueprint.definition,\n    freshness: \"live\",\n    drilldownHref: blueprint.drilldownHref,\n  };\n}\n\nexport async function getGrowthReferralOverview(\n  options: GrowthOverviewOptions = {},\n): Promise<PeekGrowthOverview> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n\n  const [\n    referrersRows,\n    referredUsersRows,\n    activatedReferredRows,\n    referrerEarningsRows,\n    refereeRebatesRows,\n    pendingClaimsLamportsRows,\n    failedClaimsRows,\n    kolCountRows,\n  ] = await Promise.all([\n    sql<CountRow[]>`\n      select count(distinct referrer_user_id)::int as \"value\"\n      from referral_links\n    `,\n    sql<CountRow[]>`\n      select count(*)::int as \"value\"\n      from referral_links\n    `,\n    sql<CountRow[]>`\n      select count(*)::int as \"value\"\n      from (\n        select rl.referee_user_id\n        from referral_links rl\n        where exists (\n          select 1 from game_entries ge\n          where ge.user_id = rl.referee_user_id\n        )\n      ) activated\n    `,\n    sql<SumRow[]>`\n      select coalesce(sum(referrer_earned_lamports), 0)::text as \"value\"\n      from referral_earnings\n    `,\n    sql<SumRow[]>`\n      select coalesce(sum(referee_rebate_lamports), 0)::text as \"value\"\n      from referral_earnings\n    `,\n    sql<SumRow[]>`\n      select coalesce(sum(amount_lamports), 0)::text as \"value\"\n      from referral_claims\n      where status in ('pending', 'processing')\n    `,\n    sql<CountRow[]>`\n      select count(*)::int as \"value\"\n      from referral_claims\n      where status in ('failed', 'error')\n    `,\n    sql<CountRow[]>`\n      select count(*)::int as \"value\"\n      from referral_kol_rates\n    `,\n  ]);\n\n  const referrers = readCount(referrersRows);\n  const referredUsers = readCount(referredUsersRows);\n  const activatedReferred = readCount(activatedReferredRows);\n  const referrerEarnings = readSum(referrerEarningsRows);\n  const refereeRebates = readSum(refereeRebatesRows);\n  const pendingClaimsLamports = readSum(pendingClaimsLamportsRows);\n  const failedClaims = readCount(failedClaimsRows);\n  const kolCount = readCount(kolCountRows);\n\n  const blueprints: ReadonlyArray<{\n    blueprint: GrowthMetricBlueprint;\n    raw: number | string;\n    display: string;\n  }> = [\n    {\n      blueprint: {\n        id: \"growth.referrers\",\n        label: \"Referrers\",\n        unit: \"users\",\n        source: \"referral_links\",\n        windowLabel: \"All time\",\n        definition:\n          \"Distinct referrer_user_id values in referral_links — users who have referred at least one player.\",\n        drilldownHref: \"/growth/referrals#top-referrers\",\n      },\n      raw: referrers,\n      display: formatCount(referrers),\n    },\n    {\n      blueprint: {\n        id: \"growth.referred_users\",\n        label: \"Referred users\",\n        unit: \"users\",\n        source: \"referral_links\",\n        windowLabel: \"All time\",\n        definition:\n          \"Total referral_links rows — referees attached to a referrer (one row per referee).\",\n        drilldownHref: \"/growth/referrals#top-referrers\",\n      },\n      raw: referredUsers,\n      display: formatCount(referredUsers),\n    },\n    {\n      blueprint: {\n        id: \"growth.activated_referred_users\",\n        label: \"Activated referred users\",\n        unit: \"users\",\n        source: \"referral_links + game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Referees who have at least one game_entries row — they have actually played.\",\n        drilldownHref: \"/growth/referrals#top-referrers\",\n      },\n      raw: activatedReferred,\n      display: formatCount(activatedReferred),\n    },\n    {\n      blueprint: {\n        id: \"growth.referrer_earnings_lamports\",\n        label: \"Referrer earnings (lamports)\",\n        unit: \"lamports\",\n        source: \"referral_earnings\",\n        windowLabel: \"All time\",\n        definition:\n          \"Sum of referrer_earned_lamports across referral_earnings — the gross referral economy paid to referrers.\",\n        drilldownHref: \"/growth/referrals#top-referrers\",\n      },\n      raw: referrerEarnings,\n      display: formatLamports(referrerEarnings),\n    },\n    {\n      blueprint: {\n        id: \"growth.referee_rebates_lamports\",\n        label: \"Referee rebates (lamports)\",\n        unit: \"lamports\",\n        source: \"referral_earnings\",\n        windowLabel: \"All time\",\n        definition:\n          \"Sum of referee_rebate_lamports across referral_earnings — the referee-side rebate paid back from referral fees.\",\n        drilldownHref: \"/growth/referrals#top-referrers\",\n      },\n      raw: refereeRebates,\n      display: formatLamports(refereeRebates),\n    },\n    {\n      blueprint: {\n        id: \"growth.pending_claims_lamports\",\n        label: \"Pending claim payouts (lamports)\",\n        unit: \"lamports\",\n        source: \"referral_claims\",\n        windowLabel: \"Status pending or processing\",\n        definition:\n          \"Sum of amount_lamports for referral_claims awaiting on-chain payout (status pending/processing).\",\n        drilldownHref: \"/growth/referrals?claimStatus=pending\",\n      },\n      raw: pendingClaimsLamports,\n      display: formatLamports(pendingClaimsLamports),\n    },\n    {\n      blueprint: {\n        id: \"growth.failed_claims\",\n        label: \"Failed claims\",\n        unit: \"claims\",\n        source: \"referral_claims\",\n        windowLabel: \"Status failed or error\",\n        definition:\n          \"Referral claims with status 'failed' or 'error' that have not been recovered.\",\n        drilldownHref: \"/growth/referrals?claimStatus=failed\",\n      },\n      raw: failedClaims,\n      display: formatCount(failedClaims),\n    },\n    {\n      blueprint: {\n        id: \"growth.kol_count\",\n        label: \"KOLs\",\n        unit: \"users\",\n        source: \"referral_kol_rates\",\n        windowLabel: \"All time\",\n        definition:\n          \"Rows in referral_kol_rates — users with an explicit KOL rate override.\",\n        drilldownHref: \"/growth/kol\",\n      },\n      raw: kolCount,\n      display: formatCount(kolCount),\n    },\n  ];\n\n  return {\n    generatedAt,\n    metrics: blueprints.map(({ blueprint, raw, display }) =>\n      buildMetric(blueprint, raw, display, generatedAt),\n    ),\n  };\n}\n\nexport async function listTopReferrers(\n  options: ListLimitOptions = {},\n): Promise<ReadonlyArray<PeekTopReferrerRow>> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const limit = clampLimit(\n    options.limit,\n    PEEK_GROWTH_TOP_REFERRERS_DEFAULT_LIMIT,\n    PEEK_GROWTH_TOP_REFERRERS_MAX_LIMIT,\n  );\n\n  return sql<Array<PeekTopReferrerRow>>`\n    select\n      rl_agg.referrer_user_id as \"referrerUserId\",\n      pp.username as \"username\",\n      rl_agg.referrer_wallet as \"wallet\",\n      rc.code as \"referralCode\",\n      rl_agg.referee_count as \"refereeCount\",\n      rl_agg.active_referee_count as \"activeRefereeCount\",\n      coalesce(re_agg.wager_lamports, 0)::text as \"referredWagerLamports\",\n      coalesce(re_agg.referrer_earned_lamports, 0)::text as \"referrerEarnedLamports\",\n      coalesce(claims_agg.pending_lamports, 0)::text as \"pendingClaimLamports\"\n    from (\n      select\n        rl.referrer_user_id,\n        max(rl.referrer_wallet) as referrer_wallet,\n        count(*)::int as referee_count,\n        count(distinct ge.user_id)::int as active_referee_count\n      from referral_links rl\n      left join (\n        select distinct user_id from game_entries\n      ) ge on ge.user_id = rl.referee_user_id\n      group by rl.referrer_user_id\n    ) rl_agg\n    left join player_profiles pp on pp.user_id = rl_agg.referrer_user_id\n    left join referral_codes rc on rc.user_id = rl_agg.referrer_user_id\n    left join (\n      select\n        referrer_user_id,\n        sum(wager_lamports) as wager_lamports,\n        sum(referrer_earned_lamports) as referrer_earned_lamports\n      from referral_earnings\n      group by referrer_user_id\n    ) re_agg on re_agg.referrer_user_id = rl_agg.referrer_user_id\n    left join (\n      select\n        user_id,\n        sum(amount_lamports) as pending_lamports\n      from referral_claims\n      where status in ('pending', 'processing')\n      group by user_id\n    ) claims_agg on claims_agg.user_id = rl_agg.referrer_user_id\n    order by\n      coalesce(re_agg.referrer_earned_lamports, 0) desc,\n      rl_agg.referee_count desc,\n      rl_agg.referrer_user_id asc\n    limit ${limit}\n  `;","numLines":300,"startLine":100,"totalLines":573}}}
