{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_017nQrfV4entasNqp6pWHgkM","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01KeUcPdFzfw3e4sxKqm5ZgU","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","old_string":"export type PeekReferralGraphNode = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  referralCode: string | null;\n  inboundReferrer: PeekReferralGraphInboundReferrer;\n  outboundReferees: ReadonlyArray<PeekReferralGraphRefereeRow>;\n};","new_string":"export type PeekReferralGraphNode = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  referralCode: string | null;\n  inboundReferrer: PeekReferralGraphInboundReferrer;\n  outboundReferees: ReadonlyArray<PeekReferralGraphRefereeRow>;\n};\n\n// --- Games overview (FR-8) ---------------------------------------------------\n//\n// Browser-safe view models for `/games`. The engine query reads the single\n// source of truth `game_entries` (migration 007) and produces (a) a small set\n// of platform-wide FR-4 metrics for the overview strip and (b) per-game rows\n// with the operational counters the spec calls out: entries, unique users,\n// wagered lamports, settled entries, refund entries, payout lamports, wins,\n// losses. Lamport sums round-trip as `text` to preserve u64 precision; the UI\n// formats at render time.\n//\n// `PeekGameId` mirrors the migration's CHECK constraint on `game_entries.game`\n// (`'flipyou' | 'potshot' | 'closecall'`). Deferred games (Crash, Game of\n// Trades, Chart the Course, Slots Utopia, Tug of Earn) are documented\n// placeholders rendered by the page; they intentionally are not part of the\n// data shape because they have no persisted source yet (system invariant 13).\n\nexport type PeekGameId = \"flipyou\" | \"potshot\" | \"closecall\";\n\nexport const PEEK_GAME_IDS: ReadonlyArray<PeekGameId> = [\n  \"flipyou\",\n  \"potshot\",\n  \"closecall\",\n];\n\nexport type PeekGameOverviewRow = {\n  game: PeekGameId;\n  entries: number;\n  uniqueUsers: number;\n  wageredLamports: string;\n  settledEntries: number;\n  refundEntries: number;\n  payoutLamports: string;\n  wins: number;\n  losses: number;\n};\n\nexport type PeekGameOverviewMetricId =\n  | \"games.total_entries\"\n  | \"games.unique_users\"\n  | \"games.wagered_lamports\"\n  | \"games.settled_entries\"\n  | \"games.refund_entries\"\n  | \"games.payout_lamports\";\n\nexport const PEEK_GAME_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekGameOverviewMetricId> =\n  [\n    \"games.total_entries\",\n    \"games.unique_users\",\n    \"games.wagered_lamports\",\n    \"games.settled_entries\",\n    \"games.refund_entries\",\n    \"games.payout_lamports\",\n  ];\n\nexport type PeekGameOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n  perGame: ReadonlyArray<PeekGameOverviewRow>;\n};"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3828,"cache_read_input_tokens":94068,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3828},"output_tokens":42,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"e174db15-b365-437f-8743-46cb380241b8","uuid":"0de87078-f300-48c3-a774-b3c13c4423f7"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KeUcPdFzfw3e4sxKqm5ZgU","type":"tool_result","content":"The file /workspaces/rng-utopia/peek/src/lib/types/peek.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"e174db15-b365-437f-8743-46cb380241b8","uuid":"f70715ed-e2b4-4721-b807-9b6156298c23","timestamp":"2026-04-25T12:40:19.677Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","oldString":"export type PeekReferralGraphNode = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  referralCode: string | null;\n  inboundReferrer: PeekReferralGraphInboundReferrer;\n  outboundReferees: ReadonlyArray<PeekReferralGraphRefereeRow>;\n};","newString":"export type PeekReferralGraphNode = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  referralCode: string | null;\n  inboundReferrer: PeekReferralGraphInboundReferrer;\n  outboundReferees: ReadonlyArray<PeekReferralGraphRefereeRow>;\n};\n\n// --- Games overview (FR-8) ---------------------------------------------------\n//\n// Browser-safe view models for `/games`. The engine query reads the single\n// source of truth `game_entries` (migration 007) and produces (a) a small set\n// of platform-wide FR-4 metrics for the overview strip and (b) per-game rows\n// with the operational counters the spec calls out: entries, unique users,\n// wagered lamports, settled entries, refund entries, payout lamports, wins,\n// losses. Lamport sums round-trip as `text` to preserve u64 precision; the UI\n// formats at render time.\n//\n// `PeekGameId` mirrors the migration's CHECK constraint on `game_entries.game`\n// (`'flipyou' | 'potshot' | 'closecall'`). Deferred games (Crash, Game of\n// Trades, Chart the Course, Slots Utopia, Tug of Earn) are documented\n// placeholders rendered by the page; they intentionally are not part of the\n// data shape because they have no persisted source yet (system invariant 13).\n\nexport type PeekGameId = \"flipyou\" | \"potshot\" | \"closecall\";\n\nexport const PEEK_GAME_IDS: ReadonlyArray<PeekGameId> = [\n  \"flipyou\",\n  \"potshot\",\n  \"closecall\",\n];\n\nexport type PeekGameOverviewRow = {\n  game: PeekGameId;\n  entries: number;\n  uniqueUsers: number;\n  wageredLamports: string;\n  settledEntries: number;\n  refundEntries: number;\n  payoutLamports: string;\n  wins: number;\n  losses: number;\n};\n\nexport type PeekGameOverviewMetricId =\n  | \"games.total_entries\"\n  | \"games.unique_users\"\n  | \"games.wagered_lamports\"\n  | \"games.settled_entries\"\n  | \"games.refund_entries\"\n  | \"games.payout_lamports\";\n\nexport const PEEK_GAME_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekGameOverviewMetricId> =\n  [\n    \"games.total_entries\",\n    \"games.unique_users\",\n    \"games.wagered_lamports\",\n    \"games.settled_entries\",\n    \"games.refund_entries\",\n    \"games.payout_lamports\",\n  ];\n\nexport type PeekGameOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n  perGame: ReadonlyArray<PeekGameOverviewRow>;\n};","originalFile":"// Browser-safe view-model primitives for `peek`.\n//\n// Foundational shapes used across feature pages: metric metadata (FR-4),\n// URL-addressable table filters, pagination, sort, and a small table-row base\n// type that per-feature row types can extend. Per-feature shapes (PeekUserRow,\n// PeekUserDetail, future referral/game/queue/etc. rows) live alongside or\n// extend these primitives.\n\nimport type { PeekRole } from \"../access-policy\";\n\n// --- Existing 303-era shapes (kept stable for current callers) ---------------\n\nexport type PeekSummary = {\n  totalUsers: number;\n  totalUsersWithCodes: number;\n  totalReferredUsers: number;\n  totalUniqueReferrers: number;\n};\n\nexport type PeekUserRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  joinedAt: string;\n  referralCode: string | null;\n  referrerUserId: string | null;\n  referrerCode: string | null;\n  refereeCount: number;\n  telegramUsername: string | null;\n  telegramUserId: string | null;\n};\n\n// --- Expanded user-detail shapes (FR-6) --------------------------------------\n//\n// Per-section row types for the full support/audit user profile. Lamports and\n// numeric/precision-sensitive values arrive as `text` to preserve precision; the\n// UI re-formats at render time. All shapes are browser-safe (no server imports).\n\nexport type PeekLinkedAccountRow = {\n  id: string;\n  provider: string;\n  providerAccountId: string;\n  status: string;\n  telegramUsername: string | null;\n  metadataJson: Record<string, unknown> | null;\n  linkedAt: string;\n  updatedAt: string;\n};\n\nexport type PeekTelegramLinkTokenRow = {\n  id: string;\n  status: string;\n  telegramUserId: string | null;\n  telegramUsername: string | null;\n  expiresAt: string;\n  redeemedAt: string | null;\n  createdAt: string;\n};\n\nexport type PeekKolRate = {\n  rateBps: number;\n  setBy: string;\n  createdAt: string;\n  updatedAt: string;\n};\n\nexport type PeekReferralEarningsSummary = {\n  earningsCount: number;\n  totalReferrerEarnedLamports: string;\n  totalRefereeRebateLamports: string;\n  lastEarnedAt: string | null;\n};\n\nexport type PeekReferralClaimRow = {\n  id: string;\n  amountLamports: string;\n  status: string;\n  retryCount: number;\n  txSignature: string | null;\n  error: string | null;\n  requestedAt: string;\n  processedAt: string | null;\n};\n\nexport type PeekPointGrantRow = {\n  id: string;\n  sourceType: string;\n  sourceId: string;\n  amount: string;\n  createdAt: string;\n};\n\nexport type PeekPlayerPoints = {\n  balance: string;\n  lifetimeEarned: string;\n  updatedAt: string | null;\n};\n\nexport type PeekCrateDropRow = {\n  id: string;\n  triggerType: string;\n  triggerId: string;\n  crateType: string;\n  contentsAmount: string;\n  status: string;\n  createdAt: string;\n  grantedAt: string | null;\n};\n\nexport type PeekChallengeAssignmentSummary = {\n  active: number;\n  completed: number;\n  expired: number;\n  total: number;\n};\n\nexport type PeekGameEntryRow = {\n  id: string;\n  game: string;\n  roundPda: string;\n  matchId: string;\n  amountLamports: string;\n  side: string | null;\n  isWinner: boolean | null;\n  payoutLamports: string;\n  createdAt: string;\n  settledAt: string | null;\n};\n\nexport type PeekTransactionRow = {\n  id: string;\n  game: string;\n  matchId: string;\n  txType: string;\n  amountLamports: string;\n  txSig: string;\n  createdAt: string;\n};\n\nexport type PeekFraudFlagRow = {\n  id: string;\n  flagType: string;\n  status: string;\n  relatedId: string | null;\n  createdAt: string;\n  resolvedAt: string | null;\n};\n\nexport type PeekUserQueueEventRow = {\n  id: string;\n  eventType: string;\n  status: string;\n  attempts: number;\n  maxAttempts: number;\n  scheduledAt: string;\n  createdAt: string;\n  error: string | null;\n};\n\nexport type PeekUserAttentionFlags = {\n  failedClaim: boolean;\n  deadQueueEvent: boolean;\n  activeFraudFlag: boolean;\n  pendingSolCratePayout: boolean;\n  suspiciousReferralLoop: boolean;\n};\n\nexport type PeekUserDetailUser = PeekUserRow & {\n  avatarUrl: string | null;\n  heatMultiplier: string;\n  profilePointsBalance: string;\n};\n\nexport type PeekUserDetail = {\n  user: PeekUserDetailUser;\n  inboundReferral: {\n    referrerUserId: string | null;\n    referrerCode: string | null;\n    linkedAt: string | null;\n  };\n  outboundReferees: Array<{\n    refereeUserId: string;\n    refereeUsername: string | null;\n    createdAt: string;\n  }>;\n  telegram: {\n    state: \"active\" | \"none\";\n    telegramUserId: string | null;\n    telegramUsername: string | null;\n  };\n  linkedAccounts: ReadonlyArray<PeekLinkedAccountRow>;\n  recentTelegramLinkTokens: ReadonlyArray<PeekTelegramLinkTokenRow>;\n  kolRate: PeekKolRate | null;\n  referralEarnings: PeekReferralEarningsSummary;\n  recentReferralClaims: ReadonlyArray<PeekReferralClaimRow>;\n  points: PeekPlayerPoints;\n  recentPointGrants: ReadonlyArray<PeekPointGrantRow>;\n  recentCrateDrops: ReadonlyArray<PeekCrateDropRow>;\n  challengeSummary: PeekChallengeAssignmentSummary;\n  recentGameEntries: ReadonlyArray<PeekGameEntryRow>;\n  recentTransactions: ReadonlyArray<PeekTransactionRow>;\n  fraudFlags: ReadonlyArray<PeekFraudFlagRow>;\n  recentUserQueueEvents: ReadonlyArray<PeekUserQueueEventRow>;\n  attention: PeekUserAttentionFlags;\n};\n\n// --- Actor view model (browser-safe) -----------------------------------------\n\nexport type PeekActorView = {\n  email: string;\n  role: PeekRole;\n};\n\n// --- Metric metadata (FR-4) --------------------------------------------------\n//\n// Each metric carries the bookkeeping required by the data-surfacing standard:\n// stable id, label, value, source table/query, time window, \"as of\" timestamp,\n// short definition, optional unit, and optional drill-down link to the filtered\n// detail rows behind the number.\n\nexport type PeekMetricFreshness = \"live\" | \"cached\" | \"manual\" | \"sampled\";\n\nexport type PeekMetric = {\n  id: string;\n  label: string;\n  value: number | string | null;\n  valueDisplay: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  asOf: string | null;\n  definition: string;\n  freshness: PeekMetricFreshness;\n  drilldownHref: string | null;\n};\n\n// --- Pagination primitive ----------------------------------------------------\n\nexport type PeekPagination = {\n  page: number;\n  pageSize: number;\n  totalCount: number;\n  totalPages: number;\n};\n\n// --- Sort primitive ----------------------------------------------------------\n\nexport type PeekSortDirection = \"asc\" | \"desc\";\n\nexport type PeekTableSort = {\n  column: string;\n  direction: PeekSortDirection;\n};\n\n// --- Table filter primitive (URL-addressable) --------------------------------\n\nexport type PeekFilterKind =\n  | \"text\"\n  | \"select\"\n  | \"boolean\"\n  | \"date\"\n  | \"dateRange\";\n\nexport type PeekFilterOption = {\n  value: string;\n  label: string;\n};\n\nexport type PeekTableFilter = {\n  id: string;\n  label: string;\n  kind: PeekFilterKind;\n  value: string | null;\n  options: ReadonlyArray<PeekFilterOption> | null;\n  placeholder: string | null;\n  required: boolean;\n};\n\n// --- Status chip tone (shared) -----------------------------------------------\n\nexport type PeekStatusTone =\n  | \"neutral\"\n  | \"positive\"\n  | \"warning\"\n  | \"negative\"\n  | \"info\";\n\n// --- Empty-state primitive ---------------------------------------------------\n\nexport type PeekEmptyState = {\n  title: string;\n  body: string | null;\n};\n\n// --- Table row + column primitives -------------------------------------------\n//\n// Per-feature row types extend `PeekTableRowBase` for the shared identifier +\n// optional drill-down link, then add feature-specific fields. The shared dense\n// table component reads `columns` for layout and per-row data via the typed\n// row shape supplied by the feature page.\n\nexport type PeekTableColumnAlign = \"left\" | \"right\" | \"center\";\n\nexport type PeekTableColumn = {\n  id: string;\n  label: string;\n  align: PeekTableColumnAlign;\n  sortable: boolean;\n};\n\nexport type PeekTableRowBase = {\n  id: string;\n  href: string | null;\n};\n\nexport type PeekTableViewModel<TRow extends PeekTableRowBase> = {\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<TRow>;\n  pagination: PeekPagination;\n  filters: ReadonlyArray<PeekTableFilter>;\n  sort: PeekTableSort | null;\n  empty: PeekEmptyState;\n};\n\n// --- Command-center attention queue (FR-3, FR-10) ----------------------------\n//\n// The command-center page surfaces a small set of \"needs attention\" metrics so\n// operators see exception states (failed claims, dead queue events, stuck\n// settlements, pending SOL crate payouts, stale active Dogpile events,\n// high-value export activity) before they dig into per-feature pages. Each\n// item is a `PeekMetric` so the metric-strip primitive renders it with the\n// FR-4 bookkeeping (definition, source, time window, \"as of\", drill-down).\n\nexport type PeekCommandCenterAttentionId =\n  | \"failed_claims\"\n  | \"dead_queue_events\"\n  | \"stuck_rounds_flipyou_potshot\"\n  | \"stuck_rounds_closecall\"\n  | \"pending_sol_crate_payouts\"\n  | \"stale_active_dogpile_events\"\n  | \"high_value_exports_24h\";\n\nexport type PeekCommandCenterAttention = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};\n\n// --- Recent operator activity (FR-3 command-center \"high-signal activity\") ---\n//\n// Compact projection of the latest `operator_events` rows for the command-center\n// \"Recent activity\" section. Pulled from the same JSONB payload the audit\n// writer persists, but kept narrow on purpose — the command center surfaces\n// only the few fields needed to recognize what happened, not the full payload.\n// The audit view (`/audit`, later iteration) renders the full bounded table.\n\nexport type PeekRecentActivityItem = {\n  id: string;\n  eventType: string;\n  actorEmail: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  route: string | null;\n  createdAt: string;\n};\n\n// --- Audit event contracts (FR-11) -------------------------------------------\n//\n// Browser-safe view of `operator_events` rows the audit writer produces under\n// `peek.*` event types. The `PeekAuditPayload` shape pins the fields required by\n// FR-11 so the writer (`peek/src/server/audit/**`, next iteration) and the audit\n// view (`/audit`, later iteration) agree on a serialization contract. Secrets\n// (JWTs, access tokens, DB URLs, private keys, raw secrets) must be replaced by\n// `PEEK_AUDIT_REDACTED` before persisting; the audit-view component renders the\n// token verbatim so reviewers can see that a field was redacted (not silently\n// absent).\n\nexport type PeekAuditEventType =\n  | \"peek.search\"\n  | \"peek.user.view_sensitive\"\n  | \"peek.export\"\n  | \"peek.access.denied\"\n  | \"peek.change.applied\"\n  | \"peek.change.rejected\";\n\nexport const PEEK_AUDIT_EVENT_TYPES: ReadonlyArray<PeekAuditEventType> = [\n  \"peek.search\",\n  \"peek.user.view_sensitive\",\n  \"peek.export\",\n  \"peek.access.denied\",\n  \"peek.change.applied\",\n  \"peek.change.rejected\",\n];\n\nexport function isPeekAuditEventType(\n  value: unknown,\n): value is PeekAuditEventType {\n  return (\n    typeof value === \"string\" &&\n    (PEEK_AUDIT_EVENT_TYPES as ReadonlyArray<string>).includes(value)\n  );\n}\n\nexport const PEEK_AUDIT_REDACTED = \"[REDACTED]\";\n\nexport type PeekAuditScalar = string | number | boolean | null;\n\nexport type PeekAuditChange = {\n  field: string;\n  before: PeekAuditScalar;\n  after: PeekAuditScalar;\n};\n\nexport type PeekAuditPayload = {\n  actorEmail: string;\n  route: string | null;\n  actionId: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  filterSummary: string | null;\n  resultCount: number | null;\n  requestId: string | null;\n  rejectionReason: string | null;\n  changes: ReadonlyArray<PeekAuditChange> | null;\n};\n\nexport type PeekAuditEvent = {\n  id: string;\n  eventType: PeekAuditEventType;\n  createdAt: string;\n  payload: PeekAuditPayload;\n};\n\n// --- Export contracts (FR-12) ------------------------------------------------\n//\n// Exports are server-rendered CSVs gated by the same page-level access as the\n// source page, bounded by a server-side row cap, named with a deterministic\n// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n// bytes return. Export rows reuse the table view-model column ids so the export\n// shape stays in lockstep with the rendered table; values are pre-formatted\n// strings so CSV serialization stays straightforward and locale-stable.\n\nexport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n\nexport type PeekExportEntity =\n  | \"users\"\n  | \"referrers\"\n  | \"kol\"\n  | \"claims\"\n  | \"rounds\"\n  | \"transactions\"\n  | \"queue\"\n  | \"audit\";\n\nexport type PeekExportRow = Record<string, string>;\n\nexport type PeekExportFilenameInput = {\n  entity: PeekExportEntity;\n  date: string;\n  filterSlug: string;\n};\n\nexport type PeekExportResult = {\n  filename: string;\n  rowCount: number;\n  rowCap: number;\n  rowCapApplied: boolean;\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<PeekExportRow>;\n};\n\n// --- Universal search (FR-5) -------------------------------------------------\n//\n// One search entry point that resolves common operational identifiers to typed\n// result groups. Results are grouped by entity type so the UI can section them\n// (user, referral, linked account, round, transaction, queue event). Each\n// result includes enough context to disambiguate similar matches; sensitive\n// values (wallet, Telegram id, tx signature) live in the result's `id`/`label`\n// fields for operator readability and the audit event records only the actor\n// email, query class, and result counts (never the raw query, which the audit\n// writer redacts if it looks like a secret).\n\nexport type PeekSearchEntityType =\n  | \"user\"\n  | \"referral\"\n  | \"linked_account\"\n  | \"round\"\n  | \"transaction\"\n  | \"queue_event\";\n\nexport const PEEK_SEARCH_ENTITY_TYPES: ReadonlyArray<PeekSearchEntityType> = [\n  \"user\",\n  \"referral\",\n  \"linked_account\",\n  \"round\",\n  \"transaction\",\n  \"queue_event\",\n];\n\n// Coarse heuristic classification used only for the `peek.search` audit\n// summary so reviewers can see which class of identifier was searched without\n// inferring it from the (possibly redacted) raw query.\nexport type PeekSearchQueryClass =\n  | \"empty\"\n  | \"free_text\"\n  | \"user_id\"\n  | \"username\"\n  | \"wallet\"\n  | \"referral_code\"\n  | \"telegram_username\"\n  | \"telegram_provider_id\"\n  | \"round_pda\"\n  | \"match_id\"\n  | \"tx_signature\"\n  | \"queue_event_id\";\n\nexport type PeekSearchResult = {\n  entityType: PeekSearchEntityType;\n  id: string;\n  label: string;\n  sublabel: string | null;\n  context: string | null;\n  href: string;\n};\n\nexport type PeekSearchGroup = {\n  entityType: PeekSearchEntityType;\n  results: ReadonlyArray<PeekSearchResult>;\n  truncated: boolean;\n};\n\nexport type PeekSearchResponse = {\n  query: string;\n  queryClass: PeekSearchQueryClass;\n  groups: ReadonlyArray<PeekSearchGroup>;\n  totalResults: number;\n  perGroupLimit: number;\n  generatedAt: string;\n};\n\nexport const PEEK_SEARCH_DEFAULT_PER_GROUP_LIMIT = 5;\nexport const PEEK_SEARCH_MAX_PER_GROUP_LIMIT = 25;\n\n// --- Growth + referral admin (FR-7) ------------------------------------------\n//\n// Browser-safe view models for `/growth/referrals` and `/growth/kol`. The\n// engine queries surface (a) overview metrics that fit the FR-4 metric\n// bookkeeping, (b) top-referrer rows that combine `referral_links`,\n// `referral_codes`, `referral_earnings`, and pending `referral_claims` per\n// referrer, (c) KOL rows that join `referral_kol_rates` with linked\n// performance from `referral_links`/`referral_earnings`, (d) claim rows for\n// the filterable `/growth/referrals` claims table, and (e) a one-hop\n// referral-graph node that lets the UI navigate from a user-detail page to\n// the inbound referrer or any outbound referee and back.\n//\n// All numeric/precision-sensitive values arrive as `text` to preserve u64\n// lamport precision; the UI formats at render time.\n\nexport type PeekGrowthOverviewMetricId =\n  | \"growth.referrers\"\n  | \"growth.referred_users\"\n  | \"growth.activated_referred_users\"\n  | \"growth.referrer_earnings_lamports\"\n  | \"growth.referee_rebates_lamports\"\n  | \"growth.pending_claims_lamports\"\n  | \"growth.failed_claims\"\n  | \"growth.kol_count\";\n\nexport const PEEK_GROWTH_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekGrowthOverviewMetricId> =\n  [\n    \"growth.referrers\",\n    \"growth.referred_users\",\n    \"growth.activated_referred_users\",\n    \"growth.referrer_earnings_lamports\",\n    \"growth.referee_rebates_lamports\",\n    \"growth.pending_claims_lamports\",\n    \"growth.failed_claims\",\n    \"growth.kol_count\",\n  ];\n\nexport type PeekGrowthOverview = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};\n\nexport type PeekTopReferrerRow = {\n  referrerUserId: string;\n  username: string | null;\n  wallet: string;\n  referralCode: string | null;\n  refereeCount: number;\n  activeRefereeCount: number;\n  referredWagerLamports: string;\n  referrerEarnedLamports: string;\n  pendingClaimLamports: string;\n};\n\nexport type PeekKolPerformanceRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  rateBps: number;\n  setBy: string;\n  createdAt: string;\n  updatedAt: string;\n  refereeCount: number;\n  referredWagerLamports: string;\n  referrerEarnedLamports: string;\n};\n\n// Status filter values mirror the migration check constraint:\n// 'pending' | 'processing' | 'error' | 'completed' | 'failed'. Treated as a\n// loose `string` here so the UI can pass through a \"failed_or_error\" virtual\n// alias without a contract change. Extends the per-user\n// `PeekReferralClaimRow` with the `userId`/`username`/`wallet` columns the\n// /growth/referrals claims table needs to render and link rows back to user\n// detail.\nexport type PeekGrowthClaimRow = PeekReferralClaimRow & {\n  userId: string;\n  username: string | null;\n  wallet: string;\n};\n\nexport type PeekReferralClaimFilters = {\n  status: string | null;\n  userId: string | null;\n  minAmountLamports: string | null;\n  maxAmountLamports: string | null;\n  requestedFrom: string | null;\n  requestedTo: string | null;\n  txSignature: string | null;\n  errorContains: string | null;\n};\n\nexport type PeekReferralGraphRefereeRow = {\n  refereeUserId: string;\n  refereeUsername: string | null;\n  refereeWallet: string;\n  createdAt: string;\n};\n\nexport type PeekReferralGraphInboundReferrer = {\n  referrerUserId: string | null;\n  referrerUsername: string | null;\n  referrerWallet: string | null;\n  referrerCode: string | null;\n  linkedAt: string | null;\n};\n\nexport type PeekReferralGraphNode = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  referralCode: string | null;\n  inboundReferrer: PeekReferralGraphInboundReferrer;\n  outboundReferees: ReadonlyArray<PeekReferralGraphRefereeRow>;\n};\n","structuredPatch":[{"oldStart":654,"oldLines":3,"newStart":654,"newLines":63,"lines":["   inboundReferrer: PeekReferralGraphInboundReferrer;","   outboundReferees: ReadonlyArray<PeekReferralGraphRefereeRow>;"," };","+","+// --- Games overview (FR-8) ---------------------------------------------------","+//","+// Browser-safe view models for `/games`. The engine query reads the single","+// source of truth `game_entries` (migration 007) and produces (a) a small set","+// of platform-wide FR-4 metrics for the overview strip and (b) per-game rows","+// with the operational counters the spec calls out: entries, unique users,","+// wagered lamports, settled entries, refund entries, payout lamports, wins,","+// losses. Lamport sums round-trip as `text` to preserve u64 precision; the UI","+// formats at render time.","+//","+// `PeekGameId` mirrors the migration's CHECK constraint on `game_entries.game`","+// (`'flipyou' | 'potshot' | 'closecall'`). Deferred games (Crash, Game of","+// Trades, Chart the Course, Slots Utopia, Tug of Earn) are documented","+// placeholders rendered by the page; they intentionally are not part of the","+// data shape because they have no persisted source yet (system invariant 13).","+","+export type PeekGameId = \"flipyou\" | \"potshot\" | \"closecall\";","+","+export const PEEK_GAME_IDS: ReadonlyArray<PeekGameId> = [","+  \"flipyou\",","+  \"potshot\",","+  \"closecall\",","+];","+","+export type PeekGameOverviewRow = {","+  game: PeekGameId;","+  entries: number;","+  uniqueUsers: number;","+  wageredLamports: string;","+  settledEntries: number;","+  refundEntries: number;","+  payoutLamports: string;","+  wins: number;","+  losses: number;","+};","+","+export type PeekGameOverviewMetricId =","+  | \"games.total_entries\"","+  | \"games.unique_users\"","+  | \"games.wagered_lamports\"","+  | \"games.settled_entries\"","+  | \"games.refund_entries\"","+  | \"games.payout_lamports\";","+","+export const PEEK_GAME_OVERVIEW_METRIC_IDS: ReadonlyArray<PeekGameOverviewMetricId> =","+  [","+    \"games.total_entries\",","+    \"games.unique_users\",","+    \"games.wagered_lamports\",","+    \"games.settled_entries\",","+    \"games.refund_entries\",","+    \"games.payout_lamports\",","+  ];","+","+export type PeekGameOverview = {","+  generatedAt: string;","+  metrics: ReadonlyArray<PeekMetric>;","+  perGame: ReadonlyArray<PeekGameOverviewRow>;","+};"]}],"userModified":false,"replaceAll":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01XvJoK8LFkVh5UX6e36P9C7","type":"message","role":"assistant","content":[{"type":"text","text":"Now create the games overview query module."}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3726,"cache_read_input_tokens":97896,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3726},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"e174db15-b365-437f-8743-46cb380241b8","uuid":"ab1d748e-42b8-4d80-9a87-d8d69d308b18"}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01XvJoK8LFkVh5UX6e36P9C7","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FWmGmMcakURsVtSJVLfPDj","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/db/queries/get-games-overview.ts","content":"// Games overview admin queries (FR-8).\n//\n// Backs `/games`: cross-game `game_entries` aggregations per game, plus a\n// small platform-wide metric strip suitable for the FR-4 metric primitive.\n// The single source of truth is `game_entries` (migration 007): one row per\n// participation, UPSERT'd at settlement. The migration documents the refund\n// convention used here:\n//\n//   \"Refunded entries: is_winner = NULL, payout_lamports = amount_lamports.\"\n//\n// Per-game counters:\n//   entries          — all game_entries rows for the game\n//   uniqueUsers      — distinct user_id values\n//   wageredLamports  — sum(amount_lamports)\n//   settledEntries   — rows with settled_at IS NOT NULL\n//   refundEntries    — settled rows with is_winner IS NULL (refund sentinel)\n//   payoutLamports   — sum(payout_lamports)\n//   wins             — rows with is_winner = TRUE\n//   losses           — rows with is_winner = FALSE\n//\n// Bounded: a single grouped query — no row-level data crosses the wire here.\n// Deferred games (Crash, Game of Trades, Chart the Course, Slots Utopia, Tug\n// of Earn) are not part of the data shape; the `/games` page renders them as\n// documented placeholders only (system invariant 13).\n\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_GAME_IDS,\n  type PeekGameId,\n  type PeekGameOverview,\n  type PeekGameOverviewMetricId,\n  type PeekGameOverviewRow,\n  type PeekMetric,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport type GamesOverviewOptions = {\n  sql?: Sql;\n  now?: Date;\n};\n\ntype AggregateRow = {\n  game: PeekGameId;\n  entries: number | string;\n  unique_users: number | string;\n  wagered_lamports: string;\n  settled_entries: number | string;\n  refund_entries: number | string;\n  payout_lamports: string;\n  wins: number | string;\n  losses: number | string;\n};\n\ntype CountRow = { value: number | string };\n\nfunction readInt(value: number | string | null | undefined): number {\n  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n  if (typeof value === \"string\") {\n    const parsed = Number.parseInt(value, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction readSum(value: string | null | undefined): string {\n  return typeof value === \"string\" && value.length > 0 ? value : \"0\";\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\nfunction formatLamports(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nfunction emptyRow(game: PeekGameId): PeekGameOverviewRow {\n  return {\n    game,\n    entries: 0,\n    uniqueUsers: 0,\n    wageredLamports: \"0\",\n    settledEntries: 0,\n    refundEntries: 0,\n    payoutLamports: \"0\",\n    wins: 0,\n    losses: 0,\n  };\n}\n\nfunction sumLamports(values: ReadonlyArray<string>): string {\n  // BigInt sum keeps u64 precision across per-game lamport totals; values\n  // are strings from the postgres driver.\n  let total = 0n;\n  for (const v of values) {\n    if (!v) continue;\n    try {\n      total += BigInt(v);\n    } catch {\n      // ignore unparsable values; the per-game row already reflects them.\n    }\n  }\n  return total.toString();\n}\n\ntype MetricBlueprint = {\n  id: PeekGameOverviewMetricId;\n  label: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  definition: string;\n  drilldownHref: string | null;\n};\n\nfunction buildMetric(\n  blueprint: MetricBlueprint,\n  raw: number | string,\n  display: string,\n  asOf: string,\n): PeekMetric {\n  return {\n    id: blueprint.id,\n    label: blueprint.label,\n    value: raw,\n    valueDisplay: display,\n    unit: blueprint.unit,\n    source: blueprint.source,\n    windowLabel: blueprint.windowLabel,\n    asOf,\n    definition: blueprint.definition,\n    freshness: \"live\",\n    drilldownHref: blueprint.drilldownHref,\n  };\n}\n\nexport async function getGamesOverview(\n  options: GamesOverviewOptions = {},\n): Promise<PeekGameOverview> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n\n  // Two queries fire in parallel:\n  //   1. per-game aggregates (one row per game appearing in the table).\n  //   2. platform-wide unique-users count (DISTINCT user_id across all\n  //      games — different from summing per-game distinct counts because a\n  //      single player can appear in multiple games).\n  const [aggregateRows, uniqueUsersRows] = await Promise.all([\n    sql<AggregateRow[]>`\n      select\n        game,\n        count(*)::int as \"entries\",\n        count(distinct user_id)::int as \"unique_users\",\n        coalesce(sum(amount_lamports), 0)::text as \"wagered_lamports\",\n        count(*) filter (where settled_at is not null)::int as \"settled_entries\",\n        count(*) filter (where settled_at is not null and is_winner is null)::int as \"refund_entries\",\n        coalesce(sum(payout_lamports), 0)::text as \"payout_lamports\",\n        count(*) filter (where is_winner = true)::int as \"wins\",\n        count(*) filter (where is_winner = false)::int as \"losses\"\n      from game_entries\n      group by game\n    `,\n    sql<CountRow[]>`\n      select count(distinct user_id)::int as \"value\"\n      from game_entries\n    `,\n  ]);\n\n  // Normalize: emit one row per known PeekGameId in stable order, zeroed when\n  // a game has no entries yet so the UI does not have to special-case missing\n  // rows. Unknown game values returned by the DB are ignored — the migration\n  // CHECK constraint should keep them in lockstep with PEEK_GAME_IDS, but\n  // skipping unknowns here means an out-of-band row cannot leak into the UI.\n  const byGame = new Map<PeekGameId, AggregateRow>();\n  for (const row of aggregateRows) {\n    if ((PEEK_GAME_IDS as ReadonlyArray<string>).includes(row.game)) {\n      byGame.set(row.game, row);\n    }\n  }\n\n  const perGame: PeekGameOverviewRow[] = PEEK_GAME_IDS.map((game) => {\n    const row = byGame.get(game);\n    if (!row) return emptyRow(game);\n    return {\n      game,\n      entries: readInt(row.entries),\n      uniqueUsers: readInt(row.unique_users),\n      wageredLamports: readSum(row.wagered_lamports),\n      settledEntries: readInt(row.settled_entries),\n      refundEntries: readInt(row.refund_entries),\n      payoutLamports: readSum(row.payout_lamports),\n      wins: readInt(row.wins),\n      losses: readInt(row.losses),\n    };\n  });\n\n  const totalEntries = perGame.reduce((acc, r) => acc + r.entries, 0);\n  const totalSettled = perGame.reduce((acc, r) => acc + r.settledEntries, 0);\n  const totalRefunds = perGame.reduce((acc, r) => acc + r.refundEntries, 0);\n  const totalWagered = sumLamports(perGame.map((r) => r.wageredLamports));\n  const totalPayouts = sumLamports(perGame.map((r) => r.payoutLamports));\n  const platformUniqueUsers = readInt(\n    uniqueUsersRows.length > 0 ? uniqueUsersRows[0]?.value : 0,\n  );\n\n  const blueprints: ReadonlyArray<{\n    blueprint: MetricBlueprint;\n    raw: number | string;\n    display: string;\n  }> = [\n    {\n      blueprint: {\n        id: \"games.total_entries\",\n        label: \"Game entries\",\n        unit: \"entries\",\n        source: \"game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Total game_entries rows across FlipYou, Pot Shot, and Close Call — one row per participation.\",\n        drilldownHref: \"/games\",\n      },\n      raw: totalEntries,\n      display: formatCount(totalEntries),\n    },\n    {\n      blueprint: {\n        id: \"games.unique_users\",\n        label: \"Unique players\",\n        unit: \"users\",\n        source: \"game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Distinct user_id values across all games — a single player counted once even if they played multiple games.\",\n        drilldownHref: \"/games\",\n      },\n      raw: platformUniqueUsers,\n      display: formatCount(platformUniqueUsers),\n    },\n    {\n      blueprint: {\n        id: \"games.wagered_lamports\",\n        label: \"Wagered (lamports)\",\n        unit: \"lamports\",\n        source: \"game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Sum of amount_lamports across game_entries — gross wager volume across all games.\",\n        drilldownHref: \"/games\",\n      },\n      raw: totalWagered,\n      display: formatLamports(totalWagered),\n    },\n    {\n      blueprint: {\n        id: \"games.settled_entries\",\n        label: \"Settled entries\",\n        unit: \"entries\",\n        source: \"game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Game entries with settled_at set — includes wins, losses, and refunds.\",\n        drilldownHref: \"/games\",\n      },\n      raw: totalSettled,\n      display: formatCount(totalSettled),\n    },\n    {\n      blueprint: {\n        id: \"games.refund_entries\",\n        label: \"Refunded entries\",\n        unit: \"entries\",\n        source: \"game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Settled entries with is_winner IS NULL — the migration's refund sentinel (payout_lamports = amount_lamports).\",\n        drilldownHref: \"/games\",\n      },\n      raw: totalRefunds,\n      display: formatCount(totalRefunds),\n    },\n    {\n      blueprint: {\n        id: \"games.payout_lamports\",\n        label: \"Paid out (lamports)\",\n        unit: \"lamports\",\n        source: \"game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Sum of payout_lamports across game_entries — gross winnings + refunds returned to players.\",\n        drilldownHref: \"/games\",\n      },\n      raw: totalPayouts,\n      display: formatLamports(totalPayouts),\n    },\n  ];\n\n  return {\n    generatedAt,\n    metrics: blueprints.map(({ blueprint, raw, display }) =>\n      buildMetric(blueprint, raw, display, generatedAt),\n    ),\n    perGame,\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3726,"cache_read_input_tokens":97896,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3726},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"e174db15-b365-437f-8743-46cb380241b8","uuid":"46543e6e-fffc-4174-966d-b6a0a968d037"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FWmGmMcakURsVtSJVLfPDj","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/server/db/queries/get-games-overview.ts"}]},"parent_tool_use_id":null,"session_id":"e174db15-b365-437f-8743-46cb380241b8","uuid":"ced0f9d7-3df8-42d0-b2c9-0507a21ef3e4","timestamp":"2026-04-25T12:40:59.113Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-games-overview.ts","content":"// Games overview admin queries (FR-8).\n//\n// Backs `/games`: cross-game `game_entries` aggregations per game, plus a\n// small platform-wide metric strip suitable for the FR-4 metric primitive.\n// The single source of truth is `game_entries` (migration 007): one row per\n// participation, UPSERT'd at settlement. The migration documents the refund\n// convention used here:\n//\n//   \"Refunded entries: is_winner = NULL, payout_lamports = amount_lamports.\"\n//\n// Per-game counters:\n//   entries          — all game_entries rows for the game\n//   uniqueUsers      — distinct user_id values\n//   wageredLamports  — sum(amount_lamports)\n//   settledEntries   — rows with settled_at IS NOT NULL\n//   refundEntries    — settled rows with is_winner IS NULL (refund sentinel)\n//   payoutLamports   — sum(payout_lamports)\n//   wins             — rows with is_winner = TRUE\n//   losses           — rows with is_winner = FALSE\n//\n// Bounded: a single grouped query — no row-level data crosses the wire here.\n// Deferred games (Crash, Game of Trades, Chart the Course, Slots Utopia, Tug\n// of Earn) are not part of the data shape; the `/games` page renders them as\n// documented placeholders only (system invariant 13).\n\nimport type { Sql } from \"postgres\";\nimport {\n  PEEK_GAME_IDS,\n  type PeekGameId,\n  type PeekGameOverview,\n  type PeekGameOverviewMetricId,\n  type PeekGameOverviewRow,\n  type PeekMetric,\n} from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport type GamesOverviewOptions = {\n  sql?: Sql;\n  now?: Date;\n};\n\ntype AggregateRow = {\n  game: PeekGameId;\n  entries: number | string;\n  unique_users: number | string;\n  wagered_lamports: string;\n  settled_entries: number | string;\n  refund_entries: number | string;\n  payout_lamports: string;\n  wins: number | string;\n  losses: number | string;\n};\n\ntype CountRow = { value: number | string };\n\nfunction readInt(value: number | string | null | undefined): number {\n  if (typeof value === \"number\" && Number.isFinite(value)) return value;\n  if (typeof value === \"string\") {\n    const parsed = Number.parseInt(value, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction readSum(value: string | null | undefined): string {\n  return typeof value === \"string\" && value.length > 0 ? value : \"0\";\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\nfunction formatLamports(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nfunction emptyRow(game: PeekGameId): PeekGameOverviewRow {\n  return {\n    game,\n    entries: 0,\n    uniqueUsers: 0,\n    wageredLamports: \"0\",\n    settledEntries: 0,\n    refundEntries: 0,\n    payoutLamports: \"0\",\n    wins: 0,\n    losses: 0,\n  };\n}\n\nfunction sumLamports(values: ReadonlyArray<string>): string {\n  // BigInt sum keeps u64 precision across per-game lamport totals; values\n  // are strings from the postgres driver.\n  let total = 0n;\n  for (const v of values) {\n    if (!v) continue;\n    try {\n      total += BigInt(v);\n    } catch {\n      // ignore unparsable values; the per-game row already reflects them.\n    }\n  }\n  return total.toString();\n}\n\ntype MetricBlueprint = {\n  id: PeekGameOverviewMetricId;\n  label: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  definition: string;\n  drilldownHref: string | null;\n};\n\nfunction buildMetric(\n  blueprint: MetricBlueprint,\n  raw: number | string,\n  display: string,\n  asOf: string,\n): PeekMetric {\n  return {\n    id: blueprint.id,\n    label: blueprint.label,\n    value: raw,\n    valueDisplay: display,\n    unit: blueprint.unit,\n    source: blueprint.source,\n    windowLabel: blueprint.windowLabel,\n    asOf,\n    definition: blueprint.definition,\n    freshness: \"live\",\n    drilldownHref: blueprint.drilldownHref,\n  };\n}\n\nexport async function getGamesOverview(\n  options: GamesOverviewOptions = {},\n): Promise<PeekGameOverview> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n\n  // Two queries fire in parallel:\n  //   1. per-game aggregates (one row per game appearing in the table).\n  //   2. platform-wide unique-users count (DISTINCT user_id across all\n  //      games — different from summing per-game distinct counts because a\n  //      single player can appear in multiple games).\n  const [aggregateRows, uniqueUsersRows] = await Promise.all([\n    sql<AggregateRow[]>`\n      select\n        game,\n        count(*)::int as \"entries\",\n        count(distinct user_id)::int as \"unique_users\",\n        coalesce(sum(amount_lamports), 0)::text as \"wagered_lamports\",\n        count(*) filter (where settled_at is not null)::int as \"settled_entries\",\n        count(*) filter (where settled_at is not null and is_winner is null)::int as \"refund_entries\",\n        coalesce(sum(payout_lamports), 0)::text as \"payout_lamports\",\n        count(*) filter (where is_winner = true)::int as \"wins\",\n        count(*) filter (where is_winner = false)::int as \"losses\"\n      from game_entries\n      group by game\n    `,\n    sql<CountRow[]>`\n      select count(distinct user_id)::int as \"value\"\n      from game_entries\n    `,\n  ]);\n\n  // Normalize: emit one row per known PeekGameId in stable order, zeroed when\n  // a game has no entries yet so the UI does not have to special-case missing\n  // rows. Unknown game values returned by the DB are ignored — the migration\n  // CHECK constraint should keep them in lockstep with PEEK_GAME_IDS, but\n  // skipping unknowns here means an out-of-band row cannot leak into the UI.\n  const byGame = new Map<PeekGameId, AggregateRow>();\n  for (const row of aggregateRows) {\n    if ((PEEK_GAME_IDS as ReadonlyArray<string>).includes(row.game)) {\n      byGame.set(row.game, row);\n    }\n  }\n\n  const perGame: PeekGameOverviewRow[] = PEEK_GAME_IDS.map((game) => {\n    const row = byGame.get(game);\n    if (!row) return emptyRow(game);\n    return {\n      game,\n      entries: readInt(row.entries),\n      uniqueUsers: readInt(row.unique_users),\n      wageredLamports: readSum(row.wagered_lamports),\n      settledEntries: readInt(row.settled_entries),\n      refundEntries: readInt(row.refund_entries),\n      payoutLamports: readSum(row.payout_lamports),\n      wins: readInt(row.wins),\n      losses: readInt(row.losses),\n    };\n  });\n\n  const totalEntries = perGame.reduce((acc, r) => acc + r.entries, 0);\n  const totalSettled = perGame.reduce((acc, r) => acc + r.settledEntries, 0);\n  const totalRefunds = perGame.reduce((acc, r) => acc + r.refundEntries, 0);\n  const totalWagered = sumLamports(perGame.map((r) => r.wageredLamports));\n  const totalPayouts = sumLamports(perGame.map((r) => r.payoutLamports));\n  const platformUniqueUsers = readInt(\n    uniqueUsersRows.length > 0 ? uniqueUsersRows[0]?.value : 0,\n  );\n\n  const blueprints: ReadonlyArray<{\n    blueprint: MetricBlueprint;\n    raw: number | string;\n    display: string;\n  }> = [\n    {\n      blueprint: {\n        id: \"games.total_entries\",\n        label: \"Game entries\",\n        unit: \"entries\",\n        source: \"game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Total game_entries rows across FlipYou, Pot Shot, and Close Call — one row per participation.\",\n        drilldownHref: \"/games\",\n      },\n      raw: totalEntries,\n      display: formatCount(totalEntries),\n    },\n    {\n      blueprint: {\n        id: \"games.unique_users\",\n        label: \"Unique players\",\n        unit: \"users\",\n        source: \"game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Distinct user_id values across all games — a single player counted once even if they played multiple games.\",\n        drilldownHref: \"/games\",\n      },\n      raw: platformUniqueUsers,\n      display: formatCount(platformUniqueUsers),\n    },\n    {\n      blueprint: {\n        id: \"games.wagered_lamports\",\n        label: \"Wagered (lamports)\",\n        unit: \"lamports\",\n        source: \"game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Sum of amount_lamports across game_entries — gross wager volume across all games.\",\n        drilldownHref: \"/games\",\n      },\n      raw: totalWagered,\n      display: formatLamports(totalWagered),\n    },\n    {\n      blueprint: {\n        id: \"games.settled_entries\",\n        label: \"Settled entries\",\n        unit: \"entries\",\n        source: \"game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Game entries with settled_at set — includes wins, losses, and refunds.\",\n        drilldownHref: \"/games\",\n      },\n      raw: totalSettled,\n      display: formatCount(totalSettled),\n    },\n    {\n      blueprint: {\n        id: \"games.refund_entries\",\n        label: \"Refunded entries\",\n        unit: \"entries\",\n        source: \"game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Settled entries with is_winner IS NULL — the migration's refund sentinel (payout_lamports = amount_lamports).\",\n        drilldownHref: \"/games\",\n      },\n      raw: totalRefunds,\n      display: formatCount(totalRefunds),\n    },\n    {\n      blueprint: {\n        id: \"games.payout_lamports\",\n        label: \"Paid out (lamports)\",\n        unit: \"lamports\",\n        source: \"game_entries\",\n        windowLabel: \"All time\",\n        definition:\n          \"Sum of payout_lamports across game_entries — gross winnings + refunds returned to players.\",\n        drilldownHref: \"/games\",\n      },\n      raw: totalPayouts,\n      display: formatLamports(totalPayouts),\n    },\n  ];\n\n  return {\n    generatedAt,\n    metrics: blueprints.map(({ blueprint, raw, display }) =>\n      buildMetric(blueprint, raw, display, generatedAt),\n    ),\n    perGame,\n  };\n}\n","structuredPatch":[],"originalFile":null,"userModified":false}}
