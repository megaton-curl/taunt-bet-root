{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018fDzrenGT1EfiHaA3JZiH5","type":"tool_result","content":"1\timport type { PeekUserDetail } from \"../../../lib/types/peek\";\n2\timport { getSqlClient } from \"../client\";\n3\t\n4\texport function formatUserHeading(user: {\n5\t  userId: string;\n6\t  username: string | null;\n7\t}) {\n8\t  return user.username ?? user.userId;\n9\t}\n10\t\n11\texport async function getPeekUserDetail(\n12\t  userId: string\n13\t): Promise<PeekUserDetail | null> {\n14\t  const sql = getSqlClient();\n15\t  const [user] = await sql<any[]>`\n16\t    select\n17\t      pp.user_id as \"userId\",\n18\t      pp.username as \"username\",\n19\t      pp.wallet as \"wallet\",\n20\t      pp.created_at::text as \"joinedAt\",\n21\t      rc.code as \"referralCode\",\n22\t      rl.referrer_user_id as \"referrerUserId\",\n23\t      ref_code.code as \"referrerCode\",\n24\t      (\n25\t        select count(*)::int\n26\t        from referral_links outbound\n27\t        where outbound.referrer_user_id = pp.user_id\n28\t      ) as \"refereeCount\",\n29\t      coalesce(tla.status, 'none') as \"telegramLinkState\",\n30\t      rl.created_at::text as \"linkedAt\",\n31\t      tla.telegram_user_id as \"telegramUserId\",\n32\t      tla.telegram_username as \"telegramUsername\"\n33\t    from player_profiles pp\n34\t    left join referral_codes rc on rc.user_id = pp.user_id\n35\t    left join referral_links rl on rl.referee_user_id = pp.user_id\n36\t    left join referral_codes ref_code on ref_code.user_id = rl.referrer_user_id\n37\t    left join lateral (\n38\t      select\n39\t        status,\n40\t        provider_account_id as telegram_user_id,\n41\t        nullif(metadata_json->>'telegramUsername', '') as telegram_username\n42\t      from linked_accounts\n43\t      where user_id = pp.user_id\n44\t        and provider = 'telegram'\n45\t        and status = 'active'\n46\t      limit 1\n47\t    ) tla on true\n48\t    where pp.user_id = ${userId}\n49\t  `;\n50\t\n51\t  if (!user) {\n52\t    return null;\n53\t  }\n54\t\n55\t  const outboundReferees = await sql<\n56\t    Array<{\n57\t      refereeUserId: string;\n58\t      refereeUsername: string | null;\n59\t      createdAt: string;\n60\t    }>\n61\t  >`\n62\t    select\n63\t      rl.referee_user_id as \"refereeUserId\",\n64\t      pp.username as \"refereeUsername\",\n65\t      rl.created_at::text as \"createdAt\"\n66\t    from referral_links rl\n67\t    left join player_profiles pp on pp.user_id = rl.referee_user_id\n68\t    where rl.referrer_user_id = ${userId}\n69\t    order by rl.created_at desc\n70\t  `;\n71\t\n72\t  return {\n73\t    user: {\n74\t      userId: user.userId,\n75\t      username: user.username,\n76\t      wallet: user.wallet,\n77\t      joinedAt: user.joinedAt,\n78\t      referralCode: user.referralCode,\n79\t      referrerUserId: user.referrerUserId,\n80\t      referrerCode: user.referrerCode,\n81\t      refereeCount: user.refereeCount,\n82\t      telegramUsername: user.telegramUsername,\n83\t      telegramUserId: user.telegramUserId,\n84\t    },\n85\t    inboundReferral: {\n86\t      referrerUserId: user.referrerUserId,\n87\t      referrerCode: user.referrerCode,\n88\t      linkedAt: user.linkedAt,\n89\t    },\n90\t    outboundReferees,\n91\t    telegram: {\n92\t      state: user.telegramLinkState,\n93\t      telegramUserId: user.telegramUserId,\n94\t      telegramUsername: user.telegramUsername,\n95\t    },\n96\t  };\n97\t}\n98\t"}]},"parent_tool_use_id":null,"session_id":"ad5daed8-e332-4da3-beea-b105192abc37","uuid":"d4e3a046-256f-4acd-a227-835005a57f09","timestamp":"2026-04-25T11:15:50.696Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-peek-user-detail.ts","content":"import type { PeekUserDetail } from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport function formatUserHeading(user: {\n  userId: string;\n  username: string | null;\n}) {\n  return user.username ?? user.userId;\n}\n\nexport async function getPeekUserDetail(\n  userId: string\n): Promise<PeekUserDetail | null> {\n  const sql = getSqlClient();\n  const [user] = await sql<any[]>`\n    select\n      pp.user_id as \"userId\",\n      pp.username as \"username\",\n      pp.wallet as \"wallet\",\n      pp.created_at::text as \"joinedAt\",\n      rc.code as \"referralCode\",\n      rl.referrer_user_id as \"referrerUserId\",\n      ref_code.code as \"referrerCode\",\n      (\n        select count(*)::int\n        from referral_links outbound\n        where outbound.referrer_user_id = pp.user_id\n      ) as \"refereeCount\",\n      coalesce(tla.status, 'none') as \"telegramLinkState\",\n      rl.created_at::text as \"linkedAt\",\n      tla.telegram_user_id as \"telegramUserId\",\n      tla.telegram_username as \"telegramUsername\"\n    from player_profiles pp\n    left join referral_codes rc on rc.user_id = pp.user_id\n    left join referral_links rl on rl.referee_user_id = pp.user_id\n    left join referral_codes ref_code on ref_code.user_id = rl.referrer_user_id\n    left join lateral (\n      select\n        status,\n        provider_account_id as telegram_user_id,\n        nullif(metadata_json->>'telegramUsername', '') as telegram_username\n      from linked_accounts\n      where user_id = pp.user_id\n        and provider = 'telegram'\n        and status = 'active'\n      limit 1\n    ) tla on true\n    where pp.user_id = ${userId}\n  `;\n\n  if (!user) {\n    return null;\n  }\n\n  const outboundReferees = await sql<\n    Array<{\n      refereeUserId: string;\n      refereeUsername: string | null;\n      createdAt: string;\n    }>\n  >`\n    select\n      rl.referee_user_id as \"refereeUserId\",\n      pp.username as \"refereeUsername\",\n      rl.created_at::text as \"createdAt\"\n    from referral_links rl\n    left join player_profiles pp on pp.user_id = rl.referee_user_id\n    where rl.referrer_user_id = ${userId}\n    order by rl.created_at desc\n  `;\n\n  return {\n    user: {\n      userId: user.userId,\n      username: user.username,\n      wallet: user.wallet,\n      joinedAt: user.joinedAt,\n      referralCode: user.referralCode,\n      referrerUserId: user.referrerUserId,\n      referrerCode: user.referrerCode,\n      refereeCount: user.refereeCount,\n      telegramUsername: user.telegramUsername,\n      telegramUserId: user.telegramUserId,\n    },\n    inboundReferral: {\n      referrerUserId: user.referrerUserId,\n      referrerCode: user.referrerCode,\n      linkedAt: user.linkedAt,\n    },\n    outboundReferees,\n    telegram: {\n      state: user.telegramLinkState,\n      telegramUserId: user.telegramUserId,\n      telegramUsername: user.telegramUsername,\n    },\n  };\n}\n","numLines":98,"startLine":1,"totalLines":98}}}
