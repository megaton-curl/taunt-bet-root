ed')),\n  open_price      BIGINT       NOT NULL,\n  open_price_expo INT          NOT NULL,\n  close_price     BIGINT,\n  outcome         TEXT         NOT NULL DEFAULT 'pending' CHECK (outcome IN ('pending', 'green', 'red', 'refund')),\n  green_pool      BIGINT       NOT NULL DEFAULT 0,\n  red_pool        BIGINT       NOT NULL DEFAULT 0,\n  total_fee       BIGINT       NOT NULL DEFAULT 0,\n  settle_tx       TEXT,\n  created_at      TIMESTAMPTZ  NOT NULL DEFAULT now(),\n  settled_at      TIMESTAMPTZ\n);\n\nCREATE INDEX idx_closecall_rounds_phase ON closecall_rounds (phase);\nCREATE INDEX idx_closecall_rounds_settled_at ON closecall_rounds (settled_at DESC);\nCREATE INDEX idx_cc_rounds_settled ON closecall_rounds (settled_at DESC) WHERE phase = 'settled';\n","numLines":23,"startLine":1,"totalLines":23}}}
