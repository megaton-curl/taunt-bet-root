{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A4M8wcCrT85uB11JY8ssKQ","type":"tool_result","content":"1\timport type { PeekSearchParams } from \"../../../lib/search-params\";\n2\timport type { PeekUserRow } from \"../../../lib/types/peek\";\n3\timport { getSqlClient } from \"../client\";\n4\t\n5\texport async function listPeekUsers(\n6\t  params: PeekSearchParams\n7\t): Promise<PeekUserRow[]> {\n8\t  const sql = getSqlClient();\n9\t  const search = `%${params.query}%`;\n10\t  const orderByColumn =\n11\t    params.sort === \"refereeCount\"\n12\t      ? sql.unsafe(`count(outbound.referee_user_id) ${params.direction}`)\n13\t      : sql.unsafe(`pp.created_at ${params.direction}`);\n14\t\n15\t  return sql<PeekUserRow[]>`\n16\t    select\n17\t      pp.user_id as \"userId\",\n18\t      pp.username as \"username\",\n19\t      pp.wallet as \"wallet\",\n20\t      pp.created_at::text as \"joinedAt\",\n21\t      rc.code as \"referralCode\",\n22\t      rl.referrer_user_id as \"referrerUserId\",\n23\t      ref_code.code as \"referrerCode\",\n24\t      count(outbound.referee_user_id)::int as \"refereeCount\",\n25\t      tla.telegram_username as \"telegramUsername\",\n26\t      tla.telegram_user_id as \"telegramUserId\"\n27\t    from player_profiles pp\n28\t    left join referral_codes rc on rc.user_id = pp.user_id\n29\t    left join referral_links rl on rl.referee_user_id = pp.user_id\n30\t    left join referral_codes ref_code on ref_code.user_id = rl.referrer_user_id\n31\t    left join referral_links outbound on outbound.referrer_user_id = pp.user_id\n32\t    left join lateral (\n33\t      select\n34\t        nullif(metadata_json->>'telegramUsername', '') as telegram_username,\n35\t        provider_account_id as telegram_user_id\n36\t      from linked_accounts\n37\t      where user_id = pp.user_id\n38\t        and provider = 'telegram'\n39\t        and status = 'active'\n40\t      limit 1\n41\t    ) tla on true\n42\t    where (\n43\t      ${params.query === \"\"}\n44\t      or pp.user_id ilike ${search}\n45\t      or pp.wallet ilike ${search}\n46\t      or coalesce(pp.username, '') ilike ${search}\n47\t      or coalesce(rc.code, '') ilike ${search}\n48\t    )\n49\t    and (${!params.filters.hasReferrer} or rl.referrer_user_id is not null)\n50\t    and (${!params.filters.hasReferees} or exists (\n51\t      select 1\n52\t      from referral_links outbound_exists\n53\t      where outbound_exists.referrer_user_id = pp.user_id\n54\t    ))\n55\t    and (${!params.filters.hasCode} or rc.code is not null)\n56\t    and (${!params.filters.hasTelegram} or tla.telegram_user_id is not null)\n57\t    group by\n58\t      pp.user_id,\n59\t      pp.username,\n60\t      pp.wallet,\n61\t      pp.created_at,\n62\t      rc.code,\n63\t      rl.referrer_user_id,\n64\t      ref_code.code,\n65\t      tla.telegram_username,\n66\t      tla.telegram_user_id\n67\t    order by ${orderByColumn}\n68\t    limit ${params.pageSize}\n69\t    offset ${(params.page - 1) * params.pageSize}\n70\t  `;\n71\t}\n72\t"}]},"parent_tool_use_id":null,"session_id":"ad5daed8-e332-4da3-beea-b105192abc37","uuid":"5307ce5b-2395-4ef2-b217-55998d068d14","timestamp":"2026-04-25T11:14:38.445Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/list-peek-users.ts","content":"import type { PeekSearchParams } from \"../../../lib/search-params\";\nimport type { PeekUserRow } from \"../../../lib/types/peek\";\nimport { getSqlClient } from \"../client\";\n\nexport async function listPeekUsers(\n  params: PeekSearchParams\n): Promise<PeekUserRow[]> {\n  const sql = getSqlClient();\n  const search = `%${params.query}%`;\n  const orderByColumn =\n    params.sort === \"refereeCount\"\n      ? sql.unsafe(`count(outbound.referee_user_id) ${params.direction}`)\n      : sql.unsafe(`pp.created_at ${params.direction}`);\n\n  return sql<PeekUserRow[]>`\n    select\n      pp.user_id as \"userId\",\n      pp.username as \"username\",\n      pp.wallet as \"wallet\",\n      pp.created_at::text as \"joinedAt\",\n      rc.code as \"referralCode\",\n      rl.referrer_user_id as \"referrerUserId\",\n      ref_code.code as \"referrerCode\",\n      count(outbound.referee_user_id)::int as \"refereeCount\",\n      tla.telegram_username as \"telegramUsername\",\n      tla.telegram_user_id as \"telegramUserId\"\n    from player_profiles pp\n    left join referral_codes rc on rc.user_id = pp.user_id\n    left join referral_links rl on rl.referee_user_id = pp.user_id\n    left join referral_codes ref_code on ref_code.user_id = rl.referrer_user_id\n    left join referral_links outbound on outbound.referrer_user_id = pp.user_id\n    left join lateral (\n      select\n        nullif(metadata_json->>'telegramUsername', '') as telegram_username,\n        provider_account_id as telegram_user_id\n      from linked_accounts\n      where user_id = pp.user_id\n        and provider = 'telegram'\n        and status = 'active'\n      limit 1\n    ) tla on true\n    where (\n      ${params.query === \"\"}\n      or pp.user_id ilike ${search}\n      or pp.wallet ilike ${search}\n      or coalesce(pp.username, '') ilike ${search}\n      or coalesce(rc.code, '') ilike ${search}\n    )\n    and (${!params.filters.hasReferrer} or rl.referrer_user_id is not null)\n    and (${!params.filters.hasReferees} or exists (\n      select 1\n      from referral_links outbound_exists\n      where outbound_exists.referrer_user_id = pp.user_id\n    ))\n    and (${!params.filters.hasCode} or rc.code is not null)\n    and (${!params.filters.hasTelegram} or tla.telegram_user_id is not null)\n    group by\n      pp.user_id,\n      pp.username,\n      pp.wallet,\n      pp.created_at,\n      rc.code,\n      rl.referrer_user_id,\n      ref_code.code,\n      tla.telegram_username,\n      tla.telegram_user_id\n    order by ${orderByColumn}\n    limit ${params.pageSize}\n    offset ${(params.page - 1) * params.pageSize}\n  `;\n}\n","numLines":72,"startLine":1,"totalLines":72}}}
