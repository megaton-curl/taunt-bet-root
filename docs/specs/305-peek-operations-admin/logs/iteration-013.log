{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01NBw6r5jfGzDYTCzT4om4eR","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Q2xGfD2yhCc45UFWHaEns3","name":"Edit","input":{"replace_all":false,"file_path":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","old_string":"// --- Audit event contracts (FR-11) -------------------------------------------","new_string":"// --- Command-center attention queue (FR-3, FR-10) ----------------------------\n//\n// The command-center page surfaces a small set of \"needs attention\" metrics so\n// operators see exception states (failed claims, dead queue events, stuck\n// settlements, pending SOL crate payouts, stale active Dogpile events,\n// high-value export activity) before they dig into per-feature pages. Each\n// item is a `PeekMetric` so the metric-strip primitive renders it with the\n// FR-4 bookkeeping (definition, source, time window, \"as of\", drill-down).\n\nexport type PeekCommandCenterAttentionId =\n  | \"failed_claims\"\n  | \"dead_queue_events\"\n  | \"stuck_rounds_flipyou_potshot\"\n  | \"stuck_rounds_closecall\"\n  | \"pending_sol_crate_payouts\"\n  | \"stale_active_dogpile_events\"\n  | \"high_value_exports_24h\";\n\nexport type PeekCommandCenterAttention = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};\n\n// --- Audit event contracts (FR-11) -------------------------------------------"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2888,"cache_read_input_tokens":106865,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2888},"output_tokens":40,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"ad5daed8-e332-4da3-beea-b105192abc37","uuid":"5c310f9d-e8ea-4bc9-89a0-e6268bfb5119"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q2xGfD2yhCc45UFWHaEns3","type":"tool_result","content":"The file /workspaces/rng-utopia/peek/src/lib/types/peek.ts has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"ad5daed8-e332-4da3-beea-b105192abc37","uuid":"10beb250-924b-41e0-88bf-05aa67463d2d","timestamp":"2026-04-25T11:16:19.118Z","tool_use_result":{"filePath":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","oldString":"// --- Audit event contracts (FR-11) -------------------------------------------","newString":"// --- Command-center attention queue (FR-3, FR-10) ----------------------------\n//\n// The command-center page surfaces a small set of \"needs attention\" metrics so\n// operators see exception states (failed claims, dead queue events, stuck\n// settlements, pending SOL crate payouts, stale active Dogpile events,\n// high-value export activity) before they dig into per-feature pages. Each\n// item is a `PeekMetric` so the metric-strip primitive renders it with the\n// FR-4 bookkeeping (definition, source, time window, \"as of\", drill-down).\n\nexport type PeekCommandCenterAttentionId =\n  | \"failed_claims\"\n  | \"dead_queue_events\"\n  | \"stuck_rounds_flipyou_potshot\"\n  | \"stuck_rounds_closecall\"\n  | \"pending_sol_crate_payouts\"\n  | \"stale_active_dogpile_events\"\n  | \"high_value_exports_24h\";\n\nexport type PeekCommandCenterAttention = {\n  generatedAt: string;\n  metrics: ReadonlyArray<PeekMetric>;\n};\n\n// --- Audit event contracts (FR-11) -------------------------------------------","originalFile":"// Browser-safe view-model primitives for `peek`.\n//\n// Foundational shapes used across feature pages: metric metadata (FR-4),\n// URL-addressable table filters, pagination, sort, and a small table-row base\n// type that per-feature row types can extend. Per-feature shapes (PeekUserRow,\n// PeekUserDetail, future referral/game/queue/etc. rows) live alongside or\n// extend these primitives.\n\nimport type { PeekRole } from \"../access-policy\";\n\n// --- Existing 303-era shapes (kept stable for current callers) ---------------\n\nexport type PeekSummary = {\n  totalUsers: number;\n  totalUsersWithCodes: number;\n  totalReferredUsers: number;\n  totalUniqueReferrers: number;\n};\n\nexport type PeekUserRow = {\n  userId: string;\n  username: string | null;\n  wallet: string;\n  joinedAt: string;\n  referralCode: string | null;\n  referrerUserId: string | null;\n  referrerCode: string | null;\n  refereeCount: number;\n  telegramUsername: string | null;\n  telegramUserId: string | null;\n};\n\nexport type PeekUserDetail = {\n  user: PeekUserRow;\n  inboundReferral: {\n    referrerUserId: string | null;\n    referrerCode: string | null;\n    linkedAt: string | null;\n  };\n  outboundReferees: Array<{\n    refereeUserId: string;\n    refereeUsername: string | null;\n    createdAt: string;\n  }>;\n  telegram: {\n    state: \"active\" | \"none\";\n    telegramUserId: string | null;\n    telegramUsername: string | null;\n  };\n};\n\n// --- Actor view model (browser-safe) -----------------------------------------\n\nexport type PeekActorView = {\n  email: string;\n  role: PeekRole;\n};\n\n// --- Metric metadata (FR-4) --------------------------------------------------\n//\n// Each metric carries the bookkeeping required by the data-surfacing standard:\n// stable id, label, value, source table/query, time window, \"as of\" timestamp,\n// short definition, optional unit, and optional drill-down link to the filtered\n// detail rows behind the number.\n\nexport type PeekMetricFreshness = \"live\" | \"cached\" | \"manual\" | \"sampled\";\n\nexport type PeekMetric = {\n  id: string;\n  label: string;\n  value: number | string | null;\n  valueDisplay: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  asOf: string | null;\n  definition: string;\n  freshness: PeekMetricFreshness;\n  drilldownHref: string | null;\n};\n\n// --- Pagination primitive ----------------------------------------------------\n\nexport type PeekPagination = {\n  page: number;\n  pageSize: number;\n  totalCount: number;\n  totalPages: number;\n};\n\n// --- Sort primitive ----------------------------------------------------------\n\nexport type PeekSortDirection = \"asc\" | \"desc\";\n\nexport type PeekTableSort = {\n  column: string;\n  direction: PeekSortDirection;\n};\n\n// --- Table filter primitive (URL-addressable) --------------------------------\n\nexport type PeekFilterKind =\n  | \"text\"\n  | \"select\"\n  | \"boolean\"\n  | \"date\"\n  | \"dateRange\";\n\nexport type PeekFilterOption = {\n  value: string;\n  label: string;\n};\n\nexport type PeekTableFilter = {\n  id: string;\n  label: string;\n  kind: PeekFilterKind;\n  value: string | null;\n  options: ReadonlyArray<PeekFilterOption> | null;\n  placeholder: string | null;\n  required: boolean;\n};\n\n// --- Status chip tone (shared) -----------------------------------------------\n\nexport type PeekStatusTone =\n  | \"neutral\"\n  | \"positive\"\n  | \"warning\"\n  | \"negative\"\n  | \"info\";\n\n// --- Empty-state primitive ---------------------------------------------------\n\nexport type PeekEmptyState = {\n  title: string;\n  body: string | null;\n};\n\n// --- Table row + column primitives -------------------------------------------\n//\n// Per-feature row types extend `PeekTableRowBase` for the shared identifier +\n// optional drill-down link, then add feature-specific fields. The shared dense\n// table component reads `columns` for layout and per-row data via the typed\n// row shape supplied by the feature page.\n\nexport type PeekTableColumnAlign = \"left\" | \"right\" | \"center\";\n\nexport type PeekTableColumn = {\n  id: string;\n  label: string;\n  align: PeekTableColumnAlign;\n  sortable: boolean;\n};\n\nexport type PeekTableRowBase = {\n  id: string;\n  href: string | null;\n};\n\nexport type PeekTableViewModel<TRow extends PeekTableRowBase> = {\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<TRow>;\n  pagination: PeekPagination;\n  filters: ReadonlyArray<PeekTableFilter>;\n  sort: PeekTableSort | null;\n  empty: PeekEmptyState;\n};\n\n// --- Audit event contracts (FR-11) -------------------------------------------\n//\n// Browser-safe view of `operator_events` rows the audit writer produces under\n// `peek.*` event types. The `PeekAuditPayload` shape pins the fields required by\n// FR-11 so the writer (`peek/src/server/audit/**`, next iteration) and the audit\n// view (`/audit`, later iteration) agree on a serialization contract. Secrets\n// (JWTs, access tokens, DB URLs, private keys, raw secrets) must be replaced by\n// `PEEK_AUDIT_REDACTED` before persisting; the audit-view component renders the\n// token verbatim so reviewers can see that a field was redacted (not silently\n// absent).\n\nexport type PeekAuditEventType =\n  | \"peek.search\"\n  | \"peek.user.view_sensitive\"\n  | \"peek.export\"\n  | \"peek.access.denied\"\n  | \"peek.change.applied\"\n  | \"peek.change.rejected\";\n\nexport const PEEK_AUDIT_EVENT_TYPES: ReadonlyArray<PeekAuditEventType> = [\n  \"peek.search\",\n  \"peek.user.view_sensitive\",\n  \"peek.export\",\n  \"peek.access.denied\",\n  \"peek.change.applied\",\n  \"peek.change.rejected\",\n];\n\nexport function isPeekAuditEventType(\n  value: unknown,\n): value is PeekAuditEventType {\n  return (\n    typeof value === \"string\" &&\n    (PEEK_AUDIT_EVENT_TYPES as ReadonlyArray<string>).includes(value)\n  );\n}\n\nexport const PEEK_AUDIT_REDACTED = \"[REDACTED]\";\n\nexport type PeekAuditScalar = string | number | boolean | null;\n\nexport type PeekAuditChange = {\n  field: string;\n  before: PeekAuditScalar;\n  after: PeekAuditScalar;\n};\n\nexport type PeekAuditPayload = {\n  actorEmail: string;\n  route: string | null;\n  actionId: string | null;\n  resourceType: string | null;\n  resourceId: string | null;\n  filterSummary: string | null;\n  resultCount: number | null;\n  requestId: string | null;\n  rejectionReason: string | null;\n  changes: ReadonlyArray<PeekAuditChange> | null;\n};\n\nexport type PeekAuditEvent = {\n  id: string;\n  eventType: PeekAuditEventType;\n  createdAt: string;\n  payload: PeekAuditPayload;\n};\n\n// --- Export contracts (FR-12) ------------------------------------------------\n//\n// Exports are server-rendered CSVs gated by the same page-level access as the\n// source page, bounded by a server-side row cap, named with a deterministic\n// `entity-date-filter` slug, and emit a `peek.export` audit event before the\n// bytes return. Export rows reuse the table view-model column ids so the export\n// shape stays in lockstep with the rendered table; values are pre-formatted\n// strings so CSV serialization stays straightforward and locale-stable.\n\nexport const PEEK_EXPORT_ROW_CAP_DEFAULT = 5000;\n\nexport type PeekExportEntity =\n  | \"users\"\n  | \"referrers\"\n  | \"kol\"\n  | \"claims\"\n  | \"rounds\"\n  | \"transactions\"\n  | \"queue\"\n  | \"audit\";\n\nexport type PeekExportRow = Record<string, string>;\n\nexport type PeekExportFilenameInput = {\n  entity: PeekExportEntity;\n  date: string;\n  filterSlug: string;\n};\n\nexport type PeekExportResult = {\n  filename: string;\n  rowCount: number;\n  rowCap: number;\n  rowCapApplied: boolean;\n  columns: ReadonlyArray<PeekTableColumn>;\n  rows: ReadonlyArray<PeekExportRow>;\n};\n","structuredPatch":[{"oldStart":167,"oldLines":6,"newStart":167,"newLines":29,"lines":["   empty: PeekEmptyState;"," };"," ","+// --- Command-center attention queue (FR-3, FR-10) ----------------------------","+//","+// The command-center page surfaces a small set of \"needs attention\" metrics so","+// operators see exception states (failed claims, dead queue events, stuck","+// settlements, pending SOL crate payouts, stale active Dogpile events,","+// high-value export activity) before they dig into per-feature pages. Each","+// item is a `PeekMetric` so the metric-strip primitive renders it with the","+// FR-4 bookkeeping (definition, source, time window, \"as of\", drill-down).","+","+export type PeekCommandCenterAttentionId =","+  | \"failed_claims\"","+  | \"dead_queue_events\"","+  | \"stuck_rounds_flipyou_potshot\"","+  | \"stuck_rounds_closecall\"","+  | \"pending_sol_crate_payouts\"","+  | \"stale_active_dogpile_events\"","+  | \"high_value_exports_24h\";","+","+export type PeekCommandCenterAttention = {","+  generatedAt: string;","+  metrics: ReadonlyArray<PeekMetric>;","+};","+"," // --- Audit event contracts (FR-11) -------------------------------------------"," //"," // Browser-safe view of `operator_events` rows the audit writer produces under"]}],"userModified":false,"replaceAll":false}}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01NMksNRMPgjkcjk6X2zGs2c","type":"message","role":"assistant","content":[{"type":"text","text":"Now create the query module."}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2150,"cache_read_input_tokens":109753,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2150},"output_tokens":7,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"ad5daed8-e332-4da3-beea-b105192abc37","uuid":"d9c147fe-e461-4132-83b0-dbdbc49894b6"}
{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01NMksNRMPgjkcjk6X2zGs2c","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01QrnJQ2Z275QcEuXc1gEaA5","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/src/server/db/queries/get-command-center-attention.ts","content":"// Command-center attention queue query (FR-3, FR-10).\n//\n// Returns a small set of bounded \"needs attention\" metrics that the command\n// center renders at the top of `/`. Each metric carries the FR-4 bookkeeping\n// (id, label, value, source table, time window, \"as of\", definition,\n// freshness, drill-down href) so the metric-strip primitive can render it\n// without per-page hardcoding.\n//\n// Bounded queries: every query returns a single integer count. No row-level\n// data crosses the wire here; per-feature pages provide the row drill-downs.\n\nimport type {\n  PeekCommandCenterAttention,\n  PeekCommandCenterAttentionId,\n  PeekMetric,\n} from \"../../../lib/types/peek\";\nimport type { Sql } from \"postgres\";\nimport { getSqlClient } from \"../client\";\n\n// Thresholds — tuned for an operator console, not a fairness oracle. Tests can\n// override via the `options` argument so age/limit assertions stay\n// deterministic.\nexport const COMMAND_CENTER_DEFAULTS = {\n  stuckRoundsAgeMinutes: 5,\n  stuckRoundsMaxSettleAttempts: 3,\n  stuckCloseCallAgeMinutes: 5,\n  exportWindowHours: 24,\n  exportRowCountThreshold: 1000,\n} as const;\n\nexport type CommandCenterThresholds = typeof COMMAND_CENTER_DEFAULTS;\n\nexport type CommandCenterOptions = {\n  sql?: Sql;\n  thresholds?: Partial<CommandCenterThresholds>;\n  now?: Date;\n};\n\ntype AttentionRow = { value: number };\n\nfunction readCount(rows: ReadonlyArray<AttentionRow> | undefined): number {\n  if (!rows || rows.length === 0) {\n    return 0;\n  }\n  const raw = rows[0]?.value;\n  if (typeof raw === \"number\" && Number.isFinite(raw)) {\n    return raw;\n  }\n  if (typeof raw === \"string\") {\n    const parsed = Number.parseInt(raw, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\ntype MetricBlueprint = {\n  id: PeekCommandCenterAttentionId;\n  label: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  definition: string;\n  drilldownHref: string | null;\n};\n\nfunction makeMetric(\n  blueprint: MetricBlueprint,\n  count: number,\n  asOf: string,\n): PeekMetric {\n  return {\n    id: blueprint.id,\n    label: blueprint.label,\n    value: count,\n    valueDisplay: formatCount(count),\n    unit: blueprint.unit,\n    source: blueprint.source,\n    windowLabel: blueprint.windowLabel,\n    asOf,\n    definition: blueprint.definition,\n    freshness: \"live\",\n    drilldownHref: blueprint.drilldownHref,\n  };\n}\n\nexport async function getCommandCenterAttention(\n  options: CommandCenterOptions = {},\n): Promise<PeekCommandCenterAttention> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const thresholds: CommandCenterThresholds = {\n    ...COMMAND_CENTER_DEFAULTS,\n    ...options.thresholds,\n  };\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n\n  const stuckRoundsAgeInterval = `${thresholds.stuckRoundsAgeMinutes} minutes`;\n  const stuckCloseCallAgeInterval = `${thresholds.stuckCloseCallAgeMinutes} minutes`;\n  const exportWindowInterval = `${thresholds.exportWindowHours} hours`;\n\n  const [\n    failedClaimsRows,\n    deadQueueEventsRows,\n    stuckRoundsRows,\n    stuckCloseCallRows,\n    pendingSolCrateRows,\n    staleActiveDogpileRows,\n    highValueExportsRows,\n  ] = await Promise.all([\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from referral_claims\n      where status in ('failed', 'error')\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from event_queue\n      where status = 'dead'\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from rounds\n      where phase in ('created', 'locked', 'settling')\n        and (\n          created_at < now() - ${stuckRoundsAgeInterval}::interval\n          or settle_attempts > ${thresholds.stuckRoundsMaxSettleAttempts}\n        )\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from closecall_rounds\n      where phase = 'open'\n        and created_at < now() - ${stuckCloseCallAgeInterval}::interval\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from crate_drops\n      where crate_type = 'sol'\n        and status = 'pending'\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from dogpile_events\n      where status = 'active'\n        and ends_at < now()\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from operator_events\n      where event_type = 'peek.export'\n        and created_at > now() - ${exportWindowInterval}::interval\n        and coalesce((payload->>'resultCount')::int, 0)\n            > ${thresholds.exportRowCountThreshold}\n    `,\n  ]);\n\n  const blueprints: ReadonlyArray<{\n    blueprint: MetricBlueprint;\n    rows: ReadonlyArray<AttentionRow>;\n  }> = [\n    {\n      blueprint: {\n        id: \"failed_claims\",\n        label: \"Failed referral claims\",\n        unit: \"claims\",\n        source: \"referral_claims\",\n        windowLabel: \"All time\",\n        definition:\n          \"Referral claims with status 'failed' or 'error' that have not been recovered.\",\n        drilldownHref: \"/growth/referrals?claimStatus=failed\",\n      },\n      rows: failedClaimsRows,\n    },\n    {\n      blueprint: {\n        id: \"dead_queue_events\",\n        label: \"Dead queue events\",\n        unit: \"events\",\n        source: \"event_queue\",\n        windowLabel: \"All time\",\n        definition:\n          \"Event-queue rows in 'dead' status — past max attempts and not retried.\",\n        drilldownHref: \"/operations/queue?status=dead\",\n      },\n      rows: deadQueueEventsRows,\n    },\n    {\n      blueprint: {\n        id: \"stuck_rounds_flipyou_potshot\",\n        label: \"Stuck Flip You / Pot Shot rounds\",\n        unit: \"rounds\",\n        source: \"rounds\",\n        windowLabel: `Older than ${thresholds.stuckRoundsAgeMinutes}m or settle_attempts > ${thresholds.stuckRoundsMaxSettleAttempts}`,\n        definition:\n          \"Rounds in nonterminal phases (created/locked/settling) past the age threshold or with elevated settle attempts.\",\n        drilldownHref: \"/games?stuck=true\",\n      },\n      rows: stuckRoundsRows,\n    },\n    {\n      blueprint: {\n        id: \"stuck_rounds_closecall\",\n        label: \"Stuck Close Call rounds\",\n        unit: \"rounds\",\n        source: \"closecall_rounds\",\n        windowLabel: `Open phase older than ${thresholds.stuckCloseCallAgeMinutes}m`,\n        definition:\n          \"Close Call rounds still in 'open' phase past the age threshold; rounds settle on minute boundaries via Pyth.\",\n        drilldownHref: \"/games/closecall?stuck=true\",\n      },\n      rows: stuckCloseCallRows,\n    },\n    {\n      blueprint: {\n        id: \"pending_sol_crate_payouts\",\n        label: \"Pending SOL crate payouts\",\n        unit: \"crates\",\n        source: \"crate_drops\",\n        windowLabel: \"All time\",\n        definition:\n          \"SOL-denominated crate drops in 'pending' status — payout has not been delivered on-chain.\",\n        drilldownHref: \"/economy/rewards?crateType=sol&status=pending\",\n      },\n      rows: pendingSolCrateRows,\n    },\n    {\n      blueprint: {\n        id: \"stale_active_dogpile_events\",\n        label: \"Stale active Dogpile events\",\n        unit: \"events\",\n        source: \"dogpile_events\",\n        windowLabel: \"Active past end time\",\n        definition:\n          \"Dogpile events still in 'active' status whose ends_at has already passed; they should have transitioned to 'ended'.\",\n        drilldownHref: \"/operations/dogpile?status=active\",\n      },\n      rows: staleActiveDogpileRows,\n    },\n    {\n      blueprint: {\n        id: \"high_value_exports_24h\",\n        label: \"High-value exports (24h)\",\n        unit: \"exports\",\n        source: \"operator_events\",\n        windowLabel: `Last ${thresholds.exportWindowHours}h`,\n        definition: `peek.export operator events in the last ${thresholds.exportWindowHours}h whose resultCount exceeds ${thresholds.exportRowCountThreshold} rows.`,\n        drilldownHref: \"/audit?eventType=peek.export\",\n      },\n      rows: highValueExportsRows,\n    },\n  ];\n\n  const metrics: PeekMetric[] = blueprints.map(({ blueprint, rows }) =>\n    makeMetric(blueprint, readCount(rows), generatedAt),\n  );\n\n  return {\n    generatedAt,\n    metrics,\n  };\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2150,"cache_read_input_tokens":109753,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2150},"output_tokens":7,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"ad5daed8-e332-4da3-beea-b105192abc37","uuid":"1ed5e491-f8ca-485e-b4d5-3c08791166fa"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QrnJQ2Z275QcEuXc1gEaA5","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/src/server/db/queries/get-command-center-attention.ts"}]},"parent_tool_use_id":null,"session_id":"ad5daed8-e332-4da3-beea-b105192abc37","uuid":"59de3d57-1266-4cd9-8d5d-f007847fb93b","timestamp":"2026-04-25T11:16:53.514Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/src/server/db/queries/get-command-center-attention.ts","content":"// Command-center attention queue query (FR-3, FR-10).\n//\n// Returns a small set of bounded \"needs attention\" metrics that the command\n// center renders at the top of `/`. Each metric carries the FR-4 bookkeeping\n// (id, label, value, source table, time window, \"as of\", definition,\n// freshness, drill-down href) so the metric-strip primitive can render it\n// without per-page hardcoding.\n//\n// Bounded queries: every query returns a single integer count. No row-level\n// data crosses the wire here; per-feature pages provide the row drill-downs.\n\nimport type {\n  PeekCommandCenterAttention,\n  PeekCommandCenterAttentionId,\n  PeekMetric,\n} from \"../../../lib/types/peek\";\nimport type { Sql } from \"postgres\";\nimport { getSqlClient } from \"../client\";\n\n// Thresholds — tuned for an operator console, not a fairness oracle. Tests can\n// override via the `options` argument so age/limit assertions stay\n// deterministic.\nexport const COMMAND_CENTER_DEFAULTS = {\n  stuckRoundsAgeMinutes: 5,\n  stuckRoundsMaxSettleAttempts: 3,\n  stuckCloseCallAgeMinutes: 5,\n  exportWindowHours: 24,\n  exportRowCountThreshold: 1000,\n} as const;\n\nexport type CommandCenterThresholds = typeof COMMAND_CENTER_DEFAULTS;\n\nexport type CommandCenterOptions = {\n  sql?: Sql;\n  thresholds?: Partial<CommandCenterThresholds>;\n  now?: Date;\n};\n\ntype AttentionRow = { value: number };\n\nfunction readCount(rows: ReadonlyArray<AttentionRow> | undefined): number {\n  if (!rows || rows.length === 0) {\n    return 0;\n  }\n  const raw = rows[0]?.value;\n  if (typeof raw === \"number\" && Number.isFinite(raw)) {\n    return raw;\n  }\n  if (typeof raw === \"string\") {\n    const parsed = Number.parseInt(raw, 10);\n    return Number.isFinite(parsed) ? parsed : 0;\n  }\n  return 0;\n}\n\nfunction formatCount(count: number): string {\n  return count.toLocaleString(\"en-US\");\n}\n\ntype MetricBlueprint = {\n  id: PeekCommandCenterAttentionId;\n  label: string;\n  unit: string | null;\n  source: string;\n  windowLabel: string;\n  definition: string;\n  drilldownHref: string | null;\n};\n\nfunction makeMetric(\n  blueprint: MetricBlueprint,\n  count: number,\n  asOf: string,\n): PeekMetric {\n  return {\n    id: blueprint.id,\n    label: blueprint.label,\n    value: count,\n    valueDisplay: formatCount(count),\n    unit: blueprint.unit,\n    source: blueprint.source,\n    windowLabel: blueprint.windowLabel,\n    asOf,\n    definition: blueprint.definition,\n    freshness: \"live\",\n    drilldownHref: blueprint.drilldownHref,\n  };\n}\n\nexport async function getCommandCenterAttention(\n  options: CommandCenterOptions = {},\n): Promise<PeekCommandCenterAttention> {\n  const sql = options.sql ?? (getSqlClient() as unknown as Sql);\n  const thresholds: CommandCenterThresholds = {\n    ...COMMAND_CENTER_DEFAULTS,\n    ...options.thresholds,\n  };\n  const now = options.now ?? new Date();\n  const generatedAt = now.toISOString();\n\n  const stuckRoundsAgeInterval = `${thresholds.stuckRoundsAgeMinutes} minutes`;\n  const stuckCloseCallAgeInterval = `${thresholds.stuckCloseCallAgeMinutes} minutes`;\n  const exportWindowInterval = `${thresholds.exportWindowHours} hours`;\n\n  const [\n    failedClaimsRows,\n    deadQueueEventsRows,\n    stuckRoundsRows,\n    stuckCloseCallRows,\n    pendingSolCrateRows,\n    staleActiveDogpileRows,\n    highValueExportsRows,\n  ] = await Promise.all([\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from referral_claims\n      where status in ('failed', 'error')\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from event_queue\n      where status = 'dead'\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from rounds\n      where phase in ('created', 'locked', 'settling')\n        and (\n          created_at < now() - ${stuckRoundsAgeInterval}::interval\n          or settle_attempts > ${thresholds.stuckRoundsMaxSettleAttempts}\n        )\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from closecall_rounds\n      where phase = 'open'\n        and created_at < now() - ${stuckCloseCallAgeInterval}::interval\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from crate_drops\n      where crate_type = 'sol'\n        and status = 'pending'\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from dogpile_events\n      where status = 'active'\n        and ends_at < now()\n    `,\n    sql<AttentionRow[]>`\n      select count(*)::int as \"value\"\n      from operator_events\n      where event_type = 'peek.export'\n        and created_at > now() - ${exportWindowInterval}::interval\n        and coalesce((payload->>'resultCount')::int, 0)\n            > ${thresholds.exportRowCountThreshold}\n    `,\n  ]);\n\n  const blueprints: ReadonlyArray<{\n    blueprint: MetricBlueprint;\n    rows: ReadonlyArray<AttentionRow>;\n  }> = [\n    {\n      blueprint: {\n        id: \"failed_claims\",\n        label: \"Failed referral claims\",\n        unit: \"claims\",\n        source: \"referral_claims\",\n        windowLabel: \"All time\",\n        definition:\n          \"Referral claims with status 'failed' or 'error' that have not been recovered.\",\n        drilldownHref: \"/growth/referrals?claimStatus=failed\",\n      },\n      rows: failedClaimsRows,\n    },\n    {\n      blueprint: {\n        id: \"dead_queue_events\",\n        label: \"Dead queue events\",\n        unit: \"events\",\n        source: \"event_queue\",\n        windowLabel: \"All time\",\n        definition:\n          \"Event-queue rows in 'dead' status — past max attempts and not retried.\",\n        drilldownHref: \"/operations/queue?status=dead\",\n      },\n      rows: deadQueueEventsRows,\n    },\n    {\n      blueprint: {\n        id: \"stuck_rounds_flipyou_potshot\",\n        label: \"Stuck Flip You / Pot Shot rounds\",\n        unit: \"rounds\",\n        source: \"rounds\",\n        windowLabel: `Older than ${thresholds.stuckRoundsAgeMinutes}m or settle_attempts > ${thresholds.stuckRoundsMaxSettleAttempts}`,\n        definition:\n          \"Rounds in nonterminal phases (created/locked/settling) past the age threshold or with elevated settle attempts.\",\n        drilldownHref: \"/games?stuck=true\",\n      },\n      rows: stuckRoundsRows,\n    },\n    {\n      blueprint: {\n        id: \"stuck_rounds_closecall\",\n        label: \"Stuck Close Call rounds\",\n        unit: \"rounds\",\n        source: \"closecall_rounds\",\n        windowLabel: `Open phase older than ${thresholds.stuckCloseCallAgeMinutes}m`,\n        definition:\n          \"Close Call rounds still in 'open' phase past the age threshold; rounds settle on minute boundaries via Pyth.\",\n        drilldownHref: \"/games/closecall?stuck=true\",\n      },\n      rows: stuckCloseCallRows,\n    },\n    {\n      blueprint: {\n        id: \"pending_sol_crate_payouts\",\n        label: \"Pending SOL crate payouts\",\n        unit: \"crates\",\n        source: \"crate_drops\",\n        windowLabel: \"All time\",\n        definition:\n          \"SOL-denominated crate drops in 'pending' status — payout has not been delivered on-chain.\",\n        drilldownHref: \"/economy/rewards?crateType=sol&status=pending\",\n      },\n      rows: pendingSolCrateRows,\n    },\n    {\n      blueprint: {\n        id: \"stale_active_dogpile_events\",\n        label: \"Stale active Dogpile events\",\n        unit: \"events\",\n        source: \"dogpile_events\",\n        windowLabel: \"Active past end time\",\n        definition:\n          \"Dogpile events still in 'active' status whose ends_at has already passed; they should have transitioned to 'ended'.\",\n        drilldownHref: \"/operations/dogpile?status=active\",\n      },\n      rows: staleActiveDogpileRows,\n    },\n    {\n      blueprint: {\n        id: \"high_value_exports_24h\",\n        label: \"High-value exports (24h)\",\n        unit: \"exports\",\n        source: \"operator_events\",\n        windowLabel: `Last ${thresholds.exportWindowHours}h`,\n        definition: `peek.export operator events in the last ${thresholds.exportWindowHours}h whose resultCount exceeds ${thresholds.exportRowCountThreshold} rows.`,\n        drilldownHref: \"/audit?eventType=peek.export\",\n      },\n      rows: highValueExportsRows,\n    },\n  ];\n\n  const metrics: PeekMetric[] = blueprints.map(({ blueprint, rows }) =>\n    makeMetric(blueprint, readCount(rows), generatedAt),\n  );\n\n  return {\n    generatedAt,\n    metrics,\n  };\n}\n","structuredPatch":[],"originalFile":null,"userModified":false}}
