{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vs3k1MW2g3TdrBY6DxK6d3","type":"tool_result","content":"1\t-- 009_event_queue.sql — Postgres-backed async event queue.\n2\t--\n3\t-- Decouples settlement hot path from secondary side-effects (reward delivery,\n4\t-- notifications, analytics). Worker polls with SKIP LOCKED for safe concurrency.\n5\t\n6\tCREATE TABLE event_queue (\n7\t  id            BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n8\t  event_type    TEXT         NOT NULL,\n9\t  payload       JSONB        NOT NULL,\n10\t  status        TEXT         NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'completed', 'failed', 'dead')),\n11\t  attempts      INTEGER      NOT NULL DEFAULT 0,\n12\t  max_attempts  INTEGER      NOT NULL DEFAULT 3,\n13\t  scheduled_at  TIMESTAMPTZ  NOT NULL DEFAULT now(),\n14\t  started_at    TIMESTAMPTZ,\n15\t  completed_at  TIMESTAMPTZ,\n16\t  error         TEXT,\n17\t  created_at    TIMESTAMPTZ  NOT NULL DEFAULT now()\n18\t);\n19\t\n20\tCREATE INDEX idx_event_queue_poll ON event_queue (scheduled_at) WHERE status = 'pending';\n21\tCREATE INDEX idx_event_queue_status ON event_queue (status, created_at);\n22\t"}]},"parent_tool_use_id":null,"session_id":"ad5daed8-e332-4da3-beea-b105192abc37","uuid":"7951b676-8fd2-411b-8933-baec4334dd0d","timestamp":"2026-04-25T11:14:49.854Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/backend/migrations/009_event_queue.sql","content":"-- 009_event_queue.sql — Postgres-backed async event queue.\n--\n-- Decouples settlement hot path from secondary side-effects (reward delivery,\n-- notifications, analytics). Worker polls with SKIP LOCKED for safe concurrency.\n\nCREATE TABLE event_queue (\n  id            BIGINT GENERATED ALWAYS AS IDENTITY PRIMARY KEY,\n  event_type    TEXT         NOT NULL,\n  payload       JSONB        NOT NULL,\n  status        TEXT         NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'processing', 'completed', 'failed', 'dead')),\n  attempts      INTEGER      NOT NULL DEFAULT 0,\n  max_attempts  INTEGER      NOT NULL DEFAULT 3,\n  scheduled_at  TIMESTAMPTZ  NOT NULL DEFAULT now(),\n  started_at    TIMESTAMPTZ,\n  completed_at  TIMESTAMPTZ,\n  error         TEXT,\n  created_at    TIMESTAMPTZ  NOT NULL DEFAULT now()\n);\n\nCREATE INDEX idx_event_queue_poll ON event_queue (scheduled_at) WHERE status = 'pending';\nCREATE INDEX idx_event_queue_status ON event_queue (status, created_at);\n","numLines":22,"startLine":1,"totalLines":22}}}
