le}>{emptyTitle}</p>\n        {emptyBody ? <p style={emptyBodyStyle}>{emptyBody}</p> : null}\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <nav aria-label={ariaLabel} style={navStyle}>\n        <ul style={listStyle}>\n          {sections.map((section) => {\n            const isActive = activeId === section.id;\n            return (\n              <li key={section.id}>\n                <a\n                  href={`#${section.id}`}\n                  aria-current={isActive ? \"true\" : undefined}\n                  style={isActive ? activeLinkStyle : linkStyle}\n                >\n                  {section.label}\n                </a>\n              </li>\n            );\n          })}\n        </ul>\n      </nav>\n      <div style={sectionsStyle}>\n        {sections.map((section) => (\n          <section\n            key={section.id}\n            id={section.id}\n            aria-labelledby={`peek-section-${section.id}-label`}\n            style={sectionStyle}\n          >\n            <h2 id={`peek-section-${section.id}-label`} style={sectionHeadingStyle}>\n              {section.label}\n            </h2>\n            <div>{section.body}</div>\n          </section>\n        ))}\n      </div>\n    </div>\n  );\n}\n\nconst wrapperStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1rem\",\n};\n\nconst navStyle: CSSProperties = {\n  position: \"sticky\",\n  top: 0,\n  background: \"#0b1220\",\n  paddingBlock: \"0.5rem\",\n};\n\nconst listStyle: CSSProperties = {\n  listStyle: \"none\",\n  margin: 0,\n  padding: 0,\n  display: \"flex\",\n  gap: \"0.5rem\",\n  flexWrap: \"wrap\",\n};\n\nconst linkStyle: CSSProperties = {\n  display: \"inline-flex\",\n  alignItems: \"center\",\n  fontSize: \"0.8125rem\",\n  textDecoration: \"none\",\n  color: \"#94a3b8\",\n  padding: \"0.375rem 0.75rem\",\n  borderRadius: \"9999px\",\n  border: \"1px solid #1e293b\",\n};\n\nconst activeLinkStyle: CSSProperties = {\n  ...linkStyle,\n  color: \"#eff6ff\",\n  background: \"#1d4ed8\",\n  borderColor: \"#1d4ed8\",\n};\n\nconst sectionsStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n  background: \"#111827\",\n  padding: \"1rem\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#e2e8f0\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n","numLines":171,"startLine":1,"totalLines":171}}}
