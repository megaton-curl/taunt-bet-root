adonlyArray<PeekGameOverviewRow> = [];\n50\t\n51\t  try {\n52\t    overview = await getGamesOverview();\n53\t    perGame = overview.perGame;\n54\t  } catch (error) {\n55\t    overviewError =\n56\t      error instanceof Error\n57\t        ? error.message\n58\t        : \"Games overview could not be loaded.\";\n59\t  }\n60\t\n61\t  return (\n62\t    <main style={mainStyle}>\n63\t      <header>\n64\t        <h1>Games</h1>\n65\t        <p style={leadStyle}>\n66\t          Cross-game activity from `game_entries` across FlipYou, Pot Shot, and\n67\t          Close Call. Deferred games appear as documented placeholders until\n68\t          their persisted data sources land.\n69\t        </p>\n70\t      </header>\n71\t\n72\t      <section aria-labelledby=\"overview-heading\">\n73\t        <h2 id=\"overview-heading\" style={sectionHeadingStyle}>\n74\t          Overview\n75\t        </h2>\n76\t        <MetricStrip metrics={overview.metrics} error={overviewError} />\n77\t      </section>\n78\t\n79\t      <section\n80\t        aria-labelledby=\"per-game-heading\"\n81\t        id=\"per-game\"\n82\t        style={sectionStyle}\n83\t      >\n84\t        <h2 id=\"per-game-heading\" style={sectionHeadingStyle}>\n85\t          Per-game activity\n86\t        </h2>\n87\t        <p style={hintStyle}>\n88\t          One row per active game · counters from `game_entries` · all-time.\n89\t        </p>\n90\t        <GamesOverviewTable rows={perGame} error={overviewError} />\n91\t      </section>\n92\t\n93\t      <section\n94\t        aria-labelledby=\"deferred-heading\"\n95\t        id=\"deferred\"\n96\t        style={sectionStyle}\n97\t      >\n98\t        <h2 id=\"deferred-heading\" style={sectionHeadingStyle}>\n99\t          Deferred games\n100\t        </h2>\n101\t        <p style={hintStyle}>\n102\t          Listed for visibility only; no persisted data source yet, so no\n103\t          counters are computed (System Invariant 13).\n104\t        </p>\n105\t        <ul style={deferredList