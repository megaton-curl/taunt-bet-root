{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Hmr8ARsr3sduF6uES9fKBo","type":"tool_result","content":"1\t// /games/[game] — per-game round audit (FR-8).\n2\t//\n3\t// Handles FlipYou + Pot Shot + Close Call through one [game] param. FlipYou +\n4\t// Pot Shot share the `rounds` table, so the page calls `listRounds({ game })`\n5\t// and renders the shared `GameRoundsTable`. Close Call has its own table and\n6\t// lifecycle (`open` -> `settled`/`refunded` plus a Pyth-driven outcome), so the\n7\t// page calls `listCloseCallRounds()` and renders `CloseCallRoundsTable`.\n8\t//\n9\t// Stuck-state filters cover the four FR-8 operational signals (nonterminal &\n10\t// aged, high settle attempts [FlipYou+Pot Shot only], settled without expected\n11\t// transaction, refunds). Filters are URL-addressable so an admin can share a\n12\t// link to the exact investigation state.\n13\timport { notFound } from \"next/navigation\";\n14\timport Link from \"next/link\";\n15\timport type { CSSProperties } from \"react\";\n16\timport { CloseCallRoundsTable } from \"../../../src/components/closecall-rounds-table\";\n17\timport { GameRoundsFilterBar } from \"../../../src/components/game-rounds-filter-bar\";\n18\timport { GameRoundsTable } from \"../../../src/components/game-rounds-table\";\n19\timport {\n20\t  buildRoundsQueryString,\n21\t  normalizeCloseCallRoundFiltersFromSearchParams,\n22\t  normalizeRoundFiltersFromSearchParams,\n23\t  readPageFromSearchParams,\n24\t} from \"../../../src/lib/games-search-params\";\n25\timport {\n26\t  PEEK_GAME_IDS,\n27\t  type PeekCloseCallRoundRow,\n28\t  type PeekGameId,\n29\t  type PeekRoundRow,\n30\t  type PeekRoundsListResult,\n31\t} from \"../../../src/lib/types/peek\";\n32\timport {\n33\t  getPeekActorContext,\n34\t  isRouteAllowedForRole,\n35\t} from \"../../../src/server/access-policy\";\n36\timport {\n37\t  listCloseCallRounds,\n38\t  listRounds,\n39\t  PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n40\t} from \"../../../src/server/db/queries/get-game-rounds\";\n41\t\n42\texport const dynamic = \"force-dynamic\";\n43\t\n44\tconst GAME_LABELS: Record<PeekGameId, string> = {\n45\t  flipyou: \"FlipYou\",\n46\t  potshot: \"Pot Shot\",\n47\t  closecall: \"Close Call\",\n48\t};\n49\t\n50\tfunction isPeekGameId(value: string): value is PeekGameId {\n51\t  return (PEEK_GAME_IDS as ReadonlyArray<string>).includes(value);\n52\t}\n53\t\n54\texport default async function GameRoundsPage({\n55\t  params,\n56\t  searchParams,\n57\t}: {\n58\t  params: Promise<{ game: string }>;\n59\t  searchParams: Promise<Record<string, string | string[] | undefined>>;\n60\t}) {\n61\t  const { game: gameParam } = await params;\n62\t  if (!isPeekGameId(gameParam)) {\n63\t    notFound();\n64\t  }\n65\t  const game = gameParam as PeekGameId;\n66\t  const route = `/games/${game}`;\n67\t\n68\t  const actor = await getPeekActorContext();\n69\t  const allowed = isRouteAllowedForRole(route, actor?.role ?? null);\n70\t\n71\t  if (!allowed) {\n72\t    return (\n73\t      <main style={mainStyle}>\n74\t        <header>\n75\t          <h1>Games · {GAME_LABELS[game]}</h1>\n76\t        </header>\n77\t        <p role=\"alert\" style={errorStyle}>\n78\t          You do not have access to this page.\n79\t        </p>\n80\t      </main>\n81\t    );\n82\t  }\n83\t\n84\t  const rawParams = await searchParams;\n85\t  const page = readPageFromSearchParams(rawParams);\n86\t\n87\t  return game === \"closecall\" ? (\n88\t    <CloseCallView\n89\t      route={route}\n90\t      label={GAME_LABELS[game]}\n91\t      page={page}\n92\t      rawParams={rawParams}\n93\t    />\n94\t  ) : (\n95\t    <RoundsView\n96\t      route={route}\n97\t      label={GAME_LABELS[game]}\n98\t      game={game}\n99\t      page={page}\n100\t      rawParams={rawParams}\n101\t    />\n102\t  );\n103\t}\n104\t\n105\tasync function RoundsView({\n106\t  route,\n107\t  label,\n108\t  game,\n109\t  page,\n110\t  rawParams,\n111\t}: {\n112\t  route: string;\n113\t  label: string;\n114\t  game: \"flipyou\" | \"potshot\";\n115\t  page: number;\n116\t  rawParams: Record<string, string | string[] | undefined>;\n117\t}) {\n118\t  const filters = normalizeRoundFiltersFromSearchParams(rawParams);\n119\t\n120\t  let result: PeekRoundsListResult<PeekRoundRow> = {\n121\t    rows: [],\n122\t    pagination: {\n123\t      page,\n124\t      pageSize: PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n125\t      totalCount: 0,\n126\t      totalPages: 1,\n127\t    },\n128\t  };\n129\t  let error: string | null = null;\n130\t\n131\t  try {\n132\t    result = await listRounds({ game, filters, page });\n133\t  } catch (err) {\n134\t    error =\n135\t      err instanceof Error ? err.message : \"Rounds could not be loaded.\";\n136\t  }\n137\t\n138\t  return (\n139\t    <main style={mainStyle}>\n140\t      <PageHeader route={route} label={label} />\n141\t      <SectionFilters>\n142\t        <GameRoundsFilterBar game={game} filters={filters} action={route} />\n143\t      </SectionFilters>\n144\t      <SectionTable\n145\t        rows={result.rows.length}\n146\t        total={result.pagination.totalCount}\n147\t        page={result.pagination.page}\n148\t        totalPages={result.pagination.totalPages}\n149\t        rawParams={rawParams}\n150\t        route={route}\n151\t      >\n152\t        <GameRoundsTable rows={result.rows} error={error} />\n153\t      </SectionTable>\n154\t    </main>\n155\t  );\n156\t}\n157\t\n158\tasync function CloseCallView({\n159\t  route,\n160\t  label,\n161\t  page,\n162\t  rawParams,\n163\t}: {\n164\t  route: string;\n165\t  label: string;\n166\t  page: number;\n167\t  rawParams: Record<string, string | string[] | undefined>;\n168\t}) {\n169\t  const filters = normalizeCloseCallRoundFiltersFromSearchParams(rawParams);\n170\t\n171\t  let result: PeekRoundsListResult<PeekCloseCallRoundRow> = {\n172\t    rows: [],\n173\t    pagination: {\n174\t      page,\n175\t      pageSize: PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n176\t      totalCount: 0,\n177\t      totalPages: 1,\n178\t    },\n179\t  };\n180\t  let error: string | null = null;\n181\t\n182\t  try {\n183\t    result = await listCloseCallRounds({ filters, page });\n184\t  } catch (err) {\n185\t    error =\n186\t      err instanceof Error ? err.message : \"Rounds could not be loaded.\";\n187\t  }\n188\t\n189\t  return (\n190\t    <main style={mainStyle}>\n191\t      <PageHeader route={route} label={label} />\n192\t      <SectionFilters>\n193\t        <GameRoundsFilterBar\n194\t          game=\"closecall\"\n195\t          filters={filters}\n196\t          action={route}\n197\t        />\n198\t      </SectionFilters>\n199\t      <SectionTable\n200\t        rows={result.rows.length}\n201\t        total={result.pagination.totalCount}\n202\t        page={result.pagination.page}\n203\t        totalPages={result.pagination.totalPages}\n204\t        rawParams={rawParams}\n205\t        route={route}\n206\t      >\n207\t        <CloseCallRoundsTable rows={result.rows} error={error} />\n208\t      </SectionTable>\n209\t    </main>\n210\t  );\n211\t}\n212\t\n213\tfunction PageHeader({ route, label }: { route: string; label: string }) {\n214\t  return (\n215\t    <header>\n216\t      <p style={breadcrumbStyle}>\n217\t        <Link href=\"/games\" style={breadcrumbLinkStyle}>\n218\t          ← Games\n219\t        </Link>\n220\t      </p>\n221\t      <h1>Games · {label}</h1>\n222\t      <p style={leadStyle}>\n223\t        Round-level audit for {label}. Filter by phase, search by pda/match\n224\t        id/creator, narrow by created date, or apply stuck-state filters to\n225\t        find rounds that need attention. Filters are URL-addressable. Source:\n226\t        <code style={codeStyle}> {route}</code>.\n227\t      </p>\n228\t    </header>\n229\t  );\n230\t}\n231\t\n232\tfunction SectionFilters({ children }: { children: React.ReactNode }) {\n233\t  return (\n234\t    <section aria-labelledby=\"filters-heading\" style={sectionStyle}>\n235\t      <h2 id=\"filters-heading\" style={sectionHeadingStyle}>\n236\t        Filters\n237\t      </h2>\n238\t      {children}\n239\t    </section>\n240\t  );\n241\t}\n242\t\n243\tfunction SectionTable({\n244\t  children,\n245\t  rows,\n246\t  total,\n247\t  page,\n248\t  totalPages,\n249\t  rawParams,\n250\t  route,\n251\t}: {\n252\t  children: React.ReactNode;\n253\t  rows: number;\n254\t  total: number;\n255\t  page: number;\n256\t  totalPages: number;\n257\t  rawParams: Record<string, string | string[] | undefined>;\n258\t  route: string;\n259\t}) {\n260\t  return (\n261\t    <section aria-labelledby=\"rounds-heading\" style={sectionStyle}>\n262\t      <h2 id=\"rounds-heading\" style={sectionHeadingStyle}>\n263\t        Rounds\n264\t      </h2>\n265\t      <p style={hintStyle}>\n266\t        {rows} shown · {total} total · sorted by created_at desc · default 50\n267\t        rows · server-side capped at 250.\n268\t      </p>\n269\t      {children}\n270\t      {totalPages > 1 ? (\n271\t        <nav aria-label=\"Pagination\" style={paginationStyle}>\n272\t          <PageLink\n273\t            disabled={page <= 1}\n274\t            href={pageHref(route, rawParams, page - 1)}\n275\t          >\n276\t            Previous\n277\t          </PageLink>\n278\t          <span style={pageLabelStyle}>\n279\t            Page {page} of {totalPages}\n280\t          </span>\n281\t          <PageLink\n282\t            disabled={page >= totalPages}\n283\t            href={pageHref(route, rawParams, page + 1)}\n284\t          >\n285\t            Next\n286\t          </PageLink>\n287\t        </nav>\n288\t      ) : null}\n289\t    </section>\n290\t  );\n291\t}\n292\t\n293\tfunction pageHref(\n294\t  route: string,\n295\t  rawParams: Record<string, string | string[] | undefined>,\n296\t  page: number,\n297\t): string {\n298\t  const qs = buildRoundsQueryString(rawParams, { page });\n299\t  return qs ? `${route}?${qs}` : route;\n300\t}\n301\t\n302\tfunction PageLink({\n303\t  href,\n304\t  disabled,\n305\t  children,\n306\t}: {\n307\t  href: string;\n308\t  disabled: boolean;\n309\t  children: React.ReactNode;\n310\t}) {\n311\t  if (disabled) {\n312\t    return (\n313\t      <span aria-disabled=\"true\" style={{ ...pageButton, ...pageButtonDisabled }}>\n314\t        {children}\n315\t      </span>\n316\t    );\n317\t  }\n318\t  return (\n319\t    <Link href={href} style={pageButton}>\n320\t      {children}\n321\t    </Link>\n322\t  );\n323\t}\n324\t\n325\tconst mainStyle: CSSProperties = {\n326\t  display: \"grid\",\n327\t  gap: \"1.5rem\",\n328\t};\n329\t\n330\tconst sectionStyle: CSSProperties = {\n331\t  display: \"grid\",\n332\t  gap: \"0.75rem\",\n333\t};\n334\t\n335\tconst sectionHeadingStyle: CSSProperties = {\n336\t  margin: \"0 0 0.75rem\",\n337\t  fontSize: \"1rem\",\n338\t  fontWeight: 600,\n339\t  color: \"#cbd5f5\",\n340\t  textTransform: \"uppercase\",\n341\t  letterSpacing: \"0.05em\",\n342\t};\n343\t\n344\tconst breadcrumbStyle: CSSProperties = {\n345\t  margin: 0,\n346\t  fontSize: \"0.875rem\",\n347\t  color: \"#94a3b8\",\n348\t};\n349\t\n350\tconst breadcrumbLinkStyle: CSSProperties = {\n351\t  color: \"#93c5fd\",\n352\t  textDecoration: \"none\",\n353\t};\n354\t\n355\tconst leadStyle: CSSProperties = {\n356\t  margin: \"0.25rem 0 0\",\n357\t  color: \"#94a3b8\",\n358\t};\n359\t\n360\tconst codeStyle: CSSProperties = {\n361\t  fontFamily: \"monospace\",\n362\t  color: \"#cbd5f5\",\n363\t};\n364\t\n365\tconst hintStyle: CSSProperties = {\n366\t  margin: 0,\n367\t  color: \"#94a3b8\",\n368\t  fontSize: \"0.8125rem\",\n369\t};\n370\t\n371\tconst errorStyle: CSSProperties = {\n372\t  margin: 0,\n373\t  padding: \"0.75rem 1rem\",\n374\t  borderRadius: \"0.75rem\",\n375\t  background: \"#3f1d1d\",\n376\t  color: \"#fecaca\",\n377\t};\n378\t\n379\tconst paginationStyle: CSSProperties = {\n380\t  display: \"flex\",\n381\t  gap: \"0.75rem\",\n382\t  alignItems: \"center\",\n383\t  flexWrap: \"wrap\",\n384\t};\n385\t\n386\tconst pageLabelStyle: CSSProperties = {\n387\t  color: \"#cbd5e1\",\n388\t  fontSize: \"0.875rem\",\n389\t};\n390\t\n391\tconst pageButton: CSSProperties = {\n392\t  borderRadius: \"0.5rem\",\n393\t  border: \"1px solid #334155\",\n394\t  padding: \"0.5rem 0.75rem\",\n395\t  color: \"#e2e8f0\",\n396\t  textDecoration: \"none\",\n397\t  fontSize: \"0.875rem\",\n398\t};\n399\t\n400\tconst pageButtonDisabled: CSSProperties = {\n401\t  color: \"#64748b\",\n402\t  borderColor: \"#1e293b\",\n403\t  cursor: \"not-allowed\",\n404\t};\n405\t"}]},"parent_tool_use_id":null,"session_id":"e7393274-dd95-4a47-827c-0160987ea587","uuid":"d5665cbd-4c76-4682-810e-b9c4edcaf064","timestamp":"2026-04-25T13:26:15.364Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/app/games/[game]/page.tsx","content":"// /games/[game] — per-game round audit (FR-8).\n//\n// Handles FlipYou + Pot Shot + Close Call through one [game] param. FlipYou +\n// Pot Shot share the `rounds` table, so the page calls `listRounds({ game })`\n// and renders the shared `GameRoundsTable`. Close Call has its own table and\n// lifecycle (`open` -> `settled`/`refunded` plus a Pyth-driven outcome), so the\n// page calls `listCloseCallRounds()` and renders `CloseCallRoundsTable`.\n//\n// Stuck-state filters cover the four FR-8 operational signals (nonterminal &\n// aged, high settle attempts [FlipYou+Pot Shot only], settled without expected\n// transaction, refunds). Filters are URL-addressable so an admin can share a\n// link to the exact investigation state.\nimport { notFound } from \"next/navigation\";\nimport Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport { CloseCallRoundsTable } from \"../../../src/components/closecall-rounds-table\";\nimport { GameRoundsFilterBar } from \"../../../src/components/game-rounds-filter-bar\";\nimport { GameRoundsTable } from \"../../../src/components/game-rounds-table\";\nimport {\n  buildRoundsQueryString,\n  normalizeCloseCallRoundFiltersFromSearchParams,\n  normalizeRoundFiltersFromSearchParams,\n  readPageFromSearchParams,\n} from \"../../../src/lib/games-search-params\";\nimport {\n  PEEK_GAME_IDS,\n  type PeekCloseCallRoundRow,\n  type PeekGameId,\n  type PeekRoundRow,\n  type PeekRoundsListResult,\n} from \"../../../src/lib/types/peek\";\nimport {\n  getPeekActorContext,\n  isRouteAllowedForRole,\n} from \"../../../src/server/access-policy\";\nimport {\n  listCloseCallRounds,\n  listRounds,\n  PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n} from \"../../../src/server/db/queries/get-game-rounds\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst GAME_LABELS: Record<PeekGameId, string> = {\n  flipyou: \"FlipYou\",\n  potshot: \"Pot Shot\",\n  closecall: \"Close Call\",\n};\n\nfunction isPeekGameId(value: string): value is PeekGameId {\n  return (PEEK_GAME_IDS as ReadonlyArray<string>).includes(value);\n}\n\nexport default async function GameRoundsPage({\n  params,\n  searchParams,\n}: {\n  params: Promise<{ game: string }>;\n  searchParams: Promise<Record<string, string | string[] | undefined>>;\n}) {\n  const { game: gameParam } = await params;\n  if (!isPeekGameId(gameParam)) {\n    notFound();\n  }\n  const game = gameParam as PeekGameId;\n  const route = `/games/${game}`;\n\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(route, actor?.role ?? null);\n\n  if (!allowed) {\n    return (\n      <main style={mainStyle}>\n        <header>\n          <h1>Games · {GAME_LABELS[game]}</h1>\n        </header>\n        <p role=\"alert\" style={errorStyle}>\n          You do not have access to this page.\n        </p>\n      </main>\n    );\n  }\n\n  const rawParams = await searchParams;\n  const page = readPageFromSearchParams(rawParams);\n\n  return game === \"closecall\" ? (\n    <CloseCallView\n      route={route}\n      label={GAME_LABELS[game]}\n      page={page}\n      rawParams={rawParams}\n    />\n  ) : (\n    <RoundsView\n      route={route}\n      label={GAME_LABELS[game]}\n      game={game}\n      page={page}\n      rawParams={rawParams}\n    />\n  );\n}\n\nasync function RoundsView({\n  route,\n  label,\n  game,\n  page,\n  rawParams,\n}: {\n  route: string;\n  label: string;\n  game: \"flipyou\" | \"potshot\";\n  page: number;\n  rawParams: Record<string, string | string[] | undefined>;\n}) {\n  const filters = normalizeRoundFiltersFromSearchParams(rawParams);\n\n  let result: PeekRoundsListResult<PeekRoundRow> = {\n    rows: [],\n    pagination: {\n      page,\n      pageSize: PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n      totalCount: 0,\n      totalPages: 1,\n    },\n  };\n  let error: string | null = null;\n\n  try {\n    result = await listRounds({ game, filters, page });\n  } catch (err) {\n    error =\n      err instanceof Error ? err.message : \"Rounds could not be loaded.\";\n  }\n\n  return (\n    <main style={mainStyle}>\n      <PageHeader route={route} label={label} />\n      <SectionFilters>\n        <GameRoundsFilterBar game={game} filters={filters} action={route} />\n      </SectionFilters>\n      <SectionTable\n        rows={result.rows.length}\n        total={result.pagination.totalCount}\n        page={result.pagination.page}\n        totalPages={result.pagination.totalPages}\n        rawParams={rawParams}\n        route={route}\n      >\n        <GameRoundsTable rows={result.rows} error={error} />\n      </SectionTable>\n    </main>\n  );\n}\n\nasync function CloseCallView({\n  route,\n  label,\n  page,\n  rawParams,\n}: {\n  route: string;\n  label: string;\n  page: number;\n  rawParams: Record<string, string | string[] | undefined>;\n}) {\n  const filters = normalizeCloseCallRoundFiltersFromSearchParams(rawParams);\n\n  let result: PeekRoundsListResult<PeekCloseCallRoundRow> = {\n    rows: [],\n    pagination: {\n      page,\n      pageSize: PEEK_GAME_ROUNDS_DEFAULT_PAGE_SIZE,\n      totalCount: 0,\n      totalPages: 1,\n    },\n  };\n  let error: string | null = null;\n\n  try {\n    result = await listCloseCallRounds({ filters, page });\n  } catch (err) {\n    error =\n      err instanceof Error ? err.message : \"Rounds could not be loaded.\";\n  }\n\n  return (\n    <main style={mainStyle}>\n      <PageHeader route={route} label={label} />\n      <SectionFilters>\n        <GameRoundsFilterBar\n          game=\"closecall\"\n          filters={filters}\n          action={route}\n        />\n      </SectionFilters>\n      <SectionTable\n        rows={result.rows.length}\n        total={result.pagination.totalCount}\n        page={result.pagination.page}\n        totalPages={result.pagination.totalPages}\n        rawParams={rawParams}\n        route={route}\n      >\n        <CloseCallRoundsTable rows={result.rows} error={error} />\n      </SectionTable>\n    </main>\n  );\n}\n\nfunction PageHeader({ route, label }: { route: string; label: string }) {\n  return (\n    <header>\n      <p style={breadcrumbStyle}>\n        <Link href=\"/games\" style={breadcrumbLinkStyle}>\n          ← Games\n        </Link>\n      </p>\n      <h1>Games · {label}</h1>\n      <p style={leadStyle}>\n        Round-level audit for {label}. Filter by phase, search by pda/match\n        id/creator, narrow by created date, or apply stuck-state filters to\n        find rounds that need attention. Filters are URL-addressable. Source:\n        <code style={codeStyle}> {route}</code>.\n      </p>\n    </header>\n  );\n}\n\nfunction SectionFilters({ children }: { children: React.ReactNode }) {\n  return (\n    <section aria-labelledby=\"filters-heading\" style={sectionStyle}>\n      <h2 id=\"filters-heading\" style={sectionHeadingStyle}>\n        Filters\n      </h2>\n      {children}\n    </section>\n  );\n}\n\nfunction SectionTable({\n  children,\n  rows,\n  total,\n  page,\n  totalPages,\n  rawParams,\n  route,\n}: {\n  children: React.ReactNode;\n  rows: number;\n  total: number;\n  page: number;\n  totalPages: number;\n  rawParams: Record<string, string | string[] | undefined>;\n  route: string;\n}) {\n  return (\n    <section aria-labelledby=\"rounds-heading\" style={sectionStyle}>\n      <h2 id=\"rounds-heading\" style={sectionHeadingStyle}>\n        Rounds\n      </h2>\n      <p style={hintStyle}>\n        {rows} shown · {total} total · sorted by created_at desc · default 50\n        rows · server-side capped at 250.\n      </p>\n      {children}\n      {totalPages > 1 ? (\n        <nav aria-label=\"Pagination\" style={paginationStyle}>\n          <PageLink\n            disabled={page <= 1}\n            href={pageHref(route, rawParams, page - 1)}\n          >\n            Previous\n          </PageLink>\n          <span style={pageLabelStyle}>\n            Page {page} of {totalPages}\n          </span>\n          <PageLink\n            disabled={page >= totalPages}\n            href={pageHref(route, rawParams, page + 1)}\n          >\n            Next\n          </PageLink>\n        </nav>\n      ) : null}\n    </section>\n  );\n}\n\nfunction pageHref(\n  route: string,\n  rawParams: Record<string, string | string[] | undefined>,\n  page: number,\n): string {\n  const qs = buildRoundsQueryString(rawParams, { page });\n  return qs ? `${route}?${qs}` : route;\n}\n\nfunction PageLink({\n  href,\n  disabled,\n  children,\n}: {\n  href: string;\n  disabled: boolean;\n  children: React.ReactNode;\n}) {\n  if (disabled) {\n    return (\n      <span aria-disabled=\"true\" style={{ ...pageButton, ...pageButtonDisabled }}>\n        {children}\n      </span>\n    );\n  }\n  return (\n    <Link href={href} style={pageButton}>\n      {children}\n    </Link>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst breadcrumbStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n\nconst breadcrumbLinkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst codeStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  color: \"#cbd5f5\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst paginationStyle: CSSProperties = {\n  display: \"flex\",\n  gap: \"0.75rem\",\n  alignItems: \"center\",\n  flexWrap: \"wrap\",\n};\n\nconst pageLabelStyle: CSSProperties = {\n  color: \"#cbd5e1\",\n  fontSize: \"0.875rem\",\n};\n\nconst pageButton: CSSProperties = {\n  borderRadius: \"0.5rem\",\n  border: \"1px solid #334155\",\n  padding: \"0.5rem 0.75rem\",\n  color: \"#e2e8f0\",\n  textDecoration: \"none\",\n  fontSize: \"0.875rem\",\n};\n\nconst pageButtonDisabled: CSSProperties = {\n  color: \"#64748b\",\n  borderColor: \"#1e293b\",\n  cursor: \"not-allowed\",\n};\n","numLines":405,"startLine":1,"totalLines":405}}}
