{"type":"assistant","message":{"model":"claude-opus-4-7","id":"msg_01VVdEyoGzJxs8zf12QMiwEm","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_012sfruPcc2MCxfxtxtXXgtX","name":"Write","input":{"file_path":"/workspaces/rng-utopia/peek/app/games/[game]/rounds/[roundId]/page.tsx","content":"// /games/[game]/rounds/[roundId] — round-level participant + transaction audit\n// (FR-8).\n//\n// Resolves the URL `roundId` against the round's on-chain `pda` (the same key\n// shape for FlipYou, Pot Shot, and Close Call). Renders the round summary,\n// then the per-round entries from `game_entries` and the per-round\n// `transactions` rows so an operator can confirm who participated and which\n// on-chain SOL movements settled the round. Read-only.\nimport { notFound } from \"next/navigation\";\nimport Link from \"next/link\";\nimport type { CSSProperties, ReactNode } from \"react\";\nimport { StatusChip } from \"../../../../../src/components/status-chip\";\nimport {\n  PEEK_GAME_IDS,\n  type PeekCloseCallOutcome,\n  type PeekCloseCallPhase,\n  type PeekCloseCallRoundRow,\n  type PeekGameId,\n  type PeekRoundDetail,\n  type PeekRoundEntryRow,\n  type PeekRoundPhase,\n  type PeekRoundRow,\n  type PeekRoundTransactionRow,\n  type PeekStatusTone,\n} from \"../../../../../src/lib/types/peek\";\nimport {\n  getPeekActorContext,\n  isRouteAllowedForRole,\n} from \"../../../../../src/server/access-policy\";\nimport { getRoundDetail } from \"../../../../../src/server/db/queries/get-round-detail\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst GAME_LABELS: Record<PeekGameId, string> = {\n  flipyou: \"FlipYou\",\n  potshot: \"Pot Shot\",\n  closecall: \"Close Call\",\n};\n\nfunction isPeekGameId(value: string): value is PeekGameId {\n  return (PEEK_GAME_IDS as ReadonlyArray<string>).includes(value);\n}\n\nexport default async function RoundDetailPage({\n  params,\n}: {\n  params: Promise<{ game: string; roundId: string }>;\n}) {\n  const { game: gameParam, roundId } = await params;\n  if (!isPeekGameId(gameParam)) {\n    notFound();\n  }\n  const game = gameParam as PeekGameId;\n  const route = `/games/${game}/rounds/${roundId}`;\n\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(route, actor?.role ?? null);\n\n  if (!allowed) {\n    return (\n      <main style={mainStyle}>\n        <header>\n          <h1>\n            Games · {GAME_LABELS[game]} · Round\n          </h1>\n        </header>\n        <p role=\"alert\" style={errorStyle}>\n          You do not have access to this page.\n        </p>\n      </main>\n    );\n  }\n\n  let detail: PeekRoundDetail | null = null;\n  let loadError: string | null = null;\n\n  try {\n    detail = await getRoundDetail({ game, roundId });\n  } catch (err) {\n    loadError =\n      err instanceof Error ? err.message : \"Round detail could not be loaded.\";\n  }\n\n  if (!loadError && !detail) {\n    notFound();\n  }\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <p style={breadcrumbStyle}>\n          <Link href=\"/games\" style={breadcrumbLinkStyle}>\n            ← Games\n          </Link>\n          {\" · \"}\n          <Link\n            href={`/games/${game}`}\n            style={breadcrumbLinkStyle}\n          >\n            {GAME_LABELS[game]}\n          </Link>\n        </p>\n        <h1>Round audit · {GAME_LABELS[game]}</h1>\n        <p style={leadStyle}>\n          Round identifier (pda):{\" \"}\n          <code style={codeStyle}>{roundId}</code>. Sources:{\" \"}\n          <code style={codeStyle}>\n            {game === \"closecall\" ? \"closecall_rounds\" : \"rounds\"}\n          </code>\n          {\", \"}\n          <code style={codeStyle}>game_entries</code>,{\" \"}\n          <code style={codeStyle}>transactions</code>.\n        </p>\n      </header>\n\n      {loadError ? (\n        <p role=\"alert\" style={errorStyle}>\n          Round detail unavailable: {loadError}\n        </p>\n      ) : detail ? (\n        <RoundDetailSections detail={detail} />\n      ) : null}\n    </main>\n  );\n}\n\nfunction RoundDetailSections({ detail }: { detail: PeekRoundDetail }) {\n  return (\n    <>\n      <Section heading=\"Round summary\" headingId=\"round-summary-heading\">\n        {detail.game === \"closecall\" ? (\n          <CloseCallSummary round={detail.round} />\n        ) : (\n          <RoundSummary round={detail.round} />\n        )}\n      </Section>\n\n      <Section heading=\"Entries\" headingId=\"entries-heading\">\n        <p style={hintStyle}>\n          {detail.entries.length} participant\n          {detail.entries.length === 1 ? \"\" : \"s\"} from{\" \"}\n          <code style={codeStyle}>game_entries</code> · sorted oldest first.\n        </p>\n        <EntriesTable entries={detail.entries} game={detail.game} />\n      </Section>\n\n      <Section heading=\"Transactions\" headingId=\"transactions-heading\">\n        <p style={hintStyle}>\n          {detail.transactions.length} on-chain SOL movement\n          {detail.transactions.length === 1 ? \"\" : \"s\"} from{\" \"}\n          <code style={codeStyle}>transactions</code> · sorted oldest first.\n        </p>\n        <TransactionsTable transactions={detail.transactions} />\n      </Section>\n    </>\n  );\n}\n\nfunction RoundSummary({ round }: { round: PeekRoundRow }) {\n  return (\n    <dl style={summaryGridStyle}>\n      <SummaryItem label=\"Phase\">\n        <StatusChip label={round.phase} tone={phaseTone(round.phase)} />\n      </SummaryItem>\n      <SummaryItem label=\"Match ID\">\n        <Mono title={round.matchId}>{round.matchId}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"PDA\">\n        <Mono title={round.pda}>{round.pda}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"Creator\">\n        <Mono title={round.creator}>{round.creator}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"Amount (lamports)\">\n        {formatNumber(round.amountLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Target slot\">\n        {round.targetSlot ? formatNumber(round.targetSlot) : \"—\"}\n      </SummaryItem>\n      <SummaryItem label=\"Settle attempts\">\n        {String(round.settleAttempts)}\n      </SummaryItem>\n      <SummaryItem label=\"Result side\">\n        {round.resultSide === null ? \"—\" : String(round.resultSide)}\n      </SummaryItem>\n      <SummaryItem label=\"Winner\">\n        {round.winner ? <Mono title={round.winner}>{round.winner}</Mono> : \"—\"}\n      </SummaryItem>\n      <SummaryItem label=\"Settle tx\">\n        {round.settleTx ? (\n          <Mono title={round.settleTx}>{round.settleTx}</Mono>\n        ) : (\n          \"—\"\n        )}\n      </SummaryItem>\n      <SummaryItem label=\"Created\">{round.createdAt}</SummaryItem>\n      <SummaryItem label=\"Updated\">{round.updatedAt}</SummaryItem>\n      <SummaryItem label=\"Settled\">{round.settledAt ?? \"—\"}</SummaryItem>\n    </dl>\n  );\n}\n\nfunction CloseCallSummary({ round }: { round: PeekCloseCallRoundRow }) {\n  return (\n    <dl style={summaryGridStyle}>\n      <SummaryItem label=\"Phase\">\n        <StatusChip label={round.phase} tone={closeCallPhaseTone(round.phase)} />\n      </SummaryItem>\n      <SummaryItem label=\"Outcome\">\n        <StatusChip\n          label={round.outcome}\n          tone={closeCallOutcomeTone(round.outcome)}\n        />\n      </SummaryItem>\n      <SummaryItem label=\"Round ID\">\n        <Mono title={round.roundId}>{round.roundId}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"PDA\">\n        <Mono title={round.pda}>{round.pda}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"Open price\">\n        {formatNumber(round.openPrice)}\n        <span style={subValueStyle}> · expo {round.openPriceExpo}</span>\n      </SummaryItem>\n      <SummaryItem label=\"Close price\">\n        {round.closePrice ? formatNumber(round.closePrice) : \"—\"}\n      </SummaryItem>\n      <SummaryItem label=\"Green pool (lamports)\">\n        {formatNumber(round.greenPoolLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Red pool (lamports)\">\n        {formatNumber(round.redPoolLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Total fee (lamports)\">\n        {formatNumber(round.totalFeeLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Settle tx\">\n        {round.settleTx ? (\n          <Mono title={round.settleTx}>{round.settleTx}</Mono>\n        ) : (\n          \"—\"\n        )}\n      </SummaryItem>\n      <SummaryItem label=\"Created\">{round.createdAt}</SummaryItem>\n      <SummaryItem label=\"Settled\">{round.settledAt ?? \"—\"}</SummaryItem>\n    </dl>\n  );\n}\n\nfunction EntriesTable({\n  entries,\n  game,\n}: {\n  entries: ReadonlyArray<PeekRoundEntryRow>;\n  game: PeekGameId;\n}) {\n  if (entries.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No entries recorded for this round.</p>\n        <p style={emptyBodyStyle}>\n          The <code style={codeStyle}>game_entries</code> table has no rows\n          joined to this round PDA. This is normal for rounds that were created\n          but never joined.\n        </p>\n      </div>\n    );\n  }\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>\n            <th style={headerCellStyle(\"left\")}>\n              {game === \"closecall\" ? \"Side\" : \"Side\"}\n            </th>\n            <th style={headerCellStyle(\"left\")}>Winner</th>\n            <th style={headerCellStyle(\"right\")}>Payout (lamports)</th>\n            <th style={headerCellStyle(\"left\")}>Settled</th>\n          </tr>\n        </thead>\n        <tbody>\n          {entries.map((entry) => (\n            <tr key={entry.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{entry.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <Link\n                  href={`/users/${entry.userId}`}\n                  style={linkStyle}\n                  title={entry.userId}\n                >\n                  {entry.username ?? truncate(entry.userId, 12)}\n                </Link>\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={entry.wallet}>{truncate(entry.wallet, 12)}</span>\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(entry.amountLamports)}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{entry.side ?? \"—\"}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                {entry.isWinner === null ? \"—\" : entry.isWinner ? \"yes\" : \"no\"}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(entry.payoutLamports)}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{entry.settledAt ?? \"—\"}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction TransactionsTable({\n  transactions,\n}: {\n  transactions: ReadonlyArray<PeekRoundTransactionRow>;\n}) {\n  if (transactions.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No transactions recorded for this round.</p>\n        <p style={emptyBodyStyle}>\n          The <code style={codeStyle}>transactions</code> table has no rows\n          joined to this round. Settled rounds without transaction rows are an\n          attention state surfaced by the stuck-state filters on{\" \"}\n          <code style={codeStyle}>/games/[game]</code>.\n        </p>\n      </div>\n    );\n  }\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>Type</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>\n            <th style={headerCellStyle(\"left\")}>Tx signature</th>\n          </tr>\n        </thead>\n        <tbody>\n          {transactions.map((tx) => (\n            <tr key={tx.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{tx.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip label={tx.txType} tone=\"info\" />\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                {tx.userId ? (\n                  <Link\n                    href={`/users/${tx.userId}`}\n                    style={linkStyle}\n                    title={tx.userId}\n                  >\n                    {tx.username ?? truncate(tx.userId, 12)}\n                  </Link>\n                ) : (\n                  \"—\"\n                )}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={tx.wallet}>{truncate(tx.wallet, 12)}</span>\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(tx.amountLamports)}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={tx.txSig}>{truncate(tx.txSig, 16)}</span>\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction Section({\n  heading,\n  headingId,\n  children,\n}: {\n  heading: string;\n  headingId: string;\n  children: ReactNode;\n}) {\n  return (\n    <section aria-labelledby={headingId} style={sectionStyle}>\n      <h2 id={headingId} style={sectionHeadingStyle}>\n        {heading}\n      </h2>\n      {children}\n    </section>\n  );\n}\n\nfunction SummaryItem({\n  label,\n  children,\n}: {\n  label: string;\n  children: ReactNode;\n}) {\n  return (\n    <div style={summaryItemStyle}>\n      <dt style={summaryLabelStyle}>{label}</dt>\n      <dd style={summaryValueStyle}>{children}</dd>\n    </div>\n  );\n}\n\nfunction Mono({ title, children }: { title: string; children: ReactNode }) {\n  return (\n    <span style={{ fontFamily: \"monospace\" }} title={title}>\n      {typeof children === \"string\" ? truncate(children, 16) : children}\n    </span>\n  );\n}\n\nfunction phaseTone(phase: PeekRoundPhase): PeekStatusTone {\n  if (phase === \"settled\") return \"positive\";\n  if (phase === \"expired\") return \"warning\";\n  if (phase === \"settling\") return \"info\";\n  if (phase === \"locked\") return \"info\";\n  return \"neutral\";\n}\n\nfunction closeCallPhaseTone(phase: PeekCloseCallPhase): PeekStatusTone {\n  if (phase === \"settled\") return \"positive\";\n  if (phase === \"refunded\") return \"warning\";\n  return \"info\";\n}\n\nfunction closeCallOutcomeTone(outcome: PeekCloseCallOutcome): PeekStatusTone {\n  if (outcome === \"green\") return \"positive\";\n  if (outcome === \"red\") return \"negative\";\n  if (outcome === \"refund\") return \"warning\";\n  return \"neutral\";\n}\n\nfunction truncate(value: string, max: number): string {\n  if (value.length <= max) return value;\n  const head = Math.max(2, Math.floor((max - 1) / 2));\n  const tail = Math.max(2, max - 1 - head);\n  return `${value.slice(0, head)}…${value.slice(-tail)}`;\n}\n\nfunction formatNumber(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst breadcrumbStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n\nconst breadcrumbLinkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst codeStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  color: \"#cbd5f5\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n  marginLeft: \"0.25rem\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst summaryGridStyle: CSSProperties = {\n  display: \"grid\",\n  gridTemplateColumns: \"repeat(auto-fit, minmax(220px, 1fr))\",\n  gap: \"0.75rem\",\n  margin: 0,\n  padding: \"1rem\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n  background: \"#0b1220\",\n};\n\nconst summaryItemStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst summaryLabelStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst summaryValueStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#e2e8f0\",\n};\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n  };\n}\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":643,"cache_read_input_tokens":97744,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":643},"output_tokens":44,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"e7393274-dd95-4a47-827c-0160987ea587","uuid":"74a9c331-d380-4bc8-b19b-e872b2247143"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012sfruPcc2MCxfxtxtXXgtX","type":"tool_result","content":"File created successfully at: /workspaces/rng-utopia/peek/app/games/[game]/rounds/[roundId]/page.tsx"}]},"parent_tool_use_id":null,"session_id":"e7393274-dd95-4a47-827c-0160987ea587","uuid":"f9aa1ac3-1640-4df6-a225-778dc1aa9e73","timestamp":"2026-04-25T13:28:12.094Z","tool_use_result":{"type":"create","filePath":"/workspaces/rng-utopia/peek/app/games/[game]/rounds/[roundId]/page.tsx","content":"// /games/[game]/rounds/[roundId] — round-level participant + transaction audit\n// (FR-8).\n//\n// Resolves the URL `roundId` against the round's on-chain `pda` (the same key\n// shape for FlipYou, Pot Shot, and Close Call). Renders the round summary,\n// then the per-round entries from `game_entries` and the per-round\n// `transactions` rows so an operator can confirm who participated and which\n// on-chain SOL movements settled the round. Read-only.\nimport { notFound } from \"next/navigation\";\nimport Link from \"next/link\";\nimport type { CSSProperties, ReactNode } from \"react\";\nimport { StatusChip } from \"../../../../../src/components/status-chip\";\nimport {\n  PEEK_GAME_IDS,\n  type PeekCloseCallOutcome,\n  type PeekCloseCallPhase,\n  type PeekCloseCallRoundRow,\n  type PeekGameId,\n  type PeekRoundDetail,\n  type PeekRoundEntryRow,\n  type PeekRoundPhase,\n  type PeekRoundRow,\n  type PeekRoundTransactionRow,\n  type PeekStatusTone,\n} from \"../../../../../src/lib/types/peek\";\nimport {\n  getPeekActorContext,\n  isRouteAllowedForRole,\n} from \"../../../../../src/server/access-policy\";\nimport { getRoundDetail } from \"../../../../../src/server/db/queries/get-round-detail\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst GAME_LABELS: Record<PeekGameId, string> = {\n  flipyou: \"FlipYou\",\n  potshot: \"Pot Shot\",\n  closecall: \"Close Call\",\n};\n\nfunction isPeekGameId(value: string): value is PeekGameId {\n  return (PEEK_GAME_IDS as ReadonlyArray<string>).includes(value);\n}\n\nexport default async function RoundDetailPage({\n  params,\n}: {\n  params: Promise<{ game: string; roundId: string }>;\n}) {\n  const { game: gameParam, roundId } = await params;\n  if (!isPeekGameId(gameParam)) {\n    notFound();\n  }\n  const game = gameParam as PeekGameId;\n  const route = `/games/${game}/rounds/${roundId}`;\n\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(route, actor?.role ?? null);\n\n  if (!allowed) {\n    return (\n      <main style={mainStyle}>\n        <header>\n          <h1>\n            Games · {GAME_LABELS[game]} · Round\n          </h1>\n        </header>\n        <p role=\"alert\" style={errorStyle}>\n          You do not have access to this page.\n        </p>\n      </main>\n    );\n  }\n\n  let detail: PeekRoundDetail | null = null;\n  let loadError: string | null = null;\n\n  try {\n    detail = await getRoundDetail({ game, roundId });\n  } catch (err) {\n    loadError =\n      err instanceof Error ? err.message : \"Round detail could not be loaded.\";\n  }\n\n  if (!loadError && !detail) {\n    notFound();\n  }\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <p style={breadcrumbStyle}>\n          <Link href=\"/games\" style={breadcrumbLinkStyle}>\n            ← Games\n          </Link>\n          {\" · \"}\n          <Link\n            href={`/games/${game}`}\n            style={breadcrumbLinkStyle}\n          >\n            {GAME_LABELS[game]}\n          </Link>\n        </p>\n        <h1>Round audit · {GAME_LABELS[game]}</h1>\n        <p style={leadStyle}>\n          Round identifier (pda):{\" \"}\n          <code style={codeStyle}>{roundId}</code>. Sources:{\" \"}\n          <code style={codeStyle}>\n            {game === \"closecall\" ? \"closecall_rounds\" : \"rounds\"}\n          </code>\n          {\", \"}\n          <code style={codeStyle}>game_entries</code>,{\" \"}\n          <code style={codeStyle}>transactions</code>.\n        </p>\n      </header>\n\n      {loadError ? (\n        <p role=\"alert\" style={errorStyle}>\n          Round detail unavailable: {loadError}\n        </p>\n      ) : detail ? (\n        <RoundDetailSections detail={detail} />\n      ) : null}\n    </main>\n  );\n}\n\nfunction RoundDetailSections({ detail }: { detail: PeekRoundDetail }) {\n  return (\n    <>\n      <Section heading=\"Round summary\" headingId=\"round-summary-heading\">\n        {detail.game === \"closecall\" ? (\n          <CloseCallSummary round={detail.round} />\n        ) : (\n          <RoundSummary round={detail.round} />\n        )}\n      </Section>\n\n      <Section heading=\"Entries\" headingId=\"entries-heading\">\n        <p style={hintStyle}>\n          {detail.entries.length} participant\n          {detail.entries.length === 1 ? \"\" : \"s\"} from{\" \"}\n          <code style={codeStyle}>game_entries</code> · sorted oldest first.\n        </p>\n        <EntriesTable entries={detail.entries} game={detail.game} />\n      </Section>\n\n      <Section heading=\"Transactions\" headingId=\"transactions-heading\">\n        <p style={hintStyle}>\n          {detail.transactions.length} on-chain SOL movement\n          {detail.transactions.length === 1 ? \"\" : \"s\"} from{\" \"}\n          <code style={codeStyle}>transactions</code> · sorted oldest first.\n        </p>\n        <TransactionsTable transactions={detail.transactions} />\n      </Section>\n    </>\n  );\n}\n\nfunction RoundSummary({ round }: { round: PeekRoundRow }) {\n  return (\n    <dl style={summaryGridStyle}>\n      <SummaryItem label=\"Phase\">\n        <StatusChip label={round.phase} tone={phaseTone(round.phase)} />\n      </SummaryItem>\n      <SummaryItem label=\"Match ID\">\n        <Mono title={round.matchId}>{round.matchId}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"PDA\">\n        <Mono title={round.pda}>{round.pda}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"Creator\">\n        <Mono title={round.creator}>{round.creator}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"Amount (lamports)\">\n        {formatNumber(round.amountLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Target slot\">\n        {round.targetSlot ? formatNumber(round.targetSlot) : \"—\"}\n      </SummaryItem>\n      <SummaryItem label=\"Settle attempts\">\n        {String(round.settleAttempts)}\n      </SummaryItem>\n      <SummaryItem label=\"Result side\">\n        {round.resultSide === null ? \"—\" : String(round.resultSide)}\n      </SummaryItem>\n      <SummaryItem label=\"Winner\">\n        {round.winner ? <Mono title={round.winner}>{round.winner}</Mono> : \"—\"}\n      </SummaryItem>\n      <SummaryItem label=\"Settle tx\">\n        {round.settleTx ? (\n          <Mono title={round.settleTx}>{round.settleTx}</Mono>\n        ) : (\n          \"—\"\n        )}\n      </SummaryItem>\n      <SummaryItem label=\"Created\">{round.createdAt}</SummaryItem>\n      <SummaryItem label=\"Updated\">{round.updatedAt}</SummaryItem>\n      <SummaryItem label=\"Settled\">{round.settledAt ?? \"—\"}</SummaryItem>\n    </dl>\n  );\n}\n\nfunction CloseCallSummary({ round }: { round: PeekCloseCallRoundRow }) {\n  return (\n    <dl style={summaryGridStyle}>\n      <SummaryItem label=\"Phase\">\n        <StatusChip label={round.phase} tone={closeCallPhaseTone(round.phase)} />\n      </SummaryItem>\n      <SummaryItem label=\"Outcome\">\n        <StatusChip\n          label={round.outcome}\n          tone={closeCallOutcomeTone(round.outcome)}\n        />\n      </SummaryItem>\n      <SummaryItem label=\"Round ID\">\n        <Mono title={round.roundId}>{round.roundId}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"PDA\">\n        <Mono title={round.pda}>{round.pda}</Mono>\n      </SummaryItem>\n      <SummaryItem label=\"Open price\">\n        {formatNumber(round.openPrice)}\n        <span style={subValueStyle}> · expo {round.openPriceExpo}</span>\n      </SummaryItem>\n      <SummaryItem label=\"Close price\">\n        {round.closePrice ? formatNumber(round.closePrice) : \"—\"}\n      </SummaryItem>\n      <SummaryItem label=\"Green pool (lamports)\">\n        {formatNumber(round.greenPoolLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Red pool (lamports)\">\n        {formatNumber(round.redPoolLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Total fee (lamports)\">\n        {formatNumber(round.totalFeeLamports)}\n      </SummaryItem>\n      <SummaryItem label=\"Settle tx\">\n        {round.settleTx ? (\n          <Mono title={round.settleTx}>{round.settleTx}</Mono>\n        ) : (\n          \"—\"\n        )}\n      </SummaryItem>\n      <SummaryItem label=\"Created\">{round.createdAt}</SummaryItem>\n      <SummaryItem label=\"Settled\">{round.settledAt ?? \"—\"}</SummaryItem>\n    </dl>\n  );\n}\n\nfunction EntriesTable({\n  entries,\n  game,\n}: {\n  entries: ReadonlyArray<PeekRoundEntryRow>;\n  game: PeekGameId;\n}) {\n  if (entries.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No entries recorded for this round.</p>\n        <p style={emptyBodyStyle}>\n          The <code style={codeStyle}>game_entries</code> table has no rows\n          joined to this round PDA. This is normal for rounds that were created\n          but never joined.\n        </p>\n      </div>\n    );\n  }\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>\n            <th style={headerCellStyle(\"left\")}>\n              {game === \"closecall\" ? \"Side\" : \"Side\"}\n            </th>\n            <th style={headerCellStyle(\"left\")}>Winner</th>\n            <th style={headerCellStyle(\"right\")}>Payout (lamports)</th>\n            <th style={headerCellStyle(\"left\")}>Settled</th>\n          </tr>\n        </thead>\n        <tbody>\n          {entries.map((entry) => (\n            <tr key={entry.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{entry.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <Link\n                  href={`/users/${entry.userId}`}\n                  style={linkStyle}\n                  title={entry.userId}\n                >\n                  {entry.username ?? truncate(entry.userId, 12)}\n                </Link>\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={entry.wallet}>{truncate(entry.wallet, 12)}</span>\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(entry.amountLamports)}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{entry.side ?? \"—\"}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                {entry.isWinner === null ? \"—\" : entry.isWinner ? \"yes\" : \"no\"}\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(entry.payoutLamports)}\n              </td>\n              <td style={bodyCellStyle(\"left\")}>{entry.settledAt ?? \"—\"}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction TransactionsTable({\n  transactions,\n}: {\n  transactions: ReadonlyArray<PeekRoundTransactionRow>;\n}) {\n  if (transactions.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No transactions recorded for this round.</p>\n        <p style={emptyBodyStyle}>\n          The <code style={codeStyle}>transactions</code> table has no rows\n          joined to this round. Settled rounds without transaction rows are an\n          attention state surfaced by the stuck-state filters on{\" \"}\n          <code style={codeStyle}>/games/[game]</code>.\n        </p>\n      </div>\n    );\n  }\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>Type</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"right\")}>Amount (lamports)</th>\n            <th style={headerCellStyle(\"left\")}>Tx signature</th>\n          </tr>\n        </thead>\n        <tbody>\n          {transactions.map((tx) => (\n            <tr key={tx.id} style={bodyRowStyle}>\n              <td style={bodyCellStyle(\"left\")}>{tx.createdAt}</td>\n              <td style={bodyCellStyle(\"left\")}>\n                <StatusChip label={tx.txType} tone=\"info\" />\n              </td>\n              <td style={bodyCellStyle(\"left\")}>\n                {tx.userId ? (\n                  <Link\n                    href={`/users/${tx.userId}`}\n                    style={linkStyle}\n                    title={tx.userId}\n                  >\n                    {tx.username ?? truncate(tx.userId, 12)}\n                  </Link>\n                ) : (\n                  \"—\"\n                )}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={tx.wallet}>{truncate(tx.wallet, 12)}</span>\n              </td>\n              <td style={bodyCellStyle(\"right\")}>\n                {formatNumber(tx.amountLamports)}\n              </td>\n              <td style={{ ...bodyCellStyle(\"left\"), fontFamily: \"monospace\" }}>\n                <span title={tx.txSig}>{truncate(tx.txSig, 16)}</span>\n              </td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction Section({\n  heading,\n  headingId,\n  children,\n}: {\n  heading: string;\n  headingId: string;\n  children: ReactNode;\n}) {\n  return (\n    <section aria-labelledby={headingId} style={sectionStyle}>\n      <h2 id={headingId} style={sectionHeadingStyle}>\n        {heading}\n      </h2>\n      {children}\n    </section>\n  );\n}\n\nfunction SummaryItem({\n  label,\n  children,\n}: {\n  label: string;\n  children: ReactNode;\n}) {\n  return (\n    <div style={summaryItemStyle}>\n      <dt style={summaryLabelStyle}>{label}</dt>\n      <dd style={summaryValueStyle}>{children}</dd>\n    </div>\n  );\n}\n\nfunction Mono({ title, children }: { title: string; children: ReactNode }) {\n  return (\n    <span style={{ fontFamily: \"monospace\" }} title={title}>\n      {typeof children === \"string\" ? truncate(children, 16) : children}\n    </span>\n  );\n}\n\nfunction phaseTone(phase: PeekRoundPhase): PeekStatusTone {\n  if (phase === \"settled\") return \"positive\";\n  if (phase === \"expired\") return \"warning\";\n  if (phase === \"settling\") return \"info\";\n  if (phase === \"locked\") return \"info\";\n  return \"neutral\";\n}\n\nfunction closeCallPhaseTone(phase: PeekCloseCallPhase): PeekStatusTone {\n  if (phase === \"settled\") return \"positive\";\n  if (phase === \"refunded\") return \"warning\";\n  return \"info\";\n}\n\nfunction closeCallOutcomeTone(outcome: PeekCloseCallOutcome): PeekStatusTone {\n  if (outcome === \"green\") return \"positive\";\n  if (outcome === \"red\") return \"negative\";\n  if (outcome === \"refund\") return \"warning\";\n  return \"neutral\";\n}\n\nfunction truncate(value: string, max: number): string {\n  if (value.length <= max) return value;\n  const head = Math.max(2, Math.floor((max - 1) / 2));\n  const tail = Math.max(2, max - 1 - head);\n  return `${value.slice(0, head)}…${value.slice(-tail)}`;\n}\n\nfunction formatNumber(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst breadcrumbStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n\nconst breadcrumbLinkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst codeStyle: CSSProperties = {\n  fontFamily: \"monospace\",\n  color: \"#cbd5f5\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n  marginLeft: \"0.25rem\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst summaryGridStyle: CSSProperties = {\n  display: \"grid\",\n  gridTemplateColumns: \"repeat(auto-fit, minmax(220px, 1fr))\",\n  gap: \"0.75rem\",\n  margin: 0,\n  padding: \"1rem\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n  background: \"#0b1220\",\n};\n\nconst summaryItemStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.25rem\",\n};\n\nconst summaryLabelStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.75rem\",\n  color: \"#94a3b8\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst summaryValueStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#e2e8f0\",\n};\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n  };\n}\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","structuredPatch":[],"originalFile":null,"userModified":false}}
