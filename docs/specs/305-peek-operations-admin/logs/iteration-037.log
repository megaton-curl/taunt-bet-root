{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G84ksBzDWkyokeC6vqJNhH","type":"tool_result","content":"759\texport type PeekRoundRow = {\n760\t  game: PeekRoundsGameId;\n761\t  pda: string;\n762\t  matchId: string;\n763\t  phase: PeekRoundPhase;\n764\t  creator: string;\n765\t  targetSlot: string | null;\n766\t  settleAttempts: number;\n767\t  settleTx: string | null;\n768\t  resultSide: number | null;\n769\t  winner: string | null;\n770\t  amountLamports: string;\n771\t  createdAt: string;\n772\t  updatedAt: string;\n773\t  settledAt: string | null;\n774\t};\n775\t\n776\texport type PeekCloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n777\t\n778\texport const PEEK_CLOSECALL_PHASES: ReadonlyArray<PeekCloseCallPhase> = [\n779\t  \"open\",\n780\t  \"settled\",\n781\t  \"refunded\",\n782\t];\n783\t\n784\texport type PeekCloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n785\t\n786\texport const PEEK_CLOSECALL_OUTCOMES: ReadonlyArray<PeekCloseCallOutcome> = [\n787\t  \"pending\",\n788\t  \"green\",\n789\t  \"red\",\n790\t  \"refund\",\n791\t];\n792\t\n793\texport type PeekCloseCallRoundRow = {\n794\t  pda: string;\n795\t  roundId: string;\n796\t  phase: PeekCloseCallPhase;\n797\t  outcome: PeekCloseCallOutcome;\n798\t  openPrice: string;\n799\t  openPriceExpo: number;\n800\t  closePrice: string | null;\n801\t  greenPoolLamports: string;\n802\t  redPoolLamports: string;\n803\t  totalFeeLamports: string;\n804\t  settleTx: string | null;\n805\t  createdAt: string;\n806\t  settledAt: string | null;\n807\t};\n808\t\n809\texport type PeekRoundStuckFilters = {\n810\t  nonterminalAged: boolean;\n811\t  highAttempts: boolean;\n812\t  settledWithoutTx: boolean;\n813\t  refunds: boolean;\n814\t};\n815\t\n816\texport type PeekRoundFilters = {\n817\t  phase: PeekRoundPhase | null;\n818\t  search: string | null;\n819\t  fromDate: string | null;\n820\t  toDate: string | null;\n821\t  stuck: PeekRoundStuckFilters;\n822\t};\n823\t\n824\texport type PeekCloseCallRoundStuckFilters = Omit<\n825\t  PeekRoundStuckFilters,\n826\t  \"highAttempts\"\n827\t>;\n828\t\n829\texport type PeekCloseCallRoundFilters = {\n830\t  phase: PeekCloseCallPhase | null;\n831\t  outcome: PeekCloseCallOutcome | null;\n832\t  search: string | null;\n833\t  fromDate: string | null;\n834\t  toDate: string | null;\n835\t  stuck: PeekCloseCallRoundStuckFilters;\n836\t};\n837\t\n838\texport type PeekRoundsListResult<TRow> = {\n839\t  rows: ReadonlyArray<TRow>;\n840\t  pagination: PeekPagination;\n841\t};\n842\t\n843\t// --- Round detail (FR-8) -----------------------------------------------------\n844\t//\n845\t// Browser-safe view models for `/games/[game]/rounds/[roundId]`. The detail\n846\t// joins the round summary (FlipYou/Pot Shot from `rounds`, Close Call from\n847\t// `closecall_rounds`) with all participating `game_entries` and the related\n848\t// `transactions` rows for the round (matched by `match_id` + `game`, where\n849\t// `match_id` is `closecall_rounds.round_id` for the Close Call branch).\n850\t//\n851\t// Entries and transactions carry the operator-readable identity context the\n852\t// detail page renders alongside each row (wallet always; user id + username\n853\t// when the player has a `player_profiles` row). Lamport amounts and slot\n854\t// values stay as `text` to preserve u64 precision.\n855\t\n856\texport type PeekRoundEntryRow = {\n857\t  id: string;\n858\t  userId: string;\n859\t  username: string | null;\n860\t  wallet: string;\n861\t  amountLamports: string;\n862\t  side: string | null;\n863\t  isWinner: boolean | null;\n864\t  payoutLamports: string;\n865\t  createdAt: string;\n866\t  settledAt: string | null;\n867\t};\n868\t\n869\texport type PeekRoundTransactionRow = {\n870\t  id: string;\n871\t  userId: string | null;\n872\t  username: string | null;\n873\t  wallet: string;\n874\t  txType: string;\n875\t  amountLamports: string;\n876\t  txSig: string;\n877\t  createdAt: string;\n878\t};\n879\t\n880\texport type PeekRoundDetail =\n881\t  | {\n882\t      game: PeekRoundsGameId;\n883\t      round: PeekRoundRow;\n884\t      entries: ReadonlyArray<PeekRoundEntryRow>;\n885\t      transactions: ReadonlyArray<PeekRoundTransactionRow>;\n886\t    }\n887\t  | {\n888\t      game: \"closecall\";\n889\t      round: PeekCloseCallRoundRow;\n890\t      entries: ReadonlyArray<PeekRoundEntryRow>;\n891\t      transactions: ReadonlyArray<PeekRoundTransactionRow>;\n892\t    };\n893\t"}]},"parent_tool_use_id":null,"session_id":"e7393274-dd95-4a47-827c-0160987ea587","uuid":"910ab514-9053-49d1-bf7a-40494676e189","timestamp":"2026-04-25T13:26:25.142Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/types/peek.ts","content":"export type PeekRoundRow = {\n  game: PeekRoundsGameId;\n  pda: string;\n  matchId: string;\n  phase: PeekRoundPhase;\n  creator: string;\n  targetSlot: string | null;\n  settleAttempts: number;\n  settleTx: string | null;\n  resultSide: number | null;\n  winner: string | null;\n  amountLamports: string;\n  createdAt: string;\n  updatedAt: string;\n  settledAt: string | null;\n};\n\nexport type PeekCloseCallPhase = \"open\" | \"settled\" | \"refunded\";\n\nexport const PEEK_CLOSECALL_PHASES: ReadonlyArray<PeekCloseCallPhase> = [\n  \"open\",\n  \"settled\",\n  \"refunded\",\n];\n\nexport type PeekCloseCallOutcome = \"pending\" | \"green\" | \"red\" | \"refund\";\n\nexport const PEEK_CLOSECALL_OUTCOMES: ReadonlyArray<PeekCloseCallOutcome> = [\n  \"pending\",\n  \"green\",\n  \"red\",\n  \"refund\",\n];\n\nexport type PeekCloseCallRoundRow = {\n  pda: string;\n  roundId: string;\n  phase: PeekCloseCallPhase;\n  outcome: PeekCloseCallOutcome;\n  openPrice: string;\n  openPriceExpo: number;\n  closePrice: string | null;\n  greenPoolLamports: string;\n  redPoolLamports: string;\n  totalFeeLamports: string;\n  settleTx: string | null;\n  createdAt: string;\n  settledAt: string | null;\n};\n\nexport type PeekRoundStuckFilters = {\n  nonterminalAged: boolean;\n  highAttempts: boolean;\n  settledWithoutTx: boolean;\n  refunds: boolean;\n};\n\nexport type PeekRoundFilters = {\n  phase: PeekRoundPhase | null;\n  search: string | null;\n  fromDate: string | null;\n  toDate: string | null;\n  stuck: PeekRoundStuckFilters;\n};\n\nexport type PeekCloseCallRoundStuckFilters = Omit<\n  PeekRoundStuckFilters,\n  \"highAttempts\"\n>;\n\nexport type PeekCloseCallRoundFilters = {\n  phase: PeekCloseCallPhase | null;\n  outcome: PeekCloseCallOutcome | null;\n  search: string | null;\n  fromDate: string | null;\n  toDate: string | null;\n  stuck: PeekCloseCallRoundStuckFilters;\n};\n\nexport type PeekRoundsListResult<TRow> = {\n  rows: ReadonlyArray<TRow>;\n  pagination: PeekPagination;\n};\n\n// --- Round detail (FR-8) -----------------------------------------------------\n//\n// Browser-safe view models for `/games/[game]/rounds/[roundId]`. The detail\n// joins the round summary (FlipYou/Pot Shot from `rounds`, Close Call from\n// `closecall_rounds`) with all participating `game_entries` and the related\n// `transactions` rows for the round (matched by `match_id` + `game`, where\n// `match_id` is `closecall_rounds.round_id` for the Close Call branch).\n//\n// Entries and transactions carry the operator-readable identity context the\n// detail page renders alongside each row (wallet always; user id + username\n// when the player has a `player_profiles` row). Lamport amounts and slot\n// values stay as `text` to preserve u64 precision.\n\nexport type PeekRoundEntryRow = {\n  id: string;\n  userId: string;\n  username: string | null;\n  wallet: string;\n  amountLamports: string;\n  side: string | null;\n  isWinner: boolean | null;\n  payoutLamports: string;\n  createdAt: string;\n  settledAt: string | null;\n};\n\nexport type PeekRoundTransactionRow = {\n  id: string;\n  userId: string | null;\n  username: string | null;\n  wallet: string;\n  txType: string;\n  amountLamports: string;\n  txSig: string;\n  createdAt: string;\n};\n\nexport type PeekRoundDetail =\n  | {\n      game: PeekRoundsGameId;\n      round: PeekRoundRow;\n      entries: ReadonlyArray<PeekRoundEntryRow>;\n      transactions: ReadonlyArray<PeekRoundTransactionRow>;\n    }\n  | {\n      game: \"closecall\";\n      round: PeekCloseCallRoundRow;\n      entries: ReadonlyArray<PeekRoundEntryRow>;\n      transactions: ReadonlyArray<PeekRoundTransactionRow>;\n    };\n","numLines":135,"startLine":759,"totalLines":893}}}
