{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015UP7ZgaRExfQVopySCKY8S","type":"tool_result","content":"1\t// URL-addressable filter params for /economy/points and /economy/crates (FR-9).\n2\t//\n3\t// Each form/page uses prefixed param names so two filter bars can co-exist on\n4\t// the points page (player_points + point_grants) without clashing. Empty /\n5\t// whitespace-only values normalise to `null` so the engine query skips them.\n6\t// Unknown enum values normalise to `null` (passing them through would still\n7\t// just return zero rows because the migration's CHECK constraints enforce the\n8\t// allowlist server-side, but normalising avoids leaking bogus filter chips\n9\t// into the table title).\n10\t\n11\timport type {\n12\t  PeekCrateDropFilters,\n13\t  PeekPlayerPointsFilters,\n14\t  PeekPointGrantFilters,\n15\t} from \"./types/peek\";\n16\t\n17\texport const PEEK_POINT_GRANT_SOURCE_TYPES: ReadonlyArray<string> = [\n18\t  \"wager\",\n19\t  \"challenge_completed\",\n20\t  \"bonus_completed\",\n21\t  \"crate_points\",\n22\t];\n23\t\n24\texport const PEEK_CRATE_DROP_TYPES: ReadonlyArray<string> = [\"points\", \"sol\"];\n25\t\n26\texport const PEEK_CRATE_DROP_STATUSES: ReadonlyArray<string> = [\n27\t  \"pending\",\n28\t  \"granted\",\n29\t  \"failed\",\n30\t];\n31\t\n32\texport const PEEK_CRATE_DROP_TRIGGER_TYPES: ReadonlyArray<string> = [\n33\t  \"game_settled\",\n34\t  \"challenge_completed\",\n35\t  \"bonus_completed\",\n36\t];\n37\t\n38\tfunction readSingleValue(value: string | string[] | undefined): string {\n39\t  return Array.isArray(value) ? value[0] ?? \"\" : value ?? \"\";\n40\t}\n41\t\n42\tfunction trimOrNull(value: string): string | null {\n43\t  const trimmed = value.trim();\n44\t  return trimmed.length > 0 ? trimmed : null;\n45\t}\n46\t\n47\tfunction allowlistOrNull(\n48\t  value: string | null,\n49\t  allowed: ReadonlyArray<string>,\n50\t): string | null {\n51\t  if (!value) return null;\n52\t  return allowed.includes(value) ? value : null;\n53\t}\n54\t\n55\texport function normalizePlayerPointsFiltersFromSearchParams(\n56\t  input: Record<string, string | string[] | undefined>,\n57\t): PeekPlayerPointsFilters {\n58\t  return {\n59\t    userId: trimOrNull(readSingleValue(input.pointsUserId)),\n60\t    wallet: trimOrNull(readSingleValue(input.pointsWallet)),\n61\t  };\n62\t}\n63\t\n64\texport function normalizePointGrantFiltersFromSearchParams(\n65\t  input: Record<string, string | string[] | undefined>,\n66\t): PeekPointGrantFilters {\n67\t  const sourceType = trimOrNull(readSingleValue(input.grantSourceType));\n68\t  return {\n69\t    userId: trimOrNull(readSingleValue(input.grantUserId)),\n70\t    sourceType: allowlistOrNull(sourceType, PEEK_POINT_GRANT_SOURCE_TYPES),\n71\t    sourceId: trimOrNull(readSingleValue(input.grantSourceId)),\n72\t    createdFrom: trimOrNull(readSingleValue(input.grantFrom)),\n73\t    createdTo: trimOrNull(readSingleValue(input.grantTo)),\n74\t  };\n75\t}\n76\t\n77\texport function normalizeCrateDropFiltersFromSearchParams(\n78\t  input: Record<string, string | string[] | undefined>,\n79\t): PeekCrateDropFilters {\n80\t  const crateType = trimOrNull(readSingleValue(input.crateType));\n81\t  const status = trimOrNull(readSingleValue(input.crateStatus));\n82\t  const triggerType = trimOrNull(readSingleValue(input.crateTriggerType));\n83\t  return {\n84\t    userId: trimOrNull(readSingleValue(input.crateUserId)),\n85\t    crateType: allowlistOrNull(crateType, PEEK_CRATE_DROP_TYPES),\n86\t    status: allowlistOrNull(status, PEEK_CRATE_DROP_STATUSES),\n87\t    triggerType: allowlistOrNull(triggerType, PEEK_CRATE_DROP_TRIGGER_TYPES),\n88\t    createdFrom: trimOrNull(readSingleValue(input.crateFrom)),\n89\t    createdTo: trimOrNull(readSingleValue(input.crateTo)),\n90\t  };\n91\t}\n92\t"}]},"parent_tool_use_id":null,"session_id":"72282212-796d-49bb-9582-6d039a64f3f9","uuid":"d27a3483-bbb5-4106-bec7-5421927fe534","timestamp":"2026-04-26T05:46:23.798Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/lib/economy-search-params.ts","content":"// URL-addressable filter params for /economy/points and /economy/crates (FR-9).\n//\n// Each form/page uses prefixed param names so two filter bars can co-exist on\n// the points page (player_points + point_grants) without clashing. Empty /\n// whitespace-only values normalise to `null` so the engine query skips them.\n// Unknown enum values normalise to `null` (passing them through would still\n// just return zero rows because the migration's CHECK constraints enforce the\n// allowlist server-side, but normalising avoids leaking bogus filter chips\n// into the table title).\n\nimport type {\n  PeekCrateDropFilters,\n  PeekPlayerPointsFilters,\n  PeekPointGrantFilters,\n} from \"./types/peek\";\n\nexport const PEEK_POINT_GRANT_SOURCE_TYPES: ReadonlyArray<string> = [\n  \"wager\",\n  \"challenge_completed\",\n  \"bonus_completed\",\n  \"crate_points\",\n];\n\nexport const PEEK_CRATE_DROP_TYPES: ReadonlyArray<string> = [\"points\", \"sol\"];\n\nexport const PEEK_CRATE_DROP_STATUSES: ReadonlyArray<string> = [\n  \"pending\",\n  \"granted\",\n  \"failed\",\n];\n\nexport const PEEK_CRATE_DROP_TRIGGER_TYPES: ReadonlyArray<string> = [\n  \"game_settled\",\n  \"challenge_completed\",\n  \"bonus_completed\",\n];\n\nfunction readSingleValue(value: string | string[] | undefined): string {\n  return Array.isArray(value) ? value[0] ?? \"\" : value ?? \"\";\n}\n\nfunction trimOrNull(value: string): string | null {\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nfunction allowlistOrNull(\n  value: string | null,\n  allowed: ReadonlyArray<string>,\n): string | null {\n  if (!value) return null;\n  return allowed.includes(value) ? value : null;\n}\n\nexport function normalizePlayerPointsFiltersFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): PeekPlayerPointsFilters {\n  return {\n    userId: trimOrNull(readSingleValue(input.pointsUserId)),\n    wallet: trimOrNull(readSingleValue(input.pointsWallet)),\n  };\n}\n\nexport function normalizePointGrantFiltersFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): PeekPointGrantFilters {\n  const sourceType = trimOrNull(readSingleValue(input.grantSourceType));\n  return {\n    userId: trimOrNull(readSingleValue(input.grantUserId)),\n    sourceType: allowlistOrNull(sourceType, PEEK_POINT_GRANT_SOURCE_TYPES),\n    sourceId: trimOrNull(readSingleValue(input.grantSourceId)),\n    createdFrom: trimOrNull(readSingleValue(input.grantFrom)),\n    createdTo: trimOrNull(readSingleValue(input.grantTo)),\n  };\n}\n\nexport function normalizeCrateDropFiltersFromSearchParams(\n  input: Record<string, string | string[] | undefined>,\n): PeekCrateDropFilters {\n  const crateType = trimOrNull(readSingleValue(input.crateType));\n  const status = trimOrNull(readSingleValue(input.crateStatus));\n  const triggerType = trimOrNull(readSingleValue(input.crateTriggerType));\n  return {\n    userId: trimOrNull(readSingleValue(input.crateUserId)),\n    crateType: allowlistOrNull(crateType, PEEK_CRATE_DROP_TYPES),\n    status: allowlistOrNull(status, PEEK_CRATE_DROP_STATUSES),\n    triggerType: allowlistOrNull(triggerType, PEEK_CRATE_DROP_TRIGGER_TYPES),\n    createdFrom: trimOrNull(readSingleValue(input.crateFrom)),\n    createdTo: trimOrNull(readSingleValue(input.crateTo)),\n  };\n}\n","numLines":92,"startLine":1,"totalLines":92}}}
