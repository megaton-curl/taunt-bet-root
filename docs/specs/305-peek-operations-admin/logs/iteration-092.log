ilters = normalizeCrateDropFiltersFromSearchParams(params);\n\n  let rows: ReadonlyArray<PeekCrateDropLedgerRow> = [];\n  let error: string | null = null;\n\n  try {\n    rows = await listCrateDrops({ filters });\n  } catch (caught) {\n    error =\n      caught instanceof Error\n        ? caught.message\n        : \"Crate drops could not be loaded.\";\n  }\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <h1>Economy · Crates</h1>\n        <p style={leadStyle}>\n          Crate drop ledger across all users. Pending SOL crates flag the\n          off-chain payout queue; pending points crates are still pending\n          ledger updates.\n        </p>\n      </header>\n\n      <section\n        aria-labelledby=\"crate-drops-heading\"\n        id=\"crate-drops\"\n        style={sectionStyle}\n      >\n        <h2 id=\"crate-drops-heading\" style={sectionHeadingStyle}>\n          Crate drops\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_CRATE_DROPS_DEFAULT_LIMIT} rows · sorted newest first ·\n          server-side capped. Filter by user, crate type, status, trigger\n          type, and a [from, to) date window.\n        </p>\n        <EconomyCratesFilterBar filters={filters} action={ROUTE} />\n        <CrateDropsTable rows={rows} error={error} />\n      </section>\n    </main>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":895,"cache_read_input_tokens":108906,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":895},"output_tokens":57,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"72282212-796d-49bb-9582-6d039a64f3f9","uuid":"7c78a9d4-ab73-4e54-953b-36a3411ae223"}
