{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015WqdQPL8LhqX3GckK39B8q","type":"tool_result","content":"1\t// /economy/points — points economy admin page (FR-9).\n2\t//\n3\t// Reads two migration-011 tables via `get-points-and-crates.ts`:\n4\t//   - player_points  — top point holders (filterable by user/wallet)\n5\t//   - point_grants   — append-only grant ledger (filterable by user, source\n6\t//                      type, source id, and a [from, to) date window)\n7\t//\n8\t// Both filter bars submit to this same route so URL-addressable filters\n9\t// (FR-4) survive page reloads and can be shared inside the team.\n10\timport type { CSSProperties } from \"react\";\n11\timport {\n12\t  PlayerPointsFilterBar,\n13\t  PointGrantsFilterBar,\n14\t} from \"../../../src/components/economy-points-filter-bar\";\n15\timport { PlayerPointsTable } from \"../../../src/components/player-points-table\";\n16\timport { PointGrantsTable } from \"../../../src/components/point-grants-table\";\n17\timport {\n18\t  normalizePlayerPointsFiltersFromSearchParams,\n19\t  normalizePointGrantFiltersFromSearchParams,\n20\t} from \"../../../src/lib/economy-search-params\";\n21\timport type {\n22\t  PeekPlayerPointsRow,\n23\t  PeekPointGrantLedgerRow,\n24\t} from \"../../../src/lib/types/peek\";\n25\timport {\n26\t  getPeekActorContext,\n27\t  isRouteAllowedForRole,\n28\t} from \"../../../src/server/access-policy\";\n29\timport {\n30\t  PEEK_PLAYER_POINTS_DEFAULT_LIMIT,\n31\t  PEEK_POINT_GRANTS_DEFAULT_LIMIT,\n32\t  listPlayerPoints,\n33\t  listPointGrants,\n34\t} from \"../../../src/server/db/queries/get-points-and-crates\";\n35\t\n36\texport const dynamic = \"force-dynamic\";\n37\t\n38\tconst ROUTE = \"/economy/points\";\n39\t\n40\texport default async function EconomyPointsPage({\n41\t  searchParams,\n42\t}: {\n43\t  searchParams: Promise<Record<string, string | string[] | undefined>>;\n44\t}) {\n45\t  const actor = await getPeekActorContext();\n46\t  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n47\t\n48\t  if (!allowed) {\n49\t    return (\n50\t      <main style={mainStyle}>\n51\t        <header>\n52\t          <h1>Economy · Points</h1>\n53\t        </header>\n54\t        <p role=\"alert\" style={errorStyle}>\n55\t          You do not have access to this page.\n56\t        </p>\n57\t      </main>\n58\t    );\n59\t  }\n60\t\n61\t  const params = await searchParams;\n62\t  const pointsFilters = normalizePlayerPointsFiltersFromSearchParams(params);\n63\t  const grantFilters = normalizePointGrantFiltersFromSearchParams(params);\n64\t\n65\t  let pointsRows: ReadonlyArray<PeekPlayerPointsRow> = [];\n66\t  let grantRows: ReadonlyArray<PeekPointGrantLedgerRow> = [];\n67\t  let pointsError: string | null = null;\n68\t  let grantsError: string | null = null;\n69\t\n70\t  try {\n71\t    pointsRows = await listPlayerPoints({ filters: pointsFilters });\n72\t  } catch (error) {\n73\t    pointsError =\n74\t      error instanceof Error\n75\t        ? error.message\n76\t        : \"Player points could not be loaded.\";\n77\t  }\n78\t\n79\t  try {\n80\t    grantRows = await listPointGrants({ filters: grantFilters });\n81\t  } catch (error) {\n82\t    grantsError =\n83\t      error instanceof Error\n84\t        ? error.message\n85\t        : \"Point grants could not be loaded.\";\n86\t  }\n87\t\n88\t  return (\n89\t    <main style={mainStyle}>\n90\t      <header>\n91\t        <h1>Economy · Points</h1>\n92\t        <p style={leadStyle}>\n93\t          Top point holders and the append-only grant ledger. Drill into a row\n94\t          to open the user-detail page for that player.\n95\t        </p>\n96\t      </header>\n97\t\n98\t      <section\n99\t        aria-labelledby=\"balances-heading\"\n100\t        id=\"balances\"\n101\t        style={sectionStyle}\n102\t      >\n103\t        <h2 id=\"balances-heading\" style={sectionHeadingStyle}>\n104\t          Player points\n105\t        </h2>\n106\t        <p style={hintStyle}>\n107\t          Default {PEEK_PLAYER_POINTS_DEFAULT_LIMIT} rows · sorted by balance\n108\t          desc · server-side capped. Bigint balances retain raw precision in\n109\t          the cell `title=` attribute.\n110\t        </p>\n111\t        <PlayerPointsFilterBar filters={pointsFilters} action={ROUTE} />\n112\t        <PlayerPointsTable rows={pointsRows} error={pointsError} />\n113\t      </section>\n114\t\n115\t      <section\n116\t        aria-labelledby=\"grants-heading\"\n117\t        id=\"grants\"\n118\t        style={sectionStyle}\n119\t      >\n120\t        <h2 id=\"grants-heading\" style={sectionHeadingStyle}>\n121\t          Point grants ledger\n122\t        </h2>\n123\t        <p style={hintStyle}>\n124\t          Default {PEEK_POINT_GRANTS_DEFAULT_LIMIT} rows · sorted newest first\n125\t          · server-side capped. Filter by user, source type, source id, and a\n126\t          [from, to) date window.\n127\t        </p>\n128\t        <PointGrantsFilterBar filters={grantFilters} action={ROUTE} />\n129\t        <PointGrantsTable rows={grantRows} error={grantsError} />\n130\t      </section>\n131\t    </main>\n132\t  );\n133\t}\n134\t\n135\tconst mainStyle: CSSProperties = {\n136\t  display: \"grid\",\n137\t  gap: \"1.5rem\",\n138\t};\n139\t\n140\tconst sectionStyle: CSSProperties = {\n141\t  display: \"grid\",\n142\t  gap: \"0.75rem\",\n143\t};\n144\t\n145\tconst sectionHeadingStyle: CSSProperties = {\n146\t  margin: \"0 0 0.75rem\",\n147\t  fontSize: \"1rem\",\n148\t  fontWeight: 600,\n149\t  color: \"#cbd5f5\",\n150\t  textTransform: \"uppercase\",\n151\t  letterSpacing: \"0.05em\",\n152\t};\n153\t\n154\tconst leadStyle: CSSProperties = {\n155\t  margin: \"0.25rem 0 0\",\n156\t  color: \"#94a3b8\",\n157\t};\n158\t\n159\tconst hintStyle: CSSProperties = {\n160\t  margin: 0,\n161\t  color: \"#94a3b8\",\n162\t  fontSize: \"0.8125rem\",\n163\t};\n164\t\n165\tconst errorStyle: CSSProperties = {\n166\t  margin: 0,\n167\t  padding: \"0.75rem 1rem\",\n168\t  borderRadius: \"0.75rem\",\n169\t  background: \"#3f1d1d\",\n170\t  color: \"#fecaca\",\n171\t};\n172\t"}]},"parent_tool_use_id":null,"session_id":"72282212-796d-49bb-9582-6d039a64f3f9","uuid":"b27aa036-bddf-4136-a751-1180c695b355","timestamp":"2026-04-26T05:46:00.647Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/app/economy/points/page.tsx","content":"// /economy/points — points economy admin page (FR-9).\n//\n// Reads two migration-011 tables via `get-points-and-crates.ts`:\n//   - player_points  — top point holders (filterable by user/wallet)\n//   - point_grants   — append-only grant ledger (filterable by user, source\n//                      type, source id, and a [from, to) date window)\n//\n// Both filter bars submit to this same route so URL-addressable filters\n// (FR-4) survive page reloads and can be shared inside the team.\nimport type { CSSProperties } from \"react\";\nimport {\n  PlayerPointsFilterBar,\n  PointGrantsFilterBar,\n} from \"../../../src/components/economy-points-filter-bar\";\nimport { PlayerPointsTable } from \"../../../src/components/player-points-table\";\nimport { PointGrantsTable } from \"../../../src/components/point-grants-table\";\nimport {\n  normalizePlayerPointsFiltersFromSearchParams,\n  normalizePointGrantFiltersFromSearchParams,\n} from \"../../../src/lib/economy-search-params\";\nimport type {\n  PeekPlayerPointsRow,\n  PeekPointGrantLedgerRow,\n} from \"../../../src/lib/types/peek\";\nimport {\n  getPeekActorContext,\n  isRouteAllowedForRole,\n} from \"../../../src/server/access-policy\";\nimport {\n  PEEK_PLAYER_POINTS_DEFAULT_LIMIT,\n  PEEK_POINT_GRANTS_DEFAULT_LIMIT,\n  listPlayerPoints,\n  listPointGrants,\n} from \"../../../src/server/db/queries/get-points-and-crates\";\n\nexport const dynamic = \"force-dynamic\";\n\nconst ROUTE = \"/economy/points\";\n\nexport default async function EconomyPointsPage({\n  searchParams,\n}: {\n  searchParams: Promise<Record<string, string | string[] | undefined>>;\n}) {\n  const actor = await getPeekActorContext();\n  const allowed = isRouteAllowedForRole(ROUTE, actor?.role ?? null);\n\n  if (!allowed) {\n    return (\n      <main style={mainStyle}>\n        <header>\n          <h1>Economy · Points</h1>\n        </header>\n        <p role=\"alert\" style={errorStyle}>\n          You do not have access to this page.\n        </p>\n      </main>\n    );\n  }\n\n  const params = await searchParams;\n  const pointsFilters = normalizePlayerPointsFiltersFromSearchParams(params);\n  const grantFilters = normalizePointGrantFiltersFromSearchParams(params);\n\n  let pointsRows: ReadonlyArray<PeekPlayerPointsRow> = [];\n  let grantRows: ReadonlyArray<PeekPointGrantLedgerRow> = [];\n  let pointsError: string | null = null;\n  let grantsError: string | null = null;\n\n  try {\n    pointsRows = await listPlayerPoints({ filters: pointsFilters });\n  } catch (error) {\n    pointsError =\n      error instanceof Error\n        ? error.message\n        : \"Player points could not be loaded.\";\n  }\n\n  try {\n    grantRows = await listPointGrants({ filters: grantFilters });\n  } catch (error) {\n    grantsError =\n      error instanceof Error\n        ? error.message\n        : \"Point grants could not be loaded.\";\n  }\n\n  return (\n    <main style={mainStyle}>\n      <header>\n        <h1>Economy · Points</h1>\n        <p style={leadStyle}>\n          Top point holders and the append-only grant ledger. Drill into a row\n          to open the user-detail page for that player.\n        </p>\n      </header>\n\n      <section\n        aria-labelledby=\"balances-heading\"\n        id=\"balances\"\n        style={sectionStyle}\n      >\n        <h2 id=\"balances-heading\" style={sectionHeadingStyle}>\n          Player points\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_PLAYER_POINTS_DEFAULT_LIMIT} rows · sorted by balance\n          desc · server-side capped. Bigint balances retain raw precision in\n          the cell `title=` attribute.\n        </p>\n        <PlayerPointsFilterBar filters={pointsFilters} action={ROUTE} />\n        <PlayerPointsTable rows={pointsRows} error={pointsError} />\n      </section>\n\n      <section\n        aria-labelledby=\"grants-heading\"\n        id=\"grants\"\n        style={sectionStyle}\n      >\n        <h2 id=\"grants-heading\" style={sectionHeadingStyle}>\n          Point grants ledger\n        </h2>\n        <p style={hintStyle}>\n          Default {PEEK_POINT_GRANTS_DEFAULT_LIMIT} rows · sorted newest first\n          · server-side capped. Filter by user, source type, source id, and a\n          [from, to) date window.\n        </p>\n        <PointGrantsFilterBar filters={grantFilters} action={ROUTE} />\n        <PointGrantsTable rows={grantRows} error={grantsError} />\n      </section>\n    </main>\n  );\n}\n\nconst mainStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"1.5rem\",\n};\n\nconst sectionStyle: CSSProperties = {\n  display: \"grid\",\n  gap: \"0.75rem\",\n};\n\nconst sectionHeadingStyle: CSSProperties = {\n  margin: \"0 0 0.75rem\",\n  fontSize: \"1rem\",\n  fontWeight: 600,\n  color: \"#cbd5f5\",\n  textTransform: \"uppercase\",\n  letterSpacing: \"0.05em\",\n};\n\nconst leadStyle: CSSProperties = {\n  margin: \"0.25rem 0 0\",\n  color: \"#94a3b8\",\n};\n\nconst hintStyle: CSSProperties = {\n  margin: 0,\n  color: \"#94a3b8\",\n  fontSize: \"0.8125rem\",\n};\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n","numLines":172,"startLine":1,"totalLines":172}}}
