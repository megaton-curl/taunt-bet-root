{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018CtArUbmPWRScRt1TXZVLk","type":"tool_result","content":"1\t// Cross-user crate_drops table for /economy/crates (FR-9).\n2\t//\n3\t// Surfaces the pending-payout state called out in FR-9: SOL crate drops sitting\n4\t// in 'pending' status are payout obligations the off-chain crate worker has not\n5\t// yet delivered, so the row gets a \"negative\" status chip + a \"Payout pending\"\n6\t// hint cell to make the operator queue obvious. Points crates also use the\n7\t// pending state but the operational urgency is lower (they are off-chain\n8\t// ledger updates, not on-chain transfers), so they keep an \"info\" tone.\n9\timport Link from \"next/link\";\n10\timport type { CSSProperties } from \"react\";\n11\timport type {\n12\t  PeekCrateDropLedgerRow,\n13\t  PeekStatusTone,\n14\t} from \"../lib/types/peek\";\n15\timport { StatusChip } from \"./status-chip\";\n16\t\n17\texport type CrateDropsTableProps = {\n18\t  rows: ReadonlyArray<PeekCrateDropLedgerRow>;\n19\t  error?: string | null;\n20\t};\n21\t\n22\texport function CrateDropsTable({\n23\t  rows,\n24\t  error = null,\n25\t}: CrateDropsTableProps) {\n26\t  if (error) {\n27\t    return (\n28\t      <div role=\"alert\" style={errorStyle}>\n29\t        Crate drops unavailable: {error}\n30\t      </div>\n31\t    );\n32\t  }\n33\t\n34\t  if (rows.length === 0) {\n35\t    return (\n36\t      <div role=\"status\" style={emptyStyle}>\n37\t        <p style={emptyTitleStyle}>No crate_drops rows match these filters.</p>\n38\t        <p style={emptyBodyStyle}>\n39\t          Adjust the filters above or clear them to see recent crate drops.\n40\t        </p>\n41\t      </div>\n42\t    );\n43\t  }\n44\t\n45\t  return (\n46\t    <div style={wrapperStyle}>\n47\t      <table style={tableStyle}>\n48\t        <thead>\n49\t          <tr style={headerRowStyle}>\n50\t            <th style={headerCellStyle(\"left\")}>Created</th>\n51\t            <th style={headerCellStyle(\"left\")}>User</th>\n52\t            <th style={headerCellStyle(\"left\")}>Wallet</th>\n53\t            <th style={headerCellStyle(\"left\")}>Crate type</th>\n54\t            <th style={headerCellStyle(\"left\")}>Trigger</th>\n55\t            <th style={headerCellStyle(\"left\")}>Trigger id</th>\n56\t            <th style={headerCellStyle(\"right\")}>Amount</th>\n57\t            <th style={headerCellStyle(\"left\")}>Status</th>\n58\t            <th style={headerCellStyle(\"left\")}>Granted</th>\n59\t          </tr>\n60\t        </thead>\n61\t        <tbody>\n62\t          {rows.map((row) => {\n63\t            const pendingSol =\n64\t              row.status === \"pending\" && row.crateType === \"sol\";\n65\t            return (\n66\t              <tr\n67\t                key={row.id}\n68\t                style={pendingSol ? pendingSolRowStyle : bodyRowStyle}\n69\t              >\n70\t                <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n71\t                <td style={bodyCellStyle(\"left\")}>\n72\t                  <Link href={`/users/${row.userId}`} style={linkStyle}>\n73\t                    {row.username ?? row.userId}\n74\t                  </Link>\n75\t                  {row.username ? (\n76\t                    <span style={subValueStyle}> · {row.userId}</span>\n77\t                  ) : null}\n78\t                </td>\n79\t                <td\n80\t                  style={{\n81\t                    ...bodyCellStyle(\"left\"),\n82\t                    fontFamily: \"monospace\",\n83\t                  }}\n84\t                >\n85\t                  {row.wallet ?? \"—\"}\n86\t                </td>\n87\t                <td style={bodyCellStyle(\"left\")}>\n88\t                  <StatusChip\n89\t                    label={row.crateType}\n90\t                    tone={crateTypeTone(row.crateType)}\n91\t                  />\n92\t                </td>\n93\t                <td style={bodyCellStyle(\"left\")}>{row.triggerType}</td>\n94\t                <td\n95\t                  style={{\n96\t                    ...bodyCellStyle(\"left\"),\n97\t                    fontFamily: \"monospace\",\n98\t                  }}\n99\t                >\n100\t                  {row.triggerId}\n101\t                </td>\n102\t                <td\n103\t                  style={{\n104\t                    ...bodyCellStyle(\"right\"),\n105\t                    fontFamily: \"monospace\",\n106\t                  }}\n107\t                  title={row.contentsAmount}\n108\t                >\n109\t                  {formatCount(row.contentsAmount)}\n110\t                </td>\n111\t                <td style={bodyCellStyle(\"left\")}>\n112\t                  <StatusChip\n113\t                    label={\n114\t                      pendingSol ? \"pending · payout\" : row.status\n115\t                    }\n116\t                    tone={statusTone(row.status, row.crateType)}\n117\t                    title={\n118\t                      pendingSol\n119\t                        ? \"SOL crate payout has not been delivered on-chain.\"\n120\t                        : undefined\n121\t                    }\n122\t                  />\n123\t                </td>\n124\t                <td style={bodyCellStyle(\"left\")}>{row.grantedAt ?? \"—\"}</td>\n125\t              </tr>\n126\t            );\n127\t          })}\n128\t        </tbody>\n129\t      </table>\n130\t    </div>\n131\t  );\n132\t}\n133\t\n134\tfunction crateTypeTone(value: string): PeekStatusTone {\n135\t  if (value === \"sol\") return \"warning\";\n136\t  if (value === \"points\") return \"info\";\n137\t  return \"neutral\";\n138\t}\n139\t\n140\tfunction statusTone(status: string, crateType: string): PeekStatusTone {\n141\t  if (status === \"granted\") return \"positive\";\n142\t  if (status === \"failed\") return \"negative\";\n143\t  if (status === \"pending\") {\n144\t    return crateType === \"sol\" ? \"negative\" : \"info\";\n145\t  }\n146\t  return \"neutral\";\n147\t}\n148\t\n149\tfunction formatCount(value: string): string {\n150\t  if (!value || value === \"0\") return \"0\";\n151\t  const negative = value.startsWith(\"-\");\n152\t  const digits = negative ? value.slice(1) : value;\n153\t  if (!/^[0-9]+$/.test(digits)) return value;\n154\t  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n155\t  return negative ? `-${grouped}` : grouped;\n156\t}\n157\t\n158\tconst wrapperStyle: CSSProperties = {\n159\t  overflowX: \"auto\",\n160\t  border: \"1px solid #1e293b\",\n161\t  borderRadius: \"0.75rem\",\n162\t};\n163\t\n164\tconst tableStyle: CSSProperties = {\n165\t  width: \"100%\",\n166\t  borderCollapse: \"collapse\",\n167\t};\n168\t\n169\tconst headerRowStyle: CSSProperties = {\n170\t  background: \"#111827\",\n171\t  color: \"#94a3b8\",\n172\t};\n173\t\n174\tconst bodyRowStyle: CSSProperties = {\n175\t  borderTop: \"1px solid #1e293b\",\n176\t};\n177\t\n178\tconst pendingSolRowStyle: CSSProperties = {\n179\t  borderTop: \"1px solid #1e293b\",\n180\t  background: \"#1f1212\",\n181\t};\n182\t\n183\tconst linkStyle: CSSProperties = {\n184\t  color: \"#93c5fd\",\n185\t  textDecoration: \"none\",\n186\t};\n187\t\n188\tconst subValueStyle: CSSProperties = {\n189\t  color: \"#64748b\",\n190\t  fontSize: \"0.75rem\",\n191\t  marginLeft: \"0.25rem\",\n192\t};\n193\t\n194\tfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n195\t  return {\n196\t    padding: \"0.75rem\",\n197\t    textAlign: align,\n198\t    fontSize: \"0.875rem\",\n199\t    fontWeight: 600,\n200\t  };\n201\t}\n202\t\n203\tfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n204\t  return {\n205\t    padding: \"0.75rem\",\n206\t    textAlign: align,\n207\t    fontSize: \"0.875rem\",\n208\t    color: \"#e2e8f0\",\n209\t    verticalAlign: \"top\",\n210\t  };\n211\t}\n212\t\n213\tconst errorStyle: CSSProperties = {\n214\t  margin: 0,\n215\t  padding: \"0.75rem 1rem\",\n216\t  borderRadius: \"0.75rem\",\n217\t  background: \"#3f1d1d\",\n218\t  color: \"#fecaca\",\n219\t};\n220\t\n221\tconst emptyStyle: CSSProperties = {\n222\t  padding: \"1.5rem\",\n223\t  borderRadius: \"0.75rem\",\n224\t  border: \"1px dashed #334155\",\n225\t  background: \"#0b1220\",\n226\t  color: \"#cbd5f5\",\n227\t  display: \"grid\",\n228\t  gap: \"0.5rem\",\n229\t};\n230\t\n231\tconst emptyTitleStyle: CSSProperties = {\n232\t  margin: 0,\n233\t  fontSize: \"1rem\",\n234\t  fontWeight: 600,\n235\t};\n236\t\n237\tconst emptyBodyStyle: CSSProperties = {\n238\t  margin: 0,\n239\t  fontSize: \"0.875rem\",\n240\t  color: \"#94a3b8\",\n241\t};\n242\t"}]},"parent_tool_use_id":null,"session_id":"72282212-796d-49bb-9582-6d039a64f3f9","uuid":"46b5add4-dba6-4443-9a34-41c340788422","timestamp":"2026-04-26T05:46:21.177Z","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/rng-utopia/peek/src/components/crate-drops-table.tsx","content":"// Cross-user crate_drops table for /economy/crates (FR-9).\n//\n// Surfaces the pending-payout state called out in FR-9: SOL crate drops sitting\n// in 'pending' status are payout obligations the off-chain crate worker has not\n// yet delivered, so the row gets a \"negative\" status chip + a \"Payout pending\"\n// hint cell to make the operator queue obvious. Points crates also use the\n// pending state but the operational urgency is lower (they are off-chain\n// ledger updates, not on-chain transfers), so they keep an \"info\" tone.\nimport Link from \"next/link\";\nimport type { CSSProperties } from \"react\";\nimport type {\n  PeekCrateDropLedgerRow,\n  PeekStatusTone,\n} from \"../lib/types/peek\";\nimport { StatusChip } from \"./status-chip\";\n\nexport type CrateDropsTableProps = {\n  rows: ReadonlyArray<PeekCrateDropLedgerRow>;\n  error?: string | null;\n};\n\nexport function CrateDropsTable({\n  rows,\n  error = null,\n}: CrateDropsTableProps) {\n  if (error) {\n    return (\n      <div role=\"alert\" style={errorStyle}>\n        Crate drops unavailable: {error}\n      </div>\n    );\n  }\n\n  if (rows.length === 0) {\n    return (\n      <div role=\"status\" style={emptyStyle}>\n        <p style={emptyTitleStyle}>No crate_drops rows match these filters.</p>\n        <p style={emptyBodyStyle}>\n          Adjust the filters above or clear them to see recent crate drops.\n        </p>\n      </div>\n    );\n  }\n\n  return (\n    <div style={wrapperStyle}>\n      <table style={tableStyle}>\n        <thead>\n          <tr style={headerRowStyle}>\n            <th style={headerCellStyle(\"left\")}>Created</th>\n            <th style={headerCellStyle(\"left\")}>User</th>\n            <th style={headerCellStyle(\"left\")}>Wallet</th>\n            <th style={headerCellStyle(\"left\")}>Crate type</th>\n            <th style={headerCellStyle(\"left\")}>Trigger</th>\n            <th style={headerCellStyle(\"left\")}>Trigger id</th>\n            <th style={headerCellStyle(\"right\")}>Amount</th>\n            <th style={headerCellStyle(\"left\")}>Status</th>\n            <th style={headerCellStyle(\"left\")}>Granted</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map((row) => {\n            const pendingSol =\n              row.status === \"pending\" && row.crateType === \"sol\";\n            return (\n              <tr\n                key={row.id}\n                style={pendingSol ? pendingSolRowStyle : bodyRowStyle}\n              >\n                <td style={bodyCellStyle(\"left\")}>{row.createdAt}</td>\n                <td style={bodyCellStyle(\"left\")}>\n                  <Link href={`/users/${row.userId}`} style={linkStyle}>\n                    {row.username ?? row.userId}\n                  </Link>\n                  {row.username ? (\n                    <span style={subValueStyle}> · {row.userId}</span>\n                  ) : null}\n                </td>\n                <td\n                  style={{\n                    ...bodyCellStyle(\"left\"),\n                    fontFamily: \"monospace\",\n                  }}\n                >\n                  {row.wallet ?? \"—\"}\n                </td>\n                <td style={bodyCellStyle(\"left\")}>\n                  <StatusChip\n                    label={row.crateType}\n                    tone={crateTypeTone(row.crateType)}\n                  />\n                </td>\n                <td style={bodyCellStyle(\"left\")}>{row.triggerType}</td>\n                <td\n                  style={{\n                    ...bodyCellStyle(\"left\"),\n                    fontFamily: \"monospace\",\n                  }}\n                >\n                  {row.triggerId}\n                </td>\n                <td\n                  style={{\n                    ...bodyCellStyle(\"right\"),\n                    fontFamily: \"monospace\",\n                  }}\n                  title={row.contentsAmount}\n                >\n                  {formatCount(row.contentsAmount)}\n                </td>\n                <td style={bodyCellStyle(\"left\")}>\n                  <StatusChip\n                    label={\n                      pendingSol ? \"pending · payout\" : row.status\n                    }\n                    tone={statusTone(row.status, row.crateType)}\n                    title={\n                      pendingSol\n                        ? \"SOL crate payout has not been delivered on-chain.\"\n                        : undefined\n                    }\n                  />\n                </td>\n                <td style={bodyCellStyle(\"left\")}>{row.grantedAt ?? \"—\"}</td>\n              </tr>\n            );\n          })}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n\nfunction crateTypeTone(value: string): PeekStatusTone {\n  if (value === \"sol\") return \"warning\";\n  if (value === \"points\") return \"info\";\n  return \"neutral\";\n}\n\nfunction statusTone(status: string, crateType: string): PeekStatusTone {\n  if (status === \"granted\") return \"positive\";\n  if (status === \"failed\") return \"negative\";\n  if (status === \"pending\") {\n    return crateType === \"sol\" ? \"negative\" : \"info\";\n  }\n  return \"neutral\";\n}\n\nfunction formatCount(value: string): string {\n  if (!value || value === \"0\") return \"0\";\n  const negative = value.startsWith(\"-\");\n  const digits = negative ? value.slice(1) : value;\n  if (!/^[0-9]+$/.test(digits)) return value;\n  const grouped = digits.replace(/\\B(?=(\\d{3})+(?!\\d))/g, \",\");\n  return negative ? `-${grouped}` : grouped;\n}\n\nconst wrapperStyle: CSSProperties = {\n  overflowX: \"auto\",\n  border: \"1px solid #1e293b\",\n  borderRadius: \"0.75rem\",\n};\n\nconst tableStyle: CSSProperties = {\n  width: \"100%\",\n  borderCollapse: \"collapse\",\n};\n\nconst headerRowStyle: CSSProperties = {\n  background: \"#111827\",\n  color: \"#94a3b8\",\n};\n\nconst bodyRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n};\n\nconst pendingSolRowStyle: CSSProperties = {\n  borderTop: \"1px solid #1e293b\",\n  background: \"#1f1212\",\n};\n\nconst linkStyle: CSSProperties = {\n  color: \"#93c5fd\",\n  textDecoration: \"none\",\n};\n\nconst subValueStyle: CSSProperties = {\n  color: \"#64748b\",\n  fontSize: \"0.75rem\",\n  marginLeft: \"0.25rem\",\n};\n\nfunction headerCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    fontWeight: 600,\n  };\n}\n\nfunction bodyCellStyle(align: \"left\" | \"right\" | \"center\"): CSSProperties {\n  return {\n    padding: \"0.75rem\",\n    textAlign: align,\n    fontSize: \"0.875rem\",\n    color: \"#e2e8f0\",\n    verticalAlign: \"top\",\n  };\n}\n\nconst errorStyle: CSSProperties = {\n  margin: 0,\n  padding: \"0.75rem 1rem\",\n  borderRadius: \"0.75rem\",\n  background: \"#3f1d1d\",\n  color: \"#fecaca\",\n};\n\nconst emptyStyle: CSSProperties = {\n  padding: \"1.5rem\",\n  borderRadius: \"0.75rem\",\n  border: \"1px dashed #334155\",\n  background: \"#0b1220\",\n  color: \"#cbd5f5\",\n  display: \"grid\",\n  gap: \"0.5rem\",\n};\n\nconst emptyTitleStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"1rem\",\n  fontWeight: 600,\n};\n\nconst emptyBodyStyle: CSSProperties = {\n  margin: 0,\n  fontSize: \"0.875rem\",\n  color: \"#94a3b8\",\n};\n","numLines":242,"startLine":1,"totalLines":242}}}
