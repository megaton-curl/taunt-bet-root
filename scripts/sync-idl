#!/usr/bin/env bash
# Copies Anchor-generated IDL JSON + TypeScript type files into backend/packages/anchor-client/src/
# Run from the root repo: ./scripts/sync-idl

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
IDL_SRC="$ROOT/solana/target/idl"
TYPES_SRC="$ROOT/solana/target/types"
DEST="$ROOT/backend/packages/anchor-client/src"

if [ ! -d "$IDL_SRC" ]; then
  echo "Error: IDL directory not found at $IDL_SRC"
  echo "Run 'cd solana && anchor build' first."
  exit 1
fi

mkdir -p "$DEST"

# Copy IDL JSON files
for f in "$IDL_SRC"/*.json; do
  [ -f "$f" ] || continue
  cp "$f" "$DEST/"
  echo "Copied $(basename "$f")"
done

# Copy TypeScript type files
for f in "$TYPES_SRC"/*.ts; do
  [ -f "$f" ] || continue
  cp "$f" "$DEST/"
  echo "Copied $(basename "$f")"
done

echo "IDL sync complete."
